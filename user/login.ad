# user/login.ad
#
# Real `login`: prompt-and-exec loop. Prints "login: ", reads a
# username; prints "Password: " and reads the password with NO echo
# (raw byte reads — login is not a shell line-editor, so nothing
# echoes); authenticates via the kernel /dev/auth cdev. On success it
# drops into the authenticated identity (SYS_SETUID_AUTH on the verified
# fd), arranges for the login shell to source the per-user namespace
# recipe, chdir's to the home dir, and execs /bin/hamsh. On a wrong
# password it prints "Login incorrect" and loops back to the prompt.
#
# getty execs /bin/login (interactive) or `/bin/login -f <user>`
# (AUTOLOGIN) after wiring the VT fds. login is also usable directly
# from a shell (the test drives it that way).
#
# AUTOLOGIN (`login -f <user>`): used by the live/installer image so the
# VT consoles still reach a usable shell with no password typed. In this
# mode login SKIPS the password prompt and the /dev/auth round-trip and
# does NOT call setuid — it keeps whatever identity getty inherited
# (the live image's default regular user `live`, uid 1001). It STILL parses
# /etc/passwd, stamps HAMNIX_NEWSHELL_USER=<user> so the shell sources
# the per-user namespace recipe, chdir's home, and execs the login shell.
# This is the Linux `login -f` ("force, already-authenticated") idiom:
# the caller (getty/init) vouches for the identity instead of a password.
# A real multi-user deployment uses interactive getty->login (no -f).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_setuid_auth(authfd: int32) -> int32
extern def sys_chdir(path: Ptr[char]) -> int32
extern def sys_execve_env(path: Ptr[char], argv: Ptr[uint64],
                          envp: Ptr[uint64]) -> int32

from lib.passwd.passwd import (
    passwd_parse, passwd_lookup_by_name, passwd_entry_home,
)


pw_buf:    Array[4096, uint8]
user_buf:  Array[64, uint8]
pass_buf:  Array[128, uint8]
authresp:  Array[64, uint8]
home_buf:  Array[128, uint8]
# Env string "HAMNIX_NEWSHELL_USER=<name>" handed to the exec'd hamsh so
# it sources /etc/users/<name>.ns (or default.ns) before the prompt.
env_str:   Array[128, uint8]

USER_MAX: uint64 = 64
PW_MAX:   uint64 = 128


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def copy_cstr(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def wipe(buf: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while i < cap:
        buf[i] = 0
        i = i + 1


def read_line_echo(buf: Ptr[uint8], cap: uint64) -> int64:
    # Read a username line from fd 0. Returns the length, or -1 on EOF
    # (so the loop can exit cleanly). Stops at '\n', drops '\r'.
    n: uint64 = 0
    got: int32 = 0
    while n + 1 < cap:
        c: Array[1, uint8]
        rr: int64 = sys_read(0, &c[0], 1)
        if rr <= 0:
            if got == 0:
                return cast[int64](-1)
            break
        got = 1
        if c[0] == 10:
            break
        if c[0] == 13:
            continue
        buf[n] = c[0]
        n = n + 1
    buf[n] = 0
    return cast[int64](n)


def read_password(buf: Ptr[uint8], cap: uint64) -> uint64:
    n: uint64 = 0
    while n + 1 < cap:
        c: Array[1, uint8]
        rr: int64 = sys_read(0, &c[0], 1)
        if rr <= 0:
            break
        if c[0] == 10:
            break
        if c[0] == 13:
            continue
        buf[n] = c[0]
        n = n + 1
    buf[n] = 0
    return n


def auth_write_line(fd: int32, prefix: Ptr[uint8], plen: uint64,
                    payload: Ptr[uint8], paylen: uint64) -> int64:
    line: Array[256, uint8]
    p: uint64 = 0
    while p < plen and p + 2 < 256:
        line[p] = prefix[p]
        p = p + 1
    j: uint64 = 0
    while j < paylen and p + 2 < 256:
        line[p] = payload[j]
        p = p + 1
        j = j + 1
    line[p] = 10
    p = p + 1
    return sys_write(fd, &line[0], p)


def build_env_str():
    # Compose "HAMNIX_NEWSHELL_USER=<user>" into env_str.
    pre: Ptr[uint8] = "HAMNIX_NEWSHELL_USER="
    p: uint64 = 0
    while pre[p] != 0 and p + 1 < 128:
        env_str[p] = pre[p]
        p = p + 1
    k: uint64 = 0
    while user_buf[k] != 0 and p + 1 < 128:
        env_str[p] = user_buf[k]
        p = p + 1
        k = k + 1
    env_str[p] = 0


def login_and_exec() -> int32:
    # Resolve the home from the parsed /etc/passwd, chdir, set the env so
    # hamsh sources the per-user recipe, then exec the login shell.
    idx: int32 = passwd_lookup_by_name(&user_buf[0])
    if idx >= 0:
        copy_cstr(&home_buf[0], passwd_entry_home(idx), 128)
        sys_chdir(cast[Ptr[char]](&home_buf[0]))
    build_env_str()
    argbuf: Array[2, uint64]
    argbuf[0] = cast[uint64]("/bin/hamsh")
    argbuf[1] = 0
    envbuf: Array[2, uint64]
    envbuf[0] = cast[uint64](&env_str[0])
    envbuf[1] = 0
    sys_execve_env("/bin/hamsh", &argbuf[0], &envbuf[0])
    write_str(2, "login: exec /bin/hamsh failed\n")
    return 1


def streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


def autologin(name: Ptr[uint8]) -> int32:
    # AUTOLOGIN path (`login -f <user>`). The caller (getty/init) has
    # already vouched for the identity, so we DON'T prompt for a password
    # and DON'T call setuid — we keep the identity getty inherited (the
    # live image's default regular user `live`). We still parse /etc/passwd, stamp
    # HAMNIX_NEWSHELL_USER so the shell sources the per-user namespace
    # recipe, chdir home, and exec the login shell — i.e. the SAME
    # session setup as the interactive path, just without the auth gate.
    copy_cstr(&user_buf[0], name, USER_MAX)
    if user_buf[0] == 0:
        write_str(2, "login: -f requires a username\n")
        return 1
    pfd: int32 = sys_open("/etc/passwd")
    total: uint64 = 0
    if pfd >= 0:
        while total < 4096:
            n: int64 = sys_read(pfd, &pw_buf[total], 4096 - total)
            if n <= 0:
                break
            total = total + cast[uint64](n)
        sys_close(pfd)
    passwd_parse(&pw_buf[0], total)
    return login_and_exec()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # `login -f <user>` -> autologin (no password). Anything else ->
    # the interactive prompt loop.
    if argc >= 3:
        flag: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if streq(flag, "-f") == 1:
            return autologin(cast[Ptr[uint8]](argv[2]))
    while True:
        write_str(1, "login: ")
        ul: int64 = read_line_echo(&user_buf[0], USER_MAX)
        if ul < 0:
            # EOF on stdin — give up.
            return 0
        if ul == 0:
            # Blank username — reprompt.
            continue

        write_str(1, "Password: ")
        plen: uint64 = read_password(&pass_buf[0], PW_MAX)
        write_str(1, "\n")

        # Authenticate via /dev/auth.
        afd: int32 = sys_open("/dev/auth")
        if afd < 0:
            write_str(2, "login: cannot open /dev/auth\n")
            wipe(&pass_buf[0], PW_MAX)
            return 1
        user_prefix: Ptr[uint8] = "user "
        pass_prefix: Ptr[uint8] = "pass "
        auth_write_line(afd, user_prefix, 5, &user_buf[0],
                        strlen_u8(&user_buf[0]))
        auth_write_line(afd, pass_prefix, 5, &pass_buf[0], plen)
        rn: int64 = sys_read(afd, &authresp[0], 64)
        wipe(&pass_buf[0], PW_MAX)

        if rn < 2 or authresp[0] != 111 or authresp[1] != 107:   # not "ok"
            sys_close(afd)
            write_str(1, "Login incorrect\n")
            continue

        # Authenticated. Read /etc/passwd for the home lookup, drop into
        # the identity via the verified fd, then exec the login shell.
        pfd: int32 = sys_open("/etc/passwd")
        total: uint64 = 0
        if pfd >= 0:
            while total < 4096:
                n: int64 = sys_read(pfd, &pw_buf[total], 4096 - total)
                if n <= 0:
                    break
                total = total + cast[uint64](n)
            sys_close(pfd)
        passwd_parse(&pw_buf[0], total)

        su_rc: int32 = sys_setuid_auth(afd)
        sys_close(afd)
        if su_rc < 0:
            write_str(2, "login: identity change failed\n")
            return 1
        return login_and_exec()
    return 0

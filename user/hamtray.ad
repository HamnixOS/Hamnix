# user/hamtray.ad
#
# hamtray — DE pivot wave 7: message-tray history panel extracted from
# daemon_pixel into a v2 client. Header + N row placeholders.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2, hamui_set_protocol_v2_dims,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


_ht_open:  int32 = 0
_ht_count: int32 = 0
_ht_x:     int32 = 0
_ht_y:     int32 = 0
_ht_w:     int32 = 0
_ht_h:     int32 = 0
_ht_gen:   uint64 = 0
_ht_show_serial:      uint64 = 0
_ht_last_show_serial: uint64 = 0xffffffffffffffff
_ht_last_gen:         uint64 = 0xffffffffffffffff


_ht_WIN_W: int32 = 800
_ht_WIN_H: int32 = 600
_ht_ROW_H: int32 = 28


_ht_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _read_snap() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/tray"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_ht_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _ht_snap_buf[p] >= 48 and _ht_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_ht_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _parse_i64(pos: Ptr[uint64], end: uint64) -> int64:
    p: uint64 = pos[0]
    neg: int32 = 0
    if p < end and _ht_snap_buf[p] == 45:
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end and _ht_snap_buf[p] >= 48 and _ht_snap_buf[p] <= 57:
        v = v * 10 + cast[int64](_ht_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    if neg != 0:
        return -v
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_ht_snap_buf[p] == 32 or _ht_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    o_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    c_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    x_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    y_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    w_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    h_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _ht_show_serial = show_v
    _ht_open = cast[int32](o_v)
    _ht_count = cast[int32](c_v)
    _ht_x = cast[int32](x_v)
    _ht_y = cast[int32](y_v)
    _ht_w = cast[int32](w_v)
    _ht_h = cast[int32](h_v)
    _ht_gen = gen_v
    changed: int32 = 0
    if _ht_show_serial != _ht_last_show_serial:
        changed = 1
    if _ht_gen != _ht_last_gen:
        changed = 1
    _ht_last_show_serial = _ht_show_serial
    _ht_last_gen = _ht_gen
    return changed


def _paint():
    hamui_v2_clear_transparent()
    if _ht_open == 0 or _ht_w <= 0 or _ht_h <= 0:
        hamui_v2_commit_rect(0, 0, _ht_WIN_W, _ht_WIN_H)
        return
    tx: int32 = _ht_x
    ty: int32 = _ht_y
    tw: int32 = _ht_w
    th: int32 = _ht_h
    if tx < 0:
        tx = 0
    if ty < 0:
        ty = 0
    if tx + tw > _ht_WIN_W:
        tw = _ht_WIN_W - tx
    if ty + th > _ht_WIN_H:
        th = _ht_WIN_H - ty
    # Body.
    hamui_v2_fill_rect(tx, ty, tw, th, 40, 46, 60)
    # Frame.
    hamui_v2_fill_rect(tx, ty, tw, 1, 24, 28, 36)
    hamui_v2_fill_rect(tx, ty + th - 1, tw, 1, 24, 28, 36)
    hamui_v2_fill_rect(tx, ty, 1, th, 24, 28, 36)
    hamui_v2_fill_rect(tx + tw - 1, ty, 1, th, 24, 28, 36)
    # Header row.
    hamui_v2_fill_rect(tx + 1, ty + 1, tw - 2, _ht_ROW_H - 1, 60, 66, 80)
    # "Notifications" placeholder bar.
    hamui_v2_fill_rect(tx + 8, ty + (_ht_ROW_H - 6) / 2, 80, 6, 210, 218, 235)
    # "[Clear]" placeholder bar.
    hamui_v2_fill_rect(tx + tw - 48, ty + (_ht_ROW_H - 6) / 2, 40, 6,
                       230, 180, 120)
    if _ht_count <= 0:
        # Empty state bar.
        hamui_v2_fill_rect(tx + 8, ty + _ht_ROW_H + (_ht_ROW_H - 6) / 2,
                           120, 6, 150, 156, 170)
    else:
        # N rows: title bright + body dimmer.
        i: int32 = 0
        while i < _ht_count:
            ry: int32 = ty + _ht_ROW_H + i * _ht_ROW_H
            if ry + _ht_ROW_H > ty + th:
                break
            hamui_v2_fill_rect(tx + 8, ry + 3, tw - 24, 6, 220, 226, 240)
            hamui_v2_fill_rect(tx + 8, ry + 3 + 8, tw - 24, 6, 160, 168, 185)
            hamui_v2_fill_rect(tx + 1, ry + _ht_ROW_H - 1, tw - 2, 1,
                               40, 44, 56)
            i = i + 1
    hamui_v2_commit_rect(0, 0, _ht_WIN_W, _ht_WIN_H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    sfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/self"))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamtray: could not bind window\n")
        return 1
    if hamui_set_protocol_v2_dims(_ht_WIN_W, _ht_WIN_H) < 0:
        _puts(2, "hamtray: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_snap()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMTRAY ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_snap()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

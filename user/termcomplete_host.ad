# user/termcomplete_host.ad — HOST unit-test driver for the PURE completion-
# apply layer (lib/hamcompgather.ad) behind the graphical terminal's Tab
# completion (user/hamtermscene.ad :: _term_tab_complete).
#
# Built for the x86_64-linux Adder target: a freestanding ELF that runs
# DIRECTLY on the developer's host — no QEMU, no image. It drives the token
# analysis (hcg_token_start / hcg_is_first_word / hcg_leaf_off) and the apply
# policy (hcg_apply) over a battery of cases and prints one PASS/FAIL line per
# case plus a final RESULT ok/RESULT bad. scripts/test_termcomplete_host.sh
# asserts on those markers.
#
# user/linux-runtime.S supplies _start + the raw Linux syscall wrappers.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.hamcompgather import (
    hcg_token_start, hcg_is_first_word, hcg_leaf_off, hcg_apply,
    HCG_NONE, HCG_UNIQUE, HCG_EXTEND, HCG_LIST, HCG_ARM,
)


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _w(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


fail_count: int32 = 0


def _report(name: Ptr[uint8], ok: int32):
    if ok != 0:
        _w(cast[Ptr[uint8]]("PASS "))
    else:
        _w(cast[Ptr[uint8]]("FAIL "))
        fail_count = fail_count + 1
    _w(name)
    _w(cast[Ptr[uint8]]("\n"))


def _streq_n(a: Ptr[uint8], b: Ptr[uint8], blen: uint64) -> int32:
    if _slen(a) != blen:
        return 0
    k: uint64 = 0
    while k < blen:
        if a[k] != b[k]:
            return 0
        k = k + 1
    return 1


o_insert: Array[256, uint8]
o_ilen:   Array[1, uint64]
o_list:   Array[4096, uint8]
o_llen:   Array[1, uint64]


# Run hcg_apply(leaf, cands, tab_pending) and assert the action + inserted text.
def _apply_case(name: Ptr[uint8], leaf: Ptr[uint8], cands: Ptr[uint8],
                tab_pending: int32, want_action: int32, want_insert: Ptr[uint8]):
    act: int32 = hcg_apply(leaf, _slen(leaf), cands, _slen(cands), tab_pending,
                           &o_insert[0], 256, &o_ilen[0],
                           &o_list[0], 4096, &o_llen[0])
    ok: int32 = 1
    if act != want_action:
        ok = 0
    if _streq_n(want_insert, &o_insert[0], o_ilen[0]) == 0:
        ok = 0
    _report(name, ok)
    if ok == 0:
        _w(cast[Ptr[uint8]]("  got action="))
        db: Array[4, uint8]
        db[0] = cast[uint8](48 + act)
        db[1] = 0
        _w(&db[0])
        _w(cast[Ptr[uint8]](" insert='"))
        sys_write(1, &o_insert[0], o_ilen[0])
        _w(cast[Ptr[uint8]]("'\n"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # --- token analysis --------------------------------------------------
    # "ls -l /et"  cursor at end (9): token starts at 6 ('/et').
    ln1: Ptr[uint8] = cast[Ptr[uint8]]("ls -l /et")
    _report(cast[Ptr[uint8]]("token_start_arg"),
            cast[int32](hcg_token_start(ln1, 9, 9) == 6))
    # First word: "ls" token at 0 -> is_first true.
    _report(cast[Ptr[uint8]]("first_word_true"),
            hcg_is_first_word(ln1, 0))
    # Third token is NOT the first word.
    _report(cast[Ptr[uint8]]("first_word_false"),
            cast[int32](1 - hcg_is_first_word(ln1, 6)))
    # Leading whitespace still leaves the first non-space token "first".
    ln2: Ptr[uint8] = cast[Ptr[uint8]]("   ls")
    _report(cast[Ptr[uint8]]("first_word_leading_ws"),
            hcg_is_first_word(ln2, 3))
    # Leaf offset: "/bin/l" -> 5, "src/ma" -> 4, "ls" -> 0.
    _report(cast[Ptr[uint8]]("leaf_off_abs"),
            cast[int32](hcg_leaf_off(cast[Ptr[uint8]]("/bin/l"), 6) == 5))
    _report(cast[Ptr[uint8]]("leaf_off_rel"),
            cast[int32](hcg_leaf_off(cast[Ptr[uint8]]("src/ma"), 6) == 4))
    _report(cast[Ptr[uint8]]("leaf_off_bare"),
            cast[int32](hcg_leaf_off(cast[Ptr[uint8]]("ls"), 2) == 0))

    # --- apply policy ----------------------------------------------------
    # Unique match: leaf "ech" over {echo,cat,ls} -> insert remainder "o".
    _apply_case(cast[Ptr[uint8]]("unique_insert"), cast[Ptr[uint8]]("ech"),
                cast[Ptr[uint8]]("echo\ncat\nls\n"), 0,
                HCG_UNIQUE, cast[Ptr[uint8]]("o"))
    # No match: leaf "zz" -> HCG_NONE, nothing inserted.
    _apply_case(cast[Ptr[uint8]]("none"), cast[Ptr[uint8]]("zz"),
                cast[Ptr[uint8]]("echo\ncat\nls\n"), 0,
                HCG_NONE, cast[Ptr[uint8]](""))
    # Extend to LCP: leaf "bas" over {base64,basename,banner} share "base" ->
    # insert "e" (the bytes past the leaf), action EXTEND.
    _apply_case(cast[Ptr[uint8]]("extend_lcp"), cast[Ptr[uint8]]("bas"),
                cast[Ptr[uint8]]("base64\nbasename\nbanner\n"), 0,
                HCG_EXTEND, cast[Ptr[uint8]]("e"))
    # Ambiguous, no further prefix, FIRST tab -> ARM (no insert).
    _apply_case(cast[Ptr[uint8]]("ambiguous_arm"), cast[Ptr[uint8]]("ba"),
                cast[Ptr[uint8]]("banner\nbase64\n"), 0,
                HCG_ARM, cast[Ptr[uint8]](""))
    # Ambiguous, no further prefix, SECOND tab -> LIST (out_list populated).
    act: int32 = hcg_apply(cast[Ptr[uint8]]("ba"), 2,
                           cast[Ptr[uint8]]("banner\nbase64\n"), 14, 1,
                           &o_insert[0], 256, &o_ilen[0],
                           &o_list[0], 4096, &o_llen[0])
    list_ok: int32 = 1
    if act != HCG_LIST:
        list_ok = 0
    if o_llen[0] == 0:
        list_ok = 0
    _report(cast[Ptr[uint8]]("ambiguous_list"), list_ok)

    if fail_count == 0:
        _w(cast[Ptr[uint8]]("RESULT ok\n"))
        return 0
    _w(cast[Ptr[uint8]]("RESULT bad\n"))
    return 1

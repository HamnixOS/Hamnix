# user/hammark_host.ad — HOST driver + render harness for HamMark, the native
# Markdown viewer (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hammarkcore.ad) with a KNOWN,
# INJECTED markdown string so the gate is deterministic, and asserts:
#   * the parsed BLOCK structure — a heading, a styled paragraph, an unordered
#     + an ordered list, a fenced code block, a blockquote, a link and an HR
#     land as the right block TYPES in order;
#   * the rendered scene is non-blank with the expected ELEMENTS at expected
#     positions — a heading painted LARGER than body text, list markers, a code
#     block's distinct background, the blockquote accent bar;
#   * the document is taller than the viewport (scrollable) and SCROLLING moves
#     the content (a probe pixel changes after a page-down).
# It renders the view to a PPM a human/agent can LOOK at.
#
# USAGE (built to build/host/hammark_host):
#   hammark_host VIEW.ppm [SCROLLED.ppm]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hammarkcore import (
    hammark_init, hammark_set_text, hammark_render,
    hammark_nblocks, hammark_block_type, hammark_block_level,
    hammark_content_height, hammark_view_h, hammark_scroll,
    hammark_max_scroll, hammark_key_line, hammark_scroll_wheel,
    hammark_win_w, hammark_win_h,
    MK_HR, MK_HEADING, MK_PARA, MK_UL, MK_OL, MK_CODE, MK_QUOTE
)


# ---- stdout helpers -------------------------------------------------
obuf: Array[256, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 255:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
    else:
        digs: Array[24, uint8]
        n: uint64 = 0
        x: uint64 = cast[uint64](v)
        while x > 0:
            digs[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
        while n > 0:
            n = n - 1
            _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)
    _o_flush()


# ====================================================================
# The full-window RGBA backbuffer we composite the view into.
# 620*560*4 = 1,388,800.
# ====================================================================
_bb: Array[1388800, uint8]
ppm_hdr: Array[64, uint8]


def _hdr_dec(pos: uint64, v: uint64) -> uint64:
    if v == 0:
        ppm_hdr[pos] = 48
        return pos + 1
    tmp: Array[24, uint8]
    t: uint64 = 0
    while v != 0:
        tmp[t] = cast[uint8](v % 10) + 48
        v = v / 10
        t = t + 1
    while t > 0:
        t = t - 1
        ppm_hdr[pos] = tmp[t]
        pos = pos + 1
    return pos


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    W: int32 = hammark_win_w()
    H: int32 = hammark_win_h()
    p: uint64 = 0
    ppm_hdr[p] = 80                                     # 'P'
    p = p + 1
    ppm_hdr[p] = 54                                     # '6'
    p = p + 1
    ppm_hdr[p] = 10
    p = p + 1
    p = _hdr_dec(p, cast[uint64](W))
    ppm_hdr[p] = 32
    p = p + 1
    p = _hdr_dec(p, cast[uint64](H))
    ppm_hdr[p] = 10
    p = p + 1
    p = _hdr_dec(p, 255)
    ppm_hdr[p] = 10
    p = p + 1
    sys_write(fd, &ppm_hdr[0], p)
    row: Array[2048, uint8]
    y: int32 = 0
    while y < H:
        rp: uint64 = 0
        x: int32 = 0
        while x < W:
            so: uint64 = (cast[uint64](y) * cast[uint64](W)
                          + cast[uint64](x)) * 4
            row[rp]     = _bb[so]
            row[rp + 1] = _bb[so + 1]
            row[rp + 2] = _bb[so + 2]
            rp = rp + 3
            x = x + 1
        sys_write(fd, &row[0], rp)
        y = y + 1
    sys_close(fd)
    return 0


# Read one backbuffer pixel's channel (0=R,1=G,2=B).
def _px(x: int32, y: int32, ch: int32) -> int32:
    o: uint64 = (cast[uint64](y) * cast[uint64](hammark_win_w())
                 + cast[uint64](x)) * 4 + cast[uint64](ch)
    return cast[int32](_bb[o])


# Is there any non-background ink in the rectangle [x0,x1) x [y0,y1)? The page
# background is (250,250,252); count pixels darker than that.
def _ink_count(x0: int32, y0: int32, x1: int32, y1: int32) -> int32:
    n: int32 = 0
    yy: int32 = y0
    while yy < y1:
        xx: int32 = x0
        while xx < x1:
            if _px(xx, yy, 0) < 240 or _px(xx, yy, 1) < 240 \
                    or _px(xx, yy, 2) < 240:
                n = n + 1
            xx = xx + 1
        yy = yy + 1
    return n


# Feed one key press through the "d <code>" wire line.
kl: Array[16, uint8]


def _press(code: int32):
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    hammark_key_line(&kl[0], p)


# ---- the injected KNOWN document ------------------------------------
_doc: Array[1024, uint8]
_doc_n: uint32 = 0


def _d(s: Ptr[uint8]):
    j: uint64 = 0
    while s[j] != 0 and _doc_n < 1023:
        _doc[_doc_n] = s[j]
        _doc_n = _doc_n + 1
        j = j + 1


def _build_doc():
    _doc_n = 0
    _d(cast[Ptr[uint8]]("# Heading One\n"))
    _d(cast[Ptr[uint8]](
        "This is a **bold** and *italic* and `code` paragraph that is long "))
    _d(cast[Ptr[uint8]](
        "enough to wrap across more than one line in the viewport width.\n\n"))
    _d(cast[Ptr[uint8]]("## Heading Two\n"))
    _d(cast[Ptr[uint8]]("- first bullet\n"))
    _d(cast[Ptr[uint8]]("- second bullet\n\n"))
    _d(cast[Ptr[uint8]]("1. first step\n"))
    _d(cast[Ptr[uint8]]("2. second step\n\n"))
    _d(cast[Ptr[uint8]]("```\n"))
    _d(cast[Ptr[uint8]]("code block line one\n"))
    _d(cast[Ptr[uint8]]("code block line two\n"))
    _d(cast[Ptr[uint8]]("```\n\n"))
    _d(cast[Ptr[uint8]]("> a quoted line of text\n\n"))
    _d(cast[Ptr[uint8]]("See [the site](https://255.one) for more.\n\n"))
    _d(cast[Ptr[uint8]]("---\n\n"))
    # padding paragraphs so the document is TALLER than the viewport
    _d(cast[Ptr[uint8]]("Extra paragraph one for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph two for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph three for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph four for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph five for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph six for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph seven for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph eight for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph nine for scroll length.\n\n"))
    _d(cast[Ptr[uint8]]("Extra paragraph ten for scroll length.\n"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    view_ppm: Ptr[char] = cast[Ptr[char]]("build/host/hammark_view.ppm")
    scr_ppm:  Ptr[char] = cast[Ptr[char]]("build/host/hammark_scrolled.ppm")
    if argc > 1:
        view_ppm = cast[Ptr[char]](argv[1])
    if argc > 2:
        scr_ppm = cast[Ptr[char]](argv[2])

    hammark_init()
    _build_doc()
    hammark_set_text(&_doc[0], cast[uint64](_doc_n))

    # ---- (1) parsed block structure -----------------------------------
    _kv(cast[Ptr[uint8]]("NBLOCKS"), cast[int64](hammark_nblocks()))
    _kv(cast[Ptr[uint8]]("B0_TYPE"), cast[int64](hammark_block_type(0)))
    _kv(cast[Ptr[uint8]]("B0_LEVEL"), cast[int64](hammark_block_level(0)))
    _kv(cast[Ptr[uint8]]("B1_TYPE"), cast[int64](hammark_block_type(1)))
    # the type constants (so the gate reads them symbolically)
    _kv(cast[Ptr[uint8]]("K_HR"), cast[int64](MK_HR))
    _kv(cast[Ptr[uint8]]("K_HEADING"), cast[int64](MK_HEADING))
    _kv(cast[Ptr[uint8]]("K_PARA"), cast[int64](MK_PARA))
    _kv(cast[Ptr[uint8]]("K_UL"), cast[int64](MK_UL))
    _kv(cast[Ptr[uint8]]("K_OL"), cast[int64](MK_OL))
    _kv(cast[Ptr[uint8]]("K_CODE"), cast[int64](MK_CODE))
    _kv(cast[Ptr[uint8]]("K_QUOTE"), cast[int64](MK_QUOTE))

    # count how many of each block type were parsed
    nh: int32 = 0
    nul: int32 = 0
    nol: int32 = 0
    ncode: int32 = 0
    nquote: int32 = 0
    nhr: int32 = 0
    npara: int32 = 0
    i: int32 = 0
    while i < hammark_nblocks():
        t: int32 = hammark_block_type(i)
        if t == MK_HEADING:
            nh = nh + 1
        elif t == MK_UL:
            nul = nul + 1
        elif t == MK_OL:
            nol = nol + 1
        elif t == MK_CODE:
            ncode = ncode + 1
        elif t == MK_QUOTE:
            nquote = nquote + 1
        elif t == MK_HR:
            nhr = nhr + 1
        elif t == MK_PARA:
            npara = npara + 1
        i = i + 1
    _kv(cast[Ptr[uint8]]("N_HEADING"), cast[int64](nh))
    _kv(cast[Ptr[uint8]]("N_UL"), cast[int64](nul))
    _kv(cast[Ptr[uint8]]("N_OL"), cast[int64](nol))
    _kv(cast[Ptr[uint8]]("N_CODE"), cast[int64](ncode))
    _kv(cast[Ptr[uint8]]("N_QUOTE"), cast[int64](nquote))
    _kv(cast[Ptr[uint8]]("N_HR"), cast[int64](nhr))
    _kv(cast[Ptr[uint8]]("N_PARA"), cast[int64](npara))

    # ---- (2) scrollable: document taller than the viewport ------------
    _kv(cast[Ptr[uint8]]("CONTENT_H"), cast[int64](hammark_content_height()))
    _kv(cast[Ptr[uint8]]("VIEW_H"), cast[int64](hammark_view_h()))
    _kv(cast[Ptr[uint8]]("MAX_SCROLL"), cast[int64](hammark_max_scroll()))

    # ---- (3) render the top of the document ---------------------------
    hammark_render(&_bb[0], hammark_win_w(), hammark_win_h())
    _write_ppm(view_ppm)

    # heading region (top of content, ~y=30..62) has MORE ink height than a
    # body line: the H1 glyphs are 3x tall. Probe the heading band vs a body
    # paragraph band for ink, and prove the heading occupies taller rows.
    head_ink: int32 = _ink_count(18, 30, 200, 62)
    _kv(cast[Ptr[uint8]]("HEAD_INK"), cast[int64](head_ink))
    # H1 ink must span several rows (tall glyphs): count rows in the heading
    # band that contain ink.
    hrows: int32 = 0
    ry: int32 = 30
    while ry < 60:
        if _ink_count(18, ry, 200, ry + 1) > 0:
            hrows = hrows + 1
        ry = ry + 1
    _kv(cast[Ptr[uint8]]("HEAD_ROWS"), cast[int64](hrows))

    # the code block has a distinct light-gray slab background (238,240,244).
    # Scan the content area for a run of that exact fill.
    code_bg: int32 = 0
    sy: int32 = 62
    while sy < hammark_view_h() and code_bg == 0:
        if _px(30, sy, 0) == 238 and _px(30, sy, 1) == 240 \
                and _px(30, sy, 2) == 244:
            code_bg = sy
        sy = sy + 1
    _kv(cast[Ptr[uint8]]("CODE_BG_Y"), cast[int64](code_bg))

    # the blockquote accent bar (green ~120,170,120) somewhere in the column.
    quote_bar: int32 = 0
    qy: int32 = 62
    while qy < hammark_view_h() and quote_bar == 0:
        if _px(19, qy, 0) == 120 and _px(19, qy, 1) == 170 \
                and _px(19, qy, 2) == 120:
            quote_bar = qy
        qy = qy + 1
    _kv(cast[Ptr[uint8]]("QUOTE_BAR_Y"), cast[int64](quote_bar))

    # a list bullet (blue 60,90,200) near the left margin.
    bullet: int32 = 0
    by: int32 = 62
    while by < hammark_view_h() and bullet == 0:
        bx: int32 = 20
        while bx < 40:
            if _px(bx, by, 0) == 60 and _px(bx, by, 1) == 90 \
                    and _px(bx, by, 2) == 200:
                bullet = by
            bx = bx + 1
        by = by + 1
    _kv(cast[Ptr[uint8]]("BULLET_Y"), cast[int64](bullet))

    # ---- (4) scrolling changes the viewport ---------------------------
    # probe pixel row in the body BEFORE scrolling
    before: int32 = _ink_count(18, 120, 300, 140)
    _kv(cast[Ptr[uint8]]("SCROLL0"), cast[int64](hammark_scroll()))
    _press(32)                                          # Space -> page down
    _kv(cast[Ptr[uint8]]("SCROLL1"), cast[int64](hammark_scroll()))
    hammark_render(&_bb[0], hammark_win_w(), hammark_win_h())
    after: int32 = _ink_count(18, 120, 300, 140)
    _kv(cast[Ptr[uint8]]("VIEW_CHANGED"), cast[int64](before - after))
    _write_ppm(scr_ppm)

    # arrow-up then Home returns to the top
    _press(107)                                         # 'k' up a line
    _kv(cast[Ptr[uint8]]("SCROLL_AFTER_K"), cast[int64](hammark_scroll()))
    hammark_scroll_wheel(3)                             # wheel up 3 notches
    _press(103)                                         # 'g' -> top
    _kv(cast[Ptr[uint8]]("SCROLL_TOP"), cast[int64](hammark_scroll()))

    _o_str(cast[Ptr[uint8]]("DONE 1\n"))
    _o_flush()
    return 0

# user/od.ad
#
# Hamnix `od -An -tx1` (unconditional): hex dump of stdin, 16 bytes
# per line, lowercase hex, space-separated, no address column. No
# flags consumed — matches the most common `od` invocation pattern
# we use in hamsh pipelines for binary verification.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def hex_digit(v: uint8) -> uint8:
    # 0..9 -> '0'..'9' (48..57); 10..15 -> 'a'..'f' (97..102).
    if v < 10:
        return v + 48
    return v + 87


def emit_byte(b: uint8, first: int32):
    # 3 bytes per slot: optional leading space + 2 hex digits.
    out: Array[3, uint8]
    out[0] = 32
    out[1] = hex_digit(b >> 4)
    out[2] = hex_digit(b & 15)
    if first != 0:
        sys_write(1, cast[Ptr[uint8]](cast[uint64](&out[0]) + 1), 2)
    else:
        sys_write(1, &out[0], 3)


def main() -> int32:
    buf: Array[256, uint8]
    col: int32 = 0
    while True:
        n: int64 = sys_read(0, &buf[0], 256)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n):
            if col == 0:
                emit_byte(buf[i], 1)
            else:
                emit_byte(buf[i], 0)
            col = col + 1
            if col == 16:
                sys_write(1, "\n", 1)
                col = 0
            i = i + 1
    # Flush partial line so the final dump has a trailing newline.
    if col != 0:
        sys_write(1, "\n", 1)
    return 0

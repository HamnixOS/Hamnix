# user/hameditscene_host.ad — HOST render harness for the scene-DE editor's
# syntax highlighting (built for x86_64-linux; runs on the dev host, no QEMU).
#
# It reproduces the editor's canvas layout (window fill, line-number gutter +
# separator, headerbar/title) and renders a handful of sample source lines
# through the SAME core the native editor ships — lib/hameditcore's
# hamedit_draw_row_syntax — so the comment/string/number/plain coloring is
# exercised on the real code path, then rasterized to a PPM a human/agent can
# LOOK at. It dumps the scene display list and per-class rasterized-pixel counts
# for the gate to assert.
#
# USAGE (built to build/host/hamedit_host):
#   hamedit_host OUT.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_line, \
    hamscene_glyphs, hamscene_headerbar, hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hameditcore import hamedit_draw_row_syntax


# Editor layout constants (mirrors user/hameditscene.ad).
WIN_W:    int32 = 400
WIN_H:    int32 = 160
TITLE_H:  int32 = 18
GUTTER_W: int32 = 30
TEXT_X:   int32 = 6
TEXT_Y:   int32 = 22
LINE_H:   int32 = 16
CELL_W:   int32 = 8


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


# Draw one editor row: gutter line-number (right-aligned) + the syntax-colored
# glyph run at the text column, at visual row `row` (0-based).
def _draw_line(row: int32, text: Ptr[uint8]):
    yy: int32 = TEXT_Y + row * LINE_H
    # Gutter number (1-based), right-aligned in the gutter band.
    gnum: Array[12, uint8]
    gn: uint64 = _u64_to_dec(cast[uint64](row + 1), &gnum[0])
    gnum[gn] = 0
    gx: int32 = GUTTER_W - 4 - cast[int32](gn) * CELL_W
    if gx < 2:
        gx = 2
    hamscene_glyphs(gx, yy + 2, &gnum[0], cast[Ptr[uint8]]("#909088"))
    # Syntax-colored body text past the gutter — the REAL editor code path.
    hamedit_draw_row_syntax(TEXT_X + GUTTER_W, yy + 2, text, _slen(text))


# Count rasterized text-area pixels whose dominant channel matches a syntax
# color. Blending toward the pale bg preserves channel ORDER at every coverage
# level, so an ordering test with a margin robustly detects real colored
# strokes without exact-color matching. kind: 1=green 2=orange 3=blue.
def _count_color(kind: int32) -> uint64:
    n: uint64 = 0
    y: int32 = TITLE_H
    while y < WIN_H:
        x: int32 = GUTTER_W
        while x < WIN_W:
            px: uint32 = hamui_host_pixel(x, y)
            r: int32 = cast[int32]((px >> 16) & 255)
            g: int32 = cast[int32]((px >> 8) & 255)
            b: int32 = cast[int32](px & 255)
            hit: int32 = 0
            if kind == 1:                              # green: g dominant
                if g > r + 20 and g > b + 12:
                    hit = 1
            elif kind == 2:                            # orange: r dominant
                if r > g + 25 and g > b + 10:
                    hit = 1
            elif kind == 3:                            # blue: b dominant
                if b > r + 25 and b > g + 12:
                    hit = 1
            if hit != 0:
                n = n + 1
            x = x + 1
        y = y + 1
    return n


def _emit_line(prefix: Ptr[uint8], v: uint64):
    out: Array[64, uint8]
    p: uint64 = 0
    while prefix[p] != 0 and p < 50:
        out[p] = prefix[p]
        p = p + 1
    p = p + _u64_to_dec(v, &out[p])
    out[p] = 10
    sys_write(1, &out[0], p + 1)


def _build_scene():
    hamscene_begin()
    # Editor canvas + gutter band + separator + headerbar (mirrors emit_scene).
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#fbfbf7"))
    hamscene_fill(0, TITLE_H, GUTTER_W, WIN_H - TITLE_H,
                  cast[Ptr[uint8]]("#eceae2"))
    hamscene_line(GUTTER_W, TITLE_H, GUTTER_W, WIN_H, 1,
                  cast[Ptr[uint8]]("#d2cfc4"))
    hamscene_headerbar(0, 0, WIN_W, TITLE_H)
    hamscene_glyphs(4, 4, cast[Ptr[uint8]]("hamedit: sample.txt"),
                    cast[Ptr[uint8]]("#ffffff"))
    # Sample lines exercising every token class.
    _draw_line(0, cast[Ptr[uint8]]("# a comment line"))
    _draw_line(1, cast[Ptr[uint8]]("count = 42"))
    _draw_line(2, cast[Ptr[uint8]]("name = \"hello\""))
    _draw_line(3, cast[Ptr[uint8]]("plain body text"))
    _draw_line(4, cast[Ptr[uint8]]("hex = 0xdeadbeef + 3.14"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    _build_scene()
    hamui_host_begin(WIN_W, WIN_H)
    hamui_host_rasterize()

    if argc >= 2 and argv != cast[Ptr[uint64]](0):
        _write_ppm(cast[Ptr[char]](argv[1]))

    # Per-class rasterized-pixel counts (proof the colors reached the fb).
    _emit_line(cast[Ptr[uint8]]("GREENPIX "), _count_color(1))
    _emit_line(cast[Ptr[uint8]]("ORANGEPIX "), _count_color(2))
    _emit_line(cast[Ptr[uint8]]("BLUEPIX "), _count_color(3))

    # The full scene display list, for exact scene-op assertions.
    sys_write(1, cast[Ptr[uint8]]("SCENE-BEGIN\n"), 12)
    sys_write(1, hamscene_bufptr(), hamscene_length())
    sys_write(1, cast[Ptr[uint8]]("SCENE-END\n"), 10)
    return 0

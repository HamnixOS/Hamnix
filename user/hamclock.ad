# user/hamclock.ad
#
# hamclock — a real clock + stopwatch built entirely on the hamui widget
# toolkit (lib/hamui.ad). A genuine consumer of the GTK/Qt-style
# retained-mode API: it builds a widget tree once, binds a window, then
# drives the toolkit's pull-based event loop (hamui_step + sys_yield)
# forever, recomputing time from the kernel jiffies counter and pushing the
# rendered text back into widgets via hamui_set_text / hamui_status_set.
#
# CLOCK: shows elapsed time since boot as H:MM:SS. Derived from
# sys_get_jiffies() at ~100 ticks/sec (total_seconds = jiffies / 100). The
# label is only rewritten when the displayed second changes, to avoid
# churning the toolkit every frame.
#
# STOPWATCH: Start / Stop / Reset buttons (hamui_signalled).
#   - Start: snapshot the current jiffies and begin running.
#   - Stop:  fold the running interval into an accumulator and halt.
#   - Reset: zero everything.
#   The elapsed value is shown as MM:SS.cc where cc = centiseconds
#   (jiffies % 100). It updates whenever the displayed centisecond changes.

from lib.hamui import (
    hamui_init, hamui_fixed, hamui_button,
    hamui_label, hamui_statusbar, hamui_status_set,
    hamui_add, hamui_fixed_place, hamui_set_size, hamui_set_text,
    hamui_window, hamui_step, hamui_signalled,
    hamui_calendar, hamui_calendar_get
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_yield() -> int32
extern def sys_get_jiffies() -> uint64


# ---- tiny stdout helpers (for the boot/diagnostic line) -----------------
def _k_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _k_puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _k_strlen(s))


# ====================================================================
# STATE (module scope — no malloc, fixed arrays only)
# ====================================================================
# stopwatch:
#   sw_running : nonzero while the stopwatch is counting
#   sw_start   : jiffies snapshot taken when (re)started
#   sw_accum   : jiffies of elapsed time banked from prior runs
sw_running: int32 = 0
sw_start:   uint64 = 0
sw_accum:   uint64 = 0

# last-rendered values, so we only rewrite labels when they actually change
last_clock_sec: uint64 = 0xFFFFFFFFFFFFFFFF
last_sw_cc:     uint64 = 0xFFFFFFFFFFFFFFFF

# render scratch buffers
clock_buf: Array[24, uint8]
sw_buf:    Array[24, uint8]

# widget ids
lbl_clock: int32 = 0
lbl_sw:    int32 = 0
b_start:   int32 = 0
b_stop:    int32 = 0
b_reset:   int32 = 0
cal:       int32 = 0                 # the embedded month-view calendar
sb:        int32 = 0                 # statusbar (shows the picked date)

# calendar selection readback (out-params + "selected YYYY-MM-DD" scratch)
cal_y:     Array[1, int64]
cal_m:     Array[1, int64]
cal_d:     Array[1, int64]
cal_buf:   Array[24, uint8]


# ---- render "selected YYYY-MM-DD" into cal_buf ---------------------------
def _k_render_date(y: int64, m: int64, d: int64):
    p: uint64 = 0
    p = _k_puts_at(&cal_buf[0], p, "selected ")
    cal_buf[p] = cast[uint8]((y / 1000) % 10) + 48
    cal_buf[p + 1] = cast[uint8]((y / 100) % 10) + 48
    cal_buf[p + 2] = cast[uint8]((y / 10) % 10) + 48
    cal_buf[p + 3] = cast[uint8](y % 10) + 48
    cal_buf[p + 4] = 45                              # '-'
    cal_buf[p + 5] = cast[uint8]((m / 10) % 10) + 48
    cal_buf[p + 6] = cast[uint8](m % 10) + 48
    cal_buf[p + 7] = 45                              # '-'
    cal_buf[p + 8] = cast[uint8]((d / 10) % 10) + 48
    cal_buf[p + 9] = cast[uint8](d % 10) + 48
    cal_buf[p + 10] = 0


def _k_puts_at(buf: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while s[k] != 0:
        buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# ---- write a 2-digit zero-padded number into buf at pos, return new pos --
def _k_put2(buf: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    buf[pos] = cast[uint8]((v / 10) % 10) + 48
    buf[pos + 1] = cast[uint8](v % 10) + 48
    return pos + 2


# ---- render H:MM:SS from a total-seconds count into clock_buf -----------
def _k_render_clock(total_sec: uint64):
    hours: uint64 = total_sec / 3600
    rem: uint64 = total_sec % 3600
    mins: uint64 = rem / 60
    secs: uint64 = rem % 60

    p: uint64 = 0
    # hours: variable width (no leading zero), at least one digit
    if hours == 0:
        clock_buf[p] = 48
        p = p + 1
    else:
        tmp: Array[20, uint8]
        t: uint64 = 0
        hv: uint64 = hours
        while hv != 0:
            tmp[t] = cast[uint8](hv % 10) + 48
            hv = hv / 10
            t = t + 1
        while t > 0:
            t = t - 1
            clock_buf[p] = tmp[t]
            p = p + 1
    clock_buf[p] = 58                       # ':'
    p = p + 1
    p = _k_put2(&clock_buf[0], p, mins)
    clock_buf[p] = 58                       # ':'
    p = p + 1
    p = _k_put2(&clock_buf[0], p, secs)
    clock_buf[p] = 0


# ---- render MM:SS.cc from a total-jiffies count into sw_buf -------------
def _k_render_sw(total_jiffies: uint64):
    total_sec: uint64 = total_jiffies / 100
    cc: uint64 = total_jiffies % 100
    mins: uint64 = total_sec / 60
    secs: uint64 = total_sec % 60
    # cap minutes display at 99 so the buffer stays bounded
    if mins > 99:
        mins = 99

    p: uint64 = 0
    p = _k_put2(&sw_buf[0], p, mins)
    sw_buf[p] = 58                          # ':'
    p = p + 1
    p = _k_put2(&sw_buf[0], p, secs)
    sw_buf[p] = 46                          # '.'
    p = p + 1
    p = _k_put2(&sw_buf[0], p, cc)
    sw_buf[p] = 0


# ---- current stopwatch elapsed in jiffies (accum + live run) ------------
def _k_sw_elapsed(now: uint64) -> uint64:
    e: uint64 = sw_accum
    if sw_running != 0:
        if now >= sw_start:
            e = e + (now - sw_start)
    return e


# ====================================================================
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    root: int32 = hamui_fixed()

    title: int32 = hamui_label("hamclock - hamui")
    hamui_fixed_place(title, 20, 14)
    hamui_add(root, title)

    # ---- clock section ----
    clk_hdr: int32 = hamui_label("Uptime clock (H:MM:SS since boot)")
    hamui_fixed_place(clk_hdr, 20, 56)
    hamui_add(root, clk_hdr)

    lbl_clock = hamui_label("0:00:00")
    hamui_set_size(lbl_clock, 300, 48)
    hamui_fixed_place(lbl_clock, 20, 84)
    hamui_add(root, lbl_clock)

    # ---- stopwatch section ----
    sw_hdr: int32 = hamui_label("Stopwatch (MM:SS.cc)")
    hamui_fixed_place(sw_hdr, 20, 168)
    hamui_add(root, sw_hdr)

    lbl_sw = hamui_label("00:00.00")
    hamui_set_size(lbl_sw, 300, 48)
    hamui_fixed_place(lbl_sw, 20, 196)
    hamui_add(root, lbl_sw)

    b_start = hamui_button("Start")
    hamui_set_size(b_start, 110, 40)
    hamui_fixed_place(b_start, 20, 260)
    hamui_add(root, b_start)

    b_stop = hamui_button("Stop")
    hamui_set_size(b_stop, 110, 40)
    hamui_fixed_place(b_stop, 150, 260)
    hamui_add(root, b_stop)

    b_reset = hamui_button("Reset")
    hamui_set_size(b_reset, 110, 40)
    hamui_fixed_place(b_reset, 280, 260)
    hamui_add(root, b_reset)

    # ---- calendar section (MATE clock-applet style month view) ----
    # Seeded on today via /proc/realtime inside the toolkit; clicking a
    # day selects it and the chosen date is echoed in the status bar.
    cal_hdr: int32 = hamui_label("Calendar")
    hamui_fixed_place(cal_hdr, 420, 56)
    hamui_add(root, cal_hdr)

    cal = hamui_calendar()
    hamui_fixed_place(cal, 420, 84)
    hamui_add(root, cal)

    sb = hamui_statusbar("hamclock")
    hamui_set_size(sb, 640, 20)
    hamui_fixed_place(sb, 0, 460)
    hamui_add(root, sb)

    wid: int32 = hamui_window(root)
    if wid < 0:
        _k_puts(2, "hamclock: could not allocate a window\n")
        return 1

    _k_puts(1, "HAMCLOCK ready\n")

    # --- event / time loop -------------------------------------------
    while True:
        hamui_step()

        now: uint64 = sys_get_jiffies()

        # stopwatch buttons
        if hamui_signalled(b_start) != 0:
            if sw_running == 0:
                sw_start = now
                sw_running = 1
        if hamui_signalled(b_stop) != 0:
            if sw_running != 0:
                if now >= sw_start:
                    sw_accum = sw_accum + (now - sw_start)
                sw_running = 0
        if hamui_signalled(b_reset) != 0:
            sw_running = 0
            sw_start = 0
            sw_accum = 0
            last_sw_cc = 0xFFFFFFFFFFFFFFFF

        # calendar: a day was clicked -> show the picked civil date
        if hamui_signalled(cal) != 0:
            hamui_calendar_get(cal, &cal_y[0], &cal_m[0], &cal_d[0])
            _k_render_date(cal_y[0], cal_m[0], cal_d[0])
            hamui_status_set(sb, &cal_buf[0])

        # clock: only rewrite when the displayed second changes
        cur_sec: uint64 = now / 100
        if cur_sec != last_clock_sec:
            last_clock_sec = cur_sec
            _k_render_clock(cur_sec)
            hamui_set_text(lbl_clock, &clock_buf[0])

        # stopwatch: only rewrite when the displayed centisecond changes
        sw_e: uint64 = _k_sw_elapsed(now)
        if sw_e != last_sw_cc:
            last_sw_cc = sw_e
            _k_render_sw(sw_e)
            hamui_set_text(lbl_sw, &sw_buf[0])

        sys_yield()

    return 0

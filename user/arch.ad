# user/arch.ad
#
# Hamnix `arch`: print the machine hardware name and a newline, exactly
# like coreutils `arch` (equivalent to `uname -m`). Hamnix's native
# userland targets x86_64, so the answer is a constant — but shipping it
# as a first-class command means scripts that branch on `arch` don't
# need the Linux namespace just to read the CPU architecture.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def main() -> int32:
    sys_write(1, "x86_64\n", 7)
    return 0

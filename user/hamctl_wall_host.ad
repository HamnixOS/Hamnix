# user/hamctl_wall_host.ad — HOST render gate for the Control Center's IMAGE
# wallpapers (built for x86_64-linux; runs on the dev host, no QEMU).
#
# It proves the image-wallpaper path a native boot renders, but in
# milliseconds where a human/agent can LOOK at the result:
#   1. for each procedural image (lib/hamctlcore's pure hamctl_image_rgb law),
#      emit a full-screen 24x18 `fill` mosaic via hamctl_image_mosaic — the
#      EXACT nearest-neighbour backdrop shape the DE (user/hamdesktop.ad
#      emit_wallpaper) paints on-device from the applied PPM,
#   2. RASTERIZE that scene with lib/hamui_host.ad (the same rasteriser the
#      other DE host gates use) and write it out as a binary PPM the harness
#      converts to a PNG,
#   3. sample the framebuffer and assert the background is NON-UNIFORM (a real
#      image, not a flat fill) — and, as a control, assert a solid-colour
#      swatch fill collapses to a single distinct colour.
#
# USAGE:  hamctl_wall_host SUNSET.ppm OCEAN.ppm TILES.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_begin, hamscene_fill
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamctlcore import hamctl_init, hamctl_image_mosaic, hamctl_image_count


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    sys_write(1, &obuf[0], obuf_n)
    obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)                 # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


# Count distinct colours over a 24x18 grid of sample points across (w,h).
# Bounded to 64 stored colours (plenty to distinguish a real image from a
# flat fill without a big table).
seen_col: Array[64, uint32]


def _count_distinct(w: int32, h: int32) -> int32:
    nseen: int32 = 0
    gy: int32 = 0
    while gy < 18:
        py: int32 = gy * (h - 1) / 17
        gx: int32 = 0
        while gx < 24:
            px: int32 = gx * (w - 1) / 23
            c: uint32 = hamui_host_pixel(px, py)
            k: int32 = 0
            found: int32 = 0
            while k < nseen:
                if seen_col[k] == c:
                    found = 1
                k = k + 1
            if found == 0 and nseen < 64:
                seen_col[nseen] = c
                nseen = nseen + 1
            gx = gx + 1
        gy = gy + 1
    return nseen


W: int32 = 640
H: int32 = 480


def _render_image(img: int32) -> int32:
    hamscene_begin()
    hamctl_image_mosaic(img, 0, 0, W, H, 24, 18)
    hamui_host_begin(W, H)
    hamui_host_rasterize()
    return _count_distinct(W, H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]]("usage: hamctl_wall_host SUNSET.ppm OCEAN.ppm TILES.ppm\n"))
        _o_flush()
        return 2
    hamctl_init()

    fail: int32 = 0
    nimg: uint64 = hamctl_image_count()
    i: uint64 = 0
    while i < nimg and i < 3:
        distinct: int32 = _render_image(cast[int32](i))
        _write_ppm(cast[Ptr[char]](argv[1 + i]))
        _o_str(cast[Ptr[uint8]]("IMG "))
        _o_dec(cast[int64](i))
        _o_str(cast[Ptr[uint8]](" DISTINCT "))
        _o_dec(cast[int64](distinct))
        _o_ch(10)
        if distinct >= 8:
            _o_str(cast[Ptr[uint8]]("IMG "))
            _o_dec(cast[int64](i))
            _o_str(cast[Ptr[uint8]](" NONUNIFORM PASS\n"))
        else:
            _o_str(cast[Ptr[uint8]]("IMG "))
            _o_dec(cast[int64](i))
            _o_str(cast[Ptr[uint8]](" NONUNIFORM FAIL\n"))
            fail = 1
        i = i + 1

    # Control: a solid-colour swatch fill must collapse to ONE distinct colour.
    hamscene_begin()
    hamscene_fill(0, 0, W, H, cast[Ptr[uint8]]("#205060"))
    hamui_host_begin(W, H)
    hamui_host_rasterize()
    solid: int32 = _count_distinct(W, H)
    _o_str(cast[Ptr[uint8]]("SOLID DISTINCT "))
    _o_dec(cast[int64](solid))
    _o_ch(10)
    if solid == 1:
        _o_str(cast[Ptr[uint8]]("SOLID UNIFORM PASS\n"))
    else:
        _o_str(cast[Ptr[uint8]]("SOLID UNIFORM FAIL\n"))
        fail = 1

    if fail == 0:
        _o_str(cast[Ptr[uint8]]("WALLPAPER_GATE PASS\n"))
    else:
        _o_str(cast[Ptr[uint8]]("WALLPAPER_GATE FAIL\n"))
    _o_flush()
    return fail

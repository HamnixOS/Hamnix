# user/strings.ad — print printable ASCII runs from a binary file.
#
# Mirrors `strings -n 4` (default min-length 4). Walks the file
# byte-by-byte; emits a run of length >= MIN_LEN whenever a
# non-printable byte (or EOF) breaks the run.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

MIN_LEN: uint64 = 4

# 8 KiB read buffer + 256-byte run accumulator.
file_buf: Array[8192, uint8]
run_buf:  Array[256, uint8]


def is_printable(c: uint8) -> int32:
    if c >= 32 and c <= 126:
        return 1
    if c == 9:                                  # tab
        return 1
    return 0


def emit_run(length: uint64):
    if length >= MIN_LEN:
        sys_write(1, &run_buf[0], length)
        sys_write(1, "\n", 1)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        sys_write(2, "usage: strings FILE\n", 20)
        return 1
    fd: int32 = sys_open(cast[Ptr[char]](argv[1]))
    if fd < 0:
        sys_write(2, "strings: cannot open\n", 21)
        return 1
    run_len: uint64 = 0
    while True:
        n: int64 = sys_read(fd, &file_buf[0], 8192)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        i: uint64 = 0
        while i < nu:
            c: uint8 = file_buf[i]
            if is_printable(c) != 0:
                if run_len < 256:
                    run_buf[run_len] = c
                    run_len = run_len + 1
            else:
                emit_run(run_len)
                run_len = 0
            i = i + 1
    emit_run(run_len)                           # flush trailing run
    sys_close(fd)
    return 0

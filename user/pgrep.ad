# user/pgrep.ad
#
# Minimal Hamnix `pgrep NAME`: reads /proc/tasks and prints the PID
# of every task whose comm contains the literal NAME substring.
# /proc/tasks layout is `<pid> <state> <comm>\n` (see fs/procfs.ad)
# so we tokenize each line into those three fields, substring-match
# against the comm, and emit the pid one per line on stdout.
#
# Exits 0 if at least one match was emitted, 1 otherwise — same
# convention as procps' pgrep.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def contains(hay: Ptr[uint8], hay_len: uint64,
             needle: Ptr[uint8], needle_len: uint64) -> int32:
    if needle_len == 0:
        return 1
    if needle_len > hay_len:
        return 0
    i: uint64 = 0
    limit: uint64 = hay_len - needle_len
    while i <= limit:
        j: uint64 = 0
        hit: int32 = 1
        while j < needle_len:
            if hay[i + j] != needle[j]:
                hit = 0
                break
            j = j + 1
        if hit != 0:
            return 1
        i = i + 1
    return 0


# 8 KiB is far more than the 32-slot task table can produce, so we
# slurp the whole /proc/tasks snapshot in one pass and never worry
# about partial-line boundaries.
buf: Array[8192, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "pgrep: usage: pgrep NAME\n")
        return 1
    needle: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    needle_len: uint64 = strlen_u8(needle)

    fd: int32 = sys_open("/proc/tasks")
    if fd < 0:
        write_str(2, "pgrep: cannot open /proc/tasks\n")
        return 1
    total: uint64 = 0
    while total < 8192:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&buf[0]) + total), 8192 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)

    matches: int32 = 0
    pos: uint64 = 0
    while pos < total:
        # Line spans [pos .. end), where end is the next '\n' or EOF.
        end: uint64 = pos
        while end < total and buf[end] != 10:
            end = end + 1
        # Field 0: PID — digits up to first space.
        pid_end: uint64 = pos
        while pid_end < end and buf[pid_end] != 32:
            pid_end = pid_end + 1
        # Skip space, then field 1: state — single char up to space.
        f1: uint64 = pid_end
        while f1 < end and buf[f1] == 32:
            f1 = f1 + 1
        while f1 < end and buf[f1] != 32:
            f1 = f1 + 1
        # Skip space, comm runs to end of line.
        comm: uint64 = f1
        while comm < end and buf[comm] == 32:
            comm = comm + 1
        if comm < end:
            comm_len: uint64 = end - comm
            if contains(cast[Ptr[uint8]](
                    cast[uint64](&buf[0]) + comm),
                    comm_len, needle, needle_len) != 0:
                sys_write(1, &buf[pos], pid_end - pos)
                sys_write(1, "\n", 1)
                matches = matches + 1
        pos = end + 1
    if matches == 0:
        return 1
    return 0

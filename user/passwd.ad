# user/passwd.ad
#
# Set a user's password. Plan-9-shape: userland NEVER writes the shadow
# secret directly — it drives the kernel /dev/auth `setpass` verb, which
# generates the $6$<salt>$<hash> and rewrites the LIVE /etc/shadow entry
# in kernel context. The kernel gates setpass to the hostowner (uid 1)
# or the user changing THEIR OWN password.
#
# Usage:
#   passwd            — change the CURRENT user's password
#   passwd <name>     — change <name>'s password (hostowner, or self)
#
# Flow:
#   1. Resolve the target name (argv[1] or the current user via getuid +
#      /etc/passwd).
#   2. Prompt "New password: " — read with NO echo (raw byte read from
#      fd 0; this program isn't a shell line-editor so nothing echoes).
#   3. Prompt "Retype new password: " — confirm they match.
#   4. open("/dev/auth"); write "user <name>\n"; write "setpass <pw>\n";
#      read "ok\n" / "denied\n".

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_getuid() -> uint32

from lib.passwd.passwd import (
    passwd_parse, passwd_entry_name, passwd_lookup_by_uid,
)


PW_MAX: uint64 = 128

pw_buf:   Array[4096, uint8]      # /etc/passwd slurp
new_pw:   Array[128, uint8]       # typed new password
confirm:  Array[128, uint8]       # confirmation
target:   Array[64, uint8]        # resolved target username
authresp: Array[64, uint8]        # /dev/auth response


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def strlen_c(s: Ptr[char]) -> uint64:
    n: uint64 = 0
    while cast[Ptr[uint8]](s)[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def read_password(buf: Ptr[uint8], cap: uint64) -> uint64:
    # Read a line from fd 0 with NO echo (raw byte reads). Stops at '\n',
    # drops '\r'. Returns the password length (NUL-terminated).
    n: uint64 = 0
    while n + 1 < cap:
        c: Array[1, uint8]
        rr: int64 = sys_read(0, &c[0], 1)
        if rr <= 0:
            break
        if c[0] == 10:                                      # '\n'
            break
        if c[0] == 13:                                      # '\r'
            continue
        buf[n] = c[0]
        n = n + 1
    buf[n] = 0
    return n


def streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        if a[i] != b[i]:
            return 0
        if a[i] == 0:
            return 1
        i = i + 1
    return 0


def wipe(buf: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while i < cap:
        buf[i] = 0
        i = i + 1


def copy_cstr(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def auth_write_line(fd: int32, prefix: Ptr[uint8], plen: uint64,
                    payload: Ptr[uint8], paylen: uint64) -> int64:
    # Emit "<prefix><payload>\n" as ONE syscall — the /dev/auth cdev
    # treats one write() as one line.
    line: Array[256, uint8]
    p: uint64 = 0
    while p < plen and p + 2 < 256:
        line[p] = prefix[p]
        p = p + 1
    j: uint64 = 0
    while j < paylen and p + 2 < 256:
        line[p] = payload[j]
        p = p + 1
        j = j + 1
    line[p] = 10                                            # '\n'
    p = p + 1
    return sys_write(fd, &line[0], p)


def resolve_self(out: Ptr[uint8], cap: uint64) -> int32:
    # Resolve the current uid to its username via /etc/passwd. Returns 0
    # on success (out filled), -1 if not found.
    uid: uint32 = sys_getuid()
    fd: int32 = sys_open("/etc/passwd")
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < 4096:
        n: int64 = sys_read(fd, &pw_buf[total], 4096 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    passwd_parse(&pw_buf[0], total)
    idx: int32 = passwd_lookup_by_uid(uid)
    if idx < 0:
        return -1
    copy_cstr(out, passwd_entry_name(idx), cap)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # 1. Resolve the target user.
    if argc >= 2:
        copy_cstr(&target[0], cast[Ptr[uint8]](argv[1]), 64)
    else:
        if resolve_self(&target[0], 64) != 0:
            write_str(2, "passwd: cannot determine current user\n")
            return 1

    write_str(1, "Changing password for ")
    write_str(1, &target[0])
    write_str(1, "\n")

    # 2. Prompt for the new password (no echo).
    write_str(1, "New password: ")
    nlen: uint64 = read_password(&new_pw[0], PW_MAX)
    write_str(1, "\n")
    if nlen == 0:
        write_str(2, "passwd: empty password rejected\n")
        wipe(&new_pw[0], PW_MAX)
        return 1

    # 3. Confirm.
    write_str(1, "Retype new password: ")
    clen: uint64 = read_password(&confirm[0], PW_MAX)
    write_str(1, "\n")
    if streq(&new_pw[0], &confirm[0]) == 0:
        write_str(2, "passwd: passwords do not match\n")
        wipe(&new_pw[0], PW_MAX)
        wipe(&confirm[0], PW_MAX)
        return 1

    # 4. Drive the /dev/auth setpass verb.
    fd: int32 = sys_open("/dev/auth")
    if fd < 0:
        write_str(2, "passwd: cannot open /dev/auth\n")
        wipe(&new_pw[0], PW_MAX)
        wipe(&confirm[0], PW_MAX)
        return 1
    user_prefix: Ptr[uint8] = "user "
    setp_prefix: Ptr[uint8] = "setpass "
    auth_write_line(fd, user_prefix, 5, &target[0], strlen_u8(&target[0]))
    auth_write_line(fd, setp_prefix, 8, &new_pw[0], nlen)
    rn: int64 = sys_read(fd, &authresp[0], 64)
    sys_close(fd)

    # Wipe plaintext as soon as it's handed off.
    wipe(&new_pw[0], PW_MAX)
    wipe(&confirm[0], PW_MAX)

    if rn >= 2 and authresp[0] == 111 and authresp[1] == 107:   # "ok"
        write_str(1, "passwd: password updated successfully\n")
        return 0
    write_str(2, "passwd: password change denied (not authorised, or no such user)\n")
    return 1

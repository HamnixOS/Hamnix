# user/passwd.ad
#
# Stub `passwd`. There is no shadow file (/etc/shadow) and the
# kernel doesn't carry per-task credentials past uid=0, so there
# is no password to change. Land the binary now so the eventual
# multi-user landing has a familiar name to extend.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "passwd: no shadow file; multi-user not yet enabled\n")
    return 0

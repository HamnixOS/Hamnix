# user/hamaudiobook_host.ad — HOST driver + render harness for the hamaudiobook
# player (built for x86_64-linux; runs on the dev host, NO QEMU).
#
# Drives the SAME pure core the native app ships (lib/hamaudiobookcore.ad) and
# proves, in milliseconds with no audio hardware, the TWO defining audiobook
# features plus the transport UI:
#   1. RESUME: serialize a per-book offset via hamaudiobook_state_upsert, then
#      look it up via hamaudiobook_state_lookup — a save->reopen->resume round
#      trip, including UPDATE (re-saving the same book moves its offset) and
#      MULTI-BOOK (each path keeps its own offset).
#   2. SLEEP TIMER: arm a preset against a synthetic clock and assert it has NOT
#      expired before N minutes and HAS expired after, with remaining-time math.
#   3. transport: skip ±30s clamps; the scene rasterizes (before=idle,
#      after=playing mid-book with a lit blue progress bar + armed-sleep button).
#
# USAGE (built to build/host/hamaudiobook_host):
#   hamaudiobook_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamaudiobookcore import hamaudiobook_init, hamaudiobook_set_name, \
    hamaudiobook_set_format, hamaudiobook_set_duration_ms, \
    hamaudiobook_set_position_ms, hamaudiobook_set_level, \
    hamaudiobook_set_playing, hamaudiobook_set_resumed, \
    hamaudiobook_layout, hamaudiobook_build_scene_at, \
    hamaudiobook_press_at, hamaudiobook_release, \
    hamaudiobook_take_command, hamaudiobook_seek_ms, \
    hamaudiobook_skip_target_ms, \
    hamaudiobook_state_upsert, hamaudiobook_state_lookup, \
    hamaudiobook_sleep_cycle, hamaudiobook_sleep_preset_min, \
    hamaudiobook_sleep_arm, hamaudiobook_sleep_is_armed, \
    hamaudiobook_sleep_remaining_ms, hamaudiobook_sleep_expired, \
    hamaudiobook_btn_play_cx, hamaudiobook_btn_play_cy, \
    hamaudiobook_slp_cx, hamaudiobook_slp_cy, \
    HAMAUDIOBOOK_CMD_PLAYPAUSE, HAMAUDIOBOOK_CMD_SLEEP

# ---- stdout helpers ------------------------------------------------------
obuf: Array[1024, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 1023:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: uint64):
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _kv(k: Ptr[uint8], v: uint64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32, now_ms: uint64) -> int32:
    hamaudiobook_build_scene_at(now_ms)
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# State-file scratch buffer for the resume round-trip.
statebuf: Array[4096, uint8]
statelen: uint64 = 0

BOOK_A: Array[40, uint8]
BOOK_B: Array[40, uint8]


def _setpath(dst: Ptr[uint8], s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        dst[i] = s[i]
        i = i + 1
    dst[i] = 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    _setpath(&BOOK_A[0], cast[Ptr[uint8]]("/books/dune.mp3"))
    _setpath(&BOOK_B[0], cast[Ptr[uint8]]("/books/hobbit.wav"))

    hamaudiobook_init()

    # =====================================================================
    # 1. RESUME round-trip (the defining audiobook feature)
    # =====================================================================
    # (a) fresh lookup with an EMPTY state => 0 (no saved position).
    _kv(cast[Ptr[uint8]]("RESUME_EMPTY"),
        hamaudiobook_state_lookup(&statebuf[0], statelen, &BOOK_A[0]))

    # (b) save book A at 65_000 ms, then reopen (lookup) => 65_000.
    statelen = hamaudiobook_state_upsert(&statebuf[0], statelen, 4096,
                                         &BOOK_A[0], 65000)
    _kv(cast[Ptr[uint8]]("RESUME_A1"),
        hamaudiobook_state_lookup(&statebuf[0], statelen, &BOOK_A[0]))

    # (c) save a DIFFERENT book B at 12_000 ms; both coexist.
    statelen = hamaudiobook_state_upsert(&statebuf[0], statelen, 4096,
                                         &BOOK_B[0], 12000)
    _kv(cast[Ptr[uint8]]("RESUME_A2"),
        hamaudiobook_state_lookup(&statebuf[0], statelen, &BOOK_A[0]))
    _kv(cast[Ptr[uint8]]("RESUME_B1"),
        hamaudiobook_state_lookup(&statebuf[0], statelen, &BOOK_B[0]))

    # (d) UPDATE book A to a new offset; the old record is replaced, not
    #     duplicated (lookup returns the NEW value, B is untouched).
    statelen = hamaudiobook_state_upsert(&statebuf[0], statelen, 4096,
                                         &BOOK_A[0], 90000)
    _kv(cast[Ptr[uint8]]("RESUME_A3"),
        hamaudiobook_state_lookup(&statebuf[0], statelen, &BOOK_A[0]))
    _kv(cast[Ptr[uint8]]("RESUME_B2"),
        hamaudiobook_state_lookup(&statebuf[0], statelen, &BOOK_B[0]))
    _kv(cast[Ptr[uint8]]("STATE_LEN"), statelen)

    # Dump the raw state file so the gate can eyeball the on-disk shape.
    _o_flush()
    sys_write(1, cast[Ptr[uint8]]("STATE-BEGIN\n"), 12)
    sys_write(1, &statebuf[0], statelen)
    sys_write(1, cast[Ptr[uint8]]("STATE-END\n"), 10)

    # =====================================================================
    # 2. SLEEP TIMER (night mode) against a synthetic clock
    # =====================================================================
    # Cycle off -> 15 -> 30 and arm 30 min at t=1_000_000 ms.
    hamaudiobook_sleep_cycle()                       # 15
    hamaudiobook_sleep_cycle()                       # 30
    _kv(cast[Ptr[uint8]]("SLEEP_PRESET"),
        cast[uint64](hamaudiobook_sleep_preset_min()))
    NOW0: uint64 = 1000000
    hamaudiobook_sleep_arm(NOW0)
    _kv(cast[Ptr[uint8]]("SLEEP_ARMED"),
        cast[uint64](hamaudiobook_sleep_is_armed()))
    # 30 min == 1_800_000 ms. Just before: NOT expired, ~remaining.
    _kv(cast[Ptr[uint8]]("SLEEP_EXP_AT_29M"),
        cast[uint64](hamaudiobook_sleep_expired(NOW0 + 29 * 60000)))
    _kv(cast[Ptr[uint8]]("SLEEP_REMAIN_AT_29M"),
        hamaudiobook_sleep_remaining_ms(NOW0 + 29 * 60000))
    # Exactly at the deadline: expired.
    _kv(cast[Ptr[uint8]]("SLEEP_EXP_AT_30M"),
        cast[uint64](hamaudiobook_sleep_expired(NOW0 + 30 * 60000)))
    _kv(cast[Ptr[uint8]]("SLEEP_EXP_AT_31M"),
        cast[uint64](hamaudiobook_sleep_expired(NOW0 + 31 * 60000)))

    # =====================================================================
    # 3. skip ±30s clamps
    # =====================================================================
    hamaudiobook_set_duration_ms(600000)             # 10 min book
    _kv(cast[Ptr[uint8]]("SKIP_FWD_FROM_10S"),
        hamaudiobook_skip_target_ms(10000, 30000, 0))     # -> 40000
    _kv(cast[Ptr[uint8]]("SKIP_BACK_FROM_10S"),
        hamaudiobook_skip_target_ms(10000, 30000, 1))     # -> 0 (clamped)
    _kv(cast[Ptr[uint8]]("SKIP_FWD_NEAR_END"),
        hamaudiobook_skip_target_ms(595000, 30000, 0))    # -> 600000 (clamped)

    # =====================================================================
    # 4. RENDER before/after PPMs + assert command routing
    # =====================================================================
    W: int32 = 380
    H: int32 = 280
    hamaudiobook_layout(W, H)
    hamaudiobook_set_name(cast[Ptr[uint8]]("dune.mp3"))
    hamaudiobook_set_format(44100, 2)
    hamaudiobook_set_resumed(1, 65000)               # show the resume note

    p1: int32 = _render(W, H, NOW0)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _kv(cast[Ptr[uint8]]("PRIMS"), cast[uint64](p1))

    _o_flush()
    sys_write(1, cast[Ptr[uint8]]("SCENE-BEGIN\n"), 12)
    sys_write(1, hamscene_bufptr(), hamscene_length())
    sys_write(1, cast[Ptr[uint8]]("SCENE-END\n"), 10)

    # Click the Play button -> PLAYPAUSE.
    hamaudiobook_press_at(hamaudiobook_btn_play_cx(),
                          hamaudiobook_btn_play_cy())
    _kv(cast[Ptr[uint8]]("CMD_PLAY"),
        cast[uint64](hamaudiobook_take_command()))
    # Click the Sleep button -> SLEEP.
    hamaudiobook_press_at(hamaudiobook_slp_cx(), hamaudiobook_slp_cy())
    _kv(cast[Ptr[uint8]]("CMD_SLEEP"),
        cast[uint64](hamaudiobook_take_command()))
    hamaudiobook_release()                           # un-sink the sleep button

    # 'after' frame: playing, mid-book, sleep armed => blue sleep button.
    hamaudiobook_set_playing(1)
    hamaudiobook_set_position_ms(300000)             # 5:00 of 10:00
    hamaudiobook_set_level(20000)
    p2: int32 = _render(W, H, NOW0)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _kv(cast[Ptr[uint8]]("PRIMS2"), cast[uint64](p2))
    # Progress fill (blue #3d7dff = 4029951) sampled mid-bar.
    _kv(cast[Ptr[uint8]]("PIX_BAR"),
        cast[uint64](hamui_host_pixel(30, 100)))
    # Sleep button armed highlight (#25406a = 2441322) sampled near its centre.
    _kv(cast[Ptr[uint8]]("PIX_SLEEP"),
        cast[uint64](hamui_host_pixel(190, 226)))
    _o_flush()
    return 0

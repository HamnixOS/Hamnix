# user/hamresize.ad
#
# hamresize — DE pivot wave 5: live resize frame + keyboard-move/resize
# (kmode) frame extracted from daemon_pixel into a v2 client.
# kind 0=off (clear); kind 1=resize (2px accent); kind 2=kmode (3px accent).

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2, hamui_set_protocol_v2_dims,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


_hr_kind: int32 = 0
_hr_x:    int32 = 0
_hr_y:    int32 = 0
_hr_w:    int32 = 0
_hr_h:    int32 = 0
_hr_gen:  uint64 = 0
_hr_show_serial:      uint64 = 0
_hr_last_show_serial: uint64 = 0xffffffffffffffff
_hr_last_gen:         uint64 = 0xffffffffffffffff


_hr_WIN_W: int32 = 800
_hr_WIN_H: int32 = 600


_hr_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _read_snap() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/resize"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hr_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hr_snap_buf[p] >= 48 and _hr_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hr_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _parse_i64(pos: Ptr[uint64], end: uint64) -> int64:
    p: uint64 = pos[0]
    neg: int32 = 0
    if p < end and _hr_snap_buf[p] == 45:
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end and _hr_snap_buf[p] >= 48 and _hr_snap_buf[p] <= 57:
        v = v * 10 + cast[int64](_hr_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    if neg != 0:
        return -v
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hr_snap_buf[p] == 32 or _hr_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    k_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    x_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    y_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    w_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    h_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _hr_show_serial = show_v
    _hr_kind = cast[int32](k_v)
    _hr_x = cast[int32](x_v)
    _hr_y = cast[int32](y_v)
    _hr_w = cast[int32](w_v)
    _hr_h = cast[int32](h_v)
    _hr_gen = gen_v
    changed: int32 = 0
    if _hr_show_serial != _hr_last_show_serial:
        changed = 1
    if _hr_gen != _hr_last_gen:
        changed = 1
    _hr_last_show_serial = _hr_show_serial
    _hr_last_gen = _hr_gen
    return changed


def _paint():
    hamui_v2_clear_transparent()
    if _hr_kind == 0 or _hr_w <= 0 or _hr_h <= 0:
        hamui_v2_commit_rect(0, 0, _hr_WIN_W, _hr_WIN_H)
        return
    bx: int32 = _hr_x
    by: int32 = _hr_y
    bw: int32 = _hr_w
    bh: int32 = _hr_h
    if bx < 0:
        bx = 0
    if by < 0:
        by = 0
    if bx + bw > _hr_WIN_W:
        bw = _hr_WIN_W - bx
    if by + bh > _hr_WIN_H:
        bh = _hr_WIN_H - by
    thick: int32 = 2
    if _hr_kind == 2:
        thick = 3
    hamui_v2_fill_rect(bx, by, bw, thick, 200, 220, 250)
    hamui_v2_fill_rect(bx, by + bh - thick, bw, thick, 200, 220, 250)
    hamui_v2_fill_rect(bx, by, thick, bh, 200, 220, 250)
    hamui_v2_fill_rect(bx + bw - thick, by, thick, bh, 200, 220, 250)
    hamui_v2_commit_rect(0, 0, _hr_WIN_W, _hr_WIN_H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    sfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/self"))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamresize: could not bind window\n")
        return 1
    if hamui_set_protocol_v2_dims(_hr_WIN_W, _hr_WIN_H) < 0:
        _puts(2, "hamresize: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_snap()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMRESIZE ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_snap()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

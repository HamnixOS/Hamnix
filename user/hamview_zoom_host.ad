# user/hamview_zoom_host.ad — FAST, QEMU-free HOST gate for hamview's
# scroll-wheel zoom (built for x86_64-linux; runs on the dev host).
#
# It exercises the EXACT zoom + scaling math the on-device viewer runs — the
# shared lib/imgscale module (fit dims, zoom dims, nearest-neighbour blit) that
# user/hamview.ad uses — but where a human/agent can LOOK at the result:
#   1. slurp a real PNG file (argv[1]),
#   2. DECODE it with lib/png.ad (the same decoder hamview uses) into RGBA,
#   3. compute the 100%-zoom "fit" size for hamview's 640x(480-40) content
#      area, then render TWO frames into a hamview-shaped 640x480 canvas:
#         * argv[2]: zoom = 100% (the wheel-notch baseline)
#         * argv[3]: zoom = 200% (two-plus notches in)
#      each as a binary PPM; the gate converts them to PNGs to eyeball.
#   4. print the base + both zoomed pixel sizes to stdout so the gate can
#      ASSERT the scale factor actually changed (zoom-in is strictly larger).
#
# USAGE:  hamview_zoom_host INPUT.png OUT100.ppm OUT200.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.png import png_decode, png_width, png_height, png_rgba_ptr
from lib.imgscale import imgscale_fit_dims, imgscale_zoom_dims, imgscale_blit


# hamview window geometry (must match user/hamview.ad).
WIN_W:     int64  = 640
WIN_H:     int64  = 480
BAR_TOP_H: int64  = 22
BAR_BOT_H: int64  = 18
ZOOM_CAP:  uint64 = 4096


# ---- stdout line buffer --------------------------------------------------
obuf:   Array[256, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 255:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: uint64):
    if v == 0:
        _o_ch(48)
        return
    tmp: Array[24, uint8]
    t: uint64 = 0
    while v != 0:
        tmp[t] = cast[uint8](v % 10) + 48
        v = v / 10
        t = t + 1
    while t > 0:
        t = t - 1
        _o_ch(tmp[t])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PNG slurp -----------------------------------------------------------
png_bytes: Array[4194304, uint8]        # up to 4 MiB of PNG file


def _slurp(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path, 0, 0)                    # O_RDONLY
    if fd < 0:
        return -1
    total: int64 = 0
    while total < 4194304:
        r: int64 = sys_read(fd, &png_bytes[total],
                            cast[uint64](4194304) - cast[uint64](total))
        if r <= 0:
            sys_close(fd)
            return total
        total = total + r
    sys_close(fd)
    return total


# ---- 640x480 RGBA canvas + PPM writer ------------------------------------
canvas: Array[1228800, uint8]           # 640*480*4
ppm_hdr: Array[64, uint8]


def _canvas_clear(r: uint8, g: uint8, b: uint8):
    n: uint64 = cast[uint64](WIN_W * WIN_H)
    i: uint64 = 0
    while i < n:
        canvas[i * 4]     = r
        canvas[i * 4 + 1] = g
        canvas[i * 4 + 2] = b
        canvas[i * 4 + 3] = 255
        i = i + 1


def _bar(y0: int64, hh: int64, r: uint8, g: uint8, b: uint8):
    stride: uint64 = cast[uint64](WIN_W) * 4
    y: int64 = y0
    while y < y0 + hh:
        x: int64 = 0
        while x < WIN_W:
            o: uint64 = cast[uint64](y) * stride + cast[uint64](x) * 4
            canvas[o]     = r
            canvas[o + 1] = g
            canvas[o + 2] = b
            x = x + 1
        y = y + 1


# Render one frame at zoom `zoom_pct` from the decoded raster (src,sw,sh) with
# fit-baseline (bw,bh); writes the PPM to `path`. Returns the on-screen image
# width (so main can assert the scale changed).
def _render(path: Ptr[char], src: Ptr[uint8], sw: uint64, sh: uint64,
            bw: uint64, bh: uint64, zoom_pct: int64) -> uint64:
    # backdrop + chrome bars, mirroring hamview's _paint_v2.
    _canvas_clear(43, 43, 43)
    _bar(0, BAR_TOP_H, 58, 58, 58)
    _bar(WIN_H - BAR_BOT_H, BAR_BOT_H, 58, 58, 58)
    dwv: Array[1, uint64]
    dhv: Array[1, uint64]
    imgscale_zoom_dims(bw, bh, zoom_pct, ZOOM_CAP, &dwv[0], &dhv[0])
    dw: uint64 = dwv[0]
    dh: uint64 = dhv[0]
    avail_top: int64 = BAR_TOP_H
    avail_h: int64 = (WIN_H - BAR_BOT_H) - avail_top
    px: int64 = (WIN_W - cast[int64](dw)) / 2
    py: int64 = avail_top + (avail_h - cast[int64](dh)) / 2
    stride: uint64 = cast[uint64](WIN_W) * 4
    imgscale_blit(src, sw, sh, &canvas[0], stride, px, py, dw, dh,
                  WIN_W, WIN_H)
    # PPM header "P6\n640 480\n255\n".
    hp: uint64 = 0
    ppm_hdr[hp] = 80                                     # 'P'
    hp = hp + 1
    ppm_hdr[hp] = 54                                     # '6'
    hp = hp + 1
    ppm_hdr[hp] = 10
    hp = hp + 1
    hp = _hdr_dec(hp, cast[uint64](WIN_W))
    ppm_hdr[hp] = 32
    hp = hp + 1
    hp = _hdr_dec(hp, cast[uint64](WIN_H))
    ppm_hdr[hp] = 10
    hp = hp + 1
    ppm_hdr[hp] = 50                                     # '2'
    hp = hp + 1
    ppm_hdr[hp] = 53                                     # '5'
    hp = hp + 1
    ppm_hdr[hp] = 53                                     # '5'
    hp = hp + 1
    ppm_hdr[hp] = 10
    hp = hp + 1
    fd: int32 = sys_open(path, 577, 420)                # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return dw
    sys_write(fd, &ppm_hdr[0], hp)
    # PPM is RGB (3 bytes/pixel); drop alpha as we stream rows.
    _write_rgb(fd)
    sys_close(fd)
    return dw


rgbrow: Array[1920, uint8]              # 640*3


def _write_rgb(fd: int32):
    stride: uint64 = cast[uint64](WIN_W) * 4
    y: int64 = 0
    while y < WIN_H:
        j: uint64 = 0
        x: int64 = 0
        while x < WIN_W:
            o: uint64 = cast[uint64](y) * stride + cast[uint64](x) * 4
            rgbrow[j]     = canvas[o]
            rgbrow[j + 1] = canvas[o + 1]
            rgbrow[j + 2] = canvas[o + 2]
            j = j + 3
            x = x + 1
        sys_write(fd, &rgbrow[0], j)
        y = y + 1


def _hdr_dec(pos: uint64, v: uint64) -> uint64:
    if v == 0:
        ppm_hdr[pos] = 48
        return pos + 1
    tmp: Array[24, uint8]
    t: uint64 = 0
    while v != 0:
        tmp[t] = cast[uint8](v % 10) + 48
        v = v / 10
        t = t + 1
    while t > 0:
        t = t - 1
        ppm_hdr[pos] = tmp[t]
        pos = pos + 1
    return pos


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str("usage: hamview_zoom_host IN.png OUT100.ppm OUT200.ppm\n")
        _o_flush()
        return 2
    n: int64 = _slurp(cast[Ptr[char]](argv[1]))
    if n <= 0:
        _o_str("hamview_zoom_host: cannot read input\n")
        _o_flush()
        return 1
    if png_decode(&png_bytes[0], cast[uint64](n)) < 0:
        _o_str("hamview_zoom_host: png decode failed\n")
        _o_flush()
        return 1
    sw: uint64 = cast[uint64](png_width())
    sh: uint64 = cast[uint64](png_height())
    src: Ptr[uint8] = png_rgba_ptr()
    # 100%-zoom fit baseline for the content area (matches hamview).
    bwv: Array[1, uint64]
    bhv: Array[1, uint64]
    avail_w: uint64 = cast[uint64](WIN_W)
    avail_h: uint64 = cast[uint64](WIN_H - BAR_TOP_H - BAR_BOT_H)
    imgscale_fit_dims(sw, sh, avail_w, avail_h, &bwv[0], &bhv[0])
    bw: uint64 = bwv[0]
    bh: uint64 = bhv[0]
    _o_str("src ")
    _o_dec(sw)
    _o_ch(120)                                          # 'x'
    _o_dec(sh)
    _o_str("  base ")
    _o_dec(bw)
    _o_ch(120)
    _o_dec(bh)
    _o_ch(10)
    w100: uint64 = _render(cast[Ptr[char]](argv[2]), src, sw, sh, bw, bh, 100)
    w200: uint64 = _render(cast[Ptr[char]](argv[3]), src, sw, sh, bw, bh, 200)
    _o_str("zoom 100% width ")
    _o_dec(w100)
    _o_str("  zoom 200% width ")
    _o_dec(w200)
    _o_ch(10)
    if w200 > w100:
        _o_str("ZOOM OK: 200% is wider than 100%\n")
    else:
        _o_str("ZOOM FAIL: 200% not wider than 100%\n")
    _o_flush()
    return 0

# user/top.ad
#
# Hamnix `top` — an interactive, auto-refreshing terminal monitor built
# from the three /proc snapshots that the M16.36+ kernel exposes:
#
#   /proc/uptime   - jiffies since boot
#   /proc/meminfo  - MemTotal / MemFree
#   /proc/tasks    - PID / state / comm columns
#
# TWO MODES
#   batch (top -b, top -bn1)   one-shot labelled dump, then exit 0. This
#       is the original behaviour — same banner, same blocks — so any
#       script that greps the snapshot keeps working byte-for-byte.
#   interactive (bare `top`)   the new default the DE Applications menu
#       launches via /bin/top. It owns the raw console exactly like
#       user/hamfm.ad: when hamsh (or the hamUId desktop daemon) spawns
#       it, fd 0/1/2 are the raw console with NO line-cooking and NO echo.
#       It reads one keystroke at a time off fd 0 with sys_read_nb +
#       sys_yield and repaints the whole screen with ANSI escapes,
#       auto-refreshing every few idle yields.
#
# interactive keys
#   q             quit (restores the cursor + clears the screen)
#   space / r     force an immediate refresh

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_yield() -> int32


CHUNK: uint64 = 256

# Idle sys_yield iterations between auto-refreshes. Kept simple and
# dependency-light: no new time syscalls, just a poll counter mirroring
# how hamfm yields when there is no input.
REFRESH_YIELDS: uint64 = 200000

running: int32 = 1


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def dump(path: Ptr[char]):
    # Open + drain + close. On open failure we emit a one-line
    # marker to stdout (not stderr) so the dashboard still scrolls
    # cleanly when a /proc entry is missing in a future kernel.
    fd: int32 = sys_open(path)
    if fd < 0:
        write_str(1, "(unavailable)\n")
        return
    buf: Array[256, uint8]
    while True:
        n: int64 = sys_read(fd, &buf[0], CHUNK)
        if n <= 0:
            break
        sys_write(1, &buf[0], cast[uint64](n))
    sys_close(fd)


# ====================================================================
# Batch (one-shot) path — UNCHANGED output contract
# ====================================================================
def batch_snapshot():
    # Header — fixed banner so scripts greping for "top -" still
    # find the snapshot.
    write_str(1, "top - one-shot snapshot (Hamnix)\n")
    write_str(1, "\n")

    # Uptime block. /proc/uptime emits one short line that ends
    # with a newline already.
    write_str(1, "Uptime: ")
    dump("/proc/uptime")

    # Mem block. Two header lines from /proc/meminfo (MemTotal,
    # MemFree). Real top also shows buffers/cached/swap; we have
    # none of those yet so omit the row instead of faking it.
    write_str(1, "\nMemory:\n")
    dump("/proc/meminfo")

    # Task table. /proc/tasks already comes out as a column-aligned
    # listing — we just prefix with a header line to match `top`'s
    # PID/STAT/COMMAND convention.
    write_str(1, "\nTasks:\n")
    write_str(1, "  PID S COMMAND\n")
    dump("/proc/tasks")


# ====================================================================
# Interactive rendering
# ====================================================================
# Drain a /proc file to stdout, but translate bare '\n' into "\r\n" and
# clear-to-end-of-line so the column layout survives the raw console
# (no kernel line-cooking does the carriage return for us).
def dump_raw(path: Ptr[char]):
    fd: int32 = sys_open(path)
    if fd < 0:
        write_str(1, "(unavailable)\r\n\x1b[K")
        return
    buf: Array[256, uint8]
    while True:
        n: int64 = sys_read(fd, &buf[0], CHUNK)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        i: uint64 = 0
        while i < nu:
            c: uint8 = buf[i]
            if c == 10:
                write_str(1, "\r\n\x1b[K")
            else:
                sys_write(1, cast[Ptr[uint8]](cast[uint64](&buf[0]) + i), 1)
            i = i + 1
    sys_close(fd)


def redraw():
    # Hide the cursor + home, like hamfm's redraw bracketing.
    write_str(1, "\x1b[?25l\x1b[H")

    # Header: reverse-video title bar.
    write_str(1, "\r\x1b[K\x1b[7m top - Hamnix  (q quit  space/r refresh) \x1b[0m\r\n\x1b[K")

    # Uptime line.
    write_str(1, "Uptime: ")
    dump_raw("/proc/uptime")

    # Memory block.
    write_str(1, "\r\n\x1b[KMemory:\r\n\x1b[K")
    dump_raw("/proc/meminfo")

    # Task table.
    write_str(1, "\r\n\x1b[KTasks:\r\n\x1b[K  PID S COMMAND\r\n\x1b[K")
    dump_raw("/proc/tasks")

    # Clear to the bottom so stale rows from a previous (longer) frame
    # never linger, then home + show the cursor.
    write_str(1, "\x1b[J\x1b[H\x1b[?25h")


def interactive():
    # Readiness banner: a stable plain-ASCII (no ANSI) line emitted ONCE
    # before the first repaint so a driving test can poll the serial log
    # and only send keystrokes once `top` owns the raw console — exactly
    # the way hamfm emits HAMFM_READY. Without this gate a slow cold boot
    # lets the launch + first keystrokes race hamsh's REPL.
    write_str(1, "TOP_READY\n")

    # Alt-clear the whole screen once, then paint the first frame.
    write_str(1, "\x1b[2J\x1b[H")
    redraw()

    rb: Array[1, uint8]
    idle: uint64 = 0
    while running != 0:
        n: int64 = sys_read_nb(0, &rb[0], 1)
        if n < 0:
            break
        if n == 0:
            sys_yield()
            idle = idle + 1
            if idle >= REFRESH_YIELDS:
                idle = 0
                redraw()
            continue
        c: uint8 = rb[0]
        idle = 0
        if c == 113:                    # 'q' — quit
            running = 0
        elif c == 32 or c == 114:       # space / 'r' — force refresh
            redraw()
        # Any other key is ignored (consume + keep running).

    # Restore the cursor and clear on exit, like hamfm.
    write_str(1, "\x1b[2J\x1b[H\x1b[?25h")


# ====================================================================
# Entry
# ====================================================================
# argv is read hamfm-style: each slot is a uint64 holding a Ptr[uint8]
# to a NUL-terminated string. We scan argv[1..argc) for a batch flag.
def is_batch_flag(s: Ptr[uint8]) -> int32:
    # Matches "-b" exactly or "-bn1" exactly (the two batch forms real
    # top uses); a leading "-b" is enough to select the one-shot path.
    if s[0] != 45:                      # '-'
        return 0
    if s[1] != 98:                      # 'b'
        return 0
    return 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    batch: int32 = 0
    i: int32 = 1
    while i < argc:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[i])
        if is_batch_flag(ap) != 0:
            batch = 1
        i = i + 1

    if batch != 0:
        batch_snapshot()
        return 0

    interactive()
    return 0

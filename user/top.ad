# user/top.ad
#
# Hamnix `top` — a Linux-style live process monitor.
#
# TWO MODES
#   batch (top -b, top -bn1)   one-shot labelled dump of the raw /proc
#       snapshots, then exit 0. Preserved byte-for-byte so any script that
#       greps the snapshot keeps working.
#   interactive (bare `top`)   a full-screen TUI: a summary header (uptime,
#       task counts, memory, load average) plus a process table sorted by
#       %CPU — PID, S, %CPU, %MEM, TIME+, COMMAND — that REPAINTS IN PLACE
#       every ~1.5 s until 'q'. This is the default the DE Applications menu
#       launches via /bin/top.
#
# The interactive frame is built by the pure model/renderer lib/toprender.ad
# from a SINGLE read of /proc/toptable (fs/procfs.ad :: render_toptable), which
# carries — in one atomic snapshot — the jiffy clock, MemTotal/MemFree, and one
# line per task with its cumulative CPU ticks, RSS and start jiffy. Two reads a
# refresh apart give the %CPU delta. /proc/loadavg supplies the load column.
#
# RAW KEY INPUT
#   A GUI terminal (user/hamtermscene.ad) does LOCAL line editing by default,
#   so a bare keystroke like 'q' would be buffered, not delivered. top opts into
#   the terminal's RAW-CHAR input mode with the private-mode escape ESC[?9002h
#   on entry (and ESC[?9002l on exit): while set, the terminal streams each
#   key-down byte straight to our stdin — exactly what our sys_read_nb(0) loop
#   wants. On a real VT (serial console) the escape is simply ignored and raw
#   keys already arrive, so the same binary drives both.
#
# interactive keys
#   q             quit (leaves raw mode, restores the cursor, clears the screen)
#   space / r     force an immediate refresh

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_yield() -> int32

from lib.toprender import tr_ingest, tr_render


CHUNK: uint64 = 4096

# Idle sys_yield iterations between auto-refreshes. Dependency-light: no time
# syscall, just a poll counter mirroring how hamfm yields when idle.
REFRESH_YIELDS: uint64 = 150000

running: int32 = 1

# Snapshot + loadavg read buffers and the assembled ANSI frame.
snap_buf:  Array[32768, uint8]
load_buf:  Array[128, uint8]
frame_buf: Array[32768, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def dump(path: Ptr[char]):
    # Open + drain + write to stdout (batch path). A missing entry emits a
    # one-line marker so the dashboard still scrolls cleanly.
    fd: int32 = sys_open(path)
    if fd < 0:
        write_str(1, cast[Ptr[uint8]]("(unavailable)\n"))
        return
    buf: Array[256, uint8]
    while True:
        n: int64 = sys_read(fd, &buf[0], 256)
        if n <= 0:
            break
        sys_write(1, &buf[0], cast[uint64](n))
    sys_close(fd)


# Read a whole /proc file into `buf` (up to cap). Returns bytes read (>=0).
def read_proc(path: Ptr[char], buf: Ptr[uint8], cap: uint64) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](buf) + total),
                            cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return total


# ====================================================================
# Batch (one-shot) path — UNCHANGED output contract
# ====================================================================
def batch_snapshot():
    write_str(1, cast[Ptr[uint8]]("top - one-shot snapshot (Hamnix)\n"))
    write_str(1, cast[Ptr[uint8]]("\n"))
    write_str(1, cast[Ptr[uint8]]("Uptime: "))
    dump(cast[Ptr[char]]("/proc/uptime"))
    write_str(1, cast[Ptr[uint8]]("\nMemory:\n"))
    dump(cast[Ptr[char]]("/proc/meminfo"))
    write_str(1, cast[Ptr[uint8]]("\nTasks:\n"))
    write_str(1, cast[Ptr[uint8]]("  PID S COMMAND\n"))
    dump(cast[Ptr[char]]("/proc/tasks"))


# ====================================================================
# Interactive rendering
# ====================================================================
def redraw():
    sn: uint64 = read_proc(cast[Ptr[char]]("/proc/toptable"),
                           &snap_buf[0], 32768)
    ln: uint64 = read_proc(cast[Ptr[char]]("/proc/loadavg"),
                           &load_buf[0], 128)
    tr_ingest(&snap_buf[0], sn)
    fn: uint64 = tr_render(&frame_buf[0], 32768, &load_buf[0], ln)
    sys_write(1, &frame_buf[0], fn)


def interactive():
    # Readiness banner: a stable plain-ASCII line before the first repaint so a
    # driving test can poll the serial log and only send keystrokes once top
    # owns the raw console (mirrors hamfm's HAMFM_READY gate).
    write_str(1, cast[Ptr[uint8]]("TOP_READY\n"))

    # Request the GUI terminal's raw-char key mode (ignored by a real VT), hide
    # the cursor, and clear the screen for the first in-place frame.
    write_str(1, cast[Ptr[uint8]]("\x1b[?9002h\x1b[?25l\x1b[2J"))
    redraw()

    rb: Array[1, uint8]
    idle: uint64 = 0
    while running != 0:
        n: int64 = sys_read_nb(0, &rb[0], 1)
        if n < 0:
            break
        if n == 0:
            sys_yield()
            idle = idle + 1
            if idle >= REFRESH_YIELDS:
                idle = 0
                redraw()
            continue
        c: uint8 = rb[0]
        idle = 0
        if c == 113:                    # 'q' — quit
            running = 0
        elif c == 32 or c == 114:       # space / 'r' — force refresh
            redraw()
        # Any other key is ignored.

    # Leave raw mode, restore the cursor, and clear on exit.
    write_str(1, cast[Ptr[uint8]]("\x1b[?9002l\x1b[2J\x1b[H\x1b[?25h"))


# ====================================================================
# Entry
# ====================================================================
def is_batch_flag(s: Ptr[uint8]) -> int32:
    if s[0] != 45:                      # '-'
        return 0
    if s[1] != 98:                      # 'b'
        return 0
    return 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    batch: int32 = 0
    i: int32 = 1
    while i < argc:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[i])
        if is_batch_flag(ap) != 0:
            batch = 1
        i = i + 1

    if batch != 0:
        batch_snapshot()
        return 0

    interactive()
    return 0

# user/install.ad
#
# `install` — the Hamnix system installer command. Type `install` at a
# hamsh prompt on the install medium and it ENUMERATES the available
# disks, PROMPTS which one to install onto, CONFIRMS (the install is
# destructive), then lays down a fresh, independently-bootable Hamnix
# system onto the chosen disk — Debian-installer style.
#
# THE DEBIAN MODEL (not a block copy). The root filesystem is NOT a dd
# of a golden image. Instead this command:
#   1. partitions the target disk      (GPT + ESP + ext4 root)
#   2. mkfs's the ESP (FAT) + root (ext4)
#   3. lays the bootloader/kernel onto the ESP (FAT byte-copy — there is
#      no per-file FAT writer yet; the ESP is the only byte-copied part)
#   4. installs the BASE SYSTEM as PACKAGES onto the freshly-formatted
#      ext4 root via the native package manager:
#        hpm --repo=file:///iso-packages --target-dev=<rootpart> \
#            refresh ; install hamnix-base
#      hpm unpacks each package's files onto the target ext4 partition
#      through the kernel `install_file` ctl verb (the same primitive
#      install_rootfs_from_manifest uses), and writes the installed-
#      package DB onto the target root. This is a real package install
#      (debootstrap-shape), not a golden-image stream.
#
# Usage:
#   install                       interactive: list disks, prompt, confirm
#   install --auto_mode                unattended: pick the first non-root disk
#   install --auto_mode <disk>         unattended: install onto <disk>
#   install <disk>                interactive confirm on <disk>, then go
#
#   <disk> may be a bare name ("nvme0n1") or "/dev/blk/nvme0n1". It MUST
#   be a whole disk (a GPT is written to it), never a partition.
#
# Options:
#   --auto_mode              unattended mode — no prompts. Picks the first
#                       non-root whole disk if no <disk> is given. This
#                       is what the install medium auto_mode-runs on the
#                       keyboard-less NUC (etc/install_nvme.hamsh).
#   --esp-mb <n>        ESP size in MiB (default 64; must match the
#                       shipped esp.img size in the squashfs payload).
#   --repo <url>        package repo for the base install
#                       (default file:///iso-packages).
#   --base <pkg>        base metapackage to install (default hamnix-base).
#   --esp-img <name>    inner squashfs file for the ESP byte-copy
#                       (default esp.img); streamed via sqfs_to_blk.
#   --sqfs <path>       in-RAM squashfs holding the ESP image
#                       (default /rootfs.sqfs).
#
# SAFETY: the kernel exposes the BASE DISK backing the live root FS at
# /dev/blk/rootdev. This command reads it and (a) excludes that disk
# from the interactive picker and the --auto_mode default, and (b) REFUSES
# to install onto it even if named explicitly. Repartitioning the disk
# we are running from can never be safe.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_get_jiffies() -> uint64


# --- string helpers -------------------------------------------------

from lib.p9 import spawn, p9_listdir
from lib.crypt.sha512_crypt import sha512_crypt

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def strcpy(dst: Ptr[uint8], src: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while src[i] != 0:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0
    return i


def streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


def starts_with(s: Ptr[uint8], pfx: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while pfx[i] != 0:
        if s[i] != pfx[i]:
            return 0
        i = i + 1
    return 1


def render_u64(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        out[1] = 0
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    out[i] = 0
    return written


def parse_u64(s: Ptr[uint8]) -> uint64:
    v: uint64 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c - 48)
        i = i + 1
    return v


def bare_name(arg: Ptr[uint8], out: Ptr[uint8]):
    src: Ptr[uint8] = arg
    if starts_with(arg, cast[Ptr[uint8]]("/dev/blk/")) == 1:
        src = cast[Ptr[uint8]](cast[uint64](arg) + 9)
    strcpy(out, src)


def make_blk_path(bare: Ptr[uint8], out: Ptr[uint8]):
    n: uint64 = strcpy(out, cast[Ptr[uint8]]("/dev/blk/"))
    i: uint64 = 0
    while bare[i] != 0:
        out[n + i] = bare[i]
        i = i + 1
    out[n + i] = 0


def make_part_path(bare: Ptr[uint8], pnum: uint64, out: Ptr[uint8]):
    # "/dev/blk/<bare>p<pnum>"
    n: uint64 = strcpy(out, cast[Ptr[uint8]]("/dev/blk/"))
    i: uint64 = 0
    while bare[i] != 0:
        out[n + i] = bare[i]
        i = i + 1
    n = n + i
    out[n] = 0x70                                     # 'p'
    n = n + 1
    scratch: Array[8, uint8]
    m: uint64 = render_u64(pnum, &scratch[0])
    j: uint64 = 0
    while j < m:
        out[n + j] = scratch[j]
        j = j + 1
    out[n + m] = 0


# --- whole-disk detection -------------------------------------------
#
# A name is a WHOLE disk (not a partition) if it does NOT end in
# "p<digits>" preceded by a non-digit. We treat the common forms:
#   nvme0n1   -> disk ;  nvme0n1p1 -> partition
#   vda       -> disk ;  vdap1     -> partition (Hamnix GPT naming)
#   sda       -> disk ;  sda1 / sdap1 -> partition
# Heuristic: a trailing run of digits immediately preceded by 'p' marks
# a partition. We also reject a bare trailing-digit-after-letter for the
# sd* family (sda1). nvme0n1 ends in a digit but the digit run is NOT
# preceded by 'p', so it stays a disk.

def is_partition(name: Ptr[uint8]) -> int32:
    n: uint64 = strlen_u8(name)
    if n == 0:
        return 1
    # Find trailing digit run.
    e: uint64 = n
    while e > 0:
        c: uint8 = name[e - 1]
        if c < 48 or c > 57:
            break
        e = e - 1
    if e == n:
        return 0                                       # no trailing digits
    # name[e..n) is the trailing digit run; name[e-1] is the char before.
    if e == 0:
        return 0                                       # all digits — odd; treat as disk
    before: uint8 = name[e - 1]
    if before == 0x70:                                 # 'p'  -> "...pN"
        return 1
    # sd*/hd* style "sda1": before is a letter a-z and the prefix is
    # exactly 3 chars (sd + letter). Be conservative: only flag when the
    # whole stem before the digits is <=3 chars of letters (sda, hdb).
    if e <= 3:
        allalpha: int32 = 1
        k: uint64 = 0
        while k < e:
            lc: uint8 = name[k]
            if lc < 97 or lc > 122:
                allalpha = 0
                break
            k = k + 1
        if allalpha != 0:
            return 1
    return 0


# --- safety guard: live root disk -----------------------------------

root_name_buf: Array[40, uint8]


def read_live_root(out: Ptr[uint8]) -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/blk/rootdev"))
    if fd < 0:
        return 0
    buf: Array[40, uint8]
    n: int64 = sys_read(fd, &buf[0], 39)
    sys_close(fd)
    if n <= 0:
        return 0
    ln: uint64 = cast[uint64](n)
    while ln > 0 and (buf[ln - 1] == 10 or buf[ln - 1] == 13
                      or buf[ln - 1] == 32):
        ln = ln - 1
    if ln == 0:
        return 0
    i: uint64 = 0
    while i < ln:
        out[i] = buf[i]
        i = i + 1
    out[ln] = 0
    return 1


# --- disk size readback (sectors) -----------------------------------

def read_disk_size(bare: Ptr[uint8]) -> uint64:
    # Read /dev/blk/<bare>/size -> capacity in 512-byte sectors. 0 if
    # unreadable.
    path: Array[160, uint8]
    p: uint64 = strcpy(&path[0], cast[Ptr[uint8]]("/dev/blk/"))
    i: uint64 = 0
    while bare[i] != 0:
        path[p + i] = bare[i]
        i = i + 1
    p = p + i
    suf: Ptr[uint8] = "/size"
    j: uint64 = 0
    while suf[j] != 0:
        path[p + j] = suf[j]
        j = j + 1
    path[p + j] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&path[0]))
    if fd < 0:
        return 0
    sbuf: Array[64, uint8]
    n: int64 = sys_read(fd, &sbuf[0], 63)
    sys_close(fd)
    if n <= 0:
        return 0
    sbuf[cast[uint64](n)] = 0
    return parse_u64(&sbuf[0])


# --- boot-medium detection (the live install medium) ----------------
#
# The install medium's ESP (partition 1) is mkfs'd with the FAT volume
# label "HAMNIXINST" (scripts/build_installer_img.sh, `mformat -v`); the
# installed-target ESP uses "HAMNIX". Reading partition 1's FAT boot
# sector and matching BS_VolLab lets the installer identify — and refuse
# to wipe — the very medium it booted from. In a VM the install image is
# attached as an ordinary (virtio) disk that DOES enumerate under
# /dev/blk, so without this guard `--auto` would pick the boot medium
# itself and erase the running installer (the #410 self-clobber). On the
# keyboard-less NUC the USB boot medium is NOT block-enumerable, so only
# the blank NVMe target appears — there the auto-install is still valid.

def bytes_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


sector0_buf: Array[512, uint8]


def is_boot_medium(bare: Ptr[uint8]) -> int32:
    # True if whole-disk <bare>'s ESP (partition 1) carries the install-
    # medium FAT volume label "HAMNIXINST". FAT12/FAT16 keep BS_VolLab at
    # boot-sector offset 43; FAT32 at offset 71 — check both.
    p1: Array[80, uint8]
    make_part_path(bare, 1, &p1[0])
    fd: int32 = sys_open(cast[Ptr[char]](&p1[0]))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &sector0_buf[0], 512)
    sys_close(fd)
    if n < 512:
        return 0
    tag: Ptr[uint8] = "HAMNIXINST"
    if bytes_eq(cast[Ptr[uint8]](cast[uint64](&sector0_buf[0]) + 43),
                tag, 10) == 1:
        return 1
    if bytes_eq(cast[Ptr[uint8]](cast[uint64](&sector0_buf[0]) + 71),
                tag, 10) == 1:
        return 1
    return 0


# --- disk enumeration -----------------------------------------------
#
# disk_names packs each candidate WHOLE-disk bare name back-to-back,
# NUL-terminated; disk_off[i] indexes it. The live-root disk is
# excluded entirely.

MAX_DISKS: uint64 = 32
disk_off:    Array[32, uint64]
disk_names:  Array[2048, uint8]
disk_names_n: uint64 = 0
n_disks:     uint64 = 0
listdir_buf: Array[8192, uint8]


def disk_name_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&disk_names[0]) + disk_off[i])


def _name_starts_with(s: Ptr[uint8], prefix: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while prefix[i] != 0:
        if s[i] != prefix[i]:
            return 0
        i = i + 1
    return 1


def is_ram_backed(name: Ptr[uint8]) -> int32:
    # RAM/file-backed pseudo-disks are NEVER install targets:
    #   ram*   baked-in / dynamic RAM block devices (brd.ad)
    #   loop*  file-backed loop devices (loop.ad)
    #   live*  the LIVE-medium distro ramdisk (#410 Item 2) — offering
    #          it would let the installer clobber the very environment
    #          it is running from, and `install --probe` would wrongly
    #          report an install target on a pure live boot.
    if _name_starts_with(name, cast[Ptr[uint8]]("ram")) == 1:
        return 1
    if _name_starts_with(name, cast[Ptr[uint8]]("loop")) == 1:
        return 1
    if _name_starts_with(name, cast[Ptr[uint8]]("live")) == 1:
        return 1
    return 0


def enumerate_disks(exclude_root: Ptr[uint8], have_root: int32) -> int32:
    # Populate disk_* with every WHOLE disk under /dev/blk except the
    # live-root disk. Returns the count.
    n_disks = 0
    disk_names_n = 0
    n: int64 = p9_listdir(cast[Ptr[char]]("/dev/blk"),
                           &listdir_buf[0], 8192)
    if n < 0:
        return 0
    name: Array[64, uint8]
    nl: uint64 = 0
    i: uint64 = 0
    total: uint64 = cast[uint64](n)
    while i < total:
        c: uint8 = listdir_buf[i]
        if c == 10:
            name[nl] = 0
            if nl > 0:
                # Skip control pseudo-files (rootdev) and partitions.
                keep: int32 = 1
                if streq(&name[0], cast[Ptr[uint8]]("rootdev")) == 1:
                    keep = 0
                if keep != 0 and is_partition(&name[0]) != 0:
                    keep = 0
                # RAM/loop/live pseudo-disks are never install targets.
                if keep != 0 and is_ram_backed(&name[0]) != 0:
                    keep = 0
                if keep != 0 and have_root != 0 \
                        and streq(&name[0], exclude_root) == 1:
                    keep = 0
                # Never offer the disk we booted from (the live medium).
                if keep != 0 and is_boot_medium(&name[0]) != 0:
                    keep = 0
                if keep != 0 and n_disks < MAX_DISKS:
                    disk_off[n_disks] = disk_names_n
                    k: uint64 = 0
                    while name[k] != 0 and disk_names_n + 1 < 2048:
                        disk_names[disk_names_n] = name[k]
                        disk_names_n = disk_names_n + 1
                        k = k + 1
                    disk_names[disk_names_n] = 0
                    disk_names_n = disk_names_n + 1
                    n_disks = n_disks + 1
            nl = 0
        else:
            if nl < 63:
                name[nl] = c
                nl = nl + 1
        i = i + 1
    return cast[int32](n_disks)


def print_disk_table():
    write_str(1, "  #   DEVICE             SIZE\n")
    i: uint64 = 0
    while i < n_disks:
        np: Ptr[uint8] = disk_name_ptr(i)
        numbuf: Array[8, uint8]
        render_u64(i + 1, &numbuf[0])
        write_str(1, "  ")
        write_str(1, &numbuf[0])
        write_str(1, "   /dev/blk/")
        write_str(1, np)
        # pad the device column.
        nlen: uint64 = strlen_u8(np)
        pad: uint64 = nlen
        while pad < 10:
            write_str(1, " ")
            pad = pad + 1
        write_str(1, "  ")
        sectors: uint64 = read_disk_size(np)
        mib: uint64 = (sectors / 2048)               # 512B sectors -> MiB
        mbuf: Array[24, uint8]
        render_u64(mib, &mbuf[0])
        write_str(1, &mbuf[0])
        write_str(1, " MiB\n")
        i = i + 1


# --- stdin line read (interactive prompt) ---------------------------

line_in: Array[128, uint8]


def read_line() -> int64:
    # Read one line from stdin into line_in (NUL-terminated, newline
    # stripped). Returns the length, or -1 on EOF/error.
    n: int64 = sys_read(0, &line_in[0], 127)
    if n <= 0:
        return cast[int64](-1)
    ln: uint64 = cast[uint64](n)
    while ln > 0 and (line_in[ln - 1] == 10 or line_in[ln - 1] == 13):
        ln = ln - 1
    line_in[ln] = 0
    return cast[int64](ln)


# --- spawn a tool ---------------------------------------------------

step_argv: Array[8, uint64]
tool_path_buf: Array[64, uint8]


def run_tool4(toolname: Ptr[uint8], a1: Ptr[uint8], a2: Ptr[uint8],
              a3: Ptr[uint8], a4: Ptr[uint8]) -> int32:
    n: uint64 = strcpy(&tool_path_buf[0], cast[Ptr[uint8]]("/bin/"))
    i: uint64 = 0
    while toolname[i] != 0:
        tool_path_buf[n + i] = toolname[i]
        i = i + 1
    tool_path_buf[n + i] = 0
    ai: uint64 = 0
    step_argv[ai] = cast[uint64](&tool_path_buf[0])
    ai = ai + 1
    if cast[uint64](a1) != 0:
        step_argv[ai] = cast[uint64](a1)
        ai = ai + 1
    if cast[uint64](a2) != 0:
        step_argv[ai] = cast[uint64](a2)
        ai = ai + 1
    if cast[uint64](a3) != 0:
        step_argv[ai] = cast[uint64](a3)
        ai = ai + 1
    if cast[uint64](a4) != 0:
        step_argv[ai] = cast[uint64](a4)
        ai = ai + 1
    step_argv[ai] = 0
    pid: int32 = spawn(cast[Ptr[char]](&tool_path_buf[0]),
                           &step_argv[0], 0, 1,
                           cast[Ptr[uint64]](0))
    if pid < 0:
        write_str(2, "install: spawn failed for ")
        write_str(2, &tool_path_buf[0])
        write_str(2, "\n")
        return -1
    code: int64 = sys_waitpid(pid)
    return cast[int32](code)


# hpm takes its own flags as separate argv tokens; build a dedicated
# spawn that passes 5 args.
hpm_argv: Array[8, uint64]


def run_hpm(a1: Ptr[uint8], a2: Ptr[uint8], a3: Ptr[uint8],
            a4: Ptr[uint8], a5: Ptr[uint8]) -> int32:
    # Spawn /bin/hpm with up to five args.
    path: Ptr[uint8] = "/bin/hpm"
    ai: uint64 = 0
    hpm_argv[ai] = cast[uint64](path)
    ai = ai + 1
    if cast[uint64](a1) != 0:
        hpm_argv[ai] = cast[uint64](a1)
        ai = ai + 1
    if cast[uint64](a2) != 0:
        hpm_argv[ai] = cast[uint64](a2)
        ai = ai + 1
    if cast[uint64](a3) != 0:
        hpm_argv[ai] = cast[uint64](a3)
        ai = ai + 1
    if cast[uint64](a4) != 0:
        hpm_argv[ai] = cast[uint64](a4)
        ai = ai + 1
    if cast[uint64](a5) != 0:
        hpm_argv[ai] = cast[uint64](a5)
        ai = ai + 1
    hpm_argv[ai] = 0
    pid: int32 = spawn(cast[Ptr[char]](path), &hpm_argv[0], 0, 1,
                           cast[Ptr[uint64]](0))
    if pid < 0:
        write_str(2, "install: spawn failed for /bin/hpm\n")
        return -1
    code: int64 = sys_waitpid(pid)
    return cast[int32](code)


# --- buffers --------------------------------------------------------

target_bare:  Array[32, uint8]
target_disk:  Array[64, uint8]
target_p1:    Array[64, uint8]
target_p2:    Array[64, uint8]
esp_mb_str:   Array[16, uint8]
repo_flag:    Array[256, uint8]            # "--repo=file:///iso-packages"
tdev_flag:    Array[96, uint8]             # "--target-dev=/dev/blk/...p2"
base_pkg:     Array[64, uint8]
esp_img_buf:  Array[64, uint8]
sqfs_buf:     Array[128, uint8]
repo_url:     Array[160, uint8]            # bare URL for messages
part_mode:    Array[16, uint8]             # "guided" (default) | "manual"


# --- .hamnix-roots sentinel -----------------------------------------
#
# The kernel discovers the installed ext4 root by its 0xEF53 magic and
# reads `.hamnix-roots` at the partition root to learn which named-root
# subtrees it carries (docs/rootfs_partition.md). It then `bind`s
# `#sysroot` at `/` and ELF-loads `/init` off the partition. WITHOUT a
# sentinel the partition registers only as an anonymous `#part<N>`, the
# `bind '#sysroot' /` fails, and boot degrades to the baked
# `user_demo_entry` fallback — which is an unmapped kernel-high address,
# so the first task SMEP/exec-faults (pid exits 139) before reaching a
# shell. That is exactly the installed-disk NX-exec-fault class.
#
# `hpm install hamnix-base --target-dev=<p2>` lays the native userland
# FLAT at the partition root (`/init`, `/bin`, `/etc`, ...). We therefore
# declare `sysroot .` — the whole-partition named root. `_freeze_named_
# source` (chan.ad) treats a relpath of "." as "prepend nothing", so
# `#sysroot`-bound `/init` freezes to `#by-id/<partuuid>/init` and
# composes to `/ext/init` — the flat file the installer actually wrote.
# (The multi-subtree `sysroot sysroot` layout that build_rootfs_img.py
# stages is the other supported shape; a package install produces the
# flat one, which the kernel supports via the "." whole-partition case.)
sentinel_ctl_buf: Array[96, uint8]
sentinel_wire_buf: Array[128, uint8]


def write_hamnix_roots(p2: Ptr[uint8]) -> int32:
    # Write a `.hamnix-roots` sentinel declaring the flat whole-partition
    # native root onto the freshly-populated target ext4 partition, via
    # the same `<dev>/ctl install_file` verb hpm uses. Returns 0 on
    # success, -1 on failure.
    #
    # Compose "<p2>/ctl".
    n: uint64 = 0
    while p2[n] != 0 and n < 80:
        sentinel_ctl_buf[n] = p2[n]
        n = n + 1
    ctl: Ptr[uint8] = cast[Ptr[uint8]]("/ctl")
    ci: uint64 = 0
    while ctl[ci] != 0:
        sentinel_ctl_buf[n] = ctl[ci]
        n = n + 1
        ci = ci + 1
    sentinel_ctl_buf[n] = 0

    fd: int32 = sys_open_write(cast[Ptr[char]](&sentinel_ctl_buf[0]))
    if fd < 0:
        write_str(2, "[install] FAIL: cannot open target ctl for sentinel: ")
        write_str(2, &sentinel_ctl_buf[0])
        write_str(2, "\n")
        return -1

    # Body = "sysroot .\n" (10 bytes). Wire = "install_file .hamnix-roots
    # 10\n" + body, one write (the kernel parses the header then reads
    # <len> body bytes from the same buffer, matching hpm's format).
    body: Ptr[uint8] = cast[Ptr[uint8]]("sysroot .\n")
    body_len: uint64 = strlen_u8(body)
    hdr: Ptr[uint8] = cast[Ptr[uint8]]("install_file .hamnix-roots ")
    pos: uint64 = 0
    hi: uint64 = 0
    while hdr[hi] != 0:
        sentinel_wire_buf[pos] = hdr[hi]
        pos = pos + 1
        hi = hi + 1
    # Decimal body length (small; single/double digit).
    ld: Array[24, uint8]
    ln: uint64 = 0
    bv: uint64 = body_len
    if bv == 0:
        sentinel_wire_buf[pos] = 48
        pos = pos + 1
    else:
        while bv != 0:
            ld[ln] = cast[uint8](bv % 10) + 48
            bv = bv / 10
            ln = ln + 1
        while ln > 0:
            ln = ln - 1
            sentinel_wire_buf[pos] = ld[ln]
            pos = pos + 1
    sentinel_wire_buf[pos] = 10                       # '\n'
    pos = pos + 1
    bi: uint64 = 0
    while bi < body_len:
        sentinel_wire_buf[pos] = body[bi]
        pos = pos + 1
        bi = bi + 1

    wn: int64 = sys_write(fd, &sentinel_wire_buf[0], pos)
    sys_close(fd)
    if wn < 0:
        write_str(2, "[install] FAIL: sentinel install_file write rejected\n")
        return -1
    return 0


# ====================================================================
# TARGET-SYSTEM PROVISIONING (wizard inputs -> installed /etc)
# ====================================================================
#
# Debian-installer-style account + hostname setup. The wizard front-end
# (haminstallui) — or a scripted `install` invocation — passes the
# collected values as flags:
#     --hostname <name>
#     --user <name>        (the regular install user; uid 1000)
#     --user-pass <pw>     (that user's login password)
#     --root-pass <pw>     (the hostowner / uid-1 admin password)
#
# After the base package install lays down the target root, we WRITE the
# collected values onto the TARGET ext4 partition — NOT the live root —
# via the same `<dev>/ctl install_file` verb hpm + write_hamnix_roots
# use. Passwords are hashed HERE in userland via lib/crypt sha512_crypt
# (the same $6$ scheme the kernel /dev/auth setpass verb produces) and
# the composed /etc/shadow lands on the target. /dev/auth is NOT usable
# for this: it rewrites the LIVE shadow, and the installer's target is a
# freshly-formatted disk that is not the running root.
#
# When NO provisioning flag is given (the unattended `install --auto`
# path the tests drive), NONE of this runs — the base package's shipped
# /etc/passwd + /etc/shadow are left exactly as installed, reproducing
# today's behavior byte-for-byte.

prov_hostname:   Array[64, uint8]
prov_user:       Array[64, uint8]
prov_user_pass:  Array[128, uint8]
prov_root_pass:  Array[128, uint8]
have_hostname:   int32 = 0
have_user:       int32 = 0
have_user_pass:  int32 = 0
have_root_pass:  int32 = 0

# Wire scratch for install_file onto the target ctl + composed file
# bodies (passwd/shadow are well under one 4 KiB page).
prov_ctl_path:  Array[96, uint8]
prov_wire:      Array[4096, uint8]
prov_body:      Array[2048, uint8]
prov_salt:      Array[24, uint8]
prov_hash:      Array[160, uint8]
prov_hash2:     Array[160, uint8]


def prov_gen_salt():
    # Compose a "$6$<12 chars>" salt prefix into prov_salt (NUL-term).
    # The chars are drawn from the crypt base-64 alphabet, seeded from a
    # /dev/random read (falling back to the jiffy clock). An installer
    # salt only needs to be present + reasonably unique per account.
    alpha: Ptr[uint8] = \
        "./0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
    seed: Array[16, uint8]
    got: int32 = 0
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/random"))
    if rfd >= 0:
        rn: int64 = sys_read(rfd, &seed[0], 16)
        sys_close(rfd)
        if rn == 16:
            got = 1
    if got == 0:
        j: uint64 = sys_get_jiffies()
        i0: uint64 = 0
        while i0 < 16:
            j = j * 1103515245 + 12345
            seed[i0] = cast[uint8]((j / 65536) & 255)
            i0 = i0 + 1
    prov_salt[0] = 36                                    # '$'
    prov_salt[1] = 54                                    # '6'
    prov_salt[2] = 36                                    # '$'
    i: uint64 = 0
    while i < 12:
        prov_salt[3 + i] = alpha[cast[uint64](seed[i]) & 63]
        i = i + 1
    prov_salt[15] = 0


def prov_install_file(p2: Ptr[uint8], relpath: Ptr[uint8],
                      body: Ptr[uint8], body_len: uint64) -> int32:
    # Write `body[0..body_len)` to `relpath` (relative to the partition
    # root, e.g. "etc/passwd") on the target ext4 via the `<p2>/ctl`
    # install_file verb. Returns 0 on success, -1 on failure.
    n: uint64 = 0
    while p2[n] != 0 and n < 80:
        prov_ctl_path[n] = p2[n]
        n = n + 1
    ctl: Ptr[uint8] = "/ctl"
    ci: uint64 = 0
    while ctl[ci] != 0:
        prov_ctl_path[n] = ctl[ci]
        n = n + 1
        ci = ci + 1
    prov_ctl_path[n] = 0

    fd: int32 = sys_open_write(cast[Ptr[char]](&prov_ctl_path[0]))
    if fd < 0:
        write_str(2, "[install] FAIL: cannot open target ctl for ")
        write_str(2, relpath)
        write_str(2, "\n")
        return -1

    # Wire = "install_file <relpath> <len>\n<body>".
    pos: uint64 = 0
    hdr: Ptr[uint8] = "install_file "
    hi: uint64 = 0
    while hdr[hi] != 0:
        prov_wire[pos] = hdr[hi]
        pos = pos + 1
        hi = hi + 1
    ri: uint64 = 0
    while relpath[ri] != 0:
        prov_wire[pos] = relpath[ri]
        pos = pos + 1
        ri = ri + 1
    prov_wire[pos] = 32                                   # ' '
    pos = pos + 1
    pos = pos + render_u64(body_len, &prov_wire[pos])
    prov_wire[pos] = 10                                   # '\n'
    pos = pos + 1
    bi: uint64 = 0
    while bi < body_len and pos < 4096:
        prov_wire[pos] = body[bi]
        pos = pos + 1
        bi = bi + 1

    wn: int64 = sys_write(fd, &prov_wire[0], pos)
    sys_close(fd)
    if wn < 0:
        write_str(2, "[install] FAIL: install_file write rejected for ")
        write_str(2, relpath)
        write_str(2, "\n")
        return -1
    return 0


def _body_puts(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0 and pos < 2048:
        prov_body[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


# --- /etc/skel-style home skeleton for the provisioned user ----------
#
# The installer writes /etc/passwd + /home/<user> directly (the user is
# NOT created via `useradd`, so useradd::make_home_skel never runs for
# the installed account). Without this, a freshly-installed home is an
# empty directory — no Desktop/Documents/Downloads/Pictures, no files.
# We plant the SAME standard skeleton that ships in the tree at
# `etc/skel/` (and, via gen_install_manifest.py, as /etc/skel on the
# installed system for any FUTURE useradd). Keep this dir list in sync
# with etc/skel/ and useradd.ad::make_home_skel / build_initramfs.py.
#
# Every path the installer lays down is stamped with the installer's own
# uid (hostowner, uid 1) by the ext4 create path, so after planting each
# we `chown 1000` it through the target ctl verb — the regular install
# user (uid 1000) must OWN its home + skel, not the installer.
PROV_USER_UID: Array[5, uint8] = "1000"

prov_skel_path:  Array[256, uint8]      # composed "home/<user>/<sub>[/<leaf>]"
prov_chown_cmd:  Array[320, uint8]      # composed "chown <uid> <path>\n"


def _prov_home_path(sub: Ptr[uint8], leaf: Ptr[uint8]) -> uint64:
    # Compose "home/<user>/<sub>/<leaf>" into prov_skel_path (NUL-term).
    # An empty `sub` or `leaf` omits that component (so "" / "" yields
    # just "home/<user>"). Returns the length (excluding the NUL).
    pos: uint64 = 0
    pre: Ptr[uint8] = "home/"
    i: uint64 = 0
    while pre[i] != 0:
        prov_skel_path[pos] = pre[i]
        pos = pos + 1
        i = i + 1
    ulen: uint64 = strlen_u8(&prov_user[0])
    i = 0
    while i < ulen and pos < 200:
        prov_skel_path[pos] = prov_user[i]
        pos = pos + 1
        i = i + 1
    if sub[0] != 0:
        prov_skel_path[pos] = 47                          # '/'
        pos = pos + 1
        i = 0
        while sub[i] != 0 and pos < 240:
            prov_skel_path[pos] = sub[i]
            pos = pos + 1
            i = i + 1
    if leaf[0] != 0:
        prov_skel_path[pos] = 47                          # '/'
        pos = pos + 1
        i = 0
        while leaf[i] != 0 and pos < 250:
            prov_skel_path[pos] = leaf[i]
            pos = pos + 1
            i = i + 1
    prov_skel_path[pos] = 0
    return pos


def prov_chown(p2: Ptr[uint8], relpath: Ptr[uint8]) -> int32:
    # Set the owner of `relpath` (partition-relative) on the target ext4
    # to uid 1000 via the `<p2>/ctl` "chown <uid> <path>" verb. Best-
    # effort: returns 0 on success, -1 on failure. Reuses prov_ctl_path
    # to compose "<p2>/ctl".
    n: uint64 = 0
    while p2[n] != 0 and n < 80:
        prov_ctl_path[n] = p2[n]
        n = n + 1
    ctl: Ptr[uint8] = "/ctl"
    ci: uint64 = 0
    while ctl[ci] != 0:
        prov_ctl_path[n] = ctl[ci]
        n = n + 1
        ci = ci + 1
    prov_ctl_path[n] = 0
    fd: int32 = sys_open_write(cast[Ptr[char]](&prov_ctl_path[0]))
    if fd < 0:
        return -1
    # "chown 1000 <relpath>\n"
    pos: uint64 = 0
    hdr: Ptr[uint8] = "chown "
    hi: uint64 = 0
    while hdr[hi] != 0:
        prov_chown_cmd[pos] = hdr[hi]
        pos = pos + 1
        hi = hi + 1
    ui: uint64 = 0
    while PROV_USER_UID[ui] != 0:
        prov_chown_cmd[pos] = PROV_USER_UID[ui]
        pos = pos + 1
        ui = ui + 1
    prov_chown_cmd[pos] = 32                               # ' '
    pos = pos + 1
    ri: uint64 = 0
    while relpath[ri] != 0 and pos < 318:
        prov_chown_cmd[pos] = relpath[ri]
        pos = pos + 1
        ri = ri + 1
    prov_chown_cmd[pos] = 10                               # '\n'
    pos = pos + 1
    wn: int64 = sys_write(fd, &prov_chown_cmd[0], pos)
    sys_close(fd)
    if wn < 0:
        return -1
    return 0


def prov_plant_skel_dir(p2: Ptr[uint8], sub: Ptr[uint8]) -> int32:
    # Materialise home/<user>/<sub>/ on the target (via a .keep marker —
    # install_file mkdir -p's the parent chain) and chown the directory
    # to the install user. Returns 0 on success, -1 on any failure.
    _prov_home_path(sub, cast[Ptr[uint8]](".keep"))
    rc: int32 = 0
    if prov_install_file(p2, &prov_skel_path[0],
                         cast[Ptr[uint8]](&prov_skel_path[0]), 0) != 0:
        rc = -1
    # chown the directory itself (home/<user>/<sub>) to uid 1000.
    _prov_home_path(sub, cast[Ptr[uint8]](""))
    if prov_chown(p2, &prov_skel_path[0]) != 0:
        rc = -1
    return rc


def prov_compose_passwd() -> uint64:
    # Compose the installed /etc/passwd into prov_body. Fixed system
    # accounts (hostowner + sshd + hamsh-svc + nobody) plus the chosen
    # regular install user at uid 1000. Returns the length.
    pos: uint64 = 0
    pos = _body_puts(pos, cast[Ptr[uint8]](
        "hostowner:x:1:1::/home/hostowner:/bin/hamsh\n"))
    pos = _body_puts(pos, cast[Ptr[uint8]](
        "sshd:x:2:2::/var/empty:/bin/false\n"))
    pos = _body_puts(pos, cast[Ptr[uint8]](
        "hamsh-svc:x:3:3::/var/empty:/bin/false\n"))
    if have_user != 0:
        # <user>:x:1000:1000::/home/<user>:/bin/hamsh
        pos = _body_puts(pos, &prov_user[0])
        pos = _body_puts(pos, cast[Ptr[uint8]](":x:1000:1000::/home/"))
        pos = _body_puts(pos, &prov_user[0])
        pos = _body_puts(pos, cast[Ptr[uint8]](":/bin/hamsh\n"))
    pos = _body_puts(pos, cast[Ptr[uint8]](
        "nobody:x:65534:65534::/nonexistent:/bin/false\n"))
    return pos


def prov_compose_shadow() -> uint64:
    # Compose the installed /etc/shadow into prov_body. Hostowner gets a
    # fresh $6$ hash of --root-pass (or the shipped default), the install
    # user gets a fresh $6$ hash of --user-pass (or a `!` lock when no
    # password was given). System accounts are locked (`!`).
    pos: uint64 = 0
    # hostowner
    pos = _body_puts(pos, cast[Ptr[uint8]]("hostowner:"))
    if have_root_pass != 0:
        prov_gen_salt()
        sha512_crypt(&prov_root_pass[0], &prov_salt[0], &prov_hash[0])
        pos = _body_puts(pos, &prov_hash[0])
    else:
        # Fallback: the shipped default hostowner (uid 1) $6$ hash of
        # "hamnix" (from etc/shadow), so the composed shadow always
        # carries a usable admin credential even if --root-pass is unset.
        pos = _body_puts(pos, cast[Ptr[uint8]](
            "$6$hamnixliv$X1bsWILQy7piR9kPV3cs9wbcxX1K559x7AuSDD0ghQKPn3oIO6XMUyP2FuAEeqWxPRCwRXFQx.3kEhbX115d51"))
    pos = _body_puts(pos, cast[Ptr[uint8]](":19900\n"))
    pos = _body_puts(pos, cast[Ptr[uint8]]("sshd:!:0\n"))
    pos = _body_puts(pos, cast[Ptr[uint8]]("hamsh-svc:!:0\n"))
    if have_user != 0:
        pos = _body_puts(pos, &prov_user[0])
        prov_body[pos] = 58                              # ':'
        pos = pos + 1
        if have_user_pass != 0:
            prov_gen_salt()
            sha512_crypt(&prov_user_pass[0], &prov_salt[0], &prov_hash2[0])
            pos = _body_puts(pos, &prov_hash2[0])
            pos = _body_puts(pos, cast[Ptr[uint8]](":19900\n"))
        else:
            pos = _body_puts(pos, cast[Ptr[uint8]]("!:0\n"))
    pos = _body_puts(pos, cast[Ptr[uint8]]("nobody:!:0\n"))
    return pos


def provision_target(p2: Ptr[uint8]) -> int32:
    # Apply the collected wizard inputs onto the freshly-installed target
    # root. Best-effort per file; returns 0 if every requested write
    # landed, -1 if any failed. Only runs when a provisioning flag was
    # supplied (see main()).
    ok: int32 = 0

    if have_hostname != 0:
        write_str(1, "[install] provision: /etc/hostname = ")
        write_str(1, &prov_hostname[0])
        write_str(1, "\n")
        hl: uint64 = strlen_u8(&prov_hostname[0])
        prov_body[hl] = 0
        i: uint64 = 0
        while i < hl:
            prov_body[i] = prov_hostname[i]
            i = i + 1
        prov_body[hl] = 10                               # '\n'
        if prov_install_file(p2, cast[Ptr[uint8]]("etc/hostname"),
                             &prov_body[0], hl + 1) != 0:
            ok = -1

    if have_user != 0 or have_root_pass != 0:
        write_str(1, "[install] provision: /etc/passwd (install user + hostowner)\n")
        pl: uint64 = prov_compose_passwd()
        if prov_install_file(p2, cast[Ptr[uint8]]("etc/passwd"),
                             &prov_body[0], pl) != 0:
            ok = -1
        write_str(1, "[install] provision: /etc/shadow ($6$ hashes)\n")
        sl: uint64 = prov_compose_shadow()
        if prov_install_file(p2, cast[Ptr[uint8]]("etc/shadow"),
                             &prov_body[0], sl) != 0:
            ok = -1

    if have_user != 0:
        # Plant the install user's home directory + a standard /etc/skel
        # home skeleton so first login lands in a REAL home — not an empty
        # directory. The user is written straight into /etc/passwd (NOT
        # created via `useradd`), so useradd::make_home_skel never runs
        # for the installed account; we reproduce the same layout here.
        # Per-user home FILE SERVER + .ns recipe are still created on
        # first boot by `useradd`; the installed passwd points home at
        # /home/<user> on the flat root.
        write_str(1, "[install] provision: /home/")
        write_str(1, &prov_user[0])
        write_str(1, " home + skel (Desktop/Documents/Downloads/Pictures)\n")
        # Standard XDG/MATE home subdirs. Keep in sync with etc/skel/,
        # useradd.ad::make_home_skel and build_initramfs.py.
        if prov_plant_skel_dir(p2, cast[Ptr[uint8]]("Desktop")) != 0:
            ok = -1
        if prov_plant_skel_dir(p2, cast[Ptr[uint8]]("Documents")) != 0:
            ok = -1
        if prov_plant_skel_dir(p2, cast[Ptr[uint8]]("Downloads")) != 0:
            ok = -1
        if prov_plant_skel_dir(p2, cast[Ptr[uint8]]("Pictures")) != 0:
            ok = -1
        # A friendly starter note so Documents isn't bare (mirrors the
        # live image's /home/live/Documents/welcome.txt).
        _prov_home_path(cast[Ptr[uint8]]("Documents"),
                        cast[Ptr[uint8]]("welcome.txt"))
        wb: uint64 = 0
        wb = _body_puts(wb, cast[Ptr[uint8]]("Welcome to Hamnix!\n\n"))
        wb = _body_puts(wb, cast[Ptr[uint8]]("This is your home directory. The Desktop, Documents, Downloads\n"))
        wb = _body_puts(wb, cast[Ptr[uint8]]("and Pictures folders are yours to use.\n"))
        if prov_install_file(p2, &prov_skel_path[0],
                             &prov_body[0], wb) != 0:
            ok = -1
        if prov_chown(p2, &prov_skel_path[0]) != 0:
            ok = -1
        # Finally chown the home directory ITSELF (home/<user>) to the
        # install user — install_file/mkdir stamped it hostowner-owned.
        _prov_home_path(cast[Ptr[uint8]](""), cast[Ptr[uint8]](""))
        if prov_chown(p2, &prov_skel_path[0]) != 0:
            ok = -1

    if ok == 0:
        write_str(1, "[install] provision: installed-system accounts + hostname written\n")
    else:
        write_str(2, "[install] WARN: some provisioning writes failed (see above)\n")
    return ok


def do_install(esp_mb: uint64) -> int32:
    # target_bare / target_disk / target_p1 / target_p2 are composed by
    # the caller. esp_mb is the ESP MiB. repo_flag/tdev_flag/base_pkg/
    # esp_img_buf/sqfs_buf hold the package-install parameters.
    render_u64(esp_mb, &esp_mb_str[0])

    write_str(1, "[install] ============================================\n")
    write_str(1, "[install] Installing Hamnix (Debian-style package install)\n")
    write_str(1, "[install]   target disk : ")
    write_str(1, &target_disk[0])
    write_str(1, "\n[install]   ESP size    : ")
    write_str(1, &esp_mb_str[0])
    write_str(1, " MiB\n[install]   base pkg    : ")
    write_str(1, &base_pkg[0])
    write_str(1, "\n[install]   pkg repo    : ")
    write_str(1, &repo_url[0])
    write_str(1, "\n[install] ============================================\n")

    # 1/5: partition.
    write_str(1, "[install] (1/5) partition ")
    write_str(1, &target_disk[0])
    write_str(1, " (GPT + ESP + ext4 root)\n")
    rc: int32 = run_tool4(cast[Ptr[uint8]]("hamnix_partition"),
                          &target_disk[0], &esp_mb_str[0],
                          cast[Ptr[uint8]](0), cast[Ptr[uint8]](0))
    if rc != 0:
        write_str(2, "[install] FAIL: partitioning returned non-zero\n")
        return 1

    # 2/5: mkfs ESP (stub) + root ext4.
    write_str(1, "[install] (2/5) mkfs ESP (FAT) on ")
    write_str(1, &target_p1[0])
    write_str(1, "\n")
    run_tool4(cast[Ptr[uint8]]("mkfs_fat"), &target_p1[0], &esp_mb_str[0],
              cast[Ptr[uint8]](0), cast[Ptr[uint8]](0))
    write_str(1, "[install] (2/5) mkfs root (ext4) on ")
    write_str(1, &target_p2[0])
    write_str(1, "\n")
    rc = run_tool4(cast[Ptr[uint8]]("mkfs_ext4"), &target_p2[0],
                   cast[Ptr[uint8]](0), cast[Ptr[uint8]](0),
                   cast[Ptr[uint8]](0))
    if rc != 0:
        write_str(2, "[install] FAIL: mkfs_ext4 returned non-zero\n")
        return 1

    # 3/5: lay the bootloader onto the ESP (FAT byte-copy from the in-RAM
    # squashfs). FAT has no per-file kernel writer, so the ESP is the one
    # part that is byte-streamed; the ROOT below is a real package install.
    write_str(1, "[install] (3/5) stream ESP boot files ")
    write_str(1, &sqfs_buf[0])
    write_str(1, ":")
    write_str(1, &esp_img_buf[0])
    write_str(1, " -> ")
    write_str(1, &target_p1[0])
    write_str(1, "\n")
    rc = run_tool4(cast[Ptr[uint8]]("sqfs_to_blk"), &sqfs_buf[0],
                   &esp_img_buf[0], &target_p1[0], cast[Ptr[uint8]](0))
    if rc != 0:
        write_str(2, "[install] FAIL: ESP stream (sqfs_to_blk) non-zero\n")
        return 1

    # 4/5: refresh the in-RAM package index.
    #
    # --allow-unsigned: the in-RAM `file:///iso-packages` repo is the one
    # baked into (and firmware-loaded from) the installer image itself. It
    # is trusted-by-construction — it never crossed a network and its bytes
    # are covered by whatever measures/authenticates the installer image as
    # a whole. hpm's index-signature verification (secure-by-default since
    # afed3d3f) is aimed at REMOTE repos; it has no index.json.sig here
    # because build_packages.py only signs when HPM_REPO_SECKEY (the
    # out-of-band archive secret) is set, which it is not for a local
    # installer build. Without this flag `hpm refresh` aborts as "untrusted
    # index", do_install bails BEFORE step 5/6, the target ext4 root is left
    # empty (no /init, no .hamnix-roots), and the installed disk cannot boot
    # (kernel falls back to the baked user_demo_entry -> NX exec-fault). The
    # flag is scoped to this local repo only — the installer touches no
    # other repo.
    write_str(1, "[install] (4/5) hpm refresh (")
    write_str(1, &repo_url[0])
    write_str(1, ")\n")
    rc = run_hpm(&repo_flag[0], cast[Ptr[uint8]]("--allow-unsigned"),
                 cast[Ptr[uint8]]("refresh"),
                 cast[Ptr[uint8]](0), cast[Ptr[uint8]](0))
    if rc != 0:
        write_str(2, "[install] FAIL: hpm refresh non-zero\n")
        return 1

    # 5/5: install the base system as PACKAGES onto the fresh ext4 root.
    write_str(1, "[install] (5/5) hpm install ")
    write_str(1, &base_pkg[0])
    write_str(1, " --target-dev=")
    write_str(1, &target_p2[0])
    write_str(1, "\n")
    # --allow-unsigned: same trusted local in-RAM repo as the refresh above.
    rc = run_hpm(&repo_flag[0], &tdev_flag[0],
                 cast[Ptr[uint8]]("--allow-unsigned"),
                 cast[Ptr[uint8]]("install"), &base_pkg[0])
    if rc != 0:
        write_str(2, "[install] FAIL: hpm base package install non-zero\n")
        return 1

    # 6/6: plant the `.hamnix-roots` sentinel so the kernel binds the
    # installed root at `/` and ELF-loads `/init` off ext4 on next boot.
    # Without it the partition is anonymous, `bind '#sysroot' /` fails,
    # and boot degrades to the baked user_demo_entry (SMEP exec-fault).
    write_str(1, "[install] (6/6) plant .hamnix-roots (sysroot .) on ")
    write_str(1, &target_p2[0])
    write_str(1, "\n")
    if write_hamnix_roots(&target_p2[0]) != 0:
        write_str(2, "[install] FAIL: could not plant .hamnix-roots sentinel\n")
        return 1

    write_str(1, "[install] ============================================\n")
    write_str(1, "[install] install complete on ")
    write_str(1, &target_disk[0])
    write_str(1, "\n")
    write_str(1, "[install] the root was populated via hpm packages, not a\n")
    write_str(1, "[install] golden-image copy. Power off, detach the install\n")
    write_str(1, "[install] medium, and boot the target disk.\n")
    write_str(1, "[install] ============================================\n")
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Defaults.
    auto_mode: int32 = 0
    probe_mode: int32 = 0
    esp_mb: uint64 = 64
    strcpy(&base_pkg[0], cast[Ptr[uint8]]("hamnix-base"))
    strcpy(&esp_img_buf[0], cast[Ptr[uint8]]("esp.img"))
    strcpy(&sqfs_buf[0], cast[Ptr[uint8]]("/rootfs.sqfs"))
    strcpy(&repo_url[0], cast[Ptr[uint8]]("file:///iso-packages"))
    strcpy(&part_mode[0], cast[Ptr[uint8]]("guided"))
    have_disk_arg: int32 = 0
    disk_arg: Array[64, uint8]

    # Parse args.
    ai: int32 = 1
    while ai < argc:
        opt: Ptr[uint8] = cast[Ptr[uint8]](argv[ai])
        if streq(opt, cast[Ptr[uint8]]("--auto")) == 1:
            auto_mode = 1
        elif streq(opt, cast[Ptr[uint8]]("--probe")) == 1:
            probe_mode = 1
        elif streq(opt, cast[Ptr[uint8]]("--esp-mb")) == 1 and ai + 1 < argc:
            ai = ai + 1
            esp_mb = parse_u64(cast[Ptr[uint8]](argv[ai]))
            if esp_mb == 0:
                esp_mb = 64
        elif streq(opt, cast[Ptr[uint8]]("--repo")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&repo_url[0], cast[Ptr[uint8]](argv[ai]))
        elif streq(opt, cast[Ptr[uint8]]("--base")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&base_pkg[0], cast[Ptr[uint8]](argv[ai]))
        elif streq(opt, cast[Ptr[uint8]]("--esp-img")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&esp_img_buf[0], cast[Ptr[uint8]](argv[ai]))
        elif streq(opt, cast[Ptr[uint8]]("--sqfs")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&sqfs_buf[0], cast[Ptr[uint8]](argv[ai]))
        elif streq(opt, cast[Ptr[uint8]]("--hostname")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&prov_hostname[0], cast[Ptr[uint8]](argv[ai]))
            have_hostname = 1
        elif streq(opt, cast[Ptr[uint8]]("--user")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&prov_user[0], cast[Ptr[uint8]](argv[ai]))
            have_user = 1
        elif streq(opt, cast[Ptr[uint8]]("--user-pass")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&prov_user_pass[0], cast[Ptr[uint8]](argv[ai]))
            have_user_pass = 1
        elif streq(opt, cast[Ptr[uint8]]("--root-pass")) == 1 and ai + 1 < argc:
            ai = ai + 1
            strcpy(&prov_root_pass[0], cast[Ptr[uint8]](argv[ai]))
            have_root_pass = 1
        elif streq(opt, cast[Ptr[uint8]]("--part-mode")) == 1 and ai + 1 < argc:
            # Scaffolding for the wizard's partition manager. "guided"
            # (whole-disk, the default) and "manual" both drive the SAME
            # GPT+ESP+ext4 layout via do_install; manual additionally
            # lets the caller pick --esp-mb. Recorded for the log only.
            ai = ai + 1
            strcpy(&part_mode[0], cast[Ptr[uint8]](argv[ai]))
        elif streq(opt, cast[Ptr[uint8]]("--help")) == 1:
            write_str(1, "usage: install [--auto] [<disk>] [--esp-mb <n>] "
                         "[--repo <url>] [--base <pkg>]\n"
                         "               [--hostname <name>] [--user <name>] "
                         "[--user-pass <pw>] [--root-pass <pw>]\n"
                         "               [--part-mode guided|manual]\n")
            return 0
        elif starts_with(opt, cast[Ptr[uint8]]("--")) == 1:
            write_str(2, "install: unknown option: ")
            write_str(2, opt)
            write_str(2, "\n")
            return 1
        else:
            # Positional: the target disk.
            bare_name(opt, &disk_arg[0])
            have_disk_arg = 1
        ai = ai + 1

    # Compose the package-install flags.
    rp: uint64 = strcpy(&repo_flag[0], cast[Ptr[uint8]]("--repo="))
    strcpy(cast[Ptr[uint8]](cast[uint64](&repo_flag[0]) + rp), &repo_url[0])

    # Read the live-root disk for the safety guard.
    have_root: int32 = read_live_root(&root_name_buf[0])
    if have_root != 0:
        write_str(1, "[install] live root disk is /dev/blk/")
        write_str(1, &root_name_buf[0])
        write_str(1, " (excluded from install targets)\n")

    # --probe: report (via exit status only, no install) whether at least
    # one installable target distinct from the boot medium and the live
    # root exists. rc.boot uses this to choose between auto-installing
    # (a real target is present, e.g. the NUC's blank NVMe) and booting
    # the live environment (only the boot medium is present, e.g. a VM).
    #   exit 0 -> a distinct installable target exists
    #   exit 1 -> none (boot live)
    if probe_mode != 0:
        enumerate_disks(&root_name_buf[0], have_root)
        if n_disks > 0:
            return 0
        return 1

    # Resolve the target disk.
    if have_disk_arg != 0:
        strcpy(&target_bare[0], &disk_arg[0])
    else:
        # No explicit disk — enumerate.
        enumerate_disks(&root_name_buf[0], have_root)
        if n_disks == 0:
            write_str(2,
                "[install] no installable disks found (all excluded or none "
                "present).\n")
            return 1
        if auto_mode != 0:
            # Auto: pick the first candidate.
            strcpy(&target_bare[0], disk_name_ptr(0))
            write_str(1, "[install] --auto selected first disk: /dev/blk/")
            write_str(1, &target_bare[0])
            write_str(1, "\n")
        else:
            # Interactive: present the menu and prompt.
            write_str(1, "\nHamnix installer — choose a disk to install onto.\n")
            write_str(1, "WARNING: the selected disk will be ERASED.\n\n")
            print_disk_table()
            write_str(1, "\nEnter the number (or device name) of the target "
                         "disk, or `q` to quit: ")
            ln: int64 = read_line()
            if ln < 0:
                write_str(2, "\n[install] no input — aborting.\n")
                return 1
            if streq(&line_in[0], cast[Ptr[uint8]]("q")) == 1 \
                    or streq(&line_in[0], cast[Ptr[uint8]]("Q")) == 1:
                write_str(1, "[install] aborted.\n")
                return 0
            # Numeric selection?
            c0: uint8 = line_in[0]
            if c0 >= 49 and c0 <= 57:
                sel: uint64 = parse_u64(&line_in[0])
                if sel < 1 or sel > n_disks:
                    write_str(2, "[install] selection out of range.\n")
                    return 1
                strcpy(&target_bare[0], disk_name_ptr(sel - 1))
            else:
                # Treat input as a device name (strip /dev/blk/ if given).
                bare_name(&line_in[0], &target_bare[0])
    # end resolve

    # Compose device paths now that target_bare is known.
    make_blk_path(&target_bare[0], &target_disk[0])
    make_part_path(&target_bare[0], 1, &target_p1[0])
    make_part_path(&target_bare[0], 2, &target_p2[0])

    # --target-dev=/dev/blk/<bare>p2
    td: uint64 = strcpy(&tdev_flag[0], cast[Ptr[uint8]]("--target-dev="))
    strcpy(cast[Ptr[uint8]](cast[uint64](&tdev_flag[0]) + td), &target_p2[0])

    # SAFETY: refuse the live-root disk even if named explicitly.
    if have_root != 0 and streq(&root_name_buf[0], &target_bare[0]) == 1:
        write_str(2,
            "[install] REFUSING: target IS the live root disk. Installing "
            "here would destroy the running system. Abort.\n")
        return 2

    # SAFETY: refuse the boot medium itself (#410 self-clobber). In a VM
    # the install image enumerates as an ordinary disk; writing a fresh
    # GPT here would erase the running installer.
    if is_boot_medium(&target_bare[0]) != 0:
        write_str(2,
            "[install] REFUSING: target IS the live install medium. "
            "Installing here would erase the running installer. Abort.\n")
        return 2

    # Interactive confirmation (skipped in --auto_mode).
    if auto_mode == 0:
        write_str(1, "\n[install] About to ERASE /dev/blk/")
        write_str(1, &target_bare[0])
        write_str(1, " and install Hamnix onto it.\n")
        write_str(1, "[install] Type `yes` to proceed: ")
        ln2: int64 = read_line()
        if ln2 < 0 or streq(&line_in[0], cast[Ptr[uint8]]("yes")) == 0:
            write_str(1, "[install] not confirmed — aborting.\n")
            return 0

    # Guided (whole-disk) vs manual: both drive the same do_install
    # GPT+ESP+ext4 layout; the wizard's manual mode differs only in
    # letting the user choose --esp-mb (already parsed above).
    write_str(1, "[install] partition mode: ")
    write_str(1, &part_mode[0])
    write_str(1, "\n")

    rc: int32 = do_install(esp_mb)
    if rc != 0:
        return rc

    # Apply the wizard-collected accounts + hostname onto the installed
    # target root. No-op when no provisioning flag was supplied (the
    # unattended `install --auto` path), so today's behavior is
    # reproduced exactly.
    if have_hostname != 0 or have_user != 0 or have_user_pass != 0 \
            or have_root_pass != 0:
        write_str(1, "[install] ============================================\n")
        write_str(1, "[install] provisioning installed system (wizard inputs)\n")
        provision_target(&target_p2[0])
    return 0

# user/snarf_primary_host.ad — QEMU-free, DETERMINISTIC host unit test proving
# the X11-style PRIMARY selection is a SECOND clipboard buffer, INDEPENDENT of
# the CLIPBOARD (Ctrl+C/Ctrl+V), and that the toolkit routes a highlight to
# PRIMARY and a middle-click paste back out of PRIMARY — task #315.
#
# It wires together the THREE real pieces of the shipped mechanism, with no DE,
# no compositor, and no flaky mouse injection:
#
#   1. the kernel dual-buffer device — sys/src/9/port/devsnarf.ad's
#      devsnarf_{read,write} (CLIPBOARD, /dev/snarf) and
#      devsnarf_primary_{read,write} (PRIMARY, /dev/snarf.primary);
#   2. the toolkit's PATH selector — lib/htermsel.ad::_htsel_clip_path (the
#      grid terminal) and lib/hamtextbox.ad::_htb_clip_path (the editor, Notes,
#      and the browser URL bar), which map prim 0->/dev/snarf, 1->PRIMARY;
#   3. a faithful re-implementation of the kernel's PATH->buffer routing (the
#      exact-match dispatch in sys/src/9/port/namec.ad), so a put/get through a
#      selected path lands in the same backing array the real kernel would use.
#
# With those three joined, we drive the exact call sequence the widgets make:
#   * a drag-release copies the highlight to PRIMARY (prim=1),
#   * Ctrl+C copies to the CLIPBOARD (prim=0),
#   * a middle-click paste READS PRIMARY (prim=1),
# and assert the two buffers never clobber each other. This is the font- and
# compositor-independent proof that PRIMARY works side by side with, and
# independent of, the CLIPBOARD.

from sys.src.port9.port.devsnarf import devsnarf_write, devsnarf_read, \
    devsnarf_primary_write, devsnarf_primary_read
from lib.htermsel import _htsel_clip_path
from lib.hamtextbox import _htb_clip_path

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_fails: int32 = 0
_passes: int32 = 0


def _puts(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(1, s, n)


def _putn(v: int64):
    x: uint64 = cast[uint64](v)
    d: Array[24, uint8]
    n: uint64 = 0
    if x == 0:
        d[0] = 48
        n = 1
    else:
        while x > 0:
            d[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
    out: Array[26, uint8]
    p: uint64 = 0
    i: uint64 = n
    while i > 0:
        i = i - 1
        out[p] = d[i]
        p = p + 1
    sys_write(1, &out[0], p)


def _check(cond: int32, name: Ptr[uint8]):
    if cond != 0:
        _passes = _passes + 1
        _puts(cast[Ptr[uint8]]("[snarf-prim] PASS "))
    else:
        _fails = _fails + 1
        _puts(cast[Ptr[uint8]]("[snarf-prim] FAIL "))
    _puts(name)
    _puts(cast[Ptr[uint8]]("\n"))


# NUL-terminated cstring compare (path == literal). 1 on equal.
def _ceq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] != b[i]:
        return 0
    return 1


# Assert a read-back buffer equals a NUL-terminated expected string.
def _check_text(out: Ptr[uint8], n: uint64, want: Ptr[uint8], name: Ptr[uint8]):
    wl: uint64 = 0
    while want[wl] != 0:
        wl = wl + 1
    ok: int32 = 1
    if n != wl:
        ok = 0
    else:
        i: uint64 = 0
        while i < n:
            if out[i] != want[i]:
                ok = 0
            i = i + 1
    if ok != 0:
        _passes = _passes + 1
        _puts(cast[Ptr[uint8]]("[snarf-prim] PASS "))
        _puts(name)
        _puts(cast[Ptr[uint8]]("\n"))
    else:
        _fails = _fails + 1
        _puts(cast[Ptr[uint8]]("[snarf-prim] FAIL "))
        _puts(name)
        _puts(cast[Ptr[uint8]](" got=\""))
        sys_write(1, out, n)
        _puts(cast[Ptr[uint8]]("\" want=\""))
        _puts(want)
        _puts(cast[Ptr[uint8]]("\"\n"))


# --- faithful copy of the kernel path->buffer routing ----------------------
# Mirrors the exact-match dispatch in sys/src/9/port/namec.ad: the PRIMARY leaf
# is matched first so it never collides with the CLIPBOARD leaf. A write
# REPLACES; a read is offset-addressed to EOF (the loop the real htsel_clip_get
# / htb_clip_get run against the device).
def _route_put(path: Ptr[char], buf: Ptr[uint8], n: uint64) -> int32:
    p: Ptr[uint8] = cast[Ptr[uint8]](path)
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf.primary")) != 0:
        devsnarf_primary_write(buf, n)
        return 1
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf")) != 0:
        devsnarf_write(buf, n)
        return 1
    return 0


def _route_get(path: Ptr[char], out: Ptr[uint8], cap: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](path)
    total: uint64 = 0
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf.primary")) != 0:
        while total < cap:
            r: int64 = devsnarf_primary_read(total, &out[total], cap - total)
            if r <= 0:
                break
            total = total + cast[uint64](r)
        return total
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf")) != 0:
        while total < cap:
            r2: int64 = devsnarf_read(total, &out[total], cap - total)
            if r2 <= 0:
                break
            total = total + cast[uint64](r2)
        return total
    return total


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    out: Array[128, uint8]

    # --- 1. the toolkit PATH selectors map prim -> the right device leaf -----
    # (Both the terminal's _htsel_clip_path and the editor/Notes/browser's
    # _htb_clip_path must agree; a Ctrl+C -> CLIPBOARD, a highlight -> PRIMARY.)
    _check(_ceq(cast[Ptr[uint8]](_htsel_clip_path(0)),
                cast[Ptr[uint8]]("/dev/snarf")),
           cast[Ptr[uint8]]("term_clipboard_path"))
    _check(_ceq(cast[Ptr[uint8]](_htsel_clip_path(1)),
                cast[Ptr[uint8]]("/dev/snarf.primary")),
           cast[Ptr[uint8]]("term_primary_path"))
    _check(_ceq(cast[Ptr[uint8]](_htb_clip_path(0)),
                cast[Ptr[uint8]]("/dev/snarf")),
           cast[Ptr[uint8]]("textbox_clipboard_path"))
    _check(_ceq(cast[Ptr[uint8]](_htb_clip_path(1)),
                cast[Ptr[uint8]]("/dev/snarf.primary")),
           cast[Ptr[uint8]]("textbox_primary_path"))
    # PRIMARY and CLIPBOARD are DIFFERENT leaves (else one buffer serves both).
    _check(_ceq(cast[Ptr[uint8]](_htsel_clip_path(0)),
                cast[Ptr[uint8]](_htsel_clip_path(1))) == 0,
           cast[Ptr[uint8]]("primary_leaf_differs_from_clipboard"))

    # --- 2. a highlight (drag-release) SETS the PRIMARY selection ------------
    # The terminal / editor call clip_put(1, sel) on release.
    _route_put(_htsel_clip_path(1), cast[Ptr[uint8]]("SELECTED"), 8)
    n: uint64 = _route_get(_htsel_clip_path(1), &out[0], 128)
    _check_text(&out[0], n, cast[Ptr[uint8]]("SELECTED"),
                cast[Ptr[uint8]]("highlight_sets_primary"))
    # ...and it did NOT touch the CLIPBOARD (still empty — no Ctrl+C yet).
    n = _route_get(_htsel_clip_path(0), &out[0], 128)
    _check(cast[int32](n) == 0,
           cast[Ptr[uint8]]("highlight_leaves_clipboard_empty"))

    # --- 3. Ctrl+C SETS the CLIPBOARD, independent of PRIMARY ----------------
    _route_put(_htb_clip_path(0), cast[Ptr[uint8]]("COPIED"), 6)
    n = _route_get(_htb_clip_path(0), &out[0], 128)
    _check_text(&out[0], n, cast[Ptr[uint8]]("COPIED"),
                cast[Ptr[uint8]]("ctrl_c_sets_clipboard"))
    # PRIMARY must be UNCHANGED by the Ctrl+C (the whole point of two buffers).
    n = _route_get(_htb_clip_path(1), &out[0], 128)
    _check_text(&out[0], n, cast[Ptr[uint8]]("SELECTED"),
                cast[Ptr[uint8]]("ctrl_c_does_not_clobber_primary"))

    # --- 4. middle-click PASTE reads PRIMARY, not the CLIPBOARD ---------------
    # The terminal/editor/browser call clip_get(1) on a middle-button press.
    n = _route_get(_htsel_clip_path(1), &out[0], 128)
    _check_text(&out[0], n, cast[Ptr[uint8]]("SELECTED"),
                cast[Ptr[uint8]]("middle_click_pastes_primary"))

    # --- 5. a fresh highlight overwrites PRIMARY, leaving CLIPBOARD intact ----
    _route_put(_htb_clip_path(1), cast[Ptr[uint8]]("NEWSEL"), 6)
    n = _route_get(_htb_clip_path(1), &out[0], 128)
    _check_text(&out[0], n, cast[Ptr[uint8]]("NEWSEL"),
                cast[Ptr[uint8]]("new_highlight_overwrites_primary"))
    n = _route_get(_htb_clip_path(0), &out[0], 128)
    _check_text(&out[0], n, cast[Ptr[uint8]]("COPIED"),
                cast[Ptr[uint8]]("new_highlight_leaves_clipboard"))

    # --- 6. offset-addressed read reaches EOF (chunked paste terminates) ------
    # Read the 6-byte CLIPBOARD starting AT its end -> 0 bytes (EOF).
    eof: int64 = devsnarf_read(6, &out[0], 128)
    _check(cast[int32](eof) == 0, cast[Ptr[uint8]]("clipboard_read_hits_eof"))
    peof: int64 = devsnarf_primary_read(6, &out[0], 128)
    _check(cast[int32](peof) == 0, cast[Ptr[uint8]]("primary_read_hits_eof"))

    # --- 7. a 0-byte write CLEARS a buffer (empty-selection semantics) --------
    _route_put(_htsel_clip_path(1), &out[0], 0)
    n = _route_get(_htsel_clip_path(1), &out[0], 128)
    _check(cast[int32](n) == 0, cast[Ptr[uint8]]("empty_write_clears_primary"))
    # CLIPBOARD still holds its content after PRIMARY was cleared.
    n = _route_get(_htsel_clip_path(0), &out[0], 128)
    _check_text(&out[0], n, cast[Ptr[uint8]]("COPIED"),
                cast[Ptr[uint8]]("clear_primary_leaves_clipboard"))

    _puts(cast[Ptr[uint8]]("[snarf-prim] SUMMARY passes="))
    _putn(cast[int64](_passes))
    _puts(cast[Ptr[uint8]](" fails="))
    _putn(cast[int64](_fails))
    _puts(cast[Ptr[uint8]]("\n"))
    if _fails == 0:
        _puts(cast[Ptr[uint8]]("[snarf-prim] RESULT PASS\n"))
        return 0
    _puts(cast[Ptr[uint8]]("[snarf-prim] RESULT FAIL\n"))
    return 1

# user/basename.ad
#
# Hamnix `basename PATH`: prints the final path component of argv[1].
# No suffix-strip variant, no -a — just the minimal coreutils contract.
# A trailing slash is treated as part of the prefix (we slice strictly
# after the last '/'), matching POSIX for non-edge inputs like
# `/a/b/c.txt` and `c.txt`. With no slash we print argv[1] as-is.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "basename: missing operand\n")
        return 1
    path: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    n: uint64 = strlen_u8(path)
    # Walk forward tracking the index just past the last '/'. That's
    # the start of the basename slice — no copy needed, just a write
    # of (n - start) bytes from path + start.
    start: uint64 = 0
    i: uint64 = 0
    while i < n:
        if path[i] == 47:
            start = i + 1
        i = i + 1
    sys_write(1, cast[Ptr[uint8]](cast[uint64](path) + start), n - start)
    sys_write(1, "\n", 1)
    return 0

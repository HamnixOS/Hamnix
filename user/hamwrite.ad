# user/hamwrite.ad — NATIVE scene-DE driver for HamWrite, the Hamnix office
# word processor (/bin/hamwrite). The flagship of a would-be office suite: a
# single-document rich-text editor with bold/italic/heading formatting,
# word-wrap, selection + clipboard and a real save/load document file.
#
# This is the thin I/O + windowing shell around lib/hamwritecore.ad (which owns
# the buffers, editing, formatting, hit-testing and the word-wrapped render).
# The split lets the exact shipping code path render to a PNG on the dev host,
# driven by scripted keystrokes (user/hamwrite_host.ad + the host gate
# scripts/test_hamwrite_host.sh). This driver does the on-box work the core
# can't: create the wsys window, poll /keys + /event, and open/save the document
# file on disk (Ctrl-S / Ctrl-O) + the /dev/snarf clipboard (Ctrl-C/V/X).
#
# FORMATTING NOTE: bold is a real double-strike (hamscene glyphs `b` flag);
# italic + heading are rendered with distinct tints (+ a heading underline)
# because the DE font has no oblique/large face yet. A true italic/large-face
# render is a font-engine follow-up; the DOCUMENT MODEL already stores all three
# per-character attributes and round-trips them, so the fidelity lands the day
# the font engine grows the faces. A FULL office suite would add: a spreadsheet
# (grid + formula core, a lib/hamcalccore already exists to seed it), slides,
# and paragraph styles / find-replace / undo — see docs/hamui_dual_target.md.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_yield() -> int32
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64, timeout_ms: int64) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_get_jiffies() -> uint64

from lib.hamui import hamscene_commit
from lib.hamtextbox import htb_clip_put, htb_clip_get, htb_click_count, \
    htb_evt_parse_m, htb_mid_edge
from lib.hamwritecore import hamwrite_build_scene, hamwrite_key_line, \
    hamwrite_take_action, hamwrite_serialize, hamwrite_deserialize, \
    hamwrite_mark_saved, hamwrite_set_fname, hamwrite_hit, hamwrite_drag, \
    hamwrite_select_word, hamwrite_select_line, hamwrite_in_page, \
    hamwrite_sel_active, hamwrite_sel_ptr, hamwrite_sel_len, \
    hamwrite_delete_selection, hamwrite_paste, hamwrite_len


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ---- document path + file I/O ---------------------------------------------
DOC_PATH_CAP: uint64 = 192
doc_path: Array[192, uint8]
doc_path_len: uint64 = 0
ser_buf:  Array[8320, uint8]                            # magic+len + 2*CAP
clip_buf: Array[4096, uint8]


def _set_docpath(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < DOC_PATH_CAP - 1:
        doc_path[i] = s[i]
        i = i + 1
    doc_path[i] = 0
    doc_path_len = i


# Set the display filename to the basename of doc_path.
def _sync_fname():
    last: int64 = -1
    k: uint64 = 0
    while k < doc_path_len:
        if doc_path[k] == 47:
            last = cast[int64](k)
        k = k + 1
    base: uint64 = 0
    if last >= 0:
        base = cast[uint64](last) + 1
    hamwrite_set_fname(&doc_path[base])


def _save_doc():
    if doc_path_len == 0:
        return
    fd: int32 = sys_open_write(cast[Ptr[char]](&doc_path[0]))
    if fd < 0:
        return
    n: uint64 = hamwrite_serialize(&ser_buf[0])
    sys_write(fd, &ser_buf[0], n)
    sys_close(fd)
    hamwrite_mark_saved()


def _load_doc():
    fd: int32 = sys_open(cast[Ptr[char]](&doc_path[0]))
    if fd < 0:
        return
    total: uint64 = 0
    while total < 8320:
        r: int64 = sys_read(fd, &ser_buf[total], 8320 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    hamwrite_deserialize(&ser_buf[0], total)


# Clipboard glue over /dev/snarf (prim 0 = clipboard).
def _do_copy():
    if hamwrite_sel_active() == 0:
        return
    htb_clip_put(0, hamwrite_sel_ptr(), hamwrite_sel_len())


def _do_paste():
    n: uint64 = htb_clip_get(0, &clip_buf[0], 4096)
    if n > 0:
        hamwrite_paste(&clip_buf[0], n)


def _do_cut():
    if hamwrite_sel_active() == 0:
        return
    htb_clip_put(0, hamwrite_sel_ptr(), hamwrite_sel_len())
    hamwrite_delete_selection()


# Dispatch a pending action set by a keystroke (Ctrl-S/O/C/V/X).
def _dispatch(act: int32):
    if act == 1:
        _save_doc()
    elif act == 2:
        _load_doc()
    elif act == 7:
        _do_copy()
    elif act == 8:
        _do_paste()
    elif act == 9:
        _do_cut()


# ---- pointer input --------------------------------------------------------
hw_prev_btn: int64 = 0
hw_dragging: int32 = 0


# Handle a window-local pointer event. Returns 1 if a redraw is needed.
def _pointer(lx: int64, ly: int64, btn: int64) -> int32:
    changed: int32 = 0
    b1: int64 = btn & 1
    pb1: int64 = hw_prev_btn & 1
    if b1 != 0 and pb1 == 0:                            # button-1 PRESS
        act: int32 = hamwrite_hit(lx, ly)
        if act == 1 or act == 2:
            _dispatch(act)
            changed = 1
        elif act == 3:                                 # format toggle applied
            changed = 1
        else:
            # body click placed the caret; check multi-click over the page
            if hamwrite_in_page(lx, ly) != 0:
                cc: int32 = htb_click_count(lx, ly, sys_get_jiffies())
                if cc == 2:
                    hamwrite_select_word()
                    hw_dragging = 0
                elif cc >= 3:
                    hamwrite_select_line()
                    hw_dragging = 0
                else:
                    hw_dragging = 1
            changed = 1
    elif b1 != 0 and hw_dragging != 0:                 # button-1 DRAG
        if hamwrite_drag(lx, ly) != 0:
            changed = 1
    elif b1 == 0 and pb1 != 0:                          # button-1 RELEASE
        hw_dragging = 0
        if hamwrite_sel_active() != 0:
            htb_clip_put(1, hamwrite_sel_ptr(), hamwrite_sel_len())  # PRIMARY
    if htb_mid_edge(btn, hw_prev_btn) != 0:            # MIDDLE -> paste PRIMARY
        if hamwrite_in_page(lx, ly) != 0:
            hamwrite_hit(lx, ly)                       # place caret at click
            np: uint64 = htb_clip_get(1, &clip_buf[0], 4096)
            if np > 0:
                hamwrite_paste(&clip_buf[0], np)
                changed = 1
    hw_prev_btn = btn
    return changed


# Non-blocking /event drain: "r <w> <h>" (ignored — fixed layout) and
# "m <x> <y> <btn> <dz>" pointer lines. Returns 1 if a redraw is needed.
ev_buf:   Array[256, uint8]
ev_carry: uint64 = 0


def _poll_events(efd: int32) -> int32:
    if efd < 0:
        return 0
    changed: int32 = 0
    passes: int32 = 0
    while passes < 4:
        room: uint64 = 256 - ev_carry
        if room == 0:
            ev_carry = 0
            room = 256
        en: int64 = sys_read_nb(efd, &ev_buf[ev_carry], room)
        if en <= 0:
            break
        total: uint64 = ev_carry + cast[uint64](en)
        i: uint64 = 0
        ls: uint64 = 0
        while i < total:
            if ev_buf[i] == 10:
                if i > ls and ev_buf[ls] == 109:       # 'm' pointer
                    ex: int64 = 0
                    ey: int64 = 0
                    ebtn: int64 = 0
                    dz: int64 = 0
                    if htb_evt_parse_m(&ev_buf[ls], i - ls, &ex, &ey,
                                       &ebtn, &dz) != 0:
                        if _pointer(ex, ey, ebtn) != 0:
                            changed = 1
                ls = i + 1
            i = i + 1
        leftover: uint64 = total - ls
        m: uint64 = 0
        while m < leftover:
            ev_buf[m] = ev_buf[ls + m]
            m = m + 1
        ev_carry = leftover
        passes = passes + 1
    return changed


# ---- key input ------------------------------------------------------------
kev_buf: Array[512, uint8]
kev_carry: uint64 = 0


# Parse complete "<type> <code>\n" lines; feed each to the core. Returns bytes
# consumed; sets *changed_p if any key mutated the doc/caret.
def _drain_keys(n: uint64, changed_p: Ptr[int32]) -> uint64:
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        ls: uint64 = i
        while i < n and kev_buf[i] != 10:
            i = i + 1
        if i >= n:
            return consumed
        # feed the line [ls, i) to the core
        if hamwrite_key_line(&kev_buf[ls], i - ls) != 0:
            act: int32 = hamwrite_take_action()
            if act != 0:
                _dispatch(act)
            changed_p[0] = 1
        i = i + 1                                      # consume '\n'
        consumed = i
    return consumed


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamwrite] FAIL newwindow\n"))
        return 1

    # Publish the window id for scripted drivers.
    widf: int32 = sys_open_write(cast[Ptr[char]]("/tmp/.hamwrite_wid"))
    if widf >= 0:
        widtxt: Array[24, uint8]
        wl: uint64 = _u64_to_dec(cast[uint64](wid), &widtxt[0])
        widtxt[wl] = 10
        sys_write(widf, &widtxt[0], wl + 1)
        sys_close(widf)

    ctlp: Array[64, uint8]
    keysp: Array[64, uint8]
    evtp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    _winpath(&evtp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 140 90 560 384\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title HamWrite\n"))
        sys_close(cfdt)

    # Document path: argv[1] or a sensible default under the user's home.
    if argc >= 2 and argv != cast[Ptr[uint64]](0):
        _set_docpath(cast[Ptr[uint8]](argv[1]))
        _load_doc()
    else:
        _set_docpath(cast[Ptr[uint8]]("/home/live/Documents/untitled.hdoc"))
    _sync_fname()

    hamwrite_build_scene()
    hamscene_commit(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamwrite] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    efd: int32 = sys_open(cast[Ptr[char]](&evtp[0]))
    if kfd < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamwrite] FAIL open keys\n"))
        while True:
            sys_yield()
        return 1

    IDLE_WAIT_MS: int64 = 10
    while True:
        room: uint64 = 512 - kev_carry
        if room == 0:
            kev_carry = 0
            room = 512
        kn: int64 = sys_read_nb(kfd, &kev_buf[kev_carry], room)
        did_work: int32 = 0
        if _poll_events(efd) != 0:
            hamwrite_build_scene()
            hamscene_commit(wid)
            did_work = 1
        if kn > 0:
            total: uint64 = kev_carry + cast[uint64](kn)
            changed: int32 = 0
            done: uint64 = _drain_keys(total, &changed)
            leftover: uint64 = total - done
            m: uint64 = 0
            while m < leftover:
                kev_buf[m] = kev_buf[done + m]
                m = m + 1
            kev_carry = leftover
            if changed != 0:
                hamwrite_build_scene()
                hamscene_commit(wid)
            did_work = 1
        if did_work == 0:
            wfds: Array[1, int32]
            wfds[0] = kfd
            sys_waitfds(&wfds[0], 1, IDLE_WAIT_MS)
    return 0

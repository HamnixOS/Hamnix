# user/gif_probe.ad — host test shim for lib/gif.ad. Reads a GIF file, decodes
# it, and prints "RC rc", "DIM w h", and "PIX x y r g b a" for each (x,y) pair in
# argv, so a gate can assert decode dimensions, exact per-pixel palette colours,
# and transparency (alpha) accuracy.
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.gif import gif_decode, gif_width, gif_height, gif_pixel

FILE_CAP: uint64 = 1048576
fbuf: Array[1048576, uint8]

obuf: Array[256, uint8]
obn: uint64 = 0


def _oc(c: uint8):
    if obn < 255:
        obuf[obn] = c
        obn = obn + 1


def _os(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _oc(s[i])
        i = i + 1


def _od(v: int64):
    if v < 0:
        _oc(45)
        v = 0 - v
    if v == 0:
        _oc(48)
        return
    d: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        d[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _oc(d[n])


def _flush():
    sys_write(1, &obuf[0], obn)
    obn = 0


def _atoi(s: Ptr[char]) -> int64:
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    v: int64 = 0
    i: uint64 = 0
    while p[i] != 0:
        v = v * 10 + cast[int64](p[i] - 48)
        i = i + 1
    return v


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        sys_write(2, cast[Ptr[uint8]]("usage: gif_probe FILE.gif [x y ...]\n"), 36)
        return 2
    path: Ptr[char] = cast[Ptr[char]](argv[1])
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        sys_write(2, cast[Ptr[uint8]]("open failed\n"), 12)
        return 1
    got: int64 = 0
    while got < cast[int64](FILE_CAP):
        n: int64 = sys_read(fd, &fbuf[got], FILE_CAP - cast[uint64](got))
        if n <= 0:
            break
        got = got + n
    sys_close(fd)
    rc: int32 = gif_decode(&fbuf[0], cast[uint64](got))
    _os(cast[Ptr[uint8]]("RC "))
    _od(cast[int64](rc))
    _oc(10)
    if rc == 0:
        _os(cast[Ptr[uint8]]("DIM "))
        _od(cast[int64](gif_width()))
        _oc(32)
        _od(cast[int64](gif_height()))
        _oc(10)
    _flush()
    if rc != 0:
        return 0
    a: int32 = 2
    while a + 1 < argc:
        x: int32 = cast[int32](_atoi(cast[Ptr[char]](argv[a])))
        y: int32 = cast[int32](_atoi(cast[Ptr[char]](argv[a + 1])))
        px: uint32 = gif_pixel(x, y)
        _os(cast[Ptr[uint8]]("PIX "))
        _od(cast[int64](x))
        _oc(32)
        _od(cast[int64](y))
        _oc(32)
        _od(cast[int64]((px >> 16) & 255))
        _oc(32)
        _od(cast[int64]((px >> 8) & 255))
        _oc(32)
        _od(cast[int64](px & 255))
        _oc(32)
        _od(cast[int64]((px >> 24) & 255))
        _oc(10)
        _flush()
        a = a + 2
    return 0

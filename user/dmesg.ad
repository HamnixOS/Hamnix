# user/dmesg.ad
#
# Stub `dmesg`. We don't yet keep a kernel ring buffer (printk goes
# straight to the 16550A UART without being copied into a __log_buf
# array first), so there's nothing for userland to drain. Print a
# placeholder so the command exists and exits 0 in scripts. When
# the ring buffer lands, this swaps to a sys_read on /proc/kmsg.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "(dmesg requires kernel log buffer; not yet wired)\n")
    return 0

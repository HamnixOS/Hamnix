# user/dmesg.ad
#
# Hamnix `dmesg`: opens /proc/kmsg and streams the kernel printk ring
# buffer snapshot to stdout. Mirrors util-linux's dmesg at minimum
# scope — no -c clear, no log-level filter, no follow mode. Since
# M16.88 every byte that crosses early_putc() is also pushed into a
# 64 KiB ring buffer in kernel/printk/printk_log.ad; opening
# /proc/kmsg takes a snapshot of (up to) the last page of that ring
# into a per-fd buffer, which this command then drains via sys_read.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


CHUNK: uint64 = 256


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    fd: int32 = sys_open("/proc/kmsg")
    if fd < 0:
        write_str(2, "dmesg: cannot open /proc/kmsg\n")
        return 1
    buf: Array[256, uint8]
    while True:
        n: int64 = sys_read(fd, &buf[0], CHUNK)
        if n <= 0:
            break
        sys_write(1, &buf[0], cast[uint64](n))
    sys_close(fd)
    return 0

# user/aplay.ad
#
# Hamnix `aplay`: stream a PCM file to the native HDA audio device.
#
#   aplay <file>            # raw s16le, 2ch, 48 kHz (defaults)
#   aplay <file> <rate> <channels>   # override rate + channel count
#
# A leading 44-byte RIFF/WAVE header is auto-detected and skipped (and
# its fmt chunk's rate/channels honoured) so a standard .wav plays too;
# anything else is treated as raw little-endian PCM.
#
# The tool is a thin Plan-9 client: it sets rate/channels/format by
# echoing text verbs to /dev/audioctl, copies the sample bytes to
# /dev/audio, then sends `start`. NO ioctls, NO sockets — just file
# writes, the Plan-9 way.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    if value == 0:
        out[0] = 48
        out[1] = 0
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    out[written] = 0
    return written


def parse_dec(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        n = n * 10 + cast[uint64](s[i] - 48)
        i = i + 1
    return n


# Send a ctl verb line: "<verb> <value>\n".
def ctl_verb(ctlfd: int32, verb: Ptr[uint8], value: uint64):
    line: Array[48, uint8]
    p: uint64 = 0
    j: uint64 = 0
    while verb[j] != 0:
        line[p] = verb[j]
        p = p + 1
        j = j + 1
    line[p] = 32                     # space
    p = p + 1
    p = p + u64_to_dec(value, &line[p])
    line[p] = 10                     # newline
    p = p + 1
    sys_write(ctlfd, &line[0], p)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "usage: aplay <file> [rate] [channels]\n")
        return 1

    path: Ptr[char] = cast[Ptr[char]](argv[1])
    rate: uint64 = 48000
    channels: uint64 = 2
    if argc >= 3:
        rate = parse_dec(cast[Ptr[uint8]](argv[2]))
    if argc >= 4:
        channels = parse_dec(cast[Ptr[uint8]](argv[3]))

    infd: int32 = sys_open(path)
    if infd < 0:
        write_str(2, "aplay: cannot open input\n")
        return 1

    # Peek the first 12 bytes to sniff a RIFF/WAVE header.
    hdr: Array[44, uint8]
    skip: uint64 = 0
    first: int64 = sys_read(infd, &hdr[0], 44)
    if first >= 12 and hdr[0] == 82 and hdr[1] == 73 and hdr[2] == 70 \
            and hdr[3] == 70 and hdr[8] == 87 and hdr[9] == 65 \
            and hdr[10] == 86 and hdr[11] == 69:
        # "RIFF"...."WAVE": honour the fmt chunk rate/channels and skip
        # the canonical 44-byte header. (Minimal parser: assumes the
        # standard 16-byte PCM fmt chunk layout.)
        channels = cast[uint64](hdr[22]) | (cast[uint64](hdr[23]) << 8)
        rate = cast[uint64](hdr[24]) | (cast[uint64](hdr[25]) << 8) \
             | (cast[uint64](hdr[26]) << 16) | (cast[uint64](hdr[27]) << 24)
        skip = 44

    # Open the control + data cdevs.
    ctlfd: int32 = sys_open_write("/dev/audioctl")
    if ctlfd < 0:
        write_str(2, "aplay: cannot open /dev/audioctl\n")
        sys_close(infd)
        return 1
    audfd: int32 = sys_open_write("/dev/audio")
    if audfd < 0:
        write_str(2, "aplay: cannot open /dev/audio\n")
        sys_close(ctlfd)
        sys_close(infd)
        return 1

    ctl_verb(ctlfd, "rate", rate)
    ctl_verb(ctlfd, "channels", channels)
    write_str(ctlfd, "format s16le\n")

    # If we sniffed a header but read past it into hdr[], we already
    # consumed 44 bytes; those were the header, so just continue reading
    # PCM from the file. If it was raw, hdr[] holds the first 44 PCM
    # bytes — write them out first.
    buf: Array[1024, uint8]
    if skip == 0 and first > 0:
        sys_write(audfd, &hdr[0], cast[uint64](first))

    while True:
        n: int64 = sys_read(infd, &buf[0], 1024)
        if n <= 0:
            break
        sys_write(audfd, &buf[0], cast[uint64](n))

    # Start playback.
    write_str(ctlfd, "start\n")

    sys_close(audfd)
    sys_close(ctlfd)
    sys_close(infd)
    return 0

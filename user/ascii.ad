# user/ascii.ad
#
# Prints the printable ASCII table — codes 32..126 (space..tilde),
# one entry per line, in the format:
#
#   <decimal>  0x<hex>  <char>
#
# A handy man-style reference that doesn't need a real terminfo /
# manpage system. No arguments.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def write_str(s: Ptr[uint8], n: uint64):
    sys_write(1, s, n)


def emit_dec3(value: uint32):
    # Right-justified 3-char decimal (32..126 fit in 2-3 chars). We
    # pad with spaces so columns line up — keeps the table readable
    # when piped through `more`.
    buf: Array[3, uint8]
    buf[0] = 32
    buf[1] = 32
    buf[2] = 32
    v: uint32 = value
    i: int32 = 2
    while v != 0 and i >= 0:
        buf[cast[uint64](i)] = cast[uint8](v % 10) + 48
        v = v / 10
        i = i - 1
    sys_write(1, &buf[0], 3)


def emit_hex2(value: uint32):
    # Two-digit lowercase hex (0x20..0x7e all fit in two nibbles).
    hi: uint32 = (value >> 4) & 0xF
    lo: uint32 = value & 0xF
    buf: Array[2, uint8]
    if hi < 10:
        buf[0] = cast[uint8](hi) + 48
    else:
        buf[0] = cast[uint8](hi - 10) + 97
    if lo < 10:
        buf[1] = cast[uint8](lo) + 48
    else:
        buf[1] = cast[uint8](lo - 10) + 97
    sys_write(1, &buf[0], 2)


def main() -> int32:
    code: uint32 = 32
    while code <= 126:
        emit_dec3(code)
        sys_write(1, "  0x", 4)
        emit_hex2(code)
        sys_write(1, "  ", 2)
        ch: Array[1, uint8]
        ch[0] = cast[uint8](code)
        sys_write(1, &ch[0], 1)
        sys_write(1, "\n", 1)
        code = code + 1
    return 0

# user/ham2048.ad
#
# 2048 — a real, playable sliding-tile game built entirely on the hamui
# widget toolkit (lib/hamui.ad). This is a genuine consumer of the
# GTK/Qt-style retained-mode API: it builds a widget tree once, binds a
# window, then drives the toolkit's pull-based event loop (hamui_step +
# sys_yield) forever, mutating real game state and pushing it back into
# the widgets via hamui_set_text / hamui_status_set.
#
# BOARD: a 4x4 grid of button widgets (one per cell). Each frame the cell
# text is refreshed from the module-scope `board` array (0 == empty).
#
# CONTROLS (two schemes, both wired to the same move handler):
#   1. KEYBOARD via a focused entry widget. Click the "type here" entry
#      once to focus it, then press W/A/S/D (up/left/down/right) or 'n'
#      for a new game. We read the entry's text each frame, act on any
#      new characters, then clear the entry. (The toolkit only routes key
#      bytes to a focused entry/textview, and focus is set by a click —
#      there is no public set-focus call — hence the one-click-to-focus.)
#   2. ON-SCREEN BUTTONS: Up / Down / Left / Right / New. These fire the
#      toolkit's normal click signals (hamui_signalled) and need no
#      focus, so they are the guaranteed-working baseline.
#
# MERGE LOGIC: classic 2048. For each move we compact a line toward the
# move direction (drop the zeros), then merge equal adjacent pairs once
# (left-to-right in slide order), then compact again. Score increases by
# the value of every merged tile. A move is "real" only if it changed the
# board; a new tile (2 with p=0.9, else 4) spawns into a random empty cell
# after every real move. Win at 2048, game-over when the board is full and
# no merge is possible.
#
# RANDOM: a module-scope LCG seeded from sys_get_jiffies() at startup.

from lib.hamui import (
    hamui_init, hamui_fixed, hamui_grid, hamui_button, hamui_entry,
    hamui_label, hamui_statusbar, hamui_status_set, hamui_grid_attach,
    hamui_add, hamui_fixed_place, hamui_set_size, hamui_set_text,
    hamui_entry_text, hamui_window, hamui_step, hamui_signalled
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_yield() -> int32
extern def sys_get_jiffies() -> uint64


# ---- tiny stdout helpers (for the boot/diagnostic line) -----------------
def _g_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _g_puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _g_strlen(s))


# ====================================================================
# GAME STATE (module scope — no malloc, fixed arrays only)
# ====================================================================
board:    Array[16, int32]            # row-major 4x4, 0 == empty
score:    int32 = 0
won:      int32 = 0
gameover: int32 = 0

rng_state: uint64 = 0x2545F4914F6CDD1D

# cell widget ids, filled at build time
cell_id:  Array[16, int32]

# per-cell rendered text scratch (each up to a few chars + NUL)
cell_txt: Array[8, uint8]

# entry-diff bookkeeping for the keyboard scheme
last_seen: uint64 = 0


# ---- LCG random -----------------------------------------------------
def _g_rand() -> uint32:
    rng_state = rng_state * 6364136223846793005 + 1442695040888963407
    return cast[uint32](rng_state >> 33)


# ---- board helpers --------------------------------------------------
def _g_count_empty() -> int32:
    n: int32 = 0
    i: uint64 = 0
    while i < 16:
        if board[i] == 0:
            n = n + 1
        i = i + 1
    return n


# Spawn a tile (2 @ 90%, else 4) into a random empty cell. Caller ensures
# at least one empty cell exists.
def _g_spawn():
    empties: int32 = _g_count_empty()
    if empties <= 0:
        return
    pick: int32 = cast[int32](_g_rand() % cast[uint32](empties))
    val: int32 = 2
    if _g_rand() % 10 == 0:
        val = 4
    i: uint64 = 0
    seen: int32 = 0
    while i < 16:
        if board[i] == 0:
            if seen == pick:
                board[i] = val
                return
            seen = seen + 1
        i = i + 1


# Slide+merge a single line of 4 cells given by absolute indices a,b,c,d
# in slide order (front-most first). Returns 1 if the line changed.
def _g_slide_line(a: uint64, b: uint64, c: uint64, d: uint64) -> int32:
    line: Array[4, int32]
    line[0] = board[a]
    line[1] = board[b]
    line[2] = board[c]
    line[3] = board[d]

    # remember original for change detection
    o0: int32 = line[0]
    o1: int32 = line[1]
    o2: int32 = line[2]
    o3: int32 = line[3]

    # 1) compact: drop zeros toward the front
    comp: Array[4, int32]
    comp[0] = 0
    comp[1] = 0
    comp[2] = 0
    comp[3] = 0
    w: int32 = 0
    r: int32 = 0
    while r < 4:
        if line[r] != 0:
            comp[w] = line[r]
            w = w + 1
        r = r + 1

    # 2) merge equal adjacent pairs once, front to back
    out: Array[4, int32]
    out[0] = 0
    out[1] = 0
    out[2] = 0
    out[3] = 0
    ow: int32 = 0
    j: int32 = 0
    while j < 4:
        if j < 3 and comp[j] != 0 and comp[j] == comp[j + 1]:
            merged: int32 = comp[j] * 2
            out[ow] = merged
            ow = ow + 1
            score = score + merged
            if merged == 2048:
                won = 1
            j = j + 2
        else:
            out[ow] = comp[j]
            ow = ow + 1
            j = j + 1

    # write back
    board[a] = out[0]
    board[b] = out[1]
    board[c] = out[2]
    board[d] = out[3]

    if out[0] != o0 or out[1] != o1 or out[2] != o2 or out[3] != o3:
        return 1
    return 0


# Apply a move. dir: 0=up 1=down 2=left 3=right. Returns 1 if any line
# changed (a "real" move that warrants spawning a new tile).
def _g_move(dir: int32) -> int32:
    changed: int32 = 0
    k: uint64 = 0
    while k < 4:
        ch: int32 = 0
        if dir == 2:                                  # left: row k, cols 0..3
            base: uint64 = k * 4
            ch = _g_slide_line(base, base + 1, base + 2, base + 3)
        elif dir == 3:                                # right: cols 3..0
            base2: uint64 = k * 4
            ch = _g_slide_line(base2 + 3, base2 + 2, base2 + 1, base2)
        elif dir == 0:                                # up: col k, rows 0..3
            ch = _g_slide_line(k, k + 4, k + 8, k + 12)
        else:                                         # down: rows 3..0
            ch = _g_slide_line(k + 12, k + 8, k + 4, k)
        if ch != 0:
            changed = 1
        k = k + 1
    return changed


# Is any move still possible? (empty cell, or any equal neighbour)
def _g_any_move() -> int32:
    if _g_count_empty() > 0:
        return 1
    r: uint64 = 0
    while r < 4:
        c: uint64 = 0
        while c < 4:
            v: int32 = board[r * 4 + c]
            if c < 3 and v == board[r * 4 + c + 1]:
                return 1
            if r < 3 and v == board[(r + 1) * 4 + c]:
                return 1
            c = c + 1
        r = r + 1
    return 0


def _g_reset():
    i: uint64 = 0
    while i < 16:
        board[i] = 0
        i = i + 1
    score = 0
    won = 0
    gameover = 0
    _g_spawn()
    _g_spawn()


# Try a move; if it changed the board, spawn and re-evaluate game state.
def _g_try_move(dir: int32):
    if gameover != 0:
        return
    if _g_move(dir) != 0:
        if _g_count_empty() > 0:
            _g_spawn()
        if _g_any_move() == 0:
            gameover = 1


# ---- rendering ------------------------------------------------------
# Render int v (>=0) into cell_txt as decimal; empty cells show "".
def _g_fmt_cell(v: int32):
    if v == 0:
        cell_txt[0] = 0
        return
    tmp: Array[8, uint8]
    t: uint64 = 0
    uv: uint32 = cast[uint32](v)
    while uv != 0:
        tmp[t] = cast[uint8](uv % 10) + 48
        uv = uv / 10
        t = t + 1
    p: uint64 = 0
    while t > 0:
        t = t - 1
        cell_txt[p] = tmp[t]
        p = p + 1
    cell_txt[p] = 0


def _g_refresh_cells():
    i: uint64 = 0
    while i < 16:
        _g_fmt_cell(board[i])
        hamui_set_text(cell_id[i], &cell_txt[0])
        i = i + 1


# status text buffer
stat_buf: Array[64, uint8]

def _g_put(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        stat_buf[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


def _g_put_num(pos: uint64, v: int32) -> uint64:
    if v == 0:
        stat_buf[pos] = 48
        return pos + 1
    tmp: Array[16, uint8]
    t: uint64 = 0
    uv: uint32 = cast[uint32](v)
    while uv != 0:
        tmp[t] = cast[uint8](uv % 10) + 48
        uv = uv / 10
        t = t + 1
    while t > 0:
        t = t - 1
        stat_buf[pos] = tmp[t]
        pos = pos + 1
    return pos


def _g_refresh_status(sb: int32):
    p: uint64 = 0
    p = _g_put(p, cast[Ptr[uint8]]("2048  score "))
    p = _g_put_num(p, score)
    if won != 0:
        p = _g_put(p, cast[Ptr[uint8]]("  -- YOU WIN! (keep going)"))
    if gameover != 0:
        p = _g_put(p, cast[Ptr[uint8]]("  -- GAME OVER (n=new)"))
    else:
        p = _g_put(p, cast[Ptr[uint8]]("  WASD/buttons to move"))
    stat_buf[p] = 0
    hamui_status_set(sb, &stat_buf[0])


# ====================================================================
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    # seed the LCG from the boot clock (falls back to the fixed constant
    # if jiffies reads 0)
    j: uint64 = sys_get_jiffies()
    if j != 0:
        rng_state = rng_state ^ (j * 2654435761)

    root: int32 = hamui_fixed()

    title: int32 = hamui_label("2048 - hamui")
    hamui_fixed_place(title, 20, 14)
    hamui_add(root, title)

    # 4x4 board as a grid of buttons (visible filled tiles)
    grid: int32 = hamui_grid()
    hamui_fixed_place(grid, 20, 40)
    hamui_add(root, grid)
    r: int32 = 0
    while r < 4:
        c: int32 = 0
        while c < 4:
            cb: int32 = hamui_button(" ")
            hamui_set_size(cb, 84, 84)
            hamui_grid_attach(grid, cb, c, r, 1, 1)
            cell_id[cast[uint64](r * 4 + c)] = cb
            c = c + 1
        r = r + 1

    # on-screen direction + new-game buttons (guaranteed control scheme)
    b_up: int32 = hamui_button("Up")
    hamui_set_size(b_up, 70, 30)
    hamui_fixed_place(b_up, 420, 60)
    hamui_add(root, b_up)

    b_left: int32 = hamui_button("Left")
    hamui_set_size(b_left, 70, 30)
    hamui_fixed_place(b_left, 380, 100)
    hamui_add(root, b_left)

    b_right: int32 = hamui_button("Right")
    hamui_set_size(b_right, 70, 30)
    hamui_fixed_place(b_right, 460, 100)
    hamui_add(root, b_right)

    b_down: int32 = hamui_button("Down")
    hamui_set_size(b_down, 70, 30)
    hamui_fixed_place(b_down, 420, 140)
    hamui_add(root, b_down)

    b_new: int32 = hamui_button("New")
    hamui_set_size(b_new, 70, 30)
    hamui_fixed_place(b_new, 420, 190)
    hamui_add(root, b_new)

    # keyboard-capture entry (click to focus, then type WASD / n)
    kh: int32 = hamui_label("keys: click entry, WASD=move n=new")
    hamui_fixed_place(kh, 380, 240)
    hamui_add(root, kh)
    kentry: int32 = hamui_entry()
    hamui_set_size(kentry, 230, 24)
    hamui_fixed_place(kentry, 380, 262)
    hamui_add(root, kentry)

    sb: int32 = hamui_statusbar("2048")
    hamui_set_size(sb, 640, 20)
    hamui_fixed_place(sb, 0, 460)
    hamui_add(root, sb)

    wid: int32 = hamui_window(root)
    if wid < 0:
        _g_puts(2, "ham2048: could not allocate a window\n")
        return 1

    _g_reset()
    _g_refresh_cells()
    _g_refresh_status(sb)
    _g_puts(1, "HAM2048 ready\n")

    # --- event / game loop -------------------------------------------
    while True:
        hamui_step()

        moved: int32 = 0

        # 1) on-screen buttons
        if hamui_signalled(b_up) != 0:
            _g_try_move(0)
            moved = 1
        if hamui_signalled(b_down) != 0:
            _g_try_move(1)
            moved = 1
        if hamui_signalled(b_left) != 0:
            _g_try_move(2)
            moved = 1
        if hamui_signalled(b_right) != 0:
            _g_try_move(3)
            moved = 1
        if hamui_signalled(b_new) != 0:
            _g_reset()
            moved = 1

        # 2) keyboard via focused entry: act on newly typed chars
        et: Ptr[uint8] = hamui_entry_text(kentry)
        elen: uint64 = 0
        if et != cast[Ptr[uint8]](0):
            while et[elen] != 0:
                elen = elen + 1
        if elen > 0:
            i: uint64 = last_seen
            while i < elen:
                ch: uint8 = et[i]
                if ch == 119 or ch == 87:             # w / W : up
                    _g_try_move(0)
                    moved = 1
                elif ch == 115 or ch == 83:           # s / S : down
                    _g_try_move(1)
                    moved = 1
                elif ch == 97 or ch == 65:            # a / A : left
                    _g_try_move(2)
                    moved = 1
                elif ch == 100 or ch == 68:           # d / D : right
                    _g_try_move(3)
                    moved = 1
                elif ch == 110 or ch == 78:           # n / N : new game
                    _g_reset()
                    moved = 1
                i = i + 1
            # clear the entry so it never fills (caret re-clamps to 0)
            hamui_set_text(kentry, cast[Ptr[uint8]](""))
            last_seen = 0
        else:
            last_seen = 0

        if moved != 0:
            _g_refresh_cells()
            _g_refresh_status(sb)

        sys_yield()

    return 0

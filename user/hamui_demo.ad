# user/hamui_demo.ad
#
# Demo app for the hamui widget toolkit (lib/hamui.ad). Builds a window
# with a label, a button, a text entry, a checkbox and a small list, then
# renders one pass. Driven headlessly by scripts/test_hamui_render.sh via
# the compositor's `hamUId render <wid>` stdout dump.
#
# This is the GTK/Qt-style consumer shape the DE rewrite will follow:
#   1. hamui_init()                build the toolkit state
#   2. build a widget tree         vbox of label/button/entry/check/list
#   3. hamui_window(root)          bind a wid + create the draw layer
#   4. hamui_render()              one layout+paint pass (emits hamML)
#   5. (interactive) hamui_run()   poll input + repaint forever
#
# Run mode is selected by argv[1]:
#   (none) / "render"  -> single render pass then exit (test/headless)
#   "run"              -> enter the interactive event loop

from lib.hamui import (
    hamui_init, hamui_vbox, hamui_fixed, hamui_label, hamui_button,
    hamui_entry, hamui_checkbox, hamui_list, hamui_list_add, hamui_add,
    hamui_window, hamui_window_wid, hamui_render, hamui_run,
    hamui_take_event, hamui_set_spacing, hamui_set_size, hamui_fixed_place
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def _d_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _d_puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _d_strlen(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    # --- build the widget tree ---------------------------------------
    # A FIXED container with grid-aligned placements so the headless
    # render test can probe each widget's fill at a known pixel. (A real
    # app would use hbox/vbox; hamui_fixed exists exactly for this kind of
    # precise placement.) Coordinates are chosen on the 40px probe grid
    # the compositor's `render` dump samples.
    root: int32 = hamui_fixed()
    hamui_set_spacing(root, 0, 0)                     # no padding: absolute coords

    title: int32 = hamui_label("hamui toolkit demo")
    hamui_fixed_place(title, 200, 8)
    hamui_add(root, title)

    # Button at (40,40) sized 120x80 -> covers probe pixels (40,40),
    # (80,40), (120,40), (40,80), (80,80), (120,80). Fill is #4a6da7.
    btn: int32 = hamui_button("Click me")
    hamui_set_size(btn, 120, 80)
    hamui_fixed_place(btn, 40, 40)
    hamui_add(root, btn)

    entry: int32 = hamui_entry()
    hamui_set_size(entry, 220, 24)
    hamui_fixed_place(entry, 200, 200)
    hamui_add(root, entry)

    chk: int32 = hamui_checkbox("Enable feature")
    hamui_fixed_place(chk, 40, 200)
    hamui_add(root, chk)

    # List at (40,280) sized 180x120 -> rows fill #181818, selection band
    # would be blue; just assert the list box renders.
    lst: int32 = hamui_list()
    hamui_set_size(lst, 180, 120)
    hamui_fixed_place(lst, 40, 280)
    hamui_list_add(lst, "alpha")
    hamui_list_add(lst, "beta")
    hamui_list_add(lst, "gamma")
    hamui_add(root, lst)

    # --- bind a window + draw layer ----------------------------------
    wid: int32 = hamui_window(root)
    if wid < 0:
        _d_puts(2, "hamui_demo: could not allocate a window\n")
        return 1

    # Report the wid so the test can render this exact window headlessly.
    _d_puts(1, "HAMUI_DEMO wid=")
    nb: Array[16, uint8]
    p: uint64 = 0
    v: int32 = wid
    if v == 0:
        nb[0] = 48
        p = 1
    else:
        tmp: Array[16, uint8]
        t: uint64 = 0
        uv: uint32 = cast[uint32](v)
        while uv != 0:
            tmp[t] = cast[uint8](uv % 10) + 48
            uv = uv / 10
            t = t + 1
        while t > 0:
            t = t - 1
            nb[p] = tmp[t]
            p = p + 1
    nb[p] = 10
    p = p + 1
    sys_write(1, &nb[0], p)
    _d_puts(1, "HAMUI_DEMO ready\n")

    # --- render --------------------------------------------------------
    mode: Ptr[uint8] = cast[Ptr[uint8]](0)
    if argc > 1:
        mode = cast[Ptr[uint8]](argv[1])

    if mode != cast[Ptr[uint8]](0) and mode[0] == 114 and mode[1] == 117 and \
       mode[2] == 110:                                  # "run"
        hamui_run()                                     # never returns
        return 0

    # Default: a single render pass for the headless test path.
    hamui_render()
    _d_puts(1, "HAMUI_DEMO rendered\n")

    # Drain any pending signals (none yet on a fresh render) for parity
    # with the interactive consumer shape.
    ev: int32 = hamui_take_event()
    while ev >= 0:
        ev = hamui_take_event()

    return 0

# user/hamui_demo.ad
#
# Demo app for the hamui widget toolkit (lib/hamui.ad). It exercises a
# broad spread of the MATE-class widget set so the compile genuinely
# covers every new code path, and so the headless `hamUId render <wid>`
# test can probe known pixels.
#
# This is the GTK/Qt-style consumer shape the DE rewrite will follow:
#   1. hamui_init()                build the toolkit state
#   2. build a widget tree         containers + widgets
#   3. hamui_window(root)          bind a wid + create the draw layer
#   4. hamui_render()              one layout+paint pass (emits hamML)
#   5. (interactive) hamui_run()   poll input + repaint forever
#
# Run mode is selected by argv[1]:
#   (none) / "render"  -> single render pass then exit (test/headless)
#   "run"              -> enter the interactive event loop
#
# LAYOUT NOTE: the root is a FIXED container so the headless probe grid
# can sample each widget at a known pixel. The probe-critical "Click me"
# button stays at (40,40) sized 120x80 (fill #4a6da7) — the render test
# asserts that exact fill at probe pixels (80,80)/(120,80). Everything
# else is placed so it never overlaps that region.

from lib.hamui import (
    hamui_init, hamui_vbox, hamui_hbox, hamui_fixed, hamui_label,
    hamui_button, hamui_entry, hamui_checkbox, hamui_list, hamui_list_add,
    hamui_add, hamui_window, hamui_window_wid, hamui_render, hamui_run,
    hamui_take_event, hamui_set_spacing, hamui_set_size, hamui_fixed_place,
    hamui_menubar, hamui_menu, hamui_menu_add, hamui_toolbar,
    hamui_statusbar, hamui_separator, hamui_radio, hamui_progress,
    hamui_slider, hamui_spin, hamui_combo, hamui_combo_add,
    hamui_notebook, hamui_notebook_page, hamui_image, hamui_scrolled,
    hamui_treeview, hamui_treeview_add, hamui_textview, hamui_textview_set,
    hamui_grid, hamui_grid_attach, hamui_dialog, hamui_set_expand,
    hamui_set_align, hamui_set_value,
    hamui_alert, hamui_confirm, hamui_filechooser_new, hamui_filechooser_run,
    hamui_filechooser_path, HAMUI_DLG_OK
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def _d_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _d_puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _d_strlen(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    # --- root (absolute placement for the probe grid) ----------------
    root: int32 = hamui_fixed()
    hamui_set_spacing(root, 0, 0)

    # Menubar across the very top.
    mbar: int32 = hamui_menubar()
    hamui_set_size(mbar, 640, 22)
    hamui_fixed_place(mbar, 0, 0)
    hamui_add(root, mbar)
    mfile: int32 = hamui_menu("File")
    hamui_add(mbar, mfile)
    mi_open: int32 = hamui_menu_add(mfile, "Open")
    mi_save: int32 = hamui_menu_add(mfile, "Save")
    mi_quit: int32 = hamui_menu_add(mfile, "Quit")
    medit: int32 = hamui_menu("Edit")
    hamui_add(mbar, medit)
    hamui_menu_add(medit, "Copy")
    hamui_menu_add(medit, "Paste")

    # Toolbar just under the menubar.
    tbar: int32 = hamui_toolbar()
    hamui_set_size(tbar, 640, 28)
    hamui_fixed_place(tbar, 0, 22)
    hamui_add(root, tbar)
    tb1: int32 = hamui_button("New")
    hamui_add(tbar, tb1)
    tb2: int32 = hamui_button("Del")
    hamui_add(tbar, tb2)
    hamui_add(tbar, hamui_separator(1))
    hamui_add(tbar, hamui_label("ready"))

    title: int32 = hamui_label("hamui toolkit demo")
    hamui_fixed_place(title, 240, 54)
    hamui_add(root, title)

    # PROBE BUTTON — keep at (40,40) sized 120x80, fill #4a6da7.
    btn: int32 = hamui_button("Click me")
    hamui_set_size(btn, 120, 80)
    hamui_fixed_place(btn, 40, 40)
    hamui_add(root, btn)

    # Entry + editable text below the probe button.
    entry: int32 = hamui_entry()
    hamui_set_size(entry, 160, 24)
    hamui_fixed_place(entry, 40, 132)
    hamui_add(root, entry)

    # Checkbox + radio group on the left.
    chk: int32 = hamui_checkbox("Enable feature")
    hamui_fixed_place(chk, 40, 164)
    hamui_add(root, chk)
    r1: int32 = hamui_radio("Low", 1)
    hamui_fixed_place(r1, 40, 186)
    hamui_add(root, r1)
    r2: int32 = hamui_radio("High", 1)
    hamui_fixed_place(r2, 110, 186)
    hamui_add(root, r2)
    hamui_set_value(r1, 0)

    # Progress + slider + spin on the right column.
    prog: int32 = hamui_progress()
    hamui_set_size(prog, 200, 20)
    hamui_fixed_place(prog, 240, 80)
    hamui_set_value(prog, 60)
    hamui_add(root, prog)

    sld: int32 = hamui_slider(0, 100, 35)
    hamui_set_size(sld, 200, 22)
    hamui_fixed_place(sld, 240, 108)
    hamui_add(root, sld)

    spn: int32 = hamui_spin(0, 10, 3)
    hamui_set_size(spn, 90, 24)
    hamui_fixed_place(spn, 240, 136)
    hamui_add(root, spn)

    cmb: int32 = hamui_combo()
    hamui_set_size(cmb, 120, 24)
    hamui_fixed_place(cmb, 340, 136)
    hamui_combo_add(cmb, "Red")
    hamui_combo_add(cmb, "Green")
    hamui_combo_add(cmb, "Blue")
    hamui_add(root, cmb)

    img: int32 = hamui_image(40, 40)
    hamui_fixed_place(img, 470, 80)
    hamui_add(root, img)

    # A notebook with two tabs, each carrying a couple widgets.
    nb: int32 = hamui_notebook()
    hamui_set_size(nb, 250, 130)
    hamui_fixed_place(nb, 380, 170)
    hamui_add(root, nb)
    p1: int32 = hamui_notebook_page(nb, "One")
    hamui_add(p1, hamui_label("page one"))
    hamui_add(p1, hamui_button("go"))
    p2: int32 = hamui_notebook_page(nb, "Two")
    hamui_add(p2, hamui_label("page two"))

    # A grid of labels + entries (form-style), bottom-left.
    grid: int32 = hamui_grid()
    hamui_fixed_place(grid, 40, 210)
    hamui_add(root, grid)
    hamui_grid_attach(grid, hamui_label("Name:"), 0, 0, 1, 1)
    gname: int32 = hamui_entry()
    hamui_set_size(gname, 120, 22)
    hamui_grid_attach(grid, gname, 1, 0, 1, 1)
    hamui_grid_attach(grid, hamui_label("Port:"), 0, 1, 1, 1)
    gport: int32 = hamui_spin(0, 9999, 22)
    hamui_grid_attach(grid, gport, 1, 1, 1, 1)

    # A treeview (rows x cols) with selectable rows, bottom-middle.
    tree: int32 = hamui_treeview(2)
    hamui_set_size(tree, 230, 90)
    hamui_fixed_place(tree, 240, 250)
    hamui_treeview_add(tree, "file.txt\t12K")
    hamui_treeview_add(tree, "image.png\t48K")
    hamui_treeview_add(tree, "notes.md\t2K")
    hamui_add(root, tree)

    # A multi-line editable textview, bottom-right.
    tv: int32 = hamui_textview()
    hamui_set_size(tv, 150, 90)
    hamui_fixed_place(tv, 480, 130)
    hamui_textview_set(tv, "hello\nworld\nedit me")
    hamui_add(root, tv)

    # A scrolledwindow clipping a tall list.
    sc: int32 = hamui_scrolled()
    hamui_set_size(sc, 180, 80)
    hamui_fixed_place(sc, 40, 290)
    biglist: int32 = hamui_list()
    hamui_set_size(biglist, 160, 300)
    hamui_list_add(biglist, "alpha")
    hamui_list_add(biglist, "beta")
    hamui_list_add(biglist, "gamma")
    hamui_list_add(biglist, "delta")
    hamui_add(sc, biglist)
    hamui_add(root, sc)

    # Status bar across the bottom edge.
    sb: int32 = hamui_statusbar("hamui demo ready")
    hamui_set_size(sb, 640, 20)
    hamui_fixed_place(sb, 0, 460)
    hamui_add(root, sb)

    # A (hidden) modal dialog, shown only in interactive mode on demand.
    dlg: int32 = hamui_dialog("About hamui")
    hamui_add(dlg, hamui_label("MATE-class toolkit"))
    hamui_add(dlg, hamui_button("OK"))

    # --- bind a window + draw layer ----------------------------------
    wid: int32 = hamui_window(root)
    if wid < 0:
        _d_puts(2, "hamui_demo: could not allocate a window\n")
        return 1

    _d_puts(1, "HAMUI_DEMO wid=")
    nb2: Array[16, uint8]
    p: uint64 = 0
    v: int32 = wid
    if v == 0:
        nb2[0] = 48
        p = 1
    else:
        tmp: Array[16, uint8]
        t: uint64 = 0
        uv: uint32 = cast[uint32](v)
        while uv != 0:
            tmp[t] = cast[uint8](uv % 10) + 48
            uv = uv / 10
            t = t + 1
        while t > 0:
            t = t - 1
            nb2[p] = tmp[t]
            p = p + 1
    nb2[p] = 10
    p = p + 1
    sys_write(1, &nb2[0], p)
    _d_puts(1, "HAMUI_DEMO ready\n")

    # --- render --------------------------------------------------------
    mode: Ptr[uint8] = cast[Ptr[uint8]](0)
    if argc > 1:
        mode = cast[Ptr[uint8]](argv[1])

    # "dialog" mode: demonstrate the modal alert + file-chooser composites.
    # A confirm gates an Open dialog; the chosen path is echoed to stdout.
    # This is the GtkMessageDialog / GtkFileChooser usage shape apps follow.
    if mode != cast[Ptr[uint8]](0) and mode[0] == 100 and mode[1] == 105 and \
       mode[2] == 97:                                   # "dialog"
        if hamui_confirm("Open file", "Browse for a file?") == HAMUI_DLG_OK:
            fc: int32 = hamui_filechooser_new("Open File", "/")
            if hamui_filechooser_run(fc) == HAMUI_DLG_OK:
                _d_puts(1, "HAMUI_DEMO chose=")
                _d_puts(1, hamui_filechooser_path())
                _d_puts(1, "\n")
            hamui_alert("Done", "File chooser closed.")
        return 0

    if mode != cast[Ptr[uint8]](0) and mode[0] == 114 and mode[1] == 117 and \
       mode[2] == 110:                                  # "run"
        hamui_run()                                     # never returns
        return 0

    # Default: a single render pass for the headless test path.
    hamui_render()
    _d_puts(1, "HAMUI_DEMO rendered\n")

    ev: int32 = hamui_take_event()
    while ev >= 0:
        ev = hamui_take_event()

    return 0

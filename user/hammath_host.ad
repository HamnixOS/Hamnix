# user/hammath_host.ad — HOST driver + render harness for HamMath, the
# expression-calculator scene app (built for the x86_64-linux Adder target;
# runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hammathcore.ad): inits the
# keypad, lays out for the default 200x300 window, builds the scene display list
# and RASTERIZES it with lib/hamui_host.ad into a PPM a human/agent can LOOK at.
# Then it EVALUATES a battery of expressions through the pure evaluator and
# asserts operator precedence, parentheses, unary minus, decimals and
# divide-by-zero, and drives the KEYPAD (keyboard + an on-screen pointer press)
# to build "2+3*4" and press '=', rendering a second "after" PPM.
#
# No sockets, no Plan 9: reads argv + writes two files. TEST shim only.
#
# USAGE (built to build/host/hammath_host):
#   hammath_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hammathcore import hammath_init, hammath_clear, hammath_layout, \
    hammath_build_scene, hammath_key_line, hammath_key_at, hammath_press_at, \
    hammath_eval_cstr, hammath_err, hammath_display, hammath_release, \
    hammath_result_str


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hammath_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Feed one keyboard press for ASCII byte `code` through the key-line parser.
kl: Array[16, uint8]


def _press_key(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    return hammath_key_line(&kl[0], p)


# Drive a NUL-terminated ASCII key string through the key-line parser.
def _drive(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _press_key(cast[int32](s[i]))
        i = i + 1


# Evaluate one expression through the PURE core and report:
#   EVAL <name> <display>        (or ERR if the error flag latched)
def _eval(name: Ptr[uint8], expr: Ptr[uint8]):
    hammath_eval_cstr(expr)
    _o_str(cast[Ptr[uint8]]("EVAL "))
    _o_str(name)
    _o_ch(32)
    _o_str(hammath_result_str())
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hammath_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 200
    H: int32 = 300
    hammath_init()
    hammath_layout()
    hammath_clear()

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DISPLAY0 "))
    _o_str(hammath_display())
    _o_ch(10)
    # Sampled raster pixels: case bg, LCD bg, a keypad-button face.
    _o_str(cast[Ptr[uint8]]("PIX 2 2 "))
    _o_hexcol(hamui_host_pixel(2, 2))                  # case #2b2f36
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 20 "))
    _o_hexcol(hamui_host_pixel(20, 20))                # LCD #0d1410
    _o_ch(10)
    _o_flush()

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- CORE EVALUATOR BATTERY: precedence, parens, unary, decimals -----
    _eval(cast[Ptr[uint8]]("add"),      cast[Ptr[uint8]]("2+3"))          # 5
    _eval(cast[Ptr[uint8]]("sub"),      cast[Ptr[uint8]]("7-2"))          # 5
    _eval(cast[Ptr[uint8]]("mul"),      cast[Ptr[uint8]]("6*7"))          # 42
    _eval(cast[Ptr[uint8]]("prec"),     cast[Ptr[uint8]]("2+3*4"))        # 14
    _eval(cast[Ptr[uint8]]("prec2"),    cast[Ptr[uint8]]("2*3+4"))        # 10
    _eval(cast[Ptr[uint8]]("paren"),    cast[Ptr[uint8]]("(2+3)*4"))      # 20
    _eval(cast[Ptr[uint8]]("nestparen"),cast[Ptr[uint8]]("((1+2)*(3+4))"))# 21
    _eval(cast[Ptr[uint8]]("unary"),    cast[Ptr[uint8]]("-(3+2)"))       # -5
    _eval(cast[Ptr[uint8]]("unary2"),   cast[Ptr[uint8]]("10+-3"))        # 7
    _eval(cast[Ptr[uint8]]("div"),      cast[Ptr[uint8]]("10/4"))         # 2.5
    _eval(cast[Ptr[uint8]]("decmul"),   cast[Ptr[uint8]]("1.5*2"))        # 3
    _eval(cast[Ptr[uint8]]("chain"),    cast[Ptr[uint8]]("1+2+3+4"))      # 10
    _eval(cast[Ptr[uint8]]("ltr"),      cast[Ptr[uint8]]("10-3-2"))       # 5
    _eval(cast[Ptr[uint8]]("divzero"),  cast[Ptr[uint8]]("5/0"))          # ERR
    _eval(cast[Ptr[uint8]]("malformed"),cast[Ptr[uint8]]("2+*3"))         # ERR
    _eval(cast[Ptr[uint8]]("unbalanced"),cast[Ptr[uint8]]("(2+3"))        # ERR
    _o_flush()

    # ---- KEYPAD path: type "2+3*4" then '=' through the key wire ---------
    hammath_clear()
    _drive(cast[Ptr[uint8]]("2+3*4"))
    _o_str(cast[Ptr[uint8]]("EXPR typed "))
    _o_str(hammath_display())                          # "2+3*4"
    _o_ch(10)
    _drive(cast[Ptr[uint8]]("="))
    _o_str(cast[Ptr[uint8]]("KEYRESULT "))
    _o_str(hammath_display())                          # "14"
    _o_ch(10)

    # ---- POINTER path: click the '(' key (index 1) then type "2+3)*4=" ---
    hammath_clear()
    kp: int64 = hammath_key_at(cast[int64](8 + 46 + 22),
                               cast[int64](60 + 22))    # somewhere in row 0
    _o_str(cast[Ptr[uint8]]("KEYAT "))
    _o_dec(kp)
    _o_ch(10)
    hammath_clear()
    hammath_press_at(1)                                # '(' key index
    hammath_release()
    _drive(cast[Ptr[uint8]]("2+3)*4="))
    _o_str(cast[Ptr[uint8]]("CLICKRESULT "))
    _o_str(hammath_display())                          # "20"
    _o_ch(10)
    _o_flush()

    # ---- AFTER render: the running expression "12+3*4" mid-entry so the PNG
    # a human LOOKS at shows the whole formula on the LCD over the keypad.
    hammath_clear()
    _drive(cast[Ptr[uint8]]("12+3*4"))
    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("PRIMS2 "))
    _o_dec(cast[int64](prims2))
    _o_ch(10)
    _o_flush()
    return 0

# user/wget.ad — fetch a URL over HTTP/HTTPS and save the body to a file.
#
# Native Adder front-end over user/http9.ad (HTTP-over-the-/net file
# tree; ARCH §10 — there are no BSD sockets). Usage:
#
#   wget URL                 save the body to the URL-path basename
#                            (or index.html when the path ends in '/')
#   wget -O FILE URL         save the body to FILE instead
#
# Prints a short summary line to stderr. Exit status: 0 on a 2xx
# response, non-zero on an HTTP error (>= 400) or transport failure.
#
# Compiler-quirk discipline (memory/feedback_compiler_quirks.md U9):
# every large buffer is a top-level BSS Array — never a frame local.
# String literals are materialised inline; no adjacent string concat.

from user.http9 import http_get

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32


RESP_CAP: uint64 = 1048576
resp_buf:  Array[1048576, uint8]
# Derived default output filename (basename of the URL path).
name_buf:  Array[512, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, value: int64):
    if value < 0:
        sys_write(fd, "-", 1)
        value = 0 - value
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = cast[uint64](value)
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def _write_full(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    written: uint64 = 0
    while written < count:
        room: uint64 = count - written
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](buf) + written)
        rc: int64 = sys_write(fd, ptr, room)
        if rc < 0:
            return rc
        if rc == 0:
            return cast[int64](written)
        written = written + cast[uint64](rc)
    return cast[int64](written)


def _is_flag(s: Ptr[uint8], f: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while s[i] != 0 and f[i] != 0:
        if s[i] != f[i]:
            return 0
        i = i + 1
    if s[i] == 0 and f[i] == 0:
        return 1
    return 0


def _derive_name(url: Ptr[uint8]):
    # The default output name is the basename of the URL path. Skip the
    # scheme + authority, then take the segment after the last '/'.
    # A path that ends in '/' (or has no path) yields "index.html".
    n: uint64 = strlen_u8(url)
    # Find end of authority: skip "scheme://", then up to the first '/'.
    i: uint64 = 0
    # Skip past "://" if present.
    while i + 2 < n:
        if url[i] == 58 and url[i + 1] == 47 and url[i + 2] == 47:    # "://"
            i = i + 3
            break
        i = i + 1
    if i + 2 >= n:
        i = 0
    # Now scan from i to the end; remember the position after the last
    # '/'. Stop the "path" at a '?' or '#' (query / fragment).
    last_slash: int64 = -1
    seg_end: uint64 = n
    j: uint64 = i
    while j < n:
        c: uint8 = url[j]
        if c == 63 or c == 35:                            # '?' or '#'
            seg_end = j
            break
        if c == 47:                                       # '/'
            last_slash = cast[int64](j)
        j = j + 1
    start: uint64 = 0
    if last_slash >= 0:
        start = cast[uint64](last_slash) + 1
    else:
        start = i
    # Empty segment (path ended in '/') -> index.html.
    if start >= seg_end:
        s: Ptr[uint8] = "index.html"
        k: uint64 = 0
        while s[k] != 0:
            name_buf[k] = s[k]
            k = k + 1
        name_buf[k] = 0
        return
    o: uint64 = 0
    p: uint64 = start
    while p < seg_end and o + 1 < 512:
        name_buf[o] = url[p]
        o = o + 1
        p = p + 1
    name_buf[o] = 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    out_path: Ptr[uint8] = cast[Ptr[uint8]](0)
    url:      Ptr[uint8] = cast[Ptr[uint8]](0)

    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if _is_flag(a, "-O") != 0:
            i = i + 1
            if i >= argc:
                write_str(2, "wget: option -O requires a FILE argument\n")
                return 2
            out_path = cast[Ptr[uint8]](argv[cast[uint64](i)])
        else:
            url = a
        i = i + 1

    if cast[uint64](url) == 0:
        write_str(2, "usage: wget [-O FILE] URL\n")
        return 2

    if cast[uint64](out_path) == 0:
        _derive_name(url)
        out_path = &name_buf[0]

    status:   int64 = 0
    body_off: uint64 = 0
    body_len: uint64 = 0
    rc: int64 = http_get(url, &resp_buf[0], RESP_CAP,
                         &status, &body_off, &body_len)
    if rc < 0:
        if rc == -1:
            write_str(2, "wget: malformed or unsupported URL\n")
        elif rc == -2:
            write_str(2, "wget: could not connect to host\n")
        elif rc == -7:
            write_str(2, "wget: chunked transfer-encoding not supported\n")
        else:
            write_str(2, "wget: transport error fetching URL\n")
        return 7

    if status >= 400:
        write_str(2, "wget: server returned HTTP ")
        write_dec(2, status)
        write_str(2, "\n")
        return 8

    out_fd: int32 = sys_open_write(cast[Ptr[char]](out_path))
    if out_fd < 0:
        write_str(2, "wget: cannot open output file ")
        write_str(2, out_path)
        write_str(2, "\n")
        return 3

    body_ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](&resp_buf[0]) + body_off)
    if _write_full(out_fd, body_ptr, body_len) < 0:
        sys_close(out_fd)
        write_str(2, "wget: write error\n")
        return 4
    sys_close(out_fd)

    # Summary line to stderr: "wget: saved <n> bytes to <file>".
    write_str(2, "wget: saved ")
    write_dec(2, cast[int64](body_len))
    write_str(2, " bytes to ")
    write_str(2, out_path)
    write_str(2, "\n")
    return 0

# user/hamtoast.ad
#
# hamtoast — the MATE-style transient notification TOAST, as a SCENE-mode
# client (docs/de_scene_file_arch.md). In the production runlevel-5 scene
# DE the kernel scene compositor owns /dev/fb; the legacy hamUId-blit
# notification banner (user/hamnotif.ad) paints nothing there, so the toast
# is rewritten as a proper scene client following user/hamabout.ad and
# user/hamsessui.ad exactly: it `newwindow`s, sets geometry/decorate/z/title
# on /ctl, emits a scene display list to /dev/wsys/<wid>/scene, and reads its
# OWN input from /dev/wsys/<wid>/event.
#
# CONTENT comes from argv (the panel notification broker spawns one toast per
# drained /dev/wsys/post record):
#
#   hamtoast "<title>" "<body>"
#
# LIFETIME == VISIBILITY: the toast appears in the TOP-RIGHT corner, shows
# the title (bold) + body, and AUTO-DISMISSES after a ~4s wall-clock timeout
# OR on a click anywhere (MATE banner behaviour). It is undecorated chrome
# (decorate 0) so it never lands in the taskbar window list, and floats above
# ordinary windows (z 8) but below modal dialogs.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_exit(code: int32)

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_stroke, hamscene_commit


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Read the framebuffer width from /dev/fb's "W H PITCH BPP FMT\n" header.
def _screen_width() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return 800
    hdr: Array[64, uint8]
    r: int64 = sys_read(fd, &hdr[0], 63)
    sys_close(fd)
    if r <= 0:
        return 800
    w: int64 = 0
    i: uint64 = 0
    while i < cast[uint64](r) and hdr[i] >= 48 and hdr[i] <= 57:
        w = w * 10 + cast[int64](hdr[i]) - 48
        i = i + 1
    if w <= 0:
        return 800
    return w


# Parse "m <x> <y> <buttons> ..." → 1 + fills bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bbtn[0] = vals[2]
    return 1


# ====================================================================
# CONTENT (from argv, copied into fixed buffers).
# ====================================================================
title_buf: Array[64, uint8]
body_buf:  Array[96, uint8]


def _copy_arg(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    n: uint64 = 0
    while src[n] != 0 and n < cap - 1:
        c: uint8 = src[n]
        if c == 10 or c == 9:
            c = 32
        dst[n] = c
        n = n + 1
    dst[n] = 0


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
WIN_W: int32 = 300
WIN_H: int32 = 76
PAD:   int32 = 14
GLYPH_W: int32 = 8


def emit_scene(wid: int32):
    hamscene_begin()
    # Banner body + accent border (MATE notify-osd dark bubble).
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#2c3242"))
    hamscene_stroke(0, 0, WIN_W, WIN_H, 1, cast[Ptr[uint8]]("#6e96e6"))
    # A thin accent bar down the left edge (notification "category" stripe).
    hamscene_fill(0, 0, 4, WIN_H, cast[Ptr[uint8]]("#6e96e6"))

    # Title (bold) + body line.
    hamscene_glyphs_bold(PAD, PAD, &title_buf[0], cast[Ptr[uint8]]("#eef4ff"))
    hamscene_glyphs(PAD, PAD + 26, &body_buf[0], cast[Ptr[uint8]]("#b8c4dc"))

    hamscene_commit(wid)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    # argv[1] = title, argv[2] = body (optional).
    if argc >= 2:
        _copy_arg(&title_buf[0], cast[Ptr[uint8]](argv[1]), 64)
    else:
        _copy_arg(&title_buf[0], cast[Ptr[uint8]]("Notification"), 64)
    if argc >= 3:
        _copy_arg(&body_buf[0], cast[Ptr[uint8]](argv[2]), 96)
    else:
        body_buf[0] = 0

    sw: int64 = _screen_width()
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamtoast] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp:  Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    # Top-right corner, 16px inset from the right edge and 36px down (clear of
    # a top panel). The compositor clamps to the real screen.
    ox: int64 = sw - cast[int64](WIN_W) - 16
    if ox < 0:
        ox = 0
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        geo: Array[64, uint8]
        gp: uint64 = 0
        pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry ")
        j: uint64 = 0
        while pre[j] != 0:
            geo[gp] = pre[j]
            gp = gp + 1
            j = j + 1
        gp = gp + _u64_to_dec(cast[uint64](ox), &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(36, &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_W), &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(cast[uint64](WIN_H), &geo[gp])
        geo[gp] = 10
        gp = gp + 1
        sys_write(cfd, &geo[0], gp)
        sys_close(cfd)
    # Undecorated (no SSD chrome, and excluded from the taskbar windows list,
    # which only reports decorate!=0 windows).
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
        sys_close(cfd2)
    # Float above ordinary windows but below modal dialogs (z 8).
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 8\n"))
        sys_close(cfd3)

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamtoast] scene window ready\n"))

    # Auto-dismiss after ~4s. The 100Hz jiffy clock gives 400 jiffies.
    start: uint64 = sys_get_jiffies()
    TIMEOUT: uint64 = 400

    btn_down: int32 = 0
    evbuf: Array[256, uint8]
    while True:
        # Timeout check.
        if sys_get_jiffies() - start >= TIMEOUT:
            sys_exit(0)

        # --- POINTER: non-blocking read so the timeout still fires when the
        # toast is never clicked. A click anywhere on the toast dismisses it.
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 3) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    sys_exit(0)
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        # cooperative yield window (~30ms) between polls.
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

# user/hamtermscene.ad
#
# Scene-file DE terminal (docs/de_scene_file_arch.md §16 step 8).
#
# A REAL terminal drawn entirely as a scene display list. It spawns ONE
# long-lived interactive `/bin/hamsh` over a pair of pipes (exactly the
# bridge user/hamterm.ad / user/sshd.ad use) and renders the SHELL'S
# OUTPUT as a scrolling monospace glyph grid (the `glyphs` primitive, the
# terminal tier per §4). It is a decorated window (decorate 1) so the
# compositor draws an SSD titlebar and the window is movable.
#
# INPUT (§11)
# -----------
# The compositor's focus router delivers KEY events to the FOCUSED window
# on /dev/wsys/<wid>/keys as ASCII "<type> <code>\n" lines (type 'd' =
# press, 'u' = release; code is a raw ASCII byte) — the SAME stream
# lib/hamui.ad and user/hamecho.ad consume. We read that file, accumulate
# typed bytes into a command line, and on Enter ('\n' / '\r') feed the
# line + '\n' to the shell's stdin. Backspace edits the line.
#
# POINTER events arrive on /dev/wsys/<wid>/event ("m <x> <y> <buttons>
# <dz>" lines — the in-kernel router pushes pointer lines onto the EVENT
# ring, NOT a separate /pointer file). A terminal does NOT type its mouse,
# so x/y/buttons are ignored (no glyph spam) — but the wheel-notch dz (5th
# field, signed) drives the scrollback view: dz>0 (wheel up) shows OLDER
# rows, dz<0 walks back toward the live tail. The click that gives us focus
# is handled entirely by the compositor.
#
# Each tick we non-blockingly drain the shell's stdout pipe into a bounded
# scrollback ring, re-emit our scene (damage-scoped: one commit per change)
# and commit. Type `ls`+Enter -> the shell's prompt + output stream into
# the grid, not pointer noise.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_pipechan() -> int32
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64,
                       timeout_ms: int64) -> int64
extern def sys_fdbind(pid: int32, fdnum: int32, kind: int32,
                      arg: int32) -> int32

# devfd channel-kinds + spawn sentinel (match user/hamsh.ad / devfd.ad).
DEVFD_CONS:     int32 = 1
DEVFD_PIPE_R:   int32 = 2
DEVFD_PIPE_W:   int32 = 3
SPAWN_STDIO_NS: int32 = -2

from lib.p9 import spawn

# task #323: grid-text SELECTION (click-drag to select shell output, copy an
# error message out of the terminal). lib/htermsel.ad owns the anchor/caret cell
# model, the pixel->cell map, the text-flow span test + cell-span->text
# extraction, and the file-backed clipboard put/get (/dev/snarf[.primary]).
from lib.htermsel import htsel_reset, htsel_begin, htsel_extend, htsel_active, \
    htsel_cell_selected, htsel_extract, htsel_pix_to_cell, \
    htsel_clip_put, htsel_clip_get, \
    htsel_anchor_row, htsel_anchor_col, htsel_caret_row, htsel_caret_col


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    # Write "newwindow", then re-open ctl for READ to fetch the wid (a
    # write-only fd is not reliably readable).
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# BUG 1b: the grid is now RESIZE-AWARE. The window can grow (maximize / snap
# / free-resize) so the row/col counts are runtime variables, not constants,
# recomputed from the window's pixel w/h when an "r <w> <h>" resize event
# arrives on /event. The backing arrays are sized to a generous MAX (a full
# 1280x800 screen worth of cells); the ACTIVE grid is term_rows_n x term_cols_n.
# The per-row STRIDE in term_rows[] stays fixed at TERM_STRIDE so indexing is
# simple regardless of the active column count.
TERM_STRIDE:    uint64 = 160              # max cols per row (1280px / 8px glyph)
TERM_MAX_ROWS:  uint64 = 40              # max rows (800px / 20px line)
TERM_GLYPH_W:   int64  = 8               # glyph advance used by the cache font
TERM_LINE_H:    int64  = 20              # line pitch in _emit_scene (y = 6 + r*20)

# DEFAULT window size. hamtermscene creates its OWN decorated window via the
# `geometry` ctl verb in main() (it is NOT sized by hamUId's
# daemon_spawn_terminal — that path drives the legacy /bin/hamterm bridge).
# The kernel wsys compositor (the live DE path) treats this w x h as the
# window's CONTENT canvas and draws the SSD titlebar ABOVE it, so the whole
# w x h is visible content — the glyph grid that fills term_w x term_h is the
# visible area, no chrome is subtracted on screen.
#
# PRIOR BUG (user-reported "bottom input row + right columns cut off, fixed by
# maximizing"): main() created a small 360x200 window but the grid constants
# claimed 480x320 (15 rows x 20px = 300px tall, 59 cols x 8px = 472px wide),
# so ~5 bottom rows (INCLUDING the live input/prompt row) and ~14 right
# columns rendered OUTSIDE the 360x200 window and were clipped off. Maximizing
# grew the window to fit the oversized grid, hiding the bug.
#
# FIX: a single source of truth. TERM_DEF_W/H is the default window the
# geometry ctl write in main() uses AND what the initial grid is derived from,
# via the SAME formula _term_apply_resize uses, so the first frame fits with
# zero right/bottom clipping and no first-resize jump. 600x400 gives a roomy
# ~74x19 grid that fits the 640x480 screen below the panel + titlebar.
#   cols = (600 - 8) / TERM_GLYPH_W(8) = 74
#   rows = (400 - 6) / TERM_LINE_H(20) = 19
# The background fill in _emit_scene is sized to term_w x term_h, so these
# must equal the real window or the painted background under-fills it.
TERM_DEF_W: int64 = 600                    # default window CONTENT width (px)
TERM_DEF_H: int64 = 400                    # default window CONTENT height (px)
term_w: int64 = 600                       # current window CONTENT width (px)
term_h: int64 = 400                       # current window CONTENT height (px)
term_rows_n: uint64 = 19                  # active row count  ((400-6)/20)
term_cols_n: uint64 = 74                  # active column count ((600-8)/8)

# A ring of text rows the terminal renders as glyphs. The bottom row is the
# LIVE edit line (prompt-relative input echo); rows above it are the committed
# scrollback the shell produced.
term_rows: Array[6400, uint8]             # TERM_MAX_ROWS * TERM_STRIDE
term_row_len: Array[40, uint64]           # TERM_MAX_ROWS

# --- retained scrollback history (mouse-wheel scrollback) -------------
# The live grid (term_rows) only holds the VISIBLE window; _term_scroll
# drops the top row when output pushes past the bottom. To let the user
# wheel BACK through earlier output we keep a separate history ring of the
# rows that scrolled off the top. It is a fixed-depth ring of full-width
# row images, oldest evicted when full.
#
# term_view_off is the scroll-back distance in ROWS from the live tail:
#   0          == auto-follow (render the live grid, cursor at bottom)
#   k (k > 0)  == show the window shifted UP by k rows, so the top k rows
#                 of the viewport come from history and the live grid's
#                 bottom k rows are hidden above the fold.
# Wheel-up raises term_view_off (older); wheel-down lowers it toward 0
# (resume live tail). Clamped to [0, sb_count].
SB_MAX_ROWS: uint64 = 400                 # retained scrollback depth (rows)
sb_rows:    Array[64000, uint8]           # SB_MAX_ROWS * TERM_STRIDE
sb_len:     Array[400, uint64]            # live byte count per history row
sb_head:    uint64 = 0                    # next-write slot (ring cursor)
sb_count:   uint64 = 0                    # number of rows retained (<= SB_MAX_ROWS)
term_view_off: uint64 = 0                 # rows scrolled back from live tail


def _sb_push(src: Ptr[uint8], n: uint64):
    # Append one row image (the row about to be discarded from the top of
    # the live grid) into the history ring. Oldest row is evicted when the
    # ring is full.
    slot: uint64 = sb_head
    base: uint64 = slot * TERM_STRIDE
    cn: uint64 = n
    if cn > TERM_STRIDE:
        cn = TERM_STRIDE
    k: uint64 = 0
    while k < cn:
        sb_rows[base + k] = src[k]
        k = k + 1
    sb_len[slot] = cn
    sb_head = (sb_head + 1) % SB_MAX_ROWS
    if sb_count < SB_MAX_ROWS:
        sb_count = sb_count + 1


def _sb_row_ptr(back: uint64) -> uint64:
    # Byte offset into sb_rows of history row `back` (1 = most-recently
    # evicted, i.e. the row just above the live grid). Caller guarantees
    # 1 <= back <= sb_count.
    slot: uint64 = (sb_head + SB_MAX_ROWS - back) % SB_MAX_ROWS
    return slot * TERM_STRIDE


# Checksum of the VISIBLE grid (rows + lengths). We re-emit the scene only
# when this changes, NOT merely when bytes were consumed. hamsh repaints its
# prompt to stdout every ~3s (its idle heartbeat calls _ed_redraw), which our
# ANSI filter collapses to the SAME visible glyphs — re-committing that
# identical frame is exactly the periodic full-window repaint the flicker
# gate forbids. Hashing the grid makes those no-op repaints free.
def _grid_hash() -> uint64:
    h: uint64 = 1469598103934665603              # FNV-1a offset basis
    # Fold in the scroll-back view offset so changing what the viewport
    # shows (wheel up/down through history) re-commits the frame even when
    # the live grid bytes are unchanged.
    h = (h ^ term_view_off) * 1099511628211
    # Fold the selection state so highlighting / clearing a selection re-commits
    # the frame even when the underlying grid bytes are unchanged (#323).
    h = (h ^ cast[uint64](htsel_active())) * 1099511628211
    if htsel_active() != 0:
        h = (h ^ cast[uint64](htsel_anchor_row())) * 1099511628211
        h = (h ^ cast[uint64](htsel_anchor_col())) * 1099511628211
        h = (h ^ cast[uint64](htsel_caret_row())) * 1099511628211
        h = (h ^ cast[uint64](htsel_caret_col())) * 1099511628211
    r: uint64 = 0
    while r < term_rows_n:
        ln: uint64 = term_row_len[r]
        h = (h ^ ln) * 1099511628211
        base: uint64 = r * TERM_STRIDE
        k: uint64 = 0
        while k < ln:
            h = (h ^ cast[uint64](term_rows[base + k])) * 1099511628211
            k = k + 1
        r = r + 1
    return h


def _term_clear():
    r: uint64 = 0
    while r < term_rows_n:
        term_row_len[r] = 0
        r = r + 1


def _term_set_row(r: uint64, s: Ptr[uint8]):
    n: uint64 = 0
    base: uint64 = r * TERM_STRIDE
    while s[n] != 0 and n < term_cols_n:
        term_rows[base + n] = s[n]
        n = n + 1
    term_row_len[r] = n


def _term_apply_resize(nw: int64, nh: int64):
    # BUG 1b: a resize event ("r <w> <h>") changed our window's content size.
    # Recompute the glyph grid (cols/rows) from the new pixel size so the
    # terminal fills the whole window and scrolls correctly. Content already
    # in the grid is kept in place (rows are bottom-anchored by the scroll
    # logic). Growing exposes more scrollback rows; shrinking drops the top.
    if nw < 8:
        nw = 8
    if nh < 20:
        nh = 20
    term_w = nw
    term_h = nh
    # Columns: leave a small left/right margin (glyphs start at x=6).
    nc: uint64 = cast[uint64]((nw - 8) / TERM_GLYPH_W)
    if nc < 8:
        nc = 8
    if nc > TERM_STRIDE:
        nc = TERM_STRIDE
    # Rows: first glyph cell top at y=6, line pitch TERM_LINE_H, glyph cell 16px
    # tall. The LAST row's bottom pixel is 6 + (nr-1)*TERM_LINE_H + 16, which
    # must be <= nh or that row (the live input/prompt row when following the
    # tail) is clipped off the bottom of the window — the user-reported bug.
    # Solve for nr: nr <= (nh - 6 - 16)/TERM_LINE_H + 1 = (nh - 2)/TERM_LINE_H.
    # Using (nh - 2) instead of (nh - 6) guarantees the bottom row's full
    # 16px-tall glyph cell fits inside the window content area.
    nr: uint64 = cast[uint64]((nh - 2) / TERM_LINE_H)
    if nr < 2:
        nr = 2
    if nr > TERM_MAX_ROWS:
        nr = TERM_MAX_ROWS
    old_rows: uint64 = term_rows_n
    if nr == old_rows and nc == term_cols_n:
        return
    # Re-anchor existing content to the BOTTOM of the new grid (so the live
    # edit line stays at the bottom and scrollback grows upward). Shift rows
    # by the row-count delta.
    if nr != old_rows:
        if nr > old_rows:
            # Grow: move existing rows DOWN by (nr-old_rows), clear the new top.
            d: uint64 = nr - old_rows
            r: uint64 = old_rows
            while r > 0:
                r = r - 1
                src: uint64 = r * TERM_STRIDE
                dst: uint64 = (r + d) * TERM_STRIDE
                k: uint64 = 0
                while k < TERM_STRIDE:
                    term_rows[dst + k] = term_rows[src + k]
                    k = k + 1
                term_row_len[r + d] = term_row_len[r]
            cr: uint64 = 0
            while cr < d:
                term_row_len[cr] = 0
                cr = cr + 1
        else:
            # Shrink: drop the top (old_rows-nr) rows, move the rest UP.
            d2: uint64 = old_rows - nr
            r2: uint64 = 0
            while r2 < nr:
                src2: uint64 = (r2 + d2) * TERM_STRIDE
                dst2: uint64 = r2 * TERM_STRIDE
                k2: uint64 = 0
                while k2 < TERM_STRIDE:
                    term_rows[dst2 + k2] = term_rows[src2 + k2]
                    k2 = k2 + 1
                term_row_len[r2] = term_row_len[r2 + d2]
                r2 = r2 + 1
    term_rows_n = nr
    term_cols_n = nc


def _term_scroll():
    # Scroll the grid up by one row (drop the top, shift the rest up). The
    # discarded top row is pushed into the scrollback history ring so the
    # user can wheel back to it later.
    # #323: a scroll shifts every row, so any active grid selection now points
    # at the WRONG cells — clear it (the highlight was already auto-copied to
    # PRIMARY on drag-release, so no data is lost).
    if htsel_active() != 0:
        htsel_reset()
    _sb_push(&term_rows[0], term_row_len[0])
    # If the user is currently scrolled back (viewing history), keep their
    # view anchored on the same content as new output streams in: each new
    # row pushed into history is one more row between the tail and their
    # viewport, so bump the offset (clamped to the retained depth).
    if term_view_off > 0 and term_view_off < sb_count:
        term_view_off = term_view_off + 1
    r: uint64 = 0
    while r + 1 < term_rows_n:
        sb: uint64 = (r + 1) * TERM_STRIDE
        db: uint64 = r * TERM_STRIDE
        ln: uint64 = term_row_len[r + 1]
        k: uint64 = 0
        while k < ln:
            term_rows[db + k] = term_rows[sb + k]
            k = k + 1
        term_row_len[r] = ln
        r = r + 1
    term_row_len[term_rows_n - 1] = 0


# Append one output byte from the shell into the grid, wrapping/scrolling.
# The terminal cursor lives on the bottom row (term_rows_n-1) at column
# term_col. A '\n' or column overflow scrolls up and resets the column.
term_col: uint64 = 0


def _term_putc(c: uint8):
    last: uint64 = (term_rows_n - 1) * TERM_STRIDE
    if c == 10:                             # newline -> scroll up one row
        _term_scroll()
        term_col = 0
        return
    if c == 13:                             # carriage-return -> col 0, no clear
        # Move to column 0; subsequent writes OVERWRITE in place. A prompt
        # repaint does CR + reprint + ESC[K; CR must NOT clear (that would
        # erase what the reprint then rewrites and churn the grid). ESC[K
        # (handled in the CSI filter) clears the stale tail instead.
        term_col = 0
        return
    if c == 8 or c == 127:                  # backspace / DEL
        if term_col > 0:
            term_col = term_col - 1
            term_rows[last + term_col] = 32
            if term_row_len[term_rows_n - 1] > 0:
                term_row_len[term_rows_n - 1] = term_col
        return
    if c == 9:                              # tab -> a couple of spaces
        _term_putc(32)
        _term_putc(32)
        return
    if c < 32:                              # drop other control bytes
        return
    if term_col >= term_cols_n:
        _term_scroll()
        term_col = 0
    term_rows[last + term_col] = c
    term_col = term_col + 1
    if term_col > term_row_len[term_rows_n - 1]:
        term_row_len[term_rows_n - 1] = term_col


# ANSI escape filter state. hamsh's prompt/readline emits VT100 control
# sequences (cursor moves, "show cursor", colours). We are a glyph grid, not
# a VT220, so we SWALLOW escape sequences rather than draw "[7C" / "[?25h" as
# literal glyphs. States: 0 = ground, 1 = saw ESC, 2 = inside CSI (ESC [ ...),
# 3 = inside OSC (ESC ] ... terminated by BEL or ST).
esc_st: int32 = 0

# Private-mode accumulator for the CSI parser. When we see ESC [ ? <digits>
# <final> we capture the '?' marker and the numeric parameter so we can honour
# the shell's local-echo control (private mode 7767): ESC[?7767l = echo OFF,
# ESC[?7767h = echo ON. This is how a raw fd-0 password read (newshell/su/login)
# tells us to stop rendering typed keystrokes so the password isn't shown in
# clear text. Every other private mode (e.g. ?25h/?25l cursor visibility) is
# still simply swallowed, exactly as before.
csi_priv: int32 = 0                          # saw '?' after ESC [
csi_num:  int32 = 0                          # accumulated decimal parameter
# LOCAL keystroke echo: 1 = render typed chars into the pane (normal), 0 =
# suppress rendering during a password read. The line is still buffered + sent
# to the shell on Enter; only the on-screen echo is hidden.
local_echo_on: int32 = 1
LOCAL_ECHO_MODE: int32 = 7767                # private CSI number for echo ctl


def _term_feed(c: uint8):
    if esc_st == 0:
        if c == 27:                         # ESC
            esc_st = 1
            return
        _term_putc(c)
        return
    if esc_st == 1:                         # just saw ESC
        if c == 91:                         # '[' -> CSI
            esc_st = 2
            csi_priv = 0
            csi_num = 0
        else:
            if c == 93:                     # ']' -> OSC
                esc_st = 3
            else:
                # Two-byte escape (e.g. ESC c) — done.
                esc_st = 0
        return
    if esc_st == 2:                         # CSI: params until a final byte
        if c == 63:                         # '?' — private-mode marker
            csi_priv = 1
            return
        if c >= 48 and c <= 57:             # accumulate a decimal parameter
            csi_num = csi_num * 10 + cast[int32](c) - 48
            return
        # Final byte is in 0x40..0x7E (@ A..Z [ \ ] ^ _ ` a..z { | } ~).
        if c >= 64 and c <= 126:
            if csi_priv != 0 and csi_num == LOCAL_ECHO_MODE:
                # Shell's local-echo control (password read bracket).
                if c == 104:                # 'h' — echo ON
                    local_echo_on = 1
                elif c == 108:              # 'l' — echo OFF
                    local_echo_on = 0
            if c == 75:                     # 'K' — erase to end of line
                # Clear from the cursor column to the end of the bottom row
                # (the prompt-repaint tail clear). This is what keeps a CR +
                # reprint + ESC[K idempotent: identical content each repaint.
                if term_row_len[term_rows_n - 1] > term_col:
                    term_row_len[term_rows_n - 1] = term_col
            esc_st = 0
            csi_priv = 0
            csi_num = 0
        # Non-digit, non-final intermediates (e.g. ';') are swallowed.
        return
    if esc_st == 3:                         # OSC: until BEL (7) or ESC-\ (ST)
        if c == 7:
            esc_st = 0
        else:
            if c == 27:                     # ST begins with ESC; consume next
                esc_st = 1
        return


def _term_puts_n(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        _term_feed(p[i])
        i = i + 1


def _emit_scene(scenepath: Ptr[char]):
    sfd: int32 = sys_open_write(scenepath)
    if sfd < 0:
        return
    # BUG 1b: scene buffer sized for the MAX grid (40 rows * ~160 cols + per-
    # row overhead). A maximized terminal emits far more than the old 360x200
    # box did, so the old 4096 buffer would truncate the scene.
    # Sized for the MAX grid (40 rows * ~160 cols glyphs + per-row overhead) PLUS
    # a per-row selection-highlight `fill` line (#323, ~24 bytes/row) so a
    # maximized terminal with a full-height selection never truncates the scene.
    scene: Array[12288, uint8]
    sp: uint64 = 0
    # Background dark panel sized to the CURRENT window (term_w x term_h) so a
    # maximized / snapped terminal fills its whole window, not the original box.
    head: Ptr[uint8] = cast[Ptr[uint8]]("# scene v1 term\nfill 0 0 ")
    a: uint64 = 0
    while head[a] != 0:
        scene[sp] = head[a]
        sp = sp + 1
        a = a + 1
    sp = sp + _u64_to_dec(cast[uint64](term_w), &scene[sp])
    scene[sp] = 32
    sp = sp + 1
    sp = sp + _u64_to_dec(cast[uint64](term_h), &scene[sp])
    bgtail: Ptr[uint8] = cast[Ptr[uint8]](" #101418\n")
    bt: uint64 = 0
    while bgtail[bt] != 0:
        scene[sp] = bgtail[bt]
        sp = sp + 1
        bt = bt + 1
    # each text row as a glyphs line at y = 6 + r*20.
    #
    # When term_view_off == 0 the viewport IS the live grid (the common,
    # auto-follow case). When the user has wheeled back (term_view_off > 0)
    # the viewport is shifted UP by term_view_off rows: viewport row r shows
    # the content term_view_off rows ABOVE live-grid row r — which is either
    # an earlier live-grid row (r >= view_off) or a row from the scrollback
    # history ring (r < view_off). The bottom (cursor/edit) row marker is
    # only drawn when following the live tail.
    voff: uint64 = term_view_off
    r: uint64 = 0
    while r < term_rows_n:
        # Resolve this viewport row's source bytes (rptr/rlen).
        rptr: Ptr[uint8] = cast[Ptr[uint8]](0)
        rlen: uint64 = 0
        if voff == 0:
            rptr = &term_rows[r * TERM_STRIDE]
            rlen = term_row_len[r]
        elif r >= voff:
            rptr = &term_rows[(r - voff) * TERM_STRIDE]
            rlen = term_row_len[r - voff]
        else:
            back: uint64 = voff - r          # 1 == row just above live grid
            if back <= sb_count:
                off: uint64 = _sb_row_ptr(back)
                rptr = &sb_rows[off]
                rlen = sb_len[(sb_head + SB_MAX_ROWS - back) % SB_MAX_ROWS]
            else:
                rlen = 0                      # past the top of history — blank
        is_cursor_row: int32 = 0
        if r == term_rows_n - 1 and voff == 0:
            is_cursor_row = 1
        # SELECTION HIGHLIGHT (#323): when following the live tail (voff==0) and
        # a selection is active, paint a background band UNDER this row's
        # selected columns BEFORE the glyphs (scene primitives draw in order, so
        # the glyphs land on top of the fill). We coalesce the row's contiguous
        # selected column run [selc0,selc1] into one fill rect at the 8px cell
        # model the grid uses (x = 6 + col*8). Selection is grid-row indexed, so
        # only meaningful when the viewport shows the live grid (voff==0).
        if voff == 0 and htsel_active() != 0:
            selc0: int64 = -1
            selc1: int64 = -1
            cc: uint64 = 0
            while cc < term_cols_n:
                if htsel_cell_selected(cast[int64](r), cast[int64](cc)) != 0:
                    if selc0 < 0:
                        selc0 = cast[int64](cc)
                    selc1 = cast[int64](cc)
                cc = cc + 1
            if selc0 >= 0:
                fx: uint64 = 6 + cast[uint64](selc0) * 8
                fw: uint64 = cast[uint64](selc1 - selc0 + 1) * 8
                fy: uint64 = 4 + r * 20
                sf: Ptr[uint8] = cast[Ptr[uint8]]("fill ")
                fq: uint64 = 0
                while sf[fq] != 0:
                    scene[sp] = sf[fq]
                    sp = sp + 1
                    fq = fq + 1
                sp = sp + _u64_to_dec(fx, &scene[sp])
                scene[sp] = 32
                sp = sp + 1
                sp = sp + _u64_to_dec(fy, &scene[sp])
                scene[sp] = 32
                sp = sp + 1
                sp = sp + _u64_to_dec(fw, &scene[sp])
                scene[sp] = 32
                sp = sp + 1
                sp = sp + _u64_to_dec(18, &scene[sp])
                selfill: Ptr[uint8] = cast[Ptr[uint8]](" #2a4d8f\n")
                fk: uint64 = 0
                while selfill[fk] != 0:
                    scene[sp] = selfill[fk]
                    sp = sp + 1
                    fk = fk + 1
        # Always emit the bottom (edit) row even when empty so a blinking-ish
        # cursor marker is visible; skip blank scrollback rows.
        if rlen > 0 or is_cursor_row != 0:
            g: Ptr[uint8] = cast[Ptr[uint8]]("glyphs 6 ")
            b: uint64 = 0
            while g[b] != 0:
                scene[sp] = g[b]
                sp = sp + 1
                b = b + 1
            yy: uint64 = 6 + r * 20
            sp = sp + _u64_to_dec(yy, &scene[sp])
            scene[sp] = 32
            scene[sp + 1] = 34                     # opening quote
            sp = sp + 2
            # The '_' text cursor tracks the edit caret column (term_col),
            # which _redraw_edit_line parks at the current in-line position.
            # Draw it OVER the glyph at that column for a mid-line caret, or
            # append it past the text when the caret sits at end-of-line.
            # (Previously it was always appended at rlen, so the underscore
            # stayed pinned to the line end and never followed Left/Right.)
            cur_col: uint64 = term_col
            k: uint64 = 0
            while k < rlen:
                ch: uint8 = rptr[k]
                if ch == 34 or ch == 10:           # sanitize quote/newline
                    ch = 32
                if is_cursor_row != 0 and k == cur_col:
                    ch = 95                         # '_' text cursor overlay
                scene[sp] = ch
                sp = sp + 1
                k = k + 1
            if is_cursor_row != 0 and cur_col >= rlen:
                scene[sp] = 95                      # '_' caret at end of line
                sp = sp + 1
            tail: Ptr[uint8] = cast[Ptr[uint8]]("\" #c0f0c0\n")
            c: uint64 = 0
            while tail[c] != 0:
                scene[sp] = tail[c]
                sp = sp + 1
                c = c + 1
        r = r + 1
    sys_write(sfd, &scene[0], sp)
    sys_close(sfd)


# --- persistent shell wiring ------------------------------------------
# BUG 1 ROOT-CAUSE + FIX. The old wiring used sys_pipe()+integer-fd spawn
# (sin=to_sh[0], sout=from_sh[1]); lib/p9.spawn dup2'd those onto the
# child's INTEGER fd 0/1. But hamsh reads/serves stdio through the `/fd`
# NAME table (devfd), which is a SEPARATE table from the integer fds. With
# only integer fds dup'd, hamsh's `/fd/0,1` stayed DEVFD_NONE, so hamsh's
# _setup_fd_namespace SEEDED them to DEVFD_CONS (the kernel console). hamsh
# itself read/wrote integer fd 0/1 (the pipe) for its prompt + readline
# echo — so the BANNER and the echoed command line reached our grid — but
# every EXTERNAL command (`ls`, `cat`, …) inherits hamsh's `/fd/1` via the
# COW Pgrp clone, and that was CONS, so `ls /` output went to the boot
# console, NOT our window. The terminal looked like an empty namespace;
# it was really lost child-stdout. (#450 retired the kernel SYS_SPAWN arm
# that used to auto-populate /fd/0,1,2 from the integer-fd backings — the
# regression that orphaned the /fd names.)
#
# FIX: spawn hamsh with SPAWN_STDIO_NS and bind its `/fd/0` / `/fd/1` to
# real pipe CHANS (DEVFD_PIPE_R / DEVFD_PIPE_W) — the exact mechanism
# hamsh's own pipeline / command-substitution path uses. Now external
# children inherit the pipe through the Pgrp clone and their output streams
# back into our glyph grid. We hold the OPPOSITE ends by binding them at
# our own scratch `/fd/10` (stdin write) and `/fd/11` (stdout read) and
# opening those names for integer fds we read/write.
spawn_argv:  Array[4, uint64]
TERM_IN_FD:  int32 = 10        # our scratch /fd name for the stdin WRITE end
TERM_OUT_FD: int32 = 11        # our scratch /fd name for the stdout READ end
sh_in_fd:  int32 = -1          # write end -> hamsh stdin (feed commands)
sh_out_fd: int32 = -1          # read end  <- hamsh stdout (drain output)
sh_alive:  int32 = 0
read_buf:  Array[512, uint8]


def _start_shell() -> int32:
    # Two pipe Chans: in_slot = terminal -> hamsh stdin;
    #                 out_slot = hamsh stdout -> terminal.
    in_slot: int32 = sys_pipechan()
    if in_slot < 0:
        return -1
    out_slot: int32 = sys_pipechan()
    if out_slot < 0:
        return -1
    # Hold our ends: bind the stdin WRITE end + the stdout READ end at our
    # own scratch /fd names, then open them for readable/writable int fds.
    sys_fdbind(0, TERM_IN_FD,  DEVFD_PIPE_W, in_slot)
    sys_fdbind(0, TERM_OUT_FD, DEVFD_PIPE_R, out_slot)
    sh_in_fd  = sys_open(cast[Ptr[char]]("/fd/10"))
    sh_out_fd = sys_open(cast[Ptr[char]]("/fd/11"))
    if sh_in_fd < 0 or sh_out_fd < 0:
        return -1
    # BUG 1 + BUG 3 FIX. Spawn the inner interactive shell as
    #   /bin/hamsh --no-echo /etc/rc.de-user
    # so it:
    #   (1) SOURCES /etc/rc.de-user — the SAME rc the outer hamUId shell
    #       sourced — which defines the `linux` / `debian` namespace
    #       TEMPLATE VARIABLES (and re-asserts the device/proc/srv/net/home
    #       binds, idempotent on top of the COW-inherited ones). The OLD
    #       wiring spawned a bare `/bin/hamsh` whose interactive shell had
    #       NO `linux`/`debian` variables, so `enter linux { ls }` hit
    #       ns_not_a_template() and printed "not a namespace: linux" to fd 2
    #       (the serial console) — invisible in the pane, NO output. With
    #       the templates loaded, `enter linux { ls }` switches `/` to the
    #       Debian root and streams the listing back over stdout into our
    #       grid. rc.de-user falls through to the interactive REPL because
    #       HAMNIX_DE_PROG is NOT set (no third arg), and that REPL reads
    #       the SAME /fd/0,1,2 pipes we wire below.
    #   (2) --no-echo (consumed by hamsh main BEFORE rc dispatch) suppresses
    #       the shell readline's per-character echo. hamterm now owns LOCAL
    #       line editing + LOCAL echo (BUG 3 lag fix), so the shell must NOT
    #       echo the bytes back over stdout or every char would appear twice.
    spawn_argv[0] = cast[uint64]("/bin/hamsh")
    spawn_argv[1] = cast[uint64]("--no-echo")
    spawn_argv[2] = cast[uint64]("/etc/rc.de-user")
    spawn_argv[3] = 0
    # SPAWN_STDIO_NS: the child's stdio are NAMES (/fd/0,1,2) we wire by
    # fdbind below — NOT dup'd integer fds. This is what lets hamsh's
    # external children inherit real pipes for stdin/stdout.
    pid: int32 = spawn(cast[Ptr[char]]("/bin/hamsh"), &spawn_argv[0],
                       SPAWN_STDIO_NS, SPAWN_STDIO_NS,
                       cast[Ptr[uint64]](0))
    if pid < 0:
        return -1
    # Wire hamsh's /fd/0 = stdin READ end, /fd/1 = stdout WRITE end. The
    # child is still STATE_READY (cooperative scheduler), so these binds
    # land in its namespace before its first instruction runs.
    sys_fdbind(pid, 0, DEVFD_PIPE_R, in_slot)
    sys_fdbind(pid, 1, DEVFD_PIPE_W, out_slot)
    # BUG 1 FIX: fd 2 (stderr) -> the SAME stdout-write pipe as fd 1, so the
    # shell's USER-FACING diagnostics ("command not found", "not a namespace:
    # linux", a failed command's error, ls errors) render IN THE PANE instead
    # of vanishing onto the serial console. Genuine kernel/boot debug still
    # goes to /dev/cons (which hamtermscene itself opens separately); only the
    # inner shell's stderr is redirected to the visible grid.
    sys_fdbind(pid, 2, DEVFD_PIPE_W, out_slot)
    # Drop OUR write-reference to the stdin-read pipe and read-reference to
    # the stdout-write pipe by releasing the creator slot bindings: the
    # child + our held ends keep the refcounts alive. (We never bound those
    # opposite ends at our own names, so nothing to release here; the
    # pipechan creator ref is consumed by the two fdbinds.)
    sh_alive = 1
    return 0


# Cooperative short sleep (jiffy-granular, HZ=100 → 10 ms floor). Parks the
# task off the runqueue (sti+hlt) so it does NOT busy-spin; other tasks (the
# shell) get the CPU while we wait. Used by the main loop's bounded readiness
# poll: every wake we drain BOTH /keys and the shell pipe, so shell output
# (the new prompt) renders within ~one tick even when no key is pressed.

# Non-blocking drain of the shell's stdout into the glyph grid. Returns the
# number of bytes consumed this call (0 = nothing). Sets sh_alive = 0 on EOF.
def _drain_shell() -> uint64:
    if sh_alive == 0 or sh_out_fd < 0:
        return 0
    got: uint64 = 0
    passes: int32 = 0
    while passes < 8:
        n: int64 = sys_read_nb(sh_out_fd, &read_buf[0], 512)
        if n > 0:
            _term_puts_n(&read_buf[0], cast[uint64](n))
            got = got + cast[uint64](n)
            passes = passes + 1
            continue
        if n < 0:
            sh_alive = 0
        break
    # Re-anchor the local edit base to wherever the shell's freshly-streamed
    # output (the new prompt) left the cursor, but ONLY when the user has no
    # half-typed line — otherwise streamed output would shift the edit text.
    # After Enter the line is empty, so the next prompt re-anchors cleanly and
    # subsequent local edits render right after the "$ " prompt.
    if got > 0 and term_line_len == 0:
        edit_base = term_col
    return got


# Feed one command line (NUL-terminated, length ln) to the shell's stdin,
# appending '\n'. Returns 0 on success, -1 if the shell is gone.
line_buf: Array[576, uint8]


def _send_line(buf: Ptr[uint8], ln: uint64) -> int32:
    if sh_alive == 0 or sh_in_fd < 0:
        return -1
    j: uint64 = 0
    while j < ln and j < 574:
        line_buf[j] = buf[j]
        j = j + 1
    line_buf[j] = 10                        # '\n'
    j = j + 1
    w: int64 = sys_write(sh_in_fd, &line_buf[0], j)
    if w < 0:
        sh_alive = 0
        return -1
    return 0


# --- BUG 1 occlusion-independent proof --------------------------------
# The Bug-1 verdict (does the terminal's hamsh see a real, non-empty
# namespace?) used to be read ONLY off a composited screendump / a late
# `cat /dev/wsys/3/scene` capture. Both are unreliable: the file-manager
# window stacks ON TOP of the terminal and OCCLUDES its output rows, and
# the late scene capture races the serial keystroke-echo flood. So neither
# can reliably observe the `ls /` listing even when it rendered correctly.
#
# Instead we prove it AT THE SOURCE: once the startup probe's `ls /` output
# has streamed back over the shell's stdout into our OWN glyph grid, we scan
# the grid for a real root-directory entry and emit ONE deterministic serial
# marker — "[hamterm] NS_PROBE: <entry>" — to the boot console (fd 2). This
# is occlusion-proof (it reads our private grid, not the framebuffer) and
# fires exactly once (no per-frame spam, no flicker, no UART carve-out
# breakage). The gate asserts on that marker.
#
# _grid_find_root() returns the byte-length of the first matching root entry
# (writing it NUL-terminated into `out`), or 0 if none is present yet. The
# token set mirrors the gate's ROOT_RE (proc/srv/net/sys/bin/etc/usr/mnt/
# ext/var/lib/tmp/dev). We match a whole grid "word" (delimited by space,
# tab, '/', or row end) so we never false-match on the prompt or the echoed
# command text.
root_tokens: Array[13, uint64]
root_tok_len: Array[13, uint64]


def _tok_eq(base: uint64, start: uint64, wlen: uint64,
            tok: Ptr[uint8], tlen: uint64) -> int32:
    if wlen != tlen:
        return 0
    k: uint64 = 0
    while k < tlen:
        if term_rows[base + start + k] != tok[k]:
            return 0
        k = k + 1
    return 1


def _grid_find_root(out: Ptr[uint8]) -> uint64:
    # Seed the recognized root-entry token table (idempotent).
    root_tokens[0]  = cast[uint64]("proc")
    root_tok_len[0]  = 4
    root_tokens[1]  = cast[uint64]("srv")
    root_tok_len[1]  = 3
    root_tokens[2]  = cast[uint64]("net")
    root_tok_len[2]  = 3
    root_tokens[3]  = cast[uint64]("sys")
    root_tok_len[3]  = 3
    root_tokens[4]  = cast[uint64]("bin")
    root_tok_len[4]  = 3
    root_tokens[5]  = cast[uint64]("etc")
    root_tok_len[5]  = 3
    root_tokens[6]  = cast[uint64]("usr")
    root_tok_len[6]  = 3
    root_tokens[7]  = cast[uint64]("mnt")
    root_tok_len[7]  = 3
    root_tokens[8]  = cast[uint64]("ext")
    root_tok_len[8]  = 3
    root_tokens[9]  = cast[uint64]("var")
    root_tok_len[9]  = 3
    root_tokens[10] = cast[uint64]("lib")
    root_tok_len[10] = 3
    root_tokens[11] = cast[uint64]("tmp")
    root_tok_len[11] = 3
    root_tokens[12] = cast[uint64]("dev")
    root_tok_len[12] = 3
    r: uint64 = 0
    while r < term_rows_n:
        ln: uint64 = term_row_len[r]
        base: uint64 = r * TERM_STRIDE
        i: uint64 = 0
        while i < ln:
            c: uint8 = term_rows[base + i]
            # word delimiters: space / tab / '/'
            if c == 32 or c == 9 or c == 47:
                i = i + 1
                continue
            # start of a word: measure its extent
            ws: uint64 = i
            while i < ln:
                d: uint8 = term_rows[base + i]
                if d == 32 or d == 9 or d == 47:
                    break
                i = i + 1
            wlen: uint64 = i - ws
            t: uint64 = 0
            while t < 13:
                tok: Ptr[uint8] = cast[Ptr[uint8]](root_tokens[t])
                if _tok_eq(base, ws, wlen, tok, root_tok_len[t]) != 0:
                    k: uint64 = 0
                    while k < wlen:
                        out[k] = term_rows[base + ws + k]
                        k = k + 1
                    out[wlen] = 0
                    return wlen
                t = t + 1
        r = r + 1
    return 0


# --- key input from /dev/wsys/<wid>/keys ------------------------------
kev_buf:  Array[512, uint8]
kev_carry: uint64 = 0                     # leftover partial-line bytes at buf head
keyout:   Array[256, uint8]              # forwarded bytes -> shell stdin


# BUG 3 FIX — LOCAL LINE DISCIPLINE with CURSOR MOTION + HISTORY.
#
# The OLD model forwarded each raw keystroke to the shell and WAITED for the
# shell's readline to echo it back over the stdout pipe before committing the
# frame (the `await_echo` pump). That term -> pipe -> cooperatively-scheduled
# hamsh -> readline-echo -> pipe -> term round-trip was the ~0.5s per-char lag.
#
# hamterm now owns line editing LOCALLY: a key edits the in-memory line and
# re-renders the bottom (edit) grid row IMMEDIATELY, in the same wake, ZERO
# round-trips. We accumulate the typed line in `term_line` with an INSERTION
# CURSOR `term_line_cur`, and feed the WHOLE line + '\n' to the shell's stdin
# on Enter. The inner shell runs with `--no-echo` (see _start_shell) so its
# readline does NOT echo the bytes back.
#
# CURSOR + HISTORY (this fix). Previously every control byte (<32) was dropped,
# so the arrow keys' ESC '[' A/B/C/D bytes leaked into the grid as the literal
# glyphs "[A"/"[B"/... — the user-reported "arrows insert special characters".
# Now:
#   * ESC '[' A/B/C/D are DECODED (state machine over the per-byte key stream)
#     and never reach the line as text;
#   * Left/Right move `term_line_cur` within the line (inline editing);
#   * Up/Down recall previous/next command from a local HISTORY ring;
#   * Home/End (ESC '[' H / F, and Ctrl-A / Ctrl-E) jump to line start/end;
#   * Backspace/DEL and printable inserts act AT the cursor (mid-line edits).
# The bottom edit row is fully re-rendered from `term_line` on each edit
# (`_redraw_edit_line`), with the text cursor drawn at `term_line_cur`.
#
# `keys_local_changed` is set whenever a key changed the grid locally, so the
# main loop commits the echo this frame without any shell round-trip.
TERM_LINE_MAX: uint64 = 512
term_line:     Array[512, uint8]          # the line being edited (no '\n')
term_line_len: uint64 = 0
term_line_cur: uint64 = 0                  # insertion point within term_line
edit_base:     uint64 = 0                  # bottom-row column where editing starts
keys_local_changed: int32 = 0
keys_forwarded: uint64 = 0                 # bytes sent to shell this wake

# Arrow/escape decode for the KEY stream. The keyboard driver delivers arrow
# keys as the byte run ESC(27) '['(91) <final>; we reassemble it here so the
# bytes drive cursor/history instead of leaking into the line as glyphs.
# 0 = ground, 1 = saw ESC, 2 = saw ESC '['  (also absorbs an optional numeric
# parameter for Home/End "1~"/"4~" style sequences).
key_esc_st: int32 = 0
csi_param:  int32 = 0                       # last digit byte inside a CSI

# --- command history ring (local, like a shell's readline history) ---------
HIST_MAX:  uint64 = 32                     # remembered command count
HIST_STRIDE: uint64 = 512                  # bytes per stored command (== TERM_LINE_MAX)
hist_buf:  Array[16384, uint8]             # HIST_MAX * HIST_STRIDE
hist_len:  Array[32, uint64]               # live length of each stored command
hist_count: uint64 = 0                     # commands stored (<= HIST_MAX)
hist_head:  uint64 = 0                     # next write slot (ring cursor)
# Browse position: 0 = editing the live line; k>0 = showing the k-th most
# recent command (1 == most recent). Reset to 0 whenever the line is edited
# or submitted.
hist_pos:   uint64 = 0


def _hist_push(buf: Ptr[uint8], n: uint64):
    # Append a submitted command to the history ring (skip empty lines and an
    # exact repeat of the most recent entry, like a shell's HISTCONTROL).
    if n == 0:
        return
    if hist_count > 0:
        prev_slot: uint64 = (hist_head + HIST_MAX - 1) % HIST_MAX
        if hist_len[prev_slot] == n:
            same: int32 = 1
            k: uint64 = 0
            while k < n:
                if hist_buf[prev_slot * HIST_STRIDE + k] != buf[k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                return
    base: uint64 = hist_head * HIST_STRIDE
    cn: uint64 = n
    if cn > HIST_STRIDE:
        cn = HIST_STRIDE
    k2: uint64 = 0
    while k2 < cn:
        hist_buf[base + k2] = buf[k2]
        k2 = k2 + 1
    hist_len[hist_head] = cn
    hist_head = (hist_head + 1) % HIST_MAX
    if hist_count < HIST_MAX:
        hist_count = hist_count + 1


# Load the k-th most recent history entry (1 == most recent) into term_line.
def _hist_load(k: uint64):
    if k == 0 or k > hist_count:
        return
    slot: uint64 = (hist_head + HIST_MAX - k) % HIST_MAX
    base: uint64 = slot * HIST_STRIDE
    n: uint64 = hist_len[slot]
    if n > TERM_LINE_MAX - 1:
        n = TERM_LINE_MAX - 1
    i: uint64 = 0
    while i < n:
        term_line[i] = hist_buf[base + i]
        i = i + 1
    term_line_len = n
    term_line_cur = n


# Forward one raw control byte (e.g. Ctrl-C) to the shell's stdin verbatim —
# used for keys hamterm does not handle in its local line editor.
def _key_raw_to_shell(c: uint8):
    if sh_alive == 0 or sh_in_fd < 0:
        return
    term_view_off = 0
    keyout[0] = c
    w: int64 = sys_write(sh_in_fd, &keyout[0], 1)
    if w < 0:
        sh_alive = 0
        return
    keys_forwarded = keys_forwarded + 1


# Re-render the bottom (edit) grid row from the prompt prefix + term_line, with
# the block text cursor at term_line_cur. The prompt prefix (drawn by the
# shell's stdout) occupies columns [0, edit_base); we rewrite [edit_base, ...).
def _redraw_edit_line():
    last: uint64 = (term_rows_n - 1) * TERM_STRIDE
    # If the edit text would overflow the visible columns, scroll the visible
    # window leftward so the cursor stays on screen (simple horizontal pan).
    avail: uint64 = 0
    if term_cols_n > edit_base:
        avail = term_cols_n - edit_base
    start: uint64 = 0
    if avail > 0 and term_line_cur >= avail:
        start = term_line_cur - avail + 1
    col: uint64 = edit_base
    i: uint64 = start
    while i < term_line_len and col < term_cols_n:
        ch: uint8 = term_line[i]
        if ch == 9:
            ch = 32
        term_rows[last + col] = ch
        col = col + 1
        i = i + 1
    # Clear any stale tail (a shorter line after backspace / history recall).
    c2: uint64 = col
    while c2 < term_cols_n:
        term_rows[last + c2] = 32
        c2 = c2 + 1
    # Trim the row length back to the last non-space-or-cursor column.
    term_row_len[term_rows_n - 1] = col
    # Park the streaming cursor (term_col) at the editing caret so a following
    # shell write (rare mid-edit) and the cursor block line up.
    term_col = edit_base + (term_line_cur - start)
    if term_col > term_cols_n:
        term_col = term_cols_n


# Decode one arrow/escape final byte (after ESC '['). Returns 1 if it changed
# the line/cursor (caller redraws + commits).
def _key_csi_final(code: int32) -> int32:
    if code == 65:                          # 'A' — Up: older history
        if hist_count == 0:
            return 0
        if hist_pos < hist_count:
            hist_pos = hist_pos + 1
        _hist_load(hist_pos)
        _redraw_edit_line()
        return 1
    if code == 66:                          # 'B' — Down: newer history
        if hist_pos > 0:
            hist_pos = hist_pos - 1
        if hist_pos == 0:
            term_line_len = 0
            term_line_cur = 0
        else:
            _hist_load(hist_pos)
        _redraw_edit_line()
        return 1
    if code == 67:                          # 'C' — Right
        if term_line_cur < term_line_len:
            term_line_cur = term_line_cur + 1
            _redraw_edit_line()
            return 1
        return 0
    if code == 68:                          # 'D' — Left
        if term_line_cur > 0:
            term_line_cur = term_line_cur - 1
            _redraw_edit_line()
            return 1
        return 0
    if code == 72:                          # 'H' — Home
        if term_line_cur != 0:
            term_line_cur = 0
            _redraw_edit_line()
            return 1
        return 0
    if code == 70:                          # 'F' — End
        if term_line_cur != term_line_len:
            term_line_cur = term_line_len
            _redraw_edit_line()
            return 1
        return 0
    return 0


def _key_local_noecho(code: int32):
    # Password-entry key handler: buffer the line for the shell WITHOUT
    # rendering it, so a typed password is never shown in the pane. Only
    # printable bytes, Backspace/DEL, Enter and Ctrl-C matter here; arrows,
    # history and other control keys are ignored, both so nothing leaks AND so
    # a history recall can't overwrite the password buffer. The buffered line
    # is still sent to the shell on Enter (its raw fd-0 read consumes it).
    term_view_off = 0
    if code == 10:                          # Enter — submit (no echo/history)
        if sh_alive != 0 and sh_in_fd >= 0:
            _send_line(&term_line[0], term_line_len)
        term_line_len = 0
        term_line_cur = 0
        return
    if code == 8 or code == 127:            # Backspace / DEL
        if term_line_len > 0:
            term_line_len = term_line_len - 1
            term_line_cur = term_line_len
        return
    if code == 3:                           # Ctrl-C — abandon, tell shell
        term_line_len = 0
        term_line_cur = 0
        _key_raw_to_shell(cast[uint8](3))
        return
    if code < 32:                           # any other control byte: drop
        return
    # Printable byte: append to the buffer (no mid-line cursor edits while a
    # password is being read — keeps this path simple and leak-free).
    if term_line_len < TERM_LINE_MAX - 1:
        term_line[term_line_len] = cast[uint8](code)
        term_line_len = term_line_len + 1
        term_line_cur = term_line_len


def _key_local(code: int32):
    # Apply one decoded key press to the LOCAL line editor, re-rendering the
    # edit row immediately. `code` is the ASCII byte (Enter normalised to 10,
    # CR folded to NL by the caller). Typing snaps the scrollback to the tail.
    # While the shell has signalled echo-off (a password read), divert to the
    # non-rendering handler so nothing is drawn to the pane.
    if local_echo_on == 0:
        _key_local_noecho(code)
        return
    term_view_off = 0
    # --- arrow / escape-sequence decode (must run before the <32 drop) ---
    if key_esc_st == 1:                     # saw ESC
        if code == 91:                      # '['
            key_esc_st = 2
            return
        # Bare ESC or ESC <other> — abandon the sequence, ignore.
        key_esc_st = 0
        return
    if key_esc_st == 2:                     # inside CSI (ESC '[')
        # Absorb an optional numeric parameter (e.g. "1~" Home / "4~" End).
        if code >= 48 and code <= 57:
            # Remember the digit for the '~' finals; we only special-case
            # 1 (Home) and 4 (End) here, mapped via the final byte below.
            csi_param = code
            return
        key_esc_st = 0
        fin: int32 = code
        if code == 126:                     # '~' final: 1~ Home, 4~ End
            if csi_param == 49:             # '1'
                fin = 72                    # treat as Home
            elif csi_param == 52:           # '4'
                fin = 70                    # treat as End
            else:
                csi_param = 0
                return
        csi_param = 0
        if _key_csi_final(fin) != 0:
            keys_local_changed = 1
        return
    if code == 27:                          # ESC -> begin a CSI sequence
        key_esc_st = 1
        return
    if code == 10:                          # Enter — submit the whole line
        _hist_push(&term_line[0], term_line_len)
        hist_pos = 0
        _term_putc(10)                      # move to a fresh row in the grid
        keys_local_changed = 1
        if sh_alive != 0 and sh_in_fd >= 0:
            _send_line(&term_line[0], term_line_len)
        term_line_len = 0
        term_line_cur = 0
        return
    if code == 8 or code == 127:            # Backspace / DEL — delete at cursor
        if term_line_cur > 0:
            j: uint64 = term_line_cur - 1
            while j + 1 < term_line_len:
                term_line[j] = term_line[j + 1]
                j = j + 1
            term_line_len = term_line_len - 1
            term_line_cur = term_line_cur - 1
            hist_pos = 0
            _redraw_edit_line()
            keys_local_changed = 1
        return
    if code == 1:                           # Ctrl-A — Home
        if term_line_cur != 0:
            term_line_cur = 0
            _redraw_edit_line()
            keys_local_changed = 1
        return
    if code == 5:                           # Ctrl-E — End
        if term_line_cur != term_line_len:
            term_line_cur = term_line_len
            _redraw_edit_line()
            keys_local_changed = 1
        return
    if code == 3:                           # Ctrl-C
        # #323: X11-terminal convention — Ctrl-C COPIES to the CLIPBOARD when a
        # selection is active (so it does NOT hijack job-control ^C), otherwise
        # it is SIGINT. So: select an error -> Ctrl-C grabs it into /dev/snarf;
        # with nothing selected, Ctrl-C still interrupts the running command.
        if htsel_active() != 0:
            _copy_selection(0)              # 0 = CLIPBOARD (/dev/snarf)
            htsel_reset()                   # copy consumes the highlight
            keys_local_changed = 1
            return
        term_line_len = 0
        term_line_cur = 0
        hist_pos = 0
        _term_putc(10)
        keys_local_changed = 1
        _key_raw_to_shell(cast[uint8](3))
        return
    if code == 9:                           # Tab — insert at cursor (no completion)
        if term_line_len < TERM_LINE_MAX - 1:
            j2: uint64 = term_line_len
            while j2 > term_line_cur:
                term_line[j2] = term_line[j2 - 1]
                j2 = j2 - 1
            term_line[term_line_cur] = 9
            term_line_len = term_line_len + 1
            term_line_cur = term_line_cur + 1
            hist_pos = 0
            _redraw_edit_line()
            keys_local_changed = 1
        return
    if code < 32:
        # Any other control byte (no in-line meaning) is dropped.
        return
    # Printable byte: INSERT at the cursor (mid-line edits supported).
    if term_line_len < TERM_LINE_MAX - 1:
        j3: uint64 = term_line_len
        while j3 > term_line_cur:
            term_line[j3] = term_line[j3 - 1]
            j3 = j3 - 1
        term_line[term_line_cur] = cast[uint8](code)
        term_line_len = term_line_len + 1
        term_line_cur = term_line_cur + 1
        hist_pos = 0
        _redraw_edit_line()
        keys_local_changed = 1


# Parse "<type> <code>\n" key lines out of a freshly-read chunk. For each
# 'd' (press) line with a printable / Enter / Backspace code, forward the
# byte to the shell. The shell's echo comes back over stdout (rendered by
# _drain_shell). Returns 1 if any key was forwarded (so we re-poll output).
# BUG 3 FIX (dropped keystroke, consumer side). Parse only COMPLETE
# "<type> <code>\n" lines out of kev_buf[0..n). Returns the number of bytes
# CONSUMED — i.e. the offset just past the last '\n'. Any trailing partial
# line (the read split a key line at the buffer boundary) is left for the
# caller to carry forward, so a keystroke split across two reads is NOT
# dropped. (Previously the parser consumed a partial trailing line and lost
# that press under a burst.)
def _drain_keys_chunk(n: uint64) -> uint64:
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        ls: uint64 = i                      # start of this line
        t: uint8 = kev_buf[i]
        i = i + 1
        if i < n and kev_buf[i] == 32:
            i = i + 1
        # parse decimal code
        code: int32 = 0
        have: int32 = 0
        neg: int32 = 0
        if i < n and kev_buf[i] == 45:
            neg = 1
            i = i + 1
        while i < n and kev_buf[i] >= 48 and kev_buf[i] <= 57:
            code = code * 10 + cast[int32](kev_buf[i]) - 48
            i = i + 1
            have = 1
        # advance to end of line
        while i < n and kev_buf[i] != 10:
            i = i + 1
        if i >= n:
            # No terminating '\n' in this chunk — the line is incomplete.
            # Stop; the caller carries kev_buf[ls..n) into the next read.
            return ls
        i = i + 1                           # consume '\n'
        consumed = i
        if neg != 0:
            code = 0 - code
        # Only press events ('d') with a real code drive input.
        if t != 100 or have == 0:
            continue
        if code == 13:                      # CR -> NL for the line editor
            code = 10
        # BUG 3 FIX: drive the LOCAL line editor (immediate local echo, no
        # shell round-trip). _key_local handles printable bytes, Enter,
        # Backspace/DEL and Ctrl-C; it accumulates the line and sends it to
        # the shell only on Enter. Arrow/Home/End escape sequences (which the
        # keyboard driver emits as ESC '[' <final> byte runs) are dropped by
        # _key_local — the local discipline has no in-line cursor motion or
        # history; that is the classic line-buffered terminal behaviour and
        # the price of zero-lag local echo.
        if code >= 1 and code < 127:
            _key_local(code)
    return consumed


# --- resize events from /dev/wsys/<wid>/event -------------------------
# The compositor emits "r <w> <h>\n" on the event ring when our window's
# content size changes (maximize / snap / free-resize). We poll that file
# non-blocking and re-layout the grid. Pointer 'm'/'s' and focus 'f' lines
# are ignored (a terminal types its keys, not its mouse).
evt_buf:   Array[512, uint8]
evt_carry: uint64 = 0
# One-shot marker guard: the wheel-scroll gate greps for a single
# "[hamterm] WHEEL dz applied" line to prove end-to-end delivery. We emit it
# only once (first applied notch) so live scrolling doesn't flood the console.
wheel_marked: uint64 = 0


# --- pointer / selection state (#323) ---------------------------------
# The previous pointer button bitmap, so we detect press/drag/release edges of
# the "m <x> <y> <buttons> <dz>" stream (buttons bit0=L bit1=R bit2=M). A terminal
# still does NOT type its mouse, but LEFT drag now selects grid text and MIDDLE
# click pastes the PRIMARY selection into the edit line.
ptr_prev_buttons: int32 = 0
sel_text:  Array[12288, uint8]            # extracted selection (copy payload)
paste_buf: Array[4096, uint8]             # PRIMARY read on middle-click paste


def _copy_selection(prim: int32) -> uint64:
    # Extract the active grid selection -> text and WRITE it to the CLIPBOARD
    # (prim=0, /dev/snarf) or the PRIMARY selection (prim=1, /dev/snarf.primary).
    # Returns the byte length copied (0 if nothing selected).
    n: uint64 = htsel_extract(&term_rows[0], &term_row_len[0], TERM_STRIDE,
                              term_cols_n, &sel_text[0], 12288)
    if n == 0:
        return 0
    htsel_clip_put(prim, &sel_text[0], n)
    return n


def _paste_primary():
    # Middle-click paste: read the PRIMARY selection and inject it into the local
    # line editor as if typed (CR folded to NL, i.e. a pasted newline submits the
    # line — standard terminal middle-click behaviour).
    n: uint64 = htsel_clip_get(1, &paste_buf[0], 4096)
    i: uint64 = 0
    while i < n:
        c: uint8 = paste_buf[i]
        if c == 13:
            c = 10
        _key_local(cast[int32](c))
        i = i + 1


def _evt_next_field(pp: Ptr[uint64], le: uint64, out: Ptr[int64]) -> int32:
    # Parse the next whitespace-delimited (optionally negative) integer field of
    # an event line out of evt_buf, starting at *pp. Advances *pp past it.
    # Returns 1 if a digit was seen, 0 otherwise.
    p: uint64 = pp[0]
    while p < le and evt_buf[p] == 32:
        p = p + 1
    neg: int32 = 0
    if p < le and evt_buf[p] == 45:         # '-'
        neg = 1
        p = p + 1
    v: int64 = 0
    have: int32 = 0
    while p < le and evt_buf[p] >= 48 and evt_buf[p] <= 57:
        v = v * 10 + cast[int64](evt_buf[p]) - 48
        p = p + 1
        have = 1
    if neg != 0:
        v = 0 - v
    pp[0] = p
    out[0] = v
    return have


def _evt_apply_wheel(ls: uint64, le: uint64):
    # Parse the full "m <x> <y> <buttons> <dz>" pointer line spanning
    # evt_buf[ls..le). Fold the wheel dz into the scrollback view AND drive
    # click-drag text SELECTION (left button) + PRIMARY paste (middle button).
    # (x/y are window-content-local pixels; buttons is bit0=L bit1=R bit2=M.)
    p: uint64 = ls + 1                      # skip the 'm' type byte
    x: int64 = 0
    y: int64 = 0
    btn: int64 = 0
    dz: int64 = 0
    if _evt_next_field(&p, le, &x) == 0:
        return
    if _evt_next_field(&p, le, &y) == 0:
        return
    _evt_next_field(&p, le, &btn)           # buttons bitmap (may be 0)
    _evt_next_field(&p, le, &dz)           # wheel notch (may be absent -> 0)
    if dz != 0:
        _scroll_by(dz)
        # End-to-end delivery proof (boot console): a wheel notch reached this
        # window's /event ring and moved the scrollback view. Emitted ONCE (the
        # wheel-scroll gate only needs one line); gated so live scrolling doesn't
        # flood the console.
        if wheel_marked == 0:
            wheel_marked = 1
            _writeall(1, cast[Ptr[uint8]]("[hamterm] WHEEL dz applied\n"))
    # --- click-drag text selection (#323) -------------------------------
    left_now: int32 = 0
    if (btn & 1) != 0:
        left_now = 1
    mid_now: int32 = 0
    if (btn & 4) != 0:
        mid_now = 1
    left_prev: int32 = 0
    if (ptr_prev_buttons & 1) != 0:
        left_prev = 1
    mid_prev: int32 = 0
    if (ptr_prev_buttons & 4) != 0:
        mid_prev = 1
    # Selection is grid-row indexed, so only when following the LIVE tail
    # (term_view_off==0). Scrollback-region selection is deferred to round 2.
    if term_view_off == 0:
        row: int64 = 0
        col: int64 = 0
        htsel_pix_to_cell(x, y, cast[int64](term_rows_n),
                          cast[int64](term_cols_n), &row, &col)
        if left_now != 0 and left_prev == 0:
            htsel_begin(row, col)           # press: drop the anchor
        elif left_now != 0 and left_prev != 0:
            htsel_extend(row, col)          # drag: extend the caret
        elif left_now == 0 and left_prev != 0:
            # release: auto-copy the highlighted span to PRIMARY (X11-style:
            # highlight -> middle-click paste, no key needed).
            if htsel_active() != 0:
                np: uint64 = _copy_selection(1)
                if np > 0:
                    _writeall(1, cast[Ptr[uint8]](
                        "[hamterm] SEL copied PRIMARY\n"))
        # middle-click: paste the PRIMARY selection into the edit line.
        if mid_now != 0 and mid_prev == 0:
            _paste_primary()
    ptr_prev_buttons = cast[int32](btn)


def _drain_events_chunk(n: uint64) -> uint64:
    # Parse complete lines out of evt_buf[0..n). Apply 'r <w> <h>' resize.
    # Returns the number of bytes consumed (offset past the last '\n').
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        ls: uint64 = i
        t: uint8 = evt_buf[i]
        # Find end of this line.
        while i < n and evt_buf[i] != 10:
            i = i + 1
        if i >= n:
            return ls                       # incomplete line; carry forward
        le: uint64 = i
        i = i + 1                           # consume '\n'
        consumed = i
        if t == 109:                        # 'm' pointer line: mine the dz
            # The in-kernel pointer router (_wsys_evt_emit_pointer) delivers
            # "m <x> <y> <buttons> <dz>" on the /event ring (same ring as the
            # 'r' resize line), NOT on the separate /pointer file. We consume
            # ONLY the dz (5th) field and fold its notch into the scrollback
            # view; x/y/buttons are pointer noise a terminal does not type.
            _evt_apply_wheel(ls, le)
            continue
        if t != 114:                        # not 'r' (resize) — ignore
            continue
        # Parse "r <w> <h>".
        p: uint64 = ls + 1
        while p < le and evt_buf[p] == 32:
            p = p + 1
        wv: int64 = 0
        while p < le and evt_buf[p] >= 48 and evt_buf[p] <= 57:
            wv = wv * 10 + cast[int64](evt_buf[p]) - 48
            p = p + 1
        while p < le and evt_buf[p] == 32:
            p = p + 1
        hv: int64 = 0
        while p < le and evt_buf[p] >= 48 and evt_buf[p] <= 57:
            hv = hv * 10 + cast[int64](evt_buf[p]) - 48
            p = p + 1
        if wv > 0 and hv > 0:
            _term_apply_resize(wv, hv)
    return consumed


# Poll the event fd (non-blocking) and apply any resize events. Returns 1 if a
# resize was applied (caller should re-emit the scene), else 0.
def _poll_events(efd: int32) -> int32:
    if efd < 0:
        return 0
    changed: int32 = 0
    prev_rows: uint64 = term_rows_n
    prev_cols: uint64 = term_cols_n
    prev_voff: uint64 = term_view_off
    passes: int32 = 0
    while passes < 4:
        room: uint64 = 512 - evt_carry
        if room == 0:
            evt_carry = 0
            room = 512
        en: int64 = sys_read_nb(efd, &evt_buf[evt_carry], room)
        if en <= 0:
            break
        total: uint64 = evt_carry + cast[uint64](en)
        done: uint64 = _drain_events_chunk(total)
        leftover: uint64 = total - done
        m: uint64 = 0
        while m < leftover:
            evt_buf[m] = evt_buf[done + m]
            m = m + 1
        evt_carry = leftover
        passes = passes + 1
    if term_rows_n != prev_rows or term_cols_n != prev_cols:
        changed = 1
    if term_view_off != prev_voff:          # mouse-wheel scrolled the view
        changed = 1
    return changed


# --- mouse-wheel scrollback ------------------------------------------
# The wheel notch (dz) rides the "m <x> <y> <buttons> <dz>" pointer line on
# the /event ring (see _evt_apply_wheel above, which _drain_events_chunk
# calls). dz>0 (wheel up) shows OLDER rows; dz<0 (wheel down) walks back
# toward the live tail. term_view_off is clamped to [0, sb_count].
def _scroll_by(notches: int64):
    # Adjust the scrollback view by `notches` rows (positive = older).
    if notches > 0:
        room: uint64 = sb_count - term_view_off
        add: uint64 = cast[uint64](notches)
        if add > room:
            add = room
        term_view_off = term_view_off + add
    elif notches < 0:
        sub: uint64 = cast[uint64](0 - notches)
        if sub > term_view_off:
            term_view_off = 0
        else:
            term_view_off = term_view_off - sub


# Re-emit + commit the scene ONLY when the visible grid actually changed.
# `prev` carries the last committed grid hash across calls; returns the new
# hash. A no-change call costs one _grid_hash() and skips the kernel commit,
# so hamsh's identical idle prompt-repaints never re-present a frame.
def _commit_if_changed(scenepath: Ptr[char], ctlpath: Ptr[char],
                       prev: uint64) -> uint64:
    new_hash: uint64 = _grid_hash()
    if new_hash == prev:
        return prev
    _emit_scene(scenepath)
    cfd: int32 = sys_open_write(ctlpath)
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("commit\n"))
        sys_close(cfd)
    return new_hash


# BUG 2 (terminal input lag) FIX — bounded shell pump.
#
# Root cause of the residual ~0.5s lag: the old loop NEVER slept off the
# runqueue — it busy-yielded a fixed 2-jiffy (~20ms) window every pass. With
# the panel, file manager and visual gate ALSO runnable, a keystroke's
# echo round-trip (term -> shell stdin -> shell readline echo -> shell
# stdout -> term) waited for the persistent shell to win SEVERAL full
# round-robins against all those spinners, i.e. hundreds of ms. The terminal
# is now EVENT-DRIVEN: it BLOCKS on /keys (parks off the runqueue, freeing
# the CPU so the shell runs immediately) and only does a SHORT bounded drain
# of the shell pipe to collect the echo/output burst before re-blocking.
#
# Drain the shell pipe until it goes quiet for a bounded number of empty
# passes (so a multi-chunk echo / command burst is fully collected), then
# return. Commits whenever the grid changes. Returns the new committed hash.
# `budget` caps total passes so a chatty command (long `ls`) can't wedge us
# off the keyboard — leftover output is collected on the next wake.
def _pump_shell_bounded(scenepath: Ptr[char], ctlpath: Ptr[char],
                        prev: uint64, budget: int32) -> uint64:
    return _pump_shell_ex(scenepath, ctlpath, prev, budget, 0)


# Extended pump. `await_echo` != 0 means "we just forwarded keystroke(s); do
# not return on the first quiet window until the shell has produced AT LEAST
# ONE byte of output (the readline echo of the typed char)". This closes the
# BUG 1 off-by-one: the cooperatively-scheduled hamsh frequently hasn't run
# its readline echo by the time we first drain, so the plain pump would see
# two empty passes and bail BEFORE the echo arrived — committing a frame that
# still shows key N-1. With await_echo we keep yielding (bounded by an echo
# deadline in jiffies, so a dead/quiet shell can't wedge us off the keyboard)
# until the echo lands, then fall back to normal quiet-detection to collect any
# trailing output. The typed char now appears in the SAME frame.
ECHO_WAIT_JIFFIES: uint64 = 10           # bounded ~100ms wait for the echo


def _pump_shell_ex(scenepath: Ptr[char], ctlpath: Ptr[char],
                   prev: uint64, budget: int32, await_echo: int32) -> uint64:
    h: uint64 = prev
    empties: int32 = 0
    passes: int32 = 0
    saw_echo: int32 = 0
    deadline: uint64 = sys_get_jiffies() + ECHO_WAIT_JIFFIES
    while passes < budget:
        got: uint64 = _drain_shell()
        if got > 0:
            h = _commit_if_changed(scenepath, ctlpath, h)
            empties = 0
            saw_echo = 1
        else:
            empties = empties + 1
            # Normally two consecutive empty passes = the shell is quiet, so we
            # return and re-block on /keys. But if we're still WAITING for the
            # just-typed char's echo (await_echo and not yet saw_echo), keep
            # yielding until either the echo arrives or the bounded deadline
            # expires — so the typed char commits in this frame, not the next.
            if empties >= 2:
                if await_echo == 0 or saw_echo != 0:
                    break
                if sys_get_jiffies() >= deadline:
                    break                   # bounded: never spin forever
                empties = 1                 # keep waiting for the echo
            sys_yield()
        passes = passes + 1
    return h


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Optional initial command (argv[1]): when the panel launches a
    # Terminal=true app (e.g. the "Linux Process Viewer" .desktop entry,
    # `enter linux { … }`) it spawns us with the command line as argv[1].
    # We feed it to the persistent shell right after the startup NS probe so
    # the app runs INSIDE a real, rendered terminal window — the freedesktop
    # `Terminal=true` contract. A CLI Linux-ns tool has no Wayland surface of
    # its own, so without this host it ran headless and no window appeared.
    init_cmd: Ptr[uint8] = cast[Ptr[uint8]](0)
    if argc >= 2:
        c: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if cast[uint64](c) != 0 and c[0] != 0:
            init_cmd = c
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[term] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    scenep: Array[64, uint8]
    keysp: Array[64, uint8]
    evtp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&scenep[0], wid, cast[Ptr[uint8]]("/scene"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    _winpath(&evtp[0], wid, cast[Ptr[uint8]]("/event"))

    # geometry: a TERM_DEF_W x TERM_DEF_H box (600x400), decorated, mid-screen.
    # The grid constants (term_w/h, rows/cols) are derived from these SAME dims
    # so every row INCLUDING the bottom input/prompt line and every column is
    # fully visible at the default size — no clipping, no need to maximize.
    # Built from TERM_DEF_W/H so the window and the grid never disagree again.
    #
    # X ORIGIN clears the desktop-icon column (the MATE-style launcher strut
    # hamdesktop lays down the LEFT edge: icons + labels occupy roughly
    # x=[14,130], the widest label "System Monitor" ending ~x=130). The old
    # x=24 origin bisected that column, so the leftmost ~6px of each icon
    # label's first glyph stayed exposed in the x=[18,24) sliver just left of
    # the window border — a row of orphaned single-glyph fragments hugging the
    # terminal's left edge that read as text "bleeding through" the window.
    # The compositor z-order was correct (the strip genuinely is NOT under any
    # window); the fix is to open clear of the strut, matching every other
    # default DE app (editor x=180, monitor x=300, calc x=610, fm x=760).
    geo_cmd: Array[64, uint8]
    gq: uint64 = 0
    # Y ORIGIN clears the 28px top panel: the SSD titlebar sits TITLEBAR_H(18)px
    # ABOVE the content origin, so a content y of 40 tucked the titlebar top (and
    # its now-rounded corners, #254) UNDER the panel where they were occluded. y
    # =52 puts the titlebar top at 34 — a clean 6px below the panel — so the
    # KDE-ish rounded top corners are actually visible on the default desktop.
    geo_pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry 150 52 ")
    while geo_pre[gq] != 0:
        geo_cmd[gq] = geo_pre[gq]
        gq = gq + 1
    gp: uint64 = gq
    gp = gp + _u64_to_dec(cast[uint64](TERM_DEF_W), &geo_cmd[gp])
    geo_cmd[gp] = 32
    gp = gp + 1
    gp = gp + _u64_to_dec(cast[uint64](TERM_DEF_H), &geo_cmd[gp])
    geo_cmd[gp] = 10
    gp = gp + 1
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        sys_write(cfd, &geo_cmd[0], gp)
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 5\n"))
        sys_close(cfd3)
    # taskbar title (read by the panel via /dev/wsys/windows).
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Terminal\n"))
        sys_close(cfdt)

    _term_clear()
    _term_set_row(0, cast[Ptr[uint8]]("Hamnix scene terminal"))
    _term_set_row(1, cast[Ptr[uint8]]("type a command, press Enter"))

    # Cold-start timing (perf D1): jiffy stamp just before we spawn the
    # persistent hamsh, so we can report how long shell-spawn + rc-sourcing +
    # the startup `ls /` probe took. On the FIRST terminal after boot this is
    # the cold file-cache path; on a later terminal the caches are warm and
    # this is much smaller. rc.5 now pre-warms those caches before the first
    # terminal launches, so even terminal #1 should read "warm". HZ=100 ->
    # each jiffy is 10ms.
    t_cold0: uint64 = sys_get_jiffies()
    # Start the ONE persistent interactive hamsh.
    if _start_shell() != 0:
        _term_set_row(2, cast[Ptr[uint8]]("(shell failed to start)"))
        _writeall(1, cast[Ptr[uint8]]("[term] shell spawn FAILED\n"))
    else:
        _writeall(1, cast[Ptr[uint8]]("[term] hamsh spawned\n"))

    _emit_scene(cast[Ptr[char]](&scenep[0]))
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("commit\n"))
        sys_close(cfd4)

    _writeall(1, cast[Ptr[uint8]]("[term] scene window ready\n"))

    # Open the per-window KEY stream (focused-window keys, ASCII bytes).
    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    # BUG 1b + mouse-wheel scrollback: open /event (non-blocking polled).
    # BOTH the "r <w> <h>" resize line AND the "m <x> <y> <buttons> <dz>"
    # pointer/wheel line are delivered here by the in-kernel router (the
    # separate /pointer file is only used by the userland-compositor path,
    # which the live DE does not drive). We consume the wheel-notch dz field
    # to scroll the scrollback; pointer x/y/buttons are noise a terminal does
    # not type.
    efd: int32 = sys_open(cast[Ptr[char]](&evtp[0]))

    # BUG 2 (terminal input lag) FIX — EVENT-DRIVEN main loop.
    #
    # The terminal now BLOCKS on /keys (devwsys_keys_read parks the task on
    # the per-window keys wait-queue, OFF the runqueue) instead of busy-
    # yielding a fixed jiffy window. The compositor's wsys_route_key does a
    # directed wq_wake_one on a keystroke, so we wake in ~0 latency and the
    # shell — no longer starved by our spin — gets the CPU to echo
    # immediately. After each keystroke we forward it and do a SHORT bounded
    # drain of the shell pipe to collect the echo, then re-block. Result:
    # keystroke -> on-screen echo is next-frame (single-digit ms), not the
    # ~0.5s round-robin wait of the old poll loop.
    #
    # `prev_hash` carries the last committed grid hash so an unchanged grid
    # never re-commits (flicker-stable idle, unchanged from before).
    prev_hash: uint64 = _grid_hash()

    # The NS_PROBE marker goes to /dev/cons (writes -> printk + serial), NOT
    # our own fd 1/2 (this DE daemon is spawned detached). Open it once.
    consfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/cons"))

    # BUG 1 PROBE/PROOF: feed the shell a one-shot `echo NS_OK; ls /` over
    # its stdin pipe (the channel we own — no /dev/cons keystroke
    # contention). hamsh's `/bin/ls` runs in the namespace it COW-inherited
    # from us (PID-1's ambient ns); its output streams back over the shell's
    # stdout into our glyph grid — deterministic proof the graphical
    # terminal's shell sees a populated namespace like the FM. Sent ONCE,
    # up-front, BEFORE the blocking loop (the loop blocks on /keys and would
    # otherwise never poll the shell without a keystroke). The probe output
    # is then collected by a bounded pump.
    probe_cmd: Array[24, uint8]
    _pc: Ptr[uint8] = cast[Ptr[uint8]]("echo NS_OK; ls /")
    _pn: uint64 = 0
    while _pc[_pn] != 0:
        probe_cmd[_pn] = _pc[_pn]
        _pn = _pn + 1
    _send_line(&probe_cmd[0], _pn)
    # Collect the probe's banner + `ls /` listing. A generous budget so the
    # whole listing lands (the shell may take a few scheduler turns to start
    # /bin/ls and stream its output) — this runs ONCE at startup only.
    prev_hash = _pump_shell_bounded(cast[Ptr[char]](&scenep[0]),
                                    cast[Ptr[char]](&ctlp[0]), prev_hash, 200)
    # Cold-start timing report (perf D1). Elapsed jiffies from just-before the
    # shell spawn to here (rc sourced + probe `ls /` streamed). A gate can grep
    # "[hamterm] COLD_START jiffies=<N>" to prove the FIRST terminal's shell
    # bring-up is no longer paying the cold file-cache penalty (rc.5 pre-warm).
    # HZ=100, so ms = jiffies * 10. Emitted once, to /dev/cons.
    if consfd >= 0:
        t_cold1: uint64 = sys_get_jiffies()
        tj: uint64 = t_cold1 - t_cold0
        cl: Array[48, uint8]
        cpfx: Ptr[uint8] = cast[Ptr[uint8]]("[hamterm] COLD_START jiffies=")
        cp: uint64 = 0
        while cpfx[cp] != 0:
            cl[cp] = cpfx[cp]
            cp = cp + 1
        cp = cp + _u64_to_dec(tj, &cl[cp])
        cl[cp] = 10
        cp = cp + 1
        sys_write(consfd, &cl[0], cp)
    # BUG 1 OCCLUSION-INDEPENDENT PROOF: scan the grid for a real root entry
    # and emit ONE serial marker carrying the entry name (the gate asserts
    # on "[hamterm] NS_PROBE: <entry>"). Built + emitted in a SINGLE atomic
    # write so it never interleaves with hamsh's idle heartbeat mid-line.
    nsmark: Array[16, uint8]
    if consfd >= 0:
        mlen: uint64 = _grid_find_root(&nsmark[0])
        if mlen > 0:
            ml: Array[48, uint8]
            pfx: Ptr[uint8] = cast[Ptr[uint8]]("[hamterm] NS_PROBE: ")
            mp: uint64 = 0
            while pfx[mp] != 0:
                ml[mp] = pfx[mp]
                mp = mp + 1
            k2: uint64 = 0
            while k2 < mlen:
                ml[mp] = nsmark[k2]
                mp = mp + 1
                k2 = k2 + 1
            ml[mp] = 10
            mp = mp + 1
            sys_write(consfd, &ml[0], mp)

    # INITIAL COMMAND (Terminal=true launch): feed argv[1] to the shell now
    # that the startup probe has drained and the prompt is live. The command
    # streams its output into our glyph grid exactly like a typed line, so the
    # hosted app (e.g. `enter linux { /bin/hamnix-linux-demo }`) renders in
    # THIS window. Sent once, up-front, before the blocking loop.
    if cast[uint64](init_cmd) != 0:
        icl: uint64 = 0
        while init_cmd[icl] != 0:
            icl = icl + 1
        _send_line(init_cmd, icl)
        if consfd >= 0:
            _writeall(consfd, cast[Ptr[uint8]]("[hamterm] init cmd: "))
            _writeall(consfd, init_cmd)
            _writeall(consfd, cast[Ptr[uint8]]("\n"))
        prev_hash = _pump_shell_bounded(cast[Ptr[char]](&scenep[0]),
                                        cast[Ptr[char]](&ctlp[0]), prev_hash,
                                        200)

    # If we somehow have no /keys handle, fall back to a slow poll so the
    # terminal still renders shell output rather than wedging.
    if kfd < 0:
        while True:
            prev_hash = _pump_shell_bounded(cast[Ptr[char]](&scenep[0]),
                                            cast[Ptr[char]](&ctlp[0]),
                                            prev_hash, 8)
            # BUG #126: same shell-exit -> window-close teardown as the
            # event-driven loop below (see the long note there). Exit the
            # process on shell EOF so the wsys reaper reclaims our window.
            if sh_alive == 0:
                if consfd >= 0:
                    _writeall(consfd, cast[Ptr[uint8]](
                        "[hamterm] shell exited; closing window\n"))
                return 0
            s2: uint64 = sys_get_jiffies()
            while sys_get_jiffies() - s2 < 2:
                sys_yield()
        return 0

    # READINESS-MULTIPLEXING loop (KEYSTONE BUG #1 FIX).
    #
    # The OLD loop did a BLOCKING sys_read on /keys. While parked there the
    # shell's stdout pipe (sh_out_fd) was NOT serviced, so a command's output
    # and the next prompt did not render until the user pressed a key (the only
    # thing that woke the read). We must wait on BOTH /keys AND sh_out_fd.
    #
    # A NON-BLOCKING keys read + an UNCONDITIONAL _drain_shell() every
    # iteration; when BOTH /keys and the shell are idle we BLOCK in
    # sys_waitfds([keys, shell-stdout]) (both wake-wired via waitfds_notify),
    # which parks off the runqueue and wakes in ~0ms on a keystroke or shell
    # byte — no busy-spin and no fixed wake-floor before an echo. Result: shell
    # output renders within ~one tick with no follow-up keystroke (#1), and a
    # key's echo commits in the same frame (#2 — drain keys -> forward -> drain
    # echo -> commit, all in one wake).
    #
    # Idle CPU cost is bounded: when both /keys and the shell are quiet we
    # hlt-sleep one jiffy per loop, identical to a parked blocking read.
    TERM_IDLE_SLEEP_MS: int64 = 10            # /event re-poll cap (1 jiffy)
    while True:
        room: uint64 = 512 - kev_carry
        if room == 0:
            # Pathologically large carry (malformed line with no newline) —
            # drop it to avoid a wedge; never happens for well-formed
            # "<t> <code>\n" lines (<=~12 bytes).
            kev_carry = 0
            room = 512
        # NON-BLOCKING keys read: 0 = no key this tick (we still drain the
        # shell below), >0 = bytes, <0 = error/EOF (treated as no-data).
        kn: int64 = sys_read_nb(kfd, &kev_buf[kev_carry], room)
        # BUG 1b + mouse-wheel: BOTH the "r <w> <h>" resize line AND the
        # "m <x> <y> <buttons> <dz>" pointer line arrive on /event (the
        # in-kernel router _wsys_evt_emit_pointer pushes pointer lines onto
        # the EVENT ring, not the separate /pointer file). _poll_events drains
        # the ring, re-layouts on resize, and folds wheel notches (dz) into
        # the scrollback view. It returns non-zero when EITHER the grid size
        # OR the scroll-back view offset changed; force a re-emit + commit so
        # wheeling is instant even at idle (the grid hash folds term_view_off).
        evt_changed: int32 = _poll_events(efd)
        if evt_changed != 0:
            _emit_scene(cast[Ptr[char]](&scenep[0]))
            cfdr: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
            if cfdr >= 0:
                _writeall(cfdr, cast[Ptr[uint8]]("commit\n"))
                sys_close(cfdr)
            prev_hash = _grid_hash()
        keys_forwarded = 0
        keys_local_changed = 0
        if kn > 0:
            # BUG 3 FIX: parse only COMPLETE "<t> <code>\n" lines; CARRY any
            # partial trailing line across reads so a keystroke split at a
            # buffer boundary or a fast burst is never lost.
            total: uint64 = kev_carry + cast[uint64](kn)
            done: uint64 = _drain_keys_chunk(total)
            leftover: uint64 = total - done
            m: uint64 = 0
            while m < leftover:
                kev_buf[m] = kev_buf[done + m]
                m = m + 1
            kev_carry = leftover
        before: uint64 = prev_hash
        # BUG 3 FIX: commit the LOCAL echo IMMEDIATELY (same wake, no shell
        # round-trip). The typed char is already in the grid via _key_local's
        # _term_putc; commit it now so it appears with no perceptible lag.
        #
        # The old per-keystroke "[term-lat] j=<jiffies>" probe was removed: it
        # did a SYNCHRONOUS /dev/cons (serial) write on every echoed keystroke,
        # adding hot-path latency to the very thing it measured AND flooding the
        # console. Keystroke->echo is now a same-wake local commit; the residual
        # is at most one timer tick (~10ms) of kbd-pump delay (kbd_pump_to_
        # compositor runs on the timer IRQ), well below perceptible.
        if keys_local_changed != 0:
            prev_hash = _commit_if_changed(cast[Ptr[char]](&scenep[0]),
                                           cast[Ptr[char]](&ctlp[0]), prev_hash)
        # ALWAYS drain the shell. Shell output (the prompt, command results)
        # is serviced every iteration, not only on a keystroke. No await_echo:
        # the local echo already committed above, so a plain bounded drain
        # collects the command's OUTPUT (which is the only thing the shell
        # emits now — its readline runs --no-echo).
        prev_hash = _pump_shell_bounded(cast[Ptr[char]](&scenep[0]),
                                        cast[Ptr[char]](&ctlp[0]),
                                        prev_hash, 32)
        # SHELL EXIT -> CLOSE THE WINDOW (BUG #126). A real terminal window
        # disappears when its interactive shell exits (`exit`, Ctrl-D/EOF, or
        # death). _drain_shell — reached via the pump above — clears sh_alive
        # when the shell's stdout pipe hits true EOF, i.e. the hamsh process is
        # gone and no writer holds the pipe. Until now this loop was `while
        # True` with NO sh_alive check, so hamtermscene stayed alive forever
        # after `exit` and its window lingered as a dead, frozen box (the
        # user-reported bug; task #65 fixed the LEGACY /bin/hamterm bridge, not
        # this scene-path terminal). Break out and RETURN so the process exits;
        # the kernel wsys reaper (wsys_reap_dead_wids, run on the panel's
        # periodic /dev/wsys/windows taskbar poll and on any alloc-table-full)
        # then sees our now-dead owner pid, frees the wid, and recomposes the
        # window off-screen (wsys_free_wid's recompose+flush). A scene client
        # cannot `free` its OWN wid (that ctl verb is hostowner-only), so
        # process-exit + owner-dead reap is the sanctioned scene-DE teardown.
        if sh_alive == 0:
            if consfd >= 0:
                _writeall(consfd, cast[Ptr[uint8]](
                    "[hamterm] shell exited; closing window\n"))
            break
        # Block ONLY when this iteration was fully idle (no key, no shell
        # output, no commit). Instead of a blind timer sleep — which made a
        # keystroke landing just after we dozed wait the full 10ms floor (the
        # residual input lag the user saw) — we BLOCK on {keys, shell-stdout}
        # via sys_waitfds. Both are wake-wired (wsys_route_key + pipe_write
        # call waitfds_notify), so a keystroke or shell byte wakes us in ~0ms
        # for an instant echo. The short timeout only bounds the re-poll of
        # /event (wheel/resize has no waitfds wake hook), so wheeling at idle
        # still scrolls within one tick. Off-the-runqueue — no busy-spin.
        if kn <= 0 and evt_changed == 0 and prev_hash == before:
            wfds: Array[2, int32]
            wfds[0] = kfd
            wfds[1] = sh_out_fd
            sys_waitfds(&wfds[0], 2, TERM_IDLE_SLEEP_MS)
    return 0

# user/hamtermscene.ad
#
# Scene-file DE terminal (docs/de_scene_file_arch.md §16 step 8).
#
# A REAL terminal drawn entirely as a scene display list. It spawns ONE
# long-lived interactive `/bin/hamsh` over a pair of pipes (exactly the
# bridge user/hamterm.ad / user/sshd.ad use) and renders the SHELL'S
# OUTPUT as a scrolling monospace glyph grid (the `glyphs` primitive, the
# terminal tier per §4). It is a decorated window (decorate 1) so the
# compositor draws an SSD titlebar and the window is movable.
#
# INPUT (§11)
# -----------
# The compositor's focus router delivers KEY events to the FOCUSED window
# on /dev/wsys/<wid>/keys as ASCII "<type> <code>\n" lines (type 'd' =
# press, 'u' = release; code is a raw ASCII byte) — the SAME stream
# lib/hamui.ad and user/hamecho.ad consume. We read that file, accumulate
# typed bytes into a command line, and on Enter ('\n' / '\r') feed the
# line + '\n' to the shell's stdin. Backspace edits the line.
#
# POINTER events arrive on a SEPARATE file (/dev/wsys/<wid>/event, "m <x>
# <y> ..." lines). A terminal does NOT type its mouse: we NEVER open or
# render that file, so mousing over the window no longer fills it with
# "m <x> <y> ..." glyph spam (the old echo-every-event bug). The click
# that gives us focus is handled entirely by the compositor; we only need
# keys after that.
#
# Each tick we non-blockingly drain the shell's stdout pipe into a bounded
# scrollback ring, re-emit our scene (damage-scoped: one commit per change)
# and commit. Type `ls`+Enter -> the shell's prompt + output stream into
# the grid, not pointer noise.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_nanosleep(req: Ptr[int64], rem: Ptr[int64]) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_pipechan() -> int32
extern def sys_fdbind(pid: int32, fdnum: int32, kind: int32,
                      arg: int32) -> int32

# devfd channel-kinds + spawn sentinel (match user/hamsh.ad / devfd.ad).
DEVFD_CONS:     int32 = 1
DEVFD_PIPE_R:   int32 = 2
DEVFD_PIPE_W:   int32 = 3
SPAWN_STDIO_NS: int32 = -2

from lib.p9 import spawn


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    # Write "newwindow", then re-open ctl for READ to fetch the wid (a
    # write-only fd is not reliably readable).
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# BUG 1b: the grid is now RESIZE-AWARE. The window can grow (maximize / snap
# / free-resize) so the row/col counts are runtime variables, not constants,
# recomputed from the window's pixel w/h when an "r <w> <h>" resize event
# arrives on /event. The backing arrays are sized to a generous MAX (a full
# 1280x800 screen worth of cells); the ACTIVE grid is term_rows_n x term_cols_n.
# The per-row STRIDE in term_rows[] stays fixed at TERM_STRIDE so indexing is
# simple regardless of the active column count.
TERM_STRIDE:    uint64 = 160              # max cols per row (1280px / 8px glyph)
TERM_MAX_ROWS:  uint64 = 40              # max rows (800px / 20px line)
TERM_GLYPH_W:   int64  = 8               # glyph advance used by the cache font
TERM_LINE_H:    int64  = 20              # line pitch in _emit_scene (y = 6 + r*20)

term_w: int64 = 360                       # current window CONTENT width (px)
term_h: int64 = 200                       # current window CONTENT height (px)
term_rows_n: uint64 = 9                   # active row count
term_cols_n: uint64 = 56                  # active column count

# A ring of text rows the terminal renders as glyphs. The bottom row is the
# LIVE edit line (prompt-relative input echo); rows above it are the committed
# scrollback the shell produced.
term_rows: Array[6400, uint8]             # TERM_MAX_ROWS * TERM_STRIDE
term_row_len: Array[40, uint64]           # TERM_MAX_ROWS


# Checksum of the VISIBLE grid (rows + lengths). We re-emit the scene only
# when this changes, NOT merely when bytes were consumed. hamsh repaints its
# prompt to stdout every ~3s (its idle heartbeat calls _ed_redraw), which our
# ANSI filter collapses to the SAME visible glyphs — re-committing that
# identical frame is exactly the periodic full-window repaint the flicker
# gate forbids. Hashing the grid makes those no-op repaints free.
def _grid_hash() -> uint64:
    h: uint64 = 1469598103934665603              # FNV-1a offset basis
    r: uint64 = 0
    while r < term_rows_n:
        ln: uint64 = term_row_len[r]
        h = (h ^ ln) * 1099511628211
        base: uint64 = r * TERM_STRIDE
        k: uint64 = 0
        while k < ln:
            h = (h ^ cast[uint64](term_rows[base + k])) * 1099511628211
            k = k + 1
        r = r + 1
    return h


def _term_clear():
    r: uint64 = 0
    while r < term_rows_n:
        term_row_len[r] = 0
        r = r + 1


def _term_set_row(r: uint64, s: Ptr[uint8]):
    n: uint64 = 0
    base: uint64 = r * TERM_STRIDE
    while s[n] != 0 and n < term_cols_n:
        term_rows[base + n] = s[n]
        n = n + 1
    term_row_len[r] = n


def _term_apply_resize(nw: int64, nh: int64):
    # BUG 1b: a resize event ("r <w> <h>") changed our window's content size.
    # Recompute the glyph grid (cols/rows) from the new pixel size so the
    # terminal fills the whole window and scrolls correctly. Content already
    # in the grid is kept in place (rows are bottom-anchored by the scroll
    # logic). Growing exposes more scrollback rows; shrinking drops the top.
    if nw < 8:
        nw = 8
    if nh < 20:
        nh = 20
    term_w = nw
    term_h = nh
    # Columns: leave a small left/right margin (glyphs start at x=6).
    nc: uint64 = cast[uint64]((nw - 8) / TERM_GLYPH_W)
    if nc < 8:
        nc = 8
    if nc > TERM_STRIDE:
        nc = TERM_STRIDE
    # Rows: first glyph baseline at y=6, line pitch TERM_LINE_H.
    nr: uint64 = cast[uint64]((nh - 6) / TERM_LINE_H)
    if nr < 2:
        nr = 2
    if nr > TERM_MAX_ROWS:
        nr = TERM_MAX_ROWS
    old_rows: uint64 = term_rows_n
    if nr == old_rows and nc == term_cols_n:
        return
    # Re-anchor existing content to the BOTTOM of the new grid (so the live
    # edit line stays at the bottom and scrollback grows upward). Shift rows
    # by the row-count delta.
    if nr != old_rows:
        if nr > old_rows:
            # Grow: move existing rows DOWN by (nr-old_rows), clear the new top.
            d: uint64 = nr - old_rows
            r: uint64 = old_rows
            while r > 0:
                r = r - 1
                src: uint64 = r * TERM_STRIDE
                dst: uint64 = (r + d) * TERM_STRIDE
                k: uint64 = 0
                while k < TERM_STRIDE:
                    term_rows[dst + k] = term_rows[src + k]
                    k = k + 1
                term_row_len[r + d] = term_row_len[r]
            cr: uint64 = 0
            while cr < d:
                term_row_len[cr] = 0
                cr = cr + 1
        else:
            # Shrink: drop the top (old_rows-nr) rows, move the rest UP.
            d2: uint64 = old_rows - nr
            r2: uint64 = 0
            while r2 < nr:
                src2: uint64 = (r2 + d2) * TERM_STRIDE
                dst2: uint64 = r2 * TERM_STRIDE
                k2: uint64 = 0
                while k2 < TERM_STRIDE:
                    term_rows[dst2 + k2] = term_rows[src2 + k2]
                    k2 = k2 + 1
                term_row_len[r2] = term_row_len[r2 + d2]
                r2 = r2 + 1
    term_rows_n = nr
    term_cols_n = nc


def _term_scroll():
    # Scroll the grid up by one row (drop the top, shift the rest up).
    r: uint64 = 0
    while r + 1 < term_rows_n:
        sb: uint64 = (r + 1) * TERM_STRIDE
        db: uint64 = r * TERM_STRIDE
        ln: uint64 = term_row_len[r + 1]
        k: uint64 = 0
        while k < ln:
            term_rows[db + k] = term_rows[sb + k]
            k = k + 1
        term_row_len[r] = ln
        r = r + 1
    term_row_len[term_rows_n - 1] = 0


# Append one output byte from the shell into the grid, wrapping/scrolling.
# The terminal cursor lives on the bottom row (term_rows_n-1) at column
# term_col. A '\n' or column overflow scrolls up and resets the column.
term_col: uint64 = 0


def _term_putc(c: uint8):
    last: uint64 = (term_rows_n - 1) * TERM_STRIDE
    if c == 10:                             # newline -> scroll up one row
        _term_scroll()
        term_col = 0
        return
    if c == 13:                             # carriage-return -> col 0, no clear
        # Move to column 0; subsequent writes OVERWRITE in place. A prompt
        # repaint does CR + reprint + ESC[K; CR must NOT clear (that would
        # erase what the reprint then rewrites and churn the grid). ESC[K
        # (handled in the CSI filter) clears the stale tail instead.
        term_col = 0
        return
    if c == 8 or c == 127:                  # backspace / DEL
        if term_col > 0:
            term_col = term_col - 1
            term_rows[last + term_col] = 32
            if term_row_len[term_rows_n - 1] > 0:
                term_row_len[term_rows_n - 1] = term_col
        return
    if c == 9:                              # tab -> a couple of spaces
        _term_putc(32)
        _term_putc(32)
        return
    if c < 32:                              # drop other control bytes
        return
    if term_col >= term_cols_n:
        _term_scroll()
        term_col = 0
    term_rows[last + term_col] = c
    term_col = term_col + 1
    if term_col > term_row_len[term_rows_n - 1]:
        term_row_len[term_rows_n - 1] = term_col


# ANSI escape filter state. hamsh's prompt/readline emits VT100 control
# sequences (cursor moves, "show cursor", colours). We are a glyph grid, not
# a VT220, so we SWALLOW escape sequences rather than draw "[7C" / "[?25h" as
# literal glyphs. States: 0 = ground, 1 = saw ESC, 2 = inside CSI (ESC [ ...),
# 3 = inside OSC (ESC ] ... terminated by BEL or ST).
esc_st: int32 = 0


def _term_feed(c: uint8):
    if esc_st == 0:
        if c == 27:                         # ESC
            esc_st = 1
            return
        _term_putc(c)
        return
    if esc_st == 1:                         # just saw ESC
        if c == 91:                         # '[' -> CSI
            esc_st = 2
        else:
            if c == 93:                     # ']' -> OSC
                esc_st = 3
            else:
                # Two-byte escape (e.g. ESC c) — done.
                esc_st = 0
        return
    if esc_st == 2:                         # CSI: params until a final byte
        # Final byte is in 0x40..0x7E (@ A..Z [ \ ] ^ _ ` a..z { | } ~).
        if c >= 64 and c <= 126:
            if c == 75:                     # 'K' — erase to end of line
                # Clear from the cursor column to the end of the bottom row
                # (the prompt-repaint tail clear). This is what keeps a CR +
                # reprint + ESC[K idempotent: identical content each repaint.
                if term_row_len[term_rows_n - 1] > term_col:
                    term_row_len[term_rows_n - 1] = term_col
            esc_st = 0
        return
    if esc_st == 3:                         # OSC: until BEL (7) or ESC-\ (ST)
        if c == 7:
            esc_st = 0
        else:
            if c == 27:                     # ST begins with ESC; consume next
                esc_st = 1
        return


def _term_puts_n(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        _term_feed(p[i])
        i = i + 1


def _emit_scene(scenepath: Ptr[char]):
    sfd: int32 = sys_open_write(scenepath)
    if sfd < 0:
        return
    # BUG 1b: scene buffer sized for the MAX grid (40 rows * ~160 cols + per-
    # row overhead). A maximized terminal emits far more than the old 360x200
    # box did, so the old 4096 buffer would truncate the scene.
    scene: Array[8192, uint8]
    sp: uint64 = 0
    # Background dark panel sized to the CURRENT window (term_w x term_h) so a
    # maximized / snapped terminal fills its whole window, not the original box.
    head: Ptr[uint8] = cast[Ptr[uint8]]("# scene v1 term\nfill 0 0 ")
    a: uint64 = 0
    while head[a] != 0:
        scene[sp] = head[a]
        sp = sp + 1
        a = a + 1
    sp = sp + _u64_to_dec(cast[uint64](term_w), &scene[sp])
    scene[sp] = 32
    sp = sp + 1
    sp = sp + _u64_to_dec(cast[uint64](term_h), &scene[sp])
    bgtail: Ptr[uint8] = cast[Ptr[uint8]](" #101418\n")
    bt: uint64 = 0
    while bgtail[bt] != 0:
        scene[sp] = bgtail[bt]
        sp = sp + 1
        bt = bt + 1
    # each text row as a glyphs line at y = 6 + r*20
    r: uint64 = 0
    while r < term_rows_n:
        ln: uint64 = term_row_len[r]
        is_cursor_row: int32 = 0
        if r == term_rows_n - 1:
            is_cursor_row = 1
        # Always emit the bottom (edit) row even when empty so a blinking-ish
        # cursor marker is visible; skip blank scrollback rows.
        if ln > 0 or is_cursor_row != 0:
            g: Ptr[uint8] = cast[Ptr[uint8]]("glyphs 6 ")
            b: uint64 = 0
            while g[b] != 0:
                scene[sp] = g[b]
                sp = sp + 1
                b = b + 1
            yy: uint64 = 6 + r * 20
            sp = sp + _u64_to_dec(yy, &scene[sp])
            scene[sp] = 32
            scene[sp + 1] = 34                     # opening quote
            sp = sp + 2
            base: uint64 = r * TERM_STRIDE
            k: uint64 = 0
            while k < ln:
                ch: uint8 = term_rows[base + k]
                if ch == 34 or ch == 10:           # sanitize quote/newline
                    ch = 32
                scene[sp] = ch
                sp = sp + 1
                k = k + 1
            if is_cursor_row != 0:
                scene[sp] = 95                      # '_' text cursor
                sp = sp + 1
            tail: Ptr[uint8] = cast[Ptr[uint8]]("\" #c0f0c0\n")
            c: uint64 = 0
            while tail[c] != 0:
                scene[sp] = tail[c]
                sp = sp + 1
                c = c + 1
        r = r + 1
    sys_write(sfd, &scene[0], sp)
    sys_close(sfd)


# --- persistent shell wiring ------------------------------------------
# BUG 1 ROOT-CAUSE + FIX. The old wiring used sys_pipe()+integer-fd spawn
# (sin=to_sh[0], sout=from_sh[1]); lib/p9.spawn dup2'd those onto the
# child's INTEGER fd 0/1. But hamsh reads/serves stdio through the `/fd`
# NAME table (devfd), which is a SEPARATE table from the integer fds. With
# only integer fds dup'd, hamsh's `/fd/0,1` stayed DEVFD_NONE, so hamsh's
# _setup_fd_namespace SEEDED them to DEVFD_CONS (the kernel console). hamsh
# itself read/wrote integer fd 0/1 (the pipe) for its prompt + readline
# echo — so the BANNER and the echoed command line reached our grid — but
# every EXTERNAL command (`ls`, `cat`, …) inherits hamsh's `/fd/1` via the
# COW Pgrp clone, and that was CONS, so `ls /` output went to the boot
# console, NOT our window. The terminal looked like an empty namespace;
# it was really lost child-stdout. (#450 retired the kernel SYS_SPAWN arm
# that used to auto-populate /fd/0,1,2 from the integer-fd backings — the
# regression that orphaned the /fd names.)
#
# FIX: spawn hamsh with SPAWN_STDIO_NS and bind its `/fd/0` / `/fd/1` to
# real pipe CHANS (DEVFD_PIPE_R / DEVFD_PIPE_W) — the exact mechanism
# hamsh's own pipeline / command-substitution path uses. Now external
# children inherit the pipe through the Pgrp clone and their output streams
# back into our glyph grid. We hold the OPPOSITE ends by binding them at
# our own scratch `/fd/10` (stdin write) and `/fd/11` (stdout read) and
# opening those names for integer fds we read/write.
spawn_argv:  Array[2, uint64]
TERM_IN_FD:  int32 = 10        # our scratch /fd name for the stdin WRITE end
TERM_OUT_FD: int32 = 11        # our scratch /fd name for the stdout READ end
sh_in_fd:  int32 = -1          # write end -> hamsh stdin (feed commands)
sh_out_fd: int32 = -1          # read end  <- hamsh stdout (drain output)
sh_alive:  int32 = 0
read_buf:  Array[512, uint8]


def _start_shell() -> int32:
    # Two pipe Chans: in_slot = terminal -> hamsh stdin;
    #                 out_slot = hamsh stdout -> terminal.
    in_slot: int32 = sys_pipechan()
    if in_slot < 0:
        return -1
    out_slot: int32 = sys_pipechan()
    if out_slot < 0:
        return -1
    # Hold our ends: bind the stdin WRITE end + the stdout READ end at our
    # own scratch /fd names, then open them for readable/writable int fds.
    sys_fdbind(0, TERM_IN_FD,  DEVFD_PIPE_W, in_slot)
    sys_fdbind(0, TERM_OUT_FD, DEVFD_PIPE_R, out_slot)
    sh_in_fd  = sys_open(cast[Ptr[char]]("/fd/10"))
    sh_out_fd = sys_open(cast[Ptr[char]]("/fd/11"))
    if sh_in_fd < 0 or sh_out_fd < 0:
        return -1
    spawn_argv[0] = cast[uint64]("/bin/hamsh")
    spawn_argv[1] = 0
    # SPAWN_STDIO_NS: the child's stdio are NAMES (/fd/0,1,2) we wire by
    # fdbind below — NOT dup'd integer fds. This is what lets hamsh's
    # external children inherit real pipes for stdin/stdout.
    pid: int32 = spawn(cast[Ptr[char]]("/bin/hamsh"), &spawn_argv[0],
                       SPAWN_STDIO_NS, SPAWN_STDIO_NS,
                       cast[Ptr[uint64]](0))
    if pid < 0:
        return -1
    # Wire hamsh's /fd/0 = stdin READ end, /fd/1 = stdout WRITE end. The
    # child is still STATE_READY (cooperative scheduler), so these binds
    # land in its namespace before its first instruction runs.
    sys_fdbind(pid, 0, DEVFD_PIPE_R, in_slot)
    sys_fdbind(pid, 1, DEVFD_PIPE_W, out_slot)
    # fd 2 (stderr) -> the console so hamsh's TEMP_DEBUG_* stage markers
    # still reach the serial log; the window only renders stdout.
    sys_fdbind(pid, 2, DEVFD_CONS, 0)
    # Drop OUR write-reference to the stdin-read pipe and read-reference to
    # the stdout-write pipe by releasing the creator slot bindings: the
    # child + our held ends keep the refcounts alive. (We never bound those
    # opposite ends at our own names, so nothing to release here; the
    # pipechan creator ref is consumed by the two fdbinds.)
    sh_alive = 1
    return 0


# Cooperative short sleep (jiffy-granular, HZ=100 → 10 ms floor). Parks the
# task off the runqueue (sti+hlt) so it does NOT busy-spin; other tasks (the
# shell) get the CPU while we wait. Used by the main loop's bounded readiness
# poll: every wake we drain BOTH /keys and the shell pipe, so shell output
# (the new prompt) renders within ~one tick even when no key is pressed.
term_sleep_ts: Array[2, int64]


def _short_sleep_ns(ns: int64):
    term_sleep_ts[0] = 0                       # tv_sec
    term_sleep_ts[1] = ns                      # tv_nsec
    sys_nanosleep(&term_sleep_ts[0], cast[Ptr[int64]](0))


# Non-blocking drain of the shell's stdout into the glyph grid. Returns the
# number of bytes consumed this call (0 = nothing). Sets sh_alive = 0 on EOF.
def _drain_shell() -> uint64:
    if sh_alive == 0 or sh_out_fd < 0:
        return 0
    got: uint64 = 0
    passes: int32 = 0
    while passes < 8:
        n: int64 = sys_read_nb(sh_out_fd, &read_buf[0], 512)
        if n > 0:
            _term_puts_n(&read_buf[0], cast[uint64](n))
            got = got + cast[uint64](n)
            passes = passes + 1
            continue
        if n < 0:
            sh_alive = 0
        break
    return got


# Feed one command line (NUL-terminated, length ln) to the shell's stdin,
# appending '\n'. Returns 0 on success, -1 if the shell is gone.
line_buf: Array[576, uint8]


def _send_line(buf: Ptr[uint8], ln: uint64) -> int32:
    if sh_alive == 0 or sh_in_fd < 0:
        return -1
    j: uint64 = 0
    while j < ln and j < 574:
        line_buf[j] = buf[j]
        j = j + 1
    line_buf[j] = 10                        # '\n'
    j = j + 1
    w: int64 = sys_write(sh_in_fd, &line_buf[0], j)
    if w < 0:
        sh_alive = 0
        return -1
    return 0


# --- BUG 1 occlusion-independent proof --------------------------------
# The Bug-1 verdict (does the terminal's hamsh see a real, non-empty
# namespace?) used to be read ONLY off a composited screendump / a late
# `cat /dev/wsys/3/scene` capture. Both are unreliable: the file-manager
# window stacks ON TOP of the terminal and OCCLUDES its output rows, and
# the late scene capture races the serial keystroke-echo flood. So neither
# can reliably observe the `ls /` listing even when it rendered correctly.
#
# Instead we prove it AT THE SOURCE: once the startup probe's `ls /` output
# has streamed back over the shell's stdout into our OWN glyph grid, we scan
# the grid for a real root-directory entry and emit ONE deterministic serial
# marker — "[hamterm] NS_PROBE: <entry>" — to the boot console (fd 2). This
# is occlusion-proof (it reads our private grid, not the framebuffer) and
# fires exactly once (no per-frame spam, no flicker, no UART carve-out
# breakage). The gate asserts on that marker.
#
# _grid_find_root() returns the byte-length of the first matching root entry
# (writing it NUL-terminated into `out`), or 0 if none is present yet. The
# token set mirrors the gate's ROOT_RE (proc/srv/net/sys/bin/etc/usr/mnt/
# ext/var/lib/tmp/dev). We match a whole grid "word" (delimited by space,
# tab, '/', or row end) so we never false-match on the prompt or the echoed
# command text.
root_tokens: Array[13, uint64]
root_tok_len: Array[13, uint64]


def _tok_eq(base: uint64, start: uint64, wlen: uint64,
            tok: Ptr[uint8], tlen: uint64) -> int32:
    if wlen != tlen:
        return 0
    k: uint64 = 0
    while k < tlen:
        if term_rows[base + start + k] != tok[k]:
            return 0
        k = k + 1
    return 1


def _grid_find_root(out: Ptr[uint8]) -> uint64:
    # Seed the recognized root-entry token table (idempotent).
    root_tokens[0]  = cast[uint64]("proc")
    root_tok_len[0]  = 4
    root_tokens[1]  = cast[uint64]("srv")
    root_tok_len[1]  = 3
    root_tokens[2]  = cast[uint64]("net")
    root_tok_len[2]  = 3
    root_tokens[3]  = cast[uint64]("sys")
    root_tok_len[3]  = 3
    root_tokens[4]  = cast[uint64]("bin")
    root_tok_len[4]  = 3
    root_tokens[5]  = cast[uint64]("etc")
    root_tok_len[5]  = 3
    root_tokens[6]  = cast[uint64]("usr")
    root_tok_len[6]  = 3
    root_tokens[7]  = cast[uint64]("mnt")
    root_tok_len[7]  = 3
    root_tokens[8]  = cast[uint64]("ext")
    root_tok_len[8]  = 3
    root_tokens[9]  = cast[uint64]("var")
    root_tok_len[9]  = 3
    root_tokens[10] = cast[uint64]("lib")
    root_tok_len[10] = 3
    root_tokens[11] = cast[uint64]("tmp")
    root_tok_len[11] = 3
    root_tokens[12] = cast[uint64]("dev")
    root_tok_len[12] = 3
    r: uint64 = 0
    while r < term_rows_n:
        ln: uint64 = term_row_len[r]
        base: uint64 = r * TERM_STRIDE
        i: uint64 = 0
        while i < ln:
            c: uint8 = term_rows[base + i]
            # word delimiters: space / tab / '/'
            if c == 32 or c == 9 or c == 47:
                i = i + 1
                continue
            # start of a word: measure its extent
            ws: uint64 = i
            while i < ln:
                d: uint8 = term_rows[base + i]
                if d == 32 or d == 9 or d == 47:
                    break
                i = i + 1
            wlen: uint64 = i - ws
            t: uint64 = 0
            while t < 13:
                tok: Ptr[uint8] = cast[Ptr[uint8]](root_tokens[t])
                if _tok_eq(base, ws, wlen, tok, root_tok_len[t]) != 0:
                    k: uint64 = 0
                    while k < wlen:
                        out[k] = term_rows[base + ws + k]
                        k = k + 1
                    out[wlen] = 0
                    return wlen
                t = t + 1
        r = r + 1
    return 0


# --- key input from /dev/wsys/<wid>/keys ------------------------------
kev_buf:  Array[512, uint8]
kev_carry: uint64 = 0                     # leftover partial-line bytes at buf head
keyout:   Array[256, uint8]              # forwarded bytes -> shell stdin


# Forward one raw byte to the persistent shell's stdin. We feed keystrokes
# straight through (no local line buffer): hamsh's interactive readline does
# its OWN echo + line editing, and that echo streams back over the shell's
# stdout into our glyph grid — exactly like a real terminal. Locally echoing
# would double every character.
#
# `keys_forwarded` counts bytes pushed to the shell this wake. The main-loop
# pump uses it to WAIT for the just-typed char's echo before committing the
# frame (BUG 1 off-by-one fix): without it the pump bailed after 2 quick empty
# drains — before the cooperatively-scheduled shell had run its readline echo —
# so the echo of key N only landed on the NEXT keystroke's wake, leaving the
# screen one character behind the keyboard.
keys_forwarded: uint64 = 0


def _key_to_shell(c: uint8):
    if sh_alive == 0 or sh_in_fd < 0:
        return
    keyout[0] = c
    w: int64 = sys_write(sh_in_fd, &keyout[0], 1)
    if w < 0:
        sh_alive = 0
        return
    keys_forwarded = keys_forwarded + 1


# Parse "<type> <code>\n" key lines out of a freshly-read chunk. For each
# 'd' (press) line with a printable / Enter / Backspace code, forward the
# byte to the shell. The shell's echo comes back over stdout (rendered by
# _drain_shell). Returns 1 if any key was forwarded (so we re-poll output).
# BUG 3 FIX (dropped keystroke, consumer side). Parse only COMPLETE
# "<type> <code>\n" lines out of kev_buf[0..n). Returns the number of bytes
# CONSUMED — i.e. the offset just past the last '\n'. Any trailing partial
# line (the read split a key line at the buffer boundary) is left for the
# caller to carry forward, so a keystroke split across two reads is NOT
# dropped. (Previously the parser consumed a partial trailing line and lost
# that press under a burst.)
def _drain_keys_chunk(n: uint64) -> uint64:
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        ls: uint64 = i                      # start of this line
        t: uint8 = kev_buf[i]
        i = i + 1
        if i < n and kev_buf[i] == 32:
            i = i + 1
        # parse decimal code
        code: int32 = 0
        have: int32 = 0
        neg: int32 = 0
        if i < n and kev_buf[i] == 45:
            neg = 1
            i = i + 1
        while i < n and kev_buf[i] >= 48 and kev_buf[i] <= 57:
            code = code * 10 + cast[int32](kev_buf[i]) - 48
            i = i + 1
            have = 1
        # advance to end of line
        while i < n and kev_buf[i] != 10:
            i = i + 1
        if i >= n:
            # No terminating '\n' in this chunk — the line is incomplete.
            # Stop; the caller carries kev_buf[ls..n) into the next read.
            return ls
        i = i + 1                           # consume '\n'
        consumed = i
        if neg != 0:
            code = 0 - code
        # Only press events ('d') with a real code drive input.
        if t != 100 or have == 0:
            continue
        if code == 13:                      # CR -> NL for the shell
            code = 10
        # Forward printable bytes, Enter and Backspace/DEL to the shell.
        if code == 10 or code == 8 or code == 127 \
                or (code >= 32 and code < 127):
            _key_to_shell(cast[uint8](code))
    return consumed


# --- resize events from /dev/wsys/<wid>/event -------------------------
# The compositor emits "r <w> <h>\n" on the event ring when our window's
# content size changes (maximize / snap / free-resize). We poll that file
# non-blocking and re-layout the grid. Pointer 'm'/'s' and focus 'f' lines
# are ignored (a terminal types its keys, not its mouse).
evt_buf:   Array[512, uint8]
evt_carry: uint64 = 0


def _drain_events_chunk(n: uint64) -> uint64:
    # Parse complete lines out of evt_buf[0..n). Apply 'r <w> <h>' resize.
    # Returns the number of bytes consumed (offset past the last '\n').
    i: uint64 = 0
    consumed: uint64 = 0
    while i < n:
        ls: uint64 = i
        t: uint8 = evt_buf[i]
        # Find end of this line.
        while i < n and evt_buf[i] != 10:
            i = i + 1
        if i >= n:
            return ls                       # incomplete line; carry forward
        le: uint64 = i
        i = i + 1                           # consume '\n'
        consumed = i
        if t != 114:                        # not 'r' (resize) — ignore
            continue
        # Parse "r <w> <h>".
        p: uint64 = ls + 1
        while p < le and evt_buf[p] == 32:
            p = p + 1
        wv: int64 = 0
        while p < le and evt_buf[p] >= 48 and evt_buf[p] <= 57:
            wv = wv * 10 + cast[int64](evt_buf[p]) - 48
            p = p + 1
        while p < le and evt_buf[p] == 32:
            p = p + 1
        hv: int64 = 0
        while p < le and evt_buf[p] >= 48 and evt_buf[p] <= 57:
            hv = hv * 10 + cast[int64](evt_buf[p]) - 48
            p = p + 1
        if wv > 0 and hv > 0:
            _term_apply_resize(wv, hv)
    return consumed


# Poll the event fd (non-blocking) and apply any resize events. Returns 1 if a
# resize was applied (caller should re-emit the scene), else 0.
def _poll_events(efd: int32) -> int32:
    if efd < 0:
        return 0
    changed: int32 = 0
    prev_rows: uint64 = term_rows_n
    prev_cols: uint64 = term_cols_n
    passes: int32 = 0
    while passes < 4:
        room: uint64 = 512 - evt_carry
        if room == 0:
            evt_carry = 0
            room = 512
        en: int64 = sys_read_nb(efd, &evt_buf[evt_carry], room)
        if en <= 0:
            break
        total: uint64 = evt_carry + cast[uint64](en)
        done: uint64 = _drain_events_chunk(total)
        leftover: uint64 = total - done
        m: uint64 = 0
        while m < leftover:
            evt_buf[m] = evt_buf[done + m]
            m = m + 1
        evt_carry = leftover
        passes = passes + 1
    if term_rows_n != prev_rows or term_cols_n != prev_cols:
        changed = 1
    return changed


# Re-emit + commit the scene ONLY when the visible grid actually changed.
# `prev` carries the last committed grid hash across calls; returns the new
# hash. A no-change call costs one _grid_hash() and skips the kernel commit,
# so hamsh's identical idle prompt-repaints never re-present a frame.
def _commit_if_changed(scenepath: Ptr[char], ctlpath: Ptr[char],
                       prev: uint64) -> uint64:
    new_hash: uint64 = _grid_hash()
    if new_hash == prev:
        return prev
    _emit_scene(scenepath)
    cfd: int32 = sys_open_write(ctlpath)
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("commit\n"))
        sys_close(cfd)
    return new_hash


# BUG 2 (terminal input lag) FIX — bounded shell pump.
#
# Root cause of the residual ~0.5s lag: the old loop NEVER slept off the
# runqueue — it busy-yielded a fixed 2-jiffy (~20ms) window every pass. With
# the panel, file manager and visual gate ALSO runnable, a keystroke's
# echo round-trip (term -> shell stdin -> shell readline echo -> shell
# stdout -> term) waited for the persistent shell to win SEVERAL full
# round-robins against all those spinners, i.e. hundreds of ms. The terminal
# is now EVENT-DRIVEN: it BLOCKS on /keys (parks off the runqueue, freeing
# the CPU so the shell runs immediately) and only does a SHORT bounded drain
# of the shell pipe to collect the echo/output burst before re-blocking.
#
# Drain the shell pipe until it goes quiet for a bounded number of empty
# passes (so a multi-chunk echo / command burst is fully collected), then
# return. Commits whenever the grid changes. Returns the new committed hash.
# `budget` caps total passes so a chatty command (long `ls`) can't wedge us
# off the keyboard — leftover output is collected on the next wake.
def _pump_shell_bounded(scenepath: Ptr[char], ctlpath: Ptr[char],
                        prev: uint64, budget: int32) -> uint64:
    return _pump_shell_ex(scenepath, ctlpath, prev, budget, 0)


# Extended pump. `await_echo` != 0 means "we just forwarded keystroke(s); do
# not return on the first quiet window until the shell has produced AT LEAST
# ONE byte of output (the readline echo of the typed char)". This closes the
# BUG 1 off-by-one: the cooperatively-scheduled hamsh frequently hasn't run
# its readline echo by the time we first drain, so the plain pump would see
# two empty passes and bail BEFORE the echo arrived — committing a frame that
# still shows key N-1. With await_echo we keep yielding (bounded by an echo
# deadline in jiffies, so a dead/quiet shell can't wedge us off the keyboard)
# until the echo lands, then fall back to normal quiet-detection to collect any
# trailing output. The typed char now appears in the SAME frame.
ECHO_WAIT_JIFFIES: uint64 = 10           # bounded ~100ms wait for the echo


def _pump_shell_ex(scenepath: Ptr[char], ctlpath: Ptr[char],
                   prev: uint64, budget: int32, await_echo: int32) -> uint64:
    h: uint64 = prev
    empties: int32 = 0
    passes: int32 = 0
    saw_echo: int32 = 0
    deadline: uint64 = sys_get_jiffies() + ECHO_WAIT_JIFFIES
    while passes < budget:
        got: uint64 = _drain_shell()
        if got > 0:
            h = _commit_if_changed(scenepath, ctlpath, h)
            empties = 0
            saw_echo = 1
        else:
            empties = empties + 1
            # Normally two consecutive empty passes = the shell is quiet, so we
            # return and re-block on /keys. But if we're still WAITING for the
            # just-typed char's echo (await_echo and not yet saw_echo), keep
            # yielding until either the echo arrives or the bounded deadline
            # expires — so the typed char commits in this frame, not the next.
            if empties >= 2:
                if await_echo == 0 or saw_echo != 0:
                    break
                if sys_get_jiffies() >= deadline:
                    break                   # bounded: never spin forever
                empties = 1                 # keep waiting for the echo
            sys_yield()
        passes = passes + 1
    return h


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[term] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    scenep: Array[64, uint8]
    keysp: Array[64, uint8]
    evtp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&scenep[0], wid, cast[Ptr[uint8]]("/scene"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))
    _winpath(&evtp[0], wid, cast[Ptr[uint8]]("/event"))

    # geometry: a 360x200 box, decorated, mid-screen.
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 200 120 360 200\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 5\n"))
        sys_close(cfd3)
    # taskbar title (read by the panel via /dev/wsys/windows).
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Terminal\n"))
        sys_close(cfdt)

    _term_clear()
    _term_set_row(0, cast[Ptr[uint8]]("Hamnix scene terminal"))
    _term_set_row(1, cast[Ptr[uint8]]("type a command, press Enter"))

    # Start the ONE persistent interactive hamsh.
    if _start_shell() != 0:
        _term_set_row(2, cast[Ptr[uint8]]("(shell failed to start)"))
        _writeall(1, cast[Ptr[uint8]]("[term] shell spawn FAILED\n"))
    else:
        _writeall(1, cast[Ptr[uint8]]("[term] hamsh spawned\n"))

    _emit_scene(cast[Ptr[char]](&scenep[0]))
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("commit\n"))
        sys_close(cfd4)

    _writeall(1, cast[Ptr[uint8]]("[term] scene window ready\n"))

    # Open the per-window KEY stream (focused-window keys, ASCII bytes).
    # POINTER events live on a SEPARATE file we deliberately never open —
    # a terminal types its keyboard, not its mouse.
    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    # BUG 1b: open /event (non-blocking polled) for resize notifications.
    efd: int32 = sys_open(cast[Ptr[char]](&evtp[0]))

    # BUG 2 (terminal input lag) FIX — EVENT-DRIVEN main loop.
    #
    # The terminal now BLOCKS on /keys (devwsys_keys_read parks the task on
    # the per-window keys wait-queue, OFF the runqueue) instead of busy-
    # yielding a fixed jiffy window. The compositor's wsys_route_key does a
    # directed wq_wake_one on a keystroke, so we wake in ~0 latency and the
    # shell — no longer starved by our spin — gets the CPU to echo
    # immediately. After each keystroke we forward it and do a SHORT bounded
    # drain of the shell pipe to collect the echo, then re-block. Result:
    # keystroke -> on-screen echo is next-frame (single-digit ms), not the
    # ~0.5s round-robin wait of the old poll loop.
    #
    # `prev_hash` carries the last committed grid hash so an unchanged grid
    # never re-commits (flicker-stable idle, unchanged from before).
    prev_hash: uint64 = _grid_hash()

    # The NS_PROBE marker goes to /dev/cons (writes -> printk + serial), NOT
    # our own fd 1/2 (this DE daemon is spawned detached). Open it once.
    consfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/cons"))

    # BUG 1 PROBE/PROOF: feed the shell a one-shot `echo NS_OK; ls /` over
    # its stdin pipe (the channel we own — no /dev/cons keystroke
    # contention). hamsh's `/bin/ls` runs in the namespace it COW-inherited
    # from us (PID-1's ambient ns); its output streams back over the shell's
    # stdout into our glyph grid — deterministic proof the graphical
    # terminal's shell sees a populated namespace like the FM. Sent ONCE,
    # up-front, BEFORE the blocking loop (the loop blocks on /keys and would
    # otherwise never poll the shell without a keystroke). The probe output
    # is then collected by a bounded pump.
    probe_cmd: Array[24, uint8]
    _pc: Ptr[uint8] = cast[Ptr[uint8]]("echo NS_OK; ls /")
    _pn: uint64 = 0
    while _pc[_pn] != 0:
        probe_cmd[_pn] = _pc[_pn]
        _pn = _pn + 1
    _send_line(&probe_cmd[0], _pn)
    # Collect the probe's banner + `ls /` listing. A generous budget so the
    # whole listing lands (the shell may take a few scheduler turns to start
    # /bin/ls and stream its output) — this runs ONCE at startup only.
    prev_hash = _pump_shell_bounded(cast[Ptr[char]](&scenep[0]),
                                    cast[Ptr[char]](&ctlp[0]), prev_hash, 200)
    # BUG 1 OCCLUSION-INDEPENDENT PROOF: scan the grid for a real root entry
    # and emit ONE serial marker carrying the entry name (the gate asserts
    # on "[hamterm] NS_PROBE: <entry>"). Built + emitted in a SINGLE atomic
    # write so it never interleaves with hamsh's idle heartbeat mid-line.
    nsmark: Array[16, uint8]
    if consfd >= 0:
        mlen: uint64 = _grid_find_root(&nsmark[0])
        if mlen > 0:
            ml: Array[48, uint8]
            pfx: Ptr[uint8] = cast[Ptr[uint8]]("[hamterm] NS_PROBE: ")
            mp: uint64 = 0
            while pfx[mp] != 0:
                ml[mp] = pfx[mp]
                mp = mp + 1
            k2: uint64 = 0
            while k2 < mlen:
                ml[mp] = nsmark[k2]
                mp = mp + 1
                k2 = k2 + 1
            ml[mp] = 10
            mp = mp + 1
            sys_write(consfd, &ml[0], mp)

    # If we somehow have no /keys handle, fall back to a slow poll so the
    # terminal still renders shell output rather than wedging.
    if kfd < 0:
        while True:
            prev_hash = _pump_shell_bounded(cast[Ptr[char]](&scenep[0]),
                                            cast[Ptr[char]](&ctlp[0]),
                                            prev_hash, 8)
            s2: uint64 = sys_get_jiffies()
            while sys_get_jiffies() - s2 < 2:
                sys_yield()
        return 0

    # READINESS-MULTIPLEXING loop (KEYSTONE BUG #1 FIX).
    #
    # The OLD loop did a BLOCKING sys_read on /keys. While parked there the
    # shell's stdout pipe (sh_out_fd) was NOT serviced, so a command's output
    # and the next prompt did not render until the user pressed a key (the only
    # thing that woke the read). We must wait on BOTH /keys AND sh_out_fd.
    #
    # There is no epoll syscall exposed to userland in this tree (no
    # epoll_create/ctl/wait, and /keys is not poll-registerable), so we use the
    # documented FALLBACK: a NON-BLOCKING keys read + an UNCONDITIONAL
    # _drain_shell() every iteration, sleeping cooperatively (sys_nanosleep,
    # which parks off the runqueue — no busy-spin) ONLY when neither source had
    # data. Result: shell output renders within ~one tick (10 ms floor) with no
    # follow-up keystroke (#1), and a key's echo commits in the same frame
    # (#2 — drain keys -> forward -> drain echo -> commit, all in one wake).
    #
    # Idle CPU cost is bounded: when both /keys and the shell are quiet we
    # hlt-sleep one jiffy per loop, identical to a parked blocking read.
    TERM_IDLE_SLEEP_NS: int64 = 10000000      # 10 ms (1 jiffy at HZ=100)
    while True:
        room: uint64 = 512 - kev_carry
        if room == 0:
            # Pathologically large carry (malformed line with no newline) —
            # drop it to avoid a wedge; never happens for well-formed
            # "<t> <code>\n" lines (<=~12 bytes).
            kev_carry = 0
            room = 512
        # NON-BLOCKING keys read: 0 = no key this tick (we still drain the
        # shell below), >0 = bytes, <0 = error/EOF (treated as no-data).
        kn: int64 = sys_read_nb(kfd, &kev_buf[kev_carry], room)
        # BUG 1b: a resize arrives on /event — poll it and re-layout. Force a
        # scene re-emit on a size change (the grid hash alone wouldn't catch the
        # fill-size / column-count change, only the row content).
        if _poll_events(efd) != 0:
            _emit_scene(cast[Ptr[char]](&scenep[0]))
            cfdr: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
            if cfdr >= 0:
                _writeall(cfdr, cast[Ptr[uint8]]("commit\n"))
                sys_close(cfdr)
            prev_hash = _grid_hash()
        keys_forwarded = 0
        if kn > 0:
            # BUG 3 FIX: parse only COMPLETE "<t> <code>\n" lines; CARRY any
            # partial trailing line across reads so a keystroke split at a
            # buffer boundary or a fast burst is never lost.
            total: uint64 = kev_carry + cast[uint64](kn)
            done: uint64 = _drain_keys_chunk(total)
            leftover: uint64 = total - done
            m: uint64 = 0
            while m < leftover:
                kev_buf[m] = kev_buf[done + m]
                m = m + 1
            kev_carry = leftover
        # ALWAYS drain the shell. This is the heart of the fix: shell output
        # (the new prompt, command results) is serviced every iteration, not
        # only on a keystroke. If we just forwarded a key, await_echo waits
        # (bounded) for the echo so the typed char commits in THIS frame.
        awaite: int32 = 0
        if keys_forwarded > 0:
            awaite = 1
        before: uint64 = prev_hash
        prev_hash = _pump_shell_ex(cast[Ptr[char]](&scenep[0]),
                                   cast[Ptr[char]](&ctlp[0]),
                                   prev_hash, 32, awaite)
        # Sleep ONLY when this iteration was fully idle (no key, no shell
        # output, no commit). Otherwise loop immediately so a chatty command
        # streams at full speed. Cooperative hlt-sleep — no busy-spin.
        if kn <= 0 and prev_hash == before:
            _short_sleep_ns(TERM_IDLE_SLEEP_NS)
    return 0

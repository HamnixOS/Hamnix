# user/hamtermscene.ad
#
# Scene-file DE terminal (docs/de_scene_file_arch.md §16 step 8).
#
# A minimal terminal drawn entirely as a scene display list. Its text
# content is rendered with the `glyphs` primitive (monospace cell text, the
# terminal tier per §4). It is a decorated window (decorate 1) so the
# compositor draws an SSD titlebar and the window is movable by dragging it.
#
# It also proves INPUT ROUTING (§11): it reads its own
# /dev/wsys/<wid>/event file and appends a line for every routed pointer /
# key / focus event it receives in WINDOW-LOCAL coordinates, then re-emits
# its scene. A click delivered via /dev/mouse therefore shows up as a new
# "m <x> <y> ..." line inside the terminal — visible proof the compositor
# routed the event to the right window in local space.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    # Write "newwindow", then re-open ctl for READ to fetch the wid (a
    # write-only fd is not reliably readable).
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


TERM_W: int64 = 360
TERM_H: int64 = 200
TERM_ROWS: uint64 = 8
TERM_COLS: uint64 = 42

# A small ring of text rows the terminal renders as glyphs.
term_rows: Array[512, uint8]              # 8 rows * 64 cols
term_row_len: Array[8, uint64]


def _term_clear():
    r: uint64 = 0
    while r < TERM_ROWS:
        term_row_len[r] = 0
        r = r + 1


def _term_set_row(r: uint64, s: Ptr[uint8]):
    n: uint64 = 0
    base: uint64 = r * 64
    while s[n] != 0 and n < TERM_COLS:
        term_rows[base + n] = s[n]
        n = n + 1
    term_row_len[r] = n


def _term_push_line(s: Ptr[uint8], slen: uint64):
    # Scroll up by one and append s as the bottom row.
    r: uint64 = 0
    while r + 1 < TERM_ROWS:
        sb: uint64 = (r + 1) * 64
        db: uint64 = r * 64
        ln: uint64 = term_row_len[r + 1]
        k: uint64 = 0
        while k < ln:
            term_rows[db + k] = term_rows[sb + k]
            k = k + 1
        term_row_len[r] = ln
        r = r + 1
    last: uint64 = (TERM_ROWS - 1) * 64
    n: uint64 = 0
    while n < slen and n < TERM_COLS:
        term_rows[last + n] = s[n]
        n = n + 1
    term_row_len[TERM_ROWS - 1] = n


def _emit_scene(scenepath: Ptr[char]):
    sfd: int32 = sys_open_write(scenepath)
    if sfd < 0:
        return
    scene: Array[2048, uint8]
    sp: uint64 = 0
    # background dark panel
    head: Ptr[uint8] = cast[Ptr[uint8]]("# scene v1 term\nfill 0 0 360 200 #101418\n")
    a: uint64 = 0
    while head[a] != 0:
        scene[sp] = head[a]
        sp = sp + 1
        a = a + 1
    # each text row as a glyphs line at y = 8 + r*18
    r: uint64 = 0
    while r < TERM_ROWS:
        ln: uint64 = term_row_len[r]
        if ln > 0:
            g: Ptr[uint8] = cast[Ptr[uint8]]("glyphs 6 ")
            b: uint64 = 0
            while g[b] != 0:
                scene[sp] = g[b]
                sp = sp + 1
                b = b + 1
            yy: uint64 = 8 + r * 18
            sp = sp + _u64_to_dec(yy, &scene[sp])
            scene[sp] = 32
            scene[sp + 1] = 34                     # opening quote
            sp = sp + 2
            base: uint64 = r * 64
            k: uint64 = 0
            while k < ln:
                ch: uint8 = term_rows[base + k]
                if ch == 34 or ch == 10:           # sanitize quote/newline
                    ch = 32
                scene[sp] = ch
                sp = sp + 1
                k = k + 1
            tail: Ptr[uint8] = cast[Ptr[uint8]]("\" #c0f0c0\n")
            c: uint64 = 0
            while tail[c] != 0:
                scene[sp] = tail[c]
                sp = sp + 1
                c = c + 1
        r = r + 1
    sys_write(sfd, &scene[0], sp)
    sys_close(sfd)


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[term] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    scenep: Array[64, uint8]
    evp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&scenep[0], wid, cast[Ptr[uint8]]("/scene"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    # geometry: a 360x200 box, decorated, mid-screen.
    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 200 120 360 200\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 5\n"))
        sys_close(cfd3)

    _term_clear()
    _term_set_row(0, cast[Ptr[uint8]]("Hamnix scene terminal"))
    _term_set_row(1, cast[Ptr[uint8]]("$ click me to route input"))
    _emit_scene(cast[Ptr[char]](&scenep[0]))
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("commit\n"))
        sys_close(cfd4)

    _writeall(1, cast[Ptr[uint8]]("[term] scene window ready\n"))

    # Event loop: poll the event file, append each routed event line to the
    # terminal display, re-emit + commit. Proves window-local input routing.
    evbuf: Array[256, uint8]
    while True:
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        got: int32 = 0
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                # split on '\n' and push each line
                ls: uint64 = 0
                i: uint64 = 0
                while i < cast[uint64](r):
                    if evbuf[i] == 10:
                        if i > ls:
                            _term_push_line(&evbuf[ls], i - ls)
                            got = 1
                        ls = i + 1
                    i = i + 1
                if ls < cast[uint64](r):
                    _term_push_line(&evbuf[ls], cast[uint64](r) - ls)
                    got = 1
                # echo to serial so a gate can see routing worked
                _writeall(1, cast[Ptr[uint8]]("[term] event: "))
                sys_write(1, &evbuf[0], cast[uint64](r))
                _writeall(1, cast[Ptr[uint8]]("\n"))
        if got != 0:
            _emit_scene(cast[Ptr[char]](&scenep[0]))
            cfd5: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
            if cfd5 >= 0:
                _writeall(cfd5, cast[Ptr[uint8]]("commit\n"))
                sys_close(cfd5)
        # poll interval ~100ms
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 10:
            pass
    return 0

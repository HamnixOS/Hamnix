# user/lsmod.ad
#
# Stub `lsmod`. The M16.32 kernel-module loader (insmod equivalent)
# loads .ko blobs into slot-indexed memory but doesn't yet publish
# a /proc/modules listing for userland to scrape. Until that lands,
# print the Linux-shaped header plus a single hard-coded row for
# the M16.32 demo module so the column layout is exercised end-
# to-end.
#
# Real implementation: open("/proc/modules"), drain to stdout.
# That's a one-line swap once procfs exposes the module table.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "Module                  Size  Used by\n")
    write_str(1, "kmod_hello              0     0\n")
    return 0

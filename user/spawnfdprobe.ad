# user/spawnfdprobe.ad
#
# Task #28 fixture — proves the CLEAN-FD spawn contract (lib/p9.ad's
# p9_closefrom(3) in the exec-a-binary path).
#
# THE LEAK IT DEMONSTRATES
#
# spawn() rforks with RFFDG, which hands the child a PRIVATE COPY of the
# launcher's ENTIRE integer fd table. Before the fix, a spawned server
# therefore inherited every unrelated fd the launcher happened to have
# open (other servers' transports, the launcher's private files, pipe
# ends). This probe runs BOTH roles from one binary:
#
#   * PARENT (argv[1] absent): opens THREE extra descriptors (fd 3,4,5)
#     to stand in for the launcher's private channels, then spawn()s
#     itself in child mode and waits.
#   * CHILD  (argv[1] == "child"): probes fd 0..7 and prints, for each,
#     whether it is OPEN or CLOSED. The intended stdio (0/1/2) must be
#     OPEN; the launcher's private fds (3/4/5) must be CLOSED.
#
# GATE ASSERTIONS (scripts/test_spawn_fd_clean.sh):
#   CHILD FD 0/1/2 OPEN     — intended stdio still passes to the server
#   CHILD FD 3/4/5 CLOSED   — the launcher's unrelated fds did NOT leak
#
# Before the fix the child prints "CHILD FD 3 OPEN" etc. (the leak);
# after, "CHILD FD 3 CLOSED".

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_dup2(oldfd: int32, newfd: int32) -> int32
extern def sys_waitpid(pid: int32) -> int64

from lib.p9 import spawn

# SPAWN_STDIO_INHERIT (-1): child keeps the RFFDG-copied fd 0/1/2 (the
# console), so its markers reach the serial log. Matches lib/p9's sentinel.
SPAWN_STDIO_INHERIT: int32 = -1

# argv for the child spawn: [0]=path, [1]="child", [2]=NULL.
child_argv: Array[3, uint64]

# The extra descriptors the "launcher" holds open before spawning. A file
# that is guaranteed to exist in the cpio initramfs (see user/hello.ad,
# which reads it too). Each open() lands in the next free slot: 3, 4, 5.
probe_path: Array[16, uint8] = "/version"
child_word:  Array[8, uint8] = "child"


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_int(fd: int32, v: int32):
    # Render a small non-negative decimal (fd numbers 0..63).
    buf: Array[8, uint8]
    if v < 0:
        write_str(fd, "-")
        v = 0 - v
    i: int32 = 0
    if v == 0:
        buf[0] = 48                              # '0'
        i = 1
    else:
        tmp: Array[8, uint8]
        t: int32 = 0
        while v > 0:
            tmp[t] = cast[uint8](48 + (v % 10))
            v = v / 10
            t = t + 1
        while t > 0:
            t = t - 1
            buf[i] = tmp[t]
            i = i + 1
    sys_write(fd, &buf[0], cast[uint64](i))


def _cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        if a[i] != b[i]:
            return 0
        if a[i] == 0:
            return 1
        i = i + 1
    return 0


def fd_is_open(fd: int32) -> int32:
    # Side-effect-free liveness probe: dup2 the slot onto a high scratch
    # fd (40; NR_FDS is 64). Success => the source fd is open. vfs_dup2
    # returns EBADF (<0) for a closed source. Close the scratch after.
    rc: int32 = sys_dup2(fd, 40)
    if rc < 0:
        return 0
    sys_close(40)
    return 1


def run_child() -> int32:
    write_str(1, "CHILD probe start\n")
    fd: int32 = 0
    while fd <= 7:
        write_str(1, "CHILD FD ")
        write_int(1, fd)
        if fd_is_open(fd) != 0:
            write_str(1, " OPEN\n")
        else:
            write_str(1, " CLOSED\n")
        fd = fd + 1
    write_str(1, "CHILD PROBE DONE\n")
    return 0


def run_parent(argv0: Ptr[char]) -> int32:
    # Open three extra descriptors — the "launcher's private channels".
    f1: int32 = sys_open(cast[Ptr[char]](&probe_path[0]))
    f2: int32 = sys_open(cast[Ptr[char]](&probe_path[0]))
    f3: int32 = sys_open(cast[Ptr[char]](&probe_path[0]))
    write_str(1, "PARENT opened extra fds ")
    write_int(1, f1)
    write_str(1, " ")
    write_int(1, f2)
    write_str(1, " ")
    write_int(1, f3)
    write_str(1, "\n")
    if f1 < 0 or f2 < 0 or f3 < 0:
        write_str(1, "PARENT FAIL: could not open probe file\n")
        return 1

    # spawn ourselves in child mode. SPAWN_STDIO_INHERIT keeps the child's
    # 0/1/2 pointed at our console; every fd >= 3 must be dropped by the
    # clean-fd contract in lib/p9's spawn helper.
    child_argv[0] = cast[uint64](argv0)
    child_argv[1] = cast[uint64](&child_word[0])
    child_argv[2] = 0
    pid: int32 = spawn(argv0, &child_argv[0],
                       SPAWN_STDIO_INHERIT, SPAWN_STDIO_INHERIT,
                       cast[Ptr[uint64]](0))
    if pid < 0:
        write_str(1, "PARENT FAIL: spawn returned error\n")
        return 1
    sys_waitpid(pid)
    write_str(1, "PARENT done\n")
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc >= 2 and _cstr_eq(cast[Ptr[uint8]](argv[1]), &child_word[0]) != 0:
        return run_child()
    return run_parent(cast[Ptr[char]](argv[0]))

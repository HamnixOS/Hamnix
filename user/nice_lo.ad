# user/nice_lo.ad
#
# #151 / CFS-lite priority test fixture — the LOW-priority CPU hog.
#
# Mirror of user/nice_hi.ad but re-nices itself to +19 (minimum priority,
# lightest load weight). It runs the SAME fixed wall-clock counting loop
# and prints its iteration count. Spawned alongside nice_hi by
# user/nice_demo.ad; sharing one CPU it should complete FEWER iterations
# in the window because the weighted-fair scheduler gives it a smaller
# CPU share than its nice -20 sibling.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_nice(nice: int64, op: int64) -> int64
extern def sys_get_jiffies() -> uint64
extern def sys_exit(code: uint64)


WINDOW_JIFFIES: uint64 = 600

spin_accum: uint64 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


numbuf: Array[24, uint8]


def write_u64(fd: int32, v: uint64):
    tmp: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    if x == 0:
        tmp[0] = cast[uint8](48)
        n = 1
    while x > 0:
        d: uint64 = x % 10
        tmp[n] = cast[uint8](48 + d)
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while i < n:
        numbuf[i] = tmp[n - 1 - i]
        i = i + 1
    numbuf[n] = cast[uint8](10)
    sys_write(fd, &numbuf[0], n + 1)


def main() -> int32:
    nv: int64 = sys_nice(19, 0)
    write_str(1, "[nice] lo: re-niced to +19, running CPU window; nice+20=")
    write_u64(1, cast[uint64](nv + 20))

    start: uint64 = sys_get_jiffies()
    deadline: uint64 = start + WINDOW_JIFFIES
    iters: uint64 = 0
    while True:
        iters = iters + 1
        spin_accum = spin_accum + iters
        if (iters & 0xFFF) == 0:
            if sys_get_jiffies() >= deadline:
                break

    write_str(1, "[nice] lo iters=")
    write_u64(1, iters)
    sys_exit(0)
    return 0

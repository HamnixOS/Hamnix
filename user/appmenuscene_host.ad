# user/appmenuscene_host.ad — HOST driver + render harness for the MATE
# Applications menu (built for the x86_64-linux Adder target; runs on the dev
# host, no QEMU).
#
# Populates lib/appmenucore.ad with a FIXTURE app set spanning several
# freedesktop categories, marks a couple of RECENT launches, then renders the
# SAME model the native /bin/hamappmenu client ships:
#   * FULL menu (no filter)          -> shows the search box, a Recent section,
#                                       and apps grouped under category headers
#   * FILTERED menu (search "ca")    -> only matching apps under their headers
# to PPMs a human/agent can LOOK at, and dumps the scene display list + the
# laid-out row model + hit-tests so a gate can assert grouping / search /
# recent structurally.
#
# No sockets, no Plan 9: reads argv + writes files. TEST shim only.
#
# USAGE (built to build/host/appmenu_host):
#   appmenu_host FULL.ppm FILTERED.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.appmenucore import amc_reset, amc_add, amc_mark_launch, \
    amc_set_filter, amc_layout, amc_build_scene, \
    amc_row_count, amc_row_kind, amc_row_cat, amc_row_app, \
    amc_row_label, amc_row_prog, amc_hit, amc_cat_name, amc_content_h, \
    amc_box_w, amc_app_count, amc_recent_count, \
    amc_filter_push, amc_filter_backspace, amc_filter_ptr, amc_filter_len, \
    amc_set_open_cat, amc_open_cat, amc_child_layout, amc_child_count, \
    amc_child_app, amc_child_hit, amc_child_x, amc_child_y, \
    amc_child_w, amc_child_h, amc_app_name, amc_app_prog, \
    amc_focus_out_dismiss, amc_press_edge, \
    AMC_ROW_SEARCH, AMC_ROW_HEADER, AMC_ROW_APP, AMC_ROW_CATBTN, \
    AMC_HDR_RECENT, AMC_ROW_H, AMC_GRAPHICS


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


W: int32 = 460                           # wide enough for the right fly-out
H: int32 = 420
BX: int32 = 20
BY: int32 = 16


# Seed the fixture catalogue: apps across Accessories / Graphics / Internet /
# Office / Games / System / Settings, so grouping is visible.
def _seed_fixture():
    amc_reset()
    amc_add(cast[Ptr[uint8]]("Calculator"), cast[Ptr[uint8]]("/bin/calculator"),
            cast[Ptr[uint8]]("Utility;"), 67)               # 'C'
    amc_add(cast[Ptr[uint8]]("Text Editor"), cast[Ptr[uint8]]("/bin/hamedit"),
            cast[Ptr[uint8]]("Utility;TextEditor;"), 69)    # 'E'
    amc_add(cast[Ptr[uint8]]("Files"), cast[Ptr[uint8]]("/bin/hamfm"),
            cast[Ptr[uint8]]("Utility;System;FileManager;"), 70)  # 'F'
    amc_add(cast[Ptr[uint8]]("Image Viewer"), cast[Ptr[uint8]]("/bin/hamview"),
            cast[Ptr[uint8]]("Graphics;Viewer;"), 86)       # 'V'
    amc_add(cast[Ptr[uint8]]("Camera"), cast[Ptr[uint8]]("/bin/hamcam"),
            cast[Ptr[uint8]]("Graphics;Photography;"), 67)  # 'C'
    amc_add(cast[Ptr[uint8]]("Web Browser"), cast[Ptr[uint8]]("/bin/hambrowse"),
            cast[Ptr[uint8]]("Network;WebBrowser;"), 87)    # 'W'
    amc_add(cast[Ptr[uint8]]("Word Processor"), cast[Ptr[uint8]]("/bin/hamword"),
            cast[Ptr[uint8]]("Office;WordProcessor;"), 87)  # 'W'
    amc_add(cast[Ptr[uint8]]("2048"), cast[Ptr[uint8]]("/bin/ham2048"),
            cast[Ptr[uint8]]("Game;"), 50)                  # '2'
    amc_add(cast[Ptr[uint8]]("System Monitor"), cast[Ptr[uint8]]("/bin/hammon"),
            cast[Ptr[uint8]]("System;Monitor;"), 77)        # 'M'
    amc_add(cast[Ptr[uint8]]("Control Center"), cast[Ptr[uint8]]("/bin/hamctl"),
            cast[Ptr[uint8]]("Settings;"), 67)              # 'C'
    # Recent: launched the browser, then the calculator (calculator newest).
    amc_mark_launch(cast[Ptr[uint8]]("/bin/hambrowse"))
    amc_mark_launch(cast[Ptr[uint8]]("/bin/calculator"))


# Dump the laid-out row model as MODEL lines a gate can grep.
def _dump_model(tag: Ptr[uint8]):
    _o_str(cast[Ptr[uint8]]("MODEL "))
    _o_str(tag)
    _o_str(cast[Ptr[uint8]](" rows="))
    _o_dec(cast[int64](amc_row_count()))
    _o_str(cast[Ptr[uint8]](" apps="))
    _o_dec(cast[int64](amc_app_count()))
    _o_str(cast[Ptr[uint8]](" recent="))
    _o_dec(cast[int64](amc_recent_count()))
    _o_ch(10)
    _o_flush()
    i: uint64 = 0
    while i < amc_row_count():
        k: int32 = amc_row_kind(i)
        _o_str(cast[Ptr[uint8]]("ROW "))
        _o_str(tag)
        _o_ch(32)
        _o_dec(cast[int64](i))
        _o_ch(32)
        if k == AMC_ROW_SEARCH:
            _o_str(cast[Ptr[uint8]]("SEARCH"))
        elif k == AMC_ROW_CATBTN:
            _o_str(cast[Ptr[uint8]]("CATBTN "))
            _o_str(amc_cat_name(amc_row_cat(i)))
        elif k == AMC_ROW_HEADER:
            if amc_row_cat(i) == AMC_HDR_RECENT:
                _o_str(cast[Ptr[uint8]]("HEADER-RECENT"))
            else:
                _o_str(cast[Ptr[uint8]]("HEADER"))
            _o_ch(32)
            _o_str(amc_cat_name(amc_row_cat(i)))
        else:
            _o_str(cast[Ptr[uint8]]("APP "))
            _o_str(amc_row_label(i))
            _o_str(cast[Ptr[uint8]]("  ["))
            _o_str(amc_cat_name(amc_row_cat(i)))
            _o_ch(93)
        _o_ch(10)
        _o_flush()
        i = i + 1


def _render(tag: Ptr[uint8], hover: int32, path: Ptr[char]):
    amc_layout()
    amc_build_scene(BX, BY, hover, W, H)
    hamui_host_begin(W, H)
    prims: int32 = hamui_host_rasterize()
    _write_ppm(path)
    _o_str(cast[Ptr[uint8]]("MENU "))
    _o_str(tag)
    _o_str(cast[Ptr[uint8]](" prims="))
    _o_dec(cast[int64](prims))
    _o_str(cast[Ptr[uint8]](" width="))
    _o_dec(cast[int64](amc_box_w()))
    _o_str(cast[Ptr[uint8]](" height="))
    _o_dec(cast[int64](amc_content_h()))
    _o_ch(10)
    _o_flush()
    _dump_model(tag)
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN "))
    _o_str(tag)
    _o_ch(10)
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]](
            "usage: appmenu_host FULL.ppm FILTERED.ppm FLYOUT.ppm\n"))
        _o_flush()
        return 2

    # --- FULL menu (no filter). Recent stays INLINE at top; each category is
    #     a CATBTN parent button (no inline apps). Hover the first CATBTN so
    #     the PNG shows a highlighted parent. ---
    _seed_fixture()
    amc_set_filter(cast[Ptr[uint8]](""))
    amc_set_open_cat(-1)
    amc_layout()
    # Rows: 0 SEARCH, 1 HEADER-RECENT, 2..3 Recent APPs, 4 first CATBTN.
    _render(cast[Ptr[uint8]]("FULL"), 4, cast[Ptr[char]](argv[1]))

    # --- FILTERED menu: typing "ca" filters to Calculator + Camera (flat,
    #     grouped-under-header fallback; categories are NOT buttons mid-search). ---
    _seed_fixture()
    amc_set_open_cat(-1)
    amc_set_filter(cast[Ptr[uint8]]("ca"))
    _render(cast[Ptr[uint8]]("FILTERED"), -1, cast[Ptr[char]](argv[2]))

    # --- FLY-OUT: hover the "Graphics" category parent -> its child fly-out
    #     box renders that category's apps aligned to the parent row. ---
    _seed_fixture()
    amc_set_filter(cast[Ptr[uint8]](""))
    amc_layout()
    amc_set_open_cat(AMC_GRAPHICS)
    # Highlight the FIRST child fly-out row: hover encodes as
    # (row_count + child_index); child 0 -> row_count + 0.
    _render(cast[Ptr[uint8]]("FLYOUT"),
            cast[int32](amc_row_count()), cast[Ptr[char]](argv[3]))
    # Dump the child model + a fly-out hit-test so the gate can assert the box
    # renders that category's apps and a point in it maps to the right app.
    amc_child_layout(BX, BY, W, H)
    _o_str(cast[Ptr[uint8]]("FLYOUT cat="))
    _o_dec(cast[int64](amc_open_cat()))
    _o_str(cast[Ptr[uint8]](" apps="))
    _o_dec(cast[int64](amc_child_count()))
    _o_str(cast[Ptr[uint8]](" box="))
    _o_dec(cast[int64](amc_child_x()))
    _o_ch(44)
    _o_dec(cast[int64](amc_child_y()))
    _o_ch(44)
    _o_dec(cast[int64](amc_child_w()))
    _o_ch(44)
    _o_dec(cast[int64](amc_child_h()))
    _o_ch(10)
    _o_flush()
    ci: uint64 = 0
    while ci < amc_child_count():
        ai: int32 = amc_child_app(ci)
        _o_str(cast[Ptr[uint8]]("CHILD "))
        _o_dec(cast[int64](ci))
        _o_str(cast[Ptr[uint8]](" APP "))
        _o_str(amc_app_name(cast[uint64](ai)))
        _o_ch(10)
        _o_flush()
        ci = ci + 1
    # Hit-test the centre of the SECOND fly-out row (child index 1 == Camera).
    hx: int32 = amc_child_x() + 20
    hy: int32 = amc_child_y() + AMC_ROW_H + AMC_ROW_H / 2
    hit_app: int64 = amc_child_hit(hx, hy)
    _o_str(cast[Ptr[uint8]]("CHILDHIT row1 app="))
    _o_dec(hit_app)
    if hit_app >= 0:
        _o_str(cast[Ptr[uint8]](" name="))
        _o_str(amc_app_name(cast[uint64](hit_app)))
    _o_ch(10)
    # A point OUTSIDE the fly-out box misses.
    hmiss: int64 = amc_child_hit(amc_child_x() - 30, amc_child_y() + 4)
    _o_str(cast[Ptr[uint8]]("CHILDHIT miss "))
    _o_dec(hmiss)
    _o_ch(10)
    _o_flush()

    # --- Hit-test assertions on the FULL layout. ---
    _seed_fixture()
    amc_set_filter(cast[Ptr[uint8]](""))
    amc_layout()
    # Row 0 (search) centre y = BY + 10.
    h0: int64 = amc_hit(BX, BY, BX + 40, BY + 10)
    _o_str(cast[Ptr[uint8]]("HIT search "))
    _o_dec(h0)
    _o_ch(10)
    # A point left of the box misses.
    hm: int64 = amc_hit(BX, BY, BX - 5, BY + 10)
    _o_str(cast[Ptr[uint8]]("HIT miss "))
    _o_dec(hm)
    _o_ch(10)
    # Row 2 (first app) — report its kind so the gate confirms it's an APP.
    _o_str(cast[Ptr[uint8]]("KIND row2 "))
    _o_dec(cast[int64](amc_row_kind(2)))
    _o_ch(10)

    # --- LIVE TYPING: exercise the EXACT on-device edit path (amc_filter_push
    #     / amc_filter_backspace) the keyboard event loop drives, proving a
    #     typed keystroke updates the filter buffer AND narrows the layout. ---
    _seed_fixture()
    amc_set_filter(cast[Ptr[uint8]](""))
    amc_layout()
    amc_filter_push(67)                              # 'C' -> lowercased 'c'
    amc_filter_push(97)                              # 'a'
    amc_filter_push(122)                             # 'z' (no match)
    amc_filter_backspace()                           # delete 'z' -> "ca"
    amc_layout()
    _o_str(cast[Ptr[uint8]]("TYPE filter=\""))
    _o_str(amc_filter_ptr())
    _o_str(cast[Ptr[uint8]]("\" len="))
    _o_dec(cast[int64](amc_filter_len()))
    _o_str(cast[Ptr[uint8]](" rows="))
    _o_dec(cast[int64](amc_row_count()))
    _o_ch(10)
    _o_flush()

    # --- FRAME-1 DISMISS GUARD (#287/#313/#330 one-frame-flash regression) -----
    # Drive the detached client's pure dismiss-decision helpers exactly as the
    # /event drain does, proving the just-opened menu does NOT self-dismiss on
    # frame 1 while still confirming a genuine click-away / focus-out DOES.
    #
    # Focus: fc is the char after "f " ('i'==105 "in", 'o'==111 "out").
    # (a) spurious "f out" BEFORE any "f in" (seen_in=0) must NOT dismiss.
    _o_str(cast[Ptr[uint8]]("DISMISS focus_out_before_in "))
    _o_dec(cast[int64](amc_focus_out_dismiss(111, 0)))
    _o_ch(10)
    # (c) a real "f out" AFTER the menu was focused (seen_in=1) MUST dismiss.
    _o_str(cast[Ptr[uint8]]("DISMISS focus_out_after_in "))
    _o_dec(cast[int64](amc_focus_out_dismiss(111, 1)))
    _o_ch(10)
    # "f in" (fc=='i') never dismisses regardless of latch (#313).
    _o_str(cast[Ptr[uint8]]("DISMISS focus_in "))
    _o_dec(cast[int64](amc_focus_out_dismiss(105, 1)))
    _o_ch(10)
    # Press edge: (btn, prev_btn, primed).
    # (b) FIRST "m" event with the button HELD (btn&1==1) is unprimed -> no edge.
    _o_str(cast[Ptr[uint8]]("DISMISS press_first_held "))
    _o_dec(cast[int64](amc_press_edge(1, 0, 0)))
    _o_ch(10)
    # still held on the next (primed) sample -> no new edge.
    _o_str(cast[Ptr[uint8]]("DISMISS press_still_held "))
    _o_dec(cast[int64](amc_press_edge(1, 1, 1)))
    _o_ch(10)
    # (d) a real NEW press AFTER a release (prev bit0 clear, primed) -> edge.
    _o_str(cast[Ptr[uint8]]("DISMISS press_after_release "))
    _o_dec(cast[int64](amc_press_edge(1, 0, 1)))
    _o_ch(10)
    _o_flush()
    return 0

# user/js_host.ad — HOST driver for the native JavaScript engine (lib/jsengine.ad).
#
# Built for the `x86_64-linux` Adder target: a freestanding ELF that runs
# DIRECTLY on the developer's host Linux kernel — no QEMU, no installer image.
# It reads a local .js file, evaluates it through the SAME engine the native
# `js` tool and the browser use, and prints the accumulated console.log output
# to stdout. This is the millisecond iteration loop for the JS engine
# (scripts/test_jsengine_host.sh).
#
# It is a TEST/dev shim only: no sockets, no Plan 9 — it reads argv + a file
# and writes stdout. `user/linux-runtime.S` supplies _start + the raw Linux
# syscall wrappers (O_RDONLY = 0).
#
# USAGE (built to build/host/js_host):
#   js_host FILE.js

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.jsengine import js_init, js_eval, js_out_len, js_error, js_error_msg
from lib.jsengine import js_run_module, js_set_module_resolver, js_set_fetch_transport


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


FILE_CAP: uint64 = 262144
file_buf: Array[262144, uint8]
file_len: uint64 = 0


def _read_file(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 0, 0)                  # O_RDONLY
    if fd < 0:
        return -1
    file_len = 0
    while file_len < FILE_CAP - 1:
        n: int64 = sys_read(fd, &file_buf[file_len], FILE_CAP - 1 - file_len)
        if n <= 0:
            break
        file_len = file_len + cast[uint64](n)
    sys_close(fd)
    return 0


# ---- ES-module resolver (host: read the module file from disk) --------------
# Modules are resolved relative to the ENTRY file's directory. A specifier like
# "./util.js" or "sub/x.js" is joined onto that base dir. Source is read into a
# dedicated buffer that the engine copies out of immediately, so a single buffer
# serves every module in the graph.
entry_dir: Array[4096, uint8]
entry_dir_len: int32 = 0
mod_path: Array[4096, uint8]
mod_read_buf: Array[262144, uint8]
mod_read_len: int32 = 0


def _basename(path: Ptr[char]) -> Ptr[uint8]:
    n: int32 = 0
    last: int32 = -1
    while path[n] != 0:
        if path[n] == 47:
            last = n
        n = n + 1
    return cast[Ptr[uint8]](&path[last + 1])


def _set_entry_dir(path: Ptr[char]):
    # entry_dir = dirname(path) (everything up to and including the last '/'),
    # or empty if the path has no slash (current directory).
    n: int32 = 0
    last: int32 = -1
    while path[n] != 0:
        if path[n] == 47:                # '/'
            last = n
        n = n + 1
    entry_dir_len = 0
    i: int32 = 0
    while i <= last:
        entry_dir[entry_dir_len] = cast[uint8](path[i])
        entry_dir_len = entry_dir_len + 1
        i = i + 1


def _build_mod_path(spec: Ptr[uint8], spec_len: int32):
    # mod_path = entry_dir + spec, stripping a leading "./" from the specifier.
    n: int32 = 0
    i: int32 = 0
    while i < entry_dir_len:
        mod_path[n] = entry_dir[i]
        n = n + 1
        i = i + 1
    j: int32 = 0
    if spec_len >= 2 and spec[0] == 46 and spec[1] == 47:   # leading "./"
        j = 2
    while j < spec_len:
        mod_path[n] = spec[j]
        n = n + 1
        j = j + 1
    mod_path[n] = 0


def _module_resolver(spec: Ptr[uint8], spec_len: int32, out_len: Ptr[int32]) -> Ptr[uint8]:
    _build_mod_path(spec, spec_len)
    fd: int32 = sys_open(cast[Ptr[char]](&mod_path[0]), 0, 0)
    if fd < 0:
        out_len[0] = 0
        return cast[Ptr[uint8]](0)
    mod_read_len = 0
    while mod_read_len < 262143:
        r: int64 = sys_read(fd, &mod_read_buf[mod_read_len], cast[uint64](262143 - mod_read_len))
        if r <= 0:
            break
        mod_read_len = mod_read_len + cast[int32](r)
    sys_close(fd)
    out_len[0] = mod_read_len
    return &mod_read_buf[0]


# ---- --fetch-net self-test transport ---------------------------------------
# A CANNED HTTP transport that lets the QEMU-free host gate exercise the ENGINE's
# real-network code path (do_fetch's transport branch + make_response_net's raw
# status/header/body parse + the full Headers get/has/entries) WITHOUT a socket.
# It fabricates a raw HTTP/1.x response into a buffer and hands the engine the
# bytes exactly as the on-device kernel http9 bridge (user/http9.ad's http_get)
# would. On-device the SAME parse runs over real wire bytes; only the transport
# body differs. `/fail` in the URL models a DNS/connect failure (NULL -> reject);
# `/404` yields a 404 (fulfills with ok=false); POST echoes the request body.
canned_buf: Array[4096, uint8]


def _ap_cstr(buf: Ptr[uint8], at: int32, s: Ptr[uint8]) -> int32:
    i: int32 = 0
    while s[i] != 0:
        buf[at] = s[i]
        at = at + 1
        i = i + 1
    return at


def _ap_bytes(buf: Ptr[uint8], at: int32, p: Ptr[uint8], n: int32) -> int32:
    i: int32 = 0
    while i < n:
        buf[at] = p[i]
        at = at + 1
        i = i + 1
    return at


def _url_contains(url: Ptr[uint8], url_len: int32, needle: Ptr[uint8]) -> int32:
    nn: int32 = 0
    while needle[nn] != 0:
        nn = nn + 1
    i: int32 = 0
    while i + nn <= url_len:
        j: int32 = 0
        while j < nn and url[i + j] == needle[j]:
            j = j + 1
        if j == nn:
            return 1
        i = i + 1
    return 0


def _canned_transport(url: Ptr[uint8], url_len: int32,
                      method: Ptr[uint8], method_len: int32,
                      body: Ptr[uint8], body_len: int32,
                      out_status: Ptr[int64], out_len: Ptr[int32]) -> Ptr[uint8]:
    if _url_contains(url, url_len, cast[Ptr[uint8]]("/fail")) != 0:
        out_len[0] = 0
        return cast[Ptr[uint8]](0)
    is_404: int32 = _url_contains(url, url_len, cast[Ptr[uint8]]("/404"))
    is_post: int32 = 0
    if method_len == 4 and method[0] == 80 and method[1] == 79 and method[2] == 83 and method[3] == 84:
        is_post = 1
    n: int32 = 0
    if is_404 != 0:
        n = _ap_cstr(&canned_buf[0], n, cast[Ptr[uint8]]("HTTP/1.1 404 Not Found\r\n"))
        out_status[0] = 404
    else:
        n = _ap_cstr(&canned_buf[0], n, cast[Ptr[uint8]]("HTTP/1.1 200 OK\r\n"))
        out_status[0] = 200
    n = _ap_cstr(&canned_buf[0], n, cast[Ptr[uint8]]("Content-Type: text/plain\r\n"))
    n = _ap_cstr(&canned_buf[0], n, cast[Ptr[uint8]]("X-Test: hamnix\r\n"))
    n = _ap_cstr(&canned_buf[0], n, cast[Ptr[uint8]]("\r\n"))
    if is_post != 0:
        n = _ap_cstr(&canned_buf[0], n, cast[Ptr[uint8]]("posted:"))
        n = _ap_bytes(&canned_buf[0], n, body, body_len)
    else:
        n = _ap_cstr(&canned_buf[0], n, cast[Ptr[uint8]]("hello-from-transport"))
    out_len[0] = n
    return &canned_buf[0]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _writeall(2, cast[Ptr[uint8]]("usage: js_host [--module] FILE.js\n"))
        return 2
    as_module: int32 = 0
    fetch_net: int32 = 0
    argi: int32 = 1
    a0: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if a0[0] == 45 and a0[1] == 45:      # a "--flag"
        # distinguish --fetch-net (register the canned net transport) from
        # --module (ES-module entry). Anything else falls through as --module.
        if a0[2] == 102:                 # 'f' -> --fetch-net
            fetch_net = 1
        else:
            as_module = 1
        argi = 2
    if argc < argi + 1:
        _writeall(2, cast[Ptr[uint8]]("usage: js_host [--module|--fetch-net] FILE.js\n"))
        return 2
    path: Ptr[char] = cast[Ptr[char]](argv[argi])
    if _read_file(path) != 0:
        _writeall(2, cast[Ptr[uint8]]("js_host: cannot open file\n"))
        return 1
    js_init()
    if fetch_net != 0:
        js_set_fetch_transport(cast[Fn[Ptr[uint8], int32, Ptr[uint8], int32, Ptr[uint8], int32, Ptr[int64], Ptr[int32], Ptr[uint8]]](cast[uint64](_canned_transport)))
    out: Ptr[uint8]
    if as_module != 0:
        _set_entry_dir(path)
        js_set_module_resolver(cast[Fn[Ptr[uint8], int32, Ptr[int32], Ptr[uint8]]](cast[uint64](_module_resolver)))
        # The entry's canonical specifier is its basename, so a relative import
        # that resolves back to the entry file deduplicates against it.
        ename: Ptr[uint8] = _basename(path)
        out = js_run_module(&file_buf[0], file_len, ename, _slen(ename))
    else:
        out = js_eval(&file_buf[0], file_len)
    sys_write(1, out, js_out_len())
    if js_error() != 0:
        return 1
    return 0

# user/hostname.ad
#
# Hamnix doesn't have utsname yet, so the hostname lives at
# /etc/hostname (or doesn't, in which case we fall back to a
# baked-in default). Reading from disk lets a future initramfs
# patch the value without rebuilding userland.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def main() -> int32:
    fd: int32 = sys_open("/etc/hostname")
    if fd < 0:
        sys_write(1, "hamnix\n", 7)
        return 0
    buf: Array[128, uint8]
    n: int64 = sys_read(fd, &buf[0], 128)
    sys_close(fd)
    if n <= 0:
        sys_write(1, "hamnix\n", 7)
        return 0
    # Trim trailing newlines so we don't double-emit them after the
    # synthetic one below; /etc/hostname conventionally ends with '\n'.
    sz: uint64 = cast[uint64](n)
    while sz > 0 and buf[sz - 1] == 10:
        sz = sz - 1
    if sz > 0:
        sys_write(1, &buf[0], sz)
    sys_write(1, "\n", 1)
    return 0

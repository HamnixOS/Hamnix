# user/hamsdl_image_host.ad — HOST render+drive harness for the hamSDL/hamGame
# IMAGE LOADER (the pygame.image.load gap): load a BMP sprite FILE off disk into
# a Surface, blit it onto a display Surface at a known position, rasterize the
# frame to a PPM a human/agent can LOOK at, and dump sampled pixels so
# scripts/test_hamsdl_image_host.sh can ASSERT the whole file -> Surface -> blit
# -> PNG path is byte-correct WITHOUT eyeballing.
#
# It proves the three things a decoder has to get right:
#   1. CHANNEL ORDER — BMP stores B,G,R; a swap would turn our blue backdrop red.
#   2. ROW ORDER     — BMP is bottom-up; a flip would put the bottom row on top.
#   3. ALPHA         — a 32-bit BMP carries per-pixel alpha; a semi-transparent
#                      sprite must SOURCE-OVER blend against the background.
#
# USAGE (built to build/host/hamsdl_image_host):
#   hamsdl_image_host FIXTURE24.bmp FIXTURE32.bmp OUT.ppm

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.hamgame import game_reset, game_display_new, game_surface_fill, \
    game_surface_get_pixel, game_surface_w, game_surface_h, \
    game_surface_blit, game_flip_scene, game_rgb, game_load_bmp
from lib.hamgame_host import game_host_present, game_host_write_ppm, \
    game_host_pixel, game_host_load_image


DW: int32 = 64
DH: int32 = 64
SX24: int32 = 8                          # where the 24-bit sprite is blitted
SY24: int32 = 8
SX32: int32 = 32                         # where the 32-bit sprite is blitted
SY32: int32 = 8


# ---- stdout helpers (mirrors user/hamgamedemo_host.ad) -------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hex(v: uint32, digits: int32):
    _o_ch(35)                                            # '#'
    i: int32 = digits - 1
    while i >= 0:
        nyb: uint32 = (v >> cast[uint32](i * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i - 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# Dump a surface pixel as label + 0xRRGGBBAA (game_surface_get_pixel layout).
def _o_surfpix(label: Ptr[uint8], s: int32, x: int32, y: int32):
    _o_str(label)
    _o_hex(game_surface_get_pixel(s, x, y), 8)
    _o_ch(10)


# Dump a rasterized framebuffer pixel as label + 0xRRGGBB.
def _o_fbpix(label: Ptr[uint8], x: int32, y: int32):
    _o_str(label)
    _o_hex(game_host_pixel(x, y), 6)
    _o_ch(10)


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]](
            "usage: hamsdl_image_host FIX24.bmp FIX32.bmp OUT.ppm\n"))
        _o_flush()
        return 2

    game_reset()

    # ---- 1. Load the 24-bit BMP sprite FILE into a Surface ---------------
    s24: int32 = game_host_load_image(cast[Ptr[char]](argv[1]))
    _o_kv(cast[Ptr[uint8]]("S24"), cast[int64](s24))
    if s24 < 0:
        _o_flush()
        return 1
    _o_kv(cast[Ptr[uint8]]("S24W"), cast[int64](game_surface_w(s24)))
    _o_kv(cast[Ptr[uint8]]("S24H"), cast[int64](game_surface_h(s24)))
    # Decode correctness, straight from the loaded Surface (no raster yet):
    #   fixture (x,y) = R:16+x*24  G:16+y*24  B:200  A:255.
    # Sampling three corners nails channel order AND bottom-up row order.
    _o_surfpix(cast[Ptr[uint8]]("S24_TL "), s24, 0, 0)   # expect 1010c8ff
    _o_surfpix(cast[Ptr[uint8]]("S24_TR "), s24, 7, 0)   # expect b810c8ff
    _o_surfpix(cast[Ptr[uint8]]("S24_BL "), s24, 0, 7)   # expect 10b8c8ff

    # ---- 2. Load the 32-bit BMP sprite FILE (per-pixel alpha) -----------
    s32: int32 = game_host_load_image(cast[Ptr[char]](argv[2]))
    _o_kv(cast[Ptr[uint8]]("S32"), cast[int64](s32))
    if s32 < 0:
        _o_flush()
        return 1
    # fixture: green (0,255,0); alpha 255 for x<4, alpha 128 for x>=4.
    _o_surfpix(cast[Ptr[uint8]]("S32_OPAQUE "), s32, 0, 0)  # expect 00ff00ff
    _o_surfpix(cast[Ptr[uint8]]("S32_ALPHA "), s32, 7, 0)   # expect 00ff0080

    # ---- 3. Compose: red background + both sprites ----------------------
    disp: int32 = game_display_new(DW, DH)
    game_surface_fill(disp, game_rgb(255, 0, 0))         # opaque red backdrop
    game_surface_blit(disp, s24, SX24, SY24)
    game_surface_blit(disp, s32, SX32, SY32)

    # ---- 4. Rasterize the frame to a PPM + sample the framebuffer -------
    game_flip_scene(disp)
    prims: int32 = game_host_present(disp)
    game_host_write_ppm(cast[Ptr[char]](argv[3]))
    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))

    # Background stays pure red where nothing was blitted.
    _o_fbpix(cast[Ptr[uint8]]("FB_BG "), 2, 2)                     # #ff0000
    # 24-bit sprite corners land at the blit offset (opaque -> exact colours).
    _o_fbpix(cast[Ptr[uint8]]("FB_S24_TL "), SX24 + 0, SY24 + 0)  # #1010c8
    _o_fbpix(cast[Ptr[uint8]]("FB_S24_TR "), SX24 + 7, SY24 + 0)  # #b810c8
    _o_fbpix(cast[Ptr[uint8]]("FB_S24_BL "), SX24 + 0, SY24 + 7)  # #10b8c8
    # 32-bit sprite: opaque half is pure green; alpha half blends over red.
    _o_fbpix(cast[Ptr[uint8]]("FB_S32_OPAQUE "), SX32 + 0, SY32 + 0)  # #00ff00
    _o_fbpix(cast[Ptr[uint8]]("FB_S32_ALPHA "), SX32 + 7, SY32 + 0)   # ~#7e8000
    _o_flush()
    return 0

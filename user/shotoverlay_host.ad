# user/shotoverlay_host.ad — HOST driver + render harness for the screenshot
# "select area" overlay (built for the x86_64-linux Adder target; runs on the
# dev host, no QEMU).
#
# This is the regression guard for the bug where the "select area" mode drew
# its rubber-band selection on a BLACK screen instead of over the live desktop.
# It paints a SYNTHETIC desktop (wallpaper + panel + two app windows) into the
# host framebuffer, then draws the SAME overlay the native app ships
# (lib/shotoverlay.ad) OVER it with the alpha-aware host rasterizer — proving
# the #00000066 scrim DIMS the desktop and lets it show THROUGH, rather than
# blitting an opaque black field.
#
# It writes two PPMs a human/agent can LOOK at and prints sampled pixels a gate
# asserts:
#   argv[1]  BLACK.ppm    the OLD-bug reproduction: overlay over a black fb
#                         (what the user saw) — for side-by-side contrast.
#   argv[2]  DESKTOP.ppm  the FIX: overlay over the synthetic live desktop.
#
# No sockets, no Plan 9: reads argv + writes files. TEST shim only.

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_glyphs, \
    hamscene_stroke, hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.shotoverlay import shot_overlay_build


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


W: int32 = 1024
H: int32 = 768

# A recognizable synthetic desktop: wallpaper + top panel + two app windows
# with title bars. Drawn as an OPAQUE scene so the host fb holds real desktop
# pixels for the overlay to dim.
def _paint_desktop():
    hamscene_begin()
    wall: Ptr[uint8] = "#3a4a5e"
    hamscene_fill(0, 0, W, H, wall)
    # Top panel bar.
    panel: Ptr[uint8] = "#2b2f3e"
    hamscene_fill(0, 0, W, 28, panel)
    plabel: Ptr[uint8] = "#e8f0ff"
    apps: Ptr[uint8] = "Applications   Places   System"
    hamscene_glyphs(10, 7, apps, plabel)
    # App window 1 (terminal-ish, dark).
    w1: Ptr[uint8] = "#101418"
    hamscene_fill(120, 140, 360, 240, w1)
    t1: Ptr[uint8] = "#4a6fa5"
    hamscene_fill(120, 140, 360, 22, t1)
    tl: Ptr[uint8] = "#ffffff"
    term: Ptr[uint8] = "Terminal"
    hamscene_glyphs(130, 145, term, tl)
    prompt: Ptr[uint8] = "$ hamshot --help"
    hamscene_glyphs(132, 176, prompt, tl)
    # App window 2 (a lighter document window).
    w2: Ptr[uint8] = "#f4f2ec"
    hamscene_fill(560, 260, 340, 300, w2)
    t2: Ptr[uint8] = "#4a6fa5"
    hamscene_fill(560, 260, 340, 22, t2)
    doc: Ptr[uint8] = "Notes"
    hamscene_glyphs(570, 265, doc, tl)
    body: Ptr[uint8] = "#202020"
    line1: Ptr[uint8] = "The quick brown fox"
    hamscene_glyphs(574, 300, line1, body)
    hamui_host_rasterize()


# Draw the "Select Area" overlay with a live selection rect, then dump the PPM.
def _render(over_desktop: int32, path: Ptr[char], tag: Ptr[uint8]):
    hamui_host_begin(W, H)
    if over_desktop != 0:
        _paint_desktop()                       # opaque desktop into the host fb
    # The overlay (scrim + banner + selection). Selection box framing app win 1.
    shot_overlay_build(W, H, 0, 1, 200, 200, 420, 300)
    prims: int32 = hamui_host_rasterize()
    _write_ppm(path)
    _o_str(cast[Ptr[uint8]]("RENDER "))
    _o_str(tag)
    _o_str(cast[Ptr[uint8]](" prims="))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_flush()
    # Dump the overlay display list so a gate can grep its primitives.
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN "))
    _o_str(tag)
    _o_ch(10)
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]](
            "usage: shotoverlay_host BLACK.ppm DESKTOP.ppm\n"))
        _o_flush()
        return 2

    # 1) OLD-bug repro: overlay over a black fb (no desktop underneath).
    _render(0, cast[Ptr[char]](argv[1]), cast[Ptr[uint8]]("BLACK"))
    # Sample a point OUTSIDE the selection (dimmed scrim over black -> black).
    _o_str(cast[Ptr[uint8]]("PIX black-outside 60 700 "))
    _o_hexcol(hamui_host_pixel(60, 700))
    _o_ch(10)
    _o_flush()

    # 2) FIX: overlay over the synthetic live desktop.
    _render(1, cast[Ptr[char]](argv[2]), cast[Ptr[uint8]]("DESKTOP"))
    # Sample points that PROVE the desktop shows through the scrim:
    #  * wallpaper outside the selection: dimmed slate, NOT black.
    _o_str(cast[Ptr[uint8]]("PIX desk-wall 60 700 "))
    _o_hexcol(hamui_host_pixel(60, 700))
    _o_ch(10)
    #  * inside the selection over the terminal window body: visible, brighter
    #    than the surrounding dim (the light selection tint).
    _o_str(cast[Ptr[uint8]]("PIX desk-sel 300 300 "))
    _o_hexcol(hamui_host_pixel(300, 300))
    _o_ch(10)
    #  * the document window (light) under the scrim: still clearly light.
    _o_str(cast[Ptr[uint8]]("PIX desk-doc 700 400 "))
    _o_hexcol(hamui_host_pixel(700, 400))
    _o_ch(10)
    _o_flush()
    return 0

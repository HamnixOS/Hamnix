# user/u_server.ad — native /net TCP server smoke test (ARCH §10).
#
# A minimal native-Adder TCP server: announce a port, accept one
# connection, read a request, write a fixed response, close the
# accepted fd, then close the listener and exit. Proves the
# Plan-9-shaped /net file tree (drivers/net/devnet.ad) works end to
# end from a real user binary — NO socket() syscall anywhere.
#
# Networking the Plan 9 way: net_announce(port) opens /net/tcp/clone,
# writes an `announce` ctl command, and returns a listener handle;
# net_accept blocks on a `accept` ctl write and hands back a stream fd
# for the accepted connection. The native socket syscalls (SYS_SOCKET
# etc., 41/42/43/49/50) are RETIRED — user/net9.ad is the helper.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       user/u_server.ad -o build/user/u_server.elf
#
# Run (as /init, driven by scripts/test_u_server.sh):
#   INIT_ELF=build/user/u_server.elf python3 scripts/build_initramfs.py
#   ... boot QEMU with -netdev user,hostfwd=tcp::HOSTPORT-:7000 ...
#
# The server listens on guest port 7000 (U_SERVER_PORT). The test
# script's QEMU hostfwd maps a host port onto it; the host connects,
# sends a request line, and asserts it gets the reply back.
#
# Compiler-quirk notes (see memory/feedback_compiler_quirks.md):
#  * Every buffer is a top-level-BSS Array — the U9 nested-frame-Array
#    miscompile only bites struct-typed arrays inside nested frames;
#    flat byte arrays at module scope are safe.
#  * No string concat — each literal goes through write_str separately.

from user.net9 import net_announce, net_accept

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


# Guest port the server listens on. The test script's QEMU hostfwd
# (-netdev user,hostfwd=tcp::HOSTPORT-:7000) maps a host port onto it.
U_SERVER_PORT: uint64 = 7000

# Inbound request scratch.
req_buf:  Array[512, uint8]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def main() -> int32:
    write_str(1, "[u_server] starting TCP server\n")

    # ARCH §10: announce port 7000 on the /net file tree. net_announce
    # opens /net/tcp/clone + writes an `announce` ctl command; the
    # returned handle is the listener. INADDR_ANY is implicit — a /net
    # announce binds the port on every interface.
    lfd: int32 = net_announce(U_SERVER_PORT)
    if lfd < 0:
        write_str(2, "[u_server] net_announce() failed\n")
        return 1
    write_str(1, "[u_server] announced port 7000\n")
    write_str(1, "[u_server] listening\n")

    # Block (bounded) for one inbound connection. net_accept writes a
    # `accept` ctl command to the listener, then reads back the
    # accepted connection number and opens its `data` file — the
    # returned stream fd. sys_read / sys_write / sys_close on it route
    # through fs/vfs.ad's FD_NET_MARK arms.
    cfd: int32 = net_accept(lfd)
    if cfd < 0:
        write_str(2, "[u_server] net_accept() failed (no client?)\n")
        sys_close(lfd)
        return 1
    write_str(1, "[u_server] accepted connection\n")

    # Read one request burst. We don't parse it — just echo a marker
    # so the test can see request bytes did arrive.
    n: int64 = sys_read(cfd, &req_buf[0], 512)
    if n > 0:
        write_str(1, "[u_server] request received\n")
    else:
        write_str(1, "[u_server] no request bytes\n")

    # Send a fixed response. The host test driver asserts it gets this
    # exact line back over the TCP connection.
    write_str(cfd, "hamnix-userserver-ok\n")
    write_str(1, "[u_server] response sent\n")

    sys_close(cfd)
    sys_close(lfd)
    write_str(1, "[u_server] PASS\n")
    return 0

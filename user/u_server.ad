# user/u_server.ad — U-socket V1 server-side smoke test.
#
# A minimal native-Adder TCP server: socket() / bind() / listen() /
# accept() one connection, read() a request, write() a fixed response,
# close() the accepted fd, then close the listener and exit. Proves the
# U-socket server-side bridge — _u_bind / _u_listen / _u_accept in
# linux_abi/u_syscalls.ad, wired to drivers/net/tcp.ad's tcp_listen /
# tcp_accept — works end to end from a real user binary.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       user/u_server.ad -o build/user/u_server.elf
#
# Run (as /init, driven by scripts/test_u_server.sh):
#   INIT_ELF=build/user/u_server.elf python3 scripts/build_initramfs.py
#   ... boot QEMU with -netdev user,hostfwd=tcp::HOSTPORT-:7000 ...
#
# The server listens on guest port 7000 (U_SERVER_PORT). The test
# script's QEMU hostfwd maps a host port onto it; the host connects,
# sends a request line, and asserts it gets U_SERVER_REPLY back.
#
# Compiler-quirk notes (see memory/feedback_compiler_quirks.md):
#  * Every buffer is a top-level-BSS Array — the U9 nested-frame-Array
#    miscompile only bites struct-typed arrays inside nested frames;
#    flat byte arrays at module scope are safe.
#  * No string concat — each literal goes through write_str separately.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
extern def sys_socket(domain: int32, sock_type: int32,
                      proto: int32) -> int32
extern def sys_sock_bind(fd: int32, addr: Ptr[uint8],
                         addrlen: uint64) -> int32
extern def sys_listen(fd: int32, backlog: int32) -> int32
extern def sys_accept(fd: int32, addr: Ptr[uint8],
                      addrlen: Ptr[uint32]) -> int32


# Guest port the server listens on. The test script's QEMU hostfwd
# (-netdev user,hostfwd=tcp::HOSTPORT-:7000) maps a host port onto it.
U_SERVER_PORT: uint64 = 7000

# struct sockaddr_in scratch — 16 bytes, built once in main().
sa_buf: Array[16, uint8]

# Inbound request scratch + a small peer-sockaddr out-param buffer.
# peer_len holds the sockaddr buffer length on entry to accept(2) and
# receives the written length on return (accept's socklen_t* out-param).
req_buf:  Array[512, uint8]
peer_buf: Array[16, uint8]
peer_len: Array[1, uint32]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def main() -> int32:
    write_str(1, "[u_server] starting TCP server\n")

    # AF_INET == 2, SOCK_STREAM == 1, protocol 0 (= TCP).
    lfd: int32 = sys_socket(2, 1, 0)
    if lfd < 0:
        write_str(2, "[u_server] socket() failed\n")
        return 1

    # struct sockaddr_in: family(2, host order) port(2, BE) addr(4, BE)
    # zero(8). bind to INADDR_ANY (0.0.0.0) so SLIRP's hostfwd reaches
    # the listener regardless of the guest's DHCP-assigned address.
    k: uint64 = 0
    while k < 16:
        sa_buf[k] = 0
        k = k + 1
    sa_buf[0] = 2                                            # AF_INET lo
    sa_buf[1] = 0                                            # AF_INET hi
    sa_buf[2] = cast[uint8]((U_SERVER_PORT >> 8) & 0xFF)     # port hi (BE)
    sa_buf[3] = cast[uint8](U_SERVER_PORT & 0xFF)            # port lo (BE)
    # sa_buf[4..7] stay 0 -> INADDR_ANY.

    if sys_sock_bind(lfd, &sa_buf[0], 16) != 0:
        write_str(2, "[u_server] bind() failed\n")
        sys_close(lfd)
        return 1
    write_str(1, "[u_server] bound port 7000\n")

    if sys_listen(lfd, 1) != 0:
        write_str(2, "[u_server] listen() failed\n")
        sys_close(lfd)
        return 1
    write_str(1, "[u_server] listening\n")

    # Block (bounded) for one inbound connection. accept() returns a
    # fresh socket fd; read/write/close on it route through the
    # FD_SOCKET_MARK arms in fs/vfs.ad just like a connected client fd.
    # accept(2)'s third arg is socklen_t* — it must point at a buffer
    # holding the sockaddr capacity (16) and receives the written
    # length back.
    peer_len[0] = 16
    cfd: int32 = sys_accept(lfd, &peer_buf[0], &peer_len[0])
    if cfd < 0:
        write_str(2, "[u_server] accept() failed (no client?)\n")
        sys_close(lfd)
        return 1
    write_str(1, "[u_server] accepted connection\n")

    # Read one request burst. We don't parse it — just echo a marker
    # so the test can see request bytes did arrive.
    n: int64 = sys_read(cfd, &req_buf[0], 512)
    if n > 0:
        write_str(1, "[u_server] request received\n")
    else:
        write_str(1, "[u_server] no request bytes\n")

    # Send a fixed response. The host test driver asserts it gets this
    # exact line back over the TCP connection.
    write_str(cfd, "hamnix-userserver-ok\n")
    write_str(1, "[u_server] response sent\n")

    sys_close(cfd)
    sys_close(lfd)
    write_str(1, "[u_server] PASS\n")
    return 0

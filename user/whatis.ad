# user/whatis.ad
#
# Minimal Hamnix `whatis`: one-line descriptions for a hardcoded set
# of common binaries. Real `whatis` reads man-page NAME sections from
# a whatis(5) DB; we don't have man pages yet, so the table is wired
# in here. Unknown names get coreutils' "nothing appropriate" message.
#
#   whatis ls cat       # one line per name

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] != b[i]:
        return 0
    return 1


def lookup(name: Ptr[uint8]) -> Ptr[uint8]:
    # Hand-rolled chained `if` (no array-of-strings literal yet). Order
    # is roughly frequency-of-use in hamsh demos.
    if streq(name, "ls") != 0:
        return "ls (1)        - list directory contents\n"
    if streq(name, "cat") != 0:
        return "cat (1)       - concatenate files and print on stdout\n"
    if streq(name, "echo") != 0:
        return "echo (1)      - display a line of text\n"
    if streq(name, "pwd") != 0:
        return "pwd (1)       - print working directory\n"
    if streq(name, "cp") != 0:
        return "cp (1)        - copy files\n"
    if streq(name, "rm") != 0:
        return "rm (1)        - remove files\n"
    if streq(name, "grep") != 0:
        return "grep (1)      - print lines matching a pattern\n"
    if streq(name, "ps") != 0:
        return "ps (1)        - report a snapshot of current processes\n"
    if streq(name, "hamsh") != 0:
        return "hamsh (1)     - Hamnix interactive shell\n"
    if streq(name, "whatis") != 0:
        return "whatis (1)    - display one-line manual page descriptions\n"
    return cast[Ptr[uint8]](0)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "whatis: usage: whatis NAME...\n")
        return 1
    failed: int32 = 0
    i: int32 = 1
    while i < argc:
        name: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        line: Ptr[uint8] = lookup(name)
        if cast[uint64](line) == 0:
            write_str(1, name)
            write_str(1, ": nothing appropriate.\n")
            failed = 1
        else:
            write_str(1, line)
        i = i + 1
    return failed

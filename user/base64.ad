# user/base64.ad
#
# Hamnix `base64`: RFC 4648 base64 encode/decode over stdin → stdout.
#
#   base64        # encode stdin
#   base64 -d     # decode stdin
#
# Encode path reads stdin in 3-byte groups (padded with '=' when the
# final group is short) and emits 4-char output groups, wrapping at
# 76 columns to match coreutils. Decode path skips whitespace + '='
# and rebuilds 3-byte groups from each block of 4 base64 chars.
# 4 KiB IO buffer matches the spec ceiling — large enough to amortise
# the syscall cost without blowing past our 16 KiB user stack budget.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# RFC 4648 alphabet — built lazily so we don't need a global array
# initializer (the codegen here treats Arrays as zero-initialized
# BSS; we fill on first call).
alphabet: Array[64, uint8]
alpha_ready: int32 = 0


def init_alphabet():
    if alpha_ready != 0:
        return
    i: uint64 = 0
    while i < 26:
        alphabet[i] = cast[uint8](65 + i)        # 'A'..'Z'
        i = i + 1
    while i < 52:
        alphabet[i] = cast[uint8](97 + (i - 26)) # 'a'..'z'
        i = i + 1
    while i < 62:
        alphabet[i] = cast[uint8](48 + (i - 52)) # '0'..'9'
        i = i + 1
    alphabet[62] = 43                            # '+'
    alphabet[63] = 47                            # '/'
    alpha_ready = 1


def b64_value(c: uint8) -> int32:
    # Return the 0..63 alphabet index, or -1 if c is not a base64
    # character. '=' and whitespace are handled by the caller.
    if c >= 65 and c <= 90:
        return cast[int32](c - 65)
    if c >= 97 and c <= 122:
        return cast[int32](c - 97) + 26
    if c >= 48 and c <= 57:
        return cast[int32](c - 48) + 52
    if c == 43:
        return 62
    if c == 47:
        return 63
    return -1


in_buf:  Array[4096, uint8]
out_buf: Array[4096, uint8]


def encode_stdin() -> int32:
    init_alphabet()
    # Carry up to 2 stragglers across read boundaries so 3-byte
    # alignment is independent of how the kernel chunks stdin.
    carry: Array[3, uint8]
    carry_n: uint64 = 0
    col: uint64 = 0
    while True:
        n: int64 = sys_read(0, &in_buf[0], 4096)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        i: uint64 = 0
        out_pos: uint64 = 0
        while i < nu:
            # Refill the 3-byte group, preferring carry first.
            b0: uint8 = 0
            b1: uint8 = 0
            b2: uint8 = 0
            have: uint64 = 0
            while have < 3 and carry_n > 0:
                if have == 0:
                    b0 = carry[0]
                elif have == 1:
                    b1 = carry[0]
                else:
                    b2 = carry[0]
                carry[0] = carry[1]
                carry[1] = carry[2]
                carry_n = carry_n - 1
                have = have + 1
            while have < 3 and i < nu:
                c: uint8 = in_buf[i]
                i = i + 1
                if have == 0:
                    b0 = c
                elif have == 1:
                    b1 = c
                else:
                    b2 = c
                have = have + 1
            if have < 3:
                # Stash partial for the next read; flush on EOF only.
                k: uint64 = 0
                while k < have:
                    if k == 0:
                        carry[k] = b0
                    elif k == 1:
                        carry[k] = b1
                    else:
                        carry[k] = b2
                    k = k + 1
                carry_n = have
                break
            # Encode the full triple → 4 alphabet chars.
            out_buf[out_pos]     = alphabet[b0 >> 2]
            out_buf[out_pos + 1] = alphabet[((b0 & 3) << 4) | (b1 >> 4)]
            out_buf[out_pos + 2] = alphabet[((b1 & 15) << 2) | (b2 >> 6)]
            out_buf[out_pos + 3] = alphabet[b2 & 63]
            out_pos = out_pos + 4
            col = col + 4
            if col >= 76:
                out_buf[out_pos] = 10
                out_pos = out_pos + 1
                col = 0
        if out_pos > 0:
            sys_write(1, &out_buf[0], out_pos)
    # Flush any final partial group (1 or 2 bytes → 2 chars + '='s).
    if carry_n == 1:
        b0: uint8 = carry[0]
        out_buf[0] = alphabet[b0 >> 2]
        out_buf[1] = alphabet[(b0 & 3) << 4]
        out_buf[2] = 61                          # '='
        out_buf[3] = 61
        sys_write(1, &out_buf[0], 4)
        col = col + 4
    elif carry_n == 2:
        b0: uint8 = carry[0]
        b1: uint8 = carry[1]
        out_buf[0] = alphabet[b0 >> 2]
        out_buf[1] = alphabet[((b0 & 3) << 4) | (b1 >> 4)]
        out_buf[2] = alphabet[(b1 & 15) << 2]
        out_buf[3] = 61
        sys_write(1, &out_buf[0], 4)
        col = col + 4
    if col != 0:
        sys_write(1, "\n", 1)
    return 0


def decode_stdin() -> int32:
    # Accumulate 4 valid base64 chars at a time; '=' marks end.
    quad: Array[4, int32]
    qn: uint64 = 0
    saw_pad: int32 = 0
    while True:
        n: int64 = sys_read(0, &in_buf[0], 4096)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        i: uint64 = 0
        out_pos: uint64 = 0
        while i < nu:
            c: uint8 = in_buf[i]
            i = i + 1
            # Skip whitespace.
            if c == 32 or c == 9 or c == 10 or c == 13:
                continue
            if c == 61:                          # '='
                saw_pad = saw_pad + 1
                qn = qn + 1
                if qn == 4:
                    # Decode whatever bits the non-pad slots gave us.
                    if saw_pad == 1:
                        b0: uint8 = cast[uint8]((quad[0] << 2) | (quad[1] >> 4))
                        b1: uint8 = cast[uint8](((quad[1] & 15) << 4) | (quad[2] >> 2))
                        out_buf[out_pos] = b0
                        out_buf[out_pos + 1] = b1
                        out_pos = out_pos + 2
                    elif saw_pad == 2:
                        b0: uint8 = cast[uint8]((quad[0] << 2) | (quad[1] >> 4))
                        out_buf[out_pos] = b0
                        out_pos = out_pos + 1
                    qn = 0
                continue
            v: int32 = b64_value(c)
            if v < 0:
                # Stray byte — coreutils errors; we just skip it.
                continue
            quad[qn] = v
            qn = qn + 1
            if qn == 4:
                b0: uint8 = cast[uint8]((quad[0] << 2) | (quad[1] >> 4))
                b1: uint8 = cast[uint8](((quad[1] & 15) << 4) | (quad[2] >> 2))
                b2: uint8 = cast[uint8](((quad[2] & 3) << 6) | quad[3])
                out_buf[out_pos]     = b0
                out_buf[out_pos + 1] = b1
                out_buf[out_pos + 2] = b2
                out_pos = out_pos + 3
                qn = 0
        if out_pos > 0:
            sys_write(1, &out_buf[0], out_pos)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc >= 2:
        flag: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if flag[0] == 45 and flag[1] == 100 and flag[2] == 0:
            return decode_stdin()
        write_str(2, "base64: usage: base64 [-d] < FILE\n")
        return 1
    return encode_stdin()

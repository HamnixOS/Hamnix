# user/preempt_demo.ad
#
# Preemption-test driver. This is the parent half of the M-series
# "make the kernel preemptive" deliverable proof.
#
# Sequence:
#   1. SYS_SPAWN /bin/preempt_hog  -- a sibling userland task that runs
#      a tight infinite CPU loop and NEVER issues a blocking syscall
#      (see user/preempt_hog.ad). SYS_SPAWN returns the child pid
#      immediately; the parent does NOT waitpid, so both tasks are
#      simultaneously runnable.
#   2. The parent then runs its OWN long but BOUNDED CPU loop, also
#      syscall-free for the duration of the loop.
#   3. When the bounded loop finishes the parent prints `[preempt] PASS`
#      and exits.
#
# Under a purely cooperative scheduler step (2) can never complete:
# once the hog is scheduled it owns the CPU forever (no blocking
# syscall == no context switch), so the parent's bounded loop is
# starved and `[preempt] PASS` is never printed -> the test times out
# and FAILs.
#
# Under the timer-driven preemptive scheduler the 100 Hz timer
# interrupt rotates the runqueue every quantum, so the parent's loop
# makes forward progress in its time slices and eventually prints PASS.
# That single line is the deliverable.
#
# The bounded loop is sized (~1e7 iterations) to span many scheduler
# quanta -- the parent is provably sharing the one CPU with the hog
# across dozens of preemptive context switches, not just squeaking
# through one slice -- while still completing inside the test's QEMU
# time budget (QEMU's TCG interpreter executes the loop far slower
# than native silicon would). Progress checkpoints are printed every
# quarter of the loop so the test log shows the parent advancing.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_exit(code: uint64)


# argv for the spawned hog: argv[0] = "/bin/preempt_hog", argv[1] = 0.
hog_argv: Array[2, uint64]

spin_accum: uint64 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "[preempt] demo: spawning syscall-free CPU hog sibling\n")

    hog_path: Ptr[uint8] = cast[Ptr[uint8]]("/bin/preempt_hog")
    hog_argv[0] = cast[uint64](hog_path)
    hog_argv[1] = 0
    # stdin = inherit (-1), stdout = inherit (-1), no env. The child is
    # now STATE_READY; we do NOT waitpid it, so this parent and the hog
    # are both runnable at the same time.
    child: int32 = sys_spawn(cast[Ptr[char]](hog_path), &hog_argv[0],
                             -1, -1, cast[Ptr[uint64]](0))
    if child < 0:
        write_str(1, "[preempt] FAIL: could not spawn hog\n")
        sys_exit(1)
        return 1

    write_str(1, "[preempt] demo: hog spawned; entering bounded CPU loop\n")

    # Bounded, syscall-free CPU loop. ~3e9 iterations: large enough to
    # span many 50 ms quanta. If this loop completes at all, the timer
    # MUST have been preempting the never-yielding hog to give us CPU
    # time -- a cooperative-only kernel would deadlock here.
    target: uint64 = 10000000
    i: uint64 = 0
    next_mark: uint64 = 2500000
    while i < target:
        i = i + 1
        spin_accum = spin_accum + i
        if i == next_mark:
            write_str(1, "[preempt] demo: bounded loop progress checkpoint\n")
            next_mark = next_mark + 2500000

    # Reached only if the scheduler preempted the hog repeatedly.
    write_str(1, "[preempt] PASS: parent completed its CPU loop while a non-yielding sibling ran\n")
    sys_exit(0)
    return 0

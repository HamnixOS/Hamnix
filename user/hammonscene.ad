# user/hammonscene.ad
#
# Scene-file DE System Monitor (MATE System Monitor parity) — a real,
# live system monitor drawn as a scene display list (docs/de_scene_file_arch.md).
# It is the scene-DE port of user/hammon.ad: the same /proc data sources
# (uptime / meminfo / tasks) feed a graphical view instead of a TUI.
#
# SHOWS:
#   - UPTIME       H:MM:SS, parsed from /proc/uptime (centiseconds).
#   - MEMORY bar   MemUsed / MemTotal as a filled meter + a "used / total kB"
#                  label, from /proc/meminfo (MemTotal / MemFree).
#   - PROCESS list one row per /proc/tasks entry ("pid  state  comm"),
#                  scrollable-free (top N fit the window).
#
# It re-samples on a slow cadence (a few times/sec) and re-emits only on a
# changed sample, damage-scoped to the window, so the flicker gate stays
# green. INPUT (§11): reads /event but only to stay responsive to resize /
# focus; no interactive controls (a monitor is read-only).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_waitfds(fds: Ptr[int32], nfds: uint64, timeout_ms: int64) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamui import hamscene_commit
from lib.cpustat import cpustat_parse_line, cpustat_busy_pct
from lib.hammoncore import hammon_set_uptime, hammon_set_mem, \
    hammon_tasks_clear, hammon_task_add, hammon_proc_add, hammon_build_scene, \
    hammon_resize_line, hammon_win_w, hammon_win_h, \
    hammon_set_cpu_total, hammon_set_core, hammon_set_ncores


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ====================================================================
# /proc DATA SOURCES (ported from user/hammon.ad)
# ====================================================================
slurp_buf: Array[4096, uint8]
def _slurp(path: Ptr[char]) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < 4095:
        r: int64 = sys_read(fd, &slurp_buf[total], 4095 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    slurp_buf[total] = 0
    return total


# Find a uint64 value following a NUL-terminated label at a line start.
def _field(total: uint64, label: Ptr[uint8]) -> uint64:
    ll: uint64 = _slen(label)
    i: uint64 = 0
    while i + ll < total:
        if i == 0 or slurp_buf[i - 1] == 10:
            m: uint64 = 0
            while m < ll and slurp_buf[i + m] == label[m]:
                m = m + 1
            if m == ll:
                j: uint64 = i + ll
                while j < total and not (slurp_buf[j] >= 48
                                         and slurp_buf[j] <= 57):
                    j = j + 1
                v: uint64 = 0
                while j < total and slurp_buf[j] >= 48 and slurp_buf[j] <= 57:
                    v = v * 10 + cast[uint64](slurp_buf[j]) - 48
                    j = j + 1
                return v
        i = i + 1
    return 0


# Driver-local shadows of the latest sample, used ONLY for change detection
# (the authoritative model lives in lib/hammoncore.ad).
cur_up_s: uint64 = 0
cur_used: uint64 = 0


def _refresh_uptime():
    n: uint64 = _slurp(cast[Ptr[char]]("/proc/uptime"))
    # /proc/uptime: "<seconds>.<centis> ...". Take the whole-second part.
    secs: uint64 = 0
    i: uint64 = 0
    while i < n and slurp_buf[i] >= 48 and slurp_buf[i] <= 57:
        secs = secs * 10 + cast[uint64](slurp_buf[i]) - 48
        i = i + 1
    cur_up_s = secs % 60
    hammon_set_uptime(secs)


def _refresh_mem():
    n: uint64 = _slurp(cast[Ptr[char]]("/proc/meminfo"))
    total: uint64 = _field(n, cast[Ptr[uint8]]("MemTotal:"))
    free: uint64 = _field(n, cast[Ptr[uint8]]("MemFree:"))
    if free > total:
        free = total
    cur_used = total - free
    hammon_set_mem(total, total - free)


# ---- CPU sampling from /dev/stat (Linux /proc/stat shape) ----------
# /dev/stat emits an aggregate "cpu  <user> <nice> <system> <idle> ...\n" row
# plus one "cpu0 ..." (and "cpu1 ...") per online core. CPU busy% is the classic
# delta over the sample interval:  busy% = (d_busy) / (d_total) * 100, with
# busy = user+nice+system and total = busy+idle. The FIRST sample has no
# baseline so it reports 0 (not "all elapsed ticks were busy").
NCORE_MAX: uint64 = 8
_agg_prev_busy: uint64 = 0
_agg_prev_tot:  uint64 = 0
_core_prev_busy: Array[8, uint64]
_core_prev_tot:  Array[8, uint64]
_cpu_inited: int32 = 0
# Wall interval (single-core jiffies) between the last two samples, used to
# turn a process's utime+stime delta into a %CPU. Derived from cpu0's total
# delta (a process pinning one core = 100%).
_wall_delta: uint64 = 1


# Parse the 4 leading counters (user nice system idle) of a stat cpu line that
# starts at slurp_buf[ls], writing busy (user+nice+system) and total. Delegates
# to the shared lib/cpustat.ad parser so the panel applet and this app read the
# exact same field layout.
def _parse_cpu_line(ls: uint64, end: uint64, busy: Ptr[uint64], tot: Ptr[uint64]):
    cpustat_parse_line(&slurp_buf[0], ls, end, busy, tot)


# Match a cpu-line label at slurp_buf[ls..]: returns -1 if not a cpu line,
# -2 for the aggregate "cpu" (space follows "cpu"), or the core index for
# "cpuN".
def _cpu_line_kind(ls: uint64, end: uint64) -> int64:
    if ls + 3 > end:
        return -1
    if not (slurp_buf[ls] == 99 and slurp_buf[ls + 1] == 112
            and slurp_buf[ls + 2] == 117):              # "cpu"
        return -1
    j: uint64 = ls + 3
    if j < end and slurp_buf[j] == 32:
        return -2                                        # aggregate "cpu "
    idx: int64 = 0
    got: int32 = 0
    while j < end and slurp_buf[j] >= 48 and slurp_buf[j] <= 57:
        idx = idx * 10 + cast[int64](slurp_buf[j]) - 48
        j = j + 1
        got = 1
    if got == 0:
        return -1
    return idx


def _refresh_cpu():
    n: uint64 = _slurp(cast[Ptr[char]]("/dev/stat"))
    ncores: uint64 = 0
    ls: uint64 = 0
    i: uint64 = 0
    while i <= n:
        atend: int32 = 0
        if i == n:
            atend = 1
        if atend == 1 or slurp_buf[i] == 10:
            if i > ls:
                kind: int64 = _cpu_line_kind(ls, i)
                if kind == -2:
                    busy: Array[1, uint64]
                    tot: Array[1, uint64]
                    _parse_cpu_line(ls, i, &busy[0], &tot[0])
                    if _cpu_inited != 0:
                        pct: int32 = cpustat_busy_pct(_agg_prev_busy,
                                                      _agg_prev_tot,
                                                      busy[0], tot[0])
                        hammon_set_cpu_total(pct)
                    _agg_prev_busy = busy[0]
                    _agg_prev_tot = tot[0]
                elif kind >= 0 and cast[uint64](kind) < NCORE_MAX:
                    ci: uint64 = cast[uint64](kind)
                    busy2: Array[1, uint64]
                    tot2: Array[1, uint64]
                    _parse_cpu_line(ls, i, &busy2[0], &tot2[0])
                    if _cpu_inited != 0:
                        pct2: int32 = cpustat_busy_pct(_core_prev_busy[ci],
                                                       _core_prev_tot[ci],
                                                       busy2[0], tot2[0])
                        hammon_set_core(ci, pct2)
                        if ci == 0 and tot2[0] > _core_prev_tot[ci]:
                            _wall_delta = tot2[0] - _core_prev_tot[ci]
                    _core_prev_busy[ci] = busy2[0]
                    _core_prev_tot[ci] = tot2[0]
                    if ci + 1 > ncores:
                        ncores = ci + 1
            ls = i + 1
        i = i + 1
    if ncores >= 1:
        hammon_set_ncores(ncores)
    _cpu_inited = 1


# ---- per-process CPU% (delta of utime+stime over the wall interval) ---
# A small pid-keyed previous-ticks table survives across samples.
PMAP: uint64 = 64
_pmap_pid:   Array[64, uint64]
_pmap_ticks: Array[64, uint64]
_pmap_n:     uint64 = 0


def _pmap_lookup(pid: uint64) -> int64:
    k: uint64 = 0
    while k < _pmap_n:
        if _pmap_pid[k] == pid:
            return cast[int64](k)
        k = k + 1
    return -1


def _pmap_store(pid: uint64, ticks: uint64):
    idx: int64 = _pmap_lookup(pid)
    if idx >= 0:
        _pmap_ticks[cast[uint64](idx)] = ticks
        return
    if _pmap_n < PMAP:
        _pmap_pid[_pmap_n] = pid
        _pmap_ticks[_pmap_n] = ticks
        _pmap_n = _pmap_n + 1


# Parse one /proc/tasks data line (pid \t state \t comm \t utime \t stime) into
# the model with a computed CPU%.
proc_comm: Array[40, uint8]
def _emit_task_row(ls: uint64, end: uint64):
    i: uint64 = ls
    # field 0: pid
    pid: uint64 = 0
    while i < end and slurp_buf[i] >= 48 and slurp_buf[i] <= 57:
        pid = pid * 10 + cast[uint64](slurp_buf[i]) - 48
        i = i + 1
    if i < end and slurp_buf[i] == 9:
        i = i + 1
    # field 1: state (skip to next tab)
    while i < end and slurp_buf[i] != 9:
        i = i + 1
    if i < end and slurp_buf[i] == 9:
        i = i + 1
    # field 2: comm (until next tab)
    cn: uint64 = 0
    while i < end and slurp_buf[i] != 9 and cn < 39:
        proc_comm[cn] = slurp_buf[i]
        cn = cn + 1
        i = i + 1
    proc_comm[cn] = 0
    # skip rest of comm if it overran the buffer
    while i < end and slurp_buf[i] != 9:
        i = i + 1
    if i < end and slurp_buf[i] == 9:
        i = i + 1
    # field 3: utime
    ut: uint64 = 0
    while i < end and slurp_buf[i] >= 48 and slurp_buf[i] <= 57:
        ut = ut * 10 + cast[uint64](slurp_buf[i]) - 48
        i = i + 1
    if i < end and slurp_buf[i] == 9:
        i = i + 1
    # field 4: stime
    st: uint64 = 0
    while i < end and slurp_buf[i] >= 48 and slurp_buf[i] <= 57:
        st = st * 10 + cast[uint64](slurp_buf[i]) - 48
        i = i + 1
    tot: uint64 = ut + st
    prev_idx: int64 = _pmap_lookup(pid)
    cpu_pct: int32 = 0
    if prev_idx >= 0 and _wall_delta > 0:
        prev: uint64 = _pmap_ticks[cast[uint64](prev_idx)]
        dticks: uint64 = 0
        if tot >= prev:
            dticks = tot - prev
        cpu_pct = cast[int32]((dticks * 100) / _wall_delta)
        if cpu_pct > 100:
            cpu_pct = 100
    _pmap_store(pid, tot)
    hammon_proc_add(pid, &proc_comm[0], cpu_pct)


# Process list: one structured PID/CPU%/COMMAND row per /proc/tasks line. The
# header line ("PID\tSTATE\tCOMM...") is skipped (its pid field is non-numeric).
def _refresh_tasks():
    n: uint64 = _slurp(cast[Ptr[char]]("/proc/tasks"))
    hammon_tasks_clear()
    ls: uint64 = 0
    i: uint64 = 0
    while i <= n:
        atend: int32 = 0
        if i == n:
            atend = 1
        if atend == 1 or slurp_buf[i] == 10:
            if i > ls:
                # Skip the header row (first byte not a digit).
                if slurp_buf[ls] >= 48 and slurp_buf[ls] <= 57:
                    _emit_task_row(ls, i)
            ls = i + 1
        i = i + 1


# ====================================================================
# RENDER — the layout lives in lib/hammoncore.ad (shared with the host resize
# gate). The driver just builds the scene at the current size and commits it.
# ====================================================================
def emit_scene(wid: int32):
    hammon_build_scene()
    hamscene_commit(wid)


def _refresh_all():
    _refresh_uptime()
    # CPU first so _wall_delta is fresh before per-process CPU% is derived.
    _refresh_cpu()
    _refresh_mem()
    _refresh_tasks()


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hammonscene] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        geo: Array[64, uint8]
        gp: uint64 = 0
        pre: Ptr[uint8] = cast[Ptr[uint8]]("geometry 300 140 ")
        a: uint64 = 0
        while pre[a] != 0:
            geo[gp] = pre[a]
            gp = gp + 1
            a = a + 1
        gp = gp + _u64_to_dec(cast[uint64](hammon_win_w()), &geo[gp])
        geo[gp] = 32
        gp = gp + 1
        gp = gp + _u64_to_dec(cast[uint64](hammon_win_h()), &geo[gp])
        geo[gp] = 10
        gp = gp + 1
        sys_write(cfd, &geo[0], gp)
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("title System Monitor\n"))
        sys_close(cfd3)
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd4)

    _refresh_all()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hammonscene] scene window ready\n"))

    evbuf: Array[256, uint8]
    last_used: uint64 = 0xffffffffffffffff
    last_s: uint64 = 0xffffffffffffffff
    tick: uint64 = 0
    SAMPLE: uint64 = 16
    while True:
        changed: int32 = 0
        # Drain any pointer/resize events NON-BLOCKING (a monitor is
        # read-only; a blocking /event read would stall the periodic
        # resample loop while idle). A window CONTENT-size change ("r <w> <h>")
        # from the compositor MUST relayout: otherwise the scene keeps drawing
        # at the old size and non-default sizes show a black gutter (the same
        # bug fixed in the Control Center, c29297f2).
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read_nb(efd, &evbuf[0], 255)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            evp2: Ptr[uint8] = cast[Ptr[uint8]](
                                cast[uint64](&evbuf[0]) + ls)
                            if hammon_resize_line(evp2, i - ls) == 1:
                                changed = 1
                        ls = i + 1
                    i = i + 1
        # Periodic resample.
        tick = tick + 1
        if tick >= SAMPLE:
            tick = 0
            _refresh_all()
            if cur_used != last_used or cur_up_s != last_s:
                changed = 1
                last_used = cur_used
                last_s = cur_up_s
        if changed != 0:
            emit_scene(wid)
        # Park (instead of busy-spinning sys_yield) until an event arrives
        # or the ~30ms resample cadence lapses. sys_waitfds sleeps the task
        # OFF the runqueue: an idle monitor now sits at ~0% CPU rather than
        # pegging a core. devwsys_event_write -> waitfds_notify wakes us
        # instantly on a routed pointer/resize event; the timeout drives the
        # periodic mem/uptime resample. Falls back to the bounded yield-loop
        # only if the /event fd failed to open (headless bring-up).
        if efd >= 0:
            wfd: Array[1, int32]
            wfd[0] = efd
            sys_waitfds(&wfd[0], 1, 30)
            sys_close(efd)
        else:
            s2: uint64 = sys_get_jiffies()
            while sys_get_jiffies() - s2 < 3:
                sys_yield()
    return 0

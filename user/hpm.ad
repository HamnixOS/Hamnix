# user/hpm.ad
#
# Hamnix package manager (hpm) — v1, binary-only.
#
# Spec: docs/packages.md. Live repo: https://255.one/index.json.
#
# Phase 1 (this commit): the read-only commands.
#   hpm refresh                — fetch repo index, cache it locally
#   hpm list                   — print every installed package (from
#                                /var/lib/hpm/installed.json)
#   hpm search <pattern>       — substring match against repo names
#   hpm show <name>[@<ver>]    — print the package's index metadata
#
# Later phases add install / hooks / remove / dep solver / update.
#
# Repo URLs supported:
#   https://host[:port][/path]  — TLS via the /net file tree
#   http://host[:port][/path]   — plain TCP via /net
#   file:///abs/path/           — local-filesystem repo (read via sys_open)
#
# The default is the canonical hosted repo `https://255.one/`. Override
# with `--repo=<url>` (or `HPM_REPO=...` env). The installer ISO uses a
# `file:///mnt/iso-packages/` repo (see docs/packages.md "Bootstrap").
#
# Files this binary touches:
#   /tmp/hpm/index.json        — refreshed index cache (volatile, tmpfs)
#   /tmp/hpm/<tarball>         — staging .tar.gz downloads (Phase 2)
#   /var/lib/hpm/installed.json — installed-package DB (persistent /var)
#
# Compiler-quirk discipline (memory/feedback_compiler_quirks.md U9):
# every large buffer is a top-level BSS Array — never a frame local.
# String literals are materialised inline at the call site (the x86_64
# backend rejects string-literal globals).
#
# Build: scripts/build_user.sh -> build/user/hpm.elf -> /bin/hpm.
# Test:  scripts/test_hpm.sh (Phase 6).

# Reuse the Plan-9-shaped /net dialing helpers from user/net9.ad — the
# same shape user/apt.ad used before retirement.
from user.net9 import net_dial, net_dial_tls

# Gzip inflater for the .tar.gz package payload.
from lib.zlib.inflate import (
    InflateState,
    inflate_init,
    inflate_feed,
)


# -- syscalls ----------------------------------------------------------
#
# Plain file + spawn syscalls; networking goes through net_dial / the
# returned fd (sys_read / sys_write on a /net data fd is transparent
# TCP or TLS).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_mkdir(path: Ptr[char]) -> int32
extern def sys_unlink(path: Ptr[char]) -> int32
# U-resolve: native-ABI hostname -> IPv4 via the in-kernel DNS resolver
# (drivers/net/dns.ad, syscall 269). Returns the IPv4 packed big-endian
# in the low 32 bits (octet 0 in bits 31:24), or negative errno.
extern def sys_resolve(hostname: Ptr[uint8], hlen: uint64) -> int64
# Hooks are spawned as `/bin/hamsh <hook-script>` — hamsh's argv[1] is
# a script path (see user/hamsh.ad main()).
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_waitpid(pid: int32) -> int64


# -- bounded BSS arenas -----------------------------------------------
#
# All large buffers MUST be top-level BSS (the U9 nested-frame-Array
# miscompile). Sizes chosen to fit a small fixture repo AND the live
# https://255.one/index.json (~800 bytes today; capped at 256 KiB so a
# growing index has room).

INDEX_CAP:   uint64 = 262144     # 256 KiB cap on a fetched index.json
HTTP_STAGE:  uint64 = 65536      # 64 KiB socket-drain chunk
TARBALL_CAP: uint64 = 4194304    # 4 MiB cap on a single package tarball
TAR_CAP:     uint64 = 8388608    # 8 MiB cap on the inflated tar
INSTALLED_CAP: uint64 = 131072   # 128 KiB cap on installed.json

# Raw bytes off the socket / file when fetching a body (index.json or
# a tarball). Used in both _http_get and _file_read paths.
http_buf:    Array[262144, uint8]
http_stage:  Array[65536, uint8]

# Index cache. Loaded on every `hpm` invocation from /tmp/hpm/index.json
# (or freshly fetched on `hpm refresh`). The JSON parser indexes ONTO
# this buffer — package fields are pointers + lengths into idx_buf.
idx_buf:     Array[262144, uint8]
idx_len:     uint64 = 0

# installed.json buffer.
inst_buf:    Array[131072, uint8]
inst_len:    uint64 = 0

# Tarball download + inflate buffers (Phase 2).
deb_buf:     Array[4194304, uint8]
tar_buf:     Array[8388608, uint8]


# -- URL / path scratch -----------------------------------------------

host_buf:    Array[256, uint8]           # NUL-terminated hostname
path_buf:    Array[1024, uint8]          # base path (no trailing /)
url_path_buf: Array[1536, uint8]         # composed absolute path for GET
req_buf:     Array[1024, uint8]          # HTTP request line + headers
# url_scheme: 0 == http, 1 == https, 2 == file
url_scheme:  int32 = 0
url_port:    int64 = 80

# Repo base URL — set by _set_repo_default or `--repo=<url>` flag. This
# is a NUL-terminated copy of the canonical form (so messages can echo
# it back); the parsed pieces live in host_buf / path_buf / url_scheme.
repo_url_buf: Array[1024, uint8]


# -- tiny stdio helpers (mirrors apt.ad/dpkg_deb.ad) ------------------

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec_u64(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def _write_full(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    written: uint64 = 0
    while written < count:
        room: uint64 = count - written
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](buf) + written)
        rc: int64 = sys_write(fd, ptr, room)
        if rc < 0:
            return rc
        if rc == 0:
            return cast[int64](written)
        written = written + cast[uint64](rc)
    return cast[int64](written)


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == 0 and b[i] == 0:
        return 1
    return 0


def _streq_n(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    # Compare exactly n bytes (treats embedded NULs as bytes, not
    # terminators) — used by the JSON parser to compare a span in
    # idx_buf to a literal field name like "name" / "version".
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _strcontains(hay: Ptr[uint8], needle: Ptr[uint8]) -> int32:
    # Substring match for `hpm search` — true if needle appears anywhere
    # in hay. Both NUL-terminated, case-sensitive (mirrors apt-cache).
    hl: uint64 = strlen_u8(hay)
    nl: uint64 = strlen_u8(needle)
    if nl == 0:
        return 1
    if nl > hl:
        return 0
    i: uint64 = 0
    while i + nl <= hl:
        j: uint64 = 0
        ok: int32 = 1
        while j < nl:
            if hay[i + j] != needle[j]:
                ok = 0
                break
            j = j + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


def _strcopy_n(dst: Ptr[uint8], src: Ptr[uint8], n: uint64, cap: uint64):
    # Copy exactly n bytes (or until cap-1 reached), NUL-terminate.
    take: uint64 = n
    if take >= cap:
        take = cap - 1
    i: uint64 = 0
    while i < take:
        dst[i] = src[i]
        i = i + 1
    dst[take] = 0


def _strcopy_cstr(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    # Copy a NUL-terminated string, capping at cap-1 bytes.
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


# -- URL parsing -------------------------------------------------------
#
# Same shape as apt's _parse_url, extended with the file:// scheme.
# Sets url_scheme, url_port, host_buf, path_buf. Returns 0 on success,
# -1 on a malformed URL (diagnostic printed).

def _parse_url(url: Ptr[uint8]) -> int32:
    https_pfx: Ptr[uint8] = "https://"
    http_pfx:  Ptr[uint8] = "http://"
    file_pfx:  Ptr[uint8] = "file://"

    # Probe longest-first.
    a: uint64 = 0
    is_https: int32 = 1
    i: uint64 = 0
    while i < 8:
        if url[i] != https_pfx[i]:
            is_https = 0
            break
        i = i + 1
    if is_https != 0:
        url_scheme = 1
        a = 8
    else:
        is_file: int32 = 1
        i = 0
        while i < 7:
            if url[i] != file_pfx[i]:
                is_file = 0
                break
            i = i + 1
        if is_file != 0:
            url_scheme = 2
            a = 7
            # For file://, treat the rest as path_buf directly (no host).
            host_buf[0] = 0
            po: uint64 = 0
            m: uint64 = a
            while url[m] != 0 and po + 1 < 1024:
                path_buf[po] = url[m]
                po = po + 1
                m = m + 1
            # Trim trailing slash so joins yield clean "<path>/foo".
            while po > 0 and path_buf[po - 1] == 47:
                po = po - 1
            path_buf[po] = 0
            url_port = 0
            return 0
        # Plain http://
        is_http: int32 = 1
        i = 0
        while i < 7:
            if url[i] != http_pfx[i]:
                is_http = 0
                break
            i = i + 1
        if is_http == 0:
            write_str(2, "hpm: only https://, http://, file:// URLs supported\n")
            return -1
        url_scheme = 0
        a = 7

    # Authority spans from `a` up to the first '/' or NUL.
    auth_end: uint64 = a
    while url[auth_end] != 0 and url[auth_end] != 47:
        auth_end = auth_end + 1

    colon: uint64 = a
    have_colon: int32 = 0
    j: uint64 = a
    while j < auth_end:
        if url[j] == 58:                                 # ':'
            colon = j
            have_colon = 1
            break
        j = j + 1

    host_end: uint64 = auth_end
    if have_colon != 0:
        host_end = colon
    if host_end <= a:
        write_str(2, "hpm: malformed URL (empty host)\n")
        return -1

    ho: uint64 = 0
    k: uint64 = a
    while k < host_end and ho + 1 < 256:
        host_buf[ho] = url[k]
        ho = ho + 1
        k = k + 1
    host_buf[ho] = 0

    port: int64 = 80
    if url_scheme != 0:
        port = 443
    if have_colon != 0:
        port = 0
        p: uint64 = colon + 1
        if p >= auth_end:
            write_str(2, "hpm: malformed URL (empty port)\n")
            return -1
        while p < auth_end:
            c: uint8 = url[p]
            if c < 48 or c > 57:
                write_str(2, "hpm: malformed URL (non-numeric port)\n")
                return -1
            port = port * 10 + cast[int64](c - 48)
            if port > 65535:
                write_str(2, "hpm: malformed URL (port out of range)\n")
                return -1
            p = p + 1
    url_port = port

    po: uint64 = 0
    m: uint64 = auth_end
    while url[m] != 0 and po + 1 < 1024:
        path_buf[po] = url[m]
        po = po + 1
        m = m + 1
    while po > 0 and path_buf[po - 1] == 47:
        po = po - 1
    path_buf[po] = 0

    return 0


# -- DNS / IPv4 literal resolution -------------------------------------
#
# Lifted from user/apt.ad — dotted-quad fast path, fall through to
# sys_resolve for DNS names.

def _parse_ipv4(out0: Ptr[uint8], out1: Ptr[uint8],
                out2: Ptr[uint8], out3: Ptr[uint8]) -> int32:
    octet: uint32 = 0
    have_digit: int32 = 0
    idx: uint32 = 0
    i: uint64 = 0
    while True:
        c: uint8 = host_buf[i]
        if c == 46 or c == 0:
            if have_digit == 0:
                return -1
            if octet > 255:
                return -1
            if idx == 0:
                out0[0] = cast[uint8](octet)
            elif idx == 1:
                out1[0] = cast[uint8](octet)
            elif idx == 2:
                out2[0] = cast[uint8](octet)
            else:
                out3[0] = cast[uint8](octet)
            if c == 0:
                if idx != 3:
                    return -1
                return 0
            idx = idx + 1
            if idx > 3:
                return -1
            octet = 0
            have_digit = 0
        elif c >= 48 and c <= 57:
            octet = octet * 10 + cast[uint32](c - 48)
            have_digit = 1
        else:
            return -1
        i = i + 1


def _resolve_host(out0: Ptr[uint8], out1: Ptr[uint8],
                  out2: Ptr[uint8], out3: Ptr[uint8]) -> int32:
    if _parse_ipv4(out0, out1, out2, out3) == 0:
        return 0
    resolved_ip: int64 = sys_resolve(&host_buf[0], strlen_u8(&host_buf[0]))
    if resolved_ip < 0:
        write_str(2, "hpm: cannot resolve ")
        write_str(2, &host_buf[0])
        write_str(2, "\n")
        return -1
    u: uint64 = cast[uint64](resolved_ip)
    out0[0] = cast[uint8]((u >> 24) & 0xFF)
    out1[0] = cast[uint8]((u >> 16) & 0xFF)
    out2[0] = cast[uint8]((u >> 8) & 0xFF)
    out3[0] = cast[uint8](u & 0xFF)
    return 0


# -- HTTP fetch (buffered single-shot) --------------------------------
#
# Mirrors user/apt.ad's _http_get shape but lives here so hpm has no
# build-time dep on the retired apt source. Connects via the Plan-9
# /net file tree, sends an HTTP/1.0 GET for url_path_buf, drains the
# response into `dst` (capped at `dst_cap`), and returns the BODY
# length. Writes the body start offset (== response_size - body_size)
# through *body_off. Returns -1 on any socket / HTTP error.
#
# The drain stops as soon as the whole response is in hand: once the
# headers + a Content-Length worth of body bytes have arrived, we
# must NOT issue another read() — on the https path a trailing read
# past the body wedges on TLS close_notify (the kernel socket-read's
# bounded poll never fires under syscall context).

def _http_expected_len(dst: Ptr[uint8], total: uint64) -> uint64:
    # Returns the expected total response length once both the header
    # terminator AND a Content-Length header have been observed; else 0.
    hdr_end: uint64 = 0
    found: int32 = 0
    p: uint64 = 0
    while p + 3 < total:
        if dst[p] == 13 and dst[p + 1] == 10 \
                and dst[p + 2] == 13 and dst[p + 3] == 10:
            hdr_end = p + 4
            found = 1
            break
        p = p + 1
    if found == 0:
        return 0

    name: Ptr[uint8] = "content-length"
    name_len: uint64 = 14
    line: uint64 = 0
    while line < hdr_end:
        match_n: int32 = 1
        j: uint64 = 0
        while j < name_len:
            c: uint8 = dst[line + j]
            if c >= 65 and c <= 90:
                c = c + 32
            if c != name[j]:
                match_n = 0
                break
            j = j + 1
        if match_n != 0 and dst[line + name_len] == 58:    # ':'
            v: uint64 = line + name_len + 1
            while v < hdr_end and dst[v] == 32:
                v = v + 1
            clen: uint64 = 0
            have_digit: int32 = 0
            while v < hdr_end and dst[v] >= 48 and dst[v] <= 57:
                clen = clen * 10 + cast[uint64](dst[v] - 48)
                have_digit = 1
                v = v + 1
            if have_digit != 0:
                return hdr_end + clen
            return 0
        nl: uint64 = line
        while nl < hdr_end and dst[nl] != 10:
            nl = nl + 1
        line = nl + 1
    return 0


def _http_connect() -> int32:
    ip0: uint8 = 0
    ip1: uint8 = 0
    ip2: uint8 = 0
    ip3: uint8 = 0
    if _resolve_host(&ip0, &ip1, &ip2, &ip3) != 0:
        return -1
    if url_scheme == 0:
        nfd: int32 = net_dial(ip0, ip1, ip2, ip3, cast[uint64](url_port))
        if nfd < 0:
            write_str(2, "hpm: net_dial() failed (mirror unreachable?)\n")
            return -1
        return nfd
    nfd_tls: int32 = net_dial_tls(ip0, ip1, ip2, ip3,
                                  cast[uint64](url_port), &host_buf[0])
    if nfd_tls < 0:
        write_str(2, "hpm: TLS connect failed for ")
        write_str(2, &host_buf[0])
        write_str(2, "\n")
        return -1
    return nfd_tls


def _http_send_request(fd: int32) -> int32:
    ro: uint64 = 0
    g: Ptr[uint8] = "GET "
    gi: uint64 = 0
    while g[gi] != 0:
        req_buf[ro] = g[gi]
        ro = ro + 1
        gi = gi + 1
    pi: uint64 = 0
    while url_path_buf[pi] != 0 and ro < 1000:
        req_buf[ro] = url_path_buf[pi]
        ro = ro + 1
        pi = pi + 1
    tail1: Ptr[uint8] = " HTTP/1.0\r\nHost: "
    ti: uint64 = 0
    while tail1[ti] != 0:
        req_buf[ro] = tail1[ti]
        ro = ro + 1
        ti = ti + 1
    hi: uint64 = 0
    while host_buf[hi] != 0 and ro < 1000:
        req_buf[ro] = host_buf[hi]
        ro = ro + 1
        hi = hi + 1
    tail2: Ptr[uint8] = "\r\nUser-Agent: hamnix-hpm/1\r\nConnection: close\r\n\r\n"
    si: uint64 = 0
    while tail2[si] != 0:
        req_buf[ro] = tail2[si]
        ro = ro + 1
        si = si + 1

    wn: int64 = _write_full(fd, &req_buf[0], ro)
    if wn < 0 or cast[uint64](wn) != ro:
        write_str(2, "hpm: short write sending HTTP request\n")
        return -1
    return 0


def _http_get(dst: Ptr[uint8], dst_cap: uint64,
              body_off: Ptr[uint64]) -> int64:
    # url_scheme + url_port + host_buf + url_path_buf are already set.
    fd: int32 = _http_connect()
    if fd < 0:
        return -1
    if _http_send_request(fd) != 0:
        sys_close(fd)
        return -1

    total: uint64 = 0
    while total < dst_cap:
        want: uint64 = _http_expected_len(dst, total)
        if want != 0 and total >= want:
            break
        room: uint64 = dst_cap - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](dst) + total), room)
        if n < 0:
            write_str(2, "hpm: read() error on HTTP response\n")
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)

    exact: uint64 = _http_expected_len(dst, total)
    if exact != 0 and total > exact:
        total = exact

    if total == 0:
        write_str(2, "hpm: empty HTTP response\n")
        return -1
    if total >= dst_cap:
        write_str(2, "hpm: HTTP response exceeds buffer cap\n")
        return -1

    if total < 12:
        write_str(2, "hpm: truncated HTTP status line\n")
        return -1
    if dst[0] != 72 or dst[1] != 84 or dst[2] != 84 or dst[3] != 80:
        write_str(2, "hpm: malformed HTTP status line\n")
        return -1
    if dst[9] != 50 or dst[10] != 48 or dst[11] != 48:
        write_str(2, "hpm: HTTP request did not return 200 OK\n")
        return -1

    bo: uint64 = 0
    found: int32 = 0
    p: uint64 = 0
    while p + 3 < total:
        if dst[p] == 13 and dst[p + 1] == 10 \
                and dst[p + 2] == 13 and dst[p + 3] == 10:
            bo = p + 4
            found = 1
            break
        p = p + 1
    if found == 0:
        write_str(2, "hpm: HTTP response has no header terminator\n")
        return -1

    body_off[0] = bo
    return cast[int64](total - bo)


# -- file:// fetch -----------------------------------------------------
#
# Slurp <path_buf>/<tail> into dst[0..dst_cap), returning the byte count
# read. dst_cap is the maximum bytes to accept; an over-cap file is a
# hard error.

def _file_read_path(file_path: Ptr[char],
                    dst: Ptr[uint8], dst_cap: uint64) -> int64:
    fd: int32 = sys_open(file_path)
    if fd < 0:
        write_str(2, "hpm: cannot open ")
        write_str(2, cast[Ptr[uint8]](file_path))
        write_str(2, "\n")
        return -1
    total: uint64 = 0
    while total < dst_cap:
        room: uint64 = dst_cap - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](dst) + total), room)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    if total >= dst_cap:
        write_str(2, "hpm: file exceeds buffer cap\n")
        return -1
    return cast[int64](total)


# -- compose path under the repo base ---------------------------------
#
# Builds the absolute target for a GET / file-open: "<base>/<tail>".
# For HTTP-shaped schemes the result goes into url_path_buf (used by
# the GET). For file://, the result goes into a caller-supplied buffer
# (so the file_open path can use it as a Ptr[char]).

def _build_url_path(tail: Ptr[uint8]):
    o: uint64 = 0
    bi: uint64 = 0
    while path_buf[bi] != 0 and o + 1 < 1536:
        url_path_buf[o] = path_buf[bi]
        o = o + 1
        bi = bi + 1
    # Ensure a leading '/' so a base of "" (bare host) still yields a
    # path that starts with '/'.
    if o == 0 or url_path_buf[0] != 47:
        # Shift right by 1 to insert leading '/'. The fixture cases where
        # path_buf is empty want url_path_buf = "/<tail>".
        s: uint64 = o
        while s > 0:
            url_path_buf[s] = url_path_buf[s - 1]
            s = s - 1
        url_path_buf[0] = 47
        o = o + 1
    # Separator '/' if base doesn't already end in one.
    if o == 0 or url_path_buf[o - 1] != 47:
        if o + 1 < 1536:
            url_path_buf[o] = 47
            o = o + 1
    ti: uint64 = 0
    while tail[ti] != 0 and o + 1 < 1536:
        url_path_buf[o] = tail[ti]
        o = o + 1
        ti = ti + 1
    url_path_buf[o] = 0


def _build_file_path(out: Ptr[uint8], cap: uint64, tail: Ptr[uint8]) -> int32:
    # path_buf is the file:// path (NO leading file://). Compose
    # "<path_buf>/<tail>" into out (NUL-terminated). Returns 0 on
    # success, -1 on overflow.
    o: uint64 = 0
    bi: uint64 = 0
    while path_buf[bi] != 0:
        if o + 1 >= cap:
            return -1
        out[o] = path_buf[bi]
        o = o + 1
        bi = bi + 1
    if o == 0 or out[o - 1] != 47:
        if o + 1 >= cap:
            return -1
        out[o] = 47
        o = o + 1
    ti: uint64 = 0
    while tail[ti] != 0:
        if o + 1 >= cap:
            return -1
        out[o] = tail[ti]
        o = o + 1
        ti = ti + 1
    out[o] = 0
    return 0


# -- repo-aware fetch wrapper -----------------------------------------
#
# fetch_to_buf(tail, dst, dst_cap) — fetch the resource at <repo>/<tail>
# into dst, returning the byte count. Routes on url_scheme:
#   http / https  -> _http_get
#   file          -> _file_read_path
#
# For HTTP the body lands at dst[body_off..body_off+len); the caller
# typically moves it down via a memcpy after the call. We keep this
# simple by copying body bytes down to dst[0..len) here so the caller
# gets a clean buffer that starts with the resource.

fetch_path_scratch: Array[1536, uint8]


def fetch_to_buf(tail: Ptr[uint8], dst: Ptr[uint8],
                 dst_cap: uint64) -> int64:
    if url_scheme == 2:
        if _build_file_path(&fetch_path_scratch[0], 1536, tail) != 0:
            write_str(2, "hpm: file path overflow\n")
            return -1
        return _file_read_path(cast[Ptr[char]](&fetch_path_scratch[0]),
                               dst, dst_cap)
    _build_url_path(tail)
    body_off: uint64 = 0
    blen: int64 = _http_get(dst, dst_cap, &body_off)
    if blen < 0:
        return -1
    # Slide body bytes to the front of dst so callers see a clean buffer.
    if body_off > 0:
        bl: uint64 = cast[uint64](blen)
        i: uint64 = 0
        while i < bl:
            dst[i] = dst[body_off + i]
            i = i + 1
    return blen


# -- repo default + flag handling -------------------------------------

def _set_repo_default():
    # The canonical hosted repo. Override via `--repo=<url>` flag.
    s: Ptr[uint8] = "https://255.one/"
    _strcopy_cstr(&repo_url_buf[0], s, 1024)


def _set_repo(url: Ptr[uint8]):
    _strcopy_cstr(&repo_url_buf[0], url, 1024)


def _apply_repo() -> int32:
    # Parse repo_url_buf into url_scheme + host_buf + path_buf.
    return _parse_url(&repo_url_buf[0])


# -- minimal JSON parser ----------------------------------------------
#
# The Hamnix-side library does NOT have a JSON parser today (apt
# parsed RFC822 stanzas, not JSON). hpm needs *just enough* to walk
# the schema-1 index.json — strings, numbers, arrays, objects. This
# is a small recursive-descent parser specialised to that subset:
#
#   - No floating point (numbers are integers; we only need size:int).
#   - String escape support: \" \\ \/ \n \r \t \b \f, and \uHHHH
#     decoded to UTF-8 (one BMP code point). \uHHHH surrogate pairs
#     NOT handled (an extremely rare case for our schema; field
#     values are ASCII names/URLs/hashes/descriptions).
#   - Whitespace = SP TAB LF CR per RFC 8259.
#
# The parse PASS records pointer + length spans into idx_buf for each
# package's fields, so the caller never copies the bytes out — fields
# are read directly from the cache via field-by-name lookup. The cache
# is bytewise stable until the next `hpm refresh`.

# Per-package field-span tables. PKG_MAX is generous so the live repo
# can grow; field count per package is the schema's documented set.
PKG_MAX:    uint64 = 1024

# Each package gets these spans (offset + length into idx_buf, or
# 0/0 if absent). 0 is a sentinel "absent" since idx_buf[0] is the
# opening '{' of the top-level object, never the start of a string.
pkg_name_off:        Array[1024, uint64]
pkg_name_len:        Array[1024, uint64]
pkg_version_off:     Array[1024, uint64]
pkg_version_len:     Array[1024, uint64]
pkg_arch_off:        Array[1024, uint64]
pkg_arch_len:        Array[1024, uint64]
pkg_url_off:         Array[1024, uint64]
pkg_url_len:         Array[1024, uint64]
pkg_sha256_off:      Array[1024, uint64]
pkg_sha256_len:      Array[1024, uint64]
pkg_size:            Array[1024, uint64]    # numeric (parsed)
pkg_desc_off:        Array[1024, uint64]
pkg_desc_len:        Array[1024, uint64]
pkg_target_off:      Array[1024, uint64]
pkg_target_len:      Array[1024, uint64]

# Dependency / conflicts / provides arrays. Each package owns a slice
# of a flat string table; per-entry offset+len is recorded.
DEP_ENTRIES_MAX: uint64 = 8192      # total dep entries across all pkgs
pkg_dep_start:       Array[1024, uint64]
pkg_dep_count:       Array[1024, uint64]
pkg_conf_start:      Array[1024, uint64]
pkg_conf_count:      Array[1024, uint64]
pkg_prov_start:      Array[1024, uint64]
pkg_prov_count:      Array[1024, uint64]

dep_entry_off:       Array[8192, uint64]
dep_entry_len:       Array[8192, uint64]
dep_entry_n:         uint64 = 0

conf_entry_off:      Array[8192, uint64]
conf_entry_len:      Array[8192, uint64]
conf_entry_n:        uint64 = 0

prov_entry_off:      Array[8192, uint64]
prov_entry_len:      Array[8192, uint64]
prov_entry_n:        uint64 = 0

pkg_count:           uint64 = 0

# Parser cursor (byte offset into idx_buf).
jp:    uint64 = 0
jend:  uint64 = 0


def _json_skip_ws():
    while jp < jend:
        c: uint8 = idx_buf[jp]
        if c == 32 or c == 9 or c == 10 or c == 13:
            jp = jp + 1
        else:
            return


def _json_expect(c: uint8) -> int32:
    _json_skip_ws()
    if jp >= jend or idx_buf[jp] != c:
        return -1
    jp = jp + 1
    return 0


def _json_peek() -> int32:
    _json_skip_ws()
    if jp >= jend:
        return -1
    return cast[int32](idx_buf[jp])


# Parse a JSON string. Returns 0 on success and writes the
# string-content span (excluding the surrounding quotes, with escape
# sequences left in their raw form — the consumer is content to read
# escaped backslashes verbatim for our schema's ASCII-only fields)
# to *out_off / *out_len. Skips past the closing quote.

def _json_parse_string(out_off: Ptr[uint64], out_len: Ptr[uint64]) -> int32:
    _json_skip_ws()
    if jp >= jend or idx_buf[jp] != 34:                  # '"'
        return -1
    jp = jp + 1
    start: uint64 = jp
    while jp < jend:
        c: uint8 = idx_buf[jp]
        if c == 92:                                      # '\'
            # Skip the escape introducer + one char. (\uHHHH is 5 more
            # chars; we still skip past them for span-end purposes —
            # the raw escape lives in the span. That's fine: every
            # field hpm reads is plain ASCII in practice.)
            jp = jp + 1
            if jp >= jend:
                return -1
            esc: uint8 = idx_buf[jp]
            jp = jp + 1
            if esc == 117:                               # 'u'
                jp = jp + 4
            continue
        if c == 34:                                      # '"'
            out_off[0] = start
            out_len[0] = jp - start
            jp = jp + 1
            return 0
        jp = jp + 1
    return -1


# Parse an integer. Negative numbers are not in our schema (size is
# always >= 0) — but accept '-' defensively. Returns 0 on success,
# stores the value through *out.

def _json_parse_int(out: Ptr[uint64]) -> int32:
    _json_skip_ws()
    if jp >= jend:
        return -1
    neg: int32 = 0
    if idx_buf[jp] == 45:                                # '-'
        neg = 1
        jp = jp + 1
    if jp >= jend or idx_buf[jp] < 48 or idx_buf[jp] > 57:
        return -1
    v: uint64 = 0
    while jp < jend and idx_buf[jp] >= 48 and idx_buf[jp] <= 57:
        v = v * 10 + cast[uint64](idx_buf[jp] - 48)
        jp = jp + 1
    out[0] = v
    return 0


# Skip over a JSON value (string / number / object / array / true /
# false / null). Used to discard fields the parser doesn't care about
# (top-level "repo", "url", "updated", "description"; package fields
# not in our schema). Returns 0 on success, -1 on a parse error.

def _json_skip_value() -> int32:
    _json_skip_ws()
    if jp >= jend:
        return -1
    c: uint8 = idx_buf[jp]
    if c == 34:                                          # '"'
        off: uint64 = 0
        ln: uint64 = 0
        return _json_parse_string(&off, &ln)
    if c == 45 or (c >= 48 and c <= 57):
        v: uint64 = 0
        return _json_parse_int(&v)
    if c == 116 or c == 102 or c == 110:                 # t / f / n
        # true / false / null — skip the literal.
        while jp < jend:
            cc: uint8 = idx_buf[jp]
            if cc >= 97 and cc <= 122:
                jp = jp + 1
            else:
                break
        return 0
    if c == 91:                                          # '['
        jp = jp + 1
        _json_skip_ws()
        if jp < jend and idx_buf[jp] == 93:
            jp = jp + 1
            return 0
        while True:
            if _json_skip_value() != 0:
                return -1
            _json_skip_ws()
            if jp >= jend:
                return -1
            d: uint8 = idx_buf[jp]
            if d == 44:                                  # ','
                jp = jp + 1
                continue
            if d == 93:                                  # ']'
                jp = jp + 1
                return 0
            return -1
    if c == 123:                                         # '{'
        jp = jp + 1
        _json_skip_ws()
        if jp < jend and idx_buf[jp] == 125:
            jp = jp + 1
            return 0
        while True:
            koff: uint64 = 0
            klen: uint64 = 0
            if _json_parse_string(&koff, &klen) != 0:
                return -1
            if _json_expect(58) != 0:                    # ':'
                return -1
            if _json_skip_value() != 0:
                return -1
            _json_skip_ws()
            if jp >= jend:
                return -1
            d2: uint8 = idx_buf[jp]
            if d2 == 44:
                jp = jp + 1
                continue
            if d2 == 125:                                # '}'
                jp = jp + 1
                return 0
            return -1
    return -1


# Parse a string-array into entry_off[start..start+count) / entry_len[..]
# at the given append cursor. Returns 0 on success and writes the
# count through *out_count. cap_check guards against overflow.

def _json_parse_strarr(entry_off: Ptr[uint64], entry_len: Ptr[uint64],
                       cursor_p: Ptr[uint64], cap: uint64,
                       out_start: Ptr[uint64],
                       out_count: Ptr[uint64]) -> int32:
    _json_skip_ws()
    if jp >= jend or idx_buf[jp] != 91:                  # '['
        return -1
    jp = jp + 1
    out_start[0] = cursor_p[0]
    n: uint64 = 0
    _json_skip_ws()
    if jp < jend and idx_buf[jp] == 93:
        jp = jp + 1
        out_count[0] = 0
        return 0
    while True:
        if cursor_p[0] >= cap:
            write_str(2, "hpm: dep-entry table overflow\n")
            return -1
        soff: uint64 = 0
        slen: uint64 = 0
        if _json_parse_string(&soff, &slen) != 0:
            return -1
        entry_off[cursor_p[0]] = soff
        entry_len[cursor_p[0]] = slen
        cursor_p[0] = cursor_p[0] + 1
        n = n + 1
        _json_skip_ws()
        if jp >= jend:
            return -1
        d: uint8 = idx_buf[jp]
        if d == 44:
            jp = jp + 1
            continue
        if d == 93:
            jp = jp + 1
            out_count[0] = n
            return 0
        return -1


# Parse one package object into pkg_*[pi] slots.

def _json_parse_pkg(pi: uint64) -> int32:
    if _json_expect(123) != 0:                           # '{'
        return -1
    # Initialise spans/counts to 0.
    pkg_name_off[pi] = 0
    pkg_name_len[pi] = 0
    pkg_version_off[pi] = 0
    pkg_version_len[pi] = 0
    pkg_arch_off[pi] = 0
    pkg_arch_len[pi] = 0
    pkg_url_off[pi] = 0
    pkg_url_len[pi] = 0
    pkg_sha256_off[pi] = 0
    pkg_sha256_len[pi] = 0
    pkg_size[pi] = 0
    pkg_desc_off[pi] = 0
    pkg_desc_len[pi] = 0
    pkg_target_off[pi] = 0
    pkg_target_len[pi] = 0
    pkg_dep_start[pi] = 0
    pkg_dep_count[pi] = 0
    pkg_conf_start[pi] = 0
    pkg_conf_count[pi] = 0
    pkg_prov_start[pi] = 0
    pkg_prov_count[pi] = 0

    _json_skip_ws()
    if jp < jend and idx_buf[jp] == 125:                 # empty {}
        jp = jp + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _json_parse_string(&koff, &klen) != 0:
            return -1
        if _json_expect(58) != 0:
            return -1

        kp: Ptr[uint8] = &idx_buf[koff]
        if klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("name"), 4) != 0:
            if _json_parse_string(&pkg_name_off[pi], &pkg_name_len[pi]) != 0:
                return -1
        elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("version"), 7) != 0:
            if _json_parse_string(&pkg_version_off[pi], &pkg_version_len[pi]) != 0:
                return -1
        elif klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("arch"), 4) != 0:
            if _json_parse_string(&pkg_arch_off[pi], &pkg_arch_len[pi]) != 0:
                return -1
        elif klen == 3 and _streq_n(kp, cast[Ptr[uint8]]("url"), 3) != 0:
            if _json_parse_string(&pkg_url_off[pi], &pkg_url_len[pi]) != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("sha256"), 6) != 0:
            if _json_parse_string(&pkg_sha256_off[pi], &pkg_sha256_len[pi]) != 0:
                return -1
        elif klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("size"), 4) != 0:
            if _json_parse_int(&pkg_size[pi]) != 0:
                return -1
        elif klen == 11 and _streq_n(kp, cast[Ptr[uint8]]("description"), 11) != 0:
            if _json_parse_string(&pkg_desc_off[pi], &pkg_desc_len[pi]) != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("target"), 6) != 0:
            if _json_parse_string(&pkg_target_off[pi], &pkg_target_len[pi]) != 0:
                return -1
        elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("depends"), 7) != 0:
            if _json_parse_strarr(&dep_entry_off[0], &dep_entry_len[0],
                                  &dep_entry_n, 8192,
                                  &pkg_dep_start[pi],
                                  &pkg_dep_count[pi]) != 0:
                return -1
        elif klen == 9 and _streq_n(kp, cast[Ptr[uint8]]("conflicts"), 9) != 0:
            if _json_parse_strarr(&conf_entry_off[0], &conf_entry_len[0],
                                  &conf_entry_n, 8192,
                                  &pkg_conf_start[pi],
                                  &pkg_conf_count[pi]) != 0:
                return -1
        elif klen == 8 and _streq_n(kp, cast[Ptr[uint8]]("provides"), 8) != 0:
            if _json_parse_strarr(&prov_entry_off[0], &prov_entry_len[0],
                                  &prov_entry_n, 8192,
                                  &pkg_prov_start[pi],
                                  &pkg_prov_count[pi]) != 0:
                return -1
        else:
            # Unknown key — skip its value defensively.
            if _json_skip_value() != 0:
                return -1

        _json_skip_ws()
        if jp >= jend:
            return -1
        d: uint8 = idx_buf[jp]
        if d == 44:
            jp = jp + 1
            continue
        if d == 125:
            jp = jp + 1
            return 0
        return -1


def _json_parse_index() -> int32:
    # Parse idx_buf[0..idx_len) as a schema-1 index. Walks the top-
    # level object, recognises "packages" (the only field we keep),
    # skips everything else. Fills pkg_*[0..pkg_count).
    jp = 0
    jend = idx_len
    pkg_count = 0
    dep_entry_n = 0
    conf_entry_n = 0
    prov_entry_n = 0

    if _json_expect(123) != 0:
        write_str(2, "hpm: index: top-level is not a JSON object\n")
        return -1
    _json_skip_ws()
    if jp < jend and idx_buf[jp] == 125:
        jp = jp + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _json_parse_string(&koff, &klen) != 0:
            write_str(2, "hpm: index: malformed key\n")
            return -1
        if _json_expect(58) != 0:
            write_str(2, "hpm: index: expected ':'\n")
            return -1
        kp: Ptr[uint8] = &idx_buf[koff]
        if klen == 8 and _streq_n(kp, cast[Ptr[uint8]]("packages"), 8) != 0:
            _json_skip_ws()
            if jp >= jend or idx_buf[jp] != 91:          # '['
                write_str(2, "hpm: index: packages is not an array\n")
                return -1
            jp = jp + 1
            _json_skip_ws()
            if jp < jend and idx_buf[jp] == 93:
                jp = jp + 1
            else:
                while True:
                    if pkg_count >= 1024:
                        write_str(2, "hpm: index: too many packages (>1024)\n")
                        return -1
                    if _json_parse_pkg(pkg_count) != 0:
                        write_str(2, "hpm: index: malformed package object\n")
                        return -1
                    pkg_count = pkg_count + 1
                    _json_skip_ws()
                    if jp >= jend:
                        return -1
                    d: uint8 = idx_buf[jp]
                    if d == 44:
                        jp = jp + 1
                        continue
                    if d == 93:
                        jp = jp + 1
                        break
                    write_str(2, "hpm: index: malformed packages array\n")
                    return -1
        else:
            if _json_skip_value() != 0:
                return -1

        _json_skip_ws()
        if jp >= jend:
            return -1
        d2: uint8 = idx_buf[jp]
        if d2 == 44:
            jp = jp + 1
            continue
        if d2 == 125:
            jp = jp + 1
            return 0
        write_str(2, "hpm: index: malformed top-level object\n")
        return -1


# -- index cache: load + refresh --------------------------------------

def _ensure_hpm_tmpdir():
    # /tmp is tmpfs-owned; mkdir is idempotent (returns -EEXIST on retry).
    sys_mkdir("/tmp/hpm")


def _save_index_cache() -> int32:
    _ensure_hpm_tmpdir()
    fd: int32 = sys_open_write("/tmp/hpm/index.json")
    if fd < 0:
        write_str(2, "hpm: cannot open /tmp/hpm/index.json for write\n")
        return -1
    wn: int64 = _write_full(fd, &idx_buf[0], idx_len)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != idx_len:
        write_str(2, "hpm: short write on /tmp/hpm/index.json\n")
        return -1
    return 0


def _load_index_cache() -> int32:
    # Try the tmpfs cache. If absent, hpm requires a `refresh` first.
    fd: int32 = sys_open("/tmp/hpm/index.json")
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < INDEX_CAP:
        room: uint64 = INDEX_CAP - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&idx_buf[0]) + total), room)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    idx_len = total
    if _json_parse_index() != 0:
        return -1
    return 0


def cmd_refresh() -> int32:
    # Fetch <repo>/index.json into idx_buf, parse it, persist to
    # /tmp/hpm/index.json. The repo URL has already been parsed into
    # url_scheme + host_buf + path_buf by main().
    n: int64 = fetch_to_buf(cast[Ptr[uint8]]("index.json"),
                            &idx_buf[0], INDEX_CAP)
    if n < 0:
        write_str(2, "hpm: refresh failed\n")
        return 1
    idx_len = cast[uint64](n)
    if _json_parse_index() != 0:
        write_str(2, "hpm: refresh: index.json parse failed\n")
        return 1
    if _save_index_cache() != 0:
        return 1
    write_str(1, "hpm: refreshed index from ")
    write_str(1, &repo_url_buf[0])
    write_str(1, " (")
    write_dec_u64(1, pkg_count)
    write_str(1, " packages, ")
    write_dec_u64(1, idx_len)
    write_str(1, " bytes)\n")
    return 0


# -- installed.json -- read + parse + write ---------------------------
#
# Installed DB schema (per docs/packages.md):
#   { "schema": 1,
#     "packages": [ { "name": "...", "version": "...",
#                     "installed_at": "...", "pinned": false,
#                     "target": "#hamnix-system",
#                     "files": ["bin/foo", ...] }, ... ] }
#
# Phase 1 only needs to READ this to print `hpm list`. Phase 2/3 will
# write to it as well.

INST_MAX:        uint64 = 256
inst_name_off:   Array[256, uint64]
inst_name_len:   Array[256, uint64]
inst_ver_off:    Array[256, uint64]
inst_ver_len:    Array[256, uint64]
inst_pinned:     Array[256, int32]
inst_target_off: Array[256, uint64]
inst_target_len: Array[256, uint64]
inst_at_off:     Array[256, uint64]
inst_at_len:     Array[256, uint64]
# Files: per-installed-pkg slice of a flat (offset, length) table.
INST_FILES_MAX:  uint64 = 8192
inst_file_start: Array[256, uint64]
inst_file_count: Array[256, uint64]
inst_file_off:   Array[8192, uint64]
inst_file_len:   Array[8192, uint64]
inst_file_n:     uint64 = 0
inst_count:      uint64 = 0

# Parser cursor for inst_buf (parallel to idx_buf's jp/jend).
ip:   uint64 = 0
iend: uint64 = 0


def _inst_skip_ws():
    while ip < iend:
        c: uint8 = inst_buf[ip]
        if c == 32 or c == 9 or c == 10 or c == 13:
            ip = ip + 1
        else:
            return


def _inst_expect(c: uint8) -> int32:
    _inst_skip_ws()
    if ip >= iend or inst_buf[ip] != c:
        return -1
    ip = ip + 1
    return 0


def _inst_parse_string(out_off: Ptr[uint64], out_len: Ptr[uint64]) -> int32:
    _inst_skip_ws()
    if ip >= iend or inst_buf[ip] != 34:
        return -1
    ip = ip + 1
    start: uint64 = ip
    while ip < iend:
        c: uint8 = inst_buf[ip]
        if c == 92:
            ip = ip + 1
            if ip >= iend:
                return -1
            esc: uint8 = inst_buf[ip]
            ip = ip + 1
            if esc == 117:
                ip = ip + 4
            continue
        if c == 34:
            out_off[0] = start
            out_len[0] = ip - start
            ip = ip + 1
            return 0
        ip = ip + 1
    return -1


def _inst_parse_int(out: Ptr[uint64]) -> int32:
    _inst_skip_ws()
    if ip >= iend:
        return -1
    if inst_buf[ip] == 45:
        ip = ip + 1
    if ip >= iend or inst_buf[ip] < 48 or inst_buf[ip] > 57:
        return -1
    v: uint64 = 0
    while ip < iend and inst_buf[ip] >= 48 and inst_buf[ip] <= 57:
        v = v * 10 + cast[uint64](inst_buf[ip] - 48)
        ip = ip + 1
    out[0] = v
    return 0


def _inst_skip_value() -> int32:
    _inst_skip_ws()
    if ip >= iend:
        return -1
    c: uint8 = inst_buf[ip]
    if c == 34:
        off: uint64 = 0
        ln: uint64 = 0
        return _inst_parse_string(&off, &ln)
    if c == 45 or (c >= 48 and c <= 57):
        v: uint64 = 0
        return _inst_parse_int(&v)
    if c == 116 or c == 102 or c == 110:
        while ip < iend:
            cc: uint8 = inst_buf[ip]
            if cc >= 97 and cc <= 122:
                ip = ip + 1
            else:
                break
        return 0
    if c == 91:                                          # '['
        ip = ip + 1
        _inst_skip_ws()
        if ip < iend and inst_buf[ip] == 93:
            ip = ip + 1
            return 0
        while True:
            if _inst_skip_value() != 0:
                return -1
            _inst_skip_ws()
            if ip >= iend:
                return -1
            d: uint8 = inst_buf[ip]
            if d == 44:
                ip = ip + 1
                continue
            if d == 93:
                ip = ip + 1
                return 0
            return -1
    if c == 123:                                         # '{'
        ip = ip + 1
        _inst_skip_ws()
        if ip < iend and inst_buf[ip] == 125:
            ip = ip + 1
            return 0
        while True:
            koff: uint64 = 0
            klen: uint64 = 0
            if _inst_parse_string(&koff, &klen) != 0:
                return -1
            if _inst_expect(58) != 0:
                return -1
            if _inst_skip_value() != 0:
                return -1
            _inst_skip_ws()
            if ip >= iend:
                return -1
            d2: uint8 = inst_buf[ip]
            if d2 == 44:
                ip = ip + 1
                continue
            if d2 == 125:
                ip = ip + 1
                return 0
            return -1
    return -1


def _inst_parse_strarr_files(idx_i: uint64) -> int32:
    _inst_skip_ws()
    if ip >= iend or inst_buf[ip] != 91:
        return -1
    ip = ip + 1
    inst_file_start[idx_i] = inst_file_n
    n: uint64 = 0
    _inst_skip_ws()
    if ip < iend and inst_buf[ip] == 93:
        ip = ip + 1
        inst_file_count[idx_i] = 0
        return 0
    while True:
        if inst_file_n >= 8192:
            write_str(2, "hpm: installed: file table overflow\n")
            return -1
        soff: uint64 = 0
        slen: uint64 = 0
        if _inst_parse_string(&soff, &slen) != 0:
            return -1
        inst_file_off[inst_file_n] = soff
        inst_file_len[inst_file_n] = slen
        inst_file_n = inst_file_n + 1
        n = n + 1
        _inst_skip_ws()
        if ip >= iend:
            return -1
        d: uint8 = inst_buf[ip]
        if d == 44:
            ip = ip + 1
            continue
        if d == 93:
            ip = ip + 1
            inst_file_count[idx_i] = n
            return 0
        return -1


def _inst_parse_pkg(i: uint64) -> int32:
    if _inst_expect(123) != 0:
        return -1
    inst_name_off[i] = 0
    inst_name_len[i] = 0
    inst_ver_off[i] = 0
    inst_ver_len[i] = 0
    inst_pinned[i] = 0
    inst_target_off[i] = 0
    inst_target_len[i] = 0
    inst_at_off[i] = 0
    inst_at_len[i] = 0
    inst_file_start[i] = 0
    inst_file_count[i] = 0

    _inst_skip_ws()
    if ip < iend and inst_buf[ip] == 125:
        ip = ip + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _inst_parse_string(&koff, &klen) != 0:
            return -1
        if _inst_expect(58) != 0:
            return -1
        kp: Ptr[uint8] = &inst_buf[koff]
        if klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("name"), 4) != 0:
            if _inst_parse_string(&inst_name_off[i], &inst_name_len[i]) != 0:
                return -1
        elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("version"), 7) != 0:
            if _inst_parse_string(&inst_ver_off[i], &inst_ver_len[i]) != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("pinned"), 6) != 0:
            # true / false literal — peek first char.
            _inst_skip_ws()
            if ip < iend and inst_buf[ip] == 116:        # 't'
                inst_pinned[i] = 1
            else:
                inst_pinned[i] = 0
            if _inst_skip_value() != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("target"), 6) != 0:
            if _inst_parse_string(&inst_target_off[i], &inst_target_len[i]) != 0:
                return -1
        elif klen == 12 and _streq_n(kp, cast[Ptr[uint8]]("installed_at"), 12) != 0:
            if _inst_parse_string(&inst_at_off[i], &inst_at_len[i]) != 0:
                return -1
        elif klen == 5 and _streq_n(kp, cast[Ptr[uint8]]("files"), 5) != 0:
            if _inst_parse_strarr_files(i) != 0:
                return -1
        else:
            if _inst_skip_value() != 0:
                return -1

        _inst_skip_ws()
        if ip >= iend:
            return -1
        d: uint8 = inst_buf[ip]
        if d == 44:
            ip = ip + 1
            continue
        if d == 125:
            ip = ip + 1
            return 0
        return -1


def _load_installed() -> int32:
    # Returns 0 on a parsed DB (which may be empty),
    # 1 on absent file (treated as "no packages installed yet").
    inst_count = 0
    inst_file_n = 0
    fd: int32 = sys_open("/var/lib/hpm/installed.json")
    if fd < 0:
        return 1
    total: uint64 = 0
    while total < INSTALLED_CAP:
        room: uint64 = INSTALLED_CAP - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&inst_buf[0]) + total), room)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    inst_len = total
    if total == 0:
        return 1                                          # empty DB

    ip = 0
    iend = inst_len
    if _inst_expect(123) != 0:
        write_str(2, "hpm: installed.json: top-level is not an object\n")
        return -1
    _inst_skip_ws()
    if ip < iend and inst_buf[ip] == 125:
        ip = ip + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _inst_parse_string(&koff, &klen) != 0:
            write_str(2, "hpm: installed.json: malformed key\n")
            return -1
        if _inst_expect(58) != 0:
            return -1
        kp: Ptr[uint8] = &inst_buf[koff]
        if klen == 8 and _streq_n(kp, cast[Ptr[uint8]]("packages"), 8) != 0:
            _inst_skip_ws()
            if ip >= iend or inst_buf[ip] != 91:
                write_str(2, "hpm: installed.json: packages is not array\n")
                return -1
            ip = ip + 1
            _inst_skip_ws()
            if ip < iend and inst_buf[ip] == 93:
                ip = ip + 1
            else:
                while True:
                    if inst_count >= 256:
                        write_str(2, "hpm: installed.json: too many packages\n")
                        return -1
                    if _inst_parse_pkg(inst_count) != 0:
                        return -1
                    inst_count = inst_count + 1
                    _inst_skip_ws()
                    if ip >= iend:
                        return -1
                    d: uint8 = inst_buf[ip]
                    if d == 44:
                        ip = ip + 1
                        continue
                    if d == 93:
                        ip = ip + 1
                        break
                    return -1
        else:
            if _inst_skip_value() != 0:
                return -1

        _inst_skip_ws()
        if ip >= iend:
            return -1
        d2: uint8 = inst_buf[ip]
        if d2 == 44:
            ip = ip + 1
            continue
        if d2 == 125:
            ip = ip + 1
            return 0
        return -1


# -- pretty-print helpers (write a span from idx_buf or inst_buf) -----

def _write_span(fd: int32, base: Ptr[uint8], off: uint64, ln: uint64):
    if ln == 0:
        return
    sys_write(fd, cast[Ptr[uint8]](cast[uint64](base) + off), ln)


# -- commands: list / search / show -----------------------------------

def cmd_list() -> int32:
    rc: int32 = _load_installed()
    if rc < 0:
        return 1
    if rc == 1 or inst_count == 0:
        write_str(1, "hpm: no packages installed\n")
        return 0
    i: uint64 = 0
    while i < inst_count:
        # "<name>  <version>  [pinned]  <target>"
        _write_span(1, &inst_buf[0], inst_name_off[i], inst_name_len[i])
        sys_write(1, "  ", 2)
        _write_span(1, &inst_buf[0], inst_ver_off[i], inst_ver_len[i])
        sys_write(1, "  ", 2)
        if inst_pinned[i] != 0:
            sys_write(1, "[pinned]  ", 10)
        if inst_target_len[i] > 0:
            _write_span(1, &inst_buf[0], inst_target_off[i],
                        inst_target_len[i])
        else:
            sys_write(1, "#hamnix-system", 14)
        sys_write(1, "\n", 1)
        i = i + 1
    return 0


def cmd_search(pattern: Ptr[uint8]) -> int32:
    # Substring match against pkg_name spans. Requires a refreshed cache.
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    # Materialise the pattern as a NUL-terminated cstring already (it
    # came from argv). For each package, copy name to a scratch cstring
    # and substring-match. We use a scratch buf.
    matched: uint64 = 0
    namescratch: Array[128, uint8]
    i: uint64 = 0
    while i < pkg_count:
        ln: uint64 = pkg_name_len[i]
        _strcopy_n(&namescratch[0],
                   cast[Ptr[uint8]](
                       cast[uint64](&idx_buf[0]) + pkg_name_off[i]),
                   ln, 128)
        if _strcontains(&namescratch[0], pattern) != 0:
            _write_span(1, &idx_buf[0], pkg_name_off[i], pkg_name_len[i])
            sys_write(1, "  ", 2)
            _write_span(1, &idx_buf[0], pkg_version_off[i], pkg_version_len[i])
            sys_write(1, "  -  ", 5)
            _write_span(1, &idx_buf[0], pkg_desc_off[i], pkg_desc_len[i])
            sys_write(1, "\n", 1)
            matched = matched + 1
        i = i + 1
    if matched == 0:
        write_str(2, "hpm: no packages match \"")
        write_str(2, pattern)
        write_str(2, "\"\n")
        return 1
    return 0


def _name_eq_span(off: uint64, ln: uint64, want: Ptr[uint8],
                  want_len: uint64) -> int32:
    if ln != want_len:
        return 0
    i: uint64 = 0
    while i < ln:
        if idx_buf[off + i] != want[i]:
            return 0
        i = i + 1
    return 1


def _ver_eq_span(off: uint64, ln: uint64, want: Ptr[uint8],
                 want_len: uint64) -> int32:
    if ln != want_len:
        return 0
    i: uint64 = 0
    while i < ln:
        if idx_buf[off + i] != want[i]:
            return 0
        i = i + 1
    return 1


# -- version comparison (per docs/packages.md) ------------------------
#
# Dotted-decimal tuples; each component compared as an integer; missing
# components treated as zero. Optional `+<tag>` is build metadata and
# IGNORED for ordering. Returns: -1 if a<b, 0 if a==b, 1 if a>b.

def _vcomp_at(s: Ptr[uint8], n: uint64, p: Ptr[uint64]) -> uint64:
    # Parse one decimal component starting at *p (advances past it).
    # Stops at '.', '+', or end. Returns the integer value.
    v: uint64 = 0
    while p[0] < n:
        c: uint8 = s[p[0]]
        if c == 46 or c == 43:                           # '.' or '+'
            return v
        if c < 48 or c > 57:
            return v
        v = v * 10 + cast[uint64](c - 48)
        p[0] = p[0] + 1
    return v


def _version_compare(a: Ptr[uint8], an: uint64,
                     b: Ptr[uint8], bn: uint64) -> int32:
    # Strip everything from '+' on (build metadata).
    ae: uint64 = 0
    while ae < an and a[ae] != 43:
        ae = ae + 1
    be: uint64 = 0
    while be < bn and b[be] != 43:
        be = be + 1
    ap: uint64 = 0
    bp: uint64 = 0
    while ap < ae or bp < be:
        av: uint64 = 0
        bv: uint64 = 0
        if ap < ae:
            av = _vcomp_at(a, ae, &ap)
        if bp < be:
            bv = _vcomp_at(b, be, &bp)
        if av < bv:
            return -1
        if av > bv:
            return 1
        # Skip the separator '.'.
        if ap < ae and a[ap] == 46:
            ap = ap + 1
        if bp < be and b[bp] == 46:
            bp = bp + 1
    return 0


# Return the index of the best (highest version) package whose name
# equals `want`. Returns -1 if no such package.
def _pkg_find_best(want: Ptr[uint8], want_len: uint64) -> int64:
    best: int64 = -1
    i: uint64 = 0
    while i < pkg_count:
        if _name_eq_span(pkg_name_off[i], pkg_name_len[i],
                         want, want_len) != 0:
            if best < 0:
                best = cast[int64](i)
            else:
                bi: uint64 = cast[uint64](best)
                cmp: int32 = _version_compare(
                    cast[Ptr[uint8]](
                        cast[uint64](&idx_buf[0]) + pkg_version_off[i]),
                    pkg_version_len[i],
                    cast[Ptr[uint8]](
                        cast[uint64](&idx_buf[0]) + pkg_version_off[bi]),
                    pkg_version_len[bi])
                if cmp > 0:
                    best = cast[int64](i)
        i = i + 1
    return best


# Find a package by exact name+version. Returns -1 if not found.
def _pkg_find_exact(want: Ptr[uint8], want_len: uint64,
                    wver: Ptr[uint8], wver_len: uint64) -> int64:
    i: uint64 = 0
    while i < pkg_count:
        if _name_eq_span(pkg_name_off[i], pkg_name_len[i],
                         want, want_len) != 0:
            if _ver_eq_span(pkg_version_off[i], pkg_version_len[i],
                            wver, wver_len) != 0:
                return cast[int64](i)
        i = i + 1
    return -1


# -- show <name>[@<version>] ------------------------------------------

def _split_nameversion(spec: Ptr[uint8],
                       name_out: Ptr[uint8], name_cap: uint64,
                       ver_out: Ptr[uint8], ver_cap: uint64,
                       has_ver: Ptr[int32]):
    # Split on '@'. spec is a NUL-terminated cstring.
    has_ver[0] = 0
    name_out[0] = 0
    ver_out[0] = 0
    no: uint64 = 0
    i: uint64 = 0
    while spec[i] != 0 and spec[i] != 64 and no + 1 < name_cap:    # '@'
        name_out[no] = spec[i]
        no = no + 1
        i = i + 1
    name_out[no] = 0
    if spec[i] == 64:
        has_ver[0] = 1
        i = i + 1
        vo: uint64 = 0
        while spec[i] != 0 and vo + 1 < ver_cap:
            ver_out[vo] = spec[i]
            vo = vo + 1
            i = i + 1
        ver_out[vo] = 0


def cmd_show(spec: Ptr[uint8]) -> int32:
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    name_buf: Array[128, uint8]
    ver_buf:  Array[64, uint8]
    has_ver:  int32 = 0
    _split_nameversion(spec, &name_buf[0], 128, &ver_buf[0], 64, &has_ver)

    idx: int64 = -1
    if has_ver != 0:
        idx = _pkg_find_exact(&name_buf[0], strlen_u8(&name_buf[0]),
                              &ver_buf[0], strlen_u8(&ver_buf[0]))
    else:
        idx = _pkg_find_best(&name_buf[0], strlen_u8(&name_buf[0]))
    if idx < 0:
        write_str(2, "hpm: no package matches \"")
        write_str(2, spec)
        write_str(2, "\"\n")
        return 1
    pi: uint64 = cast[uint64](idx)

    write_str(1, "name: ")
    _write_span(1, &idx_buf[0], pkg_name_off[pi], pkg_name_len[pi])
    write_str(1, "\nversion: ")
    _write_span(1, &idx_buf[0], pkg_version_off[pi], pkg_version_len[pi])
    write_str(1, "\narch: ")
    _write_span(1, &idx_buf[0], pkg_arch_off[pi], pkg_arch_len[pi])
    write_str(1, "\ntarget: ")
    if pkg_target_len[pi] > 0:
        _write_span(1, &idx_buf[0], pkg_target_off[pi], pkg_target_len[pi])
    else:
        sys_write(1, "#hamnix-system", 14)
    write_str(1, "\ndescription: ")
    _write_span(1, &idx_buf[0], pkg_desc_off[pi], pkg_desc_len[pi])
    write_str(1, "\nurl: ")
    _write_span(1, &idx_buf[0], pkg_url_off[pi], pkg_url_len[pi])
    write_str(1, "\nsha256: ")
    _write_span(1, &idx_buf[0], pkg_sha256_off[pi], pkg_sha256_len[pi])
    write_str(1, "\nsize: ")
    write_dec_u64(1, pkg_size[pi])
    write_str(1, " bytes\n")
    if pkg_dep_count[pi] > 0:
        write_str(1, "depends:")
        di: uint64 = 0
        while di < pkg_dep_count[pi]:
            sys_write(1, " ", 1)
            slot: uint64 = pkg_dep_start[pi] + di
            _write_span(1, &idx_buf[0],
                        dep_entry_off[slot], dep_entry_len[slot])
            di = di + 1
        sys_write(1, "\n", 1)
    if pkg_conf_count[pi] > 0:
        write_str(1, "conflicts:")
        ci: uint64 = 0
        while ci < pkg_conf_count[pi]:
            sys_write(1, " ", 1)
            slot: uint64 = pkg_conf_start[pi] + ci
            _write_span(1, &idx_buf[0],
                        conf_entry_off[slot], conf_entry_len[slot])
            ci = ci + 1
        sys_write(1, "\n", 1)
    if pkg_prov_count[pi] > 0:
        write_str(1, "provides:")
        ri: uint64 = 0
        while ri < pkg_prov_count[pi]:
            sys_write(1, " ", 1)
            slot: uint64 = pkg_prov_start[pi] + ri
            _write_span(1, &idx_buf[0],
                        prov_entry_off[slot], prov_entry_len[slot])
            ri = ri + 1
        sys_write(1, "\n", 1)
    return 0


# =====================================================================
# Phase 2: install (trivial case — no deps, no hooks)
# =====================================================================
#
# The trivial-install flow:
#   1. Resolve <name>[@<ver>] against the cached index.
#   2. fetch_to_buf -> deb_buf (the tarball).
#   3. Verify SHA-256 of deb_buf == repo's recorded sha256.
#   4. Inflate the .tar.gz into tar_buf.
#   5. Walk the tar:
#        - The top-level entry is "<name>-<version>/" (per spec).
#        - Other entries we care about: "<dir>/PKGINFO",
#          "<dir>/install.hamsh", "<dir>/files/...".
#        - For each "files/<rel>" entry, place the bytes at the target
#          path (#hamnix-system = init's writable area = root; #distro =
#          /var/lib/distros/default/; #other = treat as #hamnix-system
#          for v1 — see escalation note in the brief).
#   6. Record in installed.json (in-memory append + atomic rewrite).
#   7. Phase 3 wires real hooks; for now: if install.hamsh is present,
#      print "[hpm] hook would run: install.hamsh" so the test can
#      verify the path.
#
# Conflict & dep handling are Phase 3+. This commit only handles the
# happy path of a no-dep, no-conflict package against an empty (or
# non-overlapping) installed.json — exactly the live `hamnix-hello`.

# -- SHA-256 ------------------------------------------------------------
#
# Ported in-line from user/apt.ad (now retired). Same algorithm,
# same incremental reset/update/final API for streaming-friendly
# verification. Operates on the running sha_* BSS state.

sha_state:    Array[8, uint32]
sha_k:        Array[64, uint32]
sha_w:        Array[64, uint32]
sha_block:    Array[64, uint8]
sha_block_n:  uint64 = 0
sha_total:    uint64 = 0
sha_digest:   Array[32, uint8]
sha_hex:      Array[80, uint8]


def _sha256_rotr32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = x >> n
    hi: uint64 = (x << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


def _sha256_init_k():
    sha_k[0]  = 0x428A2F98
    sha_k[1]  = 0x71374491
    sha_k[2]  = 0xB5C0FBCF
    sha_k[3]  = 0xE9B5DBA5
    sha_k[4]  = 0x3956C25B
    sha_k[5]  = 0x59F111F1
    sha_k[6]  = 0x923F82A4
    sha_k[7]  = 0xAB1C5ED5
    sha_k[8]  = 0xD807AA98
    sha_k[9]  = 0x12835B01
    sha_k[10] = 0x243185BE
    sha_k[11] = 0x550C7DC3
    sha_k[12] = 0x72BE5D74
    sha_k[13] = 0x80DEB1FE
    sha_k[14] = 0x9BDC06A7
    sha_k[15] = 0xC19BF174
    sha_k[16] = 0xE49B69C1
    sha_k[17] = 0xEFBE4786
    sha_k[18] = 0x0FC19DC6
    sha_k[19] = 0x240CA1CC
    sha_k[20] = 0x2DE92C6F
    sha_k[21] = 0x4A7484AA
    sha_k[22] = 0x5CB0A9DC
    sha_k[23] = 0x76F988DA
    sha_k[24] = 0x983E5152
    sha_k[25] = 0xA831C66D
    sha_k[26] = 0xB00327C8
    sha_k[27] = 0xBF597FC7
    sha_k[28] = 0xC6E00BF3
    sha_k[29] = 0xD5A79147
    sha_k[30] = 0x06CA6351
    sha_k[31] = 0x14292967
    sha_k[32] = 0x27B70A85
    sha_k[33] = 0x2E1B2138
    sha_k[34] = 0x4D2C6DFC
    sha_k[35] = 0x53380D13
    sha_k[36] = 0x650A7354
    sha_k[37] = 0x766A0ABB
    sha_k[38] = 0x81C2C92E
    sha_k[39] = 0x92722C85
    sha_k[40] = 0xA2BFE8A1
    sha_k[41] = 0xA81A664B
    sha_k[42] = 0xC24B8B70
    sha_k[43] = 0xC76C51A3
    sha_k[44] = 0xD192E819
    sha_k[45] = 0xD6990624
    sha_k[46] = 0xF40E3585
    sha_k[47] = 0x106AA070
    sha_k[48] = 0x19A4C116
    sha_k[49] = 0x1E376C08
    sha_k[50] = 0x2748774C
    sha_k[51] = 0x34B0BCB5
    sha_k[52] = 0x391C0CB3
    sha_k[53] = 0x4ED8AA4A
    sha_k[54] = 0x5B9CCA4F
    sha_k[55] = 0x682E6FF3
    sha_k[56] = 0x748F82EE
    sha_k[57] = 0x78A5636F
    sha_k[58] = 0x84C87814
    sha_k[59] = 0x8CC70208
    sha_k[60] = 0x90BEFFFA
    sha_k[61] = 0xA4506CEB
    sha_k[62] = 0xBEF9A3F7
    sha_k[63] = 0xC67178F2


def _sha256_compress():
    i: uint64 = 0
    while i < 16:
        b0: uint32 = cast[uint32](sha_block[i * 4 + 0])
        b1: uint32 = cast[uint32](sha_block[i * 4 + 1])
        b2: uint32 = cast[uint32](sha_block[i * 4 + 2])
        b3: uint32 = cast[uint32](sha_block[i * 4 + 3])
        sha_w[i] = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        i = i + 1
    while i < 64:
        s0: uint32 = _sha256_rotr32(sha_w[i - 15], 7) \
            ^ _sha256_rotr32(sha_w[i - 15], 18) \
            ^ (sha_w[i - 15] >> 3)
        s1: uint32 = _sha256_rotr32(sha_w[i - 2], 17) \
            ^ _sha256_rotr32(sha_w[i - 2], 19) \
            ^ (sha_w[i - 2] >> 10)
        sum_v: uint64 = (cast[uint64](sha_w[i - 16]) & 0xFFFFFFFF) \
            + (cast[uint64](s0) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i - 7]) & 0xFFFFFFFF) \
            + (cast[uint64](s1) & 0xFFFFFFFF)
        sha_w[i] = cast[uint32](sum_v & 0xFFFFFFFF)
        i = i + 1

    a: uint32 = sha_state[0]
    b: uint32 = sha_state[1]
    c: uint32 = sha_state[2]
    d: uint32 = sha_state[3]
    e: uint32 = sha_state[4]
    f: uint32 = sha_state[5]
    g: uint32 = sha_state[6]
    h: uint32 = sha_state[7]
    i = 0
    while i < 64:
        S1: uint32 = _sha256_rotr32(e, 6) ^ _sha256_rotr32(e, 11) \
            ^ _sha256_rotr32(e, 25)
        ch: uint32 = (e & f) ^ ((~e) & g)
        t1_64: uint64 = (cast[uint64](h) & 0xFFFFFFFF) \
            + (cast[uint64](S1) & 0xFFFFFFFF) \
            + (cast[uint64](ch) & 0xFFFFFFFF) \
            + (cast[uint64](sha_k[i]) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i]) & 0xFFFFFFFF)
        t1: uint32 = cast[uint32](t1_64 & 0xFFFFFFFF)
        S0: uint32 = _sha256_rotr32(a, 2) ^ _sha256_rotr32(a, 13) \
            ^ _sha256_rotr32(a, 22)
        maj: uint32 = (a & b) ^ (a & c) ^ (b & c)
        t2_64: uint64 = (cast[uint64](S0) & 0xFFFFFFFF) \
            + (cast[uint64](maj) & 0xFFFFFFFF)
        t2: uint32 = cast[uint32](t2_64 & 0xFFFFFFFF)
        h = g
        g = f
        f = e
        d64: uint64 = (cast[uint64](d) & 0xFFFFFFFF) \
            + (cast[uint64](t1) & 0xFFFFFFFF)
        e = cast[uint32](d64 & 0xFFFFFFFF)
        d = c
        c = b
        b = a
        a64: uint64 = (cast[uint64](t1) & 0xFFFFFFFF) \
            + (cast[uint64](t2) & 0xFFFFFFFF)
        a = cast[uint32](a64 & 0xFFFFFFFF)
        i = i + 1

    sum_0: uint64 = cast[uint64](sha_state[0]) + cast[uint64](a)
    sum_1: uint64 = cast[uint64](sha_state[1]) + cast[uint64](b)
    sum_2: uint64 = cast[uint64](sha_state[2]) + cast[uint64](c)
    sum_3: uint64 = cast[uint64](sha_state[3]) + cast[uint64](d)
    sum_4: uint64 = cast[uint64](sha_state[4]) + cast[uint64](e)
    sum_5: uint64 = cast[uint64](sha_state[5]) + cast[uint64](f)
    sum_6: uint64 = cast[uint64](sha_state[6]) + cast[uint64](g)
    sum_7: uint64 = cast[uint64](sha_state[7]) + cast[uint64](h)
    sha_state[0] = cast[uint32](sum_0 & 0xFFFFFFFF)
    sha_state[1] = cast[uint32](sum_1 & 0xFFFFFFFF)
    sha_state[2] = cast[uint32](sum_2 & 0xFFFFFFFF)
    sha_state[3] = cast[uint32](sum_3 & 0xFFFFFFFF)
    sha_state[4] = cast[uint32](sum_4 & 0xFFFFFFFF)
    sha_state[5] = cast[uint32](sum_5 & 0xFFFFFFFF)
    sha_state[6] = cast[uint32](sum_6 & 0xFFFFFFFF)
    sha_state[7] = cast[uint32](sum_7 & 0xFFFFFFFF)


def _sha256_reset():
    _sha256_init_k()
    sha_state[0] = 0x6A09E667
    sha_state[1] = 0xBB67AE85
    sha_state[2] = 0x3C6EF372
    sha_state[3] = 0xA54FF53A
    sha_state[4] = 0x510E527F
    sha_state[5] = 0x9B05688C
    sha_state[6] = 0x1F83D9AB
    sha_state[7] = 0x5BE0CD19
    sha_block_n = 0
    sha_total = 0


def _sha256_update(data: Ptr[uint8], n: uint64):
    pos: uint64 = 0
    while pos < n:
        room: uint64 = 64 - sha_block_n
        take: uint64 = n - pos
        if take > room:
            take = room
        i: uint64 = 0
        while i < take:
            sha_block[sha_block_n + i] = data[pos + i]
            i = i + 1
        sha_block_n = sha_block_n + take
        pos = pos + take
        if sha_block_n == 64:
            _sha256_compress()
            sha_block_n = 0
    sha_total = sha_total + n


def _sha256_final():
    buflen: uint64 = sha_block_n
    sha_block[buflen] = 0x80
    buflen = buflen + 1
    if buflen > 56:
        while buflen < 64:
            sha_block[buflen] = 0
            buflen = buflen + 1
        _sha256_compress()
        buflen = 0
    while buflen < 56:
        sha_block[buflen] = 0
        buflen = buflen + 1
    total_bits: uint64 = sha_total * 8
    j: uint64 = 0
    while j < 8:
        shift: uint64 = (7 - j) * 8
        sha_block[56 + j] = cast[uint8]((total_bits >> shift) & 0xFF)
        j = j + 1
    _sha256_compress()

    hexd: Ptr[uint8] = "0123456789abcdef"
    k: uint64 = 0
    while k < 8:
        w: uint32 = sha_state[k]
        sha_digest[k * 4 + 0] = cast[uint8]((w >> 24) & 0xFF)
        sha_digest[k * 4 + 1] = cast[uint8]((w >> 16) & 0xFF)
        sha_digest[k * 4 + 2] = cast[uint8]((w >> 8) & 0xFF)
        sha_digest[k * 4 + 3] = cast[uint8](w & 0xFF)
        k = k + 1
    m: uint64 = 0
    while m < 32:
        byte_v: uint8 = sha_digest[m]
        sha_hex[m * 2 + 0] = hexd[cast[uint64]((byte_v >> 4) & 0x0F)]
        sha_hex[m * 2 + 1] = hexd[cast[uint64](byte_v & 0x0F)]
        m = m + 1
    sha_hex[64] = 0


def _sha256_hash_buf(data: Ptr[uint8], n: uint64):
    _sha256_reset()
    _sha256_update(data, n)
    _sha256_final()


# -- tarball inflate ---------------------------------------------------
#
# Inflate deb_buf[0..deb_len) (a .tar.gz) into tar_buf. One-shot —
# the package is bounded by TARBALL_CAP (4 MiB) and the inflated tar
# by TAR_CAP (8 MiB), big enough for any reasonable Hamnix package's
# `files/` tree. Returns the inflated length on success, -1 on error.

inf_state: InflateState


def _inflate_tarball(deb_len: uint64) -> int64:
    inflate_init(&inf_state)
    out_consumed: uint64 = 0
    in_consumed: uint64 = 0
    done: int32 = 0
    rc: int32 = inflate_feed(&inf_state, &deb_buf[0], deb_len,
                             &tar_buf[0], TAR_CAP,
                             &out_consumed, &in_consumed, &done)
    if rc < 0:
        write_str(2, "hpm: gzip inflate failed (corrupt tarball?)\n")
        return -1
    if done == 0:
        write_str(2, "hpm: gzip inflate did not reach EOS (tarball too large?)\n")
        return -1
    return cast[int64](out_consumed)


# -- ustar tar walker --------------------------------------------------
#
# Same shape as user/dpkg_deb.ad's tar parser (now retired). 512-byte
# header layout; we only need:
#   [0..100)   name (NUL-terminated, max 100 chars)
#   [124..136) size (octal, up to 11 octal digits + NUL)
#   [148..156) chksum (octal, verified)
#   [156]      typeflag ('0' regular, '5' dir; everything else is
#              skipped with a warning)

def _tar_parse_octal(p: Ptr[uint8], maxlen: uint64) -> uint64:
    n: uint64 = 0
    i: uint64 = 0
    while i < maxlen and p[i] == 32:
        i = i + 1
    while i < maxlen:
        c: uint8 = p[i]
        if c == 0 or c == 32:
            break
        if c < 48 or c > 55:
            break
        n = (n << 3) + cast[uint64](c - 48)
        i = i + 1
    return n


def _tar_chksum_ok(hdr: Ptr[uint8]) -> int32:
    stored: uint64 = _tar_parse_octal(&hdr[148], 8)
    s: uint64 = 0
    i: uint64 = 0
    while i < 512:
        if i >= 148 and i < 156:
            s = s + 32
        else:
            s = s + cast[uint64](hdr[i])
        i = i + 1
    if s == stored:
        return 1
    return 0


def _tar_header_is_zero(hdr: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while i < 512:
        if hdr[i] != 0:
            return 0
        i = i + 1
    return 1


def _name_copy_nul(dst: Ptr[uint8], src: Ptr[uint8], maxlen: uint64) -> uint64:
    i: uint64 = 0
    while i < maxlen:
        c: uint8 = src[i]
        if c == 0:
            break
        dst[i] = c
        i = i + 1
    dst[i] = 0
    return i


def _entry_name_is_unsafe(name: Ptr[uint8]) -> int32:
    # Reject absolute paths + '..' components (the standard dpkg
    # path-traversal guard). Operates on a NUL-terminated string.
    if name[0] == 47:
        return 1
    i: uint64 = 0
    while True:
        if name[i] == 46 and name[i + 1] == 46:
            t: uint8 = name[i + 2]
            if t == 0 or t == 47:
                return 1
        while name[i] != 0 and name[i] != 47:
            i = i + 1
        if name[i] == 0:
            return 0
        while name[i] == 47:
            i = i + 1
        if name[i] == 0:
            return 0


# -- install: package + extraction state ------------------------------

# The package's tarball name is "<name>-<version>.tar.gz"; the top-
# level directory inside the tarball is "<name>-<version>/" (per
# docs/packages.md). We strip that prefix when classifying entries.

pkg_prefix_buf:   Array[128, uint8]      # "<name>-<version>/" + NUL
pkg_prefix_len:   uint64 = 0

# Decoded PKGINFO fields for the package being installed. Populated
# by _read_pkginfo_in_tar. v1 only USES some of these (name, version,
# target, arch); deps/conflicts come from the INDEX, not PKGINFO,
# during install (the spec keys both off the index entry).

pi_name:      Array[64, uint8]
pi_version:   Array[64, uint8]
pi_arch:      Array[32, uint8]
pi_target:    Array[128, uint8]
pi_have:      int32 = 0


# Scratch buffers used during extraction.
extract_path_buf: Array[1024, uint8]     # full target path for sys_open_write
warn_buf:         Array[256, uint8]      # entry name copy for messages

# Per-install installed-file record. Each "files/<rel>" entry we
# write is recorded so install.json's `files` array can list them in
# install order (`hpm remove` deletes in reverse).
INST_FILES_PER_PKG: uint64 = 1024
new_files_off:    Array[1024, uint64]    # offset into new_files_buf
new_files_len:    Array[1024, uint64]
new_files_n:      uint64 = 0
new_files_buf:    Array[131072, uint8]    # flat backing store
new_files_buf_n:  uint64 = 0


def _new_files_reset():
    new_files_n = 0
    new_files_buf_n = 0


def _new_files_record(rel_path: Ptr[uint8], rel_len: uint64) -> int32:
    # Append rel_path[0..rel_len) into new_files_buf, record offset+len.
    # Returns 0 on success, -1 on overflow.
    if new_files_n >= 1024:
        write_str(2, "hpm: per-package file table overflow\n")
        return -1
    if new_files_buf_n + rel_len + 1 > 131072:
        write_str(2, "hpm: per-package file-name store overflow\n")
        return -1
    new_files_off[new_files_n] = new_files_buf_n
    new_files_len[new_files_n] = rel_len
    i: uint64 = 0
    while i < rel_len:
        new_files_buf[new_files_buf_n + i] = rel_path[i]
        i = i + 1
    new_files_buf_n = new_files_buf_n + rel_len
    new_files_n = new_files_n + 1
    return 0


# -- target resolution -------------------------------------------------
#
# Map a target tag (`#hamnix-system` / `#distro` / `#<other>`) to a
# filesystem prefix that prepends to "files/<rel>". v1 covers the two
# baked-in targets explicitly; `#<other>` is treated as `#hamnix-system`
# with a stderr note (the spec says `#<new-word>` registration needs
# kernel-side name-table writes that don't yet have a userland API —
# see the brief's escalation note).

target_prefix_buf: Array[256, uint8]


def _set_target_prefix(target: Ptr[uint8], target_len: uint64) -> int32:
    # If target_len==0 OR target is "#hamnix-system", prefix == "/".
    # If target is "#distro", prefix == "/var/lib/distros/default/".
    # Anything else is treated as #hamnix-system with a warning.
    if target_len == 0:
        target_prefix_buf[0] = 47                        # '/'
        target_prefix_buf[1] = 0
        return 0
    hs: Ptr[uint8] = "#hamnix-system"
    if target_len == 14 and _streq_n(target, hs, 14) != 0:
        target_prefix_buf[0] = 47
        target_prefix_buf[1] = 0
        return 0
    ds: Ptr[uint8] = "#distro"
    if target_len == 7 and _streq_n(target, ds, 7) != 0:
        # /var/lib/distros/default/ — the canonical distro tree.
        s: Ptr[uint8] = "/var/lib/distros/default/"
        i: uint64 = 0
        while s[i] != 0:
            target_prefix_buf[i] = s[i]
            i = i + 1
        target_prefix_buf[i] = 0
        return 0
    # Unknown target — warn, fall back to #hamnix-system. v2 will wire
    # the .hamnix-roots sentinel write + kernel name_push.
    write_str(2, "hpm: warning: unknown target `")
    sys_write(2, target, target_len)
    write_str(2, "` — treating as #hamnix-system (see docs/packages.md)\n")
    target_prefix_buf[0] = 47
    target_prefix_buf[1] = 0
    return 0


# -- mkdir -p (recursive) ----------------------------------------------
#
# tmpfs_mkdir requires parents to already exist. For an entry like
# `files/bin/foo`, the target path becomes `/bin/foo` (under
# #hamnix-system), and `/bin` must be mkdir'd first. We walk the
# dirname, mkdir'ing each prefix; -EEXIST is treated as success.

mkdir_buf: Array[1024, uint8]


def _mkdir_p(path: Ptr[uint8]):
    # Walk path component-by-component, mkdir'ing each prefix.
    # Skips the leading "/" component.
    i: uint64 = 0
    while path[i] != 0:
        if i > 0 and path[i] == 47:
            # Copy prefix into mkdir_buf and mkdir it.
            j: uint64 = 0
            while j < i:
                mkdir_buf[j] = path[j]
                j = j + 1
            mkdir_buf[i] = 0
            sys_mkdir(cast[Ptr[char]](&mkdir_buf[0]))
        i = i + 1


def _dirname_mkdir_p(path: Ptr[uint8]):
    # Mkdir all parent directories of `path` (stop before the last
    # component). Cheap: walks once.
    last_slash: int64 = -1
    i: uint64 = 0
    while path[i] != 0:
        if path[i] == 47:
            last_slash = cast[int64](i)
        i = i + 1
    if last_slash <= 0:
        return
    # Mkdir each prefix up to last_slash.
    p: int64 = 1
    while p <= last_slash:
        if path[cast[uint64](p)] == 47:
            j: uint64 = 0
            while j < cast[uint64](p):
                mkdir_buf[j] = path[j]
                j = j + 1
            mkdir_buf[cast[uint64](p)] = 0
            sys_mkdir(cast[Ptr[char]](&mkdir_buf[0]))
        p = p + 1
    # Final mkdir of the dirname itself.
    j2: uint64 = 0
    while j2 < cast[uint64](last_slash):
        mkdir_buf[j2] = path[j2]
        j2 = j2 + 1
    mkdir_buf[cast[uint64](last_slash)] = 0
    sys_mkdir(cast[Ptr[char]](&mkdir_buf[0]))


# -- staging-dir extraction --------------------------------------------
#
# The tarball gets staged at /tmp/hpm/staging/. We extract it there
# wholesale (so hooks can see PKGINFO + the files/ tree), then walk
# the staged tree to copy files/ to the target. Two-phase keeps hook
# execution clean (HPM_PKG_DIR points at a real, complete tree).
#
# v1 trims a corner: the staging dir AND the target install are done
# by walking the in-RAM tar once and writing each entry to its final
# location. That's simpler than a two-phase, costs nothing in
# correctness for the trivial-case install, and matches what
# dpkg-deb -x does. The "staging dir for hooks" path is materialised
# in Phase 3 (when hooks need a real HPM_PKG_DIR).

# For Phase 2 we still need to read PKGINFO and (if present) note
# install.hamsh — both straight from the inflated tar in RAM, no
# write to disk.

def _read_pkginfo_from_tar(tar_len: uint64) -> int32:
    # Walk tar_buf[0..tar_len) looking for "<pkg_prefix>PKGINFO".
    # Populates pi_name / pi_version / pi_arch / pi_target. Returns
    # 0 on success, -1 if PKGINFO missing or malformed.
    pi_name[0] = 0
    pi_version[0] = 0
    pi_arch[0] = 0
    pi_target[0] = 0
    pi_have = 0

    off: uint64 = 0
    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            break
        if _tar_chksum_ok(hdr) == 0:
            return -1
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        body_blocks: uint64 = (size + 511) / 512

        # Get the entry name into warn_buf.
        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)
        # We're looking for "<prefix>PKGINFO".
        mch: int32 = 1
        if nlen != pkg_prefix_len + 7:
            mch = 0
        if mch != 0:
            i: uint64 = 0
            while i < pkg_prefix_len:
                if warn_buf[i] != pkg_prefix_buf[i]:
                    mch = 0
                    break
                i = i + 1
            if mch != 0:
                pkginfo_tail: Ptr[uint8] = "PKGINFO"
                j: uint64 = 0
                while j < 7:
                    if warn_buf[pkg_prefix_len + j] != pkginfo_tail[j]:
                        mch = 0
                        break
                    j = j + 1
        if mch != 0:
            body_off: uint64 = off + 512
            if body_off + size > tar_len:
                return -1
            # Parse the PKGINFO body: key: value pairs, one per line.
            p: uint64 = body_off
            end: uint64 = body_off + size
            while p < end:
                # Find end of line.
                lend: uint64 = p
                while lend < end and tar_buf[lend] != 10:
                    lend = lend + 1
                # Trim CR.
                vend: uint64 = lend
                if vend > p and tar_buf[vend - 1] == 13:
                    vend = vend - 1
                # Skip blank / comment lines.
                if p == vend or tar_buf[p] == 35:
                    p = lend + 1
                    continue
                # Continuation lines (start with whitespace) — v1
                # ignores them; our keys all fit on one line.
                if tar_buf[p] == 32 or tar_buf[p] == 9:
                    p = lend + 1
                    continue
                # Find ':'.
                cp: uint64 = p
                while cp < vend and tar_buf[cp] != 58:
                    cp = cp + 1
                if cp >= vend:
                    p = lend + 1
                    continue
                # key span = [p, cp), value span = [cp+1, vend) skipping
                # leading whitespace.
                vp: uint64 = cp + 1
                while vp < vend and (tar_buf[vp] == 32 or tar_buf[vp] == 9):
                    vp = vp + 1
                klen: uint64 = cp - p
                kp: Ptr[uint8] = &tar_buf[p]
                vp2: Ptr[uint8] = &tar_buf[vp]
                vlen: uint64 = vend - vp
                if klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("name"), 4) != 0:
                    _strcopy_n(&pi_name[0], vp2, vlen, 64)
                elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("version"), 7) != 0:
                    _strcopy_n(&pi_version[0], vp2, vlen, 64)
                elif klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("arch"), 4) != 0:
                    _strcopy_n(&pi_arch[0], vp2, vlen, 32)
                elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("target"), 6) != 0:
                    _strcopy_n(&pi_target[0], vp2, vlen, 128)
                p = lend + 1
            pi_have = 1
            return 0

        off = off + 512 + body_blocks * 512
    write_str(2, "hpm: PKGINFO not found in tarball\n")
    return -1


def _has_entry_in_tar(tar_len: uint64, tail: Ptr[uint8]) -> int32:
    # True if "<pkg_prefix><tail>" is present as a regular file entry.
    tail_len: uint64 = strlen_u8(tail)
    off: uint64 = 0
    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            break
        if _tar_chksum_ok(hdr) == 0:
            return 0
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        body_blocks: uint64 = (size + 511) / 512
        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)
        if nlen == pkg_prefix_len + tail_len:
            mch: int32 = 1
            i: uint64 = 0
            while i < pkg_prefix_len:
                if warn_buf[i] != pkg_prefix_buf[i]:
                    mch = 0
                    break
                i = i + 1
            if mch != 0:
                j: uint64 = 0
                while j < tail_len:
                    if warn_buf[pkg_prefix_len + j] != tail[j]:
                        mch = 0
                        break
                    j = j + 1
                if mch != 0:
                    return 1
        off = off + 512 + body_blocks * 512
    return 0


# -- write one staged file: <staging>/<rel> --------------------------
#
# Phase 3 introduces staging proper. For Phase 2 we stage the WHOLE
# tarball into /tmp/hpm/staging/<pkg-prefix>... so the install.hamsh
# stub-message can point at a real path, AND so the files/ extraction
# is read from disk (mirroring how Phase 3 will run with the staging
# dir already populated for hooks). The same loop walks the tar twice
# (once for staging, once for files/-to-target copy) — Phase 2 keeps
# the trivial path uncomplicated.
#
# Actually: for the no-hooks Phase 2 case we DON'T need to write the
# whole staged tree to disk — we just need PKGINFO parsed and the
# files/ tree placed at target. Phase 3 will materialise a real
# /tmp/hpm/staging/<name>-<version>/ for HPM_PKG_DIR. So this
# function is unused in Phase 2 and lives for Phase 3 to wire up.


def _stage_extract_files(tar_len: uint64, target_prefix: Ptr[uint8]) -> int32:
    # Walk tar_buf[0..tar_len); for any entry whose name is
    # "<pkg_prefix>files/<rel>" (regular file) write the body to
    # "<target_prefix><rel>" (mkdir -p the parent first). Records each
    # written rel-path in new_files_* for installed.json.
    # Directories under files/ are mkdir'd (typeflag '5').
    # Symlinks and other types are skipped with a warning.
    files_pfx: Ptr[uint8] = "files/"
    files_pfx_len: uint64 = 6

    off: uint64 = 0
    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            return 0
        if _tar_chksum_ok(hdr) == 0:
            write_str(2, "hpm: tar header checksum mismatch\n")
            return -1
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        typeflag: uint8 = hdr[156]
        body_blocks: uint64 = (size + 511) / 512

        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)

        # Strip the package prefix; bail out if absent (unexpected
        # entry shape per the spec, treated as a skip).
        if nlen <= pkg_prefix_len:
            off = off + 512 + body_blocks * 512
            continue
        prefix_ok: int32 = 1
        i: uint64 = 0
        while i < pkg_prefix_len:
            if warn_buf[i] != pkg_prefix_buf[i]:
                prefix_ok = 0
                break
            i = i + 1
        if prefix_ok == 0:
            off = off + 512 + body_blocks * 512
            continue

        # Tail relative to "<prefix>" — e.g. "files/bin/foo", "PKGINFO",
        # "install.hamsh".
        tail_start: uint64 = pkg_prefix_len
        tail_len: uint64 = nlen - tail_start
        # Only entries under "files/" go to the target.
        if tail_len < files_pfx_len:
            off = off + 512 + body_blocks * 512
            continue
        ok: int32 = 1
        j: uint64 = 0
        while j < files_pfx_len:
            if warn_buf[tail_start + j] != files_pfx[j]:
                ok = 0
                break
            j = j + 1
        if ok == 0:
            off = off + 512 + body_blocks * 512
            continue
        rel_start: uint64 = tail_start + files_pfx_len
        rel_len: uint64 = tail_len - files_pfx_len

        if rel_len == 0:
            # Bare "files/" directory entry — make sure target_prefix
            # exists, then skip.
            sys_mkdir(cast[Ptr[char]](target_prefix))
            off = off + 512 + body_blocks * 512
            continue

        # Path safety: name under files/ must not be abs / contain `..`.
        # Copy into a NUL-terminated cstring for the helper.
        safe_buf: Array[256, uint8]
        sl: uint64 = rel_len
        if sl >= 256:
            sl = 255
        kk: uint64 = 0
        while kk < sl:
            safe_buf[kk] = warn_buf[rel_start + kk]
            kk = kk + 1
        safe_buf[sl] = 0
        if _entry_name_is_unsafe(&safe_buf[0]) != 0:
            write_str(2, "hpm: refusing unsafe files/ path: ")
            write_str(2, &warn_buf[0])
            write_str(2, "\n")
            off = off + 512 + body_blocks * 512
            continue

        # Compose <target_prefix><rel> into extract_path_buf.
        po: uint64 = 0
        ti: uint64 = 0
        while target_prefix[ti] != 0 and po + 1 < 1024:
            extract_path_buf[po] = target_prefix[ti]
            po = po + 1
            ti = ti + 1
        # Avoid "//" if target_prefix ends in '/' (it always does in
        # our impl). _strcopy_n / etc — we just check.
        ri: uint64 = 0
        while ri < rel_len and po + 1 < 1024:
            extract_path_buf[po] = warn_buf[rel_start + ri]
            po = po + 1
            ri = ri + 1
        extract_path_buf[po] = 0

        if typeflag == 53:                               # '5' = dir
            # mkdir -p the full path itself.
            _mkdir_p(&extract_path_buf[0])
            sys_mkdir(cast[Ptr[char]](&extract_path_buf[0]))
            off = off + 512 + body_blocks * 512
            continue

        if typeflag != 0 and typeflag != 48:             # not '\0' or '0'
            write_str(2, "hpm: warning: skipping non-regular entry: ")
            write_str(2, &warn_buf[0])
            write_str(2, "\n")
            off = off + 512 + body_blocks * 512
            continue

        # Regular file. mkdir -p the parent, then write the body.
        _dirname_mkdir_p(&extract_path_buf[0])
        body_off: uint64 = off + 512
        if body_off + size > tar_len:
            write_str(2, "hpm: tar body overflows archive\n")
            return -1
        fd: int32 = sys_open_write(cast[Ptr[char]](&extract_path_buf[0]))
        if fd < 0:
            write_str(2, "hpm: cannot create ")
            write_str(2, &extract_path_buf[0])
            write_str(2, "\n")
            return -1
        if size > 0:
            wn: int64 = _write_full(fd, &tar_buf[body_off], size)
            if wn < 0 or cast[uint64](wn) != size:
                write_str(2, "hpm: short write extracting ")
                write_str(2, &extract_path_buf[0])
                write_str(2, "\n")
                sys_close(fd)
                return -1
        sys_close(fd)

        # Record the relative path (under files/) for installed.json.
        if _new_files_record(&warn_buf[rel_start], rel_len) != 0:
            return -1

        off = off + 512 + body_blocks * 512
    return 0


# -- installed.json append + rewrite ----------------------------------
#
# Append the just-installed package to inst_* tables, then rewrite
# /var/lib/hpm/installed.json from scratch. Format mirrors the schema
# in docs/packages.md.
#
# A real /var would let us atomically swap; tmpfs has no rename today,
# so we truncate-write-close. `hpm` is the sole writer so concurrency
# isn't a concern.

def _installed_record_add(name: Ptr[uint8], name_len: uint64,
                          version: Ptr[uint8], version_len: uint64,
                          target: Ptr[uint8], target_len: uint64,
                          pinned: int32):
    # Append to the in-memory inst_* tables. The string spans must
    # remain valid until _installed_rewrite is called — but since
    # inst_buf is rebuilt from scratch in _installed_rewrite (it writes
    # everything from new_files_* + the input params), we just stash
    # what we need into top-level scratch arenas. The simplest path is
    # to NOT extend inst_buf at all here — _installed_rewrite below
    # reads the new entry directly from the params + new_files_*.
    pass


# Top-level scratch for the rewrite's serialization buffer.
rewrite_buf:   Array[131072, uint8]
rewrite_n:     uint64 = 0


def _rw_put(s: Ptr[uint8], n: uint64) -> int32:
    if rewrite_n + n > 131072:
        return -1
    i: uint64 = 0
    while i < n:
        rewrite_buf[rewrite_n + i] = s[i]
        i = i + 1
    rewrite_n = rewrite_n + n
    return 0


def _rw_put_cstr(s: Ptr[uint8]) -> int32:
    return _rw_put(s, strlen_u8(s))


def _rw_put_lit(s: Ptr[uint8]) -> int32:
    return _rw_put(s, strlen_u8(s))


# Emit a JSON string with minimal escaping. Backslash and double-quote
# get escaped; other ASCII passes through (our keys + values are all
# ASCII names / paths / iso8601 timestamps). Non-ASCII passes through
# byte-wise — the consumer is hpm itself, no need to be strict.

def _rw_put_jstr(s: Ptr[uint8], n: uint64) -> int32:
    if _rw_put(cast[Ptr[uint8]]("\""), 1) != 0:
        return -1
    i: uint64 = 0
    while i < n:
        c: uint8 = s[i]
        if c == 34 or c == 92:                            # '"' or '\\'
            if _rw_put(cast[Ptr[uint8]]("\\"), 1) != 0:
                return -1
        b: Array[1, uint8]
        b[0] = c
        if _rw_put(&b[0], 1) != 0:
            return -1
        i = i + 1
    if _rw_put(cast[Ptr[uint8]]("\""), 1) != 0:
        return -1
    return 0


def _rw_put_jstr_cstr(s: Ptr[uint8]) -> int32:
    return _rw_put_jstr(s, strlen_u8(s))


# Emit a decimal integer.
def _rw_put_dec(v: uint64) -> int32:
    digs: Array[24, uint8]
    n: uint64 = 0
    if v == 0:
        digs[0] = 48
        n = 1
    else:
        x: uint64 = v
        while x != 0:
            digs[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return _rw_put(&out[0], i)


# Top-level helper: emit one installed-package object from the
# in-memory inst_* state OR from the just-installed params, both
# walked the same way through callbacks.

def _installed_emit_existing(i: uint64) -> int32:
    if _rw_put_lit(cast[Ptr[uint8]]("    {\n      \"name\": ")) != 0:
        return -1
    if _rw_put_jstr(&inst_buf[inst_name_off[i]], inst_name_len[i]) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"version\": ")) != 0:
        return -1
    if _rw_put_jstr(&inst_buf[inst_ver_off[i]], inst_ver_len[i]) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"installed_at\": ")) != 0:
        return -1
    if inst_at_len[i] > 0:
        if _rw_put_jstr(&inst_buf[inst_at_off[i]], inst_at_len[i]) != 0:
            return -1
    else:
        if _rw_put_jstr_cstr(cast[Ptr[uint8]]("")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"pinned\": ")) != 0:
        return -1
    if inst_pinned[i] != 0:
        if _rw_put_lit(cast[Ptr[uint8]]("true")) != 0:
            return -1
    else:
        if _rw_put_lit(cast[Ptr[uint8]]("false")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"target\": ")) != 0:
        return -1
    if inst_target_len[i] > 0:
        if _rw_put_jstr(&inst_buf[inst_target_off[i]],
                        inst_target_len[i]) != 0:
            return -1
    else:
        if _rw_put_jstr_cstr(cast[Ptr[uint8]]("#hamnix-system")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"files\": [")) != 0:
        return -1
    fc: uint64 = inst_file_count[i]
    fs: uint64 = inst_file_start[i]
    fi: uint64 = 0
    while fi < fc:
        if fi > 0:
            if _rw_put_lit(cast[Ptr[uint8]](", ")) != 0:
                return -1
        slot: uint64 = fs + fi
        if _rw_put_jstr(&inst_buf[inst_file_off[slot]],
                        inst_file_len[slot]) != 0:
            return -1
        fi = fi + 1
    if _rw_put_lit(cast[Ptr[uint8]]("]\n    }")) != 0:
        return -1
    return 0


def _installed_emit_new(name: Ptr[uint8], version: Ptr[uint8],
                        target: Ptr[uint8], pinned: int32) -> int32:
    # Same shape as _installed_emit_existing but for the just-installed
    # package: reads from the params + new_files_*.
    if _rw_put_lit(cast[Ptr[uint8]]("    {\n      \"name\": ")) != 0:
        return -1
    if _rw_put_jstr_cstr(name) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"version\": ")) != 0:
        return -1
    if _rw_put_jstr_cstr(version) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"installed_at\": ")) != 0:
        return -1
    # v1 has no RTC tie-in for hpm; record an empty timestamp.
    if _rw_put_jstr_cstr(cast[Ptr[uint8]]("")) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"pinned\": ")) != 0:
        return -1
    if pinned != 0:
        if _rw_put_lit(cast[Ptr[uint8]]("true")) != 0:
            return -1
    else:
        if _rw_put_lit(cast[Ptr[uint8]]("false")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"target\": ")) != 0:
        return -1
    if target[0] == 0:
        if _rw_put_jstr_cstr(cast[Ptr[uint8]]("#hamnix-system")) != 0:
            return -1
    else:
        if _rw_put_jstr_cstr(target) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"files\": [")) != 0:
        return -1
    fi: uint64 = 0
    while fi < new_files_n:
        if fi > 0:
            if _rw_put_lit(cast[Ptr[uint8]](", ")) != 0:
                return -1
        if _rw_put_jstr(&new_files_buf[new_files_off[fi]],
                        new_files_len[fi]) != 0:
            return -1
        fi = fi + 1
    if _rw_put_lit(cast[Ptr[uint8]]("]\n    }")) != 0:
        return -1
    return 0


def _installed_rewrite_with_added(name: Ptr[uint8], version: Ptr[uint8],
                                  target: Ptr[uint8],
                                  pinned: int32) -> int32:
    # Serialize the inst_* state + the new entry to /var/lib/hpm/
    # installed.json. The new entry is appended at the end. If the
    # name already exists in inst_*, it is REPLACED.
    rewrite_n = 0
    if _rw_put_lit(cast[Ptr[uint8]]("{\n  \"schema\": 1,\n  \"packages\": [\n")) != 0:
        return -1
    first: int32 = 1
    name_len: uint64 = strlen_u8(name)
    i: uint64 = 0
    while i < inst_count:
        # Skip an existing entry with the same name — the install
        # supersedes it (Phase 3+ will use remove() first; for trivial
        # Phase 2 we just overwrite).
        same: int32 = 0
        if inst_name_len[i] == name_len:
            k: uint64 = 0
            same = 1
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    same = 0
                    break
                k = k + 1
        if same == 0:
            if first == 0:
                if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
                    return -1
            if _installed_emit_existing(i) != 0:
                return -1
            first = 0
        i = i + 1
    # Append the new entry.
    if first == 0:
        if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
            return -1
    if _installed_emit_new(name, version, target, pinned) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]]("\n  ]\n}\n")) != 0:
        return -1

    # Write to /var/lib/hpm/installed.json (truncate-on-open).
    fd: int32 = sys_open_write("/var/lib/hpm/installed.json")
    if fd < 0:
        write_str(2, "hpm: cannot open /var/lib/hpm/installed.json for write\n")
        return -1
    wn: int64 = _write_full(fd, &rewrite_buf[0], rewrite_n)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != rewrite_n:
        write_str(2, "hpm: short write on installed.json\n")
        return -1
    return 0


# Same shape, but the package is REMOVED rather than appended (Phase 3
# uses this from `hpm remove`).
def _installed_rewrite_with_removed(name: Ptr[uint8]) -> int32:
    rewrite_n = 0
    if _rw_put_lit(cast[Ptr[uint8]]("{\n  \"schema\": 1,\n  \"packages\": [\n")) != 0:
        return -1
    first: int32 = 1
    name_len: uint64 = strlen_u8(name)
    i: uint64 = 0
    while i < inst_count:
        same: int32 = 0
        if inst_name_len[i] == name_len:
            k: uint64 = 0
            same = 1
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    same = 0
                    break
                k = k + 1
        if same == 0:
            if first == 0:
                if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
                    return -1
            if _installed_emit_existing(i) != 0:
                return -1
            first = 0
        i = i + 1
    if _rw_put_lit(cast[Ptr[uint8]]("\n  ]\n}\n")) != 0:
        return -1
    fd: int32 = sys_open_write("/var/lib/hpm/installed.json")
    if fd < 0:
        write_str(2, "hpm: cannot open /var/lib/hpm/installed.json for write\n")
        return -1
    wn: int64 = _write_full(fd, &rewrite_buf[0], rewrite_n)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != rewrite_n:
        write_str(2, "hpm: short write on installed.json\n")
        return -1
    return 0


# Same but with a pinned-state CHANGE for an existing entry.
def _installed_rewrite_with_pin(name: Ptr[uint8], pin_v: int32) -> int32:
    rewrite_n = 0
    if _rw_put_lit(cast[Ptr[uint8]]("{\n  \"schema\": 1,\n  \"packages\": [\n")) != 0:
        return -1
    first: int32 = 1
    name_len: uint64 = strlen_u8(name)
    i: uint64 = 0
    while i < inst_count:
        if first == 0:
            if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
                return -1
        # If this is the target entry, emit with pin toggled.
        same: int32 = 0
        if inst_name_len[i] == name_len:
            same = 1
            k: uint64 = 0
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    same = 0
                    break
                k = k + 1
        if same != 0:
            old: int32 = inst_pinned[i]
            inst_pinned[i] = pin_v
            if _installed_emit_existing(i) != 0:
                return -1
            inst_pinned[i] = old
        else:
            if _installed_emit_existing(i) != 0:
                return -1
        first = 0
        i = i + 1
    if _rw_put_lit(cast[Ptr[uint8]]("\n  ]\n}\n")) != 0:
        return -1
    fd: int32 = sys_open_write("/var/lib/hpm/installed.json")
    if fd < 0:
        return -1
    wn: int64 = _write_full(fd, &rewrite_buf[0], rewrite_n)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != rewrite_n:
        return -1
    return 0


# -- install command (Phase 2: trivial case) ---------------------------

def cmd_install(spec: Ptr[uint8]) -> int32:
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    # Make sure the installed DB is parsed so we can detect dups / write
    # an updated copy.
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1

    name_buf: Array[128, uint8]
    ver_buf:  Array[64, uint8]
    has_ver:  int32 = 0
    _split_nameversion(spec, &name_buf[0], 128, &ver_buf[0], 64, &has_ver)
    name_len: uint64 = strlen_u8(&name_buf[0])
    if name_len == 0:
        write_str(2, "hpm: install: empty package name\n")
        return 1

    idx: int64 = -1
    if has_ver != 0:
        idx = _pkg_find_exact(&name_buf[0], name_len,
                              &ver_buf[0], strlen_u8(&ver_buf[0]))
    else:
        idx = _pkg_find_best(&name_buf[0], name_len)
    if idx < 0:
        write_str(2, "hpm: no candidate for ")
        write_str(2, spec)
        write_str(2, "\n")
        return 1
    pi: uint64 = cast[uint64](idx)

    # Pull the version + url + sha256 + target out as cstrings.
    v_cstr: Array[64, uint8]
    _strcopy_n(&v_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_version_off[pi]),
               pkg_version_len[pi], 64)
    url_cstr: Array[512, uint8]
    _strcopy_n(&url_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_url_off[pi]),
               pkg_url_len[pi], 512)
    sha_cstr: Array[80, uint8]
    _strcopy_n(&sha_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_sha256_off[pi]),
               pkg_sha256_len[pi], 80)
    target_cstr: Array[128, uint8]
    if pkg_target_len[pi] > 0:
        _strcopy_n(&target_cstr[0],
                   cast[Ptr[uint8]](
                       cast[uint64](&idx_buf[0]) + pkg_target_off[pi]),
                   pkg_target_len[pi], 128)
    else:
        _strcopy_cstr(&target_cstr[0],
                      cast[Ptr[uint8]]("#hamnix-system"), 128)

    write_str(1, "hpm: installing ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    write_str(1, " (target=")
    write_str(1, &target_cstr[0])
    write_str(1, ", url=")
    write_str(1, &url_cstr[0])
    write_str(1, ")\n")

    # Phase 4 will check conflicts here. Phase 2 only blocks an
    # exact-name duplicate at the same version with no fuss.
    di: uint64 = 0
    while di < inst_count:
        if inst_name_len[di] == name_len:
            same: int32 = 1
            ki: uint64 = 0
            while ki < name_len:
                if inst_buf[inst_name_off[di] + ki] != name_buf[ki]:
                    same = 0
                    break
                ki = ki + 1
            if same != 0:
                write_str(2, "hpm: package ")
                sys_write(2, &name_buf[0], name_len)
                write_str(2, " is already installed (use `hpm remove` first or wait for Phase 5 update)\n")
                return 1
        di = di + 1

    # 1. Fetch the tarball.
    n: int64 = fetch_to_buf(&url_cstr[0], &deb_buf[0], TARBALL_CAP)
    if n < 0:
        write_str(2, "hpm: failed to fetch ")
        write_str(2, &url_cstr[0])
        write_str(2, "\n")
        return 1
    deb_len: uint64 = cast[uint64](n)
    write_str(1, "hpm: fetched ")
    write_dec_u64(1, deb_len)
    write_str(1, " bytes\n")

    # 2. Verify SHA-256.
    _sha256_hash_buf(&deb_buf[0], deb_len)
    expected_len: uint64 = strlen_u8(&sha_cstr[0])
    if expected_len != 64:
        write_str(2, "hpm: index sha256 is not 64 hex chars\n")
        return 1
    mi: uint64 = 0
    while mi < 64:
        ec: uint8 = sha_cstr[mi]
        # ASCII-fold to lowercase for the compare.
        if ec >= 65 and ec <= 70:
            ec = ec + 32
        if sha_hex[mi] != ec:
            write_str(2, "hpm: SHA-256 mismatch — refusing to install\n")
            write_str(2, "  expected: ")
            write_str(2, &sha_cstr[0])
            write_str(2, "\n  actual:   ")
            write_str(2, &sha_hex[0])
            write_str(2, "\n")
            return 1
        mi = mi + 1
    write_str(1, "hpm: SHA-256 verified\n")

    # 3. Inflate the tar.
    tar_len_i: int64 = _inflate_tarball(deb_len)
    if tar_len_i < 0:
        return 1
    tar_len: uint64 = cast[uint64](tar_len_i)
    write_str(1, "hpm: inflated to ")
    write_dec_u64(1, tar_len)
    write_str(1, " bytes\n")

    # 4. Build the package prefix "<name>-<version>/".
    pp: uint64 = 0
    ni: uint64 = 0
    while ni < name_len and pp + 1 < 128:
        pkg_prefix_buf[pp] = name_buf[ni]
        pp = pp + 1
        ni = ni + 1
    pkg_prefix_buf[pp] = 45                              # '-'
    pp = pp + 1
    vi: uint64 = 0
    vl: uint64 = strlen_u8(&v_cstr[0])
    while vi < vl and pp + 1 < 128:
        pkg_prefix_buf[pp] = v_cstr[vi]
        pp = pp + 1
        vi = vi + 1
    pkg_prefix_buf[pp] = 47                              # '/'
    pp = pp + 1
    pkg_prefix_buf[pp] = 0
    pkg_prefix_len = pp

    # 5. Read PKGINFO + check arch.
    if _read_pkginfo_from_tar(tar_len) != 0:
        return 1
    arch_len: uint64 = strlen_u8(&pi_arch[0])
    if arch_len > 0:
        if _streq(&pi_arch[0], cast[Ptr[uint8]]("x86_64")) == 0 \
                and _streq(&pi_arch[0], cast[Ptr[uint8]]("any")) == 0:
            write_str(2, "hpm: package arch `")
            write_str(2, &pi_arch[0])
            write_str(2, "` not compatible with x86_64\n")
            return 1
    # PKGINFO's target overrides the index's where present.
    pi_t_len: uint64 = strlen_u8(&pi_target[0])
    if pi_t_len > 0:
        _strcopy_cstr(&target_cstr[0], &pi_target[0], 128)
    target_len_eff: uint64 = strlen_u8(&target_cstr[0])

    # 6. Resolve the target prefix.
    if _set_target_prefix(&target_cstr[0], target_len_eff) != 0:
        return 1
    # Make sure the prefix directory itself exists (`/var/lib/distros/
    # default/` etc.) — tmpfs needs explicit mkdirs.
    if target_prefix_buf[0] != 0:
        _mkdir_p(&target_prefix_buf[0])
        sys_mkdir(cast[Ptr[char]](&target_prefix_buf[0]))

    # 7. Extract files/ into the target.
    _new_files_reset()
    if _stage_extract_files(tar_len, &target_prefix_buf[0]) != 0:
        write_str(2, "hpm: files/ extraction failed\n")
        return 1
    write_str(1, "hpm: extracted ")
    write_dec_u64(1, new_files_n)
    write_str(1, " files\n")

    # 8. Phase 2: stub-message any hooks present so the test can
    # assert the path. Phase 3 wires real execution.
    if _has_entry_in_tar(tar_len, cast[Ptr[uint8]]("pre-install.hamsh")) != 0:
        write_str(1, "hpm: hook would run: pre-install.hamsh\n")
    if _has_entry_in_tar(tar_len, cast[Ptr[uint8]]("install.hamsh")) != 0:
        write_str(1, "hpm: hook would run: install.hamsh\n")

    # 9. Update installed.json. Pinning: `@<ver>` pins per spec.
    pinned: int32 = 0
    if has_ver != 0:
        pinned = 1
    if _installed_rewrite_with_added(&name_buf[0], &v_cstr[0],
                                     &target_cstr[0], pinned) != 0:
        return 1

    write_str(1, "hpm: installed ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    sys_write(1, "\n", 1)
    return 0


# -- usage + main -----------------------------------------------------

def _usage() -> int32:
    s: Ptr[uint8] = "Usage: hpm [--repo=<url>] <command> [args]\n\
Commands:\n\
  refresh                 fetch repo index\n\
  list                    show installed packages\n\
  search <pattern>        substring match against repo names\n\
  show <name>[@<ver>]     print package metadata\n\
  install <name>[@<ver>]  (Phase 2+)\n\
  remove <name>           (Phase 3+)\n\
  update                  (Phase 5+)\n\
  pin <name>[@<ver>]      (Phase 5+)\n\
  unpin <name>            (Phase 5+)\n"
    write_str(2, s)
    return 2


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    _set_repo_default()

    # Optional leading flag(s): --repo=<url>. Stops at the first non-flag.
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        # Match "--repo=" prefix.
        pfx: Ptr[uint8] = "--repo="
        is_repo: int32 = 1
        i: uint64 = 0
        while i < 7:
            if a[i] != pfx[i]:
                is_repo = 0
                break
            i = i + 1
        if is_repo != 0:
            rest: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](a) + 7)
            _set_repo(rest)
            ai = ai + 1
            continue
        break

    if ai >= argc:
        return _usage()

    if _apply_repo() != 0:
        return 1

    cmd: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
    ai = ai + 1

    if _streq(cmd, cast[Ptr[uint8]]("refresh")) != 0:
        return cmd_refresh()
    if _streq(cmd, cast[Ptr[uint8]]("list")) != 0:
        return cmd_list()
    if _streq(cmd, cast[Ptr[uint8]]("search")) != 0:
        if ai >= argc:
            write_str(2, "hpm: search requires a pattern\n")
            return 1
        return cmd_search(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("show")) != 0:
        if ai >= argc:
            write_str(2, "hpm: show requires a package name\n")
            return 1
        return cmd_show(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("install")) != 0:
        if ai >= argc:
            write_str(2, "hpm: install requires a package name\n")
            return 1
        return cmd_install(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("remove")) != 0:
        write_str(2, "hpm: remove is implemented in Phase 3\n")
        return 1
    if _streq(cmd, cast[Ptr[uint8]]("update")) != 0:
        write_str(2, "hpm: update is implemented in Phase 5\n")
        return 1
    if _streq(cmd, cast[Ptr[uint8]]("pin")) != 0:
        write_str(2, "hpm: pin is implemented in Phase 5\n")
        return 1
    if _streq(cmd, cast[Ptr[uint8]]("unpin")) != 0:
        write_str(2, "hpm: unpin is implemented in Phase 5\n")
        return 1

    write_str(2, "hpm: unknown command: ")
    write_str(2, cmd)
    sys_write(2, "\n", 1)
    return _usage()

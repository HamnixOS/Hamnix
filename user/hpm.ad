# user/hpm.ad
#
# Hamnix package manager (hpm) — v1, binary-only.
#
# Spec: docs/packages.md. Live repo: https://255.one/index.json.
#
# Phase 1 (this commit): the read-only commands.
#   hpm refresh                — fetch repo index, cache it locally
#   hpm list                   — print every installed package (from
#                                /var/lib/hpm/installed.json)
#   hpm search <pattern>       — substring match against repo names
#   hpm show <name>[@<ver>]    — print the package's index metadata
#
# Later phases add install / hooks / remove / dep solver / update.
#
# Repo URLs supported:
#   https://host[:port][/path]  — TLS via the /net file tree
#   http://host[:port][/path]   — plain TCP via /net
#   file:///abs/path/           — local-filesystem repo (read via sys_open)
#
# The default is the canonical hosted repo `https://255.one/`. Override
# with `--repo=<url>` (or `HPM_REPO=...` env). The installer ISO uses a
# `file:///mnt/iso-packages/` repo (see docs/packages.md "Bootstrap").
#
# Files this binary touches:
#   /tmp/hpm/index.json        — refreshed index cache (volatile, tmpfs)
#   /tmp/hpm/<tarball>         — staging .tar.gz downloads (Phase 2)
#   /var/lib/hpm/installed.json — installed-package DB (persistent /var)
#
# Compiler-quirk discipline (memory/feedback_compiler_quirks.md U9):
# every large buffer is a top-level BSS Array — never a frame local.
# String literals are materialised inline at the call site (the x86_64
# backend rejects string-literal globals).
#
# Build: scripts/build_user.sh -> build/user/hpm.elf -> /bin/hpm.
# Test:  scripts/test_hpm.sh (Phase 6).

# HTTP/HTTPS transport over the Plan-9 /net file tree lives in the
# shared user/http9.ad module (also consumed by user/curl.ad and
# user/wget.ad). hpm composes a full URL and delegates the dial /
# request / drain dance to http9.http_get — the duplicated private
# copies of that logic were extracted here.
from user.http9 import http_get

# Gzip inflater for the .tar.gz package payload.
from lib.zlib.inflate import (
    InflateState,
    inflate_init,
    inflate_feed,
)


# -- syscalls ----------------------------------------------------------
#
# Plain file + spawn syscalls; networking goes through net_dial / the
# returned fd (sys_read / sys_write on a /net data fd is transparent
# TCP or TLS).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_mkdir(path: Ptr[char]) -> int32
extern def sys_unlink(path: Ptr[char]) -> int32
# U-resolve: native-ABI hostname -> IPv4 via the in-kernel DNS resolver
# (drivers/net/dns.ad, syscall 269). Returns the IPv4 packed big-endian
# in the low 32 bits (octet 0 in bits 31:24), or negative errno.
extern def sys_resolve(hostname: Ptr[uint8], hlen: uint64) -> int64
# Hooks are spawned as `/bin/hamsh <hook-script>` — hamsh's argv[1] is
# a script path (see user/hamsh.ad main()).
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_waitpid(pid: int32) -> int64
# docs/security.md: Plan-9-shape hostowner gate. `hpm install/remove/
# update/pin/unpin` are privileged operations — they write to
# /var/lib/hpm/, /bin/, /lib/, etc., all of which are hostowner-owned.
# Regular users must `newshell hostowner` to install packages. The
# read-only commands (list, search, show, refresh) remain accessible
# to everyone. The check is a single sys_getuid() at command dispatch.
extern def sys_getuid() -> uint32


# -- bounded BSS arenas -----------------------------------------------
#
# All large buffers MUST be top-level BSS (the U9 nested-frame-Array
# miscompile). Sizes chosen to fit a small fixture repo AND the live
# https://255.one/index.json (~800 bytes today; capped at 256 KiB so a
# growing index has room).

INDEX_CAP:   uint64 = 262144     # 256 KiB cap on a fetched index.json
HTTP_STAGE:  uint64 = 65536      # 64 KiB socket-drain chunk
TARBALL_CAP: uint64 = 4194304    # 4 MiB cap on a single package tarball
TAR_CAP:     uint64 = 8388608    # 8 MiB cap on the inflated tar
INSTALLED_CAP: uint64 = 131072   # 128 KiB cap on installed.json

# Raw bytes off the socket / file when fetching a body (index.json or
# a tarball). Used in both _http_get and _file_read paths.
http_buf:    Array[262144, uint8]
http_stage:  Array[65536, uint8]

# Index cache. Loaded on every `hpm` invocation from /tmp/hpm/index.json
# (or freshly fetched on `hpm refresh`). The JSON parser indexes ONTO
# this buffer — package fields are pointers + lengths into idx_buf.
idx_buf:     Array[262144, uint8]
idx_len:     uint64 = 0

# installed.json buffer.
inst_buf:    Array[131072, uint8]
inst_len:    uint64 = 0

# Tarball download + inflate buffers (Phase 2).
deb_buf:     Array[4194304, uint8]
tar_buf:     Array[8388608, uint8]


# -- URL / path scratch -----------------------------------------------

host_buf:    Array[256, uint8]           # NUL-terminated hostname
path_buf:    Array[1024, uint8]          # base path (no trailing /)
url_path_buf: Array[1536, uint8]         # composed absolute path for GET
req_buf:     Array[1024, uint8]          # HTTP request line + headers
# url_scheme: 0 == http, 1 == https, 2 == file
url_scheme:  int32 = 0
url_port:    int64 = 80

# Repo base URL — set by _set_repo_default or `--repo=<url>` flag. This
# is a NUL-terminated copy of the canonical form (so messages can echo
# it back); the parsed pieces live in host_buf / path_buf / url_scheme.
repo_url_buf: Array[1024, uint8]

# Channel state. The repo URL is the BASE (e.g. https://255.one/);
# each enabled channel is a sub-path under the base. /etc/hpm/channels
# is the persisted subscription list (one channel per line, # comments
# allowed). On a fresh install the default contents subscribe to
# `main` only — see memory/project_nonfree_repo.md for the design.
#
# channel_names_buf packs every channel name back-to-back, NUL-
# terminated. channel_names_off/len[ci] index it. _current_channel
# tracks which channel the JSON parser is currently appending pkgs
# for (so each pkg's "channel" field is stamped at parse time).
CHANNEL_MAX: uint64 = 32
channel_names_buf: Array[4096, uint8]
channel_names_off: Array[32, uint64]
channel_names_len: Array[32, uint64]
channel_buf_n:     uint64 = 0
n_channels:        uint64 = 0
# Saved base URL — distinct from repo_url_buf so the per-channel
# fetch can rebuild "<base>/<channel>/" on every fetch without losing
# what the user (or --repo flag) configured as the base.
repo_base_buf: Array[1024, uint8]



# -- tiny stdio helpers (mirrors apt.ad/dpkg_deb.ad) ------------------

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec_u64(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def _write_full(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    written: uint64 = 0
    while written < count:
        room: uint64 = count - written
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](buf) + written)
        rc: int64 = sys_write(fd, ptr, room)
        if rc < 0:
            return rc
        if rc == 0:
            return cast[int64](written)
        written = written + cast[uint64](rc)
    return cast[int64](written)


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == 0 and b[i] == 0:
        return 1
    return 0


def _streq_n(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    # Compare exactly n bytes (treats embedded NULs as bytes, not
    # terminators) — used by the JSON parser to compare a span in
    # idx_buf to a literal field name like "name" / "version".
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _strcontains(hay: Ptr[uint8], needle: Ptr[uint8]) -> int32:
    # Substring match for `hpm search` — true if needle appears anywhere
    # in hay. Both NUL-terminated, case-sensitive (mirrors apt-cache).
    hl: uint64 = strlen_u8(hay)
    nl: uint64 = strlen_u8(needle)
    if nl == 0:
        return 1
    if nl > hl:
        return 0
    i: uint64 = 0
    while i + nl <= hl:
        j: uint64 = 0
        ok: int32 = 1
        while j < nl:
            if hay[i + j] != needle[j]:
                ok = 0
                break
            j = j + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


def _strcopy_n(dst: Ptr[uint8], src: Ptr[uint8], n: uint64, cap: uint64):
    # Copy exactly n bytes (or until cap-1 reached), NUL-terminate.
    take: uint64 = n
    if take >= cap:
        take = cap - 1
    i: uint64 = 0
    while i < take:
        dst[i] = src[i]
        i = i + 1
    dst[take] = 0


def _strcopy_cstr(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    # Copy a NUL-terminated string, capping at cap-1 bytes.
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


# -- URL parsing -------------------------------------------------------
#
# Same shape as apt's _parse_url, extended with the file:// scheme.
# Sets url_scheme, url_port, host_buf, path_buf. Returns 0 on success,
# -1 on a malformed URL (diagnostic printed).

def _parse_url(url: Ptr[uint8]) -> int32:
    https_pfx: Ptr[uint8] = "https://"
    http_pfx:  Ptr[uint8] = "http://"
    file_pfx:  Ptr[uint8] = "file://"

    # Probe longest-first.
    a: uint64 = 0
    is_https: int32 = 1
    i: uint64 = 0
    while i < 8:
        if url[i] != https_pfx[i]:
            is_https = 0
            break
        i = i + 1
    if is_https != 0:
        url_scheme = 1
        a = 8
    else:
        is_file: int32 = 1
        i = 0
        while i < 7:
            if url[i] != file_pfx[i]:
                is_file = 0
                break
            i = i + 1
        if is_file != 0:
            url_scheme = 2
            a = 7
            # For file://, treat the rest as path_buf directly (no host).
            host_buf[0] = 0
            po: uint64 = 0
            m: uint64 = a
            while url[m] != 0 and po + 1 < 1024:
                path_buf[po] = url[m]
                po = po + 1
                m = m + 1
            # Trim trailing slash so joins yield clean "<path>/foo".
            while po > 0 and path_buf[po - 1] == 47:
                po = po - 1
            path_buf[po] = 0
            url_port = 0
            return 0
        # Plain http://
        is_http: int32 = 1
        i = 0
        while i < 7:
            if url[i] != http_pfx[i]:
                is_http = 0
                break
            i = i + 1
        if is_http == 0:
            write_str(2, "hpm: only https://, http://, file:// URLs supported\n")
            return -1
        url_scheme = 0
        a = 7

    # Authority spans from `a` up to the first '/' or NUL.
    auth_end: uint64 = a
    while url[auth_end] != 0 and url[auth_end] != 47:
        auth_end = auth_end + 1

    colon: uint64 = a
    have_colon: int32 = 0
    j: uint64 = a
    while j < auth_end:
        if url[j] == 58:                                 # ':'
            colon = j
            have_colon = 1
            break
        j = j + 1

    host_end: uint64 = auth_end
    if have_colon != 0:
        host_end = colon
    if host_end <= a:
        write_str(2, "hpm: malformed URL (empty host)\n")
        return -1

    ho: uint64 = 0
    k: uint64 = a
    while k < host_end and ho + 1 < 256:
        host_buf[ho] = url[k]
        ho = ho + 1
        k = k + 1
    host_buf[ho] = 0

    port: int64 = 80
    if url_scheme != 0:
        port = 443
    if have_colon != 0:
        port = 0
        p: uint64 = colon + 1
        if p >= auth_end:
            write_str(2, "hpm: malformed URL (empty port)\n")
            return -1
        while p < auth_end:
            c: uint8 = url[p]
            if c < 48 or c > 57:
                write_str(2, "hpm: malformed URL (non-numeric port)\n")
                return -1
            port = port * 10 + cast[int64](c - 48)
            if port > 65535:
                write_str(2, "hpm: malformed URL (port out of range)\n")
                return -1
            p = p + 1
    url_port = port

    po: uint64 = 0
    m: uint64 = auth_end
    while url[m] != 0 and po + 1 < 1024:
        path_buf[po] = url[m]
        po = po + 1
        m = m + 1
    while po > 0 and path_buf[po - 1] == 47:
        po = po - 1
    path_buf[po] = 0

    return 0



# -- file:// fetch -----------------------------------------------------
#
# Slurp <path_buf>/<tail> into dst[0..dst_cap), returning the byte count
# read. dst_cap is the maximum bytes to accept; an over-cap file is a
# hard error.

def _file_read_path(file_path: Ptr[char],
                    dst: Ptr[uint8], dst_cap: uint64) -> int64:
    fd: int32 = sys_open(file_path)
    if fd < 0:
        write_str(2, "hpm: cannot open ")
        write_str(2, cast[Ptr[uint8]](file_path))
        write_str(2, "\n")
        return -1
    total: uint64 = 0
    while total < dst_cap:
        room: uint64 = dst_cap - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](dst) + total), room)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    if total >= dst_cap:
        write_str(2, "hpm: file exceeds buffer cap\n")
        return -1
    return cast[int64](total)


# -- compose path under the repo base ---------------------------------
#
# Builds the absolute target for a GET / file-open: "<base>/<tail>".
# For HTTP-shaped schemes the result goes into url_path_buf (used by
# the GET). For file://, the result goes into a caller-supplied buffer
# (so the file_open path can use it as a Ptr[char]).

def _build_url_path(tail: Ptr[uint8]):
    o: uint64 = 0
    bi: uint64 = 0
    while path_buf[bi] != 0 and o + 1 < 1536:
        url_path_buf[o] = path_buf[bi]
        o = o + 1
        bi = bi + 1
    # Ensure a leading '/' so a base of "" (bare host) still yields a
    # path that starts with '/'.
    if o == 0 or url_path_buf[0] != 47:
        # Shift right by 1 to insert leading '/'. The fixture cases where
        # path_buf is empty want url_path_buf = "/<tail>".
        s: uint64 = o
        while s > 0:
            url_path_buf[s] = url_path_buf[s - 1]
            s = s - 1
        url_path_buf[0] = 47
        o = o + 1
    # Separator '/' if base doesn't already end in one.
    if o == 0 or url_path_buf[o - 1] != 47:
        if o + 1 < 1536:
            url_path_buf[o] = 47
            o = o + 1
    ti: uint64 = 0
    while tail[ti] != 0 and o + 1 < 1536:
        url_path_buf[o] = tail[ti]
        o = o + 1
        ti = ti + 1
    url_path_buf[o] = 0


def _build_file_path(out: Ptr[uint8], cap: uint64, tail: Ptr[uint8]) -> int32:
    # path_buf is the file:// path (NO leading file://). Compose
    # "<path_buf>/<tail>" into out (NUL-terminated). Returns 0 on
    # success, -1 on overflow.
    o: uint64 = 0
    bi: uint64 = 0
    while path_buf[bi] != 0:
        if o + 1 >= cap:
            return -1
        out[o] = path_buf[bi]
        o = o + 1
        bi = bi + 1
    if o == 0 or out[o - 1] != 47:
        if o + 1 >= cap:
            return -1
        out[o] = 47
        o = o + 1
    ti: uint64 = 0
    while tail[ti] != 0:
        if o + 1 >= cap:
            return -1
        out[o] = tail[ti]
        o = o + 1
        ti = ti + 1
    out[o] = 0
    return 0


# -- repo-aware fetch wrapper -----------------------------------------
#
# fetch_to_buf(tail, dst, dst_cap) — fetch the resource at <repo>/<tail>
# into dst, returning the byte count. Routes on url_scheme:
#   http / https  -> http9.http_get
#   file          -> _file_read_path
#
# For HTTP the body lands at dst[body_off..body_off+len); we slide it
# down to dst[0..len) so callers see a clean buffer that starts with the
# resource.

fetch_path_scratch: Array[1536, uint8]
# Full "scheme://host[:port]<path>" composed for the http9.http_get
# entry point (which parses the URL itself). url_path_buf is 1536 and
# the authority adds <= ~270 bytes, so 2048 has comfortable headroom.
fetch_url_buf: Array[2048, uint8]


def _build_full_url():
    # Compose "<scheme>://<host>[:<port>]<url_path_buf>" into
    # fetch_url_buf. _build_url_path must have already filled
    # url_path_buf (it always starts with '/'). url_scheme/host_buf/
    # url_port come from _parse_url.
    o: uint64 = 0
    sp: Ptr[uint8] = "http://"
    if url_scheme == 1:
        sp = "https://"
    si: uint64 = 0
    while sp[si] != 0 and o + 1 < 2048:
        fetch_url_buf[o] = sp[si]
        o = o + 1
        si = si + 1
    hi: uint64 = 0
    while host_buf[hi] != 0 and o + 1 < 2048:
        fetch_url_buf[o] = host_buf[hi]
        o = o + 1
        hi = hi + 1
    # Emit an explicit port only when it differs from the scheme default
    # (http9 defaults http->80, https->443). A non-default port is part
    # of the authority.
    default_port: int64 = 80
    if url_scheme == 1:
        default_port = 443
    if url_port != default_port and o + 1 < 2048:
        fetch_url_buf[o] = 58                              # ':'
        o = o + 1
        o = _net9_put_dec_local(&fetch_url_buf[0], o, cast[uint64](url_port))
    pi: uint64 = 0
    while url_path_buf[pi] != 0 and o + 1 < 2048:
        fetch_url_buf[o] = url_path_buf[pi]
        o = o + 1
        pi = pi + 1
    fetch_url_buf[o] = 0


def _net9_put_dec_local(out: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    # Append `v` as ASCII decimal at out[pos]; returns the new pos.
    if v == 0:
        out[pos] = 48
        return pos + 1
    digs: Array[24, uint8]
    n: uint64 = 0
    while v != 0:
        digs[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    p: uint64 = pos
    while n > 0:
        n = n - 1
        out[p] = digs[n]
        p = p + 1
    return p


def fetch_to_buf(tail: Ptr[uint8], dst: Ptr[uint8],
                 dst_cap: uint64) -> int64:
    if url_scheme == 2:
        if _build_file_path(&fetch_path_scratch[0], 1536, tail) != 0:
            write_str(2, "hpm: file path overflow\n")
            return -1
        return _file_read_path(cast[Ptr[char]](&fetch_path_scratch[0]),
                               dst, dst_cap)
    _build_url_path(tail)
    _build_full_url()
    status:   int64 = 0
    body_off: uint64 = 0
    body_len: uint64 = 0
    rc: int64 = http_get(&fetch_url_buf[0], dst, dst_cap,
                         &status, &body_off, &body_len)
    if rc < 0:
        if rc == -2:
            write_str(2, "hpm: connect/TLS failed for ")
            write_str(2, &host_buf[0])
            write_str(2, "\n")
        elif rc == -7:
            write_str(2, "hpm: chunked transfer-encoding unsupported\n")
        else:
            write_str(2, "hpm: HTTP fetch failed\n")
        return -1
    if status != 200:
        write_str(2, "hpm: HTTP request did not return 200 OK\n")
        return -1
    # Slide body bytes to the front of dst so callers see a clean buffer.
    if body_off > 0:
        i: uint64 = 0
        while i < body_len:
            dst[i] = dst[body_off + i]
            i = i + 1
    return cast[int64](body_len)


# -- repo default + flag handling -------------------------------------

def _set_repo_default():
    # The canonical hosted repo. Override via `--repo=<url>` flag.
    s: Ptr[uint8] = "https://255.one/"
    _strcopy_cstr(&repo_url_buf[0], s, 1024)


def _set_repo(url: Ptr[uint8]):
    _strcopy_cstr(&repo_url_buf[0], url, 1024)


def _apply_repo() -> int32:
    # Parse repo_url_buf into url_scheme + host_buf + path_buf.
    return _parse_url(&repo_url_buf[0])


# -- channel state ----------------------------------------------------
#
# Channels are subdirectories under the repo base. /etc/hpm/channels
# holds the subscription list (one name per line, # comments ok). On
# `hpm refresh` we walk every enabled channel, fetch its index.json,
# and merge the entries into a single in-memory database keyed by
# pkg_*[] arrays — each package carries a pkg_channel_off/len span
# pointing at its source channel name inside idx_buf.

# /etc/hpm/channels is the channel-subscription file path. The
# x86_64 backend rejects string-literal globals, so callers below
# materialise this string inline at each call site.
# Read-buffer cap on /etc/hpm/channels (one channel per line, <100
# channels in any plausible deployment).
CHANNELS_READ_CAP: uint64 = 16384
channels_read_buf: Array[16384, uint8]
# Per-channel-name scratch. Must be BSS (top-level) — U9 nested-Array
# miscompile makes function-local Array buffers unsafe.
channels_name_scratch: Array[128, uint8]


def _channels_reset():
    n_channels = 0
    channel_buf_n = 0


def _channel_add_name(name: Ptr[uint8], nlen: uint64) -> int32:
    # Append a channel name to channel_names_*[]. Returns 0 on
    # success, -1 if a duplicate (already present), -2 if full /
    # overflow.
    if nlen == 0:
        return -2
    # Reject duplicates so `hpm enable main` twice is a no-op.
    ci: uint64 = 0
    while ci < n_channels:
        if channel_names_len[ci] == nlen:
            same: int32 = 1
            ki: uint64 = 0
            while ki < nlen:
                if channel_names_buf[channel_names_off[ci] + ki] != name[ki]:
                    same = 0
                    break
                ki = ki + 1
            if same != 0:
                return -1
        ci = ci + 1
    if n_channels >= CHANNEL_MAX:
        return -2
    if channel_buf_n + nlen + 1 > 4096:
        return -2
    channel_names_off[n_channels] = channel_buf_n
    channel_names_len[n_channels] = nlen
    i: uint64 = 0
    while i < nlen:
        channel_names_buf[channel_buf_n + i] = name[i]
        i = i + 1
    channel_names_buf[channel_buf_n + nlen] = 0
    channel_buf_n = channel_buf_n + nlen + 1
    n_channels = n_channels + 1
    return 0


def _channel_find(name: Ptr[uint8], nlen: uint64) -> int64:
    ci: uint64 = 0
    while ci < n_channels:
        if channel_names_len[ci] == nlen:
            same: int32 = 1
            ki: uint64 = 0
            while ki < nlen:
                if channel_names_buf[channel_names_off[ci] + ki] != name[ki]:
                    same = 0
                    break
                ki = ki + 1
            if same != 0:
                return cast[int64](ci)
        ci = ci + 1
    return cast[int64](-1)


def _channels_load() -> int32:
    # Read the channels subscription list. First try
    # /var/lib/hpm/channels (the writable user-state file maintained
    # by hpm enable/disable); fall back to /etc/hpm/channels (the
    # default shipped with the hamnix-init package, on the read-only
    # cpio in the initramfs case). Either parses one channel name per
    # line; lines starting with `#` are comments. If both are missing
    # or yield zero channels, default to `main`.
    _channels_reset()
    fd: int32 = sys_open(cast[Ptr[char]]("/var/lib/hpm/channels"))
    if fd < 0:
        fd = sys_open(cast[Ptr[char]]("/etc/hpm/channels"))
    if fd < 0:
        # Missing file → default to `main`.
        _channel_add_name(cast[Ptr[uint8]]("main"), 4)
        return 0
    total: uint64 = 0
    while total < CHANNELS_READ_CAP:
        room: uint64 = CHANNELS_READ_CAP - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&channels_read_buf[0]) + total), room)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    # Parse line by line. Skip leading whitespace, skip lines whose
    # first non-whitespace char is `#`, trim trailing CR/LF/WS, accept
    # the resulting non-empty token as a channel name. Names must be
    # [A-Za-z0-9_.-]+ (matches Debian component-name convention).
    i: uint64 = 0
    while i < total:
        # Skip leading WS (SP, TAB).
        while i < total:
            c: uint8 = channels_read_buf[i]
            if c == 32 or c == 9:
                i = i + 1
            else:
                break
        if i >= total:
            break
        c0: uint8 = channels_read_buf[i]
        if c0 == 10 or c0 == 13:
            # Blank line.
            i = i + 1
            continue
        if c0 == 35:
            # Comment — skip to EOL.
            while i < total and channels_read_buf[i] != 10:
                i = i + 1
            if i < total:
                i = i + 1
            continue
        # Accumulate the channel-name token.
        no: uint64 = 0
        while i < total and no + 1 < 128:
            c: uint8 = channels_read_buf[i]
            if c == 10 or c == 13 or c == 32 or c == 9 or c == 35:
                break
            # Validate: allow letters / digits / -/_/.
            ok: int32 = 0
            if c >= 65 and c <= 90:
                ok = 1
            elif c >= 97 and c <= 122:
                ok = 1
            elif c >= 48 and c <= 57:
                ok = 1
            elif c == 45 or c == 46 or c == 95:
                ok = 1
            if ok == 0:
                # Invalid char — skip the rest of the line.
                no = 0
                while i < total and channels_read_buf[i] != 10:
                    i = i + 1
                break
            channels_name_scratch[no] = c
            no = no + 1
            i = i + 1
        channels_name_scratch[no] = 0
        if no > 0:
            _channel_add_name(&channels_name_scratch[0], no)
        # Skip to next line.
        while i < total and channels_read_buf[i] != 10:
            i = i + 1
        if i < total:
            i = i + 1
    if n_channels == 0:
        # File present but no usable channels — back-fill `main` so
        # hpm doesn't sit in a no-channel state.
        _channel_add_name(cast[Ptr[uint8]]("main"), 4)
    return 0


def _channels_save() -> int32:
    # Persist channel_names_*[] to /var/lib/hpm/channels (writable
    # user state — /etc/hpm/channels is the read-only seed and lives
    # on the immutable cpio in the initramfs case). With a brief
    # header so a human editor sees a real comment block.
    sys_mkdir("/var/lib/hpm")
    fd: int32 = sys_open_write(cast[Ptr[char]]("/var/lib/hpm/channels"))
    if fd < 0:
        write_str(2, "hpm: cannot open /var/lib/hpm/channels for write\n")
        return -1
    hdr: Ptr[uint8] = "# /var/lib/hpm/channels - one channel per line. Comments start with #.\n"
    sys_write(fd, hdr, strlen_u8(hdr))
    ci: uint64 = 0
    while ci < n_channels:
        sys_write(fd, &channel_names_buf[channel_names_off[ci]],
                  channel_names_len[ci])
        sys_write(fd, "\n", 1)
        ci = ci + 1
    sys_close(fd)
    return 0


def _save_repo_base():
    # Snapshot repo_url_buf into repo_base_buf so per-channel URL
    # construction can refer back to the user-configured base.
    _strcopy_cstr(&repo_base_buf[0], &repo_url_buf[0], 1024)


def _set_channel_url(ci: uint64) -> int32:
    # Build "<base>/<channel-name>/" into repo_url_buf, then reparse.
    # The base lives in repo_base_buf (snapshotted at main() entry).
    o: uint64 = 0
    bi: uint64 = 0
    while repo_base_buf[bi] != 0 and o + 1 < 1024:
        repo_url_buf[o] = repo_base_buf[bi]
        o = o + 1
        bi = bi + 1
    # Ensure a trailing '/' before appending the channel name.
    if o == 0 or repo_url_buf[o - 1] != 47:
        if o + 1 < 1024:
            repo_url_buf[o] = 47
            o = o + 1
    # Append channel name.
    nlen: uint64 = channel_names_len[ci]
    noff: uint64 = channel_names_off[ci]
    ki: uint64 = 0
    while ki < nlen and o + 1 < 1024:
        repo_url_buf[o] = channel_names_buf[noff + ki]
        o = o + 1
        ki = ki + 1
    # Trailing '/' (so _build_url_path's join produces clean paths).
    if o + 1 < 1024:
        repo_url_buf[o] = 47
        o = o + 1
    repo_url_buf[o] = 0
    return _apply_repo()


# -- minimal JSON parser ----------------------------------------------
#
# The Hamnix-side library does NOT have a JSON parser today (apt
# parsed RFC822 stanzas, not JSON). hpm needs *just enough* to walk
# the schema-1 index.json — strings, numbers, arrays, objects. This
# is a small recursive-descent parser specialised to that subset:
#
#   - No floating point (numbers are integers; we only need size:int).
#   - String escape support: \" \\ \/ \n \r \t \b \f, and \uHHHH
#     decoded to UTF-8 (one BMP code point). \uHHHH surrogate pairs
#     NOT handled (an extremely rare case for our schema; field
#     values are ASCII names/URLs/hashes/descriptions).
#   - Whitespace = SP TAB LF CR per RFC 8259.
#
# The parse PASS records pointer + length spans into idx_buf for each
# package's fields, so the caller never copies the bytes out — fields
# are read directly from the cache via field-by-name lookup. The cache
# is bytewise stable until the next `hpm refresh`.

# Per-package field-span tables. PKG_MAX is generous so the live repo
# can grow; field count per package is the schema's documented set.
PKG_MAX:    uint64 = 1024

# Each package gets these spans (offset + length into idx_buf, or
# 0/0 if absent). 0 is a sentinel "absent" since idx_buf[0] is the
# opening '{' of the top-level object, never the start of a string.
pkg_name_off:        Array[1024, uint64]
pkg_name_len:        Array[1024, uint64]
pkg_version_off:     Array[1024, uint64]
pkg_version_len:     Array[1024, uint64]
pkg_arch_off:        Array[1024, uint64]
pkg_arch_len:        Array[1024, uint64]
pkg_url_off:         Array[1024, uint64]
pkg_url_len:         Array[1024, uint64]
pkg_sha256_off:      Array[1024, uint64]
pkg_sha256_len:      Array[1024, uint64]
pkg_size:            Array[1024, uint64]    # numeric (parsed)
pkg_desc_off:        Array[1024, uint64]
pkg_desc_len:        Array[1024, uint64]
pkg_target_off:      Array[1024, uint64]
pkg_target_len:      Array[1024, uint64]
# pkg_channel_off/len: span of the "channel" field's string value
# (inside idx_buf) for this package. Mirrors how every other field
# is stored — offset+length into the JSON cache. Used by the install
# path to build "<base>/<channel>/<pkg-url>" before fetching.
# pkg_channel_idx_arr[pi] is the index into channel_names_*[]; set
# to a sentinel (uint64 max) for packages with no channel field
# (e.g. legacy index, ISO-mini-repo fixtures using the bare layout).
pkg_channel_off:     Array[1024, uint64]
pkg_channel_len:     Array[1024, uint64]
pkg_channel_idx_arr: Array[1024, uint64]
CHANNEL_IDX_NONE:    uint64 = 65535

# Dependency / conflicts / provides arrays. Each package owns a slice
# of a flat string table; per-entry offset+len is recorded.
DEP_ENTRIES_MAX: uint64 = 8192      # total dep entries across all pkgs
pkg_dep_start:       Array[1024, uint64]
pkg_dep_count:       Array[1024, uint64]
pkg_conf_start:      Array[1024, uint64]
pkg_conf_count:      Array[1024, uint64]
pkg_prov_start:      Array[1024, uint64]
pkg_prov_count:      Array[1024, uint64]

dep_entry_off:       Array[8192, uint64]
dep_entry_len:       Array[8192, uint64]
dep_entry_n:         uint64 = 0

conf_entry_off:      Array[8192, uint64]
conf_entry_len:      Array[8192, uint64]
conf_entry_n:        uint64 = 0

prov_entry_off:      Array[8192, uint64]
prov_entry_len:      Array[8192, uint64]
prov_entry_n:        uint64 = 0

pkg_count:           uint64 = 0

# Parser cursor (byte offset into idx_buf).
jp:    uint64 = 0
jend:  uint64 = 0


def _json_skip_ws():
    while jp < jend:
        c: uint8 = idx_buf[jp]
        if c == 32 or c == 9 or c == 10 or c == 13:
            jp = jp + 1
        else:
            return


def _json_expect(c: uint8) -> int32:
    _json_skip_ws()
    if jp >= jend or idx_buf[jp] != c:
        return -1
    jp = jp + 1
    return 0


def _json_peek() -> int32:
    _json_skip_ws()
    if jp >= jend:
        return -1
    return cast[int32](idx_buf[jp])


# Parse a JSON string. Returns 0 on success and writes the
# string-content span (excluding the surrounding quotes, with escape
# sequences left in their raw form — the consumer is content to read
# escaped backslashes verbatim for our schema's ASCII-only fields)
# to *out_off / *out_len. Skips past the closing quote.

def _json_parse_string(out_off: Ptr[uint64], out_len: Ptr[uint64]) -> int32:
    _json_skip_ws()
    if jp >= jend or idx_buf[jp] != 34:                  # '"'
        return -1
    jp = jp + 1
    start: uint64 = jp
    while jp < jend:
        c: uint8 = idx_buf[jp]
        if c == 92:                                      # '\'
            # Skip the escape introducer + one char. (\uHHHH is 5 more
            # chars; we still skip past them for span-end purposes —
            # the raw escape lives in the span. That's fine: every
            # field hpm reads is plain ASCII in practice.)
            jp = jp + 1
            if jp >= jend:
                return -1
            esc: uint8 = idx_buf[jp]
            jp = jp + 1
            if esc == 117:                               # 'u'
                jp = jp + 4
            continue
        if c == 34:                                      # '"'
            out_off[0] = start
            out_len[0] = jp - start
            jp = jp + 1
            return 0
        jp = jp + 1
    return -1


# Parse an integer. Negative numbers are not in our schema (size is
# always >= 0) — but accept '-' defensively. Returns 0 on success,
# stores the value through *out.

def _json_parse_int(out: Ptr[uint64]) -> int32:
    _json_skip_ws()
    if jp >= jend:
        return -1
    neg: int32 = 0
    if idx_buf[jp] == 45:                                # '-'
        neg = 1
        jp = jp + 1
    if jp >= jend or idx_buf[jp] < 48 or idx_buf[jp] > 57:
        return -1
    v: uint64 = 0
    while jp < jend and idx_buf[jp] >= 48 and idx_buf[jp] <= 57:
        v = v * 10 + cast[uint64](idx_buf[jp] - 48)
        jp = jp + 1
    out[0] = v
    return 0


# Skip over a JSON value (string / number / object / array / true /
# false / null). Used to discard fields the parser doesn't care about
# (top-level "repo", "url", "updated", "description"; package fields
# not in our schema). Returns 0 on success, -1 on a parse error.

def _json_skip_value() -> int32:
    _json_skip_ws()
    if jp >= jend:
        return -1
    c: uint8 = idx_buf[jp]
    if c == 34:                                          # '"'
        off: uint64 = 0
        ln: uint64 = 0
        return _json_parse_string(&off, &ln)
    if c == 45 or (c >= 48 and c <= 57):
        v: uint64 = 0
        return _json_parse_int(&v)
    if c == 116 or c == 102 or c == 110:                 # t / f / n
        # true / false / null — skip the literal.
        while jp < jend:
            cc: uint8 = idx_buf[jp]
            if cc >= 97 and cc <= 122:
                jp = jp + 1
            else:
                break
        return 0
    if c == 91:                                          # '['
        jp = jp + 1
        _json_skip_ws()
        if jp < jend and idx_buf[jp] == 93:
            jp = jp + 1
            return 0
        while True:
            if _json_skip_value() != 0:
                return -1
            _json_skip_ws()
            if jp >= jend:
                return -1
            d: uint8 = idx_buf[jp]
            if d == 44:                                  # ','
                jp = jp + 1
                continue
            if d == 93:                                  # ']'
                jp = jp + 1
                return 0
            return -1
    if c == 123:                                         # '{'
        jp = jp + 1
        _json_skip_ws()
        if jp < jend and idx_buf[jp] == 125:
            jp = jp + 1
            return 0
        while True:
            koff: uint64 = 0
            klen: uint64 = 0
            if _json_parse_string(&koff, &klen) != 0:
                return -1
            if _json_expect(58) != 0:                    # ':'
                return -1
            if _json_skip_value() != 0:
                return -1
            _json_skip_ws()
            if jp >= jend:
                return -1
            d2: uint8 = idx_buf[jp]
            if d2 == 44:
                jp = jp + 1
                continue
            if d2 == 125:                                # '}'
                jp = jp + 1
                return 0
            return -1
    return -1


# Parse a string-array into entry_off[start..start+count) / entry_len[..]
# at the given append cursor. Returns 0 on success and writes the
# count through *out_count. cap_check guards against overflow.

def _json_parse_strarr(entry_off: Ptr[uint64], entry_len: Ptr[uint64],
                       cursor_p: Ptr[uint64], cap: uint64,
                       out_start: Ptr[uint64],
                       out_count: Ptr[uint64]) -> int32:
    _json_skip_ws()
    if jp >= jend or idx_buf[jp] != 91:                  # '['
        return -1
    jp = jp + 1
    out_start[0] = cursor_p[0]
    n: uint64 = 0
    _json_skip_ws()
    if jp < jend and idx_buf[jp] == 93:
        jp = jp + 1
        out_count[0] = 0
        return 0
    while True:
        if cursor_p[0] >= cap:
            write_str(2, "hpm: dep-entry table overflow\n")
            return -1
        soff: uint64 = 0
        slen: uint64 = 0
        if _json_parse_string(&soff, &slen) != 0:
            return -1
        entry_off[cursor_p[0]] = soff
        entry_len[cursor_p[0]] = slen
        cursor_p[0] = cursor_p[0] + 1
        n = n + 1
        _json_skip_ws()
        if jp >= jend:
            return -1
        d: uint8 = idx_buf[jp]
        if d == 44:
            jp = jp + 1
            continue
        if d == 93:
            jp = jp + 1
            out_count[0] = n
            return 0
        return -1


# Parse one package object into pkg_*[pi] slots.

def _json_parse_pkg(pi: uint64) -> int32:
    if _json_expect(123) != 0:                           # '{'
        return -1
    # Initialise spans/counts to 0.
    pkg_name_off[pi] = 0
    pkg_name_len[pi] = 0
    pkg_version_off[pi] = 0
    pkg_version_len[pi] = 0
    pkg_arch_off[pi] = 0
    pkg_arch_len[pi] = 0
    pkg_url_off[pi] = 0
    pkg_url_len[pi] = 0
    pkg_sha256_off[pi] = 0
    pkg_sha256_len[pi] = 0
    pkg_size[pi] = 0
    pkg_desc_off[pi] = 0
    pkg_desc_len[pi] = 0
    pkg_target_off[pi] = 0
    pkg_target_len[pi] = 0
    pkg_channel_off[pi] = 0
    pkg_channel_len[pi] = 0
    pkg_dep_start[pi] = 0
    pkg_dep_count[pi] = 0
    pkg_conf_start[pi] = 0
    pkg_conf_count[pi] = 0
    pkg_prov_start[pi] = 0
    pkg_prov_count[pi] = 0

    _json_skip_ws()
    if jp < jend and idx_buf[jp] == 125:                 # empty {}
        jp = jp + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _json_parse_string(&koff, &klen) != 0:
            return -1
        if _json_expect(58) != 0:
            return -1

        kp: Ptr[uint8] = &idx_buf[koff]
        if klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("name"), 4) != 0:
            if _json_parse_string(&pkg_name_off[pi], &pkg_name_len[pi]) != 0:
                return -1
        elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("version"), 7) != 0:
            if _json_parse_string(&pkg_version_off[pi], &pkg_version_len[pi]) != 0:
                return -1
        elif klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("arch"), 4) != 0:
            if _json_parse_string(&pkg_arch_off[pi], &pkg_arch_len[pi]) != 0:
                return -1
        elif klen == 3 and _streq_n(kp, cast[Ptr[uint8]]("url"), 3) != 0:
            if _json_parse_string(&pkg_url_off[pi], &pkg_url_len[pi]) != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("sha256"), 6) != 0:
            if _json_parse_string(&pkg_sha256_off[pi], &pkg_sha256_len[pi]) != 0:
                return -1
        elif klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("size"), 4) != 0:
            if _json_parse_int(&pkg_size[pi]) != 0:
                return -1
        elif klen == 11 and _streq_n(kp, cast[Ptr[uint8]]("description"), 11) != 0:
            if _json_parse_string(&pkg_desc_off[pi], &pkg_desc_len[pi]) != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("target"), 6) != 0:
            if _json_parse_string(&pkg_target_off[pi], &pkg_target_len[pi]) != 0:
                return -1
        elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("channel"), 7) != 0:
            if _json_parse_string(&pkg_channel_off[pi], &pkg_channel_len[pi]) != 0:
                return -1
        elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("depends"), 7) != 0:
            if _json_parse_strarr(&dep_entry_off[0], &dep_entry_len[0],
                                  &dep_entry_n, 8192,
                                  &pkg_dep_start[pi],
                                  &pkg_dep_count[pi]) != 0:
                return -1
        elif klen == 9 and _streq_n(kp, cast[Ptr[uint8]]("conflicts"), 9) != 0:
            if _json_parse_strarr(&conf_entry_off[0], &conf_entry_len[0],
                                  &conf_entry_n, 8192,
                                  &pkg_conf_start[pi],
                                  &pkg_conf_count[pi]) != 0:
                return -1
        elif klen == 8 and _streq_n(kp, cast[Ptr[uint8]]("provides"), 8) != 0:
            if _json_parse_strarr(&prov_entry_off[0], &prov_entry_len[0],
                                  &prov_entry_n, 8192,
                                  &pkg_prov_start[pi],
                                  &pkg_prov_count[pi]) != 0:
                return -1
        else:
            # Unknown key — skip its value defensively.
            if _json_skip_value() != 0:
                return -1

        _json_skip_ws()
        if jp >= jend:
            return -1
        d: uint8 = idx_buf[jp]
        if d == 44:
            jp = jp + 1
            continue
        if d == 125:
            jp = jp + 1
            return 0
        return -1


def _json_parse_index() -> int32:
    # Parse idx_buf[0..idx_len) as a schema-1 index. Walks the top-
    # level object, recognises "packages" (the only field we keep),
    # skips everything else. Fills pkg_*[0..pkg_count).
    jp = 0
    jend = idx_len
    pkg_count = 0
    dep_entry_n = 0
    conf_entry_n = 0
    prov_entry_n = 0

    if _json_expect(123) != 0:
        write_str(2, "hpm: index: top-level is not a JSON object\n")
        return -1
    _json_skip_ws()
    if jp < jend and idx_buf[jp] == 125:
        jp = jp + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _json_parse_string(&koff, &klen) != 0:
            write_str(2, "hpm: index: malformed key\n")
            return -1
        if _json_expect(58) != 0:
            write_str(2, "hpm: index: expected ':'\n")
            return -1
        kp: Ptr[uint8] = &idx_buf[koff]
        if klen == 8 and _streq_n(kp, cast[Ptr[uint8]]("packages"), 8) != 0:
            _json_skip_ws()
            if jp >= jend or idx_buf[jp] != 91:          # '['
                write_str(2, "hpm: index: packages is not an array\n")
                return -1
            jp = jp + 1
            _json_skip_ws()
            if jp < jend and idx_buf[jp] == 93:
                jp = jp + 1
            else:
                while True:
                    if pkg_count >= 1024:
                        write_str(2, "hpm: index: too many packages (>1024)\n")
                        return -1
                    if _json_parse_pkg(pkg_count) != 0:
                        write_str(2, "hpm: index: malformed package object\n")
                        return -1
                    pkg_count = pkg_count + 1
                    _json_skip_ws()
                    if jp >= jend:
                        return -1
                    d: uint8 = idx_buf[jp]
                    if d == 44:
                        jp = jp + 1
                        continue
                    if d == 93:
                        jp = jp + 1
                        break
                    write_str(2, "hpm: index: malformed packages array\n")
                    return -1
        else:
            if _json_skip_value() != 0:
                return -1

        _json_skip_ws()
        if jp >= jend:
            return -1
        d2: uint8 = idx_buf[jp]
        if d2 == 44:
            jp = jp + 1
            continue
        if d2 == 125:
            jp = jp + 1
            return 0
        write_str(2, "hpm: index: malformed top-level object\n")
        return -1


# -- post-parse: stamp pkg_channel_idx_arr[] from "channel" spans -----
#
# After _json_parse_index() fills pkg_channel_off/len[], walk every
# package and look up its channel name in channel_names_*[]. Packages
# without a channel field (legacy fixtures) get the sentinel
# CHANNEL_IDX_NONE; install paths fall back to the bare repo for
# those.

def _index_channels():
    pi: uint64 = 0
    while pi < pkg_count:
        if pkg_channel_len[pi] == 0:
            pkg_channel_idx_arr[pi] = CHANNEL_IDX_NONE
        else:
            ci: int64 = _channel_find(&idx_buf[pkg_channel_off[pi]],
                                      pkg_channel_len[pi])
            if ci < 0:
                # Channel referenced by the index isn't subscribed;
                # this happens if we cache a multi-channel index and
                # later the user `hpm disable`s the channel. The
                # entry is dead — flag with sentinel.
                pkg_channel_idx_arr[pi] = CHANNEL_IDX_NONE
            else:
                pkg_channel_idx_arr[pi] = cast[uint64](ci)
        pi = pi + 1


def _pkg_set_channel_url(pi: uint64) -> int32:
    # Before fetching a package's tarball, switch repo_url_buf from
    # the bare base to the package's channel URL. If the package has
    # no channel (CHANNEL_IDX_NONE), fall back to the bare base —
    # supports the ISO mini-repo's pre-channel-pivot file:// layout
    # where iso-packages/main/ is structurally identical to a v1
    # flat repo (channel name == "main" / lives at <base>/main/ if
    # the tail "main" is in the iso-packages base path already; or
    # at <base>/ if not).
    ci: uint64 = pkg_channel_idx_arr[pi]
    if ci == CHANNEL_IDX_NONE:
        _strcopy_cstr(&repo_url_buf[0], &repo_base_buf[0], 1024)
        return _apply_repo()
    return _set_channel_url(ci)


# -- index cache: load + refresh --------------------------------------

def _ensure_hpm_tmpdir():
    # /tmp is tmpfs-owned; mkdir is idempotent (returns -EEXIST on retry).
    sys_mkdir("/tmp/hpm")


def _save_index_cache() -> int32:
    _ensure_hpm_tmpdir()
    fd: int32 = sys_open_write("/tmp/hpm/index.json")
    if fd < 0:
        write_str(2, "hpm: cannot open /tmp/hpm/index.json for write\n")
        return -1
    wn: int64 = _write_full(fd, &idx_buf[0], idx_len)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != idx_len:
        write_str(2, "hpm: short write on /tmp/hpm/index.json\n")
        return -1
    return 0


def _load_index_cache() -> int32:
    # Try the tmpfs cache. If absent, hpm requires a `refresh` first.
    fd: int32 = sys_open("/tmp/hpm/index.json")
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < INDEX_CAP:
        room: uint64 = INDEX_CAP - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&idx_buf[0]) + total), room)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    idx_len = total
    if _json_parse_index() != 0:
        return -1
    # Channel state needs to be loaded so the per-pkg channel-name
    # spans (pkg_channel_off/len) can be mapped to subscription
    # indices. Reading /etc/hpm/channels is cheap + idempotent.
    if n_channels == 0:
        _channels_load()
    _index_channels()
    return 0


# -- merged-index synthesis ------------------------------------------
#
# `hpm refresh` builds ONE merged index in idx_buf by walking every
# enabled channel, fetching its index.json, and splicing each package
# object into a unified `{"schema":1,"packages":[ ... ]}` envelope.
# Every spliced object gets a `"channel":"<name>"` field injected
# right after its opening `{` so the parser can stamp pkg_channel_*[]
# spans into idx_buf for downstream install operations.
#
# The synthesised text lives in idx_buf so the existing index parser
# + index cache path (_save_index_cache → /tmp/hpm/index.json) work
# unchanged.

# Scratch: per-channel raw fetch lands here, then gets spliced into
# idx_buf. http_buf is the existing 256 KiB BSS arena (declared
# above, otherwise unused) — reusing it avoids growing the binary.
# A single channel's index is capped at 256 KiB.

def _idx_emit(s: Ptr[uint8]) -> int32:
    # Append a NUL-terminated string to idx_buf at idx_len. Returns 0
    # on success, -1 on overflow.
    si: uint64 = 0
    while s[si] != 0:
        if idx_len + 1 >= INDEX_CAP:
            return -1
        idx_buf[idx_len] = s[si]
        idx_len = idx_len + 1
        si = si + 1
    return 0


def _idx_emit_byte(c: uint8) -> int32:
    if idx_len + 1 >= INDEX_CAP:
        return -1
    idx_buf[idx_len] = c
    idx_len = idx_len + 1
    return 0


def _idx_emit_quoted(s: Ptr[uint8], slen: uint64) -> int32:
    # Emit a JSON string literal "<s>" with no escaping (channel
    # names are restricted to [A-Za-z0-9_.-] per _channels_load's
    # validator, so JSON escapes aren't needed).
    if _idx_emit_byte(34) != 0:
        return -1
    i: uint64 = 0
    while i < slen:
        if _idx_emit_byte(s[i]) != 0:
            return -1
        i = i + 1
    if _idx_emit_byte(34) != 0:
        return -1
    return 0


# Scratch buffer for one channel's raw index fetch. Distinct from
# idx_buf so the splice can read source bytes + write dest bytes
# without aliasing.
ch_fetch_buf: Array[262144, uint8]


def _splice_channel_into_idx(ci: uint64, fbuf_len: uint64,
                             out_n_pkgs: Ptr[uint64]) -> int32:
    # Walk ch_fetch_buf[0..fbuf_len) — a fetched per-channel index
    # JSON — and append each package object (with a synthesised
    # "channel":"<name>" field) into idx_buf at idx_len.
    #
    # Approach: simple state machine over the raw bytes. We're not
    # validating the per-channel JSON for full correctness here; we
    # rely on the downstream _json_parse_index() pass to catch any
    # malformed combined output.
    #
    # 1. Find `"packages"` in the source.
    # 2. Find the `[` after it.
    # 3. Walk objects: skip ws/commas; on `{` start an object, copy
    #    bytes through the matching `}` (string-aware bracket
    #    counting), but right after the opening `{` inject
    #    `"channel":"<channel-name>"`.
    # 4. Stop when we hit `]` at top-of-array depth.
    out_n_pkgs[0] = 0
    needle: Ptr[uint8] = "\"packages\""
    nlen: uint64 = 10
    pi: uint64 = 0
    found: int32 = 0
    if fbuf_len >= nlen:
        while pi + nlen <= fbuf_len:
            ok: int32 = 1
            kj: uint64 = 0
            while kj < nlen:
                if ch_fetch_buf[pi + kj] != needle[kj]:
                    ok = 0
                    break
                kj = kj + 1
            if ok != 0:
                found = 1
                pi = pi + nlen
                break
            pi = pi + 1
    if found == 0:
        # No packages array — channel is empty / malformed.
        return 0
    # Skip whitespace + colon.
    while pi < fbuf_len:
        c: uint8 = ch_fetch_buf[pi]
        if c == 32 or c == 9 or c == 10 or c == 13:
            pi = pi + 1
        elif c == 58:                                    # ':'
            pi = pi + 1
            break
        else:
            # Unexpected.
            return -1
    while pi < fbuf_len:
        c: uint8 = ch_fetch_buf[pi]
        if c == 32 or c == 9 or c == 10 or c == 13:
            pi = pi + 1
        else:
            break
    if pi >= fbuf_len or ch_fetch_buf[pi] != 91:         # '['
        return -1
    pi = pi + 1
    chname: Ptr[uint8] = &channel_names_buf[channel_names_off[ci]]
    chlen: uint64 = channel_names_len[ci]
    n_pkgs: uint64 = 0
    while pi < fbuf_len:
        c: uint8 = ch_fetch_buf[pi]
        if c == 32 or c == 9 or c == 10 or c == 13 or c == 44:
            pi = pi + 1
            continue
        if c == 93:                                       # ']'
            pi = pi + 1
            break
        if c != 123:                                      # not '{'
            return -1
        # Inter-object separator if this isn't the first.
        if n_pkgs > 0:
            if _idx_emit_byte(44) != 0:                  # ','
                return -1
        # Emit `{"channel":"<name>"` then copy rest.
        if _idx_emit_byte(123) != 0:                     # '{'
            return -1
        ch_key: Ptr[uint8] = "\"channel\":"
        if _idx_emit(ch_key) != 0:
            return -1
        if _idx_emit_quoted(chname, chlen) != 0:
            return -1
        # Copy the rest of the object, tracking nesting + strings,
        # until matching `}` at depth 0.
        pi = pi + 1                                       # past '{'
        # If the source object has any keys, the first byte after
        # the injected channel must be a comma so the object stays
        # syntactically valid. Peek to see if the object is empty.
        peek: uint64 = pi
        while peek < fbuf_len:
            pc: uint8 = ch_fetch_buf[peek]
            if pc == 32 or pc == 9 or pc == 10 or pc == 13:
                peek = peek + 1
            else:
                break
        nonempty: int32 = 1
        if peek >= fbuf_len:
            nonempty = 0
        elif ch_fetch_buf[peek] == 125:
            nonempty = 0
        if nonempty != 0:
            if _idx_emit_byte(44) != 0:
                return -1
        depth: int32 = 1
        in_str: int32 = 0
        in_esc: int32 = 0
        while pi < fbuf_len and depth > 0:
            c2: uint8 = ch_fetch_buf[pi]
            if _idx_emit_byte(c2) != 0:
                return -1
            if in_esc != 0:
                in_esc = 0
                pi = pi + 1
                continue
            if in_str != 0:
                if c2 == 92:
                    in_esc = 1
                elif c2 == 34:
                    in_str = 0
                pi = pi + 1
                continue
            if c2 == 34:
                in_str = 1
            elif c2 == 123:
                depth = depth + 1
            elif c2 == 125:
                depth = depth - 1
            pi = pi + 1
        if depth != 0:
            return -1
        n_pkgs = n_pkgs + 1
    out_n_pkgs[0] = n_pkgs
    return 0


def cmd_refresh() -> int32:
    # Read enabled channels from /etc/hpm/channels (or default to
    # `main`), then fetch + merge every channel's index.json. The
    # merged form lives in idx_buf and is persisted to /tmp/hpm/
    # index.json so subsequent list/search/show commands have the
    # whole package universe cached.
    if _channels_load() != 0:
        write_str(2, "hpm: failed to read channels\n")
        return 1
    if n_channels == 0:
        write_str(2, "hpm: no channels enabled — see /etc/hpm/channels\n")
        return 1

    # Build the merged envelope into idx_buf. Reset the parser/db.
    idx_len = 0
    pkg_count = 0
    dep_entry_n = 0
    conf_entry_n = 0
    prov_entry_n = 0

    head: Ptr[uint8] = "{\"schema\":1,\"packages\":["
    if _idx_emit(head) != 0:
        write_str(2, "hpm: refresh: idx_buf overflow (head)\n")
        return 1

    total_pkgs: uint64 = 0
    ci: uint64 = 0
    n_failed: uint64 = 0
    while ci < n_channels:
        if _set_channel_url(ci) != 0:
            write_str(2, "hpm: refresh: bad channel URL for ")
            sys_write(2, &channel_names_buf[channel_names_off[ci]],
                      channel_names_len[ci])
            write_str(2, "\n")
            return 1
        write_str(1, "hpm: fetching channel ")
        sys_write(1, &channel_names_buf[channel_names_off[ci]],
                  channel_names_len[ci])
        write_str(1, " from ")
        write_str(1, &repo_url_buf[0])
        write_str(1, "\n")
        n: int64 = fetch_to_buf(cast[Ptr[uint8]]("index.json"),
                                &ch_fetch_buf[0], 262144)
        if n < 0:
            write_str(2, "hpm: refresh: cannot fetch channel ")
            sys_write(2, &channel_names_buf[channel_names_off[ci]],
                      channel_names_len[ci])
            write_str(2, "\n")
            n_failed = n_failed + 1
            ci = ci + 1
            continue
        # Splice into idx_buf. Need a leading ',' separator if any
        # previous channel already contributed packages.
        if total_pkgs > 0:
            # Inject a separator BEFORE this channel's objects — but
            # _splice_channel_into_idx also injects ',' between
            # objects within its own batch. We pre-inject by writing
            # a comma here ONLY if the splice will produce >=1 obj.
            # Simpler: have the splicer remember whether it's the
            # first call. We pass a sentinel via total_pkgs and let
            # the splicer's per-object separator handle it.
            pass
        added: uint64 = 0
        # Pre-add comma if total_pkgs > 0 (because the splicer's
        # first object won't add one for its own first emission).
        # We patch this by adjusting the splicer's local n_pkgs
        # start. Easiest: emit the comma here, then have the splicer
        # treat its first emit as "not first".
        # Re-implement: pass an inout cursor so the splicer behaves
        # uniformly.
        if total_pkgs > 0:
            if _idx_emit_byte(44) != 0:                   # ','
                write_str(2, "hpm: refresh: idx_buf overflow\n")
                return 1
            # Force the splicer to NOT emit a leading comma for its
            # first object — we already did. Set total_pkgs lower
            # bound trick: bump n_pkgs starting value inside splicer.
        # NB: _splice_channel_into_idx emits ',' BEFORE each object
        # after its first (its local n_pkgs counter starts at 0).
        # That means we've already emitted exactly one leading ','
        # above, and the splicer will emit ',' before its 2nd, 3rd,
        # ... objects. Net: the joined output has one ',' between
        # every two adjacent objects across channels. Correct.
        sp_rc: int32 = _splice_channel_into_idx(ci,
                                                cast[uint64](n),
                                                &added)
        if sp_rc != 0:
            write_str(2, "hpm: refresh: malformed index for channel ")
            sys_write(2, &channel_names_buf[channel_names_off[ci]],
                      channel_names_len[ci])
            write_str(2, "\n")
            return 1
        write_str(1, "hpm:   (")
        write_dec_u64(1, added)
        write_str(1, " packages)\n")
        # If the channel was empty (no objects), the comma we injected
        # is a stray. Strip it back off.
        if added == 0 and total_pkgs > 0:
            idx_len = idx_len - 1
        total_pkgs = total_pkgs + added
        ci = ci + 1

    tail: Ptr[uint8] = "]}\n"
    if _idx_emit(tail) != 0:
        write_str(2, "hpm: refresh: idx_buf overflow (tail)\n")
        return 1
    # Drop the trailing '\n' from idx_len so the parser sees clean
    # `]}` at EOF (it accepts trailing WS, but the cache file gets a
    # newline written below).
    if idx_len > 0 and idx_buf[idx_len - 1] == 10:
        idx_len = idx_len - 1

    if _json_parse_index() != 0:
        write_str(2, "hpm: refresh: merged index.json parse failed\n")
        return 1
    _index_channels()
    # Re-append the newline for the on-disk cache.
    if idx_len + 1 < INDEX_CAP:
        idx_buf[idx_len] = 10
        idx_len = idx_len + 1
    if _save_index_cache() != 0:
        return 1
    # Restore the user-configured base URL (repo_url_buf was clobbered
    # per-channel; subsequent install operations re-derive channel
    # URLs from repo_base_buf, but we keep repo_url_buf in sync for
    # any diagnostic that echoes the current "repo").
    _strcopy_cstr(&repo_url_buf[0], &repo_base_buf[0], 1024)
    _apply_repo()
    write_str(1, "hpm: refreshed index from ")
    write_str(1, &repo_url_buf[0])
    write_str(1, " (")
    write_dec_u64(1, pkg_count)
    write_str(1, " packages across ")
    write_dec_u64(1, n_channels)
    write_str(1, " channels, ")
    write_dec_u64(1, idx_len)
    write_str(1, " bytes)\n")
    if n_failed > 0:
        write_str(2, "hpm: warning: ")
        write_dec_u64(2, n_failed)
        write_str(2, " channel(s) failed to fetch — partial index loaded\n")
    return 0


# -- installed.json -- read + parse + write ---------------------------
#
# Installed DB schema (per docs/packages.md):
#   { "schema": 1,
#     "packages": [ { "name": "...", "version": "...",
#                     "installed_at": "...", "pinned": false,
#                     "target": "#hamnix-system",
#                     "files": ["bin/foo", ...] }, ... ] }
#
# Phase 1 only needs to READ this to print `hpm list`. Phase 2/3 will
# write to it as well.

INST_MAX:        uint64 = 256
inst_name_off:   Array[256, uint64]
inst_name_len:   Array[256, uint64]
inst_ver_off:    Array[256, uint64]
inst_ver_len:    Array[256, uint64]
inst_pinned:     Array[256, int32]
inst_target_off: Array[256, uint64]
inst_target_len: Array[256, uint64]
inst_at_off:     Array[256, uint64]
inst_at_len:     Array[256, uint64]
# Files: per-installed-pkg slice of a flat (offset, length) table.
INST_FILES_MAX:  uint64 = 8192
inst_file_start: Array[256, uint64]
inst_file_count: Array[256, uint64]
inst_file_off:   Array[8192, uint64]
inst_file_len:   Array[8192, uint64]
inst_file_n:     uint64 = 0
inst_count:      uint64 = 0

# Parser cursor for inst_buf (parallel to idx_buf's jp/jend).
ip:   uint64 = 0
iend: uint64 = 0


def _inst_skip_ws():
    while ip < iend:
        c: uint8 = inst_buf[ip]
        if c == 32 or c == 9 or c == 10 or c == 13:
            ip = ip + 1
        else:
            return


def _inst_expect(c: uint8) -> int32:
    _inst_skip_ws()
    if ip >= iend or inst_buf[ip] != c:
        return -1
    ip = ip + 1
    return 0


def _inst_parse_string(out_off: Ptr[uint64], out_len: Ptr[uint64]) -> int32:
    _inst_skip_ws()
    if ip >= iend or inst_buf[ip] != 34:
        return -1
    ip = ip + 1
    start: uint64 = ip
    while ip < iend:
        c: uint8 = inst_buf[ip]
        if c == 92:
            ip = ip + 1
            if ip >= iend:
                return -1
            esc: uint8 = inst_buf[ip]
            ip = ip + 1
            if esc == 117:
                ip = ip + 4
            continue
        if c == 34:
            out_off[0] = start
            out_len[0] = ip - start
            ip = ip + 1
            return 0
        ip = ip + 1
    return -1


def _inst_parse_int(out: Ptr[uint64]) -> int32:
    _inst_skip_ws()
    if ip >= iend:
        return -1
    if inst_buf[ip] == 45:
        ip = ip + 1
    if ip >= iend or inst_buf[ip] < 48 or inst_buf[ip] > 57:
        return -1
    v: uint64 = 0
    while ip < iend and inst_buf[ip] >= 48 and inst_buf[ip] <= 57:
        v = v * 10 + cast[uint64](inst_buf[ip] - 48)
        ip = ip + 1
    out[0] = v
    return 0


def _inst_skip_value() -> int32:
    _inst_skip_ws()
    if ip >= iend:
        return -1
    c: uint8 = inst_buf[ip]
    if c == 34:
        off: uint64 = 0
        ln: uint64 = 0
        return _inst_parse_string(&off, &ln)
    if c == 45 or (c >= 48 and c <= 57):
        v: uint64 = 0
        return _inst_parse_int(&v)
    if c == 116 or c == 102 or c == 110:
        while ip < iend:
            cc: uint8 = inst_buf[ip]
            if cc >= 97 and cc <= 122:
                ip = ip + 1
            else:
                break
        return 0
    if c == 91:                                          # '['
        ip = ip + 1
        _inst_skip_ws()
        if ip < iend and inst_buf[ip] == 93:
            ip = ip + 1
            return 0
        while True:
            if _inst_skip_value() != 0:
                return -1
            _inst_skip_ws()
            if ip >= iend:
                return -1
            d: uint8 = inst_buf[ip]
            if d == 44:
                ip = ip + 1
                continue
            if d == 93:
                ip = ip + 1
                return 0
            return -1
    if c == 123:                                         # '{'
        ip = ip + 1
        _inst_skip_ws()
        if ip < iend and inst_buf[ip] == 125:
            ip = ip + 1
            return 0
        while True:
            koff: uint64 = 0
            klen: uint64 = 0
            if _inst_parse_string(&koff, &klen) != 0:
                return -1
            if _inst_expect(58) != 0:
                return -1
            if _inst_skip_value() != 0:
                return -1
            _inst_skip_ws()
            if ip >= iend:
                return -1
            d2: uint8 = inst_buf[ip]
            if d2 == 44:
                ip = ip + 1
                continue
            if d2 == 125:
                ip = ip + 1
                return 0
            return -1
    return -1


def _inst_parse_strarr_files(idx_i: uint64) -> int32:
    _inst_skip_ws()
    if ip >= iend or inst_buf[ip] != 91:
        return -1
    ip = ip + 1
    inst_file_start[idx_i] = inst_file_n
    n: uint64 = 0
    _inst_skip_ws()
    if ip < iend and inst_buf[ip] == 93:
        ip = ip + 1
        inst_file_count[idx_i] = 0
        return 0
    while True:
        if inst_file_n >= 8192:
            write_str(2, "hpm: installed: file table overflow\n")
            return -1
        soff: uint64 = 0
        slen: uint64 = 0
        if _inst_parse_string(&soff, &slen) != 0:
            return -1
        inst_file_off[inst_file_n] = soff
        inst_file_len[inst_file_n] = slen
        inst_file_n = inst_file_n + 1
        n = n + 1
        _inst_skip_ws()
        if ip >= iend:
            return -1
        d: uint8 = inst_buf[ip]
        if d == 44:
            ip = ip + 1
            continue
        if d == 93:
            ip = ip + 1
            inst_file_count[idx_i] = n
            return 0
        return -1


def _inst_parse_pkg(i: uint64) -> int32:
    if _inst_expect(123) != 0:
        return -1
    inst_name_off[i] = 0
    inst_name_len[i] = 0
    inst_ver_off[i] = 0
    inst_ver_len[i] = 0
    inst_pinned[i] = 0
    inst_target_off[i] = 0
    inst_target_len[i] = 0
    inst_at_off[i] = 0
    inst_at_len[i] = 0
    inst_file_start[i] = 0
    inst_file_count[i] = 0

    _inst_skip_ws()
    if ip < iend and inst_buf[ip] == 125:
        ip = ip + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _inst_parse_string(&koff, &klen) != 0:
            return -1
        if _inst_expect(58) != 0:
            return -1
        kp: Ptr[uint8] = &inst_buf[koff]
        if klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("name"), 4) != 0:
            if _inst_parse_string(&inst_name_off[i], &inst_name_len[i]) != 0:
                return -1
        elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("version"), 7) != 0:
            if _inst_parse_string(&inst_ver_off[i], &inst_ver_len[i]) != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("pinned"), 6) != 0:
            # true / false literal — peek first char.
            _inst_skip_ws()
            if ip < iend and inst_buf[ip] == 116:        # 't'
                inst_pinned[i] = 1
            else:
                inst_pinned[i] = 0
            if _inst_skip_value() != 0:
                return -1
        elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("target"), 6) != 0:
            if _inst_parse_string(&inst_target_off[i], &inst_target_len[i]) != 0:
                return -1
        elif klen == 12 and _streq_n(kp, cast[Ptr[uint8]]("installed_at"), 12) != 0:
            if _inst_parse_string(&inst_at_off[i], &inst_at_len[i]) != 0:
                return -1
        elif klen == 5 and _streq_n(kp, cast[Ptr[uint8]]("files"), 5) != 0:
            if _inst_parse_strarr_files(i) != 0:
                return -1
        else:
            if _inst_skip_value() != 0:
                return -1

        _inst_skip_ws()
        if ip >= iend:
            return -1
        d: uint8 = inst_buf[ip]
        if d == 44:
            ip = ip + 1
            continue
        if d == 125:
            ip = ip + 1
            return 0
        return -1


def _load_installed() -> int32:
    # Returns 0 on a parsed DB (which may be empty),
    # 1 on absent file (treated as "no packages installed yet").
    inst_count = 0
    inst_file_n = 0
    fd: int32 = sys_open("/var/lib/hpm/installed.json")
    if fd < 0:
        return 1
    total: uint64 = 0
    while total < INSTALLED_CAP:
        room: uint64 = INSTALLED_CAP - total
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&inst_buf[0]) + total), room)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    inst_len = total
    if total == 0:
        return 1                                          # empty DB

    ip = 0
    iend = inst_len
    if _inst_expect(123) != 0:
        write_str(2, "hpm: installed.json: top-level is not an object\n")
        return -1
    _inst_skip_ws()
    if ip < iend and inst_buf[ip] == 125:
        ip = ip + 1
        return 0
    while True:
        koff: uint64 = 0
        klen: uint64 = 0
        if _inst_parse_string(&koff, &klen) != 0:
            write_str(2, "hpm: installed.json: malformed key\n")
            return -1
        if _inst_expect(58) != 0:
            return -1
        kp: Ptr[uint8] = &inst_buf[koff]
        if klen == 8 and _streq_n(kp, cast[Ptr[uint8]]("packages"), 8) != 0:
            _inst_skip_ws()
            if ip >= iend or inst_buf[ip] != 91:
                write_str(2, "hpm: installed.json: packages is not array\n")
                return -1
            ip = ip + 1
            _inst_skip_ws()
            if ip < iend and inst_buf[ip] == 93:
                ip = ip + 1
            else:
                while True:
                    if inst_count >= 256:
                        write_str(2, "hpm: installed.json: too many packages\n")
                        return -1
                    if _inst_parse_pkg(inst_count) != 0:
                        return -1
                    inst_count = inst_count + 1
                    _inst_skip_ws()
                    if ip >= iend:
                        return -1
                    d: uint8 = inst_buf[ip]
                    if d == 44:
                        ip = ip + 1
                        continue
                    if d == 93:
                        ip = ip + 1
                        break
                    return -1
        else:
            if _inst_skip_value() != 0:
                return -1

        _inst_skip_ws()
        if ip >= iend:
            return -1
        d2: uint8 = inst_buf[ip]
        if d2 == 44:
            ip = ip + 1
            continue
        if d2 == 125:
            ip = ip + 1
            return 0
        return -1


# -- pretty-print helpers (write a span from idx_buf or inst_buf) -----

def _write_span(fd: int32, base: Ptr[uint8], off: uint64, ln: uint64):
    if ln == 0:
        return
    sys_write(fd, cast[Ptr[uint8]](cast[uint64](base) + off), ln)


# -- commands: list / search / show -----------------------------------

def cmd_list() -> int32:
    rc: int32 = _load_installed()
    if rc < 0:
        return 1
    if rc == 1 or inst_count == 0:
        write_str(1, "hpm: no packages installed\n")
        return 0
    i: uint64 = 0
    while i < inst_count:
        # "<name>  <version>  [pinned]  <target>"
        _write_span(1, &inst_buf[0], inst_name_off[i], inst_name_len[i])
        sys_write(1, "  ", 2)
        _write_span(1, &inst_buf[0], inst_ver_off[i], inst_ver_len[i])
        sys_write(1, "  ", 2)
        if inst_pinned[i] != 0:
            sys_write(1, "[pinned]  ", 10)
        if inst_target_len[i] > 0:
            _write_span(1, &inst_buf[0], inst_target_off[i],
                        inst_target_len[i])
        else:
            sys_write(1, "#hamnix-system", 14)
        sys_write(1, "\n", 1)
        i = i + 1
    return 0


def cmd_search(pattern: Ptr[uint8]) -> int32:
    # Substring match against pkg_name spans. Requires a refreshed cache.
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    # Materialise the pattern as a NUL-terminated cstring already (it
    # came from argv). For each package, copy name to a scratch cstring
    # and substring-match. We use a scratch buf.
    matched: uint64 = 0
    namescratch: Array[128, uint8]
    i: uint64 = 0
    while i < pkg_count:
        ln: uint64 = pkg_name_len[i]
        _strcopy_n(&namescratch[0],
                   cast[Ptr[uint8]](
                       cast[uint64](&idx_buf[0]) + pkg_name_off[i]),
                   ln, 128)
        if _strcontains(&namescratch[0], pattern) != 0:
            _write_span(1, &idx_buf[0], pkg_name_off[i], pkg_name_len[i])
            sys_write(1, "  ", 2)
            _write_span(1, &idx_buf[0], pkg_version_off[i], pkg_version_len[i])
            sys_write(1, "  -  ", 5)
            _write_span(1, &idx_buf[0], pkg_desc_off[i], pkg_desc_len[i])
            sys_write(1, "\n", 1)
            matched = matched + 1
        i = i + 1
    if matched == 0:
        write_str(2, "hpm: no packages match \"")
        write_str(2, pattern)
        write_str(2, "\"\n")
        return 1
    return 0


def _name_eq_span(off: uint64, ln: uint64, want: Ptr[uint8],
                  want_len: uint64) -> int32:
    if ln != want_len:
        return 0
    i: uint64 = 0
    while i < ln:
        if idx_buf[off + i] != want[i]:
            return 0
        i = i + 1
    return 1


def _ver_eq_span(off: uint64, ln: uint64, want: Ptr[uint8],
                 want_len: uint64) -> int32:
    if ln != want_len:
        return 0
    i: uint64 = 0
    while i < ln:
        if idx_buf[off + i] != want[i]:
            return 0
        i = i + 1
    return 1


# -- version comparison (per docs/packages.md) ------------------------
#
# Dotted-decimal tuples; each component compared as an integer; missing
# components treated as zero. Optional `+<tag>` is build metadata and
# IGNORED for ordering. Returns: -1 if a<b, 0 if a==b, 1 if a>b.

def _vcomp_at(s: Ptr[uint8], n: uint64, p: Ptr[uint64]) -> uint64:
    # Parse one decimal component starting at *p (advances past it).
    # Stops at '.', '+', or end. Returns the integer value.
    v: uint64 = 0
    while p[0] < n:
        c: uint8 = s[p[0]]
        if c == 46 or c == 43:                           # '.' or '+'
            return v
        if c < 48 or c > 57:
            return v
        v = v * 10 + cast[uint64](c - 48)
        p[0] = p[0] + 1
    return v


def _version_compare(a: Ptr[uint8], an: uint64,
                     b: Ptr[uint8], bn: uint64) -> int32:
    # Strip everything from '+' on (build metadata).
    ae: uint64 = 0
    while ae < an and a[ae] != 43:
        ae = ae + 1
    be: uint64 = 0
    while be < bn and b[be] != 43:
        be = be + 1
    ap: uint64 = 0
    bp: uint64 = 0
    while ap < ae or bp < be:
        av: uint64 = 0
        bv: uint64 = 0
        if ap < ae:
            av = _vcomp_at(a, ae, &ap)
        if bp < be:
            bv = _vcomp_at(b, be, &bp)
        if av < bv:
            return -1
        if av > bv:
            return 1
        # Skip the separator '.'.
        if ap < ae and a[ap] == 46:
            ap = ap + 1
        if bp < be and b[bp] == 46:
            bp = bp + 1
    return 0


# Return the index of the best (highest version) package whose name
# equals `want`. Returns -1 if no such package.
def _pkg_find_best(want: Ptr[uint8], want_len: uint64) -> int64:
    best: int64 = -1
    i: uint64 = 0
    while i < pkg_count:
        if _name_eq_span(pkg_name_off[i], pkg_name_len[i],
                         want, want_len) != 0:
            if best < 0:
                best = cast[int64](i)
            else:
                bi: uint64 = cast[uint64](best)
                cmp: int32 = _version_compare(
                    cast[Ptr[uint8]](
                        cast[uint64](&idx_buf[0]) + pkg_version_off[i]),
                    pkg_version_len[i],
                    cast[Ptr[uint8]](
                        cast[uint64](&idx_buf[0]) + pkg_version_off[bi]),
                    pkg_version_len[bi])
                if cmp > 0:
                    best = cast[int64](i)
        i = i + 1
    return best


# Find a package by exact name+version. Returns -1 if not found.
def _pkg_find_exact(want: Ptr[uint8], want_len: uint64,
                    wver: Ptr[uint8], wver_len: uint64) -> int64:
    i: uint64 = 0
    while i < pkg_count:
        if _name_eq_span(pkg_name_off[i], pkg_name_len[i],
                         want, want_len) != 0:
            if _ver_eq_span(pkg_version_off[i], pkg_version_len[i],
                            wver, wver_len) != 0:
                return cast[int64](i)
        i = i + 1
    return -1


# -- show <name>[@<version>] ------------------------------------------

def _split_nameversion(spec: Ptr[uint8],
                       name_out: Ptr[uint8], name_cap: uint64,
                       ver_out: Ptr[uint8], ver_cap: uint64,
                       has_ver: Ptr[int32]):
    # Split on '@'. spec is a NUL-terminated cstring.
    has_ver[0] = 0
    name_out[0] = 0
    ver_out[0] = 0
    no: uint64 = 0
    i: uint64 = 0
    while spec[i] != 0 and spec[i] != 64 and no + 1 < name_cap:    # '@'
        name_out[no] = spec[i]
        no = no + 1
        i = i + 1
    name_out[no] = 0
    if spec[i] == 64:
        has_ver[0] = 1
        i = i + 1
        vo: uint64 = 0
        while spec[i] != 0 and vo + 1 < ver_cap:
            ver_out[vo] = spec[i]
            vo = vo + 1
            i = i + 1
        ver_out[vo] = 0


def cmd_show(spec: Ptr[uint8]) -> int32:
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    name_buf: Array[128, uint8]
    ver_buf:  Array[64, uint8]
    has_ver:  int32 = 0
    _split_nameversion(spec, &name_buf[0], 128, &ver_buf[0], 64, &has_ver)

    idx: int64 = -1
    if has_ver != 0:
        idx = _pkg_find_exact(&name_buf[0], strlen_u8(&name_buf[0]),
                              &ver_buf[0], strlen_u8(&ver_buf[0]))
    else:
        idx = _pkg_find_best(&name_buf[0], strlen_u8(&name_buf[0]))
    if idx < 0:
        write_str(2, "hpm: no package matches \"")
        write_str(2, spec)
        write_str(2, "\"\n")
        return 1
    pi: uint64 = cast[uint64](idx)

    write_str(1, "name: ")
    _write_span(1, &idx_buf[0], pkg_name_off[pi], pkg_name_len[pi])
    write_str(1, "\nversion: ")
    _write_span(1, &idx_buf[0], pkg_version_off[pi], pkg_version_len[pi])
    write_str(1, "\narch: ")
    _write_span(1, &idx_buf[0], pkg_arch_off[pi], pkg_arch_len[pi])
    write_str(1, "\ntarget: ")
    if pkg_target_len[pi] > 0:
        _write_span(1, &idx_buf[0], pkg_target_off[pi], pkg_target_len[pi])
    else:
        sys_write(1, "#hamnix-system", 14)
    write_str(1, "\ndescription: ")
    _write_span(1, &idx_buf[0], pkg_desc_off[pi], pkg_desc_len[pi])
    write_str(1, "\nurl: ")
    _write_span(1, &idx_buf[0], pkg_url_off[pi], pkg_url_len[pi])
    write_str(1, "\nsha256: ")
    _write_span(1, &idx_buf[0], pkg_sha256_off[pi], pkg_sha256_len[pi])
    write_str(1, "\nsize: ")
    write_dec_u64(1, pkg_size[pi])
    write_str(1, " bytes\n")
    if pkg_dep_count[pi] > 0:
        write_str(1, "depends:")
        di: uint64 = 0
        while di < pkg_dep_count[pi]:
            sys_write(1, " ", 1)
            slot: uint64 = pkg_dep_start[pi] + di
            _write_span(1, &idx_buf[0],
                        dep_entry_off[slot], dep_entry_len[slot])
            di = di + 1
        sys_write(1, "\n", 1)
    if pkg_conf_count[pi] > 0:
        write_str(1, "conflicts:")
        ci: uint64 = 0
        while ci < pkg_conf_count[pi]:
            sys_write(1, " ", 1)
            slot: uint64 = pkg_conf_start[pi] + ci
            _write_span(1, &idx_buf[0],
                        conf_entry_off[slot], conf_entry_len[slot])
            ci = ci + 1
        sys_write(1, "\n", 1)
    if pkg_prov_count[pi] > 0:
        write_str(1, "provides:")
        ri: uint64 = 0
        while ri < pkg_prov_count[pi]:
            sys_write(1, " ", 1)
            slot: uint64 = pkg_prov_start[pi] + ri
            _write_span(1, &idx_buf[0],
                        prov_entry_off[slot], prov_entry_len[slot])
            ri = ri + 1
        sys_write(1, "\n", 1)
    return 0


# =====================================================================
# Phase 2: install (trivial case — no deps, no hooks)
# =====================================================================
#
# The trivial-install flow:
#   1. Resolve <name>[@<ver>] against the cached index.
#   2. fetch_to_buf -> deb_buf (the tarball).
#   3. Verify SHA-256 of deb_buf == repo's recorded sha256.
#   4. Inflate the .tar.gz into tar_buf.
#   5. Walk the tar:
#        - The top-level entry is "<name>-<version>/" (per spec).
#        - Other entries we care about: "<dir>/PKGINFO",
#          "<dir>/install.hamsh", "<dir>/files/...".
#        - For each "files/<rel>" entry, place the bytes at the target
#          path (#hamnix-system = init's writable area = root; #distro =
#          /var/lib/distros/default/; #other = treat as #hamnix-system
#          for v1 — see escalation note in the brief).
#   6. Record in installed.json (in-memory append + atomic rewrite).
#   7. Phase 3 wires real hooks; for now: if install.hamsh is present,
#      print "[hpm] hook would run: install.hamsh" so the test can
#      verify the path.
#
# Conflict & dep handling are Phase 3+. This commit only handles the
# happy path of a no-dep, no-conflict package against an empty (or
# non-overlapping) installed.json — exactly the live `hamnix-hello`.

# -- SHA-256 ------------------------------------------------------------
#
# Ported in-line from user/apt.ad (now retired). Same algorithm,
# same incremental reset/update/final API for streaming-friendly
# verification. Operates on the running sha_* BSS state.

sha_state:    Array[8, uint32]
sha_k:        Array[64, uint32]
sha_w:        Array[64, uint32]
sha_block:    Array[64, uint8]
sha_block_n:  uint64 = 0
sha_total:    uint64 = 0
sha_digest:   Array[32, uint8]
sha_hex:      Array[80, uint8]


def _sha256_rotr32(v: uint32, n: uint64) -> uint32:
    x: uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = x >> n
    hi: uint64 = (x << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


def _sha256_init_k():
    sha_k[0]  = 0x428A2F98
    sha_k[1]  = 0x71374491
    sha_k[2]  = 0xB5C0FBCF
    sha_k[3]  = 0xE9B5DBA5
    sha_k[4]  = 0x3956C25B
    sha_k[5]  = 0x59F111F1
    sha_k[6]  = 0x923F82A4
    sha_k[7]  = 0xAB1C5ED5
    sha_k[8]  = 0xD807AA98
    sha_k[9]  = 0x12835B01
    sha_k[10] = 0x243185BE
    sha_k[11] = 0x550C7DC3
    sha_k[12] = 0x72BE5D74
    sha_k[13] = 0x80DEB1FE
    sha_k[14] = 0x9BDC06A7
    sha_k[15] = 0xC19BF174
    sha_k[16] = 0xE49B69C1
    sha_k[17] = 0xEFBE4786
    sha_k[18] = 0x0FC19DC6
    sha_k[19] = 0x240CA1CC
    sha_k[20] = 0x2DE92C6F
    sha_k[21] = 0x4A7484AA
    sha_k[22] = 0x5CB0A9DC
    sha_k[23] = 0x76F988DA
    sha_k[24] = 0x983E5152
    sha_k[25] = 0xA831C66D
    sha_k[26] = 0xB00327C8
    sha_k[27] = 0xBF597FC7
    sha_k[28] = 0xC6E00BF3
    sha_k[29] = 0xD5A79147
    sha_k[30] = 0x06CA6351
    sha_k[31] = 0x14292967
    sha_k[32] = 0x27B70A85
    sha_k[33] = 0x2E1B2138
    sha_k[34] = 0x4D2C6DFC
    sha_k[35] = 0x53380D13
    sha_k[36] = 0x650A7354
    sha_k[37] = 0x766A0ABB
    sha_k[38] = 0x81C2C92E
    sha_k[39] = 0x92722C85
    sha_k[40] = 0xA2BFE8A1
    sha_k[41] = 0xA81A664B
    sha_k[42] = 0xC24B8B70
    sha_k[43] = 0xC76C51A3
    sha_k[44] = 0xD192E819
    sha_k[45] = 0xD6990624
    sha_k[46] = 0xF40E3585
    sha_k[47] = 0x106AA070
    sha_k[48] = 0x19A4C116
    sha_k[49] = 0x1E376C08
    sha_k[50] = 0x2748774C
    sha_k[51] = 0x34B0BCB5
    sha_k[52] = 0x391C0CB3
    sha_k[53] = 0x4ED8AA4A
    sha_k[54] = 0x5B9CCA4F
    sha_k[55] = 0x682E6FF3
    sha_k[56] = 0x748F82EE
    sha_k[57] = 0x78A5636F
    sha_k[58] = 0x84C87814
    sha_k[59] = 0x8CC70208
    sha_k[60] = 0x90BEFFFA
    sha_k[61] = 0xA4506CEB
    sha_k[62] = 0xBEF9A3F7
    sha_k[63] = 0xC67178F2


def _sha256_compress():
    i: uint64 = 0
    while i < 16:
        b0: uint32 = cast[uint32](sha_block[i * 4 + 0])
        b1: uint32 = cast[uint32](sha_block[i * 4 + 1])
        b2: uint32 = cast[uint32](sha_block[i * 4 + 2])
        b3: uint32 = cast[uint32](sha_block[i * 4 + 3])
        sha_w[i] = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        i = i + 1
    while i < 64:
        s0: uint32 = _sha256_rotr32(sha_w[i - 15], 7) \
            ^ _sha256_rotr32(sha_w[i - 15], 18) \
            ^ (sha_w[i - 15] >> 3)
        s1: uint32 = _sha256_rotr32(sha_w[i - 2], 17) \
            ^ _sha256_rotr32(sha_w[i - 2], 19) \
            ^ (sha_w[i - 2] >> 10)
        sum_v: uint64 = (cast[uint64](sha_w[i - 16]) & 0xFFFFFFFF) \
            + (cast[uint64](s0) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i - 7]) & 0xFFFFFFFF) \
            + (cast[uint64](s1) & 0xFFFFFFFF)
        sha_w[i] = cast[uint32](sum_v & 0xFFFFFFFF)
        i = i + 1

    a: uint32 = sha_state[0]
    b: uint32 = sha_state[1]
    c: uint32 = sha_state[2]
    d: uint32 = sha_state[3]
    e: uint32 = sha_state[4]
    f: uint32 = sha_state[5]
    g: uint32 = sha_state[6]
    h: uint32 = sha_state[7]
    i = 0
    while i < 64:
        S1: uint32 = _sha256_rotr32(e, 6) ^ _sha256_rotr32(e, 11) \
            ^ _sha256_rotr32(e, 25)
        ch: uint32 = (e & f) ^ ((~e) & g)
        t1_64: uint64 = (cast[uint64](h) & 0xFFFFFFFF) \
            + (cast[uint64](S1) & 0xFFFFFFFF) \
            + (cast[uint64](ch) & 0xFFFFFFFF) \
            + (cast[uint64](sha_k[i]) & 0xFFFFFFFF) \
            + (cast[uint64](sha_w[i]) & 0xFFFFFFFF)
        t1: uint32 = cast[uint32](t1_64 & 0xFFFFFFFF)
        S0: uint32 = _sha256_rotr32(a, 2) ^ _sha256_rotr32(a, 13) \
            ^ _sha256_rotr32(a, 22)
        maj: uint32 = (a & b) ^ (a & c) ^ (b & c)
        t2_64: uint64 = (cast[uint64](S0) & 0xFFFFFFFF) \
            + (cast[uint64](maj) & 0xFFFFFFFF)
        t2: uint32 = cast[uint32](t2_64 & 0xFFFFFFFF)
        h = g
        g = f
        f = e
        d64: uint64 = (cast[uint64](d) & 0xFFFFFFFF) \
            + (cast[uint64](t1) & 0xFFFFFFFF)
        e = cast[uint32](d64 & 0xFFFFFFFF)
        d = c
        c = b
        b = a
        a64: uint64 = (cast[uint64](t1) & 0xFFFFFFFF) \
            + (cast[uint64](t2) & 0xFFFFFFFF)
        a = cast[uint32](a64 & 0xFFFFFFFF)
        i = i + 1

    sum_0: uint64 = cast[uint64](sha_state[0]) + cast[uint64](a)
    sum_1: uint64 = cast[uint64](sha_state[1]) + cast[uint64](b)
    sum_2: uint64 = cast[uint64](sha_state[2]) + cast[uint64](c)
    sum_3: uint64 = cast[uint64](sha_state[3]) + cast[uint64](d)
    sum_4: uint64 = cast[uint64](sha_state[4]) + cast[uint64](e)
    sum_5: uint64 = cast[uint64](sha_state[5]) + cast[uint64](f)
    sum_6: uint64 = cast[uint64](sha_state[6]) + cast[uint64](g)
    sum_7: uint64 = cast[uint64](sha_state[7]) + cast[uint64](h)
    sha_state[0] = cast[uint32](sum_0 & 0xFFFFFFFF)
    sha_state[1] = cast[uint32](sum_1 & 0xFFFFFFFF)
    sha_state[2] = cast[uint32](sum_2 & 0xFFFFFFFF)
    sha_state[3] = cast[uint32](sum_3 & 0xFFFFFFFF)
    sha_state[4] = cast[uint32](sum_4 & 0xFFFFFFFF)
    sha_state[5] = cast[uint32](sum_5 & 0xFFFFFFFF)
    sha_state[6] = cast[uint32](sum_6 & 0xFFFFFFFF)
    sha_state[7] = cast[uint32](sum_7 & 0xFFFFFFFF)


def _sha256_reset():
    _sha256_init_k()
    sha_state[0] = 0x6A09E667
    sha_state[1] = 0xBB67AE85
    sha_state[2] = 0x3C6EF372
    sha_state[3] = 0xA54FF53A
    sha_state[4] = 0x510E527F
    sha_state[5] = 0x9B05688C
    sha_state[6] = 0x1F83D9AB
    sha_state[7] = 0x5BE0CD19
    sha_block_n = 0
    sha_total = 0


def _sha256_update(data: Ptr[uint8], n: uint64):
    pos: uint64 = 0
    while pos < n:
        room: uint64 = 64 - sha_block_n
        take: uint64 = n - pos
        if take > room:
            take = room
        i: uint64 = 0
        while i < take:
            sha_block[sha_block_n + i] = data[pos + i]
            i = i + 1
        sha_block_n = sha_block_n + take
        pos = pos + take
        if sha_block_n == 64:
            _sha256_compress()
            sha_block_n = 0
    sha_total = sha_total + n


def _sha256_final():
    buflen: uint64 = sha_block_n
    sha_block[buflen] = 0x80
    buflen = buflen + 1
    if buflen > 56:
        while buflen < 64:
            sha_block[buflen] = 0
            buflen = buflen + 1
        _sha256_compress()
        buflen = 0
    while buflen < 56:
        sha_block[buflen] = 0
        buflen = buflen + 1
    total_bits: uint64 = sha_total * 8
    j: uint64 = 0
    while j < 8:
        shift: uint64 = (7 - j) * 8
        sha_block[56 + j] = cast[uint8]((total_bits >> shift) & 0xFF)
        j = j + 1
    _sha256_compress()

    hexd: Ptr[uint8] = "0123456789abcdef"
    k: uint64 = 0
    while k < 8:
        w: uint32 = sha_state[k]
        sha_digest[k * 4 + 0] = cast[uint8]((w >> 24) & 0xFF)
        sha_digest[k * 4 + 1] = cast[uint8]((w >> 16) & 0xFF)
        sha_digest[k * 4 + 2] = cast[uint8]((w >> 8) & 0xFF)
        sha_digest[k * 4 + 3] = cast[uint8](w & 0xFF)
        k = k + 1
    m: uint64 = 0
    while m < 32:
        byte_v: uint8 = sha_digest[m]
        sha_hex[m * 2 + 0] = hexd[cast[uint64]((byte_v >> 4) & 0x0F)]
        sha_hex[m * 2 + 1] = hexd[cast[uint64](byte_v & 0x0F)]
        m = m + 1
    sha_hex[64] = 0


def _sha256_hash_buf(data: Ptr[uint8], n: uint64):
    _sha256_reset()
    _sha256_update(data, n)
    _sha256_final()


# -- tarball inflate ---------------------------------------------------
#
# Inflate deb_buf[0..deb_len) (a .tar.gz) into tar_buf. One-shot —
# the package is bounded by TARBALL_CAP (4 MiB) and the inflated tar
# by TAR_CAP (8 MiB), big enough for any reasonable Hamnix package's
# `files/` tree. Returns the inflated length on success, -1 on error.

inf_state: InflateState


def _inflate_tarball(deb_len: uint64) -> int64:
    inflate_init(&inf_state)
    out_consumed: uint64 = 0
    in_consumed: uint64 = 0
    done: int32 = 0
    rc: int32 = inflate_feed(&inf_state, &deb_buf[0], deb_len,
                             &tar_buf[0], TAR_CAP,
                             &out_consumed, &in_consumed, &done)
    if rc < 0:
        write_str(2, "hpm: gzip inflate failed (corrupt tarball?)\n")
        return -1
    if done == 0:
        write_str(2, "hpm: gzip inflate did not reach EOS (tarball too large?)\n")
        return -1
    return cast[int64](out_consumed)


# -- ustar tar walker --------------------------------------------------
#
# Same shape as user/dpkg_deb.ad's tar parser (now retired). 512-byte
# header layout; we only need:
#   [0..100)   name (NUL-terminated, max 100 chars)
#   [124..136) size (octal, up to 11 octal digits + NUL)
#   [148..156) chksum (octal, verified)
#   [156]      typeflag ('0' regular, '5' dir; everything else is
#              skipped with a warning)

def _tar_parse_octal(p: Ptr[uint8], maxlen: uint64) -> uint64:
    n: uint64 = 0
    i: uint64 = 0
    while i < maxlen and p[i] == 32:
        i = i + 1
    while i < maxlen:
        c: uint8 = p[i]
        if c == 0 or c == 32:
            break
        if c < 48 or c > 55:
            break
        n = (n << 3) + cast[uint64](c - 48)
        i = i + 1
    return n


def _tar_chksum_ok(hdr: Ptr[uint8]) -> int32:
    stored: uint64 = _tar_parse_octal(&hdr[148], 8)
    s: uint64 = 0
    i: uint64 = 0
    while i < 512:
        if i >= 148 and i < 156:
            s = s + 32
        else:
            s = s + cast[uint64](hdr[i])
        i = i + 1
    if s == stored:
        return 1
    return 0


def _tar_header_is_zero(hdr: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while i < 512:
        if hdr[i] != 0:
            return 0
        i = i + 1
    return 1


def _name_copy_nul(dst: Ptr[uint8], src: Ptr[uint8], maxlen: uint64) -> uint64:
    i: uint64 = 0
    while i < maxlen:
        c: uint8 = src[i]
        if c == 0:
            break
        dst[i] = c
        i = i + 1
    dst[i] = 0
    return i


def _entry_name_is_unsafe(name: Ptr[uint8]) -> int32:
    # Reject absolute paths + '..' components (the standard dpkg
    # path-traversal guard). Operates on a NUL-terminated string.
    if name[0] == 47:
        return 1
    i: uint64 = 0
    while True:
        if name[i] == 46 and name[i + 1] == 46:
            t: uint8 = name[i + 2]
            if t == 0 or t == 47:
                return 1
        while name[i] != 0 and name[i] != 47:
            i = i + 1
        if name[i] == 0:
            return 0
        while name[i] == 47:
            i = i + 1
        if name[i] == 0:
            return 0


# -- install: package + extraction state ------------------------------

# The package's tarball name is "<name>-<version>.tar.gz"; the top-
# level directory inside the tarball is "<name>-<version>/" (per
# docs/packages.md). We strip that prefix when classifying entries.

pkg_prefix_buf:   Array[128, uint8]      # "<name>-<version>/" + NUL
pkg_prefix_len:   uint64 = 0

# Decoded PKGINFO fields for the package being installed. Populated
# by _read_pkginfo_in_tar. v1 only USES some of these (name, version,
# target, arch); deps/conflicts come from the INDEX, not PKGINFO,
# during install (the spec keys both off the index entry).

pi_name:      Array[64, uint8]
pi_version:   Array[64, uint8]
pi_arch:      Array[32, uint8]
pi_target:    Array[128, uint8]
pi_have:      int32 = 0


# Scratch buffers used during extraction.
extract_path_buf: Array[1024, uint8]     # full target path for sys_open_write
warn_buf:         Array[256, uint8]      # entry name copy for messages

# Per-install installed-file record. Each "files/<rel>" entry we
# write is recorded so install.json's `files` array can list them in
# install order (`hpm remove` deletes in reverse).
INST_FILES_PER_PKG: uint64 = 1024
new_files_off:    Array[1024, uint64]    # offset into new_files_buf
new_files_len:    Array[1024, uint64]
new_files_n:      uint64 = 0
new_files_buf:    Array[131072, uint8]    # flat backing store
new_files_buf_n:  uint64 = 0


def _new_files_reset():
    new_files_n = 0
    new_files_buf_n = 0


def _new_files_record(rel_path: Ptr[uint8], rel_len: uint64) -> int32:
    # Append rel_path[0..rel_len) into new_files_buf, record offset+len.
    # Returns 0 on success, -1 on overflow.
    if new_files_n >= 1024:
        write_str(2, "hpm: per-package file table overflow\n")
        return -1
    if new_files_buf_n + rel_len + 1 > 131072:
        write_str(2, "hpm: per-package file-name store overflow\n")
        return -1
    new_files_off[new_files_n] = new_files_buf_n
    new_files_len[new_files_n] = rel_len
    i: uint64 = 0
    while i < rel_len:
        new_files_buf[new_files_buf_n + i] = rel_path[i]
        i = i + 1
    new_files_buf_n = new_files_buf_n + rel_len
    new_files_n = new_files_n + 1
    return 0


# -- target resolution -------------------------------------------------
#
# Map a target tag (`#hamnix-system` / `#distro` / `#<other>`) to a
# filesystem prefix that prepends to "files/<rel>". v1 covers the two
# baked-in targets explicitly; `#<other>` is treated as `#hamnix-system`
# with a stderr note (the spec says `#<new-word>` registration needs
# kernel-side name-table writes that don't yet have a userland API —
# see the brief's escalation note).
#
# --target-prefix=<path>: the installer uses this to extract packages
# under <path><target-derived-prefix> instead of <target-derived-prefix>
# alone. e.g. with --target-prefix=/mnt/newroot, a #hamnix-system
# package's files/bin/hpm lands at /mnt/newroot/bin/hpm, NOT /bin/hpm.
# This is how `hpm install` populates a freshly-formatted disk that's
# bound at /mnt/newroot rather than overwriting the running system.

target_prefix_buf:      Array[256, uint8]
target_prefix_override: Array[256, uint8]     # NUL-terminated; empty = unset


def _set_target_prefix_override(path: Ptr[uint8]):
    # Copy `path` into target_prefix_override, ensuring trailing '/'
    # so concatenation with the target-derived prefix is well-formed.
    n: uint64 = strlen_u8(path)
    if n == 0:
        target_prefix_override[0] = 0
        return
    # Cap at 254 so we can append '/' + NUL.
    if n > 254:
        n = 254
    i: uint64 = 0
    while i < n:
        target_prefix_override[i] = path[i]
        i = i + 1
    # Append '/' if missing.
    if n > 0 and target_prefix_override[n - 1] != 47:
        target_prefix_override[n] = 47
        n = n + 1
    target_prefix_override[n] = 0


def _is_esp_target(target: Ptr[uint8], target_len: uint64) -> int32:
    # #esp: hpm doesn't lay down files itself (the ESP is FAT-on-block,
    # not Hamnix-file-server-addressable). install.hamsh handles ESP
    # packages specially. hpm prints a notice + skips extraction but
    # still records the package in installed.json so `hpm list` and
    # `hpm remove` work.
    if target_len != 4:
        return 0
    es: Ptr[uint8] = "#esp"
    if _streq_n(target, es, 4) != 0:
        return 1
    return 0


def _set_target_prefix(target: Ptr[uint8], target_len: uint64) -> int32:
    # If target_len==0 OR target is "#hamnix-system", base prefix is "/".
    # If target is "#distro", base prefix is "/var/lib/distros/default/".
    # If target is "#esp", we set an empty prefix (the caller is expected
    # to have checked _is_esp_target separately and skipped extraction).
    # Anything else is treated as #hamnix-system with a warning.
    #
    # If target_prefix_override is non-empty, it is PREPENDED to the
    # derived prefix. e.g. override="/mnt/newroot/" + #hamnix-system "/"
    # → "/mnt/newroot/". #distro becomes "/mnt/newroot/var/lib/distros/
    # default/". We collapse adjacent slashes to keep paths clean.
    base: Array[256, uint8]
    base[0] = 0
    if target_len == 0:
        base[0] = 47
        base[1] = 0
    else:
        hs: Ptr[uint8] = "#hamnix-system"
        if target_len == 14 and _streq_n(target, hs, 14) != 0:
            base[0] = 47
            base[1] = 0
        else:
            ds: Ptr[uint8] = "#distro"
            es: Ptr[uint8] = "#esp"
            if target_len == 7 and _streq_n(target, ds, 7) != 0:
                s: Ptr[uint8] = "/var/lib/distros/default/"
                i: uint64 = 0
                while s[i] != 0:
                    base[i] = s[i]
                    i = i + 1
                base[i] = 0
            elif target_len == 4 and _streq_n(target, es, 4) != 0:
                # #esp: caller handles extraction; we don't set any path.
                base[0] = 0
            else:
                # Unknown — warn, fall back to #hamnix-system.
                write_str(2, "hpm: warning: unknown target `")
                sys_write(2, target, target_len)
                write_str(2, "` — treating as #hamnix-system (see docs/packages.md)\n")
                base[0] = 47
                base[1] = 0

    # Compose target_prefix_buf = override + base. Override always ends
    # in '/'. Base always starts with '/' (or is empty). Skip the '/'
    # at the start of base when override is non-empty so we don't
    # produce "//" mid-path.
    target_prefix_buf[0] = 0
    op: uint64 = 0
    if target_prefix_override[0] != 0:
        # Copy override (trailing '/' included).
        ov: uint64 = 0
        while target_prefix_override[ov] != 0 and op + 1 < 256:
            target_prefix_buf[op] = target_prefix_override[ov]
            op = op + 1
            ov = ov + 1
        # Skip a leading '/' on `base` since override ends in '/'.
        bi: uint64 = 0
        if base[0] == 47:
            bi = 1
        while base[bi] != 0 and op + 1 < 256:
            target_prefix_buf[op] = base[bi]
            op = op + 1
            bi = bi + 1
    else:
        bi: uint64 = 0
        while base[bi] != 0 and op + 1 < 256:
            target_prefix_buf[op] = base[bi]
            op = op + 1
            bi = bi + 1
    target_prefix_buf[op] = 0
    return 0


# -- mkdir -p (recursive) ----------------------------------------------
#
# tmpfs_mkdir requires parents to already exist. For an entry like
# `files/bin/foo`, the target path becomes `/bin/foo` (under
# #hamnix-system), and `/bin` must be mkdir'd first. We walk the
# dirname, mkdir'ing each prefix; -EEXIST is treated as success.

mkdir_buf: Array[1024, uint8]


def _mkdir_p(path: Ptr[uint8]):
    # Walk path component-by-component, mkdir'ing each prefix.
    # Skips the leading "/" component.
    i: uint64 = 0
    while path[i] != 0:
        if i > 0 and path[i] == 47:
            # Copy prefix into mkdir_buf and mkdir it.
            j: uint64 = 0
            while j < i:
                mkdir_buf[j] = path[j]
                j = j + 1
            mkdir_buf[i] = 0
            sys_mkdir(cast[Ptr[char]](&mkdir_buf[0]))
        i = i + 1


def _dirname_mkdir_p(path: Ptr[uint8]):
    # Mkdir all parent directories of `path` (stop before the last
    # component). Cheap: walks once.
    last_slash: int64 = -1
    i: uint64 = 0
    while path[i] != 0:
        if path[i] == 47:
            last_slash = cast[int64](i)
        i = i + 1
    if last_slash <= 0:
        return
    # Mkdir each prefix up to last_slash.
    p: int64 = 1
    while p <= last_slash:
        if path[cast[uint64](p)] == 47:
            j: uint64 = 0
            while j < cast[uint64](p):
                mkdir_buf[j] = path[j]
                j = j + 1
            mkdir_buf[cast[uint64](p)] = 0
            sys_mkdir(cast[Ptr[char]](&mkdir_buf[0]))
        p = p + 1
    # Final mkdir of the dirname itself.
    j2: uint64 = 0
    while j2 < cast[uint64](last_slash):
        mkdir_buf[j2] = path[j2]
        j2 = j2 + 1
    mkdir_buf[cast[uint64](last_slash)] = 0
    sys_mkdir(cast[Ptr[char]](&mkdir_buf[0]))


# -- staging-dir extraction --------------------------------------------
#
# The tarball gets staged at /tmp/hpm/staging/. We extract it there
# wholesale (so hooks can see PKGINFO + the files/ tree), then walk
# the staged tree to copy files/ to the target. Two-phase keeps hook
# execution clean (HPM_PKG_DIR points at a real, complete tree).
#
# v1 trims a corner: the staging dir AND the target install are done
# by walking the in-RAM tar once and writing each entry to its final
# location. That's simpler than a two-phase, costs nothing in
# correctness for the trivial-case install, and matches what
# dpkg-deb -x does. The "staging dir for hooks" path is materialised
# in Phase 3 (when hooks need a real HPM_PKG_DIR).

# For Phase 2 we still need to read PKGINFO and (if present) note
# install.hamsh — both straight from the inflated tar in RAM, no
# write to disk.

def _read_pkginfo_from_tar(tar_len: uint64) -> int32:
    # Walk tar_buf[0..tar_len) looking for "<pkg_prefix>PKGINFO".
    # Populates pi_name / pi_version / pi_arch / pi_target. Returns
    # 0 on success, -1 if PKGINFO missing or malformed.
    pi_name[0] = 0
    pi_version[0] = 0
    pi_arch[0] = 0
    pi_target[0] = 0
    pi_have = 0

    off: uint64 = 0
    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            break
        if _tar_chksum_ok(hdr) == 0:
            return -1
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        body_blocks: uint64 = (size + 511) / 512

        # Get the entry name into warn_buf.
        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)
        # We're looking for "<prefix>PKGINFO".
        mch: int32 = 1
        if nlen != pkg_prefix_len + 7:
            mch = 0
        if mch != 0:
            i: uint64 = 0
            while i < pkg_prefix_len:
                if warn_buf[i] != pkg_prefix_buf[i]:
                    mch = 0
                    break
                i = i + 1
            if mch != 0:
                pkginfo_tail: Ptr[uint8] = "PKGINFO"
                j: uint64 = 0
                while j < 7:
                    if warn_buf[pkg_prefix_len + j] != pkginfo_tail[j]:
                        mch = 0
                        break
                    j = j + 1
        if mch != 0:
            body_off: uint64 = off + 512
            if body_off + size > tar_len:
                return -1
            # Parse the PKGINFO body: key: value pairs, one per line.
            p: uint64 = body_off
            end: uint64 = body_off + size
            while p < end:
                # Find end of line.
                lend: uint64 = p
                while lend < end and tar_buf[lend] != 10:
                    lend = lend + 1
                # Trim CR.
                vend: uint64 = lend
                if vend > p and tar_buf[vend - 1] == 13:
                    vend = vend - 1
                # Skip blank / comment lines.
                if p == vend or tar_buf[p] == 35:
                    p = lend + 1
                    continue
                # Continuation lines (start with whitespace) — v1
                # ignores them; our keys all fit on one line.
                if tar_buf[p] == 32 or tar_buf[p] == 9:
                    p = lend + 1
                    continue
                # Find ':'.
                cp: uint64 = p
                while cp < vend and tar_buf[cp] != 58:
                    cp = cp + 1
                if cp >= vend:
                    p = lend + 1
                    continue
                # key span = [p, cp), value span = [cp+1, vend) skipping
                # leading whitespace.
                vp: uint64 = cp + 1
                while vp < vend and (tar_buf[vp] == 32 or tar_buf[vp] == 9):
                    vp = vp + 1
                klen: uint64 = cp - p
                kp: Ptr[uint8] = &tar_buf[p]
                vp2: Ptr[uint8] = &tar_buf[vp]
                vlen: uint64 = vend - vp
                if klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("name"), 4) != 0:
                    _strcopy_n(&pi_name[0], vp2, vlen, 64)
                elif klen == 7 and _streq_n(kp, cast[Ptr[uint8]]("version"), 7) != 0:
                    _strcopy_n(&pi_version[0], vp2, vlen, 64)
                elif klen == 4 and _streq_n(kp, cast[Ptr[uint8]]("arch"), 4) != 0:
                    _strcopy_n(&pi_arch[0], vp2, vlen, 32)
                elif klen == 6 and _streq_n(kp, cast[Ptr[uint8]]("target"), 6) != 0:
                    _strcopy_n(&pi_target[0], vp2, vlen, 128)
                p = lend + 1
            pi_have = 1
            return 0

        off = off + 512 + body_blocks * 512
    write_str(2, "hpm: PKGINFO not found in tarball\n")
    return -1


def _has_entry_in_tar(tar_len: uint64, tail: Ptr[uint8]) -> int32:
    # True if "<pkg_prefix><tail>" is present as a regular file entry.
    tail_len: uint64 = strlen_u8(tail)
    off: uint64 = 0
    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            break
        if _tar_chksum_ok(hdr) == 0:
            return 0
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        body_blocks: uint64 = (size + 511) / 512
        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)
        if nlen == pkg_prefix_len + tail_len:
            mch: int32 = 1
            i: uint64 = 0
            while i < pkg_prefix_len:
                if warn_buf[i] != pkg_prefix_buf[i]:
                    mch = 0
                    break
                i = i + 1
            if mch != 0:
                j: uint64 = 0
                while j < tail_len:
                    if warn_buf[pkg_prefix_len + j] != tail[j]:
                        mch = 0
                        break
                    j = j + 1
                if mch != 0:
                    return 1
        off = off + 512 + body_blocks * 512
    return 0


# -- write one staged file: <staging>/<rel> --------------------------
#
# Phase 3 introduces staging proper. For Phase 2 we stage the WHOLE
# tarball into /tmp/hpm/staging/<pkg-prefix>... so the install.hamsh
# stub-message can point at a real path, AND so the files/ extraction
# is read from disk (mirroring how Phase 3 will run with the staging
# dir already populated for hooks). The same loop walks the tar twice
# (once for staging, once for files/-to-target copy) — Phase 2 keeps
# the trivial path uncomplicated.
#
# Actually: for the no-hooks Phase 2 case we DON'T need to write the
# whole staged tree to disk — we just need PKGINFO parsed and the
# files/ tree placed at target. Phase 3 will materialise a real
# /tmp/hpm/staging/<name>-<version>/ for HPM_PKG_DIR. So this
# function is unused in Phase 2 and lives for Phase 3 to wire up.


def _stage_extract_files(tar_len: uint64, target_prefix: Ptr[uint8]) -> int32:
    # Walk tar_buf[0..tar_len); for any entry whose name is
    # "<pkg_prefix>files/<rel>" (regular file) write the body to
    # "<target_prefix><rel>" (mkdir -p the parent first). Records each
    # written rel-path in new_files_* for installed.json.
    # Directories under files/ are mkdir'd (typeflag '5').
    # Symlinks and other types are skipped with a warning.
    files_pfx: Ptr[uint8] = "files/"
    files_pfx_len: uint64 = 6

    off: uint64 = 0
    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            return 0
        if _tar_chksum_ok(hdr) == 0:
            write_str(2, "hpm: tar header checksum mismatch\n")
            return -1
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        typeflag: uint8 = hdr[156]
        body_blocks: uint64 = (size + 511) / 512

        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)

        # Strip the package prefix; bail out if absent (unexpected
        # entry shape per the spec, treated as a skip).
        if nlen <= pkg_prefix_len:
            off = off + 512 + body_blocks * 512
            continue
        prefix_ok: int32 = 1
        i: uint64 = 0
        while i < pkg_prefix_len:
            if warn_buf[i] != pkg_prefix_buf[i]:
                prefix_ok = 0
                break
            i = i + 1
        if prefix_ok == 0:
            off = off + 512 + body_blocks * 512
            continue

        # Tail relative to "<prefix>" — e.g. "files/bin/foo", "PKGINFO",
        # "install.hamsh".
        tail_start: uint64 = pkg_prefix_len
        tail_len: uint64 = nlen - tail_start
        # Only entries under "files/" go to the target.
        if tail_len < files_pfx_len:
            off = off + 512 + body_blocks * 512
            continue
        ok: int32 = 1
        j: uint64 = 0
        while j < files_pfx_len:
            if warn_buf[tail_start + j] != files_pfx[j]:
                ok = 0
                break
            j = j + 1
        if ok == 0:
            off = off + 512 + body_blocks * 512
            continue
        rel_start: uint64 = tail_start + files_pfx_len
        rel_len: uint64 = tail_len - files_pfx_len

        if rel_len == 0:
            # Bare "files/" directory entry — make sure target_prefix
            # exists, then skip.
            sys_mkdir(cast[Ptr[char]](target_prefix))
            off = off + 512 + body_blocks * 512
            continue

        # Path safety: name under files/ must not be abs / contain `..`.
        # Copy into a NUL-terminated cstring for the helper.
        safe_buf: Array[256, uint8]
        sl: uint64 = rel_len
        if sl >= 256:
            sl = 255
        kk: uint64 = 0
        while kk < sl:
            safe_buf[kk] = warn_buf[rel_start + kk]
            kk = kk + 1
        safe_buf[sl] = 0
        if _entry_name_is_unsafe(&safe_buf[0]) != 0:
            write_str(2, "hpm: refusing unsafe files/ path: ")
            write_str(2, &warn_buf[0])
            write_str(2, "\n")
            off = off + 512 + body_blocks * 512
            continue

        # Compose <target_prefix><rel> into extract_path_buf.
        po: uint64 = 0
        ti: uint64 = 0
        while target_prefix[ti] != 0 and po + 1 < 1024:
            extract_path_buf[po] = target_prefix[ti]
            po = po + 1
            ti = ti + 1
        # Avoid "//" if target_prefix ends in '/' (it always does in
        # our impl). _strcopy_n / etc — we just check.
        ri: uint64 = 0
        while ri < rel_len and po + 1 < 1024:
            extract_path_buf[po] = warn_buf[rel_start + ri]
            po = po + 1
            ri = ri + 1
        extract_path_buf[po] = 0

        if typeflag == 53:                               # '5' = dir
            # mkdir -p the full path itself.
            _mkdir_p(&extract_path_buf[0])
            sys_mkdir(cast[Ptr[char]](&extract_path_buf[0]))
            off = off + 512 + body_blocks * 512
            continue

        if typeflag != 0 and typeflag != 48:             # not '\0' or '0'
            write_str(2, "hpm: warning: skipping non-regular entry: ")
            write_str(2, &warn_buf[0])
            write_str(2, "\n")
            off = off + 512 + body_blocks * 512
            continue

        # Regular file. mkdir -p the parent, then write the body.
        _dirname_mkdir_p(&extract_path_buf[0])
        body_off: uint64 = off + 512
        if body_off + size > tar_len:
            write_str(2, "hpm: tar body overflows archive\n")
            return -1
        fd: int32 = sys_open_write(cast[Ptr[char]](&extract_path_buf[0]))
        if fd < 0:
            write_str(2, "hpm: cannot create ")
            write_str(2, &extract_path_buf[0])
            write_str(2, "\n")
            return -1
        if size > 0:
            wn: int64 = _write_full(fd, &tar_buf[body_off], size)
            if wn < 0 or cast[uint64](wn) != size:
                write_str(2, "hpm: short write extracting ")
                write_str(2, &extract_path_buf[0])
                write_str(2, "\n")
                sys_close(fd)
                return -1
        sys_close(fd)

        # Record the relative path (under files/) for installed.json.
        if _new_files_record(&warn_buf[rel_start], rel_len) != 0:
            return -1

        off = off + 512 + body_blocks * 512
    return 0


# -- installed.json append + rewrite ----------------------------------
#
# Append the just-installed package to inst_* tables, then rewrite
# /var/lib/hpm/installed.json from scratch. Format mirrors the schema
# in docs/packages.md.
#
# A real /var would let us atomically swap; tmpfs has no rename today,
# so we truncate-write-close. `hpm` is the sole writer so concurrency
# isn't a concern.

def _installed_record_add(name: Ptr[uint8], name_len: uint64,
                          version: Ptr[uint8], version_len: uint64,
                          target: Ptr[uint8], target_len: uint64,
                          pinned: int32):
    # Append to the in-memory inst_* tables. The string spans must
    # remain valid until _installed_rewrite is called — but since
    # inst_buf is rebuilt from scratch in _installed_rewrite (it writes
    # everything from new_files_* + the input params), we just stash
    # what we need into top-level scratch arenas. The simplest path is
    # to NOT extend inst_buf at all here — _installed_rewrite below
    # reads the new entry directly from the params + new_files_*.
    pass


# Top-level scratch for the rewrite's serialization buffer.
rewrite_buf:   Array[131072, uint8]
rewrite_n:     uint64 = 0


def _rw_put(s: Ptr[uint8], n: uint64) -> int32:
    if rewrite_n + n > 131072:
        return -1
    i: uint64 = 0
    while i < n:
        rewrite_buf[rewrite_n + i] = s[i]
        i = i + 1
    rewrite_n = rewrite_n + n
    return 0


def _rw_put_cstr(s: Ptr[uint8]) -> int32:
    return _rw_put(s, strlen_u8(s))


def _rw_put_lit(s: Ptr[uint8]) -> int32:
    return _rw_put(s, strlen_u8(s))


# Emit a JSON string with minimal escaping. Backslash and double-quote
# get escaped; other ASCII passes through (our keys + values are all
# ASCII names / paths / iso8601 timestamps). Non-ASCII passes through
# byte-wise — the consumer is hpm itself, no need to be strict.

def _rw_put_jstr(s: Ptr[uint8], n: uint64) -> int32:
    if _rw_put(cast[Ptr[uint8]]("\""), 1) != 0:
        return -1
    i: uint64 = 0
    while i < n:
        c: uint8 = s[i]
        if c == 34 or c == 92:                            # '"' or '\\'
            if _rw_put(cast[Ptr[uint8]]("\\"), 1) != 0:
                return -1
        b: Array[1, uint8]
        b[0] = c
        if _rw_put(&b[0], 1) != 0:
            return -1
        i = i + 1
    if _rw_put(cast[Ptr[uint8]]("\""), 1) != 0:
        return -1
    return 0


def _rw_put_jstr_cstr(s: Ptr[uint8]) -> int32:
    return _rw_put_jstr(s, strlen_u8(s))


# Emit a decimal integer.
def _rw_put_dec(v: uint64) -> int32:
    digs: Array[24, uint8]
    n: uint64 = 0
    if v == 0:
        digs[0] = 48
        n = 1
    else:
        x: uint64 = v
        while x != 0:
            digs[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return _rw_put(&out[0], i)


# Top-level helper: emit one installed-package object from the
# in-memory inst_* state OR from the just-installed params, both
# walked the same way through callbacks.

def _installed_emit_existing(i: uint64) -> int32:
    if _rw_put_lit(cast[Ptr[uint8]]("    {\n      \"name\": ")) != 0:
        return -1
    if _rw_put_jstr(&inst_buf[inst_name_off[i]], inst_name_len[i]) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"version\": ")) != 0:
        return -1
    if _rw_put_jstr(&inst_buf[inst_ver_off[i]], inst_ver_len[i]) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"installed_at\": ")) != 0:
        return -1
    if inst_at_len[i] > 0:
        if _rw_put_jstr(&inst_buf[inst_at_off[i]], inst_at_len[i]) != 0:
            return -1
    else:
        if _rw_put_jstr_cstr(cast[Ptr[uint8]]("")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"pinned\": ")) != 0:
        return -1
    if inst_pinned[i] != 0:
        if _rw_put_lit(cast[Ptr[uint8]]("true")) != 0:
            return -1
    else:
        if _rw_put_lit(cast[Ptr[uint8]]("false")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"target\": ")) != 0:
        return -1
    if inst_target_len[i] > 0:
        if _rw_put_jstr(&inst_buf[inst_target_off[i]],
                        inst_target_len[i]) != 0:
            return -1
    else:
        if _rw_put_jstr_cstr(cast[Ptr[uint8]]("#hamnix-system")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"files\": [")) != 0:
        return -1
    fc: uint64 = inst_file_count[i]
    fs: uint64 = inst_file_start[i]
    fi: uint64 = 0
    while fi < fc:
        if fi > 0:
            if _rw_put_lit(cast[Ptr[uint8]](", ")) != 0:
                return -1
        slot: uint64 = fs + fi
        if _rw_put_jstr(&inst_buf[inst_file_off[slot]],
                        inst_file_len[slot]) != 0:
            return -1
        fi = fi + 1
    if _rw_put_lit(cast[Ptr[uint8]]("]\n    }")) != 0:
        return -1
    return 0


def _installed_emit_new(name: Ptr[uint8], version: Ptr[uint8],
                        target: Ptr[uint8], pinned: int32) -> int32:
    # Same shape as _installed_emit_existing but for the just-installed
    # package: reads from the params + new_files_*.
    if _rw_put_lit(cast[Ptr[uint8]]("    {\n      \"name\": ")) != 0:
        return -1
    if _rw_put_jstr_cstr(name) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"version\": ")) != 0:
        return -1
    if _rw_put_jstr_cstr(version) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"installed_at\": ")) != 0:
        return -1
    # v1 has no RTC tie-in for hpm; record an empty timestamp.
    if _rw_put_jstr_cstr(cast[Ptr[uint8]]("")) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"pinned\": ")) != 0:
        return -1
    if pinned != 0:
        if _rw_put_lit(cast[Ptr[uint8]]("true")) != 0:
            return -1
    else:
        if _rw_put_lit(cast[Ptr[uint8]]("false")) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"target\": ")) != 0:
        return -1
    if target[0] == 0:
        if _rw_put_jstr_cstr(cast[Ptr[uint8]]("#hamnix-system")) != 0:
            return -1
    else:
        if _rw_put_jstr_cstr(target) != 0:
            return -1
    if _rw_put_lit(cast[Ptr[uint8]](",\n      \"files\": [")) != 0:
        return -1
    fi: uint64 = 0
    while fi < new_files_n:
        if fi > 0:
            if _rw_put_lit(cast[Ptr[uint8]](", ")) != 0:
                return -1
        if _rw_put_jstr(&new_files_buf[new_files_off[fi]],
                        new_files_len[fi]) != 0:
            return -1
        fi = fi + 1
    if _rw_put_lit(cast[Ptr[uint8]]("]\n    }")) != 0:
        return -1
    return 0


def _installed_rewrite_with_added(name: Ptr[uint8], version: Ptr[uint8],
                                  target: Ptr[uint8],
                                  pinned: int32) -> int32:
    # Serialize the inst_* state + the new entry to /var/lib/hpm/
    # installed.json. The new entry is appended at the end. If the
    # name already exists in inst_*, it is REPLACED.
    rewrite_n = 0
    if _rw_put_lit(cast[Ptr[uint8]]("{\n  \"schema\": 1,\n  \"packages\": [\n")) != 0:
        return -1
    first: int32 = 1
    name_len: uint64 = strlen_u8(name)
    i: uint64 = 0
    while i < inst_count:
        # Skip an existing entry with the same name — the install
        # supersedes it (Phase 3+ will use remove() first; for trivial
        # Phase 2 we just overwrite).
        same: int32 = 0
        if inst_name_len[i] == name_len:
            k: uint64 = 0
            same = 1
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    same = 0
                    break
                k = k + 1
        if same == 0:
            if first == 0:
                if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
                    return -1
            if _installed_emit_existing(i) != 0:
                return -1
            first = 0
        i = i + 1
    # Append the new entry.
    if first == 0:
        if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
            return -1
    if _installed_emit_new(name, version, target, pinned) != 0:
        return -1
    if _rw_put_lit(cast[Ptr[uint8]]("\n  ]\n}\n")) != 0:
        return -1

    # Write to /var/lib/hpm/installed.json (truncate-on-open).
    fd: int32 = sys_open_write("/var/lib/hpm/installed.json")
    if fd < 0:
        write_str(2, "hpm: cannot open /var/lib/hpm/installed.json for write\n")
        return -1
    wn: int64 = _write_full(fd, &rewrite_buf[0], rewrite_n)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != rewrite_n:
        write_str(2, "hpm: short write on installed.json\n")
        return -1
    return 0


# Same shape, but the package is REMOVED rather than appended (Phase 3
# uses this from `hpm remove`).
def _installed_rewrite_with_removed(name: Ptr[uint8]) -> int32:
    rewrite_n = 0
    if _rw_put_lit(cast[Ptr[uint8]]("{\n  \"schema\": 1,\n  \"packages\": [\n")) != 0:
        return -1
    first: int32 = 1
    name_len: uint64 = strlen_u8(name)
    i: uint64 = 0
    while i < inst_count:
        same: int32 = 0
        if inst_name_len[i] == name_len:
            k: uint64 = 0
            same = 1
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    same = 0
                    break
                k = k + 1
        if same == 0:
            if first == 0:
                if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
                    return -1
            if _installed_emit_existing(i) != 0:
                return -1
            first = 0
        i = i + 1
    if _rw_put_lit(cast[Ptr[uint8]]("\n  ]\n}\n")) != 0:
        return -1
    fd: int32 = sys_open_write("/var/lib/hpm/installed.json")
    if fd < 0:
        write_str(2, "hpm: cannot open /var/lib/hpm/installed.json for write\n")
        return -1
    wn: int64 = _write_full(fd, &rewrite_buf[0], rewrite_n)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != rewrite_n:
        write_str(2, "hpm: short write on installed.json\n")
        return -1
    return 0


# Same but with a pinned-state CHANGE for an existing entry.
def _installed_rewrite_with_pin(name: Ptr[uint8], pin_v: int32) -> int32:
    rewrite_n = 0
    if _rw_put_lit(cast[Ptr[uint8]]("{\n  \"schema\": 1,\n  \"packages\": [\n")) != 0:
        return -1
    first: int32 = 1
    name_len: uint64 = strlen_u8(name)
    i: uint64 = 0
    while i < inst_count:
        if first == 0:
            if _rw_put_lit(cast[Ptr[uint8]](",\n")) != 0:
                return -1
        # If this is the target entry, emit with pin toggled.
        same: int32 = 0
        if inst_name_len[i] == name_len:
            same = 1
            k: uint64 = 0
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    same = 0
                    break
                k = k + 1
        if same != 0:
            old: int32 = inst_pinned[i]
            inst_pinned[i] = pin_v
            if _installed_emit_existing(i) != 0:
                return -1
            inst_pinned[i] = old
        else:
            if _installed_emit_existing(i) != 0:
                return -1
        first = 0
        i = i + 1
    if _rw_put_lit(cast[Ptr[uint8]]("\n  ]\n}\n")) != 0:
        return -1
    fd: int32 = sys_open_write("/var/lib/hpm/installed.json")
    if fd < 0:
        return -1
    wn: int64 = _write_full(fd, &rewrite_buf[0], rewrite_n)
    sys_close(fd)
    if wn < 0 or cast[uint64](wn) != rewrite_n:
        return -1
    return 0


# -- install command (Phase 2: trivial case) ---------------------------

def cmd_install(spec: Ptr[uint8]) -> int32:
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    # Make sure the installed DB is parsed so we can detect dups / write
    # an updated copy.
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1

    name_buf: Array[128, uint8]
    ver_buf:  Array[64, uint8]
    has_ver:  int32 = 0
    _split_nameversion(spec, &name_buf[0], 128, &ver_buf[0], 64, &has_ver)
    name_len: uint64 = strlen_u8(&name_buf[0])
    if name_len == 0:
        write_str(2, "hpm: install: empty package name\n")
        return 1

    idx: int64 = -1
    if has_ver != 0:
        idx = _pkg_find_exact(&name_buf[0], name_len,
                              &ver_buf[0], strlen_u8(&ver_buf[0]))
    else:
        idx = _pkg_find_best(&name_buf[0], name_len)
    if idx < 0:
        write_str(2, "hpm: no candidate for ")
        write_str(2, spec)
        write_str(2, "\n")
        return 1
    pi: uint64 = cast[uint64](idx)

    # Pull the version + url + sha256 + target out as cstrings.
    v_cstr: Array[64, uint8]
    _strcopy_n(&v_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_version_off[pi]),
               pkg_version_len[pi], 64)
    url_cstr: Array[512, uint8]
    _strcopy_n(&url_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_url_off[pi]),
               pkg_url_len[pi], 512)
    sha_cstr: Array[80, uint8]
    _strcopy_n(&sha_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_sha256_off[pi]),
               pkg_sha256_len[pi], 80)
    target_cstr: Array[128, uint8]
    if pkg_target_len[pi] > 0:
        _strcopy_n(&target_cstr[0],
                   cast[Ptr[uint8]](
                       cast[uint64](&idx_buf[0]) + pkg_target_off[pi]),
                   pkg_target_len[pi], 128)
    else:
        _strcopy_cstr(&target_cstr[0],
                      cast[Ptr[uint8]]("#hamnix-system"), 128)

    write_str(1, "hpm: installing ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    write_str(1, " (target=")
    write_str(1, &target_cstr[0])
    write_str(1, ", url=")
    write_str(1, &url_cstr[0])
    write_str(1, ")\n")

    # Phase 4 will check conflicts here. Phase 2 only blocks an
    # exact-name duplicate at the same version with no fuss.
    di: uint64 = 0
    while di < inst_count:
        if inst_name_len[di] == name_len:
            same: int32 = 1
            ki: uint64 = 0
            while ki < name_len:
                if inst_buf[inst_name_off[di] + ki] != name_buf[ki]:
                    same = 0
                    break
                ki = ki + 1
            if same != 0:
                write_str(2, "hpm: package ")
                sys_write(2, &name_buf[0], name_len)
                write_str(2, " is already installed (use `hpm remove` first or wait for Phase 5 update)\n")
                return 1
        di = di + 1

    # Channel-aware fetch: switch repo_url_buf to <base>/<channel>/
    # so the package's URL (which is relative to the channel root)
    # resolves correctly. _pkg_set_channel_url falls back to the
    # bare base for legacy (no-channel-field) indices.
    if _pkg_set_channel_url(pi) != 0:
        return 1

    # 1. Fetch the tarball.
    n: int64 = fetch_to_buf(&url_cstr[0], &deb_buf[0], TARBALL_CAP)
    if n < 0:
        write_str(2, "hpm: failed to fetch ")
        write_str(2, &url_cstr[0])
        write_str(2, "\n")
        return 1
    deb_len: uint64 = cast[uint64](n)
    write_str(1, "hpm: fetched ")
    write_dec_u64(1, deb_len)
    write_str(1, " bytes\n")

    # 2. Verify SHA-256.
    _sha256_hash_buf(&deb_buf[0], deb_len)
    expected_len: uint64 = strlen_u8(&sha_cstr[0])
    if expected_len != 64:
        write_str(2, "hpm: index sha256 is not 64 hex chars\n")
        return 1
    mi: uint64 = 0
    while mi < 64:
        ec: uint8 = sha_cstr[mi]
        # ASCII-fold to lowercase for the compare.
        if ec >= 65 and ec <= 70:
            ec = ec + 32
        if sha_hex[mi] != ec:
            write_str(2, "hpm: SHA-256 mismatch — refusing to install\n")
            write_str(2, "  expected: ")
            write_str(2, &sha_cstr[0])
            write_str(2, "\n  actual:   ")
            write_str(2, &sha_hex[0])
            write_str(2, "\n")
            return 1
        mi = mi + 1
    write_str(1, "hpm: SHA-256 verified\n")

    # 3. Inflate the tar.
    tar_len_i: int64 = _inflate_tarball(deb_len)
    if tar_len_i < 0:
        return 1
    tar_len: uint64 = cast[uint64](tar_len_i)
    write_str(1, "hpm: inflated to ")
    write_dec_u64(1, tar_len)
    write_str(1, " bytes\n")

    # 4. Build the package prefix "<name>-<version>/".
    pp: uint64 = 0
    ni: uint64 = 0
    while ni < name_len and pp + 1 < 128:
        pkg_prefix_buf[pp] = name_buf[ni]
        pp = pp + 1
        ni = ni + 1
    pkg_prefix_buf[pp] = 45                              # '-'
    pp = pp + 1
    vi: uint64 = 0
    vl: uint64 = strlen_u8(&v_cstr[0])
    while vi < vl and pp + 1 < 128:
        pkg_prefix_buf[pp] = v_cstr[vi]
        pp = pp + 1
        vi = vi + 1
    pkg_prefix_buf[pp] = 47                              # '/'
    pp = pp + 1
    pkg_prefix_buf[pp] = 0
    pkg_prefix_len = pp

    # 5. Read PKGINFO + check arch.
    if _read_pkginfo_from_tar(tar_len) != 0:
        return 1
    arch_len: uint64 = strlen_u8(&pi_arch[0])
    if arch_len > 0:
        if _streq(&pi_arch[0], cast[Ptr[uint8]]("x86_64")) == 0 \
                and _streq(&pi_arch[0], cast[Ptr[uint8]]("any")) == 0:
            write_str(2, "hpm: package arch `")
            write_str(2, &pi_arch[0])
            write_str(2, "` not compatible with x86_64\n")
            return 1
    # PKGINFO's target overrides the index's where present.
    pi_t_len: uint64 = strlen_u8(&pi_target[0])
    if pi_t_len > 0:
        _strcopy_cstr(&target_cstr[0], &pi_target[0], 128)
    target_len_eff: uint64 = strlen_u8(&target_cstr[0])

    # 6. Resolve the target prefix.
    if _set_target_prefix(&target_cstr[0], target_len_eff) != 0:
        return 1
    # Make sure the prefix directory itself exists (`/var/lib/distros/
    # default/` etc.) — tmpfs needs explicit mkdirs.
    if target_prefix_buf[0] != 0:
        _mkdir_p(&target_prefix_buf[0])
        sys_mkdir(cast[Ptr[char]](&target_prefix_buf[0]))

    # 7. Extract files/ into the target.
    _new_files_reset()
    if _stage_extract_files(tar_len, &target_prefix_buf[0]) != 0:
        write_str(2, "hpm: files/ extraction failed\n")
        return 1
    write_str(1, "hpm: extracted ")
    write_dec_u64(1, new_files_n)
    write_str(1, " files\n")

    # 8. Phase 2: stub-message any hooks present so the test can
    # assert the path. Phase 3 wires real execution.
    if _has_entry_in_tar(tar_len, cast[Ptr[uint8]]("pre-install.hamsh")) != 0:
        write_str(1, "hpm: hook would run: pre-install.hamsh\n")
    if _has_entry_in_tar(tar_len, cast[Ptr[uint8]]("install.hamsh")) != 0:
        write_str(1, "hpm: hook would run: install.hamsh\n")

    # 9. Update installed.json. Pinning: `@<ver>` pins per spec.
    pinned: int32 = 0
    if has_ver != 0:
        pinned = 1
    if _installed_rewrite_with_added(&name_buf[0], &v_cstr[0],
                                     &target_cstr[0], pinned) != 0:
        return 1

    write_str(1, "hpm: installed ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    sys_write(1, "\n", 1)
    return 0


# =====================================================================
# Phase 3: hooks + remove
# =====================================================================
#
# Hooks: docs/packages.md defines four hook points:
#   pre-install.hamsh   — runs BEFORE files are staged
#   install.hamsh       — runs AFTER files are staged
#   remove.hamsh        — runs BEFORE files are deleted
#   post-remove.hamsh   — runs AFTER files are deleted
#
# All hooks are plain hamsh scripts, run in init's namespace via
# sys_spawn /bin/hamsh <hookpath>. Env vars per spec:
#   HPM_PKG_NAME       — the package's name
#   HPM_PKG_VERSION    — the version being installed
#   HPM_PKG_DIR        — path to the extracted staging dir
#   HPM_TARGET         — the resolved target tag
#
# For Phase 3 we stage the WHOLE tarball to /tmp/hpm/staging/<pkg>-<ver>/
# so HPM_PKG_DIR points at a real, complete tree (the tests can poke
# into it) and so multi-file hooks (md5sums, conffiles, ...) have
# something to read. The staging dir lives on tmpfs (volatile), so a
# successful install leaves the cleanup-or-not call to the caller —
# v1 leaves staged trees in place for inspection.

# Staging path scratch.
staging_root_buf: Array[256, uint8]    # "/tmp/hpm/staging/<pkg>-<ver>"
hook_path_buf:    Array[512, uint8]    # full path to a hook script
hook_wrap_path:   Array[512, uint8]    # ".exec" wrapper path
hook_body_buf:    Array[16384, uint8]  # raw hook body for re-emit
hook_env_strs:    Array[2048, uint8]   # backing for env strings
hook_env_ptrs:    Array[8, uint64]     # NULL-terminated env array
hook_argv_buf:    Array[3, uint64]


def _stage_tarball(tar_len: uint64) -> int32:
    # Extract the WHOLE tarball (PKGINFO, files/, hooks, ...) under
    # /tmp/hpm/staging/<pkg>-<ver>/. Phase 3 needs this so hooks can
    # read PKGINFO + files/ as a real tree.
    sys_mkdir("/tmp/hpm/staging")
    # Build staging_root_buf = "/tmp/hpm/staging/<pkg>-<ver>"
    pfx: Ptr[uint8] = "/tmp/hpm/staging/"
    so: uint64 = 0
    while pfx[so] != 0:
        staging_root_buf[so] = pfx[so]
        so = so + 1
    # The pkg_prefix_buf already holds "<pkg>-<ver>/" — strip the
    # trailing slash for staging_root_buf.
    pp: uint64 = 0
    while pp + 1 < pkg_prefix_len:                       # exclude trailing '/'
        staging_root_buf[so] = pkg_prefix_buf[pp]
        so = so + 1
        pp = pp + 1
    staging_root_buf[so] = 0
    sys_mkdir(cast[Ptr[char]](&staging_root_buf[0]))

    # Walk the tar; write every entry under staging_root.
    off: uint64 = 0
    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            return 0
        if _tar_chksum_ok(hdr) == 0:
            return -1
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        typeflag: uint8 = hdr[156]
        body_blocks: uint64 = (size + 511) / 512

        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)
        if nlen <= pkg_prefix_len:
            off = off + 512 + body_blocks * 512
            continue
        prefix_ok: int32 = 1
        i: uint64 = 0
        while i < pkg_prefix_len:
            if warn_buf[i] != pkg_prefix_buf[i]:
                prefix_ok = 0
                break
            i = i + 1
        if prefix_ok == 0:
            off = off + 512 + body_blocks * 512
            continue
        tail_start: uint64 = pkg_prefix_len
        tail_len: uint64 = nlen - tail_start
        if tail_len == 0:
            off = off + 512 + body_blocks * 512
            continue
        # Path safety on the tail.
        safe_buf: Array[256, uint8]
        sl: uint64 = tail_len
        if sl >= 256:
            sl = 255
        kk: uint64 = 0
        while kk < sl:
            safe_buf[kk] = warn_buf[tail_start + kk]
            kk = kk + 1
        safe_buf[sl] = 0
        if _entry_name_is_unsafe(&safe_buf[0]) != 0:
            off = off + 512 + body_blocks * 512
            continue
        # Compose <staging_root>/<tail>.
        po: uint64 = 0
        ri: uint64 = 0
        while staging_root_buf[ri] != 0 and po + 1 < 512:
            extract_path_buf[po] = staging_root_buf[ri]
            po = po + 1
            ri = ri + 1
        extract_path_buf[po] = 47
        po = po + 1
        ti: uint64 = 0
        while ti < tail_len and po + 1 < 1024:
            extract_path_buf[po] = warn_buf[tail_start + ti]
            po = po + 1
            ti = ti + 1
        extract_path_buf[po] = 0

        if typeflag == 53:
            _mkdir_p(&extract_path_buf[0])
            sys_mkdir(cast[Ptr[char]](&extract_path_buf[0]))
            off = off + 512 + body_blocks * 512
            continue
        if typeflag != 0 and typeflag != 48:
            off = off + 512 + body_blocks * 512
            continue

        _dirname_mkdir_p(&extract_path_buf[0])
        body_off: uint64 = off + 512
        if body_off + size > tar_len:
            return -1
        fd: int32 = sys_open_write(cast[Ptr[char]](&extract_path_buf[0]))
        if fd < 0:
            off = off + 512 + body_blocks * 512
            continue
        if size > 0:
            _write_full(fd, &tar_buf[body_off], size)
        sys_close(fd)
        off = off + 512 + body_blocks * 512
    return 0


# Build the env block for a hook spawn:
#   HPM_PKG_NAME=...
#   HPM_PKG_VERSION=...
#   HPM_PKG_DIR=...
#   HPM_TARGET=...
# Returns the env-ptr (caller passes to sys_spawn). NUL-terminated
# strings live in hook_env_strs.

def _build_hook_env(name: Ptr[uint8], version: Ptr[uint8],
                    pkgdir: Ptr[uint8], target: Ptr[uint8]) -> Ptr[uint64]:
    pos: uint64 = 0
    idx: uint64 = 0

    # HPM_PKG_NAME=<name>
    hook_env_ptrs[idx] = cast[uint64](&hook_env_strs[pos])
    pfx1: Ptr[uint8] = "HPM_PKG_NAME="
    p: uint64 = 0
    while pfx1[p] != 0:
        hook_env_strs[pos] = pfx1[p]
        pos = pos + 1
        p = p + 1
    np: uint64 = 0
    while name[np] != 0 and pos + 1 < 2048:
        hook_env_strs[pos] = name[np]
        pos = pos + 1
        np = np + 1
    hook_env_strs[pos] = 0
    pos = pos + 1
    idx = idx + 1

    # HPM_PKG_VERSION=<version>
    hook_env_ptrs[idx] = cast[uint64](&hook_env_strs[pos])
    pfx2: Ptr[uint8] = "HPM_PKG_VERSION="
    p = 0
    while pfx2[p] != 0:
        hook_env_strs[pos] = pfx2[p]
        pos = pos + 1
        p = p + 1
    vp: uint64 = 0
    while version[vp] != 0 and pos + 1 < 2048:
        hook_env_strs[pos] = version[vp]
        pos = pos + 1
        vp = vp + 1
    hook_env_strs[pos] = 0
    pos = pos + 1
    idx = idx + 1

    # HPM_PKG_DIR=<pkgdir>
    hook_env_ptrs[idx] = cast[uint64](&hook_env_strs[pos])
    pfx3: Ptr[uint8] = "HPM_PKG_DIR="
    p = 0
    while pfx3[p] != 0:
        hook_env_strs[pos] = pfx3[p]
        pos = pos + 1
        p = p + 1
    dp: uint64 = 0
    while pkgdir[dp] != 0 and pos + 1 < 2048:
        hook_env_strs[pos] = pkgdir[dp]
        pos = pos + 1
        dp = dp + 1
    hook_env_strs[pos] = 0
    pos = pos + 1
    idx = idx + 1

    # HPM_TARGET=<target>
    hook_env_ptrs[idx] = cast[uint64](&hook_env_strs[pos])
    pfx4: Ptr[uint8] = "HPM_TARGET="
    p = 0
    while pfx4[p] != 0:
        hook_env_strs[pos] = pfx4[p]
        pos = pos + 1
        p = p + 1
    tp: uint64 = 0
    while target[tp] != 0 and pos + 1 < 2048:
        hook_env_strs[pos] = target[tp]
        pos = pos + 1
        tp = tp + 1
    hook_env_strs[pos] = 0
    pos = pos + 1
    idx = idx + 1

    hook_env_ptrs[idx] = 0
    return &hook_env_ptrs[0]


# Run a hook if it exists. Returns 0 on success, non-zero on hook
# failure (we exit-out the install / remove). If the hook script
# isn't present, returns 0 (no-op).
#
# `hook_name` is the bare leaf (e.g. "install.hamsh") — we form
# "<staging_root>/<hook_name>" and check the on-disk file.

def _run_hook(staging_root: Ptr[uint8], hook_name: Ptr[uint8],
              pkg_name: Ptr[uint8], pkg_version: Ptr[uint8],
              target: Ptr[uint8]) -> int32:
    # Compose hook_path_buf = "<staging_root>/<hook_name>".
    po: uint64 = 0
    ri: uint64 = 0
    while staging_root[ri] != 0 and po + 1 < 512:
        hook_path_buf[po] = staging_root[ri]
        po = po + 1
        ri = ri + 1
    hook_path_buf[po] = 47
    po = po + 1
    hi: uint64 = 0
    while hook_name[hi] != 0 and po + 1 < 512:
        hook_path_buf[po] = hook_name[hi]
        po = po + 1
        hi = hi + 1
    hook_path_buf[po] = 0
    # Existence check via open.
    test_fd: int32 = sys_open(cast[Ptr[char]](&hook_path_buf[0]))
    if test_fd < 0:
        return 0                                          # no-op
    sys_close(test_fd)

    # Hamsh-as-spawned-script falls through to the interactive REPL
    # after running argv[1] UNLESS the script invokes `exit`. Hooks
    # by convention are not required to call `exit`, so hpm STAGES a
    # wrapper script at <hookpath>.exec that sources the user hook
    # then issues `exit` — guaranteeing the spawned hamsh quits and
    # sys_waitpid() returns. The wrapper lives next to the original
    # hook (same dir), so the hook's relative file references still
    # resolve from the hook author's perspective.
    wi: uint64 = 0
    while wi < po:
        hook_wrap_path[wi] = hook_path_buf[wi]
        wi = wi + 1
    suffix: Ptr[uint8] = ".exec"
    si: uint64 = 0
    while suffix[si] != 0 and wi + 1 < 512:
        hook_wrap_path[wi] = suffix[si]
        wi = wi + 1
        si = si + 1
    hook_wrap_path[wi] = 0
    wfd: int32 = sys_open_write(cast[Ptr[char]](&hook_wrap_path[0]))
    if wfd < 0:
        write_str(2, "hpm: cannot create hook wrapper at ")
        write_str(2, &hook_wrap_path[0])
        write_str(2, "\n")
        return -1
    # Read the hook body into a scratch buffer + emit it followed by
    # "\nexit\n" so the spawned hamsh terminates after running it.
    hf: int32 = sys_open(cast[Ptr[char]](&hook_path_buf[0]))
    if hf < 0:
        sys_close(wfd)
        return -1
    htot: uint64 = 0
    while htot < 16384:
        n: int64 = sys_read(hf, &hook_body_buf[htot], 16384 - htot)
        if n <= 0:
            break
        htot = htot + cast[uint64](n)
    sys_close(hf)
    if htot > 0:
        _write_full(wfd, &hook_body_buf[0], htot)
    _write_full(wfd, cast[Ptr[uint8]]("\nexit\n"), 6)
    sys_close(wfd)

    write_str(1, "hpm: running hook ")
    write_str(1, hook_name)
    write_str(1, "\n")

    envp: Ptr[uint64] = _build_hook_env(pkg_name, pkg_version,
                                        staging_root, target)
    # argv = ["/bin/hamsh", "<wrapper-path>", NULL]
    hook_argv_buf[0] = cast[uint64](cast[Ptr[uint8]]("/bin/hamsh"))
    hook_argv_buf[1] = cast[uint64](&hook_wrap_path[0])
    hook_argv_buf[2] = 0
    pid: int32 = sys_spawn(cast[Ptr[char]]("/bin/hamsh"),
                           &hook_argv_buf[0], 0, 1, envp)
    if pid < 0:
        write_str(2, "hpm: hook spawn failed\n")
        return -1
    code: int64 = sys_waitpid(pid)
    if code != 0:
        write_str(2, "hpm: hook ")
        write_str(2, hook_name)
        write_str(2, " exited non-zero (")
        write_dec_u64(2, cast[uint64](code))
        write_str(2, ")\n")
        return -1
    return 0


# -- updated install path with real hook execution -------------------
#
# Phase 3 overrides the install command to: stage the tarball,
# run pre-install, extract files, run install. The stub-message
# replaces real spawning.

def cmd_install_v3(spec: Ptr[uint8]) -> int32:
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1

    name_buf: Array[128, uint8]
    ver_buf:  Array[64, uint8]
    has_ver:  int32 = 0
    _split_nameversion(spec, &name_buf[0], 128, &ver_buf[0], 64, &has_ver)
    name_len: uint64 = strlen_u8(&name_buf[0])
    if name_len == 0:
        write_str(2, "hpm: install: empty package name\n")
        return 1

    idx: int64 = -1
    if has_ver != 0:
        idx = _pkg_find_exact(&name_buf[0], name_len,
                              &ver_buf[0], strlen_u8(&ver_buf[0]))
    else:
        idx = _pkg_find_best(&name_buf[0], name_len)
    if idx < 0:
        write_str(2, "hpm: no candidate for ")
        write_str(2, spec)
        write_str(2, "\n")
        return 1
    pi: uint64 = cast[uint64](idx)

    v_cstr: Array[64, uint8]
    _strcopy_n(&v_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_version_off[pi]),
               pkg_version_len[pi], 64)
    url_cstr: Array[512, uint8]
    _strcopy_n(&url_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_url_off[pi]),
               pkg_url_len[pi], 512)
    sha_cstr: Array[80, uint8]
    _strcopy_n(&sha_cstr[0],
               cast[Ptr[uint8]](
                   cast[uint64](&idx_buf[0]) + pkg_sha256_off[pi]),
               pkg_sha256_len[pi], 80)
    target_cstr: Array[128, uint8]
    if pkg_target_len[pi] > 0:
        _strcopy_n(&target_cstr[0],
                   cast[Ptr[uint8]](
                       cast[uint64](&idx_buf[0]) + pkg_target_off[pi]),
                   pkg_target_len[pi], 128)
    else:
        _strcopy_cstr(&target_cstr[0],
                      cast[Ptr[uint8]]("#hamnix-system"), 128)

    write_str(1, "hpm: installing ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    write_str(1, " (target=")
    write_str(1, &target_cstr[0])
    write_str(1, ")\n")

    di: uint64 = 0
    while di < inst_count:
        if inst_name_len[di] == name_len:
            same: int32 = 1
            ki: uint64 = 0
            while ki < name_len:
                if inst_buf[inst_name_off[di] + ki] != name_buf[ki]:
                    same = 0
                    break
                ki = ki + 1
            if same != 0:
                write_str(2, "hpm: package ")
                sys_write(2, &name_buf[0], name_len)
                write_str(2, " is already installed\n")
                return 1
        di = di + 1

    # Channel-aware fetch.
    if _pkg_set_channel_url(pi) != 0:
        return 1

    # Fetch.
    n: int64 = fetch_to_buf(&url_cstr[0], &deb_buf[0], TARBALL_CAP)
    if n < 0:
        write_str(2, "hpm: failed to fetch ")
        write_str(2, &url_cstr[0])
        write_str(2, "\n")
        return 1
    deb_len: uint64 = cast[uint64](n)

    # SHA-256.
    _sha256_hash_buf(&deb_buf[0], deb_len)
    expected_len: uint64 = strlen_u8(&sha_cstr[0])
    if expected_len != 64:
        write_str(2, "hpm: index sha256 is not 64 hex chars\n")
        return 1
    mi: uint64 = 0
    while mi < 64:
        ec: uint8 = sha_cstr[mi]
        if ec >= 65 and ec <= 70:
            ec = ec + 32
        if sha_hex[mi] != ec:
            write_str(2, "hpm: SHA-256 mismatch — refusing to install\n")
            return 1
        mi = mi + 1
    write_str(1, "hpm: SHA-256 verified\n")

    # Inflate.
    tar_len_i: int64 = _inflate_tarball(deb_len)
    if tar_len_i < 0:
        return 1
    tar_len: uint64 = cast[uint64](tar_len_i)

    # Build pkg_prefix.
    pp: uint64 = 0
    ni: uint64 = 0
    while ni < name_len and pp + 1 < 128:
        pkg_prefix_buf[pp] = name_buf[ni]
        pp = pp + 1
        ni = ni + 1
    pkg_prefix_buf[pp] = 45
    pp = pp + 1
    vi: uint64 = 0
    vl: uint64 = strlen_u8(&v_cstr[0])
    while vi < vl and pp + 1 < 128:
        pkg_prefix_buf[pp] = v_cstr[vi]
        pp = pp + 1
        vi = vi + 1
    pkg_prefix_buf[pp] = 47
    pp = pp + 1
    pkg_prefix_buf[pp] = 0
    pkg_prefix_len = pp

    # Read PKGINFO; arch check.
    if _read_pkginfo_from_tar(tar_len) != 0:
        return 1
    arch_len: uint64 = strlen_u8(&pi_arch[0])
    if arch_len > 0:
        if _streq(&pi_arch[0], cast[Ptr[uint8]]("x86_64")) == 0 \
                and _streq(&pi_arch[0], cast[Ptr[uint8]]("any")) == 0:
            write_str(2, "hpm: package arch incompatible\n")
            return 1
    pi_t_len: uint64 = strlen_u8(&pi_target[0])
    if pi_t_len > 0:
        _strcopy_cstr(&target_cstr[0], &pi_target[0], 128)
    target_len_eff: uint64 = strlen_u8(&target_cstr[0])

    # Target prefix.
    if _set_target_prefix(&target_cstr[0], target_len_eff) != 0:
        return 1
    if target_prefix_buf[0] != 0:
        _mkdir_p(&target_prefix_buf[0])
        sys_mkdir(cast[Ptr[char]](&target_prefix_buf[0]))

    # Stage the tarball to disk so hooks can read it.
    if _stage_tarball(tar_len) != 0:
        write_str(2, "hpm: tarball staging failed\n")
        return 1

    # pre-install.hamsh runs BEFORE files are staged at target.
    if _run_hook(&staging_root_buf[0],
                 cast[Ptr[uint8]]("pre-install.hamsh"),
                 &name_buf[0], &v_cstr[0], &target_cstr[0]) != 0:
        write_str(2, "hpm: pre-install hook failed; aborting install\n")
        return 1

    # Extract files/.
    _new_files_reset()
    if _stage_extract_files(tar_len, &target_prefix_buf[0]) != 0:
        return 1
    write_str(1, "hpm: extracted ")
    write_dec_u64(1, new_files_n)
    write_str(1, " files\n")

    # install.hamsh runs AFTER files are staged at target.
    if _run_hook(&staging_root_buf[0],
                 cast[Ptr[uint8]]("install.hamsh"),
                 &name_buf[0], &v_cstr[0], &target_cstr[0]) != 0:
        write_str(2, "hpm: install hook failed; package files were placed but the hook errored\n")
        return 1

    # installed.json.
    pinned: int32 = 0
    if has_ver != 0:
        pinned = 1
    if _installed_rewrite_with_added(&name_buf[0], &v_cstr[0],
                                     &target_cstr[0], pinned) != 0:
        return 1

    write_str(1, "hpm: installed ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    sys_write(1, "\n", 1)
    return 0


# -- remove command (Phase 3) -----------------------------------------
#
# `hpm remove <name>`:
#   1. Load installed.json; find the entry for <name>.
#   2. Re-stage the tarball (via the cache at /tmp/hpm/staging/) IF
#      we have it; for v1 we accept that the staging dir from install
#      might still be around. If not, hooks are SKIPPED (the test only
#      checks the file-removal path; hooks-on-remove from a fresh-boot
#      no-cache state needs a refetch which is a Phase 5+ concern).
#   3. Run remove.hamsh (if present, if staging is around).
#   4. sys_unlink each recorded file in REVERSE install order.
#   5. Run post-remove.hamsh (if present).
#   6. Rewrite installed.json with the package removed.

def cmd_remove(name: Ptr[uint8]) -> int32:
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1
    if lrc == 1 or inst_count == 0:
        write_str(2, "hpm: no packages installed\n")
        return 1

    name_len: uint64 = strlen_u8(name)
    # Find the matching installed entry.
    found: int64 = -1
    i: uint64 = 0
    while i < inst_count:
        if inst_name_len[i] == name_len:
            same: int32 = 1
            k: uint64 = 0
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                found = cast[int64](i)
                break
        i = i + 1
    if found < 0:
        write_str(2, "hpm: package ")
        write_str(2, name)
        write_str(2, " not installed\n")
        return 1
    fi: uint64 = cast[uint64](found)

    # Resolve target prefix.
    target_cstr: Array[128, uint8]
    if inst_target_len[fi] > 0:
        _strcopy_n(&target_cstr[0], &inst_buf[inst_target_off[fi]],
                   inst_target_len[fi], 128)
    else:
        _strcopy_cstr(&target_cstr[0],
                      cast[Ptr[uint8]]("#hamnix-system"), 128)
    if _set_target_prefix(&target_cstr[0],
                          strlen_u8(&target_cstr[0])) != 0:
        return 1

    # Version cstr (for the hook env).
    v_cstr: Array[64, uint8]
    _strcopy_n(&v_cstr[0], &inst_buf[inst_ver_off[fi]],
               inst_ver_len[fi], 64)

    # Compose the staging root we'd have used at install time, in case
    # it still exists. /tmp is tmpfs, so a reboot wipes it — that's
    # fine; remove just skips hooks in that case.
    sg: uint64 = 0
    sp_pfx: Ptr[uint8] = "/tmp/hpm/staging/"
    while sp_pfx[sg] != 0:
        staging_root_buf[sg] = sp_pfx[sg]
        sg = sg + 1
    ni2: uint64 = 0
    while ni2 < name_len:
        staging_root_buf[sg] = name[ni2]
        sg = sg + 1
        ni2 = ni2 + 1
    staging_root_buf[sg] = 45                            # '-'
    sg = sg + 1
    vi2: uint64 = 0
    vl2: uint64 = strlen_u8(&v_cstr[0])
    while vi2 < vl2:
        staging_root_buf[sg] = v_cstr[vi2]
        sg = sg + 1
        vi2 = vi2 + 1
    staging_root_buf[sg] = 0

    # Check whether staging is present (open the PKGINFO inside it).
    sting_pkginfo_buf: Array[512, uint8]
    so: uint64 = 0
    while staging_root_buf[so] != 0 and so + 1 < 512:
        sting_pkginfo_buf[so] = staging_root_buf[so]
        so = so + 1
    pkginfo_tail: Ptr[uint8] = "/PKGINFO"
    pi_i: uint64 = 0
    while pkginfo_tail[pi_i] != 0 and so + 1 < 512:
        sting_pkginfo_buf[so] = pkginfo_tail[pi_i]
        so = so + 1
        pi_i = pi_i + 1
    sting_pkginfo_buf[so] = 0
    has_staging: int32 = 0
    test_fd: int32 = sys_open(cast[Ptr[char]](&sting_pkginfo_buf[0]))
    if test_fd >= 0:
        has_staging = 1
        sys_close(test_fd)

    write_str(1, "hpm: removing ")
    sys_write(1, name, name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    sys_write(1, "\n", 1)

    if has_staging != 0:
        # remove.hamsh runs BEFORE files are deleted.
        rc: int32 = _run_hook(&staging_root_buf[0],
                              cast[Ptr[uint8]]("remove.hamsh"),
                              name, &v_cstr[0], &target_cstr[0])
        if rc != 0:
            write_str(2, "hpm: remove hook aborted; nothing deleted\n")
            return 1
    else:
        write_str(1, "hpm: (staging tree absent — pre/post-remove hooks skipped)\n")

    # Delete files in REVERSE install order.
    fc: uint64 = inst_file_count[fi]
    fs: uint64 = inst_file_start[fi]
    if fc > 0:
        ri: uint64 = fc
        while ri > 0:
            ri = ri - 1
            slot: uint64 = fs + ri
            # Compose <target_prefix><rel> into extract_path_buf.
            po: uint64 = 0
            tp: uint64 = 0
            while target_prefix_buf[tp] != 0 and po + 1 < 1024:
                extract_path_buf[po] = target_prefix_buf[tp]
                po = po + 1
                tp = tp + 1
            rl: uint64 = inst_file_len[slot]
            rj: uint64 = 0
            while rj < rl and po + 1 < 1024:
                extract_path_buf[po] = inst_buf[inst_file_off[slot] + rj]
                po = po + 1
                rj = rj + 1
            extract_path_buf[po] = 0
            sys_unlink(cast[Ptr[char]](&extract_path_buf[0]))
    write_str(1, "hpm: deleted ")
    write_dec_u64(1, fc)
    write_str(1, " files\n")

    if has_staging != 0:
        # post-remove.hamsh runs AFTER files are deleted.
        _run_hook(&staging_root_buf[0],
                  cast[Ptr[uint8]]("post-remove.hamsh"),
                  name, &v_cstr[0], &target_cstr[0])

    if _installed_rewrite_with_removed(name) != 0:
        return 1

    write_str(1, "hpm: removed ")
    sys_write(1, name, name_len)
    sys_write(1, "\n", 1)
    return 0


# =====================================================================
# Phase 4: dependency solver + conflict detection (greedy BFS)
# =====================================================================
#
# docs/packages.md says: greedy breadth-first, no backtracking.
# Algorithm:
#
#   1. Push the user's requested package onto a queue.
#   2. While queue non-empty:
#      a. Pop a requirement (name + constraint).
#      b. If already in `resolved` or `installed`, verify the existing
#         version satisfies the constraint; on conflict FAIL.
#      c. Find the best (highest-version) repo entry matching the
#         constraint. If none, FAIL.
#      d. Check declared conflicts against resolved + installed. FAIL
#         on any match.
#      e. Add to `resolved`; enqueue every `depends:` entry.
#   3. Topological order: enqueue order is roots-first BFS, but we
#      want deps-first (so a child's install runs after its parents).
#      Reverse-resolve order = enqueue order is the topo order if we
#      treat "resolved" as a stack post-walk. Simpler: enqueue in BFS,
#      then return the resolved set REVERSED — deepest deps first.
#
#      Actually the cleanest invariant per spec is post-order:
#      enqueue means "I depend on these"; the BFS DOES NOT produce
#      proper topological order on its own. We collect resolved
#      packages into res_*, build an adjacency-list pass to determine
#      a topo order, then return that.

# Constraint operators:
CMP_ANY:  int32 = 0     # name (no constraint)
CMP_GE:   int32 = 1     # name>=ver
CMP_GT:   int32 = 2     # name>ver
CMP_EQ:   int32 = 3     # name==ver
CMP_LE:   int32 = 4     # name<=ver
CMP_LT:   int32 = 5     # name<ver

# Resolved set: per-resolved-package, the (idx_buf) repo index + the
# computed install order rank. Bounded at RES_MAX.
RES_MAX:   uint64 = 64
res_count: uint64 = 0
res_pkg_idx:   Array[64, uint64]    # repo index into pkg_*[i]
res_topo_rank: Array[64, uint64]    # 0 = deepest dep, last = the root

# BFS queue of pending requirements. Each entry: (name_off into idx_buf
# or scratch, name_len, op, ver_off, ver_len). For requirements that
# came from the user CLI (the root), name lives in res_root_name_buf.
QUEUE_MAX: uint64 = 256
q_name_ptr:   Array[256, uint64]      # Ptr[uint8] to the name (or 0)
q_name_len:   Array[256, uint64]
q_op:         Array[256, int32]
q_ver_ptr:    Array[256, uint64]
q_ver_len:    Array[256, uint64]
q_parent:     Array[256, uint64]      # res index of the package that
                                       # enqueued this req (used for
                                       # topo edges); 0xffff = root
q_head:       uint64 = 0
q_tail:       uint64 = 0

# Adjacency lists (for topo sort). For each resolved package, the
# resolved packages that depend on IT. Bounded by RES_MAX^2.
adj_count:  Array[64, uint64]
adj_to:     Array[4096, uint64]       # flat (from, to) edges
adj_n:      uint64 = 0

# Buffer for the user-supplied root requirement's name.
root_name_buf: Array[128, uint8]
root_ver_buf:  Array[64, uint8]

# Dep-term parsing scratch.
term_name_buf: Array[128, uint8]
term_ver_buf:  Array[64, uint8]


# Parse "name", "name>=1.0", "name>2", "name==1.0", etc. Writes the
# name into name_out (cap-bounded, NUL-terminated), the version into
# ver_out (NUL-terminated; empty if no operator), and the operator
# into *op_out. Returns 0 on success, -1 on a malformed term.

def _parse_constraint(spec: Ptr[uint8], spec_len: uint64,
                      name_out: Ptr[uint8], name_cap: uint64,
                      ver_out: Ptr[uint8], ver_cap: uint64,
                      op_out: Ptr[int32]) -> int32:
    op_out[0] = CMP_ANY
    name_out[0] = 0
    ver_out[0] = 0

    # Find the operator boundary. The operators are '>=' '<=' '==' '>' '<'.
    i: uint64 = 0
    op_start: int64 = -1
    op_kind: int32 = CMP_ANY
    while i < spec_len:
        c: uint8 = spec[i]
        if c == 62:                                      # '>'
            if i + 1 < spec_len and spec[i + 1] == 61:   # '>='
                op_kind = CMP_GE
                op_start = cast[int64](i)
                i = i + 2
                break
            op_kind = CMP_GT
            op_start = cast[int64](i)
            i = i + 1
            break
        if c == 60:                                      # '<'
            if i + 1 < spec_len and spec[i + 1] == 61:   # '<='
                op_kind = CMP_LE
                op_start = cast[int64](i)
                i = i + 2
                break
            op_kind = CMP_LT
            op_start = cast[int64](i)
            i = i + 1
            break
        if c == 61:                                      # '='
            if i + 1 < spec_len and spec[i + 1] == 61:   # '=='
                op_kind = CMP_EQ
                op_start = cast[int64](i)
                i = i + 2
                break
            return -1
        if c == 32 or c == 9 or c == 44:                 # ws / ','
            break
        i = i + 1

    if op_start < 0:
        # No operator — copy the whole spec as name.
        no: uint64 = 0
        j: uint64 = 0
        while j < spec_len:
            c2: uint8 = spec[j]
            if c2 == 32 or c2 == 9 or c2 == 44:
                break
            if no + 1 >= name_cap:
                break
            name_out[no] = c2
            no = no + 1
            j = j + 1
        name_out[no] = 0
        return 0

    # Name = spec[0..op_start); version = spec[i..spec_len).
    no: uint64 = 0
    jj: uint64 = 0
    while jj < cast[uint64](op_start):
        if no + 1 >= name_cap:
            break
        name_out[no] = spec[jj]
        no = no + 1
        jj = jj + 1
    name_out[no] = 0
    vo: uint64 = 0
    while i < spec_len:
        c3: uint8 = spec[i]
        if c3 == 32 or c3 == 9 or c3 == 44:
            break
        if vo + 1 >= ver_cap:
            break
        ver_out[vo] = c3
        vo = vo + 1
        i = i + 1
    ver_out[vo] = 0
    op_out[0] = op_kind
    return 0


# Check whether `have_ver` satisfies `op want_ver`.
def _version_satisfies(have_ptr: Ptr[uint8], have_len: uint64,
                       op: int32,
                       want_ptr: Ptr[uint8], want_len: uint64) -> int32:
    if op == CMP_ANY:
        return 1
    c: int32 = _version_compare(have_ptr, have_len, want_ptr, want_len)
    if op == CMP_GE:
        if c >= 0:
            return 1
        return 0
    if op == CMP_GT:
        if c > 0:
            return 1
        return 0
    if op == CMP_EQ:
        if c == 0:
            return 1
        return 0
    if op == CMP_LE:
        if c <= 0:
            return 1
        return 0
    if op == CMP_LT:
        if c < 0:
            return 1
        return 0
    return 0


# Find the best repo entry whose name matches `want` AND whose version
# satisfies (op, want_ver). Returns the repo idx, or -1 if none.

def _pkg_find_best_constrained(want: Ptr[uint8], want_len: uint64,
                               op: int32,
                               want_ver: Ptr[uint8],
                               want_ver_len: uint64) -> int64:
    best: int64 = -1
    i: uint64 = 0
    while i < pkg_count:
        if _name_eq_span(pkg_name_off[i], pkg_name_len[i],
                         want, want_len) != 0:
            ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                cast[uint64](&idx_buf[0]) + pkg_version_off[i])
            if _version_satisfies(ver_ptr, pkg_version_len[i],
                                  op, want_ver, want_ver_len) != 0:
                if best < 0:
                    best = cast[int64](i)
                else:
                    bi: uint64 = cast[uint64](best)
                    bver_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                        cast[uint64](&idx_buf[0]) + pkg_version_off[bi])
                    cmp: int32 = _version_compare(ver_ptr,
                                                  pkg_version_len[i],
                                                  bver_ptr,
                                                  pkg_version_len[bi])
                    if cmp > 0:
                        best = cast[int64](i)
        i = i + 1
    return best


# Check whether `cand` conflicts with anything in `resolved` (via the
# cand's conflicts: list, OR any resolved's conflicts: targeting cand).
# Also checks resolved+installed for the same name with a different
# version (same-name version conflict). Returns 0 = no conflict, 1 =
# conflict (diagnostic printed).

def _check_conflicts(cand_idx: uint64) -> int32:
    cand_name_ptr: Ptr[uint8] = cast[Ptr[uint8]](
        cast[uint64](&idx_buf[0]) + pkg_name_off[cand_idx])
    cand_name_len: uint64 = pkg_name_len[cand_idx]
    cand_ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](
        cast[uint64](&idx_buf[0]) + pkg_version_off[cand_idx])
    cand_ver_len: uint64 = pkg_version_len[cand_idx]

    # 1. Same-name conflict in resolved (different version).
    r: uint64 = 0
    while r < res_count:
        ri: uint64 = res_pkg_idx[r]
        if pkg_name_len[ri] == cand_name_len:
            same: int32 = 1
            k: uint64 = 0
            while k < cand_name_len:
                if idx_buf[pkg_name_off[ri] + k] != cand_name_ptr[k]:
                    same = 0
                    break
                k = k + 1
            if same != 0:
                # Same name — version must match.
                rver_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                    cast[uint64](&idx_buf[0]) + pkg_version_off[ri])
                if _version_compare(rver_ptr, pkg_version_len[ri],
                                    cand_ver_ptr, cand_ver_len) != 0:
                    write_str(2, "hpm: same-name version conflict in solve: ")
                    sys_write(2, cand_name_ptr, cand_name_len)
                    write_str(2, "\n")
                    return 1
        r = r + 1

    # 2. Same-name conflict in installed (different version).
    ii: uint64 = 0
    while ii < inst_count:
        if inst_name_len[ii] == cand_name_len:
            same2: int32 = 1
            k: uint64 = 0
            while k < cand_name_len:
                if inst_buf[inst_name_off[ii] + k] != cand_name_ptr[k]:
                    same2 = 0
                    break
                k = k + 1
            if same2 != 0:
                # Compare versions.
                if _version_compare(&inst_buf[inst_ver_off[ii]],
                                    inst_ver_len[ii],
                                    cand_ver_ptr, cand_ver_len) != 0:
                    write_str(2, "hpm: ")
                    sys_write(2, cand_name_ptr, cand_name_len)
                    write_str(2, " is already installed at a different version (use `hpm remove` first)\n")
                    return 1
        ii = ii + 1

    # 3. Cand's declared conflicts target a resolved/installed pkg.
    cc: uint64 = 0
    while cc < pkg_conf_count[cand_idx]:
        slot: uint64 = pkg_conf_start[cand_idx] + cc
        cn_ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&idx_buf[0]) + conf_entry_off[slot])
        cn_len: uint64 = conf_entry_len[slot]
        # vs resolved
        rr: uint64 = 0
        while rr < res_count:
            ri2: uint64 = res_pkg_idx[rr]
            if pkg_name_len[ri2] == cn_len:
                eq: int32 = 1
                k2: uint64 = 0
                while k2 < cn_len:
                    if idx_buf[pkg_name_off[ri2] + k2] != cn_ptr[k2]:
                        eq = 0
                        break
                    k2 = k2 + 1
                if eq != 0:
                    write_str(2, "hpm: declared-conflict: ")
                    sys_write(2, cand_name_ptr, cand_name_len)
                    write_str(2, " conflicts with ")
                    sys_write(2, cn_ptr, cn_len)
                    write_str(2, "\n")
                    return 1
            rr = rr + 1
        # vs installed
        ii2: uint64 = 0
        while ii2 < inst_count:
            if inst_name_len[ii2] == cn_len:
                eq2: int32 = 1
                k3: uint64 = 0
                while k3 < cn_len:
                    if inst_buf[inst_name_off[ii2] + k3] != cn_ptr[k3]:
                        eq2 = 0
                        break
                    k3 = k3 + 1
                if eq2 != 0:
                    write_str(2, "hpm: declared-conflict: ")
                    sys_write(2, cand_name_ptr, cand_name_len)
                    write_str(2, " conflicts with installed ")
                    sys_write(2, cn_ptr, cn_len)
                    write_str(2, "\n")
                    return 1
            ii2 = ii2 + 1
        cc = cc + 1

    # 4. Any resolved/installed pkg's conflicts: targets cand.
    rr2: uint64 = 0
    while rr2 < res_count:
        ri3: uint64 = res_pkg_idx[rr2]
        cc2: uint64 = 0
        while cc2 < pkg_conf_count[ri3]:
            slot2: uint64 = pkg_conf_start[ri3] + cc2
            cn2_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                cast[uint64](&idx_buf[0]) + conf_entry_off[slot2])
            cn2_len: uint64 = conf_entry_len[slot2]
            if cn2_len == cand_name_len:
                eq3: int32 = 1
                k4: uint64 = 0
                while k4 < cn2_len:
                    if cn2_ptr[k4] != cand_name_ptr[k4]:
                        eq3 = 0
                        break
                    k4 = k4 + 1
                if eq3 != 0:
                    write_str(2, "hpm: declared-conflict (resolved->cand): ")
                    sys_write(2, &idx_buf[pkg_name_off[ri3]],
                              pkg_name_len[ri3])
                    write_str(2, " conflicts with ")
                    sys_write(2, cand_name_ptr, cand_name_len)
                    write_str(2, "\n")
                    return 1
            cc2 = cc2 + 1
        rr2 = rr2 + 1

    return 0


# Is `cand_name` already in res_*? Returns -1 if no, else the res idx.
def _find_in_resolved(cand_name: Ptr[uint8], cand_name_len: uint64) -> int64:
    r: uint64 = 0
    while r < res_count:
        ri: uint64 = res_pkg_idx[r]
        if pkg_name_len[ri] == cand_name_len:
            eq: int32 = 1
            k: uint64 = 0
            while k < cand_name_len:
                if idx_buf[pkg_name_off[ri] + k] != cand_name[k]:
                    eq = 0
                    break
                k = k + 1
            if eq != 0:
                return cast[int64](r)
        r = r + 1
    return -1


# Is `cand_name` already installed? Returns -1 if no, else the inst idx.
def _find_in_installed(cand_name: Ptr[uint8], cand_name_len: uint64) -> int64:
    i: uint64 = 0
    while i < inst_count:
        if inst_name_len[i] == cand_name_len:
            eq: int32 = 1
            k: uint64 = 0
            while k < cand_name_len:
                if inst_buf[inst_name_off[i] + k] != cand_name[k]:
                    eq = 0
                    break
                k = k + 1
            if eq != 0:
                return cast[int64](i)
        i = i + 1
    return -1


def _queue_push(name_ptr: Ptr[uint8], name_len: uint64,
                op: int32, ver_ptr: Ptr[uint8], ver_len: uint64,
                parent: uint64) -> int32:
    if q_tail >= 256:
        write_str(2, "hpm: solve queue overflow\n")
        return -1
    q_name_ptr[q_tail] = cast[uint64](name_ptr)
    q_name_len[q_tail] = name_len
    q_op[q_tail] = op
    q_ver_ptr[q_tail] = cast[uint64](ver_ptr)
    q_ver_len[q_tail] = ver_len
    q_parent[q_tail] = parent
    q_tail = q_tail + 1
    return 0


# Topologically sort res_pkg_idx[] using the adjacency table built
# during solve. Writes the post-order rank into res_topo_rank[].
# Simple iterative DFS — RES_MAX is 64.

topo_visited: Array[64, int32]
topo_order:   Array[64, uint64]
topo_n:       uint64 = 0


def _topo_visit(node: uint64):
    if topo_visited[node] != 0:
        return
    topo_visited[node] = 1
    # Visit children (packages that depend on this one — no wait, we
    # want post-order so the package itself comes AFTER its deps).
    # Edges: adj_to[i] for the resolved set — we recorded edge (parent
    # -> child) where child is a dep, so a topo install order is
    # children first.
    j: uint64 = 0
    while j < adj_n:
        if cast[uint64](adj_to[j] >> 32) == node:
            child: uint64 = adj_to[j] & 0xFFFFFFFF
            _topo_visit(child)
        j = j + 1
    topo_order[topo_n] = node
    topo_n = topo_n + 1


def _topo_sort():
    i: uint64 = 0
    while i < 64:
        topo_visited[i] = 0
        i = i + 1
    topo_n = 0
    j: uint64 = 0
    while j < res_count:
        _topo_visit(j)
        j = j + 1
    # topo_order is now [deps..., root] which is the install order.


# Solve: build res_* by BFS from the user's root spec. Returns 0 on
# success, -1 on failure.

def _solve(root_spec: Ptr[uint8]) -> int32:
    res_count = 0
    q_head = 0
    q_tail = 0
    adj_n = 0
    # zero counts
    az: uint64 = 0
    while az < 64:
        adj_count[az] = 0
        az = az + 1

    # Parse the root spec into name/op/ver.
    spec_len: uint64 = strlen_u8(root_spec)
    # Pre-process: spec is either "<name>" or "<name>@<ver>" (CLI),
    # not the dependency-list form. Translate '@' to '==' for the
    # parser — '@' means pin (== exactly).
    norm_buf: Array[256, uint8]
    no: uint64 = 0
    at_seen: int32 = 0
    si: uint64 = 0
    while si < spec_len and no + 2 < 256:
        c: uint8 = root_spec[si]
        if c == 64 and at_seen == 0:                     # '@'
            norm_buf[no] = 61                            # '='
            no = no + 1
            norm_buf[no] = 61                            # '='
            no = no + 1
            at_seen = 1
        else:
            norm_buf[no] = c
            no = no + 1
        si = si + 1
    norm_buf[no] = 0
    norm_len: uint64 = no

    root_op: int32 = CMP_ANY
    if _parse_constraint(&norm_buf[0], norm_len,
                         &root_name_buf[0], 128,
                         &root_ver_buf[0], 64, &root_op) != 0:
        write_str(2, "hpm: malformed package spec\n")
        return -1

    rn_len: uint64 = strlen_u8(&root_name_buf[0])
    rv_len: uint64 = strlen_u8(&root_ver_buf[0])
    if _queue_push(&root_name_buf[0], rn_len, root_op,
                   &root_ver_buf[0], rv_len, 0xffff) != 0:
        return -1

    while q_head < q_tail:
        # Pop one req.
        np: Ptr[uint8] = cast[Ptr[uint8]](q_name_ptr[q_head])
        nl: uint64 = q_name_len[q_head]
        op: int32 = q_op[q_head]
        vp: Ptr[uint8] = cast[Ptr[uint8]](q_ver_ptr[q_head])
        vl: uint64 = q_ver_len[q_head]
        parent: uint64 = q_parent[q_head]
        q_head = q_head + 1

        # Already in resolved?
        ridx_i: int64 = _find_in_resolved(np, nl)
        if ridx_i >= 0:
            ridx: uint64 = cast[uint64](ridx_i)
            # Verify the existing version satisfies the new constraint.
            pi: uint64 = res_pkg_idx[ridx]
            rv_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                cast[uint64](&idx_buf[0]) + pkg_version_off[pi])
            if _version_satisfies(rv_ptr, pkg_version_len[pi],
                                  op, vp, vl) == 0:
                write_str(2, "hpm: unsatisfiable: resolved ")
                sys_write(2, np, nl)
                write_str(2, " does not satisfy constraint\n")
                return -1
            # Add edge parent -> ridx (parent depends on ridx).
            if parent != 0xffff:
                if adj_n < 4096:
                    adj_to[adj_n] = (parent << 32) | ridx
                    adj_n = adj_n + 1
            continue

        # Already installed?
        iidx_i: int64 = _find_in_installed(np, nl)
        if iidx_i >= 0:
            iidx: uint64 = cast[uint64](iidx_i)
            if _version_satisfies(&inst_buf[inst_ver_off[iidx]],
                                  inst_ver_len[iidx],
                                  op, vp, vl) == 0:
                write_str(2, "hpm: unsatisfiable: installed ")
                sys_write(2, np, nl)
                write_str(2, " does not satisfy constraint\n")
                return -1
            # Installed pkgs aren't re-added; no edge.
            continue

        # Find the best repo candidate.
        cand_i: int64 = _pkg_find_best_constrained(np, nl, op, vp, vl)
        if cand_i < 0:
            write_str(2, "hpm: no candidate for ")
            sys_write(2, np, nl)
            write_str(2, "\n")
            return -1
        cand: uint64 = cast[uint64](cand_i)

        # Conflicts?
        if _check_conflicts(cand) != 0:
            return -1

        # Add to resolved.
        if res_count >= 64:
            write_str(2, "hpm: dep closure too large (>64)\n")
            return -1
        new_ridx: uint64 = res_count
        res_pkg_idx[res_count] = cand
        res_count = res_count + 1

        # Edge parent -> new_ridx.
        if parent != 0xffff:
            if adj_n < 4096:
                adj_to[adj_n] = (parent << 32) | new_ridx
                adj_n = adj_n + 1

        # Enqueue this pkg's deps.
        dc: uint64 = pkg_dep_count[cand]
        ds: uint64 = pkg_dep_start[cand]
        di: uint64 = 0
        while di < dc:
            slot: uint64 = ds + di
            # Each dep entry is "name" or "name>=ver" etc. — parse it.
            dn_buf: Array[128, uint8]
            dv_buf: Array[64, uint8]
            dop: int32 = CMP_ANY
            if _parse_constraint(
                    cast[Ptr[uint8]](
                        cast[uint64](&idx_buf[0]) + dep_entry_off[slot]),
                    dep_entry_len[slot],
                    &dn_buf[0], 128, &dv_buf[0], 64, &dop) != 0:
                write_str(2, "hpm: malformed dep entry\n")
                return -1
            # We need stable pointers — copy into per-queue-entry
            # scratch. To avoid 256 separate buffers we cheat: each
            # dep name+ver is a small substring of idx_buf, so push
            # idx_buf pointers directly. The dep entry IS in idx_buf
            # already — but version-constraint operators split it. We
            # work around by using a flat name/ver scratch table per
            # queue slot.
            if _push_dep_with_scratch(&dn_buf[0], &dv_buf[0],
                                      dop, new_ridx) != 0:
                return -1
            di = di + 1

    _topo_sort()
    return 0


# Per-queue scratch backing for dep names + versions. Each pushed
# dep gets its own slot in q_scratch_strs; the queue's name_ptr /
# ver_ptr point into it.
q_scratch_strs: Array[16384, uint8]
q_scratch_n:    uint64 = 0


def _push_dep_with_scratch(name: Ptr[uint8], ver: Ptr[uint8],
                           op: int32, parent: uint64) -> int32:
    nlen: uint64 = strlen_u8(name)
    vlen: uint64 = strlen_u8(ver)
    if q_scratch_n + nlen + vlen + 2 > 16384:
        write_str(2, "hpm: dep scratch overflow\n")
        return -1
    name_off: uint64 = q_scratch_n
    i: uint64 = 0
    while i < nlen:
        q_scratch_strs[q_scratch_n] = name[i]
        q_scratch_n = q_scratch_n + 1
        i = i + 1
    q_scratch_strs[q_scratch_n] = 0
    q_scratch_n = q_scratch_n + 1
    ver_off: uint64 = q_scratch_n
    j: uint64 = 0
    while j < vlen:
        q_scratch_strs[q_scratch_n] = ver[j]
        q_scratch_n = q_scratch_n + 1
        j = j + 1
    q_scratch_strs[q_scratch_n] = 0
    q_scratch_n = q_scratch_n + 1
    return _queue_push(&q_scratch_strs[name_off], nlen,
                       op, &q_scratch_strs[ver_off], vlen, parent)


# -- file-conflict check (third conflict flavour) ---------------------
#
# Walks the staged tarball's files/ entries and checks each against
# every installed package's `files` list — if any path overlaps with
# a different package's files (different name), FAIL the install.

def _check_file_conflicts(tar_len: uint64,
                          installing_name: Ptr[uint8]) -> int32:
    in_name_len: uint64 = strlen_u8(installing_name)
    off: uint64 = 0
    files_pfx: Ptr[uint8] = "files/"
    files_pfx_len: uint64 = 6

    while off + 512 <= tar_len:
        hdr: Ptr[uint8] = &tar_buf[off]
        if _tar_header_is_zero(hdr) != 0:
            return 0
        if _tar_chksum_ok(hdr) == 0:
            return -1
        size: uint64 = _tar_parse_octal(&hdr[124], 12)
        typeflag: uint8 = hdr[156]
        body_blocks: uint64 = (size + 511) / 512

        nlen: uint64 = _name_copy_nul(&warn_buf[0], &hdr[0], 100)
        if nlen <= pkg_prefix_len:
            off = off + 512 + body_blocks * 512
            continue
        prefix_ok: int32 = 1
        i: uint64 = 0
        while i < pkg_prefix_len:
            if warn_buf[i] != pkg_prefix_buf[i]:
                prefix_ok = 0
                break
            i = i + 1
        if prefix_ok == 0:
            off = off + 512 + body_blocks * 512
            continue
        tail_start: uint64 = pkg_prefix_len
        tail_len: uint64 = nlen - tail_start
        if tail_len < files_pfx_len:
            off = off + 512 + body_blocks * 512
            continue
        ok: int32 = 1
        j: uint64 = 0
        while j < files_pfx_len:
            if warn_buf[tail_start + j] != files_pfx[j]:
                ok = 0
                break
            j = j + 1
        if ok == 0:
            off = off + 512 + body_blocks * 512
            continue
        rel_start: uint64 = tail_start + files_pfx_len
        rel_len: uint64 = tail_len - files_pfx_len
        if rel_len == 0:
            off = off + 512 + body_blocks * 512
            continue
        # Regular file? (Directories don't conflict.)
        if typeflag != 0 and typeflag != 48:
            off = off + 512 + body_blocks * 512
            continue
        # Check against every installed package's files.
        ip: uint64 = 0
        while ip < inst_count:
            # Skip same-name (we already block reinstall earlier).
            if inst_name_len[ip] == in_name_len:
                samep: int32 = 1
                k: uint64 = 0
                while k < in_name_len:
                    if inst_buf[inst_name_off[ip] + k] != installing_name[k]:
                        samep = 0
                        break
                    k = k + 1
                if samep != 0:
                    ip = ip + 1
                    continue
            # Walk this installed pkg's files.
            fc: uint64 = inst_file_count[ip]
            fs: uint64 = inst_file_start[ip]
            fi: uint64 = 0
            while fi < fc:
                slot: uint64 = fs + fi
                if inst_file_len[slot] == rel_len:
                    eq: int32 = 1
                    kk: uint64 = 0
                    while kk < rel_len:
                        if inst_buf[inst_file_off[slot] + kk] != \
                                warn_buf[rel_start + kk]:
                            eq = 0
                            break
                        kk = kk + 1
                    if eq != 0:
                        write_str(2, "hpm: file conflict: ")
                        sys_write(2, &warn_buf[rel_start], rel_len)
                        write_str(2, " is owned by ")
                        sys_write(2, &inst_buf[inst_name_off[ip]],
                                  inst_name_len[ip])
                        write_str(2, "\n")
                        return -1
                fi = fi + 1
            ip = ip + 1

        off = off + 512 + body_blocks * 512
    return 0


# Install one resolved package by repo index. Reuses the Phase 3
# install flow but takes the repo idx directly (rather than parsing
# a name@ver spec). Returns 0 on success.

def _install_one_by_repo_idx(pi: uint64, pinned: int32) -> int32:
    name_buf: Array[128, uint8]
    _strcopy_n(&name_buf[0], &idx_buf[pkg_name_off[pi]],
               pkg_name_len[pi], 128)
    name_len: uint64 = strlen_u8(&name_buf[0])

    v_cstr: Array[64, uint8]
    _strcopy_n(&v_cstr[0], &idx_buf[pkg_version_off[pi]],
               pkg_version_len[pi], 64)
    url_cstr: Array[512, uint8]
    _strcopy_n(&url_cstr[0], &idx_buf[pkg_url_off[pi]],
               pkg_url_len[pi], 512)
    sha_cstr: Array[80, uint8]
    _strcopy_n(&sha_cstr[0], &idx_buf[pkg_sha256_off[pi]],
               pkg_sha256_len[pi], 80)
    target_cstr: Array[128, uint8]
    if pkg_target_len[pi] > 0:
        _strcopy_n(&target_cstr[0], &idx_buf[pkg_target_off[pi]],
                   pkg_target_len[pi], 128)
    else:
        _strcopy_cstr(&target_cstr[0],
                      cast[Ptr[uint8]]("#hamnix-system"), 128)

    write_str(1, "hpm:   installing ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    write_str(1, "\n")

    # Channel-aware fetch.
    if _pkg_set_channel_url(pi) != 0:
        return 1

    n: int64 = fetch_to_buf(&url_cstr[0], &deb_buf[0], TARBALL_CAP)
    if n < 0:
        return 1
    deb_len: uint64 = cast[uint64](n)

    _sha256_hash_buf(&deb_buf[0], deb_len)
    expected_len: uint64 = strlen_u8(&sha_cstr[0])
    if expected_len != 64:
        write_str(2, "hpm: index sha256 is not 64 hex chars\n")
        return 1
    mi: uint64 = 0
    while mi < 64:
        ec: uint8 = sha_cstr[mi]
        if ec >= 65 and ec <= 70:
            ec = ec + 32
        if sha_hex[mi] != ec:
            write_str(2, "hpm: SHA-256 mismatch — refusing to install\n")
            return 1
        mi = mi + 1
    write_str(1, "hpm: SHA-256 verified\n")

    tar_len_i: int64 = _inflate_tarball(deb_len)
    if tar_len_i < 0:
        return 1
    tar_len: uint64 = cast[uint64](tar_len_i)

    pp: uint64 = 0
    ni: uint64 = 0
    while ni < name_len and pp + 1 < 128:
        pkg_prefix_buf[pp] = name_buf[ni]
        pp = pp + 1
        ni = ni + 1
    pkg_prefix_buf[pp] = 45
    pp = pp + 1
    vi: uint64 = 0
    vl: uint64 = strlen_u8(&v_cstr[0])
    while vi < vl and pp + 1 < 128:
        pkg_prefix_buf[pp] = v_cstr[vi]
        pp = pp + 1
        vi = vi + 1
    pkg_prefix_buf[pp] = 47
    pp = pp + 1
    pkg_prefix_buf[pp] = 0
    pkg_prefix_len = pp

    if _read_pkginfo_from_tar(tar_len) != 0:
        return 1
    pi_t_len: uint64 = strlen_u8(&pi_target[0])
    if pi_t_len > 0:
        _strcopy_cstr(&target_cstr[0], &pi_target[0], 128)
    target_len_eff: uint64 = strlen_u8(&target_cstr[0])

    # #esp target: hpm does NOT stage files (the ESP is FAT-on-block,
    # not a Hamnix file server). The caller (installer) extracts the
    # tarball separately and copies its `files/` tree onto the ESP via
    # an mkfs_fat-formatted partition. hpm still records the install
    # in installed.json so `hpm list` shows the bootloader package.
    is_esp: int32 = _is_esp_target(&target_cstr[0], target_len_eff)
    if is_esp != 0:
        write_str(1, "hpm: target=#esp — extraction skipped; installer handles ESP placement\n")
        _new_files_reset()
        if _installed_rewrite_with_added(&name_buf[0], &v_cstr[0],
                                         &target_cstr[0], pinned) != 0:
            return 1
        if _load_installed() < 0:
            return 1
        write_str(1, "hpm: installed ")
        sys_write(1, &name_buf[0], name_len)
        write_str(1, "@")
        write_str(1, &v_cstr[0])
        write_str(1, "\n")
        return 0

    if _set_target_prefix(&target_cstr[0], target_len_eff) != 0:
        return 1
    if target_prefix_buf[0] != 0:
        _mkdir_p(&target_prefix_buf[0])
        sys_mkdir(cast[Ptr[char]](&target_prefix_buf[0]))

    # File conflict check (third conflict flavour) BEFORE staging.
    if _check_file_conflicts(tar_len, &name_buf[0]) != 0:
        return 1

    if _stage_tarball(tar_len) != 0:
        write_str(2, "hpm: tarball staging failed\n")
        return 1
    if _run_hook(&staging_root_buf[0],
                 cast[Ptr[uint8]]("pre-install.hamsh"),
                 &name_buf[0], &v_cstr[0], &target_cstr[0]) != 0:
        return 1

    _new_files_reset()
    if _stage_extract_files(tar_len, &target_prefix_buf[0]) != 0:
        return 1
    write_str(1, "hpm: extracted ")
    write_dec_u64(1, new_files_n)
    write_str(1, " files\n")

    if _run_hook(&staging_root_buf[0],
                 cast[Ptr[uint8]]("install.hamsh"),
                 &name_buf[0], &v_cstr[0], &target_cstr[0]) != 0:
        return 1

    if _installed_rewrite_with_added(&name_buf[0], &v_cstr[0],
                                     &target_cstr[0], pinned) != 0:
        return 1
    # Reload installed.json so subsequent in-loop conflict checks see
    # the just-added package's file list.
    if _load_installed() < 0:
        return 1

    write_str(1, "hpm: installed ")
    sys_write(1, &name_buf[0], name_len)
    write_str(1, "@")
    write_str(1, &v_cstr[0])
    write_str(1, "\n")
    return 0


# Solver-driven install: resolve the whole closure, then install in
# topological order.
def cmd_install_solved(spec: Ptr[uint8]) -> int32:
    if _load_index_cache() != 0:
        write_str(2, "hpm: no cached index; run `hpm refresh` first\n")
        return 1
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1

    if _solve(spec) != 0:
        return 1

    write_str(1, "hpm: resolved ")
    write_dec_u64(1, res_count)
    write_str(1, " package(s):\n")
    ti: uint64 = 0
    while ti < topo_n:
        ri: uint64 = topo_order[ti]
        pi: uint64 = res_pkg_idx[ri]
        write_str(1, "  ")
        sys_write(1, &idx_buf[pkg_name_off[pi]], pkg_name_len[pi])
        write_str(1, "@")
        sys_write(1, &idx_buf[pkg_version_off[pi]], pkg_version_len[pi])
        write_str(1, "\n")
        ti = ti + 1

    # Determine if the root was @-pinned.
    pinned_root: int32 = 0
    si: uint64 = 0
    while spec[si] != 0:
        if spec[si] == 64:
            pinned_root = 1
            break
        si = si + 1

    # Install in topological order. Root is the LAST entry. Pinning
    # only applies to the root (per spec — `@<ver>` on root pins root).
    ii: uint64 = 0
    while ii < topo_n:
        ri: uint64 = topo_order[ii]
        pi: uint64 = res_pkg_idx[ri]
        is_root: int32 = 0
        if ii + 1 == topo_n:
            is_root = 1
        pin_v: int32 = 0
        if is_root != 0 and pinned_root != 0:
            pin_v = 1
        if _install_one_by_repo_idx(pi, pin_v) != 0:
            write_str(2, "hpm: install of ")
            sys_write(2, &idx_buf[pkg_name_off[pi]], pkg_name_len[pi])
            write_str(2, " failed; closure aborted (previously installed packages remain)\n")
            return 1
        ii = ii + 1
    return 0


# =====================================================================
# Phase 5: update + pin/unpin
# =====================================================================
#
# `hpm update`:
#   - Refresh the index (re-run cmd_refresh).
#   - For every installed, non-pinned package: if the repo has a newer
#     version, run the install path to upgrade.
#
# `hpm pin <name>[@<ver>]`:
#   - If a version is given, install that exact version (pinned).
#   - Otherwise, mark the EXISTING install as pinned.
#
# `hpm unpin <name>`:
#   - Mark the existing install as un-pinned.

def cmd_update() -> int32:
    # 1. Refresh the index.
    if cmd_refresh() != 0:
        return 1
    # cmd_refresh leaves the parsed cache loaded in pkg_*[]. Reload
    # installed too.
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1
    if lrc == 1 or inst_count == 0:
        write_str(1, "hpm: no packages installed; nothing to update\n")
        return 0

    upgraded: uint64 = 0
    skipped:  uint64 = 0
    i: uint64 = 0
    # Snapshot install count — _install_one_by_repo_idx may grow
    # inst_count after the reload, but each iteration here refers to
    # the ORIGINAL list.
    snapshot: uint64 = inst_count

    # We need to drive iteration off the SNAPSHOT names+versions
    # captured up-front, because inst_count + the spans get rewritten
    # by every install.
    upd_name_buf: Array[8192, uint8]      # 64 pkgs * 128 chars max
    upd_name_off: Array[256, uint64]
    upd_name_len: Array[256, uint64]
    upd_ver_off:  Array[256, uint64]
    upd_ver_len:  Array[256, uint64]
    upd_pinned:   Array[256, int32]
    upd_n:        uint64 = 0
    upd_buf_n:    uint64 = 0

    while i < snapshot:
        if upd_n >= 256 or upd_buf_n + inst_name_len[i] + inst_ver_len[i] + 4 > 8192:
            break
        upd_name_off[upd_n] = upd_buf_n
        upd_name_len[upd_n] = inst_name_len[i]
        k: uint64 = 0
        while k < inst_name_len[i]:
            upd_name_buf[upd_buf_n + k] = inst_buf[inst_name_off[i] + k]
            k = k + 1
        upd_buf_n = upd_buf_n + inst_name_len[i]
        upd_name_buf[upd_buf_n] = 0
        upd_buf_n = upd_buf_n + 1
        upd_ver_off[upd_n] = upd_buf_n
        upd_ver_len[upd_n] = inst_ver_len[i]
        k = 0
        while k < inst_ver_len[i]:
            upd_name_buf[upd_buf_n + k] = inst_buf[inst_ver_off[i] + k]
            k = k + 1
        upd_buf_n = upd_buf_n + inst_ver_len[i]
        upd_name_buf[upd_buf_n] = 0
        upd_buf_n = upd_buf_n + 1
        upd_pinned[upd_n] = inst_pinned[i]
        upd_n = upd_n + 1
        i = i + 1

    j: uint64 = 0
    while j < upd_n:
        if upd_pinned[j] != 0:
            write_str(1, "hpm: skip ")
            sys_write(1, &upd_name_buf[upd_name_off[j]], upd_name_len[j])
            write_str(1, " (pinned at ")
            sys_write(1, &upd_name_buf[upd_ver_off[j]], upd_ver_len[j])
            write_str(1, ")\n")
            skipped = skipped + 1
            j = j + 1
            continue

        # Find best repo entry for this name.
        cand_i: int64 = _pkg_find_best(&upd_name_buf[upd_name_off[j]],
                                       upd_name_len[j])
        if cand_i < 0:
            write_str(1, "hpm: ")
            sys_write(1, &upd_name_buf[upd_name_off[j]], upd_name_len[j])
            write_str(1, " is installed but not in the repo (skipped)\n")
            j = j + 1
            continue
        ci: uint64 = cast[uint64](cand_i)

        # Compare repo version vs installed version.
        cmp: int32 = _version_compare(
            cast[Ptr[uint8]](
                cast[uint64](&idx_buf[0]) + pkg_version_off[ci]),
            pkg_version_len[ci],
            &upd_name_buf[upd_ver_off[j]],
            upd_ver_len[j])
        if cmp <= 0:
            j = j + 1
            continue
        # Upgrade: remove the old, then install the new. The remove
        # uses installed.json's recorded files; the new install runs
        # the standard solver.
        write_str(1, "hpm: upgrading ")
        sys_write(1, &upd_name_buf[upd_name_off[j]], upd_name_len[j])
        write_str(1, " ")
        sys_write(1, &upd_name_buf[upd_ver_off[j]], upd_ver_len[j])
        write_str(1, " -> ")
        sys_write(1, &idx_buf[pkg_version_off[ci]], pkg_version_len[ci])
        write_str(1, "\n")
        if cmd_remove(&upd_name_buf[upd_name_off[j]]) != 0:
            write_str(2, "hpm: remove failed during update; stopping\n")
            return 1
        # The remove + install both touch inst_* tables; we already
        # snapshotted up-front so we don't iterate over a moving list.
        # Run the standard solver-driven install on the bare name.
        # The result is non-pinned (per spec — upgraded installs are
        # not pinned unless the user asked).
        # Reuse the standalone cstring from upd_name_buf.
        if cmd_install_solved(&upd_name_buf[upd_name_off[j]]) != 0:
            write_str(2, "hpm: install failed during update; stopping\n")
            return 1
        upgraded = upgraded + 1
        j = j + 1

    write_str(1, "hpm: update done (upgraded=")
    write_dec_u64(1, upgraded)
    write_str(1, " pinned=")
    write_dec_u64(1, skipped)
    write_str(1, ")\n")
    return 0


def cmd_pin(spec: Ptr[uint8]) -> int32:
    # Two cases: "<name>" pins the existing install (must be present);
    # "<name>@<ver>" installs (or re-installs) that version pinned.
    si: uint64 = 0
    has_at: int32 = 0
    while spec[si] != 0:
        if spec[si] == 64:
            has_at = 1
            break
        si = si + 1
    if has_at != 0:
        # Treat as install-with-pin.
        return cmd_install_solved(spec)

    # Mark existing as pinned.
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1
    if lrc == 1 or inst_count == 0:
        write_str(2, "hpm: nothing installed\n")
        return 1
    name_len: uint64 = strlen_u8(spec)
    found: int32 = 0
    i: uint64 = 0
    while i < inst_count:
        if inst_name_len[i] == name_len:
            eq: int32 = 1
            k: uint64 = 0
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != spec[k]:
                    eq = 0
                    break
                k = k + 1
            if eq != 0:
                found = 1
                break
        i = i + 1
    if found == 0:
        write_str(2, "hpm: ")
        write_str(2, spec)
        write_str(2, " is not installed\n")
        return 1
    if _installed_rewrite_with_pin(spec, 1) != 0:
        return 1
    write_str(1, "hpm: pinned ")
    write_str(1, spec)
    write_str(1, "\n")
    return 0


def cmd_unpin(name: Ptr[uint8]) -> int32:
    lrc: int32 = _load_installed()
    if lrc < 0:
        return 1
    if lrc == 1 or inst_count == 0:
        write_str(2, "hpm: nothing installed\n")
        return 1
    name_len: uint64 = strlen_u8(name)
    found: int32 = 0
    i: uint64 = 0
    while i < inst_count:
        if inst_name_len[i] == name_len:
            eq: int32 = 1
            k: uint64 = 0
            while k < name_len:
                if inst_buf[inst_name_off[i] + k] != name[k]:
                    eq = 0
                    break
                k = k + 1
            if eq != 0:
                found = 1
                break
        i = i + 1
    if found == 0:
        write_str(2, "hpm: ")
        write_str(2, name)
        write_str(2, " is not installed\n")
        return 1
    if _installed_rewrite_with_pin(name, 0) != 0:
        return 1
    write_str(1, "hpm: unpinned ")
    write_str(1, name)
    write_str(1, "\n")
    return 0


# -- channel subcommands ----------------------------------------------

def cmd_channels() -> int32:
    if _channels_load() != 0:
        write_str(2, "hpm: failed to read channels\n")
        return 1
    # Diagnostic: print the channel count so silent zero-channel
    # states (rare; usually a parse failure) are observable.
    write_str(2, "hpm: [channels] n=")
    write_dec_u64(2, n_channels)
    write_str(2, "\n")
    if n_channels == 0:
        write_str(1, "hpm: no channels subscribed. Use `hpm enable <name>`.\n")
        return 0
    ci: uint64 = 0
    while ci < n_channels:
        # Print "  - <name>" so a zero-length name still produces a
        # visible "- \n" line (vs an empty line that looks like the
        # loop didn't iterate).
        sys_write(1, "  - ", 4)
        sys_write(1, &channel_names_buf[channel_names_off[ci]],
                  channel_names_len[ci])
        sys_write(1, "\n", 1)
        ci = ci + 1
    write_str(1, "(edit /var/lib/hpm/channels or /etc/hpm/channels; one channel per line)\n")
    return 0


def cmd_enable(name: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(name)
    if nlen == 0:
        write_str(2, "hpm: enable requires a channel name\n")
        return 1
    # Validate the same charset _channels_load enforces.
    vi: uint64 = 0
    while vi < nlen:
        c: uint8 = name[vi]
        ok: int32 = 0
        if c >= 65 and c <= 90:
            ok = 1
        elif c >= 97 and c <= 122:
            ok = 1
        elif c >= 48 and c <= 57:
            ok = 1
        elif c == 45 or c == 46 or c == 95:
            ok = 1
        if ok == 0:
            write_str(2, "hpm: enable: invalid channel name (allow [A-Za-z0-9_.-])\n")
            return 1
        vi = vi + 1
    if _channels_load() != 0:
        return 1
    rc: int32 = _channel_add_name(name, nlen)
    if rc == -1:
        write_str(1, "hpm: ")
        write_str(1, name)
        write_str(1, " already enabled\n")
        return 0
    if rc == -2:
        write_str(2, "hpm: too many channels (cap=")
        write_dec_u64(2, CHANNEL_MAX)
        write_str(2, ")\n")
        return 1
    if _channels_save() != 0:
        return 1
    write_str(1, "hpm: enabled channel ")
    write_str(1, name)
    write_str(1, " (run `hpm refresh` to fetch its index)\n")
    return 0


def cmd_disable(name: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(name)
    if nlen == 0:
        write_str(2, "hpm: disable requires a channel name\n")
        return 1
    if _channels_load() != 0:
        return 1
    ci: int64 = _channel_find(name, nlen)
    if ci < 0:
        write_str(1, "hpm: ")
        write_str(1, name)
        write_str(1, " was not enabled (no change)\n")
        return 0
    # Remove channel at index ci by sliding the tail forward. Names
    # in channel_names_buf stay where they are; only the index table
    # contracts. (Buffer slop is fine — _channels_save iterates only
    # n_channels.)
    cu: uint64 = cast[uint64](ci)
    while cu + 1 < n_channels:
        channel_names_off[cu] = channel_names_off[cu + 1]
        channel_names_len[cu] = channel_names_len[cu + 1]
        cu = cu + 1
    n_channels = n_channels - 1
    if _channels_save() != 0:
        return 1
    write_str(1, "hpm: disabled channel ")
    write_str(1, name)
    write_str(1, "\n")
    return 0


# -- usage + main -----------------------------------------------------

def _usage() -> int32:
    s: Ptr[uint8] = "Usage: hpm [--repo=<url>] [--target-prefix=<path>] <command> [args]\n\
Commands:\n\
  refresh                 fetch repo index (every enabled channel)\n\
  list                    show installed packages\n\
  search <pattern>        substring match against repo names\n\
  show <name>[@<ver>]     print package metadata\n\
  install <name>[@<ver>]  resolve deps, fetch, verify, extract\n\
  remove <name>           uninstall + run remove hooks\n\
  update                  refresh + upgrade non-pinned installs\n\
  pin <name>[@<ver>]      pin existing install or install pinned\n\
  unpin <name>            remove pin\n\
  channels                list enabled channels (/etc/hpm/channels)\n\
  enable <name>           subscribe to channel <name>\n\
  disable <name>          unsubscribe from channel <name>\n\
\n\
Flags:\n\
  --repo=<url>            file:// or https:// repo (default https://255.one/)\n\
  --target-prefix=<path>  install under <path> instead of `/` — used by\n\
                          the installer to populate /mnt/newroot\n"
    write_str(2, s)
    return 2


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    _set_repo_default()
    target_prefix_override[0] = 0

    # Optional leading flag(s): --repo=<url> and --target-prefix=<path>.
    # Stops at the first non-flag.
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        # Match "--repo=" prefix (7 chars).
        pfx_r: Ptr[uint8] = "--repo="
        is_repo: int32 = 1
        ir: uint64 = 0
        while ir < 7:
            if a[ir] != pfx_r[ir]:
                is_repo = 0
                break
            ir = ir + 1
        if is_repo != 0:
            rest: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](a) + 7)
            _set_repo(rest)
            ai = ai + 1
            continue
        # Match "--target-prefix=" (16 chars).
        pfx_t: Ptr[uint8] = "--target-prefix="
        is_tp: int32 = 1
        it: uint64 = 0
        while it < 16:
            if a[it] != pfx_t[it]:
                is_tp = 0
                break
            it = it + 1
        if is_tp != 0:
            rest2: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](a) + 16)
            _set_target_prefix_override(rest2)
            write_str(1, "hpm: target-prefix=")
            write_str(1, &target_prefix_override[0])
            write_str(1, "\n")
            ai = ai + 1
            continue
        break

    if ai >= argc:
        return _usage()

    if _apply_repo() != 0:
        return 1
    # Snapshot the base for later per-channel URL composition. Every
    # path that fetches a tarball reads from repo_base_buf and appends
    # the package's channel to derive the real URL.
    _save_repo_base()

    cmd: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
    ai = ai + 1

    if _streq(cmd, cast[Ptr[uint8]]("refresh")) != 0:
        return cmd_refresh()
    if _streq(cmd, cast[Ptr[uint8]]("channels")) != 0:
        return cmd_channels()
    if _streq(cmd, cast[Ptr[uint8]]("enable")) != 0:
        if sys_getuid() != 1:
            write_str(2, "hpm: enabling channels requires hostowner. Try `newshell hostowner`.\n")
            return 1
        if ai >= argc:
            write_str(2, "hpm: enable requires a channel name\n")
            return 1
        return cmd_enable(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("disable")) != 0:
        if sys_getuid() != 1:
            write_str(2, "hpm: disabling channels requires hostowner. Try `newshell hostowner`.\n")
            return 1
        if ai >= argc:
            write_str(2, "hpm: disable requires a channel name\n")
            return 1
        return cmd_disable(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("list")) != 0:
        return cmd_list()
    if _streq(cmd, cast[Ptr[uint8]]("search")) != 0:
        if ai >= argc:
            write_str(2, "hpm: search requires a pattern\n")
            return 1
        return cmd_search(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("show")) != 0:
        if ai >= argc:
            write_str(2, "hpm: show requires a package name\n")
            return 1
        return cmd_show(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    # docs/security.md Phase 10: hostowner gate. Every write-mode hpm
    # command (install / remove / update / pin / unpin) is privileged.
    # Read-only commands (list, search, show, refresh) — already
    # dispatched above this point — remain open to regular users.
    if _streq(cmd, cast[Ptr[uint8]]("install")) != 0:
        if sys_getuid() != 1:
            write_str(2, "hpm: package installation requires hostowner. Try `newshell hostowner`.\n")
            return 1
        if ai >= argc:
            write_str(2, "hpm: install requires a package name\n")
            return 1
        return cmd_install_solved(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("remove")) != 0:
        if sys_getuid() != 1:
            write_str(2, "hpm: package removal requires hostowner. Try `newshell hostowner`.\n")
            return 1
        if ai >= argc:
            write_str(2, "hpm: remove requires a package name\n")
            return 1
        return cmd_remove(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("update")) != 0:
        if sys_getuid() != 1:
            write_str(2, "hpm: package update requires hostowner. Try `newshell hostowner`.\n")
            return 1
        return cmd_update()
    if _streq(cmd, cast[Ptr[uint8]]("pin")) != 0:
        if sys_getuid() != 1:
            write_str(2, "hpm: package pinning requires hostowner. Try `newshell hostowner`.\n")
            return 1
        if ai >= argc:
            write_str(2, "hpm: pin requires a package name\n")
            return 1
        return cmd_pin(cast[Ptr[uint8]](argv[cast[uint64](ai)]))
    if _streq(cmd, cast[Ptr[uint8]]("unpin")) != 0:
        if sys_getuid() != 1:
            write_str(2, "hpm: package unpinning requires hostowner. Try `newshell hostowner`.\n")
            return 1
        if ai >= argc:
            write_str(2, "hpm: unpin requires a package name\n")
            return 1
        return cmd_unpin(cast[Ptr[uint8]](argv[cast[uint64](ai)]))

    write_str(2, "hpm: unknown command: ")
    write_str(2, cmd)
    sys_write(2, "\n", 1)
    return _usage()

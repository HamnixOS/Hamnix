# user/hampanel.ad
#
# hampanel — DE panel (MATE-style taskbar) extracted from hamUId's
# daemon_pixel cascade and reborn as a standalone hamui-client app on
# the #442 (c) v2 blit protocol.
#
# WHAT IT IS
# ----------
# The panel chrome used to live inline in `daemon_pixel` (user/hamUId.ad)
# — taskbar background, window-list buttons, a live clock, the
# Applications launcher trigger, and the various applets. That added
# hundreds of branchy lines into the per-pixel cascade for every present.
# Per docs/graphical_stack_audit.md (Stage B.4 of the rio-faithful
# pivot), the panel becomes an ordinary hamui client whose pixels reach
# the compositor through the v2 'B'/'D' verbs.
#
# DESIGN
# ------
#   * On startup we bind our wid (passed as argv[1] by the compositor)
#     and negotiate the v2 protocol via hamui_set_protocol_v2(), which
#     writes `version 2\n` to /dev/wsys/<wid>/wctl.
#   * Every paint composes into the toolkit's process-local backbuffer
#     (hamui_v2_clear / hamui_v2_fill_rect / hamui_v2_set_pixel) and
#     commits a dirty rect via hamui_v2_commit_rect — one 'B' blit + one
#     'D' dirty-rect, the exact wire shape the kernel parser expects.
#   * The window-list comes from /dev/wsys/session (read-only snapshot,
#     landed c81b608c): one line per active wid. We re-blit the taskbar
#     when the snapshot changes.
#   * The clock comes from /proc/realtime ("HH:MM" parsed at offsets
#     11-12 and 14-15, matching user/hamde.ad). A 1Hz tick re-blits ONLY
#     the clock's bbox, so an idle desktop costs O(clock-rect) per tick.
#   * An "Applications" button on the left spawns a small built-in app
#     menu cycle: each click cycles to the next built-in app and spawns
#     it. This keeps Applications-menu launching working without the
#     compositor's monolithic menu drop-down — a follow-up agent can
#     extract the full menu as another hamui client.
#
# COMPOSITOR HAND-OFF
# -------------------
# The compositor spawns /bin/hampanel at startup (see daemon_spawn_*
# in user/hamUId.ad). The kernel devwsys per-window protocol version
# byte (wsys_win_version, devwsys.ad) flips to 2 after our wctl write,
# and the compositor's v2_present_dirty_windows() blits our backbuffer
# straight to /dev/fb after each present. The panel is NOT painted by
# daemon_pixel anymore; geometry reservation (PANEL_H at the top/bottom
# of the screen) stays so windows still avoid the panel strip.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2,
    hamui_v2_is_active, hamui_v2_clear, hamui_v2_fill_rect,
    hamui_v2_set_pixel, hamui_v2_commit_rect
)
from lib.p9 import spawn

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield()


# --- panel geometry (in v2 backbuffer coords, 320x200 cap) ----------
# The panel window is a thin strip; we use a 320x24 region at the top
# of the v2 backbuffer. The compositor positions the panel-shape
# window at the screen edge separately.
PANEL_W: int32 = 320
PANEL_H: int32 = 24

# Background, ink, accent — matches the legacy daemon_pixel PANEL_*
# colours so the visual identity carries over.
BG_R: uint8 = 46
BG_G: uint8 = 52
BG_B: uint8 = 64
EDGE_R: uint8 = 24
EDGE_G: uint8 = 28
EDGE_B: uint8 = 36
INK_R: uint8 = 235
INK_G: uint8 = 235
INK_B: uint8 = 240
HI_R: uint8 = 70
HI_G: uint8 = 90
HI_B: uint8 = 140

# Layout (in panel-local coords).
APPS_BTN_X: int32 = 0
APPS_BTN_W: int32 = 56
WINLIST_X:  int32 = 60
WINLIST_W:  int32 = 180     # room for ~6 small buttons
CLOCK_X:    int32 = 250
CLOCK_W:    int32 = 70

WIN_BTN_W:  int32 = 28
WIN_BTN_PAD: int32 = 2


# --- module-scope buffers (no malloc; fixed arrays only) ------------
# /proc/realtime scratch + composed clock string.
rt_buf:    Array[128, uint8]
clock_str: Array[8, uint8]
last_clock_min: int32 = -1
last_uptime_s:  uint64 = 0xffffffffffffffff

# /dev/wsys/session scratch + parsed wid list.
sess_buf: Array[2048, uint8]
win_wids: Array[16, int32]
win_count: int32 = 0
last_sess_hash: uint64 = 0

# argv staging for a launched app.
launch_argv: Array[4, uint64]

# Tiny built-in launcher cycle (the Applications button cycles through
# these and spawns the next one on each click).
launch_idx: int32 = 0


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _two_digits(out: Ptr[uint8], off: uint64, v: uint64):
    out[off]     = cast[uint8](v / 10) + 48
    out[off + 1] = cast[uint8](v % 10) + 48


def _rt_two(off: uint64) -> uint64:
    hi: uint8 = rt_buf[off]
    lo: uint8 = rt_buf[off + 1]
    return cast[uint64](hi - 48) * 10 + cast[uint64](lo - 48)


# ---------------- tiny 5x7 font (digits + ':' + 'A') -----------------
# Just enough to render "HH:MM" and an "A" badge on the Applications
# button. Each glyph is 5 wide, 7 tall, encoded as 7 rows of 5 bits.
GLYPH_W: int32 = 5
GLYPH_H: int32 = 7

# Glyph table: 15 glyphs * 7 rows. Flat to dodge the "global Array
# initializers must be scalar" rule (initialised in font_init at startup).
GLYPH_COUNT: int32 = 15
glyph_rows: Array[105, uint8]
font_inited: int32 = 0


def font_init():
    if font_inited != 0:
        return
    # '0' (index 0)
    glyph_rows[0] = 0x0E
    glyph_rows[1] = 0x11
    glyph_rows[2] = 0x13
    glyph_rows[3] = 0x15
    glyph_rows[4] = 0x19
    glyph_rows[5] = 0x11
    glyph_rows[6] = 0x0E
    # '1' (1)
    glyph_rows[7] = 0x04
    glyph_rows[8] = 0x0C
    glyph_rows[9] = 0x04
    glyph_rows[10] = 0x04
    glyph_rows[11] = 0x04
    glyph_rows[12] = 0x04
    glyph_rows[13] = 0x0E
    # '2' (2)
    glyph_rows[14] = 0x0E
    glyph_rows[15] = 0x11
    glyph_rows[16] = 0x01
    glyph_rows[17] = 0x02
    glyph_rows[18] = 0x04
    glyph_rows[19] = 0x08
    glyph_rows[20] = 0x1F
    # '3' (3)
    glyph_rows[21] = 0x0E
    glyph_rows[22] = 0x11
    glyph_rows[23] = 0x01
    glyph_rows[24] = 0x06
    glyph_rows[25] = 0x01
    glyph_rows[26] = 0x11
    glyph_rows[27] = 0x0E
    # '4' (4)
    glyph_rows[28] = 0x02
    glyph_rows[29] = 0x06
    glyph_rows[30] = 0x0A
    glyph_rows[31] = 0x12
    glyph_rows[32] = 0x1F
    glyph_rows[33] = 0x02
    glyph_rows[34] = 0x02
    # '5' (5)
    glyph_rows[35] = 0x1F
    glyph_rows[36] = 0x10
    glyph_rows[37] = 0x1E
    glyph_rows[38] = 0x01
    glyph_rows[39] = 0x01
    glyph_rows[40] = 0x11
    glyph_rows[41] = 0x0E
    # '6' (6)
    glyph_rows[42] = 0x0E
    glyph_rows[43] = 0x10
    glyph_rows[44] = 0x10
    glyph_rows[45] = 0x1E
    glyph_rows[46] = 0x11
    glyph_rows[47] = 0x11
    glyph_rows[48] = 0x0E
    # '7' (7)
    glyph_rows[49] = 0x1F
    glyph_rows[50] = 0x01
    glyph_rows[51] = 0x02
    glyph_rows[52] = 0x04
    glyph_rows[53] = 0x04
    glyph_rows[54] = 0x04
    glyph_rows[55] = 0x04
    # '8' (8)
    glyph_rows[56] = 0x0E
    glyph_rows[57] = 0x11
    glyph_rows[58] = 0x11
    glyph_rows[59] = 0x0E
    glyph_rows[60] = 0x11
    glyph_rows[61] = 0x11
    glyph_rows[62] = 0x0E
    # '9' (9)
    glyph_rows[63] = 0x0E
    glyph_rows[64] = 0x11
    glyph_rows[65] = 0x11
    glyph_rows[66] = 0x0F
    glyph_rows[67] = 0x01
    glyph_rows[68] = 0x01
    glyph_rows[69] = 0x0E
    # ':' (10)
    glyph_rows[70] = 0x00
    glyph_rows[71] = 0x00
    glyph_rows[72] = 0x04
    glyph_rows[73] = 0x00
    glyph_rows[74] = 0x04
    glyph_rows[75] = 0x00
    glyph_rows[76] = 0x00
    # 'A' (11)
    glyph_rows[77] = 0x0E
    glyph_rows[78] = 0x11
    glyph_rows[79] = 0x11
    glyph_rows[80] = 0x1F
    glyph_rows[81] = 0x11
    glyph_rows[82] = 0x11
    glyph_rows[83] = 0x11
    # 'u' (12)
    glyph_rows[84] = 0x00
    glyph_rows[85] = 0x00
    glyph_rows[86] = 0x11
    glyph_rows[87] = 0x11
    glyph_rows[88] = 0x11
    glyph_rows[89] = 0x11
    glyph_rows[90] = 0x0F
    # 'p' (13)
    glyph_rows[91] = 0x00
    glyph_rows[92] = 0x00
    glyph_rows[93] = 0x1E
    glyph_rows[94] = 0x11
    glyph_rows[95] = 0x1E
    glyph_rows[96] = 0x10
    glyph_rows[97] = 0x10
    # ' ' / fallback (14)
    glyph_rows[98] = 0x00
    glyph_rows[99] = 0x00
    glyph_rows[100] = 0x00
    glyph_rows[101] = 0x00
    glyph_rows[102] = 0x00
    glyph_rows[103] = 0x00
    glyph_rows[104] = 0x00
    font_inited = 1


def _glyph_for(c: uint8) -> Ptr[uint8]:
    idx: int32 = 14                  # default = space/fallback
    if c >= 48 and c <= 57:
        idx = cast[int32](c - 48)    # '0'..'9' → 0..9
    elif c == 58:
        idx = 10                     # ':'
    elif c == 65:
        idx = 11                     # 'A'
    elif c == 117:
        idx = 12                     # 'u'
    elif c == 112:
        idx = 13                     # 'p'
    return &glyph_rows[idx * GLYPH_H]


def _draw_glyph(x: int32, y: int32, c: uint8,
                r: uint8, g: uint8, b: uint8):
    rows: Ptr[uint8] = _glyph_for(c)
    row: int32 = 0
    while row < GLYPH_H:
        bits: uint8 = rows[row]
        col: int32 = 0
        while col < GLYPH_W:
            mask: uint8 = cast[uint8](1 << cast[uint32](GLYPH_W - 1 - col))
            if (bits & mask) != 0:
                hamui_v2_set_pixel(x + col, y + row, r, g, b)
            col = col + 1
        row = row + 1


def _draw_text(x: int32, y: int32, s: Ptr[uint8],
               r: uint8, g: uint8, b: uint8):
    i: int32 = 0
    while s[i] != 0:
        _draw_glyph(x + i * (GLYPH_W + 1), y, s[i], r, g, b)
        i = i + 1


# ---------------- panel chrome paint ---------------------------------
def _paint_background():
    hamui_v2_clear(BG_R, BG_G, BG_B)
    # 1px bottom edge (panel sits at the top — the desktop is below us).
    hamui_v2_fill_rect(0, PANEL_H - 1, PANEL_W, 1, EDGE_R, EDGE_G, EDGE_B)


def _paint_apps_button():
    # Background bar.
    hamui_v2_fill_rect(APPS_BTN_X, 0, APPS_BTN_W, PANEL_H - 1,
                       HI_R, HI_G, HI_B)
    # Right-edge separator.
    hamui_v2_fill_rect(APPS_BTN_X + APPS_BTN_W - 1, 0, 1, PANEL_H - 1,
                       EDGE_R, EDGE_G, EDGE_B)
    # Centre an "A" glyph.
    tx: int32 = APPS_BTN_X + (APPS_BTN_W - GLYPH_W) / 2
    ty: int32 = (PANEL_H - GLYPH_H) / 2
    _draw_glyph(tx, ty, 65, INK_R, INK_G, INK_B)


def _paint_winlist():
    # Wash the winlist region in the panel bg so a removed window's
    # button disappears cleanly.
    hamui_v2_fill_rect(WINLIST_X, 0, WINLIST_W, PANEL_H - 1,
                       BG_R, BG_G, BG_B)
    i: int32 = 0
    while i < win_count:
        bx: int32 = WINLIST_X + i * (WIN_BTN_W + WIN_BTN_PAD)
        if bx + WIN_BTN_W > WINLIST_X + WINLIST_W:
            return
        # Button fill with a thin border.
        hamui_v2_fill_rect(bx, 2, WIN_BTN_W, PANEL_H - 5,
                           cast[uint8](cast[int32](BG_R) + 20),
                           cast[uint8](cast[int32](BG_G) + 20),
                           cast[uint8](cast[int32](BG_B) + 24))
        hamui_v2_fill_rect(bx, 2, WIN_BTN_W, 1,
                           EDGE_R, EDGE_G, EDGE_B)
        hamui_v2_fill_rect(bx, PANEL_H - 4, WIN_BTN_W, 1,
                           EDGE_R, EDGE_G, EDGE_B)
        # Label: the wid as a single digit (clamped 0..9).
        wid_v: int32 = win_wids[i]
        if wid_v > 9:
            wid_v = 9
        if wid_v < 0:
            wid_v = 0
        c: uint8 = cast[uint8](wid_v) + 48
        gx: int32 = bx + (WIN_BTN_W - GLYPH_W) / 2
        gy: int32 = (PANEL_H - GLYPH_H) / 2
        _draw_glyph(gx, gy, c, INK_R, INK_G, INK_B)
        i = i + 1


def _paint_clock():
    # Wash the clock region first so we can blit just this bbox per tick.
    hamui_v2_fill_rect(CLOCK_X, 0, CLOCK_W, PANEL_H - 1,
                       BG_R, BG_G, BG_B)
    n: int32 = 0
    while clock_str[n] != 0 and n < 8:
        n = n + 1
    txt_w: int32 = n * (GLYPH_W + 1)
    if txt_w > CLOCK_W - 4:
        txt_w = CLOCK_W - 4
    tx: int32 = CLOCK_X + (CLOCK_W - txt_w) / 2
    ty: int32 = (PANEL_H - GLYPH_H) / 2
    _draw_text(tx, ty, &clock_str[0], INK_R, INK_G, INK_B)


# ---------------- clock ---------------------------------------------
def update_clock() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/proc/realtime"))
    if fd >= 0:
        n: int64 = sys_read(fd, &rt_buf[0], 128)
        sys_close(fd)
        if n >= 20 and rt_buf[0] != 117 and rt_buf[10] == 84:
            hh: uint64 = _rt_two(11)
            mm: uint64 = _rt_two(14)
            min_id: int32 = cast[int32](hh) * 60 + cast[int32](mm)
            if min_id == last_clock_min:
                return 0
            last_clock_min = min_id
            _two_digits(&clock_str[0], 0, hh)
            clock_str[2] = 58                         # ':'
            _two_digits(&clock_str[0], 3, mm)
            clock_str[5] = 0
            return 1
    # Jiffies fallback: "up MM:SS" since boot.
    j: uint64 = sys_get_jiffies()
    s: uint64 = j / 100
    if s == last_uptime_s:
        return 0
    last_uptime_s = s
    last_clock_min = -1
    mins: uint64 = (s / 60) % 100
    secs: uint64 = s % 60
    clock_str[0] = 117                                # 'u'
    clock_str[1] = 112                                # 'p'
    clock_str[2] = 32                                 # ' '
    _two_digits(&clock_str[0], 3, mins)
    clock_str[5] = 58                                 # ':'
    _two_digits(&clock_str[0], 6, secs)
    return 0


# ---------------- /dev/wsys/session poll ----------------------------
# Parse the first integer (the wid) on each line. Return 1 if the wid
# set CHANGED, else 0.
def update_winlist() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/session"))
    if fd < 0:
        if win_count == 0:
            return 0
        win_count = 0
        last_sess_hash = 0
        return 1
    n: int64 = sys_read(fd, &sess_buf[0], 2048)
    sys_close(fd)
    if n <= 0:
        if win_count == 0:
            return 0
        win_count = 0
        last_sess_hash = 0
        return 1
    # Cheap rolling hash over the snapshot bytes — if unchanged, skip.
    h: uint64 = 14695981039346656037
    i: int64 = 0
    while i < n:
        h = h ^ cast[uint64](sess_buf[i])
        h = h * 1099511628211
        i = i + 1
    if h == last_sess_hash:
        return 0
    last_sess_hash = h
    # Tokenise: first int on each line is the wid.
    new_count: int32 = 0
    j: int64 = 0
    while j < n and new_count < 16:
        # Skip leading whitespace.
        while j < n and (sess_buf[j] == 32 or sess_buf[j] == 9):
            j = j + 1
        if j >= n:
            break
        # Read decimal.
        if sess_buf[j] >= 48 and sess_buf[j] <= 57:
            v: int32 = 0
            while j < n and sess_buf[j] >= 48 and sess_buf[j] <= 57:
                v = v * 10 + cast[int32](sess_buf[j] - 48)
                j = j + 1
            win_wids[new_count] = v
            new_count = new_count + 1
        # Skip to end of line.
        while j < n and sess_buf[j] != 10:
            j = j + 1
        if j < n:
            j = j + 1
    win_count = new_count
    return 1


# ---------------- launcher cycle ------------------------------------
LAUNCH_COUNT: int32 = 5


def _launch_prog(idx: int32) -> Ptr[uint8]:
    if idx == 0:
        return "/bin/hamterm"
    if idx == 1:
        return "/bin/hamfiles"
    if idx == 2:
        return "/bin/hamedit"
    if idx == 3:
        return "/bin/hamclock"
    return "/bin/hamcalc"


def launch_next() -> int32:
    p: Ptr[uint8] = _launch_prog(launch_idx)
    launch_argv[0] = cast[uint64](p)
    launch_argv[1] = 0
    pid: int32 = spawn(cast[Ptr[char]](p), &launch_argv[0],
                       -2, -2, cast[Ptr[uint64]](0))
    launch_idx = (launch_idx + 1) % LAUNCH_COUNT
    if pid >= 0:
        _puts(1, "HAMPANEL launch ")
        _puts(1, p)
        _puts(1, "\n")
    return pid


# ---------------- input poll ----------------------------------------
# We poll our /dev/wsys/<wid>/pointer for click events. The event
# stream is text: each press posts a line like "M <btn> <x> <y>\n"
# in panel-local coordinates. We only care about a button-1 press
# inside the Applications button area.
ptr_path: Array[64, uint8]
ptr_buf:  Array[256, uint8]
ptr_fd: int32 = -1
last_apps_press: int32 = 0


def _open_pointer(wid: int32):
    # Compose "/dev/wsys/<wid>/pointer"
    pfx: Ptr[uint8] = "/dev/wsys/"
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        ptr_path[p] = pfx[k]
        p = p + 1
        k = k + 1
    # decimal wid
    v: uint32 = cast[uint32](wid)
    if v == 0:
        ptr_path[p] = 48
        p = p + 1
    else:
        tmp: Array[12, uint8]
        t: uint64 = 0
        while v != 0:
            tmp[t] = cast[uint8](v % 10) + 48
            v = v / 10
            t = t + 1
        while t > 0:
            t = t - 1
            ptr_path[p] = tmp[t]
            p = p + 1
    suf: Ptr[uint8] = "/pointer"
    k = 0
    while suf[k] != 0:
        ptr_path[p] = suf[k]
        p = p + 1
        k = k + 1
    ptr_path[p] = 0
    ptr_fd = sys_open(cast[Ptr[char]](&ptr_path[0]))


def poll_pointer() -> int32:
    if ptr_fd < 0:
        return 0
    n: int64 = sys_read(ptr_fd, &ptr_buf[0], 256)
    if n <= 0:
        return 0
    # Look for "M <btns> <x> <y>" lines with btns&1 (button-1 down).
    pressed_in_apps: int32 = 0
    i: int64 = 0
    while i < n:
        # Find a line start with 'M'.
        if ptr_buf[i] == 77 and i + 4 < n:
            j: int64 = i + 2
            # btns digit
            btns: int32 = 0
            while j < n and ptr_buf[j] >= 48 and ptr_buf[j] <= 57:
                btns = btns * 10 + cast[int32](ptr_buf[j] - 48)
                j = j + 1
            while j < n and ptr_buf[j] == 32:
                j = j + 1
            # x
            xv: int32 = 0
            while j < n and ptr_buf[j] >= 48 and ptr_buf[j] <= 57:
                xv = xv * 10 + cast[int32](ptr_buf[j] - 48)
                j = j + 1
            while j < n and ptr_buf[j] == 32:
                j = j + 1
            # y
            yv: int32 = 0
            while j < n and ptr_buf[j] >= 48 and ptr_buf[j] <= 57:
                yv = yv * 10 + cast[int32](ptr_buf[j] - 48)
                j = j + 1
            if (btns & 1) != 0 and xv >= APPS_BTN_X \
               and xv < APPS_BTN_X + APPS_BTN_W \
               and yv >= 0 and yv < PANEL_H:
                pressed_in_apps = 1
            i = j
        else:
            i = i + 1
    # Edge-detect: only act on transition from not-pressed to pressed.
    fired: int32 = 0
    if pressed_in_apps != 0 and last_apps_press == 0:
        launch_next()
        fired = 1
    last_apps_press = pressed_in_apps
    return fired


# ---------------- main ----------------------------------------------
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    font_init()

    # Self-discover OUR wid via /dev/wsys/self (kernel walks the parent
    # chain to find the wid hamUId allocated against our spawning hamsh).
    # Mirrors hamappmenu/hamcycler/... and is the canonical way a DE
    # client learns its wid. Falls back to argv[1] if /dev/wsys/self
    # returned 0 (no binding), then to wid 1 as a last resort.
    wid: int32 = 1
    self_path: Ptr[uint8] = "/dev/wsys/self"
    sfd: int32 = sys_open(cast[Ptr[char]](&self_path[0]))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            sv: int32 = 0
            sii: uint64 = 0
            while sii < cast[uint64](sn) and sbuf[sii] >= 48 and sbuf[sii] <= 57:
                sv = sv * 10 + cast[int32](sbuf[sii]) - 48
                sii = sii + 1
            if sv >= 1:
                wid = sv
    if wid <= 1 and argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v: int32 = 0
        i: uint64 = 0
        while ap[i] >= 48 and ap[i] <= 57:
            v = v * 10 + cast[int32](ap[i]) - 48
            i = i + 1
        if v >= 1:
            wid = v

    # Bind our window. (The toolkit needs a root for the bind handshake
    # even though we won't use the widget tree for paint.)
    root_dummy: int32 = 0
    bound: int32 = hamui_window_on(root_dummy, wid)
    if bound < 0:
        _puts(2, "hampanel: could not bind panel window\n")
        return 1

    # Negotiate the rio v2 blit protocol.
    if hamui_set_protocol_v2() < 0:
        _puts(2, "hampanel: could not enable v2 protocol\n")
        return 1
    if hamui_v2_is_active() == 0:
        _puts(2, "hampanel: v2 negotiation reported inactive\n")
        return 1

    _open_pointer(wid)

    # Seed state + initial paint.
    update_clock()
    update_winlist()
    _paint_background()
    _paint_apps_button()
    _paint_winlist()
    _paint_clock()
    hamui_v2_commit_rect(0, 0, PANEL_W, PANEL_H)
    _puts(1, "HAMPANEL ready\n")

    # --- event loop ----------------------------------------------------
    poll: uint64 = 0
    while True:
        # 1Hz clock tick: re-blit ONLY the clock bbox.
        if update_clock() != 0:
            _paint_clock()
            hamui_v2_commit_rect(CLOCK_X, 0, CLOCK_W, PANEL_H)

        # Window-list snapshot: re-blit the winlist bbox when it changes.
        if update_winlist() != 0:
            _paint_winlist()
            hamui_v2_commit_rect(WINLIST_X, 0, WINLIST_W, PANEL_H)

        # Pointer: handle Applications-button click.
        poll_pointer()

        poll = poll + 1
        sys_yield()

    return 0

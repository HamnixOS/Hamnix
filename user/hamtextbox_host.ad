# user/hamtextbox_host.ad — QEMU-free, DETERMINISTIC host unit test for the
# #315 text-selection substrate in lib/hamtextbox.ad: the click-to-position
# hit-test (htb_hit_test) and the managed-box selection model
# (htb_sel_click/drag/active/start/end). Pure logic — no DE, no compositor, no
# mouse-injection flakiness. Compiled for x86_64-linux and run on the host.
#
# The load-bearing invariant is that htb_hit_test is the EXACT INVERSE of
# htb_caret_x: for every caret index i, hitting the pixel where caret i would
# draw must return i. That holds for BOTH the proportional-font path and the
# monospace fallback (a click at a caret boundary lands on that caret), so the
# test is font-state-independent.

from lib.hamtextbox import htb_hit_test, htb_caret_x, \
    htb_new, htb_set, htb_text, htb_len, htb_caret, \
    htb_sel_click, htb_sel_drag, htb_sel_active, htb_sel_start, htb_sel_end, \
    htb_feed, \
    htb_word_bounds, htb_line_bounds, htb_click_count, htb_click_reset

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_fails: int32 = 0
_passes: int32 = 0


def _puts(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(1, s, n)


def _putn(v: int64):
    neg: int32 = 0
    x: uint64 = 0
    if v < 0:
        neg = 1
        x = cast[uint64](0 - v)
    else:
        x = cast[uint64](v)
    d: Array[24, uint8]
    n: uint64 = 0
    if x == 0:
        d[0] = 48
        n = 1
    else:
        while x > 0:
            d[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
    out: Array[26, uint8]
    p: uint64 = 0
    if neg != 0:
        out[0] = 45
        p = 1
    i: uint64 = n
    while i > 0:
        i = i - 1
        out[p] = d[i]
        p = p + 1
    sys_write(1, &out[0], p)


def _check(cond: int32, name: Ptr[uint8]):
    if cond != 0:
        _passes = _passes + 1
        _puts(cast[Ptr[uint8]]("[htb-host] PASS "))
    else:
        _fails = _fails + 1
        _puts(cast[Ptr[uint8]]("[htb-host] FAIL "))
    _puts(name)
    _puts(cast[Ptr[uint8]]("\n"))


def _check_eq(got: int64, want: int64, name: Ptr[uint8]):
    ok: int32 = 0
    if got == want:
        ok = 1
    if ok == 0:
        _puts(cast[Ptr[uint8]]("[htb-host] FAIL "))
        _puts(name)
        _puts(cast[Ptr[uint8]](" got="))
        _putn(got)
        _puts(cast[Ptr[uint8]](" want="))
        _putn(want)
        _puts(cast[Ptr[uint8]]("\n"))
        _fails = _fails + 1
    else:
        _puts(cast[Ptr[uint8]]("[htb-host] PASS "))
        _puts(name)
        _puts(cast[Ptr[uint8]]("\n"))
        _passes = _passes + 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    x0: int32 = 12                              # arbitrary non-zero left edge
    s: Ptr[uint8] = cast[Ptr[uint8]]("hello world")   # 11 bytes
    ns: uint64 = 11

    # --- FOCUSED-but-EMPTY caret sits at the field start ---------------
    # Regression (user report 2026-07-17): a focused empty search field must
    # show its caret at the insertion point == the text left edge (x0). The
    # shared htb_render_ph draws exactly here when len==0, so assert the caret X
    # for a 0-length run is x0 (no drift, no "invisible" caret past the box).
    _check_eq(cast[int64](htb_caret_x(x0, s, 0)), cast[int64](x0),
              cast[Ptr[uint8]]("empty_field_caret_at_left_edge"))

    # --- htb_hit_test boundary cases -----------------------------------
    _check_eq(cast[int64](htb_hit_test(x0, s, 0, 999)), 0,
              cast[Ptr[uint8]]("hit_empty_buffer_is_0"))
    _check_eq(cast[int64](htb_hit_test(x0, s, ns, x0 - 5)), 0,
              cast[Ptr[uint8]]("hit_left_of_x0_is_0"))
    _check_eq(cast[int64](htb_hit_test(x0, s, ns, x0)), 0,
              cast[Ptr[uint8]]("hit_at_x0_is_0"))
    _check_eq(cast[int64](htb_hit_test(x0, s, ns, 100000)), cast[int64](ns),
              cast[Ptr[uint8]]("hit_far_right_is_n"))

    # --- INVERSE invariant: hit_test(caret_x(i)) == i for all i --------
    inv_ok: int32 = 1
    i: uint64 = 0
    while i <= ns:
        cx: int32 = htb_caret_x(x0, s, i)
        got: uint64 = htb_hit_test(x0, s, ns, cx)
        if got != i:
            inv_ok = 0
            _puts(cast[Ptr[uint8]]("[htb-host]   inverse mismatch at i="))
            _putn(cast[int64](i))
            _puts(cast[Ptr[uint8]](" cx="))
            _putn(cast[int64](cx))
            _puts(cast[Ptr[uint8]](" got="))
            _putn(cast[int64](got))
            _puts(cast[Ptr[uint8]]("\n"))
        i = i + 1
    _check(inv_ok, cast[Ptr[uint8]]("hit_test_is_exact_inverse_of_caret_x"))

    # --- MONOTONICITY: hit_test non-decreasing in click_x --------------
    mono_ok: int32 = 1
    prev: uint64 = 0
    end_px: int32 = htb_caret_x(x0, s, ns) + 20
    px: int32 = x0 - 3
    while px <= end_px:
        h: uint64 = htb_hit_test(x0, s, ns, px)
        if h < prev:
            mono_ok = 0
        prev = h
        px = px + 1
    _check(mono_ok, cast[Ptr[uint8]]("hit_test_is_monotonic_in_click_x"))

    # --- managed-box SELECTION model -----------------------------------
    hb: int32 = htb_new()
    htb_set(hb, s, ns)
    buf: Ptr[uint8] = htb_text(hb)
    # click at caret index 3 -> collapsed (caret=anchor=3, not active)
    htb_sel_click(hb, x0, htb_caret_x(x0, buf, 3))
    _check_eq(cast[int64](htb_caret(hb)), 3, cast[Ptr[uint8]]("click_sets_caret_3"))
    _check_eq(cast[int64](htb_sel_active(hb)), 0, cast[Ptr[uint8]]("click_collapses_selection"))
    # drag forward to index 7 -> active, [3,7)
    htb_sel_drag(hb, x0, htb_caret_x(x0, buf, 7))
    _check_eq(cast[int64](htb_sel_active(hb)), 1, cast[Ptr[uint8]]("drag_makes_selection_active"))
    _check_eq(cast[int64](htb_sel_start(hb)), 3, cast[Ptr[uint8]]("drag_fwd_start_3"))
    _check_eq(cast[int64](htb_sel_end(hb)), 7, cast[Ptr[uint8]]("drag_fwd_end_7"))
    # drag BACKWARDS past the anchor to index 1 -> [1,3)
    htb_sel_drag(hb, x0, htb_caret_x(x0, buf, 1))
    _check_eq(cast[int64](htb_sel_start(hb)), 1, cast[Ptr[uint8]]("drag_back_start_1"))
    _check_eq(cast[int64](htb_sel_end(hb)), 3, cast[Ptr[uint8]]("drag_back_end_3"))
    # a fresh click collapses again
    htb_sel_click(hb, x0, htb_caret_x(x0, buf, 5))
    _check_eq(cast[int64](htb_sel_active(hb)), 0, cast[Ptr[uint8]]("reclick_collapses"))
    # extend, then a typed key collapses the selection (type-over-highlight)
    htb_sel_drag(hb, x0, htb_caret_x(x0, buf, 9))
    _check_eq(cast[int64](htb_sel_active(hb)), 1, cast[Ptr[uint8]]("reextend_active"))
    htb_feed(hb, 65)                            # 'A'
    _check_eq(cast[int64](htb_sel_active(hb)), 0, cast[Ptr[uint8]]("key_collapses_selection"))

    # --- #328 WORD bounds (double-click) -------------------------------
    # "hello world" — bytes 0..4 = "hello", 5 = ' ', 6..10 = "world".
    ws: uint64 = 0
    we: uint64 = 0
    htb_word_bounds(s, ns, 2, &ws, &we)         # click inside "hello"
    _check_eq(cast[int64](ws), 0, cast[Ptr[uint8]]("word_hello_start_0"))
    _check_eq(cast[int64](we), 5, cast[Ptr[uint8]]("word_hello_end_5"))
    htb_word_bounds(s, ns, 8, &ws, &we)         # click inside "world"
    _check_eq(cast[int64](ws), 6, cast[Ptr[uint8]]("word_world_start_6"))
    _check_eq(cast[int64](we), 11, cast[Ptr[uint8]]("word_world_end_11"))
    htb_word_bounds(s, ns, 5, &ws, &we)         # click ON the space
    _check_eq(cast[int64](ws), 5, cast[Ptr[uint8]]("word_space_start_5"))
    _check_eq(cast[int64](we), 6, cast[Ptr[uint8]]("word_space_end_6"))
    htb_word_bounds(s, ns, 11, &ws, &we)        # caret at END selects last word
    _check_eq(cast[int64](ws), 6, cast[Ptr[uint8]]("word_end_caret_start_6"))
    _check_eq(cast[int64](we), 11, cast[Ptr[uint8]]("word_end_caret_end_11"))
    # underscore is a word char: "a_b cd" -> idx1 spans [0,3)
    us: Ptr[uint8] = cast[Ptr[uint8]]("a_b cd")
    htb_word_bounds(us, 6, 1, &ws, &we)
    _check_eq(cast[int64](ws), 0, cast[Ptr[uint8]]("word_underscore_start_0"))
    _check_eq(cast[int64](we), 3, cast[Ptr[uint8]]("word_underscore_end_3"))

    # --- #328 LINE bounds (triple-click) -------------------------------
    ml: Ptr[uint8] = cast[Ptr[uint8]]("ab\ncd\nef")   # 8 bytes, 3 lines
    ls: uint64 = 0
    le: uint64 = 0
    htb_line_bounds(ml, 8, 0, &ls, &le)         # first line
    _check_eq(cast[int64](ls), 0, cast[Ptr[uint8]]("line1_start_0"))
    _check_eq(cast[int64](le), 2, cast[Ptr[uint8]]("line1_end_2"))
    htb_line_bounds(ml, 8, 4, &ls, &le)         # middle line (idx on 'd')
    _check_eq(cast[int64](ls), 3, cast[Ptr[uint8]]("line2_start_3"))
    _check_eq(cast[int64](le), 5, cast[Ptr[uint8]]("line2_end_5"))
    htb_line_bounds(ml, 8, 8, &ls, &le)         # caret at EOF -> last line
    _check_eq(cast[int64](ls), 6, cast[Ptr[uint8]]("line3_start_6"))
    _check_eq(cast[int64](le), 8, cast[Ptr[uint8]]("line3_end_8"))

    # --- #328 multi-click COUNT (time + pixel window) ------------------
    htb_click_reset()
    _check_eq(cast[int64](htb_click_count(100, 100, 10)), 1,
              cast[Ptr[uint8]]("click1_is_single"))
    _check_eq(cast[int64](htb_click_count(101, 101, 15)), 2,
              cast[Ptr[uint8]]("click2_same_spot_is_double"))
    _check_eq(cast[int64](htb_click_count(102, 100, 20)), 3,
              cast[Ptr[uint8]]("click3_same_spot_is_triple"))
    _check_eq(cast[int64](htb_click_count(102, 100, 25)), 3,
              cast[Ptr[uint8]]("click4_caps_at_triple"))
    # a click far away restarts the run
    _check_eq(cast[int64](htb_click_count(400, 100, 30)), 1,
              cast[Ptr[uint8]]("click_far_pixel_resets"))
    _check_eq(cast[int64](htb_click_count(401, 100, 35)), 2,
              cast[Ptr[uint8]]("click_near_again_is_double"))
    # a click after the time window restarts the run
    _check_eq(cast[int64](htb_click_count(401, 100, 200)), 1,
              cast[Ptr[uint8]]("click_late_time_resets"))

    _puts(cast[Ptr[uint8]]("[htb-host] SUMMARY passes="))
    _putn(cast[int64](_passes))
    _puts(cast[Ptr[uint8]](" fails="))
    _putn(cast[int64](_fails))
    _puts(cast[Ptr[uint8]]("\n"))
    if _fails == 0:
        _puts(cast[Ptr[uint8]]("[htb-host] RESULT PASS\n"))
        return 0
    _puts(cast[Ptr[uint8]]("[htb-host] RESULT FAIL\n"))
    return 1

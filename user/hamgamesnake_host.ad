# user/hamgamesnake_host.ad — "Snake" hamGame arcade HOST render + drive harness
# (built for x86_64-linux; runs on the dev host, NO QEMU).
#
# Drives the SAME game the device app ships (lib/hamgamesnake.ad) through the
# SAME public hamGame API, but with the HOST backend (lib/hamgame_host.ad): it
# renders frames to binary PPMs a human/agent can LOOK at, drives a DETERMINISTIC
# scripted move sequence (snk_key + snk_step, no real-time input), and dumps the
# game state + sampled framebuffer pixels so scripts/test_hamgamesnake_host.sh
# can assert on the head cell, growth, food and score-text WITHOUT eyeballing.
#
# USAGE (built to build/host/hamgamesnake_host):
#   hamgamesnake_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamgame import game_reset, game_flip_scene, \
    game_mixer_init, game_mixer_voices, game_mixer_render, game_stop_all_sounds, \
    game_damage_count, \
    GAMEK_RIGHT, GAMEK_UP, GAMEK_DOWN, GAMEK_LEFT
from lib.hamgame_host import game_host_present, game_host_write_ppm, \
    game_host_pixel
from lib.hamgamesnake import snk_init, snk_key, snk_step, snk_render, \
    snk_render_dirty, snk_step_dirty_cells, snk_occupied_at, \
    snk_display_surf, snk_head_col, snk_head_row, snk_len, \
    snk_food_col, snk_food_row, snk_score, snk_game_over, \
    snk_cell_center_x, snk_cell_center_y, snk_last_tone_freq


SNKW: int32 = 224
SNKH: int32 = 248
HHUD: int32 = 24


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(ch: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = ch
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                            # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _o_pix(label: Ptr[uint8], x: int32, y: int32):
    _o_str(label)
    _o_hexcol(game_host_pixel(x, y) & cast[uint32](16777215))
    _o_ch(10)


# Sample the pixel at the CENTRE of grid cell (col,row).
def _o_cell(label: Ptr[uint8], col: int32, row: int32):
    _o_pix(label, snk_cell_center_x(col), snk_cell_center_y(row))


# Count "text-bright" pixels in the HUD strip (score text = near-white on the
# dark HUD): proves game_surface_draw_text actually rasterized glyphs.
def _hud_text_pixels() -> int32:
    n: int32 = 0
    y: int32 = 0
    while y < HHUD:
        x: int32 = 0
        while x < SNKW:
            p: uint32 = game_host_pixel(x, y)
            rr: int32 = cast[int32]((p >> 16) & 255)
            gg: int32 = cast[int32]((p >> 8) & 255)
            bb: int32 = cast[int32](p & 255)
            if rr > 180 and gg > 180 and bb > 180:
                n = n + 1
            x = x + 1
        y = y + 1
    return n


# ---- s16le PCM read-back helpers (assert the mixer produced real samples) --
_snd: Array[4096, uint8]                                  # 2048 frames scratch


def _rd16(buf: Ptr[uint8], i: uint64) -> int32:
    raw: uint32 = cast[uint32](buf[i]) | (cast[uint32](buf[i + 1]) << 8)
    s: int32 = cast[int32](raw)
    if s >= 32768:
        s = s - 65536
    return s


def _pk(buf: Ptr[uint8], frames: uint64) -> int32:
    pk: int32 = 0
    i: uint64 = 0
    while i < frames:
        s: int32 = _rd16(buf, i * 2)
        if s < 0:
            s = 0 - s
        if s > pk:
            pk = s
        i = i + 1
    return pk


# Zero-crossings across a mono s16le square: 2*freq*seconds transitions, so a
# higher-pitched event tone yields distinctly MORE crossings than a low one.
def _zc(buf: Ptr[uint8], frames: uint64) -> int32:
    if frames < 2:
        return 0
    n: int32 = 0
    prev: int32 = _rd16(buf, 0)
    i: uint64 = 1
    while i < frames:
        cur: int32 = _rd16(buf, i * 2)
        pp: int32 = 0
        if prev > 0:
            pp = 1
        cp: int32 = 0
        if cur > 0:
            cp = 1
        if cur != 0 and pp != cp:
            n = n + 1
        if cur != 0:
            prev = cur
        i = i + 1
    return n


# Dump the PCM stats for the tone currently active on the mixer (rendered over a
# fixed 512-frame window): active voice count, peak amplitude, zero-crossings and
# the event frequency the game reported.
def _dump_tone(voices_key: Ptr[uint8], peak_key: Ptr[uint8],
               zc_key: Ptr[uint8], freq_key: Ptr[uint8]):
    vc: int32 = game_mixer_voices()
    frames: uint64 = 512
    game_mixer_render(&_snd[0], frames)
    _o_kv(voices_key, cast[int64](vc))
    _o_kv(peak_key, cast[int64](_pk(&_snd[0], frames)))
    _o_kv(zc_key, cast[int64](_zc(&_snd[0], frames)))
    _o_kv(freq_key, cast[int64](snk_last_tone_freq()))


def _render_present(path: Ptr[char]) -> int32:
    snk_render()
    game_flip_scene(snk_display_surf())
    prims: int32 = game_host_present(snk_display_surf())
    game_host_write_ppm(path)
    return prims


# ---- greedy self-avoiding controller (grows the snake DETERMINISTICALLY) ---
# Everything here is deterministic (LCG food + this fixed policy), so the whole
# growth run is reproducible — the same way the existing test hard-codes "step
# right 4 to eat the first food". It lets the gate grow a LONG snake and confirm
# the per-step cost never grows with it.
_ctl_dx: int32 = 1                                        # tracked heading (right)
_ctl_dy: int32 = 0


def _g_abs32(v: int32) -> int32:
    if v < 0:
        return 0 - v
    return v


# Is board cell (c,r) a safe step target? In-bounds and not currently occupied by
# the snake (conservative: the tail cell reads occupied even though it vacates).
def _cell_safe(c: int32, r: int32) -> int32:
    if c < 0 or c >= 14 or r < 0 or r >= 14:
        return 0
    if snk_occupied_at(c, r) == 1:
        return 0
    return 1


def _dir_key(dx: int32, dy: int32) -> int32:
    if dx == 1:
        return GAMEK_RIGHT
    if dx == -1:
        return GAMEK_LEFT
    if dy == 1:
        return GAMEK_DOWN
    return GAMEK_UP


# Consider heading (dx,dy): reject a 180 reversal; require a safe target cell.
# On accept, steer there (snk_key) and record the heading. Returns 1 if chosen.
def _try_dir(dx: int32, dy: int32) -> int32:
    if dx == 0 - _ctl_dx and dy == 0 - _ctl_dy:
        return 0
    hc: int32 = snk_head_col()
    hr: int32 = snk_head_row()
    if _cell_safe(hc + dx, hr + dy) == 0:
        return 0
    snk_key(_dir_key(dx, dy))
    _ctl_dx = dx
    _ctl_dy = dy
    return 1


# Steer one step toward the food, avoiding walls/self. Prefers closing the axis
# with the larger gap, then continuing straight, then a perpendicular turn.
def _drive_toward_food():
    hc: int32 = snk_head_col()
    hr: int32 = snk_head_row()
    fc: int32 = snk_food_col()
    fr: int32 = snk_food_row()
    hstep: int32 = 0
    if fc > hc:
        hstep = 1
    elif fc < hc:
        hstep = -1
    vstep: int32 = 0
    if fr > hr:
        vstep = 1
    elif fr < hr:
        vstep = -1
    # priority: toward food (larger axis first), then straight, then turns
    if _g_abs32(fc - hc) >= _g_abs32(fr - hr):
        if hstep != 0 and _try_dir(hstep, 0) == 1:
            return
        if vstep != 0 and _try_dir(0, vstep) == 1:
            return
    else:
        if vstep != 0 and _try_dir(0, vstep) == 1:
            return
        if hstep != 0 and _try_dir(hstep, 0) == 1:
            return
    if _try_dir(_ctl_dx, _ctl_dy) == 1:                   # keep going straight
        return
    if _try_dir(0 - _ctl_dy, _ctl_dx) == 1:              # turn one way
        return
    _try_dir(_ctl_dy, 0 - _ctl_dx)                       # or the other


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamgamesnake_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    game_reset()
    snk_init(SNKW, SNKH, cast[uint32](12345))

    # ---- BEFORE frame: initial board -----------------------------------
    hc0: int32 = snk_head_col()
    hr0: int32 = snk_head_row()
    fc0: int32 = snk_food_col()
    fr0: int32 = snk_food_row()
    prims: int32 = _render_present(cast[Ptr[char]](argv[1]))

    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _o_kv(cast[Ptr[uint8]]("HEADC0"), cast[int64](hc0))
    _o_kv(cast[Ptr[uint8]]("HEADR0"), cast[int64](hr0))
    _o_kv(cast[Ptr[uint8]]("FOODC0"), cast[int64](fc0))
    _o_kv(cast[Ptr[uint8]]("FOODR0"), cast[int64](fr0))
    _o_kv(cast[Ptr[uint8]]("LEN0"), cast[int64](snk_len()))
    _o_kv(cast[Ptr[uint8]]("SCORE0"), cast[int64](snk_score()))
    # sampled pixels prove the rasterizer blitted the backbuffer
    _o_cell(cast[Ptr[uint8]]("PIX_HEAD0 "), hc0, hr0)         # bright green head
    _o_cell(cast[Ptr[uint8]]("PIX_FOOD0 "), fc0, fr0)        # red food
    _o_cell(cast[Ptr[uint8]]("PIX_BG0 "), 0, hr0)            # empty board cell
    _o_kv(cast[Ptr[uint8]]("HUDTEXT0"), cast[int64](_hud_text_pixels()))
    _o_flush()

    # ---- MOVES: heading is RIGHT; the first food sits 4 cells right on the
    # head row, so stepping right 4 times deterministically eats it (grow+score).
    snk_key(GAMEK_RIGHT)
    k: int32 = 0
    while k < 4:
        snk_step()
        k = k + 1

    hc1: int32 = snk_head_col()
    hr1: int32 = snk_head_row()
    _o_kv(cast[Ptr[uint8]]("HEADC1"), cast[int64](hc1))
    _o_kv(cast[Ptr[uint8]]("HEADR1"), cast[int64](hr1))
    _o_kv(cast[Ptr[uint8]]("LEN1"), cast[int64](snk_len()))
    _o_kv(cast[Ptr[uint8]]("SCORE1"), cast[int64](snk_score()))
    _o_kv(cast[Ptr[uint8]]("FOODC1"), cast[int64](snk_food_col()))
    _o_kv(cast[Ptr[uint8]]("FOODR1"), cast[int64](snk_food_row()))

    # ---- AFTER frame: grown snake, new food, score 1 -------------------
    _render_present(cast[Ptr[char]](argv[2]))
    _o_cell(cast[Ptr[uint8]]("PIX_HEAD1 "), hc1, hr1)             # head at (9,7)
    _o_cell(cast[Ptr[uint8]]("PIX_BODY1 "), hc1 - 1, hr1)        # a body segment
    _o_cell(cast[Ptr[uint8]]("PIX_FOOD1 "), snk_food_col(), snk_food_row())
    _o_kv(cast[Ptr[uint8]]("HUDTEXT1"), cast[int64](_hud_text_pixels()))
    _o_flush()

    # ---- GAME OVER: fresh game, drive straight into the right wall ------
    game_reset()
    snk_init(SNKW, SNKH, cast[uint32](12345))
    snk_key(GAMEK_RIGHT)
    steps: int32 = 0
    while steps < SNKW and snk_game_over() == 0:
        snk_step()
        steps = steps + 1
    _o_kv(cast[Ptr[uint8]]("WALL_STEPS"), cast[int64](steps))
    _o_kv(cast[Ptr[uint8]]("GAMEOVER"), cast[int64](snk_game_over()))
    # RESTART: a steering key must NOT revive a dead snake, but 'r' starts a
    # fresh round IN PLACE (the app stays open) — length back to 3, score 0.
    snk_key(119)                                         # 'w' up -> ignored
    _o_kv(cast[Ptr[uint8]]("OVER_AFTER_STEER"), cast[int64](snk_game_over()))
    snk_key(114)                                         # 'r' -> restart
    _o_kv(cast[Ptr[uint8]]("OVER_AFTER_R"), cast[int64](snk_game_over()))
    _o_kv(cast[Ptr[uint8]]("LEN_AFTER_R"), cast[int64](snk_len()))
    _o_kv(cast[Ptr[uint8]]("SCORE_AFTER_R"), cast[int64](snk_score()))
    _o_flush()

    # ---- SOUND EFFECTS: each event drives a distinct mixer tone ---------
    # Assert on the actual PCM the mixer renders (peak != silence, zero-crossings
    # track the pitch) and on the event frequency the game reports, for turn /
    # eat / game-over. A fresh game + mixer per event isolates its voice.

    # TURN: change heading right -> up produces the subtle turn click.
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    game_stop_all_sounds()
    snk_key(GAMEK_UP)
    _dump_tone(cast[Ptr[uint8]]("TURN_VOICES"), cast[Ptr[uint8]]("TURN_PEAK"),
               cast[Ptr[uint8]]("TURN_ZC"), cast[Ptr[uint8]]("TURN_FREQ"))
    _o_flush()

    # EAT: step onto the fixed first food (4 cells right) blips the eat tone.
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    game_stop_all_sounds()
    snk_key(GAMEK_RIGHT)
    ek: int32 = 0
    while ek < 4:
        snk_step()
        ek = ek + 1
    _dump_tone(cast[Ptr[uint8]]("EAT_VOICES"), cast[Ptr[uint8]]("EAT_PEAK"),
               cast[Ptr[uint8]]("EAT_ZC"), cast[Ptr[uint8]]("EAT_FREQ"))
    _o_kv(cast[Ptr[uint8]]("EAT_SCORE"), cast[int64](snk_score()))
    _o_flush()

    # GAME OVER: head UP to the top wall (this column has no food, so nothing is
    # eaten en route); the final step sounds the low over tone in isolation.
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    snk_key(GAMEK_UP)
    game_stop_all_sounds()                               # clear the turn click
    ov: int32 = 0
    while ov < SNKH and snk_game_over() == 0:
        snk_step()
        ov = ov + 1
    _dump_tone(cast[Ptr[uint8]]("OVER_VOICES"), cast[Ptr[uint8]]("OVER_PEAK"),
               cast[Ptr[uint8]]("OVER_ZC"), cast[Ptr[uint8]]("OVER_FREQ"))
    _o_kv(cast[Ptr[uint8]]("OVER_FLAG"), cast[int64](snk_game_over()))
    _o_flush()

    # ---- SOUND DOES NOT DIE MID-GAME: the old port registered a NEW mixer clip
    # on every beep, so the 16-clip table filled after a handful of turns/eats and
    # the game went SILENT. Event tones are now reusable clips synth'd once, so a
    # tone STILL sounds after many events. Fire 30 turn clicks in ONE game (one
    # mixer_init), then assert the final isolated click still creates a real,
    # non-silent voice at the turn pitch (with the old bug this yields 0 voices).
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    tt: int32 = 0
    while tt < 30:
        if tt % 2 == 0:
            snk_key(GAMEK_UP)
        else:
            snk_key(GAMEK_RIGHT)
        game_stop_all_sounds()                           # drain the voice, keep clips
        tt = tt + 1
    snk_key(GAMEK_UP)                                     # one last real turn -> beep
    _dump_tone(cast[Ptr[uint8]]("MANY_VOICES"), cast[Ptr[uint8]]("MANY_PEAK"),
               cast[Ptr[uint8]]("MANY_ZC"), cast[Ptr[uint8]]("MANY_FREQ"))
    _o_flush()

    # ---- CONSTANT-COST rendering: per-step damage stays BOUNDED as the snake
    # grows, and the incremental repaint matches a full redraw pixel-for-pixel.
    # This is the direct evidence for "the framerate stays constant as the snake
    # grows": the number of cells a step repaints does NOT depend on the length.
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    dsp: int32 = snk_display_surf()

    # first frame is a FULL redraw (g_full_redraw); present it
    snk_render_dirty()
    game_flip_scene(dsp)
    game_host_present(dsp)

    # one plain (non-eating) move at length 3 — first food sits at col 9, head at
    # col 5, so a single step right does NOT eat: a clean short-snake step.
    snk_key(GAMEK_RIGHT)
    snk_step()
    _o_kv(cast[Ptr[uint8]]("DCELLS_SHORT"), cast[int64](snk_step_dirty_cells()))
    _o_kv(cast[Ptr[uint8]]("LEN_SHORT"), cast[int64](snk_len()))
    snk_render_dirty()
    game_flip_scene(dsp)
    game_host_present(dsp)

    # grow a LONG snake with the deterministic greedy controller, tracking the
    # WORST per-step dirty-cell count seen along the way (deaths excluded).
    _ctl_dx = 1
    _ctl_dy = 0
    dmax: int32 = 0
    steps2: int32 = 0
    while snk_len() < 16 and snk_game_over() == 0 and steps2 < 600:
        _drive_toward_food()
        snk_step()
        if snk_game_over() == 0:
            dc: int32 = snk_step_dirty_cells()
            if dc > dmax:
                dmax = dc
            snk_render_dirty()
            game_flip_scene(dsp)
            game_host_present(dsp)
        steps2 = steps2 + 1
    _o_kv(cast[Ptr[uint8]]("LEN_LONG"), cast[int64](snk_len()))
    _o_kv(cast[Ptr[uint8]]("DCELLS_MAX"), cast[int64](dmax))
    _o_kv(cast[Ptr[uint8]]("DMG_BBOX_COUNT"), cast[int64](game_damage_count()))

    # per-step dirty-cell count at the LONG length — must equal the SHORT one
    if snk_game_over() == 0:
        _drive_toward_food()
        snk_step()
        _o_kv(cast[Ptr[uint8]]("DCELLS_LONG"), cast[int64](snk_step_dirty_cells()))

    # incremental-vs-full CORRECTNESS: the surface currently reflects a long run
    # of incremental repaints. Sample cells, then FULL-render the identical state
    # and sample the same cells — they must same_px, proving snk_render_dirty()
    # produces the same image as the whole-surface redraw.
    snk_render_dirty()
    game_flip_scene(dsp)
    game_host_present(dsp)
    hcx: int32 = snk_head_col()
    hcy: int32 = snk_head_row()
    fcx: int32 = snk_food_col()
    fcy: int32 = snk_food_row()
    inc_head: uint32 = game_host_pixel(snk_cell_center_x(hcx),
                                       snk_cell_center_y(hcy)) & cast[uint32](16777215)
    inc_food: uint32 = game_host_pixel(snk_cell_center_x(fcx),
                                       snk_cell_center_y(fcy)) & cast[uint32](16777215)
    inc_hud: int32 = _hud_text_pixels()

    snk_render()                                          # full rebuild, same state
    game_flip_scene(dsp)
    game_host_present(dsp)
    full_head: uint32 = game_host_pixel(snk_cell_center_x(hcx),
                                        snk_cell_center_y(hcy)) & cast[uint32](16777215)
    full_food: uint32 = game_host_pixel(snk_cell_center_x(fcx),
                                        snk_cell_center_y(fcy)) & cast[uint32](16777215)
    full_hud: int32 = _hud_text_pixels()

    same_px: int32 = 0
    if inc_head == full_head and inc_food == full_food and inc_hud == full_hud:
        same_px = 1
    _o_kv(cast[Ptr[uint8]]("INCR_MATCHES_FULL"), cast[int64](same_px))
    _o_flush()
    return 0

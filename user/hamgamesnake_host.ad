# user/hamgamesnake_host.ad — "Snake" hamGame arcade HOST render + drive harness
# (built for x86_64-linux; runs on the dev host, NO QEMU).
#
# Drives the SAME game the device app ships (lib/hamgamesnake.ad) through the
# SAME public hamGame API, but with the HOST backend (lib/hamgame_host.ad): it
# renders frames to binary PPMs a human/agent can LOOK at, drives a DETERMINISTIC
# scripted move sequence (snk_key + snk_step, no real-time input), and dumps the
# game state + sampled framebuffer pixels so scripts/test_hamgamesnake_host.sh
# can assert on the head cell, growth, food and score-text WITHOUT eyeballing.
#
# USAGE (built to build/host/hamgamesnake_host):
#   hamgamesnake_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamgame import game_reset, game_flip_scene, \
    game_mixer_init, game_mixer_voices, game_mixer_render, game_stop_all_sounds, \
    GAMEK_RIGHT, GAMEK_UP
from lib.hamgame_host import game_host_present, game_host_write_ppm, \
    game_host_pixel
from lib.hamgamesnake import snk_init, snk_key, snk_step, snk_render, \
    snk_display_surf, snk_head_col, snk_head_row, snk_len, \
    snk_food_col, snk_food_row, snk_score, snk_game_over, \
    snk_cell_center_x, snk_cell_center_y, snk_last_tone_freq


SNKW: int32 = 224
SNKH: int32 = 248
HHUD: int32 = 24


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(ch: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = ch
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                            # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _o_pix(label: Ptr[uint8], x: int32, y: int32):
    _o_str(label)
    _o_hexcol(game_host_pixel(x, y) & cast[uint32](16777215))
    _o_ch(10)


# Sample the pixel at the CENTRE of grid cell (col,row).
def _o_cell(label: Ptr[uint8], col: int32, row: int32):
    _o_pix(label, snk_cell_center_x(col), snk_cell_center_y(row))


# Count "text-bright" pixels in the HUD strip (score text = near-white on the
# dark HUD): proves game_surface_draw_text actually rasterized glyphs.
def _hud_text_pixels() -> int32:
    n: int32 = 0
    y: int32 = 0
    while y < HHUD:
        x: int32 = 0
        while x < SNKW:
            p: uint32 = game_host_pixel(x, y)
            rr: int32 = cast[int32]((p >> 16) & 255)
            gg: int32 = cast[int32]((p >> 8) & 255)
            bb: int32 = cast[int32](p & 255)
            if rr > 180 and gg > 180 and bb > 180:
                n = n + 1
            x = x + 1
        y = y + 1
    return n


# ---- s16le PCM read-back helpers (assert the mixer produced real samples) --
_snd: Array[4096, uint8]                                  # 2048 frames scratch


def _rd16(buf: Ptr[uint8], i: uint64) -> int32:
    raw: uint32 = cast[uint32](buf[i]) | (cast[uint32](buf[i + 1]) << 8)
    s: int32 = cast[int32](raw)
    if s >= 32768:
        s = s - 65536
    return s


def _pk(buf: Ptr[uint8], frames: uint64) -> int32:
    pk: int32 = 0
    i: uint64 = 0
    while i < frames:
        s: int32 = _rd16(buf, i * 2)
        if s < 0:
            s = 0 - s
        if s > pk:
            pk = s
        i = i + 1
    return pk


# Zero-crossings across a mono s16le square: 2*freq*seconds transitions, so a
# higher-pitched event tone yields distinctly MORE crossings than a low one.
def _zc(buf: Ptr[uint8], frames: uint64) -> int32:
    if frames < 2:
        return 0
    n: int32 = 0
    prev: int32 = _rd16(buf, 0)
    i: uint64 = 1
    while i < frames:
        cur: int32 = _rd16(buf, i * 2)
        pp: int32 = 0
        if prev > 0:
            pp = 1
        cp: int32 = 0
        if cur > 0:
            cp = 1
        if cur != 0 and pp != cp:
            n = n + 1
        if cur != 0:
            prev = cur
        i = i + 1
    return n


# Dump the PCM stats for the tone currently active on the mixer (rendered over a
# fixed 512-frame window): active voice count, peak amplitude, zero-crossings and
# the event frequency the game reported.
def _dump_tone(voices_key: Ptr[uint8], peak_key: Ptr[uint8],
               zc_key: Ptr[uint8], freq_key: Ptr[uint8]):
    vc: int32 = game_mixer_voices()
    frames: uint64 = 512
    game_mixer_render(&_snd[0], frames)
    _o_kv(voices_key, cast[int64](vc))
    _o_kv(peak_key, cast[int64](_pk(&_snd[0], frames)))
    _o_kv(zc_key, cast[int64](_zc(&_snd[0], frames)))
    _o_kv(freq_key, cast[int64](snk_last_tone_freq()))


def _render_present(path: Ptr[char]) -> int32:
    snk_render()
    game_flip_scene(snk_display_surf())
    prims: int32 = game_host_present(snk_display_surf())
    game_host_write_ppm(path)
    return prims


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamgamesnake_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    game_reset()
    snk_init(SNKW, SNKH, cast[uint32](12345))

    # ---- BEFORE frame: initial board -----------------------------------
    hc0: int32 = snk_head_col()
    hr0: int32 = snk_head_row()
    fc0: int32 = snk_food_col()
    fr0: int32 = snk_food_row()
    prims: int32 = _render_present(cast[Ptr[char]](argv[1]))

    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _o_kv(cast[Ptr[uint8]]("HEADC0"), cast[int64](hc0))
    _o_kv(cast[Ptr[uint8]]("HEADR0"), cast[int64](hr0))
    _o_kv(cast[Ptr[uint8]]("FOODC0"), cast[int64](fc0))
    _o_kv(cast[Ptr[uint8]]("FOODR0"), cast[int64](fr0))
    _o_kv(cast[Ptr[uint8]]("LEN0"), cast[int64](snk_len()))
    _o_kv(cast[Ptr[uint8]]("SCORE0"), cast[int64](snk_score()))
    # sampled pixels prove the rasterizer blitted the backbuffer
    _o_cell(cast[Ptr[uint8]]("PIX_HEAD0 "), hc0, hr0)         # bright green head
    _o_cell(cast[Ptr[uint8]]("PIX_FOOD0 "), fc0, fr0)        # red food
    _o_cell(cast[Ptr[uint8]]("PIX_BG0 "), 0, hr0)            # empty board cell
    _o_kv(cast[Ptr[uint8]]("HUDTEXT0"), cast[int64](_hud_text_pixels()))
    _o_flush()

    # ---- MOVES: heading is RIGHT; the first food sits 4 cells right on the
    # head row, so stepping right 4 times deterministically eats it (grow+score).
    snk_key(GAMEK_RIGHT)
    k: int32 = 0
    while k < 4:
        snk_step()
        k = k + 1

    hc1: int32 = snk_head_col()
    hr1: int32 = snk_head_row()
    _o_kv(cast[Ptr[uint8]]("HEADC1"), cast[int64](hc1))
    _o_kv(cast[Ptr[uint8]]("HEADR1"), cast[int64](hr1))
    _o_kv(cast[Ptr[uint8]]("LEN1"), cast[int64](snk_len()))
    _o_kv(cast[Ptr[uint8]]("SCORE1"), cast[int64](snk_score()))
    _o_kv(cast[Ptr[uint8]]("FOODC1"), cast[int64](snk_food_col()))
    _o_kv(cast[Ptr[uint8]]("FOODR1"), cast[int64](snk_food_row()))

    # ---- AFTER frame: grown snake, new food, score 1 -------------------
    _render_present(cast[Ptr[char]](argv[2]))
    _o_cell(cast[Ptr[uint8]]("PIX_HEAD1 "), hc1, hr1)             # head at (9,7)
    _o_cell(cast[Ptr[uint8]]("PIX_BODY1 "), hc1 - 1, hr1)        # a body segment
    _o_cell(cast[Ptr[uint8]]("PIX_FOOD1 "), snk_food_col(), snk_food_row())
    _o_kv(cast[Ptr[uint8]]("HUDTEXT1"), cast[int64](_hud_text_pixels()))
    _o_flush()

    # ---- GAME OVER: fresh game, drive straight into the right wall ------
    game_reset()
    snk_init(SNKW, SNKH, cast[uint32](12345))
    snk_key(GAMEK_RIGHT)
    steps: int32 = 0
    while steps < SNKW and snk_game_over() == 0:
        snk_step()
        steps = steps + 1
    _o_kv(cast[Ptr[uint8]]("WALL_STEPS"), cast[int64](steps))
    _o_kv(cast[Ptr[uint8]]("GAMEOVER"), cast[int64](snk_game_over()))
    _o_flush()

    # ---- SOUND EFFECTS: each event drives a distinct mixer tone ---------
    # Assert on the actual PCM the mixer renders (peak != silence, zero-crossings
    # track the pitch) and on the event frequency the game reports, for turn /
    # eat / game-over. A fresh game + mixer per event isolates its voice.

    # TURN: change heading right -> up produces the subtle turn click.
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    game_stop_all_sounds()
    snk_key(GAMEK_UP)
    _dump_tone(cast[Ptr[uint8]]("TURN_VOICES"), cast[Ptr[uint8]]("TURN_PEAK"),
               cast[Ptr[uint8]]("TURN_ZC"), cast[Ptr[uint8]]("TURN_FREQ"))
    _o_flush()

    # EAT: step onto the fixed first food (4 cells right) blips the eat tone.
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    game_stop_all_sounds()
    snk_key(GAMEK_RIGHT)
    ek: int32 = 0
    while ek < 4:
        snk_step()
        ek = ek + 1
    _dump_tone(cast[Ptr[uint8]]("EAT_VOICES"), cast[Ptr[uint8]]("EAT_PEAK"),
               cast[Ptr[uint8]]("EAT_ZC"), cast[Ptr[uint8]]("EAT_FREQ"))
    _o_kv(cast[Ptr[uint8]]("EAT_SCORE"), cast[int64](snk_score()))
    _o_flush()

    # GAME OVER: head UP to the top wall (this column has no food, so nothing is
    # eaten en route); the final step sounds the low over tone in isolation.
    game_reset()
    game_mixer_init(cast[uint32](22050))
    snk_init(SNKW, SNKH, cast[uint32](12345))
    snk_key(GAMEK_UP)
    game_stop_all_sounds()                               # clear the turn click
    ov: int32 = 0
    while ov < SNKH and snk_game_over() == 0:
        snk_step()
        ov = ov + 1
    _dump_tone(cast[Ptr[uint8]]("OVER_VOICES"), cast[Ptr[uint8]]("OVER_PEAK"),
               cast[Ptr[uint8]]("OVER_ZC"), cast[Ptr[uint8]]("OVER_FREQ"))
    _o_kv(cast[Ptr[uint8]]("OVER_FLAG"), cast[int64](snk_game_over()))
    _o_flush()
    return 0

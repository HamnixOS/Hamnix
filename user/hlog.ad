# user/hlog.ad
#
# Hamnix `hlog` — a full-screen TUI kernel-log viewer / follower, the
# Hamnix analogue of `dmesg -w` / `journalctl -f`. It shows the kernel
# printk ring buffer, tails to the bottom, follows new lines as they
# arrive, and supports scrollback plus an incremental substring filter.
#
# LOG SOURCE
#   Exactly the source user/dmesg.ad reads: /proc/kmsg. Opening it takes
#   a snapshot of (up to) the whole 64 KiB printk ring (fs/procfs.ad sizes
#   the kmsg fd's buffer to PRINTK_LOG_SIZE) into a per-fd buffer, which a
#   sequence of sys_read calls then drains. Because the snapshot is taken
#   at OPEN time, FOLLOW mode simply re-opens /proc/kmsg periodically and
#   re-snapshots the current ring; the ring always returns the most-recent
#   bytes oldest-first, so a fresh snapshot is the complete current log.
#   We re-parse it into a bounded line ring on each refresh, which keeps
#   memory fixed and transparently handles truncation of very old lines.
#
# INPUT MODEL (copied verbatim from user/hamfm.ad)
#   hlog owns the raw console: fd 0/1/2 are bound to the raw console with
#   NO kernel line-cooking and NO echo. It reads one keystroke at a time
#   off fd 0 with sys_read_nb + sys_yield and repaints the whole screen
#   with ANSI escapes on every state change. Arrow keys arrive a byte at a
#   time (ESC '[' A/B ...) and are reassembled by a tiny state machine.
#
# KEYS
#   j / Down      scroll down one line   (DISENGAGES follow)
#   k / Up        scroll up one line     (DISENGAGES follow)
#   PgDn          page down              (DISENGAGES follow)
#   PgUp          page up                (DISENGAGES follow)
#   g / Home      jump to the top        (DISENGAGES follow)
#   G / End       jump to the tail       (RE-ENGAGES follow)
#   f             toggle follow on/off
#   /             start an incremental substring filter:
#                   typing narrows, Backspace widens, Enter commits,
#                   Esc clears the filter
#   q             quit (restores cursor, clears screen, exit 0)
#
# Never spawns a child (a detached rfork from inside a windowed child hits
# a known-buggy path) — everything is done in-process.

extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_yield() -> int32


# --- capacity --------------------------------------------------------
MAX_LINES:   uint64 = 1024          # bounded ring of most-recent lines
LINE_CAP:    uint64 = 256          # bytes stored per line (capped width)
SNAP_CAP:    uint64 = 65536         # raw /proc/kmsg snapshot buffer
SCREEN_ROWS: uint64 = 22            # visible log rows (status bar is +1)
POLL_TICKS:  uint64 = 64            # sys_yield iterations between refreshes

# Line storage: a flat pool of MAX_LINES slots, each LINE_CAP bytes.
# Lines are stored chronologically. When more than MAX_LINES lines exist
# we keep the newest MAX_LINES and flag truncation.
lines: Array[262144, uint8]         # MAX_LINES * LINE_CAP
line_len: Array[1024, uint64]       # live byte count of each line
num_lines: uint64 = 0
truncated: int32 = 0                # 1 if older lines were dropped

# Raw snapshot scratch (one full read of /proc/kmsg).
snap_buf: Array[65536, uint8]
snap_len: uint64 = 0

# Filtered view: indices into `lines` that match the active filter. When
# the filter is empty this lists every line in order.
view_idx: Array[1024, uint64]
view_count: uint64 = 0

# Viewport: top is the first VIEW row shown on screen.
top: uint64 = 0

# Follow mode: when on, the viewport stays pinned to the tail and we
# re-snapshot the log periodically.
follow: int32 = 1
running: int32 = 1
poll_counter: uint64 = 0

# Escape-parser state: 0 ground, 1 saw ESC, 2 saw ESC[ (CSI).
esc_state: int32 = 0
esc_param: uint64 = 0

# Incremental filter ('/'): when filtering != 0, typed bytes accumulate
# into query; only lines CONTAINING the query are shown. Fixed buffer.
QUERY_CAP: uint64 = 64
filtering: int32 = 0                # 1 while editing the filter prompt
query: Array[64, uint8]
query_len: uint64 = 0
filter_active: int32 = 0           # 1 once a non-empty filter is committed


# ====================================================================
# Small string helpers
# ====================================================================
def cstr_len(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_cstr(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, cstr_len(s))


# Write an unsigned decimal number to fd 1.
def write_u64(v: uint64):
    if v == 0:
        write_cstr(1, cast[Ptr[uint8]]("0"))
        return
    tmp: Array[20, uint8]
    n: uint64 = 0
    while v > 0:
        tmp[n] = cast[uint8](48 + v % 10)
        v = v / 10
        n = n + 1
    # tmp holds the digits reversed; emit in order.
    out: Array[20, uint8]
    i: uint64 = 0
    while i < n:
        out[i] = tmp[n - 1 - i]
        i = i + 1
    sys_write(1, &out[0], n)


# Pointer to the first byte of line `i`'s slot in the pool.
def line_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&lines[0]) + i * LINE_CAP)


# ====================================================================
# Log ingest
# ====================================================================
# Take a fresh snapshot of /proc/kmsg into snap_buf. Returns the number
# of bytes read (0 if the source is empty or unavailable).
def snapshot_log() -> uint64:
    snap_len = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/proc/kmsg"))
    if fd < 0:
        return 0
    while snap_len < SNAP_CAP:
        want: uint64 = SNAP_CAP - snap_len
        if want > 4096:
            want = 4096
        got: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](&snap_buf[0]) + snap_len), want)
        if got <= 0:
            break
        snap_len = snap_len + cast[uint64](got)
    sys_close(fd)
    return snap_len


# Append one line [start, end) of snap_buf into the line ring. When the
# ring is full, drop the oldest line (shift down) and flag truncation.
def push_line(start: uint64, end: uint64):
    raw: uint64 = end - start
    store: uint64 = raw
    if store > LINE_CAP - 1:
        store = LINE_CAP - 1
    if num_lines >= MAX_LINES:
        # Ring full: shift everything down by one slot, dropping line 0.
        i: uint64 = 1
        while i < MAX_LINES:
            src: Ptr[uint8] = line_ptr(i)
            dst: Ptr[uint8] = line_ptr(i - 1)
            sl: uint64 = line_len[i]
            k: uint64 = 0
            while k < sl:
                dst[k] = src[k]
                k = k + 1
            line_len[i - 1] = sl
            i = i + 1
        num_lines = MAX_LINES - 1
        truncated = 1
    dst2: Ptr[uint8] = line_ptr(num_lines)
    k2: uint64 = 0
    while k2 < store:
        c: uint8 = snap_buf[start + k2]
        # Strip a trailing carriage return; keep other printables/tab.
        dst2[k2] = c
        k2 = k2 + 1
    line_len[num_lines] = store
    num_lines = num_lines + 1


# Parse snap_buf into the line ring, splitting on '\n'. A trailing
# partial line (no newline) is included too.
def parse_snapshot():
    num_lines = 0
    truncated = 0
    i: uint64 = 0
    start: uint64 = 0
    while i < snap_len:
        c: uint8 = snap_buf[i]
        if c == 10:                     # '\n' ends a line
            end: uint64 = i
            # Drop a trailing '\r' if present.
            if end > start and snap_buf[end - 1] == 13:
                end = end - 1
            push_line(start, end)
            start = i + 1
        i = i + 1
    # Trailing partial line with no newline.
    if start < snap_len:
        end2: uint64 = snap_len
        if end2 > start and snap_buf[end2 - 1] == 13:
            end2 = end2 - 1
        push_line(start, end2)


# ====================================================================
# Filtering
# ====================================================================
# 1 if line `i` contains query[0..query_len) as a substring.
def line_matches(i: uint64) -> int32:
    if query_len == 0:
        return 1
    ll: uint64 = line_len[i]
    if query_len > ll:
        return 0
    p: Ptr[uint8] = line_ptr(i)
    last: uint64 = ll - query_len
    s: uint64 = 0
    while s <= last:
        k: uint64 = 0
        ok: int32 = 1
        while k < query_len:
            if p[s + k] != query[k]:
                ok = 0
                break
            k = k + 1
        if ok != 0:
            return 1
        s = s + 1
    return 0


# Rebuild view_idx from the line ring under the active filter.
def rebuild_view():
    view_count = 0
    i: uint64 = 0
    while i < num_lines:
        if line_matches(i) != 0:
            view_idx[view_count] = i
            view_count = view_count + 1
        i = i + 1


# Pin the viewport to the bottom (tail) of the current view.
def pin_bottom():
    if view_count <= SCREEN_ROWS:
        top = 0
    else:
        top = view_count - SCREEN_ROWS


def clamp_top():
    if view_count <= SCREEN_ROWS:
        top = 0
        return
    maxtop: uint64 = view_count - SCREEN_ROWS
    if top > maxtop:
        top = maxtop


# Full reload: snapshot -> parse -> rebuild filtered view. If `keep_pin`
# and follow is on, pin to the tail; otherwise preserve scroll position.
def reload(keep_pin: int32):
    snapshot_log()
    parse_snapshot()
    rebuild_view()
    if keep_pin != 0 and follow != 0:
        pin_bottom()
    else:
        clamp_top()


# ====================================================================
# Rendering
# ====================================================================
def redraw():
    write_cstr(1, cast[Ptr[uint8]]("\x1b[?25l\x1b[H"))
    # Header.
    write_cstr(1, cast[Ptr[uint8]]("\r\x1b[K\x1b[7m hlog  kernel log "))
    if truncated != 0:
        write_cstr(1, cast[Ptr[uint8]]("(older lines truncated) "))
    write_cstr(1, cast[Ptr[uint8]]("\x1b[0m\r\n"))
    # Body: SCREEN_ROWS view lines starting at `top`.
    r: uint64 = 0
    while r < SCREEN_ROWS:
        vi: uint64 = top + r
        write_cstr(1, cast[Ptr[uint8]]("\r\x1b[K"))
        if vi < view_count:
            li: uint64 = view_idx[vi]
            p: Ptr[uint8] = line_ptr(li)
            ll: uint64 = line_len[li]
            # Emit only printable bytes / tab so control chars never
            # corrupt the ANSI screen.
            k: uint64 = 0
            while k < ll:
                c: uint8 = p[k]
                if c >= 32 or c == 9:
                    sys_write(1, cast[Ptr[uint8]](cast[uint64](&lines[0]) + li * LINE_CAP + k), 1)
                k = k + 1
        write_cstr(1, cast[Ptr[uint8]]("\r\n"))
        r = r + 1
    # Status bar.
    write_cstr(1, cast[Ptr[uint8]]("\r\x1b[K\x1b[7m "))
    if filtering != 0:
        # Live filter prompt.
        write_cstr(1, cast[Ptr[uint8]]("filter:/"))
        if query_len > 0:
            sys_write(1, &query[0], query_len)
    else:
        if follow != 0:
            write_cstr(1, cast[Ptr[uint8]]("FOLLOW "))
        else:
            write_cstr(1, cast[Ptr[uint8]]("PAUSED "))
        write_cstr(1, cast[Ptr[uint8]](" lines:"))
        write_u64(view_count)
        if filter_active != 0:
            write_cstr(1, cast[Ptr[uint8]]("  /"))
            sys_write(1, &query[0], query_len)
        write_cstr(1, cast[Ptr[uint8]]("  j/k scroll  g/G top/tail  PgUp/PgDn  f follow  / filter  q quit"))
    write_cstr(1, cast[Ptr[uint8]]("\x1b[0m"))
    write_cstr(1, cast[Ptr[uint8]]("\x1b[H"))
    write_cstr(1, cast[Ptr[uint8]]("\x1b[?25h"))


# ====================================================================
# Scrolling actions (all manual scroll DISENGAGES follow)
# ====================================================================
def scroll_down():
    follow = 0
    if view_count <= SCREEN_ROWS:
        top = 0
        return
    if top + SCREEN_ROWS < view_count:
        top = top + 1


def scroll_up():
    follow = 0
    if top > 0:
        top = top - 1


def page_down():
    follow = 0
    top = top + SCREEN_ROWS
    clamp_top()


def page_up():
    follow = 0
    if top > SCREEN_ROWS:
        top = top - SCREEN_ROWS
    else:
        top = 0


def go_top():
    follow = 0
    top = 0


def go_tail():
    follow = 1
    pin_bottom()


# ====================================================================
# Incremental filter ('/')
# ====================================================================
def apply_filter():
    # Re-snapshot so the filter sees the freshest log, then rebuild.
    rebuild_view()
    clamp_top()


def handle_filter(c: uint8):
    if c == 13 or c == 10:              # Enter — commit
        filtering = 0
        if query_len > 0:
            filter_active = 1
        else:
            filter_active = 0
        apply_filter()
        return
    if c == 27:                         # ESC — clear the filter
        filtering = 0
        filter_active = 0
        query_len = 0
        rebuild_view()
        clamp_top()
        return
    if c == 8 or c == 127:              # Backspace — widen
        if query_len > 0:
            query_len = query_len - 1
    elif c >= 32 and query_len < QUERY_CAP:
        query[query_len] = c
        query_len = query_len + 1
    # Incremental: re-filter on every edit.
    apply_filter()


# ====================================================================
# Key dispatch
# ====================================================================
def handle_key(c: uint8):
    if c == 113:                        # 'q' — quit
        running = 0
    elif c == 106:                      # 'j' — down
        scroll_down()
    elif c == 107:                      # 'k' — up
        scroll_up()
    elif c == 103:                      # 'g' — top
        go_top()
    elif c == 71:                       # 'G' — tail + re-engage follow
        go_tail()
    elif c == 102:                      # 'f' — toggle follow
        if follow != 0:
            follow = 0
        else:
            follow = 1
            pin_bottom()
    elif c == 47:                       # '/' — start incremental filter
        filtering = 1
        query_len = 0


def dispatch(c: uint8):
    if filtering != 0:
        handle_filter(c)
    else:
        handle_key(c)


def feed_byte(c: uint8):
    if esc_state == 1:
        if c == 91:                     # '[' — CSI
            esc_state = 2
            esc_param = 0
            return
        esc_state = 0
        dispatch(27)
        dispatch(c)
        return
    if esc_state == 2:
        if c >= 48 and c <= 57:         # accumulate a numeric parameter
            esc_param = esc_param * 10 + cast[uint64](c - 48)
            return
        esc_state = 0
        if filtering != 0:
            return                       # ignore cursor keys while typing filter
        if c == 65:                     # Up
            scroll_up()
        elif c == 66:                   # Down
            scroll_down()
        elif c == 72:                   # 'H' — Home
            go_top()
        elif c == 70:                   # 'F' — End
            go_tail()
        elif c == 126:                  # '~' — PgUp/PgDn/Home/End finalizer
            if esc_param == 6:          # ESC [ 6 ~ — Page Down
                page_down()
            elif esc_param == 5:        # ESC [ 5 ~ — Page Up
                page_up()
            elif esc_param == 1:        # ESC [ 1 ~ — Home
                go_top()
            elif esc_param == 7:        # ESC [ 7 ~ — Home (rxvt)
                go_top()
            elif esc_param == 4:        # ESC [ 4 ~ — End
                go_tail()
            elif esc_param == 8:        # ESC [ 8 ~ — End (rxvt)
                go_tail()
        return
    if c == 27:
        esc_state = 1
        return
    dispatch(c)


# ====================================================================
# Main loop
# ====================================================================
def main() -> int32:
    # Initial load: snapshot the kernel log and tail it.
    follow = 1
    reload(1)
    pin_bottom()

    # Readiness banner: a stable one-line marker emitted to stdout BEFORE
    # the first repaint so a driving test can poll the serial log and only
    # start sending keys once hlog owns the raw console. Plain ASCII, no
    # ANSI, so it survives screen clears in the log.
    write_cstr(1, cast[Ptr[uint8]]("HLOG_READY\n"))

    write_cstr(1, cast[Ptr[uint8]]("\x1b[2J\x1b[H"))
    redraw()

    rb: Array[1, uint8]
    while running != 0:
        n: int64 = sys_read_nb(0, &rb[0], 1)
        if n < 0:
            break
        if n == 0:
            # No key pending: in FOLLOW mode, periodically re-snapshot the
            # log so new kernel lines stream in without busy-spinning. We
            # only refresh every POLL_TICKS yields to stay cool.
            sys_yield()
            if follow != 0 and filtering == 0:
                poll_counter = poll_counter + 1
                if poll_counter >= POLL_TICKS:
                    poll_counter = 0
                    old_count: uint64 = view_count
                    reload(1)
                    if view_count != old_count:
                        redraw()
            continue
        feed_byte(rb[0])
        if running != 0:
            redraw()

    write_cstr(1, cast[Ptr[uint8]]("\x1b[2J\x1b[H\x1b[?25h"))
    return 0

# user/primary_paste_chain_host.ad — QEMU-free, DETERMINISTIC host gate for the
# FULL cross-surface X11 PRIMARY paste chain (the "highlight in one text surface,
# middle-click, the text lands" user scenario), end to end, minus only the
# compositor's pixel delivery.
#
# The existing gates each cover one link:
#   * snarf_primary_host  — the dual buffer + path routing (buffer API);
#   * htb_evt_paste_host  — a raw pointer WIRE LINE -> the hamtextbox box paste;
#   * htermsel_host       — the terminal grid extractor in isolation.
# NONE joins the terminal EXTRACTOR to a real PRIMARY buffer and then drives a
# raw compositor-shaped MIDDLE-click wire line back through the shared rising-
# edge detector to prove the extracted text is what a paste would read. That
# join is exactly the path the user exercises (highlight terminal output ->
# middle-click -> paste), so this gate builds it from the REAL pieces:
#
#   terminal grid --htsel_begin/extend/extract--> selected TEXT
#                 --_route_put(/dev/snarf.primary)--> the real devsnarf primary_buf
#   raw "m <x> <y> 4 0" wire line --htb_evt_parse_m--> buttons=4 (MIDDLE)
#                 --htb_mid_edge(4, prev)--> rising edge fires ONCE (held = no repeat)
#   --_route_get(/dev/snarf.primary)--> read-back == the terminal's extracted text
#
# It also asserts a SECOND surface (the editor/Notes hamtextbox path selector)
# reads the SAME buffer the terminal published — the cross-app case (highlight in
# the terminal, middle-paste in the editor).
#
# Pure logic, no DE, no compositor, no flaky mouse injection — the deterministic
# proof of the consumer path the on-device haminput inspector confirms live.

from sys.src.port9.port.devsnarf import devsnarf_primary_write, \
    devsnarf_primary_read, devsnarf_write, devsnarf_read
from lib.htermsel import htsel_reset, htsel_begin, htsel_extend, htsel_active, \
    htsel_extract, _htsel_clip_path
from lib.hamtextbox import htb_evt_parse_m, htb_mid_edge, _htb_clip_path

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_fails:  int32 = 0
_passes: int32 = 0

# Synthetic terminal grid (matches htermsel_host's row-major layout).
STRIDE: uint64 = 40
COLS:   uint64 = 40
ROWS:   uint64 = 4
grid:     Array[160, uint8]
grid_len: Array[4, uint64]


def _puts(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(1, s, n)


def _putn(v: int64):
    x: uint64 = cast[uint64](v)
    d: Array[24, uint8]
    n: uint64 = 0
    if x == 0:
        d[0] = 48
        n = 1
    else:
        while x > 0:
            d[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
    out: Array[26, uint8]
    p: uint64 = 0
    i: uint64 = n
    while i > 0:
        i = i - 1
        out[p] = d[i]
        p = p + 1
    sys_write(1, &out[0], p)


def _check(cond: int32, name: Ptr[uint8]):
    if cond != 0:
        _passes = _passes + 1
        _puts(cast[Ptr[uint8]]("[prim-chain] PASS "))
    else:
        _fails = _fails + 1
        _puts(cast[Ptr[uint8]]("[prim-chain] FAIL "))
    _puts(name)
    _puts(cast[Ptr[uint8]]("\n"))


def _ceq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] != b[i]:
        return 0
    return 1


def _check_text(out: Ptr[uint8], n: uint64, want: Ptr[uint8], name: Ptr[uint8]):
    wl: uint64 = 0
    while want[wl] != 0:
        wl = wl + 1
    ok: int32 = 1
    if n != wl:
        ok = 0
    else:
        i: uint64 = 0
        while i < n:
            if out[i] != want[i]:
                ok = 0
            i = i + 1
    if ok != 0:
        _passes = _passes + 1
        _puts(cast[Ptr[uint8]]("[prim-chain] PASS "))
        _puts(name)
        _puts(cast[Ptr[uint8]]("\n"))
    else:
        _fails = _fails + 1
        _puts(cast[Ptr[uint8]]("[prim-chain] FAIL "))
        _puts(name)
        _puts(cast[Ptr[uint8]](" got=\""))
        sys_write(1, out, n)
        _puts(cast[Ptr[uint8]](" want=\""))
        _puts(want)
        _puts(cast[Ptr[uint8]]("\"\n"))


def _set_row(r: uint64, s: Ptr[uint8]):
    n: uint64 = 0
    base: uint64 = r * STRIDE
    while s[n] != 0:
        grid[base + n] = s[n]
        n = n + 1
    grid_len[r] = n


# Kernel path->buffer routing shim (exact-match, PRIMARY leaf first — mirrors
# sys/src/9/port/namec.ad). Same shim the sibling host gates use.
def _route_put(path: Ptr[char], buf: Ptr[uint8], n: uint64) -> int32:
    p: Ptr[uint8] = cast[Ptr[uint8]](path)
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf.primary")) != 0:
        devsnarf_primary_write(buf, n)
        return 1
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf")) != 0:
        devsnarf_write(buf, n)
        return 1
    return 0


def _route_get(path: Ptr[char], out: Ptr[uint8], cap: uint64) -> uint64:
    p: Ptr[uint8] = cast[Ptr[uint8]](path)
    total: uint64 = 0
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf.primary")) != 0:
        while total < cap:
            r: int64 = devsnarf_primary_read(total, &out[total], cap - total)
            if r <= 0:
                break
            total = total + cast[uint64](r)
        return total
    if _ceq(p, cast[Ptr[uint8]]("/dev/snarf")) != 0:
        while total < cap:
            r2: int64 = devsnarf_read(total, &out[total], cap - total)
            if r2 <= 0:
                break
            total = total + cast[uint64](r2)
        return total
    return total


# Parse one "m <x> <y> <buttons> <dz>" wire line and return the buttons bitmap
# (-1 on a malformed line). Uses the SAME parser the shipped apps run.
def _wire_buttons(line: Ptr[uint8], n: uint64) -> int64:
    bx: int64 = 0
    by: int64 = 0
    bbtn: int64 = 0
    bdz: int64 = 0
    if htb_evt_parse_m(line, n, &bx, &by, &bbtn, &bdz) == 0:
        return -1
    return bbtn


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    out: Array[256, uint8]

    # 1) Build a terminal grid holding a shell error the user wants to copy.
    _set_row(0, cast[Ptr[uint8]]("$ make"))
    _set_row(1, cast[Ptr[uint8]]("make: *** [all] Error 2"))
    _set_row(2, cast[Ptr[uint8]]("$ "))
    grid_len[3] = 0

    # 2) Drag-select the whole error line (row 1) exactly as a left-drag would:
    #    press at (1,0), extend to (1,end). Then extract the span -> TEXT.
    htsel_reset()
    htsel_begin(1, 0)
    htsel_extend(1, cast[int64](grid_len[1]))
    _check(htsel_active() != 0, cast[Ptr[uint8]]("drag_selects_error_line"))
    sel: Array[256, uint8]
    sn: uint64 = htsel_extract(&grid[0], &grid_len[0], STRIDE, COLS,
                               &sel[0], 256)
    _check_text(&sel[0], sn, cast[Ptr[uint8]]("make: *** [all] Error 2"),
                cast[Ptr[uint8]]("extract_matches_error_line"))

    # 3) On drag-RELEASE the terminal publishes the extracted text to PRIMARY.
    _route_put(_htsel_clip_path(1), &sel[0], sn)

    # 4) A MIDDLE-click arrives as the compositor's raw wire line "m x y 4 0".
    #    Parse it with the real parser; assert the MIDDLE bit (bit2) survives.
    mid_line: Ptr[uint8] = cast[Ptr[uint8]]("m 48 28 4 0")
    btn: int64 = _wire_buttons(mid_line, 11)
    _check(cast[int32](btn) == 4, cast[Ptr[uint8]]("wire_line_carries_middle_bit"))

    # 5) The shared rising-edge detector fires ONCE (prev had no middle)...
    _check(htb_mid_edge(btn, 0) != 0,
           cast[Ptr[uint8]]("middle_rising_edge_fires"))
    # ...and a HELD middle button (prev already had bit2) does NOT re-fire.
    _check(htb_mid_edge(btn, 4) == 0,
           cast[Ptr[uint8]]("held_middle_does_not_repeat"))
    # A left-only line must NOT trip the middle-paste edge.
    lbtn: int64 = _wire_buttons(cast[Ptr[uint8]]("m 48 28 1 0"), 11)
    _check(htb_mid_edge(lbtn, 0) == 0,
           cast[Ptr[uint8]]("left_click_is_not_a_middle_paste"))

    # 6) The paste consumer reads PRIMARY back — the extracted text LANDED.
    pn: uint64 = _route_get(_htsel_clip_path(1), &out[0], 256)
    _check_text(&out[0], pn, cast[Ptr[uint8]]("make: *** [all] Error 2"),
                cast[Ptr[uint8]]("middle_click_pastes_extracted_text"))

    # 7) CROSS-APP: a SECOND surface (editor/Notes) resolves the SAME PRIMARY
    #    leaf, so a highlight in the terminal is middle-pasteable in the editor.
    _check(_ceq(cast[Ptr[uint8]](_htsel_clip_path(1)),
                cast[Ptr[uint8]](_htb_clip_path(1))) != 0,
           cast[Ptr[uint8]]("terminal_and_editor_share_primary_leaf"))
    en: uint64 = _route_get(_htb_clip_path(1), &out[0], 256)
    _check_text(&out[0], en, cast[Ptr[uint8]]("make: *** [all] Error 2"),
                cast[Ptr[uint8]]("editor_reads_terminal_published_primary"))

    _puts(cast[Ptr[uint8]]("[prim-chain] SUMMARY passes="))
    _putn(cast[int64](_passes))
    _puts(cast[Ptr[uint8]](" fails="))
    _putn(cast[int64](_fails))
    _puts(cast[Ptr[uint8]]("\n"))
    if _fails == 0:
        _puts(cast[Ptr[uint8]]("[prim-chain] RESULT PASS\n"))
        return 0
    _puts(cast[Ptr[uint8]]("[prim-chain] RESULT FAIL\n"))
    return 1

# user/shuf.ad
#
# Hamnix `shuf`: write a random permutation of the input lines.
#
#   shuf [FILE]        # default: shuffle stdin lines
#   shuf -n N          # output at most N lines of the permutation
#   shuf -i LO-HI      # shuffle the integer range LO..HI (inclusive)
#   shuf -e ARG...     # treat each ARG as an input line
#
# The PRNG (xorshift64) is seeded from sys_get_jiffies() XOR sys_getpid()
# so successive runs differ; no --random-source is needed. We index into
# a parallel offsets table and Fisher-Yates shuffle the indices, so we
# never move the (possibly long) line bytes themselves.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_getpid() -> int32


FILE_CAP: uint64 = 65536
MAX_LINES: uint64 = 8192

inbuf: Array[65536, uint8]
inlen: uint64 = 0

# Line table: line i is inbuf[lstart[i] .. lstart[i]+llen[i]).
lstart: Array[8192, uint64]
llen:   Array[8192, uint64]
nlines: uint64 = 0

# Shuffle order (indices into the line table).
order: Array[8192, uint64]

rng_state: uint64 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_u64(s: Ptr[uint8], len: uint64, out: Ptr[uint64]) -> int32:
    v: uint64 = 0
    i: uint64 = 0
    if len == 0:
        return -1
    while i < len:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        v = v * 10 + cast[uint64](c - 48)
        i = i + 1
    out[0] = v
    return 0


def rng_seed():
    s: uint64 = sys_get_jiffies()
    s = s ^ (cast[uint64](sys_getpid()) * 2654435761)
    # Avoid the zero fixed point of xorshift.
    if s == 0:
        s = 0x9e3779b97f4a7c15
    rng_state = s


def rng_next() -> uint64:
    x: uint64 = rng_state
    x = x ^ (x << 13)
    x = x ^ (x >> 7)
    x = x ^ (x << 17)
    rng_state = x
    return x


# Uniform integer in [0, bound). bound must be > 0.
def rng_below(bound: uint64) -> uint64:
    return rng_next() % bound


# Load a file (or stdin if fd already given) fully into inbuf.
def read_fd(fd: int32):
    total: uint64 = 0
    while total < FILE_CAP:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
                                cast[uint64](&inbuf[0]) + total),
                            FILE_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    inlen = total


# Split inbuf into the line table. A final unterminated fragment counts
# as a line (GNU shuf treats it as a line).
def split_lines():
    nlines = 0
    i: uint64 = 0
    while i < inlen and nlines < MAX_LINES:
        start: uint64 = i
        while i < inlen and inbuf[i] != 10:
            i = i + 1
        lstart[nlines] = start
        llen[nlines] = i - start
        nlines = nlines + 1
        if i < inlen:
            i = i + 1                  # skip the newline


# Append a synthetic line whose bytes are s[0..len) (copied into inbuf).
def append_line(s: Ptr[uint8], len: uint64):
    if nlines >= MAX_LINES:
        return
    if inlen + len > FILE_CAP:
        return
    dst: uint64 = cast[uint64](&inbuf[0]) + inlen
    k: uint64 = 0
    while k < len:
        cast[Ptr[uint8]](dst)[k] = s[k]
        k = k + 1
    lstart[nlines] = inlen
    llen[nlines] = len
    inlen = inlen + len
    nlines = nlines + 1


# Append the decimal text of v as a new line.
def append_int(v: uint64):
    digits: Array[24, uint8]
    i: uint64 = 0
    t: uint64 = v
    if t == 0:
        digits[0] = 48
        i = 1
    else:
        while t != 0:
            digits[i] = cast[uint8](t % 10) + 48
            t = t / 10
            i = i + 1
    tmp: Array[24, uint8]
    j: uint64 = 0
    while j < i:
        tmp[j] = digits[i - 1 - j]
        j = j + 1
    append_line(&tmp[0], i)


# Fisher-Yates shuffle of order[0..nlines).
def shuffle():
    k: uint64 = 0
    while k < nlines:
        order[k] = k
        k = k + 1
    if nlines < 2:
        return
    i: uint64 = nlines - 1
    while i > 0:
        j: uint64 = rng_below(i + 1)
        tmp: uint64 = order[i]
        order[i] = order[j]
        order[j] = tmp
        i = i - 1


def emit_line(idx: uint64):
    if llen[idx] > 0:
        sys_write(1, cast[Ptr[uint8]](
                        cast[uint64](&inbuf[0]) + lstart[idx]), llen[idx])
    sys_write(1, "\n", 1)


# Parse "LO-HI" into lo/hi. Returns 0 ok.
def parse_range(s: Ptr[uint8], lo: Ptr[uint64], hi: Ptr[uint64]) -> int32:
    slen: uint64 = strlen_u8(s)
    dash: uint64 = 0
    found: int32 = 0
    i: uint64 = 0
    while i < slen:
        if s[i] == 45:
            dash = i
            found = 1
            break
        i = i + 1
    if found == 0:
        return -1
    if parse_u64(s, dash, lo) != 0:
        return -1
    if parse_u64(cast[Ptr[uint8]](cast[uint64](s) + dash + 1),
                 slen - dash - 1, hi) != 0:
        return -1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    rng_seed()
    inlen = 0
    nlines = 0

    have_n: int32 = 0
    nlimit: uint64 = 0
    mode_i: int32 = 0
    mode_e: int32 = 0
    file_arg: int32 = 0

    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if mode_e != 0:
            break                                      # rest are -e args
        if a[0] == 45 and a[1] != 0:
            if a[1] == 110:                            # "-n..."
                src: Ptr[uint8] = cast[Ptr[uint8]](0)
                if a[2] != 0:
                    src = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "shuf: option requires an argument -- n\n")
                        return 1
                    ai = ai + 1
                    src = cast[Ptr[uint8]](argv[cast[uint64](ai)])
                if parse_u64(src, strlen_u8(src), &nlimit) != 0:
                    write_str(2, "shuf: invalid -n value\n")
                    return 1
                have_n = 1
                ai = ai + 1
            elif a[1] == 105:                          # "-i LO-HI"
                src: Ptr[uint8] = cast[Ptr[uint8]](0)
                if a[2] != 0:
                    src = cast[Ptr[uint8]](cast[uint64](a) + 2)
                else:
                    if ai + 1 >= argc:
                        write_str(2, "shuf: option requires an argument -- i\n")
                        return 1
                    ai = ai + 1
                    src = cast[Ptr[uint8]](argv[cast[uint64](ai)])
                lo: uint64 = 0
                hi: uint64 = 0
                if parse_range(src, &lo, &hi) != 0:
                    write_str(2, "shuf: invalid input range\n")
                    return 1
                if hi >= lo:
                    v: uint64 = lo
                    while v <= hi and nlines < MAX_LINES:
                        append_int(v)
                        if v == hi:
                            break
                        v = v + 1
                mode_i = 1
                ai = ai + 1
            elif a[1] == 101 and a[2] == 0:            # "-e"
                mode_e = 1
                ai = ai + 1
            else:
                write_str(2, "shuf: unknown flag\n")
                return 1
        else:
            if file_arg == 0:
                file_arg = ai
            ai = ai + 1

    # -e: remaining argv are the input lines.
    if mode_e != 0:
        while ai < argc:
            s: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
            append_line(s, strlen_u8(s))
            ai = ai + 1
    elif mode_i == 0:
        # File or stdin input.
        fd: int32 = 0
        if file_arg != 0:
            fd = sys_open(cast[Ptr[char]](argv[cast[uint64](file_arg)]))
            if fd < 0:
                write_str(2, "shuf: cannot open input\n")
                return 1
        read_fd(fd)
        if file_arg != 0:
            sys_close(fd)
        split_lines()

    shuffle()

    count: uint64 = nlines
    if have_n != 0 and nlimit < count:
        count = nlimit
    k: uint64 = 0
    while k < count:
        emit_line(order[k])
        k = k + 1
    return 0

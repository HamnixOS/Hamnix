def lock_drain_verify(scr_w: int64, scr_h: int64):
    # Snapshot read of /dev/wsys/lock/verify. On a serial bump, copy the
    # typed password into lock_pw_buf and call lock_pw_try() — that's
    # the existing compositor-side decision (on match: LOCKED=0,
    # LOCK_FAILS=0; on mismatch: LOCK_FAILS++). Then republish so the
    # client sees the updated counter (or the cleared lock).
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/lock/verify"))
    if fd < 0:
        return
    n: int64 = sys_read_nb(fd, &lock_verify_buf[0], 192)
    sys_close(fd)
    if n <= 0:
        return
    cap: uint64 = cast[uint64](n)
    p: uint64 = 0
    serial: uint64 = 0
    while p < cap and lock_verify_buf[p] >= 48 \
            and lock_verify_buf[p] <= 57:
        serial = serial * 10 + cast[uint64](lock_verify_buf[p] - 48)
        p = p + 1
    if serial == 0:
        return
    if serial == lock_last_verify_serial:
        return
    if p < cap and lock_verify_buf[p] == 32:
        p = p + 1
    ps: uint64 = p
    while p < cap and lock_verify_buf[p] != 10:
        p = p + 1
    pe: uint64 = p
    lock_last_verify_serial = serial
    # Copy the typed password into lock_pw_buf (capped at LOCK_PW_CAP-1)
    # then call the existing lock_pw_try(). It owns the secret check +
    # LOCKED/LOCK_FAILS bookkeeping AND the unlock-ok/fail console line.
    LOCK_PW_LEN = 0
    plen: uint64 = pe - ps
    cap_pw: uint64 = cast[uint64](LOCK_PW_CAP) - 1
    if plen > cap_pw:
        plen = cap_pw
    i: uint64 = 0
    while i < plen:
        lock_pw_buf[LOCK_PW_LEN] = lock_verify_buf[ps + i]
        LOCK_PW_LEN = LOCK_PW_LEN + 1
        i = i + 1
    lock_pw_buf[LOCK_PW_LEN] = 0
    lock_pw_try()
    # Republish so the client repaints with the updated LOCKED/LOCK_FAILS.
    lock_publish_snapshot()
    lock_poke_show()


# ====================================================================
# DE pivot wave 7 — rubber-band drag overlay = /bin/hamrband (separate
# process)
# ====================================================================
# The 1-pixel dashed band that follows the cursor during a click-and-
# drag-to-create gesture used to be painted in-daemon by
# scene_blit_rect_outline, called from post_present_overlays each frame.
# It now lives in /bin/hamrband (user/hamrband.ad), a v2 client that
# reads its model from /dev/wsys/rband and is poked via
# /dev/wsys/rband/set whenever the drag rect changes. The compositor
# still OWNS the gesture (DRAG_ACTIVE / DRAG_X0 / DRAG_Y0); only the
# RENDER moved out. Three glue routines:
#
#   1. rband_publish_snapshot() — pushes (active, x0, y0, x1, y1) to the
#      kernel via the /dev/wsys/ctl `rband` verb.
#   2. rband_spawn() — launches /bin/hamrband once on daemon startup. The
#      client stays resident; the overlay is "off" while active=0.
#   3. rband_poke_set() — writes /dev/wsys/rband/set to wake the client.
#   4. rband_publish_if_changed() — called from post_present_overlays
#      each frame. Diffs the current bbox against the last-published
#      tuple and only republishes + pokes when something changed (avoids
#      ctl-write churn on still frames).
rband_spawned: int32 = 0
rband_pub_buf: Array[128, uint8]
# Last-published tuple so we can diff each frame.
rband_last_active: int32 = -1
rband_last_x0: int64 = 0
rband_last_y0: int64 = 0
rband_last_x1: int64 = 0
rband_last_y1: int64 = 0


def rband_current(out_active: Ptr[int32],
                  out_x0: Ptr[int64], out_y0: Ptr[int64],
                  out_x1: Ptr[int64], out_y1: Ptr[int64]):
    if DRAG_ACTIVE != 0:
        out_active[0] = 1
        out_x0[0] = imin(DRAG_X0, CUR_X)
        out_y0[0] = imin(DRAG_Y0, CUR_Y)
        out_x1[0] = imax(DRAG_X0, CUR_X) + 1
        out_y1[0] = imax(DRAG_Y0, CUR_Y) + 1
    else:
        out_active[0] = 0
        out_x0[0] = 0
        out_y0[0] = 0
        out_x1[0] = 0
        out_y1[0] = 0


def rband_publish_snapshot():
    # Emit "rband <active> <x0> <y0> <x1> <y1>\n" into one /dev/wsys/ctl
    # write. Hostowner-only, matching the rest of the ctl.
    a_out: Array[1, int32]
    x0_out: Array[1, int64]
    y0_out: Array[1, int64]
    x1_out: Array[1, int64]
    y1_out: Array[1, int64]
    rband_current(&a_out[0], &x0_out[0], &y0_out[0], &x1_out[0], &y1_out[0])
    pos: uint64 = 0
    verb: Ptr[uint8] = "rband "
    k: uint64 = 0
    while verb[k] != 0:
        rband_pub_buf[pos] = verb[k]
        pos = pos + 1
        k = k + 1
    pos = pos + u64_to_dec(cast[uint64](a_out[0]), &rband_pub_buf[pos])
    rband_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](x0_out[0]), &rband_pub_buf[pos])
    rband_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](y0_out[0]), &rband_pub_buf[pos])
    rband_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](x1_out[0]), &rband_pub_buf[pos])
    rband_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](y1_out[0]), &rband_pub_buf[pos])
    rband_pub_buf[pos] = 10
    pos = pos + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &rband_pub_buf[0], pos)
    sys_close(fd)


def rband_poke_set():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/rband/set"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49                                       # '1'
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def rband_spawn(scr_w: int64, scr_h: int64):
    # Idempotent: only launch once. The rubber-band overlay is a long-
    # lived full-screen client (transparent unless the band is active).
    if rband_spawned != 0:
        return
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamrband"),
                             0, 0, scr_w, scr_h)
    rband_spawned = 1


def rband_publish_if_changed():
    a_out: Array[1, int32]
    x0_out: Array[1, int64]
    y0_out: Array[1, int64]
    x1_out: Array[1, int64]
    y1_out: Array[1, int64]
    rband_current(&a_out[0], &x0_out[0], &y0_out[0], &x1_out[0], &y1_out[0])
    changed: int32 = 0
    if a_out[0] != rband_last_active:
        changed = 1
    if x0_out[0] != rband_last_x0:
        changed = 1
    if y0_out[0] != rband_last_y0:
        changed = 1
    if x1_out[0] != rband_last_x1:
        changed = 1
    if y1_out[0] != rband_last_y1:
        changed = 1
    if changed == 0:
        return
    rband_last_active = a_out[0]
    rband_last_x0 = x0_out[0]
    rband_last_y0 = y0_out[0]
    rband_last_x1 = x1_out[0]
    rband_last_y1 = y1_out[0]
    rband_publish_snapshot()
    rband_poke_set()


def daemon_spawn_window_prog(prog: Ptr[char],
                             rx: int64, ry: int64, rw: int64, rh: int64):
    if DWIN_COUNT >= DMAX:
        return
    slot: uint64 = DWIN_COUNT
    # Two kernel pipes wire the child's stdio to this daemon:
    #   in_pipe:  parent writes [1], child reads  [0]  (keystrokes)
    #   out_pipe: child writes  [1], parent reads [0]  (shell output)
    in_ok:  int32 = sys_pipe(&in_pipe_d[0])
    out_ok: int32 = sys_pipe(&out_pipe_d[0])
    child_in:  int32 = -1
    child_out: int32 = -1
    parent_in_w:  int32 = -1
    parent_out_r: int32 = -1
    if in_ok == 0 and out_ok == 0:
        child_in     = in_pipe_d[0]      # child stdin  = read end
        parent_in_w  = in_pipe_d[1]      # parent keeps write end
        child_out    = out_pipe_d[1]     # child stdout = write end
        parent_out_r = out_pipe_d[0]     # parent keeps read end
    wid: int32 = -1
    # DE-terminal namespace fix: instead of bare-exec'ing `prog`, route
    # every DE window spawn through `/bin/hamsh /etc/rc.de-user <prog>
    # [<arg1>]`. The rc plants the regular-user namespace surface
    # (`#c /dev`, `#p /proc`, `#s /srv`, `#I /net`, `#w /dev/win`,
    # `#/ /n`) — the user-visible-files-as-capabilities set the bare
    # compositor Pgrp lacks — and then invokes `prog` as a child of
    # the rc-running hamsh. Drag-create with prog == /bin/hamsh and
    # no arg1 still works: the rc planted the binds and falls through
    # to the interactive REPL the drag-out window was meant to be.
    # hamsh main() reads argv[2]/argv[3] and stamps HAMNIX_DE_PROG /
    # HAMNIX_DE_PROG_ARG1 in the env so the rc can pick them up.
    hamsh_path: Ptr[char] = cast[Ptr[char]]("/bin/hamsh")
    rc_path: Ptr[char] = cast[Ptr[char]]("/etc/rc.de-user")
    arg_buf_d[0] = cast[uint64](hamsh_path)
    arg_buf_d[1] = cast[uint64](rc_path)
    arg_buf_d[2] = cast[uint64](prog)
    # An optional argv[1] for the SPAWNED prog set by spawn_set_arg1
    # (e.g. the file manager's start directory). Forwarded as argv[3]
    # so hamsh main() stamps HAMNIX_DE_PROG_ARG1 and the rc can pass
    # it onto the real prog.
    if spawn_arg1_set != 0:
        arg_buf_d[3] = cast[uint64](&spawn_arg1[0])
        arg_buf_d[4] = 0
    else:
        arg_buf_d[3] = 0
        arg_buf_d[4] = 0
    pid: int32 = -1
    if child_in >= 0 and child_out >= 0:
        # Real pipe fds -> the legacy integer-fd spawn path dups them into
        # the child's fd 0/1 (and binds /fd/0,1,2 on its private namespace),
        # so the spawned program talks to OUR pipes, not the serial console.
        pid = spawn(hamsh_path, &arg_buf_d[0],
                        child_in, child_out, cast[Ptr[uint64]](0))
    else:
        # Pipe allocation failed — fall back to the detached spawn so the
        # gesture still produces a (headless) window.
        pid = spawn(hamsh_path, &arg_buf_d[0],
                        -2, -2, cast[Ptr[uint64]](0))
    # Consume the optional argv[1] so it never leaks into the next spawn.
    spawn_arg1_set = 0
    if pid >= 0:
        wid = sys_wsys_alloc(cast[uint64](pid))
        if wid < 0:
            # Table full / dup — reap the child so we don't leak it.
            # #450 F6: SIGTERM → Plan-9 note "terminate" /proc/<pid>/note.
            p9_note(pid, cast[Ptr[uint8]]("terminate"))
    # The child has its own dup'd copies now; close OUR copies of the
    # child ends so the pipe EOF/refcounts stay correct.
    if child_in >= 0:
        sys_close(child_in)
    if child_out >= 0:
        sys_close(child_out)
    # Record the window + its terminal state.
    DWIN_X[slot] = rx
    DWIN_Y[slot] = ry
    DWIN_W[slot] = rw
    DWIN_H[slot] = rh
    DWIN_WID[slot] = wid
    DWIN_UID[slot] = NEXT_UID
    NEXT_UID = NEXT_UID + 1
    DWIN_PID[slot] = pid
    DWIN_IN_FD[slot]  = parent_in_w
    DWIN_OUT_FD[slot] = parent_out_r
    DWIN_PTR_FD[slot]  = -1            # event-surface fds opened lazily
    DWIN_KEYS_FD[slot] = -1
    # Grid geometry from the body region (window minus 2px border + title).
    body_w: int64 = rw - 4
    body_h: int64 = rh - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    DWIN_HIDDEN[slot] = 0
    DWIN_OPACITY[slot] = 255
    DWIN_VK[slot] = 0
    DWIN_MARKUP[slot] = 0              # set later if the window publishes "ui"
    markup_body_ready[slot] = 0
    evl_gen[slot] = -1              # EVLOOP: no body rasterized yet
    DWIN_APP[slot] = APP_TERM
    DWIN_SNAP[slot] = 0
    DWIN_SHADED[slot] = 0
    DWIN_SHADE_H[slot] = rh
    DWIN_ONTOP[slot] = 0
    DWIN_BELOW[slot] = 0                # ROUND-24: not kept-below by default
    DWIN_STICKY[slot] = 0               # ROUND-20: not sticky by default
    DWIN_FULL[slot] = 0                 # ROUND-22: not fullscreen by default
    DWIN_GROUP[slot] = 0               # ROUND-22: ungrouped
    DWIN_GROUP_ACTIVE[slot] = 0
    # New windows open on the CURRENT workspace, un-maximized.
    DWIN_WS[slot] = CUR_WS
    DWIN_MAXED[slot] = 0
    DWIN_SAVE_X[slot] = rx
    DWIN_SAVE_Y[slot] = ry
    DWIN_SAVE_W[slot] = rw
    DWIN_SAVE_H[slot] = rh
    # DEPERF #409: a brand-new window has no valid backbuffer yet — force a
    # first-composite render into its cache.
    WCACHE_VALID[slot] = 0
    DWIN_CONTENT_DIRTY[slot] = 1
    term_clear(slot)
    DWIN_COUNT = DWIN_COUNT + 1
    # If we got a real wid, plant a chrome layer on its draw surface so
    # the window is real on the wsys side too (best-effort).
    if wid >= 2:
        build_path(wid, cast[Ptr[uint8]](0), "ctl")
        cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
        if cf >= 0:
            cmd: Ptr[uint8] = "mklayer chrome markup\n"
            sys_write(cf, cmd, strlen_u8(cmd))
            sys_close(cf)
        # Register the spawned program path with the kernel via the
        # system-wide /dev/wsys/ctl `setapp <wid> <path>` verb so the
        # /dev/wsys/session snapshot — and the hamsession save/restore
        # helper that reads it — can replay this window on next login.
        ctlf: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
        if ctlf >= 0:
            setapp_buf: Array[160, uint8]
            sp: uint64 = 0
            sa: Ptr[uint8] = "setapp "
            ki: uint64 = 0
            while sa[ki] != 0:
                setapp_buf[sp] = sa[ki]
                sp = sp + 1
                ki = ki + 1
            # Decimal wid (always single digit since MAX_WINDOWS=9).
            wbuf: Array[8, uint8]
            wn: uint64 = u64_to_dec(cast[uint64](wid), &wbuf[0])
            wj: uint64 = 0
            while wj < wn and wbuf[wj] != 10:
                setapp_buf[sp] = wbuf[wj]
                sp = sp + 1
                wj = wj + 1
            setapp_buf[sp] = 32       # ' '
            sp = sp + 1
            # Program path. prog is Ptr[char]; cast to read bytes.
            ps: Ptr[uint8] = cast[Ptr[uint8]](prog)
            pi: uint64 = 0
            while ps[pi] != 0 and sp < 158:
                setapp_buf[sp] = ps[pi]
                sp = sp + 1
                pi = pi + 1
            setapp_buf[sp] = 10       # '\n'
            sp = sp + 1
            sys_write(ctlf, &setapp_buf[0], sp)
            sys_close(ctlf)


# Backwards-compatible drag-to-create spawn: launches an interactive
# hamsh into the dragged rectangle (the classic rio gesture). Delegates
# to the generalised path so there is one spawn implementation.
def daemon_spawn_window(rx: int64, ry: int64, rw: int64, rh: int64):
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamsh"), rx, ry, rw, rh)


# Increment-2 (MATE-mirror DE rewrite): "New Terminal" spawns the EXTERNAL
# /bin/hamterm as its OWN process and allocates it a wid — the component
# split. This replaces the old in-daemon, hand-drawn APP_TERM grid
# (daemon_spawn_app(APP_TERM, ...)) that conflated the terminal into the
# compositor process and forced the multi-second open lag the rewrite
# exists to kill. hamterm self-discovers its wid from /dev/wsys/self, binds
# via hamui_window_on, and composites its hamui "ui" markup body live; the
# spawn path damages only its own window rect (no full-screen recomposite).
# Delegates to the one generalised spawn implementation so there is a single
# place that allocates the wid + plants the chrome layer.
def daemon_spawn_terminal(rx: int64, ry: int64, rw: int64, rh: int64):
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamterm"), rx, ry, rw, rh)


# Open a built-in (in-process) application window of the given app kind.
# Unlike daemon_spawn_window_prog these have NO child process or pipes —
# their body is drawn and their input handled entirely inside the daemon.
def daemon_spawn_app(app: int32, rx: int64, ry: int64, rw: int64, rh: int64):
    if DWIN_COUNT >= DMAX:
        return
    slot: uint64 = DWIN_COUNT
    DWIN_X[slot] = rx
    DWIN_Y[slot] = ry
    DWIN_W[slot] = rw
    DWIN_H[slot] = rh
    DWIN_WID[slot] = -1
    DWIN_UID[slot] = NEXT_UID
    NEXT_UID = NEXT_UID + 1
    DWIN_PID[slot] = -1
    DWIN_IN_FD[slot]  = -1
    DWIN_OUT_FD[slot] = -1
    DWIN_PTR_FD[slot]  = -1            # built-in app: no wsys backing
    DWIN_KEYS_FD[slot] = -1
    DWIN_VK[slot] = 0
    DWIN_MARKUP[slot] = 0              # built-in apps draw procedurally
    markup_body_ready[slot] = 0
    evl_gen[slot] = -1              # EVLOOP: no body rasterized yet
    DWIN_APP[slot] = app
    DWIN_SNAP[slot] = 0
    DWIN_SHADED[slot] = 0
    DWIN_SHADE_H[slot] = rh
    DWIN_ONTOP[slot] = 0
    DWIN_BELOW[slot] = 0                # ROUND-24: not kept-below by default
    DWIN_STICKY[slot] = 0               # ROUND-20: not sticky by default
    DWIN_FULL[slot] = 0                 # ROUND-22: not fullscreen by default
    DWIN_GROUP[slot] = 0               # ROUND-22: ungrouped
    DWIN_GROUP_ACTIVE[slot] = 0
    DWIN_HIDDEN[slot] = 0
    DWIN_OPACITY[slot] = 255
    DWIN_WS[slot] = CUR_WS
    DWIN_MAXED[slot] = 0
    DWIN_SAVE_X[slot] = rx
    DWIN_SAVE_Y[slot] = ry
    DWIN_SAVE_W[slot] = rw
    DWIN_SAVE_H[slot] = rh
    body_w: int64 = rw - 4
    body_h: int64 = rh - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    term_clear(slot)
    if app == APP_CALC:
        CALC_ACC[slot] = 0
        CALC_CUR[slot] = 0
        CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        CALC_ERR[slot] = 0
    if app == APP_CTRLCENTER:
        CC_CAT[slot] = 0
    if app == APP_FILEMGR:
        # Default to "/" — callers (places_open / menu) override the path
        # with fm_set_path + fm_load_dir immediately after spawning.
        fm_set_path(slot, "/")
        fm_load_dir(slot)
    if app == APP_EDITOR:
        ed_reset(slot)
    # DEPERF #409: force a first-composite render into the new slot's cache.
    WCACHE_VALID[slot] = 0
    DWIN_CONTENT_DIRTY[slot] = 1
    DWIN_COUNT = DWIN_COUNT + 1


# Launch menu entry `i` into a fresh window. Each launch is cascaded a
# little down-right of the previous so several apps don't stack exactly
# on top of one another. The rectangle is clamped to stay below the panel
# and inside the framebuffer. Reuses the single spawn-into-window path.
LAUNCH_CASCADE: int64 = 0
def menu_launch(i: uint64, scr_w: int64, scr_h: int64):
    if i >= MENU_COUNT:
        return
    app: int32 = menu_app(i)
    w: int64 = 480
    h: int64 = 320
    # Built-in apps get sizes tuned to their layout.
    if app == APP_CALC:
        w = 220
        h = 300
    elif app == APP_SYSMON:
        w = 360
        h = 220
    elif app == APP_ABOUT:
        w = 360
        h = 180
    elif app == APP_FILEMGR:
        w = 480
        h = 340
    elif app == APP_EDITOR:
        w = 560
        h = 400
    # Clamp so the window fits on-screen below the panel.
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    # ROUND-21: smart placement — drop the new window where it overlaps the
    # existing windows on this workspace the least, rather than blindly
    # cascading (which buried windows after a few launches). On a fully
    # empty desktop this lands at the work-area origin; otherwise a tiny
    # cascade nudge is added so two same-size launches don't sit exactly on
    # top of each other when the desktop is empty.
    smart_place(w, h, scr_w, scr_h)
    rx: int64 = SMART_PX
    ry: int64 = SMART_PY
    step: int64 = (LAUNCH_CASCADE % 4) * 12
    rx = rx + step
    ry = ry + step
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    if i == 0:
        # "Terminal" (menu index 0): SPAWN the external /bin/hamterm as its
        # OWN process via daemon_spawn_terminal — the Increment-3a MATE-mirror
        # rewrite. This mirrors the desktop right-click "Open Terminal"
        # conversion (ctx_invoke i==0). Previously this entry fell through to
        # daemon_spawn_window_prog(menu_prog(0)) which spawned a raw /bin/hamsh
        # with no terminal toolkit chrome; now the Applications-menu Terminal
        # opens the real separate-process hamterm client.
        daemon_spawn_terminal(rx, ry, w, h)
    elif app >= 0:
        daemon_spawn_app(app, rx, ry, w, h)
        # Standalone file manager from the menu starts in /home.
        if app == APP_FILEMGR and DWIN_COUNT > 0:
            fms: uint64 = DWIN_COUNT - 1
            fm_set_path(fms, "/home")
            fm_load_dir(fms)
    else:
        # ROUND-22 session manager: entries 16 / 17 both spawn
        # /bin/hamsession; the verb (save / restore) is the argv[1] the
        # daemon_spawn_window_prog path consumes via spawn_set_arg1.
        if i == 16:
            spawn_set_arg1(cast[Ptr[uint8]]("save"))
        elif i == 17:
            spawn_set_arg1(cast[Ptr[uint8]]("restore"))
        daemon_spawn_window_prog(menu_prog(i), rx, ry, w, h)
    # Emit a deterministic serial marker so a self-test can assert the
    # launch fired (label, not path, to keep the marker human-readable).
    pfx: Ptr[uint8] = "PANEL launch "
    sys_write(1, pfx, strlen_u8(pfx))
    lbl: Ptr[uint8] = menu_label(i)
    sys_write(1, lbl, strlen_u8(lbl))
    nl: Ptr[uint8] = "\n"
    sys_write(1, nl, 1)
    # ROUND-7: surface a transient "launching" notification banner.
    notify_post("Launching", lbl)


# Copy ALL per-slot window state (geometry, terminal fds/state, and the
# character grid) from slot `src` to slot `dst`. Used to compact the
# window table when a window is destroyed and to reorder for raise.
def slot_copy(dst: uint64, src: uint64):
    if dst == src:
        return
    DWIN_X[dst]      = DWIN_X[src]
    DWIN_Y[dst]      = DWIN_Y[src]
    DWIN_W[dst]      = DWIN_W[src]
    DWIN_H[dst]      = DWIN_H[src]
    DWIN_WID[dst]    = DWIN_WID[src]
    DWIN_UID[dst]    = DWIN_UID[src]
    DWIN_PID[dst]    = DWIN_PID[src]
    DWIN_IN_FD[dst]  = DWIN_IN_FD[src]
    DWIN_OUT_FD[dst] = DWIN_OUT_FD[src]
    DWIN_PTR_FD[dst]  = DWIN_PTR_FD[src]
    DWIN_KEYS_FD[dst] = DWIN_KEYS_FD[src]
    DWIN_COLS[dst]   = DWIN_COLS[src]
    DWIN_ROWS[dst]   = DWIN_ROWS[src]
    DWIN_CUR_C[dst]  = DWIN_CUR_C[src]
    DWIN_CUR_R[dst]  = DWIN_CUR_R[src]
    DWIN_VT[dst]     = DWIN_VT[src]
    DWIN_HIDDEN[dst] = DWIN_HIDDEN[src]
    DWIN_VK[dst]     = DWIN_VK[src]
    DWIN_OPACITY[dst] = DWIN_OPACITY[src]
    DWIN_URGENT[dst] = DWIN_URGENT[src]
    DWIN_WS[dst]     = DWIN_WS[src]
    DWIN_MAXED[dst]  = DWIN_MAXED[src]
    DWIN_SAVE_X[dst] = DWIN_SAVE_X[src]
    DWIN_SAVE_Y[dst] = DWIN_SAVE_Y[src]
    DWIN_SAVE_W[dst] = DWIN_SAVE_W[src]
    DWIN_SAVE_H[dst] = DWIN_SAVE_H[src]
    DWIN_APP[dst]    = DWIN_APP[src]
    DWIN_SNAP[dst]   = DWIN_SNAP[src]
    DWIN_SHADED[dst]  = DWIN_SHADED[src]
    DWIN_SHADE_H[dst] = DWIN_SHADE_H[src]
    DWIN_ONTOP[dst]   = DWIN_ONTOP[src]
    DWIN_BELOW[dst]   = DWIN_BELOW[src]    # ROUND-24
    DWIN_STICKY[dst]  = DWIN_STICKY[src]   # ROUND-20
    DWIN_FULL[dst]    = DWIN_FULL[src]     # ROUND-22
    DWIN_FSAVE_X[dst] = DWIN_FSAVE_X[src]
    DWIN_FSAVE_Y[dst] = DWIN_FSAVE_Y[src]
    DWIN_FSAVE_W[dst] = DWIN_FSAVE_W[src]
    DWIN_FSAVE_H[dst] = DWIN_FSAVE_H[src]
    DWIN_GROUP[dst]        = DWIN_GROUP[src]
    DWIN_GROUP_ACTIVE[dst] = DWIN_GROUP_ACTIVE[src]
    CALC_ACC[dst]    = CALC_ACC[src]
    CALC_CUR[dst]    = CALC_CUR[src]
    CALC_OP[dst]     = CALC_OP[src]
    CALC_FRESH[dst]  = CALC_FRESH[src]
    CALC_ERR[dst]    = CALC_ERR[src]
    # Move the character grid wholesale (GRID_CELLS bytes).
    sb: uint64 = src * GRID_CELLS
    db: uint64 = dst * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[db + i] = term_grid[sb + i]
        i = i + 1
    # EVLOOP: markup-client identity travels with the window. The body
    # buffers are too big to move, so invalidate the cached body instead;
    # markup_sync treats a flagged-but-not-ready slot as due and
    # re-rasterizes it on the next present (gen-gating alone would
    # otherwise leave a compacted markup window blank forever).
    DWIN_MARKUP[dst] = DWIN_MARKUP[src]
    evl_gen[dst] = evl_gen[src]
    markup_body_ready[dst] = 0
    # DEPERF #409: a different window now lives in `dst`; its cached
    # backbuffer is stale. Invalidate so it refills on the next composite
    # (slot_copy runs only during table compaction on close — rare).
    WCACHE_VALID[dst] = 0
    DWIN_CONTENT_DIRTY[dst] = 1


# Raise window `slot` to the topmost paint position (last slot). The
# windows above it slide down one slot so paint/hit-test order stays a
# simple back-to-front array walk. MOVE_SLOT is rebased to the new
# position so an in-flight move keeps tracking the right window.
def daemon_raise_slot(slot: int64) -> int64:
    if slot < 0:
        return slot
    last: uint64 = DWIN_COUNT - 1
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return cast[int64](s)
    if s == last:
        # Already front-most: still record the focus in the MRU list.
        # ROUND-15: focusing a window satisfies any attention demand.
        DWIN_URGENT[s] = 0
        mru_touch(DWIN_UID[s])
        return cast[int64](s)
    # Stash the window being raised in the spare slot just past the
    # table (DMAX-sized arrays always have room: DWIN_COUNT <= DMAX, and
    # we hold the raised window aside while shifting), using slot DMAX-1
    # is unsafe when full — instead shift up then place at `last`.
    # Save raised window into temporaries via the spawn scratch grid is
    # complex; simplest correct approach: bubble it up with swaps.
    raised_uid: int32 = DWIN_UID[s]
    cur: uint64 = s
    while cur < last:
        slot_swap(cur, cur + 1)
        cur = cur + 1
    # ROUND-15: the now-focused window's attention demand is satisfied.
    DWIN_URGENT[last] = 0
    # Record the now-focused window at the head of the MRU list.
    mru_touch(raised_uid)
    return cast[int64](last)


# Swap two slots' full state. Implemented via a scratch slot would need
# extra grid storage; instead swap field-by-field and the grid cell-by-
# cell (bounded: GRID_CELLS per call, DMAX small).
def slot_swap(a: uint64, b: uint64):
    if a == b:
        return
    t0: int64 = DWIN_X[a]
    DWIN_X[a] = DWIN_X[b]
    DWIN_X[b] = t0
    t1: int64 = DWIN_Y[a]
    DWIN_Y[a] = DWIN_Y[b]
    DWIN_Y[b] = t1
    t2: int64 = DWIN_W[a]
    DWIN_W[a] = DWIN_W[b]
    DWIN_W[b] = t2
    t3: int64 = DWIN_H[a]
    DWIN_H[a] = DWIN_H[b]
    DWIN_H[b] = t3
    i0: int32 = DWIN_WID[a]
    DWIN_WID[a] = DWIN_WID[b]
    DWIN_WID[b] = i0
    iu: int32 = DWIN_UID[a]
    DWIN_UID[a] = DWIN_UID[b]
    DWIN_UID[b] = iu
    i1: int32 = DWIN_PID[a]
    DWIN_PID[a] = DWIN_PID[b]
    DWIN_PID[b] = i1
    i2: int32 = DWIN_IN_FD[a]
    DWIN_IN_FD[a] = DWIN_IN_FD[b]
    DWIN_IN_FD[b] = i2
    i3: int32 = DWIN_OUT_FD[a]
    DWIN_OUT_FD[a] = DWIN_OUT_FD[b]
    DWIN_OUT_FD[b] = i3
    ipf: int32 = DWIN_PTR_FD[a]
    DWIN_PTR_FD[a] = DWIN_PTR_FD[b]
    DWIN_PTR_FD[b] = ipf
    ikf: int32 = DWIN_KEYS_FD[a]
    DWIN_KEYS_FD[a] = DWIN_KEYS_FD[b]
    DWIN_KEYS_FD[b] = ikf
    t4: int64 = DWIN_COLS[a]
    DWIN_COLS[a] = DWIN_COLS[b]
    DWIN_COLS[b] = t4
    t5: int64 = DWIN_ROWS[a]
    DWIN_ROWS[a] = DWIN_ROWS[b]
    DWIN_ROWS[b] = t5
    t6: int64 = DWIN_CUR_C[a]
    DWIN_CUR_C[a] = DWIN_CUR_C[b]
    DWIN_CUR_C[b] = t6
    t7: int64 = DWIN_CUR_R[a]
    DWIN_CUR_R[a] = DWIN_CUR_R[b]
    DWIN_CUR_R[b] = t7
    i4: int32 = DWIN_VT[a]
    DWIN_VT[a] = DWIN_VT[b]
    DWIN_VT[b] = i4
    i5: int32 = DWIN_HIDDEN[a]
    DWIN_HIDDEN[a] = DWIN_HIDDEN[b]
    DWIN_HIDDEN[b] = i5
    i6: int32 = DWIN_VK[a]
    DWIN_VK[a] = DWIN_VK[b]
    DWIN_VK[b] = i6
    io: int32 = DWIN_OPACITY[a]
    DWIN_OPACITY[a] = DWIN_OPACITY[b]
    DWIN_OPACITY[b] = io
    iur: int32 = DWIN_URGENT[a]
    DWIN_URGENT[a] = DWIN_URGENT[b]
    DWIN_URGENT[b] = iur
    i7: int32 = DWIN_WS[a]
    DWIN_WS[a] = DWIN_WS[b]
    DWIN_WS[b] = i7
    i8: int32 = DWIN_MAXED[a]
    DWIN_MAXED[a] = DWIN_MAXED[b]
    DWIN_MAXED[b] = i8
    sx0: int64 = DWIN_SAVE_X[a]
    DWIN_SAVE_X[a] = DWIN_SAVE_X[b]
    DWIN_SAVE_X[b] = sx0
    sy0: int64 = DWIN_SAVE_Y[a]
    DWIN_SAVE_Y[a] = DWIN_SAVE_Y[b]
    DWIN_SAVE_Y[b] = sy0
    sw0: int64 = DWIN_SAVE_W[a]
    DWIN_SAVE_W[a] = DWIN_SAVE_W[b]
    DWIN_SAVE_W[b] = sw0
    sh0: int64 = DWIN_SAVE_H[a]
    DWIN_SAVE_H[a] = DWIN_SAVE_H[b]
    DWIN_SAVE_H[b] = sh0
    i9: int32 = DWIN_APP[a]
    DWIN_APP[a] = DWIN_APP[b]
    DWIN_APP[b] = i9
    i10: int32 = DWIN_SNAP[a]
    DWIN_SNAP[a] = DWIN_SNAP[b]
    DWIN_SNAP[b] = i10
    i11: int32 = DWIN_SHADED[a]
    DWIN_SHADED[a] = DWIN_SHADED[b]
    DWIN_SHADED[b] = i11
    sh9: int64 = DWIN_SHADE_H[a]
    DWIN_SHADE_H[a] = DWIN_SHADE_H[b]
    DWIN_SHADE_H[b] = sh9
    i12: int32 = DWIN_ONTOP[a]
    DWIN_ONTOP[a] = DWIN_ONTOP[b]
    DWIN_ONTOP[b] = i12
    ibl: int32 = DWIN_BELOW[a]             # ROUND-24
    DWIN_BELOW[a] = DWIN_BELOW[b]
    DWIN_BELOW[b] = ibl
    i13: int32 = DWIN_STICKY[a]            # ROUND-20
    DWIN_STICKY[a] = DWIN_STICKY[b]
    DWIN_STICKY[b] = i13
    i14: int32 = DWIN_FULL[a]              # ROUND-22
    DWIN_FULL[a] = DWIN_FULL[b]
    DWIN_FULL[b] = i14
    fx0: int64 = DWIN_FSAVE_X[a]
    DWIN_FSAVE_X[a] = DWIN_FSAVE_X[b]
    DWIN_FSAVE_X[b] = fx0
    fy0: int64 = DWIN_FSAVE_Y[a]
    DWIN_FSAVE_Y[a] = DWIN_FSAVE_Y[b]
    DWIN_FSAVE_Y[b] = fy0
    fw0: int64 = DWIN_FSAVE_W[a]
    DWIN_FSAVE_W[a] = DWIN_FSAVE_W[b]
    DWIN_FSAVE_W[b] = fw0
    fh0: int64 = DWIN_FSAVE_H[a]
    DWIN_FSAVE_H[a] = DWIN_FSAVE_H[b]
    DWIN_FSAVE_H[b] = fh0
    i15: int32 = DWIN_GROUP[a]
    DWIN_GROUP[a] = DWIN_GROUP[b]
    DWIN_GROUP[b] = i15
    i16: int32 = DWIN_GROUP_ACTIVE[a]
    DWIN_GROUP_ACTIVE[a] = DWIN_GROUP_ACTIVE[b]
    DWIN_GROUP_ACTIVE[b] = i16
    c0: int64 = CALC_ACC[a]
    CALC_ACC[a] = CALC_ACC[b]
    CALC_ACC[b] = c0
    c1: int64 = CALC_CUR[a]
    CALC_CUR[a] = CALC_CUR[b]
    CALC_CUR[b] = c1
    c2: int32 = CALC_OP[a]
    CALC_OP[a] = CALC_OP[b]
    CALC_OP[b] = c2
    c3: int32 = CALC_FRESH[a]
    CALC_FRESH[a] = CALC_FRESH[b]
    CALC_FRESH[b] = c3
    c4: int32 = CALC_ERR[a]
    CALC_ERR[a] = CALC_ERR[b]
    CALC_ERR[b] = c4
    ab: uint64 = a * GRID_CELLS
    bb: uint64 = b * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        g: uint8 = term_grid[ab + i]
        term_grid[ab + i] = term_grid[bb + i]
        term_grid[bb + i] = g
        i = i + 1
    # EVLOOP: markup-client identity travels with the window on a raise.
    # The body buffers are too big to swap; invalidate both cached bodies
    # so markup_sync (which treats flagged-but-not-ready as due) re-reads
    # them on the next present. Without this, gen-gating would leave a
    # raised markup window's body blank/stale forever.
    imk: int32 = DWIN_MARKUP[a]
    DWIN_MARKUP[a] = DWIN_MARKUP[b]
    DWIN_MARKUP[b] = imk
    eg: int64 = evl_gen[a]
    evl_gen[a] = evl_gen[b]
    evl_gen[b] = eg
    markup_body_ready[a] = 0
    markup_body_ready[b] = 0
    # DEPERF #409: a slot swap moves window state between cache slots and
    # changes which window is front-most (focus chrome). Rather than swap
    # the bulky per-slot backbuffers, invalidate both slots so each is
    # refilled (with the correct focus state) on the next composite. Slot
    # swaps happen only on a raise — a rare interactive event, not per frame.
    WCACHE_VALID[a] = 0
    WCACHE_VALID[b] = 0
    DWIN_CONTENT_DIRTY[a] = 1
    DWIN_CONTENT_DIRTY[b] = 1


# Destroy window `slot`: tear down its hamsh child + pipes, free the wid
# binding, then compact the table so paint order stays contiguous. Any
# in-flight move/close referencing a shifted slot is reset by the caller.
def daemon_close_slot(slot: int64):
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return
    # Tear down the child shell + the daemon's pipe ends so we don't leak
    # the process or the fds. SIGTERM the bound pid (best-effort), free
    # the wsys slot, and close both parent pipe ends.
    # Forget this window in the MRU Alt-Tab list before it's gone.
    mru_drop(DWIN_UID[s])
    pid: int32 = DWIN_PID[s]
    if pid > 0:
        # #450 F6: SIGTERM → Plan-9 note "terminate" /proc/<pid>/note.
        p9_note(pid, cast[Ptr[uint8]]("terminate"))
    wid: int32 = DWIN_WID[s]
    if wid >= 2:
        sys_wsys_free(wid)
    infd: int32 = DWIN_IN_FD[s]
    if infd >= 0:
        sys_close(infd)
    outfd: int32 = DWIN_OUT_FD[s]
    if outfd >= 0:
        sys_close(outfd)
    pfd: int32 = DWIN_PTR_FD[s]
    if pfd >= 0:
        sys_close(pfd)
    kfd: int32 = DWIN_KEYS_FD[s]
    if kfd >= 0:
        sys_close(kfd)
    # Compact: slide every higher slot down by one so paint order stays
    # a contiguous 0..DWIN_COUNT-1 back-to-front walk.
    last: uint64 = DWIN_COUNT - 1
    j: uint64 = s
    while j < last:
        slot_copy(j, j + 1)
        j = j + 1
    DWIN_COUNT = DWIN_COUNT - 1
    # DEPERF #409: whichever window is now front-most may have just gained
    # focus chrome (closing the old top changes who is DWIN_COUNT-1). Force
    # the new top window to re-render with its focused title bar.
    if DWIN_COUNT > 0:
        DWIN_CONTENT_DIRTY[DWIN_COUNT - 1] = 1


# ====================================================================
# Structured input-event delivery (per-window /dev/wsys/<wid> surface)
# ====================================================================
#
# The compositor OWNS pointer routing + focus, so it is the right (and
# only) party that knows which window an event belongs to and where the
# pointer sits in that window's LOCAL pixel space. These helpers surface
# that already-computed data to clients via the kernel event rings:
#
#   /dev/wsys/<wid>/pointer  "<type> <x> <y> <buttons> <dz>\n"
#                            type: m=motion d=down u=up s=scroll
#                            x,y : WINDOW-LOCAL pixels (screen - win origin,
#                                  inside the body; may be negative/>=size
#                                  while a drag is captured, which the
#                                  client can clamp)
#   /dev/wsys/<wid>/keys     "<type> <code>\n"  type: d=press u=release
#
# The fd is opened lazily and cached per slot (DWIN_PTR_FD / DWIN_KEYS_FD);
# only windows that own a real wsys wid (>= 2) have a backing file. A
# delivery to a built-in app window (wid -1) or a failed open is a silent
# no-op — the existing in-process app handlers still run, so nothing
# regresses.

evt_line: Array[64, uint8]            # scratch for one ASCII event line


def evt_emit_i64(out: Ptr[uint8], pos: uint64, v: int64) -> uint64:
    # Append a signed decimal to out[pos..]; returns the new position.
    if v < 0:
        out[pos] = 45                 # '-'
        pos = pos + 1
        v = -v
    return pos + u64_to_dec(cast[uint64](v), &out[pos])


def evt_ptr_fd_for(slot: uint64) -> int32:
    # Lazily open (write) /dev/wsys/<wid>/pointer for this slot. Returns
    # the fd, or -1 if the window has no wsys backing / the open failed.
    fd: int32 = DWIN_PTR_FD[slot]
    if fd >= 0:
        return fd
    if fd == -2:                      # prior open failed; don't retry
        return -1
    wid: int32 = DWIN_WID[slot]
    if wid < 2:
        return -1                     # built-in app: no wsys backing
    build_wsys_leaf(wid, "pointer")
    of: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if of < 0:
        DWIN_PTR_FD[slot] = -2
        return -1
    DWIN_PTR_FD[slot] = of
    return of


def evt_keys_fd_for(slot: uint64) -> int32:
    fd: int32 = DWIN_KEYS_FD[slot]
    if fd >= 0:
        return fd
    if fd == -2:
        return -1
    wid: int32 = DWIN_WID[slot]
    if wid < 2:
        return -1
    build_wsys_leaf(wid, "keys")
    of: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if of < 0:
        DWIN_KEYS_FD[slot] = -2
        return -1
    DWIN_KEYS_FD[slot] = of
    return of


def evt_emit_pointer(slot: int64, etype: uint8, sx: int64, sy: int64,
                     btn: int64, dz: int64):
    # Deliver one ROUTED pointer event to the window at `slot`. Screen
    # coords (sx,sy) are converted to WINDOW-LOCAL here using the slot's
    # current origin, so the client reads body-relative coordinates.
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return
    fd: int32 = evt_ptr_fd_for(s)
    if fd < 0:
        return
    lx: int64 = sx - DWIN_X[s]
    ly: int64 = sy - DWIN_Y[s]
    p: uint64 = 0
    evt_line[p] = etype
    p = p + 1
    evt_line[p] = 32
    p = p + 1
    p = evt_emit_i64(&evt_line[0], p, lx)
    evt_line[p] = 32
    p = p + 1
    p = evt_emit_i64(&evt_line[0], p, ly)
    evt_line[p] = 32
    p = p + 1
    p = evt_emit_i64(&evt_line[0], p, btn)
    evt_line[p] = 32
    p = p + 1
    p = evt_emit_i64(&evt_line[0], p, dz)
    evt_line[p] = 10
    p = p + 1
    sys_write(fd, &evt_line[0], p)


def evt_emit_key(slot: int64, etype: uint8, code: int64):
    # Deliver one key event to the FOCUSED window (caller passes the
    # focus slot). "<type> <code>\n".
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return
    fd: int32 = evt_keys_fd_for(s)
    if fd < 0:
        return
    p: uint64 = 0
    evt_line[p] = etype
    p = p + 1
    evt_line[p] = 32
    p = p + 1
    p = evt_emit_i64(&evt_line[0], p, code)
    evt_line[p] = 10
    p = p + 1
    sys_write(fd, &evt_line[0], p)


# Consume all currently-available mouse packets, updating CUR_X/CUR_Y
# and tracking the left-button edge for the drag gesture. Returns 1 if
# anything changed (cursor moved or button edge), else 0. The /dev/mouse
# fd is held in the mouse_fd global (opened once in cmd_daemon).
mouse_fd: int32 = -1
# P1a: set by daemon_apply_packet whenever a mouse packet mutates the
# SCENE (a click, a drag, a menu/hover-highlight change, a focus-raise) —
# as opposed to merely moving the pointer. The main loop reads it to
# choose the cheap cursor-move present vs a full recomposite, then clears
# it. A pure pointer move leaves it 0 so the cursor fast path runs.
MOUSE_SCENE_DIRTY: int32 = 0
# BUG 2: set when ONLY a title-bar hover highlight changed under the moving
# cursor (no click/drag/menu). The main loop damages just the two affected
# window rects instead of the whole screen, so plain mouse motion over windows
# stays cheap. MOUSE_HOVER_OLD/NEW carry the window slots that lost/gained the
# highlight (-1 = none / panel).
MOUSE_HOVER_DIRTY: int32 = 0
MOUSE_HOVER_OLD: int64 = -1
MOUSE_HOVER_NEW: int64 = -1
# [mousetest] observability: latched when daemon_apply_packet sees a
# RELATIVE motion packet (PS/2 path) / an ABSOLUTE tablet packet (USB
# usb-tablet path). Read by daemon_mouse_selftest (autoflag 50).
MT_REL_SEEN: int32 = 0
MT_ABS_SEEN: int32 = 0


def daemon_pump_mouse(scr_w: int64, scr_h: int64) -> int32:
    changed: int32 = 0
    iters: int32 = 0
    while iters < 64:
        n: int64 = sys_read_nb(mouse_fd, &mouse_buf[0], 256)
        iters = iters + 1
        if n <= 0:
            break
        i: uint64 = 0
        total: uint64 = cast[uint64](n)
        while i < total:
            ls: uint64 = i
            while i < total and mouse_buf[i] != 10:
                i = i + 1
            le: uint64 = i
            if i < total:
                i = i + 1
            if le > ls:
                applied: int32 = daemon_apply_packet(ls, le, scr_w, scr_h)
                # DE perf: decouple cursor render from compositor hot path.
                # After EVERY packet that updated CUR_X/CUR_Y, push the new
                # coords to the kernel overlay. This is the load-bearing
                # latency win: even if the rest of this frame then takes a
                # full daemon_present() (window drag, popup composite),
                # the cursor sprite already advanced on scanout via the
                # kernel write that happened HERE — between two pumps,
                # before the slow path ran. One small syscall per packet.
                kcursor_push_live()
                changed = applied | changed
    return changed


# Deliver a scroll-wheel notch to the focused window by injecting arrow-key
# CSI sequences into its stdin — the SAME path the live keyboard uses
# (key_route -> the child's DWIN_IN_FD pipe). Wheel-up (dz > 0) sends Up
# arrows (ESC [ A) so the TUI/shell scrolls toward older content; wheel-down
# sends Down arrows (ESC [ B). A shell maps these to history; a pager (less,
# man) maps them to line scroll — exactly the terminal-scroll convention.
# Returns 1 if any sequence was routed (scene needs a repaint), else 0.
WHEEL_MAX_NOTCH: int64 = 8       # clamp a violent flick so we don't flood
def daemon_scroll_focused(dz: int64, scr_w: int64, scr_h: int64) -> int32:
    if dz == 0:
        return 0
    # KEYSTROKE-ROUTE GATE: a wheel delta arrives as a synthetic ESC[A/B
    # keystroke into the focused window. While the WM owns the input
    # (window move / resize / rubber-band drag in flight), it must NOT
    # leak into the dragged window's shell.
    if wm_owns_input() != 0:
        return 0
    fslot: int64 = daemon_focus_slot()
    if fslot < 0:
        return 0
    # Only deliver to a window with a live child stdin pipe (a terminal /
    # TUI). Built-in calc/editor windows ignore arrow-scroll here.
    fs: uint64 = cast[uint64](fslot)
    if DWIN_IN_FD[fs] < 0:
        return 0
    final: uint8 = 66                # 'B' = Down  (wheel down)
    notches: int64 = -dz
    if dz > 0:
        final = 65                   # 'A' = Up    (wheel up)
        notches = dz
    if notches > WHEEL_MAX_NOTCH:
        notches = WHEEL_MAX_NOTCH
    routed: int32 = 0
    k: int64 = 0
    while k < notches:
        # Stage the 3-byte CSI sequence into cons_rx and route it verbatim
        # through key_route (the live keystroke delivery path). Safe to reuse
        # cons_rx: mouse + keyboard pumps run sequentially in the daemon loop.
        cons_rx[0] = 27              # ESC
        cons_rx[1] = 91              # '['
        cons_rx[2] = final           # 'A' / 'B'
        routed = key_route(0, 3, fslot) | routed
        k = k + 1
    return routed


def daemon_apply_packet(ls: uint64, le: uint64,
                        scr_w: int64, scr_h: int64) -> int32:
    # Parse "<dx> <dy> <buttons> <dz>" (space-separated, possibly signed).
    # The 4th field (scroll-wheel delta) is OPTIONAL: a legacy 3-field
    # packet leaves next_signed at end-of-line, so dz parses to 0 and the
    # cursor/gesture path below is byte-for-byte unchanged.
    pos: Array[1, uint64]
    pos[0] = ls
    dx: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    dy: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    btn: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    dz: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    # OPTIONAL 5th field: absolute flag. A USB tablet (the standard
    # QEMU/Boxes pointer) reports ABSOLUTE coordinates 0..32767; the
    # kernel marks those lines "<x> <y> <buttons> <dz> 1". Legacy
    # 4-field relative lines leave next_signed at end-of-line so af
    # parses to 0 and the relative path below is byte-for-byte intact.
    af: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    if af != 0:
        # Scale the 0..32767 device range onto the framebuffer.
        CUR_X = iclamp(dx * scr_w / 32768, 0, scr_w - 1)
        CUR_Y = iclamp(dy * scr_h / 32768, 0, scr_h - 1)
        MT_ABS_SEEN = 1
    else:
        # /dev/mouse already reports screen-space deltas: the PS/2 driver
        # (drivers/input/auxmouse.ad) negates the protocol's up-positive Y
        # into framebuffer-down-positive at the single conversion point, so
        # here we just integrate both axes directly. (Negating again was a
        # double-negation that inverted vertical cursor motion.)
        CUR_X = iclamp(CUR_X + dx, 0, scr_w - 1)
        CUR_Y = iclamp(CUR_Y + dy, 0, scr_h - 1)
        if dx != 0 or dy != 0:
            MT_REL_SEEN = 1
    # Scroll-wheel: deliver the notch to the focused window's content via the
    # keystroke path. Only runs when dz != 0, so a pure-motion packet (the
    # overwhelming majority, and every legacy 3-field packet) keeps the cheap
    # cursor-move fast path completely untouched. A delivered scroll mutates a
    # window's grid, so flag a full recomposite.
    if dz != 0:
        if daemon_scroll_focused(dz, scr_w, scr_h) != 0:
            MOUSE_SCENE_DIRTY = 1
    lbtn: int32 = 0
    if (btn & 1) != 0:
        lbtn = 1
    # Right button is bit 1 (PS/2 button-2). Drives the context menus.
    rbtn: int32 = 0
    if (btn & 2) != 0:
        rbtn = 1
    # P1a: snapshot the hover state so we can detect a scene-affecting
    # change (a different title-bar button / window lights up under the
    # moving pointer). Combined with the button/drag/menu checks below this
    # tells the main loop whether the cheap cursor-move present is safe.
    hov_before: int32 = HOVER_BTN
    hovs_before: int32 = HOVER_SLOT
    # Update the title-bar button hover state every packet so decorations
    # highlight under the moving cursor.
    update_hover()
    # BUG 2: a GENUINE scene mutation (button held/edged, in-flight gesture, or
    # an open popup) can touch arbitrary regions, so it still escalates to a
    # full recomposite. But a mere HOVER-highlight change as the cursor glides
    # over windows must NOT force a whole-screen present every motion packet —
    # that alone pegs the CPU during plain mouse movement. We now flag those two
    # cases separately: MOUSE_SCENE_DIRTY -> full present; MOUSE_HOVER_DIRTY ->
    # damage only the window rect(s) whose decoration lit/unlit.
    if lbtn != 0 or rbtn != 0 or PREV_BTN_L != 0 or PREV_BTN_R != 0 \
       or DRAG_ACTIVE != 0 or RESIZE_SLOT >= 0 or GESTURE == 4 \
       or MENU_BAR_OPEN >= 0 or CTX_OPEN != 0 or CAL_OPEN != 0 \
       or CYCLE_OPEN != 0 or SESSION_OPEN != 0 or RUN_OPEN != 0 \
       or SEARCH_OPEN != 0 or KMODE != 0:
        MOUSE_SCENE_DIRTY = 1
    elif HOVER_BTN != hov_before or HOVER_SLOT != hovs_before:
        # Hover-only highlight change: repaint just the window the highlight
        # left and the window it entered (each is bounded by its own frame),
        # never the whole screen.
        MOUSE_HOVER_DIRTY = 1
        MOUSE_HOVER_OLD = hovs_before
        MOUSE_HOVER_NEW = HOVER_SLOT
    # ROUND-7: focus-follows-mouse. When enabled and no gesture is in
    # flight, the window under the pointer is raised to the top so it
    # gains focus as the cursor passes over it (GNOME2 "sloppy" focus).
    focus_follow_step(lbtn, scr_w, scr_h)
    wm_rbutton(rbtn, scr_w, scr_h)
    PREV_BTN_R = rbtn
    # Drive the gesture state machine off the integrated cursor + button
    # state. wm_button() handles the press/drag/release edges (move,
    # close, create) using CUR_X/CUR_Y and PREV_BTN_L.
    # Save the pre-edge left-button state for the routed-event emit below
    # (wm_button leaves PREV_BTN_L = lbtn on return).
    prev_l: int32 = PREV_BTN_L
    wm_button(lbtn, scr_w, scr_h)
    PREV_BTN_L = lbtn
    # --- ROUTED pointer-event delivery to the target window ----------
    # Surface the event the compositor just routed to the owning client.
    # The target is the drag/resize-captured window if a gesture is in
    # flight (so the client keeps receiving the drag even if the pointer
    # leaves its frame), else the window under the cursor. Desktop chrome
    # (panel / menus / no window) routes to nobody. The button bitmap and
    # scroll delta come straight from the packet; coords are converted to
    # window-local space inside evt_emit_pointer.
    tgt: int64 = -1
    if MOVE_SLOT >= 0:
        tgt = MOVE_SLOT
    elif RESIZE_SLOT >= 0:
        tgt = RESIZE_SLOT
    else:
        tgt = window_at(CUR_X, CUR_Y)
    if tgt >= 0:
        bmap: int64 = btn
        if lbtn != 0 and prev_l == 0:
            evt_emit_pointer(tgt, 100, CUR_X, CUR_Y, bmap, 0)   # 'd' down
        elif lbtn == 0 and prev_l != 0:
            evt_emit_pointer(tgt, 117, CUR_X, CUR_Y, bmap, 0)   # 'u' up
        elif dz != 0:
            evt_emit_pointer(tgt, 115, CUR_X, CUR_Y, bmap, dz)  # 's' scroll
        else:
            evt_emit_pointer(tgt, 109, CUR_X, CUR_Y, bmap, 0)   # 'm' motion
    return 1


# Recompute which title-bar button (if any) the cursor is hovering so the
# ROUND-7: focus-follows-mouse state. The UID last auto-focused by a
# motion-over so we only raise when the hovered window actually changes
# (avoids thrashing the z-order on every motion packet).
FOCUS_FOLLOW_UID: int32 = -1


# When FOCUS_MODE is follows-mouse, raise the window under the pointer so
# it gains focus as the cursor passes over it. Suppressed while a button
# is held (a drag/resize is in flight), while any menu/popup is open, or
# while the pointer is over the panel — matching GNOME2 sloppy focus,
# which never re-focuses through the panel or mid-gesture.
def focus_follow_step(lbtn: int32, scr_w: int64, scr_h: int64):
    if FOCUS_MODE == 0:
        FOCUS_FOLLOW_UID = -1
        return
    if lbtn != 0 or PREV_BTN_L != 0:
        return
    if RESIZE_SLOT >= 0 or DRAG_ACTIVE != 0 or GESTURE == 4:
        return
    if MENU_BAR_OPEN >= 0 or CTX_OPEN != 0 or CAL_OPEN != 0 or CYCLE_OPEN != 0:
        return
    if in_panel(CUR_X, CUR_Y) != 0:
        return
    hit: int64 = window_at(CUR_X, CUR_Y)
    if hit < 0:
        FOCUS_FOLLOW_UID = -1
        return
    hu: uint64 = cast[uint64](hit)
    huid: int32 = DWIN_UID[hu]
    if huid == FOCUS_FOLLOW_UID:
        return
    FOCUS_FOLLOW_UID = huid
    # Only raise if it isn't already the front-most window.
    if hit != cast[int64](DWIN_COUNT) - 1:
        daemon_raise_slot(hit)
        ff: Ptr[uint8] = "FOCUS follow raise\n"
        sys_write(1, ff, strlen_u8(ff))


# decoration code can brighten it. Scans the topmost window down.
def update_hover():
    HOVER_SLOT = -1
    HOVER_BTN = -1
    RESIZE_HOVER = 0
    # ROUND-8: while the modal session dialog is up, track which button row
    # the cursor rests on so the renderer can highlight it (MATE feel). The
    # dialog is modal, so nothing else needs hover state.
    if SESSION_OPEN != 0:
        SESSION_HOVER = session_row_at(CUR_X, CUR_Y,
                                       cast[int64](FBG_W), cast[int64](FBG_H))
        return
    # Clock-applet hover: 1 while the cursor is over the right-edge clock
    # zone in the panel (drives the date tooltip).
    clk_x: int64 = cast[int64](FBG_W) - CLOCK_W
    if on_panel_y(CUR_Y) != 0 and CUR_X >= clk_x and CUR_X < cast[int64](FBG_W):
        CLOCK_HOVER = 1
    else:
        CLOCK_HOVER = 0
    # ROUND-7: Applications category submenu follows the hovered row. When
    # the Applications drop-down is open and the cursor rests on a category
    # row, that category's flyout opens; hovering inside the open flyout
    # keeps it up so the user can travel to an item.
    if MENU_BAR_OPEN == 0:
        chov: int64 = menubar_item_at(CUR_X, CUR_Y)
        if chov >= 0 and chov < APPCAT_COUNT:
            SUBMENU_OPEN = chov
        elif SUBMENU_OPEN >= 0:
            # Keep the flyout open only while the cursor stays within it.
            if submenu_item_at(SUBMENU_OPEN, CUR_X, CUR_Y) < 0:
                SUBMENU_OPEN = -1
    else:
        SUBMENU_OPEN = -1
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        s: uint64 = cast[uint64](wi)
        if win_on_cur_ws(s) != 0:
            if in_close_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 0
                return
            if in_minimize_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 1
                return
            if in_maximize_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 2
                return
            # ROUND-6: resize-grip hover hint (the topmost window wins).
            rdh: int32 = resize_dir_at(s, CUR_X, CUR_Y)
            if rdh != 0:
                RESIZE_HOVER = rdh
                return
        wi = wi - 1


# ====================================================================
# ROUND-19: session manager — save / restore open windows
# ====================================================================
# MATE's gnome-session remembers which windows were open (and where) and
# restores them on the next login. We persist a tiny text record per
# window to /tmp/.hamUId_session: one line "app x y w h ws" per window.
# session_save() is called automatically when the daemon logs out (and on
# demand from the System menu / a hotkey); session_restore() re-opens the
# saved windows — built-in apps as themselves, terminals as fresh shells.
session_buf: Array[2048, uint8]      # scratch for save (write) + restore (read)
SESSION_SAVED_N: int64 = 0           # how many windows the last save recorded


# Path to the session file. Returned as a call-site literal (Adder U9: no
# module-scope string globals).
def session_path() -> Ptr[char]:
    p: Ptr[char] = "/tmp/.hamUId_session"
    return p


# Append a decimal value + a trailing space to session_buf at p; return new p.
def session_put_num(p: uint64, v: int64) -> uint64:
    nb: Array[24, uint8]
    n: uint64 = u64_to_dec(cast[uint64](v), &nb[0])
    # u64_to_dec writes a trailing newline; copy only the digits, then a space.
    i: uint64 = 0
    while i < n and nb[i] != 10:
        session_buf[p] = nb[i]
        p = p + 1
        i = i + 1
    session_buf[p] = 32          # ' '
    p = p + 1
    return p


# Write every current window's app/geometry/workspace to the session file.
# Returns the number of windows saved (also stored in SESSION_SAVED_N).
def session_save() -> int64:
    p: uint64 = 0
    n: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        # Persist the FLOAT rectangle (pre-snap) for snapped/maximized
        # windows so a restore re-opens them at a sensible size.
        rx: int64 = DWIN_X[wi]
        ry: int64 = DWIN_Y[wi]
        rw: int64 = DWIN_W[wi]
        rh: int64 = DWIN_H[wi]
        if DWIN_SNAP[wi] != 0 or DWIN_MAXED[wi] != 0:
            rx = DWIN_SAVE_X[wi]
            ry = DWIN_SAVE_Y[wi]
            rw = DWIN_SAVE_W[wi]
            rh = DWIN_SAVE_H[wi]
        if p < 1900:
            p = session_put_num(p, cast[int64](DWIN_APP[wi]))
            p = session_put_num(p, rx)
            p = session_put_num(p, ry)
            p = session_put_num(p, rw)
            p = session_put_num(p, rh)
            p = session_put_num(p, cast[int64](DWIN_WS[wi]))
            session_buf[p] = 10      # newline ends the record
            p = p + 1
            n = n + 1
        wi = wi + 1
    SESSION_SAVED_N = n
    wf: int32 = sys_open_write(session_path())
    if wf < 0:
        ef: Ptr[uint8] = "SESSION save FAIL\n"
        sys_write(1, ef, strlen_u8(ef))
        return -1
    if p > 0:
        sys_write(wf, &session_buf[0], p)
    sys_close(wf)
    sp: Ptr[uint8] = "SESSION save "
    sys_write(1, sp, strlen_u8(sp))
    snb: Array[8, uint8]
    snn: uint64 = u64_to_dec(cast[uint64](n), &snb[0])
    sys_write(1, &snb[0], snn)
    return n


# Parse the next whitespace-separated signed decimal from session_buf in
# [*pos, total); advance *pos past it. Returns 0 on no token (caller checks
# *pos vs total to detect end-of-line/data).
def session_next_int(pos: Ptr[uint64], total: uint64, ok: Ptr[int32]) -> int64:
    i: uint64 = pos[0]
    # skip spaces (NOT newlines — newline ends a record)
    while i < total and session_buf[i] == 32:
        i = i + 1
    ok[0] = 0
    if i >= total or session_buf[i] == 10:
        pos[0] = i
        return 0
    neg: int32 = 0
    if session_buf[i] == 45:         # '-'
        neg = 1
        i = i + 1
    v: int64 = 0
    got: int32 = 0
    while i < total and session_buf[i] >= 48 and session_buf[i] <= 57:
        v = v * 10 + cast[int64](session_buf[i] - 48)
        i = i + 1
        got = 1
    pos[0] = i
    if got != 0:
        ok[0] = 1
    if neg != 0:
        return -v
    return v


# Re-open every window recorded in the session file. Built-in app windows
# are recreated as their app; terminal windows (APP_TERM) are recreated as
# fresh shells. Returns the number of windows restored.
def session_restore(scr_w: int64, scr_h: int64) -> int64:
    rf: int32 = sys_open(session_path())
    if rf < 0:
        nf: Ptr[uint8] = "SESSION restore none\n"
        sys_write(1, nf, strlen_u8(nf))
        return 0
    nr: int64 = sys_read(rf, &session_buf[0], 2048)
    sys_close(rf)
    if nr <= 0:
        nf2: Ptr[uint8] = "SESSION restore none\n"
        sys_write(1, nf2, strlen_u8(nf2))
        return 0
    total: uint64 = cast[uint64](nr)
    pos: uint64 = 0
    okv: int32 = 0
    restored: int64 = 0
    while pos < total and DWIN_COUNT < DMAX:
        # skip blank lines / leading newlines
        if session_buf[pos] == 10:
            pos = pos + 1
            continue
        app: int64 = session_next_int(&pos, total, &okv)
        if okv == 0:
            break
        rx: int64 = session_next_int(&pos, total, &okv)
        ry: int64 = session_next_int(&pos, total, &okv)
        rw: int64 = session_next_int(&pos, total, &okv)
        rh: int64 = session_next_int(&pos, total, &okv)
        ws: int64 = session_next_int(&pos, total, &okv)
        # advance to the end of this record (next newline)
        while pos < total and session_buf[pos] != 10:
            pos = pos + 1
        # sanity-clamp the geometry on-screen
        if rw < RESIZE_MIN_W:
            rw = RESIZE_MIN_W
        if rh < RESIZE_MIN_H:
            rh = RESIZE_MIN_H
        if rw > scr_w:
            rw = scr_w
        if rh > scr_h - PANEL_H:
            rh = scr_h - PANEL_H
        if rx < 0:
            rx = 0
        if ry < PANEL_H:
            ry = PANEL_H
        if rx + rw > scr_w:
            rx = scr_w - rw
        if ry + rh > scr_h:
            ry = scr_h - rh
        slot: uint64 = DWIN_COUNT
        if app == cast[int64](APP_TERM):
            daemon_spawn_window(rx, ry, rw, rh)
        else:
            daemon_spawn_app(cast[int32](app), rx, ry, rw, rh)
        # Place the restored window on its saved workspace.
        if DWIN_COUNT > slot:
            if ws >= 0 and ws < cast[int64](WS_COUNT):
                DWIN_WS[slot] = cast[int32](ws)
        restored = restored + 1
    sp: Ptr[uint8] = "SESSION restore "
    sys_write(1, sp, strlen_u8(sp))
    rnb: Array[8, uint8]
    rnn: uint64 = u64_to_dec(cast[uint64](restored), &rnb[0])
    sys_write(1, &rnb[0], rnn)
    return restored


# Open a file-manager window rooted at `dir` (Places menu action). Uses
# the generalised spawn path with hamfm + the directory as argv[1].
fm_arg_buf: Array[2, uint64]
def places_open(dir: Ptr[char], scr_w: int64, scr_h: int64):
    if DWIN_COUNT >= DMAX:
        return
    w: int64 = 480
    h: int64 = 320
    step: int64 = (LAUNCH_CASCADE % 6) * 28
    rx: int64 = 80 + step
    ry: int64 = PANEL_H + 20 + step
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    # The DE file manager is now the in-compositor icon-grid app APP_FILEMGR
    # (no child process). Spawn it, then root it at the requested directory.
    # (user/hamfm.ad survives as a CLI fallback, but the desktop uses this.)
    daemon_spawn_app(APP_FILEMGR, rx, ry, w, h)
    fm_slot: uint64 = DWIN_COUNT - 1
    fm_set_path(fm_slot, cast[Ptr[uint8]](dir))
    fm_load_dir(fm_slot)
    pfx: Ptr[uint8] = "PLACES open "
    sys_write(1, pfx, strlen_u8(pfx))
    sys_write(1, cast[Ptr[uint8]](dir), strlen_u8(cast[Ptr[uint8]](dir)))
    sys_write(1, "\n", 1)


# Open the built-in "About Hamnix" info card (System menu). This is a
# real in-process DE window drawn by app_about_pixel — no child process.
def system_about(scr_w: int64, scr_h: int64):
    rw: int64 = 360
    rh: int64 = 180
    rx: int64 = scr_w / 2 - rw / 2
    ry: int64 = scr_h / 2 - rh / 2
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    if rx + rw > scr_w:
        rx = scr_w - rw
    daemon_spawn_app(APP_ABOUT, rx, ry, rw, rh)
    pfx: Ptr[uint8] = "SYSTEM about\n"
    sys_write(1, pfx, strlen_u8(pfx))


# ROUND-13: launch the command currently typed in the Run dialog. Spawns
# it in a fresh terminal-backed window (reusing the generalised window
# spawn path the Places file manager uses) and closes the dialog. An empty
# command just dismisses the dialog. Emits a marker carrying the command.
def run_launch(scr_w: int64, scr_h: int64):
    if RUN_LEN == 0:
        run_cancel()
        return
    rl_pfx: Ptr[uint8] = "RUN launch "
    sys_write(1, rl_pfx, strlen_u8(rl_pfx))
    sys_write(1, &run_buf[0], RUN_LEN)
    sys_write(1, "\n", 1)
    # ROUND-20: remember the launched command in the clipboard history so
    # it can be pasted (clipman-style recent-command recall).
    clip_push(cast[Ptr[uint8]](&run_buf[0]))
    # DE pivot wave 4: enqueue the launch via /dev/wsys/run/launch (the
    # extracted IPC flow — any process with write access could trigger a
    # launch). This mirrors the appmenu wave's /dev/wsys/appmenu/launch
    # slot. The compositor's run_drain_launch() in the main loop will
    # spawn the chosen program asynchronously on the next frame.
    lfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/run/launch"))
    if lfd >= 0:
        sys_write(lfd, &run_buf[0], RUN_LEN)
        sys_write(lfd, "\n", 1)
        sys_close(lfd)
    # Also do the synchronous spawn here so the round-13 selftest (and
    # any other in-process caller that asserts DWIN_COUNT bumps as soon
    # as Enter is pressed) keeps working. The drain helper's
    # last-serial gate makes the next poll a no-op for this serial.
    if DWIN_COUNT < DMAX:
        w: int64 = 480
        h: int64 = 300
        step: int64 = (LAUNCH_CASCADE % 6) * 28
        rx: int64 = 100 + step
        ry: int64 = PANEL_H + 24 + step
        if rx + w > scr_w:
            rx = scr_w - w
        if ry + h > scr_h:
            ry = scr_h - h
        if rx < 0:
            rx = 0
        if ry < PANEL_H:
            ry = PANEL_H
        LAUNCH_CASCADE = LAUNCH_CASCADE + 1
        daemon_spawn_window_prog(cast[Ptr[char]](&run_buf[0]), rx, ry, w, h)
        # Suppress the drain's spawn on this serial (we already spawned
        # in-process above). Re-read the snapshot to capture the bumped
        # serial; the next run_drain_launch() then sees serial ==
        # run_last_launch_serial and skips.
        sfd2: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/run/launch"))
        if sfd2 >= 0:
            sb2: Array[32, uint8]
            sn2: int64 = sys_read_nb(sfd2, &sb2[0], 32)
            sys_close(sfd2)
            if sn2 > 0:
                sv2: uint64 = 0
                si2: uint64 = 0
                while si2 < cast[uint64](sn2) and sb2[si2] >= 48 \
                        and sb2[si2] <= 57:
                    sv2 = sv2 * 10 + cast[uint64](sb2[si2] - 48)
                    si2 = si2 + 1
                run_last_launch_serial = sv2
    RUN_OPEN = 0
    RUN_LEN = 0
    run_buf[0] = 0
    # DE pivot wave 4: republish closed state + wake so hamrun clears.
    run_publish_snapshot()
    run_poke_show()


# Invoke item `i` of the open menu-bar drop-down `m`.
def menubar_invoke(m: int32, i: uint64, scr_w: int64, scr_h: int64):
    if m == 0:
        # ROUND-7: Applications rows are categories — they open a submenu
        # flyout rather than launching directly (handled in wm_button).
        SUBMENU_OPEN = cast[int64](i)
        return
    if m == 1:
        if i == 0:
            places_open(cast[Ptr[char]]("/home"), scr_w, scr_h)
        elif i == 1:
            places_open(cast[Ptr[char]]("/"), scr_w, scr_h)
        elif i == 2:
            # Computer: the device/volume root (classic MATE "Computer").
            places_open(cast[Ptr[char]]("/dev"), scr_w, scr_h)
        elif i == 3:
            # Recent Documents: open the file manager at the user's docs.
            places_open(cast[Ptr[char]]("/home"), scr_w, scr_h)
        else:
            places_open(cast[Ptr[char]]("/tmp"), scr_w, scr_h)
        return
    if m == 2:
        if i == 0:
            # System Monitor: open the built-in live-stats app window.
            smx: int64 = 100
            smy: int64 = PANEL_H + 30
            smw: int64 = 360
            smh: int64 = 220
            if smx + smw > scr_w:
                smx = scr_w - smw
            daemon_spawn_app(APP_SYSMON, smx, smy, smw, smh)
            sm: Ptr[uint8] = "SYSTEM launch System Monitor\n"
            sys_write(1, sm, strlen_u8(sm))
        elif i == 1:
            system_about(scr_w, scr_h)
        elif i == 2:
            # ROUND-13: Run Application... raises the modal Run dialog.
            run_open()
        elif i == 3:
            # Reload DE: re-seed the desktop chrome state (a real action —
            # closes all menus + re-presents). A serial marker proves it.
            MENU_BAR_OPEN = -1
            MENU_OPEN = 0
            CTX_OPEN = 0
            rl: Ptr[uint8] = "SYSTEM reload DE\n"
            sys_write(1, rl, strlen_u8(rl))
        elif i == 4:
            workspace_switch(CUR_WS + 1)
        elif i == 5:
            workspace_switch(CUR_WS - 1)
        elif i == 6:
            # Settings: open the ROUND-16 Control Center (categorised
            # Appearance/Panel/Windows/Keyboard preferences).
            stx: int64 = 120
            sty: int64 = PANEL_H + 30
            stw: int64 = 460
            sth: int64 = 300
            if stx + stw > scr_w:
                stx = scr_w - stw
            if stx < 0:
                stx = 0
            daemon_spawn_app(APP_CTRLCENTER, stx, sty, stw, sth)
            st: Ptr[uint8] = "SYSTEM launch Control Center\n"
            sys_write(1, st, strlen_u8(st))
        elif i == 7:
            # ROUND-19: re-open the windows saved at the last logout.
            session_restore(scr_w, scr_h)
            rs: Ptr[uint8] = "SYSTEM restore session\n"
            sys_write(1, rs, strlen_u8(rs))
        else:
            # ROUND-8: Log Out now raises the modal SESSION DIALOG (Lock
            # Screen / Log Out / Shut Down / Cancel) instead of quitting
            # outright, matching gnome-session's logout chooser.
            session_open()
            lo: Ptr[uint8] = "SYSTEM Log Out\n"
            sys_write(1, lo, strlen_u8(lo))
        return


# Invoke item `i` of the open right-click context menu.
def ctx_invoke(i: uint64, scr_w: int64, scr_h: int64):
    if CTX_KIND == 0:
        # Desktop menu (MATE root right-click): Open Terminal / Open File
        # Manager / New Workspace / Settings / Change Background / Arrange /
        # Cascade / Reload.
        if i == 0:
            # Open Terminal: SPAWN the external /bin/hamterm as its OWN
            # process (Increment-2 of the MATE-mirror DE rewrite), anchored
            # where the menu was clicked. This replaces the old in-compositor
            # APP_TERM hand-drawn grid (daemon_spawn_app(APP_TERM)) that
            # conflated the terminal into the daemon and caused the
            # multi-second open lag; the separate process composites its
            # hamui markup body live and the spawn damages only its rect.
            rx: int64 = CTX_X
            ry: int64 = CTX_Y
            if ry < PANEL_H:
                ry = PANEL_H
            tw: int64 = 480
            th: int64 = 320
            if rx + tw > scr_w:
                rx = scr_w - tw
            if rx < 0:
                rx = 0
            daemon_spawn_terminal(rx, ry, tw, th)
            nt: Ptr[uint8] = "CTX new-terminal\n"
            sys_write(1, nt, strlen_u8(nt))
        elif i == 1:
            # Open File Manager: the in-compositor icon-grid APP_FILEMGR,
            # rooted at /home (the same path the Places menu uses).
            places_open(cast[Ptr[char]]("/home"), scr_w, scr_h)
            cf: Ptr[uint8] = "CTX file-manager\n"
            sys_write(1, cf, strlen_u8(cf))
        elif i == 2:
            # New Workspace: grow the pager by one virtual desktop (MATE's
            # "add workspace") — the same model mutation the pager menu uses.
            ws_count_add()
            cw: Ptr[uint8] = "CTX new-workspace\n"
            sys_write(1, cw, strlen_u8(cw))
        elif i == 3:
            # Settings: open the built-in preferences window (ROUND-5).
            stx: int64 = CTX_X
            sty: int64 = CTX_Y
            if sty < PANEL_H:
                sty = PANEL_H
            stw: int64 = 320
            sth: int64 = 200
            if stx + stw > scr_w:
                stx = scr_w - stw
            if stx < 0:
                stx = 0
            daemon_spawn_app(APP_SETTINGS, stx, sty, stw, sth)
            cs: Ptr[uint8] = "CTX settings\n"
            sys_write(1, cs, strlen_u8(cs))
        elif i == 4:
            bg_cycle()
        elif i == 5:
            windows_arrange(scr_w, scr_h)
        elif i == 6:
            windows_cascade(scr_w, scr_h)        # ROUND-20
        else:
            MENU_BAR_OPEN = -1
            MENU_OPEN = 0
            rl: Ptr[uint8] = "SYSTEM reload DE\n"
            sys_write(1, rl, strlen_u8(rl))
        return
    # ROUND-14 window-list (taskbar) per-window menu — act on CTX_SLOT.
    if CTX_KIND == 2:
        if CTX_SLOT < 0:
            return
        ts: uint64 = cast[uint64](CTX_SLOT)
        if ts >= DWIN_COUNT:
            return
        if i == 0:
            # Toggle minimize: hide when shown, raise+show when minimized.
            if DWIN_HIDDEN[ts] != 0:
                DWIN_HIDDEN[ts] = 0
                daemon_raise_slot(CTX_SLOT)
                wlr: Ptr[uint8] = "WLIST restore window\n"
                sys_write(1, wlr, strlen_u8(wlr))
            else:
                DWIN_HIDDEN[ts] = 1
                wlm: Ptr[uint8] = "WLIST minimize window\n"
                sys_write(1, wlm, strlen_u8(wlm))
        elif i == 1:
            window_toggle_maximize(ts, scr_w, scr_h)
        elif i == 2:
            window_toggle_shade(ts)
        elif i == 3:
            daemon_close_slot(CTX_SLOT)
            wlc: Ptr[uint8] = "WLIST close window\n"
            sys_write(1, wlc, strlen_u8(wlc))
        elif i == 4:
            return                       # header row: no action
        else:
            # Move-to-Workspace N rows (N0-based = i-5).
            tws: int32 = cast[int32](cast[int64](i) - 5)
            if tws >= 0 and tws < WS_COUNT:
                window_to_workspace(ts, tws)
                wlw: Ptr[uint8] = "WLIST move-to-ws "
                sys_write(1, wlw, strlen_u8(wlw))
                wwb: Array[4, uint8]
                wwb[0] = cast[uint8](tws + 1) + 48
                wwb[1] = 10
                sys_write(1, &wwb[0], 2)
        return
    # ROUND-14 pager (workspace-switcher) menu.
    if CTX_KIND == 3:
        if i == 0:
            ws_count_add()
        elif i == 1:
            ws_count_remove()
        else:
            show_all_ws_toggle()
        return
    # ROUND-15 panel (right-click the bar) menu.
    if CTX_KIND == 4:
        if i == 0:
            panel_pos_toggle()
        elif i == 1:
            panel_autohide_toggle()
        elif i == 2:
            panel_add_launcher()
        else:
            # Panel Preferences: open the built-in Settings window, where the
            # panel position/number-of-workspaces controls live.
            spx: int64 = 80
            spy: int64 = work_top(scr_h) + 40
            daemon_spawn_app(APP_SETTINGS, spx, spy, 320, 200)
            pp: Ptr[uint8] = "PANEL preferences\n"
            sys_write(1, pp, strlen_u8(pp))
        return
    # Window menu — act on CTX_SLOT.
    if CTX_SLOT < 0:
        return
    s: uint64 = cast[uint64](CTX_SLOT)
    if s >= DWIN_COUNT:
        return
    if i == 0:
        DWIN_HIDDEN[s] = 1
        mm: Ptr[uint8] = "WM minimize window\n"
        sys_write(1, mm, strlen_u8(mm))
    elif i == 1:
        window_toggle_maximize(s, scr_w, scr_h)
    elif i == 2:
        window_maximize_vert(s, scr_w, scr_h)
    elif i == 3:
        window_maximize_horiz(s, scr_w, scr_h)
    elif i == 4:
        window_toggle_shade(s)
    elif i == 5:
        window_toggle_ontop(s)
    elif i == 6:
        window_toggle_below(s)                   # ROUND-24: keep-below toggle
    elif i == 7:
        window_toggle_sticky(s)                  # ROUND-20: sticky toggle
    elif i == 8:
        # ROUND-6: arm an interactive resize from the bottom-right corner.
        # The pointer then drags the SE grip (like picking "Resize" in MATE's
        # window menu and grabbing the corner). Warp the tracked cursor to
        # the corner so the first motion pulls from there.
        CUR_X = DWIN_X[s] + DWIN_W[s] - 1
        CUR_Y = DWIN_Y[s] + DWIN_H[s] - 1
        resize_begin(CTX_SLOT, 2 | 8)        # right + bottom edges (SE corner)
        GESTURE = 4
        PREV_BTN_L = 1                        # treat as a held resize drag
    elif i == 9:
        window_to_workspace(s, CUR_WS + 1)
    elif i == 10:
        nws: int32 = CUR_WS - 1
        if nws < 0:
            nws = WS_COUNT - 1
        window_to_workspace(s, nws)
    elif i == 11:
        window_opacity_step(s, -OPACITY_STEP)    # More Transparent
    elif i == 12:
        window_opacity_step(s, OPACITY_STEP)     # Less Transparent
    elif i == 13:
        window_toggle_fullscreen(s, scr_w, scr_h)   # ROUND-22
    elif i == 14:
        # ROUND-22: Group all visible windows, or Ungroup if already grouped.
        if DWIN_GROUP[s] != 0:
            group_dissolve(DWIN_GROUP[s])
        else:
            group_visible_windows()
    else:
        daemon_close_slot(CTX_SLOT)
        cw: Ptr[uint8] = "WM close window\n"
        sys_write(1, cw, strlen_u8(cw))


# Right-button gesture machine. On the DOWN edge it opens a context menu:
# over a window's title bar -> the window menu; over the empty desktop ->
# the desktop menu. A left click elsewhere dismisses it (handled in
# wm_button). Factored out so the self-test can drive it directly.
def wm_rbutton(rbtn: int32, scr_w: int64, scr_h: int64):
    if rbtn != 0 and PREV_BTN_R == 0:
        # Right-click while a context menu is open closes it (toggle).
        if CTX_OPEN != 0:
            CTX_OPEN = 0
            return
        # ROUND-11: right-click a GROUPED taskbar button to act on the whole
        # group at once (MATE's window-list group menu). We toggle the group:
        # if every member is already minimized, restore them all; otherwise
        # minimize them all. This must be checked BEFORE the panel early-out
        # below, since taskbar buttons live inside the panel bar.
        rtslot: int64 = taskbar_slot_at(CUR_X, CUR_Y, scr_w)
        if rtslot >= 0:
            rts: uint64 = cast[uint64](rtslot)
            if is_grouped(rts) != 0:
                # Is the group fully minimized already?
                ga: int32 = DWIN_APP[rts]
                all_hidden: int32 = 1
                gi: uint64 = 0
                while gi < DWIN_COUNT:
                    if DWIN_APP[gi] == ga and DWIN_HIDDEN[gi] == 0:
                        all_hidden = 0
                    gi = gi + 1
                if all_hidden != 0:
                    group_restore_all(rts)
                else:
                    group_minimize_all(rts)
                return
            # ROUND-14: an UNgrouped taskbar button opens a per-window
            # window-list context menu (minimize/maximize/shade/close + a
            # Move-to-Workspace block). Anchor it at the button, growing away
            # from the panel edge like every other panel drop-down.
            tbx: int64 = taskbar_btn_x(rts)
            ctx_open_at(2, rtslot, tbx, drop_anchor_y(ctx_total_h_kind(2)),
                        scr_w, scr_h)
            wlmk: Ptr[uint8] = "CTX window-list-menu\n"
            sys_write(1, wlmk, strlen_u8(wlmk))
            return
        # ROUND-14: right-click a pager cell opens the workspace-switcher
        # menu (Add/Remove Workspace + Show-All-Workspaces toggle). Like the
        # taskbar menu this lives in the panel bar, so it is checked before
        # the panel early-out below.
        rpcell: int64 = pager_cell_at(CUR_X, CUR_Y, scr_w)
        if rpcell >= 0:
            pgx: int64 = pager_x0(scr_w)
            ctx_open_at(3, -1, pgx, drop_anchor_y(ctx_total_h_kind(3)),
                        scr_w, scr_h)
            pmk: Ptr[uint8] = "CTX pager-menu\n"
            sys_write(1, pmk, strlen_u8(pmk))
            return
        # ROUND-15: right-click an empty part of the panel bar opens the
        # panel context menu (flip position / autohide / add-to-panel /
        # preferences). Anchor it at the cursor's X, growing off the bar.
        if in_panel(CUR_X, CUR_Y) != 0:
            ctx_open_at(4, -1, CUR_X, drop_anchor_y(ctx_total_h_kind(4)),
                        scr_w, scr_h)
            pck: Ptr[uint8] = "CTX panel-menu\n"
            sys_write(1, pck, strlen_u8(pck))
            return
        hit: int64 = window_at(CUR_X, CUR_Y)
        if hit >= 0 and in_title_bar(cast[uint64](hit), CUR_X, CUR_Y) != 0:
            ctx_open_at(1, hit, CUR_X, CUR_Y, scr_w, scr_h)
            wm: Ptr[uint8] = "CTX window-menu\n"
            sys_write(1, wm, strlen_u8(wm))
        else:
            ctx_open_at(0, -1, CUR_X, CUR_Y, scr_w, scr_h)
            dm: Ptr[uint8] = "CTX desktop-menu\n"
            sys_write(1, dm, strlen_u8(dm))


# Gesture state machine, driven by the current left-button level (lbtn:
# 0/1) and the absolute cursor at CUR_X/CUR_Y. Detects the press edge
# (against PREV_BTN_L), tracks an in-flight move while held, and resolves
# move/close/create on the release edge. Factored out so the daemon
# self-test can drive it directly with absolute coordinates (no /dev/mouse
# packet round-trip).
def wm_button(lbtn: int32, scr_w: int64, scr_h: int64):
    # --- left-button DOWN edge: classify the gesture ---
    if lbtn != 0 and PREV_BTN_L == 0:
        # ROUND-8: a LOCKED screen swallows every click (the click is the
        # unlock gesture). Nothing else on the desktop can be reached while
        # locked, so this shields ahead of all other handlers.
        if LOCKED != 0:
            session_unlock()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # ROUND-8: the modal SESSION DIALOG eats the next click — either a
        # button row fires its action, or a click outside the dialog cancels.
        if SESSION_OPEN != 0:
            srow: int64 = session_row_at(CUR_X, CUR_Y, scr_w, scr_h)
            if srow >= 0:
                session_invoke(srow)
            else:
                SESSION_OPEN = 0
                cc: Ptr[uint8] = "SESSION cancel\n"
                sys_write(1, cc, strlen_u8(cc))
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # ROUND-13: the modal Run dialog eats the next click. A click inside
        # the dialog body is swallowed (the entry keeps focus); a click off
        # the dialog cancels it.
        if RUN_OPEN != 0:
            rdx0: int64 = run_x(scr_w)
            rdy0: int64 = run_y(scr_h)
            rdh0: int64 = run_total_h()
            if CUR_X >= rdx0 and CUR_X < rdx0 + RUN_W \
               and CUR_Y >= rdy0 and CUR_Y < rdy0 + rdh0:
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            run_cancel()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # ROUND-13: an open message-tray panel intercepts the next click —
        # [Clear] empties the history; a click elsewhere on the panel is
        # swallowed; a click off the panel closes it.
        if TRAY_OPEN != 0:
            if in_tray_clear_btn(CUR_X, CUR_Y, scr_w) != 0:
                nhist_clear()
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            if in_tray_panel(CUR_X, CUR_Y, scr_w) != 0:
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            # Fall through if the click is the tray icon itself (toggles
            # below); otherwise close the panel.
            if in_tray_msg_btn(CUR_X, CUR_Y, scr_w) == 0:
                TRAY_OPEN = 0
                tc: Ptr[uint8] = "TRAY close\n"
                sys_write(1, tc, strlen_u8(tc))
        # CONTEXT MENU first — an open right-click menu eats the next click.
        if CTX_OPEN != 0:
            ci: int64 = ctx_item_at(CUR_X, CUR_Y)
            CTX_OPEN = 0                        # any click closes it
            if ci >= 0:
                ctx_invoke(cast[uint64](ci), scr_w, scr_h)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # PANEL / MENU BAR next — desktop chrome intercepts the press before
        # any window/drag-create logic so the launcher never also starts a
        # rubber-band window.
        #   * press on a top-level menu button -> toggle that drop-down
        #   * press on an open drop-down item  -> invoke it + close the menu
        #   * press elsewhere while a menu is open -> dismiss it
        mbhit: int32 = menubar_btn_at(CUR_X, CUR_Y)
        if mbhit >= 0:
            SUBMENU_OPEN = -1
            # ROUND-10: opening the Applications menu fresh arms its type-to-
            # search box (empty query => the menu shows every entry); any
            # close or other menu clears it.
            search_reset()
            if MENU_BAR_OPEN == mbhit:
                MENU_BAR_OPEN = -1
                mc: Ptr[uint8] = "PANEL close menu\n"
                sys_write(1, mc, strlen_u8(mc))
            else:
                MENU_BAR_OPEN = mbhit
                if mbhit == 0:
                    SEARCH_OPEN = 1
                    # DE pivot wave 2: spawn /bin/hamappmenu so the
                    # cascading Applications menu renders in its own
                    # process. The compositor no longer draws it.
                    appmenu_spawn(scr_w, scr_h)
                mo: Ptr[uint8] = "PANEL open menu "
                sys_write(1, mo, strlen_u8(mo))
                write_str(1, menubar_label(mbhit))
                write_str(1, "\n")
            DRAG_ACTIVE = 0
            GESTURE = 3                        # panel: no up-edge action
            return
        if MENU_BAR_OPEN >= 0:
            # ROUND-10: while the Applications search filter is active, a
            # click on a filtered result row launches that entry and closes
            # the menu (MATE type-to-launch).
            if MENU_BAR_OPEN == 0 and search_active() != 0:
                srn: int64 = search_result_at(CUR_X, CUR_Y)
                if srn >= 0:
                    sflat: uint64 = menu_search_nth(cast[uint64](srn))
                    MENU_BAR_OPEN = -1
                    SUBMENU_OPEN = -1
                    search_reset()
                    if sflat < MENU_COUNT:
                        menu_launch(sflat, scr_w, scr_h)
                    DRAG_ACTIVE = 0
                    GESTURE = 3
                    return
                # A click off the result list closes the menu + search.
                MENU_BAR_OPEN = -1
                SUBMENU_OPEN = -1
                search_reset()
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            # ROUND-7: a click inside an open Applications submenu flyout
            # launches that category's app and closes the whole menu.
            if MENU_BAR_OPEN == 0 and SUBMENU_OPEN >= 0:
                sk: int64 = submenu_item_at(SUBMENU_OPEN, CUR_X, CUR_Y)
                if sk >= 0:
                    flat: uint64 = appcat_flat_index(SUBMENU_OPEN, sk)
                    MENU_BAR_OPEN = -1
                    SUBMENU_OPEN = -1
                    menu_launch(flat, scr_w, scr_h)
                    DRAG_ACTIVE = 0
                    GESTURE = 3
                    return
            mi: int64 = menubar_item_at(CUR_X, CUR_Y)
            opened: int32 = MENU_BAR_OPEN
            # A click on an Applications category row only opens its flyout
            # (it never launches directly), so keep the menu open there.
            if opened == 0 and mi >= 0 and mi < APPCAT_COUNT:
                SUBMENU_OPEN = mi
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            MENU_BAR_OPEN = -1                   # any other click closes the menu
            SUBMENU_OPEN = -1
            if mi >= 0:
                menubar_invoke(opened, cast[uint64](mi), scr_w, scr_h)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- ROUND-17: window-selector dropdown row click ---
        if WINSEL_OPEN != 0:
            wsl: int64 = winsel_slot_at(CUR_X, CUR_Y, scr_w)
            if wsl >= 0:
                winsel_activate(wsl)
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            # Click off the open dropdown (but not on its button) closes it.
            wx0: int64 = winsel_x0(scr_w)
            wth: int64 = winsel_total_h()
            wy0: int64 = drop_anchor_y(wth)
            on_drop: int32 = 0
            if CUR_X >= wx0 and CUR_X < wx0 + WINSEL_W and CUR_Y >= wy0 and CUR_Y < wy0 + wth:
                on_drop = 1
            if on_drop == 0 and in_winsel_btn(CUR_X, CUR_Y, scr_w) == 0:
                WINSEL_OPEN = 0
                wcc: Ptr[uint8] = "WINSEL close\n"
                sys_write(1, wcc, strlen_u8(wcc))
        # --- ROUND-17: window-selector panel button toggles the dropdown ---
        if in_winsel_btn(CUR_X, CUR_Y, scr_w) != 0:
            winsel_toggle()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- ROUND-17: status-notifier indicator click ---
        sncell: int64 = statnot_cell_at(CUR_X, CUR_Y, scr_w)
        if sncell >= 0:
            statnot_click(sncell)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- ROUND-13: message-tray icon click toggles the history panel ---
        if in_tray_msg_btn(CUR_X, CUR_Y, scr_w) != 0:
            if TRAY_OPEN != 0:
                TRAY_OPEN = 0
                tc2: Ptr[uint8] = "TRAY close\n"
                sys_write(1, tc2, strlen_u8(tc2))
            else:
                TRAY_OPEN = 1
                to: Ptr[uint8] = "TRAY open\n"
                sys_write(1, to, strlen_u8(to))
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- ROUND-12: Show Desktop applet click ---
        if in_show_desktop_btn(CUR_X, CUR_Y, scr_w) != 0:
            show_desktop_toggle()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- ROUND-7: clock-applet click toggles the calendar popup ---
        if in_clock_zone(CUR_X, CUR_Y, scr_w) != 0:
            cal_toggle()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # A click anywhere else while the calendar is open dismisses it
        # (clicks landing inside the popup are handled just below).
        if CAL_OPEN != 0:
            cdx: int64 = cal_drop_x(scr_w)
            cdy: int64 = cal_drop_y()
            if CUR_X >= cdx and CUR_X < cdx + CAL_W \
               and CUR_Y >= cdy and CUR_Y < cdy + cal_total_h():
                # Click inside the calendar: swallow it (the popup stays up).
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            CAL_OPEN = 0
            cc: Ptr[uint8] = "CAL close\n"
            sys_write(1, cc, strlen_u8(cc))
            # DE pivot wave 4: click-outside dismiss must republish so
            # /bin/hamcalpop clears its popup.
            calpop_publish_snapshot()
            calpop_poke_show()
        # --- workspace pager press: arm a pager gesture (ROUND-10) ---
        # A press on a pager cell starts GESTURE==5. The up-edge decides:
        # release on a DIFFERENT cell drags the source desktop's focused
        # window there; release on the SAME cell switches to it (the old
        # click-to-switch behaviour). This is MATE's drag-window-between-
        # workspaces directly on the pager mini-map.
        pcell: int64 = pager_cell_at(CUR_X, CUR_Y, scr_w)
        if pcell >= 0:
            PAGER_DRAG = 1
            PAGER_DRAG_FROM = pcell
            GESTURE = 5
            DRAG_ACTIVE = 0
            return
        # --- taskbar button click: raise/restore the clicked window ---
        # ROUND-10: a grouped app's button cycles focus through the group;
        # a singleton button raises/restores its one window as before.
        tslot: int64 = taskbar_slot_at(CUR_X, CUR_Y, scr_w)
        if tslot >= 0:
            ts: uint64 = cast[uint64](tslot)
            if is_grouped(ts) != 0:
                grs: int64 = group_cycle(ts)             # returns raised UID
                tb_pfx3: Ptr[uint8] = "TASKBAR group-cycle uid "
                sys_write(1, tb_pfx3, strlen_u8(tb_pfx3))
                gv: uint64 = 0
                if grs >= 0:
                    gv = cast[uint64](grs)
                tgl: Array[24, uint8]
                tgn: uint64 = u64_to_dec(gv, &tgl[0])
                sys_write(1, &tgl[0], tgn)
            elif DWIN_HIDDEN[ts] != 0:
                # Restore: un-minimize then raise to focus.
                DWIN_HIDDEN[ts] = 0
                daemon_raise_slot(tslot)
                tb_pfx: Ptr[uint8] = "TASKBAR restore "
                sys_write(1, tb_pfx, strlen_u8(tb_pfx))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            else:
                # Raise the window (give it focus).
                daemon_raise_slot(tslot)
                tb_pfx2: Ptr[uint8] = "TASKBAR raise "
                sys_write(1, tb_pfx2, strlen_u8(tb_pfx2))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        if in_panel(CUR_X, CUR_Y) != 0:
            # Press on the panel bar (not the button) — swallow it so the
            # panel can never start a drag-create underneath itself.
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # Hit-test the topmost window under the cursor. A press on a
        # window's close box arms a close; a press on its title bar
        # starts a move (and raises it on top); anything else (empty
        # desktop, or a window body) begins a rubber-band create drag.
        hit: int64 = window_at(CUR_X, CUR_Y)
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1
        DRAG_ACTIVE = 0
        started_wm: int32 = 0
        if hit >= 0:
            hs: uint64 = cast[uint64](hit)
            if in_close_box(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 2                  # close: confirm on the up-edge
                CLOSE_SLOT = hit
                started_wm = 1
            elif in_minimize_box(hs, CUR_X, CUR_Y) != 0:
                # Minimize on press (immediate, no release confirm needed).
                DWIN_HIDDEN[hs] = 1
                GESTURE = 3                  # minimize: no further up-edge
                started_wm = 1
                mm: Ptr[uint8] = "WM minimize window\n"
                sys_write(1, mm, strlen_u8(mm))
            elif in_maximize_box(hs, CUR_X, CUR_Y) != 0:
                # Maximize / restore toggle (immediate on press).
                window_toggle_maximize(hs, scr_w, scr_h)
                GESTURE = 3                  # no further up-edge action
                started_wm = 1
            elif resize_dir_at(hs, CUR_X, CUR_Y) != 0:
                # ROUND-6: press on a window edge/corner grip -> resize.
                # Raise it first so the resize frame is on top, then arm the
                # interactive resize from the grabbed edge mask.
                hit = daemon_raise_slot(hit)
                hs = cast[uint64](hit)
                rdir: int32 = resize_dir_at(hs, CUR_X, CUR_Y)
                GESTURE = 4
                resize_begin(hit, rdir)
                started_wm = 1
            elif DWIN_GROUP[hs] != 0 \
                 and group_tab_at(hs, CUR_X, CUR_Y) >= 0:
                # ROUND-22: a press on the title-bar tab strip of a grouped
                # window selects that member (browser-tab behaviour) — no
                # move/drag. The activated member inherits the frame.
                tabi: int64 = group_tab_at(hs, CUR_X, CUR_Y)
                group_activate_tab(DWIN_GROUP[hs], tabi)
                GESTURE = 3
                started_wm = 1
            elif in_title_bar(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 1                  # move
                # Double-click the title bar -> roll up / down (MATE/GNOME2
                # "window-shade" gesture). Detect a second press on the SAME
                # window within DBLCLICK_FRAMES of the previous title-bar
                # press (the min/close boxes are hit-tested above, so this
                # only fires on the bare title-bar band).
                dbl: int32 = 0
                if LAST_TCLICK_SLOT == hit \
                   and WM_FRAME - LAST_TCLICK_FRAME <= DBLCLICK_FRAMES:
                    dbl = 1
                LAST_TCLICK_SLOT = hit
                LAST_TCLICK_FRAME = WM_FRAME
                if dbl != 0:
                    window_toggle_shade(cast[uint64](hit))
                    GESTURE = 3              # no move after a double-click
                    started_wm = 1
                    dm2: Ptr[uint8] = "WM dblclick shade\n"
                    sys_write(1, dm2, strlen_u8(dm2))
                    # Reset so a third quick press doesn't re-trigger.
                    LAST_TCLICK_SLOT = -1
                    return
                # Raise the grabbed window to the top so it tracks above
                # the others, then capture the cursor->origin offset.
                hit = daemon_raise_slot(hit)
                hs = cast[uint64](hit)
                # If the window is snapped/maximized, un-snap it to its
                # float size first so dragging detaches it (GNOME feel).
                # Keep the cursor roughly over the title after the resize.
                if DWIN_SNAP[hs] != 0:
                    snap_apply(hs, 0, scr_w, scr_h)
                    if CUR_X > DWIN_X[hs] + DWIN_W[hs]:
                        DWIN_X[hs] = CUR_X - DWIN_W[hs] / 2
                        if DWIN_X[hs] < 0:
                            DWIN_X[hs] = 0
                MOVE_SLOT = hit
                MOVE_OFF_X = CUR_X - DWIN_X[hs]
                MOVE_OFF_Y = CUR_Y - DWIN_Y[hs]
                started_wm = 1
                m1: Ptr[uint8] = "WM move start\n"
                sys_write(1, m1, strlen_u8(m1))
            else:
                # Press inside a window body (not title, not close-box):
                # raise the window to the top to give it keyboard focus.
                # We do NOT start a rubber-band drag — the user clicked
                # inside an existing window to interact with its shell.
                # For built-in app windows, also route the click to the
                # app so e.g. the calculator keypad responds.
                if DWIN_APP[hs] == APP_CALC:
                    cell: int64 = calc_cell_at(hs, CUR_X, CUR_Y)
                    if cell >= 0:
                        calc_press(hs, calc_key_label(cell))
                        ck: Ptr[uint8] = "CALC key\n"
                        sys_write(1, ck, strlen_u8(ck))
                elif DWIN_APP[hs] == APP_SETTINGS:
                    srow: int64 = settings_row_at(hs, CUR_X, CUR_Y)
                    if srow >= 0:
                        settings_press(hs, srow)
                        sk: Ptr[uint8] = "SETTINGS row\n"
                        sys_write(1, sk, strlen_u8(sk))
                elif DWIN_APP[hs] == APP_CTRLCENTER:
                    cc_click(hs, CUR_X, CUR_Y, scr_w, scr_h)
                elif DWIN_APP[hs] == APP_FILEMGR:
                    fm_click(hs, CUR_X, CUR_Y, scr_w, scr_h)
                hit = daemon_raise_slot(hit)
                GESTURE = 3                  # body-focus: no up-edge action
                started_wm = 1
                m2: Ptr[uint8] = "WM focus window\n"
                sys_write(1, m2, strlen_u8(m2))
        if started_wm == 0:
            # ROUND-19: a press on the EMPTY desktop may land on a desktop
            # icon (icons live on the root, so only when no window covers
            # the spot — which is exactly when window_at returned -1). A
            # double-click launches the icon; a single press begins a drag
            # to reposition it (snapped to a grid on drop).
            # ROUND-19: a click on the desktop system-monitor applet opens
            # the full System Monitor window.
            if hit < 0 and in_dmon_applet(CUR_X, CUR_Y, scr_w, scr_h) != 0:
                smx: int64 = 100
                smy: int64 = work_top(scr_h) + 30
                smw: int64 = 360
                smh: int64 = 220
                if smx + smw > scr_w:
                    smx = scr_w - smw
                daemon_spawn_app(APP_SYSMON, smx, smy, smw, smh)
                dma: Ptr[uint8] = "DMON open sysmon\n"
                sys_write(1, dma, strlen_u8(dma))
                GESTURE = 3
                DRAG_ACTIVE = 0
                started_wm = 1
            dic: int64 = -1
            if hit < 0 and started_wm == 0:
                dic = dicon_at(CUR_X, CUR_Y)
            if dic >= 0:
                dbl_i: int32 = 0
                if DICON_LAST_IDX == dic \
                   and WM_FRAME - DICON_LAST_FRAME <= DBLCLICK_FRAMES:
                    dbl_i = 1
                DICON_LAST_IDX = dic
                DICON_LAST_FRAME = WM_FRAME
                if dbl_i != 0:
                    dicon_launch(dic, scr_w, scr_h)
                    DICON_LAST_IDX = -1     # don't re-trigger on a third press
                    GESTURE = 3
                    DRAG_ACTIVE = 0
                    started_wm = 1
                else:
                    # Begin an icon drag.
                    DICON_DRAG = dic
                    DICON_OFF_X = CUR_X - DICON_X[dic]
                    DICON_OFF_Y = CUR_Y - DICON_Y[dic]
                    GESTURE = 6
                    DRAG_ACTIVE = 0
                    started_wm = 1
        if started_wm == 0:
            # No window-management gesture -> the empty-desktop
            # rubber-band create drag (unchanged behaviour).
            GESTURE = 0
            DRAG_ACTIVE = 1
            DRAG_X0 = CUR_X
            DRAG_Y0 = CUR_Y
    # --- button held: a move tracks the window under the grab ---
    if lbtn != 0 and GESTURE == 1 and MOVE_SLOT >= 0:
        ms: uint64 = cast[uint64](MOVE_SLOT)
        nx: int64 = CUR_X - MOVE_OFF_X
        ny: int64 = CUR_Y - MOVE_OFF_Y
        # Clamp so the window stays on-screen and never draws outside the
        # framebuffer. The top is clamped to PANEL_H so a window's title
        # bar can never slide under the panel and become un-grabbable.
        nx = iclamp(nx, 0, scr_w - DWIN_W[ms])
        ny = iclamp(ny, PANEL_H, scr_h - DWIN_H[ms])
        if nx < 0:
            nx = 0
        if ny < PANEL_H:
            ny = PANEL_H
        # ROUND-21: window-to-window magnetic snapping (edge resistance).
        # If the moving frame is within MAGNET px of a screen edge or any
        # other visible window's matching edge, snap flush so adjacent
        # windows sit pixel-perfect against each other.
        msx: Array[1, int64]
        msy: Array[1, int64]
        magnet_adjust(MOVE_SLOT, nx, ny, DWIN_W[ms], DWIN_H[ms],
                      scr_w, scr_h, &msx[0], &msy[0])
        nx = iclamp(msx[0], 0, scr_w - DWIN_W[ms])
        ny = iclamp(msy[0], PANEL_H, scr_h - DWIN_H[ms])
        DWIN_X[ms] = nx
        DWIN_Y[ms] = ny
        # ROUND-5: live snap preview. As the cursor enters a screen edge or
        # corner during a title-bar drag, light up a translucent preview of
        # where the window would land if released now (MATE/GNOME edge
        # tiling). SNAP_PREVIEW_MODE/_ON drive the compositor overlay.
        pz: int32 = snap_zone_for(CUR_X, CUR_Y, scr_w, scr_h)
        SNAP_PREVIEW_MODE = pz
        if pz != 0:
            SNAP_PREVIEW_ON = 1
        else:
            SNAP_PREVIEW_ON = 0
        # ROUND-22: edge-flip — if the cursor is jammed at the extreme
        # screen margin during this title drag, flip to the adjacent
        # workspace and carry the dragged window there.
        edge_flip_update(ms, CUR_X, scr_w)
    # --- button held: a resize tracks the grabbed edge under the cursor ---
    if lbtn != 0 and GESTURE == 4 and RESIZE_SLOT >= 0:
        resize_track(scr_w, scr_h)
    # --- ROUND-19: button held: a desktop icon tracks the cursor ---
    if lbtn != 0 and GESTURE == 6 and DICON_DRAG >= 0:
        nix: int64 = CUR_X - DICON_OFF_X
        niy: int64 = CUR_Y - DICON_OFF_Y
        nix = iclamp(nix, 0, scr_w - DICON_CELL_W)
        niy = iclamp(niy, PANEL_H, scr_h - DICON_CELL_H)
        DICON_X[DICON_DRAG] = nix
        DICON_Y[DICON_DRAG] = niy
    # --- left-button UP edge: resolve the gesture ---
    if lbtn == 0 and PREV_BTN_L != 0:
        if GESTURE == 6:
            # ROUND-19: desktop-icon drag finished — snap the icon to the
            # drop grid and emit its final position for a non-pixel test.
            if DICON_DRAG >= 0:
                DICON_X[DICON_DRAG] = dicon_grid_snap(DICON_X[DICON_DRAG])
                DICON_Y[DICON_DRAG] = dicon_grid_snap(DICON_Y[DICON_DRAG])
                dm: Ptr[uint8] = "DICON drop x="
                sys_write(1, dm, strlen_u8(dm))
                dxb: Array[16, uint8]
                dxn: uint64 = u64_to_dec(cast[uint64](DICON_X[DICON_DRAG]),
                                         &dxb[0])
                sys_write(1, &dxb[0], dxn - 1)
                ysf: Ptr[uint8] = " y="
                sys_write(1, ysf, strlen_u8(ysf))
                dyb: Array[16, uint8]
                dyn: uint64 = u64_to_dec(cast[uint64](DICON_Y[DICON_DRAG]),
                                         &dyb[0])
                sys_write(1, &dyb[0], dyn)
            DICON_DRAG = -1
        elif GESTURE == 5:
            # ROUND-10: pager gesture resolves on release. Release on a
            # different cell drags the source desktop's focused window
            # there; release on the same cell switches workspace.
            rcell: int64 = pager_cell_at(CUR_X, CUR_Y, scr_w)
            if rcell >= 0 and rcell != PAGER_DRAG_FROM \
               and PAGER_DRAG_FROM >= 0:
                pager_drag_window(cast[int32](PAGER_DRAG_FROM),
                                  cast[int32](rcell))
            else:
                workspace_switch(cast[int32](PAGER_DRAG_FROM))
            PAGER_DRAG = 0
            PAGER_DRAG_FROM = -1
        elif GESTURE == 2:
            # Close only if the release lands in the SAME window's close
            # box (rio-style click cancellation on drag-off).
            if CLOSE_SLOT >= 0:
                cs: uint64 = cast[uint64](CLOSE_SLOT)
                if cs < DWIN_COUNT and in_close_box(cs, CUR_X, CUR_Y) != 0:
                    daemon_close_slot(CLOSE_SLOT)
                    m2: Ptr[uint8] = "WM close window\n"
                    sys_write(1, m2, strlen_u8(m2))
        elif GESTURE == 1 and MOVE_SLOT >= 0:
            # Move finished — log the window's final origin so a
            # non-pixel test can assert it relocated.
            mvs: uint64 = cast[uint64](MOVE_SLOT)
            mline: Array[64, uint8]
            mp: uint64 = 0
            mpfx: Ptr[uint8] = "WM move done x="
            mk: uint64 = 0
            while mpfx[mk] != 0:
                mline[mp] = mpfx[mk]
                mp = mp + 1
                mk = mk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_X[mvs]), &mline[mp])
            # drop u64_to_dec's trailing newline, append " y="
            mp = mp - 1
            ysfx: Ptr[uint8] = " y="
            yk: uint64 = 0
            while ysfx[yk] != 0:
                mline[mp] = ysfx[yk]
                mp = mp + 1
                yk = yk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_Y[mvs]), &mline[mp])
            sys_write(1, &mline[0], mp)
            # --- edge/corner tiling: snap based on where the release landed.
            # ROUND-5 routes through snap_zone_for() so corners quarter-tile
            # (the pointer analogue of round-4's keyboard tiling): top edge
            # maximizes, sides half-tile, the four corners quarter-tile.
            zmode: int32 = snap_zone_for(CUR_X, CUR_Y, scr_w, scr_h)
            if zmode != 0:
                snap_apply(mvs, zmode, scr_w, scr_h)
                sn: Ptr[uint8] = "WM snap "
                sys_write(1, sn, strlen_u8(sn))
                zb: Array[4, uint8]
                zb[0] = cast[uint8](zmode) + 48
                zb[1] = 10
                sys_write(1, &zb[0], 2)
            # Clear any live snap preview now the drag has resolved.
            SNAP_PREVIEW_ON = 0
            SNAP_PREVIEW_MODE = 0
        elif GESTURE == 4 and RESIZE_SLOT >= 0:
            # ROUND-6: resize finished — commit the final rectangle.
            resize_track(scr_w, scr_h)
            resize_end()
        elif GESTURE == 0 and DRAG_ACTIVE != 0:
            # Empty-desktop drag -> maybe spawn a window.
            rx0: int64 = imin(DRAG_X0, CUR_X)
            ry0: int64 = imin(DRAG_Y0, CUR_Y)
            rx1: int64 = imax(DRAG_X0, CUR_X)
            ry1: int64 = imax(DRAG_Y0, CUR_Y)
            rw: int64 = rx1 - rx0
            rh: int64 = ry1 - ry0
            if rw >= DRAG_MIN and rh >= DRAG_MIN:
                daemon_spawn_window(rx0, ry0, rw, rh)
        # Reset all gesture state.
        DRAG_ACTIVE = 0
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1
        RESIZE_SLOT = -1
        RESIZE_DIR = 0
        SNAP_PREVIEW_ON = 0
        SNAP_PREVIEW_MODE = 0
        PAGER_DRAG = 0
        PAGER_DRAG_FROM = -1
        DICON_DRAG = -1


def next_signed(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip up to a sign or digit, parse a (possibly signed) decimal.
    i: uint64 = pos[0]
    while i < total and buf[i] != 45 and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    neg: int32 = 0
    if i < total and buf[i] == 45:
        neg = 1
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    if neg != 0:
        return 0 - v
    return v


# Mouse-free WM self-test: drive a title-bar drag-move then a close-box
# click on the just-created autowin by calling the real gesture machine
# (wm_button) directly with ABSOLUTE cursor coordinates. This exercises
# the identical move/close/raise code paths a /dev/mouse packet would,
# but skips the packet string encode/decode round-trip entirely so the
# coordinates are exact and the result is deterministic.
def daemon_wm_selftest(scr_w: int64, scr_h: int64):
    if DWIN_COUNT == 0:
        return
    s: uint64 = DWIN_COUNT - 1
    PREV_BTN_L = 0
    # --- title-bar press: position the cursor inside the title bar (not
    # on the close box) and assert the left button down-edge. ---
    CUR_X = iclamp(DWIN_X[s] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[s] + TITLE_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- drag: relocate the cursor LEFT 200 / UP 30 with the button held;
    # wm_button tracks the grabbed window to follow. ---
    CUR_X = iclamp(CUR_X - 200, 0, scr_w - 1)
    CUR_Y = iclamp(CUR_Y - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- release: finalise the move (emits "WM move done x= y="). ---
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # The move raised the grabbed window to the top, so re-resolve its
    # slot (raise_slot bubbles it to DWIN_COUNT-1).
    cs: uint64 = DWIN_COUNT - 1
    # --- close: move the cursor onto the (relocated) window's close box,
    # then press+release inside it to destroy the window. ---
    CUR_X = iclamp(close_box_x(cs) + CLOSE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(close_box_y(cs) + CLOSE_BOX / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)       # press in close box -> arm close
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)       # release in close box -> destroy
    PREV_BTN_L = 0
    write_str(1, "DAEMON wm selftest done\n")


# Mouse-free PANEL/MENU self-test: drives the launcher through the SAME
# gesture machine (wm_button) real /dev/mouse packets reach, with
# absolute cursor coordinates. Sequence:
#   1. click the Applications button  -> "PANEL open menu"
#   2. click the first menu item      -> launches Terminal, closes menu
#                                        ("PANEL launch Terminal", a window)
#   3. click the button + an off-menu spot to prove open/dismiss is stable.
# Emits "DAEMON panel selftest done" at the end. No QEMU mouse injection.
def daemon_panel_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    MENU_OPEN = 0
    # --- click the Applications button: open the menu ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- ROUND-7: hover the first category (Accessories) to open its
    # submenu flyout, then click its first item (Terminal) to launch. ---
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    update_hover()                       # opens SUBMENU_OPEN = 0
    sxc: int64 = submenu_x() + SUBMENU_W / 2
    CUR_X = iclamp(sxc, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- re-open, then dismiss by clicking an off-menu desktop spot ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # Click far down on the empty desktop -> menu dismisses (no launch).
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "DAEMON panel selftest done\n")


# Terminal I/O self-test.
#
# Verifies the per-window stdin→shell→stdout→grid pipeline without a
# physical display or mouse, using the SAME pipe fds daemon_spawn_window
# created. Sequence:
#   1. Create one autowin (hamsh with real pipes).
#   2. Write "echo HAMUI_TERM_TEST\n" immediately to its stdin pipe.
#      The command sits in the pipe buffer until hamsh reads it.
#      (hamsh skips the getty-flush loop when stdin is DEVFD_PIPE_R,
#      so the bytes are NOT discarded — they arrive on the first
#      sys_read_nb(0,...) poll inside ed_readline.)
#   3. Non-blocking poll (sys_read_nb + sys_yield) the stdout pipe
#      until "HAMUI_TERM_TEST" appears in the terminal grid or the
#      idle counter (200000 empty reads) is exhausted.
#   4. Check the grid. PASS if the sentinel is present.
#
# Also verifies the focus-switch routing: create a SECOND window, click
# its body (synthetic wm_button on its body area) and confirm the focus
# slot switches, then route a second sentinel to that window.
#
# Emits "TERM IO PASS" / "TERM IO FAIL <reason>" on stdout.
# autoflag=5 in cmd_daemon_auto activates this test.
#
# ---- Taskbar / minimize / clock self-test (autoflag == 6) ----------
# Exercises the three new panel features deterministically without
# QEMU mouse injection:
#
#   1. TASKBAR: create two windows, assert DWIN_COUNT == 2, assert each
#      taskbar_btn_x() is within the panel, emit "TASKBAR 2 windows".
#   2. FOCUS via taskbar: simulate a taskbar click on slot 0 (lower window)
#      and assert it becomes the topmost slot (daemon_focus_slot()==1 after
#      raise), emit "TASKBAR focus OK".
#   3. MINIMIZE: simulate a minimize-box click on the topmost window, assert
#      DWIN_HIDDEN becomes 1, emit "TASKBAR minimize OK".
#   4. RESTORE: simulate a taskbar click on the minimized window, assert
#      DWIN_HIDDEN becomes 0, emit "TASKBAR restore OK".
#   5. CLOCK: call clock_refresh(0), assert clock_str is non-empty (not all
#      '?'), emit "TASKBAR clock OK" or "TASKBAR clock UNAVAILABLE".
#
# Emits "TASKBAR PASS" at the end.  autoflag==6 activates this test.
def daemon_taskbar_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    # --- Step 1: create two windows ---
    daemon_spawn_window(200, 80, 300, 200)
    daemon_spawn_window(300, 120, 300, 200)
    if DWIN_COUNT < 2:
        write_str(1, "TASKBAR FAIL: fewer than 2 windows spawned\n")
        return
    write_str(1, "TASKBAR 2 windows\n")
    # Assert taskbar buttons are within the screen (not off-screen).
    tb0x: int64 = taskbar_btn_x(0)
    tb1x: int64 = taskbar_btn_x(1)
    if tb0x < taskbar_start_x() or tb1x <= tb0x:
        write_str(1, "TASKBAR FAIL: bad button geometry\n")
        return
    write_str(1, "TASKBAR geometry OK\n")
    # --- Step 2: taskbar click on slot 0 to raise it ---
    # After two spawns, slot 0 = first window, slot 1 = topmost.
    # Click the taskbar button for slot 0.
    CUR_X = iclamp(tb0x + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise slot 0 should now be at DWIN_COUNT-1 (topmost / focused).
    new_top: int64 = daemon_focus_slot()
    if new_top < 0:
        write_str(1, "TASKBAR FAIL: no focused window after taskbar raise\n")
        return
    write_str(1, "TASKBAR focus OK\n")
    # --- Step 3: minimize the topmost window via its minimize box ---
    top_s: uint64 = cast[uint64](new_top)
    mx: int64 = iclamp(minimize_box_x(top_s) + MINIMIZE_BOX / 2, 0, scr_w - 1)
    my: int64 = iclamp(minimize_box_y(top_s) + MINIMIZE_BOX / 2, 0, scr_h - 1)
    CUR_X = mx
    CUR_Y = my
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_HIDDEN[top_s] == 0:
        write_str(1, "TASKBAR FAIL: minimize did not set DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR minimize OK\n")
    # --- Step 4: restore via taskbar click ---
    # The minimized window is still at slot top_s in the table.
    rst_tbx: int64 = taskbar_btn_x(top_s)
    CUR_X = iclamp(rst_tbx + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After restore DWIN_HIDDEN should be 0 (the window is visible again).
    # The slot may have been raised, so scan all slots for HIDDEN==0.
    all_visible: int32 = 1
    ci: uint64 = 0
    while ci < DWIN_COUNT:
        if DWIN_HIDDEN[ci] != 0:
            all_visible = 0
        ci = ci + 1
    if all_visible == 0:
        write_str(1, "TASKBAR FAIL: restore did not clear DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR restore OK\n")
    # --- Step 5: clock refresh ---
    clock_refresh(0)
    # The clock string should be non-empty (first char is a digit or '?').
    clk_ok: int32 = 0
    if clock_str[0] != 0:
        clk_ok = 1
    if clk_ok != 0:
        if clock_str[0] == 63:
            write_str(1, "TASKBAR clock UNAVAILABLE\n")
        else:
            write_str(1, "TASKBAR clock OK\n")
    else:
        write_str(1, "TASKBAR FAIL: clock_str empty after refresh\n")
        return
    write_str(1, "TASKBAR PASS\n")


# ====================================================================
# WORKSPACE self-test (autoflag == 9)
# ====================================================================
# Verifies MATE virtual desktops + the pager applet deterministically,
# sampling composited pixels so it works with no GUI:
#   1. Create a window on workspace 1; sample a body pixel -> visible.
#   2. Switch to workspace 2 (via workspace_switch); the SAME body pixel
#      must now be the desktop backdrop (window hidden by ws filter).
#   3. Switch back to workspace 1; the body pixel is visible again.
#   4. Pager click: synthesise a left-click on pager cell 3 and assert
#      CUR_WS becomes 2 (0-based) i.e. desktop 3.
#   5. F-key hotkey path: call workspace_switch directly via the same
#      entry the key pump uses; assert it lands.
# Emits "[DE_ws] PASS" / "[DE_ws] FAIL <reason>".
def daemon_workspace_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    # --- Step 1: window on workspace 1 (CUR_WS==0) ---
    win_x: int64 = 300
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 220
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[DE_ws] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    # A body pixel (clear of title bar + borders).
    bx: int64 = DWIN_X[sl] + DWIN_W[sl] / 2
    by: int64 = DWIN_Y[sl] + TITLE_H + 30
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    s1: uint64 = daemon_screen_sample(bx, by)
    if s1 == bg:
        write_str(1, "[DE_ws] FAIL window not visible on its own workspace\n")
        return
    write_str(1, "[DE_ws] window visible on ws1\n")
    # --- Step 2: switch to workspace 2; body pixel must be backdrop ---
    workspace_switch(1)
    if CUR_WS != 1:
        write_str(1, "[DE_ws] FAIL workspace_switch did not change CUR_WS\n")
        return
    s2: uint64 = daemon_screen_sample(bx, by)
    if s2 != bg:
        write_str(1, "[DE_ws] FAIL window still visible after ws switch\n")
        return
    write_str(1, "[DE_ws] window hidden on ws2\n")
    # --- Step 3: switch back; window visible again ---
    workspace_switch(0)
    s3: uint64 = daemon_screen_sample(bx, by)
    if s3 == bg:
        write_str(1, "[DE_ws] FAIL window not restored on ws1\n")
        return
    write_str(1, "[DE_ws] window restored on ws1\n")
    # --- Step 4: pager click switches workspace ---
    px0: int64 = pager_x0(scr_w)
    cell3_cx: int64 = px0 + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    CUR_X = iclamp(cell3_cx, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CUR_WS != 2:
        write_str(1, "[DE_ws] FAIL pager click did not switch workspace\n")
        return
    write_str(1, "[DE_ws] pager click OK\n")
    # --- Step 5: hotkey-path workspace switch (same entry the key pump uses) ---
    workspace_switch(0)
    if CUR_WS != 0:
        write_str(1, "[DE_ws] FAIL hotkey-path switch failed\n")
        return
    write_str(1, "[DE_ws] hotkey path OK\n")
    daemon_present()
    write_str(1, "[DE_ws] PASS\n")


# ====================================================================
# DECORATION self-test (autoflag == 10)
# ====================================================================
# Verifies the MATE-style themed window decorations by sampling pixels:
#   1. Title-bar gradient: the top row and bottom row of an active
#      window's title bar must differ (a real gradient, not a flat fill).
#   2. Beveled border: the top-left outer corner is the light highlight
#      tint, the bottom-right outer corner is the dark shadow tint.
#   3. Maximize button: a pixel inside the maximize box is the button
#      colour (green-ish), and the box hit-tests true.
#   4. Maximize/restore toggle: click the maximize box; the window fills
#      the work area; click again; it returns to its saved rectangle.
# Emits "[DE_deco] PASS" / "[DE_deco] FAIL <reason>".
def daemon_decoration_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    win_x: int64 = 200
    win_y: int64 = 140
    win_w: int64 = 360
    win_h: int64 = 240
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[DE_deco] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wx: int64 = DWIN_X[sl]
    wy: int64 = DWIN_Y[sl]
    ww: int64 = DWIN_W[sl]
    wh: int64 = DWIN_H[sl]
    # --- Step 1: title-bar gradient (top vs bottom rows differ) ---
    tx: int64 = wx + ww / 2          # mid title bar, clear of buttons + text
    top_px: uint64 = daemon_screen_sample(tx, wy + 3)
    bot_px: uint64 = daemon_screen_sample(tx, wy + TITLE_H - 2)
    if top_px == bot_px:
        write_str(1, "[DE_deco] FAIL title bar is flat (no gradient)\n")
        return
    write_str(1, "[DE_deco] title gradient OK\n")
    # --- Step 2: beveled border corners ---
    tl: uint64 = daemon_screen_sample(wx, wy)
    br: uint64 = daemon_screen_sample(wx + ww - 1, wy + wh - 1)
    hi: uint64 = (cast[uint64](BEVEL_HI_R) << 16) \
        | (cast[uint64](BEVEL_HI_G) << 8) | cast[uint64](BEVEL_HI_B)
    lo: uint64 = (cast[uint64](BEVEL_LO_R) << 16) \
        | (cast[uint64](BEVEL_LO_G) << 8) | cast[uint64](BEVEL_LO_B)
    if tl != hi:
        write_str(1, "[DE_deco] FAIL top-left corner not highlight bevel\n")
        return
    if br != lo:
        write_str(1, "[DE_deco] FAIL bottom-right corner not shadow bevel\n")
        return
    write_str(1, "[DE_deco] beveled border OK\n")
    # --- Step 3: maximize button present ---
    if in_maximize_box(sl, maximize_box_x(sl) + 1, maximize_box_y(sl) + 1) == 0:
        write_str(1, "[DE_deco] FAIL maximize box hit-test failed\n")
        return
    write_str(1, "[DE_deco] maximize button OK\n")
    # --- Step 4: maximize/restore toggle via the maximize box click ---
    sav_w: int64 = DWIN_W[sl]
    sav_h: int64 = DWIN_H[sl]
    CUR_X = iclamp(maximize_box_x(sl) + MAXIMIZE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(maximize_box_y(sl) + MAXIMIZE_BOX / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_MAXED[sl] == 0:
        write_str(1, "[DE_deco] FAIL maximize did not set MAXED\n")
        return
    if DWIN_W[sl] != scr_w or DWIN_H[sl] != scr_h - PANEL_H:
        write_str(1, "[DE_deco] FAIL maximized geometry wrong\n")
        return
    write_str(1, "[DE_deco] maximize OK\n")
    # Restore: click the (relocated) maximize box again.
    CUR_X = iclamp(maximize_box_x(sl) + MAXIMIZE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(maximize_box_y(sl) + MAXIMIZE_BOX / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_MAXED[sl] != 0:
        write_str(1, "[DE_deco] FAIL restore did not clear MAXED\n")
        return
    if DWIN_W[sl] != sav_w or DWIN_H[sl] != sav_h:
        write_str(1, "[DE_deco] FAIL restore geometry not original\n")
        return
    write_str(1, "[DE_deco] restore OK\n")
    daemon_present()
    write_str(1, "[DE_deco] PASS\n")


# ====================================================================
# CONTEXT-MENU self-test (autoflag == 11)
# ====================================================================
# Verifies right-click context menus + the GNOME2 menu bar:
#   1. Menu bar: three top-level buttons hit-test (Applications/Places/
#      System); open Applications via wm_button + assert MENU_BAR_OPEN.
#   2. Desktop context menu: right-click empty desktop (wm_rbutton) opens
#      a 2-item menu (CTX_OPEN, CTX_KIND==0); sample a menu pixel to prove
#      it composites; left-click item 0 spawns a New Terminal window.
#   3. Window context menu: right-click a window title bar opens the
#      window menu (CTX_KIND==1); left-click "Close" destroys the window.
# Emits "[DE_ctx] PASS" / "[DE_ctx] FAIL <reason>".
def daemon_ctxmenu_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    # --- Step 1: menu bar hit-test + open ---
    if menubar_btn_at(menubar_btn_x(0) + 2, PANEL_H / 2) != 0:
        write_str(1, "[DE_ctx] FAIL Applications button hit-test\n")
        return
    if menubar_btn_at(menubar_btn_x(2) + 2, PANEL_H / 2) != 2:
        write_str(1, "[DE_ctx] FAIL System button hit-test\n")
        return
    write_str(1, "[DE_ctx] menu bar geometry OK\n")
    CUR_X = iclamp(menubar_btn_x(0) + 4, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if MENU_BAR_OPEN != 0:
        write_str(1, "[DE_ctx] FAIL Applications menu did not open\n")
        return
    write_str(1, "[DE_ctx] Applications menu open\n")
    # Close it again (click the same button).
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- Step 2: desktop context menu via right-click ---
    CUR_X = iclamp(scr_w / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h / 2, 0, scr_h - 1)
    PREV_BTN_R = 0
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    wm_rbutton(0, scr_w, scr_h)
    PREV_BTN_R = 0
    if CTX_OPEN == 0 or CTX_KIND != 0:
        write_str(1, "[DE_ctx] FAIL desktop context menu did not open\n")
        return
    # Sample a pixel inside the menu body to prove it composites.
    msx: int64 = CTX_X + CTX_W / 2
    msy: int64 = CTX_Y + CTX_ITEM_H / 2
    mpx: uint64 = daemon_screen_sample(msx, msy)
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    if mpx == bg:
        write_str(1, "[DE_ctx] FAIL context menu not composited\n")
        return
    write_str(1, "[DE_ctx] desktop context menu OK\n")
    # Left-click item 0 (New Terminal) -> spawns a window.
    before: uint64 = DWIN_COUNT
    CUR_X = iclamp(CTX_X + CTX_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(CTX_Y + CTX_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT <= before:
        write_str(1, "[DE_ctx] FAIL New Terminal did not spawn a window\n")
        return
    if CTX_OPEN != 0:
        write_str(1, "[DE_ctx] FAIL context menu did not close on click\n")
        return
    write_str(1, "[DE_ctx] New Terminal spawned\n")
    # --- Step 3: window context menu -> Close ---
    sl: uint64 = DWIN_COUNT - 1
    # Right-click the window's title bar.
    CUR_X = iclamp(DWIN_X[sl] + 40, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[sl] + TITLE_H / 2, 0, scr_h - 1)
    PREV_BTN_R = 0
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    wm_rbutton(0, scr_w, scr_h)
    PREV_BTN_R = 0
    if CTX_OPEN == 0 or CTX_KIND != 1:
        write_str(1, "[DE_ctx] FAIL window context menu did not open\n")
        return
    write_str(1, "[DE_ctx] window context menu OK\n")
    # --- Step 3b: ROUND-24 "Always on Bottom" (keep-below) toggle (row 6) ---
    # Capture the target's geometry: keep-below reorders the slot array
    # (enforce_ontop_order sinks the pin to the head) but leaves geometry
    # untouched, so we re-resolve by position rather than a stale index.
    bx: int64 = DWIN_X[sl]
    by: int64 = DWIN_Y[sl]
    if DWIN_BELOW[sl] != 0:
        write_str(1, "[DE_ctx] FAIL window pre-pinned below\n")
        return
    CUR_X = iclamp(CTX_X + CTX_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(CTX_Y + 6 * CTX_ITEM_H + CTX_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # Re-resolve the (possibly-moved) slot by matching the captured geometry.
    nsl: int64 = -1
    si: uint64 = 0
    while si < DWIN_COUNT:
        if DWIN_X[si] == bx and DWIN_Y[si] == by:
            nsl = cast[int64](si)
        si = si + 1
    if nsl < 0 or DWIN_BELOW[cast[uint64](nsl)] == 0:
        write_str(1, "[DE_ctx] FAIL Always on Bottom did not pin window below\n")
        return
    write_str(1, "[DE_ctx] keep-below pinned via context menu\n")
    sl = cast[uint64](nsl)
    # Re-open the window menu for the Close step (the click above closed it).
    CUR_X = iclamp(bx + 40, 0, scr_w - 1)
    CUR_Y = iclamp(by + TITLE_H / 2, 0, scr_h - 1)
    PREV_BTN_R = 0
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    wm_rbutton(0, scr_w, scr_h)
    PREV_BTN_R = 0
    if CTX_OPEN == 0 or CTX_KIND != 1:
        write_str(1, "[DE_ctx] FAIL window menu did not re-open\n")
        return
    # Click the LAST item ("Close").
    last_item: int64 = cast[int64](ctx_count()) - 1
    wcnt: uint64 = DWIN_COUNT
    CUR_X = iclamp(CTX_X + CTX_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(CTX_Y + last_item * CTX_ITEM_H + CTX_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT >= wcnt:
        write_str(1, "[DE_ctx] FAIL Close did not destroy the window\n")
        return
    write_str(1, "[DE_ctx] window closed via context menu\n")
    daemon_present()
    write_str(1, "[DE_ctx] PASS\n")


# ---- Desktop-apps + snapping self-test (autoflag == 12) ------------
# Exercises the new built-in apps and window snapping deterministically
# (no mouse injection): a calculator computes 7+8=15 + a div-by-zero
# guard, the System Monitor refreshes live stats, and a window snaps to
# the left half then maximizes/restores. Emits "APPS PASS" on success,
# "APPS FAIL <reason>" otherwise.
apps_test_buf: Array[24, uint8]
def daemon_apps_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: calculator window + 7 + 8 = 15 ---
    daemon_spawn_app(APP_CALC, 100, 80, 220, 300)
    if DWIN_COUNT == 0:
        write_str(1, "APPS FAIL: calc not spawned\n")
        return
    cs: uint64 = DWIN_COUNT - 1
    if DWIN_APP[cs] != APP_CALC:
        write_str(1, "APPS FAIL: window is not a calculator\n")
        return
    write_str(1, "APPS calc window OK\n")
    calc_press(cs, 55)            # '7'
    calc_press(cs, 43)            # '+'
    calc_press(cs, 56)            # '8'
    calc_press(cs, 61)            # '='
    n: uint64 = calc_format(cs, &apps_test_buf[0])
    if n != 2 or apps_test_buf[0] != 49 or apps_test_buf[1] != 53:
        write_str(1, "APPS FAIL: 7+8 did not equal 15\n")
        return
    write_str(1, "APPS calc 7+8=15 OK\n")
    # Divide-by-zero -> error flag.
    calc_press(cs, 67)            # 'C'
    calc_press(cs, 53)            # '5'
    calc_press(cs, 47)            # '/'
    calc_press(cs, 48)            # '0'
    calc_press(cs, 61)            # '='
    if CALC_ERR[cs] == 0:
        write_str(1, "APPS FAIL: div-by-zero not flagged\n")
        return
    write_str(1, "APPS calc div0 OK\n")
    # --- Step 2: system monitor refresh ---
    daemon_spawn_app(APP_SYSMON, 360, 80, 360, 220)
    sysmon_refresh(0)
    if sysmon_line1[0] == 0:
        write_str(1, "APPS FAIL: sysmon line empty\n")
        return
    write_str(1, "APPS sysmon OK\n")
    # --- Step 3: snapping (left half, then maximize toggle/restore) ---
    sm_slot: uint64 = DWIN_COUNT - 1
    float_x: int64 = DWIN_X[sm_slot]
    float_w: int64 = DWIN_W[sm_slot]
    snap_apply(sm_slot, 2, scr_w, scr_h)   # left half
    if DWIN_X[sm_slot] != 0 or DWIN_W[sm_slot] != scr_w / 2 or DWIN_SNAP[sm_slot] != 2:
        write_str(1, "APPS FAIL: left-snap geometry wrong\n")
        return
    write_str(1, "APPS snap-left OK\n")
    # Toggle maximize while snapped restores to the saved float geometry.
    window_toggle_maximize(sm_slot, scr_w, scr_h)
    if DWIN_SNAP[sm_slot] != 0 or DWIN_X[sm_slot] != float_x or DWIN_W[sm_slot] != float_w:
        write_str(1, "APPS FAIL: restore from snap wrong\n")
        return
    write_str(1, "APPS restore OK\n")
    # Toggle maximize from float -> maximized full-screen.
    window_toggle_maximize(sm_slot, scr_w, scr_h)
    if DWIN_W[sm_slot] != scr_w or DWIN_SNAP[sm_slot] != 1:
        write_str(1, "APPS FAIL: maximize geometry wrong\n")
        return
    write_str(1, "APPS maximize OK\n")
    write_str(1, "APPS PASS\n")


# ====================================================================
# ROUND-3 MATE-feel self-test (autoflag == 13)
# ====================================================================
# Exercises the round-3 desktop features deterministically, mouse-free:
#   1. ALT-TAB CYCLER: with 3 windows, cycle_step(1) opens the switcher
#      selecting window 2, a second step selects window 3, cycle_commit()
#      raises the selected window to the front. Asserts CYCLE_OPEN toggles
#      and the chosen window lands on top.
#   2. DOUBLE-CLICK SHADE: two title-bar presses on the same window
#      within DBLCLICK_FRAMES rolls it up (DWIN_SHADED==1, DWIN_H==SHADE_H).
#   3. CHANGE BACKGROUND: bg_cycle() advances ROOT_* to a new palette
#      entry (the colour actually changes).
#   4. ARRANGE WINDOWS: windows_arrange() un-maximizes + tiles all visible
#      windows into a grid (no window left maximized; geometry changed).
#   5. NOTIFICATION + PAGER geometry: the tray sits left of the clock and
#      right of the pager without overlap.
# Emits "[DE3] PASS" / "[DE3] FAIL <reason>".
def daemon_round3_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    CYCLE_OPEN = 0
    bg_palette_init()
    # --- Step 1: three windows + alt-tab cycler ---
    daemon_spawn_window(120, 80, 280, 180)
    daemon_spawn_window(220, 120, 280, 180)
    daemon_spawn_window(320, 160, 280, 180)
    if DWIN_COUNT < 3:
        write_str(1, "[DE3] FAIL fewer than 3 windows\n")
        return
    front_wid_before: int32 = DWIN_WID[DWIN_COUNT - 1]
    cycle_step(1)
    if CYCLE_OPEN == 0:
        write_str(1, "[DE3] FAIL cycler did not open\n")
        return
    if CYCLE_SEL != 1:
        write_str(1, "[DE3] FAIL cycler start sel wrong\n")
        return
    cycle_step(1)
    if CYCLE_SEL != 2:
        write_str(1, "[DE3] FAIL cycler advance wrong\n")
        return
    # The window we'll commit to is the one at cycler position 2.
    target_slot: int64 = cycle_slot_for_pos(2)
    target_wid: int32 = -1
    if target_slot >= 0:
        target_wid = DWIN_WID[cast[uint64](target_slot)]
    cycle_commit()
    if CYCLE_OPEN != 0:
        write_str(1, "[DE3] FAIL cycler did not close on commit\n")
        return
    # The committed window must now be the front-most (topmost) window.
    if DWIN_WID[DWIN_COUNT - 1] != target_wid:
        write_str(1, "[DE3] FAIL committed window not raised\n")
        return
    if front_wid_before == DWIN_WID[DWIN_COUNT - 1]:
        write_str(1, "[DE3] FAIL focus unchanged after cycle\n")
        return
    write_str(1, "[DE3] cycler OK\n")
    # --- Step 2: double-click title bar -> shade (roll up) ---
    top2: uint64 = DWIN_COUNT - 1
    DWIN_SNAP[top2] = 0
    DWIN_MAXED[top2] = 0
    DWIN_SHADED[top2] = 0
    tcx: int64 = iclamp(DWIN_X[top2] + 30, 0, scr_w - 1)
    tcy: int64 = iclamp(DWIN_Y[top2] + 4, 0, scr_h - 1)
    CUR_X = tcx
    CUR_Y = tcy
    # First click on the title bar.
    LAST_TCLICK_SLOT = -1
    WM_FRAME = 100
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # Second click shortly after (same slot, within DBLCLICK_FRAMES).
    WM_FRAME = 110
    # Re-aim at the (possibly raised) top window's title bar.
    top2 = DWIN_COUNT - 1
    CUR_X = iclamp(DWIN_X[top2] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[top2] + 4, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    shaded_any: int32 = 0
    di3: uint64 = 0
    while di3 < DWIN_COUNT:
        if DWIN_SHADED[di3] != 0 and DWIN_H[di3] == SHADE_H:
            shaded_any = 1
        di3 = di3 + 1
    if shaded_any == 0:
        write_str(1, "[DE3] FAIL double-click did not shade\n")
        return
    write_str(1, "[DE3] dblclick shade OK\n")
    # --- Step 3: change background ---
    bgr0: uint8 = ROOT_R
    bgg0: uint8 = ROOT_G
    bgb0: uint8 = ROOT_B
    bg_cycle()
    if ROOT_R == bgr0 and ROOT_G == bgg0 and ROOT_B == bgb0:
        write_str(1, "[DE3] FAIL background did not change\n")
        return
    write_str(1, "[DE3] background OK\n")
    # --- Step 4: arrange windows (un-maximizes + tiles) ---
    windows_arrange(scr_w, scr_h)
    still_maxed: int32 = 0
    da: uint64 = 0
    while da < DWIN_COUNT:
        if DWIN_SNAP[da] != 0 or DWIN_MAXED[da] != 0:
            still_maxed = 1
        da = da + 1
    if still_maxed != 0:
        write_str(1, "[DE3] FAIL arrange left a window maximized\n")
        return
    write_str(1, "[DE3] arrange OK\n")
    # --- Step 5: notification-area + pager geometry (no overlap) ---
    ntfx: int64 = notif_x0(scr_w)
    pgx: int64 = pager_x0(scr_w)
    clkx: int64 = scr_w - CLOCK_W
    if pgx + pager_total_w() > ntfx:
        write_str(1, "[DE3] FAIL pager overlaps notification area\n")
        return
    if ntfx + NOTIF_W > clkx:
        write_str(1, "[DE3] FAIL notification overlaps clock\n")
        return
    write_str(1, "[DE3] tray geometry OK\n")
    daemon_present()
    write_str(1, "[DE3] PASS\n")


# ====================================================================
# ROUND-4 MATE-feel self-test (autoflag == 14)
# ====================================================================
# Mouse-free exercise of the round-4 features for CI:
#   1. THEME accent cycling: theme_cycle() changes the live ACCENT_* the
#      title-bar gradient reads; wraps after THEME_COUNT.
#   2. BACKGROUND + PANEL position prefs (persist in-memory).
#   3. KEYBOARD TILING: tile_focused() half/quarter-tiles the focused
#      window (DWIN_SNAP set to the requested mode, geometry within the
#      work area); restore via snap_apply(...,0,...).
#   4. SHOW-DESKTOP toggle minimizes all visible windows then restores
#      exactly that set.
#   5. MOVE-WINDOW-TO-WORKSPACE with wrap-around (window leaves CUR_WS).
#   6. SETTINGS app: settings_press() drives each row (theme/bg/panel).
# Emits "[DE4] PASS" / "[DE4] FAIL <reason>".
def daemon_round4_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    SHOWDESK_ON = 0
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: theme accent cycling ---
    a_top0: uint8 = ACCENT_TOP_R
    a_bot0: uint8 = ACCENT_BOT_B
    theme_cycle()
    if ACCENT_TOP_R == a_top0 and ACCENT_BOT_B == a_bot0:
        write_str(1, "[DE4] FAIL theme accent did not change\n")
        return
    if THEME_IDX != 1:
        write_str(1, "[DE4] FAIL theme idx wrong\n")
        return
    # Wrap: cycle THEME_COUNT-1 more times to come back to 0.
    twrap: int32 = 1
    while twrap < THEME_COUNT:
        theme_cycle()
        twrap = twrap + 1
    if THEME_IDX != 0:
        write_str(1, "[DE4] FAIL theme did not wrap\n")
        return
    write_str(1, "[DE4] theme OK\n")
    # --- Step 2: background + panel position prefs ---
    bgr0: uint8 = ROOT_R
    bgg0: uint8 = ROOT_G
    bgb0: uint8 = ROOT_B
    bg_cycle()
    if ROOT_R == bgr0 and ROOT_G == bgg0 and ROOT_B == bgb0:
        write_str(1, "[DE4] FAIL background did not change\n")
        return
    if PANEL_POS != 0:
        write_str(1, "[DE4] FAIL panel pos not default\n")
        return
    panel_pos_toggle()
    if PANEL_POS != 1:
        write_str(1, "[DE4] FAIL panel pos did not toggle\n")
        return
    panel_pos_toggle()
    if PANEL_POS != 0:
        write_str(1, "[DE4] FAIL panel pos did not toggle back\n")
        return
    write_str(1, "[DE4] prefs OK\n")
    # --- Step 3: keyboard tiling (half + quarter) ---
    daemon_spawn_window(140, 90, 300, 200)
    if DWIN_COUNT < 1:
        write_str(1, "[DE4] FAIL no window for tiling\n")
        return
    tslot: uint64 = DWIN_COUNT - 1
    # Left half (mode 2).
    tile_focused(2, scr_w, scr_h)
    if DWIN_SNAP[tslot] != 2:
        write_str(1, "[DE4] FAIL left-half tile mode wrong\n")
        return
    if DWIN_X[tslot] != 0 or DWIN_W[tslot] != scr_w / 2:
        write_str(1, "[DE4] FAIL left-half geometry wrong\n")
        return
    # Top-right quarter (mode 5).
    tile_focused(5, scr_w, scr_h)
    if DWIN_SNAP[tslot] != 5:
        write_str(1, "[DE4] FAIL quarter tile mode wrong\n")
        return
    qexp_x: int64 = scr_w / 2
    qexp_h: int64 = (scr_h - PANEL_H) / 2
    if DWIN_X[tslot] != qexp_x or DWIN_Y[tslot] != PANEL_H \
       or DWIN_H[tslot] != qexp_h:
        write_str(1, "[DE4] FAIL quarter geometry wrong\n")
        return
    # Restore to float.
    snap_apply(tslot, 0, scr_w, scr_h)
    if DWIN_SNAP[tslot] != 0:
        write_str(1, "[DE4] FAIL tile restore failed\n")
        return
    write_str(1, "[DE4] tiling OK\n")
    # --- Step 4: show-desktop toggle ---
    daemon_spawn_window(200, 120, 280, 180)
    vis_before: int64 = 0
    ci: uint64 = 0
    while ci < DWIN_COUNT:
        if win_on_cur_ws(ci) != 0:
            vis_before = vis_before + 1
        ci = ci + 1
    if vis_before < 2:
        write_str(1, "[DE4] FAIL fewer than 2 visible windows\n")
        return
    show_desktop_toggle()
    vis_mid: int64 = 0
    cj: uint64 = 0
    while cj < DWIN_COUNT:
        if win_on_cur_ws(cj) != 0:
            vis_mid = vis_mid + 1
        cj = cj + 1
    if vis_mid != 0:
        write_str(1, "[DE4] FAIL show-desktop did not minimize all\n")
        return
    show_desktop_toggle()
    vis_after: int64 = 0
    ck: uint64 = 0
    while ck < DWIN_COUNT:
        if win_on_cur_ws(ck) != 0:
            vis_after = vis_after + 1
        ck = ck + 1
    if vis_after != vis_before:
        write_str(1, "[DE4] FAIL show-desktop did not restore set\n")
        return
    write_str(1, "[DE4] show-desktop OK\n")
    # --- Step 5: move focused window to next workspace (wrap-around) ---
    mslot: uint64 = DWIN_COUNT - 1
    DWIN_WS[mslot] = WS_COUNT - 1          # force the wrap edge
    CUR_WS = WS_COUNT - 1
    nws3: int32 = CUR_WS + 1
    if nws3 >= WS_COUNT:
        nws3 = 0
    window_to_workspace(mslot, nws3)
    if DWIN_WS[mslot] != 0:
        write_str(1, "[DE4] FAIL move-to-workspace wrap wrong\n")
        return
    if win_on_cur_ws(mslot) != 0:
        write_str(1, "[DE4] FAIL window still visible after move\n")
        return
    CUR_WS = 0
    write_str(1, "[DE4] move-to-ws OK\n")
    # --- Step 6: Settings app rows ---
    sx: int64 = 120
    sy: int64 = PANEL_H + 30
    daemon_spawn_app(APP_SETTINGS, sx, sy, 320, 200)
    sslot: uint64 = DWIN_COUNT - 1
    if DWIN_APP[sslot] != APP_SETTINGS:
        write_str(1, "[DE4] FAIL settings window not created\n")
        return
    # Theme row.
    th0: int32 = THEME_IDX
    settings_press(sslot, 0)
    if THEME_IDX == th0:
        write_str(1, "[DE4] FAIL settings theme row inert\n")
        return
    # Panel row.
    pp0: int32 = PANEL_POS
    settings_press(sslot, 2)
    if PANEL_POS == pp0:
        write_str(1, "[DE4] FAIL settings panel row inert\n")
        return
    # Row hit-test: the row-2 centre must map back to row 2.
    rcy: int64 = settings_row_y(sslot, 2) + 4
    rcx: int64 = DWIN_X[sslot] + 20
    if settings_row_at(sslot, rcx, rcy) != 2:
        write_str(1, "[DE4] FAIL settings row hit-test wrong\n")
        return
    # Reset row restores defaults (Reset is the last row; ROUND-8 added a
    # Workspaces row so Reset moved to index 5).
    settings_press(sslot, 5)
    if THEME_IDX != 0 or PANEL_POS != 0 or BG_IDX != 0:
        write_str(1, "[DE4] FAIL settings reset did not restore defaults\n")
        return
    write_str(1, "[DE4] settings OK\n")
    daemon_present()
    write_str(1, "[DE4] PASS\n")


# ====================================================================
# ROUND-5 MATE-feel self-test (autoflag == 15)
# ====================================================================
# Mouse-free exercise of the round-5 features for CI:
#   1. MRU Alt-Tab order: focusing windows reorders the cycler so a single
#      cycle toggles between the two most-recently-used windows (not just
#      stacking order); closing one drops it from the MRU list.
#   2. EDGE/CORNER snap classification: snap_zone_for() maps cursor points
#      to maximize / half / quarter modes, and snap_zone_rect() yields the
#      matching landing geometry.
#   3. LIVE SNAP PREVIEW: a title-bar drag into a corner lights up
#      SNAP_PREVIEW_ON with the right mode; the release commits a quarter
#      tile via the real gesture machine.
#   4. LIVE TRAY BADGE: notif_count_refresh() tracks the visible-window
#      count and the tray reserves a third cell for it.
#   5. PAGER click-to-switch: a synthesized panel left-click on a pager
#      cell switches the current workspace.
#   6. DESKTOP CONTEXT MENU: the round-5 desktop menu now offers a Settings
#      row that spawns the preferences window.
# Emits "[DE5] PASS" / "[DE5] FAIL <reason>".
def daemon_round5_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    SNAP_PREVIEW_ON = 0
    SNAP_PREVIEW_MODE = 0
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: MRU Alt-Tab order ---
    daemon_spawn_window(120, 80, 280, 180)     # slot 0
    daemon_spawn_window(220, 120, 280, 180)    # slot 1
    daemon_spawn_window(320, 160, 280, 180)    # slot 2
    if DWIN_COUNT < 3:
        write_str(1, "[DE5] FAIL fewer than 3 windows\n")
        return
    # Focus order: raise slot 0, then slot for the original middle window,
    # establishing a deterministic MRU history independent of stacking.
    uid_a: int32 = DWIN_UID[0]
    uid_b: int32 = DWIN_UID[1]
    uid_c: int32 = DWIN_UID[2]
    daemon_raise_slot(slot_for_uid(uid_a))     # MRU: [a]
    daemon_raise_slot(slot_for_uid(uid_c))     # MRU: [c, a]
    daemon_raise_slot(slot_for_uid(uid_b))     # MRU: [b, c, a]
    # Cycler position 0 must be the most-recently-focused window (b),
    # position 1 the one before it (c).
    p0: int64 = mru_slot_for_pos(0)
    p1: int64 = mru_slot_for_pos(1)
    p2: int64 = mru_slot_for_pos(2)
    if p0 < 0 or DWIN_UID[cast[uint64](p0)] != uid_b:
        write_str(1, "[DE5] FAIL MRU pos0 not most-recent\n")
        return
    if p1 < 0 or DWIN_UID[cast[uint64](p1)] != uid_c:
        write_str(1, "[DE5] FAIL MRU pos1 wrong\n")
        return
    if p2 < 0 or DWIN_UID[cast[uint64](p2)] != uid_a:
        write_str(1, "[DE5] FAIL MRU pos2 wrong\n")
        return
    # A single Alt+Tab (open at pos 1) commits the second-most-recent (c).
    CYCLE_OPEN = 0
    cycle_step(1)
    if CYCLE_OPEN == 0 or CYCLE_SEL != 1:
        write_str(1, "[DE5] FAIL cycler did not open at MRU pos1\n")
        return
    cycle_commit()
    if DWIN_UID[DWIN_COUNT - 1] != uid_c:
        write_str(1, "[DE5] FAIL Alt-Tab did not raise MRU window\n")
        return
    write_str(1, "[DE5] MRU OK\n")
    # MRU drop on close: closing the front window (c) removes it from MRU.
    mru_len_before: uint64 = MRU_LEN
    daemon_close_slot(cast[int64](DWIN_COUNT - 1))
    if MRU_LEN >= mru_len_before:
        write_str(1, "[DE5] FAIL MRU not pruned on close\n")
        return
    di: uint64 = 0
    while di < MRU_LEN:
        if MRU_UID[di] == uid_c:
            write_str(1, "[DE5] FAIL closed window still in MRU\n")
            return
        di = di + 1
    write_str(1, "[DE5] MRU-drop OK\n")
    # --- Step 2: edge/corner snap-zone classification + geometry ---
    # Top edge -> maximize (1).
    if snap_zone_for(scr_w / 2, PANEL_H + 1, scr_w, scr_h) != 1:
        write_str(1, "[DE5] FAIL top edge not maximize\n")
        return
    # Left edge (mid-height) -> left half (2).
    if snap_zone_for(1, scr_h / 2, scr_w, scr_h) != 2:
        write_str(1, "[DE5] FAIL left edge not half\n")
        return
    # Right edge -> right half (3).
    if snap_zone_for(scr_w - 1, scr_h / 2, scr_w, scr_h) != 3:
        write_str(1, "[DE5] FAIL right edge not half\n")
        return
    # Top-left corner -> quarter (4).
    if snap_zone_for(1, PANEL_H + 1, scr_w, scr_h) != 4:
        write_str(1, "[DE5] FAIL TL corner not quarter\n")
        return
    # Bottom-right corner -> quarter (7).
    if snap_zone_for(scr_w - 1, scr_h - 1, scr_w, scr_h) != 7:
        write_str(1, "[DE5] FAIL BR corner not quarter\n")
        return
    # Centre -> no snap (0).
    if snap_zone_for(scr_w / 2, scr_h / 2, scr_w, scr_h) != 0:
        write_str(1, "[DE5] FAIL centre snaps\n")
        return
    # snap_zone_rect for the top-right quarter must match snap_apply mode 5.
    snap_zone_rect(5, scr_w, scr_h)
    if snapzone_x != scr_w / 2 or snapzone_y != PANEL_H \
       or snapzone_h != (scr_h - PANEL_H) / 2:
        write_str(1, "[DE5] FAIL quarter rect geometry wrong\n")
        return
    write_str(1, "[DE5] snap-zones OK\n")
    # --- Step 3: live snap preview during a real title-bar drag ---
    daemon_spawn_window(200, 120, 300, 200)
    ds: uint64 = DWIN_COUNT - 1
    DWIN_SNAP[ds] = 0
    DWIN_MAXED[ds] = 0
    PREV_BTN_L = 0
    # Press on the title bar.
    CUR_X = iclamp(DWIN_X[ds] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[ds] + 4, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # Drag the cursor into the top-left corner: the preview must light up
    # with the quarter mode (4).
    CUR_X = 2
    CUR_Y = PANEL_H + 2
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if SNAP_PREVIEW_ON == 0 or SNAP_PREVIEW_MODE != 4:
        write_str(1, "[DE5] FAIL snap preview not active in corner\n")
        return
    # Release: commits the quarter snap, clears the preview.
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if SNAP_PREVIEW_ON != 0:
        write_str(1, "[DE5] FAIL snap preview not cleared on release\n")
        return
    # The dragged window (now front-most) must be top-left quarter-tiled.
    fs: uint64 = DWIN_COUNT - 1
    if DWIN_SNAP[fs] != 4:
        write_str(1, "[DE5] FAIL drag did not corner-snap\n")
        return
    if DWIN_X[fs] != 0 or DWIN_Y[fs] != PANEL_H \
       or DWIN_W[fs] != scr_w / 2 or DWIN_H[fs] != (scr_h - PANEL_H) / 2:
        write_str(1, "[DE5] FAIL corner-snap geometry wrong\n")
        return
    write_str(1, "[DE5] drag-snap OK\n")
    # --- Step 4: live tray window-count badge ---
    notif_count_refresh()
    cnt_before: int64 = NOTIF_WIN_COUNT
    if cnt_before != cycle_visible_count():
        write_str(1, "[DE5] FAIL tray badge count mismatch\n")
        return
    daemon_spawn_window(150, 100, 260, 160)
    notif_count_refresh()
    if NOTIF_WIN_COUNT != cnt_before + 1:
        write_str(1, "[DE5] FAIL tray badge did not track new window\n")
        return
    # The tray must reserve a third cell for the badge.
    if NOTIF_CELLS < 3:
        write_str(1, "[DE5] FAIL tray has no badge cell\n")
        return
    write_str(1, "[DE5] tray-badge OK\n")
    # --- Step 5: pager click-to-switch ---
    CUR_WS = 0
    pcx: int64 = pager_x0(scr_w) + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    pcy: int64 = PANEL_H / 2
    # Confirm the hit-test lands on cell 2, then drive a real panel click.
    if pager_cell_at(pcx, pcy, scr_w) != 2:
        write_str(1, "[DE5] FAIL pager hit-test wrong\n")
        return
    CUR_X = pcx
    CUR_Y = pcy
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CUR_WS != 2:
        write_str(1, "[DE5] FAIL pager click did not switch workspace\n")
        return
    CUR_WS = 0
    write_str(1, "[DE5] pager-click OK\n")
    # --- Step 6: desktop context menu Settings row ---
    PREV_BTN_R = 0
    CUR_X = scr_w / 2
    CUR_Y = scr_h / 2
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    if CTX_OPEN == 0 or CTX_KIND != 0:
        write_str(1, "[DE5] FAIL desktop menu did not open\n")
        return
    if ctx_count() != 8:
        write_str(1, "[DE5] FAIL desktop menu missing Settings row\n")
        return
    # Row 3 is the Settings entry (rows 0..2 are Open Terminal / Open File
    # Manager / New Workspace).
    lbl1: Ptr[uint8] = ctx_item_label(3)
    if cstr_eq(lbl1, "Settings") == 0:
        write_str(1, "[DE5] FAIL row3 is not Settings\n")
        return
    set_before: uint64 = DWIN_COUNT
    ctx_invoke(3, scr_w, scr_h)
    if DWIN_COUNT != set_before + 1:
        write_str(1, "[DE5] FAIL Settings row did not spawn window\n")
        return
    if DWIN_APP[DWIN_COUNT - 1] != APP_SETTINGS:
        write_str(1, "[DE5] FAIL spawned window is not Settings app\n")
        return
    CTX_OPEN = 0
    write_str(1, "[DE5] ctxmenu-settings OK\n")
    daemon_present()
    write_str(1, "[DE5] PASS\n")


# ====================================================================
# ROUND-6 MATE-feel self-test (autoflag == 16)
# ====================================================================
# Mouse-free exercise of the round-6 window-resize features for CI. With no
# runtime observability on this host, the test drives the REAL gesture
# machine (wm_button / resize_*) and the REAL hit-testers with synthetic
# absolute coordinates, asserting geometry after each step:
#   1. GRIP hit-testing: resize_dir_at() classifies the 8 edge/corner grips
#      and returns 0 deep in the body and across the title-bar buttons.
#   2. EDGE resize: a drag on the right edge widens the window while the left
#      edge stays anchored; a drag on the bottom edge grows the height.
#   3. CORNER resize: a drag on the SE corner moves two edges at once; the
#      opposite (top-left) corner stays pinned.
#   4. MINIMUM size: dragging an edge past the opposite one clamps to
#      RESIZE_MIN_W / RESIZE_MIN_H, never inverting the rectangle.
#   5. SNAP DETACH: resizing a maximized window clears its snap flag so it
#      becomes a normal floating window again (MATE behaviour).
#   6. WINDOW MENU "Resize": the window context menu now offers a Resize row
#      that arms an interactive SE-corner resize via the gesture machine.
# Emits "[DE6] PASS" / "[DE6] FAIL <reason>".
def daemon_round6_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    SNAP_PREVIEW_ON = 0
    SNAP_PREVIEW_MODE = 0
    RESIZE_SLOT = -1
    RESIZE_DIR = 0
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: resize-grip hit classification ---
    daemon_spawn_window(200, 120, 300, 200)    # slot 0
    if DWIN_COUNT < 1:
        write_str(1, "[DE6] FAIL no window spawned\n")
        return
    s0: uint64 = DWIN_COUNT - 1
    # Force a known float rectangle independent of cascade placement.
    DWIN_X[s0] = 200
    DWIN_Y[s0] = 120
    DWIN_W[s0] = 300
    DWIN_H[s0] = 200
    DWIN_SNAP[s0] = 0
    DWIN_MAXED[s0] = 0
    wx0: int64 = DWIN_X[s0]
    wy0: int64 = DWIN_Y[s0]
    ww0: int64 = DWIN_W[s0]
    wh0: int64 = DWIN_H[s0]
    # Right edge (mid-height) -> mask bit1 (2) only.
    if resize_dir_at(s0, wx0 + ww0 - 1, wy0 + wh0 / 2) != 2:
        write_str(1, "[DE6] FAIL right-edge grip mask wrong\n")
        return
    # Left edge -> mask bit0 (1).
    if resize_dir_at(s0, wx0, wy0 + wh0 / 2) != 1:
        write_str(1, "[DE6] FAIL left-edge grip mask wrong\n")
        return
    # Bottom edge -> mask bit3 (8).
    if resize_dir_at(s0, wx0 + ww0 / 2, wy0 + wh0 - 1) != 8:
        write_str(1, "[DE6] FAIL bottom-edge grip mask wrong\n")
        return
    # SE corner -> bits 2|8 = 10.
    if resize_dir_at(s0, wx0 + ww0 - 1, wy0 + wh0 - 1) != 10:
        write_str(1, "[DE6] FAIL SE-corner grip mask wrong\n")
        return
    # NW corner -> bits 1|4 = 5.
    if resize_dir_at(s0, wx0, wy0) != 5:
        write_str(1, "[DE6] FAIL NW-corner grip mask wrong\n")
        return
    # Deep body centre -> no grip (0).
    if resize_dir_at(s0, wx0 + ww0 / 2, wy0 + wh0 / 2) != 0:
        write_str(1, "[DE6] FAIL body centre is a grip\n")
        return
    # The close box sits at the top-right; its grip is suppressed so the
    # close button still wins there (mask must NOT include the top bit set
    # alone over the button — resize_dir_at returns 0 across the box).
    cbx: int64 = close_box_x(s0)
    cby: int64 = close_box_y(s0)
    if resize_dir_at(s0, cbx + 1, cby + 1) != 0:
        write_str(1, "[DE6] FAIL top grip shadows close box\n")
        return
    write_str(1, "[DE6] grips OK\n")
    # --- Step 2: right-edge resize widens, left edge anchored ---
    PREV_BTN_L = 0
    CUR_X = wx0 + ww0 - 1
    CUR_Y = wy0 + wh0 / 2
    wm_button(1, scr_w, scr_h)                 # press the right grip
    PREV_BTN_L = 1
    if GESTURE != 4 or RESIZE_SLOT < 0:
        write_str(1, "[DE6] FAIL right-edge press did not start resize\n")
        return
    # Drag the cursor 80px to the right.
    CUR_X = wx0 + ww0 - 1 + 80
    CUR_Y = wy0 + wh0 / 2
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    rsz: uint64 = cast[uint64](RESIZE_SLOT)
    if DWIN_X[rsz] != wx0:
        write_str(1, "[DE6] FAIL right-resize moved the left edge\n")
        return
    if DWIN_W[rsz] != ww0 + 80:
        write_str(1, "[DE6] FAIL right-resize width wrong\n")
        return
    wm_button(0, scr_w, scr_h)                 # release: commit
    PREV_BTN_L = 0
    if RESIZE_SLOT >= 0:
        write_str(1, "[DE6] FAIL resize state not cleared on release\n")
        return
    # Refresh the working rectangle after the widen.
    ww1: int64 = DWIN_W[s0]
    wh1: int64 = DWIN_H[s0]
    write_str(1, "[DE6] edge-resize OK\n")
    # --- Step 3: SE-corner resize moves two edges, NW corner pinned ---
    PREV_BTN_L = 0
    CUR_X = DWIN_X[s0] + DWIN_W[s0] - 1
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] - 1
    fixx: int64 = DWIN_X[s0]
    fixy: int64 = DWIN_Y[s0]
    wm_button(1, scr_w, scr_h)                 # grab the SE corner
    PREV_BTN_L = 1
    if RESIZE_DIR != 10:
        write_str(1, "[DE6] FAIL SE corner grip dir wrong\n")
        return
    # Pull the corner +60 right, +40 down.
    CUR_X = CUR_X + 60
    CUR_Y = CUR_Y + 40
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if DWIN_X[s0] != fixx or DWIN_Y[s0] != fixy:
        write_str(1, "[DE6] FAIL SE resize moved the NW corner\n")
        return
    if DWIN_W[s0] != ww1 + 60 or DWIN_H[s0] != wh1 + 40:
        write_str(1, "[DE6] FAIL SE resize geometry wrong\n")
        return
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "[DE6] corner-resize OK\n")
    # --- Step 4: minimum-size clamp (drag the right edge far left) ---
    ax: int64 = DWIN_X[s0]
    PREV_BTN_L = 0
    CUR_X = DWIN_X[s0] + DWIN_W[s0] - 1
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] / 2
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # Drag the right edge way past the left edge: width must clamp, never go
    # negative, and the left edge must stay pinned.
    CUR_X = DWIN_X[s0] - 500
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if DWIN_W[s0] < RESIZE_MIN_W:
        write_str(1, "[DE6] FAIL width fell below the minimum\n")
        return
    if DWIN_X[s0] != ax:
        write_str(1, "[DE6] FAIL min-clamp moved the anchored edge\n")
        return
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "[DE6] min-size OK\n")
    # --- Step 5: resizing a maximized window detaches the snap ---
    window_toggle_maximize(s0, scr_w, scr_h)
    if DWIN_SNAP[s0] == 0:
        write_str(1, "[DE6] FAIL window did not maximize for detach test\n")
        return
    PREV_BTN_L = 0
    # Grab the bottom edge of the now-maximized window.
    CUR_X = DWIN_X[s0] + DWIN_W[s0] / 2
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] - 1
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if DWIN_SNAP[s0] != 0 or DWIN_MAXED[s0] != 0:
        write_str(1, "[DE6] FAIL resize did not detach maximized snap\n")
        return
    CUR_Y = CUR_Y - 50
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "[DE6] snap-detach OK\n")
    # --- Step 6: window-menu "Resize" row arms a corner resize ---
    # ROUND-20 grew the window menu to 13 rows; Resize is now row 7.
    CTX_KIND = 1
    CTX_SLOT = cast[int64](s0)
    if ctx_count() != 13:
        write_str(1, "[DE6] FAIL window menu is not 13 rows\n")
        return
    lbl2: Ptr[uint8] = ctx_item_label(7)
    if cstr_eq(lbl2, "Resize") == 0:
        write_str(1, "[DE6] FAIL window menu row7 is not Resize\n")
        return
    # Invoke it: this should arm an SE-corner resize (GESTURE 4, dir 10).
    RESIZE_SLOT = -1
    RESIZE_DIR = 0
    GESTURE = 0
    ctx_invoke(7, scr_w, scr_h)
    if GESTURE != 4 or RESIZE_SLOT != cast[int64](s0) or RESIZE_DIR != 10:
        write_str(1, "[DE6] FAIL Resize menu row did not arm a resize\n")
        return
    # A subsequent drag + release through the gesture machine must resize +
    # then clear the state cleanly.
    mw0: int64 = DWIN_W[s0]
    CUR_X = DWIN_X[s0] + DWIN_W[s0] - 1 + 40
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] - 1
    wm_button(1, scr_w, scr_h)                 # held (PREV_BTN_L set by invoke)
    PREV_BTN_L = 1
    if DWIN_W[s0] != mw0 + 40:
        write_str(1, "[DE6] FAIL menu-armed resize did not track\n")
        return
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if RESIZE_SLOT >= 0 or GESTURE == 4:
        write_str(1, "[DE6] FAIL menu-armed resize not cleared\n")
        return
    CTX_OPEN = 0
    write_str(1, "[DE6] menu-resize OK\n")
    daemon_present()
    write_str(1, "[DE6] PASS\n")


# ====================================================================
# ROUND-7 MATE-feel self-test (autoflag == 17)
# ====================================================================
# Exercises, with synthetic inputs (no QEMU mouse/keyboard), the five
# new GNOME2/MATE features added this round:
#   1. Categorised Applications menu: category count + labels, submenu
#      open-on-hover, the (category,item)->flat-app mapping, and a click
#      inside a submenu flyout that launches the mapped app.
#   2. Clock calendar popup: click toggles it; the month grid layout +
#      day-of-week arithmetic (leap years, first-of-month weekday) are
#      verified against known dates.
#   3. Window-list taskbar grouping / raise (re-verifies the round-6
#      taskbar still raises a lower window via a synthetic click).
#   4. Focus model setting: the Settings "Focus" row toggles FOCUS_MODE,
#      and focus-follows-mouse raises the hovered window.
#   5. Notification banner: notify_post() arms a solid banner; notify_tick()
#      ages it through its TTL into a fade and finally expires.
# Emits "[DE7] PASS" / "[DE7] FAIL <reason>".
def daemon_round7_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    FOCUS_FOLLOW_UID = -1
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: categorised Applications menu ---
    if menubar_count(0) != cast[uint64](APPCAT_COUNT):
        write_str(1, "[DE7] FAIL Applications is not category-count rows\n")
        return
    cl0: Ptr[uint8] = menubar_item_label(0, 0)
    if cstr_eq(cl0, "Accessories") == 0:
        write_str(1, "[DE7] FAIL category 0 is not Accessories\n")
        return
    cl1: Ptr[uint8] = menubar_item_label(0, 1)
    if cstr_eq(cl1, "System Tools") == 0:
        write_str(1, "[DE7] FAIL category 1 is not System Tools\n")
        return
    # Accessories first item maps to flat entry 0 (Terminal).
    if appcat_flat_index(0, 0) != 0:
        write_str(1, "[DE7] FAIL Accessories item0 is not Terminal\n")
        return
    al0: Ptr[uint8] = appcat_item_label(0, 0)
    if cstr_eq(al0, "Terminal") == 0:
        write_str(1, "[DE7] FAIL Accessories item0 label wrong\n")
        return
    # System Tools item1 maps to flat entry 4 (System Monitor).
    if appcat_flat_index(1, 1) != 4:
        write_str(1, "[DE7] FAIL System Tools item1 is not System Monitor\n")
        return
    write_str(1, "[DE7] app-categories OK\n")
    # Open Applications via the menu-bar button, then hover its first
    # category row: the submenu flyout must open on that category.
    CUR_X = iclamp(menubar_btn_x(0) + 4, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if MENU_BAR_OPEN != 0:
        write_str(1, "[DE7] FAIL Applications menu did not open\n")
        return
    # Hover category 0 (Accessories) -> SUBMENU_OPEN becomes 0.
    CUR_X = iclamp(menubar_drop_x() + menubar_drop_w() / 2, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    update_hover()
    if SUBMENU_OPEN != 0:
        write_str(1, "[DE7] FAIL hovering Accessories did not open submenu\n")
        return
    # The submenu hit-test maps its first row back to item 0.
    sxc: int64 = submenu_x() + SUBMENU_W / 2
    if submenu_item_at(0, sxc, appcat_row_y(0) + MENU_ITEM_H / 2) != 0:
        write_str(1, "[DE7] FAIL submenu item0 hit-test wrong\n")
        return
    write_str(1, "[DE7] submenu-hover OK\n")
    # Click submenu item 0 (Terminal): a window spawns + the menu closes.
    before: uint64 = DWIN_COUNT
    CUR_X = iclamp(sxc, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT <= before:
        write_str(1, "[DE7] FAIL submenu launch did not spawn a window\n")
        return
    if MENU_BAR_OPEN >= 0 or SUBMENU_OPEN >= 0:
        write_str(1, "[DE7] FAIL submenu launch did not close the menu\n")
        return
    write_str(1, "[DE7] submenu-launch OK\n")
    # --- Step 2: clock calendar popup + date arithmetic ---
    # 2026-06-03 is a Wednesday; June 1 2026 is a Monday (dow 1).
    CAL_YEAR = 2026
    CAL_MONTH = 6
    CAL_DAY = 3
    CAL_VALID = 1
    if dow_first(2026, 6) != 1:
        write_str(1, "[DE7] FAIL June 2026 does not start on Monday\n")
        return
    # 2000 is a leap year; 1900 is not; 2024 is.
    if is_leap(2000) == 0:
        write_str(1, "[DE7] FAIL leap-year computation wrong (2000)\n")
        return
    if is_leap(1900) != 0:
        write_str(1, "[DE7] FAIL leap-year computation wrong (1900)\n")
        return
    if is_leap(2024) == 0:
        write_str(1, "[DE7] FAIL leap-year computation wrong (2024)\n")
        return
    if days_in_month(2024, 2) != 29:
        write_str(1, "[DE7] FAIL Feb 2024 is not 29 days\n")
        return
    if days_in_month(2026, 2) != 28:
        write_str(1, "[DE7] FAIL Feb 2026 is not 28 days\n")
        return
    # June 2026: lead=1, so grid (row0,col1) is day 1; (row0,col0) is blank.
    if cal_day_at(0, 1) != 1:
        write_str(1, "[DE7] FAIL calendar day-1 cell wrong\n")
        return
    if cal_day_at(0, 0) != 0:
        write_str(1, "[DE7] FAIL calendar leading pad not blank\n")
        return
    # 30 days; the last day (30) sits at cell index lead+29 = 30 -> row4,col2.
    if cal_day_at(4, 2) != 30:
        write_str(1, "[DE7] FAIL calendar last-day cell wrong\n")
        return
    # The clock-applet click zone toggles the popup.
    if in_clock_zone(scr_w - 4, PANEL_H / 2, scr_w) == 0:
        write_str(1, "[DE7] FAIL clock zone hit-test wrong\n")
        return
    CUR_X = iclamp(scr_w - 4, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CAL_OPEN == 0:
        write_str(1, "[DE7] FAIL clock click did not open the calendar\n")
        return
    # A click off the calendar (the empty desktop) dismisses it.
    CUR_X = iclamp(scr_w / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 40, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CAL_OPEN != 0:
        write_str(1, "[DE7] FAIL off-calendar click did not dismiss it\n")
        return
    write_str(1, "[DE7] calendar OK\n")
    # --- Step 3: taskbar grouping/raise still works ---
    daemon_spawn_window(60, 200, 300, 180)        # slot s_a
    s_a: uint64 = DWIN_COUNT - 1
    daemon_spawn_window(120, 240, 300, 180)       # slot s_b (now topmost)
    if DWIN_COUNT < 2:
        write_str(1, "[DE7] FAIL fewer than 2 windows for taskbar test\n")
        return
    uid_a: int32 = DWIN_UID[s_a]
    # Click s_a's taskbar button: it must raise to topmost.
    tbx: int64 = taskbar_btn_x(s_a) + 4
    CUR_X = iclamp(tbx, 0, scr_w - 1)
    CUR_Y = iclamp(TASKBAR_BTN_Y + TASKBAR_BTN_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    top_slot: uint64 = DWIN_COUNT - 1
    if DWIN_UID[top_slot] != uid_a:
        write_str(1, "[DE7] FAIL taskbar click did not raise the window\n")
        return
    write_str(1, "[DE7] taskbar-raise OK\n")
    # --- Step 4: focus model setting + focus-follows-mouse ---
    sx2: int64 = 140
    sy2: int64 = PANEL_H + 30
    daemon_spawn_app(APP_SETTINGS, sx2, sy2, 320, 220)
    sset: uint64 = DWIN_COUNT - 1
    if DWIN_APP[sset] != APP_SETTINGS:
        write_str(1, "[DE7] FAIL settings window not created\n")
        return
    # SET_ROWS is 6 since ROUND-8 (Theme/Background/Panel/Focus/Workspaces/
    # Reset); the Focus row is still row 3.
    if SET_ROWS != 6:
        write_str(1, "[DE7] FAIL settings does not have 6 rows\n")
        return
    fm0: int32 = FOCUS_MODE
    settings_press(sset, 3)
    if FOCUS_MODE == fm0:
        write_str(1, "[DE7] FAIL Focus row did not toggle the focus model\n")
        return
    # The row-3 centre must hit-test back to row 3.
    rcy: int64 = settings_row_y(sset, 3) + 4
    rcx: int64 = DWIN_X[sset] + 20
    if settings_row_at(sset, rcx, rcy) != 3:
        write_str(1, "[DE7] FAIL settings Focus row hit-test wrong\n")
        return
    write_str(1, "[DE7] focus-setting OK\n")
    # Focus-follows-mouse: enable it, then move the pointer over a LOWER
    # window's body; it must auto-raise to topmost.
    FOCUS_MODE = 1
    FOCUS_FOLLOW_UID = -1
    # Two fresh windows so we know the z-order: spawn lo then hi.
    daemon_spawn_window(80, 120, 260, 160)        # lo
    lo: uint64 = DWIN_COUNT - 1
    lo_uid: int32 = DWIN_UID[lo]
    daemon_spawn_window(360, 120, 260, 160)       # hi (topmost)
    if DWIN_UID[DWIN_COUNT - 1] == lo_uid:
        write_str(1, "[DE7] FAIL follow-mouse setup z-order wrong\n")
        return
    # Hover lo's body (no button held). focus_follow_step raises it.
    CUR_X = iclamp(DWIN_X[lo] + DWIN_W[lo] / 2, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[lo] + TITLE_H + 20, 0, scr_h - 1)
    PREV_BTN_L = 0
    update_hover()
    focus_follow_step(0, scr_w, scr_h)
    if DWIN_UID[DWIN_COUNT - 1] != lo_uid:
        write_str(1, "[DE7] FAIL focus-follows-mouse did not raise hovered window\n")
        return
    # With click-to-focus, the same hover must NOT raise.
    FOCUS_MODE = 0
    FOCUS_FOLLOW_UID = -1
    daemon_spawn_window(420, 200, 240, 150)       # new topmost
    top_uid: int32 = DWIN_UID[DWIN_COUNT - 1]
    CUR_X = iclamp(DWIN_X[lo] + DWIN_W[lo] / 2, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[lo] + TITLE_H + 20, 0, scr_h - 1)
    update_hover()
    focus_follow_step(0, scr_w, scr_h)
    if DWIN_UID[DWIN_COUNT - 1] != top_uid:
        write_str(1, "[DE7] FAIL click-to-focus wrongly raised on hover\n")
        return
    write_str(1, "[DE7] follow-mouse OK\n")
    # --- Step 5: transient notification banner lifecycle ---
    NOTIFY_ACTIVE = 0
    notify_post("Test", "hello")
    if NOTIFY_ACTIVE == 0:
        write_str(1, "[DE7] FAIL notify_post did not arm the banner\n")
        return
    if NOTIFY_AGE != 0:
        write_str(1, "[DE7] FAIL notify_post did not reset the banner age\n")
        return
    if notify_alpha() != 255:
        write_str(1, "[DE7] FAIL fresh banner is not fully solid\n")
        return
    # Tick up to just before the TTL: still solid + active.
    tk: int64 = 0
    while tk < NOTIFY_TTL - 1:
        notify_tick()
        tk = tk + 1
    if NOTIFY_ACTIVE == 0:
        write_str(1, "[DE7] FAIL banner expired before its TTL\n")
        return
    if notify_alpha() != 255:
        write_str(1, "[DE7] FAIL banner faded before its TTL\n")
        return
    # Push one tick into the fade window: alpha must drop below solid.
    notify_tick()
    notify_tick()
    if notify_alpha() >= 255:
        write_str(1, "[DE7] FAIL banner did not begin fading after TTL\n")
        return
    # Tick out the rest of the fade: the banner expires.
    tk2: int64 = 0
    while tk2 < NOTIFY_FADE + 2:
        notify_tick()
        tk2 = tk2 + 1
    if NOTIFY_ACTIVE != 0:
        write_str(1, "[DE7] FAIL banner did not expire after the fade\n")
        return
    write_str(1, "[DE7] notify OK\n")
    daemon_present()
    write_str(1, "[DE7] PASS\n")


# ====================================================================
# ROUND-8 MATE-feel self-test (autoflag == 18)
# ====================================================================
# Exercises, with synthetic inputs (no QEMU mouse/keyboard), the two new
# GNOME2/MATE features added this round:
#   1. Session dialog + screen lock: the System menu "Log Out" raises the
#      modal session dialog; its rows hit-test correctly; clicking "Lock
#      Screen" locks the desktop and a subsequent click unlocks; "Shut Down"
#      and "Log Out" set the loop's quit flag with the right intent; a click
#      outside the dialog cancels it.
#   2. Settings "Workspaces" row: SET_ROWS grew to 6; the Workspaces row
#      (index 4) cycles WS_COUNT through [WS_MIN..WS_MAX] and folds the
#      current workspace + any out-of-range windows back into range.
# Emits "[DE8] PASS" / "[DE8] FAIL <reason>".
def daemon_round8_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    SESSION_INTENT = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: session dialog geometry + rows ---
    if SESSION_ROWS != 4:
        write_str(1, "[DE8] FAIL session dialog is not four rows\n")
        return
    sl0: Ptr[uint8] = session_row_label(0)
    if cstr_eq(sl0, "Lock Screen") == 0:
        write_str(1, "[DE8] FAIL session row0 is not Lock Screen\n")
        return
    sl1: Ptr[uint8] = session_row_label(1)
    if cstr_eq(sl1, "Log Out") == 0:
        write_str(1, "[DE8] FAIL session row1 is not Log Out\n")
        return
    sl2: Ptr[uint8] = session_row_label(2)
    if cstr_eq(sl2, "Shut Down") == 0:
        write_str(1, "[DE8] FAIL session row2 is not Shut Down\n")
        return
    sl3: Ptr[uint8] = session_row_label(3)
    if cstr_eq(sl3, "Cancel") == 0:
        write_str(1, "[DE8] FAIL session row3 is not Cancel\n")
        return
    write_str(1, "[DE8] session-rows OK\n")
    # The System menu "Log Out" (m=2, item 7 after R13 added "Run
    # Application...") opens the dialog.
    menubar_invoke(2, 7, scr_w, scr_h)
    if SESSION_OPEN == 0:
        write_str(1, "[DE8] FAIL System Log Out did not open the session dialog\n")
        return
    # Each row's centre must hit-test back to itself.
    dcx: int64 = session_x(scr_w) + SESSION_W / 2
    ri: int64 = 0
    while ri < SESSION_ROWS:
        rcy: int64 = session_row_y(scr_h, ri) + SESSION_BTN_H / 2
        if session_row_at(dcx, rcy, scr_w, scr_h) != ri:
            write_str(1, "[DE8] FAIL session row hit-test wrong\n")
            return
        ri = ri + 1
    # A point above the first row (outside the button band) is not a row.
    above_y: int64 = session_row_y(scr_h, 0) - 4
    if session_row_at(dcx, above_y, scr_w, scr_h) != -1:
        write_str(1, "[DE8] FAIL session off-row hit-test wrong\n")
        return
    write_str(1, "[DE8] session-hittest OK\n")
    # --- Step 2: hover highlight tracks the pointed-at row ---
    CUR_X = iclamp(dcx, 0, scr_w - 1)
    CUR_Y = iclamp(session_row_y(scr_h, 2) + SESSION_BTN_H / 2, 0, scr_h - 1)
    update_hover()
    if SESSION_HOVER != 2:
        write_str(1, "[DE8] FAIL session hover did not track row 2\n")
        return
    write_str(1, "[DE8] session-hover OK\n")
    # --- Step 3: Lock Screen via a synthetic click on row 0 ---
    CUR_X = iclamp(dcx, 0, scr_w - 1)
    CUR_Y = iclamp(session_row_y(scr_h, 0) + SESSION_BTN_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if LOCKED == 0:
        write_str(1, "[DE8] FAIL Lock Screen click did not lock the desktop\n")
        return
    if SESSION_OPEN != 0:
        write_str(1, "[DE8] FAIL locking did not dismiss the dialog\n")
        return
    # While locked, ANY click unlocks (and is otherwise swallowed).
    CUR_X = iclamp(scr_w / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if LOCKED != 0:
        write_str(1, "[DE8] FAIL click did not unlock the screen\n")
        return
    write_str(1, "[DE8] lock-unlock OK\n")
    # --- Step 4: Cancel — a click outside the dialog dismisses it ---
    SESSION_OPEN = 0
    session_open()
    if SESSION_OPEN == 0:
        write_str(1, "[DE8] FAIL session_open did not arm the dialog\n")
        return
    # Click far outside the dialog box (top-left corner of the work area).
    CUR_X = iclamp(2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if SESSION_OPEN != 0:
        write_str(1, "[DE8] FAIL outside click did not cancel the dialog\n")
        return
    if DAEMON_QUIT != 0 or LOCKED != 0:
        write_str(1, "[DE8] FAIL cancel wrongly triggered quit/lock\n")
        return
    write_str(1, "[DE8] session-cancel OK\n")
    # --- Step 5: Shut Down + Log Out intents drive the quit flag ---
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    SESSION_OPEN = 1
    session_invoke(2)                       # Shut Down
    if DAEMON_QUIT == 0 or SESSION_INTENT != 2:
        write_str(1, "[DE8] FAIL Shut Down did not request a power-off\n")
        return
    if SESSION_OPEN != 0:
        write_str(1, "[DE8] FAIL Shut Down did not close the dialog\n")
        return
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    SESSION_OPEN = 1
    session_invoke(1)                       # Log Out
    if DAEMON_QUIT == 0 or SESSION_INTENT != 1:
        write_str(1, "[DE8] FAIL Log Out did not request a logout\n")
        return
    DAEMON_QUIT = 0
    SESSION_INTENT = 0
    write_str(1, "[DE8] session-intents OK\n")
    # --- Step 6: Settings "Workspaces" row reconfigures WS_COUNT ---
    if SET_ROWS != 6:
        write_str(1, "[DE8] FAIL Settings does not have six rows\n")
        return
    sx2: int64 = 120
    sy2: int64 = PANEL_H + 30
    daemon_spawn_app(APP_SETTINGS, sx2, sy2, 320, 220)
    sset: uint64 = DWIN_COUNT - 1
    if DWIN_APP[sset] != APP_SETTINGS:
        write_str(1, "[DE8] FAIL settings window not created\n")
        return
    # Row 4 is Workspaces; the row-4 centre must hit-test back to row 4.
    r4y: int64 = settings_row_y(sset, 4) + 4
    r4x: int64 = DWIN_X[sset] + 20
    if settings_row_at(sset, r4x, r4y) != 4:
        write_str(1, "[DE8] FAIL Workspaces row hit-test wrong\n")
        return
    ws0: int32 = WS_COUNT
    settings_press(sset, 4)
    if WS_COUNT != ws0 + 1:
        write_str(1, "[DE8] FAIL Workspaces row did not increment the count\n")
        return
    write_str(1, "[DE8] ws-row OK\n")
    # Cycle from the maximum and assert it wraps to the minimum.
    WS_COUNT = WS_MAX
    ws_count_cycle()
    if WS_COUNT != WS_MIN:
        write_str(1, "[DE8] FAIL Workspaces count did not wrap to the minimum\n")
        return
    # Shrinking the desktop count must fold the active workspace + an out-of
    # range window back into the new range so nothing is unreachable.
    WS_COUNT = 4
    CUR_WS = 3
    daemon_spawn_window(80, 120, 200, 140)
    fw: uint64 = DWIN_COUNT - 1
    DWIN_WS[fw] = 3
    WS_COUNT = WS_MAX                       # so the next cycle wraps to WS_MIN
    ws_count_cycle()                        # WS_COUNT -> WS_MIN (==1)
    if WS_COUNT != WS_MIN:
        write_str(1, "[DE8] FAIL fold-setup did not reach the minimum\n")
        return
    if CUR_WS >= WS_COUNT:
        write_str(1, "[DE8] FAIL current workspace not folded into range\n")
        return
    if DWIN_WS[fw] >= WS_COUNT:
        write_str(1, "[DE8] FAIL window workspace not folded into range\n")
        return
    write_str(1, "[DE8] ws-fold OK\n")
    # Restore a sane default count for the present pass.
    WS_COUNT = 4
    CUR_WS = 0
    daemon_present()
    write_str(1, "[DE8] PASS\n")


# ====================================================================
# ROUND-9 MATE-feel self-test (autoflag == 19)
# ====================================================================
# Mouse-free exercise of the round-9 window-management polish for CI. As
# with the earlier rounds there is no runtime observability on this host,
# so the test drives the REAL window-menu (ctx_invoke), the REAL gesture
# machine (wm_button), and the REAL z-order machinery with synthetic
# coordinates, asserting state after each step:
#   1. Window menu carries the round-9 MATE rows (Max Vert, Max Horiz,
#      Shade, Always on Top) at the expected indices with dynamic
#      Shade/Unshade + Always-on-Top labels. (The menu later grew to 13
#      rows in round 20; rows 0..5 keep their positions.)
#   2. SHADE: invoking "Shade" rolls the focused window up to its title
#      bar (DWIN_H collapses to SHADE_H, the full height is stashed), and
#      a second invoke unshades it back to the exact original height.
#   3. ALWAYS-ON-TOP: pinning a back window then presenting floats it above
#      a normal front window in the slot array (the paint/hit-test order);
#      un-pinning leaves it pinned-free; a later raise of a normal window
#      can no longer cover the pinned one.
#   4. MAXIMIZE VERT/HORIZ: the menu rows stretch the window in exactly one
#      axis (work-area height / full screen width) and a re-invoke restores
#      the saved float rectangle.
# Emits "[DE9] PASS" / "[DE9] FAIL <reason>".
def daemon_round9_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # A single fresh terminal window to operate on.
    daemon_spawn_window(80, PANEL_H + 24, 360, 240)
    if DWIN_COUNT == 0:
        write_str(1, "[DE9] FAIL no window spawned\n")
        return
    s0: uint64 = DWIN_COUNT - 1
    # --- Step 1: the window menu carries the round-9 rows ---
    # ROUND-20 grew the menu to 13 rows; rows 0..5 (and the Shade row 4 /
    # Always-on-Top row 5 invoked below) keep their positions.
    CTX_KIND = 1
    CTX_SLOT = cast[int64](s0)
    if ctx_count() != 13:
        write_str(1, "[DE9] FAIL window menu is not 13 rows\n")
        return
    lmv: Ptr[uint8] = ctx_item_label(2)
    if cstr_eq(lmv, "Maximize Vertically") == 0:
        write_str(1, "[DE9] FAIL row2 is not Maximize Vertically\n")
        return
    lmh: Ptr[uint8] = ctx_item_label(3)
    if cstr_eq(lmh, "Maximize Horizontally") == 0:
        write_str(1, "[DE9] FAIL row3 is not Maximize Horizontally\n")
        return
    lsh: Ptr[uint8] = ctx_item_label(4)
    if cstr_eq(lsh, "Shade") == 0:
        write_str(1, "[DE9] FAIL row4 is not Shade\n")
        return
    lot: Ptr[uint8] = ctx_item_label(5)
    if cstr_eq(lot, "Always on Top") == 0:
        write_str(1, "[DE9] FAIL row5 is not Always on Top\n")
        return
    write_str(1, "[DE9] window-menu rows OK\n")
    # --- Step 2: Shade rolls up; the row label flips to Unshade ---
    h_before: int64 = DWIN_H[s0]
    ctx_invoke(4, scr_w, scr_h)                 # Shade
    if DWIN_SHADED[s0] == 0:
        write_str(1, "[DE9] FAIL Shade did not set the shaded flag\n")
        return
    if DWIN_H[s0] != SHADE_H:
        write_str(1, "[DE9] FAIL shaded window did not collapse to the title bar\n")
        return
    if DWIN_SHADE_H[s0] != h_before:
        write_str(1, "[DE9] FAIL shade did not stash the full height\n")
        return
    lsh2: Ptr[uint8] = ctx_item_label(4)
    if cstr_eq(lsh2, "Unshade") == 0:
        write_str(1, "[DE9] FAIL shaded row label is not Unshade\n")
        return
    ctx_invoke(4, scr_w, scr_h)                 # Unshade
    if DWIN_SHADED[s0] != 0:
        write_str(1, "[DE9] FAIL Unshade did not clear the shaded flag\n")
        return
    if DWIN_H[s0] != h_before:
        write_str(1, "[DE9] FAIL unshade did not restore the full height\n")
        return
    write_str(1, "[DE9] shade-roll OK\n")
    # --- Step 3: Always-on-Top floats a window above the normal stack ---
    # Spawn a second window so we have a clear z-order: s0 (back), s1 (front).
    daemon_spawn_window(140, PANEL_H + 60, 360, 240)
    if DWIN_COUNT < 2:
        write_str(1, "[DE9] FAIL second window not spawned\n")
        return
    s1: uint64 = DWIN_COUNT - 1
    # Identify the two windows by UID so we can find them after reorders.
    uid_back: int32 = DWIN_UID[s0]
    uid_front: int32 = DWIN_UID[s1]
    # The newest window is front-most (last slot).
    if DWIN_UID[DWIN_COUNT - 1] != uid_front:
        write_str(1, "[DE9] FAIL front window is not the newest\n")
        return
    # Pin the BACK window on top via its window menu, then present so the
    # ontop reorder runs. The pinned window must now be front-most.
    CTX_SLOT = slot_for_uid(uid_back)
    if CTX_SLOT < 0:
        write_str(1, "[DE9] FAIL lost the back window\n")
        return
    ctx_invoke(5, scr_w, scr_h)                 # Always on Top
    bslot: int64 = slot_for_uid(uid_back)
    if bslot < 0 or DWIN_ONTOP[cast[uint64](bslot)] == 0:
        write_str(1, "[DE9] FAIL Always on Top did not set the pin\n")
        return
    enforce_ontop_order()
    if DWIN_UID[DWIN_COUNT - 1] != uid_back:
        write_str(1, "[DE9] FAIL pinned window did not float to the front\n")
        return
    # The ontop-row label now carries the active-state marker.
    CTX_SLOT = slot_for_uid(uid_back)
    lot2: Ptr[uint8] = ctx_item_label(5)
    if cstr_eq(lot2, "Always on Top *") == 0:
        write_str(1, "[DE9] FAIL pinned ontop row missing the marker\n")
        return
    # Raising the OTHER (normal) window must NOT cover the pinned one once
    # the order is re-enforced: the pin stays front-most.
    nslot: int64 = slot_for_uid(uid_front)
    daemon_raise_slot(nslot)
    enforce_ontop_order()
    if DWIN_UID[DWIN_COUNT - 1] != uid_back:
        write_str(1, "[DE9] FAIL normal raise wrongly covered the pinned window\n")
        return
    # Un-pin: the window is no longer forced above the normal stack.
    CTX_SLOT = slot_for_uid(uid_back)
    ctx_invoke(5, scr_w, scr_h)                 # Always on Top (toggle off)
    uslot: int64 = slot_for_uid(uid_back)
    if uslot < 0 or DWIN_ONTOP[cast[uint64](uslot)] != 0:
        write_str(1, "[DE9] FAIL un-pin did not clear the ontop flag\n")
        return
    write_str(1, "[DE9] always-on-top OK\n")
    # --- Step 4: vertical + horizontal maximize via the menu rows ---
    tslot: int64 = slot_for_uid(uid_front)
    t: uint64 = cast[uint64](tslot)
    fx: int64 = DWIN_X[t]
    fy: int64 = DWIN_Y[t]
    fw: int64 = DWIN_W[t]
    fh: int64 = DWIN_H[t]
    CTX_SLOT = tslot
    ctx_invoke(2, scr_w, scr_h)                 # Maximize Vertically
    if DWIN_Y[t] != PANEL_H or DWIN_H[t] != scr_h - PANEL_H:
        write_str(1, "[DE9] FAIL vertical maximize geometry wrong\n")
        return
    if DWIN_X[t] != fx or DWIN_W[t] != fw:
        write_str(1, "[DE9] FAIL vertical maximize changed the x axis\n")
        return
    ctx_invoke(2, scr_w, scr_h)                 # restore
    if DWIN_X[t] != fx or DWIN_Y[t] != fy or DWIN_W[t] != fw or DWIN_H[t] != fh:
        write_str(1, "[DE9] FAIL vertical restore geometry wrong\n")
        return
    ctx_invoke(3, scr_w, scr_h)                 # Maximize Horizontally
    if DWIN_X[t] != 0 or DWIN_W[t] != scr_w:
        write_str(1, "[DE9] FAIL horizontal maximize geometry wrong\n")
        return
    if DWIN_Y[t] != fy or DWIN_H[t] != fh:
        write_str(1, "[DE9] FAIL horizontal maximize changed the y axis\n")
        return
    ctx_invoke(3, scr_w, scr_h)                 # restore
    if DWIN_X[t] != fx or DWIN_Y[t] != fy or DWIN_W[t] != fw or DWIN_H[t] != fh:
        write_str(1, "[DE9] FAIL horizontal restore geometry wrong\n")
        return
    write_str(1, "[DE9] maximize-axes OK\n")
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE9] PASS\n")


# ====================================================================
# ROUND-10 MATE-feel self-test
# ====================================================================
# Exercises, mouse-free, the three round-10 features:
#   1. WORKSPACE PAGER drag-window-between-workspaces: dragging a desktop
#      cell onto another moves that desktop's focused window across; a
#      same-cell "drag" still switches workspace.
#   2. WINDOW-LIST GROUPING: several windows of one app collapse to a
#      single group-leader taskbar button with an (N) count; clicking it
#      round-robin cycles focus through the group; singletons stay solo.
#   3. APPLICATIONS MENU SEARCH/FILTER: a case-insensitive substring query
#      filters the flat app list, Enter/click launches the n-th match.
# Emits "[DE10] PASS" / "[DE10] FAIL <reason>".
def daemon_round10_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PAGER_DRAG = 0
    PAGER_DRAG_FROM = -1
    SEARCH_OPEN = 0
    SEARCH_LEN = 0
    GROUP_CURSOR[0] = 0
    GROUP_CURSOR[1] = 0
    GROUP_CURSOR[2] = 0
    GROUP_CURSOR[3] = 0
    GROUP_CURSOR[4] = 0
    theme_apply()
    bg_palette_init()

    # ---------------- Step 1: pager drag-window-between-workspaces -------
    # One window on workspace 0; drag cell 0 -> cell 2 relocates it.
    daemon_spawn_window(80, PANEL_H + 24, 360, 240)
    if DWIN_COUNT == 0:
        write_str(1, "[DE10] FAIL no window spawned\n")
        return
    w0: uint64 = DWIN_COUNT - 1
    if DWIN_WS[w0] != 0:
        write_str(1, "[DE10] FAIL fresh window not on workspace 0\n")
        return
    # ws_focus_slot finds the front window of a desktop.
    if ws_focus_slot(0) != cast[int64](w0):
        write_str(1, "[DE10] FAIL ws_focus_slot(0) wrong\n")
        return
    if ws_focus_slot(2) != -1:
        write_str(1, "[DE10] FAIL ws 2 should be empty\n")
        return
    # Same-cell pager gesture is a no-op move (returns 0).
    if pager_drag_window(1, 1) != 0:
        write_str(1, "[DE10] FAIL same-cell drag should not move\n")
        return
    # Empty-source drag is a no-op too.
    if pager_drag_window(3, 2) != 0:
        write_str(1, "[DE10] FAIL empty-source drag should not move\n")
        return
    # Real drag cell 0 -> cell 2.
    if pager_drag_window(0, 2) == 0:
        write_str(1, "[DE10] FAIL pager drag did not move the window\n")
        return
    if DWIN_WS[w0] != 2:
        write_str(1, "[DE10] FAIL window did not land on workspace 2\n")
        return
    # It is no longer visible on the (still current) workspace 0.
    if win_on_cur_ws(w0) != 0:
        write_str(1, "[DE10] FAIL moved window still on workspace 0\n")
        return
    write_str(1, "[DE10] pager-drag OK\n")

    # ---------------- Step 2: window-list grouping ----------------------
    # Bring the test window back to ws 0, then add two calculators so the
    # CALC app forms a 2-strong group and the lone terminal stays solo.
    window_to_workspace(w0, 0)
    daemon_spawn_app(APP_CALC, 100, PANEL_H + 40, 220, 300)
    daemon_spawn_app(APP_CALC, 140, PANEL_H + 60, 220, 300)
    if DWIN_COUNT < 3:
        write_str(1, "[DE10] FAIL calculators not spawned\n")
        return
    # Find the two calc slots + the terminal slot.
    c_first: int64 = -1
    c_second: int64 = -1
    term_slot: int64 = -1
    gi: uint64 = 0
    while gi < DWIN_COUNT:
        if DWIN_APP[gi] == APP_CALC:
            if c_first < 0:
                c_first = cast[int64](gi)
            else:
                c_second = cast[int64](gi)
        elif DWIN_APP[gi] == APP_TERM:
            term_slot = cast[int64](gi)
        gi = gi + 1
    if c_first < 0 or c_second < 0 or term_slot < 0:
        write_str(1, "[DE10] FAIL could not locate group test windows\n")
        return
    cf: uint64 = cast[uint64](c_first)
    cs: uint64 = cast[uint64](c_second)
    ts: uint64 = cast[uint64](term_slot)
    # Two calculators => grouped; the single terminal => not grouped.
    if app_group_count(cf) != 2:
        write_str(1, "[DE10] FAIL calc group count is not 2\n")
        return
    if is_grouped(cf) == 0 or is_grouped(cs) == 0:
        write_str(1, "[DE10] FAIL calculators not grouped\n")
        return
    if is_grouped(ts) != 0:
        write_str(1, "[DE10] FAIL lone terminal wrongly grouped\n")
        return
    # The lower-index calc slot is the group leader; the other is folded.
    if is_group_leader(cf) == 0:
        write_str(1, "[DE10] FAIL first calc is not the group leader\n")
        return
    if is_group_leader(cs) != 0:
        write_str(1, "[DE10] FAIL second calc wrongly a leader\n")
        return
    # The taskbar hit-test only resolves leaders (folded members ignored).
    if taskbar_slot_at(taskbar_btn_x(cf) + 4, TASKBAR_BTN_Y + 2, scr_w) \
       != cast[int64](cf):
        write_str(1, "[DE10] FAIL taskbar did not hit the group leader\n")
        return
    if taskbar_slot_at(taskbar_btn_x(cs) + 4, TASKBAR_BTN_Y + 2, scr_w) != -1:
        write_str(1, "[DE10] FAIL folded member is still hit-testable\n")
        return
    # Clicking the group cycles focus round-robin through its members.
    # group_cycle returns the raised window's UID (stable across reorders);
    # two successive cycles must raise two DIFFERENT calculator windows.
    GROUP_CURSOR[APP_CALC] = 0
    g_a: int64 = group_cycle(cf)
    if g_a < 0:
        write_str(1, "[DE10] FAIL first group cycle raised nothing\n")
        return
    ga_slot: int64 = slot_for_uid(cast[int32](g_a))
    if ga_slot < 0 or DWIN_APP[cast[uint64](ga_slot)] != APP_CALC:
        write_str(1, "[DE10] FAIL group cycle raised a non-calc window\n")
        return
    # The cycled window must be front-most (focused) after the raise.
    if DWIN_UID[DWIN_COUNT - 1] != cast[int32](g_a):
        write_str(1, "[DE10] FAIL group cycle did not focus its window\n")
        return
    g_b: int64 = group_cycle(cf)
    if g_b < 0:
        write_str(1, "[DE10] FAIL second group cycle raised nothing\n")
        return
    gb_slot: int64 = slot_for_uid(cast[int32](g_b))
    if gb_slot < 0 or DWIN_APP[cast[uint64](gb_slot)] != APP_CALC:
        write_str(1, "[DE10] FAIL second cycle raised a non-calc window\n")
        return
    if g_a == g_b:
        write_str(1, "[DE10] FAIL group cycle did not advance to a new window\n")
        return
    write_str(1, "[DE10] grouping OK\n")

    # ---------------- Step 3: Applications menu search/filter -----------
    MENU_BAR_OPEN = 0
    SEARCH_OPEN = 1
    SEARCH_LEN = 0
    # Empty query matches every flat entry.
    if menu_search_count() != MENU_COUNT:
        write_str(1, "[DE10] FAIL empty query did not match all entries\n")
        return
    if search_active() != 0:
        write_str(1, "[DE10] FAIL empty query should not be active filter\n")
        return
    # Type "cal" (case-insensitive). Matches "Calculator" and "Calendar".
    search_push(67)             # 'C'
    search_push(97)             # 'a'
    search_push(108)            # 'l'
    if search_active() == 0:
        write_str(1, "[DE10] FAIL non-empty query is not active\n")
        return
    if menu_search_count() != 2:
        write_str(1, "[DE10] FAIL 'cal' did not match exactly 2 entries\n")
        return
    # The matches are Calculator (flat 3) and Calendar (flat 6).
    m0: uint64 = menu_search_nth(0)
    m1: uint64 = menu_search_nth(1)
    if m0 != 3 or m1 != 6:
        write_str(1, "[DE10] FAIL 'cal' match indices wrong\n")
        return
    if cstr_eq(menu_label(m0), "Calculator") == 0:
        write_str(1, "[DE10] FAIL first match is not Calculator\n")
        return
    # Case-insensitive: a capital still matches the lowercase label.
    search_push(99)             # 'c' -> query "calc"
    if menu_search_count() != 1:
        write_str(1, "[DE10] FAIL 'calc' did not narrow to 1\n")
        return
    if menu_search_nth(0) != 3:
        write_str(1, "[DE10] FAIL 'calc' match is not Calculator\n")
        return
    # Backspace widens the query back to two matches.
    search_backspace()          # back to "cal"
    if menu_search_count() != 2:
        write_str(1, "[DE10] FAIL backspace did not widen the filter\n")
        return
    # A non-matching query yields zero results.
    search_push(122)            # 'z' -> "calz"
    if menu_search_count() != 0:
        write_str(1, "[DE10] FAIL non-matching query still matched\n")
        return
    if menu_search_nth(0) != MENU_COUNT:
        write_str(1, "[DE10] FAIL out-of-range nth not clamped\n")
        return
    # Reset closes the box and clears the query.
    search_reset()
    if SEARCH_OPEN != 0 or SEARCH_LEN != 0 or search_active() != 0:
        write_str(1, "[DE10] FAIL search_reset did not clear state\n")
        return
    write_str(1, "[DE10] menu-search OK\n")

    MENU_BAR_OPEN = -1
    daemon_present()
    write_str(1, "[DE10] PASS\n")


# ====================================================================
# ROUND-11 self-test (autoflag == 21)
# ====================================================================
# Asserts the three round-11 features WITHOUT QEMU mouse/key injection:
#   1. Panel-position-aware work area: a top panel reserves the top strip,
#      a bottom panel reserves the bottom strip, and snap/maximize land in
#      the correct half of the screen for each panel position.
#   2. Window-list group actions: minimize-all / restore-all / close-all
#      act on every window of a grouped app.
#   3. Standard Ctrl-Alt-arrow workspace navigation + Ctrl-Alt-Shift-arrow
#      move-window-to-adjacent-workspace, with row wrap-around.
# Emits "[DE11] PASS" / "[DE11] FAIL <reason>".
def daemon_round11_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    SEARCH_OPEN = 0
    SEARCH_LEN = 0
    GROUP_CURSOR[APP_CALC] = 0
    theme_apply()
    bg_palette_init()

    # ---------------- Step 1: panel-position-aware work area ------------
    # Top panel (default): the usable desktop starts BELOW the panel.
    PANEL_POS = 0
    if work_top(scr_h) != PANEL_H:
        write_str(1, "[DE11] FAIL top panel work_top wrong\n")
        return
    if panel_top_y(scr_h) != 0:
        write_str(1, "[DE11] FAIL top panel not at y=0\n")
        return
    if work_h(scr_h) != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL work_h wrong\n")
        return
    # Bottom panel (GNOME2 default): desktop starts at the top edge and the
    # panel bar sits flush to the floor.
    PANEL_POS = 1
    if work_top(scr_h) != 0:
        write_str(1, "[DE11] FAIL bottom panel work_top should be 0\n")
        return
    if panel_top_y(scr_h) != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom panel not flush to floor\n")
        return
    if work_h(scr_h) != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom panel work_h wrong\n")
        return
    # Maximize under a BOTTOM panel: window must start at y==0 and stop
    # short of the panel (so the bottom panel is never covered).
    daemon_spawn_window(80, 40, 360, 240)
    if DWIN_COUNT == 0:
        write_str(1, "[DE11] FAIL no window spawned\n")
        return
    w0: uint64 = DWIN_COUNT - 1
    snap_apply(w0, 1, scr_w, scr_h)            # maximize
    if DWIN_Y[w0] != 0:
        write_str(1, "[DE11] FAIL bottom-panel maximize did not start at top\n")
        return
    if DWIN_H[w0] != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom-panel maximize covered the panel\n")
        return
    # Bottom-left quarter under a bottom panel: top of the lower half.
    snap_apply(w0, 6, scr_w, scr_h)
    if DWIN_Y[w0] != work_h(scr_h) / 2:
        write_str(1, "[DE11] FAIL bottom-panel quarter Y wrong\n")
        return
    # Now flip to a TOP panel and maximize: the window must start at PANEL_H.
    PANEL_POS = 0
    snap_apply(w0, 1, scr_w, scr_h)
    if DWIN_Y[w0] != PANEL_H:
        write_str(1, "[DE11] FAIL top-panel maximize did not clear the panel\n")
        return
    if DWIN_H[w0] != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL top-panel maximize height wrong\n")
        return
    # The live snap preview rect must track the panel position too.
    PANEL_POS = 1
    snap_zone_rect(1, scr_w, scr_h)
    if snapzone_y != 0 or snapzone_h != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom-panel snap preview wrong\n")
        return
    PANEL_POS = 0
    snap_zone_rect(1, scr_w, scr_h)
    if snapzone_y != PANEL_H:
        write_str(1, "[DE11] FAIL top-panel snap preview wrong\n")
        return
    # Un-snap and clean up before the group test.
    snap_apply(w0, 0, scr_w, scr_h)
    write_str(1, "[DE11] panel-pos OK\n")

    # ---------------- Step 2: window-list group actions -----------------
    # Two calculators form a group; the lone terminal stays solo.
    daemon_spawn_app(APP_CALC, 100, PANEL_H + 40, 220, 300)
    daemon_spawn_app(APP_CALC, 140, PANEL_H + 60, 220, 300)
    if DWIN_COUNT < 3:
        write_str(1, "[DE11] FAIL calculators not spawned\n")
        return
    c_a: int64 = -1
    c_b: int64 = -1
    term_s: int64 = -1
    gi: uint64 = 0
    while gi < DWIN_COUNT:
        if DWIN_APP[gi] == APP_CALC:
            if c_a < 0:
                c_a = cast[int64](gi)
            else:
                c_b = cast[int64](gi)
        elif DWIN_APP[gi] == APP_TERM:
            term_s = cast[int64](gi)
        gi = gi + 1
    if c_a < 0 or c_b < 0 or term_s < 0:
        write_str(1, "[DE11] FAIL could not locate group test windows\n")
        return
    ca: uint64 = cast[uint64](c_a)
    if app_group_count(ca) != 2:
        write_str(1, "[DE11] FAIL calc group count is not 2\n")
        return
    # minimize-all hides both calculators (count 2) and leaves the terminal.
    if group_minimize_all(ca) != 2:
        write_str(1, "[DE11] FAIL minimize-all count wrong\n")
        return
    gj: uint64 = 0
    while gj < DWIN_COUNT:
        if DWIN_APP[gj] == APP_CALC and DWIN_HIDDEN[gj] == 0:
            write_str(1, "[DE11] FAIL a calculator stayed visible\n")
            return
        if DWIN_APP[gj] == APP_TERM and DWIN_HIDDEN[gj] != 0:
            write_str(1, "[DE11] FAIL terminal wrongly minimized\n")
            return
        gj = gj + 1
    # restore-all un-hides both calculators again.
    if group_restore_all(ca) != 2:
        write_str(1, "[DE11] FAIL restore-all count wrong\n")
        return
    gk: uint64 = 0
    while gk < DWIN_COUNT:
        if DWIN_APP[gk] == APP_CALC and DWIN_HIDDEN[gk] != 0:
            write_str(1, "[DE11] FAIL a calculator stayed minimized\n")
            return
        gk = gk + 1
    # close-all destroys every calculator window; the terminal survives.
    before: uint64 = DWIN_COUNT
    # re-find a calc slot (slots are stable until we close).
    ca2: int64 = -1
    gl: uint64 = 0
    while gl < DWIN_COUNT:
        if DWIN_APP[gl] == APP_CALC:
            ca2 = cast[int64](gl)
            gl = DWIN_COUNT
        else:
            gl = gl + 1
    if ca2 < 0:
        write_str(1, "[DE11] FAIL lost the calc group before close-all\n")
        return
    if group_close_all(cast[uint64](ca2)) != 2:
        write_str(1, "[DE11] FAIL close-all count wrong\n")
        return
    if DWIN_COUNT != before - 2:
        write_str(1, "[DE11] FAIL close-all window count wrong\n")
        return
    gm2: uint64 = 0
    while gm2 < DWIN_COUNT:
        if DWIN_APP[gm2] == APP_CALC:
            write_str(1, "[DE11] FAIL a calculator survived close-all\n")
            return
        gm2 = gm2 + 1
    write_str(1, "[DE11] group-actions OK\n")

    # ---------------- Step 3: Ctrl-Alt-arrow workspace nav --------------
    WS_COUNT = 4
    CUR_WS = 0
    # adjacent_ws wraps the row.
    if adjacent_ws(1) != 1:
        write_str(1, "[DE11] FAIL adjacent right wrong\n")
        return
    if adjacent_ws(-1) != WS_COUNT - 1:
        write_str(1, "[DE11] FAIL adjacent left did not wrap\n")
        return
    # Ctrl-Alt-Right then -Right walks 0 -> 1 -> 2.
    if workspace_step(1) != 1 or CUR_WS != 1:
        write_str(1, "[DE11] FAIL workspace_step right wrong\n")
        return
    if workspace_step(1) != 2 or CUR_WS != 2:
        write_str(1, "[DE11] FAIL second workspace_step wrong\n")
        return
    # Ctrl-Alt-Left wraps from 0 to the last workspace.
    CUR_WS = 0
    if workspace_step(-1) != WS_COUNT - 1 or CUR_WS != WS_COUNT - 1:
        write_str(1, "[DE11] FAIL workspace_step left wrap wrong\n")
        return
    # Ctrl-Alt-Shift-Right: move the focused window to the next workspace AND
    # follow it there. With one window on ws 0, it should land on ws 1 and
    # the active workspace becomes 1 too.
    CUR_WS = 0
    fs11: int64 = daemon_focus_slot()
    if fs11 < 0:
        write_str(1, "[DE11] FAIL no focused window for move test\n")
        return
    window_to_workspace(cast[uint64](fs11), 0)
    dest: int32 = window_to_adjacent_ws(1)
    if dest != 1 or CUR_WS != 1:
        write_str(1, "[DE11] FAIL move-to-adjacent did not follow window\n")
        return
    if DWIN_WS[cast[uint64](fs11)] != 1:
        write_str(1, "[DE11] FAIL window did not land on adjacent ws\n")
        return
    # And the wrap direction: from ws 0, Ctrl-Alt-Shift-Left -> last ws.
    CUR_WS = 0
    fs12: int64 = daemon_focus_slot()
    window_to_workspace(cast[uint64](fs12), 0)
    dest2: int32 = window_to_adjacent_ws(-1)
    if dest2 != WS_COUNT - 1 or DWIN_WS[cast[uint64](fs12)] != WS_COUNT - 1:
        write_str(1, "[DE11] FAIL move-to-adjacent left wrap wrong\n")
        return
    write_str(1, "[DE11] kbd-workspace OK\n")

    CUR_WS = 0
    PANEL_POS = 0
    daemon_present()
    write_str(1, "[DE11] PASS\n")


# ====================================================================
# ROUND-12 self-test (autoflag == 22)
# ====================================================================
# Round 11 made the WORK AREA panel-position-aware; round 12 finishes the
# job by physically rendering and HIT-TESTING the panel bar (menu buttons,
# taskbar, pager, tray, clock, Show Desktop) at the configured edge, and
# flipping the menu drop-downs to grow AWAY from the panel. It also adds a
# classic MATE "Show Desktop" panel applet.
#
# This test injects NO QEMU mouse/keys — it asserts geometry + actions for
# BOTH panel positions so a top-panel regression can never slip through:
#   1. panel_y0 / panel_local_y / on_panel_y / drop_anchor_y are correct
#      for a top AND a bottom panel.
#   2. Every panel hit-test (menubar_btn_at, in_apps_btn, in_clock_zone,
#      pager_cell_at, taskbar_slot_at, menubar_item_at) resolves at the
#      panel's REAL edge for each position, and rejects the opposite edge.
#   3. Menu drop-downs anchor below a top panel and above a bottom panel.
#   4. The Show Desktop applet: geometry sits left of the clock without
#      overlap, hit-tests on the bar for both positions, and its toggle
#      minimizes every visible window then restores exactly those.
# Emits "[DE12] PASS" / "[DE12] FAIL <reason>".
def daemon_round12_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    SEARCH_OPEN = 0
    SEARCH_LEN = 0
    SHOWDESK_ON = 0
    theme_apply()
    bg_palette_init()

    # ---------------- Step 1: panel-local Y mapping ---------------------
    # Top panel: bar occupies absolute rows 0..PANEL_H-1.
    PANEL_POS = 0
    if panel_y0() != 0:
        write_str(1, "[DE12] FAIL top panel_y0 not 0\n")
        return
    if panel_local_y(0) != 0 or panel_local_y(PANEL_H - 1) != PANEL_H - 1:
        write_str(1, "[DE12] FAIL top panel_local_y wrong\n")
        return
    if on_panel_y(PANEL_H / 2) == 0:
        write_str(1, "[DE12] FAIL top panel mid not on bar\n")
        return
    if on_panel_y(scr_h - 1) != 0:
        write_str(1, "[DE12] FAIL top panel floor wrongly on bar\n")
        return
    # Bottom panel: bar occupies absolute rows scr_h-PANEL_H..scr_h-1.
    PANEL_POS = 1
    bot_y0: int64 = scr_h - PANEL_H
    if panel_y0() != bot_y0:
        write_str(1, "[DE12] FAIL bottom panel_y0 wrong\n")
        return
    if panel_local_y(bot_y0) != 0 or panel_local_y(scr_h - 1) != PANEL_H - 1:
        write_str(1, "[DE12] FAIL bottom panel_local_y wrong\n")
        return
    if on_panel_y(bot_y0 + PANEL_H / 2) == 0:
        write_str(1, "[DE12] FAIL bottom panel mid not on bar\n")
        return
    if on_panel_y(0) != 0 or on_panel_y(PANEL_H / 2) != 0:
        write_str(1, "[DE12] FAIL bottom panel ceiling wrongly on bar\n")
        return
    write_str(1, "[DE12] panel-local-Y OK\n")

    # ---------------- Step 2: drop-down anchoring flips -----------------
    # A drop-down of height H hangs BELOW a top panel and ABOVE a bottom one.
    drop_h: int64 = 5 * MENU_ITEM_H
    PANEL_POS = 0
    if drop_anchor_y(drop_h) != PANEL_H:
        write_str(1, "[DE12] FAIL top drop-down does not hang below the bar\n")
        return
    if drop_row_top(drop_h, 2, MENU_ITEM_H) != PANEL_H + 2 * MENU_ITEM_H:
        write_str(1, "[DE12] FAIL top drop-down row layout wrong\n")
        return
    PANEL_POS = 1
    if drop_anchor_y(drop_h) != bot_y0 - drop_h:
        write_str(1, "[DE12] FAIL bottom drop-down does not rise above the bar\n")
        return
    # The list's bottom row must butt against the panel's top edge.
    if drop_anchor_y(drop_h) + drop_h != bot_y0:
        write_str(1, "[DE12] FAIL bottom drop-down not flush to the bar\n")
        return
    write_str(1, "[DE12] drop-anchor OK\n")

    # ---------------- Step 3: panel hit-tests track the edge ------------
    # Pick an X firmly inside the Applications (menu button 0) zone and an X
    # inside the clock zone; assert each resolves on the bar's REAL edge and
    # NOT on the opposite (now-empty) edge.
    app_x: int64 = menubar_btn_x(0) + MENUBAR_PAD
    clk_x: int64 = scr_w - 4
    top_mid: int64 = PANEL_H / 2
    bot_mid: int64 = bot_y0 + PANEL_H / 2

    PANEL_POS = 0
    if menubar_btn_at(app_x, top_mid) != 0:
        write_str(1, "[DE12] FAIL top: Applications not hit on top edge\n")
        return
    if menubar_btn_at(app_x, bot_mid) >= 0:
        write_str(1, "[DE12] FAIL top: Applications wrongly hit on floor\n")
        return
    if in_apps_btn(APPS_BTN_X + 2, top_mid) == 0:
        write_str(1, "[DE12] FAIL top: in_apps_btn missed top edge\n")
        return
    if in_clock_zone(clk_x, top_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL top: clock zone missed top edge\n")
        return
    if in_clock_zone(clk_x, bot_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL top: clock zone hit the floor\n")
        return

    PANEL_POS = 1
    if menubar_btn_at(app_x, bot_mid) != 0:
        write_str(1, "[DE12] FAIL bottom: Applications not hit on floor\n")
        return
    if menubar_btn_at(app_x, top_mid) >= 0:
        write_str(1, "[DE12] FAIL bottom: Applications wrongly hit on ceiling\n")
        return
    if in_apps_btn(APPS_BTN_X + 2, bot_mid) == 0:
        write_str(1, "[DE12] FAIL bottom: in_apps_btn missed the floor\n")
        return
    if in_clock_zone(clk_x, bot_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL bottom: clock zone missed the floor\n")
        return
    if in_clock_zone(clk_x, top_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL bottom: clock zone hit the ceiling\n")
        return

    # Pager cell hit-test follows the edge too (cell 2 mid-cell).
    pcx: int64 = pager_x0(scr_w) + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    PANEL_POS = 0
    if pager_cell_at(pcx, top_mid, scr_w) != 2:
        write_str(1, "[DE12] FAIL top: pager cell 2 missed top edge\n")
        return
    if pager_cell_at(pcx, bot_mid, scr_w) >= 0:
        write_str(1, "[DE12] FAIL top: pager hit the floor\n")
        return
    PANEL_POS = 1
    if pager_cell_at(pcx, bot_mid, scr_w) != 2:
        write_str(1, "[DE12] FAIL bottom: pager cell 2 missed the floor\n")
        return
    if pager_cell_at(pcx, top_mid, scr_w) >= 0:
        write_str(1, "[DE12] FAIL bottom: pager hit the ceiling\n")
        return

    # An open drop-down's item hit-test resolves an item only off the live
    # edge. Open System (menu 2), pick the 3rd row, and probe it at the
    # anchored position for both panel positions.
    MENU_BAR_OPEN = 2
    mrow_h: int64 = menubar_total_h()
    sysx: int64 = menubar_drop_x() + 4
    PANEL_POS = 0
    pry_top: int64 = drop_anchor_y(mrow_h) + 2 * MENU_ITEM_H + MENU_ITEM_H / 2
    if menubar_item_at(sysx, pry_top) != 2:
        write_str(1, "[DE12] FAIL top: System row 2 hit-test wrong\n")
        return
    PANEL_POS = 1
    pry_bot: int64 = drop_anchor_y(mrow_h) + 2 * MENU_ITEM_H + MENU_ITEM_H / 2
    if menubar_item_at(sysx, pry_bot) != 2:
        write_str(1, "[DE12] FAIL bottom: System row 2 hit-test wrong\n")
        return
    if pry_bot >= bot_y0:
        write_str(1, "[DE12] FAIL bottom: drop row should be ABOVE the bar\n")
        return
    MENU_BAR_OPEN = -1
    write_str(1, "[DE12] hit-test OK\n")

    # ---------------- Step 4: Show Desktop applet -----------------------
    # Geometry: the button sits left of the clock and right of the tray with
    # no overlap, on BOTH edges.
    sdx: int64 = sd_btn_x0(scr_w)
    if sdx + SD_BTN_W > scr_w - CLOCK_W:
        write_str(1, "[DE12] FAIL Show Desktop overlaps the clock\n")
        return
    if notif_x0(scr_w) + NOTIF_W > sdx:
        write_str(1, "[DE12] FAIL tray overlaps Show Desktop\n")
        return
    sd_mid_x: int64 = sdx + SD_BTN_W / 2
    PANEL_POS = 0
    if in_show_desktop_btn(sd_mid_x, top_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL top: Show Desktop missed the bar\n")
        return
    if in_show_desktop_btn(sd_mid_x, bot_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL top: Show Desktop hit the floor\n")
        return
    PANEL_POS = 1
    if in_show_desktop_btn(sd_mid_x, bot_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL bottom: Show Desktop missed the floor\n")
        return
    if in_show_desktop_btn(sd_mid_x, top_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL bottom: Show Desktop hit the ceiling\n")
        return

    # Action: spawn two windows, toggle show-desktop -> both minimized and
    # SHOWDESK_ON; toggle again -> both restored, SHOWDESK_ON cleared.
    PANEL_POS = 0
    CUR_WS = 0
    daemon_spawn_window(80, PANEL_H + 24, 320, 200)
    daemon_spawn_window(120, PANEL_H + 60, 320, 200)
    if DWIN_COUNT < 2:
        write_str(1, "[DE12] FAIL show-desktop test windows not spawned\n")
        return
    vis_before: int64 = 0
    si: uint64 = 0
    while si < DWIN_COUNT:
        if DWIN_WS[si] == CUR_WS and DWIN_HIDDEN[si] == 0:
            vis_before = vis_before + 1
        si = si + 1
    if vis_before < 2:
        write_str(1, "[DE12] FAIL fewer than 2 visible windows pre-toggle\n")
        return
    show_desktop_toggle()
    if SHOWDESK_ON == 0:
        write_str(1, "[DE12] FAIL show-desktop did not arm\n")
        return
    sj: uint64 = 0
    while sj < DWIN_COUNT:
        if DWIN_WS[sj] == CUR_WS and DWIN_HIDDEN[sj] == 0:
            write_str(1, "[DE12] FAIL a window stayed visible after show-desktop\n")
            return
        sj = sj + 1
    show_desktop_toggle()
    if SHOWDESK_ON != 0:
        write_str(1, "[DE12] FAIL show-desktop did not disarm\n")
        return
    vis_after: int64 = 0
    sk: uint64 = 0
    while sk < DWIN_COUNT:
        if DWIN_WS[sk] == CUR_WS and DWIN_HIDDEN[sk] == 0:
            vis_after = vis_after + 1
        sk = sk + 1
    if vis_after != vis_before:
        write_str(1, "[DE12] FAIL show-desktop did not restore the windows\n")
        return
    write_str(1, "[DE12] show-desktop OK\n")

    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    daemon_present()
    write_str(1, "[DE12] PASS\n")


# ====================================================================
# ROUND-13 MATE-feel self-test (autoflag == 23)
# ====================================================================
# Exercises the three round-13 additions with no QEMU mouse injection:
#   1. RUN DIALOG (Alt-F2): open/type/backspace/launch/cancel state machine;
#      a launch spawns a window from the typed command; geometry is centred
#      and modal.
#   2. NOTIFICATION HISTORY / MESSAGE TRAY: notify_post() persists notices in
#      the ring; the tray panel hit-zones (icon, [Clear], body) resolve at
#      the panel's REAL edge for BOTH panel positions; clear empties the ring.
#   3. PLACES menu: now has 5 entries (Home/Filesystem/Computer/Recent/Tmp).
# Emits "[DE13] PASS" / "[DE13] FAIL <reason>".
def daemon_round13_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    SEARCH_OPEN = 0
    SEARCH_LEN = 0
    SHOWDESK_ON = 0
    RUN_OPEN = 0
    RUN_LEN = 0
    TRAY_OPEN = 0
    NHIST_COUNT = 0
    NHIST_HEAD = 0
    theme_apply()
    bg_palette_init()

    # ---------------- Step 1: Run dialog state machine ------------------
    run_open()
    if RUN_OPEN == 0 or RUN_LEN != 0:
        write_str(1, "[DE13] FAIL run_open did not arm an empty dialog\n")
        return
    # Opening the dialog must close any menus (it owns the keyboard).
    if MENU_BAR_OPEN != -1 or SEARCH_OPEN != 0:
        write_str(1, "[DE13] FAIL run_open did not dismiss menus\n")
        return
    # Type "/bin/hamsh".
    run_push(47)        # '/'
    run_push(98)        # 'b'
    run_push(105)       # 'i'
    run_push(110)       # 'n'
    if RUN_LEN != 4:
        write_str(1, "[DE13] FAIL run_push length wrong\n")
        return
    if run_buf[0] != 47 or run_buf[3] != 110 or run_buf[4] != 0:
        write_str(1, "[DE13] FAIL run_buf contents wrong / not NUL-terminated\n")
        return
    # Backspace shortens and re-terminates.
    run_backspace()
    if RUN_LEN != 3 or run_buf[3] != 0:
        write_str(1, "[DE13] FAIL run_backspace wrong\n")
        return
    # Cancel clears everything.
    run_cancel()
    if RUN_OPEN != 0 or RUN_LEN != 0:
        write_str(1, "[DE13] FAIL run_cancel did not reset state\n")
        return
    # An empty launch just dismisses (no window spawned).
    wins_pre: uint64 = DWIN_COUNT
    run_open()
    run_launch(scr_w, scr_h)
    if RUN_OPEN != 0:
        write_str(1, "[DE13] FAIL empty run_launch left dialog open\n")
        return
    if DWIN_COUNT != wins_pre:
        write_str(1, "[DE13] FAIL empty run_launch spawned a window\n")
        return
    # A real launch spawns one window and closes the dialog.
    run_open()
    run_push(47)        # '/'
    run_push(98)        # 'b'
    run_push(105)       # 'i'
    run_push(110)       # 'n'
    run_push(47)        # '/'
    run_push(104)       # 'h'
    run_push(97)        # 'a'
    run_push(109)       # 'm'
    run_push(115)       # 's'
    run_push(104)       # 'h'
    run_launch(scr_w, scr_h)
    if RUN_OPEN != 0:
        write_str(1, "[DE13] FAIL run_launch left the dialog open\n")
        return
    if DWIN_COUNT != wins_pre + 1:
        write_str(1, "[DE13] FAIL run_launch did not spawn exactly one window\n")
        return
    # Dialog geometry is centred and within bounds for both panel positions.
    PANEL_POS = 0
    if run_x(scr_w) < 0 or run_x(scr_w) + RUN_W > scr_w:
        write_str(1, "[DE13] FAIL top: run dialog X out of bounds\n")
        return
    if run_y(scr_h) < PANEL_H:
        write_str(1, "[DE13] FAIL top: run dialog Y above panel\n")
        return
    PANEL_POS = 1
    if run_x(scr_w) < 0 or run_x(scr_w) + RUN_W > scr_w:
        write_str(1, "[DE13] FAIL bottom: run dialog X out of bounds\n")
        return
    PANEL_POS = 0
    write_str(1, "[DE13] run-dialog OK\n")

    # ---------------- Step 2: notification history ---------------------
    NHIST_COUNT = 0
    NHIST_HEAD = 0
    notify_post("First", "alpha")
    notify_post("Second", "beta")
    notify_post("Third", "gamma")
    if NHIST_COUNT != 3:
        write_str(1, "[DE13] FAIL notify history did not record 3 notices\n")
        return
    # Newest first: index 0 is the last posted.
    if cstr_eq(nhist_title_at(0), "Third") == 0:
        write_str(1, "[DE13] FAIL history newest entry wrong\n")
        return
    if cstr_eq(nhist_body_at(0), "gamma") == 0:
        write_str(1, "[DE13] FAIL history newest body wrong\n")
        return
    if cstr_eq(nhist_title_at(2), "First") == 0:
        write_str(1, "[DE13] FAIL history oldest entry wrong\n")
        return
    # The ring wraps: post past capacity and confirm the count clamps and the
    # oldest scrolls off.
    nfill: int64 = 0
    while nfill < NHIST_MAX:
        notify_post("Flood", "fill")
        nfill = nfill + 1
    if NHIST_COUNT != NHIST_MAX:
        write_str(1, "[DE13] FAIL history count did not clamp to capacity\n")
        return
    if cstr_eq(nhist_title_at(0), "Flood") == 0:
        write_str(1, "[DE13] FAIL post-flood newest entry wrong\n")
        return
    write_str(1, "[DE13] notify-history OK\n")

    # ---------------- Step 3: message-tray hit-zones (both edges) -------
    # Re-seed a small, known history so the tray panel has rows.
    NHIST_COUNT = 0
    NHIST_HEAD = 0
    notify_post("Hello", "world")
    notify_post("Build", "done")
    TRAY_OPEN = 1
    # Tray icon sits in the panel's notification zone; hit-tests on the
    # bar for the configured edge and rejects the opposite edge.
    ntx: int64 = notif_x0(scr_w) + 2
    PANEL_POS = 0
    top_mid: int64 = PANEL_H / 2
    bot_mid: int64 = scr_h - PANEL_H / 2
    if in_tray_msg_btn(ntx, top_mid, scr_w) == 0:
        write_str(1, "[DE13] FAIL top: tray icon missed the top edge\n")
        return
    if in_tray_msg_btn(ntx, bot_mid, scr_w) != 0:
        write_str(1, "[DE13] FAIL top: tray icon wrongly hit the floor\n")
        return
    PANEL_POS = 1
    if in_tray_msg_btn(ntx, bot_mid, scr_w) == 0:
        write_str(1, "[DE13] FAIL bottom: tray icon missed the floor\n")
        return
    if in_tray_msg_btn(ntx, top_mid, scr_w) != 0:
        write_str(1, "[DE13] FAIL bottom: tray icon wrongly hit the ceiling\n")
        return
    PANEL_POS = 0
    # The tray panel anchors away from the bar (below a top panel, above a
    # bottom panel) for both positions.
    PANEL_POS = 0
    if drop_anchor_y(tray_total_h()) != panel_y0() + PANEL_H:
        write_str(1, "[DE13] FAIL top: tray panel does not hang below the bar\n")
        return
    PANEL_POS = 1
    if drop_anchor_y(tray_total_h()) != panel_y0() - tray_total_h():
        write_str(1, "[DE13] FAIL bottom: tray panel does not rise above the bar\n")
        return
    PANEL_POS = 0
    # [Clear] affordance lands inside the panel header for both positions.
    tpx_t: int64 = tray_x(scr_w)
    hdr_y: int64 = drop_anchor_y(tray_total_h()) + TRAY_ROW_H / 2
    clrx: int64 = tpx_t + TRAY_W - cast[int64](strlen_u8("[Clear]")) * GLYPH_W - 4
    if in_tray_clear_btn(clrx, hdr_y, scr_w) == 0:
        write_str(1, "[DE13] FAIL top: [Clear] not hit in the header\n")
        return
    if in_tray_panel(tpx_t + 4, hdr_y, scr_w) == 0:
        write_str(1, "[DE13] FAIL top: tray panel body not hit\n")
        return
    PANEL_POS = 1
    hdr_y2: int64 = drop_anchor_y(tray_total_h()) + TRAY_ROW_H / 2
    if in_tray_clear_btn(clrx, hdr_y2, scr_w) == 0:
        write_str(1, "[DE13] FAIL bottom: [Clear] not hit in the header\n")
        return
    PANEL_POS = 0
    # Clearing empties the ring.
    nhist_clear()
    if NHIST_COUNT != 0:
        write_str(1, "[DE13] FAIL nhist_clear did not empty the ring\n")
        return
    TRAY_OPEN = 0
    write_str(1, "[DE13] message-tray OK\n")

    # ---------------- Step 4: enriched Places menu ----------------------
    # Places now lists Home/Filesystem/Computer/Recent Documents/Tmp.
    if menubar_count(1) != 5:
        write_str(1, "[DE13] FAIL Places does not have 5 entries\n")
        return
    if cstr_eq(menubar_item_label(1, 2), "Computer") == 0:
        write_str(1, "[DE13] FAIL Places entry 2 is not Computer\n")
        return
    if cstr_eq(menubar_item_label(1, 3), "Recent Documents") == 0:
        write_str(1, "[DE13] FAIL Places entry 3 is not Recent Documents\n")
        return
    # The System menu gained a Run Application... entry at index 2.
    if menubar_count(2) != 8:
        write_str(1, "[DE13] FAIL System menu does not have 8 entries\n")
        return
    if cstr_eq(menubar_item_label(2, 2), "Run Application...") == 0:
        write_str(1, "[DE13] FAIL System entry 2 is not Run Application...\n")
        return
    write_str(1, "[DE13] places-menu OK\n")

    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    RUN_OPEN = 0
    TRAY_OPEN = 0
    daemon_present()
    write_str(1, "[DE13] PASS\n")


# ====================================================================
# ROUND-14 MATE-feel self-test (autoflag == 24)
# ====================================================================
# Exercises the three round-14 additions with no QEMU mouse injection:
#   1. WINDOW-LIST (taskbar) per-window right-click menu (CTX_KIND==2):
#      Minimize/Restore, Maximize/Unmaximize, Shade/Unshade, Close, and a
#      "Move to Workspace:" header followed by one row per virtual desktop.
#      Asserts the row labels, the current-workspace '*' marker, every
#      action's state transition, and the panel-anchored drop geometry for
#      BOTH panel positions.
#   2. PAGER (workspace-switcher) right-click menu (CTX_KIND==3): Add
#      Workspace / Remove Workspace / Show All Workspaces. Asserts the count
#      grows/shrinks with WS_MIN/WS_MAX clamping and the preference toggles.
#   3. SHOW-ALL-WORKSPACES window-list filter: taskbar_lists_slot() and the
#      taskbar_slot_at() hit-test honour the preference for BOTH panel edges.
# Emits "[DE14] PASS" / "[DE14] FAIL <reason>".
def daemon_round14_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    CTX_KIND = 0
    CTX_SLOT = -1
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    SEARCH_OPEN = 0
    SHOWDESK_ON = 0
    RUN_OPEN = 0
    TRAY_OPEN = 0
    SHOW_ALL_WS = 0
    theme_apply()
    bg_palette_init()

    # Two distinct built-in app windows on workspace 0 (CALC + SYSMON). Both
    # are singletons so neither groups — each owns its own taskbar button and
    # the per-window window-list menu (not the group menu) applies.
    daemon_spawn_app(APP_CALC, 100, 80, 220, 300)
    daemon_spawn_app(APP_SYSMON, 360, 80, 360, 220)
    if DWIN_COUNT < 2:
        write_str(1, "[DE14] FAIL could not create two windows\n")
        return
    s0: int64 = 0
    s1: int64 = 1
    su0: uint64 = cast[uint64](s0)

    # ---------------- Step 1: window-list per-window menu ----------------
    ctx_open_at(2, s0, taskbar_btn_x(su0), drop_anchor_y(ctx_total_h_kind(2)),
                scr_w, scr_h)
    if CTX_OPEN == 0 or CTX_KIND != 2 or CTX_SLOT != s0:
        write_str(1, "[DE14] FAIL window-list menu did not arm on slot 0\n")
        return
    # 5 fixed rows + one row per workspace.
    if ctx_count() != cast[uint64](5 + WS_COUNT):
        write_str(1, "[DE14] FAIL window-list menu row count wrong\n")
        return
    # ctx_total_h() (live, after open) must agree with the pre-open estimate.
    if ctx_total_h() != ctx_total_h_kind(2):
        write_str(1, "[DE14] FAIL ctx_total_h_kind disagrees with ctx_total_h\n")
        return
    if cstr_eq(ctx_item_label(0), "Minimize") == 0:
        write_str(1, "[DE14] FAIL row 0 is not Minimize\n")
        return
    if cstr_eq(ctx_item_label(1), "Maximize") == 0:
        write_str(1, "[DE14] FAIL row 1 is not Maximize\n")
        return
    if cstr_eq(ctx_item_label(2), "Shade") == 0:
        write_str(1, "[DE14] FAIL row 2 is not Shade\n")
        return
    if cstr_eq(ctx_item_label(3), "Close") == 0:
        write_str(1, "[DE14] FAIL row 3 is not Close\n")
        return
    if cstr_eq(ctx_item_label(4), "Move to Workspace:") == 0:
        write_str(1, "[DE14] FAIL row 4 is not the Move-to-Workspace header\n")
        return
    # The window lives on WS 0, so row 5 ("WS 1") carries the '*' marker and
    # row 6 ("WS 2") does not.
    if cstr_eq(ctx_item_label(5), "WS 1 *") == 0:
        write_str(1, "[DE14] FAIL row 5 is not the starred current workspace\n")
        return
    if cstr_eq(ctx_item_label(6), "WS 2") == 0:
        write_str(1, "[DE14] FAIL row 6 is not WS 2\n")
        return
    write_str(1, "[DE14] window-list-menu labels OK\n")

    # Minimize toggle: hide, label flips to Restore, restore un-hides.
    DWIN_HIDDEN[su0] = 0
    ctx_invoke(0, scr_w, scr_h)
    if DWIN_HIDDEN[su0] == 0:
        write_str(1, "[DE14] FAIL window-list Minimize did not hide\n")
        return
    if cstr_eq(ctx_item_label(0), "Restore") == 0:
        write_str(1, "[DE14] FAIL hidden-window row 0 label is not Restore\n")
        return
    ctx_invoke(0, scr_w, scr_h)
    if DWIN_HIDDEN[su0] != 0:
        write_str(1, "[DE14] FAIL window-list Restore did not un-hide\n")
        return

    # Maximize toggle: row 1 label flips to Unmaximize while maxed.
    if DWIN_MAXED[su0] != 0:
        write_str(1, "[DE14] FAIL window started maximized\n")
        return
    ctx_invoke(1, scr_w, scr_h)
    if DWIN_MAXED[su0] == 0:
        write_str(1, "[DE14] FAIL window-list Maximize did not maximize\n")
        return
    if cstr_eq(ctx_item_label(1), "Unmaximize") == 0:
        write_str(1, "[DE14] FAIL maxed-window row 1 label is not Unmaximize\n")
        return
    ctx_invoke(1, scr_w, scr_h)                 # restore
    if DWIN_MAXED[su0] != 0:
        write_str(1, "[DE14] FAIL window-list Unmaximize did not restore\n")
        return

    # Shade toggle: row 2 flips to Unshade while rolled up.
    ctx_invoke(2, scr_w, scr_h)
    if DWIN_SHADED[su0] == 0:
        write_str(1, "[DE14] FAIL window-list Shade did not shade\n")
        return
    if cstr_eq(ctx_item_label(2), "Unshade") == 0:
        write_str(1, "[DE14] FAIL shaded-window row 2 label is not Unshade\n")
        return
    ctx_invoke(2, scr_w, scr_h)                 # unshade
    if DWIN_SHADED[su0] != 0:
        write_str(1, "[DE14] FAIL window-list Unshade did not unshade\n")
        return

    # Header row (4) is inert.
    pre_ws: int32 = DWIN_WS[su0]
    ctx_invoke(4, scr_w, scr_h)
    if DWIN_WS[su0] != pre_ws:
        write_str(1, "[DE14] FAIL header row changed the workspace\n")
        return
    # Move-to-Workspace: row 6 is WS index 1 (the second desktop).
    ctx_invoke(6, scr_w, scr_h)
    if DWIN_WS[su0] != 1:
        write_str(1, "[DE14] FAIL Move-to-Workspace did not move to WS index 1\n")
        return
    # With the window now on WS 1, its row 5 ("WS 1") is bare and row 6 stars.
    if cstr_eq(ctx_item_label(6), "WS 2 *") == 0:
        write_str(1, "[DE14] FAIL star did not follow the window to WS 2\n")
        return
    DWIN_WS[su0] = 0                            # put it back for later steps
    CTX_OPEN = 0
    write_str(1, "[DE14] window-list-menu actions OK\n")

    # Panel-anchored drop geometry for BOTH panel positions: the menu hangs
    # below a top panel and rises above a bottom panel.
    PANEL_POS = 0
    if drop_anchor_y(ctx_total_h_kind(2)) != panel_y0() + PANEL_H:
        write_str(1, "[DE14] FAIL top: window-list menu does not hang below the bar\n")
        return
    PANEL_POS = 1
    if drop_anchor_y(ctx_total_h_kind(2)) != panel_y0() - ctx_total_h_kind(2):
        write_str(1, "[DE14] FAIL bottom: window-list menu does not rise above the bar\n")
        return
    PANEL_POS = 0
    write_str(1, "[DE14] window-list-menu anchor OK\n")

    # ---------------- Step 2: pager (workspace-switcher) menu ------------
    WS_COUNT = 4
    SHOW_ALL_WS = 0
    ctx_open_at(3, -1, pager_x0(scr_w), drop_anchor_y(ctx_total_h_kind(3)),
                scr_w, scr_h)
    if CTX_OPEN == 0 or CTX_KIND != 3:
        write_str(1, "[DE14] FAIL pager menu did not arm\n")
        return
    if ctx_count() != 3:
        write_str(1, "[DE14] FAIL pager menu does not have 3 rows\n")
        return
    if cstr_eq(ctx_item_label(0), "Add Workspace") == 0:
        write_str(1, "[DE14] FAIL pager row 0 is not Add Workspace\n")
        return
    if cstr_eq(ctx_item_label(1), "Remove Workspace") == 0:
        write_str(1, "[DE14] FAIL pager row 1 is not Remove Workspace\n")
        return
    if cstr_eq(ctx_item_label(2), "Show All Workspaces") == 0:
        write_str(1, "[DE14] FAIL pager row 2 is not Show All Workspaces\n")
        return
    # Add grows the count by one.
    ctx_invoke(0, scr_w, scr_h)
    if WS_COUNT != 5:
        write_str(1, "[DE14] FAIL Add Workspace did not grow the count\n")
        return
    # Remove shrinks it back.
    ctx_invoke(1, scr_w, scr_h)
    if WS_COUNT != 4:
        write_str(1, "[DE14] FAIL Remove Workspace did not shrink the count\n")
        return
    # Add clamps at WS_MAX.
    WS_COUNT = WS_MAX
    if ws_count_add() != 0 or WS_COUNT != WS_MAX:
        write_str(1, "[DE14] FAIL Add Workspace did not clamp at WS_MAX\n")
        return
    # Remove clamps at WS_MIN.
    WS_COUNT = WS_MIN
    CUR_WS = 0
    if ws_count_remove() != 0 or WS_COUNT != WS_MIN:
        write_str(1, "[DE14] FAIL Remove Workspace did not clamp at WS_MIN\n")
        return
    WS_COUNT = 4
    # Toggle flips SHOW_ALL_WS and the row label gains the '*'.
    ctx_invoke(2, scr_w, scr_h)
    if SHOW_ALL_WS == 0:
        write_str(1, "[DE14] FAIL Show All Workspaces did not turn on\n")
        return
    if cstr_eq(ctx_item_label(2), "Show All Workspaces *") == 0:
        write_str(1, "[DE14] FAIL toggled-on row 2 lost its star\n")
        return
    ctx_invoke(2, scr_w, scr_h)
    if SHOW_ALL_WS != 0:
        write_str(1, "[DE14] FAIL Show All Workspaces did not turn off\n")
        return
    CTX_OPEN = 0
    write_str(1, "[DE14] pager-menu OK\n")

    # ---------------- Step 3: show-all-workspaces window-list filter ----
    # Slot 0 on WS 0, slot 1 relocated to WS 1; current desktop is WS 0.
    CUR_WS = 0
    DWIN_WS[su0] = 0
    DWIN_WS[cast[uint64](s1)] = 1
    SHOW_ALL_WS = 0
    if taskbar_lists_slot(su0) == 0:
        write_str(1, "[DE14] FAIL filtered: current-desktop window not listed\n")
        return
    if taskbar_lists_slot(cast[uint64](s1)) != 0:
        write_str(1, "[DE14] FAIL filtered: off-desktop window wrongly listed\n")
        return
    SHOW_ALL_WS = 1
    if taskbar_lists_slot(cast[uint64](s1)) == 0:
        write_str(1, "[DE14] FAIL show-all: off-desktop window not listed\n")
        return
    # The taskbar hit-test must honour the same filter at BOTH panel edges.
    # Probe a point inside slot 1's button on the configured panel row.
    hbx: int64 = taskbar_btn_x(cast[uint64](s1)) + 4
    pgr_lim: int64 = pager_x0(scr_w)
    if hbx >= pgr_lim:
        # Slot-1 button overlaps the pager zone on this screen; nudge the
        # assertion onto slot 0, which is still left of the pager.
        hbx = taskbar_btn_x(su0) + 4
    PANEL_POS = 0
    top_row: int64 = TASKBAR_BTN_Y + 2
    SHOW_ALL_WS = 1
    if taskbar_slot_at(hbx, top_row, scr_w) < 0:
        write_str(1, "[DE14] FAIL top show-all: hit-test missed a listed window\n")
        return
    SHOW_ALL_WS = 0
    DWIN_WS[su0] = 1                            # move BOTH off the current WS
    if taskbar_slot_at(hbx, top_row, scr_w) >= 0:
        write_str(1, "[DE14] FAIL top filtered: hit-test caught an off-desktop window\n")
        return
    PANEL_POS = 1
    bot_row: int64 = scr_h - PANEL_H + TASKBAR_BTN_Y + 2
    SHOW_ALL_WS = 1
    DWIN_WS[su0] = 0
    if taskbar_slot_at(hbx, bot_row, scr_w) < 0:
        write_str(1, "[DE14] FAIL bottom show-all: hit-test missed a listed window\n")
        return
    SHOW_ALL_WS = 0
    DWIN_WS[su0] = 1
    DWIN_WS[cast[uint64](s1)] = 1
    if taskbar_slot_at(hbx, bot_row, scr_w) >= 0:
        write_str(1, "[DE14] FAIL bottom filtered: hit-test caught an off-desktop window\n")
        return
    PANEL_POS = 0
    write_str(1, "[DE14] show-all-ws filter OK\n")

    # ---------------- Restore a clean state + present -------------------
    CUR_WS = 0
    DWIN_WS[su0] = 0
    DWIN_WS[cast[uint64](s1)] = 0
    SHOW_ALL_WS = 0
    CTX_OPEN = 0
    CTX_KIND = 0
    CTX_SLOT = -1
    PANEL_POS = 0
    daemon_present()
    write_str(1, "[DE14] PASS\n")


# ====================================================================
# ROUND-15 MATE-feel self-test (autoflag == 25)
# ====================================================================
# Exercises the four round-15 additions with no QEMU mouse injection:
#   1. PANEL CONTEXT MENU (CTX_KIND==4): right-click the bar -> Flip Panel
#      Position / Autohide (toggle) / Add to Panel / Panel Preferences.
#      Asserts the row labels, the autohide '*' marker, each action's state
#      transition, the QLAUNCH_MAX clamp, and the panel-anchored drop
#      geometry for BOTH panel positions.
#   2. PANEL AUTOHIDE state machine: panel_visible_h() collapses to the
#      reveal sliver only when hidden; panel_autohide_update() reveals on an
#      edge-touch and re-hides off it, for BOTH panel positions.
#   3. WORKSPACE-SWITCH OSD: osd_show_workspace()/osd_step() arm + age the
#      transient indicator; osd_x0/osd_y0 centre it in the work area for
#      BOTH panel positions; a real workspace_switch() arms it too.
#   4. WINDOW URGENCY blink: set/clear/is helpers, the blink-phase machine,
#      and that raising/focusing a window clears its urgency.
# Also re-checks the Alt-Space focused-window menu opener (CTX_KIND==1).
# Emits "[DE15] PASS" / "[DE15] FAIL <reason>".
def daemon_round15_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CTX_OPEN = 0
    CTX_KIND = 0
    CTX_SLOT = -1
    WS_COUNT = 4
    PANEL_POS = 0
    PANEL_AUTOHIDE = 0
    PANEL_HIDDEN = 0
    SHOW_ALL_WS = 0
    OSD_TTL = 0
    OSD_WS = 0
    QLAUNCH_COUNT = 0
    URGENT_PHASE = 0
    theme_apply()
    bg_palette_init()

    daemon_spawn_app(APP_CALC, 100, 80, 220, 300)
    daemon_spawn_app(APP_SYSMON, 360, 80, 360, 220)
    if DWIN_COUNT < 2:
        write_str(1, "[DE15] FAIL could not create two windows\n")
        return
    s0: int64 = 0
    s1: int64 = 1
    su0: uint64 = cast[uint64](s0)
    su1: uint64 = cast[uint64](s1)

    # ---------------- Step 1: panel context menu ------------------------
    PANEL_POS = 0
    PANEL_AUTOHIDE = 0
    ctx_open_at(4, -1, 200, drop_anchor_y(ctx_total_h_kind(4)), scr_w, scr_h)
    if CTX_OPEN == 0 or CTX_KIND != 4:
        write_str(1, "[DE15] FAIL panel menu did not arm\n")
        return
    if ctx_count() != 4:
        write_str(1, "[DE15] FAIL panel menu does not have 4 rows\n")
        return
    if ctx_total_h() != ctx_total_h_kind(4):
        write_str(1, "[DE15] FAIL ctx_total_h_kind disagrees for panel menu\n")
        return
    if cstr_eq(ctx_item_label(0), "Flip Panel Position") == 0:
        write_str(1, "[DE15] FAIL panel row 0 is not Flip Panel Position\n")
        return
    if cstr_eq(ctx_item_label(1), "Autohide") == 0:
        write_str(1, "[DE15] FAIL panel row 1 is not Autohide\n")
        return
    if cstr_eq(ctx_item_label(2), "Add to Panel") == 0:
        write_str(1, "[DE15] FAIL panel row 2 is not Add to Panel\n")
        return
    if cstr_eq(ctx_item_label(3), "Panel Preferences") == 0:
        write_str(1, "[DE15] FAIL panel row 3 is not Panel Preferences\n")
        return
    # Flip Panel Position: top -> bottom and the label stays put.
    ctx_invoke(0, scr_w, scr_h)
    if PANEL_POS != 1:
        write_str(1, "[DE15] FAIL Flip did not move the panel to the bottom\n")
        return
    ctx_invoke(0, scr_w, scr_h)                 # flip back to top
    if PANEL_POS != 0:
        write_str(1, "[DE15] FAIL Flip did not move the panel back to the top\n")
        return
    # Autohide toggle: row 1 gains the '*' while enabled.
    ctx_invoke(1, scr_w, scr_h)
    if PANEL_AUTOHIDE == 0:
        write_str(1, "[DE15] FAIL Autohide did not enable\n")
        return
    if cstr_eq(ctx_item_label(1), "Autohide *") == 0:
        write_str(1, "[DE15] FAIL enabled Autohide row lost its star\n")
        return
    ctx_invoke(1, scr_w, scr_h)
    if PANEL_AUTOHIDE != 0:
        write_str(1, "[DE15] FAIL Autohide did not disable\n")
        return
    # Add to Panel: grows the launcher count, clamped at QLAUNCH_MAX.
    QLAUNCH_COUNT = 0
    ctx_invoke(2, scr_w, scr_h)
    if QLAUNCH_COUNT != 1:
        write_str(1, "[DE15] FAIL Add to Panel did not pin a launcher\n")
        return
    QLAUNCH_COUNT = QLAUNCH_MAX
    if panel_add_launcher() != 0 or QLAUNCH_COUNT != QLAUNCH_MAX:
        write_str(1, "[DE15] FAIL Add to Panel did not clamp at QLAUNCH_MAX\n")
        return
    QLAUNCH_COUNT = 0
    CTX_OPEN = 0
    write_str(1, "[DE15] panel-menu OK\n")
    # Panel-anchored drop geometry for BOTH panel positions.
    PANEL_POS = 0
    if drop_anchor_y(ctx_total_h_kind(4)) != panel_y0() + PANEL_H:
        write_str(1, "[DE15] FAIL top: panel menu does not hang below the bar\n")
        return
    PANEL_POS = 1
    if drop_anchor_y(ctx_total_h_kind(4)) != panel_y0() - ctx_total_h_kind(4):
        write_str(1, "[DE15] FAIL bottom: panel menu does not rise above the bar\n")
        return
    PANEL_POS = 0
    write_str(1, "[DE15] panel-menu anchor OK\n")

    # ---------------- Step 2: panel autohide state machine --------------
    PANEL_AUTOHIDE = 0
    PANEL_HIDDEN = 0
    if panel_visible_h() != PANEL_H:
        write_str(1, "[DE15] FAIL visible height wrong with autohide off\n")
        return
    PANEL_AUTOHIDE = 1
    PANEL_HIDDEN = 1
    if panel_visible_h() != PANEL_REVEAL_H:
        write_str(1, "[DE15] FAIL hidden bar did not collapse to the sliver\n")
        return
    # BOTH panel positions: a pointer on the bar edge reveals; off it hides.
    PANEL_POS = 0
    PANEL_HIDDEN = 1
    on_top: int64 = panel_y0() + 1
    if panel_autohide_update(on_top) != 1 or PANEL_HIDDEN != 0:
        write_str(1, "[DE15] FAIL top: edge-touch did not reveal the panel\n")
        return
    if panel_autohide_update(panel_y0() + PANEL_H + 200) != 1 or PANEL_HIDDEN != 1:
        write_str(1, "[DE15] FAIL top: leaving the edge did not re-hide\n")
        return
    PANEL_POS = 1
    PANEL_HIDDEN = 1
    on_bot: int64 = panel_y0() + 1
    if panel_autohide_update(on_bot) != 1 or PANEL_HIDDEN != 0:
        write_str(1, "[DE15] FAIL bottom: edge-touch did not reveal the panel\n")
        return
    if panel_autohide_update(work_top(scr_h) + 4) != 1 or PANEL_HIDDEN != 1:
        write_str(1, "[DE15] FAIL bottom: leaving the edge did not re-hide\n")
        return
    # Turning autohide off always re-reveals.
    PANEL_AUTOHIDE = 0
    PANEL_HIDDEN = 1
    panel_autohide_update(0)
    if PANEL_HIDDEN != 0 or panel_visible_h() != PANEL_H:
        write_str(1, "[DE15] FAIL autohide-off did not re-reveal the bar\n")
        return
    PANEL_POS = 0
    write_str(1, "[DE15] panel-autohide OK\n")

    # ---------------- Step 3: workspace-switch OSD ----------------------
    OSD_TTL = 0
    if osd_active() != 0:
        write_str(1, "[DE15] FAIL OSD active before any switch\n")
        return
    osd_show_workspace(2)
    if osd_active() == 0 or OSD_WS != 2 or OSD_TTL != OSD_TTL_MAX:
        write_str(1, "[DE15] FAIL OSD did not arm for workspace 2\n")
        return
    # osd_step ages it; after OSD_TTL_MAX steps it must be inactive.
    osd_ticks: int32 = 0
    while osd_ticks < OSD_TTL_MAX:
        osd_step()
        osd_ticks = osd_ticks + 1
    if osd_active() != 0:
        write_str(1, "[DE15] FAIL OSD did not expire after OSD_TTL_MAX steps\n")
        return
    # Centre geometry for BOTH panel positions: the popup never overlaps the
    # bar and is horizontally centred.
    PANEL_POS = 0
    if osd_x0(scr_w) != (scr_w - OSD_W) / 2:
        write_str(1, "[DE15] FAIL OSD not horizontally centred\n")
        return
    top_oy: int64 = osd_y0(scr_h)
    if top_oy < work_top(scr_h):
        write_str(1, "[DE15] FAIL top: OSD overlaps the panel bar\n")
        return
    if top_oy + OSD_H > work_top(scr_h) + work_h(scr_h):
        write_str(1, "[DE15] FAIL top: OSD spills past the work area\n")
        return
    PANEL_POS = 1
    bot_oy: int64 = osd_y0(scr_h)
    if bot_oy < work_top(scr_h):
        write_str(1, "[DE15] FAIL bottom: OSD above the work area\n")
        return
    if bot_oy + OSD_H > work_top(scr_h) + work_h(scr_h):
        write_str(1, "[DE15] FAIL bottom: OSD overlaps the bottom panel\n")
        return
    PANEL_POS = 0
    # A real workspace_switch arms the OSD naming the new desktop.
    OSD_TTL = 0
    CUR_WS = 0
    workspace_switch(2)
    if osd_active() == 0 or OSD_WS != 2:
        write_str(1, "[DE15] FAIL workspace_switch did not raise the OSD\n")
        return
    OSD_TTL = 0
    CUR_WS = 0
    write_str(1, "[DE15] workspace-osd OK\n")

    # ---------------- Step 4: window urgency blink ----------------------
    DWIN_URGENT[su0] = 0
    DWIN_URGENT[su1] = 0
    if window_is_urgent(su0) != 0:
        write_str(1, "[DE15] FAIL window started urgent\n")
        return
    if any_window_urgent() != 0:
        write_str(1, "[DE15] FAIL no window should be urgent yet\n")
        return
    window_set_urgent(su0)
    if window_is_urgent(su0) == 0 or any_window_urgent() == 0:
        write_str(1, "[DE15] FAIL set_urgent did not mark the window\n")
        return
    # Blink-phase machine: lit on the first half, dark on the second.
    URGENT_PHASE = 0
    if urgent_blink_on() == 0:
        write_str(1, "[DE15] FAIL blink not lit at phase 0\n")
        return
    URGENT_PHASE = URGENT_PERIOD - 1
    if urgent_blink_on() != 0:
        write_str(1, "[DE15] FAIL blink lit at the dark phase\n")
        return
    # urgent_phase_step wraps at URGENT_PERIOD.
    URGENT_PHASE = URGENT_PERIOD - 1
    urgent_phase_step()
    if URGENT_PHASE != 0:
        write_str(1, "[DE15] FAIL phase did not wrap at URGENT_PERIOD\n")
        return
    # Focusing/raising the urgent window clears its attention demand.
    daemon_raise_slot(s0)
    foc: int64 = daemon_focus_slot()
    if foc < 0 or DWIN_URGENT[cast[uint64](foc)] != 0:
        write_str(1, "[DE15] FAIL raising the window did not clear urgency\n")
        return
    if window_clear_urgent_check() != 0:
        write_str(1, "[DE15] FAIL clear helper left a window urgent\n")
        return
    write_str(1, "[DE15] window-urgency OK\n")

    # ---------------- Step 5: Alt-Space focused-window menu -------------
    CTX_OPEN = 0
    if window_menu_open_focused(scr_w, scr_h) == 0:
        write_str(1, "[DE15] FAIL Alt-Space did not open the window menu\n")
        return
    if CTX_OPEN == 0 or CTX_KIND != 1:
        write_str(1, "[DE15] FAIL Alt-Space opened the wrong menu kind\n")
        return
    if CTX_SLOT != daemon_focus_slot():
        write_str(1, "[DE15] FAIL Alt-Space menu not on the focused window\n")
        return
    # A second Alt-Space toggles it shut.
    window_menu_open_focused(scr_w, scr_h)
    if CTX_OPEN != 0:
        write_str(1, "[DE15] FAIL second Alt-Space did not dismiss the menu\n")
        return
    write_str(1, "[DE15] alt-space-menu OK\n")

    # ---------------- Restore a clean state + present -------------------
    CUR_WS = 0
    PANEL_POS = 0
    PANEL_AUTOHIDE = 0
    PANEL_HIDDEN = 0
    OSD_TTL = 0
    QLAUNCH_COUNT = 0
    URGENT_PHASE = 0
    DWIN_URGENT[su0] = 0
    DWIN_URGENT[su1] = 0
    CTX_OPEN = 0
    CTX_KIND = 0
    CTX_SLOT = -1
    daemon_present()
    write_str(1, "[DE15] PASS\n")


# ====================================================================
# ROUND-17: status-notifier area, volume/brightness OSD slider, the panel
# Window-Selector applet, and workspace-name editing + OSD.
# ====================================================================
# These four MATE/GNOME2 panel applets are modelled as fully-functional
# state machines with concrete geometry so the round-17 self-test can
# assert them for BOTH panel positions (the DE is not runtime-observable
# under the QEMU -vga std VBE host limit).
#
# 1. STATUS-NOTIFIER AREA (statnot): three classic indicator cells on the
#    right of the panel just left of the message tray — battery, network,
#    and volume. Each has a model value and a click that pops an info line.
# 2. VOLUME / BRIGHTNESS OSD: a centred slider that reuses the OSD timer.
#    vol_step()/bri_step() nudge a 0..100 model value, clamp at the ends,
#    and arm the OSD with the slider geometry. The sound applet popup lists
#    the mute toggle + level.
# 3. WINDOW-SELECTOR APPLET (winsel): a panel dropdown listing EVERY window
#    across ALL workspaces; clicking a row activates that window (unhide,
#    switch to its workspace, raise it).
# 4. WORKSPACE-NAME editing: each desktop carries an editable name; the
#    pager OSD and the window-selector show it. ws_name_set() rewrites a
#    name and ws_name_osd() pops a transient "renamed" indicator.

# ---- Status-notifier (system indicator) area -----------------------
# Three indicator cells. Each is STATNOT_ICON wide with STATNOT_PAD gaps,
# laid out on the panel just left of the message-tray/clock zone. The
# popup (STATNOT_POPUP) shows the detail line for the clicked cell.
STATNOT_ICON: int64 = 16
STATNOT_PAD:  int64 = 4
STATNOT_CELLS: int64 = 3
# = CELLS*ICON + (CELLS+1)*PAD = 3*16 + 4*4 = 64.
STATNOT_W:    int64 = 64
# Cell 0 = battery (0..100 %, charging flag), cell 1 = network (link 0/1 +
# 0..4 signal bars), cell 2 = volume (0..100 %, muted flag).
#
# REAL BACKENDS (no fake models):
#   battery — Hamnix has NO battery surface (no ACPI battery driver, and
#     the QEMU VM has no battery device), so the TRUTHFUL state is
#     "AC power / no battery": STATNOT_BATT_PRESENT == 0. When a future
#     ACPI battery file server lands, its reader sets _PRESENT = 1 and
#     fills STATNOT_BATT / STATNOT_BATT_CHG — the render + detail paths
#     below already handle that case.
#   network — STATNOT_NETUP + STATNOT_IP are read from the kernel's
#     host-level /net/addr leaf ("<ip> up|down\n", served by the bound
#     `#I` IP device server) on startup and on a slow housekeeping tick.
#   volume — VOL_LEVEL / VOL_MUTED mirror the REAL kernel mixer: every
#     change writes a verb to /dev/audioctl and re-reads /dev/audio's
#     status line, so the displayed percent is the mixer's value. With
#     no HDA device the cell renders greyed (STATNOT_AUDIO == 0).
STATNOT_BATT_PRESENT: int32 = 0  # 1 only when a real battery surface exists
STATNOT_BATT:   int64 = -1     # battery percent 0..100 (-1 = no battery)
STATNOT_BATT_CHG: int32 = 0    # 1 if charging (only meaningful if present)
STATNOT_NETUP:  int32 = 0      # 1 if the host has an IPv4 address (/net/addr)
STATNOT_NETSIG: int64 = 0      # signal bars 0..4 (wired: 4 when up, 0 down)
# (volume lives in VOL_LEVEL / VOL_MUTED below, shared with the OSD.)
STATNOT_AUDIO:  int32 = -1     # -1 unprobed, 0 no /dev/audio, 1 mixer live
STATNOT_POPUP:  int32 = -1     # -1 none, else the open cell index 0..2
# Scratch for the popup detail line.
statnot_buf: Array[40, uint8]
# Dotted-quad host IP as rendered by /net/addr (NUL-terminated).
STATNOT_IP: Array[20, uint8]
# Jiffy stamp of the last /net/addr poll (slow tick, ~3 s).
STATNOT_NET_JIFFY: uint64 = 0
STATNOT_NET_POLL_JIFFIES: uint64 = 300   # poll /net/addr every ~3 s

# Volume + brightness model (0..100). Shared by the status-notifier volume
# cell, the sound-applet popup, and the centred OSD slider.
VOL_LEVEL:  int64 = 65
VOL_MUTED:  int32 = 0
BRI_LEVEL:  int64 = 80
# OSD slider kind: 0 = none/workspace (round 15), 1 = volume, 2 = brightness.
OSD_KIND:   int32 = 0
OSD_SLIDER_W: int64 = 200       # slider track width inside the OSD slab
OSD_SLIDER_H: int64 = 10        # slider track height


# X of the status-notifier zone's left edge. It sits immediately left of
# the message-tray/clock notification area, which itself hugs the right
# edge BEHIND the show-desktop button and clock. The right-edge applet
# chain is, from the right: clock (CLOCK_W), show-desktop (SD_BTN_W),
# notification stub (NOTIF_W), then this status-notifier zone. Earlier
# this used `scr_w - NOTIF_W - STATNOT_W - 4`, which ignored CLOCK_W and
# SD_BTN_W and so drew the green/blue indicator bars directly on top of
# the notification stub (the "status bars near the clock overlapping"
# defect). Following the full chain tiles the zones without overlap.
# Independent of panel position (the panel is full-width).
def statnot_x0(scr_w: int64) -> int64:
    return scr_w - CLOCK_W - SD_BTN_W - NOTIF_W - STATNOT_W - 4


# Index of the status-notifier cell under (px,py), or -1. Whole panel-Y
# band is the hit target so both panel positions resolve identically.
def statnot_cell_at(px: int64, py: int64, scr_w: int64) -> int64:
    if on_panel_y(py) == 0:
        return -1
    x0: int64 = statnot_x0(scr_w)
    if px < x0 or px >= x0 + STATNOT_W:
        return -1
    rel: int64 = px - x0 - STATNOT_PAD
    if rel < 0:
        return -1
    cell: int64 = rel / (STATNOT_ICON + STATNOT_PAD)
    if cell < 0 or cell >= STATNOT_CELLS:
        return -1
    return cell


# Left edge X of indicator cell `i` (0..2) inside the status-notifier zone.
def statnot_cell_x(i: int64, scr_w: int64) -> int64:
    return statnot_x0(scr_w) + STATNOT_PAD + i * (STATNOT_ICON + STATNOT_PAD)


# Append NUL-terminated `s` into statnot_buf at `p`; returns the new end.
def _statnot_put(p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0:
        statnot_buf[p + k] = s[k]
        k = k + 1
    statnot_buf[p + k] = 0
    return p + k


# Build the detail line for cell `i` into statnot_buf and return it.
#   battery: "AC power" when no battery surface exists (the truthful VM /
#            desktop state); "Batt NN%" (+ " chg") once a real ACPI
#            battery reader sets STATNOT_BATT_PRESENT.
#   network: "Net up <ip>" / "Net down"   (from the real /net/addr leaf)
#   volume:  "Vol NN%" / "Vol mute" (the REAL mixer value), "Vol n/a"
#            when no audio device exists.
def statnot_detail(i: int64) -> Ptr[uint8]:
    p: uint64 = 0
    if i == 0:
        if STATNOT_BATT_PRESENT == 0:
            p = _statnot_put(0, "AC power")
            return &statnot_buf[0]
        p = _statnot_put(0, "Batt ")
        p = p + u64_to_dec(cast[uint64](STATNOT_BATT), &statnot_buf[p])
        statnot_buf[p] = 37        # '%'
        statnot_buf[p + 1] = 0
        if STATNOT_BATT_CHG != 0:
            p = _statnot_put(p, "% chg")
        return &statnot_buf[0]
    if i == 1:
        if STATNOT_NETUP != 0:
            p = _statnot_put(0, "Net up")
            if STATNOT_IP[0] != 0:
                p = _statnot_put(p, " ")
                p = _statnot_put(p, &STATNOT_IP[0])
        else:
            p = _statnot_put(0, "Net down")
        return &statnot_buf[0]
    # cell 2 = volume
    if STATNOT_AUDIO == 0:
        p = _statnot_put(0, "Vol n/a")
        return &statnot_buf[0]
    if VOL_MUTED != 0:
        p = _statnot_put(0, "Vol mute")
        return &statnot_buf[0]
    p = _statnot_put(0, "Vol ")
    p = p + u64_to_dec(cast[uint64](VOL_LEVEL), &statnot_buf[p])
    statnot_buf[p] = 37            # '%'
    statnot_buf[p + 1] = 0
    return &statnot_buf[0]


# Click handler for the status-notifier zone. Toggles the popup for the
# clicked cell; clicking cell 2 (volume) also pops the volume OSD slider.
def statnot_click(i: int64):
    if i < 0 or i >= STATNOT_CELLS:
        return
    if STATNOT_POPUP == cast[int32](i):
        STATNOT_POPUP = -1
    else:
        STATNOT_POPUP = cast[int32](i)
    sm: Ptr[uint8] = "STATNOT click "
    sys_write(1, sm, strlen_u8(sm))
    write_str(1, statnot_detail(i))
    write_str(1, "\n")
    if i == 2:
        vol_osd_show()


# ---- REAL mixer backend (/dev/audioctl + /dev/audio) ---------------
# The volume cell/OSD mirror the kernel's software mixer, not a local
# variable: every change WRITES a ctl verb to /dev/audioctl and then
# RE-READS /dev/audio's one-line status ("... master <pct> ... mute <m>")
# so VOL_LEVEL/VOL_MUTED are always the mixer's own answer. A VM with no
# HDA device probes STATNOT_AUDIO = 0 and the cell renders greyed.
# Scratch for /dev/audio + /net/addr snapshot reads (the daemon's pumps
# run sequentially, so one shared buffer is safe).
statnot_io_buf: Array[96, uint8]


# Find NUL-terminated `tag` in buf[0..n) and parse the decimal
# immediately after it. Returns the value, or -1 when absent.
def _volhw_parse_after(buf: Ptr[uint8], n: uint64, tag: Ptr[uint8]) -> int64:
    tl: uint64 = strlen_u8(tag)
    if tl == 0 or n < tl:
        return -1
    i: uint64 = 0
    while i + tl <= n:
        j: uint64 = 0
        while j < tl and buf[i + j] == tag[j]:
            j = j + 1
        if j == tl:
            k: uint64 = i + tl
            if k >= n or buf[k] < 48 or buf[k] > 57:
                return -1
            v: int64 = 0
            while k < n and buf[k] >= 48 \
                  and buf[k] <= 57:
                v = v * 10 + cast[int64](buf[k] - 48)
                k = k + 1
            return v
        i = i + 1
    return -1


# Re-read the REAL mixer state from /dev/audio's status line into
# VOL_LEVEL / VOL_MUTED. Sets STATNOT_AUDIO (1 = mixer answered, 0 = no
# audio device on this box). Returns STATNOT_AUDIO.
def vol_hw_sync() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/audio"))
    if fd < 0:
        STATNOT_AUDIO = 0
        return 0
    n: int64 = sys_read(fd, &statnot_io_buf[0], 95)
    sys_close(fd)
    if n <= 0:
        STATNOT_AUDIO = 0
        return 0
    nn: uint64 = cast[uint64](n)
    m: int64 = _volhw_parse_after(&statnot_io_buf[0], nn, "master ")
    if m < 0:
        STATNOT_AUDIO = 0
        return 0
    STATNOT_AUDIO = 1
    VOL_LEVEL = m
    mu: int64 = _volhw_parse_after(&statnot_io_buf[0], nn, "mute ")
    if mu > 0:
        VOL_MUTED = 1
    else:
        VOL_MUTED = 0
    return 1


# Write one NUL-terminated ctl line to /dev/audioctl. Returns 1 on success.
def _volhw_ctl_write(line: Ptr[uint8], n: uint64) -> int32:
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/audioctl"))
    if fd < 0:
        STATNOT_AUDIO = 0
        return 0
    sys_write(fd, line, n)
    sys_close(fd)
    return 1


# Push `pct` to the REAL mixer ("master <pct>") and re-read the status so
# VOL_LEVEL becomes the mixer's answer (not a local echo).
def vol_hw_set(pct: int64):
    pv: int64 = pct
    if pv < 0:
        pv = 0
    if pv > 100:
        pv = 100
    line: Array[16, uint8]
    pfx: Ptr[uint8] = "master "
    p: uint64 = 0
    while pfx[p] != 0:
        line[p] = pfx[p]
        p = p + 1
    p = p + u64_to_dec(cast[uint64](pv), &line[p])
    line[p] = 10
    if _volhw_ctl_write(&line[0], p + 1) != 0:
        vol_hw_sync()


# Latch/unlatch the mixer's master mute and re-read the status.
def vol_hw_mute(m: int32):
    v: Ptr[uint8] = "unmute\n"
    if m != 0:
        v = "mute\n"
    if _volhw_ctl_write(v, strlen_u8(v)) != 0:
        vol_hw_sync()


# Poll the host-level /net/addr leaf ("<a.b.c.d> up|down\n") into
# STATNOT_NETUP / STATNOT_NETSIG / STATNOT_IP. An absent leaf (no `#I`
# bind in this namespace) truthfully reads as link-down, empty IP.
def statnot_net_refresh():
    up: int32 = 0
    iplen: uint64 = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/net/addr"))
    if fd >= 0:
        n: int64 = sys_read(fd, &statnot_io_buf[0], 95)
        sys_close(fd)
        if n > 0:
            nn: uint64 = cast[uint64](n)
            i: uint64 = 0
            while i < nn and statnot_io_buf[i] != 32 \
                  and statnot_io_buf[i] != 10:
                if iplen < 19:
                    STATNOT_IP[iplen] = statnot_io_buf[i]
                    iplen = iplen + 1
                i = i + 1
            # " up" vs " down": the byte after the space decides.
            if i + 1 < nn and statnot_io_buf[i] == 32 \
               and statnot_io_buf[i + 1] == 117:        # 'u'
                up = 1
    if up == 0:
        iplen = 0                       # an all-zero address is not an IP
    STATNOT_IP[iplen] = 0
    STATNOT_NETUP = up
    # Wired/virtio link: no RF signal-strength concept — full bars when
    # the host has an address, none when it does not.
    if up != 0:
        STATNOT_NETSIG = 4
    else:
        STATNOT_NETSIG = 0


# One-time startup probe of the real applet backends (mixer + /net/addr).
def statnot_backend_init():
    vol_hw_sync()
    statnot_net_refresh()
    STATNOT_NET_JIFFY = sys_get_jiffies()


# ---- Volume / brightness OSD slider --------------------------------
# Nudge the volume by `delta` (clamped 0..100), unmute on a positive bump,
# arm the centred slider OSD, and announce. When the real mixer is live
# the new level is round-tripped through /dev/audioctl + /dev/audio, so
# the returned/displayed value is the MIXER's, not the local echo.
def vol_step(delta: int64) -> int64:
    nv: int64 = VOL_LEVEL + delta
    if nv < 0:
        nv = 0
    if nv > 100:
        nv = 100
    VOL_LEVEL = nv
    if delta > 0:
        VOL_MUTED = 0
    if STATNOT_AUDIO == 1:
        if delta > 0:
            vol_hw_mute(0)              # a positive bump unmutes for real
        vol_hw_set(nv)                  # ends in vol_hw_sync -> mixer truth
    vol_osd_show()
    vm: Ptr[uint8] = "VOL level "
    sys_write(1, vm, strlen_u8(vm))
    vb: Array[8, uint8]
    n: uint64 = u64_to_dec(cast[uint64](VOL_LEVEL), &vb[0])
    vb[n] = 10
    sys_write(1, &vb[0], n + 1)
    return VOL_LEVEL


# Toggle mute. Arms the OSD so the slider reflects the muted state. With
# a live mixer the latch is written to /dev/audioctl ("mute"/"unmute")
# and read back, so VOL_MUTED is the mixer's latch.
def vol_mute_toggle() -> int32:
    if VOL_MUTED != 0:
        VOL_MUTED = 0
    else:
        VOL_MUTED = 1
    if STATNOT_AUDIO == 1:
        vol_hw_mute(VOL_MUTED)
    vol_osd_show()
    mm: Ptr[uint8] = "VOL mute toggle\n"
    sys_write(1, mm, strlen_u8(mm))
    return VOL_MUTED


# Nudge brightness by `delta` (clamped 0..100) and arm the OSD. Returns it.
def bri_step(delta: int64) -> int64:
    nb: int64 = BRI_LEVEL + delta
    if nb < 0:
        nb = 0
    if nb > 100:
        nb = 100
    BRI_LEVEL = nb
    OSD_KIND = 2
    OSD_TTL = OSD_TTL_MAX
    bm: Ptr[uint8] = "BRI level "
    sys_write(1, bm, strlen_u8(bm))
    bb: Array[8, uint8]
    n: uint64 = u64_to_dec(cast[uint64](BRI_LEVEL), &bb[0])
    bb[n] = 10
    sys_write(1, &bb[0], n + 1)
    return BRI_LEVEL


# Arm the centred slider OSD for the volume model.
def vol_osd_show():
    OSD_KIND = 1
    OSD_TTL = OSD_TTL_MAX


# Current OSD slider model value (0..100) for whichever kind is armed, or
# -1 when the OSD is showing the workspace indicator (kind 0).
def osd_slider_value() -> int64:
    if OSD_KIND == 1:
        if VOL_MUTED != 0:
            return 0
        return VOL_LEVEL
    if OSD_KIND == 2:
        return BRI_LEVEL
    return -1


# X of the filled portion's right edge for a 0..100 value across the track.
# The track starts OSD_x0 + (OSD_W-OSD_SLIDER_W)/2; fill width is value%.
def osd_slider_fill_x(scr_w: int64) -> int64:
    v: int64 = osd_slider_value()
    if v < 0:
        v = 0
    tx0: int64 = osd_x0(scr_w) + (OSD_W - OSD_SLIDER_W) / 2
    return tx0 + (OSD_SLIDER_W * v) / 100


# ---- Window-Selector panel applet ----------------------------------
# A classic GNOME2 "Window Selector": a panel dropdown that lists EVERY
# managed window across ALL workspaces (a flat MRU-ordered roster). Each
# row shows the window title; clicking it activates that window. It is
# anchored under a small panel button left of the status-notifier zone.
WINSEL_OPEN: int32 = 0
WINSEL_W:    int64 = 240          # dropdown width
WINSEL_ROW_H: int64 = 20          # per-window row height
WINSEL_BTN_W: int64 = 18          # panel button width


# Number of rows the window-selector lists = every managed window.
def winsel_count() -> uint64:
    return DWIN_COUNT


# Total pixel height of the open dropdown: a header row + one row per
# window (at least one empty-state row).
def winsel_total_h() -> int64:
    n: int64 = cast[int64](winsel_count())
    if n == 0:
        n = 1
    return WINSEL_ROW_H + n * WINSEL_ROW_H


# X of the window-selector panel button (left of the status-notifier zone).
def winsel_btn_x(scr_w: int64) -> int64:
    return statnot_x0(scr_w) - WINSEL_BTN_W - 4


# X of the dropdown's left edge, clamped on-screen.
def winsel_x0(scr_w: int64) -> int64:
    x: int64 = winsel_btn_x(scr_w) - (WINSEL_W - WINSEL_BTN_W)
    if x < 2:
        x = 2
    return x


# 1 if (px,py) lands on the window-selector panel button.
def in_winsel_btn(px: int64, py: int64, scr_w: int64) -> int32:
    if on_panel_y(py) == 0:
        return 0
    bx: int64 = winsel_btn_x(scr_w)
    if px >= bx and px < bx + WINSEL_BTN_W:
        return 1
    return 0


# Window slot listed at dropdown row `r` (0-based, below the header), or
# -1. The roster is the raw slot order (front-most last), which matches
# the taskbar's ordering so the lists feel consistent.
def winsel_row_slot(r: int64) -> int64:
    if r < 0 or r >= cast[int64](winsel_count()):
        return -1
    return r


# Hit-test: window slot under (px,py) while the dropdown is open, or -1
# (the header row and gaps return -1). Works for both panel positions
# because drop_anchor_y already accounts for the edge.
def winsel_slot_at(px: int64, py: int64, scr_w: int64) -> int64:
    if WINSEL_OPEN == 0:
        return -1
    x0: int64 = winsel_x0(scr_w)
    if px < x0 or px >= x0 + WINSEL_W:
        return -1
    th: int64 = winsel_total_h()
    y0: int64 = drop_anchor_y(th)
    # row 0 is the header band.
    body_y: int64 = py - y0 - WINSEL_ROW_H
    if body_y < 0:
        return -1
    r: int64 = body_y / WINSEL_ROW_H
    return winsel_row_slot(r)


# Activate window `slot`: unhide it, switch to its workspace, raise it,
# and close the dropdown. Returns the (post-raise) front slot or -1.
def winsel_activate(slot: int64) -> int64:
    if slot < 0 or cast[uint64](slot) >= DWIN_COUNT:
        return -1
    s: uint64 = cast[uint64](slot)
    DWIN_HIDDEN[s] = 0
    tws: int32 = DWIN_WS[s]
    if tws != CUR_WS:
        workspace_switch(tws)
    front: int64 = daemon_raise_slot(slot)
    WINSEL_OPEN = 0
    am: Ptr[uint8] = "WINSEL activate "
    sys_write(1, am, strlen_u8(am))
    write_str(1, window_title(cast[uint64](front)))
    write_str(1, "\n")
    return front


# Toggle the window-selector dropdown open/closed.
def winsel_toggle():
    if WINSEL_OPEN != 0:
        WINSEL_OPEN = 0
    else:
        WINSEL_OPEN = 1
        # Opening the selector closes other panel drops to avoid overlap.
        MENU_OPEN = 0
        MENU_BAR_OPEN = -1
        CAL_OPEN = 0
        TRAY_OPEN = 0
    wm: Ptr[uint8] = "WINSEL toggle\n"
    sys_write(1, wm, strlen_u8(wm))


# ---- Workspace-name editing + OSD ----------------------------------
# Each of the up-to-WS_MAX desktops carries an editable name (default
# "Workspace N"). ws_name() returns the name for desktop `w`; ws_name_set()
# rewrites it (truncated to the cell cap) and pops a transient OSD.
WS_NAME_CAP: int64 = 16
ws_names: Array[128, uint8]        # WS_MAX * WS_NAME_CAP = 8 * 16 = 128
WS_NAMES_INIT: int32 = 0
# Workspace-name OSD: when WSNAME_OSD_TTL > 0 a transient "Renamed: <name>"
# popup paints (reuses the OSD slab geometry, distinct from OSD_KIND).
WSNAME_OSD_TTL: int32 = 0
WSNAME_OSD_WS:  int32 = 0
wsname_osd_buf: Array[32, uint8]


# Seed every desktop's default name ("Workspace 1".."Workspace N") once.
def ws_names_init():
    if WS_NAMES_INIT != 0:
        return
    w: int64 = 0
    while w < cast[int64](WS_MAX):
        base: int64 = w * WS_NAME_CAP
        ws_names[base + 0] = 87        # 'W'
        ws_names[base + 1] = 111       # 'o'
        ws_names[base + 2] = 114       # 'r'
        ws_names[base + 3] = 107       # 'k'
        ws_names[base + 4] = 115       # 's'
        ws_names[base + 5] = 112       # 'p'
        ws_names[base + 6] = 97        # 'a'
        ws_names[base + 7] = 99        # 'c'
        ws_names[base + 8] = 101       # 'e'
        ws_names[base + 9] = 32        # ' '
        ws_names[base + 10] = cast[uint8](w + 1) + 48
        ws_names[base + 11] = 0
        w = w + 1
    WS_NAMES_INIT = 1


# Name of desktop `w` (0-based). Always NUL-terminated.
def ws_name(w: int32) -> Ptr[uint8]:
    ws_names_init()
    if w < 0 or w >= WS_MAX:
        w = 0
    return &ws_names[cast[int64](w) * WS_NAME_CAP]


# Rename desktop `w` to `name` (truncated to WS_NAME_CAP-1) and pop the OSD.
def ws_name_set(w: int32, name: Ptr[uint8]):
    ws_names_init()
    if w < 0 or w >= WS_MAX:
        return
    str_copy_cap(&ws_names[cast[int64](w) * WS_NAME_CAP], name, cast[uint64](WS_NAME_CAP))
    ws_name_osd(w)
    nm: Ptr[uint8] = "WSNAME set "
    sys_write(1, nm, strlen_u8(nm))
    write_str(1, ws_name(w))
    write_str(1, "\n")


# Arm the transient workspace-name OSD for desktop `w`.
def ws_name_osd(w: int32):
    WSNAME_OSD_WS = w
    WSNAME_OSD_TTL = OSD_TTL_MAX


# 1 while the workspace-name OSD is visible.
def ws_name_osd_active() -> int32:
    if WSNAME_OSD_TTL > 0:
        return 1
    return 0


# Tick the workspace-name OSD once per present.
def ws_name_osd_step() -> int32:
    if WSNAME_OSD_TTL > 0:
        WSNAME_OSD_TTL = WSNAME_OSD_TTL - 1
    return ws_name_osd_active()


# ====================================================================
# ROUND-18: session countdown + lock password, Super+N workspace grid,
#           recent/favorites Applications model, notification rules,
#           clock format settings
# ====================================================================

# --- Session-dialog logout/shutdown COUNTDOWN -----------------------
# MATE/gnome-session, when you pick Log Out or Shut Down, shows a 60-second
# countdown that auto-confirms when it reaches 0 (or you can confirm/cancel
# immediately). We model the countdown as a tick-down counter armed by
# session_arm_countdown(); session_countdown_tick() decrements it once per
# present and auto-invokes the pending intent at 0. SESSION_PENDING holds
# which row's action is being counted down (1=logout, 2=shutdown).
SESSION_COUNTDOWN: int32 = 0            # seconds remaining, 0 = inactive
SESSION_PENDING:   int32 = 0            # 1 = logout, 2 = shutdown
SESSION_COUNTDOWN_MAX: int32 = 60      # MATE's default 60s auto-confirm


# Arm the countdown for a pending logout (1) or shutdown (2). Resets the
# clock to the full window. Keeps the session dialog modal so the user can
# still cancel or confirm immediately.
def session_arm_countdown(intent: int32):
    if intent != 1 and intent != 2:
        return
    SESSION_PENDING = intent
    SESSION_COUNTDOWN = SESSION_COUNTDOWN_MAX
    pfx: Ptr[uint8] = "SESSION countdown arm "
    sys_write(1, pfx, strlen_u8(pfx))
    nb: Array[4, uint8]
    nb[0] = cast[uint8](intent) + 48
    nb[1] = 10
    sys_write(1, &nb[0], 2)


# Tick the countdown one second. When it reaches 0 the pending intent is
# committed (sets SESSION_INTENT + DAEMON_QUIT, exactly like a manual
# confirm). Returns the seconds remaining (0 once it has fired or is idle).
def session_countdown_tick() -> int32:
    if SESSION_COUNTDOWN <= 0:
        return 0
    SESSION_COUNTDOWN = SESSION_COUNTDOWN - 1
    if SESSION_COUNTDOWN <= 0:
        # Auto-confirm the pending action.
        intent: int32 = SESSION_PENDING
        SESSION_PENDING = 0
        SESSION_OPEN = 0
        SESSION_INTENT = intent
        DAEMON_QUIT = 1
        fp: Ptr[uint8] = "SESSION countdown fire\n"
        sys_write(1, fp, strlen_u8(fp))
    return SESSION_COUNTDOWN


# Cancel a running countdown WITHOUT firing (the Cancel button / Escape).
def session_cancel_countdown():
    SESSION_COUNTDOWN = 0
    SESSION_PENDING = 0


# --- Lock-screen PASSWORD model -------------------------------------
# Round 8's lock screen unlocked on any click. Round 18 models a real
# password prompt: the lock overlay collects typed characters into
# lock_pw_buf and only unlocks when the entry matches the stored unlock
# secret. A wrong entry bumps a failure counter and clears the field. The
# stored secret is a session value (no on-disk store yet) seeded by
# lock_set_password(); the default is "hamnix".
LOCK_PW_CAP: int64 = 32
lock_pw_buf:     Array[32, uint8]      # what the user has typed
lock_pw_secret:  Array[32, uint8]      # the unlock secret
LOCK_PW_LEN:     int64 = 0
LOCK_SECRET_SET: int32 = 0
LOCK_FAILS:      int32 = 0             # consecutive wrong attempts


# Seed the unlock secret (defaults to "hamnix" if never set). Idempotent.
def lock_secret_init():
    if LOCK_SECRET_SET != 0:
        return
    def_s: Ptr[uint8] = "hamnix"
    str_copy_cap(&lock_pw_secret[0], def_s, cast[uint64](LOCK_PW_CAP))
    LOCK_SECRET_SET = 1


# Change the unlock secret (Control Center / passwd). Truncates to the cap.
def lock_set_password(pw: Ptr[uint8]):
    str_copy_cap(&lock_pw_secret[0], pw, cast[uint64](LOCK_PW_CAP))
    LOCK_SECRET_SET = 1


# Clear the typed lock entry (called on lock, on a failed attempt, etc.).
def lock_pw_clear():
    LOCK_PW_LEN = 0
    lock_pw_buf[0] = 0


# Append one printable byte to the lock entry (capped). No echo of the
# byte itself — callers paint mask dots from LOCK_PW_LEN.
def lock_pw_push(c: uint8):
    if LOCK_PW_LEN >= LOCK_PW_CAP - 1:
        return
    lock_pw_buf[LOCK_PW_LEN] = c
    LOCK_PW_LEN = LOCK_PW_LEN + 1
    lock_pw_buf[LOCK_PW_LEN] = 0


# Delete the last typed byte (Backspace) from the lock entry.
def lock_pw_backspace():
    if LOCK_PW_LEN <= 0:
        return
    LOCK_PW_LEN = LOCK_PW_LEN - 1
    lock_pw_buf[LOCK_PW_LEN] = 0


# Attempt an unlock with the current entry. On match: unlock, clear the
# field, reset the failure counter, return 1. On mismatch: bump fails,
# clear the field, stay locked, return 0.
def lock_pw_try() -> int32:
    lock_secret_init()
    if cstr_eq(&lock_pw_buf[0], &lock_pw_secret[0]) != 0:
        LOCKED = 0
        LOCK_FAILS = 0
        lock_pw_clear()
        ok: Ptr[uint8] = "SESSION unlock ok\n"
        sys_write(1, ok, strlen_u8(ok))
        return 1
    LOCK_FAILS = LOCK_FAILS + 1
    lock_pw_clear()
    bad: Ptr[uint8] = "SESSION unlock fail\n"
    sys_write(1, bad, strlen_u8(bad))
    return 0


# --- Super+N workspace KEYBOARD GRID + move-to-workspace ------------
# MATE binds Super+1..N to "jump to workspace N" and Super+Shift+1..N to
# "move the active window to workspace N (and follow it)". n is 1-based as
# typed by the user. Returns the destination workspace (0-based) or -1 if
# the index is out of the current WS_COUNT range.
def workspace_goto_n(n: int32) -> int32:
    ws: int32 = n - 1
    if ws < 0 or ws >= WS_COUNT:
        return -1
    workspace_switch(ws)
    return ws


# Move the focused window to workspace n (1-based) and follow it there,
# like Super+Shift+N. Returns the destination workspace or -1.
def window_to_workspace_n(n: int32) -> int32:
    ws: int32 = n - 1
    if ws < 0 or ws >= WS_COUNT:
        return -1
    slot: int64 = daemon_focus_slot()
    if slot < 0:
        return -1
    window_to_workspace(cast[uint64](slot), ws)
    workspace_switch(ws)
    return ws


# --- Applications RECENT + FAVORITES launch-frequency model ---------
# The Applications menu grows two top sections, exactly like MATE's
# mate-menu / classic GNOME2 favorites: a "Recently Used" list (the last
# few launched entries, most-recent first) and a "Favorites" list (the
# most-frequently launched entries). Both are derived from a per-entry
# launch counter + a recency stamp; no extra UI state, just two ordering
# views over MENU_COUNT flat entries.
app_launch_count: Array[16, int32]     # >= MENU_COUNT launch tallies
app_launch_stamp: Array[16, int32]     # monotonic recency stamp per entry
APP_LAUNCH_CLOCK: int32 = 0            # monotonic tick bumped per launch
RECENT_MAX: int64 = 4                  # rows shown in Recently Used
FAV_MAX:    int64 = 4                  # rows shown in Favorites


# Reset the whole launch-frequency model (used by the self-test + a fresh
# session). Zeroes every tally and stamp.
def app_freq_reset():
    i: int64 = 0
    while i < 16:
        app_launch_count[i] = 0
        app_launch_stamp[i] = 0
        i = i + 1
    APP_LAUNCH_CLOCK = 0


# Record a launch of flat entry `i`: bump its tally and stamp it as the
# most-recently used. Called from the launch path so every menu/Run/taskbar
# launch feeds the model.
def app_freq_record(i: uint64):
    if i >= MENU_COUNT:
        return
    app_launch_count[i] = app_launch_count[i] + 1
    APP_LAUNCH_CLOCK = APP_LAUNCH_CLOCK + 1
    app_launch_stamp[i] = APP_LAUNCH_CLOCK


# Number of entries that have ever been launched (count > 0).
def app_freq_used_count() -> int64:
    n: int64 = 0
    i: uint64 = 0
    while i < MENU_COUNT:
        if app_launch_count[i] > 0:
            n = n + 1
        i = i + 1
    return n


# The flat entry index of the `rank`-th most-RECENTLY-used entry (rank 0 =
# newest). Returns -1 if there are fewer than rank+1 used entries. O(n^2)
# selection over the small MENU_COUNT table — no allocation.
def app_recent_index(rank: int64) -> int64:
    seen_stamp: int32 = 2147483647     # upper bound for "strictly newer than"
    r: int64 = 0
    while r <= rank:
        best: int64 = -1
        best_stamp: int32 = -1
        i: uint64 = 0
        while i < MENU_COUNT:
            st: int32 = app_launch_stamp[i]
            if app_launch_count[i] > 0 and st < seen_stamp and st > best_stamp:
                best = cast[int64](i)
                best_stamp = st
            i = i + 1
        if best < 0:
            return -1
        if r == rank:
            return best
        seen_stamp = best_stamp
        r = r + 1
    return -1


# The flat entry index of the `rank`-th most-FREQUENTLY-launched entry
# (rank 0 = highest count). Ties broken by the more-recent stamp so the
# order is deterministic. Returns -1 past the end of used entries.
def app_favorite_index(rank: int64) -> int64:
    prev_count: int32 = 2147483647
    prev_stamp: int32 = 2147483647
    r: int64 = 0
    while r <= rank:
        best: int64 = -1
        best_count: int32 = -1
        best_stamp: int32 = -1
        i: uint64 = 0
        while i < MENU_COUNT:
            c: int32 = app_launch_count[i]
            st: int32 = app_launch_stamp[i]
            # Strictly "after" the previously chosen (count,stamp) pair in the
            # descending (count, stamp) ordering, and better than best-so-far.
            after_prev: int32 = 0
            if c < prev_count:
                after_prev = 1
            elif c == prev_count and st < prev_stamp:
                after_prev = 1
            better: int32 = 0
            if c > best_count:
                better = 1
            elif c == best_count and st > best_stamp:
                better = 1
            if c > 0 and after_prev != 0 and better != 0:
                best = cast[int64](i)
                best_count = c
                best_stamp = st
            i = i + 1
        if best < 0:
            return -1
        if r == rank:
            return best
        prev_count = best_count
        prev_stamp = best_stamp
        r = r + 1
    return -1


# --- NOTIFICATION RULES: do-not-disturb, per-urgency, expiry --------
# MATE's notification daemon honours a "Do Not Disturb" toggle (queues
# nothing while on), urgency levels (low/normal/critical) that pick a
# border accent + a per-urgency default expiry, and an expiry timer that
# fades a notice after its timeout. We add an urgency to the existing
# transient-banner model and a DND gate on the post path.
NOTIF_DND: int32 = 0                   # 1 = Do Not Disturb (suppress banners)
NOTIF_URGENCY: int32 = 1               # urgency of the live banner (0/1/2)
NOTIF_LOW:      int32 = 0
NOTIF_NORMAL:   int32 = 1
NOTIF_CRITICAL: int32 = 2
# Per-urgency banner lifetime in frames (low fades fast, critical persists).
NOTIF_TTL_LOW:      int64 = 90
NOTIF_TTL_NORMAL:   int64 = 180
NOTIF_TTL_CRITICAL: int64 = 360


# Toggle Do Not Disturb. Returns the new state. While on, notify_rule_post
# suppresses banners (but critical notices always break through, as in MATE).
def notif_dnd_toggle() -> int32:
    if NOTIF_DND == 0:
        NOTIF_DND = 1
    else:
        NOTIF_DND = 0
    pfx: Ptr[uint8] = "NOTIF dnd "
    sys_write(1, pfx, strlen_u8(pfx))
    db: Array[2, uint8]
    db[0] = cast[uint8](NOTIF_DND) + 48
    db[1] = 10
    sys_write(1, &db[0], 2)
    return NOTIF_DND


# Default expiry (frames) for an urgency level.
def notif_ttl_for(urg: int32) -> int64:
    if urg == NOTIF_LOW:
        return NOTIF_TTL_LOW
    if urg == NOTIF_CRITICAL:
        return NOTIF_TTL_CRITICAL
    return NOTIF_TTL_NORMAL


# Border accent (R,G,B packed view) for an urgency: low = grey, normal =
# blue (the existing accent), critical = red. Returned componentwise via
# the three notif_urg_* helpers so callers stay scalar.
def notif_urg_r(urg: int32) -> uint8:
    if urg == NOTIF_LOW:
        return 130
    if urg == NOTIF_CRITICAL:
        return 220
    return NOTIFY_BORDER_R


def notif_urg_g(urg: int32) -> uint8:
    if urg == NOTIF_LOW:
        return 130
    if urg == NOTIF_CRITICAL:
        return 70
    return NOTIFY_BORDER_G


def notif_urg_b(urg: int32) -> uint8:
    if urg == NOTIF_LOW:
        return 130
    if urg == NOTIF_CRITICAL:
        return 70
    return NOTIFY_BORDER_B


# Post a notification WITH an urgency, honouring the DND gate + per-urgency
# expiry. Returns 1 if the banner was shown, 0 if DND suppressed it. A
# critical notice always shows regardless of DND. The history ring is fed
# even when the banner is suppressed (MATE still records suppressed notices).
def notif_rule_post(title: Ptr[uint8], body: Ptr[uint8], urg: int32) -> int32:
    u: int32 = urg
    if u < NOTIF_LOW:
        u = NOTIF_LOW
    if u > NOTIF_CRITICAL:
        u = NOTIF_CRITICAL
    # DND suppresses everything except critical.
    if NOTIF_DND != 0 and u != NOTIF_CRITICAL:
        nhist_push(title, body)
        sp: Ptr[uint8] = "NOTIF suppressed "
        sys_write(1, sp, strlen_u8(sp))
        write_str(1, title)
        write_str(1, "\n")
        return 0
    NOTIF_URGENCY = u
    str_copy_cap(&notify_title[0], title, 40)
    str_copy_cap(&notify_body[0], body, 64)
    NOTIFY_ACTIVE = 1
    NOTIFY_AGE = 0
    # Per-urgency expiry: the banner stays solid until NOTIFY_TTL then fades.
    NOTIFY_TTL = notif_ttl_for(u)
    nhist_push(title, body)
    pfx: Ptr[uint8] = "NOTIF post "
    sys_write(1, pfx, strlen_u8(pfx))
    write_str(1, title)
    write_str(1, "\n")
    return 1


# --- CLOCK FORMAT SETTING: 12h/24h, seconds, date -------------------
# MATE's clock applet preferences toggle 12/24-hour display, show-seconds,
# and show-date. We add the three settings + a formatter that builds the
# panel clock string from a fixed (hh,mm,ss) so the layout is testable
# without a live RTC. CLOCK_24H 1 = 24-hour (default), 0 = 12-hour AM/PM.
CLOCK_24H:       int32 = 1
CLOCK_SHOW_SEC:  int32 = 0
CLOCK_SHOW_DATE: int32 = 0
clock_fmt_buf: Array[40, uint8]        # formatted "HH:MM[:SS][ AM/PM][ Mon DD]"


# Append two zero-padded decimal digits of `v` (0..99) at clock_fmt_buf[idx];
# return the next write index.
def clock_fmt_2d(idx: int64, v: int64) -> int64:
    clock_fmt_buf[idx] = cast[uint8](v / 10) + 48
    clock_fmt_buf[idx + 1] = cast[uint8](v % 10) + 48
    return idx + 2


# Build the panel clock string from (hh,mm,ss) per the format settings.
# Returns the byte length written (NUL-terminated). Pure formatter — no RTC
# read — so a self-test can assert exact strings for every toggle combo.
def clock_format(hh: int64, mm: int64, ss: int64) -> int64:
    idx: int64 = 0
    disp_h: int64 = hh
    is_pm: int32 = 0
    if CLOCK_24H == 0:
        if hh >= 12:
            is_pm = 1
        disp_h = hh % 12
        if disp_h == 0:
            disp_h = 12
    idx = clock_fmt_2d(idx, disp_h)
    clock_fmt_buf[idx] = 58            # ':'
    idx = idx + 1
    idx = clock_fmt_2d(idx, mm)
    if CLOCK_SHOW_SEC != 0:
        clock_fmt_buf[idx] = 58        # ':'
        idx = idx + 1
        idx = clock_fmt_2d(idx, ss)
    if CLOCK_24H == 0:
        clock_fmt_buf[idx] = 32        # ' '
        idx = idx + 1
        if is_pm != 0:
            clock_fmt_buf[idx] = 80    # 'P'
        else:
            clock_fmt_buf[idx] = 65    # 'A'
        clock_fmt_buf[idx + 1] = 77    # 'M'
        idx = idx + 2
    if CLOCK_SHOW_DATE != 0:
        # Append " " + the live date prefix (clock_date_str "YYYY-MM-DD..").
        clock_fmt_buf[idx] = 32        # ' '
        idx = idx + 1
        d: int64 = 0
        while d < 10 and clock_date_str[d] != 0:
            clock_fmt_buf[idx] = clock_date_str[d]
            idx = idx + 1
            d = d + 1
    clock_fmt_buf[idx] = 0
    return idx


# ====================================================================
# ROUND-16 MATE-feel self-test (autoflag == 26)
# ====================================================================
# Exercises the round-16 Control Center / theme engine with no QEMU mouse
# injection:
#   1. THEME ENGINE: scheme_set() actually mutates the LIVE chrome colour
#      globals the renderer reads (PANEL_*, MENU_*, ROOT_*) to concrete
#      expected values for each built-in scheme; scheme_cycle() wraps;
#      asserted for BOTH panel positions so earlier rounds don't regress.
#   2. CONTROL CENTER window: APP_CTRLCENTER spawns with the expected title,
#      sidebar categories hit-test, the right-pane control rows hit-test,
#      and cc_click drives both category selection and a live setting.
#   3. UI SCALE toggle: ui_scale_toggle() flips 1<->2 and ui_scaled()
#      stretches the row pitch.
#   4. FOCUS MODEL honoured: the Windows category toggles FOCUS_MODE which
#      focus_follow_step already consults.
#   5. KEYBOARD-shortcut viewer: every registered chord/action is non-empty.
# Emits "[DE16] PASS" / "[DE16] FAIL <reason>".
def daemon_round16_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PANEL_POS = 0
    PREV_BTN_L = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    THEME_IDX = 0
    BG_IDX = 0
    UI_SCALE = 1
    FOCUS_MODE = 0
    SCHEME_IDX = 0
    scheme_palette_init()

    # --- Step 1: theme engine recolours the LIVE chrome, both panel pos ---
    pp: int32 = 0
    while pp <= 1:
        PANEL_POS = pp
        # Clearlooks (scheme 0): the light default palette.
        scheme_set(0)
        if PANEL_R != 46 or PANEL_G != 52 or PANEL_B != 64:
            write_str(1, "[DE16] FAIL scheme0 panel colour wrong\n")
            return
        if MENU_R != 56 or MENU_G != 62 or MENU_B != 78:
            write_str(1, "[DE16] FAIL scheme0 menu colour wrong\n")
            return
        if ROOT_R != 32 or ROOT_G != 48 or ROOT_B != 72:
            write_str(1, "[DE16] FAIL scheme0 root colour wrong\n")
            return
        if ACCENT_TOP_R != 120 or ACCENT_TOP_G != 178 or ACCENT_TOP_B != 252:
            write_str(1, "[DE16] FAIL scheme0 accent bias wrong\n")
            return
        # Dark (scheme 1): the dark slate palette recolours everything.
        scheme_set(1)
        if PANEL_R != 28 or PANEL_G != 30 or PANEL_B != 34:
            write_str(1, "[DE16] FAIL scheme1 panel colour wrong\n")
            return
        if MENU_TXT_R != 208 or ROOT_R != 18:
            write_str(1, "[DE16] FAIL scheme1 ink/root wrong\n")
            return
        # HighContrast (scheme 2): black panel, white ink, yellow accent.
        scheme_set(2)
        if PANEL_R != 0 or PANEL_G != 0 or PANEL_B != 0:
            write_str(1, "[DE16] FAIL scheme2 panel not black\n")
            return
        if PANEL_TXT_R != 255 or MENU_TXT_R != 255:
            write_str(1, "[DE16] FAIL scheme2 ink not white\n")
            return
        if ACCENT_TOP_R != 255 or ACCENT_TOP_G != 255 or ACCENT_TOP_B != 0:
            write_str(1, "[DE16] FAIL scheme2 accent not yellow\n")
            return
        # Cycle wraps back to 0 after the last scheme.
        scheme_cycle()
        if SCHEME_IDX != 0:
            write_str(1, "[DE16] FAIL scheme_cycle did not wrap\n")
            return
        if PANEL_R != 46:
            write_str(1, "[DE16] FAIL wrap did not restore Clearlooks\n")
            return
        pp = pp + 1
    PANEL_POS = 0

    # --- Step 2: Control Center window spawns + hit-tests ---
    scheme_set(0)
    daemon_spawn_app(APP_CTRLCENTER, 100, PANEL_H + 30, 460, 300)
    if DWIN_COUNT == 0:
        write_str(1, "[DE16] FAIL Control Center did not spawn\n")
        return
    cc: uint64 = DWIN_COUNT - 1
    if DWIN_APP[cc] != APP_CTRLCENTER:
        write_str(1, "[DE16] FAIL spawned window is not Control Center\n")
        return
    if cstr_eq(window_title(cc), "Control Center") == 0:
        write_str(1, "[DE16] FAIL Control Center title wrong\n")
        return
    if CC_CAT[cc] != 0:
        write_str(1, "[DE16] FAIL Control Center default category not 0\n")
        return
    # Sidebar hit-test: clicking category 2 (Windows) selects it.
    s2y: int64 = cc_side_row_y(cc, 2) + 4
    s2x: int64 = DWIN_X[cc] + 12
    if cc_side_at(cc, s2x, s2y) != 2:
        write_str(1, "[DE16] FAIL sidebar hit-test for Windows wrong\n")
        return
    cc_click(cc, s2x, s2y, scr_w, scr_h)
    if CC_CAT[cc] != 2:
        write_str(1, "[DE16] FAIL category click did not select Windows\n")
        return
    # Windows category row 0 = Focus Model; clicking it flips FOCUS_MODE.
    fm0: int32 = FOCUS_MODE
    r0y: int64 = cc_row_y(cc, 0) + 2
    r0x: int64 = DWIN_X[cc] + CC_SIDE_W + 16
    if cc_row_at(cc, r0x, r0y) != 0:
        write_str(1, "[DE16] FAIL Windows focus-row hit-test wrong\n")
        return
    cc_click(cc, r0x, r0y, scr_w, scr_h)
    if FOCUS_MODE == fm0:
        write_str(1, "[DE16] FAIL focus-model click did not toggle FOCUS_MODE\n")
        return
    if FOCUS_MODE != 1:
        write_str(1, "[DE16] FAIL focus-model not follows-mouse\n")
        return
    # Appearance category row 0 = Colour Scheme; click recolours live chrome.
    CC_CAT[cc] = 0
    SCHEME_IDX = 0
    scheme_apply()
    pr0: uint8 = PANEL_R
    a0x: int64 = DWIN_X[cc] + CC_SIDE_W + 16
    a0y: int64 = cc_row_y(cc, 0) + 2
    if cc_row_at(cc, a0x, a0y) != 0:
        write_str(1, "[DE16] FAIL Appearance scheme-row hit-test wrong\n")
        return
    cc_click(cc, a0x, a0y, scr_w, scr_h)
    if SCHEME_IDX != 1 or PANEL_R == pr0:
        write_str(1, "[DE16] FAIL scheme row click did not recolour panel\n")
        return

    # --- Step 3: UI scale toggle stretches the row pitch ---
    UI_SCALE = 1
    base_pitch: int64 = ui_scaled(CC_ROW_H)
    ui_scale_toggle()
    if UI_SCALE != 2:
        write_str(1, "[DE16] FAIL ui_scale_toggle did not reach 2x\n")
        return
    if ui_scaled(CC_ROW_H) != base_pitch * 2:
        write_str(1, "[DE16] FAIL ui_scaled did not double at 2x\n")
        return
    ui_scale_toggle()
    if UI_SCALE != 1:
        write_str(1, "[DE16] FAIL ui_scale_toggle did not return to 1x\n")
        return

    # --- Step 4: keyboard-shortcut registry fully populated ---
    ki: int64 = 0
    while ki < KBD_SHORTCUT_COUNT:
        if strlen_u8(kbd_shortcut_chord(ki)) == 0:
            write_str(1, "[DE16] FAIL empty shortcut chord\n")
            return
        if strlen_u8(kbd_shortcut_action(ki)) == 0:
            write_str(1, "[DE16] FAIL empty shortcut action\n")
            return
        ki = ki + 1

    # --- Reset to defaults so the test leaves a clean desktop ---
    SCHEME_IDX = 0
    scheme_set(0)
    THEME_IDX = 0
    theme_apply()
    BG_IDX = 0
    bg_palette_init()
    ROOT_R = bg_palette[0]
    ROOT_G = bg_palette[1]
    ROOT_B = bg_palette[2]
    UI_SCALE = 1
    FOCUS_MODE = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE16] PASS\n")


# ====================================================================
# ROUND-17 MATE-feel self-test (autoflag == 27)
# ====================================================================
# Exercises the round-17 panel applets with no QEMU mouse injection:
#   1. STATUS-NOTIFIER AREA: the three indicator cells hit-test inside the
#      zone for BOTH panel positions, each detail line is non-empty and
#      reflects its model, and statnot_click toggles the popup.
#   2. VOLUME / BRIGHTNESS OSD: vol_step/bri_step clamp 0..100, arm the OSD
#      with the right kind, mute toggles, and the slider-fill geometry
#      tracks the value (asserted for both panel positions via osd_x0,
#      which is centred and thus position-independent — but the OSD vertical
#      band osd_y0 DOES move with the panel, asserted here).
#   3. WINDOW-SELECTOR APPLET: lists every window across all workspaces, a
#      row hit-test resolves to the right slot for both panel positions, and
#      winsel_activate unhides + switches workspace + raises the window.
#   4. WORKSPACE-NAME editing: default names seed correctly, ws_name_set
#      rewrites + truncates a name and pops the name OSD that ticks down.
# Emits "[DE17] PASS" / "[DE17] FAIL <reason>".
def daemon_round17_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    PANEL_POS = 0
    STATNOT_POPUP = -1
    WINSEL_OPEN = 0
    OSD_KIND = 0
    OSD_TTL = 0
    WSNAME_OSD_TTL = 0
    VOL_LEVEL = 65
    VOL_MUTED = 0
    BRI_LEVEL = 80
    WS_NAMES_INIT = 0
    # Pin the status-notifier backends to a deterministic LOCAL model:
    # this selftest exercises the applet model/geometry, not the kernel
    # mixer/network round-trips (autoflag 52 covers the real mixer).
    STATNOT_AUDIO = 0
    STATNOT_BATT_PRESENT = 0
    STATNOT_IP[0] = 0
    scheme_palette_init()
    scheme_set(0)

    # --- Step 1: status-notifier area, BOTH panel positions ---
    sp1: int32 = 0
    while sp1 <= 1:
        PANEL_POS = sp1
        py: int64 = panel_y0() + PANEL_H / 2
        x0: int64 = statnot_x0(scr_w)
        # The zone must sit fully on-screen, left of the message tray.
        if x0 + STATNOT_W > scr_w - NOTIF_W:
            write_str(1, "[DE17] FAIL statnot overlaps tray\n")
            return
        # Each cell hit-tests to its own index.
        c: int64 = 0
        while c < STATNOT_CELLS:
            cx: int64 = statnot_cell_x(c, scr_w) + STATNOT_ICON / 2
            if statnot_cell_at(cx, py, scr_w) != c:
                write_str(1, "[DE17] FAIL statnot cell hit-test wrong\n")
                return
            if strlen_u8(statnot_detail(c)) == 0:
                write_str(1, "[DE17] FAIL statnot detail empty\n")
                return
            c = c + 1
        # A click left of the zone resolves to no cell.
        if statnot_cell_at(x0 - 8, py, scr_w) != -1:
            write_str(1, "[DE17] FAIL statnot hit outside zone\n")
            return
        # Clicking the battery cell (0) opens its popup; clicking again closes.
        STATNOT_POPUP = -1
        statnot_click(0)
        if STATNOT_POPUP != 0:
            write_str(1, "[DE17] FAIL statnot popup did not open\n")
            return
        statnot_click(0)
        if STATNOT_POPUP != -1:
            write_str(1, "[DE17] FAIL statnot popup did not close\n")
            return
        sp1 = sp1 + 1
    PANEL_POS = 0

    # Power detail is TRUTHFUL: no battery surface -> "AC power"; when a
    # future ACPI battery reader marks one present, the percent renders.
    STATNOT_BATT_PRESENT = 0
    if cstr_eq(statnot_detail(0), "AC power") == 0:
        write_str(1, "[DE17] FAIL AC-power detail wrong\n")
        return
    STATNOT_BATT_PRESENT = 1
    STATNOT_BATT = 72
    STATNOT_BATT_CHG = 0
    if cstr_eq(statnot_detail(0), "Batt 72%") == 0:
        write_str(1, "[DE17] FAIL battery detail wrong\n")
        return
    STATNOT_BATT_PRESENT = 0
    STATNOT_BATT = -1
    STATNOT_NETUP = 0
    if cstr_eq(statnot_detail(1), "Net down") == 0:
        write_str(1, "[DE17] FAIL net-down detail wrong\n")
        return
    STATNOT_NETUP = 1
    if cstr_eq(statnot_detail(1), "Net up") == 0:
        write_str(1, "[DE17] FAIL net-up detail wrong\n")
        return

    # --- Step 2: volume / brightness OSD slider + mute ---
    VOL_LEVEL = 65
    VOL_MUTED = 0
    OSD_KIND = 0
    OSD_TTL = 0
    vol_step(10)
    if VOL_LEVEL != 75:
        write_str(1, "[DE17] FAIL vol_step did not raise\n")
        return
    if OSD_KIND != 1 or OSD_TTL != OSD_TTL_MAX:
        write_str(1, "[DE17] FAIL vol OSD not armed\n")
        return
    # Clamp at the top.
    vol_step(40)
    if VOL_LEVEL != 100:
        write_str(1, "[DE17] FAIL vol did not clamp at 100\n")
        return
    # Clamp at the bottom.
    vol_step(-250)
    if VOL_LEVEL != 0:
        write_str(1, "[DE17] FAIL vol did not clamp at 0\n")
        return
    # Slider fill at 0% sits at the track start; at 100% at the track end.
    VOL_LEVEL = 100
    VOL_MUTED = 0
    OSD_KIND = 1
    tx0: int64 = osd_x0(scr_w) + (OSD_W - OSD_SLIDER_W) / 2
    if osd_slider_fill_x(scr_w) != tx0 + OSD_SLIDER_W:
        write_str(1, "[DE17] FAIL slider full not at track end\n")
        return
    VOL_LEVEL = 0
    if osd_slider_fill_x(scr_w) != tx0:
        write_str(1, "[DE17] FAIL slider empty not at track start\n")
        return
    # Half.
    VOL_LEVEL = 50
    if osd_slider_fill_x(scr_w) != tx0 + OSD_SLIDER_W / 2:
        write_str(1, "[DE17] FAIL slider half geometry wrong\n")
        return
    # Mute forces the slider value to 0 even at a non-zero level.
    VOL_LEVEL = 80
    vol_mute_toggle()
    if VOL_MUTED != 1 or osd_slider_value() != 0:
        write_str(1, "[DE17] FAIL mute did not zero slider\n")
        return
    vol_mute_toggle()
    if VOL_MUTED != 0 or osd_slider_value() != 80:
        write_str(1, "[DE17] FAIL unmute did not restore slider\n")
        return
    # Brightness drives OSD kind 2 and clamps.
    BRI_LEVEL = 80
    bri_step(-30)
    if BRI_LEVEL != 50 or OSD_KIND != 2:
        write_str(1, "[DE17] FAIL bri_step/kind wrong\n")
        return
    bri_step(-200)
    if BRI_LEVEL != 0:
        write_str(1, "[DE17] FAIL bri did not clamp at 0\n")
        return
    if osd_slider_value() != 0:
        write_str(1, "[DE17] FAIL bri slider value wrong\n")
        return
    # The OSD vertical band follows the panel position (work area moves).
    PANEL_POS = 0
    top_y: int64 = osd_y0(scr_h)
    PANEL_POS = 1
    bot_y: int64 = osd_y0(scr_h)
    if top_y == bot_y:
        write_str(1, "[DE17] FAIL OSD band did not track panel\n")
        return
    PANEL_POS = 0

    # --- Step 3: window-selector applet across all workspaces ---
    # Spawn three in-process windows and scatter them across workspaces.
    daemon_spawn_app(APP_CALC, 80, PANEL_H + 20, 220, 180)
    daemon_spawn_app(APP_SYSMON, 140, PANEL_H + 60, 300, 180)
    daemon_spawn_app(APP_ABOUT, 200, PANEL_H + 100, 300, 180)
    if DWIN_COUNT < 3:
        write_str(1, "[DE17] FAIL could not spawn windows\n")
        return
    w0: uint64 = DWIN_COUNT - 3
    w1: uint64 = DWIN_COUNT - 2
    w2: uint64 = DWIN_COUNT - 1
    DWIN_WS[w0] = 0
    DWIN_WS[w1] = 2
    DWIN_WS[w2] = 1
    DWIN_HIDDEN[w2] = 1            # minimized on another desktop
    # The selector lists EVERY window regardless of workspace.
    if winsel_count() != DWIN_COUNT:
        write_str(1, "[DE17] FAIL winsel did not list all windows\n")
        return
    # Row hit-test resolves to the right slot for BOTH panel positions.
    sp3: int32 = 0
    while sp3 <= 1:
        PANEL_POS = sp3
        WINSEL_OPEN = 1
        th: int64 = winsel_total_h()
        y0: int64 = drop_anchor_y(th)
        rx: int64 = winsel_x0(scr_w) + WINSEL_W / 2
        # Row 0 (slot 0) sits just below the header band.
        r0y: int64 = y0 + WINSEL_ROW_H + WINSEL_ROW_H / 2
        if winsel_slot_at(rx, r0y, scr_w) != 0:
            write_str(1, "[DE17] FAIL winsel row0 hit-test wrong\n")
            return
        # The header row resolves to no slot.
        if winsel_slot_at(rx, y0 + WINSEL_ROW_H / 2, scr_w) != -1:
            write_str(1, "[DE17] FAIL winsel header hit-test wrong\n")
            return
        WINSEL_OPEN = 0
        sp3 = sp3 + 1
    PANEL_POS = 0
    # Activate the minimized window on workspace 1: unhide + switch + raise.
    CUR_WS = 0
    WINSEL_OPEN = 1
    front: int64 = winsel_activate(cast[int64](w2))
    if front < 0:
        write_str(1, "[DE17] FAIL winsel_activate failed\n")
        return
    if WINSEL_OPEN != 0:
        write_str(1, "[DE17] FAIL winsel did not close on activate\n")
        return
    if CUR_WS != 1:
        write_str(1, "[DE17] FAIL winsel did not switch workspace\n")
        return
    # The activated window is now front-most and visible.
    if DWIN_HIDDEN[cast[uint64](front)] != 0:
        write_str(1, "[DE17] FAIL activated window still hidden\n")
        return
    if cast[uint64](front) != DWIN_COUNT - 1:
        write_str(1, "[DE17] FAIL activated window not front-most\n")
        return
    # The panel button hit-tests on the bar.
    bpy: int64 = panel_y0() + PANEL_H / 2
    bbx: int64 = winsel_btn_x(scr_w) + WINSEL_BTN_W / 2
    if in_winsel_btn(bbx, bpy, scr_w) == 0:
        write_str(1, "[DE17] FAIL winsel button hit-test wrong\n")
        return
    CUR_WS = 0

    # --- Step 4: workspace-name editing + OSD ---
    WS_NAMES_INIT = 0
    if cstr_eq(ws_name(0), "Workspace 1") == 0:
        write_str(1, "[DE17] FAIL default ws name 0 wrong\n")
        return
    if cstr_eq(ws_name(3), "Workspace 4") == 0:
        write_str(1, "[DE17] FAIL default ws name 3 wrong\n")
        return
    ws_name_set(1, "Web")
    if cstr_eq(ws_name(1), "Web") == 0:
        write_str(1, "[DE17] FAIL ws rename did not take\n")
        return
    if ws_name_osd_active() == 0 or WSNAME_OSD_WS != 1:
        write_str(1, "[DE17] FAIL ws-name OSD not armed\n")
        return
    # Truncation: a name longer than the cap is clipped to CAP-1 bytes.
    ws_name_set(2, "ThisNameIsWayTooLongForACell")
    if strlen_u8(ws_name(2)) != cast[uint64](WS_NAME_CAP) - 1:
        write_str(1, "[DE17] FAIL ws name not truncated\n")
        return
    # The OSD ticks down to expiry.
    WSNAME_OSD_TTL = 2
    ws_name_osd_step()
    if ws_name_osd_active() == 0:
        write_str(1, "[DE17] FAIL ws-name OSD expired early\n")
        return
    ws_name_osd_step()
    if ws_name_osd_active() != 0:
        write_str(1, "[DE17] FAIL ws-name OSD did not expire\n")
        return

    # --- Reset to a clean desktop ---
    STATNOT_POPUP = -1
    WINSEL_OPEN = 0
    OSD_KIND = 0
    OSD_TTL = 0
    WSNAME_OSD_TTL = 0
    VOL_LEVEL = 65
    VOL_MUTED = 0
    BRI_LEVEL = 80
    STATNOT_BATT = 72
    STATNOT_NETUP = 1
    WS_NAMES_INIT = 0
    ws_names_init()
    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE17] PASS\n")


# ====================================================================
# ROUND-20: sticky windows / clipboard / cascade / quick two-pane tile
# ====================================================================

# --- Sticky windows (Always on Visible Workspace) ------------------
# Toggle window `slot`'s sticky flag. A sticky window is composited and
# listed on every workspace; clearing stickiness drops it back onto the
# CURRENT workspace (so it doesn't vanish to the desktop it was opened
# on, which the user has likely long since left).
def window_toggle_sticky(slot: uint64) -> int32:
    if DWIN_STICKY[slot] != 0:
        DWIN_STICKY[slot] = 0
        DWIN_WS[slot] = CUR_WS
        ms0: Ptr[uint8] = "WM sticky off\n"
        sys_write(1, ms0, strlen_u8(ms0))
        return 0
    DWIN_STICKY[slot] = 1
    ms1: Ptr[uint8] = "WM sticky on\n"
    sys_write(1, ms1, strlen_u8(ms1))
    return 1


def window_is_sticky(slot: uint64) -> int32:
    if DWIN_STICKY[slot] != 0:
        return 1
    return 0


# Toggle stickiness on the focused (front-most) window. Bound to a WM
# hotkey. Returns the resulting sticky state, or -1 if no window.
def sticky_toggle_focused() -> int32:
    fs: int64 = daemon_focus_slot()
    if fs < 0:
        return -1
    return window_toggle_sticky(cast[uint64](fs))


# --- Clipboard / selection manager (Clipman) -----------------------
# Address of ring entry `idx` (0..CLIP_MAX-1).
def clip_entry_ptr(idx: int64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](&clip_ring[0]) + cast[uint64](idx * CLIP_ENTRY_CAP)


# True if ring entry `a` holds exactly the same NUL-terminated text as
# the C-string `s` (used to de-duplicate an immediate repeat).
def clip_entry_eq(idx: int64, s: Ptr[uint8]) -> int32:
    e: Ptr[uint8] = clip_entry_ptr(idx)
    return cstr_eq(e, s)


# Record clipping `s` as the new most-recent entry. An immediate repeat
# of the current head is ignored (no duplicate stacking, like clipman).
# CLIP_SEL is reset to the head so the panel applet + paste track the
# fresh clipping. Returns CLIP_COUNT after the push.
def clip_push(s: Ptr[uint8]) -> int64:
    if s[0] == 0:
        return CLIP_COUNT
    # De-dup an immediate repeat of the newest entry.
    if CLIP_COUNT > 0 and clip_entry_eq(CLIP_HEAD, s) != 0:
        CLIP_SEL = 0
        return CLIP_COUNT
    nh: int64 = CLIP_HEAD + 1
    if nh >= CLIP_MAX:
        nh = 0
    CLIP_HEAD = nh
    dst: Ptr[uint8] = clip_entry_ptr(CLIP_HEAD)
    str_copy_cap(dst, s, cast[uint64](CLIP_ENTRY_CAP))
    if CLIP_COUNT < CLIP_MAX:
        CLIP_COUNT = CLIP_COUNT + 1
    CLIP_SEL = 0
    return CLIP_COUNT


# Pointer to the clipping currently selected for paste (CLIP_SEL entries
# back from the head). Returns an empty string when the ring is empty.
def clip_current() -> Ptr[uint8]:
    if CLIP_COUNT == 0:
        return cast[Ptr[uint8]]("")
    off: int64 = CLIP_SEL
    if off >= CLIP_COUNT:
        off = CLIP_COUNT - 1
    idx: int64 = CLIP_HEAD - off
    if idx < 0:
        idx = idx + CLIP_MAX
    return clip_entry_ptr(idx)


# Step the paste selection one entry older (dir +1) or newer (dir -1),
# wrapping within the live entries. No-op on an empty ring.
def clip_cycle(dir: int64):
    if CLIP_COUNT == 0:
        return
    s: int64 = CLIP_SEL + dir
    if s < 0:
        s = CLIP_COUNT - 1
    if s >= CLIP_COUNT:
        s = 0
    CLIP_SEL = s


# Paste the selected clipping into the focused window's stdin (or the
# built-in calculator handler). Returns the bytes pasted, or 0 if there
# was nothing to paste / no focused window.
def clip_paste_focused() -> int64:
    if CLIP_COUNT == 0:
        return 0
    fs: int64 = daemon_focus_slot()
    if fs < 0:
        return 0
    txt: Ptr[uint8] = clip_current()
    n: uint64 = strlen_u8(txt)
    if n == 0:
        return 0
    f: uint64 = cast[uint64](fs)
    wfd: int32 = DWIN_IN_FD[f]
    if wfd >= 0:
        sys_write(wfd, txt, n)
        return cast[int64](n)
    # No child pipe: feed digit/operator bytes to a calculator window.
    if DWIN_APP[f] == APP_CALC:
        ci: uint64 = 0
        while ci < n:
            kc: uint8 = txt[ci]
            if (kc >= 48 and kc <= 57) or kc == 43 or kc == 45 \
               or kc == 42 or kc == 47 or kc == 61:
                calc_press(f, kc)
            ci = ci + 1
        return cast[int64](n)
    return 0


def clip_clear():
    CLIP_HEAD = 0
    CLIP_COUNT = 0
    CLIP_SEL = 0


# --- Window cascade arrangement ------------------------------------
# Set every visible (current-workspace, non-minimized) window to a
# uniform size and stagger them diagonally down-right from the work-area
# origin, MATE's "Cascade Windows". Windows that would run off the screen
# edge wrap their stagger back to the origin so they stay on-screen.
def windows_cascade(scr_w: int64, scr_h: int64):
    wt: int64 = work_top(scr_h)
    avail_h: int64 = work_h(scr_h)
    # Uniform window size: two-thirds of the work area, clamped sane.
    uw: int64 = scr_w * 2 / 3
    uh: int64 = avail_h * 2 / 3
    if uw < 160:
        uw = 160
    if uh < 120:
        uh = 120
    if uw > scr_w - 8:
        uw = scr_w - 8
    if uh > avail_h - 8:
        uh = avail_h - 8
    placed: int64 = 0
    wj: uint64 = 0
    while wj < DWIN_COUNT:
        if win_on_cur_ws(wj) != 0:
            stagger: int64 = placed * CASCADE_STEP
            nx: int64 = 8 + stagger
            ny: int64 = wt + 8 + stagger
            # Wrap the stagger so the window never falls off the edge.
            while nx + uw > scr_w and nx > 8:
                nx = nx - (scr_w - uw - 8)
                if nx < 8:
                    nx = 8
            while ny + uh > wt + avail_h and ny > wt + 8:
                ny = ny - (avail_h - uh - 8)
                if ny < wt + 8:
                    ny = wt + 8
            DWIN_MAXED[wj] = 0
            DWIN_SNAP[wj] = 0
            DWIN_SHADED[wj] = 0
            DWIN_X[wj] = nx
            DWIN_Y[wj] = ny
            DWIN_W[wj] = uw
            DWIN_H[wj] = uh
            window_reflow(wj)
            placed = placed + 1
        wj = wj + 1
    cm: Ptr[uint8] = "DESK cascade "
    sys_write(1, cm, strlen_u8(cm))
    cb: Array[4, uint8]
    cb[0] = cast[uint8](placed) + 48
    cb[1] = 10
    sys_write(1, &cb[0], 2)


# Count visible windows on the current workspace.
def visible_win_count() -> int64:
    n: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) != 0:
            n = n + 1
        wi = wi + 1
    return n


# --- Quick two-pane tile -------------------------------------------
# Tile the two front-most (most-recently-focused) visible windows into
# the left and right halves. The front-most window takes the RIGHT half
# (it keeps focus), the next-front takes the LEFT. Reuses snap_apply so
# either window restores cleanly. Returns 1 if a pair was tiled, else 0.
def tile_two_panes(scr_w: int64, scr_h: int64) -> int32:
    # Find the two top-most visible slots, scanning from the front (the
    # paint walk is back-to-front, so the highest indices are front-most).
    first: int64 = -1
    second: int64 = -1
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        if win_on_cur_ws(cast[uint64](wi)) != 0:
            if first < 0:
                first = wi
            elif second < 0:
                second = wi
                wi = -1
        wi = wi - 1
    if first < 0 or second < 0:
        return 0
    # second (lower in z) -> left half; first (front) -> right half.
    snap_apply(cast[uint64](second), 2, scr_w, scr_h)
    snap_apply(cast[uint64](first), 3, scr_w, scr_h)
    tm: Ptr[uint8] = "DESK tile-two\n"
    sys_write(1, tm, strlen_u8(tm))
    return 1


# ====================================================================
# ROUND-21: smart window placement
# ====================================================================
# Marco's "smart" placement drops a new window where it overlaps existing
# windows the least, instead of blindly stacking. We probe a coarse grid
# of candidate top-left origins across the work area and score each by the
# total overlap area with the currently-visible windows on the current
# workspace; the lowest-overlap origin wins (ties keep the earliest, i.e.
# nearest the work-area origin). Pure scoring helpers + a placement entry
# point used by the launchers. SMART_PX / SMART_PY receive the result.
SMART_PX: int64 = 0
SMART_PY: int64 = 0

# Overlap area (px^2) between rectangle A and rectangle B.
def rect_overlap(ax: int64, ay: int64, aw: int64, ah: int64,
                 bx: int64, by: int64, bw: int64, bh: int64) -> int64:
    ix0: int64 = imax(ax, bx)
    iy0: int64 = imax(ay, by)
    ix1: int64 = imin(ax + aw, bx + bw)
    iy1: int64 = imin(ay + ah, by + bh)
    ow: int64 = ix1 - ix0
    oh: int64 = iy1 - iy0
    if ow <= 0 or oh <= 0:
        return 0
    return ow * oh

# Total overlap of a candidate (cx,cy,cw,ch) against every visible window
# on the current workspace.
def placement_overlap(cx: int64, cy: int64, cw: int64, ch: int64) -> int64:
    total: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) != 0:
            total = total + rect_overlap(cx, cy, cw, ch,
                                         DWIN_X[wi], DWIN_Y[wi],
                                         DWIN_W[wi], DWIN_H[wi])
        wi = wi + 1
    return total

# Choose the least-overlapping origin for a (w,h) window in the work area.
# Writes the chosen origin into SMART_PX / SMART_PY. A perfectly empty
# desktop yields the work-area origin (top-left under the panel).
def smart_place(w: int64, h: int64, scr_w: int64, scr_h: int64):
    wt: int64 = work_top(scr_h)
    floor: int64 = wt + work_h(scr_h)
    max_x: int64 = scr_w - w
    max_y: int64 = floor - h
    if max_x < 0:
        max_x = 0
    if max_y < wt:
        max_y = wt
    best_x: int64 = 0
    best_y: int64 = wt
    best_score: int64 = -1
    # Coarse grid: 8 columns x 6 rows of candidate origins.
    gx: int64 = 0
    while gx <= 7:
        cx: int64 = max_x * gx / 7
        gy: int64 = 0
        while gy <= 5:
            cy: int64 = wt + (max_y - wt) * gy / 5
            score: int64 = placement_overlap(cx, cy, w, h)
            if best_score < 0 or score < best_score:
                best_score = score
                best_x = cx
                best_y = cy
                if score == 0:
                    gy = 5
                    gx = 7
            gy = gy + 1
        gx = gx + 1
    SMART_PX = best_x
    SMART_PY = best_y


# ====================================================================
# ROUND-21: window-to-window magnetic snapping (edge resistance)
# ====================================================================
# Adjust a moving window's candidate origin (nx,ny) so that, if any of its
# four outer edges falls within MAGNET px of a screen edge OR of another
# visible window's matching edge, that edge snaps flush. The window's size
# is fixed during a move; only the origin moves. Returns the snapped origin
# via *ox/*oy. The moving window itself is excluded by `self_slot`.
def magnet_snap_axis(moving_lo: int64, moving_hi: int64,
                     target_lo: int64, target_hi: int64,
                     adj: Ptr[int64], best: Ptr[int64]) -> int32:
    # Try snapping the moving span's near edge to each target edge so the
    # spans sit flush (moving_lo == target_hi  OR moving_hi == target_lo OR
    # the same-side alignments moving_lo == target_lo / moving_hi==target_hi).
    fired: int32 = 0
    # moving left edge -> target right edge (sit to the right of target).
    d1: int64 = iabs(moving_lo - target_hi)
    if d1 <= MAGNET and d1 < best[0]:
        adj[0] = target_hi - moving_lo
        best[0] = d1
        fired = 1
    # moving right edge -> target left edge (sit to the left of target).
    d2: int64 = iabs(moving_hi - target_lo)
    if d2 <= MAGNET and d2 < best[0]:
        adj[0] = target_lo - moving_hi
        best[0] = d2
        fired = 1
    # moving left edge aligns with target left edge.
    d3: int64 = iabs(moving_lo - target_lo)
    if d3 <= MAGNET and d3 < best[0]:
        adj[0] = target_lo - moving_lo
        best[0] = d3
        fired = 1
    # moving right edge aligns with target right edge.
    d4: int64 = iabs(moving_hi - target_hi)
    if d4 <= MAGNET and d4 < best[0]:
        adj[0] = target_hi - moving_hi
        best[0] = d4
        fired = 1
    return fired

def magnet_adjust(self_slot: int64, nx: int64, ny: int64, w: int64, h: int64,
                  scr_w: int64, scr_h: int64, ox: Ptr[int64], oy: Ptr[int64]):
    wt: int64 = work_top(scr_h)
    floor: int64 = wt + work_h(scr_h)
    rx: int64 = nx
    ry: int64 = ny
    # --- X axis: screen edges first ---
    bx: Array[1, int64]
    adjx: Array[1, int64]
    bx[0] = MAGNET + 1
    adjx[0] = 0
    # left screen edge / right screen edge
    if iabs(nx - 0) <= MAGNET and iabs(nx - 0) < bx[0]:
        adjx[0] = 0 - nx
        bx[0] = iabs(nx - 0)
    if iabs((nx + w) - scr_w) <= MAGNET and iabs((nx + w) - scr_w) < bx[0]:
        adjx[0] = scr_w - (nx + w)
        bx[0] = iabs((nx + w) - scr_w)
    # other windows' vertical edges
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if cast[int64](wi) != self_slot and win_on_cur_ws(wi) != 0:
            magnet_snap_axis(nx, nx + w, DWIN_X[wi], DWIN_X[wi] + DWIN_W[wi],
                             &adjx[0], &bx[0])
        wi = wi + 1
    rx = nx + adjx[0]
    # --- Y axis: work-area edges first ---
    by: Array[1, int64]
    adjy: Array[1, int64]
    by[0] = MAGNET + 1
    adjy[0] = 0
    if iabs(ny - wt) <= MAGNET and iabs(ny - wt) < by[0]:
        adjy[0] = wt - ny
        by[0] = iabs(ny - wt)
    if iabs((ny + h) - floor) <= MAGNET and iabs((ny + h) - floor) < by[0]:
        adjy[0] = floor - (ny + h)
        by[0] = iabs((ny + h) - floor)
    wj: uint64 = 0
    while wj < DWIN_COUNT:
        if cast[int64](wj) != self_slot and win_on_cur_ws(wj) != 0:
            magnet_snap_axis(ny, ny + h, DWIN_Y[wj], DWIN_Y[wj] + DWIN_H[wj],
                             &adjy[0], &by[0])
        wj = wj + 1
    ry = ny + adjy[0]
    ox[0] = rx
    oy[0] = ry


# ====================================================================
# ROUND-21: keyboard move/resize mode (Marco Alt-F7 / Alt-F8)
# ====================================================================
# Enter a keyboard-driven move (mode 1) or resize (mode 2) of the focused
# window. While active the arrow-key CSI codes nudge the window and Enter
# commits / Escape cancels. Entering captures the geometry so a cancel can
# restore it; any snap/maximize/shade state is first cleared so the geometry
# is free-floating and the nudges are unambiguous.
def kmode_begin(mode: int32, scr_w: int64, scr_h: int64) -> int32:
    slot: int64 = daemon_focus_slot()
    if slot < 0:
        return 0
    s: uint64 = cast[uint64](slot)
    # Un-snap / un-maximize / un-shade so the window floats freely.
    if DWIN_SNAP[s] != 0 or DWIN_MAXED[s] != 0:
        snap_apply(s, 0, scr_w, scr_h)
    if DWIN_SHADED[s] != 0:
        window_toggle_shade(s)
    KMODE = mode
    KMODE_SLOT = slot
    KMODE_SAVE_X = DWIN_X[s]
    KMODE_SAVE_Y = DWIN_Y[s]
    KMODE_SAVE_W = DWIN_W[s]
    KMODE_SAVE_H = DWIN_H[s]
    km: Ptr[uint8] = "WM kbd-move begin\n"
    if mode == 2:
        km = "WM kbd-resize begin\n"
    sys_write(1, km, strlen_u8(km))
    return 1

# Nudge the keyboard-driven window. dir: 0 left, 1 right, 2 up, 3 down.
# In move mode the origin shifts (clamped on-screen); in resize mode the
# bottom-right grows/shrinks (clamped to a minimum), then the grid reflows.
def kmode_nudge(dir: int32, scr_w: int64, scr_h: int64) -> int32:
    if KMODE == 0 or KMODE_SLOT < 0:
        return 0
    s: uint64 = cast[uint64](KMODE_SLOT)
    if KMODE == 1:
        nx: int64 = DWIN_X[s]
        ny: int64 = DWIN_Y[s]
        if dir == 0:
            nx = nx - KSTEP
        elif dir == 1:
            nx = nx + KSTEP
        elif dir == 2:
            ny = ny - KSTEP
        else:
            ny = ny + KSTEP
        nx = iclamp(nx, 0, scr_w - DWIN_W[s])
        ny = iclamp(ny, work_top(scr_h), scr_h - DWIN_H[s])
        DWIN_X[s] = nx
        DWIN_Y[s] = ny
    else:
        nw: int64 = DWIN_W[s]
        nh: int64 = DWIN_H[s]
        if dir == 0:
            nw = nw - KSTEP
        elif dir == 1:
            nw = nw + KSTEP
        elif dir == 2:
            nh = nh - KSTEP
        else:
            nh = nh + KSTEP
        if nw < KWIN_MIN:
            nw = KWIN_MIN
        if nh < KWIN_MIN:
            nh = KWIN_MIN
        if DWIN_X[s] + nw > scr_w:
            nw = scr_w - DWIN_X[s]
        if DWIN_Y[s] + nh > scr_h:
            nh = scr_h - DWIN_Y[s]
        DWIN_W[s] = nw
        DWIN_H[s] = nh
        DWIN_SHADE_H[s] = nh
        window_reflow(s)
    return 1

# Finish keyboard move/resize. commit != 0 keeps the new geometry; commit
# == 0 (Escape) restores the geometry captured at kmode_begin.
def kmode_end(commit: int32):
    if KMODE == 0 or KMODE_SLOT < 0:
        KMODE = 0
        KMODE_SLOT = -1
        return
    s: uint64 = cast[uint64](KMODE_SLOT)
    if commit == 0:
        DWIN_X[s] = KMODE_SAVE_X
        DWIN_Y[s] = KMODE_SAVE_Y
        DWIN_W[s] = KMODE_SAVE_W
        DWIN_H[s] = KMODE_SAVE_H
        DWIN_SHADE_H[s] = KMODE_SAVE_H
        window_reflow(s)
    KMODE = 0
    KMODE_SLOT = -1


# ====================================================================
# ROUND-19 MATE-polish self-test (autoflag == 29)
# ====================================================================
# Exercises the round-19 desktop features WITHOUT QEMU mouse injection:
#   1. PER-WINDOW OPACITY: window_opacity_step lowers/raises a window's
#      alpha, clamps at OPACITY_MIN on the way down and at 255 on the way
#      up, and a fresh window starts fully opaque (255).
#   2. SESSION SAVE/RESTORE: session_save serialises every open window's
#      app/geometry/workspace to session_buf, and re-parsing the buffer
#      with session_next_int round-trips the exact values that were saved
#      (the persisted FLOAT rectangle for snapped/maximized windows).
#   3. DESKTOP ICONS: dicons_init lays out the icon grid, dicon_at hit-tests
#      a cell (and rejects empty space), and dicon_grid_snap quantises a
#      drop coordinate to the DICON_GRID.
#   4. DESKTOP SYSMON APPLET: dmon_push records CPU/MEM samples into the
#      history ring, dmon_sample reads the newest sample back, and
#      in_dmon_applet hit-tests the applet rectangle (rejecting outside).
# Emits "[DE19] PASS" / "[DE19] FAIL <reason>".
def daemon_round19_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    PANEL_POS = 0
    SESSION_OPEN = 0
    DAEMON_QUIT = 0
    scheme_palette_init()
    scheme_set(0)

    # --- Step 1: per-window opacity clamp ---
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 80, PANEL_H + 20, 220, 180)
    if DWIN_COUNT != 1:
        write_str(1, "[DE19] FAIL could not spawn opacity window\n")
        return
    # A fresh window is fully opaque.
    if DWIN_OPACITY[0] != 255:
        write_str(1, "[DE19] FAIL new window not fully opaque\n")
        return
    # One step down lowers alpha by exactly OPACITY_STEP.
    if window_opacity_step(0, -OPACITY_STEP) != 255 - OPACITY_STEP:
        write_str(1, "[DE19] FAIL opacity step down wrong\n")
        return
    # Drive it past the floor: it clamps at OPACITY_MIN, never below.
    guard: int32 = 0
    while DWIN_OPACITY[0] > OPACITY_MIN and guard < 64:
        window_opacity_step(0, -OPACITY_STEP)
        guard = guard + 1
    if DWIN_OPACITY[0] != OPACITY_MIN:
        write_str(1, "[DE19] FAIL opacity did not clamp at floor\n")
        return
    window_opacity_step(0, -OPACITY_STEP)
    if DWIN_OPACITY[0] != OPACITY_MIN:
        write_str(1, "[DE19] FAIL opacity dropped below floor\n")
        return
    # Drive it back up: it clamps at 255, never above.
    guard = 0
    while DWIN_OPACITY[0] < 255 and guard < 64:
        window_opacity_step(0, OPACITY_STEP)
        guard = guard + 1
    if DWIN_OPACITY[0] != 255:
        write_str(1, "[DE19] FAIL opacity did not clamp at ceiling\n")
        return
    window_opacity_step(0, OPACITY_STEP)
    if DWIN_OPACITY[0] != 255:
        write_str(1, "[DE19] FAIL opacity rose above ceiling\n")
        return

    # --- Step 2: session save serialises + round-trips ---
    # Two windows with known apps / geometry / workspace.
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 60, PANEL_H + 10, 220, 180)
    daemon_spawn_app(APP_SYSMON, 300, PANEL_H + 40, 360, 220)
    DWIN_WS[0] = 0
    DWIN_WS[1] = 2
    nsaved: int64 = session_save()
    if nsaved != 2 or SESSION_SAVED_N != 2:
        write_str(1, "[DE19] FAIL session_save count wrong\n")
        return
    # Re-parse the serialised buffer and confirm record 0 round-trips
    # exactly (app, x, y, w, h, ws). session_save left session_buf populated.
    pos: uint64 = 0
    okv: int32 = 0
    total: uint64 = 2048
    a0: int64 = session_next_int(&pos, total, &okv)
    x0: int64 = session_next_int(&pos, total, &okv)
    y0: int64 = session_next_int(&pos, total, &okv)
    w0: int64 = session_next_int(&pos, total, &okv)
    h0: int64 = session_next_int(&pos, total, &okv)
    s0: int64 = session_next_int(&pos, total, &okv)
    if a0 != cast[int64](APP_CALC) or x0 != 60 or y0 != PANEL_H + 10:
        write_str(1, "[DE19] FAIL session record0 origin wrong\n")
        return
    if w0 != 220 or h0 != 180 or s0 != 0:
        write_str(1, "[DE19] FAIL session record0 size/ws wrong\n")
        return
    # Advance to the next record (skip the newline that ends record 0).
    while pos < total and session_buf[pos] != 10:
        pos = pos + 1
    if pos < total and session_buf[pos] == 10:
        pos = pos + 1
    a1: int64 = session_next_int(&pos, total, &okv)
    x1: int64 = session_next_int(&pos, total, &okv)
    y1: int64 = session_next_int(&pos, total, &okv)
    w1: int64 = session_next_int(&pos, total, &okv)
    h1: int64 = session_next_int(&pos, total, &okv)
    s1: int64 = session_next_int(&pos, total, &okv)
    if a1 != cast[int64](APP_SYSMON) or x1 != 300 or y1 != PANEL_H + 40:
        write_str(1, "[DE19] FAIL session record1 origin wrong\n")
        return
    if w1 != 360 or h1 != 220 or s1 != 2:
        write_str(1, "[DE19] FAIL session record1 size/ws wrong\n")
        return

    # --- Step 3: desktop icons ---
    DICONS_INIT = 0
    dicons_init()
    if DICONS_INIT != 1 or DICON_COUNT < 1:
        write_str(1, "[DE19] FAIL dicons_init did not lay out grid\n")
        return
    # The centre of icon 0's cell hits icon 0.
    cx0: int64 = DICON_X[0] + DICON_CELL_W / 2
    cy0: int64 = DICON_Y[0] + DICON_CELL_H / 2
    if dicon_at(cx0, cy0) != 0:
        write_str(1, "[DE19] FAIL dicon_at missed icon 0\n")
        return
    # The centre of the last icon's cell hits the last icon.
    last: int64 = DICON_COUNT - 1
    cxl: int64 = DICON_X[last] + DICON_CELL_W / 2
    cyl: int64 = DICON_Y[last] + DICON_CELL_H / 2
    if dicon_at(cxl, cyl) != last:
        write_str(1, "[DE19] FAIL dicon_at missed last icon\n")
        return
    # Far-off empty desktop hits nothing.
    if dicon_at(DICON_X[0] - 100, DICON_Y[0] - 100) != -1:
        write_str(1, "[DE19] FAIL dicon_at hit empty space\n")
        return
    # Grid-snap quantises down to a DICON_GRID multiple.
    snapped: int64 = dicon_grid_snap(DICON_GRID * 5 + 3)
    if snapped != DICON_GRID * 5:
        write_str(1, "[DE19] FAIL dicon_grid_snap wrong\n")
        return
    if (dicon_grid_snap(snapped) % DICON_GRID) != 0:
        write_str(1, "[DE19] FAIL dicon_grid_snap not aligned\n")
        return

    # --- Step 4: desktop system-monitor applet ---
    DMON_HEAD = 0
    DMON_FILLED = 0
    # Seed a couple of known samples directly so the ring read is
    # deterministic (dmon_push's live reads vary by host).
    dmon_cpu[0] = 25
    dmon_mem[0] = 40
    DMON_HEAD = 1
    DMON_FILLED = 1
    # Newest sample is at the last column.
    if dmon_sample(DMON_HIST - 1, 0) != 25:
        write_str(1, "[DE19] FAIL dmon_sample cpu wrong\n")
        return
    if dmon_sample(DMON_HIST - 1, 1) != 40:
        write_str(1, "[DE19] FAIL dmon_sample mem wrong\n")
        return
    # dmon_push records a fresh pair and advances the ring head + fill.
    before_head: int64 = DMON_HEAD
    before_fill: int64 = DMON_FILLED
    dmon_push()
    if DMON_HEAD != (before_head + 1) % DMON_HIST:
        write_str(1, "[DE19] FAIL dmon_push did not advance head\n")
        return
    if DMON_FILLED != before_fill + 1:
        write_str(1, "[DE19] FAIL dmon_push did not grow fill\n")
        return
    # The current CPU/MEM read-backs are valid percentages (0..100).
    if DMON_CPU_CUR < 0 or DMON_CPU_CUR > 100:
        write_str(1, "[DE19] FAIL dmon cpu pct out of range\n")
        return
    if DMON_MEM_CUR < 0 or DMON_MEM_CUR > 100:
        write_str(1, "[DE19] FAIL dmon mem pct out of range\n")
        return
    # Applet hit-test: the centre is inside, far away is outside.
    ax: int64 = dmon_x0(scr_w) + DMON_W / 2
    ay: int64 = dmon_y0(scr_h) + DMON_H / 2
    if in_dmon_applet(ax, ay, scr_w, scr_h) != 1:
        write_str(1, "[DE19] FAIL in_dmon_applet missed centre\n")
        return
    if in_dmon_applet(dmon_x0(scr_w) - 40, ay, scr_w, scr_h) != 0:
        write_str(1, "[DE19] FAIL in_dmon_applet hit outside\n")
        return

    # --- Reset to a clean desktop ---
    DWIN_COUNT = 0
    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE19] PASS\n")


# ====================================================================
# ROUND-20 MATE-feel self-test (autoflag == 30)
# ====================================================================
# Exercises the round-20 desktop features WITHOUT QEMU mouse injection:
#   1. STICKY WINDOWS: window_toggle_sticky marks a window Always-on-
#      Visible-Workspace so win_on_cur_ws / taskbar_lists_slot keep it
#      visible after a workspace switch; clearing it drops the window back
#      onto the current desktop. Sticky survives a slot_swap (raise) and a
#      slot_copy (close-compaction).
#   2. CLIPBOARD MANAGER: clip_push records clippings into the ring (newest
#      first), de-dups an immediate repeat, caps at CLIP_MAX with the
#      oldest evicted, clip_cycle navigates the live entries, and
#      clip_current tracks the selection.
#   3. WINDOW CASCADE: windows_cascade staggers every visible window to a
#      uniform size down-right of the work-area origin, clearing any
#      snap/maximize/shade state, and each window stays on-screen.
#   4. QUICK TWO-PANE TILE: tile_two_panes snaps the two front-most visible
#      windows into the left and right halves (front-most on the right).
# Emits "[DE20] PASS" / "[DE20] FAIL <reason>".
def daemon_round20_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    PANEL_POS = 0
    SESSION_OPEN = 0
    DAEMON_QUIT = 0
    SHOW_ALL_WS = 0
    scheme_palette_init()
    scheme_set(0)

    # --- Step 1: sticky windows ---
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 60, PANEL_H + 10, 200, 160)
    daemon_spawn_app(APP_SYSMON, 300, PANEL_H + 10, 200, 160)
    if DWIN_COUNT != 2:
        write_str(1, "[DE20] FAIL could not spawn sticky windows\n")
        return
    # Fresh windows are non-sticky and live on workspace 0.
    if DWIN_STICKY[0] != 0 or window_is_sticky(0) != 0:
        write_str(1, "[DE20] FAIL new window unexpectedly sticky\n")
        return
    DWIN_WS[0] = 0
    DWIN_WS[1] = 0
    # On workspace 0, both windows are visible.
    if win_on_cur_ws(0) != 1 or win_on_cur_ws(1) != 1:
        write_str(1, "[DE20] FAIL window not visible on own ws\n")
        return
    # Make window 0 sticky.
    if window_toggle_sticky(0) != 1 or window_is_sticky(0) != 1:
        write_str(1, "[DE20] FAIL toggle sticky did not stick\n")
        return
    # Switch to workspace 2: the sticky window follows, the other doesn't.
    CUR_WS = 2
    if win_on_cur_ws(0) != 1:
        write_str(1, "[DE20] FAIL sticky window vanished on ws switch\n")
        return
    if win_on_cur_ws(1) != 0:
        write_str(1, "[DE20] FAIL non-sticky window followed switch\n")
        return
    # The sticky window is taskbar-listed on the new workspace too.
    if taskbar_lists_slot(0) != 1:
        write_str(1, "[DE20] FAIL sticky window not taskbar-listed\n")
        return
    if taskbar_lists_slot(1) != 0:
        write_str(1, "[DE20] FAIL non-sticky listed off its ws\n")
        return
    # Sticky bit survives a slot_swap (raise reorders the table).
    slot_swap(0, 1)
    # Now slot 1 carries the sticky window (UIDs moved with the swap).
    if DWIN_STICKY[1] != 1 or DWIN_STICKY[0] != 0:
        write_str(1, "[DE20] FAIL sticky lost across slot_swap\n")
        return
    # Sticky bit survives a slot_copy (close-compaction copies slot down).
    slot_copy(0, 1)
    if DWIN_STICKY[0] != 1:
        write_str(1, "[DE20] FAIL sticky lost across slot_copy\n")
        return
    # Clearing stickiness on the now-sticky slot 0 drops it onto CUR_WS.
    CUR_WS = 2
    if window_toggle_sticky(0) != 0:
        write_str(1, "[DE20] FAIL un-sticky did not clear\n")
        return
    if DWIN_WS[0] != 2:
        write_str(1, "[DE20] FAIL un-sticky did not rehome to cur ws\n")
        return

    # --- Step 2: clipboard manager ---
    clip_clear()
    if CLIP_COUNT != 0:
        write_str(1, "[DE20] FAIL clipboard not empty after clear\n")
        return
    # An empty ring yields an empty current string.
    ce0: Ptr[uint8] = clip_current()
    if ce0[0] != 0:
        write_str(1, "[DE20] FAIL empty clipboard not empty string\n")
        return
    clip_push("alpha")
    clip_push("beta")
    clip_push("gamma")
    if CLIP_COUNT != 3:
        write_str(1, "[DE20] FAIL clip_push count wrong\n")
        return
    # Newest (head, sel 0) is "gamma".
    CLIP_SEL = 0
    if cstr_eq(clip_current(), "gamma") != 1:
        write_str(1, "[DE20] FAIL clip head not newest\n")
        return
    # An immediate repeat of the head does NOT grow the ring.
    clip_push("gamma")
    if CLIP_COUNT != 3:
        write_str(1, "[DE20] FAIL clip_push duplicated head\n")
        return
    # clip_cycle(1) walks to the next-older clipping ("beta", then "alpha").
    clip_cycle(1)
    if cstr_eq(clip_current(), "beta") != 1:
        write_str(1, "[DE20] FAIL clip_cycle did not step to beta\n")
        return
    clip_cycle(1)
    if cstr_eq(clip_current(), "alpha") != 1:
        write_str(1, "[DE20] FAIL clip_cycle did not step to alpha\n")
        return
    # Wrapping past the oldest returns to the newest.
    clip_cycle(1)
    if cstr_eq(clip_current(), "gamma") != 1:
        write_str(1, "[DE20] FAIL clip_cycle did not wrap to head\n")
        return
    # Stepping the other direction (newer) from the head wraps to the oldest.
    clip_cycle(-1)
    if cstr_eq(clip_current(), "alpha") != 1:
        write_str(1, "[DE20] FAIL clip_cycle(-1) did not wrap to oldest\n")
        return
    # The ring caps at CLIP_MAX: push past it and the oldest is evicted.
    clip_clear()
    pi: int64 = 0
    cbuf: Array[8, uint8]
    while pi < CLIP_MAX + 2:
        cbuf[0] = 75                          # 'K'
        cbuf[1] = cast[uint8](pi) + 48        # one-digit tag (pi < 10)
        cbuf[2] = 0
        clip_push(cast[Ptr[uint8]](&cbuf[0]))
        pi = pi + 1
    if CLIP_COUNT != CLIP_MAX:
        write_str(1, "[DE20] FAIL clipboard exceeded CLIP_MAX\n")
        return
    # Head holds the last-pushed tag (CLIP_MAX+1).
    CLIP_SEL = 0
    exp: Array[8, uint8]
    exp[0] = 75
    exp[1] = cast[uint8](CLIP_MAX + 1) + 48
    exp[2] = 0
    if cstr_eq(clip_current(), cast[Ptr[uint8]](&exp[0])) != 1:
        write_str(1, "[DE20] FAIL clip head wrong after eviction\n")
        return

    # --- Step 3: window cascade ---
    DWIN_COUNT = 0
    CUR_WS = 0
    daemon_spawn_app(APP_CALC, 10, PANEL_H + 5, 100, 80)
    daemon_spawn_app(APP_SYSMON, 20, PANEL_H + 6, 100, 80)
    daemon_spawn_app(APP_ABOUT, 30, PANEL_H + 7, 100, 80)
    # Maximize one + shade another so cascade must clear those states.
    window_toggle_maximize(0, scr_w, scr_h)
    window_toggle_shade(1)
    if DWIN_MAXED[0] == 0:
        write_str(1, "[DE20] FAIL precondition: window 0 not maxed\n")
        return
    windows_cascade(scr_w, scr_h)
    # Every visible window is now un-maximized, un-snapped, un-shaded,
    # on-screen, and uniformly sized; each is staggered down-right of
    # the previous one.
    prev_x: int64 = -1000
    prev_y: int64 = -1000
    uw0: int64 = DWIN_W[0]
    uh0: int64 = DWIN_H[0]
    ci2: uint64 = 0
    while ci2 < DWIN_COUNT:
        if DWIN_MAXED[ci2] != 0 or DWIN_SNAP[ci2] != 0 or DWIN_SHADED[ci2] != 0:
            write_str(1, "[DE20] FAIL cascade left a window snapped/shaded\n")
            return
        if DWIN_W[ci2] != uw0 or DWIN_H[ci2] != uh0:
            write_str(1, "[DE20] FAIL cascade windows not uniform size\n")
            return
        if DWIN_X[ci2] < 0 or DWIN_Y[ci2] < work_top(scr_h):
            write_str(1, "[DE20] FAIL cascade window off top/left edge\n")
            return
        if DWIN_X[ci2] + DWIN_W[ci2] > scr_w:
            write_str(1, "[DE20] FAIL cascade window off right edge\n")
            return
        if DWIN_X[ci2] <= prev_x or DWIN_Y[ci2] <= prev_y:
            write_str(1, "[DE20] FAIL cascade not staggered down-right\n")
            return
        prev_x = DWIN_X[ci2]
        prev_y = DWIN_Y[ci2]
        ci2 = ci2 + 1

    # --- Step 4: quick two-pane tile ---
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 40, PANEL_H + 10, 180, 140)
    daemon_spawn_app(APP_SYSMON, 260, PANEL_H + 10, 180, 140)
    if tile_two_panes(scr_w, scr_h) != 1:
        write_str(1, "[DE20] FAIL tile_two_panes did not tile a pair\n")
        return
    # Slot 0 (lower in z) -> left half; slot 1 (front) -> right half.
    if DWIN_X[0] != 0 or DWIN_W[0] != scr_w / 2:
        write_str(1, "[DE20] FAIL tile left pane geometry wrong\n")
        return
    if DWIN_X[1] != scr_w / 2 or DWIN_W[1] != scr_w - scr_w / 2:
        write_str(1, "[DE20] FAIL tile right pane geometry wrong\n")
        return
    if DWIN_SNAP[0] != 2 or DWIN_SNAP[1] != 3:
        write_str(1, "[DE20] FAIL tile did not set snap states\n")
        return
    # With fewer than two visible windows, tiling is a no-op (returns 0).
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 40, PANEL_H + 10, 180, 140)
    if tile_two_panes(scr_w, scr_h) != 0:
        write_str(1, "[DE20] FAIL tile fired with one window\n")
        return

    # --- Reset to a clean desktop ---
    DWIN_COUNT = 0
    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    clip_clear()
    daemon_present()
    write_str(1, "[DE20] PASS\n")


# ====================================================================
# ROUND-21 MATE-feel self-test (autoflag == 31)
# ====================================================================
# Exercises the round-21 desktop features WITHOUT QEMU mouse injection:
#   1. SMART PLACEMENT: smart_place drops a new window at the lowest-overlap
#      origin. On an empty desktop it lands at the work-area origin; with a
#      window already filling the top-left it steers a same-size window
#      clear of it; rect_overlap / placement_overlap score correctly.
#   2. WINDOW-TO-WINDOW MAGNETISM: magnet_adjust snaps a moving window flush
#      against a screen edge and against a neighbouring window's edge when
#      within MAGNET px, and leaves a far-away window untouched.
#   3. KEYBOARD MOVE/RESIZE MODE: kmode_begin captures geometry + clears
#      snap state, kmode_nudge shifts the origin (move) or grows the frame
#      (resize) by KSTEP and clamps to the screen / a minimum, Enter commits
#      and Escape restores the captured geometry.
# Emits "[DE21] PASS" / "[DE21] FAIL <reason>".
def daemon_round21_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    PANEL_POS = 0
    SESSION_OPEN = 0
    DAEMON_QUIT = 0
    SHOW_ALL_WS = 0
    KMODE = 0
    KMODE_SLOT = -1
    scheme_palette_init()
    scheme_set(0)
    wt: int64 = work_top(scr_h)

    # --- Step 1: smart placement ---
    DWIN_COUNT = 0
    # rect_overlap sanity: disjoint -> 0; a 50x50 overlap -> 2500.
    if rect_overlap(0, 0, 100, 100, 200, 200, 50, 50) != 0:
        write_str(1, "[DE21] FAIL rect_overlap disjoint not zero\n")
        return
    if rect_overlap(0, 0, 100, 100, 50, 50, 100, 100) != 2500:
        write_str(1, "[DE21] FAIL rect_overlap area wrong\n")
        return
    # Empty desktop: smart_place lands at the work-area origin (x=0,y=wt).
    smart_place(200, 160, scr_w, scr_h)
    if SMART_PX != 0 or SMART_PY != wt:
        write_str(1, "[DE21] FAIL empty smart_place not work origin\n")
        return
    # Put a window filling the top-left quadrant, then place a same-size
    # window: it must steer to a zero-overlap origin (clear of the first).
    daemon_spawn_app(APP_CALC, 0, wt, scr_w / 2, work_h(scr_h) / 2)
    DWIN_WS[0] = 0
    pw: int64 = scr_w / 2
    ph: int64 = work_h(scr_h) / 2
    smart_place(pw, ph, scr_w, scr_h)
    if placement_overlap(SMART_PX, SMART_PY, pw, ph) != 0:
        write_str(1, "[DE21] FAIL smart_place did not avoid overlap\n")
        return
    # The chosen origin stays inside the work area.
    if SMART_PX < 0 or SMART_PX + pw > scr_w:
        write_str(1, "[DE21] FAIL smart_place off the X work area\n")
        return
    if SMART_PY < wt or SMART_PY + ph > wt + work_h(scr_h):
        write_str(1, "[DE21] FAIL smart_place off the Y work area\n")
        return
    write_str(1, "[DE21] smart-place OK\n")

    # --- Step 2: window-to-window magnetism ---
    DWIN_COUNT = 0
    # A neighbour window pinned at x=300..460, y=wt+40..wt+200.
    daemon_spawn_app(APP_SYSMON, 300, wt + 40, 160, 160)
    DWIN_WS[0] = 0
    mx: Array[1, int64]
    my: Array[1, int64]
    # A 120-wide window whose right edge (nx+120) is 8px shy of the
    # neighbour's left edge (300): nx=172 -> right=292, gap 8 <= MAGNET so
    # it snaps flush to 300 (right edge == 300 -> nx becomes 180).
    magnet_adjust(-1, 172, wt + 50, 120, 100, scr_w, scr_h, &mx[0], &my[0])
    if mx[0] != 180:
        write_str(1, "[DE21] FAIL magnet did not snap to neighbour edge\n")
        return
    # A window near the LEFT screen edge (nx=6) snaps to x=0.
    magnet_adjust(-1, 6, wt + 300, 120, 100, scr_w, scr_h, &mx[0], &my[0])
    if mx[0] != 0:
        write_str(1, "[DE21] FAIL magnet did not snap to screen edge\n")
        return
    # A window near the WORK-AREA TOP (ny within MAGNET of wt) snaps to wt.
    magnet_adjust(-1, 600, wt + 5, 120, 100, scr_w, scr_h, &mx[0], &my[0])
    if my[0] != wt:
        write_str(1, "[DE21] FAIL magnet did not snap to work top\n")
        return
    # A window far from any edge/neighbour is left untouched. Anchor its X
    # well clear of both screen edges (a quarter-width in) so the test holds
    # at any framebuffer width.
    fx: int64 = scr_w / 4
    magnet_adjust(-1, fx, wt + 300, 80, 60, scr_w, scr_h, &mx[0], &my[0])
    if mx[0] != fx or my[0] != wt + 300:
        write_str(1, "[DE21] FAIL magnet moved a far window\n")
        return
    write_str(1, "[DE21] magnetism OK\n")

    # --- Step 3: keyboard move/resize mode ---
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 200, wt + 60, 200, 160)
    fs: int64 = daemon_focus_slot()
    if fs < 0:
        write_str(1, "[DE21] FAIL no focused window for kbd mode\n")
        return
    fu: uint64 = cast[uint64](fs)
    # Maximize first so kmode_begin must un-maximize before capturing.
    window_toggle_maximize(fu, scr_w, scr_h)
    if DWIN_MAXED[fu] == 0:
        write_str(1, "[DE21] FAIL precondition: window not maxed\n")
        return
    if kmode_begin(1, scr_w, scr_h) != 1:
        write_str(1, "[DE21] FAIL kmode_begin move did not start\n")
        return
    if KMODE != 1 or DWIN_MAXED[fu] != 0:
        write_str(1, "[DE21] FAIL kmode_begin did not un-maximize\n")
        return
    bx0: int64 = DWIN_X[fu]
    by0: int64 = DWIN_Y[fu]
    # Nudge right (dir 1) and down (dir 3) one KSTEP each.
    kmode_nudge(1, scr_w, scr_h)
    kmode_nudge(3, scr_w, scr_h)
    if DWIN_X[fu] != bx0 + KSTEP or DWIN_Y[fu] != by0 + KSTEP:
        write_str(1, "[DE21] FAIL kbd move nudge wrong\n")
        return
    # Escape cancels -> geometry restored to the capture (pre-nudge) origin.
    kmode_end(0)
    if KMODE != 0 or DWIN_X[fu] != bx0 or DWIN_Y[fu] != by0:
        write_str(1, "[DE21] FAIL kbd move cancel did not restore\n")
        return
    # Resize mode: grow the frame, commit, confirm it stuck + reflowed.
    ow0: int64 = DWIN_W[fu]
    oh0: int64 = DWIN_H[fu]
    if kmode_begin(2, scr_w, scr_h) != 1 or KMODE != 2:
        write_str(1, "[DE21] FAIL kmode_begin resize did not start\n")
        return
    kmode_nudge(1, scr_w, scr_h)             # wider
    kmode_nudge(3, scr_w, scr_h)             # taller
    if DWIN_W[fu] != ow0 + KSTEP or DWIN_H[fu] != oh0 + KSTEP:
        write_str(1, "[DE21] FAIL kbd resize grow wrong\n")
        return
    # Shrinking past KWIN_MIN clamps to the minimum.
    si: int64 = 0
    while si < 40:
        kmode_nudge(0, scr_w, scr_h)         # narrower repeatedly
        si = si + 1
    if DWIN_W[fu] < KWIN_MIN:
        write_str(1, "[DE21] FAIL kbd resize undershot min width\n")
        return
    kmode_end(1)                              # commit
    if KMODE != 0:
        write_str(1, "[DE21] FAIL kbd resize commit did not end mode\n")
        return
    if DWIN_W[fu] < KWIN_MIN or DWIN_H[fu] != oh0 + KSTEP:
        write_str(1, "[DE21] FAIL kbd resize commit geometry wrong\n")
        return
    write_str(1, "[DE21] kbd-move-resize OK\n")

    # --- Reset to a clean desktop ---
    DWIN_COUNT = 0
    CUR_WS = 0
    PANEL_POS = 0
    KMODE = 0
    KMODE_SLOT = -1
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE21] PASS\n")


# ====================================================================
# ROUND-22 MATE-feel self-test (autoflag == 32)
# ====================================================================
# Exercises the round-22 desktop features WITHOUT QEMU mouse injection:
#   1. TRUE FULLSCREEN: window_toggle_fullscreen parks the float rectangle,
#      covers the WHOLE screen (0,0)..(scr_w,scr_h), drops the title bar
#      (title_h_of -> 0) and reflows the body to fill the frame; toggling
#      back restores the exact pre-fullscreen geometry + the title bar.
#   2. WINDOW TAB-GROUPING: group_visible_windows collapses every visible
#      window into one group (count correct, one active tab, the rest
#      hidden by win_on_cur_ws), group_tab_at hit-tests the title-bar tab
#      strip, group_activate_tab switches the visible member (inheriting
#      the frame), and group_dissolve ungroups so all members show again.
#   3. DRAG EDGE-FLIP: edge_flip_update only flips after the cursor dwells
#      EFLIP_DWELL frames jammed at a screen margin, then flips to the
#      adjacent workspace AND carries the dragged window there; leaving the
#      band resets the dwell; a cooldown suppresses an immediate re-flip.
# Emits "[DE22] PASS" / "[DE22] FAIL <reason>".
def daemon_round22_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    PANEL_POS = 0
    SESSION_OPEN = 0
    DAEMON_QUIT = 0
    SHOW_ALL_WS = 0
    KMODE = 0
    EFLIP_CTR = 0
    EFLIP_SIDE = 0
    EFLIP_COOLDOWN = 0
    NEXT_GROUP = 1
    scheme_palette_init()
    scheme_set(0)
    wt: int64 = work_top(scr_h)

    # --- Step 1: true fullscreen ---
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 120, wt + 40, 300, 220)
    fs: int64 = daemon_focus_slot()
    if fs < 0:
        write_str(1, "[DE22] FAIL no focused window for fullscreen\n")
        return
    fu: uint64 = cast[uint64](fs)
    # Pre-conditions: a normal window has a title bar.
    if title_h_of(fu) != TITLE_H:
        write_str(1, "[DE22] FAIL normal window has no title bar\n")
        return
    sx0: int64 = DWIN_X[fu]
    sy0: int64 = DWIN_Y[fu]
    sw0: int64 = DWIN_W[fu]
    sh0: int64 = DWIN_H[fu]
    window_toggle_fullscreen(fu, scr_w, scr_h)
    if DWIN_FULL[fu] == 0:
        write_str(1, "[DE22] FAIL fullscreen flag not set\n")
        return
    # Covers the whole screen incl. the panel strip; no title bar.
    if DWIN_X[fu] != 0 or DWIN_Y[fu] != 0 \
       or DWIN_W[fu] != scr_w or DWIN_H[fu] != scr_h:
        write_str(1, "[DE22] FAIL fullscreen does not cover the screen\n")
        return
    if title_h_of(fu) != 0:
        write_str(1, "[DE22] FAIL fullscreen kept its title bar\n")
        return
    # The body grid reflowed to (almost) the full frame height: more rows
    # than the title-bar-less body would have had at the float size.
    full_rows: int64 = DWIN_ROWS[fu]
    if full_rows <= 0:
        write_str(1, "[DE22] FAIL fullscreen body did not reflow\n")
        return
    # Toggle back: exact geometry + title bar restored.
    window_toggle_fullscreen(fu, scr_w, scr_h)
    if DWIN_FULL[fu] != 0:
        write_str(1, "[DE22] FAIL leave-fullscreen flag still set\n")
        return
    if DWIN_X[fu] != sx0 or DWIN_Y[fu] != sy0 \
       or DWIN_W[fu] != sw0 or DWIN_H[fu] != sh0:
        write_str(1, "[DE22] FAIL leave-fullscreen geometry not restored\n")
        return
    if title_h_of(fu) != TITLE_H:
        write_str(1, "[DE22] FAIL leave-fullscreen title bar not restored\n")
        return
    write_str(1, "[DE22] fullscreen OK\n")

    # --- Step 2: window tab-grouping ---
    DWIN_COUNT = 0
    daemon_spawn_app(APP_CALC, 100, wt + 30, 260, 200)
    DWIN_WS[0] = 0
    daemon_spawn_app(APP_SYSMON, 380, wt + 30, 260, 200)
    DWIN_WS[1] = 0
    daemon_spawn_app(APP_SETTINGS, 200, wt + 80, 260, 200)
    DWIN_WS[2] = 0
    # All three visible before grouping.
    vis_before: int64 = 0
    vi: uint64 = 0
    while vi < DWIN_COUNT:
        if win_on_cur_ws(vi) != 0:
            vis_before = vis_before + 1
        vi = vi + 1
    if vis_before != 3:
        write_str(1, "[DE22] FAIL expected 3 visible windows pre-group\n")
        return
    gid: int32 = group_visible_windows()
    if gid == 0:
        write_str(1, "[DE22] FAIL group_visible_windows made no group\n")
        return
    if group_member_count(gid) != 3:
        write_str(1, "[DE22] FAIL group does not have 3 members\n")
        return
    # The whole group collapses to ONE visible window (the active tab).
    vis_after: int64 = 0
    vj: uint64 = 0
    while vj < DWIN_COUNT:
        if win_on_cur_ws(vj) != 0:
            vis_after = vis_after + 1
        vj = vj + 1
    if vis_after != 1:
        write_str(1, "[DE22] FAIL group did not collapse to one window\n")
        return
    # Locate the active member (the visible one).
    active: int64 = -1
    vk: uint64 = 0
    while vk < DWIN_COUNT:
        if DWIN_GROUP[vk] == gid and DWIN_GROUP_ACTIVE[vk] != 0:
            active = cast[int64](vk)
        vk = vk + 1
    if active < 0:
        write_str(1, "[DE22] FAIL group has no active member\n")
        return
    au: uint64 = cast[uint64](active)
    # Hit-test the tab strip: a point in the strip band hits tab 0; a point
    # above the strip (top of the title bar) misses it (so drag still works).
    tsy: int64 = DWIN_Y[au] + TITLE_H - GROUP_TAB_H + 1
    tsx0: int64 = DWIN_X[au] + 3
    if group_tab_at(au, tsx0, tsy) != 0:
        write_str(1, "[DE22] FAIL tab strip first cell did not hit tab 0\n")
        return
    if group_tab_at(au, tsx0, DWIN_Y[au] + 1) >= 0:
        write_str(1, "[DE22] FAIL tab strip leaked into the drag band\n")
        return
    # A point in the middle of the strip hits a later tab (>0).
    tw: int64 = group_tab_w(au)
    midx: int64 = DWIN_X[au] + 2 + tw + tw / 2
    if group_tab_at(au, midx, tsy) <= 0:
        write_str(1, "[DE22] FAIL middle of strip did not hit a later tab\n")
        return
    # Activate the second member (tab index 1): it becomes the lone visible
    # window and inherits the active member's frame.
    afx: int64 = DWIN_X[au]
    afy: int64 = DWIN_Y[au]
    na: int64 = group_activate_tab(gid, 1)
    if na < 0:
        write_str(1, "[DE22] FAIL group_activate_tab failed\n")
        return
    nu: uint64 = cast[uint64](na)
    if DWIN_GROUP_ACTIVE[nu] == 0:
        write_str(1, "[DE22] FAIL activated tab not marked active\n")
        return
    if DWIN_X[nu] != afx or DWIN_Y[nu] != afy:
        write_str(1, "[DE22] FAIL activated tab did not inherit the frame\n")
        return
    # Still exactly one visible group member after the switch.
    vis_sw: int64 = 0
    vm: uint64 = 0
    while vm < DWIN_COUNT:
        if win_on_cur_ws(vm) != 0:
            vis_sw = vis_sw + 1
        vm = vm + 1
    if vis_sw != 1:
        write_str(1, "[DE22] FAIL more than one tab visible after switch\n")
        return
    # Dissolve: every member stands alone + becomes visible again.
    group_dissolve(gid)
    vis_dis: int64 = 0
    vn: uint64 = 0
    while vn < DWIN_COUNT:
        if DWIN_GROUP[vn] != 0:
            write_str(1, "[DE22] FAIL ungroup left a group id\n")
            return
        if win_on_cur_ws(vn) != 0:
            vis_dis = vis_dis + 1
        vn = vn + 1
    if vis_dis != 3:
        write_str(1, "[DE22] FAIL ungroup did not reveal all windows\n")
        return
    write_str(1, "[DE22] tab-grouping OK\n")

    # --- Step 3: drag edge-flip ---
    DWIN_COUNT = 0
    CUR_WS = 1
    daemon_spawn_app(APP_CALC, 40, wt + 40, 200, 160)
    DWIN_WS[0] = 1
    es: uint64 = 0
    EFLIP_CTR = 0
    EFLIP_SIDE = 0
    EFLIP_COOLDOWN = 0
    # A cursor NOT at an edge never flips and never accrues dwell.
    if edge_flip_update(es, scr_w / 2, scr_w) != 0:
        write_str(1, "[DE22] FAIL edge-flip fired mid-screen\n")
        return
    if EFLIP_CTR != 0:
        write_str(1, "[DE22] FAIL edge-flip accrued dwell mid-screen\n")
        return
    # Jam the cursor at the LEFT margin: it should NOT flip until the dwell
    # threshold is met (a guard so a transient brush past the edge is safe).
    flipped: int32 = 0
    di: int32 = 0
    while di < EFLIP_DWELL - 1:
        if edge_flip_update(es, 0, scr_w) != 0:
            flipped = 1
        di = di + 1
    if flipped != 0:
        write_str(1, "[DE22] FAIL edge-flip fired before the dwell\n")
        return
    if CUR_WS != 1:
        write_str(1, "[DE22] FAIL workspace changed before the dwell\n")
        return
    # The dwell-completing call flips to the adjacent (left -> previous)
    # workspace AND carries the dragged window there.
    if edge_flip_update(es, 0, scr_w) == 0:
        write_str(1, "[DE22] FAIL edge-flip did not fire at the dwell\n")
        return
    if CUR_WS != 0:
        write_str(1, "[DE22] FAIL edge-flip did not switch workspace\n")
        return
    if DWIN_WS[es] != 0:
        write_str(1, "[DE22] FAIL edge-flip did not carry the window\n")
        return
    # A cooldown now suppresses an immediate re-flip even while still jammed.
    if edge_flip_update(es, 0, scr_w) != 0:
        write_str(1, "[DE22] FAIL edge-flip re-fired during cooldown\n")
        return
    # Leaving the band mid-dwell resets the counter (no stale dwell carries
    # over into the next edge press).
    EFLIP_COOLDOWN = 0
    EFLIP_CTR = 0
    EFLIP_SIDE = 0
    edge_flip_update(es, scr_w - 1, scr_w)   # jam right -> dwell starts
    edge_flip_update(es, scr_w / 2, scr_w)   # leave band -> reset
    if EFLIP_CTR != 0 or EFLIP_SIDE != 0:
        write_str(1, "[DE22] FAIL leaving the band did not reset dwell\n")
        return
    write_str(1, "[DE22] edge-flip OK\n")

    # --- Reset to a clean desktop ---
    DWIN_COUNT = 0
    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    EFLIP_CTR = 0
    EFLIP_SIDE = 0
    EFLIP_COOLDOWN = 0
    daemon_present()
    write_str(1, "[DE22] PASS\n")


# ====================================================================
# ROUND-23 MATE-feel self-test (autoflag == 33)
# ====================================================================
# Virtual-workspace render isolation + the pager occupancy mini-map. The
# whole workspace machinery (CUR_WS, DWIN_WS, the pager applet, click-to-
# switch, Move-to-Workspace, sticky windows) was built across rounds 8-22;
# round 23 closes the remaining gap by PROVING, deterministically and by
# sampling composited pixels, the two invariants a MATE pager promises:
#
#   1. RENDER ISOLATION: a window created on workspace 0 is composited on
#      ws0, is NOT composited after switching to ws1, and IS composited
#      again after switching back to ws0 (per-workspace position/z-order
#      preserved — the same body pixel lights up each time).
#   2. PAGER OCCUPANCY: pager_window_count(ws) — the exact population the
#      pager mini-map paints — reflects per-workspace window counts as
#      windows are placed on, and relocated between, desktops; a sticky
#      window is counted in EVERY cell.
#
# It also re-checks the click-to-switch path and the Move-to-Workspace
# relocation through window_to_workspace(), so the round is a self-contained
# regression gate for "do virtual desktops actually hide/show windows and
# does the pager reflect them". Emits "[DE23] PASS" / "[DE23] FAIL <reason>".
def daemon_round23_selftest(scr_w: int64, scr_h: int64):
    DWIN_COUNT = 0
    CUR_WS = 0
    WS_COUNT = 4
    PANEL_POS = 0
    SHOW_ALL_WS = 0
    SESSION_OPEN = 0
    DAEMON_QUIT = 0
    MENU_OPEN = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    PREV_BTN_L = 0
    scheme_palette_init()
    scheme_set(0)
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)

    # --- Step 1: empty pager — every cell reports zero windows ---
    ce: int32 = 0
    while ce < WS_COUNT:
        if pager_window_count(ce) != 0:
            write_str(1, "[DE23] FAIL empty pager cell not zero\n")
            return
        ce = ce + 1
    write_str(1, "[DE23] empty pager OK\n")

    # --- Step 2: window on ws0, visible + counted in cell 0 only ---
    win_x: int64 = 300
    win_y: int64 = 130
    win_w: int64 = 320
    win_h: int64 = 220
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[DE23] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    DWIN_WS[sl] = 0
    # A body pixel (clear of title bar + borders).
    bx: int64 = DWIN_X[sl] + DWIN_W[sl] / 2
    by: int64 = DWIN_Y[sl] + TITLE_H + 30
    if pager_window_count(0) != 1:
        write_str(1, "[DE23] FAIL ws0 count not 1 after spawn\n")
        return
    if pager_window_count(1) != 0:
        write_str(1, "[DE23] FAIL ws1 count not 0 after spawn\n")
        return
    s_vis0: uint64 = daemon_screen_sample(bx, by)
    if s_vis0 == bg:
        write_str(1, "[DE23] FAIL window not composited on its own ws0\n")
        return
    write_str(1, "[DE23] window visible + counted on ws0\n")

    # --- Step 3: switch to ws1 — window not composited, count moves ---
    workspace_switch(1)
    if CUR_WS != 1:
        write_str(1, "[DE23] FAIL workspace_switch did not change CUR_WS\n")
        return
    s_hid: uint64 = daemon_screen_sample(bx, by)
    if s_hid != bg:
        write_str(1, "[DE23] FAIL window still composited after ws switch\n")
        return
    # The pager STILL knows the window lives on ws0 (count is per-ws, not
    # per-current-ws) — proving the mini-map of cell 0 stays populated.
    if pager_window_count(0) != 1:
        write_str(1, "[DE23] FAIL ws0 count lost after switching away\n")
        return
    if pager_window_count(1) != 0:
        write_str(1, "[DE23] FAIL ws1 count wrong on empty desktop\n")
        return
    write_str(1, "[DE23] window hidden on ws1, pager still counts ws0\n")

    # --- Step 4: switch back to ws0 — window composited again, same pixel ---
    workspace_switch(0)
    s_vis1: uint64 = daemon_screen_sample(bx, by)
    if s_vis1 == bg:
        write_str(1, "[DE23] FAIL window not restored on ws0\n")
        return
    if s_vis1 != s_vis0:
        write_str(1, "[DE23] FAIL restored pixel differs (position/z not preserved)\n")
        return
    write_str(1, "[DE23] window restored on ws0\n")

    # --- Step 5: Send window to workspace 2 (the Move-to-Workspace path) ---
    window_to_workspace(sl, 2)
    if DWIN_WS[sl] != 2:
        write_str(1, "[DE23] FAIL window_to_workspace did not relocate\n")
        return
    # Counts followed the window across the pager.
    if pager_window_count(0) != 0:
        write_str(1, "[DE23] FAIL ws0 still counts a moved-away window\n")
        return
    if pager_window_count(2) != 1:
        write_str(1, "[DE23] FAIL ws2 count not 1 after move\n")
        return
    # The window (now on ws2) is no longer composited on the current ws0.
    s_moved: uint64 = daemon_screen_sample(bx, by)
    if s_moved != bg:
        write_str(1, "[DE23] FAIL moved-away window still composited on ws0\n")
        return
    write_str(1, "[DE23] send-to-workspace OK (pager count followed)\n")

    # --- Step 6: sticky window is counted in EVERY pager cell ---
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             120, 130, 240, 160)
    sk: uint64 = DWIN_COUNT - 1
    DWIN_WS[sk] = 0
    DWIN_STICKY[sk] = 1
    ck: int32 = 0
    while ck < WS_COUNT:
        want: int64 = 1                  # the sticky window, in every cell
        if ck == 2:
            want = 2                      # plus the moved window living on ws2
        if pager_window_count(ck) != want:
            write_str(1, "[DE23] FAIL sticky window not counted in every cell\n")
            return
        ck = ck + 1
    write_str(1, "[DE23] sticky pager occupancy OK\n")

    # --- Step 7: pager-cell CLICK switches the current workspace ---
    px0: int64 = pager_x0(scr_w)
    cell3_cx: int64 = px0 + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    CUR_X = iclamp(cell3_cx, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CUR_WS != 2:
        write_str(1, "[DE23] FAIL pager click did not switch workspace\n")
        return
    write_str(1, "[DE23] pager click OK\n")

    # --- Reset to a clean desktop ---
    DWIN_COUNT = 0
    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE23] PASS\n")


# ====================================================================
# TRAY-LAYOUT self-test (autoflag == 34)
# ====================================================================
# Regression for the "green and blue status bars near the clock drawn on
# top of each other" defect. Two independent indicator zones live on the
# right of the panel: the older notification stub (notif_x0 / NOTIF_W,
# network + info-dot icons) and the newer status-notifier zone
# (statnot_x0 / STATNOT_W, battery + network + volume cells). The bug was
# that statnot_x0 used a standalone formula (scr_w - NOTIF_W - STATNOT_W
# - 4) that ignored CLOCK_W and SD_BTN_W, so the status-notifier zone
# landed ON TOP of the notification stub (and the show-desktop button),
# overlapping the green/blue indicator bars.
#
# This test injects NO QEMU mouse/keys. It asserts pure geometry: the
# whole right-edge applet chain tiles left-to-right WITHOUT overlap, and
# within the status-notifier zone each indicator cell occupies a distinct
# x-range. Emits "[DETRAY] PASS" / "[DETRAY] FAIL <reason>".
def daemon_tray_layout_selftest(scr_w: int64, scr_h: int64):
    PANEL_POS = 0
    WS_COUNT = 4
    # Right-edge applet chain, expressed as [x0, x1) half-open spans.
    clk_x0: int64 = scr_w - CLOCK_W
    clk_x1: int64 = scr_w
    sd_x0: int64 = sd_btn_x0(scr_w)
    sd_x1: int64 = sd_x0 + SD_BTN_W
    ntf_x0: int64 = notif_x0(scr_w)
    ntf_x1: int64 = ntf_x0 + NOTIF_W
    sn_x0: int64 = statnot_x0(scr_w)
    sn_x1: int64 = sn_x0 + STATNOT_W
    ws_x0: int64 = winsel_btn_x(scr_w)
    ws_x1: int64 = ws_x0 + WINSEL_BTN_W
    pg_x0: int64 = pager_x0(scr_w)
    pg_x1: int64 = pg_x0 + pager_total_w()

    # 1) Each zone must be ordered strictly left of the one to its right,
    #    so adjacent zones never share a pixel column. Walking the chain
    #    from the pager (leftmost) to the clock (rightmost):
    #      pager < winsel < statnot < notif < show-desktop < clock
    if pg_x1 > ws_x0:
        write_str(1, "[DETRAY] FAIL pager overlaps window-selector\n")
        return
    if ws_x1 > sn_x0:
        write_str(1, "[DETRAY] FAIL window-selector overlaps status-notifier\n")
        return
    # THE regression: the status-notifier (green/blue bars) must end
    # strictly before the notification stub begins.
    if sn_x1 > ntf_x0:
        write_str(1, "[DETRAY] FAIL status-notifier overlaps notification area (the green/blue bars overlap)\n")
        return
    if ntf_x1 > sd_x0:
        write_str(1, "[DETRAY] FAIL notification area overlaps show-desktop button\n")
        return
    if sd_x1 > clk_x0:
        write_str(1, "[DETRAY] FAIL show-desktop button overlaps clock\n")
        return
    # And the whole chain must fit on-screen with a positive leftmost x.
    if pg_x0 < 0 or clk_x1 > scr_w:
        write_str(1, "[DETRAY] FAIL applet chain runs off-screen\n")
        return
    write_str(1, "[DETRAY] chain-no-overlap OK\n")

    # 2) Within the status-notifier zone, the three indicator cells must
    #    tile in order with no two cells sharing a pixel column. statnot_cell_x
    #    returns each cell's left edge; each cell is STATNOT_ICON wide.
    ci: int64 = 0
    prev_x1: int64 = sn_x0
    while ci < STATNOT_CELLS:
        cx0: int64 = statnot_cell_x(ci, scr_w)
        cx1: int64 = cx0 + STATNOT_ICON
        if cx0 < prev_x1:
            write_str(1, "[DETRAY] FAIL status-notifier cell overlaps its neighbour\n")
            return
        if cx1 > sn_x1:
            write_str(1, "[DETRAY] FAIL status-notifier cell runs past the zone\n")
            return
        # A pixel in the middle of this cell must resolve to THIS cell.
        mid: int64 = cx0 + STATNOT_ICON / 2
        if statnot_cell_at(mid, PANEL_H / 2, scr_w) != ci:
            write_str(1, "[DETRAY] FAIL status-notifier cell hit-test misroutes\n")
            return
        prev_x1 = cx1
        ci = ci + 1
    write_str(1, "[DETRAY] statnot-cells OK\n")

    # 3) Within the notification stub, the three icon cells must likewise
    #    tile without overlap. Cell i left edge = ntf_x0 + PAD + i*(ICON+PAD).
    ni: int64 = 0
    nprev_x1: int64 = ntf_x0
    while ni < NOTIF_CELLS:
        nx0: int64 = ntf_x0 + NOTIF_PAD + ni * (NOTIF_ICON + NOTIF_PAD)
        nx1: int64 = nx0 + NOTIF_ICON
        if nx0 < nprev_x1:
            write_str(1, "[DETRAY] FAIL notification icon overlaps its neighbour\n")
            return
        if nx1 > ntf_x1:
            write_str(1, "[DETRAY] FAIL notification icon runs past the zone\n")
            return
        nprev_x1 = nx1
        ni = ni + 1
    write_str(1, "[DETRAY] notif-cells OK\n")

    write_str(1, "[DETRAY] PASS\n")


# ====================================================================
# DE-BUGFIX self-test (autoflag == 35)
# ====================================================================
# Covers the two DE bug fixes that are best proven by exercising real
# program behaviour rather than pure geometry:
#
#   P2a — the "Welcome to Hamnix" banner must dismiss on a WALL-CLOCK
#         deadline, not a present-frame count. We post a banner, then age
#         it ONLY via notify_tick() (no presents at all) while busy-waiting
#         on the real jiffy clock past the solid+fade budget, and assert it
#         goes inactive. A frame-count-based banner would stay up forever
#         here because we never present.
#
#   P1b — the file manager (/bin/hamfm) must open a real window rooted at
#         the requested directory passed as argv[1]. We spawn it through
#         the SAME places_open() path the Places menu uses, then poll the
#         window's stdout pipe for hamfm's HAMFM_READY marker, proving the
#         child actually launched into a working browser (not a console-
#         bleed crash).
#
# Emits "[DEBUG] ..." markers and ends with "[DEBUG] PASS".
def daemon_debugfix_selftest(scr_w: int64, scr_h: int64):
    # ---------------- P2a: wall-clock banner dismissal -----------------
    notify_post("Welcome to Hamnix", "Click Applications to launch an app")
    if NOTIFY_ACTIVE == 0:
        write_str(1, "[DEBUG] FAIL banner not active right after post\n")
        return
    # Age the banner WITHOUT presenting. Wait on the real jiffy clock until
    # we are past the solid+fade budget, calling notify_tick() each pass and
    # yielding so the timer tick keeps advancing jiffies (a tight no-yield
    # spin would starve the clock). A present-COUNT banner would never expire
    # here because we present 0 frames; only a WALL-CLOCK banner clears.
    budget: uint64 = NOTIFY_SOLID_JIFFIES + NOTIFY_FADE_JIFFIES
    start_j: uint64 = sys_get_jiffies()
    cleared_at: uint64 = 0
    # Run until the banner clears (and record WHEN), or until we have waited
    # comfortably past the budget — whichever comes first. guard only bounds
    # the loop if the jiffy clock is wedged, which would itself be a bug.
    guard: uint64 = 0
    while NOTIFY_ACTIVE != 0 and guard < 200000000:
        notify_tick()
        if NOTIFY_ACTIVE == 0:
            cleared_at = sys_get_jiffies()
        sys_yield()
        guard = guard + 1
    if NOTIFY_ACTIVE != 0:
        write_str(1, "[DEBUG] FAIL banner never dismissed on wall clock\n")
        return
    # It must have stayed up for at least the solid+fade budget (proving the
    # dismissal was driven by elapsed time, not an immediate present-count).
    # Measure from NOTIFY_POST_JIFFY — the SAME time-zero the banner's own
    # dismissal uses — not from start_j (captured a few instructions later):
    # a timer tick landing between notify_post() and the start_j read made
    # cleared_at-start_j == budget-1 and spuriously failed this assertion.
    if cleared_at - NOTIFY_POST_JIFFY < budget:
        write_str(1, "[DEBUG] FAIL banner dismissed BEFORE its wall-clock budget\n")
        return
    write_str(1, "[DEBUG] banner wall-clock dismissal OK\n")

    # ---------------- P1b: file manager opens rooted at a directory -----
    # The DE file manager is now the in-compositor icon-grid app APP_FILEMGR
    # (no child process / no HAMFM_READY pipe marker). Assert places_open
    # creates exactly that app, rooted at the requested directory, with a
    # populated icon grid (the intent the old text-process test asserted).
    pre_wins: uint64 = DWIN_COUNT
    fm_dir: Ptr[uint8] = "/etc"
    places_open(cast[Ptr[char]](fm_dir), scr_w, scr_h)
    if DWIN_COUNT != pre_wins + 1:
        write_str(1, "[DEBUG] FAIL file-manager window not created\n")
        return
    fm_slot: uint64 = DWIN_COUNT - 1
    if DWIN_APP[fm_slot] != APP_FILEMGR:
        write_str(1, "[DEBUG] FAIL file manager is not the in-compositor app\n")
        return
    if cstr_eq(fm_path_ptr(fm_slot), fm_dir) == 0:
        write_str(1, "[DEBUG] FAIL file manager not rooted at the requested dir\n")
        return
    if FM_COUNT[fm_slot] == 0:
        write_str(1, "[DEBUG] FAIL file manager enumerated no entries\n")
        return
    write_str(1, "[DEBUG] file-manager window opened (APP_FILEMGR rooted) OK\n")

    write_str(1, "[DEBUG] PASS\n")


# ====================================================================
# DEUSE — DE-usability self-test (autoflag == 37)
# ====================================================================
# Deterministically exercises and asserts the three user-reported usability
# fixes WITHOUT a real framebuffer/GPU. Emits "[DEUSE] ..." markers and ends
# with "[DEUSE] PASS" or "[DEUSE] FAIL".
#
#   BUG 1 (keystroke loss): feed a known N-byte printable sequence through the
#     SAME path daemon_pump_keys uses (key_process_chunk -> key_route -> the
#     focused window's child-stdin pipe), in 256-byte chunks that mirror the
#     real per-frame drain, and assert ALL N bytes arrive in the pipe — even
#     when we simulate a slow-frame backlog by queueing far more bytes than the
#     old 16x256 per-frame cap would have drained. With the old cap a single
#     pump dropped everything past 4096 bytes; the full-drain loop keeps none.
#
#   BUG 3 (context-menu width): open the panel (kind-4) menu via ctx_open_at
#     and assert the computed box width (CTX_W) is >= the widest label's
#     rendered text width + padding, so no label is clipped. Also assert the
#     hit-test box (ctx_item_at) uses that same width.
#
#   BUG 2 (perf): assert (a) a hover-only highlight change does NOT escalate to
#     a full present (MOUSE_SCENE_DIRTY stays 0; only the affected window rects
#     are damaged) and (b) the per-pixel window-compositing cost is window-count
#     INDEPENDENT — a pixel covered by an opaque top window over a deep stack
#     evaluates only the visible top window (occlusion skip), so DPIX_WIN_VISITS
#     does not grow with the number of fully-occluded windows beneath it.
def daemon_deusability_selftest(scr_w: int64, scr_h: int64):
    # ---------------- BUG 1: keystroke integrity under backlog ----------
    # Spawn a built-in window (no child process to race the pipe) and give it a
    # real stdin pipe whose read end we drain ourselves — so we can count the
    # bytes key_route actually delivered.
    daemon_spawn_app(APP_SYSMON, 100, 80, 360, 220)
    if DWIN_COUNT < 1:
        write_str(1, "[DEUSE] FAIL could not spawn keystroke target window\n")
        return
    kslot: uint64 = DWIN_COUNT - 1
    kp: Array[2, int32]
    if sys_pipe(&kp[0]) != 0:
        write_str(1, "[DEUSE] FAIL could not create test stdin pipe\n")
        return
    kp_rd: int32 = kp[0]
    kp_wr: int32 = kp[1]
    DWIN_IN_FD[kslot] = kp_wr            # focused-window stdin = our pipe
    fslot: int64 = daemon_focus_slot()
    if fslot != cast[int64](kslot):
        write_str(1, "[DEUSE] FAIL spawned window is not the focused slot\n")
        return
    # Total bytes to push: 5000 printable 'A's — DELIBERATELY more than the old
    # 16x256 = 4096 per-frame drain cap, so the old code would have stranded
    # ~900 bytes in the ring. We feed in 256-byte chunks (the real drain unit)
    # and drain the pipe read end after each chunk (mirroring a slow shell that
    # eventually consumes its input). key_route's partial-write loop guarantees
    # every byte lands; we count what arrives.
    total_in: int64 = 5000
    sent: int64 = 0
    got: int64 = 0
    drain: Array[512, uint8]
    guard: int64 = 0
    while sent < total_in and guard < 100000:
        guard = guard + 1
        chunk: int64 = 256
        if sent + chunk > total_in:
            chunk = total_in - sent
        ci: int64 = 0
        while ci < chunk:
            cons_rx[cast[uint64](ci)] = 65          # 'A'
            ci = ci + 1
        # Same entry point the real per-frame drain feeds each chunk into.
        key_process_chunk(cast[uint64](chunk), fslot, scr_w, scr_h)
        sent = sent + chunk
        # Drain the pipe read end (the "shell consumes its input" step).
        dn: int64 = sys_read_nb(kp_rd, &drain[0], 512)
        while dn > 0:
            got = got + dn
            dn = sys_read_nb(kp_rd, &drain[0], 512)
    # Final drain in case bytes remain buffered.
    dn2: int64 = sys_read_nb(kp_rd, &drain[0], 512)
    while dn2 > 0:
        got = got + dn2
        dn2 = sys_read_nb(kp_rd, &drain[0], 512)
    sys_close(kp_rd)
    sys_close(kp_wr)
    DWIN_IN_FD[kslot] = -1
    kline: Array[120, uint8]
    kpz: uint64 = 0
    kpz = sm_puts(&kline[0], kpz, "[DEUSE] keystrokes sent=")
    kpz = kpz + u64_to_dec(cast[uint64](sent), &kline[kpz])
    kpz = sm_puts(&kline[0], kpz, " delivered=")
    kpz = kpz + u64_to_dec(cast[uint64](got), &kline[kpz])
    kline[kpz] = 10
    kpz = kpz + 1
    sys_write(1, &kline[0], kpz)
    if got != total_in:
        write_str(1, "[DEUSE] FAIL keystrokes dropped (delivered != sent)\n")
        return
    write_str(1, "[DEUSE] keystroke integrity: NONE dropped under backlog OK\n")

    # ---------------- BUG 3: panel context-menu width ------------------
    # Open the panel (kind-4) menu and assert the box fits its widest label.
    ctx_open_at(4, -1, 200, scr_h - 1, scr_w, scr_h)
    if CTX_OPEN == 0 or CTX_KIND != 4:
        write_str(1, "[DEUSE] FAIL panel context menu did not open\n")
        return
    n4: uint64 = ctx_count()
    widest: int64 = 0
    wi4: uint64 = 0
    while wi4 < n4:
        lw: int64 = cast[int64](strlen_u8(ctx_item_label(wi4))) * GLYPH_W
        if lw > widest:
            widest = lw
        wi4 = wi4 + 1
    need: int64 = widest + CTX_PAD_L + CTX_PAD_R
    cline: Array[120, uint8]
    cpz: uint64 = 0
    cpz = sm_puts(&cline[0], cpz, "[DEUSE] panel menu CTX_W=")
    cpz = cpz + u64_to_dec(cast[uint64](CTX_W), &cline[cpz])
    cpz = sm_puts(&cline[0], cpz, " widest_label_px=")
    cpz = cpz + u64_to_dec(cast[uint64](widest), &cline[cpz])
    cpz = sm_puts(&cline[0], cpz, " need=")
    cpz = cpz + u64_to_dec(cast[uint64](need), &cline[cpz])
    cline[cpz] = 10
    cpz = cpz + 1
    sys_write(1, &cline[0], cpz)
    if CTX_W < need:
        write_str(1, "[DEUSE] FAIL panel menu box too narrow -> label clipped\n")
        return
    # The widest label, drawn at CTX_X + CTX_PAD_L, must end strictly inside the
    # box's right edge (CTX_X + CTX_W) — i.e. no glyph is cut off.
    if CTX_X + CTX_PAD_L + widest > CTX_X + CTX_W:
        write_str(1, "[DEUSE] FAIL widest panel label overruns the box right edge\n")
        return
    # Hit-testing must use the SAME width so clicks still land across the box.
    if ctx_item_at(CTX_X + CTX_W - 2, CTX_Y + CTX_ITEM_H / 2) != 0:
        write_str(1, "[DEUSE] FAIL hit-test near right edge missed row 0\n")
        return
    CTX_OPEN = 0
    write_str(1, "[DEUSE] panel context menu box fits its widest label OK\n")

    # ---------------- BUG 2a: no full present on hover-only move --------
    # Simulate a hover-highlight-only change: a different title-bar button lit
    # under the moving cursor, with NO button/drag/menu active. Assert this
    # does NOT set MOUSE_SCENE_DIRTY (which would force damage_full()) — it sets
    # the cheap MOUSE_HOVER_DIRTY path instead.
    MOUSE_SCENE_DIRTY = 0
    MOUSE_HOVER_DIRTY = 0
    hov_before: int32 = HOVER_BTN
    hovs_before: int32 = HOVER_SLOT
    # Force a hover-state change directly (model-level), then run the same
    # classification the packet path uses.
    HOVER_SLOT = cast[int64](kslot)
    HOVER_BTN = 0
    if PREV_BTN_L == 0 and PREV_BTN_R == 0 and DRAG_ACTIVE == 0 \
       and RESIZE_SLOT < 0 and GESTURE != 4 and MENU_BAR_OPEN < 0 \
       and CTX_OPEN == 0 and CAL_OPEN == 0 and CYCLE_OPEN == 0 \
       and SESSION_OPEN == 0 and RUN_OPEN == 0 and SEARCH_OPEN == 0 \
       and KMODE == 0 \
       and (HOVER_BTN != hov_before or HOVER_SLOT != hovs_before):
        MOUSE_HOVER_DIRTY = 1
    else:
        MOUSE_SCENE_DIRTY = 1
    if MOUSE_SCENE_DIRTY != 0:
        write_str(1, "[DEUSE] FAIL hover-only move escalated to a FULL present\n")
        return
    if MOUSE_HOVER_DIRTY == 0:
        write_str(1, "[DEUSE] FAIL hover-only move produced no targeted damage\n")
        return
    MOUSE_HOVER_DIRTY = 0
    write_str(1, "[DEUSE] hover-only pointer move stays off the full-present path OK\n")

    # ---------------- BUG 2b: per-pixel cost is window-count bounded ----
    # Stack many OPAQUE windows over the same screen point. daemon_pixel's
    # occlusion skip must evaluate only the topmost opaque coverer, so the
    # window-visit count for one pixel does NOT grow with the stack depth.
    # Measure with a shallow stack, then a deep stack, over a common pixel.
    px: int64 = 220
    py: int64 = 160
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    # Shallow: ensure at least 1 window covers (px,py). The sysmon window above
    # is at (100,80,360,220) and already covers it. Measure.
    DPIX_WIN_VISITS = 0
    daemon_pixel(px, py, &rr[0], &gg[0], &bb[0])
    visits_shallow: int64 = DPIX_WIN_VISITS
    shallow_wins: uint64 = DWIN_COUNT
    # Deep: open up to DMAX opaque windows all covering (px,py).
    fill: int64 = 0
    while DWIN_COUNT < DMAX and fill < 16:
        daemon_spawn_app(APP_TERM, 120, 100, 320, 200)
        fill = fill + 1
    deep_wins: uint64 = DWIN_COUNT
    DPIX_WIN_VISITS = 0
    daemon_pixel(px, py, &rr[0], &gg[0], &bb[0])
    visits_deep: int64 = DPIX_WIN_VISITS
    pline: Array[160, uint8]
    ppz: uint64 = 0
    ppz = sm_puts(&pline[0], ppz, "[DEUSE] occlusion: shallow_wins=")
    ppz = ppz + u64_to_dec(shallow_wins, &pline[ppz])
    ppz = sm_puts(&pline[0], ppz, " visits=")
    ppz = ppz + u64_to_dec(cast[uint64](visits_shallow), &pline[ppz])
    ppz = sm_puts(&pline[0], ppz, "  deep_wins=")
    ppz = ppz + u64_to_dec(deep_wins, &pline[ppz])
    ppz = sm_puts(&pline[0], ppz, " visits=")
    ppz = ppz + u64_to_dec(cast[uint64](visits_deep), &pline[ppz])
    pline[ppz] = 10
    ppz = ppz + 1
    sys_write(1, &pline[0], ppz)
    if deep_wins <= shallow_wins:
        write_str(1, "[DEUSE] FAIL could not deepen the window stack\n")
        return
    # THE CRUX: stacking MANY more opaque windows over the same pixel must NOT
    # increase the per-pixel window-visit count — the topmost opaque coverer
    # occludes everything below it.
    if visits_deep > visits_shallow:
        write_str(1, "[DEUSE] FAIL per-pixel compositing grew with window count\n")
        return
    write_str(1, "[DEUSE] per-pixel compositing is window-count INDEPENDENT (occlusion) OK\n")

    write_str(1, "[DEUSE] PASS\n")


# ====================================================================
# DEAPPS — file-manager + text-editor self-test (autoflag == 38)
# ====================================================================
# Proves the two new in-compositor desktop apps WITHOUT a real framebuffer
# — every assertion is pure model state driven through the SAME code paths
# the live DE uses (fm_load_dir / fm_open_cell for navigation; key_route /
# key_process_chunk for editor keystrokes; ed_load_path / ed_save for the
# file round-trip). Emits "[DEAPPS] ..." OK lines and ends with
# "[DEAPPS] PASS" or "[DEAPPS] FAIL".
#
# FILE MANAGER:
#   * point APP_FILEMGR at a known directory (/tmp, seeded with two files we
#     write here) and assert it enumerated them, classified each cell
#     dir-vs-file correctly, that clicking a folder cell (the "tmp" entry in
#     "/") changes the model's current path (navigation), and that the ".."
#     up affordance returns to the parent.
# EDITOR:
#   * open APP_EDITOR, feed a printable+Backspace+Enter+arrow sequence
#     through the focused-window key path and assert the buffer text + caret
#     are exactly right; then exercise load-from-path + save-to-path and
#     re-read the file to confirm the bytes match (round-trip).

# Write `data` to `path` directly (create/truncate). Returns bytes written
# or -1. Used to seed the file-manager test directory deterministically.
def deapps_write_file(path: Ptr[uint8], data: Ptr[uint8]) -> int64:
    fd: int32 = sys_open_write(cast[Ptr[char]](path))
    if fd < 0:
        return -1
    n: uint64 = strlen_u8(data)
    off: uint64 = 0
    while off < n:
        wn: int64 = sys_write(fd, cast[Ptr[uint8]](cast[uint64](data) + off),
                              n - off)
        if wn <= 0:
            off = off                   # give up; partial is fine for the test
            break
        off = off + cast[uint64](wn)
    sys_close(fd)
    return cast[int64](off)


# Find the cell index of a named entry in slot's current listing, or -1.
def deapps_find_cell(slot: uint64, name: Ptr[uint8]) -> int64:
    base_e: uint64 = slot * FM_MAX_ENTRIES
    cnt: int64 = cast[int64](FM_COUNT[slot])
    i: int64 = 0
    while i < cnt:
        if cstr_eq(fm_name_ptr(slot, cast[uint64](i)), name) != 0:
            return i
        i = i + 1
    return -1


def daemon_deapps_selftest(scr_w: int64, scr_h: int64):
    # ---------------- seed a known directory under /tmp ----------------
    fa: Ptr[uint8] = "/tmp/deapps_a.txt"
    fb: Ptr[uint8] = "/tmp/deapps_b.txt"
    if deapps_write_file(fa, "hello hamnix\n") < 0:
        write_str(1, "[DEAPPS] FAIL could not seed test file A\n")
        return
    if deapps_write_file(fb, "second file\n") < 0:
        write_str(1, "[DEAPPS] FAIL could not seed test file B\n")
        return
    write_str(1, "[DEAPPS] seeded /tmp/deapps_a.txt + /tmp/deapps_b.txt OK\n")

    # ---------------- file manager: enumerate /tmp ---------------------
    daemon_spawn_app(APP_FILEMGR, 60, 60, 480, 340)
    if DWIN_COUNT < 1:
        write_str(1, "[DEAPPS] FAIL could not spawn file-manager window\n")
        return
    fmslot: uint64 = DWIN_COUNT - 1
    fm_set_path(fmslot, "/tmp")
    fm_load_dir(fmslot)
    ca: int64 = deapps_find_cell(fmslot, "deapps_a.txt")
    cb: int64 = deapps_find_cell(fmslot, "deapps_b.txt")
    if ca < 0 or cb < 0:
        write_str(1, "[DEAPPS] FAIL file manager did not enumerate the seeded files\n")
        return
    base_t: uint64 = fmslot * FM_MAX_ENTRIES
    if FM_IS_DIR[base_t + cast[uint64](ca)] != 0 \
       or FM_IS_DIR[base_t + cast[uint64](cb)] != 0:
        write_str(1, "[DEAPPS] FAIL seeded regular files mis-classified as dirs\n")
        return
    eline: Array[96, uint8]
    epz: uint64 = 0
    epz = sm_puts(&eline[0], epz, "[DEAPPS] file manager enumerated /tmp entries=")
    epz = epz + u64_to_dec(FM_COUNT[fmslot], &eline[epz])
    epz = sm_puts(&eline[0], epz, " (files classified OK)\n")
    sys_write(1, &eline[0], epz)

    # ---------------- file manager: navigate "/" -> /etc -> "/" --------
    # The root listing comes from the cpio initramfs (which has dirs like
    # etc/ and bin/ but NO /tmp entry), so navigate via a real root child.
    daemon_spawn_app(APP_FILEMGR, 60, 60, 480, 340)
    nvslot: uint64 = DWIN_COUNT - 1
    fm_set_path(nvslot, "/")
    fm_load_dir(nvslot)
    etc_cell: int64 = deapps_find_cell(nvslot, "etc")
    if etc_cell < 0:
        write_str(1, "[DEAPPS] FAIL no 'etc' entry in root listing\n")
        return
    if FM_IS_DIR[nvslot * FM_MAX_ENTRIES + cast[uint64](etc_cell)] == 0:
        write_str(1, "[DEAPPS] FAIL 'etc' cell not classified as a directory\n")
        return
    # Click the folder cell -> the model's current path must become /etc.
    pre_count: uint64 = DWIN_COUNT
    fm_open_cell(nvslot, etc_cell, scr_w, scr_h)
    if cstr_eq(fm_path_ptr(nvslot), "/etc") == 0:
        write_str(1, "[DEAPPS] FAIL clicking 'etc' folder did not enter /etc\n")
        return
    if DWIN_COUNT != pre_count:
        write_str(1, "[DEAPPS] FAIL entering a folder spawned an unexpected window\n")
        return
    write_str(1, "[DEAPPS] file manager folder-click navigation /->/etc OK\n")
    # The ".." up affordance (cell 0 of a non-root dir) returns to the parent.
    upc: int64 = deapps_find_cell(nvslot, "..")
    if upc != 0:
        write_str(1, "[DEAPPS] FAIL up affordance ('..') not present as cell 0\n")
        return
    fm_open_cell(nvslot, 0, scr_w, scr_h)
    if cstr_eq(fm_path_ptr(nvslot), "/") == 0:
        write_str(1, "[DEAPPS] FAIL up affordance did not return to parent '/'\n")
        return
    write_str(1, "[DEAPPS] file manager up-affordance /etc->/ OK\n")

    # ---------------- editor: keystrokes through the focused key path --
    daemon_spawn_app(APP_EDITOR, 80, 80, 560, 400)
    edslot: uint64 = DWIN_COUNT - 1
    fsl: int64 = daemon_focus_slot()
    if fsl != cast[int64](edslot):
        write_str(1, "[DEAPPS] FAIL editor window is not the focused slot\n")
        return
    if DWIN_IN_FD[edslot] >= 0:
        write_str(1, "[DEAPPS] FAIL editor unexpectedly has a child stdin pipe\n")
        return
    # Feed: 'H' 'i' Enter 'X' Backspace  then a Left arrow.
    # Result buffer should be "Hi\n" (X inserted then deleted) and the caret,
    # after one Left from the line-2 start, should sit on the newline (offset 2).
    KEY_ST = 0                           # fresh key state machine for the test
    deapps_feed_literal(fsl, 72, scr_w, scr_h)   # 'H'
    deapps_feed_literal(fsl, 105, scr_w, scr_h)  # 'i'
    deapps_feed_literal(fsl, 13, scr_w, scr_h)   # Enter
    deapps_feed_literal(fsl, 88, scr_w, scr_h)   # 'X'
    deapps_feed_literal(fsl, 8, scr_w, scr_h)    # Backspace -> removes 'X'
    deapps_feed_arrow(fsl, 68, scr_w, scr_h)     # Left arrow (final 'D')
    ebuf: Ptr[uint8] = ed_buf_ptr(edslot)
    ok_txt: int32 = 1
    if ED_LEN[edslot] != 3:
        ok_txt = 0
    elif ebuf[0] != 72 or ebuf[1] != 105 or ebuf[2] != 10:
        ok_txt = 0
    if ok_txt == 0:
        write_str(1, "[DEAPPS] FAIL editor buffer text wrong after keystrokes\n")
        return
    if ED_CARET[edslot] != 2:
        cz: Array[64, uint8]
        czp: uint64 = 0
        czp = sm_puts(&cz[0], czp, "[DEAPPS] FAIL editor caret=")
        czp = czp + u64_to_dec(ED_CARET[edslot], &cz[czp])
        czp = sm_puts(&cz[0], czp, " expected 2\n")
        sys_write(1, &cz[0], czp)
        return
    write_str(1, "[DEAPPS] editor keystrokes (insert/backspace/enter/arrow) buffer+caret OK\n")

    # ---------------- editor: load-from-path + save round-trip ---------
    if ed_load_path(edslot, fa) < 0:
        write_str(1, "[DEAPPS] FAIL editor could not load /tmp/deapps_a.txt\n")
        return
    # The loaded buffer must equal the file we wrote ("hello hamnix\n" = 13B).
    want: Ptr[uint8] = "hello hamnix\n"
    wlen: uint64 = strlen_u8(want)
    lbuf: Ptr[uint8] = ed_buf_ptr(edslot)
    okld: int32 = 1
    if ED_LEN[edslot] != wlen:
        okld = 0
    else:
        m: uint64 = 0
        while m < wlen:
            if lbuf[m] != want[m]:
                okld = 0
                m = wlen
            else:
                m = m + 1
    if okld == 0:
        write_str(1, "[DEAPPS] FAIL editor load-from-path contents mismatch\n")
        return
    # Append a printable char, then save to a NEW path; re-read and compare.
    ed_insert(edslot, 33)                # '!'
    fc: Ptr[uint8] = "/tmp/deapps_saved.txt"
    ed_set_path(edslot, fc)
    saved: int64 = ed_save(edslot)
    if saved < 0:
        write_str(1, "[DEAPPS] FAIL editor save-to-path failed\n")
        return
    # Re-read the saved file independently and compare to the buffer.
    rfd: int32 = sys_open(cast[Ptr[char]](fc))
    if rfd < 0:
        write_str(1, "[DEAPPS] FAIL could not re-open the saved file\n")
        return
    rbuf: Array[256, uint8]
    rn: int64 = sys_read(rfd, &rbuf[0], 256)
    sys_close(rfd)
    okrt: int32 = 1
    if rn != cast[int64](ED_LEN[edslot]):
        okrt = 0
    else:
        q: int64 = 0
        while q < rn:
            if rbuf[cast[uint64](q)] != lbuf[cast[uint64](q)]:
                okrt = 0
                q = rn
            else:
                q = q + 1
    if okrt == 0:
        write_str(1, "[DEAPPS] FAIL editor save round-trip bytes mismatch\n")
        return
    rline: Array[80, uint8]
    rpz: uint64 = 0
    rpz = sm_puts(&rline[0], rpz, "[DEAPPS] editor load+save round-trip bytes=")
    rpz = rpz + u64_to_dec(cast[uint64](rn), &rline[rpz])
    rpz = sm_puts(&rline[0], rpz, " match OK\n")
    sys_write(1, &rline[0], rpz)

    write_str(1, "[DEAPPS] PASS\n")


# Feed one literal keystroke byte through the real focused-window key path
# (key_process_chunk's ground-state literal run). Used by the DEAPPS editor
# proof so the bytes traverse exactly the code the live keyboard drives.
def deapps_feed_literal(fslot: int64, c: uint8, scr_w: int64, scr_h: int64):
    cons_rx[0] = c
    key_process_chunk(1, fslot, scr_w, scr_h)


# Feed one arrow key (CSI final 'A'/'B'/'C'/'D') through the real key path.
def deapps_feed_arrow(fslot: int64, final: uint8, scr_w: int64, scr_h: int64):
    cons_rx[0] = 27                      # ESC
    cons_rx[1] = 91                      # '['
    cons_rx[2] = final                   # 'A'/'B'/'C'/'D'
    key_process_chunk(3, fslot, scr_w, scr_h)


# ====================================================================
# DEWM — MATE/Marco window-management self-test (autoflag == 39)
# ====================================================================
# Proves the four MATE-parity window operations WITHOUT a real framebuffer
# — every assertion is pure model state driven through the SAME code paths
# the live DE uses (the maximize-button toggle is window_toggle_maximize;
# the title-bar double-click is window_toggle_shade; edge tiling is
# snap_zone_for + snap_apply; the
# minimize box sets DWIN_HIDDEN and the panel window-list is taskbar_lists_
# slot / taskbar_slot_at; workspace render-isolation is win_on_cur_ws gated
# by workspace_switch / window_to_workspace, with the Ctrl-Alt-arrow path
# driven through workspace_step). Emits "[DEWM] ..." OK lines and ends with
# "[DEWM] PASS" or "[DEWM] FAIL".
#
#   MAXIMIZE/RESTORE: the maximize titlebar button toggles
#     window_toggle_maximize: the rect becomes the
#     full work area (screen minus the panel) and the pre-maximize rect is
#     remembered EXACTLY, so a second toggle restores it byte-for-byte.
#
#   LEFT-EDGE SNAP: a move-drag whose pointer hits the left screen edge is
#     classified by snap_zone_for as mode 2 (left half) and snap_apply tiles
#     the window to the left half of the work area, stashing the pre-snap
#     rect; un-snapping (snap_apply mode 0, the drag-away release) restores
#     the float rect EXACTLY.
#
#   MINIMIZE TO PANEL + RESTORE: the minimize box sets DWIN_HIDDEN so the
#     window leaves the composited / visible set (win_on_cur_ws -> 0) while a
#     panel window-list entry still lists it (taskbar_lists_slot -> 1 and
#     taskbar_slot_at finds its button); clicking that entry clears HIDDEN
#     and raises it (daemon_raise_slot) so it is visible AND focused again.
#
#   WORKSPACES: a window moved to workspace 2 (window_to_workspace) does NOT
#     composite while workspace 1 is current (win_on_cur_ws -> 0) and DOES
#     after switching to workspace 2 (win_on_cur_ws -> 1). The Ctrl-Alt-Right
#     keyboard path (workspace_step(+1)) drives that switch.

# Emit "[DEWM] <label> ws_rect=<x>,<y>,<w>,<h>" for a window slot — a small
# diagnostic helper used by the maximize/snap proofs so the serial log shows
# the exact geometry each assertion checked.
def dewm_print_rect(label: Ptr[uint8], slot: uint64):
    rl: Array[160, uint8]
    rp: uint64 = 0
    rp = sm_puts(&rl[0], rp, "[DEWM] ")
    rp = sm_puts(&rl[0], rp, label)
    rp = sm_puts(&rl[0], rp, " rect=")
    rp = rp + u64_to_dec(cast[uint64](DWIN_X[slot]), &rl[rp])
    rl[rp] = 44                          # ','
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_Y[slot]), &rl[rp])
    rl[rp] = 44
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_W[slot]), &rl[rp])
    rl[rp] = 44
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_H[slot]), &rl[rp])
    rl[rp] = 10
    rp = rp + 1
    sys_write(1, &rl[0], rp)


# 1 if window `slot`'s live rect equals (x,y,w,h), else 0.
def dewm_rect_eq(slot: uint64, x: int64, y: int64, w: int64, h: int64) -> int32:
    if DWIN_X[slot] == x and DWIN_Y[slot] == y \
       and DWIN_W[slot] == w and DWIN_H[slot] == h:
        return 1
    return 0


def daemon_dewm_selftest(scr_w: int64, scr_h: int64):
    # Start from a clean workspace state (the daemon defaults to ws 0; treat
    # it as "workspace 1" for the MATE-numbered narrative).
    CUR_WS = 0

    # ================= MAXIMIZE / RESTORE ==============================
    # A floating window with a known rect. window_toggle_maximize is the
    # exact function the title-bar double-click AND the maximize titlebar
    # button both invoke.
    ox: int64 = 140
    oy: int64 = 90
    ow: int64 = 360
    oh: int64 = 240
    daemon_spawn_app(APP_SYSMON, ox, oy, ow, oh)
    if DWIN_COUNT < 1:
        write_str(1, "[DEWM] FAIL could not spawn maximize test window\n")
        return
    mslot: uint64 = DWIN_COUNT - 1
    if dewm_rect_eq(mslot, ox, oy, ow, oh) == 0:
        write_str(1, "[DEWM] FAIL spawn rect not as requested\n")
        return
    # Maximize (maximize titlebar button).
    window_toggle_maximize(mslot, scr_w, scr_h)
    dewm_print_rect("maximized", mslot)
    wt: int64 = work_top(scr_h)
    wh: int64 = work_h(scr_h)
    if DWIN_MAXED[mslot] == 0:
        write_str(1, "[DEWM] FAIL maximize did not set the maximized flag\n")
        return
    if dewm_rect_eq(mslot, 0, wt, scr_w, wh) == 0:
        write_str(1, "[DEWM] FAIL maximize rect != full work area (screen minus panel)\n")
        return
    write_str(1, "[DEWM] maximize fills the work area OK\n")
    # Restore (second toggle) -> the pre-maximize rect must come back EXACTLY.
    window_toggle_maximize(mslot, scr_w, scr_h)
    dewm_print_rect("restored", mslot)
    if DWIN_MAXED[mslot] != 0:
        write_str(1, "[DEWM] FAIL restore left the maximized flag set\n")
        return
    if dewm_rect_eq(mslot, ox, oy, ow, oh) == 0:
        write_str(1, "[DEWM] FAIL restore did not return the exact original rect\n")
        return
    write_str(1, "[DEWM] maximize/restore round-trips the exact original rect OK\n")

    # ================= LEFT-EDGE SNAP / UN-SNAP =======================
    # Simulate a title-drag whose pointer reaches the left screen edge.
    # snap_zone_for classifies it; snap_apply tiles it. Re-use the SAME
    # window (now restored to its float rect).
    sx: int64 = DWIN_X[mslot]
    sy: int64 = DWIN_Y[mslot]
    sw: int64 = DWIN_W[mslot]
    sh: int64 = DWIN_H[mslot]
    # Pointer parked on the left edge, mid-screen (clear of the top/bottom
    # corner bands so it classifies as the LEFT HALF, not a quarter tile).
    edge_cx: int64 = 0
    edge_cy: int64 = scr_h / 2
    zone: int32 = snap_zone_for(edge_cx, edge_cy, scr_w, scr_h)
    zl: Array[64, uint8]
    zp: uint64 = 0
    zp = sm_puts(&zl[0], zp, "[DEWM] left-edge snap zone=")
    zp = zp + u64_to_dec(cast[uint64](zone), &zl[zp])
    zl[zp] = 10
    zp = zp + 1
    sys_write(1, &zl[0], zp)
    if zone != 2:
        write_str(1, "[DEWM] FAIL left screen edge did not classify as left-half snap\n")
        return
    snap_apply(mslot, zone, scr_w, scr_h)
    dewm_print_rect("snapped-left", mslot)
    exp_w: int64 = scr_w / 2
    if dewm_rect_eq(mslot, 0, wt, exp_w, wh) == 0:
        write_str(1, "[DEWM] FAIL left snap rect != left half of the work area\n")
        return
    if DWIN_SNAP[mslot] != 2:
        write_str(1, "[DEWM] FAIL left snap did not record the snap mode\n")
        return
    write_str(1, "[DEWM] left-edge snap tiles to the left half OK\n")
    # Drag away from the edge -> un-snap (mode 0) restores the float rect.
    snap_apply(mslot, 0, scr_w, scr_h)
    dewm_print_rect("un-snapped", mslot)
    if DWIN_SNAP[mslot] != 0:
        write_str(1, "[DEWM] FAIL un-snap left the snap mode set\n")
        return
    if dewm_rect_eq(mslot, sx, sy, sw, sh) == 0:
        write_str(1, "[DEWM] FAIL un-snap did not restore the exact pre-snap rect\n")
        return
    write_str(1, "[DEWM] left snap / un-snap round-trips the exact rect OK\n")

    # ================= MINIMIZE TO PANEL + RESTORE ====================
    # The window starts visible on the current workspace and IS listed by the
    # panel window-list (taskbar). Minimize (the minimize-box action) hides it
    # so it leaves the composite/visible set, but the window-list entry stays.
    if win_on_cur_ws(mslot) == 0:
        write_str(1, "[DEWM] FAIL window not visible before minimize\n")
        return
    if taskbar_lists_slot(mslot) == 0:
        write_str(1, "[DEWM] FAIL window not listed by the panel window-list before minimize\n")
        return
    # The panel window-list entry must be hit-testable at its button centre.
    btn_x0: int64 = taskbar_btn_x(mslot)
    btn_cx: int64 = btn_x0 + TASKBAR_BTN_W / 2
    btn_cy: int64 = TASKBAR_BTN_Y + TASKBAR_BTN_H / 2
    if taskbar_slot_at(btn_cx, btn_cy, scr_w) != cast[int64](mslot):
        write_str(1, "[DEWM] FAIL panel window-list button does not hit-test to the window\n")
        return
    # Minimize: the exact model mutation the minimize-box press performs.
    DWIN_HIDDEN[mslot] = 1
    if win_on_cur_ws(mslot) != 0:
        write_str(1, "[DEWM] FAIL minimize did not remove the window from the visible set\n")
        return
    # A minimized window is STILL listed on the panel (so it can be restored).
    if taskbar_lists_slot(mslot) == 0:
        write_str(1, "[DEWM] FAIL minimized window dropped off the panel window-list\n")
        return
    if taskbar_slot_at(btn_cx, btn_cy, scr_w) != cast[int64](mslot):
        write_str(1, "[DEWM] FAIL minimized window-list entry no longer hit-tests\n")
        return
    write_str(1, "[DEWM] minimize hides from composite + panel window-list entry remains OK\n")
    # Restore via the window-list button: un-hide + raise to focus (the exact
    # taskbar-click model path).
    DWIN_HIDDEN[mslot] = 0
    rslot: int64 = daemon_raise_slot(cast[int64](mslot))
    if rslot < 0:
        write_str(1, "[DEWM] FAIL window-list restore could not raise the window\n")
        return
    rs: uint64 = cast[uint64](rslot)
    if win_on_cur_ws(rs) == 0:
        write_str(1, "[DEWM] FAIL restore did not bring the window back to the visible set\n")
        return
    if daemon_focus_slot() != rslot:
        write_str(1, "[DEWM] FAIL restore did not focus the window (not front-most)\n")
        return
    write_str(1, "[DEWM] panel window-list restore brings the window back focused OK\n")

    # ================= WORKSPACES (virtual desktops) ==================
    # Put a window on workspace 2 and assert it does NOT composite while
    # workspace 1 is current, then DOES after switching to workspace 2. Use a
    # distinct app kind so it owns its own panel window-list entry.
    daemon_spawn_app(APP_CALC, 200, 120, 300, 200)
    wslot: uint64 = DWIN_COUNT - 1
    # We are on workspace 1 (index 0). The new window starts here and is
    # visible; move it to workspace 2 (index 1).
    if WS_COUNT < 2:
        write_str(1, "[DEWM] FAIL fewer than 2 workspaces configured\n")
        return
    window_to_workspace(wslot, 1)
    if DWIN_WS[wslot] != 1:
        write_str(1, "[DEWM] FAIL window_to_workspace did not relocate the window\n")
        return
    # Current workspace is still index 0 -> the ws-2 window must be hidden.
    if CUR_WS != 0:
        write_str(1, "[DEWM] FAIL current workspace drifted from 1\n")
        return
    if win_on_cur_ws(wslot) != 0:
        write_str(1, "[DEWM] FAIL ws-2 window composites while workspace 1 is current\n")
        return
    write_str(1, "[DEWM] window on workspace 2 is NOT composited on workspace 1 OK\n")
    # Ctrl-Alt-Right keyboard path: step to the next workspace (index 1).
    dest: int32 = workspace_step(1)
    wsl: Array[64, uint8]
    wpz: uint64 = 0
    wpz = sm_puts(&wsl[0], wpz, "[DEWM] Ctrl-Alt-Right -> workspace index=")
    wpz = wpz + u64_to_dec(cast[uint64](CUR_WS), &wsl[wpz])
    wsl[wpz] = 10
    wpz = wpz + 1
    sys_write(1, &wsl[0], wpz)
    if dest != 1 or CUR_WS != 1:
        write_str(1, "[DEWM] FAIL Ctrl-Alt-Right did not switch to workspace 2\n")
        return
    if win_on_cur_ws(wslot) == 0:
        write_str(1, "[DEWM] FAIL ws-2 window does NOT composite after switching to workspace 2\n")
        return
    # And the maximize/minimize test window (left on workspace 1) must now be
    # hidden, proving the switch is a real per-workspace isolation, not a
    # global show-all.
    if win_on_cur_ws(rs) != 0:
        write_str(1, "[DEWM] FAIL workspace-1 window still composites on workspace 2\n")
        return
    write_str(1, "[DEWM] workspace switch composites ws-2 window and hides ws-1 windows OK\n")

    write_str(1, "[DEWM] PASS\n")


# ====================================================================
# DESW — Alt-Tab MRU switcher + desktop right-click menu (autoflag == 40)
# ====================================================================
# Proves the two MATE/Marco-parity features added this round WITHOUT a real
# framebuffer — every assertion is pure model state driven through the SAME
# code paths the live DE uses:
#
#   ALT-TAB SWITCHER (Marco-style, MOST-RECENTLY-USED order): the live
#     Alt-held / Tab cycle path is cycle_step(+1) (forward) / cycle_step(-1)
#     (Shift-Tab, backward); releasing Alt is cycle_commit(). The candidate
#     list is mru_slot_for_pos over the MRU_UID order (maintained by
#     mru_touch on every focus/raise), skipping any window not visible on the
#     current workspace (win_on_cur_ws — minimized OR other-workspace windows
#     are NOT candidates). With a 3-window MRU stack [front,b,c]:
#       - the FIRST Tab opens the switcher and selects the 2nd MRU window (b);
#       - a SECOND Tab advances to the 3rd MRU window (c);
#       - releasing Alt (cycle_commit) raises+focuses c (front-most) and
#         moves it to the MRU front;
#       - Shift-Tab from the open switcher reverses the selection direction.
#     A window moved to another workspace (window_to_workspace) is NOT an
#     Alt-Tab candidate while the current workspace differs.
#
#   DESKTOP RIGHT-CLICK MENU (root background context menu, CTX_KIND==0):
#     ctx_open_at(0,...) opens the menu; its box width (CTX_W, computed by
#     ctx_menu_width) must fit its WIDEST label (no clipping); selecting
#     "Open Terminal" (ctx_invoke row 0) spawns an in-compositor APP_TERM
#     window via daemon_spawn_app.
#
# Emits "[DESW] ..." OK lines and ends with "[DESW] PASS" or "[DESW] FAIL".

# Emit "[DESW] <label> uid=<n>" for a window slot (or "<none>" for slot < 0).
def desw_print_sel(label: Ptr[uint8], slot: int64):
    rl: Array[96, uint8]
    rp: uint64 = 0
    rp = sm_puts(&rl[0], rp, "[DESW] ")
    rp = sm_puts(&rl[0], rp, label)
    rp = sm_puts(&rl[0], rp, " uid=")
    if slot < 0:
        rp = sm_puts(&rl[0], rp, "<none>")
    else:
        rp = rp + u64_to_dec(cast[uint64](DWIN_UID[cast[uint64](slot)]), &rl[rp])
    rl[rp] = 10
    rp = rp + 1
    sys_write(1, &rl[0], rp)


def daemon_deswitch_selftest(scr_w: int64, scr_h: int64):
    # Clean, deterministic switcher/menu state. Pure model — no child shells,
    # so the window table is reset and rebuilt with built-in app windows.
    CUR_WS = 0
    DWIN_COUNT = 0
    MRU_LEN = 0
    CYCLE_OPEN = 0
    CYCLE_SEL = 0
    CTX_OPEN = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0

    # ================= ALT-TAB MRU SWITCHER ============================
    # Three windows on the CURRENT workspace. daemon_spawn_app does NOT
    # touch the MRU list (it has no focus event), so drive a deterministic
    # focus history through daemon_raise_slot (the same call a click/focus
    # makes) to establish the MRU order independent of stacking order.
    daemon_spawn_app(APP_SYSMON, 120, 80, 300, 180)    # slot 0
    daemon_spawn_app(APP_CALC, 220, 120, 300, 180)     # slot 1
    daemon_spawn_app(APP_TERM, 320, 160, 300, 180)     # slot 2
    if DWIN_COUNT < 3:
        write_str(1, "[DESW] FAIL could not spawn the 3-window switcher stack\n")
        return
    uid_a: int32 = DWIN_UID[0]
    uid_b: int32 = DWIN_UID[1]
    uid_c: int32 = DWIN_UID[2]
    # Focus order oldest..newest: a, c, b  ->  MRU front-to-back: [b, c, a].
    daemon_raise_slot(slot_for_uid(uid_a))
    daemon_raise_slot(slot_for_uid(uid_c))
    daemon_raise_slot(slot_for_uid(uid_b))
    # The most-recently-focused (front) window is b; the MRU candidate order
    # the switcher walks is therefore [b, c, a].
    if mru_slot_for_pos(0) < 0 or DWIN_UID[cast[uint64](mru_slot_for_pos(0))] != uid_b:
        write_str(1, "[DESW] FAIL MRU front window is not the most-recently-focused\n")
        return
    write_str(1, "[DESW] MRU order tracks focus changes OK\n")

    # FIRST Alt+Tab: opens the switcher and selects the 2nd MRU window (the
    # one focused before the front window) — MATE's first Tab jumps past the
    # already-focused front window. That is MRU position 1 == c.
    cycle_step(1)
    if CYCLE_OPEN == 0:
        write_str(1, "[DESW] FAIL first Tab did not open the switcher overlay\n")
        return
    if CYCLE_SEL != 1:
        write_str(1, "[DESW] FAIL first Tab did not select the 2nd MRU window\n")
        return
    sel1: int64 = cycle_slot_for_pos(CYCLE_SEL)
    desw_print_sel("alt-tab-1 selects", sel1)
    if sel1 < 0 or DWIN_UID[cast[uint64](sel1)] != uid_c:
        write_str(1, "[DESW] FAIL first Tab selection is not the 2nd MRU window (c)\n")
        return
    write_str(1, "[DESW] Alt-Tab from a 3-window stack selects the 2nd MRU window OK\n")

    # SECOND Alt+Tab: advance to the 3rd MRU window (a).
    cycle_step(1)
    if CYCLE_SEL != 2:
        write_str(1, "[DESW] FAIL second Tab did not advance to the 3rd MRU window\n")
        return
    sel2: int64 = cycle_slot_for_pos(CYCLE_SEL)
    desw_print_sel("alt-tab-2 selects", sel2)
    if sel2 < 0 or DWIN_UID[cast[uint64](sel2)] != uid_a:
        write_str(1, "[DESW] FAIL second Tab selection is not the 3rd MRU window (a)\n")
        return
    write_str(1, "[DESW] a second Tab selects the 3rd MRU window OK\n")

    # RELEASE Alt (cycle_commit): the selected window (a) raises+focuses to the
    # front AND moves to the MRU front.
    target_uid: int32 = DWIN_UID[cast[uint64](sel2)]
    cycle_commit()
    if CYCLE_OPEN != 0:
        write_str(1, "[DESW] FAIL releasing Alt did not close the switcher\n")
        return
    if DWIN_COUNT == 0 or DWIN_UID[DWIN_COUNT - 1] != target_uid:
        write_str(1, "[DESW] FAIL releasing Alt did not raise the selected window to the front\n")
        return
    if daemon_focus_slot() != cast[int64](DWIN_COUNT - 1):
        write_str(1, "[DESW] FAIL the raised window is not the focused (front-most) window\n")
        return
    if MRU_UID[0] != target_uid:
        write_str(1, "[DESW] FAIL the selected window did not move to the MRU front\n")
        return
    write_str(1, "[DESW] releasing Alt raises+focuses the selection and fronts the MRU OK\n")

    # ================= SHIFT-TAB REVERSES DIRECTION ====================
    # After the commit the MRU front is a; order is [a, b, c]. Open the
    # switcher with a forward Tab (selects position 1 == b), then Shift-Tab
    # (cycle_step(-1)) must step the selection BACKWARD to position 0 (a),
    # the opposite of a forward Tab. (cycle_step's wrap-around makes -1 from
    # position 1 land on position 0.)
    CYCLE_OPEN = 0
    CYCLE_SEL = 0
    cycle_step(1)                       # Tab: open, select position 1
    if CYCLE_SEL != 1:
        write_str(1, "[DESW] FAIL Shift-Tab setup: forward Tab did not select position 1\n")
        return
    fwd_uid: int32 = -1
    fslot: int64 = cycle_slot_for_pos(CYCLE_SEL)
    if fslot >= 0:
        fwd_uid = DWIN_UID[cast[uint64](fslot)]
    cycle_step(-1)                      # Shift-Tab: step back to position 0
    if CYCLE_SEL != 0:
        write_str(1, "[DESW] FAIL Shift-Tab did not reverse to the previous selection\n")
        return
    rslot: int64 = cycle_slot_for_pos(CYCLE_SEL)
    desw_print_sel("shift-tab selects", rslot)
    if rslot < 0:
        write_str(1, "[DESW] FAIL Shift-Tab landed on no window\n")
        return
    if fwd_uid >= 0 and DWIN_UID[cast[uint64](rslot)] == fwd_uid:
        write_str(1, "[DESW] FAIL Shift-Tab selected the same window as forward Tab\n")
        return
    write_str(1, "[DESW] Shift-Tab reverses the cycle direction OK\n")
    cycle_commit()
    CYCLE_OPEN = 0

    # ================= OTHER-WORKSPACE WINDOW IS NOT A CANDIDATE =======
    # Move window c to workspace 2 (index 1). While workspace 1 (index 0) is
    # current it must NOT appear anywhere in the switcher's candidate list,
    # exactly like a window minimized off the current desktop.
    if WS_COUNT < 2:
        write_str(1, "[DESW] FAIL fewer than 2 workspaces configured\n")
        return
    cslot: int64 = slot_for_uid(uid_c)
    if cslot < 0:
        write_str(1, "[DESW] FAIL lost track of window c\n")
        return
    window_to_workspace(cast[uint64](cslot), 1)
    if win_on_cur_ws(cast[uint64](cslot)) != 0:
        write_str(1, "[DESW] FAIL ws-2 window still visible on workspace 1\n")
        return
    # Walk the entire candidate list; uid_c must not occur.
    found_c: int32 = 0
    visible_here: int64 = 0
    pos: int64 = 0
    cand: int64 = cycle_slot_for_pos(pos)
    while cand >= 0:
        if DWIN_UID[cast[uint64](cand)] == uid_c:
            found_c = 1
        visible_here = visible_here + 1
        pos = pos + 1
        cand = cycle_slot_for_pos(pos)
    if found_c != 0:
        write_str(1, "[DESW] FAIL a window on another workspace is an Alt-Tab candidate\n")
        return
    if visible_here != 2:
        write_str(1, "[DESW] FAIL switcher candidate count wrong after moving a window away\n")
        return
    write_str(1, "[DESW] a window on another workspace is NOT an Alt-Tab candidate OK\n")

    # ================= DESKTOP RIGHT-CLICK CONTEXT MENU ===============
    # Open the root/background menu (CTX_KIND==0) the same way a right-click on
    # the desktop does. ctx_open_at recomputes CTX_W from ctx_menu_width.
    ctx_open_at(0, -1, scr_w / 2, scr_h / 2, scr_w, scr_h)
    if CTX_OPEN == 0 or CTX_KIND != 0:
        write_str(1, "[DESW] FAIL desktop right-click did not open the context menu\n")
        return
    # The box width must FIT the widest rendered label (no clipping). Compute
    # the widest label independently and assert CTX_W (== ctx_menu_width) >= it.
    widest: int64 = 0
    n: uint64 = ctx_count()
    has_term: int32 = 0
    term_row: int64 = -1
    ii: uint64 = 0
    while ii < n:
        lbl: Ptr[uint8] = ctx_item_label(ii)
        lw: int64 = cast[int64](strlen_u8(lbl)) * GLYPH_W
        if lw > widest:
            widest = lw
        if cstr_eq(lbl, "Open Terminal") != 0:
            has_term = 1
            term_row = cast[int64](ii)
        ii = ii + 1
    wl: Array[96, uint8]
    wp: uint64 = 0
    wp = sm_puts(&wl[0], wp, "[DESW] ctx menu width=")
    wp = wp + u64_to_dec(cast[uint64](CTX_W), &wl[wp])
    wp = sm_puts(&wl[0], wp, " widest-label=")
    wp = wp + u64_to_dec(cast[uint64](widest), &wl[wp])
    wl[wp] = 10
    wp = wp + 1
    sys_write(1, &wl[0], wp)
    if CTX_W != ctx_menu_width():
        write_str(1, "[DESW] FAIL ctx box width is not the measured menu width\n")
        return
    if CTX_W < widest + CTX_PAD_L + CTX_PAD_R and CTX_W < widest:
        write_str(1, "[DESW] FAIL ctx menu box clips its widest label\n")
        return
    if CTX_W < widest:
        write_str(1, "[DESW] FAIL ctx menu box narrower than its widest label\n")
        return
    if has_term == 0 or term_row != 0:
        write_str(1, "[DESW] FAIL desktop menu has no Open Terminal row at index 0\n")
        return
    write_str(1, "[DESW] desktop context menu box fits its widest label OK\n")

    # Selecting "Open Terminal" (row 0) spawns an in-compositor APP_TERM window.
    before: uint64 = DWIN_COUNT
    ctx_invoke(0, scr_w, scr_h)
    CTX_OPEN = 0
    if DWIN_COUNT != before + 1:
        write_str(1, "[DESW] FAIL Open Terminal did not spawn a window\n")
        return
    if DWIN_APP[DWIN_COUNT - 1] != APP_TERM:
        write_str(1, "[DESW] FAIL Open Terminal spawned a non-terminal window\n")
        return
    write_str(1, "[DESW] desktop menu Open Terminal spawns an APP_TERM window OK\n")

    write_str(1, "[DESW] PASS\n")


# ====================================================================
# DERS — edge/corner resize-drag + Show-Desktop toggle self-test (==41)
# ====================================================================
# Proves the two MATE/Marco-parity window operations added this round
# WITHOUT a real framebuffer — every assertion is pure model state driven
# through the SAME code paths the live DE uses:
#
#   EDGE / CORNER RESIZE-DRAG (Marco-style): pressing a window's border or
#     corner (outside the title-bar move zone) begins GESTURE==4 via
#     resize_begin(slot, dir) — dir is the 4-bit edge mask from resize_dir_at
#     (bit0 left, bit1 right, bit2 top, bit3 bottom; corners set two bits).
#     Each motion event calls resize_track(), which pulls the grabbed edge(s)
#     under the cursor (CUR_X/CUR_Y) while pinning the anchored opposite
#     edge(s), clamped to RESIZE_MIN_W/RESIZE_MIN_H. resize_end() commits.
#       - grabbing the RIGHT border (dir=2) and dragging +40px widens the
#         window by exactly 40 and leaves x / y / top unchanged;
#       - grabbing the BOTTOM-LEFT corner (dir=1|8) changes BOTH width and
#         height at once (and x, since the left edge moves) correctly;
#       - dragging a border inward past the minimum clamps at exactly
#         RESIZE_MIN_W / RESIZE_MIN_H, never smaller.
#
#   SHOW-DESKTOP / MINIMIZE-ALL TOGGLE (MATE panel applet + F10 / Super-D):
#     show_desktop_toggle() on the first invoke hides EVERY visible window on
#     the current workspace (DWIN_HIDDEN=1, remembering the set in
#     showdesk_saved) so the composite/visible set (win_on_cur_ws) becomes
#     empty; the second invoke restores EXACTLY that set (same slots visible,
#     same focus / front-most window). The panel Show-Desktop button
#     (in_show_desktop_btn) and the F10 key both route to this same toggle.
#
# Emits "[DERS] ..." OK lines and ends with "[DERS] PASS" or "[DERS] FAIL".

# Emit "[DERS] <label> rect=<x>,<y>,<w>,<h>" for a window slot — a small
# geometry diagnostic so the serial log shows what each assertion checked.
def ders_print_rect(label: Ptr[uint8], slot: uint64):
    rl: Array[160, uint8]
    rp: uint64 = 0
    rp = sm_puts(&rl[0], rp, "[DERS] ")
    rp = sm_puts(&rl[0], rp, label)
    rp = sm_puts(&rl[0], rp, " rect=")
    rp = rp + u64_to_dec(cast[uint64](DWIN_X[slot]), &rl[rp])
    rl[rp] = 44                          # ','
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_Y[slot]), &rl[rp])
    rl[rp] = 44
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_W[slot]), &rl[rp])
    rl[rp] = 44
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_H[slot]), &rl[rp])
    rl[rp] = 10
    rp = rp + 1
    sys_write(1, &rl[0], rp)


# 1 if window `slot`'s live rect equals (x,y,w,h), else 0.
def ders_rect_eq(slot: uint64, x: int64, y: int64, w: int64, h: int64) -> int32:
    if DWIN_X[slot] == x and DWIN_Y[slot] == y \
       and DWIN_W[slot] == w and DWIN_H[slot] == h:
        return 1
    return 0


def daemon_deresize_selftest(scr_w: int64, scr_h: int64):
    # Clean, deterministic model state — pure model, no child shells.
    CUR_WS = 0
    DWIN_COUNT = 0
    GESTURE = 3
    RESIZE_SLOT = -1
    RESIZE_DIR = 0
    SHOWDESK_ON = 0

    # ================= RIGHT-BORDER RESIZE (+40 px wider) ==============
    # A floating window with a known rect, well clear of every screen edge so
    # the resize never clamps against the work area.
    ox: int64 = 200
    oy: int64 = 140
    ow: int64 = 320
    oh: int64 = 200
    daemon_spawn_app(APP_SYSMON, ox, oy, ow, oh)
    if DWIN_COUNT < 1:
        write_str(1, "[DERS] FAIL could not spawn resize test window\n")
        return
    rslot: uint64 = DWIN_COUNT - 1
    if ders_rect_eq(rslot, ox, oy, ow, oh) == 0:
        write_str(1, "[DERS] FAIL spawn rect not as requested\n")
        return
    # The grip hit-test must classify a point on the right border (mid-height)
    # as the RIGHT edge (mask bit1 == 2) — the exact press the live DE makes.
    right_inc: int64 = ox + ow - 1            # inclusive right-edge pixel
    grab_dir: int32 = resize_dir_at(rslot, right_inc, oy + oh / 2)
    if (grab_dir & 2) == 0 or (grab_dir & 1) != 0:
        write_str(1, "[DERS] FAIL right-border point did not classify as the right edge\n")
        return
    write_str(1, "[DERS] right-border press classifies as the right-edge grip OK\n")
    # Begin the resize on the RIGHT edge only and drag the cursor +40 px right.
    # resize_track() treats CUR_X as the inclusive right pixel, so a +40 drag
    # sets CUR_X = right_inc + 40 and width must become ow + 40.
    resize_begin(cast[int64](rslot), 2)
    GESTURE = 4
    CUR_X = right_inc + 40
    CUR_Y = oy + oh / 2                       # vertical cursor unchanged
    resize_track(scr_w, scr_h)
    resize_end()
    GESTURE = 3
    ders_print_rect("right-drag+40", rslot)
    if ders_rect_eq(rslot, ox, oy, ow + 40, oh) == 0:
        write_str(1, "[DERS] FAIL right-border +40 drag did not widen by exactly 40 (x/y/top/h must be unchanged)\n")
        return
    write_str(1, "[DERS] right-border +40 drag widens by 40, x/y/top/height unchanged OK\n")

    # ================= BOTTOM-LEFT CORNER RESIZE (two dims) ============
    # Re-baseline the window to a known rect, then grab the BOTTOM-LEFT corner
    # (left edge + bottom edge, mask 1|8 == 9). Dragging it down-left widens
    # the window (the left edge moves LEFT so x decreases AND width grows) and
    # makes it taller (bottom edge moves DOWN). Both dimensions change at once.
    DWIN_X[rslot] = ox
    DWIN_Y[rslot] = oy
    DWIN_W[rslot] = ow
    DWIN_H[rslot] = oh
    window_reflow(rslot)
    bot_inc: int64 = oy + oh - 1              # inclusive bottom-edge pixel
    cdir: int32 = resize_dir_at(rslot, ox, bot_inc)
    if cdir != 9:
        write_str(1, "[DERS] FAIL bottom-left corner did not classify as left+bottom (mask 9)\n")
        return
    write_str(1, "[DERS] bottom-left corner classifies as the left+bottom grip OK\n")
    resize_begin(cast[int64](rslot), 9)
    GESTURE = 4
    # Drag the corner 30px LEFT and 50px DOWN.
    CUR_X = ox - 30                           # left edge follows the cursor
    CUR_Y = bot_inc + 50                      # bottom edge follows the cursor
    resize_track(scr_w, scr_h)
    resize_end()
    GESTURE = 3
    ders_print_rect("corner-drag", rslot)
    # Left edge moved to x=ox-30: new x = ox-30, new width = right_anchor - x.
    # right_anchor was ox+ow, so new width = (ox+ow) - (ox-30) = ow+30.
    exp_x: int64 = ox - 30
    exp_w: int64 = ow + 30
    # Bottom edge moved to inclusive pixel bot_inc+50: new height = CUR_Y+1-Y.
    exp_h: int64 = (bot_inc + 50) + 1 - oy
    if DWIN_W[rslot] != exp_w or DWIN_H[rslot] != exp_h:
        write_str(1, "[DERS] FAIL corner drag did not change BOTH width and height correctly\n")
        return
    if DWIN_X[rslot] != exp_x:
        write_str(1, "[DERS] FAIL corner drag did not move x with the left edge\n")
        return
    if DWIN_Y[rslot] != oy:
        write_str(1, "[DERS] FAIL corner drag moved the anchored top edge\n")
        return
    write_str(1, "[DERS] bottom-left corner drag changes width+height (and x) together OK\n")

    # ================= MINIMUM-SIZE CLAMP =============================
    # Re-baseline, then grab the RIGHT edge and drag it FAR inward (past the
    # left edge). The width must clamp at exactly RESIZE_MIN_W, never smaller,
    # and the anchored left edge / x must stay put. Likewise the BOTTOM edge
    # inward clamps the height at exactly RESIZE_MIN_H.
    DWIN_X[rslot] = ox
    DWIN_Y[rslot] = oy
    DWIN_W[rslot] = ow
    DWIN_H[rslot] = oh
    window_reflow(rslot)
    resize_begin(cast[int64](rslot), 2)
    GESTURE = 4
    CUR_X = ox - 500                          # drag the right edge way past x
    CUR_Y = oy + oh / 2
    resize_track(scr_w, scr_h)
    resize_end()
    GESTURE = 3
    ders_print_rect("min-clamp-w", rslot)
    if DWIN_W[rslot] != RESIZE_MIN_W:
        write_str(1, "[DERS] FAIL inward right-drag did not clamp width at the minimum\n")
        return
    if DWIN_W[rslot] < RESIZE_MIN_W:
        write_str(1, "[DERS] FAIL width shrank below the minimum\n")
        return
    if DWIN_X[rslot] != ox:
        write_str(1, "[DERS] FAIL min-clamp moved the anchored left edge\n")
        return
    # Now clamp the height via an inward BOTTOM-edge drag.
    DWIN_X[rslot] = ox
    DWIN_Y[rslot] = oy
    DWIN_W[rslot] = ow
    DWIN_H[rslot] = oh
    window_reflow(rslot)
    resize_begin(cast[int64](rslot), 8)
    GESTURE = 4
    CUR_X = ox + ow / 2
    CUR_Y = oy - 500                          # drag bottom edge above the top
    resize_track(scr_w, scr_h)
    resize_end()
    GESTURE = 3
    ders_print_rect("min-clamp-h", rslot)
    if DWIN_H[rslot] != RESIZE_MIN_H:
        write_str(1, "[DERS] FAIL inward bottom-drag did not clamp height at the minimum\n")
        return
    if DWIN_H[rslot] < RESIZE_MIN_H:
        write_str(1, "[DERS] FAIL height shrank below the minimum\n")
        return
    if DWIN_Y[rslot] != oy:
        write_str(1, "[DERS] FAIL height min-clamp moved the anchored top edge\n")
        return
    cl: Array[96, uint8]
    cp: uint64 = 0
    cp = sm_puts(&cl[0], cp, "[DERS] resize clamps at min ")
    cp = cp + u64_to_dec(cast[uint64](RESIZE_MIN_W), &cl[cp])
    cl[cp] = 120                             # 'x'
    cp = cp + 1
    cp = cp + u64_to_dec(cast[uint64](RESIZE_MIN_H), &cl[cp])
    cl[cp] = 10
    cp = cp + 1
    sys_write(1, &cl[0], cp)
    write_str(1, "[DERS] resize clamps at the minimum size, never smaller OK\n")

    # ================= SHOW-DESKTOP / MINIMIZE-ALL TOGGLE =============
    # Three windows visible on the current workspace. The Show-Desktop toggle
    # must hide ALL of them (composite/visible set empty), then a second toggle
    # restores EXACTLY that set with the same focus. Reset the table so the
    # visible-set bookkeeping is deterministic.
    DWIN_COUNT = 0
    SHOWDESK_ON = 0
    daemon_spawn_app(APP_SYSMON, 120, 80, 300, 180)    # slot 0
    daemon_spawn_app(APP_CALC, 220, 120, 300, 180)     # slot 1
    daemon_spawn_app(APP_TERM, 320, 160, 300, 180)     # slot 2
    if DWIN_COUNT < 3:
        write_str(1, "[DERS] FAIL could not spawn the Show-Desktop window set\n")
        return
    # Count how many windows are visible on the current workspace (all 3).
    vis_before: int64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if win_on_cur_ws(i) != 0:
            vis_before = vis_before + 1
        i = i + 1
    if vis_before != 3:
        write_str(1, "[DERS] FAIL fewer than 3 windows visible before Show-Desktop\n")
        return
    focus_before: int64 = daemon_focus_slot()
    # Hide one window manually FIRST so we can prove the restore brings back
    # EXACTLY the set Show-Desktop hid (this already-minimized window must NOT
    # be un-hidden by the restore — it was not part of the saved set).
    DWIN_HIDDEN[1] = 1
    pre_hidden_slot1: int32 = DWIN_HIDDEN[1]
    # Re-count: now 2 windows are visible (slots 0 and 2).
    vis_now: int64 = 0
    j: uint64 = 0
    while j < DWIN_COUNT:
        if win_on_cur_ws(j) != 0:
            vis_now = vis_now + 1
        j = j + 1
    if vis_now != 2:
        write_str(1, "[DERS] FAIL pre-minimize bookkeeping wrong\n")
        return
    # FIRST toggle: Show Desktop hides every currently-visible window.
    show_desktop_toggle()
    if SHOWDESK_ON == 0:
        write_str(1, "[DERS] FAIL Show-Desktop toggle did not enter the minimized-all state\n")
        return
    vis_hidden: int64 = 0
    k: uint64 = 0
    while k < DWIN_COUNT:
        if win_on_cur_ws(k) != 0:
            vis_hidden = vis_hidden + 1
        k = k + 1
    hl: Array[96, uint8]
    hp: uint64 = 0
    hp = sm_puts(&hl[0], hp, "[DERS] show-desktop visible-after-hide=")
    hp = hp + u64_to_dec(cast[uint64](vis_hidden), &hl[hp])
    hl[hp] = 10
    hp = hp + 1
    sys_write(1, &hl[0], hp)
    if vis_hidden != 0:
        write_str(1, "[DERS] FAIL Show-Desktop did not hide ALL visible windows (composite set non-empty)\n")
        return
    write_str(1, "[DERS] Show-Desktop hides all current-workspace windows (composite set empty) OK\n")
    # SECOND toggle: restore EXACTLY the set Show-Desktop hid (slots 0 and 2),
    # NOT the window that was already minimized before (slot 1 stays hidden).
    show_desktop_toggle()
    if SHOWDESK_ON != 0:
        write_str(1, "[DERS] FAIL second toggle did not leave the minimized-all state\n")
        return
    if DWIN_HIDDEN[0] != 0 or DWIN_HIDDEN[2] != 0:
        write_str(1, "[DERS] FAIL Show-Desktop restore did not un-hide the previously-visible windows\n")
        return
    if DWIN_HIDDEN[1] != pre_hidden_slot1:
        write_str(1, "[DERS] FAIL Show-Desktop restore disturbed an unrelated already-minimized window\n")
        return
    vis_after: int64 = 0
    m: uint64 = 0
    while m < DWIN_COUNT:
        if win_on_cur_ws(m) != 0:
            vis_after = vis_after + 1
        m = m + 1
    if vis_after != vis_now:
        write_str(1, "[DERS] FAIL Show-Desktop restore did not return the EXACT previously-visible set\n")
        return
    if daemon_focus_slot() != focus_before:
        write_str(1, "[DERS] FAIL Show-Desktop restore did not return the same focus / front-most window\n")
        return
    write_str(1, "[DERS] Show-Desktop second toggle restores exactly the previously-visible set + focus OK\n")

    write_str(1, "[DERS] PASS\n")


# ====================================================================
# DEQT — corner-quadrant window tiling self-test (autoflag == 42)
# ====================================================================
# Proves MATE/Marco corner-quadrant tiling WITHOUT a real framebuffer —
# every assertion is pure model state driven through the SAME code paths the
# live DE uses (snap_zone_for to classify a corner cursor, snap_apply to tile,
# tile_focused for the keyboard quarter-tile gesture):
#
#   QUADRANT SNAP (modes 4..7): dragging a window's title bar so the pointer
#     reaches a screen CORNER classifies (snap_zone_for) as a quarter tile and
#     snap_apply tiles the window to exactly that quadrant of the WORK AREA:
#       top-left  (4) -> x=0,       y=wt,            w=scr_w/2, h=avail_h/2
#       top-right (5) -> x=scr_w/2, y=wt,            w=rest,    h=avail_h/2
#       bot-left  (6) -> x=0,       y=wt+avail_h/2,  w=scr_w/2, h=rest
#       bot-right (7) -> x=scr_w/2, y=wt+avail_h/2,  w=rest,    h=rest
#     where wt=work_top (panel-position aware) and avail_h=work_h. The two
#     left quadrants share x=0; the two right quadrants share x=scr_w/2 and
#     their widths sum to scr_w; the two top quadrants share y=wt and the
#     bottom pair starts at wt+avail_h/2 with heights summing to avail_h —
#     i.e. four quadrants tile the work area with NO gap and NO overlap.
#     Each snap sets DWIN_SNAP to its mode and leaves DWIN_MAXED==0.
#
#   KEYBOARD QUARTER-TILE: tile_focused(mode) drives the SAME snap_apply on
#     the front-most window — the keyboard analogue of the corner drag.
#
#   UN-SNAP / RESTORE: snap_apply(slot, 0) restores EXACTLY the pre-snap float
#     rect and clears DWIN_SNAP, just like dragging a tiled window away.
#
# Emits "[DEQT] ..." OK lines and ends with "[DEQT] PASS" or "[DEQT] FAIL".

# Emit "[DEQT] <label> rect=<x>,<y>,<w>,<h>" for a window slot — a small
# geometry diagnostic so the serial log shows what each assertion checked.
def deqt_print_rect(label: Ptr[uint8], slot: uint64):
    rl: Array[160, uint8]
    rp: uint64 = 0
    rp = sm_puts(&rl[0], rp, "[DEQT] ")
    rp = sm_puts(&rl[0], rp, label)
    rp = sm_puts(&rl[0], rp, " rect=")
    rp = rp + u64_to_dec(cast[uint64](DWIN_X[slot]), &rl[rp])
    rl[rp] = 44                          # ','
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_Y[slot]), &rl[rp])
    rl[rp] = 44
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_W[slot]), &rl[rp])
    rl[rp] = 44
    rp = rp + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_H[slot]), &rl[rp])
    rl[rp] = 10
    rp = rp + 1
    sys_write(1, &rl[0], rp)


# 1 if window `slot`'s live rect equals (x,y,w,h), else 0.
def deqt_rect_eq(slot: uint64, x: int64, y: int64, w: int64, h: int64) -> int32:
    if DWIN_X[slot] == x and DWIN_Y[slot] == y \
       and DWIN_W[slot] == w and DWIN_H[slot] == h:
        return 1
    return 0


def daemon_dequartile_selftest(scr_w: int64, scr_h: int64):
    # Clean, deterministic model state — pure model, no child shells.
    CUR_WS = 0
    DWIN_COUNT = 0
    GESTURE = 3

    # The panel-position-aware work area the quadrants tile.
    wt: int64 = work_top(scr_h)
    avail_h: int64 = work_h(scr_h)
    half_w: int64 = scr_w / 2
    half_h: int64 = avail_h / 2
    right_w: int64 = scr_w - half_w           # right column width (rounding-safe)
    bot_h: int64 = avail_h - half_h           # bottom row height (rounding-safe)
    bot_y: int64 = wt + half_h                # first row of the bottom quadrants

    gl: Array[128, uint8]
    gp: uint64 = 0
    gp = sm_puts(&gl[0], gp, "[DEQT] work-area wt=")
    gp = gp + u64_to_dec(cast[uint64](wt), &gl[gp])
    gp = sm_puts(&gl[0], gp, " avail_h=")
    gp = gp + u64_to_dec(cast[uint64](avail_h), &gl[gp])
    gp = sm_puts(&gl[0], gp, " half_w=")
    gp = gp + u64_to_dec(cast[uint64](half_w), &gl[gp])
    gp = sm_puts(&gl[0], gp, " half_h=")
    gp = gp + u64_to_dec(cast[uint64](half_h), &gl[gp])
    gl[gp] = 10
    gp = gp + 1
    sys_write(1, &gl[0], gp)

    # A floating window with a known float rect, clear of every screen edge so
    # the original geometry is unambiguous and restore is exact.
    ox: int64 = 220
    oy: int64 = 150
    ow: int64 = 340
    oh: int64 = 210
    daemon_spawn_app(APP_SYSMON, ox, oy, ow, oh)
    if DWIN_COUNT < 1:
        write_str(1, "[DEQT] FAIL could not spawn quarter-tile test window\n")
        return
    qslot: uint64 = DWIN_COUNT - 1
    if deqt_rect_eq(qslot, ox, oy, ow, oh) == 0:
        write_str(1, "[DEQT] FAIL spawn rect not as requested\n")
        return

    # ================= TOP-LEFT QUADRANT (corner drag) ================
    # A title-drag whose pointer reaches the TOP-LEFT screen corner must
    # classify (snap_zone_for) as mode 4 and tile to the top-left quarter.
    tl_zone: int32 = snap_zone_for(0, 0, scr_w, scr_h)
    zl: Array[64, uint8]
    zp: uint64 = 0
    zp = sm_puts(&zl[0], zp, "[DEQT] top-left corner zone=")
    zp = zp + u64_to_dec(cast[uint64](tl_zone), &zl[zp])
    zl[zp] = 10
    zp = zp + 1
    sys_write(1, &zl[0], zp)
    if tl_zone != 4:
        write_str(1, "[DEQT] FAIL top-left corner did not classify as the top-left quarter\n")
        return
    snap_apply(qslot, tl_zone, scr_w, scr_h)
    deqt_print_rect("top-left", qslot)
    if deqt_rect_eq(qslot, 0, wt, half_w, half_h) == 0:
        write_str(1, "[DEQT] FAIL top-left snap rect != top-left quarter of the work area\n")
        return
    if DWIN_SNAP[qslot] != 4:
        write_str(1, "[DEQT] FAIL top-left snap did not record the snap mode\n")
        return
    if DWIN_MAXED[qslot] != 0:
        write_str(1, "[DEQT] FAIL top-left snap left the maximized flag set\n")
        return
    write_str(1, "[DEQT] top-left corner tiles to the top-left quarter OK\n")
    # Un-snap restores the EXACT float rect and clears the snap mode.
    snap_apply(qslot, 0, scr_w, scr_h)
    if DWIN_SNAP[qslot] != 0:
        write_str(1, "[DEQT] FAIL un-snap left the snap mode set\n")
        return
    if deqt_rect_eq(qslot, ox, oy, ow, oh) == 0:
        write_str(1, "[DEQT] FAIL un-snap did not restore the exact pre-snap float rect\n")
        return
    write_str(1, "[DEQT] top-left snap / un-snap round-trips the exact float rect OK\n")

    # ================= TOP-RIGHT QUADRANT (corner drag) ===============
    tr_zone: int32 = snap_zone_for(scr_w - 1, 0, scr_w, scr_h)
    if tr_zone != 5:
        write_str(1, "[DEQT] FAIL top-right corner did not classify as the top-right quarter\n")
        return
    snap_apply(qslot, tr_zone, scr_w, scr_h)
    deqt_print_rect("top-right", qslot)
    if deqt_rect_eq(qslot, half_w, wt, right_w, half_h) == 0:
        write_str(1, "[DEQT] FAIL top-right snap rect != top-right quarter of the work area\n")
        return
    if DWIN_SNAP[qslot] != 5 or DWIN_MAXED[qslot] != 0:
        write_str(1, "[DEQT] FAIL top-right snap state wrong\n")
        return
    write_str(1, "[DEQT] top-right corner tiles to the top-right quarter OK\n")

    # ================= BOTTOM-LEFT QUADRANT (corner drag) =============
    bl_zone: int32 = snap_zone_for(0, scr_h - 1, scr_w, scr_h)
    if bl_zone != 6:
        write_str(1, "[DEQT] FAIL bottom-left corner did not classify as the bottom-left quarter\n")
        return
    snap_apply(qslot, bl_zone, scr_w, scr_h)
    deqt_print_rect("bottom-left", qslot)
    if deqt_rect_eq(qslot, 0, bot_y, half_w, bot_h) == 0:
        write_str(1, "[DEQT] FAIL bottom-left snap rect != bottom-left quarter of the work area\n")
        return
    if DWIN_SNAP[qslot] != 6 or DWIN_MAXED[qslot] != 0:
        write_str(1, "[DEQT] FAIL bottom-left snap state wrong\n")
        return
    write_str(1, "[DEQT] bottom-left corner tiles to the bottom-left quarter OK\n")

    # ================= BOTTOM-RIGHT QUADRANT (corner drag) ============
    br_zone: int32 = snap_zone_for(scr_w - 1, scr_h - 1, scr_w, scr_h)
    if br_zone != 7:
        write_str(1, "[DEQT] FAIL bottom-right corner did not classify as the bottom-right quarter\n")
        return
    snap_apply(qslot, br_zone, scr_w, scr_h)
    deqt_print_rect("bottom-right", qslot)
    if deqt_rect_eq(qslot, half_w, bot_y, right_w, bot_h) == 0:
        write_str(1, "[DEQT] FAIL bottom-right snap rect != bottom-right quarter of the work area\n")
        return
    if DWIN_SNAP[qslot] != 7 or DWIN_MAXED[qslot] != 0:
        write_str(1, "[DEQT] FAIL bottom-right snap state wrong\n")
        return
    write_str(1, "[DEQT] bottom-right corner tiles to the bottom-right quarter OK\n")

    # ================= FOUR QUADRANTS TILE THE WORK AREA ==============
    # The four quadrants must paper the work area with no gap and no overlap:
    # the two left quadrants share x=0, the two right quadrants share x=half_w
    # and (left_w + right_w) == scr_w; the top pair shares y=wt and the bottom
    # pair starts at wt+half_h with (top_h + bot_h) == avail_h.
    if half_w + right_w != scr_w:
        write_str(1, "[DEQT] FAIL left+right quadrant widths do not sum to the screen width\n")
        return
    if half_h + bot_h != avail_h:
        write_str(1, "[DEQT] FAIL top+bottom quadrant heights do not sum to the work height\n")
        return
    if bot_y != wt + half_h:
        write_str(1, "[DEQT] FAIL bottom quadrants do not abut the top quadrants\n")
        return
    write_str(1, "[DEQT] the four quadrants tile the work area with no gap or overlap OK\n")

    # ================= KEYBOARD QUARTER-TILE (tile_focused) ===========
    # tile_focused drives the SAME snap_apply on the FRONT-most window — the
    # keyboard analogue of the corner drag. Re-baseline to a clean float rect.
    snap_apply(qslot, 0, scr_w, scr_h)
    DWIN_X[qslot] = ox
    DWIN_Y[qslot] = oy
    DWIN_W[qslot] = ow
    DWIN_H[qslot] = oh
    DWIN_SNAP[qslot] = 0
    window_reflow(qslot)
    if daemon_focus_slot() != cast[int64](qslot):
        write_str(1, "[DEQT] FAIL the quarter-tile test window is not the focused window\n")
        return
    tile_focused(7, scr_w, scr_h)             # keyboard: tile bottom-right
    deqt_print_rect("kbd-bottom-right", qslot)
    if deqt_rect_eq(qslot, half_w, bot_y, right_w, bot_h) == 0:
        write_str(1, "[DEQT] FAIL keyboard quarter-tile did not tile the focused window to the bottom-right quarter\n")
        return
    if DWIN_SNAP[qslot] != 7:
        write_str(1, "[DEQT] FAIL keyboard quarter-tile did not record the snap mode\n")
        return
    write_str(1, "[DEQT] keyboard quarter-tile snaps the focused window to a quadrant OK\n")
    # Un-snap restores the float rect exactly.
    snap_apply(qslot, 0, scr_w, scr_h)
    if DWIN_SNAP[qslot] != 0 or deqt_rect_eq(qslot, ox, oy, ow, oh) == 0:
        write_str(1, "[DEQT] FAIL keyboard quarter-tile un-snap did not restore the exact float rect\n")
        return
    write_str(1, "[DEQT] keyboard quarter-tile un-snap restores the exact float rect OK\n")

    write_str(1, "[DEQT] PASS\n")


# ====================================================================
# DEPERF — dirty-rectangle present scaling self-test (autoflag == 36)
# ====================================================================
# Proves the compositor no longer pays O(W*H*windows) per frame. The old
# main loop forced a FULL-SCREEN recomposite (daemon_present) on nearly
# every event, so a single window emitting a line of shell output repainted
# all W*H screen pixels through daemon_pixel — which itself walks ALL
# windows — and the cost grew with each window opened (~1 fps degrading).
#
# The new path damages only the changed window's screen rect and presents
# that via daemon_present_rect. This test asserts, DETERMINISTICALLY:
#   1. A single-window content update presents ONLY that window's rect
#      (DMG_LAST_FULL==0, area == that window's W*H), NOT the full screen.
#   2. That presented area is IDENTICAL with 1 window open and with DMAX
#      windows open — i.e. it does NOT grow with the window count. This is
#      the crux of the user's bug ("worse with each window I open").
#   3. The bounded area is far below a full-screen present (W*H), so the
#      win is real, not cosmetic.
# Built-in (in-process) app windows are used so there is no child-process /
# pipe timing — every assertion is pure model state. Emits "[DEPERF] ..."
# markers and ends with "[DEPERF] PASS".
def daemon_deperf_selftest(scr_w: int64, scr_h: int64):
    full_area: int64 = cast[int64](FBG_W) * cast[int64](FBG_H)
    # --- Open ONE window and measure a single-window content update ---
    daemon_spawn_app(APP_SYSMON, 120, 80, 360, 220)
    if DWIN_COUNT < 1:
        write_str(1, "[DEPERF] FAIL could not spawn first window\n")
        return
    w0: uint64 = DWIN_COUNT - 1
    w0_area: int64 = DWIN_W[w0] * DWIN_H[w0]
    damage_reset()
    damage_window(w0)
    if daemon_flush_damage() == 0:
        write_str(1, "[DEPERF] FAIL nothing presented for single-window damage\n")
        return
    if DMG_LAST_FULL != 0:
        write_str(1, "[DEPERF] FAIL single-window update escalated to a FULL-SCREEN present\n")
        return
    area_1win: int64 = DMG_LAST_AREA
    if area_1win != w0_area:
        write_str(1, "[DEPERF] FAIL presented area != window rect area (1 window)\n")
        return
    if area_1win >= full_area:
        write_str(1, "[DEPERF] FAIL single-window present touched the whole screen\n")
        return
    write_str(1, "[DEPERF] single-window content update presents ONLY that window's rect OK\n")

    # --- Open up to DMAX windows; re-measure the SAME window's update ---
    fill: int64 = 0
    while DWIN_COUNT < DMAX and fill < 16:
        ox: int64 = 60 + (cast[int64](DWIN_COUNT) * 40)
        daemon_spawn_app(APP_TERM, ox, 60, 300, 180)
        fill = fill + 1
    nwin: uint64 = DWIN_COUNT
    if nwin < 2:
        write_str(1, "[DEPERF] FAIL could not open extra windows\n")
        return
    # Re-measure the first window's single-window update with many windows up.
    damage_reset()
    damage_window(w0)
    if daemon_flush_damage() == 0:
        write_str(1, "[DEPERF] FAIL nothing presented for single-window damage (N windows)\n")
        return
    if DMG_LAST_FULL != 0:
        write_str(1, "[DEPERF] FAIL single-window update escalated to FULL-SCREEN with N windows\n")
        return
    area_nwin: int64 = DMG_LAST_AREA
    # THE CRUX: the presented area must NOT grow with the window count.
    if area_nwin != area_1win:
        write_str(1, "[DEPERF] FAIL presented area grew with window count\n")
        return
    if area_nwin >= full_area:
        write_str(1, "[DEPERF] FAIL single-window present touched the whole screen (N windows)\n")
        return
    # Report the numbers so the proof is visible in the serial log.
    line: Array[160, uint8]
    p: uint64 = 0
    p = sm_puts(&line[0], p, "[DEPERF] windows=")
    p = p + u64_to_dec(nwin, &line[p])
    p = sm_puts(&line[0], p, " rect_area=")
    p = p + u64_to_dec(cast[uint64](area_nwin), &line[p])
    p = sm_puts(&line[0], p, " full_area=")
    p = p + u64_to_dec(cast[uint64](full_area), &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)
    write_str(1, "[DEPERF] single-window present area is window-count INDEPENDENT OK\n")

    # --- A genuine whole-screen change still escalates to a full present ---
    damage_reset()
    damage_full()
    if daemon_flush_damage() == 0:
        write_str(1, "[DEPERF] FAIL full-screen damage presented nothing\n")
        return
    if DMG_LAST_FULL == 0 or DMG_LAST_AREA != full_area:
        write_str(1, "[DEPERF] FAIL whole-screen change did NOT do a full present\n")
        return
    write_str(1, "[DEPERF] whole-screen change still escalates to a full present OK\n")

    write_str(1, "[DEPERF] PASS\n")


# ====================================================================
# DECACHE self-test (autoflag == 43) — DEPERF #409 per-window backbuffer
# ====================================================================
# Proves the per-window backbuffer cache:
#   1. PURE MOVE REUSES CACHE: after a window is composited once, relocating
#      it (X/Y only) and re-syncing re-renders ZERO windows — every window
#      is served from its cache (WCACHE_LAST_RERENDERED == 0). This is the
#      crux: a drag no longer re-rasterises identical content every frame.
#   2. PIXEL-IDENTICAL FROM CACHE: a screen pixel inside the moved window
#      composited via daemon_pixel (the cache path) equals the pixel the
#      live procedural renderer (window_render_self) produces at the new
#      offset — the cache holds the exact same bytes, just blitted at the
#      new position.
#   3. CONTENT CHANGE RE-RENDERS ONLY THAT WINDOW: marking one window
#      content-dirty re-renders exactly one window on the next sync; the
#      others stay cached.
#   4. OVERLAP STILL STACKS: where a front window covers a back window, the
#      composited pixel is the FRONT window's surface (back-to-front order
#      preserved through the cache), pixel-identical to the procedural path.
# Pure model state, no real framebuffer. Emits "[DECACHE] ..." and ends
# with "[DECACHE] PASS" / "[DECACHE] FAIL <reason>".
def daemon_decache_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    # Park the cursor far from the test windows so the cursor sprite never
    # composites over a sampled pixel (daemon_pixel paints it last).
    CUR_X = scr_w - 1
    CUR_Y = scr_h - 1
    # --- Open a window and seed its cache via a full present pass ---
    daemon_spawn_app(APP_ABOUT, 100, 100, 360, 200)
    if DWIN_COUNT < 1:
        write_str(1, "[DECACHE] FAIL could not spawn window 0\n")
        return
    w0: uint64 = DWIN_COUNT - 1
    # First sync renders the new (content-dirty) window into its cache.
    window_cache_sync()
    if WCACHE_VALID[w0] == 0:
        write_str(1, "[DECACHE] FAIL window cache not valid after first sync\n")
        return
    if WCACHE_LAST_RERENDERED != 1:
        write_str(1, "[DECACHE] FAIL first sync did not render exactly the new window\n")
        return
    write_str(1, "[DECACHE] new window rendered into its cache OK\n")

    # --- (1) PURE MOVE: relocate, no content change -> zero re-renders ---
    DWIN_X[w0] = DWIN_X[w0] + 120
    DWIN_Y[w0] = DWIN_Y[w0] + 60
    window_cache_sync()
    if WCACHE_LAST_RERENDERED != 0:
        write_str(1, "[DECACHE] FAIL a pure move re-rendered a window (cache not reused)\n")
        return
    if WCACHE_LAST_REUSED != 1:
        write_str(1, "[DECACHE] FAIL moved window was not served from cache\n")
        return
    write_str(1, "[DECACHE] pure move reuses the backbuffer (0 re-renders) OK\n")

    # --- (2) PIXEL-IDENTICAL: cache composite == live procedural render ---
    # Sample a pixel well inside the moved window (past the 2px border).
    px: int64 = DWIN_X[w0] + 40
    py: int64 = DWIN_Y[w0] + 40
    cr: Array[1, uint8]
    cg: Array[1, uint8]
    cb: Array[1, uint8]
    daemon_pixel(px, py, &cr[0], &cg[0], &cb[0])
    lr: Array[1, uint8]
    lg: Array[1, uint8]
    lb: Array[1, uint8]
    window_render_self(w0, px, py, &lr[0], &lg[0], &lb[0])
    if cr[0] != lr[0] or cg[0] != lg[0] or cb[0] != lb[0]:
        write_str(1, "[DECACHE] FAIL moved-window composite pixel != procedural render\n")
        return
    write_str(1, "[DECACHE] composited pixel is identical from cache after move OK\n")

    # --- (3) CONTENT CHANGE re-renders ONLY the dirtied window ---
    # Open two more windows so there are several caches to keep warm, then
    # sync once so all are cached and reused.
    daemon_spawn_app(APP_TERM, 80, 260, 300, 160)
    daemon_spawn_app(APP_CALC, 460, 120, 200, 280)
    window_cache_sync()                  # renders the two new windows
    window_cache_sync()                  # now everything is warm
    if WCACHE_LAST_RERENDERED != 0:
        write_str(1, "[DECACHE] FAIL warm sync still re-rendered a window\n")
        return
    # Dirty exactly ONE window's content (the About card, w0).
    window_content_dirty(w0)
    window_cache_sync()
    if WCACHE_LAST_RERENDERED != 1:
        write_str(1, "[DECACHE] FAIL content change re-rendered != 1 window\n")
        return
    write_str(1, "[DECACHE] a content change re-renders ONLY that window OK\n")

    # --- (4) OVERLAP: front window's cache wins where it covers a back one ---
    # Place a front window (highest slot, w_top) overlapping w0, then check a
    # pixel in the overlap composites to the FRONT surface, identical to the
    # procedural render of the front window.
    w_top: uint64 = DWIN_COUNT - 1
    DWIN_X[w_top] = DWIN_X[w0] + 20
    DWIN_Y[w_top] = DWIN_Y[w0] + 20
    DWIN_W[w_top] = 200
    DWIN_H[w_top] = 160
    DWIN_OPACITY[w_top] = 255            # opaque so it fully occludes
    window_reflow(w_top)                 # marks it content-dirty (geom change)
    window_cache_sync()
    ox: int64 = DWIN_X[w_top] + 50       # inside BOTH windows
    oy: int64 = DWIN_Y[w_top] + 50
    daemon_pixel(ox, oy, &cr[0], &cg[0], &cb[0])
    window_render_self(w_top, ox, oy, &lr[0], &lg[0], &lb[0])
    if cr[0] != lr[0] or cg[0] != lg[0] or cb[0] != lb[0]:
        write_str(1, "[DECACHE] FAIL overlap composite != front window surface\n")
        return
    write_str(1, "[DECACHE] overlapping windows still stack correctly through the cache OK\n")

    write_str(1, "[DECACHE] PASS\n")


# ====================================================================
# DECURSOR self-test (autoflag == 45) -- terminal cursor COLUMN tracking
# ====================================================================
# Proves the term_feed cursor-positioning CSI fix: hamsh's line editor
# repaints by emitting CR (-> column 0) then ESC[<n>C to park the caret at
# the real input column. The old term_feed swallowed every CSI, so the park
# was dropped and the cursor stayed at column 0. This drives the EXACT byte
# stream and asserts the tracked cell -- and that window_render_self draws
# the dark cursor BLOCK at that column, not at column 0. Pure model state, no
# real framebuffer. Emits '[DECURSOR] ... OK' lines + '[DECURSOR] PASS'.
def daemon_decursor_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    # Park the real cursor sprite far away so it never composites over the
    # window cells we sample.
    CUR_X = scr_w - 1
    CUR_Y = scr_h - 1
    daemon_spawn_app(APP_TERM, 100, 100, 360, 200)
    if DWIN_COUNT < 1:
        write_str(1, "[DECURSOR] FAIL could not spawn terminal window\n")
        return
    slot: uint64 = DWIN_COUNT - 1
    if DWIN_COLS[slot] < 20 or DWIN_ROWS[slot] < 3:
        write_str(1, "[DECURSOR] FAIL terminal grid too small for the test\n")
        return

    # --- 1. the hamsh _ed_redraw stream parks the caret at the real col ---
    # _ed_redraw emits: CR, prompt 'hamsh$ ', buffer 'abc', ESC[K, CR,
    # ESC[10C  (re-home then forward to the real column = prompt+buffer len).
    term_clear(slot)
    s1: Array[32, uint8]
    n1: int64 = 0
    s1[n1] = 13
    n1 = n1 + 1                    # CR
    pmt: Ptr[uint8] = "hamsh$ "
    pk: uint64 = 0
    while pmt[pk] != 0:
        s1[n1] = pmt[pk]
        n1 = n1 + 1
        pk = pk + 1
    s1[n1] = 97
    n1 = n1 + 1                    # 'a'
    s1[n1] = 98
    n1 = n1 + 1                    # 'b'
    s1[n1] = 99
    n1 = n1 + 1                    # 'c'
    s1[n1] = 27
    n1 = n1 + 1                    # ESC
    s1[n1] = 91
    n1 = n1 + 1                    # '['
    s1[n1] = 75
    n1 = n1 + 1                    # 'K'  (EL)
    s1[n1] = 13
    n1 = n1 + 1                    # CR (back to col 0)
    s1[n1] = 27
    n1 = n1 + 1                    # ESC
    s1[n1] = 91
    n1 = n1 + 1                    # '['
    s1[n1] = 49
    n1 = n1 + 1                    # '1'
    s1[n1] = 48
    n1 = n1 + 1                    # '0'
    s1[n1] = 67
    n1 = n1 + 1                    # 'C'  (CUF 10)
    term_feed(slot, &s1[0], n1)
    if DWIN_CUR_C[slot] != 10 or DWIN_CUR_R[slot] != 0:
        write_str(1, "[DECURSOR] FAIL ESC[<n>C did not park the caret at the real column\n")
        return
    write_str(1, "[DECURSOR] ESC[<n>C parks the caret at the real column OK\n")

    # --- 2. CUP sets an absolute cell (ESC[3;5H -> row2,col4 0-based) -----
    s2: Array[16, uint8]
    m2: int64 = 0
    s2[m2] = 27
    m2 = m2 + 1
    s2[m2] = 91
    m2 = m2 + 1
    s2[m2] = 51
    m2 = m2 + 1                    # '3'
    s2[m2] = 59
    m2 = m2 + 1                    # ';'
    s2[m2] = 53
    m2 = m2 + 1                    # '5'
    s2[m2] = 72
    m2 = m2 + 1                    # 'H'
    term_feed(slot, &s2[0], m2)
    if DWIN_CUR_R[slot] != 2 or DWIN_CUR_C[slot] != 4:
        write_str(1, "[DECURSOR] FAIL CUP ESC[3;5H did not land at the absolute cell\n")
        return
    write_str(1, "[DECURSOR] CUP ESC[3;5H lands at the absolute cell OK\n")

    # --- 3. CHA sets the absolute column (ESC[12G -> col11 0-based) -------
    s3: Array[16, uint8]
    m3: int64 = 0
    s3[m3] = 27
    m3 = m3 + 1
    s3[m3] = 91
    m3 = m3 + 1
    s3[m3] = 49
    m3 = m3 + 1                    # '1'
    s3[m3] = 50
    m3 = m3 + 1                    # '2'
    s3[m3] = 71
    m3 = m3 + 1                    # 'G'
    term_feed(slot, &s3[0], m3)
    if DWIN_CUR_C[slot] != 11:
        write_str(1, "[DECURSOR] FAIL CHA ESC[12G did not set the absolute column\n")
        return
    write_str(1, "[DECURSOR] CHA ESC[12G sets the absolute column OK\n")

    # --- 4. the cursor BLOCK renders at the tracked column, not column 0 --
    # Put the caret at a known interior cell, re-draw the prompt+buffer, and
    # confirm window_render_self paints the dark (24,24,24) cursor block at
    # the tracked column's pixel cell -- and NOT at column 0.
    term_clear(slot)
    pbuf: Ptr[uint8] = "hamsh$ abc"
    bk: uint64 = 0
    while pbuf[bk] != 0:
        term_putc(slot, pbuf[bk])
        bk = bk + 1
    # caret now sits at column 10 (len('hamsh$ abc'))
    track_c: int64 = DWIN_CUR_C[slot]
    track_r: int64 = DWIN_CUR_R[slot]
    if track_c != 10 or track_r != 0:
        write_str(1, "[DECURSOR] FAIL cursor not at the expected tracked cell after redraw\n")
        return
    # Sample the centre pixel of the tracked cursor cell and of column 0's
    # cell on the same row. window_render_self is window-local coords.
    cxr: Array[1, uint8]
    cxg: Array[1, uint8]
    cxb: Array[1, uint8]
    z0r: Array[1, uint8]
    z0g: Array[1, uint8]
    z0b: Array[1, uint8]
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    # body-text origin inside the window: the term grid begins just below the
    # title bar. window_render_self maps screen (x,y) to the grid internally,
    # so sample at the window's screen pixel for the tracked cell's centre.
    # Cell centre = grid origin + col*GLYPH_W + GLYPH_W/2. We don't know the
    # exact grid origin here, so probe a vertical/horizontal span and find the
    # row that contains text; instead we rely on the model: render the whole
    # tracked-column glyph column and the column-0 glyph column at the SAME
    # window-local y and compare. Use the title-bar-inclusive offset the
    # renderer itself uses by scanning for the cursor block.
    found_track: int32 = 0
    found_col0: int32 = 0
    yy: int64 = wy
    while yy < wy + DWIN_H[slot]:
        # tracked cell centre x
        xt: int64 = wx + track_c * GLYPH_W + GLYPH_W / 2
        x0c: int64 = wx + GLYPH_W / 2
        window_render_self(slot, xt, yy, &cxr[0], &cxg[0], &cxb[0])
        window_render_self(slot, x0c, yy, &z0r[0], &z0g[0], &z0b[0])
        if cxr[0] == 24 and cxg[0] == 24 and cxb[0] == 24:
            found_track = 1
        if z0r[0] == 24 and z0g[0] == 24 and z0b[0] == 24:
            found_col0 = 1
        yy = yy + 1
    if found_track == 0:
        write_str(1, "[DECURSOR] FAIL cursor block not drawn at the tracked column\n")
        return
    if found_col0 != 0:
        write_str(1, "[DECURSOR] FAIL cursor block wrongly drawn at column 0\n")
        return
    write_str(1, "[DECURSOR] cursor block renders at the tracked column, not col 0 OK\n")

    write_str(1, "[DECURSOR] PASS\n")


# ====================================================================
# DERECT self-test (autoflag == 44) — the /dev/fbctl RECT present path
# ====================================================================
# Proves PRIMITIVE 1 (binary dirty-rectangle present on /dev/fbctl) actually
# fires through to the kernel from the live compositor:
#   1. A partial present (a single window's frame) routes through the RECT
#      command. fbctl_present_rect returns 1 ONLY when the kernel's
#      _fbctl_rect_present handler ACKs the 52-byte write by returning 52,
#      so FBCTL_RECT_PRESENTS strictly increasing is end-to-end proof the
#      accelerated path ran (not the /dev/fb seek+write fallback).
#   2. SYSCALL REDUCTION: a sub-width window-frame present that used to cost
#      H seek+write pairs (one per scanline) now costs ceil(H/BAND_ROWS) RECT
#      writes. We report the row count and the RECT-write count so the win is
#      visible in the serial log.
#   3. CORRECTNESS GUARD: the RECT path composes the same screen_band buffer
#      the legacy path would; the kernel blits it opaquely (fb_present_rgba_row
#      ignores alpha, same repack as /dev/fb). We assert fbctl was actually
#      claimed (fbctl_fd >= 0) so a SKIP can be told apart from a real run.
# Emits "[DERECT] PASS" / "[DERECT] FAIL <reason>" / "[DERECT] SKIP ...".
# This self-test requires a real /dev/fbctl (claimed by fb_console_takeover
# before dispatch); on a headless surface it SKIPs cleanly.
def daemon_derect_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    # Park the cursor in a far corner so the cursor sprite never overlaps the
    # presented window rect (keeps the proof about the window, not the cursor).
    CUR_X = scr_w - 1
    CUR_Y = scr_h - 1
    if fbctl_fd < 0:
        # No /dev/fbctl on this surface: the RECT path is unavailable and the
        # compositor falls back to /dev/fb. Nothing to prove here — SKIP.
        write_str(1, "[DERECT] SKIP /dev/fbctl not claimed (headless / old kernel)\n")
        write_str(1, "[DERECT] PASS\n")
        return
    # --- Open ONE window well clear of screen edges and the fb-text console.
    daemon_spawn_app(APP_ABOUT, 760, 120, 360, 240)
    if DWIN_COUNT < 1:
        write_str(1, "[DERECT] FAIL could not spawn window 0\n")
        return
    w0: uint64 = DWIN_COUNT - 1
    wx: int64 = DWIN_X[w0]
    wy: int64 = DWIN_Y[w0]
    ww: int64 = DWIN_W[w0]
    wh: int64 = DWIN_H[w0]
    # A sub-width window frame is the case the legacy path paid one seek+write
    # PER ROW for. Confirm the rect really is sub-width (else this proves the
    # full-width band case, also fine, but say which).
    sub_width: int32 = 0
    if wx > 0 or wx + ww < scr_w:
        sub_width = 1
    # --- Drive a partial present of ONLY this window's frame via the real
    # per-frame damage path (daemon_flush_damage -> daemon_present_rect).
    before: uint64 = FBCTL_RECT_PRESENTS
    damage_reset()
    damage_window(w0)
    if daemon_flush_damage() == 0:
        write_str(1, "[DERECT] FAIL nothing presented for single-window damage\n")
        return
    if DMG_LAST_FULL != 0:
        write_str(1, "[DERECT] FAIL single-window update escalated to a FULL present\n")
        return
    after: uint64 = FBCTL_RECT_PRESENTS
    if after <= before:
        # The partial present did NOT use the RECT command — it fell back to
        # the /dev/fb seek+write path even though fbctl is claimed. That means
        # the acceleration we wired is not actually firing. Hard FAIL.
        write_str(1, "[DERECT] FAIL partial present did NOT use the /dev/fbctl RECT path\n")
        return
    rect_writes: uint64 = after - before
    # --- Report the numbers: rows presented vs. RECT writes issued. The
    # legacy path would have issued one seek+write per row (wh of them); the
    # RECT path issued rect_writes (ceil(rows / SCREEN_BAND_ROWS)).
    rows: uint64 = cast[uint64](wh)
    line: Array[200, uint8]
    p: uint64 = 0
    p = sm_puts(&line[0], p, "[DERECT] window rect=")
    p = p + u64_to_dec(cast[uint64](ww), &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(rows, &line[p])
    p = sm_puts(&line[0], p, " rows=")
    p = p + u64_to_dec(rows, &line[p])
    p = sm_puts(&line[0], p, " legacy_seekwrites=")
    p = p + u64_to_dec(rows, &line[p])
    p = sm_puts(&line[0], p, " rect_writes=")
    p = p + u64_to_dec(rect_writes, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)
    if sub_width != 0:
        write_str(1, "[DERECT] sub-width window frame presented via the /dev/fbctl RECT path OK\n")
    else:
        write_str(1, "[DERECT] full-width band presented via the /dev/fbctl RECT path OK\n")
    # The reduction must be real: for any window taller than one band, the
    # RECT path must issue strictly fewer writes than the legacy per-row path.
    if rows > SCREEN_BAND_ROWS and rect_writes >= rows:
        write_str(1, "[DERECT] FAIL RECT writes did not beat the per-row count\n")
        return
    write_str(1, "[DERECT] RECT present collapses the per-row seek+write loop OK\n")

    # --- A genuine full-screen present must ALSO ride the RECT path (the
    # full-frame daemon_present bands are RECT-blitted too).
    before2: uint64 = FBCTL_RECT_PRESENTS
    if daemon_present() != 0:
        write_str(1, "[DERECT] FAIL full present returned error\n")
        return
    after2: uint64 = FBCTL_RECT_PRESENTS
    if after2 <= before2:
        write_str(1, "[DERECT] FAIL full-screen present did NOT use the RECT path\n")
        return
    write_str(1, "[DERECT] full-screen present also rides the RECT path OK\n")

    write_str(1, "[DERECT] PASS\n")


# ====================================================================
# ROUND-18 MATE-feel self-test (autoflag == 28)
# ====================================================================
# Exercises the round-18 desktop features WITHOUT QEMU mouse injection:
#   1. SESSION COUNTDOWN: arming a logout/shutdown countdown ticks down,
#      Cancel stops it without firing, and reaching 0 auto-confirms the
#      pending intent (sets SESSION_INTENT + DAEMON_QUIT).
#   2. LOCK PASSWORD: a wrong entry bumps the fail counter + stays locked;
#      the correct secret unlocks + resets fails; the entry buffer edits
#      via push/backspace/clear.
#   3. SUPER+N WORKSPACE GRID: Super+N jumps to workspace N for in-range N
#      and rejects out-of-range; Super+Shift+N moves the focused window to
#      workspace N and follows it. Asserted for BOTH panel positions (the
#      switch path is position-independent but the OSD band tracks PANEL_POS,
#      asserted via osd_y0).
#   4. APP RECENT/FAVORITES: the launch-frequency model orders the Recently
#      Used view by recency and the Favorites view by count (ties by recency).
#   5. NOTIFICATION RULES: DND suppresses normal banners but lets critical
#      through; per-urgency expiry sets NOTIFY_TTL; urgency accent differs.
#   6. CLOCK FORMAT: 24h/12h, show-seconds and show-date produce the exact
#      expected strings.
# Emits "[DE18] PASS" / "[DE18] FAIL <reason>".
def daemon_round18_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    WS_COUNT = 4
    PANEL_POS = 0
    SESSION_OPEN = 0
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    LOCKED = 0
    scheme_palette_init()
    scheme_set(0)

    # --- Step 1: session logout/shutdown countdown ---
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    session_arm_countdown(1)             # logout
    if SESSION_COUNTDOWN != SESSION_COUNTDOWN_MAX or SESSION_PENDING != 1:
        write_str(1, "[DE18] FAIL countdown not armed\n")
        return
    # One tick decrements by exactly one second.
    if session_countdown_tick() != SESSION_COUNTDOWN_MAX - 1:
        write_str(1, "[DE18] FAIL countdown did not tick\n")
        return
    # Cancel stops it WITHOUT firing.
    session_cancel_countdown()
    if SESSION_COUNTDOWN != 0 or SESSION_PENDING != 0:
        write_str(1, "[DE18] FAIL cancel did not stop countdown\n")
        return
    if DAEMON_QUIT != 0 or SESSION_INTENT != 0:
        write_str(1, "[DE18] FAIL cancel fired the intent\n")
        return
    # Drive a shutdown countdown to zero: it auto-confirms.
    SESSION_OPEN = 1
    session_arm_countdown(2)             # shutdown
    guard: int32 = 0
    while SESSION_COUNTDOWN > 0 and guard < 1000:
        session_countdown_tick()
        guard = guard + 1
    if SESSION_INTENT != 2 or DAEMON_QUIT != 1:
        write_str(1, "[DE18] FAIL countdown did not auto-confirm shutdown\n")
        return
    if SESSION_OPEN != 0:
        write_str(1, "[DE18] FAIL session dialog still open after fire\n")
        return
    # Reset session state for the rest of the test.
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    SESSION_PENDING = 0
    SESSION_COUNTDOWN = 0
    SESSION_OPEN = 0

    # --- Step 2: lock-screen password model ---
    LOCK_SECRET_SET = 0
    lock_secret_init()                   # default secret = "hamnix"
    LOCKED = 1
    LOCK_FAILS = 0
    lock_pw_clear()
    # Type a WRONG password.
    lock_pw_push(98)                     # 'b'
    lock_pw_push(97)                     # 'a'
    lock_pw_push(100)                    # 'd'
    if LOCK_PW_LEN != 3:
        write_str(1, "[DE18] FAIL lock entry length wrong\n")
        return
    if lock_pw_try() != 0:
        write_str(1, "[DE18] FAIL wrong password unlocked\n")
        return
    if LOCKED != 1 or LOCK_FAILS != 1:
        write_str(1, "[DE18] FAIL wrong attempt did not stay locked\n")
        return
    if LOCK_PW_LEN != 0:
        write_str(1, "[DE18] FAIL field not cleared after fail\n")
        return
    # Type "hamnix" then backspace + retype the last byte to exercise edits.
    lock_pw_push(104)                    # 'h'
    lock_pw_push(97)                     # 'a'
    lock_pw_push(109)                    # 'm'
    lock_pw_push(110)                    # 'n'
    lock_pw_push(105)                    # 'i'
    lock_pw_push(120)                    # 'x'
    lock_pw_push(121)                    # 'y'  (typo)
    lock_pw_backspace()                  # remove the 'y'
    if LOCK_PW_LEN != 6:
        write_str(1, "[DE18] FAIL backspace length wrong\n")
        return
    if cstr_eq(&lock_pw_buf[0], "hamnix") == 0:
        write_str(1, "[DE18] FAIL lock entry text wrong\n")
        return
    if lock_pw_try() != 1:
        write_str(1, "[DE18] FAIL correct password did not unlock\n")
        return
    if LOCKED != 0 or LOCK_FAILS != 0:
        write_str(1, "[DE18] FAIL unlock did not reset state\n")
        return
    # A changed secret takes effect immediately.
    lock_set_password("secret")
    LOCKED = 1
    lock_pw_clear()
    lock_pw_push(104)                    # 'h' — old secret no longer valid
    lock_pw_push(97)
    if lock_pw_try() != 0:
        write_str(1, "[DE18] FAIL old secret still worked\n")
        return
    lock_pw_clear()
    lock_pw_push(115)                    # 's'
    lock_pw_push(101)                    # 'e'
    lock_pw_push(99)                     # 'c'
    lock_pw_push(114)                    # 'r'
    lock_pw_push(101)                    # 'e'
    lock_pw_push(116)                    # 't'
    if lock_pw_try() != 1:
        write_str(1, "[DE18] FAIL new secret did not unlock\n")
        return
    LOCKED = 0

    # --- Step 3: Super+N workspace grid + move-to-workspace ---
    # Jump directly to workspace 3 (1-based) => CUR_WS == 2.
    CUR_WS = 0
    if workspace_goto_n(3) != 2 or CUR_WS != 2:
        write_str(1, "[DE18] FAIL Super+3 did not jump\n")
        return
    # Out of range (WS_COUNT == 4, so 5 is invalid) is rejected, no switch.
    CUR_WS = 1
    if workspace_goto_n(5) != -1 or CUR_WS != 1:
        write_str(1, "[DE18] FAIL out-of-range Super+N not rejected\n")
        return
    # Move the focused window to workspace 4 and follow it.
    daemon_spawn_app(APP_CALC, 80, PANEL_H + 20, 220, 180)
    if DWIN_COUNT < 1:
        write_str(1, "[DE18] FAIL could not spawn window\n")
        return
    fslot: int64 = daemon_focus_slot()
    CUR_WS = 0
    if window_to_workspace_n(4) != 3:
        write_str(1, "[DE18] FAIL Super+Shift+4 did not move window\n")
        return
    if DWIN_WS[cast[uint64](fslot)] != 3 or CUR_WS != 3:
        write_str(1, "[DE18] FAIL window not on ws4 / did not follow\n")
        return
    # The workspace-switch OSD band tracks the panel position.
    PANEL_POS = 0
    top_band: int64 = osd_y0(scr_h)
    PANEL_POS = 1
    bot_band: int64 = osd_y0(scr_h)
    if top_band == bot_band:
        write_str(1, "[DE18] FAIL ws OSD band did not track panel\n")
        return
    PANEL_POS = 0
    CUR_WS = 0

    # --- Step 4: Applications recent + favorites ordering ---
    app_freq_reset()
    if app_freq_used_count() != 0:
        write_str(1, "[DE18] FAIL freq model not empty after reset\n")
        return
    # Launch sequence (flat indices): Terminal(0)x3, Calc(3)x1, Files(8)x2.
    # Most-recent order should end Files (last touched), then whatever was
    # touched before. Sequence: 0,0,3,8,0,8.
    app_freq_record(0)
    app_freq_record(0)
    app_freq_record(3)
    app_freq_record(8)
    app_freq_record(0)
    app_freq_record(8)
    if app_freq_used_count() != 3:
        write_str(1, "[DE18] FAIL used count wrong\n")
        return
    # Recency: newest is 8 (Files), then 0 (Terminal), then 3 (Calc).
    if app_recent_index(0) != 8:
        write_str(1, "[DE18] FAIL recent[0] wrong\n")
        return
    if app_recent_index(1) != 0:
        write_str(1, "[DE18] FAIL recent[1] wrong\n")
        return
    if app_recent_index(2) != 3:
        write_str(1, "[DE18] FAIL recent[2] wrong\n")
        return
    if app_recent_index(3) != -1:
        write_str(1, "[DE18] FAIL recent past-end not -1\n")
        return
    # Favorites by count: Terminal(0) count 3, Files(8) count 2, Calc(3) 1.
    if app_favorite_index(0) != 0:
        write_str(1, "[DE18] FAIL favorite[0] wrong\n")
        return
    if app_favorite_index(1) != 8:
        write_str(1, "[DE18] FAIL favorite[1] wrong\n")
        return
    if app_favorite_index(2) != 3:
        write_str(1, "[DE18] FAIL favorite[2] wrong\n")
        return
    if app_favorite_index(3) != -1:
        write_str(1, "[DE18] FAIL favorite past-end not -1\n")
        return

    # --- Step 5: notification rules (DND, urgency, expiry) ---
    NOTIF_DND = 0
    NOTIFY_ACTIVE = 0
    # A normal post shows and sets the normal TTL + accent.
    if notif_rule_post("Hi", "normal notice", NOTIF_NORMAL) != 1:
        write_str(1, "[DE18] FAIL normal post not shown\n")
        return
    if NOTIFY_ACTIVE != 1 or NOTIFY_TTL != NOTIF_TTL_NORMAL:
        write_str(1, "[DE18] FAIL normal ttl wrong\n")
        return
    if NOTIF_URGENCY != NOTIF_NORMAL:
        write_str(1, "[DE18] FAIL urgency not recorded\n")
        return
    # Turn on DND: a normal post is suppressed (returns 0, banner not re-armed).
    notif_dnd_toggle()
    if NOTIF_DND != 1:
        write_str(1, "[DE18] FAIL dnd did not turn on\n")
        return
    NOTIFY_ACTIVE = 0
    if notif_rule_post("Spam", "low notice", NOTIF_LOW) != 0:
        write_str(1, "[DE18] FAIL low not suppressed under dnd\n")
        return
    if NOTIFY_ACTIVE != 0:
        write_str(1, "[DE18] FAIL suppressed banner still armed\n")
        return
    # A CRITICAL post breaks through DND with the long expiry + red accent.
    if notif_rule_post("Battery", "critical low", NOTIF_CRITICAL) != 1:
        write_str(1, "[DE18] FAIL critical not shown under dnd\n")
        return
    if NOTIFY_TTL != NOTIF_TTL_CRITICAL:
        write_str(1, "[DE18] FAIL critical ttl wrong\n")
        return
    if notif_urg_r(NOTIF_CRITICAL) <= notif_urg_r(NOTIF_NORMAL):
        write_str(1, "[DE18] FAIL critical accent not redder\n")
        return
    if notif_urg_g(NOTIF_LOW) != notif_urg_b(NOTIF_LOW):
        write_str(1, "[DE18] FAIL low accent not neutral grey\n")
        return
    # Toggle DND back off.
    notif_dnd_toggle()
    if NOTIF_DND != 0:
        write_str(1, "[DE18] FAIL dnd did not turn off\n")
        return

    # --- Step 6: clock format settings ---
    # 24-hour, no seconds, no date: 13:05 -> "13:05".
    CLOCK_24H = 1
    CLOCK_SHOW_SEC = 0
    CLOCK_SHOW_DATE = 0
    clock_format(13, 5, 9)
    if cstr_eq(&clock_fmt_buf[0], "13:05") == 0:
        write_str(1, "[DE18] FAIL 24h clock wrong\n")
        return
    # 24-hour with seconds: 13:05:09 -> "13:05:09".
    CLOCK_SHOW_SEC = 1
    clock_format(13, 5, 9)
    if cstr_eq(&clock_fmt_buf[0], "13:05:09") == 0:
        write_str(1, "[DE18] FAIL 24h+sec clock wrong\n")
        return
    # 12-hour PM, no seconds: 13:05 -> "01:05 PM".
    CLOCK_24H = 0
    CLOCK_SHOW_SEC = 0
    clock_format(13, 5, 0)
    if cstr_eq(&clock_fmt_buf[0], "01:05 PM") == 0:
        write_str(1, "[DE18] FAIL 12h PM clock wrong\n")
        return
    # 12-hour AM, midnight maps to 12 AM: 0:30 -> "12:30 AM".
    clock_format(0, 30, 0)
    if cstr_eq(&clock_fmt_buf[0], "12:30 AM") == 0:
        write_str(1, "[DE18] FAIL 12h midnight clock wrong\n")
        return
    # 12-hour noon maps to 12 PM: 12:00 -> "12:00 PM".
    clock_format(12, 0, 0)
    if cstr_eq(&clock_fmt_buf[0], "12:00 PM") == 0:
        write_str(1, "[DE18] FAIL 12h noon clock wrong\n")
        return
    # Show-date appends the live date prefix. Seed a known date string.
    clock_date_str[0] = 50               # '2'
    clock_date_str[1] = 48               # '0'
    clock_date_str[2] = 50               # '2'
    clock_date_str[3] = 54               # '6'
    clock_date_str[4] = 45               # '-'
    clock_date_str[5] = 48               # '0'
    clock_date_str[6] = 54               # '6'
    clock_date_str[7] = 45               # '-'
    clock_date_str[8] = 48               # '0'
    clock_date_str[9] = 51               # '3'
    clock_date_str[10] = 32
    CLOCK_24H = 1
    CLOCK_SHOW_SEC = 0
    CLOCK_SHOW_DATE = 1
    clock_format(13, 5, 0)
    if cstr_eq(&clock_fmt_buf[0], "13:05 2026-06-03") == 0:
        write_str(1, "[DE18] FAIL clock+date wrong\n")
        return

    # --- Reset to a clean desktop ---
    CLOCK_24H = 1
    CLOCK_SHOW_SEC = 0
    CLOCK_SHOW_DATE = 0
    NOTIF_DND = 0
    NOTIFY_ACTIVE = 0
    NOTIFY_TTL = 180
    app_freq_reset()
    SESSION_OPEN = 0
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    SESSION_COUNTDOWN = 0
    SESSION_PENDING = 0
    LOCKED = 0
    lock_pw_clear()
    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE18] PASS\n")


# Helper for the round-15 urgency check: returns 1 if ANY window is still
# urgent after the clear path ran (so the self-test stays branch-free).
def window_clear_urgent_check() -> int32:
    return any_window_urgent()


# Scratch buffer for the stdin command we inject.
term_test_cmd: Array[32, uint8]

def daemon_terminal_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: first autowin (hamsh + pipes) ---
    daemon_spawn_window(120, 80, 400, 240)
    if DWIN_COUNT == 0:
        write_str(1, "TERM IO FAIL no window spawned\n")
        return
    sl0: uint64 = DWIN_COUNT - 1
    infd: int32 = DWIN_IN_FD[sl0]
    outfd: int32 = DWIN_OUT_FD[sl0]
    if infd < 0:
        write_str(1, "TERM IO FAIL no stdin pipe for window 0\n")
        return
    if outfd < 0:
        write_str(1, "TERM IO FAIL no stdout pipe for window 0\n")
        return
    # --- Step 2: write the sentinel command to hamsh stdin ---
    # The command bytes sit in the pipe buffer until hamsh starts and
    # calls sys_read_nb(0,...). Since we patched hamsh to skip the
    # getty-style flush loop for pipe-backed stdin (DEVFD_PIPE_R), the
    # bytes are NOT discarded by the flush window — hamsh picks them up
    # on the very first readline poll pass.
    cmd_s: Ptr[uint8] = "echo HAMUI_TERM_TEST\n"
    sys_write(infd, cmd_s, strlen_u8(cmd_s))
    # --- Step 3: Non-blocking poll loop until the sentinel appears ---
    # We use sys_read_nb + sys_yield so the hamsh process gets CPU time
    # to start up and process the command. We stop as soon as the
    # sentinel appears in the grid. Idle = consecutive empty reads; we
    # cap at IDLE_MAX to bound run time (each yield is very fast on TCG).
    # On TCG hamsh may take thousands of scheduler rounds to start — a
    # large IDLE_MAX (200000) is safe and still completes well within
    # the 120s QEMU timeout.
    found0: int32 = 0
    idle0: int32 = 0
    while idle0 < 200000 and found0 == 0:
        n: int64 = sys_read_nb(outfd, &term_rx[0], 1024)
        if n > 0:
            idle0 = 0
            term_feed(sl0, &term_rx[0], n)
            if term_grid_contains(sl0, "HAMUI_TERM_TEST") != 0:
                found0 = 1
        else:
            idle0 = idle0 + 1
            sys_yield()
    if found0 == 0:
        write_str(1, "TERM IO FAIL sentinel not in window 0 grid\n")
        return
    write_str(1, "TERM IO window0 OK\n")
    # --- Step 4: focus-switch test ---
    # Create a second window so we can verify focus routing changes.
    daemon_spawn_window(200, 160, 400, 240)
    if DWIN_COUNT < 2:
        # Only one window was created (table full or spawn failed); skip
        # the two-window focus routing test.
        write_str(1, "TERM IO PASS (single-window)\n")
        return
    # Simulate a body-click on the FIRST window (slot 0) to raise it.
    # The first window is now slot 0 (two windows: 0 and 1, where 1 is
    # topmost after creation). Compute a point inside its body area.
    bclick_x: int64 = DWIN_X[0] + DWIN_W[0] / 2
    bclick_y: int64 = DWIN_Y[0] + TITLE_H + DWIN_H[0] / 2
    bclick_x = iclamp(bclick_x, 0, scr_w - 1)
    bclick_y = iclamp(bclick_y, 0, scr_h - 1)
    # Synthetic mouse click on the first window's body: press + release.
    CUR_X = bclick_x
    CUR_Y = bclick_y
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise the first window becomes the topmost slot; confirm focus.
    new_focus: int64 = daemon_focus_slot()
    focus_x: int64 = DWIN_X[cast[uint64](new_focus)]
    focus_y: int64 = DWIN_Y[cast[uint64](new_focus)]
    # The raised window's origin should match what we clicked into.
    in_raised: int32 = 0
    if bclick_x >= focus_x and bclick_x < focus_x + DWIN_W[cast[uint64](new_focus)]:
        if bclick_y >= focus_y and bclick_y < focus_y + DWIN_H[cast[uint64](new_focus)]:
            in_raised = 1
    if in_raised == 0:
        write_str(1, "TERM IO FAIL focus did not switch to clicked window\n")
        return
    write_str(1, "TERM IO focus-switch OK\n")
    # Route a second sentinel to the newly-focused window and confirm it
    # arrives in that window's grid.
    new_infd: int32 = DWIN_IN_FD[cast[uint64](new_focus)]
    if new_infd >= 0:
        new_outfd: int32 = DWIN_OUT_FD[cast[uint64](new_focus)]
        cmd2: Ptr[uint8] = "echo HAMUI_TERM_TEST2\n"
        sys_write(new_infd, cmd2, strlen_u8(cmd2))
        found2: int32 = 0
        idle2: int32 = 0
        while idle2 < 200000 and found2 == 0:
            n2: int64 = sys_read_nb(new_outfd, &term_rx[0], 1024)
            if n2 > 0:
                idle2 = 0
                term_feed(cast[uint64](new_focus), &term_rx[0], n2)
                if term_grid_contains(cast[uint64](new_focus), "HAMUI_TERM_TEST2") != 0:
                    found2 = 1
            else:
                idle2 = idle2 + 1
                sys_yield()
        if found2 == 0:
            write_str(1, "TERM IO FAIL sentinel2 not in focused window grid\n")
            return
    write_str(1, "TERM IO window1 OK\n")
    write_str(1, "TERM IO PASS\n")


# ====================================================================
# GPU track #183 — native Vulkan output INTO a real desktop window
# ====================================================================
#
# daemon_vk_window_selftest creates a NORMAL composited window at a known
# on-screen position whose BODY is filled by the native kernel-side
# lib/vk software rasterizer (a rotating triangle). Each frame the daemon
# asks the kernel to render the next frame into the window's draw-surface
# "vk" fb layer (sys_vk_window_frame), reads that layer back into
# vk_body_buf, marks the window as vk-bodied, composites the WHOLE screen
# through the SAME daemon_present path every other window uses, and
# samples the composited result to prove:
#   * inside the window's body rect the screen shows the Vulkan colours,
#   * OUTSIDE the window the screen shows the desktop backdrop (proving
#     it is WINDOWED, not a full-screen takeover),
#   * frame N and frame N+1 differ at a pixel the rotation moves (live
#     animation, not a static blit).
# All assertions read the composited frame through daemon_pixel — the
# exact value written to /dev/fb at that screen pixel — so they are
# unforgeable. Markers print as "[vk-window] ..." lines.

# Read window `wid`'s "vk" draw-surface fb layer into vk_body_buf. The
# layer is RGBA8888, up to VK_BODY_W x VK_BODY_H. Returns the bytes read.
def daemon_vk_read_body(wid: int32) -> int64:
    vp: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while vp[j] != 0:
        path_buf[i] = vp[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    sfx: Ptr[uint8] = "/draw/vk/fb"
    j = 0
    while sfx[j] != 0:
        path_buf[i] = sfx[j]
        i = i + 1
        j = j + 1
    path_buf[i] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &vk_body_buf[0],
                          cast[uint64](VK_BODY_W * VK_BODY_H * 4))
    sys_close(fd)
    return n


# Sample the composited screen colour at (sx,sy) into r/g/b via the SAME
# daemon_pixel path that fills /dev/fb. Returns packed 0xRRGGBB.
def daemon_screen_sample(sx: int64, sy: int64) -> uint64:
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    daemon_pixel(sx, sy, &rr[0], &gg[0], &bb[0])
    return (cast[uint64](rr[0]) << 16) | (cast[uint64](gg[0]) << 8) \
        | cast[uint64](bb[0])


# ====================================================================
# MARKUP-CLIENT self-test (autoflag == 46)
# ====================================================================
# Proves the LIVE composite path now incorporates an external hamui
# client's "ui" markup layer — i.e. a program built on lib/hamui.ad
# appears as real pixels in the composited frame, NOT only through the
# offline `present`/`render` one-shot.
#
# The test simulates a hamui client end-to-end against the SAME code the
# live daemon runs every frame:
#   1. Spawn a chrome-only window (/bin/true) so the daemon owns a real
#      kernel wid with a draw surface (exactly the VK-test setup).
#   2. Inject a known "ui" markup layer onto that wid's draw surface,
#      exactly as lib/hamui.ad's hamui_render does (mklayer ui markup +
#      write hamML to .../draw/ui/markup). The markup paints a body-
#      filling rect of a SENTINEL colour with a smaller inner rect of a
#      second sentinel colour.
#   3. Call daemon_present() — the live path. Its window_cache_sync ->
#      markup_sync auto-detects the "ui" layer, latches DWIN_MARKUP, and
#      rasterises the markup into markup_body_buf; window_render_self then
#      samples that buffer for every body pixel.
#   4. Sample the COMPOSITED screen (the exact bytes written to /dev/fb)
#      and assert: the outer sentinel colour at a body pixel, the inner
#      sentinel colour at an inner-rect pixel, and the desktop backdrop
#      outside the window (proving it is windowed, not full-screen, and
#      that the markup — not a procedural app body — is on screen).
# Markers print as "[markup-client] ...".

# Inject a known "ui" markup layer onto window `wid`'s draw surface, the
# way a real hamui client would. `bw`/`bh` are the window body dimensions
# so the outer rect fills the whole body. Returns 1 on success.
mkc_inject_buf: Array[512, uint8]
def mkc_inject_ui(wid: int32, bw: int64, bh: int64) -> int32:
    # Create the "ui" markup layer (idempotent if it already exists). The
    # mklayer verb must go to the draw CTL sink at /dev/wsys/<wid>/draw/ctl
    # (DEV_WSYS_DRAW_CTL); the bare .../draw node is the READ-ONLY z-listing
    # and silently drops writes. Pass "ctl" as the layer arg so build_path
    # emits ".../draw/ctl" (leaf NULL).
    build_path(wid, cast[Ptr[uint8]]("ctl"), cast[Ptr[uint8]](0))
    cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if cf < 0:
        return 0
    mk: Ptr[uint8] = "mklayer ui markup\n"
    sys_write(cf, mk, strlen_u8(mk))
    sz: Ptr[uint8] = "setz ui 10\n"
    sys_write(cf, sz, strlen_u8(sz))
    sys_close(cf)
    # Compose the hamML: a window-content-sized outer rect (#22cc44) plus a
    # 40x30 inner rect (#cc2244) at (20,20), and a line of text. Built into
    # mkc_inject_buf with the existing decimal helper (no malloc).
    p: uint64 = 0
    s1: Ptr[uint8] = "<window w=\""
    k: uint64 = 0
    while s1[k] != 0:
        mkc_inject_buf[p] = s1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](bw), &mkc_inject_buf[p])
    s2: Ptr[uint8] = "\" h=\""
    k = 0
    while s2[k] != 0:
        mkc_inject_buf[p] = s2[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](bh), &mkc_inject_buf[p])
    s3: Ptr[uint8] = "\"><rect x=\"0\" y=\"0\" w=\""
    k = 0
    while s3[k] != 0:
        mkc_inject_buf[p] = s3[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](bw), &mkc_inject_buf[p])
    s4: Ptr[uint8] = "\" h=\""
    k = 0
    while s4[k] != 0:
        mkc_inject_buf[p] = s4[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](bh), &mkc_inject_buf[p])
    s5: Ptr[uint8] = "\" fill=\"#22cc44\"/><rect x=\"20\" y=\"20\" w=\"40\" h=\"30\" fill=\"#cc2244\"/><text x=\"20\" y=\"60\" fill=\"#ffffff\">HAMUI</text></window>"
    k = 0
    while s5[k] != 0:
        mkc_inject_buf[p] = s5[k]
        p = p + 1
        k = k + 1
    # Write the hamML to the "ui" layer's markup body in one syscall.
    build_path(wid, cast[Ptr[uint8]]("ui"), "markup")
    mf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if mf < 0:
        return 0
    sys_write(mf, &mkc_inject_buf[0], p)
    sys_close(mf)
    return 1


def daemon_markup_client_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    # --- Step 1: spawn a chrome-only window with a real kernel wid. ---
    win_x: int64 = 700
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 260
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[markup-client] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[markup-client] FAIL no wid for window\n")
        return
    # Body dimensions (window minus 2px border + title bar).
    bw: int64 = DWIN_W[sl] - 4
    bh: int64 = DWIN_H[sl] - TITLE_H - 2
    # --- Step 2: inject a hamui-style "ui" markup layer. ---
    if mkc_inject_ui(wid, bw, bh) == 0:
        write_str(1, "[markup-client] FAIL cannot inject ui markup\n")
        return
    write_str(1, "[markup-client] ui markup injected\n")
    # The window must NOT yet be flagged: detection happens in the live
    # present path, proving the daemon auto-recognises the client.
    if DWIN_MARKUP[sl] != 0:
        write_str(1, "[markup-client] FAIL flagged before present\n")
        return
    # --- Step 3: run the LIVE composite path. ---
    daemon_present()
    if DWIN_MARKUP[sl] == 0:
        write_str(1, "[markup-client] FAIL ui client not auto-detected\n")
        return
    write_str(1, "[markup-client] client auto-detected + flagged\n")
    if markup_body_ready[sl] == 0:
        write_str(1, "[markup-client] FAIL body not rasterised\n")
        return
    # --- Step 4: sample the COMPOSITED screen. ---
    body_x: int64 = DWIN_X[sl] + 2
    body_y: int64 = DWIN_Y[sl] + TITLE_H
    # Outer-rect probe: clear of the 40x30 inner rect + the text row.
    out_px: int64 = body_x + 120
    out_py: int64 = body_y + 120
    # Inner-rect probe: inside (20,20)..(60,50) in body coords.
    in_px: int64 = body_x + 35
    in_py: int64 = body_y + 32
    # Outside-window probe: the desktop backdrop.
    bgx: int64 = DWIN_X[sl] - 40
    bgy: int64 = DWIN_Y[sl] + 30
    if bgx < 0:
        bgx = 4
        bgy = 4
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    outer: uint64 = 0x22cc44
    inner: uint64 = 0xcc2244
    so: uint64 = daemon_screen_sample(out_px, out_py)
    si: uint64 = daemon_screen_sample(in_px, in_py)
    sb: uint64 = daemon_screen_sample(bgx, bgy)
    if so != outer:
        write_str(1, "[markup-client] FAIL body pixel not markup outer fill\n")
        return
    write_str(1, "[markup-client] OK outer rect on screen\n")
    if si != inner:
        write_str(1, "[markup-client] FAIL inner-rect pixel not markup inner fill\n")
        return
    write_str(1, "[markup-client] OK inner rect on screen\n")
    if sb != bg:
        write_str(1, "[markup-client] FAIL outside window is not backdrop\n")
        return
    write_str(1, "[markup-client] OK windowed (backdrop outside window)\n")
    # Final present so a screendump catches the windowed markup frame.
    daemon_present()
    write_str(1, "[markup-client] PASS\n")


# 1 iff the first `len` bytes of `hay` contain the NUL-terminated `needle`
# as a contiguous substring. Used by the spine self-test to scan accumulated
# stdout-pipe chatter for the child's markers.
def buf_contains(hay: Ptr[uint8], len: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(needle)
    if nlen == 0:
        return 1
    if nlen > len:
        return 0
    i: uint64 = 0
    while i + nlen <= len:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            if hay[i + k] != needle[k]:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


# ====================================================================
# SEPARATE-PROCESS APP SPINE self-test (autoflag == 47)
# ====================================================================
# Increment-1 of the MATE-mirror DE rewrite. Proves the component split
# end-to-end on the LIVE compositor path:
#
#   (a) INPUT OWNERSHIP / NO LEAK. The compositor SPAWNS /bin/hamecho as its
#       OWN process, allocates it a real kernel wid, makes it the focused
#       window, then routes a keystroke via the focus-gated key path
#       (evt_emit_key -> /dev/wsys/<wid>/keys). hamecho echoes the received
#       code to ITS stdout (a pipe the compositor owns). We drain that pipe
#       and assert the "ECHO <code>" marker appears — proof the routed key
#       crossed into the SEPARATE process. We ALSO read /dev/cons
#       non-blocking and assert the routed key did NOT appear there, proving
#       the keystroke went exclusively to the per-window stream and never to
#       the shared console the boot/serial shell reads.
#
#   (b) NO FULL-SCREEN RECOMPOSITE ON SPAWN (the terminal-open lag bug).
#       Spawning the app raises damage on ONLY its own window rect and
#       presents via the dirty-rect path. We assert DMG_LAST_FULL==0 and the
#       presented area equals the new window's rect area — never the screen.
#
#   (c) APP PIXELS ON SCREEN. hamecho's hamui "ui" markup layer is
#       auto-detected by the live present path (DWIN_MARKUP latches,
#       markup_body_ready set) and its body composites at the window rect
#       while the desktop backdrop shows outside it (windowed, not
#       full-screen).
#
# Markers print as "[spine] ...". The harness
# (scripts/test_hamUI_appspine_gop.sh) asserts them on a REAL EFI GOP frame.

def daemon_app_spine_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    # --- Step 1: spawn /bin/hamecho as a SEPARATE process with a wid. ---
    win_x: int64 = 700
    win_y: int64 = 140
    win_w: int64 = 300
    win_h: int64 = 220
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    # Establish a clean damage baseline, then spawn. The spawn path itself
    # raises NO damage (the caller owns damage policy), so we damage ONLY the
    # new window's rect here — never the screen — which is the structural
    # guarantee against the terminal-open full recomposite.
    damage_reset()
    pre_count: uint64 = DWIN_COUNT
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamecho"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT != pre_count + 1:
        write_str(1, "[spine] FAIL no window spawned for hamecho\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[spine] FAIL no wid allocated for hamecho\n")
        return
    outfd: int32 = DWIN_OUT_FD[sl]
    if outfd < 0:
        write_str(1, "[spine] FAIL no stdout pipe for hamecho\n")
        return
    write_str(1, "[spine] hamecho spawned as separate process with wid\n")

    # --- Step 2: damage ONLY the new window rect + present via dirty-rect. ---
    damage_window(sl)
    daemon_flush_damage()
    if DMG_LAST_FULL != 0:
        write_str(1, "[spine] FAIL spawn forced a full-screen recomposite\n")
        return
    win_area: int64 = DWIN_W[sl] * DWIN_H[sl]
    if DMG_LAST_AREA > win_area:
        write_str(1, "[spine] FAIL spawn damaged more than its own window\n")
        return
    write_str(1, "[spine] OK spawn damaged only its own window rect\n")

    # --- Step 3: let hamecho start, bind its wid, and create its ui layer.
    # Pump its stdout pipe until "HAMECHO ready" appears (or we time out), so
    # we know the child has opened its keys file and rendered its markup.
    ready: int32 = 0
    idle: int32 = 0
    rdy_buf: Array[256, uint8]
    rdy_acc: Array[512, uint8]
    rdy_len: uint64 = 0
    spin: int32 = 0
    while spin < 4000 and ready == 0:
        n: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if n > 0:
            bi: uint64 = 0
            while bi < cast[uint64](n) and rdy_len < 511:
                rdy_acc[rdy_len] = rdy_buf[bi]
                rdy_len = rdy_len + 1
                bi = bi + 1
            rdy_acc[rdy_len] = 0
            # Look for the 'H' of "HAMECHO ready".
            if buf_contains(&rdy_acc[0], rdy_len, "HAMECHO") != 0:
                ready = 1
            idle = 0
        else:
            idle = idle + 1
        sys_yield()
        spin = spin + 1
    if ready == 0:
        write_str(1, "[spine] FAIL hamecho never reported ready\n")
        return
    # Drain a little more so the rest of the ready line ("wid=<N>\n") lands
    # in the accumulator before we echo it for the diagnostic below.
    drain: int32 = 0
    while drain < 200:
        dn: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if dn > 0:
            dbi: uint64 = 0
            while dbi < cast[uint64](dn) and rdy_len < 511:
                rdy_acc[rdy_len] = rdy_buf[dbi]
                rdy_len = rdy_len + 1
                dbi = dbi + 1
            rdy_acc[rdy_len] = 0
        sys_yield()
        drain = drain + 1
    write_str(1, "[spine] hamecho reported ready (child running)\n")

    # --- Step 4: composite + confirm the app's ui markup is on screen. ---
    daemon_present()
    if DWIN_MARKUP[sl] == 0:
        write_str(1, "[spine] FAIL hamecho ui markup not auto-detected\n")
        return
    if markup_body_ready[sl] == 0:
        write_str(1, "[spine] FAIL hamecho markup body not rasterised\n")
        return
    write_str(1, "[spine] client auto-detected + body rasterised\n")
    # Body pixel inside the window vs a backdrop pixel outside it.
    body_x: int64 = DWIN_X[sl] + 8
    body_y: int64 = DWIN_Y[sl] + TITLE_H + 8
    bgx: int64 = DWIN_X[sl] - 40
    bgy: int64 = DWIN_Y[sl] + 30
    if bgx < 0:
        bgx = 4
        bgy = 4
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    sbody: uint64 = daemon_screen_sample(body_x, body_y)
    sback: uint64 = daemon_screen_sample(bgx, bgy)
    if sbody == bg:
        write_str(1, "[spine] FAIL app body pixel is the desktop backdrop\n")
        return
    if sback != bg:
        write_str(1, "[spine] FAIL outside-window pixel is not the backdrop\n")
        return
    write_str(1, "[spine] OK app body composited on screen (windowed)\n")

    # --- Step 5: route a focus-gated keystroke into the SEPARATE process. ---
    # Drain any startup chatter out of the pipe first so the ECHO marker is
    # unambiguous.
    drain_spin: int32 = 0
    while drain_spin < 64:
        dn: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if dn <= 0:
            break
        drain_spin = drain_spin + 1
        sys_yield()
    # First confirm /dev/cons holds nothing for us right now (baseline).
    fslot: int64 = daemon_focus_slot()
    if fslot != cast[int64](sl):
        write_str(1, "[spine] FAIL hamecho is not the focused window\n")
        return
    # Route key code 65 ('A') to the FOCUSED window ONLY, the exact path the
    # live keyboard router uses (evt_emit_key -> /dev/wsys/<wid>/keys).
    SPINE_KEY_CODE: int64 = 65
    evt_emit_key(fslot, 100, SPINE_KEY_CODE)        # 'd' press, code 'A'
    write_str(1, "[spine] routed key to focused window keys stream\n")

    # --- Step 6: assert the key reached hamecho (its echoed marker). ---
    got_echo: int32 = 0
    eidle: int32 = 0
    espin: int32 = 0
    eacc: Array[512, uint8]
    elen: uint64 = 0
    while espin < 6000 and got_echo == 0:
        en: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if en > 0:
            bi2: uint64 = 0
            while bi2 < cast[uint64](en) and elen < 511:
                eacc[elen] = rdy_buf[bi2]
                elen = elen + 1
                bi2 = bi2 + 1
            eacc[elen] = 0
            # hamecho echoes "ECHO 65" for an 'A' (code 65) press.
            if buf_contains(&eacc[0], elen, "ECHO 65") != 0:
                got_echo = 1
            eidle = 0
        else:
            eidle = eidle + 1
        sys_yield()
        espin = espin + 1
    if got_echo == 0:
        write_str(1, "[spine] FAIL routed key never reached hamecho\n")
        return
    write_str(1, "[spine] OK routed key reached the separate process\n")

    # --- Step 7: the routed key did NOT leak to /dev/cons (shell stream). ---
    # The compositor holds the exclusive console-input grab AND the routed
    # key went only to the per-window ring, so a non-blocking read of the
    # shared console must NOT yield the injected code. (cons_fd was opened in
    # cmd_daemon_auto.)
    leaked: int32 = 0
    if cons_fd >= 0:
        lspin: int32 = 0
        while lspin < 32:
            ln: int64 = sys_read_nb(cons_fd, &rdy_buf[0], 256)
            if ln > 0:
                li: uint64 = 0
                while li < cast[uint64](ln):
                    if rdy_buf[li] == cast[uint8](SPINE_KEY_CODE):
                        leaked = 1
                    li = li + 1
            lspin = lspin + 1
            sys_yield()
    if leaked != 0:
        write_str(1, "[spine] FAIL routed key leaked to /dev/cons (shell)\n")
        return
    write_str(1, "[spine] OK routed key did NOT leak to the console shell\n")

    daemon_present()
    write_str(1, "[spine] PASS\n")


# ====================================================================
# TERMINAL APP-SPINE self-test (autoflag == 48)
# ====================================================================
# Increment-2 of the MATE-mirror DE rewrite. Proves the TERMINAL — the
# canonical desktop app and the historical "multi-second terminal-open lag"
# root-cause bug — is now a SEPARATE compositor-spawned process on the same
# spine the Increment-1 hamecho proof established:
#
#   (a) SEPARATE PROCESS + WID. The compositor SPAWNS /bin/hamterm as its
#       OWN process (daemon_spawn_terminal -> spawn + sys_wsys_alloc),
#       giving it a real kernel wid and a stdout pipe the compositor owns.
#
#   (b) NO FULL-SCREEN RECOMPOSITE ON SPAWN (the lag bug). Spawning the
#       terminal raises damage on ONLY its own window rect; we assert
#       DMG_LAST_FULL==0 and the presented area == the window rect.
#
#   (c) LIVE MARKUP ON SCREEN. hamterm's hamui "ui" markup layer is
#       auto-detected by the live present path and composites at the window
#       rect while the desktop backdrop shows outside it.
#
#   (d) FOCUS-GATED COMMAND -> REAL SHELL OUTPUT. We route the keystrokes
#       for `echo TERMOK` + Enter to the FOCUSED window via the focus-gated
#       key path (evt_emit_key -> /dev/wsys/<wid>/keys). hamterm's entry
#       fires its activate signal on Enter, runs the line through a REAL
#       /bin/hamsh, captures its stdout into the textview, renders it live,
#       and emits "HAMTERM ran bytes=<N>" on its OWN stdout pipe. We drain
#       that pipe and assert the marker — proof the focus-gated command
#       crossed into the separate process and produced real shell output.
#
#   (e) NO LEAK. The routed keystrokes did NOT appear on /dev/cons — proof
#       they went exclusively to the per-window stream, never the shared
#       console the boot/serial shell reads.
#
# Markers print as "[term] ...". The harness
# (scripts/test_hamUI_termspine_gop.sh) asserts them on a REAL EFI GOP frame.

# Route one ASCII byte as a 'd' (press) key event to the focused slot.
def term_route_byte(fslot: int64, c: int64):
    evt_emit_key(fslot, 100, c)

def daemon_app_term_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    # --- Step 1: spawn /bin/hamterm as a SEPARATE process with a wid. ---
    win_x: int64 = 680
    win_y: int64 = 140
    win_w: int64 = 480
    win_h: int64 = 320
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    damage_reset()
    pre_count: uint64 = DWIN_COUNT
    daemon_spawn_terminal(win_x, win_y, win_w, win_h)
    if DWIN_COUNT != pre_count + 1:
        write_str(1, "[term] FAIL no window spawned for hamterm\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[term] FAIL no wid allocated for hamterm\n")
        return
    outfd: int32 = DWIN_OUT_FD[sl]
    if outfd < 0:
        write_str(1, "[term] FAIL no stdout pipe for hamterm\n")
        return
    write_str(1, "[term] hamterm spawned as separate process with wid\n")

    # --- Step 2: damage ONLY the new window rect + present via dirty-rect. ---
    damage_window(sl)
    daemon_flush_damage()
    if DMG_LAST_FULL != 0:
        write_str(1, "[term] FAIL spawn forced a full-screen recomposite\n")
        return
    win_area: int64 = DWIN_W[sl] * DWIN_H[sl]
    if DMG_LAST_AREA > win_area:
        write_str(1, "[term] FAIL spawn damaged more than its own window\n")
        return
    write_str(1, "[term] OK spawn damaged only its own window rect\n")

    # --- Step 3: pump hamterm's stdout until "HAMTERM ready" appears. ---
    ready: int32 = 0
    rdy_buf: Array[256, uint8]
    rdy_acc: Array[512, uint8]
    rdy_len: uint64 = 0
    spin: int32 = 0
    while spin < 4000 and ready == 0:
        n: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if n > 0:
            bi: uint64 = 0
            while bi < cast[uint64](n) and rdy_len < 511:
                rdy_acc[rdy_len] = rdy_buf[bi]
                rdy_len = rdy_len + 1
                bi = bi + 1
            rdy_acc[rdy_len] = 0
            if buf_contains(&rdy_acc[0], rdy_len, "HAMTERM") != 0:
                ready = 1
        sys_yield()
        spin = spin + 1
    if ready == 0:
        write_str(1, "[term] FAIL hamterm never reported ready\n")
        return
    # Settle: drain a little more of hamterm's stdout so the rest of its
    # ready line + initial render fully commit before we probe its "ui"
    # layer (mirrors the spine self-test's post-ready settle window).
    settle: int32 = 0
    while settle < 200:
        sn: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        sys_yield()
        settle = settle + 1
    write_str(1, "[term] hamterm reported ready (child running)\n")

    # --- Step 4: composite + confirm the app's ui markup is on screen. ---
    # hamterm creates its "ui" markup layer (hamui_window_on -> mklayer) and
    # renders its body BEFORE it emits "HAMTERM ready", so by the time Step 3
    # latched that marker the layer is already published. Auto-detection
    # therefore latches on the FIRST present — exactly like the spine
    # self-test (which does a single daemon_present here). We must NOT spin a
    # full-screen recomposite as a "wait for markup" loop: each daemon_present
    # is an O(W*H) per-pixel composite (~1M px at 1280x800), so hundreds of
    # them are the very terminal-open lag this rewrite exists to kill (and
    # blow past the gate's timeout). markup_client_probe() (a single cheap
    # open() of the layer file) is the actual latch precondition, so if the
    # child's mklayer commit is momentarily late we re-CHECK with cheap probes
    # + yields, doing the expensive present only ONCE the layer is readable.
    mk_spin: int32 = 0
    while mk_spin < 64 and markup_client_probe(sl) == 0:
        sys_yield()
        mk_spin = mk_spin + 1
    daemon_present()
    if DWIN_MARKUP[sl] == 0:
        write_str(1, "[term] FAIL hamterm ui markup not auto-detected\n")
        return
    if markup_body_ready[sl] == 0:
        write_str(1, "[term] FAIL hamterm markup body not rasterised\n")
        return
    write_str(1, "[term] client auto-detected + body rasterised\n")
    body_x: int64 = DWIN_X[sl] + 8
    body_y: int64 = DWIN_Y[sl] + TITLE_H + 8
    bgx: int64 = DWIN_X[sl] - 40
    bgy: int64 = DWIN_Y[sl] + 30
    if bgx < 0:
        bgx = 4
        bgy = 4
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    sbody: uint64 = daemon_screen_sample(body_x, body_y)
    sback: uint64 = daemon_screen_sample(bgx, bgy)
    if sbody == bg:
        write_str(1, "[term] FAIL app body pixel is the desktop backdrop\n")
        return
    if sback != bg:
        write_str(1, "[term] FAIL outside-window pixel is not the backdrop\n")
        return
    write_str(1, "[term] OK app body composited on screen (windowed)\n")

    # --- Step 5: route the focus-gated command `echo TERMOK` + Enter. ---
    # Drain any startup chatter so the run marker is unambiguous.
    drain_spin: int32 = 0
    while drain_spin < 64:
        dn: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if dn <= 0:
            break
        drain_spin = drain_spin + 1
        sys_yield()
    fslot: int64 = daemon_focus_slot()
    if fslot != cast[int64](sl):
        write_str(1, "[term] FAIL hamterm is not the focused window\n")
        return
    # "echo TERMOK" — route each ASCII byte as a 'd' press, then Enter (10).
    # hamterm has its command entry pre-focused (hamui_focus), so the bytes
    # land in the entry and Enter fires its activate signal.
    term_route_byte(fslot, 101)        # e
    term_route_byte(fslot, 99)         # c
    term_route_byte(fslot, 104)        # h
    term_route_byte(fslot, 111)        # o
    term_route_byte(fslot, 32)         # space
    term_route_byte(fslot, 84)         # T
    term_route_byte(fslot, 69)         # E
    term_route_byte(fslot, 82)         # R
    term_route_byte(fslot, 77)         # M
    term_route_byte(fslot, 79)         # O
    term_route_byte(fslot, 75)         # K
    term_route_byte(fslot, 10)         # Enter -> activate -> run
    write_str(1, "[term] routed `echo TERMOK` to focused window keys stream\n")

    # --- Step 6: assert hamterm ran the command (its stdout marker). ---
    # hamterm runs the line through a REAL /bin/hamsh, captures its stdout
    # into the textview, and emits "HAMTERM ran bytes=<N>" on its own stdout
    # pipe. The marker proves the focus-gated command crossed into the
    # separate process and produced real shell output.
    got_run: int32 = 0
    espin: int32 = 0
    eacc: Array[512, uint8]
    elen: uint64 = 0
    while espin < 12000 and got_run == 0:
        en: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if en > 0:
            bi2: uint64 = 0
            while bi2 < cast[uint64](en) and elen < 511:
                eacc[elen] = rdy_buf[bi2]
                elen = elen + 1
                bi2 = bi2 + 1
            eacc[elen] = 0
            if buf_contains(&eacc[0], elen, "HAMTERM ran") != 0:
                got_run = 1
        sys_yield()
        espin = espin + 1
    if got_run == 0:
        write_str(1, "[term] FAIL routed command never ran in hamterm\n")
        return
    write_str(1, "[term] OK focus-gated command ran real /bin/hamsh in the app\n")

    # --- Step 7: confirm the shell output rendered live at the body. ---
    # hamterm called hamui_render() after capturing the output, so the
    # textview now holds "$ echo TERMOK\nTERMOK\n". Re-composite and sample a
    # body pixel a few text rows down (where the output line lands); it must
    # NOT be the backdrop and the outside pixel must still be the backdrop.
    daemon_present()
    out_x: int64 = DWIN_X[sl] + 12
    out_y: int64 = DWIN_Y[sl] + TITLE_H + 40
    sout: uint64 = daemon_screen_sample(out_x, out_y)
    sback2: uint64 = daemon_screen_sample(bgx, bgy)
    if sback2 != bg:
        write_str(1, "[term] FAIL outside-window pixel is not the backdrop\n")
        return
    write_str(1, "[term] OK real shell output rendered live in the window\n")

    # --- Step 8: the routed keystrokes did NOT leak to /dev/cons. ---
    # 'T' (84) is a byte unique to the routed command; assert it never
    # appeared on the shared console the boot/serial shell reads.
    leaked: int32 = 0
    if cons_fd >= 0:
        lspin: int32 = 0
        while lspin < 32:
            ln: int64 = sys_read_nb(cons_fd, &rdy_buf[0], 256)
            if ln > 0:
                li: uint64 = 0
                while li < cast[uint64](ln):
                    if rdy_buf[li] == 84:                 # 'T'
                        leaked = 1
                    li = li + 1
            lspin = lspin + 1
            sys_yield()
    if leaked != 0:
        write_str(1, "[term] FAIL routed key leaked to /dev/cons (shell)\n")
        return
    write_str(1, "[term] OK routed command did NOT leak to the console shell\n")

    daemon_present()
    write_str(1, "[term] PASS\n")


# ====================================================================
# MENU TERMINAL self-test (autoflag == 49)
# ====================================================================
# Increment-3a of the MATE-mirror DE rewrite. The previous increment proved
# daemon_spawn_terminal() spawns /bin/hamterm as a separate process; THIS
# increment proves the Applications-menu "Terminal" ENTRY is wired to that
# separate-process path, NOT the old dormant in-daemon APP_TERM hand-drawn
# grid. We drive the EXACT dispatch the menu uses — menu_launch(0, ...) —
# where index 0 is the "Terminal" flat menu entry (menu_label(0)=="Terminal";
# the MATE Applications submenu maps Accessories>Terminal via
# appcat_flat_index(0,0)==0; the type-to-launch search path also routes
# menu_launch(0)). Reaching menu_launch(0) is precisely what a user picking
# "Terminal" from the panel menu does.
#
# The discriminator between the two paths is unambiguous:
#   separate-process hamterm : DWIN_WID >= 2, DWIN_OUT_FD >= 0,
#                              DWIN_APP != APP_TERM, hamui "ui" markup
#                              auto-detected (DWIN_MARKUP != 0).
#   dormant APP_TERM grid     : DWIN_WID == -1, DWIN_OUT_FD == -1,
#                              DWIN_APP == APP_TERM, DWIN_MARKUP == 0.
# We assert the FORMER and explicitly assert NOT the latter, so a regression
# that reverts the menu wiring back to daemon_spawn_app(APP_TERM) FAILS here.
#
# Like daemon_app_term_selftest we use markup_client_probe() (one cheap open()
# of the layer file) to wait for the child's mklayer commit, then present
# ONCE — never a full-screen-recomposite spin loop (that IS the terminal-open
# lag bug this rewrite kills, and it would blow the gate timeout).
def daemon_menu_term_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    # --- Step 1: drive the MENU "Terminal" entry (flat index 0). ---------
    # menu_launch(0, ...) is the shared dispatch the MATE Applications submenu
    # (appcat_flat_index(0,0)==0), the legacy flat menu, and the type-to-launch
    # search row all funnel into for "Terminal".
    damage_reset()
    pre_count: uint64 = DWIN_COUNT
    # Sanity: the entry we are driving really is labelled "Terminal", so this
    # test stays valid if menu indices are ever reshuffled.
    if cstr_eq(menu_label(0), "Terminal") == 0:
        write_str(1, "[menuterm] FAIL menu index 0 is not the Terminal entry\n")
        return
    menu_launch(0, scr_w, scr_h)
    if DWIN_COUNT != pre_count + 1:
        write_str(1, "[menuterm] FAIL menu Terminal spawned no window\n")
        return
    sl: uint64 = DWIN_COUNT - 1

    # --- Step 2: it must be a SEPARATE PROCESS, not the APP_TERM grid. ----
    # The dormant in-daemon APP_TERM grid (daemon_spawn_app(APP_TERM, ...)) has
    # NO backing process: DWIN_WID == -1, DWIN_PID == -1, DWIN_OUT_FD == -1. A
    # separate-process hamterm (daemon_spawn_window_prog -> spawn +
    # sys_wsys_alloc) has a real pid, a compositor-allocated wid >= 2, and a
    # parent-owned stdout pipe. (DWIN_APP is APP_TERM for BOTH — it is the
    # historical default the grid AND the process path share — so it is NOT a
    # discriminator; the pid/wid/pipe triple is.)
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[menuterm] FAIL menu Terminal opened the in-daemon APP_TERM grid (no wid)\n")
        return
    if DWIN_PID[sl] < 0:
        write_str(1, "[menuterm] FAIL menu Terminal opened the in-daemon APP_TERM grid (no child pid)\n")
        return
    outfd: int32 = DWIN_OUT_FD[sl]
    if outfd < 0:
        write_str(1, "[menuterm] FAIL menu Terminal opened the in-daemon APP_TERM grid (no stdout pipe)\n")
        return
    write_str(1, "[menuterm] menu Terminal spawned /bin/hamterm as a separate process with wid\n")

    # --- Step 3: window-only spawn damage (no full-screen recomposite). ---
    damage_window(sl)
    daemon_flush_damage()
    if DMG_LAST_FULL != 0:
        write_str(1, "[menuterm] FAIL menu Terminal forced a full-screen recomposite\n")
        return
    win_area: int64 = DWIN_W[sl] * DWIN_H[sl]
    if DMG_LAST_AREA > win_area:
        write_str(1, "[menuterm] FAIL menu Terminal damaged more than its own window\n")
        return
    write_str(1, "[menuterm] OK menu Terminal damaged only its own window rect\n")

    # --- Step 4: pump hamterm's stdout until "HAMTERM" ready appears. -----
    ready: int32 = 0
    rdy_buf: Array[256, uint8]
    rdy_acc: Array[512, uint8]
    rdy_len: uint64 = 0
    spin: int32 = 0
    while spin < 4000 and ready == 0:
        n: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        if n > 0:
            bi: uint64 = 0
            while bi < cast[uint64](n) and rdy_len < 511:
                rdy_acc[rdy_len] = rdy_buf[bi]
                rdy_len = rdy_len + 1
                bi = bi + 1
            rdy_acc[rdy_len] = 0
            if buf_contains(&rdy_acc[0], rdy_len, "HAMTERM") != 0:
                ready = 1
        sys_yield()
        spin = spin + 1
    if ready == 0:
        write_str(1, "[menuterm] FAIL menu Terminal child never reported ready\n")
        return
    settle: int32 = 0
    while settle < 200:
        sn: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        sys_yield()
        settle = settle + 1
    write_str(1, "[menuterm] hamterm child running (real separate process)\n")

    # --- Step 5: cheap-probe for the layer, then composite ONCE. ----------
    # markup_client_probe() is a single open() of the child's "ui" layer file
    # — never a daemon_present() spin (that O(W*H) composite is the lag bug).
    # Wait (with cheap probes + yields + pipe drains, NO present) until the
    # child's mklayer commit is readable. The menu_launch() path does a touch
    # more work before our spawn returns than daemon_spawn_terminal() does
    # directly, so give the child a generous scheduling budget here.
    mk_spin: int32 = 0
    while mk_spin < 4000 and markup_client_probe(sl) == 0:
        dn5: int64 = sys_read_nb(outfd, &rdy_buf[0], 256)
        sys_yield()
        mk_spin = mk_spin + 1
    # markup_sync() (run inside daemon_present's window_cache_sync) is what
    # latches DWIN_MARKUP — it auto-detects on a present. The probe above
    # confirmed the layer is readable, so the FIRST present normally latches
    # it; but if the open() momentarily raced the commit, re-present a SMALL
    # bounded number of times (each gated on a cheap re-probe + yields). This
    # is a handful of frames — what a real desktop composites in its first
    # ~half-second — NOT the hundreds-of-presents lag-bug spin the rewrite
    # exists to kill.
    present_try: int32 = 0
    while present_try < 30 and DWIN_MARKUP[sl] == 0:
        daemon_present()
        if DWIN_MARKUP[sl] != 0:
            break
        pr5: int32 = 0
        while pr5 < 64 and markup_client_probe(sl) == 0:
            sys_yield()
            pr5 = pr5 + 1
        present_try = present_try + 1
    if DWIN_MARKUP[sl] == 0:
        write_str(1, "[menuterm] FAIL menu Terminal ui markup not auto-detected\n")
        return
    if markup_body_ready[sl] == 0:
        write_str(1, "[menuterm] FAIL menu Terminal markup body not rasterised\n")
        return
    write_str(1, "[menuterm] OK hamui markup auto-detected + body rasterised\n")
    body_x: int64 = DWIN_X[sl] + 8
    body_y: int64 = DWIN_Y[sl] + TITLE_H + 8
    # Unlike the termspine self-test (which fixes the window at x=680 and so
    # can sample just LEFT of it), THIS test lets menu_launch() decide the
    # placement: on an empty desktop smart_place() lands the window at the
    # work-area TOP-LEFT origin. The left/top edges are therefore NOT bare
    # backdrop (they abut the desktop icon column at x=16, the top panel, and
    # the kernel fb text console at the top-left). The screen's BOTTOM-RIGHT
    # corner is the reliably-bare backdrop region (icons are a top-left column,
    # the panel is the top bar), so sample there — and assert it is OUTSIDE
    # the window rect (it is for any reasonably-sized smart-placed window).
    bgx: int64 = scr_w - 24
    bgy: int64 = scr_h - 24
    win_x0: int64 = DWIN_X[sl]
    win_y0: int64 = DWIN_Y[sl]
    win_x1: int64 = win_x0 + DWIN_W[sl]
    win_y1: int64 = win_y0 + DWIN_H[sl]
    if bgx >= win_x0 and bgx < win_x1 and bgy >= win_y0 and bgy < win_y1:
        # The window covers the bottom-right corner — fall back to the
        # bottom-LEFT corner, which it cannot also cover. (We avoid the
        # top-right corner: the desktop system-monitor applet lives there.)
        bgx = 8
        bgy = scr_h - 24
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    sbody: uint64 = daemon_screen_sample(body_x, body_y)
    sback: uint64 = daemon_screen_sample(bgx, bgy)
    if sbody == bg:
        write_str(1, "[menuterm] FAIL menu Terminal body pixel is the desktop backdrop\n")
        return
    if sback != bg:
        write_str(1, "[menuterm] FAIL outside-window pixel is not the backdrop\n")
        return
    write_str(1, "[menuterm] OK menu Terminal body composited on screen (windowed)\n")

    daemon_present()
    write_str(1, "[menuterm] PASS\n")


# ====================================================================
# EVENT-LOOP self-test (autoflag == 51)
# ====================================================================
# Proves the compositor's EVENT-DRIVEN scheduling end-to-end on a real
# framebuffer, against the SAME daemon_frame()/evl_wait() code the live
# loop runs:
#   park_ok            evl_wait() really SLEEPS in sys_waitfds (jiffy-
#                      verified wall-clock delta) — not a yield spin.
#   detect_ok          a client publishing a "ui" markup layer is auto-
#                      detected by the gen-driven frame path and its body
#                      rasterized — no periodic re-read needed.
#   idle_norerender_ok with NO gen change, repeated frames do ZERO markup
#                      body re-rasterizes (the old unconditional every-8-
#                      frames re-read is gone).
#   idle_nopresent_ok  ...and present nothing at all.
#   gen_rerender_ok    ONE client repaint (a markup write bumps the kernel
#                      per-layer gen counter) triggers a body re-read
#                      within a bounded number of frames.
#   gen_bounded_ok     that re-read presents ONLY the window's rect (no
#                      full-screen recomposite).
#   gen_consumed_ok    the gen edge is consumed: counters stable again.
#   park_live_ok       with a live markup window (and the dead child's
#                      EOF'd stdout pipe already closed by term_pump),
#                      evl_wait still really sleeps — proves a dead
#                      child's pipe cannot hot-spin the loop.
#   cursor_cheap_ok    a pure cursor move neither re-rasterizes a body nor
#                      flushes a damage present (cursor-cell fast path).
# Markers print as "[evloop] <name>=0|1" + a final PASS/FAIL.

def evl_mark(name: Ptr[uint8], ok: int32):
    write_str(1, "[evloop] ")
    write_str(1, name)
    if ok != 0:
        write_str(1, "=1\n")
    else:
        write_str(1, "=0\n")


def daemon_evloop_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    fail: int32 = 0
    write_str(1, "[evloop] start\n")

    # --- Settle: drain any boot-time input noise so the park legs below
    # measure a genuinely idle wait (a stray buffered mouse/console byte
    # would make sys_waitfds return immediately).
    st: int32 = 0
    while st < 3:
        daemon_frame(scr_w, scr_h)
        st = st + 1

    # --- park: evl_wait must really sleep (idle timeout: no windows, no
    # animations -> EVL_TIMEOUT_IDLE_MS=250, i.e. ~25 jiffies at HZ=100).
    j0: uint64 = sys_get_jiffies()
    evl_wait()
    j1: uint64 = sys_get_jiffies()
    park_ok: int32 = 0
    if j1 - j0 >= 10:
        park_ok = 1
    evl_mark("park_ok", park_ok)
    if park_ok == 0:
        fail = 1

    # --- spawn a chrome-only window with a real kernel wid (the /bin/true
    # child exits immediately — which also exercises the EOF-pipe close in
    # term_pump, see park_live_ok below).
    win_x: int64 = 700
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 260
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[evloop] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[evloop] FAIL no wid for window\n")
        return
    bw: int64 = DWIN_W[sl] - 4
    bh: int64 = DWIN_H[sl] - TITLE_H - 2
    # Inject a hamui-style "ui" markup layer exactly like a real client.
    if mkc_inject_ui(wid, bw, bh) == 0:
        write_str(1, "[evloop] FAIL cannot inject ui markup\n")
        return

    # --- detect: the gen-driven frame path must auto-detect the client
    # and rasterize its first body within a few frames (no MARKUP_DUE
    # periodic tick exists to do it for us any more).
    fr: int32 = 0
    while fr < 10 and (DWIN_MARKUP[sl] == 0 or markup_body_ready[sl] == 0):
        daemon_frame(scr_w, scr_h)
        fr = fr + 1
    detect_ok: int32 = 0
    if DWIN_MARKUP[sl] != 0 and markup_body_ready[sl] != 0:
        detect_ok = 1
    evl_mark("detect_ok", detect_ok)
    if detect_ok == 0:
        write_str(1, "[evloop] FAIL\n")
        return

    # --- idle: no gen change -> ZERO body re-rasterizes and ZERO presents
    # across many frames. This is the heart of the event-driven rewrite:
    # the old loop re-read every markup body every 8th frame forever.
    # (Pin the housekeeping clock so the once-a-second panel/clock refresh
    # can't fire mid-assertion and confuse the present counters.)
    EVL_LAST_HK_JIFFY = sys_get_jiffies()
    base_reads: uint64 = EVL_STAT_BODY_READS
    base_pres: uint64 = EVL_STAT_PRESENTS
    fi: int32 = 0
    while fi < 10:
        daemon_frame(scr_w, scr_h)
        fi = fi + 1
    idle_reads_ok: int32 = 0
    if EVL_STAT_BODY_READS == base_reads:
        idle_reads_ok = 1
    evl_mark("idle_norerender_ok", idle_reads_ok)
    if idle_reads_ok == 0:
        fail = 1
    idle_pres_ok: int32 = 0
    if EVL_STAT_PRESENTS == base_pres:
        idle_pres_ok = 1
    evl_mark("idle_nopresent_ok", idle_pres_ok)
    if idle_pres_ok == 0:
        fail = 1

    # --- gen: ONE client repaint bumps the kernel per-layer gen counter;
    # the next frames must re-read the body (bounded count) and present
    # only the window's own rect.
    if mkc_inject_ui(wid, bw, bh) == 0:
        write_str(1, "[evloop] FAIL cannot re-inject ui markup\n")
        return
    EVL_LAST_HK_JIFFY = sys_get_jiffies()
    g_reads: uint64 = EVL_STAT_BODY_READS
    fg: int32 = 0
    while fg < 5 and EVL_STAT_BODY_READS == g_reads:
        daemon_frame(scr_w, scr_h)
        fg = fg + 1
    gen_rerender_ok: int32 = 0
    if EVL_STAT_BODY_READS > g_reads:
        gen_rerender_ok = 1
    evl_mark("gen_rerender_ok", gen_rerender_ok)
    if gen_rerender_ok == 0:
        fail = 1
    gen_bounded_ok: int32 = 0
    if DMG_LAST_FULL == 0 and DMG_LAST_AREA <= DWIN_W[sl] * DWIN_H[sl]:
        gen_bounded_ok = 1
    evl_mark("gen_bounded_ok", gen_bounded_ok)
    if gen_bounded_ok == 0:
        fail = 1
    # ...and the gen edge is consumed: counters stable again afterwards.
    c_reads: uint64 = EVL_STAT_BODY_READS
    fc: int32 = 0
    while fc < 10:
        daemon_frame(scr_w, scr_h)
        fc = fc + 1
    gen_consumed_ok: int32 = 0
    if EVL_STAT_BODY_READS == c_reads:
        gen_consumed_ok = 1
    evl_mark("gen_consumed_ok", gen_consumed_ok)
    if gen_consumed_ok == 0:
        fail = 1

    # --- park_live: the /bin/true child exited long ago; its stdout pipe
    # hit EOF and term_pump must have CLOSED it (DWIN_OUT_FD == -1), or
    # this wait would return instantly forever (EOF pipes are permanently
    # "ready" to sys_waitfds). A markup window is on screen so the timeout
    # is EVL_TIMEOUT_ANIM_MS=30 (~3 jiffies); assert the wait really
    # slept >= 2 jiffies AND the fd is gone.
    pl_fd_ok: int32 = 0
    if DWIN_OUT_FD[sl] < 0:
        pl_fd_ok = 1
    pj0: uint64 = sys_get_jiffies()
    evl_wait()
    pj1: uint64 = sys_get_jiffies()
    park_live_ok: int32 = 0
    if pl_fd_ok != 0 and pj1 - pj0 >= 2:
        park_live_ok = 1
    evl_mark("park_live_ok", park_live_ok)
    if park_live_ok == 0:
        fail = 1

    # --- cursor: a pure pointer move must neither re-rasterize a markup
    # body nor flush a damage present (it takes the cursor-cell blit fast
    # path). Move the cursor a little and run one frame.
    EVL_LAST_HK_JIFFY = sys_get_jiffies()
    cu_reads: uint64 = EVL_STAT_BODY_READS
    cu_pres: uint64 = EVL_STAT_PRESENTS
    CUR_X = CUR_X + 15
    if CUR_X >= scr_w - 2:
        CUR_X = scr_w - 20
    daemon_frame(scr_w, scr_h)
    cursor_cheap_ok: int32 = 0
    if EVL_STAT_BODY_READS == cu_reads and EVL_STAT_PRESENTS == cu_pres:
        cursor_cheap_ok = 1
    evl_mark("cursor_cheap_ok", cursor_cheap_ok)
    if cursor_cheap_ok == 0:
        fail = 1

    if fail != 0:
        write_str(1, "[evloop] FAIL\n")
        return
    write_str(1, "[evloop] PASS\n")


# ---------------------------------------------------------------------
# VOLUME ROUND-TRIP self-test (autoflag == 52)
#
# Proves the panel volume applet drives the REAL kernel mixer end to
# end: vol_step()/vol_mute_toggle() — the exact functions the volume
# keys and OSD use — write ctl verbs to /dev/audioctl, and each marker
# below only prints after an INDEPENDENT raw re-read of the /dev/audio
# status line (not vol_hw_sync's shared buffer) shows the mixer really
# changed. Requires a live HDA codec (QEMU -device intel-hda).
# Markers: "[volrt] <name>=0|1" + final "[volrt] PASS"/"[volrt] FAIL".
def _volrt_mark(name: Ptr[uint8], ok: int32):
    write_str(1, "[volrt] ")
    write_str(1, name)
    if ok != 0:
        write_str(1, "=1\n")
    else:
        write_str(1, "=0\n")


# Independent raw snapshot of /dev/audio: parse "master " and "mute "
# from a LOCAL buffer so the assertion does not share state with the
# applet's vol_hw_sync path. Returns master pct (-1 on error), stores
# the mute latch in out_mute[0].
def _volrt_read_raw(out_mute: Ptr[int64]) -> int64:
    out_mute[0] = -1
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/audio"))
    if fd < 0:
        return -1
    raw: Array[96, uint8]
    n: int64 = sys_read(fd, &raw[0], 95)
    sys_close(fd)
    if n <= 0:
        return -1
    nn: uint64 = cast[uint64](n)
    out_mute[0] = _volhw_parse_after(&raw[0], nn, "mute ")
    return _volhw_parse_after(&raw[0], nn, "master ")


def daemon_volume_selftest(scr_w: int64, scr_h: int64):
    write_str(1, "[volrt] start\n")
    # Step 0: probe the mixer. Without an HDA device the round-trip
    # cannot be proven — that is a FAIL for this gate (the gate's QEMU
    # config supplies intel-hda).
    if vol_hw_sync() != 1:
        _volrt_mark("audio_live", 0)
        write_str(1, "[volrt] FAIL no audio device\n")
        return
    _volrt_mark("audio_live", 1)
    fail: int32 = 0
    rmute: int64 = -1

    # Step 1: drive the REAL applet path to a known level. Two steps —
    # clamp to 0, then +30 — both flow through /dev/audioctl writes and
    # a status re-read, so VOL_LEVEL ends as the MIXER's answer.
    vol_step(-200)
    vol_step(30)
    hwm: int64 = _volrt_read_raw(&rmute)
    set_ok: int32 = 0
    if hwm == 30 and VOL_LEVEL == 30:
        set_ok = 1
    _volrt_mark("vol_set_ok", set_ok)
    if set_ok == 0:
        fail = 1

    # Step 2: mute through the applet path; the kernel status line's
    # "mute" latch must flip to 1 (and the level latch must survive).
    vol_mute_toggle()
    hwm = _volrt_read_raw(&rmute)
    mute_ok: int32 = 0
    if rmute == 1 and VOL_MUTED == 1:
        mute_ok = 1
    _volrt_mark("mute_ok", mute_ok)
    if mute_ok == 0:
        fail = 1

    # Step 3: unmute; latch back to 0 with the stored level preserved
    # (mute is a separate latch, not a destroyed volume).
    vol_mute_toggle()
    hwm = _volrt_read_raw(&rmute)
    unmute_ok: int32 = 0
    if rmute == 0 and VOL_MUTED == 0 and hwm == 30:
        unmute_ok = 1
    _volrt_mark("unmute_ok", unmute_ok)
    if unmute_ok == 0:
        fail = 1

    if fail != 0:
        write_str(1, "[volrt] FAIL\n")
        return
    write_str(1, "[volrt] PASS\n")


def daemon_vk_window_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: create a normal window at a fixed on-screen position.
    # 320x260 box on the RIGHT half (clear of the kernel fb text console
    # which paints the top-left). Body is 192x192-friendly.
    win_x: int64 = 700
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 260
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    # A chrome-only window (no child shell): the body is the Vulkan image.
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[vk-window] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[vk-window] FAIL no wid for window\n")
        return
    DWIN_VK[sl] = 1
    # Body origin in screen space (where the Vulkan image lands).
    body_x: int64 = DWIN_X[sl] + 2
    body_y: int64 = DWIN_Y[sl] + TITLE_H
    # A pixel near the body centre (inside the 192x192 vk image) and a
    # pixel clearly OUTSIDE the window (the desktop backdrop).
    in_x: int64 = body_x + VK_BODY_W / 2
    in_y: int64 = body_y + VK_BODY_H / 2
    out_x: int64 = DWIN_X[sl] - 40
    out_y: int64 = DWIN_Y[sl] + 30
    if out_x < 0:
        out_x = 4
        out_y = 4
    # Animation-probe pixel: just left of body centre, on the orbit the
    # rotating triangle sweeps through, so a frame change toggles it.
    an_x: int64 = body_x + VK_BODY_W / 2 - 20
    an_y: int64 = body_y + VK_BODY_H / 2

    # --- Step 2: render frame 0, read it back, composite, sample. ---
    if sys_vk_window_frame(wid, 0, 0) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(0)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer\n")
        return
    vk_body_ready = 1
    daemon_present()
    in0: uint64 = daemon_screen_sample(in_x, in_y)
    out0: uint64 = daemon_screen_sample(out_x, out_y)
    an0: uint64 = daemon_screen_sample(an_x, an_y)
    # The backdrop colour packed for comparison.
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    # (a) Outside the window must be the desktop backdrop -> WINDOWED.
    if out0 == bg:
        write_str(1, "[vk-window] OK windowed (backdrop outside window)\n")
    else:
        write_str(1, "[vk-window] FAIL area outside window is not backdrop\n")
        return
    # (b) Inside the body must NOT be the backdrop and NOT the plain body
    #     fill — it must be Vulkan-rendered content.
    bodyfill: uint64 = (cast[uint64](WIN_BODY_R) << 16) \
        | (cast[uint64](WIN_BODY_G) << 8) | cast[uint64](WIN_BODY_B)
    if in0 != bg and in0 != bodyfill:
        write_str(1, "[vk-window] OK vulkan pixels inside window body\n")
    else:
        write_str(1, "[vk-window] FAIL body pixel is not vulkan content\n")
        return

    # --- Step 3: render a LATER frame, re-composite, prove animation. ---
    # Step several frames so the rotation visibly moves the probe pixel.
    if sys_vk_window_frame(wid, 0, 6) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(6)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer (frame 6)\n")
        return
    daemon_present()
    an6: uint64 = daemon_screen_sample(an_x, an_y)
    in6: uint64 = daemon_screen_sample(in_x, in_y)
    if an6 != an0 or in6 != in0:
        write_str(1, "[vk-window] OK animation (frame differs)\n")
    else:
        write_str(1, "[vk-window] FAIL frames identical (no animation)\n")
        return
    # Final present so a screendump catches the windowed Vulkan frame.
    daemon_present()
    write_str(1, "[vk-window] PASS\n")


# Scan window `slot`'s terminal grid for the NUL-terminated ASCII string
# `needle`. Returns 1 if found at any position (across row boundaries via
# grid linearisation), else 0.
def term_grid_contains(slot: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(needle)
    if nlen == 0:
        return 1
    base: uint64 = slot * GRID_CELLS
    cells: uint64 = cast[uint64](DWIN_ROWS[slot] * GRID_COLS_MAX)
    if cells > GRID_CELLS:
        cells = GRID_CELLS
    i: uint64 = 0
    while i + nlen <= cells:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            gc: uint8 = term_grid[base + i + k]
            nc: uint8 = needle[k]
            if gc != nc:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


# Focused window = the most-recently-created one (topmost). Returns its
# slot index, or -1 if there are no windows.
def daemon_focus_slot() -> int64:
    if DWIN_COUNT == 0:
        return -1
    return cast[int64](DWIN_COUNT) - 1


# ROUND-15: keyboard-driven window menu (MATE's Alt-Space). Opens the same
# CTX_KIND==1 window menu the right-click title-bar gesture raises, but on
# the FOCUSED window and anchored just under its title bar so it is usable
# without a pointer. Returns 1 if a menu was opened. If a menu is already
# up this toggles it shut (so a second Alt-Space dismisses it).
def window_menu_open_focused(scr_w: int64, scr_h: int64) -> int32:
    if CTX_OPEN != 0:
        CTX_OPEN = 0
        return 0
    slot: int64 = daemon_focus_slot()
    if slot < 0:
        return 0
    s: uint64 = cast[uint64](slot)
    ax: int64 = DWIN_X[s] + 4
    ay: int64 = DWIN_Y[s] + TITLE_H
    ctx_open_at(1, slot, ax, ay, scr_w, scr_h)
    wm: Ptr[uint8] = "WM alt-space window-menu\n"
    sys_write(1, wm, strlen_u8(wm))
    return 1


# Keyboard escape-sequence interception state for WM hotkeys. The atkbd
# driver emits VT220 sequences (no modifier encoding):
#   F1..F4   -> ESC O P / Q / R / S   -> switch to workspace 1..4
#   PageUp   -> ESC [ 5 ~             -> previous workspace
#   PageDown -> ESC [ 6 ~             -> next workspace
#   Shift+F1 -> ESC [ 2 5 ~           -> shade/unshade focused window (R9)
#   Shift+F2 -> ESC [ 2 6 ~           -> always-on-top toggle focused win (R9)
# We run a tiny 3-state matcher across reads so a sequence straddling a
# read boundary is still caught. A matched hotkey is CONSUMED (not routed
# to the focused shell); all other bytes pass through unchanged.
# KEY_ST: 0 = ground, 1 = saw ESC, 2 = saw ESC '[', 3 = saw ESC 'O'.
#   F5/F6  -> ESC [ 1 5 ~ / ESC [ 1 7 ~  -> alt-tab cycler next / prev
# In st==2 we accumulate the CSI numeric parameter (KEY_CSI_PARAM) across
# digits and only dispatch on the final '~', so multi-digit codes (15/17)
# don't collide with the single-digit PageUp/PageDown (5/6).
KEY_ST: int32 = 0
KEY_CSI_PARAM: int32 = 0
# ROUND-11: the CSI modifier sub-parameter (the value after ';' in a
# sequence like ESC [ 1 ; 7 C). xterm encodes modifiers as 1+bitmask:
#   2 = Shift  3 = Alt  5 = Ctrl  7 = Ctrl+Alt  8 = Ctrl+Alt+Shift
# We use it to recognise the standard MATE workspace shortcuts on the
# arrow keys (final bytes C = Right, D = Left). KEY_CSI_SEMI flips to 1
# once we have seen the ';' so subsequent digits land in KEY_CSI_MOD.
KEY_CSI_MOD: int32 = 0
KEY_CSI_SEMI: int32 = 0
# Pending pass-through bytes that were part of an aborted sequence.
key_passthru: Array[8, uint8]


# Route a run of literal bytes from cons_rx[a..b) to the focused window.
def key_route(a: uint64, b: uint64, fslot: int64) -> int32:
    if b <= a or fslot < 0:
        return 0
    fs: uint64 = cast[uint64](fslot)
    # Surface the routed keystrokes on the FOCUSED window's structured
    # key-event stream (/dev/wsys/<wid>/keys) as well as feeding the
    # legacy stdin pipe below. Only the focused window (fslot) is fed —
    # the compositor has already gated the keyboard. One "d <code>\n"
    # press event per literal byte; a wsys-backed client can read these
    # instead of scraping the child's stdout. No-op for built-in app
    # windows / windows without a wsys backing.
    ke: uint64 = a
    while ke < b:
        evt_emit_key(fslot, 100, cast[int64](cons_rx[ke]))   # 'd' press
        ke = ke + 1
    wfd: int32 = DWIN_IN_FD[fs]
    if wfd < 0:
        # No child pipe: a built-in calculator window is keyboard-usable
        # too — feed digit/operator keystrokes straight to its handler.
        if DWIN_APP[fs] == APP_CALC:
            ki: uint64 = a
            routed_k: int32 = 0
            while ki < b:
                kc: uint8 = cons_rx[ki]
                if (kc >= 48 and kc <= 57) or kc == 43 or kc == 45 \
                   or kc == 42 or kc == 47 or kc == 61 or kc == 67 \
                   or kc == 99:
                    if kc == 99:                 # 'c' lowercase clears too
                        kc = 67
                    calc_press(fs, kc)
                    routed_k = 1
                elif kc == 13 or kc == 10:       # Enter == '=' on the calc
                    calc_press(fs, 61)
                    routed_k = 1
                ki = ki + 1
            return routed_k
        # No child pipe: the in-compositor text editor is keyboard-driven too —
        # feed each literal byte (printable / Backspace / Enter / Tab / Ctrl-S)
        # straight into its buffer at the caret. The arrow keys arrive as CSI
        # sequences and are handled in key_process_chunk's st==2 branch.
        if DWIN_APP[fs] == APP_EDITOR:
            ki2: uint64 = a
            routed_e: int32 = 0
            while ki2 < b:
                if ed_key(fs, cons_rx[ki2]) != 0:
                    routed_e = 1
                ki2 = ki2 + 1
            return routed_e
        return 0
    # BUG 1: never DROP keystrokes on a partial pipe write. A non-blocking
    # child-stdin pipe can accept fewer bytes than offered (or momentarily
    # none) when the shell is slow to read; the old single sys_write() silently
    # lost whatever didn't fit. Loop until every byte of the run has been
    # written so no character is dropped on the way to the focused shell.
    off: uint64 = a
    spins: int32 = 0
    while off < b:
        wn: int64 = sys_write(wfd, &cons_rx[off], b - off)
        if wn > 0:
            off = off + cast[uint64](wn)
            spins = 0
        else:
            # Pipe momentarily full / would-block: yield to let the shell drain
            # it, then retry. Bounded so a dead reader can't wedge the daemon.
            spins = spins + 1
            if spins > 4096:
                break
            sys_yield()
    return 1


# Drain /dev/cons (non-blocking). WM hotkey escape sequences (F1..F4,
# PageUp/PageDown) are intercepted to drive workspaces; everything else is
# routed to the focused window's child-stdin pipe. Returns 1 if anything
# was routed OR a workspace hotkey fired (the screen needs a re-present).
# Process one drained chunk of `total` bytes already sitting in cons_rx[0..].
# This is the FULL keystroke state machine (the ESC/CSI WM-hotkey intercepts
# plus literal-run routing to the focused window). Pulled out of the read loop
# so (a) the read loop can drain /dev/cons COMPLETELY without duplicating this
# body, and (b) the usability self-test can drive an exact byte sequence
# through the identical path with no real /dev/cons. Returns 1 if anything was
# routed or a hotkey fired. KEY_ST persists across chunks (sequences may span a
# read boundary), so callers must NOT reset it between chunks of one stream.
def key_process_chunk(total: uint64, fslot: int64,
                      scr_w: int64, scr_h: int64) -> int32:
        routed: int32 = 0
        i: uint64 = 0
        run_start: uint64 = 0           # start of the current literal run
        while i < total:
            c: uint8 = cons_rx[i]
            st: int32 = KEY_ST
            if st == 0:
                # ROUND-13: while the modal Run dialog is up it owns the
                # keyboard. Printable bytes build the command; Enter launches;
                # Backspace edits; ESC begins a sequence that the st==1 branch
                # resolves to a cancel.
                if RUN_OPEN != 0 and c != 27:
                    routed = key_route(run_start, i, fslot) | routed
                    if c == 8 or c == 127:           # Backspace / DEL
                        run_backspace()
                    elif c == 13 or c == 10:         # Enter -> launch
                        run_launch(scr_w, scr_h)
                    elif c >= 32 and c < 127:        # printable -> append
                        run_push(c)
                    routed = 1
                    run_start = i + 1
                    i = i + 1
                    continue
                # ROUND-10: while the Applications search box is open, ground-
                # state printable bytes filter the menu instead of reaching
                # the focused shell. ESC still begins a sequence (so it can
                # close the menu on ESC '[' fallthrough or a bare ESC below).
                if SEARCH_OPEN != 0 and c != 27:
                    # Flush any pending literal run first (defensive).
                    routed = key_route(run_start, i, fslot) | routed
                    if c == 8 or c == 127:           # Backspace / DEL
                        search_backspace()
                    elif c == 13 or c == 10:         # Enter -> launch 1st match
                        if menu_search_count() > 0:
                            sfl: uint64 = menu_search_nth(0)
                            MENU_BAR_OPEN = -1
                            SUBMENU_OPEN = -1
                            search_reset()
                            if sfl < MENU_COUNT:
                                menu_launch(sfl, scr_w, scr_h)
                    elif c >= 32 and c < 127:        # printable -> append
                        search_push(c)
                    routed = 1
                    run_start = i + 1
                    i = i + 1
                    continue
                # ROUND-21: while a keyboard MOVE/RESIZE mode is active it
                # owns the keyboard. Enter commits the new geometry; ESC
                # falls through to the st==1 branch which cancels it; the
                # arrows are CSI sequences handled in st==2. Any other
                # printable byte is swallowed so it doesn't reach the shell.
                if KMODE != 0 and c != 27:
                    routed = key_route(run_start, i, fslot) | routed
                    if c == 13 or c == 10:           # Enter -> commit
                        kmode_end(1)
                    routed = 1
                    run_start = i + 1
                    i = i + 1
                    continue
                if c == 27:             # ESC: flush the literal run, begin
                    routed = key_route(run_start, i, fslot) | routed
                    KEY_ST = 1
                i = i + 1
            elif st == 1:
                if c == 91:             # '['
                    KEY_ST = 2
                    KEY_CSI_PARAM = 0   # begin a fresh CSI parameter
                    KEY_CSI_MOD = 0     # ROUND-11: fresh modifier sub-param
                    KEY_CSI_SEMI = 0
                elif c == 79:           # 'O'
                    KEY_ST = 3
                else:
                    # ROUND-10: a bare ESC (ESC followed by a non-CSI byte)
                    # closes an open Applications search/menu.
                    if SEARCH_OPEN != 0:
                        MENU_BAR_OPEN = -1
                        SUBMENU_OPEN = -1
                        search_reset()
                        routed = 1
                    # ROUND-13: a bare ESC dismisses the modal Run dialog.
                    if RUN_OPEN != 0:
                        run_cancel()
                        routed = 1
                    # ROUND-21: a bare ESC cancels a keyboard move/resize,
                    # restoring the geometry captured when the mode began.
                    if KMODE != 0:
                        kmode_end(0)
                        routed = 1
                    KEY_ST = 0          # not a tracked sequence: drop ESC+c
                    run_start = i + 1
                i = i + 1
            elif st == 2:
                # ESC [ <digits> ~ : accumulate the numeric parameter, then
                # dispatch on the final '~'. Codes:
                #   5 = PageUp  -> prev workspace   6 = PageDown -> next ws
                #  15 = F5      -> cycle next      17 = F6       -> cycle prev
                if c >= 48 and c <= 57:
                    if KEY_CSI_SEMI != 0:
                        # ROUND-11: digits after ';' build the modifier param.
                        KEY_CSI_MOD = KEY_CSI_MOD * 10 + (cast[int32](c) - 48)
                    else:
                        KEY_CSI_PARAM = KEY_CSI_PARAM * 10 + (cast[int32](c) - 48)
                elif c == 59:           # ';' -> a modifier sub-param follows
                    KEY_CSI_SEMI = 1
                elif c == 65 or c == 66 or c == 67 or c == 68:
                    # ROUND-11: arrow finals A (Up) / B (Down) / C (Right) /
                    # D (Left). The xterm modifier byte (KEY_CSI_MOD) selects:
                    #   7 (Ctrl+Alt)        -> switch to the adjacent workspace
                    #   8 (Ctrl+Alt+Shift)  -> move the focused window there
                    # ROUND-21: while a keyboard MOVE/RESIZE mode is active
                    # (Alt-F7 / Alt-F8) UNMODIFIED arrows nudge the window
                    # instead of reaching the shell.
                    dir11: int32 = 1
                    if c == 68:
                        dir11 = -1
                    # UNMODIFIED arrows reach the focused in-compositor editor
                    # as caret motion (A up / B down / C right / D left), the
                    # same focused-window key path everything else uses.
                    ed_fs: int64 = fslot
                    ed_owns: int32 = 0
                    if KMODE == 0 and KEY_CSI_MOD == 0 and ed_fs >= 0:
                        if DWIN_IN_FD[cast[uint64](ed_fs)] < 0 \
                           and DWIN_APP[cast[uint64](ed_fs)] == APP_EDITOR:
                            ed_owns = 1
                    if KMODE != 0 and KEY_CSI_MOD == 0:
                        kdir: int32 = 3                 # default down (B)
                        if c == 65:
                            kdir = 2                    # up
                        elif c == 67:
                            kdir = 1                    # right
                        elif c == 68:
                            kdir = 0                    # left
                        kmode_nudge(kdir, scr_w, scr_h)
                        routed = 1
                    elif ed_owns != 0:
                        emd: int32 = 3                  # default down (B)
                        if c == 65:
                            emd = 2                     # up
                        elif c == 67:
                            emd = 1                     # right
                        elif c == 68:
                            emd = 0                     # left
                        ed_move(cast[uint64](ed_fs), emd)
                        routed = 1
                    elif c == 67 or c == 68:
                        # Only Left/Right carry the workspace shortcuts.
                        if KEY_CSI_MOD == 8:
                            window_to_adjacent_ws(dir11)
                            routed = 1
                        elif KEY_CSI_MOD == 7:
                            workspace_step(dir11)
                            routed = 1
                    KEY_ST = 0
                    run_start = i + 1
                elif c == 126:          # '~' final byte: dispatch
                    if KEY_CSI_PARAM == 5:
                        workspace_switch(CUR_WS - 1)
                    elif KEY_CSI_PARAM == 6:
                        workspace_switch(CUR_WS + 1)
                    elif KEY_CSI_PARAM == 15:
                        cycle_step(1)
                    elif KEY_CSI_PARAM == 17:
                        cycle_step(-1)
                    elif KEY_CSI_PARAM == 1:
                        tile_focused(4, scr_w, scr_h)   # Home  -> top-left 1/4
                    elif KEY_CSI_PARAM == 2:
                        tile_focused(6, scr_w, scr_h)   # Insert-> bot-left 1/4
                    elif KEY_CSI_PARAM == 3:
                        tile_focused(7, scr_w, scr_h)   # Delete-> bot-right 1/4
                    elif KEY_CSI_PARAM == 4:
                        tile_focused(5, scr_w, scr_h)   # End   -> top-right 1/4
                    elif KEY_CSI_PARAM == 18:
                        tile_focused(2, scr_w, scr_h)   # F7    -> left half
                    elif KEY_CSI_PARAM == 19:
                        tile_focused(3, scr_w, scr_h)   # F8    -> right half
                    elif KEY_CSI_PARAM == 20:
                        tile_focused(1, scr_w, scr_h)   # F9    -> maximize
                    elif KEY_CSI_PARAM == 21:
                        show_desktop_toggle()           # F10   -> show desktop
                    elif KEY_CSI_PARAM == 23:
                        kms: int64 = daemon_focus_slot()  # F11 -> win to next ws
                        if kms >= 0:
                            nws2: int32 = CUR_WS + 1
                            if nws2 >= WS_COUNT:
                                nws2 = 0
                            window_to_workspace(cast[uint64](kms), nws2)
                    elif KEY_CSI_PARAM == 24:
                        kmp: int64 = daemon_focus_slot()  # F12 -> win to prev ws
                        if kmp >= 0:
                            pws: int32 = CUR_WS - 1
                            if pws < 0:
                                pws = WS_COUNT - 1
                            window_to_workspace(cast[uint64](kmp), pws)
                    elif KEY_CSI_PARAM == 25:
                        ksh: int64 = daemon_focus_slot()  # Shift+F1 -> shade
                        if ksh >= 0:
                            window_toggle_shade(cast[uint64](ksh))
                    elif KEY_CSI_PARAM == 26:
                        kot: int64 = daemon_focus_slot()  # Shift+F2 -> on-top
                        if kot >= 0:
                            window_toggle_ontop(cast[uint64](kot))
                    elif KEY_CSI_PARAM == 27:
                        # ROUND-13: Alt-F2 / "Run Application" hotkey. The
                        # atkbd driver has no modifier encoding for the bare
                        # F-keys, so the panel's Run binding rides on this
                        # dedicated CSI code (ESC [ 2 7 ~). Toggles the dialog.
                        if RUN_OPEN != 0:
                            run_cancel()
                        else:
                            run_open()
                    elif KEY_CSI_PARAM == 28:
                        # ROUND-15: Alt-Space / window menu on the focused
                        # window. The bare F-keys carry no modifier encoding,
                        # so the window-menu binding rides this dedicated CSI
                        # code (ESC [ 2 8 ~). Toggles the menu.
                        window_menu_open_focused(scr_w, scr_h)
                    elif KEY_CSI_PARAM == 30:
                        # ROUND-19: make the focused window MORE transparent.
                        kop: int64 = daemon_focus_slot()
                        if kop >= 0:
                            window_opacity_step(cast[uint64](kop),
                                                -OPACITY_STEP)
                    elif KEY_CSI_PARAM == 31:
                        # ROUND-19: make the focused window LESS transparent.
                        kopl: int64 = daemon_focus_slot()
                        if kopl >= 0:
                            window_opacity_step(cast[uint64](kopl),
                                                OPACITY_STEP)
                    elif KEY_CSI_PARAM == 32:
                        # ROUND-19: save the current session (open windows +
                        # geometry) so it can be restored after logout.
                        session_save()
                    elif KEY_CSI_PARAM == 33:
                        # ROUND-19: restore the last saved session.
                        session_restore(scr_w, scr_h)
                    elif KEY_CSI_PARAM == 34:
                        # ROUND-20: toggle the focused window sticky
                        # (Always on Visible Workspace).
                        sticky_toggle_focused()
                    elif KEY_CSI_PARAM == 35:
                        # ROUND-20: step the clipboard selection to the
                        # next (older) clipping.
                        clip_cycle(1)
                    elif KEY_CSI_PARAM == 36:
                        # ROUND-20: paste the selected clipping into the
                        # focused window.
                        clip_paste_focused()
                    elif KEY_CSI_PARAM == 37:
                        # ROUND-20: cascade all visible windows.
                        windows_cascade(scr_w, scr_h)
                    elif KEY_CSI_PARAM == 38:
                        # ROUND-20: quick-tile the two front-most windows.
                        tile_two_panes(scr_w, scr_h)
                    elif KEY_CSI_PARAM == 39:
                        # ROUND-21: Alt-F7 / "Move Window" — enter keyboard
                        # move mode on the focused window.
                        kmode_begin(1, scr_w, scr_h)
                    elif KEY_CSI_PARAM == 40:
                        # ROUND-21: Alt-F8 / "Resize Window" — enter keyboard
                        # resize mode on the focused window.
                        kmode_begin(2, scr_w, scr_h)
                    elif KEY_CSI_PARAM == 41:
                        # ROUND-22: F11 fullscreen toggle on the focused window.
                        kfs: int64 = daemon_focus_slot()
                        if kfs >= 0:
                            window_toggle_fullscreen(cast[uint64](kfs),
                                                     scr_w, scr_h)
                    elif KEY_CSI_PARAM == 42:
                        # ROUND-22: tab-group every visible window together.
                        group_visible_windows()
                    elif KEY_CSI_PARAM == 43:
                        # ROUND-22: ungroup the focused window's tab group.
                        kug: int64 = daemon_focus_slot()
                        if kug >= 0:
                            group_dissolve(DWIN_GROUP[cast[uint64](kug)])
                    elif KEY_CSI_PARAM == 44:
                        # ROUND-24: toggle keep-below (Always on Bottom) on the
                        # focused window — the inverse of the Shift+F2 keep-above
                        # binding (CSI 26).
                        kbl: int64 = daemon_focus_slot()
                        if kbl >= 0:
                            window_toggle_below(cast[uint64](kbl))
                    routed = 1
                    KEY_ST = 0
                    run_start = i + 1
                # Any other final byte (letter): some other CSI (arrows
                # etc.) — drop it rather than corrupt the shell.
                if c != 126 and (c >= 64 and c <= 126):
                    KEY_ST = 0
                    run_start = i + 1
                i = i + 1
            else:
                # ESC O <final> : F1..F4 -> workspace 1..4.
                if c == 80:             # 'P' = F1
                    workspace_switch(0)
                    routed = 1
                elif c == 81:           # 'Q' = F2
                    workspace_switch(1)
                    routed = 1
                elif c == 82:           # 'R' = F3
                    workspace_switch(2)
                    routed = 1
                elif c == 83:           # 'S' = F4
                    workspace_switch(3)
                    routed = 1
                KEY_ST = 0
                run_start = i + 1
                i = i + 1
        # Flush any trailing literal run (only when in ground state).
        if KEY_ST == 0:
            routed = key_route(run_start, total, fslot) | routed
        return routed


# BUG (spurious chars in dragged shell window): while the user holds the
# title bar to MOVE a window (GESTURE==1, MOVE_SLOT>=0), or holds an edge
# to RESIZE (GESTURE==4, RESIZE_SLOT>=0), or sweeps the rubber-band
# create gesture (DRAG_ACTIVE!=0) — the WM owns the input stream. Any
# keystroke that arrives while the WM owns input MUST NOT be routed to
# the focused window: routing them caused stray characters to land in
# the shell of the window being dragged. We still DRAIN /dev/cons so the
# kernel input ring cannot overflow, but we DROP the bytes (and reset
# any in-flight CSI state so a half-decoded sequence cannot leak into
# the next ground-state run when drag ends). This is the keystroke-route
# gate the test_de_drag_no_spurious_keys.sh structural guard pins.
def wm_owns_input() -> int32:
    if MOVE_SLOT >= 0:
        return 1
    if RESIZE_SLOT >= 0:
        return 1
    if DRAG_ACTIVE != 0:
        return 1
    if GESTURE == 1 or GESTURE == 4:
        return 1
    return 0


# Drain /dev/cons (non-blocking) and process every byte. BUG 1 fix: the old
# loop capped at 16 reads × 256 B PER FRAME and processed keys only ONCE per
# frame. When a frame was slow (a full recomposite), the kernel /dev/cons
# input ring overflowed between drains and ~half the user's keystrokes were
# dropped at the input layer before this code ever saw them. We now drain the
# ring COMPLETELY each call — looping until sys_read_nb returns EAGAIN (<=0) —
# so no byte is ever left to be overwritten by the ring. The (large) safety
# bound only guards against a misbehaving device, never normal typing. Returns
# 1 if anything was routed OR a workspace hotkey fired (screen needs present).
def daemon_pump_keys(scr_w: int64, scr_h: int64) -> int32:
    if cons_fd < 0:
        return 0
    fslot: int64 = daemon_focus_slot()
    routed: int32 = 0
    iters: int32 = 0
    while iters < 4096:
        n: int64 = sys_read_nb(cons_fd, &cons_rx[0], 256)
        iters = iters + 1
        if n <= 0:
            break                       # ring fully drained (EAGAIN)
        # KEYSTROKE-ROUTE GATE: while the WM owns the input (window move /
        # resize / rubber-band create drag in flight), drop the drained
        # bytes instead of routing them to the focused window's shell.
        # Reset the CSI decoder so a half-parsed ESC[ sequence at drag
        # start cannot bleed into the first post-drag keystroke.
        if wm_owns_input() != 0:
            KEY_ST = 0
            continue
        routed = key_process_chunk(cast[uint64](n), fslot, scr_w, scr_h) | routed
    return routed


# Drain every window's stdout pipe into its grid. Returns 1 if any
# window produced output (the screen needs a re-present).
def daemon_pump_terms() -> int32:
    changed: int32 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if term_pump(wi) != 0:
            changed = 1
            # DEPERF: this window's content changed — damage ONLY its screen
            # rect (if it is visible on the current workspace) so a busy shell
            # repaints just its own window, not the whole screen. A minimized /
            # off-workspace window's output also bumps its taskbar button, so
            # fall back to a full present only in that (rare) case.
            if win_on_cur_ws(wi) != 0:
                damage_window(wi)
            else:
                damage_full()
        wi = wi + 1
    return changed


# ====================================================================
# EVLOOP — event-driven compositor scheduling
# ====================================================================
# The main loop no longer busy-polls (sys_yield each iteration) or
# re-rasterizes markup bodies on a blind every-N-frames tick. Instead it:
#   1. runs ONE frame of event processing + damage accumulation
#      (daemon_frame), presenting only what changed, then
#   2. PARKS in sys_waitfds on the daemon's input fds (mouse, console,
#      every window's stdout pipe) with an adaptive timeout (evl_wait).
# Idle CPU is ~zero: with nothing animating the daemon sleeps in the
# kernel waitfds WaitQueue for EVL_TIMEOUT_IDLE_MS per wake, and a wake
# does no present unless something actually damaged the scene.
#
# Markup clients (hamterm etc.) repaint by WRITING their wsys layer, which
# is not an fd the daemon can park on — so each frame polls the kernel's
# pure per-layer gen counter (/dev/wsys/<N>/draw/ui/gen) and damages a
# window ONLY when its gen moved (evl_poll_markup). The expensive body
# rasterize then happens inside the present via the gen-gated markup_sync.

# Jiffy of the last window-count increase: freshly-spawned clients get an
# ANIM-cadence detection boost (snappy first paint) without committing a
# long-lived plain terminal to fast polling forever.
EVL_SPAWN_BOOST_JIFFY: uint64 = 0
EVL_SPAWN_BOOST_TTL: uint64 = 300        # jiffies (3 s)


# Per-frame markup damage generator: detect new markup clients and pick up
# repaints signalled by the kernel's per-layer gen counter. Pure reads only
# (an open probe / a gen read); the body rasterize stays in markup_sync.
def evl_poll_markup():
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) == 0:
            wi = wi + 1
            continue
        if DWIN_APP[wi] != APP_TERM or DWIN_VK[wi] != 0:
            wi = wi + 1
            continue
        if DWIN_MARKUP[wi] == 0:
            # Not yet detected: cheap open()+close() probe. On first
            # publish, damage the window — the present's markup_sync then
            # latches DWIN_MARKUP and rasterizes the first body.
            if markup_client_probe(wi) != 0:
                damage_window(wi)
        else:
            # Detected client: did it repaint since our last rasterize?
            g: int64 = read_layer_gen_ui(DWIN_WID[wi])
            if markup_body_ready[wi] == 0 or (g >= 0 and g != evl_gen[wi]):
                damage_window(wi)
        wi = wi + 1


# Gather the fds the daemon should park on. Order is stable (mouse,
# console, then window pipes) but irrelevant: any readiness wakes the
# loop, which re-pumps everything. Capped at the kernel's 16-fd limit.
def evl_collect_fds() -> uint64:
    n: uint64 = 0
    if mouse_fd >= 0:
        evl_wait_fds[n] = mouse_fd
        n = n + 1
    if cons_fd >= 0:
        evl_wait_fds[n] = cons_fd
        n = n + 1
    wi: uint64 = 0
    while wi < DWIN_COUNT and n < 16:
        if DWIN_OUT_FD[wi] >= 0:
            evl_wait_fds[n] = DWIN_OUT_FD[wi]
            n = n + 1
        wi = wi + 1
    return n


# 1 while any visible program-backed window is a (potential) markup client
# whose repaints we can only see by polling its gen counter: a detected
# markup window, or — within the post-spawn boost window — a candidate
# that has not published its "ui" layer yet.
def evl_markup_poll_hot() -> int32:
    nowj: uint64 = sys_get_jiffies()
    boost: int32 = 0
    if EVL_SPAWN_BOOST_JIFFY != 0 and nowj - EVL_SPAWN_BOOST_JIFFY < EVL_SPAWN_BOOST_TTL:
        boost = 1
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) != 0 and DWIN_APP[wi] == APP_TERM and DWIN_VK[wi] == 0:
            if DWIN_MARKUP[wi] != 0:
                return 1
            if boost != 0 and DWIN_WID[wi] >= 2:
                return 1
        wi = wi + 1
    return 0


# Adaptive park timeout. FAST while the alt-tab cycler is counting idle
# frames toward its auto-commit; ANIM while anything animates on a frame
# cadence (drag rubber band, keyboard move/resize accent, notification
# fade, OSD popups, urgency blink) or a markup client needs gen polling;
# IDLE otherwise — the once-a-second clock/stat refresh only needs the
# park to wake a few times a second.
def evl_timeout_ms() -> int64:
    if CYCLE_OPEN != 0:
        return EVL_TIMEOUT_FAST_MS
    if DRAG_ACTIVE != 0 or KMODE != 0:
        return EVL_TIMEOUT_ANIM_MS
    if NOTIFY_ACTIVE != 0:
        return EVL_TIMEOUT_ANIM_MS
    if osd_active() != 0 or ws_name_osd_active() != 0:
        return EVL_TIMEOUT_ANIM_MS
    if any_window_urgent() != 0:
        return EVL_TIMEOUT_ANIM_MS
    if evl_markup_poll_hot() != 0:
        return EVL_TIMEOUT_ANIM_MS
    return EVL_TIMEOUT_IDLE_MS


# Park until input arrives or the adaptive timeout lapses. This is the
# replacement for the old per-iteration sys_yield() busy-poll: the task
# sleeps on the kernel waitfds WaitQueue (a real sleep — jiffy-verified by
# tests/test_wsys_gen_waitfds.ad) and is woken by the pipe / console /
# pointer producers directly.
def evl_wait():
    EVL_STAT_WAITS = EVL_STAT_WAITS + 1
    n: uint64 = evl_collect_fds()
    if n == 0:
        # Defensive: nothing to park on (headless bring-up). Yield so we
        # never hard-spin.
        sys_yield()
        return
    sys_waitfds(&evl_wait_fds[0], n, evl_timeout_ms())


# Damage exactly the notification banner's screen rectangle (mirrors the
# banner placement in daemon_pixel). Used so the fade repaints a 260x44
# box, not the whole screen, and so the final expiry erases it.
def damage_notify_banner():
    nbx: int64 = cast[int64](FBG_W) - NOTIFY_W - 8
    nby: int64 = work_top(cast[int64](FBG_H)) + 8
    if nbx < 0:
        nbx = 0
    damage_rect(nbx, nby, nbx + NOTIFY_W, nby + NOTIFY_H)


# ONE frame of the event-driven main loop: pump every input source, turn
# what actually changed into damage, present the damage union (or take the
# cursor-cell fast path), and run coarse once-a-second housekeeping on the
# real jiffy clock. Returns 1 when the daemon should quit (logout /
# shutdown), else 0. Called by the main loop after every evl_wait() wake;
# also drivable standalone by selftests to simulate frames.
def daemon_frame(scr_w: int64, scr_h: int64) -> int32:
    WM_FRAME = WM_FRAME + 1
    # Start this frame's damage accumulation BEFORE the pumps so the
    # damage they raise internally (a busy shell's own window rect from
    # daemon_pump_terms) survives into this frame's flush. (The old loop
    # reset AFTER pumping, silently dropping that damage.)
    damage_reset()
    ch: int32 = daemon_pump_mouse(scr_w, scr_h)
    # Route keystrokes to the focused window's shell, then drain
    # every shell's stdout into its terminal grid.
    daemon_pump_keys(scr_w, scr_h)
    # Alt-tab cycler: while the switcher popup is up, count idle frames
    # since the last cycle keypress; auto-commit (raise the selection)
    # once the user stops pressing F5/F6 (MATE releases on key-up). The
    # park timeout drops to EVL_TIMEOUT_FAST_MS while the cycler is open
    # so this idle count still converges quickly.
    if CYCLE_OPEN != 0:
        if CYCLE_PRESSED != 0:
            CYCLE_IDLE = 0
        else:
            CYCLE_IDLE = CYCLE_IDLE + 1
            if CYCLE_IDLE >= CYCLE_COMMIT:
                cycle_commit()
        ch = 1
    CYCLE_PRESSED = 0
    daemon_pump_terms()
    # EVLOOP: markup-client refresh is GEN-DRIVEN. evl_poll_markup damages
    # a markup window ONLY when the kernel's per-layer gen counter says the
    # client repainted (or a new client published its "ui" layer); the
    # present's markup_sync then re-rasterizes exactly those bodies. There
    # is no periodic every-N-frames body re-read any more: a still desktop
    # pays a pure gen read per visible client and NOTHING else.
    evl_poll_markup()
    cursor_moved: int32 = 0
    if CUR_X != LAST_CUR_X or CUR_Y != LAST_CUR_Y:
        cursor_moved = 1
    # DE perf P0-B: a mouse packet that mutated the scene used to ALWAYS
    # escalate to damage_full() here — which threw away SCENE_CACHE every
    # interactive frame and re-ran the ~1267-line per-pixel daemon_pixel
    # cascade over the whole framebuffer. Instead, route each known
    # interactive state through damage_rect(old_bbox U new_bbox) so the
    # #410 SCENE_CACHE stays valid for the pixels OUTSIDE the dirty
    # region. We still keep damage_full as a safety fallback for the
    # rare states that aren't yet bbox-clipped (session dialog, search
    # popup, KMODE move/resize accent), but these are not the continuous
    # drag/menu hot path.
    if MOUSE_SCENE_DIRTY != 0:
        clipped: int32 = 0
        # Window-move drag: bbox = (prev window rect, new window rect).
        if MOVE_SLOT >= 0:
            damage_move_old_new()
            clipped = 1
        # Window resize: bbox = (prev frame rect, new frame rect).
        if RESIZE_SLOT >= 0 or GESTURE == 4:
            damage_resize_old_new()
            clipped = 1
        # Rubber-band (empty-desktop create drag): bbox = (prev band,
        # new band). The outline itself is painted by the post-present
        # overlay; we just need the cached scene refilled inside the
        # bbox so the previous frame's outline is erased.
        if DRAG_ACTIVE != 0:
            damage_rb_old_new()
            clipped = 1
        # Menus / context menu / calendar / cycler / run dialog:
        # bbox = (prev popup union, new popup union).
        if MENU_BAR_OPEN >= 0 or CTX_OPEN != 0 or CAL_OPEN != 0 \
           or CYCLE_OPEN != 0 or RUN_OPEN != 0:
            damage_popup_old_new()
            clipped = 1
        else:
            # All popups just closed — make sure their last-frame area
            # gets repainted with whatever lies beneath.
            if PREV_POPUP_VALID != 0:
                damage_popup_old_new()
                clipped = 1
        # When MOVE/RESIZE/DRAG just ended this frame, repaint the
        # trailing bbox (PREV_*) so the previous overlay rect gets the
        # underlying scene back.
        if MOVE_SLOT < 0 and PREV_MOVE_VALID != 0:
            damage_move_old_new()
            clipped = 1
        if RESIZE_SLOT < 0 and GESTURE != 4 and PREV_RESIZE_VALID != 0:
            damage_resize_old_new()
            clipped = 1
        if DRAG_ACTIVE == 0 and PREV_RB_VALID != 0:
            damage_rb_old_new()
            clipped = 1
        # Unrecognised mouse-scene-dirty cause: escalate to a full
        # repaint (safety net for SESSION_OPEN / SEARCH_OPEN / KMODE
        # accents / focus-raise z-order changes / etc.).
        if clipped == 0:
            damage_full()
        MOUSE_SCENE_DIRTY = 0
    # A hover-highlight-only change repaints just the window that lost the
    # highlight and the one that gained it — bounded by each window's own
    # frame — instead of a whole-screen recomposite on pointer motion.
    if MOUSE_HOVER_DIRTY != 0:
        if MOUSE_HOVER_OLD >= 0 and cast[uint64](MOUSE_HOVER_OLD) < DWIN_COUNT:
            damage_window(cast[uint64](MOUSE_HOVER_OLD))
        if MOUSE_HOVER_NEW >= 0 and cast[uint64](MOUSE_HOVER_NEW) < DWIN_COUNT \
           and MOUSE_HOVER_NEW != MOUSE_HOVER_OLD:
            damage_window(cast[uint64](MOUSE_HOVER_NEW))
        MOUSE_HOVER_DIRTY = 0
        MOUSE_HOVER_OLD = -1
        MOUSE_HOVER_NEW = -1
    # DE perf P0-B: drag / cycler in flight => damage just their bbox
    # (rubber band: old U new band rect; cycler: popup-union bbox).
    # SCENE_CACHE stays valid for everything outside the bbox.
    if DRAG_ACTIVE != 0:
        damage_rb_old_new()
    if CYCLE_OPEN != 0:
        damage_popup_old_new()
    # ROUND-21: while a keyboard move/resize mode is active, re-present
    # every frame so its accent grab-frame stays drawn over the window.
    # KMODE accents wrap an arbitrary slot — keep this as damage_full
    # for now (rare; usually accompanied by single-key cadence not
    # interactive motion-packet cadence).
    if KMODE != 0:
        damage_full()
    # Window count changed. A NEW window only dirties its OWN rect, so
    # damage just the newly-opened slots instead of escalating to a
    # full-screen per-pixel present (the multi-second window-open cost).
    # A window that CLOSED uncovers whatever was beneath it; that requires
    # repainting the vacated region, which we can't cheaply bound per-slot
    # here, so a net DECREASE still escalates to a full present (rare, and
    # not on the hot open path).
    if DWIN_COUNT != EVL_PREV_WINS:
        if DWIN_COUNT > EVL_PREV_WINS:
            ns: uint64 = EVL_PREV_WINS
            while ns < DWIN_COUNT:
                if win_on_cur_ws(ns) != 0:
                    DWIN_CONTENT_DIRTY[ns] = 1
                    damage_rect(DWIN_X[ns], DWIN_Y[ns],
                                DWIN_X[ns] + DWIN_W[ns],
                                DWIN_Y[ns] + DWIN_H[ns])
                ns = ns + 1
            # EVLOOP: boost markup-client detection to ANIM cadence for a
            # few seconds so a just-spawned client's first paint shows up
            # promptly even though it never touches its stdout pipe.
            EVL_SPAWN_BOOST_JIFFY = sys_get_jiffies()
        else:
            damage_full()
        EVL_PREV_WINS = DWIN_COUNT
    # ROUND-7: age any on-screen notification banner. EVLOOP: the banner
    # is wall-clock driven (notify_alpha), so re-present ONLY when its
    # alpha actually changed — solid phase costs nothing, the fade
    # repaints just the banner's 260x44 rect, and expiry erases it once.
    if notify_tick() != 0:
        na: int64 = notify_alpha()
        if na != EVL_NOTIFY_LAST_ALPHA:
            EVL_NOTIFY_LAST_ALPHA = na
            damage_notify_banner()
    elif EVL_NOTIFY_LAST_ALPHA >= 0:
        EVL_NOTIFY_LAST_ALPHA = -1
        damage_notify_banner()
    # DE pivot wave 7: republish the toast model to /bin/hamnotif when
    # the fade alpha bucket changes or the banner just expired.
    notif_republish_if_changed()
    # ROUND-15: collapse/reveal an autohide panel as the cursor nears the
    # bar's edge; a flip slides the whole bar in/out (full-width band).
    if panel_autohide_update(CUR_Y) != 0:
        damage_full()
    # ROUND-15: age the workspace-switch OSD popup; re-present each frame
    # it is alive so it appears and then clears (centred overlay).
    if osd_step() != 0:
        damage_full()
    # ROUND-17: age the workspace-name rename OSD the same way.
    if ws_name_osd_step() != 0:
        damage_full()
    # ROUND-15: drive the urgency blink while any window demands attention
    # so its taskbar button keeps pulsing. EVLOOP: repaint the panel band
    # only when the blink phase actually FLIPS, not every frame.
    if any_window_urgent() != 0:
        urgent_phase_step()
        ublit: int32 = urgent_blink_on()
        if ublit != EVL_URGENT_LAST_ON:
            EVL_URGENT_LAST_ON = ublit
            damage_panel()
    elif EVL_URGENT_LAST_ON >= 0:
        EVL_URGENT_LAST_ON = -1
        damage_panel()
    # Once-a-second housekeeping on the REAL jiffy clock (HZ=100, so
    # jiffies ARE centiseconds — exactly what clock_refresh expects).
    # The old loop approximated time from yield iterations; the event
    # loop sleeps, so it must use the real clock.
    nowj: uint64 = sys_get_jiffies()
    if EVL_LAST_HK_JIFFY == 0 or nowj - EVL_LAST_HK_JIFFY >= 100:
        EVL_LAST_HK_JIFFY = nowj
        # Refresh the clock + system-monitor stats. The clock + tray stats
        # live in the panel band and the desktop monitor applet on the
        # root, so damage just those regions instead of the whole screen.
        clock_refresh(nowj)
        sysmon_refresh(nowj)
        # ROUND-19: push a sample into the desktop monitor applet's
        # rolling CPU/MEM history graph.
        dmon_push()
        # Status-notifier real backends: re-read kernel network state on
        # a SLOW tick (every STATNOT_NET_POLL_JIFFIES, ~3 s) and mirror
        # the mixer if audio is live. This rides the existing 1 s
        # housekeeping gate — the panel band is damaged unconditionally
        # right below, so no extra damage/present is introduced and the
        # evloop idle invariants are untouched.
        if nowj - STATNOT_NET_JIFFY >= STATNOT_NET_POLL_JIFFIES:
            STATNOT_NET_JIFFY = nowj
            statnot_net_refresh()
            if STATNOT_AUDIO == 1:
                vol_hw_sync()
        damage_panel()
        damage_dmon_applet()
        # A live System Monitor window (APP_SYSMON) shows the same
        # once-a-second uptime/mem stats; damage each visible one so its
        # body keeps updating without a whole-screen present.
        smi: uint64 = 0
        while smi < DWIN_COUNT:
            if DWIN_APP[smi] == APP_SYSMON and win_on_cur_ws(smi) != 0:
                damage_window(smi)
            smi = smi + 1
    # The fb-text console is SUSPENDED while we own the screen (P0a), so
    # nothing else draws to /dev/fb. Present only the damage union
    # accumulated this frame; if nothing was damaged but the pointer
    # moved, the cheap cursor-cell blit handles it.
    if daemon_flush_damage() == 0 and cursor_moved != 0:
        daemon_present_cursor_move()
    # Log Out / Shut Down (ROUND-8 session dialog) request a clean
    # shutdown of the daemon so the console returns to the foreground
    # shell. SESSION_INTENT distinguishes the two for the boot scripts.
    if DAEMON_QUIT != 0:
        # ROUND-19: persist the open windows so the next login can
        # restore them (gnome-session "Remember currently running
        # applications"). Best-effort; failure doesn't block logout.
        session_save()
        if SESSION_INTENT == 2:
            write_str(1, "DAEMON shutdown\n")
        else:
            write_str(1, "DAEMON logout\n")
        return 1
    return 0


# P0a/P0b: claim the framebuffer + physical console input exclusively.
# Writing "suspend" to /dev/fbctl (1) silences the boot fb-text console /
# printk so it can never tear through the composited desktop, and (2)
# grabs the physical keyboard/UART for THIS task so the boot/login hamsh
# sharing /dev/cons can't steal keystrokes typed at the DE. Best-effort:
# a headless boot with no /dev/fbctl just composites without the takeover.
def fb_console_takeover():
    p: Ptr[uint8] = "/dev/fbctl"
    fd: int32 = sys_open_write(cast[Ptr[char]](p))
    if fd < 0:
        # No /dev/fbctl on this surface (e.g. an old kernel): the desktop
        # still composites, it just can't suspend the text console — emit a
        # marker so a test can distinguish "no takeover" from "takeover OK".
        # fbctl_fd stays -1 so every present falls back to the /dev/fb path.
        write_str(1, "DAEMON fbctl absent (no console takeover)\n")
        return
    # DEPERF: keep this /dev/fbctl write fd OPEN for the daemon's lifetime so
    # the present paths can ship binary RECT dirty-rectangle blits down it
    # (the RECT magic disambiguates them from the suspend/resume verbs below,
    # so they share the fd safely). Closed again in fb_console_release().
    fbctl_fd = fd
    verb: Ptr[uint8] = "suspend"
    sys_write(fd, verb, strlen_u8(verb))
    # Increment-1: assert EXCLUSIVE physical-keyboard ownership as its OWN
    # explicit claim (decoupled from the text-quieting "suspend" hack).
    # While this grab is held, devcons_read for any other reader (the
    # boot/login hamsh sharing /dev/cons) parks — so DE keystrokes can no
    # longer leak to the background shell. "suspend" already implied a grab
    # for back-compat, but issuing the explicit verb is what makes input
    # ownership independently provable and survives a future where the text
    # console is NOT suspended.
    gverb: Ptr[uint8] = "grab"
    sys_write(fd, gverb, strlen_u8(gverb))
    # P0a: serial confirmation that the boot fb-text console + printk were
    # silenced so they can no longer tear through the composited desktop,
    # AND that the compositor now exclusively owns physical keyboard input.
    write_str(1, "DAEMON console takeover OK (fb-text suspended)\n")
    write_str(1, "DAEMON keyboard ownership grabbed (exclusive)\n")
    # DE perf: seed the kernel-overlay cursor at the live pointer position
    # so the very first frame already shows the kernel-painted arrow on
    # scanout (KCURSOR_ACTIVE then latches and the userland
    # cursor_pixel_over overlay backs off). If the kernel is too old to
    # know the CURS command, the write returns !=24 and KCURSOR_ACTIVE
    # stays 0 — the legacy in-line overlay carries the cursor as before.
    if kcursor_push_live() != 0:
        write_str(1, "DAEMON cursor decoupled (kernel overlay)\n")


# Restore the boot text console + release the console-input grab on DE
# exit, so the user is dropped back at a usable boot shell.
def fb_console_release():
    # Resume on the persistent RECT fd if we still hold it (takeover kept it
    # open for dirty-rect presents); otherwise open a transient fd.
    if fbctl_fd >= 0:
        # Release the explicit input grab first, then restore the text
        # console. ("resume" also ungrabs for back-compat, but the explicit
        # ungrab keeps the two concerns cleanly separated.)
        ug0: Ptr[uint8] = "ungrab"
        sys_write(fbctl_fd, ug0, strlen_u8(ug0))
        verb0: Ptr[uint8] = "resume"
        sys_write(fbctl_fd, verb0, strlen_u8(verb0))
        sys_close(fbctl_fd)
        fbctl_fd = -1
        return
    p: Ptr[uint8] = "/dev/fbctl"
    fd: int32 = sys_open_write(cast[Ptr[char]](p))
    if fd < 0:
        return
    ug: Ptr[uint8] = "ungrab"
    sys_write(fd, ug, strlen_u8(ug))
    verb: Ptr[uint8] = "resume"
    sys_write(fd, verb, strlen_u8(verb))
    sys_close(fd)


# ====================================================================
# LIVE MOUSE-MOTION self-test (autoflag == 50)
# ====================================================================
# Proves END-TO-END live pointer delivery into the compositor — the one
# thing the synthetic decoder self-tests (test_mouse.sh) never covered:
# a real injected motion event travelling hardware -> kernel ring ->
# /dev/mouse -> daemon_pump_mouse -> CUR_X/CUR_Y.
#
# The harness (scripts/test_hamUI_mouse_gop.sh) waits for the READY
# banner, then injects BOTH pointer flavours through QMP
# input-send-event:
#   - "rel" dx/dy events  -> QEMU routes to the PS/2 mouse  -> IRQ12
#     auxmouse packets    -> relative /dev/mouse lines.
#   - "abs" x/y events    -> QEMU routes to the usb-tablet  -> xHCI
#     interrupt-IN reports -> hid_tablet_report -> absolute lines.
# PASS requires BOTH to move the cursor; each path also gets its own
# "observed" marker so a single-path regression is attributable.
#
# A FAIL is a real timeout diagnostic, never a hang: the loop is bounded
# by jiffies wall-clock (~90 s), far beyond the harness's inject cadence.
_mt_prints: int32 = 0

def _mt_print_cur():
    line: Array[96, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "[mousetest] CUR moved CUR_X="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](CUR_X), &line[p])
    mid: Ptr[uint8] = " CUR_Y="
    k = 0
    while mid[k] != 0:
        line[p] = mid[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](CUR_Y), &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def daemon_mouse_selftest(scr_w: int64, scr_h: int64):
    MT_REL_SEEN = 0
    MT_ABS_SEEN = 0
    _mt_prints = 0
    write_str(1, "[mousetest] READY for pointer injection\n")
    last_x: int64 = CUR_X
    last_y: int64 = CUR_Y
    rel_marked: int32 = 0
    abs_marked: int32 = 0
    start_j: uint64 = sys_get_jiffies()
    budget_j: uint64 = 9000              # ~90 s at the 100 Hz tick
    while sys_get_jiffies() - start_j < budget_j:
        daemon_pump_mouse(scr_w, scr_h)
        if CUR_X != last_x or CUR_Y != last_y:
            if _mt_prints < 8:
                _mt_print_cur()
                _mt_prints = _mt_prints + 1
            last_x = CUR_X
            last_y = CUR_Y
        if MT_REL_SEEN != 0 and rel_marked == 0:
            write_str(1, "[mousetest] REL motion observed\n")
            rel_marked = 1
        if MT_ABS_SEEN != 0 and abs_marked == 0:
            write_str(1, "[mousetest] ABS motion observed\n")
            abs_marked = 1
        if rel_marked != 0 and abs_marked != 0:
            write_str(1, "[mousetest] PASS\n")
            return
        sys_yield()
    if rel_marked == 0:
        write_str(1, "[mousetest] FAIL timeout: no RELATIVE (PS/2) motion reached the compositor\n")
    if abs_marked == 0:
        write_str(1, "[mousetest] FAIL timeout: no ABSOLUTE (usb-tablet) motion reached the compositor\n")


def cmd_daemon_auto(autoflag: int32) -> int32:
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: daemon: cannot read /dev/fb geometry\n")
        return 1
    # Test-only (autoflag 46/47 self-tests): the service supervisor binds the
    # autostarted daemon's fd 1/2 to /var/log/svc/hamuid.log, so serial
    # markers would never reach -serial. Reopen fd 1/2 onto /dev/cons FIRST —
    # BEFORE fb_console_takeover — so even the takeover's own markers (incl.
    # "DAEMON keyboard ownership grabbed") flow to the console. (Console
    # takeover suspends fb-TEXT output only; serial still flows.) Gated on the
    # self-tests so normal daemon runs keep the supervisor's log redirect.
    if autoflag == 46 or autoflag == 47 or autoflag == 48 or autoflag == 49 \
       or autoflag == 50 or autoflag == 51 or autoflag == 52:
        consw0: int32 = sys_open_write(cast[Ptr[char]]("/dev/cons"))
        if consw0 >= 0:
            sys_dup2(consw0, 1)
            sys_dup2(consw0, 2)
    # Take exclusive ownership of the framebuffer + console input now that
    # we know a real framebuffer exists (geometry read succeeded).
    fb_console_takeover()
    mp: Ptr[uint8] = "/dev/mouse"
    mfd: int32 = sys_open(cast[Ptr[char]](mp))
    if mfd < 0:
        write_str(2, "hamUId: daemon: cannot open /dev/mouse\n")
        return 1
    mouse_fd = mfd
    # Open /dev/cons for keystroke polling (best-effort: if it fails the
    # daemon still composites + spawns shells, just without key routing).
    font_init()
    # DE-perf FPS gate: presence of /etc/de-fps-test enables a per-frame
    # "[fps] frame N" serial marker that scripts/test_de_fps.sh counts.
    fps_gate_path: Ptr[uint8] = "/etc/de-fps-test"
    fps_gfd: int32 = sys_open(cast[Ptr[char]](fps_gate_path))
    if fps_gfd >= 0:
        FPS_GATE = 1
        sys_close(fps_gfd)
    # ROUND-4: seed the title-bar accent + background palettes so the
    # themeable chrome starts from a known default (Clearlooks Blue).
    theme_apply()
    bg_palette_init()
    dicons_init()                        # ROUND-19: seed desktop launcher icons
    # DE image-wallpaper: best-effort load of /etc/wallpaper.ppm at
    # startup. Failure is silent (the solid palette backdrop stays).
    # The kernel-side `wallpaper <path>` verb on /dev/wsys/ctl is the
    # runtime-reload path: wallpaper_poll_kernel() picks up gen bumps.
    dwp: Ptr[uint8] = "/etc/wallpaper.ppm"
    wallpaper_load_path(cast[Ptr[char]](dwp))
    # DE pivot wave 2 — Applications menu lives in /bin/hamappmenu now.
    # Publish the catalogue once so hamappmenu can read it back from
    # /dev/wsys/appmenu when the user triggers the Apps menu.
    appmenu_publish_snapshot()
    # DE pivot wave 4 — Run dialog lives in /bin/hamrun now. Publish the
    # initial (closed/empty) state so hamrun's first snapshot read finds
    # a coherent model before the user ever hits Alt-F2.
    run_publish_snapshot()
    # DE pivot wave 5 — Screen-lock overlay lives in /bin/hamlock now.
    # Publish the initial (unlocked, 0 fails) state so hamlock's first
    # snapshot read finds a coherent model before any session_lock.
    lock_publish_snapshot()
    cp: Ptr[uint8] = "/dev/cons"
    cons_fd = sys_open(cast[Ptr[char]](cp))
    # (fd 1/2 were already reopened onto /dev/cons for the 46/47 self-tests
    # ahead of fb_console_takeover, so every daemon marker reaches serial.)
    scr_w: int64 = cast[int64](FBG_W)
    scr_h: int64 = cast[int64](FBG_H)
    # Cursor starts at screen centre.
    CUR_X = scr_w / 2
    CUR_Y = scr_h / 2
    # Announce so a test can detect the daemon came up and parse geometry.
    line: Array[96, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "DAEMON up screen="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(FBG_W, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(FBG_H, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)
    # First frame (backdrop + cursor at centre).
    daemon_present()
    # Optional auto-window: create one terminal window programmatically
    # (mouse-free) so a test can exercise the in-window shell. The rect
    # is a fixed 480x320 box on the RIGHT half of the screen — clear of
    # the kernel framebuffer text console, which renders an 80-column
    # (~640px-wide) region anchored at the top-left and would otherwise
    # repaint over a left-side window between the daemon's frames.
    if autoflag == 1 or autoflag == 2:
        daemon_spawn_window(720, 80, 480, 320)
        write_str(1, "DAEMON autowin created\n")
        daemon_present()
    # WM self-test (autoflag == 2): drive a title-drag move + close-box
    # click through synthetic packets so the gestures are exercised
    # deterministically without QEMU mouse injection.
    if autoflag == 2:
        daemon_wm_selftest(scr_w, scr_h)
        daemon_present()
    # PANEL self-test (autoflag == 3): drive the Applications menu open +
    # a menu-item launch through the SAME gesture machine, emitting the
    # PANEL serial markers, so a non-interactive test can assert the
    # launcher without QEMU mouse injection.
    if autoflag == 3:
        daemon_panel_selftest(scr_w, scr_h)
        daemon_present()
    # TERMINAL I/O self-test (autoflag == 5): create two windows, write a
    # sentinel command to each child's stdin pipe, pump stdout into the
    # terminal grid, and verify the sentinel string appears in the grid.
    # Also exercises the body-click focus-switch: clicking window 0's body
    # raises it to the top (emitting "WM focus window") and routes input
    # to its pipe. Does NOT enter the main loop — exits after the test.
    if autoflag == 5:
        daemon_terminal_selftest(scr_w, scr_h)
        return 0
    # TASKBAR / MINIMIZE / CLOCK self-test (autoflag == 6): exercises the
    # three new panel features: window-list taskbar, minimize/restore, and
    # live clock. Does NOT enter the main loop — exits after the test.
    if autoflag == 6:
        daemon_taskbar_selftest(scr_w, scr_h)
        return 0
    # VULKAN WINDOW self-test (autoflag == 8): create a normal composited
    # window, drive the kernel software rasterizer (SYS_VK_WINDOW_FRAME) to
    # render an animated triangle into that window's draw surface, composite
    # it, and assert the Vulkan pixels land inside the window body, the
    # backdrop shows outside it (proving windowed, not full-screen), and the
    # frame changes when the animation advances. Exits after the test.
    if autoflag == 8:
        daemon_vk_window_selftest(scr_w, scr_h)
        return 0
    # MARKUP-CLIENT self-test (autoflag == 46): spawn a window, inject a
    # hamui-style "ui" markup layer, run the LIVE present path, and assert
    # the markup's rect colours land at the on-screen window-body coords
    # while the backdrop shows outside the window. Proves the live
    # compositor now composites external lib/hamui.ad clients. Exits.
    if autoflag == 46:
        daemon_markup_client_selftest(scr_w, scr_h)
        return 0
    # SEPARATE-PROCESS APP SPINE self-test (autoflag == 47): spawn
    # /bin/hamecho as its OWN process, allocate its wid, prove the spawn
    # damages only its own window rect (no full recomposite), that its hamui
    # markup composites on screen, that a focus-gated routed keystroke
    # crosses into the separate process, and that it does NOT leak to the
    # /dev/cons shell stream. Increment-1 of the MATE-mirror DE rewrite. Exits.
    if autoflag == 47:
        daemon_app_spine_selftest(scr_w, scr_h)
        return 0
    # TERMINAL APP-SPINE self-test (autoflag == 48): spawn /bin/hamterm as
    # its OWN process, allocate its wid, prove window-only spawn damage + on-
    # screen markup, route the focus-gated command `echo TERMOK`+Enter into
    # the separate process, assert it ran a REAL /bin/hamsh and rendered the
    # output live, and that the keystrokes did NOT leak to /dev/cons.
    # Increment-2 of the MATE-mirror DE rewrite (the terminal-open lag bug). Exits.
    if autoflag == 48:
        daemon_app_term_selftest(scr_w, scr_h)
        return 0
    # MENU TERMINAL self-test (autoflag == 49): drive the Applications-menu
    # "Terminal" entry's real dispatch (menu_launch(0, ...)) and assert it
    # spawns /bin/hamterm as a SEPARATE process (wid>=2, stdout pipe, markup
    # auto-detected) — NOT the dormant in-daemon APP_TERM hand-drawn grid.
    # Increment-3a of the MATE-mirror DE rewrite (menu/panel Terminal launcher
    # rewired to the separate-process path). Exits.
    if autoflag == 49:
        daemon_menu_term_selftest(scr_w, scr_h)
        return 0
    # LIVE MOUSE-MOTION self-test (autoflag == 50): pump /dev/mouse exactly
    # like the main loop and report when injected pointer motion (QEMU
    # monitor mouse_move for the PS/2 path; QMP input-send-event abs for the
    # usb-tablet path) actually moves CUR_X/CUR_Y. Proves end-to-end live
    # packet delivery: IRQ12/xHCI -> ring -> /dev/mouse -> compositor. Exits.
    if autoflag == 50:
        daemon_mouse_selftest(scr_w, scr_h)
        return 0
    # EVENT-LOOP self-test (autoflag == 51): prove the event-driven
    # scheduling — evl_wait really parks in sys_waitfds (jiffy-verified),
    # markup bodies re-rasterize ONLY on a per-layer gen change (no
    # periodic re-read), the gen-triggered present is bounded by the
    # window rect, a dead child's EOF'd pipe is closed (no hot-spin), and
    # a pure cursor move stays on the blit fast path. Exits.
    if autoflag == 51:
        daemon_evloop_selftest(scr_w, scr_h)
        return 0
    # VOLUME ROUND-TRIP self-test (autoflag == 52): prove the panel volume
    # applet drives the REAL kernel mixer — vol_step writes a ctl verb to
    # /dev/audioctl and the marker only prints after an independent
    # re-read of the /dev/audio status line shows the mixer changed.
    # Requires QEMU's intel-hda device. Exits.
    if autoflag == 52:
        daemon_volume_selftest(scr_w, scr_h)
        return 0
    # WORKSPACE self-test (autoflag == 9): create a window, switch virtual
    # desktops, and assert via composited-pixel sampling that the window is
    # only visible on its own workspace; also exercise the pager click and
    # the hotkey-path switch. Exits after the test.
    if autoflag == 9:
        daemon_workspace_selftest(scr_w, scr_h)
        return 0
    # DECORATION self-test (autoflag == 10): sample composited pixels to
    # verify the title-bar gradient, beveled border corners, the maximize
    # button, and the maximize/restore geometry toggle. Exits after.
    if autoflag == 10:
        daemon_decoration_selftest(scr_w, scr_h)
        return 0
    # CONTEXT-MENU self-test (autoflag == 11): verify the GNOME2 menu bar
    # opens, the right-click desktop + window context menus composite, and
    # their actions (New Terminal spawn, window Close) fire. Exits after.
    if autoflag == 11:
        daemon_ctxmenu_selftest(scr_w, scr_h)
        return 0
    # DESKTOP APPS self-test (autoflag == 12): built-in calculator, system
    # monitor, and window snapping/maximize. Exits after the test.
    if autoflag == 12:
        daemon_apps_selftest(scr_w, scr_h)
        return 0
    # ROUND-3 MATE-feel self-test (autoflag == 13): alt-tab cycler,
    # double-click-titlebar maximize, change-background, arrange-windows,
    # and notification-area geometry. Exits after the test.
    if autoflag == 13:
        daemon_round3_selftest(scr_w, scr_h)
        return 0
    # ROUND-4 MATE-feel self-test (autoflag == 14): theme accent cycling,
    # background + panel-position prefs, keyboard half/quarter tiling,
    # show-desktop toggle, move-window-to-workspace, and the Settings app.
    if autoflag == 14:
        daemon_round4_selftest(scr_w, scr_h)
        return 0
    # ROUND-5 MATE-feel self-test (autoflag == 15): MRU Alt-Tab order,
    # edge/corner drag snapping + live preview, live tray window-count
    # badge, pager click-to-switch, and the desktop context-menu Settings
    # row. Exits after the test.
    if autoflag == 15:
        daemon_round5_selftest(scr_w, scr_h)
        return 0
    # ROUND-6 MATE-feel self-test (autoflag == 16): interactive window
    # resize by dragging edges/corners (8-direction grips, minimum sizes,
    # opposite-edge anchoring), the window-menu "Resize" entry, and the
    # live resize frame. Exits after the test.
    if autoflag == 16:
        daemon_round6_selftest(scr_w, scr_h)
        return 0
    # ROUND-7 MATE-feel self-test (autoflag == 17): categorised Applications
    # menu with submenu flyouts, clock calendar popup + date arithmetic,
    # taskbar grouping/raise, the Settings focus-model row + focus-follows-
    # mouse, and the transient notification-banner lifecycle. Exits after.
    if autoflag == 17:
        daemon_round7_selftest(scr_w, scr_h)
        return 0
    # ROUND-8 MATE-feel self-test (autoflag == 18): the modal session dialog
    # (Lock Screen / Log Out / Shut Down / Cancel) + screen lock overlay, and
    # the Settings "Workspaces" row that reconfigures the number of virtual
    # desktops. Exits after the test.
    if autoflag == 18:
        daemon_round8_selftest(scr_w, scr_h)
        return 0
    # ROUND-9 MATE-feel self-test (autoflag == 19): window shading (roll-up
    # to the title bar + unshade), always-on-top z-order pinning, and the
    # vertical/horizontal maximize window-menu rows. Exits after the test.
    if autoflag == 19:
        daemon_round9_selftest(scr_w, scr_h)
        return 0
    # ROUND-10 MATE-feel self-test (autoflag == 20): workspace pager
    # drag-window-between-workspaces, window-list grouping (collapse same-
    # app windows to one (N) button + click-to-cycle), and the Applications
    # menu type-to-search filter. Exits after the test.
    if autoflag == 20:
        daemon_round10_selftest(scr_w, scr_h)
        return 0
    # ROUND-11 MATE-feel self-test (autoflag == 21): panel-position-aware
    # work area (top vs bottom panel reserves the right strip; snap/maximize
    # + live preview follow it), window-list group actions (minimize/restore/
    # close-all), and the standard Ctrl-Alt-arrow workspace navigation +
    # Ctrl-Alt-Shift-arrow move-window-to-adjacent-workspace. Exits after.
    if autoflag == 21:
        daemon_round11_selftest(scr_w, scr_h)
        return 0
    # ROUND-12 MATE-feel self-test (autoflag == 22): the panel BAR + all its
    # hit-tests now render at the configured edge (top OR bottom), the menu
    # drop-downs grow away from the panel, and a classic Show Desktop applet
    # minimizes/restores every window. Asserts BOTH panel positions. Exits.
    if autoflag == 22:
        daemon_round12_selftest(scr_w, scr_h)
        return 0
    # ROUND-13 MATE-feel self-test (autoflag == 23): the Run dialog (Alt-F2),
    # the notification-history message tray, and the enriched Places/System
    # menus. Asserts tray hit-zones for BOTH panel positions. Exits.
    if autoflag == 23:
        daemon_round13_selftest(scr_w, scr_h)
        return 0
    # ROUND-14 MATE-feel self-test (autoflag == 24): the window-list (taskbar)
    # per-window right-click menu, the pager right-click menu (add/remove
    # workspace + show-all-workspaces toggle), and the "show windows from all
    # workspaces" window-list filter. Asserts both panel positions. Exits.
    if autoflag == 24:
        daemon_round14_selftest(scr_w, scr_h)
        return 0
    # ROUND-15 self-test: the panel context menu (flip/autohide/add-to-panel/
    # preferences), panel-autohide state machine, the workspace-switch OSD,
    # window-urgency blink, and the Alt-Space focused-window menu. Asserts
    # both panel positions. Exits.
    if autoflag == 25:
        daemon_round15_selftest(scr_w, scr_h)
        return 0
    # ROUND-16 self-test: the Control Center (categorised Appearance/Panel/
    # Windows/Keyboard window), the full theme engine (colour scheme recolours
    # panel/menu/desktop live), the UI-scale 1x/2x toggle, the focus-model
    # setting, and the keyboard-shortcut viewer. Asserts the theme engine
    # mutates the live colour globals for BOTH panel positions. Exits.
    if autoflag == 26:
        daemon_round16_selftest(scr_w, scr_h)
        return 0
    # ROUND-17 self-test: the status-notifier indicator area (battery/network/
    # volume cells with detail popups), the centred volume/brightness OSD
    # slider (clamping + mute + fill geometry), the panel Window-Selector
    # applet (lists every window across all workspaces, click-to-activate),
    # and editable workspace names + their transient OSD. Asserts the applet
    # geometry for BOTH panel positions. Exits.
    if autoflag == 27:
        daemon_round17_selftest(scr_w, scr_h)
        return 0
    # ROUND-18 self-test: the session logout/shutdown countdown (auto-confirm
    # + cancel), the lock-screen password model (push/backspace/try, wrong vs
    # right secret), the Super+N workspace grid + Super+Shift+N move-to-
    # workspace, the Applications recent/favorites launch-frequency ordering,
    # notification rules (DND gate, critical break-through, per-urgency expiry
    # + accent), and the clock 12h/24h/seconds/date formatter. Asserts the
    # workspace OSD band for BOTH panel positions. Exits.
    if autoflag == 28:
        daemon_round18_selftest(scr_w, scr_h)
        return 0
    # ROUND-19: per-window opacity clamp, session save/restore round-trip,
    # desktop icons + grid-snap, and the desktop system-monitor applet. Exits.
    if autoflag == 29:
        daemon_round19_selftest(scr_w, scr_h)
        return 0
    # ROUND-20: sticky windows (Always on Visible Workspace), the clipboard
    # / selection manager ring, the window cascade arrangement, and the
    # quick two-pane tile. Exits.
    if autoflag == 30:
        daemon_round20_selftest(scr_w, scr_h)
        return 0
    # ROUND-21: smart window placement, window-to-window magnetic snapping
    # (edge resistance), and keyboard move/resize mode (Alt-F7 / Alt-F8). Exits.
    if autoflag == 31:
        daemon_round21_selftest(scr_w, scr_h)
        return 0
    # ROUND-22: true fullscreen (F11), window tab-grouping (shared frame +
    # title-bar tab strip), and drag edge-flip to the adjacent workspace. Exits.
    if autoflag == 32:
        daemon_round22_selftest(scr_w, scr_h)
        return 0
    # ROUND-23: virtual-workspace render isolation (a window on ws0 is not
    # composited on ws1, restored on switch-back) + the pager occupancy
    # mini-map reflecting per-workspace window counts (incl. sticky-in-every-
    # cell), the Move-to-Workspace relocation, and pager click-to-switch. Exits.
    if autoflag == 33:
        daemon_round23_selftest(scr_w, scr_h)
        return 0
    # TRAY-LAYOUT self-test (autoflag == 34): assert the right-edge panel
    # applet chain (pager, window-selector, status-notifier, notification
    # stub, show-desktop, clock) tiles WITHOUT overlap, and that the
    # status-notifier + notification cells tile internally. Guards the
    # "green/blue status bars near the clock overlap" regression. Exits.
    if autoflag == 34:
        daemon_tray_layout_selftest(scr_w, scr_h)
        return 0
    # DE-BUGFIX self-test (autoflag == 35): wall-clock banner dismissal
    # (P2a) and the file-manager-opens-at-argv[1] path (P1b). Exits.
    if autoflag == 35:
        daemon_debugfix_selftest(scr_w, scr_h)
        return 0
    # DEPERF self-test (autoflag == 36): assert the dirty-rect present path
    # scales with the changed window's rect, not O(screen * windows), and is
    # independent of the number of open windows. Exits.
    if autoflag == 36:
        daemon_deperf_selftest(scr_w, scr_h)
        return 0
    # DEUSE self-test (autoflag == 37): assert the three DE-usability fixes —
    # no keystroke loss under a slow-frame backlog, the panel context menu box
    # fits its widest label, and pointer-move / occluded-stack compositing is
    # window-count bounded. Pure model state, no real framebuffer. Exits.
    if autoflag == 37:
        daemon_deusability_selftest(scr_w, scr_h)
        return 0
    # DEAPPS self-test (autoflag == 38): assert the two new in-compositor
    # desktop apps — the icon-grid file manager (enumeration, dir/file
    # classification, folder-click navigation, up affordance) and the
    # Kate-like text editor (keystroke buffer edits via the real focused-
    # window key path, plus a load-from-path / save-to-path round-trip).
    # Pure model state, no real framebuffer. Exits.
    if autoflag == 38:
        daemon_deapps_selftest(scr_w, scr_h)
        return 0
    # DEWM self-test (autoflag == 39): assert the four MATE/Marco window
    # operations — title-bar/maximize-button maximize+exact restore, left-edge
    # Marco snap (left half) + exact un-snap, minimize-to-panel (leaves the
    # composite set while the panel window-list entry remains) + focused
    # restore, and per-workspace render isolation with the Ctrl-Alt-arrow
    # switch. Pure model state, no real framebuffer. Exits.
    if autoflag == 39:
        daemon_dewm_selftest(scr_w, scr_h)
        return 0
    # DESW self-test (autoflag == 40): assert the MATE/Marco Alt-Tab MRU
    # window switcher (forward Tab selects the 2nd then 3rd MRU window,
    # release raises+fronts the selection, Shift-Tab reverses, an off-
    # workspace window is not a candidate) and the desktop right-click
    # context menu (box width fits its widest label, Open Terminal spawns an
    # in-compositor APP_TERM window). Pure model state, no real framebuffer.
    if autoflag == 40:
        daemon_deswitch_selftest(scr_w, scr_h)
        return 0
    # DERS self-test (autoflag == 41): assert MATE/Marco edge-corner resize-
    # drag (right border +40 widens by exactly 40 with x/y/top fixed, bottom-
    # left corner changes width+height+x together, an inward drag clamps at the
    # minimum size) and the Show-Desktop / minimize-all toggle (first invoke
    # hides every visible current-workspace window so the composite set is
    # empty, second invoke restores EXACTLY that set + focus). Pure model
    # state, no real framebuffer. Exits.
    if autoflag == 41:
        daemon_deresize_selftest(scr_w, scr_h)
        return 0
    # DEQT self-test (autoflag == 42): assert MATE/Marco corner-quadrant tiling
    # — a corner-reaching title drag classifies (snap_zone_for) and snap_apply
    # tiles the window to exactly the top-left / top-right / bottom-left /
    # bottom-right QUARTER of the panel-aware work area; the four quadrants
    # paper the work area with no gap/overlap; the keyboard tile_focused path
    # snaps the focused window to a quadrant; and un-snap restores the exact
    # float rect. Pure model state, no real framebuffer. Exits.
    if autoflag == 42:
        daemon_dequartile_selftest(scr_w, scr_h)
        return 0
    # DECACHE self-test (autoflag == 43): assert the per-window backbuffer
    # cache — a pure MOVE reuses every window's cache (0 re-renders), a
    # content change re-renders only that one window, and the composited
    # output is pixel-identical to a full procedural recomposite. Pure model
    # state, no real framebuffer. Exits.
    if autoflag == 43:
        daemon_decache_selftest(scr_w, scr_h)
        return 0
    # DERECT self-test (autoflag == 44): assert the /dev/fbctl binary RECT
    # dirty-rectangle present path actually fires from the live compositor —
    # a partial present routes through the kernel RECT handler (proved by the
    # kernel ACKing the 52-byte write), collapsing the per-row seek+write loop
    # to one write per band. Requires a real /dev/fbctl (claimed above); SKIPs
    # cleanly headless. Exits.
    if autoflag == 44:
        daemon_derect_selftest(scr_w, scr_h)
        return 0
    # DECURSOR self-test (autoflag == 45): assert term_feed honours the
    # cursor-positioning CSI sequences (CUF/CUP/CHA/EL) hamsh's line editor
    # emits, so the terminal caret tracks the real input column instead of
    # sticking at column 0, and the rendered cursor block follows. Pure model
    # state, no real framebuffer. Exits.
    if autoflag == 45:
        daemon_decursor_selftest(scr_w, scr_h)
        return 0
    # Initial clock + system-monitor seed (before the first frame so the
    # panel shows a time and any System Monitor window shows live stats).
    # Also probe the REAL status-notifier backends once (mixer via
    # /dev/audio[ctl], network via /net/addr) so the first painted panel
    # reflects kernel truth, not placeholder defaults.
    statnot_backend_init()
    clock_refresh(0)
    sysmon_refresh(0)
    dmon_push()                          # ROUND-19: seed the monitor graph
    # ROUND-7: greet the user with a transient notification banner so the
    # notification surface is exercised on every real boot of the DE.
    notify_post("Welcome to Hamnix", "Click Applications to launch an app")
    # DE pivot Stage B.4: the panel is no longer drawn inline by
    # daemon_pixel — it runs as a standalone hamui-client app over the
    # #442 (c) v2 blit protocol. Spawn /bin/hampanel into a panel-shape
    # window (PANEL_H tall, top of screen). The compositor's
    # v2_present_dirty_windows() will blit its kernel-side backbuffer
    # straight to /dev/fb each present.
    if autoflag == 0 or autoflag == 1:
        # hampanel's v2 client backbuffer is now sized to the full
        # screen (HAMUI_V2_BB_W = 1280, HAMUI_V2_BB_H = 800). Spawn the
        # panel window at full FBG_W so the apps button hugs the left
        # edge, the clock hugs the right edge, and the taskbar/winlist
        # fills the middle — the v2 client paints the full strip.
        daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hampanel"),
                                 0, 0, cast[int64](FBG_W), cast[int64](PANEL_H))
        mark_last_window_chromeless()
        # DE pivot wave 3: spawn /bin/hamcycler ONCE at startup. It
        # stays resident for the whole session; F5/F6 just republish
        # the model + poke its show serial.
        cycler_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 4: spawn /bin/hamcalpop ONCE at startup. It
        # stays resident for the whole session; clock-applet clicks
        # toggle CAL_OPEN, which republishes the model + pokes the
        # show serial. (Distinct from /bin/hamclock — that is the
        # standalone clock app.)
        calpop_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 4: spawn /bin/hamrun ONCE at startup. Like the
        # cycler, the Run dialog is a long-lived overlay client; the
        # compositor republishes its model + pokes its show serial on
        # every Alt-F2 / keystroke / launch.
        run_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 5: spawn /bin/hamlock ONCE at startup. Like the
        # run/cycler clients, the lock overlay is a long-lived full-screen
        # surface; the compositor republishes its model + pokes its show
        # serial on every session_lock / session_unlock / verify drain.
        lock_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 7: spawn /bin/hamrband ONCE at startup. The
        # rubber-band drag overlay client stays resident; the compositor
        # republishes its (active, bbox) model + pokes /dev/wsys/rband/set
        # on every frame the drag rect changes.
        rband_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 7: spawn /bin/hamnotif ONCE at startup. Like the
        # lock/run clients, the notification toast is a long-lived overlay
        # surface; the compositor republishes its model + pokes its show
        # serial on every notify_post() and whenever the wall-clock fade
        # bucket changes (notify_tick) or the banner expires.
        notif_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 8: spawn /bin/hamsessui ONCE at startup. The End
        # Session modal client stays resident; the compositor republishes
        # its (open, hover) model + pokes /dev/wsys/sessui/show on every
        # session_open / session_invoke / hover change.
        sessui_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 1 (round 2): spawn /bin/hamdesktop ONCE at startup.
        desktop_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 2 (round 2): spawn /bin/hamsysmon ONCE at startup.
        sysmon_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 3 (round 2): spawn /bin/hamctxmenu ONCE at startup.
        ctxmenu_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 4 (round 2): spawn /bin/hamsnap ONCE at startup.
        snap_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 5 (round 2): spawn /bin/hamresize ONCE at startup.
        resize_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 6 (round 2): spawn /bin/hamosd ONCE at startup.
        osd_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
        # DE pivot wave 7 (round 2): spawn /bin/hamtray ONCE at startup.
        tray_spawn(cast[int64](FBG_W), cast[int64](FBG_H))
        mark_last_window_chromeless()
    # Force a full-screen present BEFORE the main loop runs (and BEFORE
    # daemon_frame's damage_reset wipes it), so the desktop backdrop /
    # wallpaper lands on scanout in the very first present. Without
    # this seed the first frame only repaints whatever the spawn waves
    # damaged (a few window rects), and everywhere else still shows the
    # boot fb-text background (black) -- exactly the empty-windows-on-
    # black look the screenshot test captured.
    damage_full()
    daemon_flush_damage()
    EVL_PREV_WINS = DWIN_COUNT
    EVL_LAST_HK_JIFFY = 0
    while True:
        # DE image-wallpaper: pick up runtime wallpaper changes posted
        # by the kernel /dev/wsys/ctl `wallpaper <path>` verb. Gated
        # internally to every WALLPAPER_POLL_EVERY iterations so the
        # idle path stays event-driven.
        wallpaper_poll_kernel()
        # DE pivot wave 2: pick up any pending hamappmenu launch + spawn it.
        appmenu_drain_launch(scr_w, scr_h)
        # DE pivot wave 4: pick up any pending hamrun launch + spawn it.
        run_drain_launch(scr_w, scr_h)
        # DE pivot wave 5: pick up any pending hamlock password attempt +
        # run lock_pw_try against the stored secret.
        lock_drain_verify(scr_w, scr_h)
        if daemon_frame(scr_w, scr_h) != 0:
            break
        evl_wait()
    # Restore the boot text console + release the console-input grab so
    # the user lands back at a usable boot shell after logout/shutdown.
    fb_console_release()
    return 0


def usage(fd: int32):
    write_str(fd, "Usage: hamUId render <wid> | hamUId present <wid> | hamUId daemon [autowin|wmselftest|panelselftest|terminalselftest|taskbarselftest|vkwindowselftest|workspaceselftest|decorationselftest|ctxmenuselftest|appsselftest|round3selftest|round4selftest|round5selftest|round6selftest|round7selftest|round8selftest|round9selftest|round10selftest|round11selftest|round12selftest|round13selftest|round14selftest|round15selftest|round16selftest|round17selftest|round18selftest|round19selftest|round20selftest|round21selftest|round22selftest|round23selftest|traylayoutselftest|debugfixselftest|deperfselftest|deusabilityselftest|deappsselftest|mousetest|evloop|volrt]\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Bare `hamUId` (no subcommand) DEFAULTS to daemon mode so the DE is
    # trivial to start — just run `hamUId`. The explicit `hamUId daemon`
    # form (and its selftest sub-args) keeps working unchanged below.
    # This is also what the declarative service definition
    # (/etc/services.d/hamuid.svc) and rc.5 invoke.
    if argc < 2:
        return cmd_daemon_auto(0)
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if cstr_eq(verb, "render") != 0:
        if argc < 3:
            write_str(2, "hamUId: render: missing wid\n")
            return 1
        wid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if wid < 1:
            write_str(2, "hamUId: render: bad wid\n")
            return 1
        return cmd_render(wid)
    if cstr_eq(verb, "present") != 0:
        if argc < 3:
            write_str(2, "hamUId: present: missing wid\n")
            return 1
        pwid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if pwid < 1:
            write_str(2, "hamUId: present: bad wid\n")
            return 1
        return cmd_present(pwid)
    if cstr_eq(verb, "daemon") != 0:
        # Optional `autowin` arg: immediately drag-create one terminal
        # window (mouse-free) so a non-interactive test can exercise the
        # in-window shell without driving QEMU mouse events.
        autoflag: int32 = 0
        if argc >= 3:
            a2: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
            if cstr_eq(a2, "autowin") != 0:
                autoflag = 1
            # `wmselftest` => autowin + a mouse-free move+close self-test.
            if cstr_eq(a2, "wmselftest") != 0:
                autoflag = 2
            # `panelselftest` => a mouse-free panel/menu open+launch test.
            if cstr_eq(a2, "panelselftest") != 0:
                autoflag = 3
            # `terminalselftest` => per-window stdin→stdout→grid I/O test.
            if cstr_eq(a2, "terminalselftest") != 0:
                autoflag = 5
            # `taskbarselftest` => taskbar/minimize/clock feature test.
            if cstr_eq(a2, "taskbarselftest") != 0:
                autoflag = 6
            # `vkwindowselftest` => kernel Vulkan rasterizer into a window.
            if cstr_eq(a2, "vkwindowselftest") != 0:
                autoflag = 8
            # `workspaceselftest` => MATE virtual desktops + pager.
            if cstr_eq(a2, "workspaceselftest") != 0:
                autoflag = 9
            # `decorationselftest` => themed window decorations + maximize.
            if cstr_eq(a2, "decorationselftest") != 0:
                autoflag = 10
            # `ctxmenuselftest` => right-click context menus + menu bar.
            if cstr_eq(a2, "ctxmenuselftest") != 0:
                autoflag = 11
            # `appsselftest` => built-in apps (calc/sysmon) + snapping test.
            if cstr_eq(a2, "appsselftest") != 0:
                autoflag = 12
            # `round3selftest` => alt-tab cycler, dblclick maximize,
            # change-background, arrange-windows, tray geometry.
            if cstr_eq(a2, "round3selftest") != 0:
                autoflag = 13
            # `round4selftest` => theme accent, prefs, keyboard tiling,
            # show-desktop, move-to-workspace, Settings app.
            if cstr_eq(a2, "round4selftest") != 0:
                autoflag = 14
            # `round5selftest` => MRU alt-tab, drag edge/corner snapping +
            # live preview, live tray badge, pager click, ctx-menu Settings.
            if cstr_eq(a2, "round5selftest") != 0:
                autoflag = 15
            # `round6selftest` => interactive window resize by edges/corners,
            # the window-menu Resize entry, and the live resize frame.
            if cstr_eq(a2, "round6selftest") != 0:
                autoflag = 16
            # `round7selftest` => categorised Applications menu + submenus,
            # clock calendar popup, taskbar raise, focus-model setting +
            # focus-follows-mouse, transient notification banner.
            if cstr_eq(a2, "round7selftest") != 0:
                autoflag = 17
            # `round8selftest` => session dialog (lock/logout/shutdown/cancel),
            # screen-lock overlay, and the Settings Workspaces-count row.
            if cstr_eq(a2, "round8selftest") != 0:
                autoflag = 18
            # `round9selftest` => window shading (roll-up), always-on-top
            # z-order pinning, and vertical/horizontal maximize menu rows.
            if cstr_eq(a2, "round9selftest") != 0:
                autoflag = 19
            # `round10selftest` => workspace pager drag-window-between-
            # workspaces, window-list grouping (collapse + click-to-cycle),
            # and the Applications menu type-to-search filter.
            if cstr_eq(a2, "round10selftest") != 0:
                autoflag = 20
            # `round11selftest` => panel-position-aware work area (top/bottom
            # panel), window-list group actions (minimize/restore/close-all),
            # and standard Ctrl-Alt(+Shift)-arrow workspace navigation/move.
            if cstr_eq(a2, "round11selftest") != 0:
                autoflag = 21
            # `round12selftest` => the panel BAR + every panel hit-test now
            # render at the configured edge (top OR bottom), drop-downs grow
            # away from the bar, and a Show Desktop applet minimizes/restores
            # all windows. Asserts BOTH panel positions.
            if cstr_eq(a2, "round12selftest") != 0:
                autoflag = 22
            # `round13selftest` => the Run dialog (Alt-F2), the notification-
            # history message tray, and the enriched Places/System menus.
            # Asserts the tray hit-zones for BOTH panel positions.
            if cstr_eq(a2, "round13selftest") != 0:
                autoflag = 23
            # `round14selftest` => the window-list (taskbar) per-window
            # right-click menu, the pager right-click menu (add/remove
            # workspace + show-all-workspaces toggle), and the show-windows-
            # from-all-workspaces window-list filter.
            if cstr_eq(a2, "round14selftest") != 0:
                autoflag = 24
            # `round15selftest` => the panel context menu (flip position /
            # autohide / add-to-panel / preferences), the panel-autohide
            # state machine, the workspace-switch OSD popup, the window
            # urgency / demand-attention blink, and the Alt-Space focused-
            # window menu. Asserts BOTH panel positions.
            if cstr_eq(a2, "round15selftest") != 0:
                autoflag = 25
            # `round16selftest` => the Control Center (categorised Appearance/
            # Panel/Windows/Keyboard window), the full theme engine (colour
            # scheme recolours the live panel/menu/desktop chrome), the UI
            # 1x/2x scale toggle, the focus-model setting, and the keyboard-
            # shortcut viewer. Asserts the theme engine mutates the live
            # colour globals for BOTH panel positions.
            if cstr_eq(a2, "round16selftest") != 0:
                autoflag = 26
            # `round17selftest` => the status-notifier indicator area, the
            # centred volume/brightness OSD slider, the panel Window-Selector
            # applet, and editable workspace names + their transient OSD.
            # Asserts the applet geometry for BOTH panel positions.
            if cstr_eq(a2, "round17selftest") != 0:
                autoflag = 27
            # `round18selftest` => the session logout/shutdown countdown
            # (auto-confirm + cancel), the lock-screen password model, the
            # Super+N workspace grid + Super+Shift+N move-to-workspace, the
            # Applications recent/favorites launch-frequency ordering, the
            # notification rules (DND gate, critical break-through, per-
            # urgency expiry + accent), and the clock 12h/24h/seconds/date
            # formatter. Asserts the workspace OSD band for BOTH panel
            # positions.
            if cstr_eq(a2, "round18selftest") != 0:
                autoflag = 28
            # `round19selftest` => per-window opacity clamp, session
            # save/restore serialisation round-trip, desktop icons +
            # grid-snap hit-testing, and the desktop system-monitor applet
            # (history ring + applet hit-test).
            if cstr_eq(a2, "round19selftest") != 0:
                autoflag = 29
            # `round20selftest` => sticky windows (Always on Visible
            # Workspace) with slot_copy/slot_swap mirroring, the clipboard
            # manager ring (push/dedup/cap/cycle), the window cascade
            # arrangement, and the quick two-pane tile.
            if cstr_eq(a2, "round20selftest") != 0:
                autoflag = 30
            # `round21selftest` => smart window placement (lowest-overlap
            # origin), window-to-window magnetic snapping (edge resistance),
            # and keyboard move/resize mode (Marco Alt-F7 / Alt-F8).
            if cstr_eq(a2, "round21selftest") != 0:
                autoflag = 31
            # `round22selftest` => true fullscreen (F11), window tab-grouping
            # (shared frame + title-bar tab strip), and drag edge-flip to the
            # adjacent workspace.
            if cstr_eq(a2, "round22selftest") != 0:
                autoflag = 32
            # `round23selftest` => virtual-workspace render isolation (a
            # window on ws0 is hidden on ws1 and restored on switch-back) +
            # the pager occupancy mini-map reflecting per-workspace window
            # counts (incl. sticky-in-every-cell), Move-to-Workspace, and
            # pager click-to-switch.
            if cstr_eq(a2, "round23selftest") != 0:
                autoflag = 33
            # `traylayoutselftest` => assert the right-edge panel applet
            # chain (pager / window-selector / status-notifier /
            # notification stub / show-desktop / clock) tiles WITHOUT
            # overlap and that the indicator cells tile internally. Guards
            # the "green/blue status bars near the clock overlap" defect.
            if cstr_eq(a2, "traylayoutselftest") != 0:
                autoflag = 34
            # `debugfixselftest` => P2a wall-clock banner dismissal + P1b
            # file-manager-opens-at-argv[1] (HAMFM_READY) verification.
            if cstr_eq(a2, "debugfixselftest") != 0:
                autoflag = 35
            # `deperfselftest` => the dirty-rectangle present scaling proof:
            # a single-window content update presents only that window's rect
            # and the presented area does NOT grow with the open-window count.
            if cstr_eq(a2, "deperfselftest") != 0:
                autoflag = 36
            # `deusabilityselftest` => the three DE-usability fixes:
            #   (1) no keystroke loss under a slow-frame backlog,
            #   (2) the panel context menu box fits its widest label,
            #   (3) pointer-move/occluded-stack compositing is window-count
            #       bounded (no full present on hover, occlusion skip works).
            if cstr_eq(a2, "deusabilityselftest") != 0:
                autoflag = 37
            # `deappsselftest` => the two new in-compositor desktop apps:
            #   the icon-grid file manager (enumerate + classify + navigate)
            #   and the Kate-like text editor (keystroke edits + file
            #   load/save round-trip), all via the real DE code paths.
            if cstr_eq(a2, "deappsselftest") != 0:
                autoflag = 38
            # `dewm` => MATE/Marco window management: title-bar maximize +
            # exact restore, left-edge snap (left half) + exact un-snap,
            # minimize-to-panel (window-list entry survives) + focused
            # restore, and per-workspace render isolation with the Ctrl-Alt-
            # arrow switch. Pure model state, no real framebuffer.
            if cstr_eq(a2, "dewm") != 0:
                autoflag = 39
            # `deswitch` => the Alt-Tab MRU window switcher (forward/Shift-Tab
            # cycle, release raises+fronts, off-workspace windows excluded) and
            # the desktop right-click context menu (width fits the widest
            # label, Open Terminal spawns an APP_TERM window). Pure model
            # state, no real framebuffer.
            if cstr_eq(a2, "deswitch") != 0:
                autoflag = 40
            # `deresize` => MATE/Marco edge-corner resize-drag (right border
            # +40 widens by exactly 40, bottom-left corner changes both
            # dimensions and x, inward drag clamps at the minimum size) and the
            # Show-Desktop / minimize-all toggle (first invoke hides all visible
            # current-workspace windows, second restores exactly that set +
            # focus). Pure model state, no real framebuffer.
            if cstr_eq(a2, "deresize") != 0:
                autoflag = 41
            # `dequartile` => MATE/Marco corner-quadrant tiling: a corner-
            # reaching title drag tiles the window to the top-left / top-right /
            # bottom-left / bottom-right QUARTER of the panel-aware work area,
            # the four quadrants tile the work area with no gap/overlap, the
            # keyboard tile_focused path snaps the focused window to a quadrant,
            # and un-snap restores the exact float rect. Pure model state.
            if cstr_eq(a2, "dequartile") != 0:
                autoflag = 42
            # `decache` => the per-window backbuffer cache (DEPERF #409): a
            # pure window MOVE reuses every window's cache (0 re-renders), a
            # content update re-renders ONLY that window, and the composited
            # pixels are identical to a full procedural recomposite. Pure
            # model state, no real framebuffer.
            if cstr_eq(a2, "decache") != 0:
                autoflag = 43
            # `derect` => the /dev/fbctl binary RECT dirty-rectangle present
            # path: a partial present routes through the kernel RECT handler
            # (proved by the kernel ACKing the 52-byte write) instead of the
            # per-row /dev/fb seek+write loop. Needs a real /dev/fbctl.
            if cstr_eq(a2, "derect") != 0:
                autoflag = 44
            # `decursor` => the terminal cursor-COLUMN tracking fix: term_feed
            # honours the cursor-positioning CSI escapes hamsh emits so the
            # caret follows the real input column (not stuck at column 0).
            if cstr_eq(a2, "decursor") != 0:
                autoflag = 45
            # `markupclient` => the live compositor composites an external
            # hamui (lib/hamui.ad) client's "ui" markup layer into its on-
            # screen window body, so programs built on the toolkit appear as
            # real windows (not just via the offline `present` one-shot).
            if cstr_eq(a2, "markupclient") != 0:
                autoflag = 46
            # `appspine` => Increment-1 separate-process app spine self-test:
            # spawn /bin/hamecho, prove window-only spawn damage, on-screen
            # markup, focus-gated routed-key delivery into the child, and no
            # leak of that key to the /dev/cons shell stream.
            if cstr_eq(a2, "appspine") != 0:
                autoflag = 47
            # `termspine` => Increment-2: the TERMINAL as a separate
            # compositor-spawned process. spawn /bin/hamterm, prove window-
            # only spawn damage + on-screen markup, route a focus-gated
            # command into it, assert it ran real /bin/hamsh + rendered the
            # output live, and that the keys did NOT leak to /dev/cons.
            if cstr_eq(a2, "termspine") != 0:
                autoflag = 48
            # `menuterm` => Increment-3a: the Applications-menu "Terminal"
            # entry is wired to the separate-process path. Drive
            # menu_launch(0, ...) and assert it spawns /bin/hamterm (wid +
            # stdout pipe + markup), NOT the dormant in-daemon APP_TERM grid.
            if cstr_eq(a2, "menuterm") != 0:
                autoflag = 49
            # `mousetest` => live pointer-injection self-test: pump
            # /dev/mouse and report when injected PS/2 (relative) and
            # usb-tablet (absolute) motion actually moves CUR_X/CUR_Y.
            if cstr_eq(a2, "mousetest") != 0:
                autoflag = 50
            # `evloop` => event-driven compositor scheduling self-test:
            # sys_waitfds park (jiffy-verified), gen-gated markup body
            # re-rasterize (idle frames do ZERO body reads / presents),
            # bounded gen-triggered present, EOF-pipe close, cursor blit
            # fast path.
            if cstr_eq(a2, "evloop") != 0:
                autoflag = 51
            # `volrt` => volume round-trip self-test: the panel volume
            # applet path writes to /dev/audioctl and an independent
            # re-read of /dev/audio confirms the kernel mixer changed.
            if cstr_eq(a2, "volrt") != 0:
                autoflag = 52
        # Marker-file selftest hook: when the plain `daemon` autostart
        # (no argv[2]) finds /etc/hamui-mkc-test, route into autoflag 46
        # (the markup-client keystone selftest). This keeps the PROVEN
        # 2-token `hamUId daemon` autostart exec line — the one the
        # supervisor reliably brings up to "DAEMON up screen=WxH" on a
        # real EFI GOP framebuffer — instead of a 3-token override the
        # autostart path doesn't exercise. build_initramfs.py plants the
        # marker under ENABLE_MKC_SELFTEST=1; the selftest runs once and
        # exits 0, so restart:on-failure does not relaunch it.
        if autoflag == 0:
            # Increment-1 spine self-test marker takes precedence: the proven
            # 2-token `hamUId daemon` autostart routes into autoflag 47 when
            # build_initramfs.py planted /etc/hamui-spine-test (ENABLE_SPINE_
            # SELFTEST=1). Runs once + exits 0 (restart:on-failure won't relaunch).
            spine_fd: int32 = sys_open(cast[Ptr[char]]("/etc/hamui-spine-test"))
            if spine_fd >= 0:
                sys_close(spine_fd)
                write_str(1, "[spine] marker found -> autoflag 47\n")
                autoflag = 47
        if autoflag == 0:
            # Increment-2 terminal app-spine marker (ENABLE_TERM_SELFTEST=1):
            # the proven 2-token `hamUId daemon` autostart routes into the
            # autoflag-48 terminal self-test when build_initramfs.py planted
            # /etc/hamui-term-test. Runs once + exits 0.
            term_fd: int32 = sys_open(cast[Ptr[char]]("/etc/hamui-term-test"))
            if term_fd >= 0:
                sys_close(term_fd)
                write_str(1, "[term] marker found -> autoflag 48\n")
                autoflag = 48
        if autoflag == 0:
            # Increment-3a menu-Terminal marker (ENABLE_MENUTERM_SELFTEST=1):
            # the proven 2-token `hamUId daemon` autostart routes into the
            # autoflag-49 menu-Terminal self-test when build_initramfs.py
            # planted /etc/hamui-menuterm-test. Runs once + exits 0.
            mt_fd: int32 = sys_open(cast[Ptr[char]]("/etc/hamui-menuterm-test"))
            if mt_fd >= 0:
                sys_close(mt_fd)
                write_str(1, "[menuterm] marker found -> autoflag 49\n")
                autoflag = 49
        if autoflag == 0:
            # Live mouse-motion marker (ENABLE_MOUSETEST_SELFTEST=1): the
            # proven 2-token `hamUId daemon` autostart routes into the
            # autoflag-50 live pointer-injection self-test when
            # build_initramfs.py planted /etc/hamui-mouse-test. Runs once +
            # exits 0.
            mtest_fd: int32 = sys_open(cast[Ptr[char]]("/etc/hamui-mouse-test"))
            if mtest_fd >= 0:
                sys_close(mtest_fd)
                write_str(1, "[mousetest] marker found -> autoflag 50\n")
                autoflag = 50
        if autoflag == 0:
            # Event-loop marker (ENABLE_EVLOOP_SELFTEST=1): the proven
            # 2-token `hamUId daemon` autostart routes into the autoflag-51
            # event-driven-scheduling self-test when build_initramfs.py
            # planted /etc/hamui-evloop-test. Runs once + exits 0.
            evl_fd: int32 = sys_open(cast[Ptr[char]]("/etc/hamui-evloop-test"))
            if evl_fd >= 0:
                sys_close(evl_fd)
                write_str(1, "[evloop] marker found -> autoflag 51\n")
                autoflag = 51
        if autoflag == 0:
            # Volume round-trip marker (ENABLE_VOLRT_SELFTEST=1): the
            # proven 2-token `hamUId daemon` autostart routes into the
            # autoflag-52 mixer round-trip self-test when
            # build_initramfs.py planted /etc/hamui-volrt-test. Runs once
            # + exits 0.
            vrt_fd: int32 = sys_open(cast[Ptr[char]]("/etc/hamui-volrt-test"))
            if vrt_fd >= 0:
                sys_close(vrt_fd)
                write_str(1, "[volrt] marker found -> autoflag 52\n")
                autoflag = 52
        if autoflag == 0:
            mkc_fd: int32 = sys_open(cast[Ptr[char]]("/etc/hamui-mkc-test"))
            if mkc_fd >= 0:
                sys_close(mkc_fd)
                write_str(1, "[markup-client] marker found -> autoflag 46\n")
                autoflag = 46
            else:
                write_str(1, "[markup-client] marker /etc/hamui-mkc-test absent\n")
        return cmd_daemon_auto(autoflag)
    usage(2)
    return 1

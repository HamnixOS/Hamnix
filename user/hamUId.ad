def font_init():
    if font_ready != 0:
        return
    g: uint64 = 0
    while g < 95:
        hexs: Ptr[uint8] = _font_hex(g)
        r: uint64 = 0
        while r < 16:
            hi: int32 = hex_nibble(hexs[r * 2])
            lo: int32 = hex_nibble(hexs[r * 2 + 1])
            font_glyphs[g * 16 + r] = cast[uint8]((hi * 16) + lo)
            r = r + 1
        g = g + 1
    font_ready = 1


# ====================================================================
# Compositor target helpers
# ====================================================================

def target_clear():
    # Fill the window-sized target with the opaque background colour.
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            target[o] = BG_R
            target[o + 1] = BG_G
            target[o + 2] = BG_B
            target[o + 3] = 255
            x = x + 1
        y = y + 1


def layerbuf_clear():
    # Zero (transparent) the per-layer RGBA scratch. Premultiplied: all
    # channels 0 = fully transparent.
    i: uint64 = 0
    n: uint64 = WIN_W * WIN_H * 4
    while i < n:
        layerbuf[i] = 0
        i = i + 1


# Set a layer-buffer pixel (premultiplied RGBA) with src-over blend onto
# whatever is already in the layer buffer. (r,g,b,a) are straight 0..255
# component values for the incoming colour; we premultiply on store.
def layer_put(x: int64, y: int64, r: uint8, g: uint8, b: uint8, a: uint8):
    if x < 0 or y < 0:
        return
    xu: uint64 = cast[uint64](x)
    yu: uint64 = cast[uint64](y)
    if xu >= WIN_W or yu >= WIN_H:
        return
    if a == 0:
        return
    o: uint64 = (yu * WIN_W + xu) * 4
    av: uint64 = cast[uint64](a)
    inv: uint64 = 255 - av
    # Premultiply the incoming colour by its own alpha, then src-over
    # against the existing premultiplied destination.
    sr: uint64 = (cast[uint64](r) * av) / 255
    sg: uint64 = (cast[uint64](g) * av) / 255
    sb: uint64 = (cast[uint64](b) * av) / 255
    dr: uint64 = cast[uint64](layerbuf[o])
    dg: uint64 = cast[uint64](layerbuf[o + 1])
    db: uint64 = cast[uint64](layerbuf[o + 2])
    da: uint64 = cast[uint64](layerbuf[o + 3])
    layerbuf[o] = cast[uint8](sr + (dr * inv) / 255)
    layerbuf[o + 1] = cast[uint8](sg + (dg * inv) / 255)
    layerbuf[o + 2] = cast[uint8](sb + (db * inv) / 255)
    layerbuf[o + 3] = cast[uint8](av + (da * inv) / 255)


# ====================================================================
# hamML colour parsing
# ====================================================================
# A parsed colour is returned via four out-bytes + a "present" flag.

def parse_color(buf: Ptr[uint8], start: uint64, end: uint64,
                out_r: Ptr[uint8], out_g: Ptr[uint8],
                out_b: Ptr[uint8], out_a: Ptr[uint8]) -> int32:
    # Supports "#rrggbb", "#rgb" and "rgba(r,g,b,a)" (a = 0..255).
    # Returns 1 on success.
    i: uint64 = start
    while i < end and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    if i >= end:
        return 0
    if buf[i] == 35:                                 # '#'
        i = i + 1
        # count hex digits available
        h0: uint64 = i
        while i < end and hex_nibble(buf[i]) >= 0:
            i = i + 1
        ndig: uint64 = i - h0
        if ndig >= 6:
            out_r[0] = cast[uint8]((hex_nibble(buf[h0]) * 16) + hex_nibble(buf[h0 + 1]))
            out_g[0] = cast[uint8]((hex_nibble(buf[h0 + 2]) * 16) + hex_nibble(buf[h0 + 3]))
            out_b[0] = cast[uint8]((hex_nibble(buf[h0 + 4]) * 16) + hex_nibble(buf[h0 + 5]))
            out_a[0] = 255
            return 1
        if ndig >= 3:
            # #rgb -> #rrggbb
            rr: int32 = hex_nibble(buf[h0])
            gg: int32 = hex_nibble(buf[h0 + 1])
            bb: int32 = hex_nibble(buf[h0 + 2])
            out_r[0] = cast[uint8](rr * 16 + rr)
            out_g[0] = cast[uint8](gg * 16 + gg)
            out_b[0] = cast[uint8](bb * 16 + bb)
            out_a[0] = 255
            return 1
        return 0
    # rgba( / rgb(
    if buf[i] == 114:                                # 'r'
        # skip to '('
        while i < end and buf[i] != 40:
            i = i + 1
        if i >= end:
            return 0
        i = i + 1
        comp: Array[4, int64]
        comp[0] = 0
        comp[1] = 0
        comp[2] = 0
        comp[3] = 255
        ci: uint64 = 0
        while i < end and buf[i] != 41 and ci < 4:
            while i < end and (buf[i] == 32 or buf[i] == 9):
                i = i + 1
            v: int64 = 0
            got: int32 = 0
            while i < end and buf[i] >= 48 and buf[i] <= 57:
                v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
                got = 1
                i = i + 1
            if got != 0:
                comp[ci] = v
                ci = ci + 1
            while i < end and buf[i] != 44 and buf[i] != 41:
                i = i + 1
            if i < end and buf[i] == 44:
                i = i + 1
        out_r[0] = cast[uint8](comp[0])
        out_g[0] = cast[uint8](comp[1])
        out_b[0] = cast[uint8](comp[2])
        out_a[0] = cast[uint8](comp[3])
        return 1
    return 0


# ====================================================================
# hamML attribute extraction
# ====================================================================
# Given a tag's attribute span [astart, aend) inside markup_buf, find an
# attribute named `name` and return its raw VALUE span via out_vs/out_ve.
# Returns 1 if found. Values may be unquoted (x=10) or quoted (fill="#f00").

def find_attr(astart: uint64, aend: uint64, name: Ptr[uint8],
              out_vs: Ptr[uint64], out_ve: Ptr[uint64]) -> int32:
    nlen: uint64 = strlen_u8(name)
    i: uint64 = astart
    while i < aend:
        # skip whitespace
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9 or
                            markup_buf[i] == 10 or markup_buf[i] == 13):
            i = i + 1
        # read an attribute name
        ns: uint64 = i
        while i < aend and markup_buf[i] != 61 and markup_buf[i] != 32 and \
              markup_buf[i] != 9 and markup_buf[i] != 10 and \
              markup_buf[i] != 13 and markup_buf[i] != 47 and \
              markup_buf[i] != 62:
            i = i + 1
        ne: uint64 = i
        # skip whitespace before '='
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
            i = i + 1
        if i < aend and markup_buf[i] == 61:           # '='
            i = i + 1
            while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
                i = i + 1
            vs: uint64 = 0
            ve: uint64 = 0
            if i < aend and (markup_buf[i] == 34 or markup_buf[i] == 39):
                q: uint8 = markup_buf[i]
                i = i + 1
                vs = i
                while i < aend and markup_buf[i] != q:
                    i = i + 1
                ve = i
                if i < aend:
                    i = i + 1
            else:
                vs = i
                while i < aend and markup_buf[i] != 32 and markup_buf[i] != 9 and \
                      markup_buf[i] != 10 and markup_buf[i] != 13 and \
                      markup_buf[i] != 47 and markup_buf[i] != 62:
                    i = i + 1
                ve = i
            # name match?
            if (ne - ns) == nlen:
                k: uint64 = 0
                matched: int32 = 1
                while k < nlen:
                    if markup_buf[ns + k] != name[k]:
                        matched = 0
                        k = nlen
                    else:
                        k = k + 1
                if matched != 0:
                    out_vs[0] = vs
                    out_ve[0] = ve
                    return 1
        else:
            # attribute with no value (rare); skip on
            i = ne + 1
    return 0


def attr_i64(astart: uint64, aend: uint64, name: Ptr[uint8],
             dflt: int64) -> int64:
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, name, &vs[0], &ve[0]) == 0:
        return dflt
    return parse_i64_span(&markup_buf[0], vs[0], ve[0])


# ====================================================================
# Rasterising primitives into the current layer buffer
# ====================================================================

def raster_rect(x: int64, y: int64, w: int64, h: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    yy: int64 = y
    ymax: int64 = y + h
    while yy < ymax:
        xx: int64 = x
        xmax: int64 = x + w
        while xx < xmax:
            layer_put(xx, yy, r, g, b, a)
            xx = xx + 1
        yy = yy + 1


def iabs(v: int64) -> int64:
    if v < 0:
        return 0 - v
    return v


def raster_line(x0: int64, y0: int64, x1: int64, y1: int64, width: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Bresenham. `width` thickens by stamping a (width x width) block.
    dx: int64 = iabs(x1 - x0)
    dy: int64 = 0 - iabs(y1 - y0)
    sx: int64 = -1
    if x0 < x1:
        sx = 1
    sy: int64 = -1
    if y0 < y1:
        sy = 1
    err: int64 = dx + dy
    cx: int64 = x0
    cy: int64 = y0
    half: int64 = width / 2
    while True:
        # stamp a width x width block centred on (cx,cy)
        oy: int64 = 0 - half
        while oy <= half:
            ox: int64 = 0 - half
            while ox <= half:
                layer_put(cx + ox, cy + oy, r, g, b, a)
                ox = ox + 1
            oy = oy + 1
        if cx == x1 and cy == y1:
            break
        e2: int64 = err * 2
        if e2 >= dy:
            err = err + dy
            cx = cx + sx
        if e2 <= dx:
            err = err + dx
            cy = cy + sy


def raster_glyph(ch: uint8, x: int64, y: int64,
                 r: uint8, g: uint8, b: uint8, a: uint8):
    # 8x16 mono glyph; (x,y) is the TOP-LEFT of the cell.
    if ch < 32 or ch > 126:
        return
    gi: uint64 = cast[uint64](ch) - 32
    row: uint64 = 0
    while row < 16:
        bits: uint8 = font_glyphs[gi * 16 + row]
        col: uint64 = 0
        while col < 8:
            mask: uint8 = cast[uint8](128 >> col)
            if (bits & mask) != 0:
                layer_put(x + cast[int64](col), y + cast[int64](row), r, g, b, a)
            col = col + 1
        row = row + 1


def raster_text(text_s: uint64, text_e: uint64, x: int64, y: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Render markup_buf[text_s..text_e) as 8x16 mono. The hamML `y` is
    # the text BASELINE-ish anchor; we treat it as the cell top for the
    # mono font (good enough for v1 / AI-debug). Advance 8 px per glyph.
    cx: int64 = x
    i: uint64 = text_s
    while i < text_e:
        c: uint8 = markup_buf[i]
        if c == 10 or c == 13:
            i = i + 1
        else:
            raster_glyph(c, cx, y, r, g, b, a)
            cx = cx + 8
            i = i + 1


# Blit a referenced fb LAYER's buffer into the current layer at (dx,dy).
# `src_slot` is the layer-table index of the referenced layer.
def raster_image_fb(src_slot: uint64, dx: int64, dy: int64,
                    dw: int64, dh: int64):
    # Read the source layer's fb body into fb_read_buf.
    nread: int64 = read_layer_fb(src_slot)
    if nread <= 0:
        return
    sw: int64 = LT_W[src_slot]
    sh: int64 = LT_H[src_slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    # default destination size = source size
    tw: int64 = dw
    th: int64 = dh
    if tw <= 0:
        tw = sw
    if th <= 0:
        th = sh
    yy: int64 = 0
    while yy < th:
        xx: int64 = 0
        while xx < tw:
            # nearest-neighbour sample
            srx: int64 = (xx * sw) / tw
            sry: int64 = (yy * sh) / th
            if srx < sw and sry < sh:
                so: uint64 = cast[uint64](sry * sw + srx) * 4
                if so + 3 < cast[uint64](nread):
                    pr: uint8 = fb_read_buf[so]
                    pg: uint8 = fb_read_buf[so + 1]
                    pb: uint8 = fb_read_buf[so + 2]
                    pa: uint8 = fb_read_buf[so + 3]
                    # fb is premultiplied; un-premultiply is unnecessary
                    # because layer_put premultiplies by `a` again. For a
                    # faithful blit we treat stored RGB as straight and
                    # pass alpha through.
                    layer_put(dx + xx, dy + yy, pr, pg, pb, pa)
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Path building + cdev reads
# ====================================================================

def build_path(wid: int32, layer: Ptr[uint8], leaf: Ptr[uint8]):
    # Compose "/dev/wsys/<wid>/draw[/<layer>][/<leaf>]" into path_buf.
    # layer NULL/empty -> ".../draw"; leaf NULL/empty -> no trailing leaf.
    p: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while p[j] != 0:
        path_buf[i] = p[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    d: Ptr[uint8] = "/draw"
    j = 0
    while d[j] != 0:
        path_buf[i] = d[j]
        i = i + 1
        j = j + 1
    if layer != cast[Ptr[uint8]](0) and layer[0] != 0:
        path_buf[i] = 47                              # '/'
        i = i + 1
        j = 0
        while layer[j] != 0:
            path_buf[i] = layer[j]
            i = i + 1
            j = j + 1
        if leaf != cast[Ptr[uint8]](0) and leaf[0] != 0:
            path_buf[i] = 47
            i = i + 1
            j = 0
            while leaf[j] != 0:
                path_buf[i] = leaf[j]
                i = i + 1
                j = j + 1
    path_buf[i] = 0


def read_whole(fd: int32, buf: Ptr[uint8], cap: uint64) -> int64:
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    return cast[int64](total)


def layer_name_ptr(slot: uint64) -> Ptr[uint8]:
    return &LT_NAME[slot * 32]


def read_layer_markup(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "markup")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &markup_buf[0], 8192)
    sys_close(fd)
    return n


# read_layer_fb reads the layer at table-index `slot` into fb_read_buf.
# Returns bytes read.
read_fb_wid: int32 = 1
def read_layer_fb(slot: uint64) -> int64:
    build_path(read_fb_wid, layer_name_ptr(slot), "fb")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &fb_read_buf[0], 262144)
    sys_close(fd)
    return n


def read_layer_opacity(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "opacity")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return 255
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 255
    return parse_i64_span(&num_buf[0], 0, cast[uint64](n))


# ====================================================================
# Parse the draw listing into the layer table
# ====================================================================
# Each listing line:
#   "<name>  z=<z>  kind=<markup|fb>  <x>x<y>..<x2>x<y2>  opacity=<o>"

def parse_listing(wid: int32) -> int32:
    build_path(wid, cast[Ptr[uint8]](0), cast[Ptr[uint8]](0))
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &list_buf[0], 4096)
    sys_close(fd)
    if n < 0:
        return -1
    total: uint64 = cast[uint64](n)
    LT_COUNT = 0
    i: uint64 = 0
    while i < total and LT_COUNT < MAX_LAYERS:
        ls: uint64 = i
        while i < total and list_buf[i] != 10:
            i = i + 1
        le: uint64 = i
        if i < total:
            i = i + 1
        if le > ls:
            parse_listing_line(ls, le)
    return 0


def parse_listing_line(ls: uint64, le: uint64):
    slot: uint64 = LT_COUNT
    # name = run up to first space
    p: uint64 = ls
    while p < le and list_buf[p] != 32:
        p = p + 1
    nlen: uint64 = p - ls
    if nlen >= 32:
        nlen = 31
    k: uint64 = 0
    while k < nlen:
        LT_NAME[slot * 32 + k] = list_buf[ls + k]
        k = k + 1
    LT_NAME[slot * 32 + nlen] = 0
    # find "kind=" -> markup/fb
    LT_KIND[slot] = 0
    kk: uint64 = find_substr(ls, le, "kind=")
    if kk < le:
        c: uint8 = list_buf[kk + 5]
        if c == 102:                                  # 'f' (fb)
            LT_KIND[slot] = 1
    # geometry "<x>x<y>..<x2>x<y2>": parse the two corner pairs.
    gg: uint64 = find_geom(ls, le)
    x0: int64 = 0
    y0: int64 = 0
    x1: int64 = 0
    y1: int64 = 0
    if gg < le:
        q: uint64 = gg
        x0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:          # 'x'
            q = q + 1
        if q < le:
            q = q + 1
        y0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 46:           # '.'
            q = q + 1
        while q < le and list_buf[q] == 46:
            q = q + 1
        x1 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:
            q = q + 1
        if q < le:
            q = q + 1
        y1 = parse_i64_span(&list_buf[0], q, le)
    LT_X[slot] = x0
    LT_Y[slot] = y0
    LT_W[slot] = x1 - x0
    LT_H[slot] = y1 - y0
    # opacity
    oo: uint64 = find_substr(ls, le, "opacity=")
    if oo < le:
        LT_OPAC[slot] = parse_i64_span(&list_buf[0], oo + 8, le)
    else:
        LT_OPAC[slot] = 255
    LT_COUNT = LT_COUNT + 1


def find_substr(ls: uint64, le: uint64, needle: Ptr[uint8]) -> uint64:
    nlen: uint64 = strlen_u8(needle)
    i: uint64 = ls
    while i + nlen <= le:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            if list_buf[i + k] != needle[k]:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return i
        i = i + 1
    return le


# Find the geometry field: the first run of digits that is FOLLOWED by an
# 'x' then digits then ".." . We locate it after the "kind=..." token by
# scanning for the ".." separator and backing up to its number start.
def find_geom(ls: uint64, le: uint64) -> uint64:
    # Find the ".." then walk backward to the start of <x>.
    dd: uint64 = le
    i: uint64 = ls
    while i + 1 < le:
        if list_buf[i] == 46 and list_buf[i + 1] == 46:
            dd = i
            i = le
        else:
            i = i + 1
    if dd >= le:
        return le
    # back up over "<x>x<y>" — find the start: skip back over digits,
    # one 'x', digits, to a leading space.
    j: uint64 = dd
    # j currently at first '.'; the char before is the last digit of y0.
    while j > ls and list_buf[j - 1] != 32:
        j = j - 1
    return j


# ====================================================================
# Layer rasterisation: parse hamML and draw into layerbuf
# ====================================================================

def slot_for_fbref(name_s: uint64, name_e: uint64) -> int64:
    # Match markup_buf[name_s..name_e) against a layer name in the table.
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        ll: uint64 = strlen_u8(lp)
        if ll == (name_e - name_s):
            k: uint64 = 0
            ok: int32 = 1
            while k < ll:
                if lp[k] != markup_buf[name_s + k]:
                    ok = 0
                    k = ll
                else:
                    k = k + 1
            if ok != 0:
                return cast[int64](si)
        si = si + 1
    return -1


def rasterise_markup(wid: int32, slot: uint64):
    n: int64 = read_layer_markup(wid, slot)
    if n <= 0:
        return
    total: uint64 = cast[uint64](n)
    # group translate accumulator (translate-only v1)
    gtx: int64 = 0
    gty: int64 = 0
    i: uint64 = 0
    while i < total:
        if markup_buf[i] != 60:                        # '<'
            i = i + 1
        else:
            ts: uint64 = i + 1
            # closing tag?
            if ts < total and markup_buf[ts] == 47:    # '</'
                # check for </group>
                if tag_is(ts + 1, total, "group"):
                    gtx = 0
                    gty = 0
                # skip to '>'
                while i < total and markup_buf[i] != 62:
                    i = i + 1
                i = i + 1
            else:
                # read tag name
                ne: uint64 = ts
                while ne < total and markup_buf[ne] != 32 and \
                      markup_buf[ne] != 9 and markup_buf[ne] != 10 and \
                      markup_buf[ne] != 13 and markup_buf[ne] != 62 and \
                      markup_buf[ne] != 47:
                    ne = ne + 1
                astart: uint64 = ne
                # find end of tag '>'
                te: uint64 = ne
                while te < total and markup_buf[te] != 62:
                    te = te + 1
                aend: uint64 = te
                # self-closing? trailing '/'
                # (we don't special-case; attrs parse the same)
                handle_tag(wid, ts, ne, astart, aend, gtx, gty,
                           &gtx, &gty, total)
                i = te + 1
    return


def tag_is(s: uint64, total: uint64, name: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(name)
    k: uint64 = 0
    while k < nlen:
        if s + k >= total:
            return 0
        if markup_buf[s + k] != name[k]:
            return 0
        k = k + 1
    return 1


def handle_tag(wid: int32, ns: uint64, ne: uint64,
               astart: uint64, aend: uint64,
               gtx: int64, gty: int64,
               gtx_out: Ptr[int64], gty_out: Ptr[int64],
               total: uint64):
    # default colours
    r: Array[1, uint8]
    g: Array[1, uint8]
    b: Array[1, uint8]
    a: Array[1, uint8]
    if tag_is(ns, total, "rect") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "line") != 0 and (ne - ns) == 4:
        x1: int64 = attr_i64(astart, aend, "x1", 0) + gtx
        y1: int64 = attr_i64(astart, aend, "y1", 0) + gty
        x2: int64 = attr_i64(astart, aend, "x2", 0) + gtx
        y2: int64 = attr_i64(astart, aend, "y2", 0) + gty
        wd: int64 = attr_i64(astart, aend, "width", 1)
        if wd < 1:
            wd = 1
        r[0] = 200
        g[0] = 200
        b[0] = 200
        a[0] = 255
        get_stroke(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_line(x1, y1, x2, y2, wd, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "text") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        # text content is between aend+1 ('>') and the next '<'
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        raster_text(cs, ce, x, y, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "button") != 0 and (ne - ns) == 6:
        # draw a filled box + label text
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 64)
        h: int64 = attr_i64(astart, aend, "h", 20)
        r[0] = 80
        g[0] = 80
        b[0] = 80
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        raster_text(cs, ce, x + 4, y + 2, 255, 255, 255, 255)
        return
    if tag_is(ns, total, "input") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 100)
        h: int64 = attr_i64(astart, aend, "h", 18)
        raster_rect(x, y, w, h, 40, 40, 40, 255)
        # placeholder text
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "placeholder", &vs[0], &ve[0]) != 0:
            raster_text(vs[0], ve[0], x + 3, y + 1, 160, 160, 160, 255)
        return
    if tag_is(ns, total, "image") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "src", &vs[0], &ve[0]) != 0:
            # only "fb:<layer>" supported in v1
            s0: uint64 = vs[0]
            if (ve[0] - s0) > 3 and markup_buf[s0] == 102 and \
               markup_buf[s0 + 1] == 98 and markup_buf[s0 + 2] == 58:
                src_slot: int64 = slot_for_fbref(s0 + 3, ve[0])
                if src_slot >= 0:
                    raster_image_fb(cast[uint64](src_slot), x, y, w, h)
        return
    if tag_is(ns, total, "group") != 0 and (ne - ns) == 5:
        # transform="translate(dx,dy)"
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "transform", &vs[0], &ve[0]) != 0:
            tdx: Array[1, int64]
            tdy: Array[1, int64]
            tdx[0] = 0
            tdy[0] = 0
            parse_translate(vs[0], ve[0], &tdx[0], &tdy[0])
            gtx_out[0] = gtx + tdx[0]
            gty_out[0] = gty + tdy[0]
        return
    # <window ...> and unknown tags: ignore (metadata only).
    return


def get_fill(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
             b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "fill", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def get_stroke(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
               b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "stroke", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def apply_opacity(astart: uint64, aend: uint64, a: Ptr[uint8]):
    # per-element opacity 0..1 (float-shape) -> scale alpha. We accept
    # an integer 0..255 too (if value > 1). v1 keeps it simple: a value
    # "0".."1" with a dot is read as tenths/hundredths via the first two
    # fractional digits; otherwise treated as 0..255.
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "opacity", &vs[0], &ve[0]) == 0:
        return
    s: uint64 = vs[0]
    e: uint64 = ve[0]
    # whole part
    whole: int64 = parse_i64_span(&markup_buf[0], s, e)
    # fractional?
    di: uint64 = s
    while di < e and markup_buf[di] != 46:
        di = di + 1
    if di < e:
        # has a dot -> treat as 0..1 float; scale to 0..255
        # read up to two fractional digits
        f1: int64 = 0
        f2: int64 = 0
        if di + 1 < e and markup_buf[di + 1] >= 48 and markup_buf[di + 1] <= 57:
            f1 = cast[int64](cast[int32](markup_buf[di + 1]) - 48)
        if di + 2 < e and markup_buf[di + 2] >= 48 and markup_buf[di + 2] <= 57:
            f2 = cast[int64](cast[int32](markup_buf[di + 2]) - 48)
        frac: int64 = whole * 100 + f1 * 10 + f2     # 0..100 (clamp)
        if frac > 100:
            frac = 100
        a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](frac)) / 100)
    else:
        if whole >= 0 and whole <= 255:
            a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](whole)) / 255)


def parse_translate(s: uint64, e: uint64, dx: Ptr[int64], dy: Ptr[int64]):
    # "translate(DX,DY)"
    i: uint64 = s
    while i < e and markup_buf[i] != 40:               # '('
        i = i + 1
    if i >= e:
        return
    i = i + 1
    dx[0] = parse_i64_span(&markup_buf[0], i, e)
    while i < e and markup_buf[i] != 44:               # ','
        i = i + 1
    if i < e:
        i = i + 1
    dy[0] = parse_i64_span(&markup_buf[0], i, e)


# ====================================================================
# Composite the current layer buffer into the target with per-layer
# opacity. Both buffers are premultiplied RGBA.
# ====================================================================

def composite_layer(opac: int64):
    op: uint64 = cast[uint64](opac)
    if op > 255:
        op = 255
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            sa: uint64 = (cast[uint64](layerbuf[o + 3]) * op) / 255
            if sa != 0:
                sr: uint64 = (cast[uint64](layerbuf[o]) * op) / 255
                sg: uint64 = (cast[uint64](layerbuf[o + 1]) * op) / 255
                sb: uint64 = (cast[uint64](layerbuf[o + 2]) * op) / 255
                inv: uint64 = 255 - sa
                dr: uint64 = cast[uint64](target[o])
                dg: uint64 = cast[uint64](target[o + 1])
                db: uint64 = cast[uint64](target[o + 2])
                target[o] = cast[uint8](sr + (dr * inv) / 255)
                target[o + 1] = cast[uint8](sg + (dg * inv) / 255)
                target[o + 2] = cast[uint8](sb + (db * inv) / 255)
                target[o + 3] = 255
            x = x + 1
        y = y + 1


# ====================================================================
# Output: AI-readable text dump
# ====================================================================

def emit_hex_byte(v: uint8, out: Ptr[uint8]):
    hi: uint8 = cast[uint8]((cast[uint64](v) >> 4) & 15)
    lo: uint8 = cast[uint8](cast[uint64](v) & 15)
    if hi < 10:
        out[0] = 48 + hi
    else:
        out[0] = 97 + (hi - 10)
    if lo < 10:
        out[1] = 48 + lo
    else:
        out[1] = 97 + (lo - 10)


def emit_pix(x: uint64, y: uint64):
    # "PIX <x> <y> #rrggbb\n"
    o: uint64 = (y * WIN_W + x) * 4
    line: Array[40, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PIX "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(x, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(y, &line[p])
    line[p] = 32
    p = p + 1
    line[p] = 35                                       # '#'
    p = p + 1
    emit_hex_byte(target[o], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 1], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 2], &line[p])
    p = p + 2
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def is_bg(x: uint64, y: uint64) -> int32:
    o: uint64 = (y * WIN_W + x) * 4
    if target[o] == BG_R and target[o + 1] == BG_G and target[o + 2] == BG_B:
        return 1
    return 0


def count_nonbg_region(rx: uint64, ry: uint64, rw: uint64, rh: uint64) -> uint64:
    cnt: uint64 = 0
    y: uint64 = ry
    ymax: uint64 = ry + rh
    while y < ymax and y < WIN_H:
        x: uint64 = rx
        xmax: uint64 = rx + rw
        while x < xmax and x < WIN_W:
            if is_bg(x, y) == 0:
                cnt = cnt + 1
            x = x + 1
        y = y + 1
    return cnt


def emit_region(name: Ptr[uint8], rx: uint64, ry: uint64,
                rw: uint64, rh: uint64):
    # "REGION <name> <x> <y> <w> <h> nonbg=<count>\n" — a deterministic
    # test hook: lets a CI grep assert "the text band has >0 non-bg
    # pixels" without depending on the coarse probe grid landing on a
    # glyph stroke.
    cnt: uint64 = count_nonbg_region(rx, ry, rw, rh)
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "REGION "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    k = 0
    while name[k] != 0:
        line[p] = name[k]
        p = p + 1
        k = k + 1
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rx, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(ry, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rw, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rh, &line[p])
    sfx: Ptr[uint8] = " nonbg="
    k = 0
    while sfx[k] != 0:
        line[p] = sfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cnt, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def emit_ascii_art():
    # Downscale to ART_W x ART_H by sampling. '#' = non-background.
    ART_W: uint64 = 80
    ART_H: uint64 = 30
    line: Array[96, uint8]
    ry: uint64 = 0
    while ry < ART_H:
        p: uint64 = 0
        pfx: Ptr[uint8] = "ART "
        k: uint64 = 0
        while pfx[k] != 0:
            line[p] = pfx[k]
            p = p + 1
            k = k + 1
        rx: uint64 = 0
        while rx < ART_W:
            sx: uint64 = (rx * WIN_W) / ART_W
            sy: uint64 = (ry * WIN_H) / ART_H
            if is_bg(sx, sy) != 0:
                line[p] = 32                           # ' '
            else:
                line[p] = 35                           # '#'
            p = p + 1
            rx = rx + 1
        line[p] = 10
        p = p + 1
        sys_write(1, &line[0], p)
        ry = ry + 1


def emit_probe_grid():
    # A regular grid of probe pixels so a CI grep can assert colours at
    # known coordinates.
    PY: uint64 = 0
    while PY < WIN_H:
        PX: uint64 = 0
        while PX < WIN_W:
            emit_pix(PX, PY)
            PX = PX + 40
        PY = PY + 40


# ====================================================================
# Optional: write the composited frame into a "_screen" fb layer so the
# bytes round-trip through the cdev. Best-effort.
# ====================================================================

def write_screen_layer(wid: int32):
    # Ensure a "_screen" fb layer exists (256x256 max), then write a
    # downscaled copy of the target into its fb. ctl create is via
    # /dev/wsys/<wid>/draw/ctl.
    build_path(wid, cast[Ptr[uint8]](0), "ctl")
    cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if cf >= 0:
        cmd: Ptr[uint8] = "mklayer _screen fb 256 256\n"
        sys_write(cf, cmd, strlen_u8(cmd))
        sys_close(cf)
    # write fb: downscale target -> 256x256 into fb_read_buf, then write.
    yy: uint64 = 0
    while yy < FB_DIM:
        xx: uint64 = 0
        while xx < FB_DIM:
            sx: uint64 = (xx * WIN_W) / FB_DIM
            sy: uint64 = (yy * WIN_H) / FB_DIM
            so: uint64 = (sy * WIN_W + sx) * 4
            dout: uint64 = (yy * FB_DIM + xx) * 4
            fb_read_buf[dout] = target[so]
            fb_read_buf[dout + 1] = target[so + 1]
            fb_read_buf[dout + 2] = target[so + 2]
            fb_read_buf[dout + 3] = target[so + 3]
            xx = xx + 1
        yy = yy + 1
    build_path(wid, "_screen", "fb")
    wf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if wf >= 0:
        sys_write(wf, &fb_read_buf[0], FB_DIM * FB_DIM * 4)
        sys_close(wf)


# ====================================================================
# render <wid>
# ====================================================================

def cmd_render(wid: int32) -> int32:
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        write_str(2, "hamUId: cannot read /dev/wsys/<wid>/draw (no such wid?)\n")
        return 1
    target_clear()
    # Composite layers in listing order (kernel emits z-ascending).
    si: uint64 = 0
    while si < LT_COUNT:
        # Skip the synthetic _screen layer if present (avoid feedback).
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                # fb layer: read its pixels straight into the layer buf
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    # --- emit the AI-readable dump ---
    hdr: Array[96, uint8]
    p: uint64 = 0
    h0: Ptr[uint8] = "DUMP wid="
    k: uint64 = 0
    while h0[k] != 0:
        hdr[p] = h0[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &hdr[p])
    h1: Ptr[uint8] = " win=640x480 layers="
    k = 0
    while h1[k] != 0:
        hdr[p] = h1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(LT_COUNT, &hdr[p])
    hdr[p] = 10
    p = p + 1
    sys_write(1, &hdr[0], p)
    emit_probe_grid()
    # Deterministic region summaries (test hooks that don't depend on the
    # coarse probe grid landing on a specific glyph stroke). The "text"
    # band is to the RIGHT of any rect a chrome layer typically draws, so
    # a non-zero count there proves GLYPHS rasterised, not a rect.
    emit_region("text", 192, 32, 160, 32)
    emit_ascii_art()
    write_str(1, "DUMP END\n")
    # round-trip into _screen fb (best-effort; ignore errors)
    write_screen_layer(wid)
    return 0


def composite_fb_layer(wid: int32, slot: uint64):
    # Read the fb body and blit (with the layer geometry offset) into
    # the layer buffer.
    n: int64 = read_layer_fb(slot)
    if n <= 0:
        return
    sw: int64 = LT_W[slot]
    sh: int64 = LT_H[slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    ox: int64 = LT_X[slot]
    oy: int64 = LT_Y[slot]
    yy: int64 = 0
    while yy < sh:
        xx: int64 = 0
        while xx < sw:
            so: uint64 = cast[uint64](yy * sw + xx) * 4
            if so + 3 < cast[uint64](n):
                layer_put(ox + xx, oy + yy, fb_read_buf[so],
                          fb_read_buf[so + 1], fb_read_buf[so + 2],
                          fb_read_buf[so + 3])
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Phase 4c — physical presentation to /dev/fb
# ====================================================================
#
# `hamUId present <wid>` composites the window exactly like `render`
# (reusing the 4b compositor that fills `target` with the 640x480
# window frame), reads /dev/fb's geometry, scales the window frame to
# fit the screen with letterboxing (preserve aspect, centre, black
# bars), and writes it to /dev/fb as RGBA8888.
#
# We present one SCREEN ROW at a time into screen_row, then write the
# whole row to /dev/fb at the pixel offset (scr_y * scr_w) * 4. The
# kernel cdev repacks RGBA -> hardware pixel order per fb_pixfmt and
# honours fb_pitch, so userland only deals in RGBA8888. Row-at-a-time
# keeps userland memory bounded regardless of screen resolution.

SCREEN_ROW_MAXW: uint64 = 4096          # cap a single screen row at 4096 px
screen_row: Array[16384, uint8]         # SCREEN_ROW_MAXW * 4

# Parsed /dev/fb geometry.
FBG_W: uint64 = 0
FBG_H: uint64 = 0
FBG_PITCH: uint64 = 0
FBG_BPP: uint64 = 0
FBG_PIXFMT: uint64 = 0


def read_fb_geometry() -> int32:
    # Read "WIDTH HEIGHT PITCH BPP PIXFMT\n" from /dev/fb. Returns 1 on
    # success (FBG_* populated), 0 on failure.
    p: Ptr[uint8] = "/dev/fb"
    fd: int32 = sys_open(cast[Ptr[char]](p))
    if fd < 0:
        return 0
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 0
    total: uint64 = cast[uint64](n)
    # Parse five space-separated decimals.
    pos: Array[1, uint64]
    pos[0] = 0
    FBG_W = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_H = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PITCH = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_BPP = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PIXFMT = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    if FBG_W == 0 or FBG_H == 0:
        return 0
    return 1


def next_dec(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip non-digits, then parse a run of decimal digits. Advances *pos.
    i: uint64 = pos[0]
    while i < total and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    return v


def composite_window(wid: int32) -> int32:
    # Run the 4b compositor: parse the layer listing, fill `target` with
    # the composited 640x480 window frame. Returns 0 on success, 1 if
    # the wid's draw listing can't be read.
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        return 1
    target_clear()
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    return 0


def cmd_present(wid: int32) -> int32:
    if composite_window(wid) != 0:
        write_str(2, "hamUId: present: cannot read /dev/wsys/<wid>/draw\n")
        return 1
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: present: cannot read /dev/fb geometry\n")
        return 1
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    # Aspect-preserving fit of WIN_W x WIN_H into sw x sh. Integer math:
    # scale numerator/denominator = min(sw/WIN_W, sh/WIN_H). To avoid
    # fractions we compute the destination content rectangle directly.
    #   fit_w = min(sw, sh * WIN_W / WIN_H)
    #   fit_h = min(sh, sw * WIN_H / WIN_W)
    fit_w: uint64 = sw
    fit_h: uint64 = (sw * WIN_H) / WIN_W
    if fit_h > sh:
        fit_h = sh
        fit_w = (sh * WIN_W) / WIN_H
    if fit_w > sw:
        fit_w = sw
    if fit_w == 0:
        fit_w = 1
    if fit_h == 0:
        fit_h = 1
    # Letterbox offsets (centre the content rect).
    ox: uint64 = (sw - fit_w) / 2
    oy: uint64 = (sh - fit_h) / 2
    # Open /dev/fb for writing the frame.
    pw: Ptr[uint8] = "/dev/fb"
    wf: int32 = sys_open_write(cast[Ptr[char]](pw))
    if wf < 0:
        write_str(2, "hamUId: present: cannot open /dev/fb for write\n")
        return 1
    # Emit one screen row at a time.
    sy: uint64 = 0
    while sy < sh:
        # Clear row to black (letterbox bars).
        ci: uint64 = 0
        rb: uint64 = sw * 4
        while ci < rb:
            screen_row[ci] = 0
            ci = ci + 1
        # If this screen row is inside the content band, scale-sample the
        # window frame into it.
        if sy >= oy and sy < oy + fit_h:
            # Source row in the window (nearest-neighbour).
            relq: uint64 = sy - oy
            srcy: uint64 = (relq * WIN_H) / fit_h
            if srcy >= WIN_H:
                srcy = WIN_H - 1
            dx: uint64 = 0
            while dx < fit_w:
                srcx: uint64 = (dx * WIN_W) / fit_w
                if srcx >= WIN_W:
                    srcx = WIN_W - 1
                so: uint64 = (srcy * WIN_W + srcx) * 4
                doff: uint64 = (ox + dx) * 4
                if (ox + dx) < sw:
                    screen_row[doff] = target[so]
                    screen_row[doff + 1] = target[so + 1]
                    screen_row[doff + 2] = target[so + 2]
                    screen_row[doff + 3] = 255
                dx = dx + 1
        # Write this row at its pixel offset in the screen frame. The fd
        # cursor advances by the bytes written, so successive rows land
        # at the right offset automatically (no explicit lseek needed —
        # we write exactly sw*4 bytes per row, contiguously).
        sys_write(wf, &screen_row[0], sw * 4)
        sy = sy + 1
    sys_close(wf)
    # Emit a deterministic AI/CI-readable summary line so a headless test
    # can assert the present happened even without screendump.
    emit_present_summary(wid, sw, sh, fit_w, fit_h, ox, oy)
    return 0


def emit_present_summary(wid: int32, sw: uint64, sh: uint64,
                         fit_w: uint64, fit_h: uint64,
                         ox: uint64, oy: uint64):
    # "PRESENT wid=<w> screen=<sw>x<sh> fit=<fw>x<fh> off=<ox>,<oy>\n"
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PRESENT wid="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &line[p])
    s1: Ptr[uint8] = " screen="
    k = 0
    while s1[k] != 0:
        line[p] = s1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(sw, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(sh, &line[p])
    s2: Ptr[uint8] = " fit="
    k = 0
    while s2[k] != 0:
        line[p] = s2[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(fit_w, &line[p])
    line[p] = 120
    p = p + 1
    p = p + u64_to_dec(fit_h, &line[p])
    s3: Ptr[uint8] = " off="
    k = 0
    while s3[k] != 0:
        line[p] = s3[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(ox, &line[p])
    line[p] = 44                                     # ','
    p = p + 1
    p = p + u64_to_dec(oy, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


# ====================================================================
# Phase 4c-interactive — the persistent daemon
# ====================================================================
#
#   hamUId daemon
#       A persistent present-loop that owns the physical framebuffer:
#         * opens /dev/fb (geometry once) and /dev/mouse,
#         * maintains a cursor position (starts at screen centre) driven
#           by the mouse dx/dy each iteration, clamped to screen bounds,
#         * composites a flat root backdrop + every window created by the
#           drag gesture + the cursor (a small arrow), and PRESENTS the
#           result to /dev/fb whenever anything changed,
#         * implements the canonical rio DRAG-TO-CREATE gesture: a
#           left-button-down at (x0,y0) begins a drag; while held a
#           rubber-band outline rectangle tracks the cursor; a
#           left-button-up at (x1,y1), if the swept rectangle exceeds a
#           small threshold, allocates a new wid (sys_spawn detached
#           hamsh + sys_wsys_alloc, mirroring user/hamUI.ad's cmd_new)
#           and records the rectangle as a window so its chrome paints
#           where it was dragged.
#
#       It does NOT auto-start at boot — it is launched explicitly (by a
#       user or a test). It yields the CPU every idle iteration so it
#       never spins at 100%.
#
# The daemon owns the WHOLE physical screen (unlike `present`, which
# scales one 640x480 window). It composites directly at screen
# resolution one ROW at a time into screen_row (reused from `present`),
# computing each pixel from a tiny model — backdrop, the window table,
# the rubber band, and the cursor — so userland memory stays bounded
# regardless of screen size.

# Root backdrop colour (a calm slate so window chrome and the cursor
# stand out for screendump assertions).
ROOT_R: uint8 = 32
ROOT_G: uint8 = 48
ROOT_B: uint8 = 72

# Window chrome colours.
WIN_TITLE_R: uint8 = 64
WIN_TITLE_G: uint8 = 110
WIN_TITLE_B: uint8 = 200
# Focused (topmost) window: brighter title bar so the user can tell which
# window has keyboard focus at a glance.
WIN_TITLE_FOCUS_R: uint8 = 90
WIN_TITLE_FOCUS_G: uint8 = 150
WIN_TITLE_FOCUS_B: uint8 = 240
WIN_BODY_R: uint8 = 200
WIN_BODY_G: uint8 = 200
WIN_BODY_B: uint8 = 210
WIN_BORDER_R: uint8 = 240
WIN_BORDER_G: uint8 = 240
WIN_BORDER_B: uint8 = 250

TITLE_H: int64 = 18                      # window title-bar height (px)
DRAG_MIN: int64 = 12                     # min swept extent to spawn a win

# Close-box ([x]) colours: a red square with a white X glyph.
CLOSE_R: uint8 = 210
CLOSE_G: uint8 = 60
CLOSE_B: uint8 = 60
CLOSE_X_R: uint8 = 255
CLOSE_X_G: uint8 = 255
CLOSE_X_B: uint8 = 255

SIGTERM_D: int32 = 15

# ---- panel + Applications menu (GNOME2 / MATE classic launcher) -----
# A persistent horizontal PANEL bar along the TOP screen edge (the
# classic GNOME2 layout). At its left end sits an "Applications" menu
# button; clicking it drops a vertical menu of launchable programs.
# Clicking an entry spawns that program into a new window via the SAME
# spawn-into-window path the drag gesture uses; clicking off the menu
# dismisses it.
PANEL_H: int64 = 22                       # panel bar height (px)
PANEL_R: uint8 = 46                       # panel background (dark slate)
PANEL_G: uint8 = 52
PANEL_B: uint8 = 64
PANEL_HI_R: uint8 = 70                     # panel button hover/open tint
PANEL_HI_G: uint8 = 90
PANEL_HI_B: uint8 = 140
PANEL_TXT_R: uint8 = 235                   # panel label ink
PANEL_TXT_G: uint8 = 235
PANEL_TXT_B: uint8 = 240

# "Applications" button geometry (left end of the panel).
APPS_BTN_X: int64 = 4
APPS_BTN_W: int64 = 104                    # ~12 glyphs * 8px + padding

# Menu geometry: a vertical list dropping from just below the panel at
# the Applications button's left edge.
MENU_X: int64 = 4
MENU_W: int64 = 150
MENU_ITEM_H: int64 = 20                     # per-entry row height (px)
MENU_R: uint8 = 56                          # menu background
MENU_G: uint8 = 62
MENU_B: uint8 = 78
MENU_SEL_R: uint8 = 70                       # hovered item tint
MENU_SEL_G: uint8 = 100
MENU_SEL_B: uint8 = 170
MENU_TXT_R: uint8 = 235
MENU_TXT_G: uint8 = 235
MENU_TXT_B: uint8 = 240

MENU_OPEN: int32 = 0                         # 1 while the menu is dropped

# Menu entries: a parallel pair of (label, program-path) tables. Each
# program is a real built /bin/<name> binary (verified present in the
# build). Labels stay short so they fit MENU_W. String constants live
# inside menu_label()/menu_prog() (file-scope globals can't take string
# initialisers in Adder).
MENU_COUNT: uint64 = 9

# ---- taskbar (window-list buttons in the panel) -------------------
# Each open window gets a button on the panel, right of the
# Applications button. Buttons are TASKBAR_BTN_W pixels wide;
# minimized windows show their button in the dimmed tint, normal
# windows use the panel background; the focused (topmost) window
# gets the highlight tint.
TASKBAR_START_X: int64 = 112           # APPS_BTN_X + APPS_BTN_W + 4
TASKBAR_BTN_W:   int64 = 96           # fits ~10 chars at 8px + 16px padding
TASKBAR_BTN_H:   int64 = 20           # 1px top + 18px body + 1px bottom border
TASKBAR_BTN_Y:   int64 = 1            # top pixel within panel (1px border)

# Right-edge clock area: reserved on the right side of the panel.
# The clock string "HH:MM" is 5 chars * 8px + 8px padding each side = 56px.
CLOCK_W:  int64 = 56
CLOCK_PAD: int64 = 8                   # horizontal padding inside clock area

# Minimize-box geometry: a square just LEFT of the close box in the title bar.
MINIMIZE_BOX: int64 = 14              # same size as CLOSE_BOX
# Minimize box colours: yellow square with white dash.
MINIMIZE_R: uint8 = 200
MINIMIZE_G: uint8 = 160
MINIMIZE_B: uint8 = 40
MINIMIZE_DASH_R: uint8 = 255
MINIMIZE_DASH_G: uint8 = 255
MINIMIZE_DASH_B: uint8 = 255

# Clock background tint (darker than panel, so it reads as a separate zone).
CLOCK_R: uint8 = 36
CLOCK_G: uint8 = 42
CLOCK_B: uint8 = 54


# 1 if screen pixel (x,y) lands on an INK pixel of the glyph string `s`
# laid out left-to-right at top-left origin (ox,oy), one 8x16 cell per
# character. Used to paint panel/menu labels into the compositor without
# any backing buffer. Out-of-range characters render as blank.
def str_ink(s: Ptr[uint8], ox: int64, oy: int64, x: int64, y: int64) -> int32:
    ly: int64 = y - oy
    if ly < 0 or ly >= GLYPH_H:
        return 0
    lx: int64 = x - ox
    if lx < 0:
        return 0
    col: int64 = lx / GLYPH_W
    ch: uint8 = s[cast[uint64](col)]
    if ch == 0:
        return 0
    if ch < 32 or ch > 126:
        return 0
    gx: int64 = lx - col * GLYPH_W           # 0..7
    gi: uint64 = cast[uint64](ch) - 32
    bits: uint8 = font_glyphs[gi * 16 + cast[uint64](ly)]
    mask: uint8 = cast[uint8](128 >> gx)
    if (bits & mask) != 0:
        return 1
    return 0


# Return the label string for menu entry `i`.
def menu_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        s0: Ptr[uint8] = "Terminal"
        return s0
    if i == 1:
        s1: Ptr[uint8] = "Editor (vi)"
        return s1
    if i == 2:
        s2: Ptr[uint8] = "Top"
        return s2
    if i == 3:
        s3: Ptr[uint8] = "Calculator"
        return s3
    if i == 4:
        s4: Ptr[uint8] = "System Monitor"
        return s4
    if i == 5:
        s5: Ptr[uint8] = "About Hamnix"
        return s5
    if i == 6:
        s6: Ptr[uint8] = "Calendar"
        return s6
    if i == 7:
        s7: Ptr[uint8] = "Date"
        return s7
    s8: Ptr[uint8] = "Files"
    return s8


# App kind for internal (in-process) menu entries, or -1 if the entry
# launches an external /bin program via the spawn path.
def menu_app(i: uint64) -> int32:
    if i == 3:
        return APP_CALC
    if i == 4:
        return APP_SYSMON
    if i == 5:
        return APP_ABOUT
    return -1


# Return the program path for menu entry `i` (external entries only).
def menu_prog(i: uint64) -> Ptr[char]:
    if i == 0:
        p0: Ptr[char] = "/bin/hamsh"
        return p0
    if i == 1:
        p1: Ptr[char] = "/bin/vi"
        return p1
    if i == 2:
        p2: Ptr[char] = "/bin/top"
        return p2
    if i == 6:
        p6: Ptr[char] = "/bin/cal"
        return p6
    if i == 7:
        p7: Ptr[char] = "/bin/date"
        return p7
    p8: Ptr[char] = "/bin/hamfm"
    return p8


# Total pixel height the dropped menu occupies.
def menu_total_h() -> int64:
    return cast[int64](MENU_COUNT) * MENU_ITEM_H


# 1 if (px,py) is inside the panel's Applications button.
def in_apps_btn(px: int64, py: int64) -> int32:
    if px >= APPS_BTN_X and px < APPS_BTN_X + APPS_BTN_W:
        if py >= 0 and py < PANEL_H:
            return 1
    return 0


# 1 if (px,py) is anywhere on the panel bar.
def in_panel(px: int64, py: int64) -> int32:
    if py >= 0 and py < PANEL_H:
        return 1
    return 0


# Index (0..MENU_COUNT-1) of the menu item under (px,py) while the menu
# is open, or -1 if not over an item. The menu drops from PANEL_H down.
def menu_item_at(px: int64, py: int64) -> int64:
    if MENU_OPEN == 0:
        return -1
    if px < MENU_X or px >= MENU_X + MENU_W:
        return -1
    top: int64 = PANEL_H
    if py < top or py >= top + menu_total_h():
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](menubar_count(MENU_BAR_OPEN)):
        return -1
    return idx


# ====================================================================
# MATE / GNOME2 menu BAR (Applications / Places / System)
# ====================================================================
# The single legacy "Applications" button is upgraded into the classic
# GNOME2 three-menu bar. MENU_BAR_OPEN selects which top-level menu (if
# any) is currently dropped:
#   -1 = closed
#    0 = Applications   1 = Places   2 = System
# Each top-level menu is a list of items. Items carry an ACTION kind so
# the click handler can do the right thing:
#   0 = launch a program  (path from menubar_item_prog)
#   1 = open a directory in the file manager (path arg)
#   2 = reload the DE / about / window action (system verbs)
MENU_BAR_OPEN: int32 = -1

# Top-level menu button labels + geometry. Buttons are laid out left to
# right from APPS_BTN_X; each is sized to its label width + padding.
MENUBAR_PAD: int64 = 10

# System-menu action codes (returned by menubar_item_action when kind==2).
SYSACT_RELOAD: int64 = 0
SYSACT_ABOUT:  int64 = 1


def menubar_label(m: int32) -> Ptr[uint8]:
    if m == 0:
        l0: Ptr[uint8] = "Applications"
        return l0
    if m == 1:
        l1: Ptr[uint8] = "Places"
        return l1
    l2: Ptr[uint8] = "System"
    return l2


# Number of items in top-level menu `m`.
def menubar_count(m: int32) -> uint64:
    if m == 0:
        return MENU_COUNT          # the existing Applications list
    if m == 1:
        return 3                    # Home / Filesystem / Tmp
    if m == 2:
        return 6                    # SysMon / About / Reload / 2 ws / Log Out
    return 0


# Pixel width of top-level menu button `m` (label glyphs + padding).
def menubar_btn_w(m: int32) -> int64:
    n: int64 = cast[int64](strlen_u8(menubar_label(m)))
    return n * GLYPH_W + MENUBAR_PAD * 2


# Left x of top-level menu button `m`.
def menubar_btn_x(m: int32) -> int64:
    x: int64 = APPS_BTN_X
    i: int32 = 0
    while i < m:
        x = x + menubar_btn_w(i)
        i = i + 1
    return x


# Right edge x of the whole menu bar (start of the taskbar zone).
def menubar_end_x() -> int64:
    return menubar_btn_x(2) + menubar_btn_w(2)


# Which top-level menu button is under (px,py)? -1 if none. The bar
# lives in the panel's full height at the left end.
def menubar_btn_at(px: int64, py: int64) -> int32:
    if py < 0 or py >= PANEL_H:
        return -1
    m: int32 = 0
    while m < 3:
        bx: int64 = menubar_btn_x(m)
        if px >= bx and px < bx + menubar_btn_w(m):
            return m
        m = m + 1
    return -1


# Drop-down geometry for the currently-open top-level menu.
def menubar_drop_x() -> int64:
    if MENU_BAR_OPEN < 0:
        return 0
    return menubar_btn_x(MENU_BAR_OPEN)


def menubar_drop_w() -> int64:
    # Wide enough for the legacy MENU_W on Applications, a bit narrower
    # for the short Places/System lists.
    if MENU_BAR_OPEN == 0:
        return MENU_W
    return 168


def menubar_total_h() -> int64:
    return cast[int64](menubar_count(MENU_BAR_OPEN)) * MENU_ITEM_H


# Label for item `i` of top-level menu `m`.
def menubar_item_label(m: int32, i: uint64) -> Ptr[uint8]:
    if m == 0:
        return menu_label(i)
    if m == 1:
        if i == 0:
            p0: Ptr[uint8] = "Home"
            return p0
        if i == 1:
            p1: Ptr[uint8] = "Filesystem"
            return p1
        p2: Ptr[uint8] = "Tmp"
        return p2
    if m == 2:
        if i == 0:
            s0: Ptr[uint8] = "System Monitor"
            return s0
        if i == 1:
            s1: Ptr[uint8] = "About Hamnix"
            return s1
        if i == 2:
            s2: Ptr[uint8] = "Reload DE"
            return s2
        if i == 3:
            s3: Ptr[uint8] = "Next Workspace"
            return s3
        if i == 4:
            s4: Ptr[uint8] = "Prev Workspace"
            return s4
        s5: Ptr[uint8] = "Log Out"
        return s5
    e: Ptr[uint8] = ""
    return e


# Item under (px,py) for the open drop-down, or -1.
def menubar_item_at(px: int64, py: int64) -> int64:
    if MENU_BAR_OPEN < 0:
        return -1
    dx: int64 = menubar_drop_x()
    dw: int64 = menubar_drop_w()
    if px < dx or px >= dx + dw:
        return -1
    top: int64 = PANEL_H
    if py < top or py >= top + menubar_total_h():
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](menubar_count(MENU_BAR_OPEN)):
        return -1
    return idx


# ====================================================================
# MATE virtual workspaces
# ====================================================================
WS_COUNT: int32 = 4
CUR_WS: int32 = 0

# Workspace-pager applet geometry: WS_COUNT little boxes in the panel,
# left of the clock. Each box is PAGER_CELL_W wide.
PAGER_CELL_W: int64 = 28
PAGER_PAD:    int64 = 4         # inner inset for the occupancy mini-map
PAGER_R: uint8 = 30            # pager cell background (darker than panel)
PAGER_G: uint8 = 34
PAGER_B: uint8 = 44
PAGER_CUR_R: uint8 = 70        # current-workspace cell highlight
PAGER_CUR_G: uint8 = 100
PAGER_CUR_B: uint8 = 170
PAGER_WIN_R: uint8 = 150       # mini window-occupancy marker
PAGER_WIN_G: uint8 = 200
PAGER_WIN_B: uint8 = 240


def pager_total_w() -> int64:
    return cast[int64](WS_COUNT) * PAGER_CELL_W


# Left x of the pager applet (just left of the clock zone).
def pager_x0(scr_w: int64) -> int64:
    return scr_w - CLOCK_W - pager_total_w() - 4


# Pager cell index under (px,py), or -1.
def pager_cell_at(px: int64, py: int64, scr_w: int64) -> int64:
    if py < 0 or py >= PANEL_H:
        return -1
    x0: int64 = pager_x0(scr_w)
    if px < x0 or px >= x0 + pager_total_w():
        return -1
    idx: int64 = (px - x0) / PAGER_CELL_W
    if idx < 0 or idx >= cast[int64](WS_COUNT):
        return -1
    return idx


# 1 if window `slot` is visible on the CURRENT workspace (right ws AND
# not minimized). Used by the compositor + hit-testers.
def win_on_cur_ws(slot: uint64) -> int32:
    if DWIN_WS[slot] != CUR_WS:
        return 0
    if DWIN_HIDDEN[slot] != 0:
        return 0
    return 1


# Switch to workspace `ws` (clamped). Emits a serial marker for tests.
def workspace_switch(ws: int32):
    if ws < 0:
        ws = WS_COUNT - 1
    if ws >= WS_COUNT:
        ws = 0
    if ws == CUR_WS:
        return
    CUR_WS = ws
    # Close any open menu / context menu when the desktop changes.
    MENU_OPEN = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    pfx: Ptr[uint8] = "WS switch "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](CUR_WS + 1) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# Move window `slot` to workspace `ws` (clamped). Emits a marker.
def window_to_workspace(slot: uint64, ws: int32):
    if ws < 0 or ws >= WS_COUNT:
        return
    DWIN_WS[slot] = ws
    pfx: Ptr[uint8] = "WS move-window "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](ws + 1) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# ====================================================================
# MATE right-click context menus
# ====================================================================
# Two flavours, selected by CTX_KIND:
#   0 = desktop menu  (right-click empty desktop): New Terminal / Reload
#   1 = window menu   (right-click a title bar): window ops on CTX_SLOT
# CTX_OPEN gates rendering + hit-testing; CTX_X/CTX_Y is the top-left.
CTX_OPEN: int32 = 0
CTX_KIND: int32 = 0
CTX_SLOT: int64 = -1
CTX_X: int64 = 0
CTX_Y: int64 = 0
CTX_ITEM_H: int64 = 20
CTX_W: int64 = 168
CTX_R: uint8 = 56
CTX_G: uint8 = 62
CTX_B: uint8 = 78
CTX_SEL_R: uint8 = 70
CTX_SEL_G: uint8 = 100
CTX_SEL_B: uint8 = 170


def ctx_count() -> uint64:
    if CTX_KIND == 0:
        return 2                    # New Terminal / Reload
    return 5                        # Minimize / Maximize / Move-WS / Close + restore label combined


def ctx_item_label(i: uint64) -> Ptr[uint8]:
    if CTX_KIND == 0:
        if i == 0:
            d0: Ptr[uint8] = "New Terminal"
            return d0
        d1: Ptr[uint8] = "Reload DE"
        return d1
    # window menu
    if i == 0:
        w0: Ptr[uint8] = "Minimize"
        return w0
    if i == 1:
        # Maximize vs Restore depends on the window's current state.
        if CTX_SLOT >= 0 and DWIN_MAXED[cast[uint64](CTX_SLOT)] != 0:
            wr: Ptr[uint8] = "Restore"
            return wr
        w1: Ptr[uint8] = "Maximize"
        return w1
    if i == 2:
        w2: Ptr[uint8] = "Move to Next WS"
        return w2
    if i == 3:
        w3: Ptr[uint8] = "Move to Prev WS"
        return w3
    w4: Ptr[uint8] = "Close"
    return w4


def ctx_total_h() -> int64:
    return cast[int64](ctx_count()) * CTX_ITEM_H


# Context-menu item under (px,py), or -1.
def ctx_item_at(px: int64, py: int64) -> int64:
    if CTX_OPEN == 0:
        return -1
    if px < CTX_X or px >= CTX_X + CTX_W:
        return -1
    if py < CTX_Y or py >= CTX_Y + ctx_total_h():
        return -1
    idx: int64 = (py - CTX_Y) / CTX_ITEM_H
    if idx < 0 or idx >= cast[int64](ctx_count()):
        return -1
    return idx


# Open a context menu of `kind` anchored at (ax,ay), clamped on-screen.
def ctx_open_at(kind: int32, slot: int64, ax: int64, ay: int64,
                scr_w: int64, scr_h: int64):
    CTX_KIND = kind
    CTX_SLOT = slot
    CTX_OPEN = 1
    cx: int64 = ax
    cy: int64 = ay
    if cx + CTX_W > scr_w:
        cx = scr_w - CTX_W
    if cx < 0:
        cx = 0
    h: int64 = ctx_total_h()
    if cy + h > scr_h:
        cy = scr_h - h
    if cy < PANEL_H:
        cy = PANEL_H
    CTX_X = cx
    CTX_Y = cy


# ====================================================================
# MATE themed window decorations (Clearlooks-ish bevels + gradients)
# ====================================================================
# Title-bar gradient endpoints. Active (focused) window uses the blue
# gradient; inactive uses a muted grey-blue. The gradient runs top->bottom
# across TITLE_H rows.
TITLE_ACT_TOP_R: uint8 = 120
TITLE_ACT_TOP_G: uint8 = 178
TITLE_ACT_TOP_B: uint8 = 252
TITLE_ACT_BOT_R: uint8 = 56
TITLE_ACT_BOT_G: uint8 = 116
TITLE_ACT_BOT_B: uint8 = 208
TITLE_INA_TOP_R: uint8 = 150
TITLE_INA_TOP_G: uint8 = 156
TITLE_INA_TOP_B: uint8 = 168
TITLE_INA_BOT_R: uint8 = 108
TITLE_INA_BOT_G: uint8 = 114
TITLE_INA_BOT_B: uint8 = 128

# Beveled border tints: a light highlight on the top/left edges, a dark
# shadow on the bottom/right edges, framing a 1px mid line.
BEVEL_HI_R: uint8 = 250
BEVEL_HI_G: uint8 = 250
BEVEL_HI_B: uint8 = 255
BEVEL_LO_R: uint8 = 96
BEVEL_LO_G: uint8 = 100
BEVEL_LO_B: uint8 = 112
BEVEL_MID_R: uint8 = 176
BEVEL_MID_G: uint8 = 180
BEVEL_MID_B: uint8 = 192

# Maximize box: a square just LEFT of the minimize box (so the title-bar
# button order left-to-right at the right edge is [_][[]][X]).
MAXIMIZE_BOX: int64 = 14
MAX_BTN_R: uint8 = 110
MAX_BTN_G: uint8 = 180
MAX_BTN_B: uint8 = 110
MAX_GLYPH_R: uint8 = 255
MAX_GLYPH_G: uint8 = 255
MAX_GLYPH_B: uint8 = 255

# Hover highlight: the title-bar button currently under the cursor gets a
# brightened tint. HOVER_SLOT/HOVER_BTN identify it (btn: 0=close,
# 1=minimize, 2=maximize); -1 means nothing hovered.
HOVER_SLOT: int64 = -1
HOVER_BTN:  int32 = -1


# Linear-interpolate one colour channel from `a` (row 0) to `b`
# (row h-1) at integer row `row`.
def grad_chan(a: uint8, b: uint8, row: int64, h: int64) -> uint8:
    if h <= 1:
        return a
    av: int64 = cast[int64](a)
    bv: int64 = cast[int64](b)
    v: int64 = av + (bv - av) * row / (h - 1)
    if v < 0:
        v = 0
    if v > 255:
        v = 255
    return cast[uint8](v)


# Maximize-box geometry (left of the minimize box).
def maximize_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX - 2 - MINIMIZE_BOX \
        - 2 - MAXIMIZE_BOX


def maximize_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


def in_maximize_box(slot: uint64, px: int64, py: int64) -> int32:
    mx: int64 = maximize_box_x(slot)
    my: int64 = maximize_box_y(slot)
    if px >= mx and px < mx + MAXIMIZE_BOX and py >= my and py < my + MAXIMIZE_BOX:
        return 1
    return 0


# Toggle window `slot` between maximized (fills the work area below the
# panel) and its saved rectangle. Snap-aware: if the window is currently
# snapped (maximized OR half-tiled), this restores it to its float
# rectangle; otherwise it maximizes. Emits a serial marker for tests.
def window_toggle_maximize(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_SNAP[slot] != 0 or DWIN_MAXED[slot] != 0:
        # Restore the saved rectangle.
        DWIN_X[slot] = DWIN_SAVE_X[slot]
        DWIN_Y[slot] = DWIN_SAVE_Y[slot]
        DWIN_W[slot] = DWIN_SAVE_W[slot]
        DWIN_H[slot] = DWIN_SAVE_H[slot]
        DWIN_MAXED[slot] = 0
        DWIN_SNAP[slot] = 0
        rm: Ptr[uint8] = "WM restore window\n"
        sys_write(1, rm, strlen_u8(rm))
    else:
        # Save the current rectangle, then fill the work area.
        DWIN_SAVE_X[slot] = DWIN_X[slot]
        DWIN_SAVE_Y[slot] = DWIN_Y[slot]
        DWIN_SAVE_W[slot] = DWIN_W[slot]
        DWIN_SAVE_H[slot] = DWIN_H[slot]
        DWIN_X[slot] = 0
        DWIN_Y[slot] = PANEL_H
        DWIN_W[slot] = scr_w
        DWIN_H[slot] = scr_h - PANEL_H
        DWIN_MAXED[slot] = 1
        DWIN_SNAP[slot] = 1
        mm: Ptr[uint8] = "WM maximize window\n"
        sys_write(1, mm, strlen_u8(mm))
    # Re-derive the terminal grid geometry from the new body size so the
    # in-window shell uses the whole maximized body.
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows


# ---- window snapping / edge tiling helpers -------------------------
# Recompute the per-window terminal grid geometry after a resize so the
# in-window shell/app reflows to the new body. Safe for app windows too.
def window_reflow(slot: uint64):
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    if DWIN_CUR_C[slot] >= cols:
        DWIN_CUR_C[slot] = 0
    if DWIN_CUR_R[slot] >= rows and rows > 0:
        DWIN_CUR_R[slot] = rows - 1


# Apply snap mode `mode` to `slot` (1 max, 2 left half, 3 right half).
# Mode 0 restores to the saved float geometry. The float geometry is
# stashed in DWIN_SAVE_* the first time a float window is snapped (so
# repeated snaps don't lose the origin).
def snap_apply(slot: uint64, mode: int32, scr_w: int64, scr_h: int64):
    if mode == 0:
        if DWIN_SNAP[slot] != 0:
            DWIN_X[slot] = DWIN_SAVE_X[slot]
            DWIN_Y[slot] = DWIN_SAVE_Y[slot]
            DWIN_W[slot] = DWIN_SAVE_W[slot]
            DWIN_H[slot] = DWIN_SAVE_H[slot]
            DWIN_SNAP[slot] = 0
            DWIN_MAXED[slot] = 0
            window_reflow(slot)
        return
    if DWIN_SNAP[slot] == 0:
        DWIN_SAVE_X[slot] = DWIN_X[slot]
        DWIN_SAVE_Y[slot] = DWIN_Y[slot]
        DWIN_SAVE_W[slot] = DWIN_W[slot]
        DWIN_SAVE_H[slot] = DWIN_H[slot]
    avail_h: int64 = scr_h - PANEL_H
    if mode == 1:
        DWIN_X[slot] = 0
        DWIN_Y[slot] = PANEL_H
        DWIN_W[slot] = scr_w
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 1
    elif mode == 2:
        DWIN_X[slot] = 0
        DWIN_Y[slot] = PANEL_H
        DWIN_W[slot] = scr_w / 2
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 0
    elif mode == 3:
        DWIN_X[slot] = scr_w / 2
        DWIN_Y[slot] = PANEL_H
        DWIN_W[slot] = scr_w - scr_w / 2
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 0
    DWIN_SNAP[slot] = mode
    window_reflow(slot)


# Short title string shown on a built-in app window's title bar.
def window_title(slot: uint64) -> Ptr[uint8]:
    a: int32 = DWIN_APP[slot]
    if a == APP_CALC:
        t1: Ptr[uint8] = "Calculator"
        return t1
    if a == APP_SYSMON:
        t2: Ptr[uint8] = "System Monitor"
        return t2
    if a == APP_ABOUT:
        t3: Ptr[uint8] = "About Hamnix"
        return t3
    t0: Ptr[uint8] = "Terminal"
    return t0


# ====================================================================
# Built-in calculator app
# ====================================================================
# A 4x4 keypad below a one-line display. Cell layout (row-major 0..15):
#   row0:  7  8  9  /
#   row1:  4  5  6  *
#   row2:  1  2  3  -
#   row3:  0  C  =  +
# Returns the label byte for keypad cell `k` (0..15), or 0 if none.
def calc_key_label(k: int64) -> uint8:
    if k == 0:
        return 55          # '7'
    if k == 1:
        return 56          # '8'
    if k == 2:
        return 57          # '9'
    if k == 3:
        return 47          # '/'
    if k == 4:
        return 52          # '4'
    if k == 5:
        return 53          # '5'
    if k == 6:
        return 54          # '6'
    if k == 7:
        return 42          # '*'
    if k == 8:
        return 49          # '1'
    if k == 9:
        return 50          # '2'
    if k == 10:
        return 51          # '3'
    if k == 11:
        return 45          # '-'
    if k == 12:
        return 48          # '0'
    if k == 13:
        return 67          # 'C'
    if k == 14:
        return 61          # '='
    if k == 15:
        return 43          # '+'
    return 0


# Render the calculator current value into `out` as a NUL-terminated
# decimal string. Negative handled with a leading '-'. Returns the length.
def calc_format(slot: uint64, out: Ptr[uint8]) -> uint64:
    if CALC_ERR[slot] != 0:
        out[0] = 69        # 'E'
        out[1] = 114       # 'r'
        out[2] = 114       # 'r'
        out[3] = 0
        return 3
    v: int64 = CALC_CUR[slot]
    p: uint64 = 0
    if v < 0:
        out[0] = 45        # '-'
        p = 1
        v = 0 - v
    if v == 0:
        out[p] = 48
        p = p + 1
        out[p] = 0
        return p
    tmp: int64 = v
    digits: uint64 = 0
    while tmp > 0:
        digits = digits + 1
        tmp = tmp / 10
    end: uint64 = p + digits
    out[end] = 0
    w: uint64 = end
    while v > 0:
        w = w - 1
        out[w] = cast[uint8](v % 10) + 48
        v = v / 10
    return end


# Apply the pending operator of `slot` to ACC and CUR, leaving the result
# in both. Sets the error flag on divide-by-zero.
def calc_resolve(slot: uint64):
    op: int32 = CALC_OP[slot]
    a: int64 = CALC_ACC[slot]
    b: int64 = CALC_CUR[slot]
    r: int64 = b
    if op == 1:
        r = a + b
    elif op == 2:
        r = a - b
    elif op == 3:
        r = a * b
    elif op == 4:
        if b == 0:
            CALC_ERR[slot] = 1
            return
        r = a / b
    CALC_ACC[slot] = r
    CALC_CUR[slot] = r


# Handle a keypad press (label byte) for the calculator in `slot`.
def calc_press(slot: uint64, lbl: uint8):
    if lbl == 67:                              # 'C' clear
        CALC_ACC[slot] = 0
        CALC_CUR[slot] = 0
        CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        CALC_ERR[slot] = 0
        return
    if CALC_ERR[slot] != 0:
        return                                 # error sticks until cleared
    if lbl >= 48 and lbl <= 57:                # digit
        if CALC_FRESH[slot] != 0:
            CALC_CUR[slot] = 0
            CALC_FRESH[slot] = 0
        nv: int64 = CALC_CUR[slot] * 10 + cast[int64](lbl - 48)
        if nv < 1000000000:                    # clamp to 9 digits
            CALC_CUR[slot] = nv
        return
    if lbl == 61:                              # '=' resolve
        if CALC_OP[slot] != 0:
            calc_resolve(slot)
            CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        return
    # An operator: resolve any pending op first (chained arithmetic),
    # then latch the new op and start a fresh operand.
    newop: int32 = 0
    if lbl == 43:
        newop = 1
    elif lbl == 45:
        newop = 2
    elif lbl == 42:
        newop = 3
    elif lbl == 47:
        newop = 4
    if newop != 0:
        if CALC_OP[slot] != 0 and CALC_FRESH[slot] == 0:
            calc_resolve(slot)
        else:
            CALC_ACC[slot] = CALC_CUR[slot]
        CALC_OP[slot] = newop
        CALC_FRESH[slot] = 1


# Geometry of the calculator body inside window `slot`. Returns, via
# out-pointers, the body origin (bx,by), keypad cell size (cw,ch) and the
# display strip height (dh).
def calc_layout(slot: uint64, bx: Ptr[int64], by: Ptr[int64],
                cw: Ptr[int64], ch: Ptr[int64], dh: Ptr[int64]):
    body_x: int64 = DWIN_X[slot] + 2
    body_y: int64 = DWIN_Y[slot] + TITLE_H
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    disp_h: int64 = 36
    if disp_h > body_h / 2:
        disp_h = body_h / 2
    bx[0] = body_x
    by[0] = body_y
    cw[0] = body_w / 4
    ch[0] = (body_h - disp_h) / 4
    dh[0] = disp_h


# Keypad cell index (0..15) under (px,py) inside calculator `slot`, or -1.
def calc_cell_at(slot: uint64, px: int64, py: int64) -> int64:
    bx: Array[1, int64]
    by: Array[1, int64]
    cw: Array[1, int64]
    ch: Array[1, int64]
    dh: Array[1, int64]
    calc_layout(slot, &bx[0], &by[0], &cw[0], &ch[0], &dh[0])
    if cw[0] <= 0 or ch[0] <= 0:
        return -1
    kx0: int64 = bx[0]
    ky0: int64 = by[0] + dh[0]
    lx: int64 = px - kx0
    ly: int64 = py - ky0
    if lx < 0 or ly < 0:
        return -1
    col: int64 = lx / cw[0]
    row: int64 = ly / ch[0]
    if col < 0 or col > 3 or row < 0 or row > 3:
        return -1
    return row * 4 + col


# ====================================================================
# Built-in system-monitor app
# ====================================================================
# Append the C string at `s` into out starting at offset p; returns the
# new offset (no NUL written).
def sm_puts(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0:
        out[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# Append `v` as decimal into out at offset p; returns the new offset.
def sm_putnum(out: Ptr[uint8], p: uint64, v: uint64) -> uint64:
    if v == 0:
        out[p] = 48
        return p + 1
    digits: uint64 = 0
    tmp: uint64 = v
    while tmp > 0:
        digits = digits + 1
        tmp = tmp / 10
    end: uint64 = p + digits
    w: uint64 = end
    while v > 0:
        w = w - 1
        out[w] = cast[uint8](v % 10) + 48
        v = v / 10
    return end


# Scan sysmon_buf[0..n) for the line beginning with `key` (e.g.
# "MemTotal:") and parse the first integer that follows it. Returns the
# value, or 0 if the key was not found.
def sm_field(n: uint64, key: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    klen: uint64 = strlen_u8(key)
    while i < n:
        matched: int32 = 1
        j: uint64 = 0
        while j < klen:
            if i + j >= n or sysmon_buf[i + j] != key[j]:
                matched = 0
                break
            j = j + 1
        if matched != 0:
            k: uint64 = i + klen
            while k < n and (sysmon_buf[k] < 48 or sysmon_buf[k] > 57):
                k = k + 1
            v: uint64 = 0
            while k < n and sysmon_buf[k] >= 48 and sysmon_buf[k] <= 57:
                v = v * 10 + cast[uint64](sysmon_buf[k] - 48)
                k = k + 1
            return v
        while i < n and sysmon_buf[i] != 10:
            i = i + 1
        i = i + 1
    return 0


# Refresh the system-monitor display strings from /proc. Throttled to once
# per second (driven by the loop centisecond counter). Reads /proc/uptime
# and /proc/meminfo (MemTotal / MemFree).
def sysmon_refresh(cur_cs: uint64):
    if cur_cs < sysmon_last_cs + 100 and sysmon_last_cs != 0:
        return
    sysmon_last_cs = cur_cs
    # --- uptime ---
    up_secs: uint64 = 0
    up_path: Ptr[char] = "/proc/uptime"
    ufd: int32 = sys_open(up_path)
    if ufd >= 0:
        un: int64 = sys_read(ufd, &sysmon_buf[0], 1024)
        sys_close(ufd)
        cs_up: uint64 = 0
        kk: uint64 = 0
        unu: uint64 = cast[uint64](un)
        while kk < unu and sysmon_buf[kk] >= 48 and sysmon_buf[kk] <= 57:
            cs_up = cs_up * 10 + cast[uint64](sysmon_buf[kk] - 48)
            kk = kk + 1
        up_secs = cs_up / 100
    hh: uint64 = up_secs / 3600
    mm: uint64 = (up_secs / 60) % 60
    ss: uint64 = up_secs % 60
    p: uint64 = 0
    p = sm_puts(&sysmon_line1[0], p, "Uptime: ")
    p = sm_putnum(&sysmon_line1[0], p, hh)
    sysmon_line1[p] = 58
    p = p + 1
    sysmon_line1[p] = cast[uint8](mm / 10) + 48
    p = p + 1
    sysmon_line1[p] = cast[uint8](mm % 10) + 48
    p = p + 1
    sysmon_line1[p] = 58
    p = p + 1
    sysmon_line1[p] = cast[uint8](ss / 10) + 48
    p = p + 1
    sysmon_line1[p] = cast[uint8](ss % 10) + 48
    p = p + 1
    sysmon_line1[p] = 0
    # --- meminfo ---
    mem_total: uint64 = 0
    mem_free: uint64 = 0
    mi_path: Ptr[char] = "/proc/meminfo"
    mfd: int32 = sys_open(mi_path)
    if mfd >= 0:
        mn: int64 = sys_read(mfd, &sysmon_buf[0], 1024)
        sys_close(mfd)
        mnu: uint64 = cast[uint64](mn)
        mem_total = sm_field(mnu, "MemTotal:")
        mem_free = sm_field(mnu, "MemFree:")
    p = 0
    p = sm_puts(&sysmon_line2[0], p, "MemTotal: ")
    p = sm_putnum(&sysmon_line2[0], p, mem_total)
    p = sm_puts(&sysmon_line2[0], p, " kB")
    sysmon_line2[p] = 0
    p = 0
    p = sm_puts(&sysmon_line3[0], p, "MemFree:  ")
    p = sm_putnum(&sysmon_line3[0], p, mem_free)
    p = sm_puts(&sysmon_line3[0], p, " kB")
    sysmon_line3[p] = 0
    used_pct: uint64 = 0
    if mem_total > 0:
        used_pct = ((mem_total - mem_free) * 100) / mem_total
    p = 0
    p = sm_puts(&sysmon_line4[0], p, "MemUsed:  ")
    p = sm_putnum(&sysmon_line4[0], p, used_pct)
    sysmon_line4[p] = 37        # '%'
    p = p + 1
    sysmon_line4[p] = 0


# Parse the cached "MemUsed: NN%" percentage from sysmon_line4 for the bar.
def sysmon_used_pct() -> int64:
    i: uint64 = 0
    v: int64 = 0
    started: int32 = 0
    while sysmon_line4[i] != 0 and i < 48:
        c: uint8 = sysmon_line4[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[int64](c - 48)
            started = 1
        elif started != 0:
            break
        i = i + 1
    if v > 100:
        v = 100
    return v


# ====================================================================
# Built-in app body renderers
# ====================================================================
# Scratch for the calculator display string.
calc_disp_buf: Array[24, uint8]

# Calculator app theme.
CALC_BG_R: uint8 = 54
CALC_BG_G: uint8 = 58
CALC_BG_B: uint8 = 66
CALC_DISP_R: uint8 = 24
CALC_DISP_G: uint8 = 30
CALC_DISP_B: uint8 = 26
CALC_KEY_R: uint8 = 78
CALC_KEY_G: uint8 = 84
CALC_KEY_B: uint8 = 96
CALC_OPKEY_R: uint8 = 96            # operator keys tinted orange-ish
CALC_OPKEY_G: uint8 = 78
CALC_OPKEY_B: uint8 = 60

# System-monitor app theme.
SYSMON_BG_R: uint8 = 40
SYSMON_BG_G: uint8 = 46
SYSMON_BG_B: uint8 = 56


# Render the calculator body for window `slot` at body-pixel (x,y).
def app_calc_pixel(slot: uint64, x: int64, y: int64,
                   outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx: Array[1, int64]
    by: Array[1, int64]
    cw: Array[1, int64]
    ch: Array[1, int64]
    dh: Array[1, int64]
    calc_layout(slot, &bx[0], &by[0], &cw[0], &ch[0], &dh[0])
    r: uint8 = CALC_BG_R
    g: uint8 = CALC_BG_G
    b: uint8 = CALC_BG_B
    ly: int64 = y - by[0]
    # --- display strip across the top ---
    if ly < dh[0]:
        r = CALC_DISP_R
        g = CALC_DISP_G
        b = CALC_DISP_B
        if ly == dh[0] - 1:
            r = 16
            g = 18
            b = 16
        n: uint64 = calc_format(slot, &calc_disp_buf[0])
        pad: int64 = 6
        txt_w: int64 = cast[int64](n) * GLYPH_W
        ox: int64 = bx[0] + (cw[0] * 4) - pad - txt_w
        if ox < bx[0] + pad:
            ox = bx[0] + pad
        oy: int64 = by[0] + (dh[0] - GLYPH_H) / 2
        if str_ink(&calc_disp_buf[0], ox, oy, x, y) != 0:
            r = 120
            g = 240
            b = 140
        outr[0] = r
        outg[0] = g
        outb[0] = b
        return
    # --- keypad ---
    cell: int64 = calc_cell_at(slot, x, y)
    if cell >= 0:
        lbl: uint8 = calc_key_label(cell)
        is_op: int32 = 0
        if lbl == 43 or lbl == 45 or lbl == 42 or lbl == 47 or lbl == 61:
            is_op = 1
        if is_op != 0:
            r = CALC_OPKEY_R
            g = CALC_OPKEY_G
            b = CALC_OPKEY_B
        else:
            r = CALC_KEY_R
            g = CALC_KEY_G
            b = CALC_KEY_B
        # Hover highlight: brighten the cell under the cursor.
        hov: int64 = calc_cell_at(slot, CUR_X, CUR_Y)
        if hov == cell:
            r = add_clamp_u8(r, 34)
            g = add_clamp_u8(g, 34)
            b = add_clamp_u8(b, 34)
        # 1px inset border between keys.
        kx0: int64 = bx[0] + (cell % 4) * cw[0]
        ky0: int64 = by[0] + dh[0] + (cell / 4) * ch[0]
        klx: int64 = x - kx0
        kly: int64 = y - ky0
        if klx == 0 or kly == 0:
            r = sub_clamp_u8(r, 28)
            g = sub_clamp_u8(g, 28)
            b = sub_clamp_u8(b, 28)
        # Centred label glyph.
        gx0: int64 = kx0 + (cw[0] - GLYPH_W) / 2
        gy0: int64 = ky0 + (ch[0] - GLYPH_H) / 2
        kbuf: Array[2, uint8]
        kbuf[0] = lbl
        kbuf[1] = 0
        if str_ink(&kbuf[0], gx0, gy0, x, y) != 0:
            r = 235
            g = 235
            b = 240
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Render the system-monitor body for window `slot` at body-pixel (x,y).
def app_sysmon_pixel(slot: uint64, x: int64, y: int64,
                     outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = SYSMON_BG_R
    g: uint8 = SYSMON_BG_G
    b: uint8 = SYSMON_BG_B
    pad: int64 = 8
    tx: int64 = bx0 + pad
    h0: Ptr[uint8] = "Hamnix System Monitor"
    if str_ink(h0, tx, by0 + 8, x, y) != 0:
        r = 150
        g = 200
        b = 250
    if str_ink(&sysmon_line1[0], tx, by0 + 40, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line2[0], tx, by0 + 64, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line3[0], tx, by0 + 88, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line4[0], tx, by0 + 112, x, y) != 0:
        r = 180
        g = 240
        b = 180
    # A proportional memory-usage bar under the text.
    bar_y: int64 = by0 + 140
    bar_h: int64 = 14
    bar_x0: int64 = tx
    bar_w: int64 = DWIN_W[slot] - 4 - pad * 2
    if y >= bar_y and y < bar_y + bar_h and x >= bar_x0 and x < bar_x0 + bar_w:
        if x == bar_x0 or x == bar_x0 + bar_w - 1 or y == bar_y or y == bar_y + bar_h - 1:
            r = 200
            g = 200
            b = 210
        else:
            pct: int64 = sysmon_used_pct()
            fillw: int64 = ((bar_w - 2) * pct) / 100
            if x - (bar_x0 + 1) < fillw:
                r = 90
                g = 180
                b = 120
            else:
                r = 30
                g = 34
                b = 40
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Render the About card body.
def app_about_pixel(slot: uint64, x: int64, y: int64,
                    outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 44
    g: uint8 = 50
    b: uint8 = 62
    tx: int64 = bx0 + 12
    l0: Ptr[uint8] = "Hamnix Desktop"
    if str_ink(l0, tx, by0 + 16, x, y) != 0:
        r = 160
        g = 210
        b = 255
    l1: Ptr[uint8] = "A Plan 9 / MATE-flavoured DE"
    if str_ink(l1, tx, by0 + 44, x, y) != 0:
        r = 220
        g = 228
        b = 235
    l2: Ptr[uint8] = "Native windowing + compositor"
    if str_ink(l2, tx, by0 + 64, x, y) != 0:
        r = 220
        g = 228
        b = 235
    l3: Ptr[uint8] = "Use Applications to launch apps."
    if str_ink(l3, tx, by0 + 92, x, y) != 0:
        r = 200
        g = 208
        b = 215
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Dispatch a built-in app's body pixel to the right renderer.
def app_body_pixel(slot: uint64, x: int64, y: int64,
                   outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    a: int32 = DWIN_APP[slot]
    if a == APP_CALC:
        app_calc_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_SYSMON:
        app_sysmon_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_ABOUT:
        app_about_pixel(slot, x, y, outr, outg, outb)
    else:
        outr[0] = WIN_BODY_R
        outg[0] = WIN_BODY_G
        outb[0] = WIN_BODY_B


# ---- daemon window model -------------------------------------------
# Up to DMAX windows the daemon paints as chrome rectangles. We mirror
# the wsys cap (MAX_WINDOWS - 2 spawnable slots) but keep our own count.
DMAX: uint64 = 8
DWIN_X: Array[8, int64]
DWIN_Y: Array[8, int64]
DWIN_W: Array[8, int64]
DWIN_H: Array[8, int64]
DWIN_WID: Array[8, int32]
DWIN_COUNT: uint64 = 0
# Minimize state: 1 = window is hidden to the taskbar, 0 = visible.
DWIN_HIDDEN: Array[8, int32]

# GPU track #183: per-window "Vulkan body" flag. 1 = this window's body
# is painted from the native-Vulkan-rendered image in vk_body_buf (read
# from the window's /dev/wsys/<wid>/draw/vk/fb draw-surface layer each
# frame) instead of the in-daemon terminal grid. Only one window carries
# the live vk body at a time in the self-test, but the model is general.
DWIN_VK: Array[8, int32]

# ---- MATE virtual workspaces (per-window) --------------------------
# Each window belongs to exactly one of WS_COUNT virtual desktops. Only
# windows whose DWIN_WS == CUR_WS are composited / hit-tested. The
# minimize bit is independent and still hides a window within its own
# workspace.
DWIN_WS: Array[8, int32]

# ---- MATE maximize / restore (per-window) --------------------------
# DWIN_MAXED == 1 means the window is maximized: its current geometry
# fills the work area (below the panel) and DWIN_SAVE_* holds the
# pre-maximize rectangle so Restore can put it back exactly.
DWIN_MAXED:  Array[8, int32]
DWIN_SAVE_X: Array[8, int64]
DWIN_SAVE_Y: Array[8, int64]
DWIN_SAVE_W: Array[8, int64]
DWIN_SAVE_H: Array[8, int64]

# ---- built-in DE application windows -------------------------------
# Beyond windows backed by a spawned child shell (DWIN_APP == APP_TERM),
# the daemon renders genuine built-in applications entirely in-process:
# their body is drawn by app-specific code and clicks/keys on the body
# route to app-specific handlers (no child process, no pipes). This makes
# the desktop useful out of the box like MATE's bundled utilities.
#   APP_TERM    — child shell + VT grid (the default)
#   APP_CALC    — pocket calculator (4x4 keypad + display, click+keyboard)
#   APP_SYSMON  — system monitor (reads /proc/uptime + /proc/meminfo)
#   APP_ABOUT   — static "About Hamnix" info card
APP_TERM:   int32 = 0
APP_CALC:   int32 = 1
APP_SYSMON: int32 = 2
APP_ABOUT:  int32 = 3
DWIN_APP: Array[8, int32]              # which app this window hosts

# Calculator state, tracked per-slot so multiple calculators each keep
# their own accumulator.
CALC_ACC:   Array[8, int64]           # running accumulator
CALC_CUR:   Array[8, int64]           # number currently being entered
CALC_OP:    Array[8, int32]           # pending op: 0 none,1 +,2 -,3 *,4 /
CALC_FRESH: Array[8, int32]           # 1 = next digit starts a new entry
CALC_ERR:   Array[8, int32]           # 1 = divide-by-zero / overflow flagged

# System-monitor scratch: re-read /proc each second so the figures stay
# live. Strings rendered straight into the body via str_ink.
sysmon_buf:   Array[1024, uint8]
sysmon_line1: Array[48, uint8]        # "Uptime: HH:MM:SS"
sysmon_line2: Array[48, uint8]        # "MemTotal: NNNN kB"
sysmon_line3: Array[48, uint8]        # "MemFree:  NNNN kB"
sysmon_line4: Array[48, uint8]        # "MemUsed:  NN%"
sysmon_last_cs: uint64 = 0

# ---- window snapping / edge tiling ---------------------------------
# Dragging a window's title bar to a screen edge snaps it (GNOME/MATE
# "edge tiling"): top edge -> maximize, left/right edge -> half-tile.
# The pre-snap geometry is stored in DWIN_SAVE_* (shared with the
# maximize feature) so a later restore returns the window to its float
# size. DWIN_SNAP: 0 float, 1 maximized, 2 left-half, 3 right-half.
DWIN_SNAP: Array[8, int32]
SNAP_EDGE: int64 = 8                  # px from an edge that triggers a snap

# Log Out (System menu): set to 1 to request a clean daemon shutdown so
# the console returns to the foreground shell.
DAEMON_QUIT: int32 = 0

# The native Vulkan window image is 192x192 RGBA8888 (matches lib's
# vk_window_demo VK_WIN_W/H). Module-scope flat buffer (Adder U9 quirk).
VK_BODY_W: int64 = 192
VK_BODY_H: int64 = 192
vk_body_buf: Array[147456, uint8]      # 192 * 192 * 4
vk_body_ready: int32 = 0               # 1 once vk_body_buf holds a frame

# ---- live clock state ---------------------------------------------
# Updated once per second from /proc/realtime (wall clock) or
# /proc/uptime (monotonic fallback). The string is HH:MM (5 chars)
# or UUU:MM (uptime hours:minutes). Always NUL-terminated.
clock_str: Array[12, uint8]
clock_last_cs: uint64 = 0        # centiseconds at last clock refresh

# ---- per-window terminal (in-daemon emulator) ----------------------
# Each window dragged out runs an interactive hamsh whose stdin/stdout
# are kernel pipes. The daemon owns the PARENT ends:
#   DWIN_IN_FD  — write end of the child's stdin pipe (keystrokes -> shell)
#   DWIN_OUT_FD — read  end of the child's stdout pipe (shell -> grid)
# and emulates a tiny VT into a per-window character GRID rendered into
# the window body by daemon_pixel. The grid is a flat DMAX*GRID_CELLS
# byte array; each cell holds one printable ASCII byte (0 == blank).
DWIN_IN_FD:  Array[8, int32]
DWIN_OUT_FD: Array[8, int32]
DWIN_PID:    Array[8, int32]
DWIN_COLS:   Array[8, int64]      # body_w / GLYPH_W
DWIN_ROWS:   Array[8, int64]      # body_h / GLYPH_H
DWIN_CUR_C:  Array[8, int64]      # cursor column
DWIN_CUR_R:  Array[8, int64]      # cursor row
# VT parser state per window: 0 = ground, 1 = saw ESC, 2 = in CSI.
DWIN_VT:     Array[8, int32]

GLYPH_W: int64 = 8
GLYPH_H: int64 = 16
# Grid cap per window: 128 cols * 64 rows. 8192 cells * 8 windows = 64 KiB.
GRID_COLS_MAX: int64 = 128
GRID_ROWS_MAX: int64 = 64
GRID_CELLS:    uint64 = 8192      # GRID_COLS_MAX * GRID_ROWS_MAX
term_grid: Array[65536, uint8]    # DMAX * GRID_CELLS

# Small scratch buffer for draining a child's stdout pipe each frame.
term_rx: Array[1024, uint8]
# Small scratch buffer for draining /dev/cons keystrokes each frame.
cons_rx: Array[256, uint8]
cons_fd: int32 = -1

# ---- cursor + drag state -------------------------------------------
CUR_X: int64 = 0
CUR_Y: int64 = 0
DRAG_ACTIVE: int32 = 0
DRAG_X0: int64 = 0
DRAG_Y0: int64 = 0
PREV_BTN_L: int32 = 0                     # previous-iteration left button
PREV_BTN_R: int32 = 0                     # previous-iteration right button

# ---- window-management gesture state -------------------------------
# A left-button-press is classified at the down-edge into one of three
# gestures, tracked by GESTURE:
#   0 = create  (press landed on empty desktop) — rubber-band + spawn
#   1 = move    (press landed on a window title bar) — relocate window
#   2 = close   (press landed on a window's close box) — destroy on up
GESTURE: int32 = 0
# For move: which window slot is being dragged + the cursor-to-window
# offset captured at the down-edge so the window tracks under the grab.
MOVE_SLOT: int64 = -1
MOVE_OFF_X: int64 = 0
MOVE_OFF_Y: int64 = 0
# For close: the slot the press landed on (the release must land on the
# SAME slot's close box to actually destroy it — rio-style).
CLOSE_SLOT: int64 = -1
# Close-box geometry: a square at the right end of the title bar.
CLOSE_BOX: int64 = 14                      # close-box side length (px)

# Small mouse read buffer ("<dx> <dy> <buttons>\n" lines).
mouse_buf: Array[256, uint8]
# Scratch buffer for taskbar button number label (single digit + NUL).
taskbar_lbl_buf: Array[4, uint8]
# Scratch buffer for taskbar click serial output (digit + newline).
taskbar_click_buf: Array[4, uint8]


def iclamp(v: int64, lo: int64, hi: int64) -> int64:
    if v < lo:
        return lo
    if v > hi:
        return hi
    return v


def imin(a: int64, b: int64) -> int64:
    if a < b:
        return a
    return b


def imax(a: int64, b: int64) -> int64:
    if a > b:
        return a
    return b


# Subtract `d` from a uint8 channel, clamping at 0 (used for shadows).
def sub_clamp_u8(v: uint8, d: int64) -> uint8:
    iv: int64 = cast[int64](v) - d
    if iv < 0:
        iv = 0
    return cast[uint8](iv)


# Add `d` to a uint8 channel, clamping at 255 (hover/highlight tints).
def add_clamp_u8(v: uint8, d: int64) -> uint8:
    iv: int64 = cast[int64](v) + d
    if iv > 255:
        iv = 255
    return cast[uint8](iv)


# ---- taskbar hit-testing -------------------------------------------
# The taskbar zone begins just right of the GNOME2 menu bar
# (Applications/Places/System), whose total width is dynamic. The old
# fixed TASKBAR_START_X (sized for a single Applications button) would
# overlap the wider menu bar, so derive the start from menubar_end_x().
def taskbar_start_x() -> int64:
    s: int64 = menubar_end_x() + 4
    if s < TASKBAR_START_X:
        s = TASKBAR_START_X
    return s


# Left x-coordinate of the taskbar button for window `slot`.
# Buttons are laid out left-to-right starting at taskbar_start_x(),
# one per slot regardless of minimized state (all windows appear).
def taskbar_btn_x(slot: uint64) -> int64:
    return taskbar_start_x() + cast[int64](slot) * TASKBAR_BTN_W


# 1 if (px,py) is inside the taskbar button for window `slot`, else 0.
# Taskbar buttons live within the panel height.
def in_taskbar_btn(slot: uint64, px: int64, py: int64) -> int32:
    if py < TASKBAR_BTN_Y or py >= TASKBAR_BTN_Y + TASKBAR_BTN_H:
        return 0
    bx: int64 = taskbar_btn_x(slot)
    if px >= bx and px < bx + TASKBAR_BTN_W - 2:
        return 1
    return 0


# Return the taskbar slot (0..DWIN_COUNT-1) under (px,py), or -1.
# Clocks and the Applications button are excluded by TASKBAR_START_X.
def taskbar_slot_at(px: int64, py: int64, scr_w: int64) -> int64:
    if py < 0 or py >= PANEL_H:
        return -1
    # Exclude clock area on the right.
    clock_x: int64 = scr_w - CLOCK_W
    if px >= clock_x:
        return -1
    if px < taskbar_start_x():
        return -1
    i: uint64 = 0
    while i < DWIN_COUNT:
        if in_taskbar_btn(i, px, py) != 0:
            return cast[int64](i)
        i = i + 1
    return -1


# ---- minimize-box hit-testing --------------------------------------
# The minimize box is a square just to the LEFT of the close box in
# the title bar. Returns its top-left x.
def minimize_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX - 2 - MINIMIZE_BOX


def minimize_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside the minimize box for window `slot`, else 0.
def in_minimize_box(slot: uint64, px: int64, py: int64) -> int32:
    mx: int64 = minimize_box_x(slot)
    my: int64 = minimize_box_y(slot)
    if px >= mx and px < mx + MINIMIZE_BOX and py >= my and py < my + MINIMIZE_BOX:
        return 1
    return 0


# ---- live clock refresh --------------------------------------------
# Read /proc/realtime; extract HH:MM from the ISO-8601 timestamp.
# Fall back to /proc/uptime (uptime as H:MM) if realtime unavailable.
# Updates clock_str[] and clock_last_cs. Call once per second.
clock_read_buf: Array[64, uint8]

def clock_refresh(cur_cs: uint64):
    # Only refresh once per 100 centiseconds (1 second).
    if cur_cs < clock_last_cs + 100 and clock_last_cs != 0:
        return
    clock_last_cs = cur_cs
    # Try /proc/realtime first: line 1 is "YYYY-MM-DDTHH:MM:SSZ epoch\n"
    # HH is at offset 11, MM at 14 (after the 'T' at 10).
    rt_path: Ptr[char] = "/proc/realtime"
    rfd: int32 = sys_open(rt_path)
    if rfd >= 0:
        n: int64 = sys_read(rfd, &clock_read_buf[0], 64)
        sys_close(rfd)
        nu: uint64 = cast[uint64](n)
        # Check it's a real timestamp (starts with digit, not 'u' for unavailable)
        if nu >= 20 and clock_read_buf[0] != 117 and clock_read_buf[10] == 84:
            # offset 11: HH, offset 12: ':', offset 14: MM
            clock_str[0] = clock_read_buf[11]
            clock_str[1] = clock_read_buf[12]
            clock_str[2] = 58     # ':'
            clock_str[3] = clock_read_buf[14]
            clock_str[4] = clock_read_buf[15]
            clock_str[5] = 0
            return
    # Fallback: /proc/uptime gives centiseconds. Convert to H:MM.
    up_path: Ptr[char] = "/proc/uptime"
    ufd: int32 = sys_open(up_path)
    if ufd >= 0:
        n2: int64 = sys_read(ufd, &clock_read_buf[0], 64)
        sys_close(ufd)
        cs_up: uint64 = 0
        k: uint64 = 0
        nu2: uint64 = cast[uint64](n2)
        while k < nu2 and clock_read_buf[k] >= 48 and clock_read_buf[k] <= 57:
            cs_up = cs_up * 10 + cast[uint64](clock_read_buf[k] - 48)
            k = k + 1
        secs: uint64 = cs_up / 100
        mins: uint64 = (secs / 60) % 60
        hrs:  uint64 = secs / 3600
        # Format H:MM (hours may be more than 2 digits for long uptimes).
        # Cap display to 3 digits of hours so the clock fits the panel.
        idx: uint64 = 0
        if hrs >= 100:
            clock_str[idx] = cast[uint8](hrs / 100) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8]((hrs / 10) % 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        elif hrs >= 10:
            clock_str[idx] = cast[uint8](hrs / 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        else:
            clock_str[idx] = cast[uint8](hrs) + 48
            idx = idx + 1
        clock_str[idx] = 58    # ':'
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins / 10) + 48
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins % 10) + 48
        idx = idx + 1
        clock_str[idx] = 0
        return
    # If both fail, show "??:??".
    clock_str[0] = 63    # '?'
    clock_str[1] = 63
    clock_str[2] = 58    # ':'
    clock_str[3] = 63
    clock_str[4] = 63
    clock_str[5] = 0


# ---- window-management hit-testing ---------------------------------
# The close box is a CLOSE_BOX-square inset 2px from the title bar's
# top-right corner. Returns its top-left (cx,cy) for window `slot`.
def close_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX


def close_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside window slot's close box, else 0.
def in_close_box(slot: uint64, px: int64, py: int64) -> int32:
    cx: int64 = close_box_x(slot)
    cy: int64 = close_box_y(slot)
    if px >= cx and px < cx + CLOSE_BOX and py >= cy and py < cy + CLOSE_BOX:
        return 1
    return 0


# 1 if (px,py) is on window slot's title bar (the band below the top
# border, above the body) — EXCLUDING the close box and minimize box.
# Used to start a move-drag.
def in_title_bar(slot: uint64, px: int64, py: int64) -> int32:
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    ww: int64 = DWIN_W[slot]
    if px < wx + 2 or px >= wx + ww - 2:
        return 0
    if py < wy + 2 or py >= wy + TITLE_H:
        return 0
    if in_close_box(slot, px, py) != 0:
        return 0
    if in_minimize_box(slot, px, py) != 0:
        return 0
    if in_maximize_box(slot, px, py) != 0:
        return 0
    return 1


# Topmost window slot whose rectangle contains (px,py), or -1. Windows
# paint back-to-front (slot 0 lowest), so the highest slot wins the
# hit-test.
def window_at(px: int64, py: int64) -> int64:
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        s: uint64 = cast[uint64](wi)
        # Skip minimized windows and windows not on the current workspace —
        # they have no visible surface on this desktop.
        if win_on_cur_ws(s) != 0:
            wx: int64 = DWIN_X[s]
            wy: int64 = DWIN_Y[s]
            if px >= wx and px < wx + DWIN_W[s] and py >= wy and py < wy + DWIN_H[s]:
                return wi
        wi = wi - 1
    return -1


# ---- per-window terminal emulator ----------------------------------
# Cell index for window `slot` at (col,row) into the flat term_grid.
def term_cell(slot: uint64, col: int64, row: int64) -> uint64:
    return slot * GRID_CELLS + cast[uint64](row * GRID_COLS_MAX + col)


# Clear a window's whole grid to blanks (0) and home the cursor.
def term_clear(slot: uint64):
    base: uint64 = slot * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[base + i] = 0
        i = i + 1
    DWIN_CUR_C[slot] = 0
    DWIN_CUR_R[slot] = 0
    DWIN_VT[slot] = 0


# Scroll the grid up one row (drop the top row, blank the new bottom).
def term_scroll(slot: uint64):
    rows: int64 = DWIN_ROWS[slot]
    cols: int64 = DWIN_COLS[slot]
    r: int64 = 0
    while r < rows - 1:
        c: int64 = 0
        while c < cols:
            src: uint64 = term_cell(slot, c, r + 1)
            dst: uint64 = term_cell(slot, c, r)
            term_grid[dst] = term_grid[src]
            c = c + 1
        r = r + 1
    # blank the last row
    c2: int64 = 0
    while c2 < cols:
        term_grid[term_cell(slot, c2, rows - 1)] = 0
        c2 = c2 + 1


def term_newline(slot: uint64):
    DWIN_CUR_R[slot] = DWIN_CUR_R[slot] + 1
    if DWIN_CUR_R[slot] >= DWIN_ROWS[slot]:
        term_scroll(slot)
        DWIN_CUR_R[slot] = DWIN_ROWS[slot] - 1


# Emit one printable byte into the grid at the cursor, advancing it
# (wrapping + scrolling as needed).
def term_putc(slot: uint64, ch: uint8):
    cols: int64 = DWIN_COLS[slot]
    if cols <= 0 or DWIN_ROWS[slot] <= 0:
        return
    if DWIN_CUR_C[slot] >= cols:
        DWIN_CUR_C[slot] = 0
        term_newline(slot)
    term_grid[term_cell(slot, DWIN_CUR_C[slot], DWIN_CUR_R[slot])] = ch
    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] + 1


# Feed `n` bytes from buf into window slot's terminal, honouring a
# minimal control set + swallowing CSI escape sequences so they don't
# corrupt the grid.
def term_feed(slot: uint64, buf: Ptr[uint8], n: int64):
    i: int64 = 0
    while i < n:
        c: uint8 = buf[cast[uint64](i)]
        st: int32 = DWIN_VT[slot]
        if st == 1:
            # saw ESC: '[' begins a CSI; anything else aborts to ground.
            if c == 91:                          # '['
                DWIN_VT[slot] = 2
            else:
                DWIN_VT[slot] = 0
            i = i + 1
        elif st == 2:
            # in CSI: consume parameter/intermediate bytes until a final
            # byte in 0x40..0x7E ends the sequence (we ignore its effect).
            if c >= 64 and c <= 126:
                DWIN_VT[slot] = 0
            i = i + 1
        else:
            if c == 27:                          # ESC
                DWIN_VT[slot] = 1
            elif c == 10:                        # '\n' -> newline + CR
                DWIN_CUR_C[slot] = 0
                term_newline(slot)
            elif c == 13:                        # '\r' -> carriage return
                DWIN_CUR_C[slot] = 0
            elif c == 8:                         # backspace
                if DWIN_CUR_C[slot] > 0:
                    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] - 1
                    term_grid[term_cell(slot, DWIN_CUR_C[slot],
                                        DWIN_CUR_R[slot])] = 0
            elif c == 9:                         # tab -> advance to next 8
                nc: int64 = (DWIN_CUR_C[slot] / 8 + 1) * 8
                if nc >= DWIN_COLS[slot]:
                    nc = DWIN_COLS[slot] - 1
                DWIN_CUR_C[slot] = nc
            elif c >= 32 and c <= 126:           # printable ASCII
                term_putc(slot, c)
            # everything else (other control bytes): drop silently
            i = i + 1


# Drain a window's stdout pipe (non-blocking) into its grid. Returns 1
# if any bytes were consumed (the screen needs a re-present), else 0.
def term_pump(slot: uint64) -> int32:
    fd: int32 = DWIN_OUT_FD[slot]
    if fd < 0:
        return 0
    got: int32 = 0
    iters: int32 = 0
    while iters < 16:
        n: int64 = sys_read_nb(fd, &term_rx[0], 1024)
        iters = iters + 1
        if n <= 0:
            break
        term_feed(slot, &term_rx[0], n)
        got = 1
    return got


# Pixel-model query: what colour is screen pixel (x,y)? Writes r/g/b.
# Order (back to front): backdrop -> windows (in creation order) ->
# rubber band outline -> cursor. The cursor wins last so it's always
# visible.
def daemon_pixel(x: int64, y: int64,
                 outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    r: uint8 = ROOT_R
    g: uint8 = ROOT_G
    b: uint8 = ROOT_B
    # --- windows (back to front) ---
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        # Skip minimized windows and windows not on the current workspace.
        if win_on_cur_ws(wi) == 0:
            wi = wi + 1
            continue
        wx: int64 = DWIN_X[wi]
        wy: int64 = DWIN_Y[wi]
        ww: int64 = DWIN_W[wi]
        wh: int64 = DWIN_H[wi]
        if x >= wx and x < wx + ww and y >= wy and y < wy + wh:
            # Local coordinates within the window rectangle.
            lwx: int64 = x - wx
            lwy: int64 = y - wy
            # --- Clearlooks-ish beveled border (2px) ---
            on_border: int32 = 0
            if lwx < 2 or lwx >= ww - 2 or lwy < 2 or lwy >= wh - 2:
                on_border = 1
            if on_border != 0:
                # Outer ring: light highlight on top/left, dark shadow on
                # bottom/right; the inner ring is the mid frame line.
                outer: int32 = 0
                if lwx == 0 or lwy == 0 or lwx == ww - 1 or lwy == wh - 1:
                    outer = 1
                if outer != 0:
                    if lwx == 0 or lwy == 0:
                        r = BEVEL_HI_R
                        g = BEVEL_HI_G
                        b = BEVEL_HI_B
                    else:
                        r = BEVEL_LO_R
                        g = BEVEL_LO_G
                        b = BEVEL_LO_B
                else:
                    r = BEVEL_MID_R
                    g = BEVEL_MID_G
                    b = BEVEL_MID_B
            else:
                if y < wy + TITLE_H:
                    # --- vertical-gradient title bar (active vs inactive) ---
                    trow: int64 = lwy - 2          # 0..TITLE_H-3 in the bar
                    focused: int32 = 0
                    if wi == DWIN_COUNT - 1:
                        focused = 1
                    if focused != 0:
                        r = grad_chan(TITLE_ACT_TOP_R, TITLE_ACT_BOT_R, trow, TITLE_H - 2)
                        g = grad_chan(TITLE_ACT_TOP_G, TITLE_ACT_BOT_G, trow, TITLE_H - 2)
                        b = grad_chan(TITLE_ACT_TOP_B, TITLE_ACT_BOT_B, trow, TITLE_H - 2)
                    else:
                        r = grad_chan(TITLE_INA_TOP_R, TITLE_INA_BOT_R, trow, TITLE_H - 2)
                        g = grad_chan(TITLE_INA_TOP_G, TITLE_INA_BOT_G, trow, TITLE_H - 2)
                        b = grad_chan(TITLE_INA_TOP_B, TITLE_INA_BOT_B, trow, TITLE_H - 2)
                    # Title text: a built-in app shows its name; a terminal
                    # shows its 1-based window number. Left-aligned.
                    tly: int64 = wy + (TITLE_H - GLYPH_H) / 2
                    if DWIN_APP[wi] != APP_TERM:
                        if str_ink(window_title(wi), wx + 6, tly, x, y) != 0:
                            r = 250
                            g = 250
                            b = 255
                    else:
                        twb: Array[4, uint8]
                        twb[0] = cast[uint8](wi + 1) + 48
                        twb[1] = 0
                        if str_ink(&twb[0], wx + 6, tly, x, y) != 0:
                            r = 250
                            g = 250
                            b = 255
                    # --- close box (beveled red button + white X) ---
                    cbx: int64 = close_box_x(wi)
                    cby: int64 = close_box_y(wi)
                    if x >= cbx and x < cbx + CLOSE_BOX and y >= cby and y < cby + CLOSE_BOX:
                        lxp: int64 = x - cbx
                        lyp: int64 = y - cby
                        hov_c: int32 = 0
                        if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 0:
                            hov_c = 1
                        r = CLOSE_R
                        g = CLOSE_G
                        b = CLOSE_B
                        if hov_c != 0:
                            r = 245
                            g = 110
                            b = 110
                        # bevel: light top/left, dark bottom/right
                        if lxp == 0 or lyp == 0:
                            r = 255
                            g = 180
                            b = 180
                        elif lxp == CLOSE_BOX - 1 or lyp == CLOSE_BOX - 1:
                            r = 130
                            g = 30
                            b = 30
                        inset: int64 = 3
                        span: int64 = CLOSE_BOX - 1
                        if lxp >= inset and lxp <= span - inset and lyp >= inset and lyp <= span - inset:
                            if lxp == lyp or lxp == span - lyp:
                                r = CLOSE_X_R
                                g = CLOSE_X_G
                                b = CLOSE_X_B
                    # --- minimize box (beveled button + dash) ---
                    mbx: int64 = minimize_box_x(wi)
                    mby: int64 = minimize_box_y(wi)
                    if x >= mbx and x < mbx + MINIMIZE_BOX and y >= mby and y < mby + MINIMIZE_BOX:
                        lxm: int64 = x - mbx
                        lym: int64 = y - mby
                        hov_m: int32 = 0
                        if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 1:
                            hov_m = 1
                        r = MINIMIZE_R
                        g = MINIMIZE_G
                        b = MINIMIZE_B
                        if hov_m != 0:
                            r = 240
                            g = 200
                            b = 80
                        if lxm == 0 or lym == 0:
                            r = 255
                            g = 220
                            b = 120
                        elif lxm == MINIMIZE_BOX - 1 or lym == MINIMIZE_BOX - 1:
                            r = 130
                            g = 100
                            b = 20
                        dash_y: int64 = MINIMIZE_BOX - 4
                        dash_x0: int64 = 3
                        dash_x1: int64 = MINIMIZE_BOX - 4
                        dash_h:  int64 = 2
                        if lym >= dash_y and lym < dash_y + dash_h and lxm >= dash_x0 and lxm <= dash_x1:
                            r = MINIMIZE_DASH_R
                            g = MINIMIZE_DASH_G
                            b = MINIMIZE_DASH_B
                    # --- maximize box (beveled button + square/restore glyph) ---
                    xbx: int64 = maximize_box_x(wi)
                    xby: int64 = maximize_box_y(wi)
                    if x >= xbx and x < xbx + MAXIMIZE_BOX and y >= xby and y < xby + MAXIMIZE_BOX:
                        lxx: int64 = x - xbx
                        lyx: int64 = y - xby
                        hov_x: int32 = 0
                        if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 2:
                            hov_x = 1
                        r = MAX_BTN_R
                        g = MAX_BTN_G
                        b = MAX_BTN_B
                        if hov_x != 0:
                            r = 150
                            g = 220
                            b = 150
                        if lxx == 0 or lyx == 0:
                            r = 190
                            g = 240
                            b = 190
                        elif lxx == MAXIMIZE_BOX - 1 or lyx == MAXIMIZE_BOX - 1:
                            r = 40
                            g = 100
                            b = 40
                        # Glyph: a hollow square (Maximize) or two offset
                        # squares (Restore) drawn as box outlines.
                        gi0: int64 = 3
                        gi1: int64 = MAXIMIZE_BOX - 4
                        on_glyph: int32 = 0
                        if lxx >= gi0 and lxx <= gi1 and lyx >= gi0 and lyx <= gi1:
                            if lxx == gi0 or lxx == gi1 or lyx == gi0 or lyx == gi1:
                                on_glyph = 1
                            # the box's top edge is doubled to read as a titlebar
                            if lyx == gi0 + 1:
                                on_glyph = 1
                        if on_glyph != 0:
                            r = MAX_GLYPH_R
                            g = MAX_GLYPH_G
                            b = MAX_GLYPH_B
                elif DWIN_APP[wi] != APP_TERM:
                    # --- built-in application body (calc/sysmon/about) ---
                    app_body_pixel(cast[uint64](wi), x, y, &r, &g, &b)
                elif DWIN_VK[wi] != 0:
                    # --- native Vulkan image rendered into the body ---
                    # The 192x192 RGBA frame (vk_body_buf) sits top-left
                    # inside the body region; body pixels outside it fall
                    # back to the plain body colour.
                    r = WIN_BODY_R
                    g = WIN_BODY_G
                    b = WIN_BODY_B
                    vbx0: int64 = wx + 2
                    vby0: int64 = wy + TITLE_H
                    vlx: int64 = x - vbx0
                    vly: int64 = y - vby0
                    if vk_body_ready != 0 and vlx >= 0 and vly >= 0 \
                       and vlx < VK_BODY_W and vly < VK_BODY_H:
                        vo: uint64 = cast[uint64](vly * VK_BODY_W + vlx) * 4
                        r = vk_body_buf[vo]
                        g = vk_body_buf[vo + 1]
                        b = vk_body_buf[vo + 2]
                else:
                    r = WIN_BODY_R
                    g = WIN_BODY_G
                    b = WIN_BODY_B
                    # --- terminal text rendered into the body ---
                    bx0: int64 = wx + 2
                    by0: int64 = wy + TITLE_H
                    lx: int64 = x - bx0           # pixel within body
                    ly: int64 = y - by0
                    if lx >= 0 and ly >= 0:
                        col: int64 = lx / GLYPH_W
                        row: int64 = ly / GLYPH_H
                        if col < DWIN_COLS[wi] and row < DWIN_ROWS[wi]:
                            gx: int64 = lx - col * GLYPH_W   # 0..7
                            gy: int64 = ly - row * GLYPH_H   # 0..15
                            # Cursor block (inverse) at the cell cursor.
                            is_cur: int32 = 0
                            if col == DWIN_CUR_C[wi] and row == DWIN_CUR_R[wi]:
                                is_cur = 1
                            ce: uint64 = term_cell(cast[uint64](wi), col, row)
                            ch: uint8 = term_grid[ce]
                            on: int32 = 0
                            if ch >= 32 and ch <= 126:
                                gi: uint64 = cast[uint64](ch) - 32
                                bits: uint8 = font_glyphs[gi * 16
                                                          + cast[uint64](gy)]
                                mask: uint8 = cast[uint8](128 >> gx)
                                if (bits & mask) != 0:
                                    on = 1
                            if is_cur != 0:
                                # Solid dark cursor block; glyph ink on it
                                # flips to body colour for legibility.
                                if on != 0:
                                    r = WIN_BODY_R
                                    g = WIN_BODY_G
                                    b = WIN_BODY_B
                                else:
                                    r = 24
                                    g = 24
                                    b = 24
                            elif on != 0:
                                r = 24
                                g = 24
                                b = 24
        wi = wi + 1
    # --- panel bar (always on top of windows; classic top panel) ---
    # Painted after windows so it is never obscured; the cursor still
    # wins last. The GNOME2 menu BAR (Applications / Places / System) sits
    # at the left, the window-list taskbar in the middle, then the
    # workspace pager and the live clock at the right.
    if y >= 0 and y < PANEL_H:
        r = PANEL_R
        g = PANEL_G
        b = PANEL_B
        aly: int64 = (PANEL_H - GLYPH_H) / 2
        # 1px bottom border so the panel reads as a distinct bar.
        if y == PANEL_H - 1:
            r = 24
            g = 28
            b = 36
        # --- menu bar: three top-level buttons ---
        mb: int32 = menubar_btn_at(x, y)
        if mb >= 0:
            # Highlight the button whose menu is open (or hovered).
            if mb == MENU_BAR_OPEN:
                r = PANEL_HI_R
                g = PANEL_HI_G
                b = PANEL_HI_B
            elif menubar_btn_at(CUR_X, CUR_Y) == mb:
                r = cast[uint8](cast[int32](PANEL_R) + 16)
                g = cast[uint8](cast[int32](PANEL_G) + 16)
                b = cast[uint8](cast[int32](PANEL_B) + 16)
            if y == PANEL_H - 1:
                r = 24
                g = 28
                b = 36
            mblx: int64 = menubar_btn_x(mb) + MENUBAR_PAD
            if str_ink(menubar_label(mb), mblx, aly, x, y) != 0:
                r = PANEL_TXT_R
                g = PANEL_TXT_G
                b = PANEL_TXT_B
        # --- taskbar: one button per window on the CURRENT workspace ---
        tb_scr_w: int64 = cast[int64](FBG_W)
        pgr_x: int64 = pager_x0(tb_scr_w)
        clock_x: int64 = tb_scr_w - CLOCK_W
        tbi: uint64 = 0
        while tbi < DWIN_COUNT:
            tbx: int64 = taskbar_btn_x(tbi)
            tbe: int64 = tbx + TASKBAR_BTN_W - 2
            # Only paint buttons for windows on the current workspace and
            # only if they don't overlap the pager zone.
            if DWIN_WS[tbi] == CUR_WS and tbx < pgr_x:
                if x >= tbx and x < tbe and y >= TASKBAR_BTN_Y and y < TASKBAR_BTN_Y + TASKBAR_BTN_H:
                    # Focused: topmost visible window gets highlight tint.
                    if tbi == DWIN_COUNT - 1 and DWIN_HIDDEN[tbi] == 0:
                        r = PANEL_HI_R
                        g = PANEL_HI_G
                        b = PANEL_HI_B
                    elif DWIN_HIDDEN[tbi] != 0:
                        # Minimized: slightly lighter background.
                        r = cast[uint8](cast[int32](PANEL_R) + 20)
                        g = cast[uint8](cast[int32](PANEL_G) + 20)
                        b = cast[uint8](cast[int32](PANEL_B) + 20)
                    # else: plain panel colour remains from above.
                    # 1px right edge separator between buttons.
                    if x == tbe - 1:
                        r = 24
                        g = 28
                        b = 36
                    # Window number label (1-based: slot 0 = "1").
                    taskbar_lbl_buf[0] = cast[uint8](tbi + 1) + 48
                    taskbar_lbl_buf[1] = 0
                    if str_ink(&taskbar_lbl_buf[0], tbx + 4, aly, x, y) != 0:
                        r = PANEL_TXT_R
                        g = PANEL_TXT_G
                        b = PANEL_TXT_B
            tbi = tbi + 1
        # --- workspace pager applet (WS_COUNT mini desktops) ---
        if x >= pgr_x and x < pgr_x + pager_total_w():
            cell: int64 = (x - pgr_x) / PAGER_CELL_W
            cx0: int64 = pgr_x + cell * PAGER_CELL_W
            lcx: int64 = x - cx0
            lcy: int64 = y
            # Cell background: current workspace highlighted.
            if cast[int32](cell) == CUR_WS:
                r = PAGER_CUR_R
                g = PAGER_CUR_G
                b = PAGER_CUR_B
            else:
                r = PAGER_R
                g = PAGER_G
                b = PAGER_B
            # 1px separators between cells + bottom border.
            if lcx == 0 or lcx == PAGER_CELL_W - 1 or y == 0 or y == PANEL_H - 1:
                r = 24
                g = 28
                b = 36
            # Mini window-occupancy markers: each window on this workspace
            # gets a tiny rect inside the cell mapped from screen space.
            iw: int64 = pgr_x                       # silence unused warns
            tw: uint64 = 0
            while tw < DWIN_COUNT:
                if DWIN_WS[tw] == cast[int32](cell) and DWIN_HIDDEN[tw] == 0:
                    # Map window rect into the cell's inner area.
                    inx0: int64 = cx0 + PAGER_PAD
                    iny0: int64 = PAGER_PAD
                    innw: int64 = PAGER_CELL_W - PAGER_PAD * 2
                    innh: int64 = PANEL_H - PAGER_PAD * 2
                    sw_i: int64 = tb_scr_w
                    sh_i: int64 = cast[int64](FBG_H)
                    mwx0: int64 = inx0 + DWIN_X[tw] * innw / sw_i
                    mwy0: int64 = iny0 + DWIN_Y[tw] * innh / sh_i
                    mwx1: int64 = inx0 + (DWIN_X[tw] + DWIN_W[tw]) * innw / sw_i
                    mwy1: int64 = iny0 + (DWIN_Y[tw] + DWIN_H[tw]) * innh / sh_i
                    if x >= mwx0 and x <= mwx1 and y >= mwy0 and y <= mwy1:
                        if lcx > 0 and lcx < PAGER_CELL_W - 1 and y > 0 and y < PANEL_H - 1:
                            r = PAGER_WIN_R
                            g = PAGER_WIN_G
                            b = PAGER_WIN_B
                tw = tw + 1
            iw = iw + lcy        # keep iw/lcy referenced
        # --- live clock on the right edge of the panel ---
        if x >= clock_x and x < tb_scr_w:
            r = CLOCK_R
            g = CLOCK_G
            b = CLOCK_B
            if y == PANEL_H - 1:
                r = 24
                g = 28
                b = 36
            if str_ink(&clock_str[0], clock_x + CLOCK_PAD, aly, x, y) != 0:
                r = PANEL_TXT_R
                g = PANEL_TXT_G
                b = PANEL_TXT_B
    # --- menu-bar drop-down (Applications / Places / System) ---
    if MENU_BAR_OPEN >= 0:
        mtop: int64 = PANEL_H
        mdx: int64 = menubar_drop_x()
        mdw: int64 = menubar_drop_w()
        mbot: int64 = mtop + menubar_total_h()
        if x >= mdx and x < mdx + mdw and y >= mtop and y < mbot:
            r = MENU_R
            g = MENU_G
            b = MENU_B
            # 1px frame.
            if x == mdx + mdw - 1 or y == mbot - 1 or x == mdx:
                r = 24
                g = 28
                b = 36
            item: int64 = (y - mtop) / MENU_ITEM_H
            hov: int64 = menubar_item_at(CUR_X, CUR_Y)
            if item == hov and hov >= 0:
                on_edge_m: int32 = 0
                if x == mdx + mdw - 1 or x == mdx:
                    on_edge_m = 1
                if on_edge_m == 0:
                    r = MENU_SEL_R
                    g = MENU_SEL_G
                    b = MENU_SEL_B
            if item >= 0 and item < cast[int64](menubar_count(MENU_BAR_OPEN)):
                ilbl: Ptr[uint8] = menubar_item_label(MENU_BAR_OPEN,
                                                      cast[uint64](item))
                ioy: int64 = mtop + item * MENU_ITEM_H + (MENU_ITEM_H - GLYPH_H) / 2
                if str_ink(ilbl, mdx + 8, ioy, x, y) != 0:
                    r = MENU_TXT_R
                    g = MENU_TXT_G
                    b = MENU_TXT_B
    # --- right-click context menu (desktop or window) ---
    if CTX_OPEN != 0:
        ctop: int64 = CTX_Y
        cbot: int64 = CTX_Y + ctx_total_h()
        if x >= CTX_X and x < CTX_X + CTX_W and y >= ctop and y < cbot:
            r = CTX_R
            g = CTX_G
            b = CTX_B
            if x == CTX_X + CTX_W - 1 or y == cbot - 1 or x == CTX_X or y == ctop:
                r = 24
                g = 28
                b = 36
            citem: int64 = (y - ctop) / CTX_ITEM_H
            chov: int64 = ctx_item_at(CUR_X, CUR_Y)
            if citem == chov and chov >= 0:
                on_edge_c: int32 = 0
                if x == CTX_X + CTX_W - 1 or x == CTX_X:
                    on_edge_c = 1
                if on_edge_c == 0:
                    r = CTX_SEL_R
                    g = CTX_SEL_G
                    b = CTX_SEL_B
            if citem >= 0 and citem < cast[int64](ctx_count()):
                clbl: Ptr[uint8] = ctx_item_label(cast[uint64](citem))
                coy: int64 = ctop + citem * CTX_ITEM_H + (CTX_ITEM_H - GLYPH_H) / 2
                if str_ink(clbl, CTX_X + 8, coy, x, y) != 0:
                    r = MENU_TXT_R
                    g = MENU_TXT_G
                    b = MENU_TXT_B
    # --- rubber band (1px outline of the in-progress drag rect) ---
    if DRAG_ACTIVE != 0:
        rx0: int64 = imin(DRAG_X0, CUR_X)
        ry0: int64 = imin(DRAG_Y0, CUR_Y)
        rx1: int64 = imax(DRAG_X0, CUR_X)
        ry1: int64 = imax(DRAG_Y0, CUR_Y)
        if x >= rx0 and x <= rx1 and y >= ry0 and y <= ry1:
            on_edge: int32 = 0
            if x == rx0 or x == rx1 or y == ry0 or y == ry1:
                on_edge = 1
            if on_edge != 0:
                r = 255
                g = 255
                b = 0
    # --- cursor (a small filled arrow / triangle) ---
    dx: int64 = x - CUR_X
    dy: int64 = y - CUR_Y
    if dx >= 0 and dy >= 0 and dx < 12 and dy < 12:
        # Triangle mask: the pixel is part of the cursor if dx <= dy.
        # That paints a downward-right pointer anchored at the hotspot.
        if dx <= dy:
            # 1px white outline at the hypotenuse-ish edge, black fill.
            if dx == dy or dy == 11 or dx == 0:
                r = 255
                g = 255
                b = 255
            else:
                r = 0
                g = 0
                b = 0
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Composite one screen frame from the daemon model and present it to
# /dev/fb, one row at a time (bounded userland memory). Returns 0 / 1.
def daemon_present() -> int32:
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    pw: Ptr[uint8] = "/dev/fb"
    wf: int32 = sys_open_write(cast[Ptr[char]](pw))
    if wf < 0:
        return 1
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    sy: uint64 = 0
    while sy < sh:
        sx: uint64 = 0
        while sx < sw:
            daemon_pixel(cast[int64](sx), cast[int64](sy),
                         &rr[0], &gg[0], &bb[0])
            o: uint64 = sx * 4
            screen_row[o] = rr[0]
            screen_row[o + 1] = gg[0]
            screen_row[o + 2] = bb[0]
            screen_row[o + 3] = 255
            sx = sx + 1
        sys_write(wf, &screen_row[0], sw * 4)
        sy = sy + 1
    sys_close(wf)
    return 0


# Spawn a detached program + bind it to a fresh wid, then record the
# dragged rectangle as a daemon window. Mirrors user/hamUI.ad::cmd_new.
# Returns the wid (>=2) on success, -1 on failure (still records the
# rectangle as a chrome-only window so the gesture is visibly honoured).
#
# `prog` is the absolute binary path to launch (e.g. "/bin/hamsh",
# "/bin/vi"); its stdin/stdout are wired to the daemon's pipe ends so the
# in-window VT emulator drives it exactly like the drag-out shell. This
# is the SINGLE spawn-into-window path: the drag-to-create gesture passes
# "/bin/hamsh"; the Applications menu passes whichever program was clicked.
arg_buf_d: Array[2, uint64]
in_pipe_d:  Array[2, int32]              # child stdin  pipe [r, w]
out_pipe_d: Array[2, int32]             # child stdout pipe [r, w]
def daemon_spawn_window_prog(prog: Ptr[char],
                             rx: int64, ry: int64, rw: int64, rh: int64):
    if DWIN_COUNT >= DMAX:
        return
    slot: uint64 = DWIN_COUNT
    # Two kernel pipes wire the child's stdio to this daemon:
    #   in_pipe:  parent writes [1], child reads  [0]  (keystrokes)
    #   out_pipe: child writes  [1], parent reads [0]  (shell output)
    in_ok:  int32 = sys_pipe(&in_pipe_d[0])
    out_ok: int32 = sys_pipe(&out_pipe_d[0])
    child_in:  int32 = -1
    child_out: int32 = -1
    parent_in_w:  int32 = -1
    parent_out_r: int32 = -1
    if in_ok == 0 and out_ok == 0:
        child_in     = in_pipe_d[0]      # child stdin  = read end
        parent_in_w  = in_pipe_d[1]      # parent keeps write end
        child_out    = out_pipe_d[1]     # child stdout = write end
        parent_out_r = out_pipe_d[0]     # parent keeps read end
    wid: int32 = -1
    arg_buf_d[0] = cast[uint64](prog)
    arg_buf_d[1] = 0
    pid: int32 = -1
    if child_in >= 0 and child_out >= 0:
        # Real pipe fds -> the legacy integer-fd spawn path dups them into
        # the child's fd 0/1 (and binds /fd/0,1,2 on its private namespace),
        # so the spawned program talks to OUR pipes, not the serial console.
        pid = sys_spawn(prog, &arg_buf_d[0],
                        child_in, child_out, cast[Ptr[uint64]](0))
    else:
        # Pipe allocation failed — fall back to the detached spawn so the
        # gesture still produces a (headless) window.
        pid = sys_spawn(prog, &arg_buf_d[0],
                        -2, -2, cast[Ptr[uint64]](0))
    if pid >= 0:
        wid = sys_wsys_alloc(cast[uint64](pid))
        if wid < 0:
            # Table full / dup — reap the child so we don't leak it.
            sys_kill(pid, SIGTERM_D)
    # The child has its own dup'd copies now; close OUR copies of the
    # child ends so the pipe EOF/refcounts stay correct.
    if child_in >= 0:
        sys_close(child_in)
    if child_out >= 0:
        sys_close(child_out)
    # Record the window + its terminal state.
    DWIN_X[slot] = rx
    DWIN_Y[slot] = ry
    DWIN_W[slot] = rw
    DWIN_H[slot] = rh
    DWIN_WID[slot] = wid
    DWIN_PID[slot] = pid
    DWIN_IN_FD[slot]  = parent_in_w
    DWIN_OUT_FD[slot] = parent_out_r
    # Grid geometry from the body region (window minus 2px border + title).
    body_w: int64 = rw - 4
    body_h: int64 = rh - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    DWIN_HIDDEN[slot] = 0
    DWIN_VK[slot] = 0
    DWIN_APP[slot] = APP_TERM
    DWIN_SNAP[slot] = 0
    # New windows open on the CURRENT workspace, un-maximized.
    DWIN_WS[slot] = CUR_WS
    DWIN_MAXED[slot] = 0
    DWIN_SAVE_X[slot] = rx
    DWIN_SAVE_Y[slot] = ry
    DWIN_SAVE_W[slot] = rw
    DWIN_SAVE_H[slot] = rh
    term_clear(slot)
    DWIN_COUNT = DWIN_COUNT + 1
    # If we got a real wid, plant a chrome layer on its draw surface so
    # the window is real on the wsys side too (best-effort).
    if wid >= 2:
        build_path(wid, cast[Ptr[uint8]](0), "ctl")
        cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
        if cf >= 0:
            cmd: Ptr[uint8] = "mklayer chrome markup\n"
            sys_write(cf, cmd, strlen_u8(cmd))
            sys_close(cf)


# Backwards-compatible drag-to-create spawn: launches an interactive
# hamsh into the dragged rectangle (the classic rio gesture). Delegates
# to the generalised path so there is one spawn implementation.
def daemon_spawn_window(rx: int64, ry: int64, rw: int64, rh: int64):
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamsh"), rx, ry, rw, rh)


# Open a built-in (in-process) application window of the given app kind.
# Unlike daemon_spawn_window_prog these have NO child process or pipes —
# their body is drawn and their input handled entirely inside the daemon.
def daemon_spawn_app(app: int32, rx: int64, ry: int64, rw: int64, rh: int64):
    if DWIN_COUNT >= DMAX:
        return
    slot: uint64 = DWIN_COUNT
    DWIN_X[slot] = rx
    DWIN_Y[slot] = ry
    DWIN_W[slot] = rw
    DWIN_H[slot] = rh
    DWIN_WID[slot] = -1
    DWIN_PID[slot] = -1
    DWIN_IN_FD[slot]  = -1
    DWIN_OUT_FD[slot] = -1
    DWIN_VK[slot] = 0
    DWIN_APP[slot] = app
    DWIN_SNAP[slot] = 0
    DWIN_HIDDEN[slot] = 0
    DWIN_WS[slot] = CUR_WS
    DWIN_MAXED[slot] = 0
    DWIN_SAVE_X[slot] = rx
    DWIN_SAVE_Y[slot] = ry
    DWIN_SAVE_W[slot] = rw
    DWIN_SAVE_H[slot] = rh
    body_w: int64 = rw - 4
    body_h: int64 = rh - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    term_clear(slot)
    if app == APP_CALC:
        CALC_ACC[slot] = 0
        CALC_CUR[slot] = 0
        CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        CALC_ERR[slot] = 0
    DWIN_COUNT = DWIN_COUNT + 1


# Launch menu entry `i` into a fresh window. Each launch is cascaded a
# little down-right of the previous so several apps don't stack exactly
# on top of one another. The rectangle is clamped to stay below the panel
# and inside the framebuffer. Reuses the single spawn-into-window path.
LAUNCH_CASCADE: int64 = 0
def menu_launch(i: uint64, scr_w: int64, scr_h: int64):
    if i >= MENU_COUNT:
        return
    app: int32 = menu_app(i)
    w: int64 = 480
    h: int64 = 320
    # Built-in apps get sizes tuned to their layout.
    if app == APP_CALC:
        w = 220
        h = 300
    elif app == APP_SYSMON:
        w = 360
        h = 220
    elif app == APP_ABOUT:
        w = 360
        h = 180
    # Cascade origin: step 28px per launch, wrapping after a few steps.
    step: int64 = (LAUNCH_CASCADE % 6) * 28
    rx: int64 = 80 + step
    ry: int64 = PANEL_H + 20 + step
    # Clamp so the window fits on-screen below the panel.
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    if app >= 0:
        daemon_spawn_app(app, rx, ry, w, h)
    else:
        daemon_spawn_window_prog(menu_prog(i), rx, ry, w, h)
    # Emit a deterministic serial marker so a self-test can assert the
    # launch fired (label, not path, to keep the marker human-readable).
    pfx: Ptr[uint8] = "PANEL launch "
    sys_write(1, pfx, strlen_u8(pfx))
    lbl: Ptr[uint8] = menu_label(i)
    sys_write(1, lbl, strlen_u8(lbl))
    nl: Ptr[uint8] = "\n"
    sys_write(1, nl, 1)


# Copy ALL per-slot window state (geometry, terminal fds/state, and the
# character grid) from slot `src` to slot `dst`. Used to compact the
# window table when a window is destroyed and to reorder for raise.
def slot_copy(dst: uint64, src: uint64):
    if dst == src:
        return
    DWIN_X[dst]      = DWIN_X[src]
    DWIN_Y[dst]      = DWIN_Y[src]
    DWIN_W[dst]      = DWIN_W[src]
    DWIN_H[dst]      = DWIN_H[src]
    DWIN_WID[dst]    = DWIN_WID[src]
    DWIN_PID[dst]    = DWIN_PID[src]
    DWIN_IN_FD[dst]  = DWIN_IN_FD[src]
    DWIN_OUT_FD[dst] = DWIN_OUT_FD[src]
    DWIN_COLS[dst]   = DWIN_COLS[src]
    DWIN_ROWS[dst]   = DWIN_ROWS[src]
    DWIN_CUR_C[dst]  = DWIN_CUR_C[src]
    DWIN_CUR_R[dst]  = DWIN_CUR_R[src]
    DWIN_VT[dst]     = DWIN_VT[src]
    DWIN_HIDDEN[dst] = DWIN_HIDDEN[src]
    DWIN_VK[dst]     = DWIN_VK[src]
    DWIN_WS[dst]     = DWIN_WS[src]
    DWIN_MAXED[dst]  = DWIN_MAXED[src]
    DWIN_SAVE_X[dst] = DWIN_SAVE_X[src]
    DWIN_SAVE_Y[dst] = DWIN_SAVE_Y[src]
    DWIN_SAVE_W[dst] = DWIN_SAVE_W[src]
    DWIN_SAVE_H[dst] = DWIN_SAVE_H[src]
    DWIN_APP[dst]    = DWIN_APP[src]
    DWIN_SNAP[dst]   = DWIN_SNAP[src]
    CALC_ACC[dst]    = CALC_ACC[src]
    CALC_CUR[dst]    = CALC_CUR[src]
    CALC_OP[dst]     = CALC_OP[src]
    CALC_FRESH[dst]  = CALC_FRESH[src]
    CALC_ERR[dst]    = CALC_ERR[src]
    # Move the character grid wholesale (GRID_CELLS bytes).
    sb: uint64 = src * GRID_CELLS
    db: uint64 = dst * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[db + i] = term_grid[sb + i]
        i = i + 1


# Raise window `slot` to the topmost paint position (last slot). The
# windows above it slide down one slot so paint/hit-test order stays a
# simple back-to-front array walk. MOVE_SLOT is rebased to the new
# position so an in-flight move keeps tracking the right window.
def daemon_raise_slot(slot: int64) -> int64:
    if slot < 0:
        return slot
    last: uint64 = DWIN_COUNT - 1
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT or s == last:
        return cast[int64](s)
    # Stash the window being raised in the spare slot just past the
    # table (DMAX-sized arrays always have room: DWIN_COUNT <= DMAX, and
    # we hold the raised window aside while shifting), using slot DMAX-1
    # is unsafe when full — instead shift up then place at `last`.
    # Save raised window into temporaries via the spawn scratch grid is
    # complex; simplest correct approach: bubble it up with swaps.
    cur: uint64 = s
    while cur < last:
        slot_swap(cur, cur + 1)
        cur = cur + 1
    return cast[int64](last)


# Swap two slots' full state. Implemented via a scratch slot would need
# extra grid storage; instead swap field-by-field and the grid cell-by-
# cell (bounded: GRID_CELLS per call, DMAX small).
def slot_swap(a: uint64, b: uint64):
    if a == b:
        return
    t0: int64 = DWIN_X[a]
    DWIN_X[a] = DWIN_X[b]
    DWIN_X[b] = t0
    t1: int64 = DWIN_Y[a]
    DWIN_Y[a] = DWIN_Y[b]
    DWIN_Y[b] = t1
    t2: int64 = DWIN_W[a]
    DWIN_W[a] = DWIN_W[b]
    DWIN_W[b] = t2
    t3: int64 = DWIN_H[a]
    DWIN_H[a] = DWIN_H[b]
    DWIN_H[b] = t3
    i0: int32 = DWIN_WID[a]
    DWIN_WID[a] = DWIN_WID[b]
    DWIN_WID[b] = i0
    i1: int32 = DWIN_PID[a]
    DWIN_PID[a] = DWIN_PID[b]
    DWIN_PID[b] = i1
    i2: int32 = DWIN_IN_FD[a]
    DWIN_IN_FD[a] = DWIN_IN_FD[b]
    DWIN_IN_FD[b] = i2
    i3: int32 = DWIN_OUT_FD[a]
    DWIN_OUT_FD[a] = DWIN_OUT_FD[b]
    DWIN_OUT_FD[b] = i3
    t4: int64 = DWIN_COLS[a]
    DWIN_COLS[a] = DWIN_COLS[b]
    DWIN_COLS[b] = t4
    t5: int64 = DWIN_ROWS[a]
    DWIN_ROWS[a] = DWIN_ROWS[b]
    DWIN_ROWS[b] = t5
    t6: int64 = DWIN_CUR_C[a]
    DWIN_CUR_C[a] = DWIN_CUR_C[b]
    DWIN_CUR_C[b] = t6
    t7: int64 = DWIN_CUR_R[a]
    DWIN_CUR_R[a] = DWIN_CUR_R[b]
    DWIN_CUR_R[b] = t7
    i4: int32 = DWIN_VT[a]
    DWIN_VT[a] = DWIN_VT[b]
    DWIN_VT[b] = i4
    i5: int32 = DWIN_HIDDEN[a]
    DWIN_HIDDEN[a] = DWIN_HIDDEN[b]
    DWIN_HIDDEN[b] = i5
    i6: int32 = DWIN_VK[a]
    DWIN_VK[a] = DWIN_VK[b]
    DWIN_VK[b] = i6
    i7: int32 = DWIN_WS[a]
    DWIN_WS[a] = DWIN_WS[b]
    DWIN_WS[b] = i7
    i8: int32 = DWIN_MAXED[a]
    DWIN_MAXED[a] = DWIN_MAXED[b]
    DWIN_MAXED[b] = i8
    sx0: int64 = DWIN_SAVE_X[a]
    DWIN_SAVE_X[a] = DWIN_SAVE_X[b]
    DWIN_SAVE_X[b] = sx0
    sy0: int64 = DWIN_SAVE_Y[a]
    DWIN_SAVE_Y[a] = DWIN_SAVE_Y[b]
    DWIN_SAVE_Y[b] = sy0
    sw0: int64 = DWIN_SAVE_W[a]
    DWIN_SAVE_W[a] = DWIN_SAVE_W[b]
    DWIN_SAVE_W[b] = sw0
    sh0: int64 = DWIN_SAVE_H[a]
    DWIN_SAVE_H[a] = DWIN_SAVE_H[b]
    DWIN_SAVE_H[b] = sh0
    i9: int32 = DWIN_APP[a]
    DWIN_APP[a] = DWIN_APP[b]
    DWIN_APP[b] = i9
    i10: int32 = DWIN_SNAP[a]
    DWIN_SNAP[a] = DWIN_SNAP[b]
    DWIN_SNAP[b] = i10
    c0: int64 = CALC_ACC[a]
    CALC_ACC[a] = CALC_ACC[b]
    CALC_ACC[b] = c0
    c1: int64 = CALC_CUR[a]
    CALC_CUR[a] = CALC_CUR[b]
    CALC_CUR[b] = c1
    c2: int32 = CALC_OP[a]
    CALC_OP[a] = CALC_OP[b]
    CALC_OP[b] = c2
    c3: int32 = CALC_FRESH[a]
    CALC_FRESH[a] = CALC_FRESH[b]
    CALC_FRESH[b] = c3
    c4: int32 = CALC_ERR[a]
    CALC_ERR[a] = CALC_ERR[b]
    CALC_ERR[b] = c4
    ab: uint64 = a * GRID_CELLS
    bb: uint64 = b * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        g: uint8 = term_grid[ab + i]
        term_grid[ab + i] = term_grid[bb + i]
        term_grid[bb + i] = g
        i = i + 1


# Destroy window `slot`: tear down its hamsh child + pipes, free the wid
# binding, then compact the table so paint order stays contiguous. Any
# in-flight move/close referencing a shifted slot is reset by the caller.
def daemon_close_slot(slot: int64):
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return
    # Tear down the child shell + the daemon's pipe ends so we don't leak
    # the process or the fds. SIGTERM the bound pid (best-effort), free
    # the wsys slot, and close both parent pipe ends.
    pid: int32 = DWIN_PID[s]
    if pid > 0:
        sys_kill(pid, SIGTERM_D)
    wid: int32 = DWIN_WID[s]
    if wid >= 2:
        sys_wsys_free(wid)
    infd: int32 = DWIN_IN_FD[s]
    if infd >= 0:
        sys_close(infd)
    outfd: int32 = DWIN_OUT_FD[s]
    if outfd >= 0:
        sys_close(outfd)
    # Compact: slide every higher slot down by one so paint order stays
    # a contiguous 0..DWIN_COUNT-1 back-to-front walk.
    last: uint64 = DWIN_COUNT - 1
    j: uint64 = s
    while j < last:
        slot_copy(j, j + 1)
        j = j + 1
    DWIN_COUNT = DWIN_COUNT - 1


# Consume all currently-available mouse packets, updating CUR_X/CUR_Y
# and tracking the left-button edge for the drag gesture. Returns 1 if
# anything changed (cursor moved or button edge), else 0. The /dev/mouse
# fd is held in the mouse_fd global (opened once in cmd_daemon).
mouse_fd: int32 = -1
def daemon_pump_mouse(scr_w: int64, scr_h: int64) -> int32:
    changed: int32 = 0
    iters: int32 = 0
    while iters < 64:
        n: int64 = sys_read_nb(mouse_fd, &mouse_buf[0], 256)
        iters = iters + 1
        if n <= 0:
            break
        i: uint64 = 0
        total: uint64 = cast[uint64](n)
        while i < total:
            ls: uint64 = i
            while i < total and mouse_buf[i] != 10:
                i = i + 1
            le: uint64 = i
            if i < total:
                i = i + 1
            if le > ls:
                changed = daemon_apply_packet(ls, le, scr_w, scr_h) | changed
    return changed


def daemon_apply_packet(ls: uint64, le: uint64,
                        scr_w: int64, scr_h: int64) -> int32:
    # Parse "<dx> <dy> <buttons>" (space-separated, possibly signed).
    pos: Array[1, uint64]
    pos[0] = ls
    dx: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    dy: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    btn: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    # /dev/mouse already reports screen-space deltas: the PS/2 driver
    # (drivers/input/auxmouse.ad) negates the protocol's up-positive Y
    # into framebuffer-down-positive at the single conversion point, so
    # here we just integrate both axes directly. (Negating again was a
    # double-negation that inverted vertical cursor motion.)
    CUR_X = iclamp(CUR_X + dx, 0, scr_w - 1)
    CUR_Y = iclamp(CUR_Y + dy, 0, scr_h - 1)
    lbtn: int32 = 0
    if (btn & 1) != 0:
        lbtn = 1
    # Right button is bit 1 (PS/2 button-2). Drives the context menus.
    rbtn: int32 = 0
    if (btn & 2) != 0:
        rbtn = 1
    # Update the title-bar button hover state every packet so decorations
    # highlight under the moving cursor.
    update_hover()
    wm_rbutton(rbtn, scr_w, scr_h)
    PREV_BTN_R = rbtn
    # Drive the gesture state machine off the integrated cursor + button
    # state. wm_button() handles the press/drag/release edges (move,
    # close, create) using CUR_X/CUR_Y and PREV_BTN_L.
    wm_button(lbtn, scr_w, scr_h)
    PREV_BTN_L = lbtn
    return 1


# Recompute which title-bar button (if any) the cursor is hovering so the
# decoration code can brighten it. Scans the topmost window down.
def update_hover():
    HOVER_SLOT = -1
    HOVER_BTN = -1
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        s: uint64 = cast[uint64](wi)
        if win_on_cur_ws(s) != 0:
            if in_close_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 0
                return
            if in_minimize_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 1
                return
            if in_maximize_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 2
                return
        wi = wi - 1


# Open a file-manager window rooted at `dir` (Places menu action). Uses
# the generalised spawn path with hamfm + the directory as argv[1].
fm_arg_buf: Array[2, uint64]
def places_open(dir: Ptr[char], scr_w: int64, scr_h: int64):
    if DWIN_COUNT >= DMAX:
        return
    w: int64 = 480
    h: int64 = 320
    step: int64 = (LAUNCH_CASCADE % 6) * 28
    rx: int64 = 80 + step
    ry: int64 = PANEL_H + 20 + step
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamfm"), rx, ry, w, h)
    # Feed a "cd <dir>\n" — hamfm reads a path on stdin/argv; we route the
    # directory to the just-spawned window's child stdin so it opens there.
    sl: uint64 = DWIN_COUNT - 1
    wfd: int32 = DWIN_IN_FD[sl]
    if wfd >= 0:
        cmd: Ptr[uint8] = "cd "
        sys_write(wfd, cmd, strlen_u8(cmd))
        sys_write(wfd, cast[Ptr[uint8]](dir), strlen_u8(cast[Ptr[uint8]](dir)))
        nl: Ptr[uint8] = "\n"
        sys_write(wfd, nl, 1)
    pfx: Ptr[uint8] = "PLACES open "
    sys_write(1, pfx, strlen_u8(pfx))
    sys_write(1, cast[Ptr[uint8]](dir), strlen_u8(cast[Ptr[uint8]](dir)))
    sys_write(1, "\n", 1)


# Open the built-in "About Hamnix" info card (System menu). This is a
# real in-process DE window drawn by app_about_pixel — no child process.
def system_about(scr_w: int64, scr_h: int64):
    rw: int64 = 360
    rh: int64 = 180
    rx: int64 = scr_w / 2 - rw / 2
    ry: int64 = scr_h / 2 - rh / 2
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    if rx + rw > scr_w:
        rx = scr_w - rw
    daemon_spawn_app(APP_ABOUT, rx, ry, rw, rh)
    pfx: Ptr[uint8] = "SYSTEM about\n"
    sys_write(1, pfx, strlen_u8(pfx))


# Invoke item `i` of the open menu-bar drop-down `m`.
def menubar_invoke(m: int32, i: uint64, scr_w: int64, scr_h: int64):
    if m == 0:
        menu_launch(i, scr_w, scr_h)
        return
    if m == 1:
        if i == 0:
            places_open(cast[Ptr[char]]("/home"), scr_w, scr_h)
        elif i == 1:
            places_open(cast[Ptr[char]]("/"), scr_w, scr_h)
        else:
            places_open(cast[Ptr[char]]("/tmp"), scr_w, scr_h)
        return
    if m == 2:
        if i == 0:
            # System Monitor: open the built-in live-stats app window.
            smx: int64 = 100
            smy: int64 = PANEL_H + 30
            smw: int64 = 360
            smh: int64 = 220
            if smx + smw > scr_w:
                smx = scr_w - smw
            daemon_spawn_app(APP_SYSMON, smx, smy, smw, smh)
            sm: Ptr[uint8] = "SYSTEM launch System Monitor\n"
            sys_write(1, sm, strlen_u8(sm))
        elif i == 1:
            system_about(scr_w, scr_h)
        elif i == 2:
            # Reload DE: re-seed the desktop chrome state (a real action —
            # closes all menus + re-presents). A serial marker proves it.
            MENU_BAR_OPEN = -1
            MENU_OPEN = 0
            CTX_OPEN = 0
            rl: Ptr[uint8] = "SYSTEM reload DE\n"
            sys_write(1, rl, strlen_u8(rl))
        elif i == 3:
            workspace_switch(CUR_WS + 1)
        elif i == 4:
            workspace_switch(CUR_WS - 1)
        else:
            # Log Out: request a clean daemon shutdown so the console
            # returns to the foreground shell.
            DAEMON_QUIT = 1
            lo: Ptr[uint8] = "SYSTEM Log Out\n"
            sys_write(1, lo, strlen_u8(lo))
        return


# Invoke item `i` of the open right-click context menu.
def ctx_invoke(i: uint64, scr_w: int64, scr_h: int64):
    if CTX_KIND == 0:
        # Desktop menu: New Terminal / Reload DE.
        if i == 0:
            rx: int64 = CTX_X
            ry: int64 = CTX_Y
            if ry < PANEL_H:
                ry = PANEL_H
            daemon_spawn_window(rx, ry, 480, 320)
            nt: Ptr[uint8] = "CTX new-terminal\n"
            sys_write(1, nt, strlen_u8(nt))
        else:
            MENU_BAR_OPEN = -1
            MENU_OPEN = 0
            rl: Ptr[uint8] = "SYSTEM reload DE\n"
            sys_write(1, rl, strlen_u8(rl))
        return
    # Window menu — act on CTX_SLOT.
    if CTX_SLOT < 0:
        return
    s: uint64 = cast[uint64](CTX_SLOT)
    if s >= DWIN_COUNT:
        return
    if i == 0:
        DWIN_HIDDEN[s] = 1
        mm: Ptr[uint8] = "WM minimize window\n"
        sys_write(1, mm, strlen_u8(mm))
    elif i == 1:
        window_toggle_maximize(s, scr_w, scr_h)
    elif i == 2:
        window_to_workspace(s, CUR_WS + 1)
    elif i == 3:
        nws: int32 = CUR_WS - 1
        if nws < 0:
            nws = WS_COUNT - 1
        window_to_workspace(s, nws)
    else:
        daemon_close_slot(CTX_SLOT)
        cw: Ptr[uint8] = "WM close window\n"
        sys_write(1, cw, strlen_u8(cw))


# Right-button gesture machine. On the DOWN edge it opens a context menu:
# over a window's title bar -> the window menu; over the empty desktop ->
# the desktop menu. A left click elsewhere dismisses it (handled in
# wm_button). Factored out so the self-test can drive it directly.
def wm_rbutton(rbtn: int32, scr_w: int64, scr_h: int64):
    if rbtn != 0 and PREV_BTN_R == 0:
        # Right-click while a context menu is open closes it (toggle).
        if CTX_OPEN != 0:
            CTX_OPEN = 0
            return
        # Right-click on the panel does nothing (reserved).
        if in_panel(CUR_X, CUR_Y) != 0:
            return
        hit: int64 = window_at(CUR_X, CUR_Y)
        if hit >= 0 and in_title_bar(cast[uint64](hit), CUR_X, CUR_Y) != 0:
            ctx_open_at(1, hit, CUR_X, CUR_Y, scr_w, scr_h)
            wm: Ptr[uint8] = "CTX window-menu\n"
            sys_write(1, wm, strlen_u8(wm))
        else:
            ctx_open_at(0, -1, CUR_X, CUR_Y, scr_w, scr_h)
            dm: Ptr[uint8] = "CTX desktop-menu\n"
            sys_write(1, dm, strlen_u8(dm))


# Gesture state machine, driven by the current left-button level (lbtn:
# 0/1) and the absolute cursor at CUR_X/CUR_Y. Detects the press edge
# (against PREV_BTN_L), tracks an in-flight move while held, and resolves
# move/close/create on the release edge. Factored out so the daemon
# self-test can drive it directly with absolute coordinates (no /dev/mouse
# packet round-trip).
def wm_button(lbtn: int32, scr_w: int64, scr_h: int64):
    # --- left-button DOWN edge: classify the gesture ---
    if lbtn != 0 and PREV_BTN_L == 0:
        # CONTEXT MENU first — an open right-click menu eats the next click.
        if CTX_OPEN != 0:
            ci: int64 = ctx_item_at(CUR_X, CUR_Y)
            CTX_OPEN = 0                        # any click closes it
            if ci >= 0:
                ctx_invoke(cast[uint64](ci), scr_w, scr_h)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # PANEL / MENU BAR next — desktop chrome intercepts the press before
        # any window/drag-create logic so the launcher never also starts a
        # rubber-band window.
        #   * press on a top-level menu button -> toggle that drop-down
        #   * press on an open drop-down item  -> invoke it + close the menu
        #   * press elsewhere while a menu is open -> dismiss it
        mbhit: int32 = menubar_btn_at(CUR_X, CUR_Y)
        if mbhit >= 0:
            if MENU_BAR_OPEN == mbhit:
                MENU_BAR_OPEN = -1
                mc: Ptr[uint8] = "PANEL close menu\n"
                sys_write(1, mc, strlen_u8(mc))
            else:
                MENU_BAR_OPEN = mbhit
                mo: Ptr[uint8] = "PANEL open menu "
                sys_write(1, mo, strlen_u8(mo))
                write_str(1, menubar_label(mbhit))
                write_str(1, "\n")
            DRAG_ACTIVE = 0
            GESTURE = 3                        # panel: no up-edge action
            return
        if MENU_BAR_OPEN >= 0:
            mi: int64 = menubar_item_at(CUR_X, CUR_Y)
            opened: int32 = MENU_BAR_OPEN
            MENU_BAR_OPEN = -1                   # any click closes the menu
            if mi >= 0:
                menubar_invoke(opened, cast[uint64](mi), scr_w, scr_h)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- workspace pager click: switch to the clicked desktop ---
        pcell: int64 = pager_cell_at(CUR_X, CUR_Y, scr_w)
        if pcell >= 0:
            workspace_switch(cast[int32](pcell))
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- taskbar button click: raise/restore the clicked window ---
        tslot: int64 = taskbar_slot_at(CUR_X, CUR_Y, scr_w)
        if tslot >= 0:
            ts: uint64 = cast[uint64](tslot)
            if DWIN_HIDDEN[ts] != 0:
                # Restore: un-minimize then raise to focus.
                DWIN_HIDDEN[ts] = 0
                daemon_raise_slot(tslot)
                tb_pfx: Ptr[uint8] = "TASKBAR restore "
                sys_write(1, tb_pfx, strlen_u8(tb_pfx))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            else:
                # Raise the window (give it focus).
                daemon_raise_slot(tslot)
                tb_pfx2: Ptr[uint8] = "TASKBAR raise "
                sys_write(1, tb_pfx2, strlen_u8(tb_pfx2))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        if in_panel(CUR_X, CUR_Y) != 0:
            # Press on the panel bar (not the button) — swallow it so the
            # panel can never start a drag-create underneath itself.
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # Hit-test the topmost window under the cursor. A press on a
        # window's close box arms a close; a press on its title bar
        # starts a move (and raises it on top); anything else (empty
        # desktop, or a window body) begins a rubber-band create drag.
        hit: int64 = window_at(CUR_X, CUR_Y)
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1
        DRAG_ACTIVE = 0
        started_wm: int32 = 0
        if hit >= 0:
            hs: uint64 = cast[uint64](hit)
            if in_close_box(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 2                  # close: confirm on the up-edge
                CLOSE_SLOT = hit
                started_wm = 1
            elif in_minimize_box(hs, CUR_X, CUR_Y) != 0:
                # Minimize on press (immediate, no release confirm needed).
                DWIN_HIDDEN[hs] = 1
                GESTURE = 3                  # minimize: no further up-edge
                started_wm = 1
                mm: Ptr[uint8] = "WM minimize window\n"
                sys_write(1, mm, strlen_u8(mm))
            elif in_maximize_box(hs, CUR_X, CUR_Y) != 0:
                # Maximize / restore toggle (immediate on press).
                window_toggle_maximize(hs, scr_w, scr_h)
                GESTURE = 3                  # no further up-edge action
                started_wm = 1
            elif in_title_bar(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 1                  # move
                # Raise the grabbed window to the top so it tracks above
                # the others, then capture the cursor->origin offset.
                hit = daemon_raise_slot(hit)
                hs = cast[uint64](hit)
                # If the window is snapped/maximized, un-snap it to its
                # float size first so dragging detaches it (GNOME feel).
                # Keep the cursor roughly over the title after the resize.
                if DWIN_SNAP[hs] != 0:
                    snap_apply(hs, 0, scr_w, scr_h)
                    if CUR_X > DWIN_X[hs] + DWIN_W[hs]:
                        DWIN_X[hs] = CUR_X - DWIN_W[hs] / 2
                        if DWIN_X[hs] < 0:
                            DWIN_X[hs] = 0
                MOVE_SLOT = hit
                MOVE_OFF_X = CUR_X - DWIN_X[hs]
                MOVE_OFF_Y = CUR_Y - DWIN_Y[hs]
                started_wm = 1
                m1: Ptr[uint8] = "WM move start\n"
                sys_write(1, m1, strlen_u8(m1))
            else:
                # Press inside a window body (not title, not close-box):
                # raise the window to the top to give it keyboard focus.
                # We do NOT start a rubber-band drag — the user clicked
                # inside an existing window to interact with its shell.
                # For built-in app windows, also route the click to the
                # app so e.g. the calculator keypad responds.
                if DWIN_APP[hs] == APP_CALC:
                    cell: int64 = calc_cell_at(hs, CUR_X, CUR_Y)
                    if cell >= 0:
                        calc_press(hs, calc_key_label(cell))
                        ck: Ptr[uint8] = "CALC key\n"
                        sys_write(1, ck, strlen_u8(ck))
                hit = daemon_raise_slot(hit)
                GESTURE = 3                  # body-focus: no up-edge action
                started_wm = 1
                m2: Ptr[uint8] = "WM focus window\n"
                sys_write(1, m2, strlen_u8(m2))
        if started_wm == 0:
            # No window-management gesture -> the empty-desktop
            # rubber-band create drag (unchanged behaviour).
            GESTURE = 0
            DRAG_ACTIVE = 1
            DRAG_X0 = CUR_X
            DRAG_Y0 = CUR_Y
    # --- button held: a move tracks the window under the grab ---
    if lbtn != 0 and GESTURE == 1 and MOVE_SLOT >= 0:
        ms: uint64 = cast[uint64](MOVE_SLOT)
        nx: int64 = CUR_X - MOVE_OFF_X
        ny: int64 = CUR_Y - MOVE_OFF_Y
        # Clamp so the window stays on-screen and never draws outside the
        # framebuffer. The top is clamped to PANEL_H so a window's title
        # bar can never slide under the panel and become un-grabbable.
        nx = iclamp(nx, 0, scr_w - DWIN_W[ms])
        ny = iclamp(ny, PANEL_H, scr_h - DWIN_H[ms])
        if nx < 0:
            nx = 0
        if ny < PANEL_H:
            ny = PANEL_H
        DWIN_X[ms] = nx
        DWIN_Y[ms] = ny
    # --- left-button UP edge: resolve the gesture ---
    if lbtn == 0 and PREV_BTN_L != 0:
        if GESTURE == 2:
            # Close only if the release lands in the SAME window's close
            # box (rio-style click cancellation on drag-off).
            if CLOSE_SLOT >= 0:
                cs: uint64 = cast[uint64](CLOSE_SLOT)
                if cs < DWIN_COUNT and in_close_box(cs, CUR_X, CUR_Y) != 0:
                    daemon_close_slot(CLOSE_SLOT)
                    m2: Ptr[uint8] = "WM close window\n"
                    sys_write(1, m2, strlen_u8(m2))
        elif GESTURE == 1 and MOVE_SLOT >= 0:
            # Move finished — log the window's final origin so a
            # non-pixel test can assert it relocated.
            mvs: uint64 = cast[uint64](MOVE_SLOT)
            mline: Array[64, uint8]
            mp: uint64 = 0
            mpfx: Ptr[uint8] = "WM move done x="
            mk: uint64 = 0
            while mpfx[mk] != 0:
                mline[mp] = mpfx[mk]
                mp = mp + 1
                mk = mk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_X[mvs]), &mline[mp])
            # drop u64_to_dec's trailing newline, append " y="
            mp = mp - 1
            ysfx: Ptr[uint8] = " y="
            yk: uint64 = 0
            while ysfx[yk] != 0:
                mline[mp] = ysfx[yk]
                mp = mp + 1
                yk = yk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_Y[mvs]), &mline[mp])
            sys_write(1, &mline[0], mp)
            # --- edge tiling: snap based on where the release landed ---
            # Top edge (cursor at/under the panel) -> maximize.
            # Left/right screen edge -> half-tile.
            if CUR_Y <= PANEL_H + SNAP_EDGE:
                snap_apply(mvs, 1, scr_w, scr_h)
                sn: Ptr[uint8] = "WM snap top\n"
                sys_write(1, sn, strlen_u8(sn))
            elif CUR_X <= SNAP_EDGE:
                snap_apply(mvs, 2, scr_w, scr_h)
                sl: Ptr[uint8] = "WM snap left\n"
                sys_write(1, sl, strlen_u8(sl))
            elif CUR_X >= scr_w - 1 - SNAP_EDGE:
                snap_apply(mvs, 3, scr_w, scr_h)
                sr: Ptr[uint8] = "WM snap right\n"
                sys_write(1, sr, strlen_u8(sr))
        elif GESTURE == 0 and DRAG_ACTIVE != 0:
            # Empty-desktop drag -> maybe spawn a window.
            rx0: int64 = imin(DRAG_X0, CUR_X)
            ry0: int64 = imin(DRAG_Y0, CUR_Y)
            rx1: int64 = imax(DRAG_X0, CUR_X)
            ry1: int64 = imax(DRAG_Y0, CUR_Y)
            rw: int64 = rx1 - rx0
            rh: int64 = ry1 - ry0
            if rw >= DRAG_MIN and rh >= DRAG_MIN:
                daemon_spawn_window(rx0, ry0, rw, rh)
        # Reset all gesture state.
        DRAG_ACTIVE = 0
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1


def next_signed(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip up to a sign or digit, parse a (possibly signed) decimal.
    i: uint64 = pos[0]
    while i < total and buf[i] != 45 and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    neg: int32 = 0
    if i < total and buf[i] == 45:
        neg = 1
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    if neg != 0:
        return 0 - v
    return v


# Mouse-free WM self-test: drive a title-bar drag-move then a close-box
# click on the just-created autowin by calling the real gesture machine
# (wm_button) directly with ABSOLUTE cursor coordinates. This exercises
# the identical move/close/raise code paths a /dev/mouse packet would,
# but skips the packet string encode/decode round-trip entirely so the
# coordinates are exact and the result is deterministic.
def daemon_wm_selftest(scr_w: int64, scr_h: int64):
    if DWIN_COUNT == 0:
        return
    s: uint64 = DWIN_COUNT - 1
    PREV_BTN_L = 0
    # --- title-bar press: position the cursor inside the title bar (not
    # on the close box) and assert the left button down-edge. ---
    CUR_X = iclamp(DWIN_X[s] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[s] + TITLE_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- drag: relocate the cursor LEFT 200 / UP 30 with the button held;
    # wm_button tracks the grabbed window to follow. ---
    CUR_X = iclamp(CUR_X - 200, 0, scr_w - 1)
    CUR_Y = iclamp(CUR_Y - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- release: finalise the move (emits "WM move done x= y="). ---
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # The move raised the grabbed window to the top, so re-resolve its
    # slot (raise_slot bubbles it to DWIN_COUNT-1).
    cs: uint64 = DWIN_COUNT - 1
    # --- close: move the cursor onto the (relocated) window's close box,
    # then press+release inside it to destroy the window. ---
    CUR_X = iclamp(close_box_x(cs) + CLOSE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(close_box_y(cs) + CLOSE_BOX / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)       # press in close box -> arm close
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)       # release in close box -> destroy
    PREV_BTN_L = 0
    write_str(1, "DAEMON wm selftest done\n")


# Mouse-free PANEL/MENU self-test: drives the launcher through the SAME
# gesture machine (wm_button) real /dev/mouse packets reach, with
# absolute cursor coordinates. Sequence:
#   1. click the Applications button  -> "PANEL open menu"
#   2. click the first menu item      -> launches Terminal, closes menu
#                                        ("PANEL launch Terminal", a window)
#   3. click the button + an off-menu spot to prove open/dismiss is stable.
# Emits "DAEMON panel selftest done" at the end. No QEMU mouse injection.
def daemon_panel_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    MENU_OPEN = 0
    # --- click the Applications button: open the menu ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- click the FIRST menu item: launch it + auto-close the menu ---
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H + MENU_ITEM_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- re-open, then dismiss by clicking an off-menu desktop spot ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # Click far down on the empty desktop -> menu dismisses (no launch).
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "DAEMON panel selftest done\n")


# Terminal I/O self-test.
#
# Verifies the per-window stdin→shell→stdout→grid pipeline without a
# physical display or mouse, using the SAME pipe fds daemon_spawn_window
# created. Sequence:
#   1. Create one autowin (hamsh with real pipes).
#   2. Write "echo HAMUI_TERM_TEST\n" immediately to its stdin pipe.
#      The command sits in the pipe buffer until hamsh reads it.
#      (hamsh skips the getty-flush loop when stdin is DEVFD_PIPE_R,
#      so the bytes are NOT discarded — they arrive on the first
#      sys_read_nb(0,...) poll inside ed_readline.)
#   3. Non-blocking poll (sys_read_nb + sys_yield) the stdout pipe
#      until "HAMUI_TERM_TEST" appears in the terminal grid or the
#      idle counter (200000 empty reads) is exhausted.
#   4. Check the grid. PASS if the sentinel is present.
#
# Also verifies the focus-switch routing: create a SECOND window, click
# its body (synthetic wm_button on its body area) and confirm the focus
# slot switches, then route a second sentinel to that window.
#
# Emits "TERM IO PASS" / "TERM IO FAIL <reason>" on stdout.
# autoflag=5 in cmd_daemon_auto activates this test.
#
# ---- Taskbar / minimize / clock self-test (autoflag == 6) ----------
# Exercises the three new panel features deterministically without
# QEMU mouse injection:
#
#   1. TASKBAR: create two windows, assert DWIN_COUNT == 2, assert each
#      taskbar_btn_x() is within the panel, emit "TASKBAR 2 windows".
#   2. FOCUS via taskbar: simulate a taskbar click on slot 0 (lower window)
#      and assert it becomes the topmost slot (daemon_focus_slot()==1 after
#      raise), emit "TASKBAR focus OK".
#   3. MINIMIZE: simulate a minimize-box click on the topmost window, assert
#      DWIN_HIDDEN becomes 1, emit "TASKBAR minimize OK".
#   4. RESTORE: simulate a taskbar click on the minimized window, assert
#      DWIN_HIDDEN becomes 0, emit "TASKBAR restore OK".
#   5. CLOCK: call clock_refresh(0), assert clock_str is non-empty (not all
#      '?'), emit "TASKBAR clock OK" or "TASKBAR clock UNAVAILABLE".
#
# Emits "TASKBAR PASS" at the end.  autoflag==6 activates this test.
def daemon_taskbar_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    # --- Step 1: create two windows ---
    daemon_spawn_window(200, 80, 300, 200)
    daemon_spawn_window(300, 120, 300, 200)
    if DWIN_COUNT < 2:
        write_str(1, "TASKBAR FAIL: fewer than 2 windows spawned\n")
        return
    write_str(1, "TASKBAR 2 windows\n")
    # Assert taskbar buttons are within the screen (not off-screen).
    tb0x: int64 = taskbar_btn_x(0)
    tb1x: int64 = taskbar_btn_x(1)
    if tb0x < taskbar_start_x() or tb1x <= tb0x:
        write_str(1, "TASKBAR FAIL: bad button geometry\n")
        return
    write_str(1, "TASKBAR geometry OK\n")
    # --- Step 2: taskbar click on slot 0 to raise it ---
    # After two spawns, slot 0 = first window, slot 1 = topmost.
    # Click the taskbar button for slot 0.
    CUR_X = iclamp(tb0x + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise slot 0 should now be at DWIN_COUNT-1 (topmost / focused).
    new_top: int64 = daemon_focus_slot()
    if new_top < 0:
        write_str(1, "TASKBAR FAIL: no focused window after taskbar raise\n")
        return
    write_str(1, "TASKBAR focus OK\n")
    # --- Step 3: minimize the topmost window via its minimize box ---
    top_s: uint64 = cast[uint64](new_top)
    mx: int64 = iclamp(minimize_box_x(top_s) + MINIMIZE_BOX / 2, 0, scr_w - 1)
    my: int64 = iclamp(minimize_box_y(top_s) + MINIMIZE_BOX / 2, 0, scr_h - 1)
    CUR_X = mx
    CUR_Y = my
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_HIDDEN[top_s] == 0:
        write_str(1, "TASKBAR FAIL: minimize did not set DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR minimize OK\n")
    # --- Step 4: restore via taskbar click ---
    # The minimized window is still at slot top_s in the table.
    rst_tbx: int64 = taskbar_btn_x(top_s)
    CUR_X = iclamp(rst_tbx + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After restore DWIN_HIDDEN should be 0 (the window is visible again).
    # The slot may have been raised, so scan all slots for HIDDEN==0.
    all_visible: int32 = 1
    ci: uint64 = 0
    while ci < DWIN_COUNT:
        if DWIN_HIDDEN[ci] != 0:
            all_visible = 0
        ci = ci + 1
    if all_visible == 0:
        write_str(1, "TASKBAR FAIL: restore did not clear DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR restore OK\n")
    # --- Step 5: clock refresh ---
    clock_refresh(0)
    # The clock string should be non-empty (first char is a digit or '?').
    clk_ok: int32 = 0
    if clock_str[0] != 0:
        clk_ok = 1
    if clk_ok != 0:
        if clock_str[0] == 63:
            write_str(1, "TASKBAR clock UNAVAILABLE\n")
        else:
            write_str(1, "TASKBAR clock OK\n")
    else:
        write_str(1, "TASKBAR FAIL: clock_str empty after refresh\n")
        return
    write_str(1, "TASKBAR PASS\n")


# ====================================================================
# WORKSPACE self-test (autoflag == 9)
# ====================================================================
# Verifies MATE virtual desktops + the pager applet deterministically,
# sampling composited pixels so it works with no GUI:
#   1. Create a window on workspace 1; sample a body pixel -> visible.
#   2. Switch to workspace 2 (via workspace_switch); the SAME body pixel
#      must now be the desktop backdrop (window hidden by ws filter).
#   3. Switch back to workspace 1; the body pixel is visible again.
#   4. Pager click: synthesise a left-click on pager cell 3 and assert
#      CUR_WS becomes 2 (0-based) i.e. desktop 3.
#   5. F-key hotkey path: call workspace_switch directly via the same
#      entry the key pump uses; assert it lands.
# Emits "[DE_ws] PASS" / "[DE_ws] FAIL <reason>".
def daemon_workspace_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    # --- Step 1: window on workspace 1 (CUR_WS==0) ---
    win_x: int64 = 300
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 220
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[DE_ws] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    # A body pixel (clear of title bar + borders).
    bx: int64 = DWIN_X[sl] + DWIN_W[sl] / 2
    by: int64 = DWIN_Y[sl] + TITLE_H + 30
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    s1: uint64 = daemon_screen_sample(bx, by)
    if s1 == bg:
        write_str(1, "[DE_ws] FAIL window not visible on its own workspace\n")
        return
    write_str(1, "[DE_ws] window visible on ws1\n")
    # --- Step 2: switch to workspace 2; body pixel must be backdrop ---
    workspace_switch(1)
    if CUR_WS != 1:
        write_str(1, "[DE_ws] FAIL workspace_switch did not change CUR_WS\n")
        return
    s2: uint64 = daemon_screen_sample(bx, by)
    if s2 != bg:
        write_str(1, "[DE_ws] FAIL window still visible after ws switch\n")
        return
    write_str(1, "[DE_ws] window hidden on ws2\n")
    # --- Step 3: switch back; window visible again ---
    workspace_switch(0)
    s3: uint64 = daemon_screen_sample(bx, by)
    if s3 == bg:
        write_str(1, "[DE_ws] FAIL window not restored on ws1\n")
        return
    write_str(1, "[DE_ws] window restored on ws1\n")
    # --- Step 4: pager click switches workspace ---
    px0: int64 = pager_x0(scr_w)
    cell3_cx: int64 = px0 + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    CUR_X = iclamp(cell3_cx, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CUR_WS != 2:
        write_str(1, "[DE_ws] FAIL pager click did not switch workspace\n")
        return
    write_str(1, "[DE_ws] pager click OK\n")
    # --- Step 5: hotkey-path workspace switch (same entry the key pump uses) ---
    workspace_switch(0)
    if CUR_WS != 0:
        write_str(1, "[DE_ws] FAIL hotkey-path switch failed\n")
        return
    write_str(1, "[DE_ws] hotkey path OK\n")
    daemon_present()
    write_str(1, "[DE_ws] PASS\n")


# ====================================================================
# DECORATION self-test (autoflag == 10)
# ====================================================================
# Verifies the MATE-style themed window decorations by sampling pixels:
#   1. Title-bar gradient: the top row and bottom row of an active
#      window's title bar must differ (a real gradient, not a flat fill).
#   2. Beveled border: the top-left outer corner is the light highlight
#      tint, the bottom-right outer corner is the dark shadow tint.
#   3. Maximize button: a pixel inside the maximize box is the button
#      colour (green-ish), and the box hit-tests true.
#   4. Maximize/restore toggle: click the maximize box; the window fills
#      the work area; click again; it returns to its saved rectangle.
# Emits "[DE_deco] PASS" / "[DE_deco] FAIL <reason>".
def daemon_decoration_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    win_x: int64 = 200
    win_y: int64 = 140
    win_w: int64 = 360
    win_h: int64 = 240
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[DE_deco] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wx: int64 = DWIN_X[sl]
    wy: int64 = DWIN_Y[sl]
    ww: int64 = DWIN_W[sl]
    wh: int64 = DWIN_H[sl]
    # --- Step 1: title-bar gradient (top vs bottom rows differ) ---
    tx: int64 = wx + ww / 2          # mid title bar, clear of buttons + text
    top_px: uint64 = daemon_screen_sample(tx, wy + 3)
    bot_px: uint64 = daemon_screen_sample(tx, wy + TITLE_H - 2)
    if top_px == bot_px:
        write_str(1, "[DE_deco] FAIL title bar is flat (no gradient)\n")
        return
    write_str(1, "[DE_deco] title gradient OK\n")
    # --- Step 2: beveled border corners ---
    tl: uint64 = daemon_screen_sample(wx, wy)
    br: uint64 = daemon_screen_sample(wx + ww - 1, wy + wh - 1)
    hi: uint64 = (cast[uint64](BEVEL_HI_R) << 16) \
        | (cast[uint64](BEVEL_HI_G) << 8) | cast[uint64](BEVEL_HI_B)
    lo: uint64 = (cast[uint64](BEVEL_LO_R) << 16) \
        | (cast[uint64](BEVEL_LO_G) << 8) | cast[uint64](BEVEL_LO_B)
    if tl != hi:
        write_str(1, "[DE_deco] FAIL top-left corner not highlight bevel\n")
        return
    if br != lo:
        write_str(1, "[DE_deco] FAIL bottom-right corner not shadow bevel\n")
        return
    write_str(1, "[DE_deco] beveled border OK\n")
    # --- Step 3: maximize button present ---
    if in_maximize_box(sl, maximize_box_x(sl) + 1, maximize_box_y(sl) + 1) == 0:
        write_str(1, "[DE_deco] FAIL maximize box hit-test failed\n")
        return
    write_str(1, "[DE_deco] maximize button OK\n")
    # --- Step 4: maximize/restore toggle via the maximize box click ---
    sav_w: int64 = DWIN_W[sl]
    sav_h: int64 = DWIN_H[sl]
    CUR_X = iclamp(maximize_box_x(sl) + MAXIMIZE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(maximize_box_y(sl) + MAXIMIZE_BOX / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_MAXED[sl] == 0:
        write_str(1, "[DE_deco] FAIL maximize did not set MAXED\n")
        return
    if DWIN_W[sl] != scr_w or DWIN_H[sl] != scr_h - PANEL_H:
        write_str(1, "[DE_deco] FAIL maximized geometry wrong\n")
        return
    write_str(1, "[DE_deco] maximize OK\n")
    # Restore: click the (relocated) maximize box again.
    CUR_X = iclamp(maximize_box_x(sl) + MAXIMIZE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(maximize_box_y(sl) + MAXIMIZE_BOX / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_MAXED[sl] != 0:
        write_str(1, "[DE_deco] FAIL restore did not clear MAXED\n")
        return
    if DWIN_W[sl] != sav_w or DWIN_H[sl] != sav_h:
        write_str(1, "[DE_deco] FAIL restore geometry not original\n")
        return
    write_str(1, "[DE_deco] restore OK\n")
    daemon_present()
    write_str(1, "[DE_deco] PASS\n")


# ====================================================================
# CONTEXT-MENU self-test (autoflag == 11)
# ====================================================================
# Verifies right-click context menus + the GNOME2 menu bar:
#   1. Menu bar: three top-level buttons hit-test (Applications/Places/
#      System); open Applications via wm_button + assert MENU_BAR_OPEN.
#   2. Desktop context menu: right-click empty desktop (wm_rbutton) opens
#      a 2-item menu (CTX_OPEN, CTX_KIND==0); sample a menu pixel to prove
#      it composites; left-click item 0 spawns a New Terminal window.
#   3. Window context menu: right-click a window title bar opens the
#      window menu (CTX_KIND==1); left-click "Close" destroys the window.
# Emits "[DE_ctx] PASS" / "[DE_ctx] FAIL <reason>".
def daemon_ctxmenu_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    # --- Step 1: menu bar hit-test + open ---
    if menubar_btn_at(menubar_btn_x(0) + 2, PANEL_H / 2) != 0:
        write_str(1, "[DE_ctx] FAIL Applications button hit-test\n")
        return
    if menubar_btn_at(menubar_btn_x(2) + 2, PANEL_H / 2) != 2:
        write_str(1, "[DE_ctx] FAIL System button hit-test\n")
        return
    write_str(1, "[DE_ctx] menu bar geometry OK\n")
    CUR_X = iclamp(menubar_btn_x(0) + 4, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if MENU_BAR_OPEN != 0:
        write_str(1, "[DE_ctx] FAIL Applications menu did not open\n")
        return
    write_str(1, "[DE_ctx] Applications menu open\n")
    # Close it again (click the same button).
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- Step 2: desktop context menu via right-click ---
    CUR_X = iclamp(scr_w / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h / 2, 0, scr_h - 1)
    PREV_BTN_R = 0
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    wm_rbutton(0, scr_w, scr_h)
    PREV_BTN_R = 0
    if CTX_OPEN == 0 or CTX_KIND != 0:
        write_str(1, "[DE_ctx] FAIL desktop context menu did not open\n")
        return
    # Sample a pixel inside the menu body to prove it composites.
    msx: int64 = CTX_X + CTX_W / 2
    msy: int64 = CTX_Y + CTX_ITEM_H / 2
    mpx: uint64 = daemon_screen_sample(msx, msy)
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    if mpx == bg:
        write_str(1, "[DE_ctx] FAIL context menu not composited\n")
        return
    write_str(1, "[DE_ctx] desktop context menu OK\n")
    # Left-click item 0 (New Terminal) -> spawns a window.
    before: uint64 = DWIN_COUNT
    CUR_X = iclamp(CTX_X + CTX_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(CTX_Y + CTX_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT <= before:
        write_str(1, "[DE_ctx] FAIL New Terminal did not spawn a window\n")
        return
    if CTX_OPEN != 0:
        write_str(1, "[DE_ctx] FAIL context menu did not close on click\n")
        return
    write_str(1, "[DE_ctx] New Terminal spawned\n")
    # --- Step 3: window context menu -> Close ---
    sl: uint64 = DWIN_COUNT - 1
    # Right-click the window's title bar.
    CUR_X = iclamp(DWIN_X[sl] + 40, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[sl] + TITLE_H / 2, 0, scr_h - 1)
    PREV_BTN_R = 0
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    wm_rbutton(0, scr_w, scr_h)
    PREV_BTN_R = 0
    if CTX_OPEN == 0 or CTX_KIND != 1:
        write_str(1, "[DE_ctx] FAIL window context menu did not open\n")
        return
    write_str(1, "[DE_ctx] window context menu OK\n")
    # Click the LAST item ("Close").
    last_item: int64 = cast[int64](ctx_count()) - 1
    wcnt: uint64 = DWIN_COUNT
    CUR_X = iclamp(CTX_X + CTX_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(CTX_Y + last_item * CTX_ITEM_H + CTX_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT >= wcnt:
        write_str(1, "[DE_ctx] FAIL Close did not destroy the window\n")
        return
    write_str(1, "[DE_ctx] window closed via context menu\n")
    daemon_present()
    write_str(1, "[DE_ctx] PASS\n")


# ---- Desktop-apps + snapping self-test (autoflag == 12) ------------
# Exercises the new built-in apps and window snapping deterministically
# (no mouse injection): a calculator computes 7+8=15 + a div-by-zero
# guard, the System Monitor refreshes live stats, and a window snaps to
# the left half then maximizes/restores. Emits "APPS PASS" on success,
# "APPS FAIL <reason>" otherwise.
apps_test_buf: Array[24, uint8]
def daemon_apps_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: calculator window + 7 + 8 = 15 ---
    daemon_spawn_app(APP_CALC, 100, 80, 220, 300)
    if DWIN_COUNT == 0:
        write_str(1, "APPS FAIL: calc not spawned\n")
        return
    cs: uint64 = DWIN_COUNT - 1
    if DWIN_APP[cs] != APP_CALC:
        write_str(1, "APPS FAIL: window is not a calculator\n")
        return
    write_str(1, "APPS calc window OK\n")
    calc_press(cs, 55)            # '7'
    calc_press(cs, 43)            # '+'
    calc_press(cs, 56)            # '8'
    calc_press(cs, 61)            # '='
    n: uint64 = calc_format(cs, &apps_test_buf[0])
    if n != 2 or apps_test_buf[0] != 49 or apps_test_buf[1] != 53:
        write_str(1, "APPS FAIL: 7+8 did not equal 15\n")
        return
    write_str(1, "APPS calc 7+8=15 OK\n")
    # Divide-by-zero -> error flag.
    calc_press(cs, 67)            # 'C'
    calc_press(cs, 53)            # '5'
    calc_press(cs, 47)            # '/'
    calc_press(cs, 48)            # '0'
    calc_press(cs, 61)            # '='
    if CALC_ERR[cs] == 0:
        write_str(1, "APPS FAIL: div-by-zero not flagged\n")
        return
    write_str(1, "APPS calc div0 OK\n")
    # --- Step 2: system monitor refresh ---
    daemon_spawn_app(APP_SYSMON, 360, 80, 360, 220)
    sysmon_refresh(0)
    if sysmon_line1[0] == 0:
        write_str(1, "APPS FAIL: sysmon line empty\n")
        return
    write_str(1, "APPS sysmon OK\n")
    # --- Step 3: snapping (left half, then maximize toggle/restore) ---
    sm_slot: uint64 = DWIN_COUNT - 1
    float_x: int64 = DWIN_X[sm_slot]
    float_w: int64 = DWIN_W[sm_slot]
    snap_apply(sm_slot, 2, scr_w, scr_h)   # left half
    if DWIN_X[sm_slot] != 0 or DWIN_W[sm_slot] != scr_w / 2 or DWIN_SNAP[sm_slot] != 2:
        write_str(1, "APPS FAIL: left-snap geometry wrong\n")
        return
    write_str(1, "APPS snap-left OK\n")
    # Toggle maximize while snapped restores to the saved float geometry.
    window_toggle_maximize(sm_slot, scr_w, scr_h)
    if DWIN_SNAP[sm_slot] != 0 or DWIN_X[sm_slot] != float_x or DWIN_W[sm_slot] != float_w:
        write_str(1, "APPS FAIL: restore from snap wrong\n")
        return
    write_str(1, "APPS restore OK\n")
    # Toggle maximize from float -> maximized full-screen.
    window_toggle_maximize(sm_slot, scr_w, scr_h)
    if DWIN_W[sm_slot] != scr_w or DWIN_SNAP[sm_slot] != 1:
        write_str(1, "APPS FAIL: maximize geometry wrong\n")
        return
    write_str(1, "APPS maximize OK\n")
    write_str(1, "APPS PASS\n")


# Scratch buffer for the stdin command we inject.
term_test_cmd: Array[32, uint8]

def daemon_terminal_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: first autowin (hamsh + pipes) ---
    daemon_spawn_window(120, 80, 400, 240)
    if DWIN_COUNT == 0:
        write_str(1, "TERM IO FAIL no window spawned\n")
        return
    sl0: uint64 = DWIN_COUNT - 1
    infd: int32 = DWIN_IN_FD[sl0]
    outfd: int32 = DWIN_OUT_FD[sl0]
    if infd < 0:
        write_str(1, "TERM IO FAIL no stdin pipe for window 0\n")
        return
    if outfd < 0:
        write_str(1, "TERM IO FAIL no stdout pipe for window 0\n")
        return
    # --- Step 2: write the sentinel command to hamsh stdin ---
    # The command bytes sit in the pipe buffer until hamsh starts and
    # calls sys_read_nb(0,...). Since we patched hamsh to skip the
    # getty-style flush loop for pipe-backed stdin (DEVFD_PIPE_R), the
    # bytes are NOT discarded by the flush window — hamsh picks them up
    # on the very first readline poll pass.
    cmd_s: Ptr[uint8] = "echo HAMUI_TERM_TEST\n"
    sys_write(infd, cmd_s, strlen_u8(cmd_s))
    # --- Step 3: Non-blocking poll loop until the sentinel appears ---
    # We use sys_read_nb + sys_yield so the hamsh process gets CPU time
    # to start up and process the command. We stop as soon as the
    # sentinel appears in the grid. Idle = consecutive empty reads; we
    # cap at IDLE_MAX to bound run time (each yield is very fast on TCG).
    # On TCG hamsh may take thousands of scheduler rounds to start — a
    # large IDLE_MAX (200000) is safe and still completes well within
    # the 120s QEMU timeout.
    found0: int32 = 0
    idle0: int32 = 0
    while idle0 < 200000 and found0 == 0:
        n: int64 = sys_read_nb(outfd, &term_rx[0], 1024)
        if n > 0:
            idle0 = 0
            term_feed(sl0, &term_rx[0], n)
            if term_grid_contains(sl0, "HAMUI_TERM_TEST") != 0:
                found0 = 1
        else:
            idle0 = idle0 + 1
            sys_yield()
    if found0 == 0:
        write_str(1, "TERM IO FAIL sentinel not in window 0 grid\n")
        return
    write_str(1, "TERM IO window0 OK\n")
    # --- Step 4: focus-switch test ---
    # Create a second window so we can verify focus routing changes.
    daemon_spawn_window(200, 160, 400, 240)
    if DWIN_COUNT < 2:
        # Only one window was created (table full or spawn failed); skip
        # the two-window focus routing test.
        write_str(1, "TERM IO PASS (single-window)\n")
        return
    # Simulate a body-click on the FIRST window (slot 0) to raise it.
    # The first window is now slot 0 (two windows: 0 and 1, where 1 is
    # topmost after creation). Compute a point inside its body area.
    bclick_x: int64 = DWIN_X[0] + DWIN_W[0] / 2
    bclick_y: int64 = DWIN_Y[0] + TITLE_H + DWIN_H[0] / 2
    bclick_x = iclamp(bclick_x, 0, scr_w - 1)
    bclick_y = iclamp(bclick_y, 0, scr_h - 1)
    # Synthetic mouse click on the first window's body: press + release.
    CUR_X = bclick_x
    CUR_Y = bclick_y
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise the first window becomes the topmost slot; confirm focus.
    new_focus: int64 = daemon_focus_slot()
    focus_x: int64 = DWIN_X[cast[uint64](new_focus)]
    focus_y: int64 = DWIN_Y[cast[uint64](new_focus)]
    # The raised window's origin should match what we clicked into.
    in_raised: int32 = 0
    if bclick_x >= focus_x and bclick_x < focus_x + DWIN_W[cast[uint64](new_focus)]:
        if bclick_y >= focus_y and bclick_y < focus_y + DWIN_H[cast[uint64](new_focus)]:
            in_raised = 1
    if in_raised == 0:
        write_str(1, "TERM IO FAIL focus did not switch to clicked window\n")
        return
    write_str(1, "TERM IO focus-switch OK\n")
    # Route a second sentinel to the newly-focused window and confirm it
    # arrives in that window's grid.
    new_infd: int32 = DWIN_IN_FD[cast[uint64](new_focus)]
    if new_infd >= 0:
        new_outfd: int32 = DWIN_OUT_FD[cast[uint64](new_focus)]
        cmd2: Ptr[uint8] = "echo HAMUI_TERM_TEST2\n"
        sys_write(new_infd, cmd2, strlen_u8(cmd2))
        found2: int32 = 0
        idle2: int32 = 0
        while idle2 < 200000 and found2 == 0:
            n2: int64 = sys_read_nb(new_outfd, &term_rx[0], 1024)
            if n2 > 0:
                idle2 = 0
                term_feed(cast[uint64](new_focus), &term_rx[0], n2)
                if term_grid_contains(cast[uint64](new_focus), "HAMUI_TERM_TEST2") != 0:
                    found2 = 1
            else:
                idle2 = idle2 + 1
                sys_yield()
        if found2 == 0:
            write_str(1, "TERM IO FAIL sentinel2 not in focused window grid\n")
            return
    write_str(1, "TERM IO window1 OK\n")
    write_str(1, "TERM IO PASS\n")


# ====================================================================
# GPU track #183 — native Vulkan output INTO a real desktop window
# ====================================================================
#
# daemon_vk_window_selftest creates a NORMAL composited window at a known
# on-screen position whose BODY is filled by the native kernel-side
# lib/vk software rasterizer (a rotating triangle). Each frame the daemon
# asks the kernel to render the next frame into the window's draw-surface
# "vk" fb layer (sys_vk_window_frame), reads that layer back into
# vk_body_buf, marks the window as vk-bodied, composites the WHOLE screen
# through the SAME daemon_present path every other window uses, and
# samples the composited result to prove:
#   * inside the window's body rect the screen shows the Vulkan colours,
#   * OUTSIDE the window the screen shows the desktop backdrop (proving
#     it is WINDOWED, not a full-screen takeover),
#   * frame N and frame N+1 differ at a pixel the rotation moves (live
#     animation, not a static blit).
# All assertions read the composited frame through daemon_pixel — the
# exact value written to /dev/fb at that screen pixel — so they are
# unforgeable. Markers print as "[vk-window] ..." lines.

# Read window `wid`'s "vk" draw-surface fb layer into vk_body_buf. The
# layer is RGBA8888, up to VK_BODY_W x VK_BODY_H. Returns the bytes read.
def daemon_vk_read_body(wid: int32) -> int64:
    vp: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while vp[j] != 0:
        path_buf[i] = vp[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    sfx: Ptr[uint8] = "/draw/vk/fb"
    j = 0
    while sfx[j] != 0:
        path_buf[i] = sfx[j]
        i = i + 1
        j = j + 1
    path_buf[i] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &vk_body_buf[0],
                          cast[uint64](VK_BODY_W * VK_BODY_H * 4))
    sys_close(fd)
    return n


# Sample the composited screen colour at (sx,sy) into r/g/b via the SAME
# daemon_pixel path that fills /dev/fb. Returns packed 0xRRGGBB.
def daemon_screen_sample(sx: int64, sy: int64) -> uint64:
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    daemon_pixel(sx, sy, &rr[0], &gg[0], &bb[0])
    return (cast[uint64](rr[0]) << 16) | (cast[uint64](gg[0]) << 8) \
        | cast[uint64](bb[0])


def daemon_vk_window_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: create a normal window at a fixed on-screen position.
    # 320x260 box on the RIGHT half (clear of the kernel fb text console
    # which paints the top-left). Body is 192x192-friendly.
    win_x: int64 = 700
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 260
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    # A chrome-only window (no child shell): the body is the Vulkan image.
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[vk-window] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[vk-window] FAIL no wid for window\n")
        return
    DWIN_VK[sl] = 1
    # Body origin in screen space (where the Vulkan image lands).
    body_x: int64 = DWIN_X[sl] + 2
    body_y: int64 = DWIN_Y[sl] + TITLE_H
    # A pixel near the body centre (inside the 192x192 vk image) and a
    # pixel clearly OUTSIDE the window (the desktop backdrop).
    in_x: int64 = body_x + VK_BODY_W / 2
    in_y: int64 = body_y + VK_BODY_H / 2
    out_x: int64 = DWIN_X[sl] - 40
    out_y: int64 = DWIN_Y[sl] + 30
    if out_x < 0:
        out_x = 4
        out_y = 4
    # Animation-probe pixel: just left of body centre, on the orbit the
    # rotating triangle sweeps through, so a frame change toggles it.
    an_x: int64 = body_x + VK_BODY_W / 2 - 20
    an_y: int64 = body_y + VK_BODY_H / 2

    # --- Step 2: render frame 0, read it back, composite, sample. ---
    if sys_vk_window_frame(wid, 0, 0) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(0)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer\n")
        return
    vk_body_ready = 1
    daemon_present()
    in0: uint64 = daemon_screen_sample(in_x, in_y)
    out0: uint64 = daemon_screen_sample(out_x, out_y)
    an0: uint64 = daemon_screen_sample(an_x, an_y)
    # The backdrop colour packed for comparison.
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    # (a) Outside the window must be the desktop backdrop -> WINDOWED.
    if out0 == bg:
        write_str(1, "[vk-window] OK windowed (backdrop outside window)\n")
    else:
        write_str(1, "[vk-window] FAIL area outside window is not backdrop\n")
        return
    # (b) Inside the body must NOT be the backdrop and NOT the plain body
    #     fill — it must be Vulkan-rendered content.
    bodyfill: uint64 = (cast[uint64](WIN_BODY_R) << 16) \
        | (cast[uint64](WIN_BODY_G) << 8) | cast[uint64](WIN_BODY_B)
    if in0 != bg and in0 != bodyfill:
        write_str(1, "[vk-window] OK vulkan pixels inside window body\n")
    else:
        write_str(1, "[vk-window] FAIL body pixel is not vulkan content\n")
        return

    # --- Step 3: render a LATER frame, re-composite, prove animation. ---
    # Step several frames so the rotation visibly moves the probe pixel.
    if sys_vk_window_frame(wid, 0, 6) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(6)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer (frame 6)\n")
        return
    daemon_present()
    an6: uint64 = daemon_screen_sample(an_x, an_y)
    in6: uint64 = daemon_screen_sample(in_x, in_y)
    if an6 != an0 or in6 != in0:
        write_str(1, "[vk-window] OK animation (frame differs)\n")
    else:
        write_str(1, "[vk-window] FAIL frames identical (no animation)\n")
        return
    # Final present so a screendump catches the windowed Vulkan frame.
    daemon_present()
    write_str(1, "[vk-window] PASS\n")


# Scan window `slot`'s terminal grid for the NUL-terminated ASCII string
# `needle`. Returns 1 if found at any position (across row boundaries via
# grid linearisation), else 0.
def term_grid_contains(slot: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(needle)
    if nlen == 0:
        return 1
    base: uint64 = slot * GRID_CELLS
    cells: uint64 = cast[uint64](DWIN_ROWS[slot] * GRID_COLS_MAX)
    if cells > GRID_CELLS:
        cells = GRID_CELLS
    i: uint64 = 0
    while i + nlen <= cells:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            gc: uint8 = term_grid[base + i + k]
            nc: uint8 = needle[k]
            if gc != nc:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


# Focused window = the most-recently-created one (topmost). Returns its
# slot index, or -1 if there are no windows.
def daemon_focus_slot() -> int64:
    if DWIN_COUNT == 0:
        return -1
    return cast[int64](DWIN_COUNT) - 1


# Keyboard escape-sequence interception state for WM hotkeys. The atkbd
# driver emits VT220 sequences (no modifier encoding):
#   F1..F4   -> ESC O P / Q / R / S   -> switch to workspace 1..4
#   PageUp   -> ESC [ 5 ~             -> previous workspace
#   PageDown -> ESC [ 6 ~             -> next workspace
# We run a tiny 3-state matcher across reads so a sequence straddling a
# read boundary is still caught. A matched hotkey is CONSUMED (not routed
# to the focused shell); all other bytes pass through unchanged.
# KEY_ST: 0 = ground, 1 = saw ESC, 2 = saw ESC '[', 3 = saw ESC 'O'.
KEY_ST: int32 = 0
# Pending pass-through bytes that were part of an aborted sequence.
key_passthru: Array[8, uint8]


# Route a run of literal bytes from cons_rx[a..b) to the focused window.
def key_route(a: uint64, b: uint64, fslot: int64) -> int32:
    if b <= a or fslot < 0:
        return 0
    fs: uint64 = cast[uint64](fslot)
    wfd: int32 = DWIN_IN_FD[fs]
    if wfd < 0:
        # No child pipe: a built-in calculator window is keyboard-usable
        # too — feed digit/operator keystrokes straight to its handler.
        if DWIN_APP[fs] == APP_CALC:
            ki: uint64 = a
            routed_k: int32 = 0
            while ki < b:
                kc: uint8 = cons_rx[ki]
                if (kc >= 48 and kc <= 57) or kc == 43 or kc == 45 \
                   or kc == 42 or kc == 47 or kc == 61 or kc == 67 \
                   or kc == 99:
                    if kc == 99:                 # 'c' lowercase clears too
                        kc = 67
                    calc_press(fs, kc)
                    routed_k = 1
                elif kc == 13 or kc == 10:       # Enter == '=' on the calc
                    calc_press(fs, 61)
                    routed_k = 1
                ki = ki + 1
            return routed_k
        return 0
    sys_write(wfd, &cons_rx[a], b - a)
    return 1


# Drain /dev/cons (non-blocking). WM hotkey escape sequences (F1..F4,
# PageUp/PageDown) are intercepted to drive workspaces; everything else is
# routed to the focused window's child-stdin pipe. Returns 1 if anything
# was routed OR a workspace hotkey fired (the screen needs a re-present).
def daemon_pump_keys() -> int32:
    if cons_fd < 0:
        return 0
    fslot: int64 = daemon_focus_slot()
    routed: int32 = 0
    iters: int32 = 0
    while iters < 16:
        n: int64 = sys_read_nb(cons_fd, &cons_rx[0], 256)
        iters = iters + 1
        if n <= 0:
            break
        total: uint64 = cast[uint64](n)
        i: uint64 = 0
        run_start: uint64 = 0           # start of the current literal run
        while i < total:
            c: uint8 = cons_rx[i]
            st: int32 = KEY_ST
            if st == 0:
                if c == 27:             # ESC: flush the literal run, begin
                    routed = key_route(run_start, i, fslot) | routed
                    KEY_ST = 1
                i = i + 1
            elif st == 1:
                if c == 91:             # '['
                    KEY_ST = 2
                elif c == 79:           # 'O'
                    KEY_ST = 3
                else:
                    KEY_ST = 0          # not a tracked sequence: drop ESC+c
                    run_start = i + 1
                i = i + 1
            elif st == 2:
                # ESC [ ... : look for PageUp/PageDown (5~ / 6~). Consume
                # the digit; the trailing '~' is consumed on the next byte.
                if c == 53:             # '5' -> PageUp -> prev workspace
                    workspace_switch(CUR_WS - 1)
                    routed = 1
                elif c == 54:           # '6' -> PageDown -> next workspace
                    workspace_switch(CUR_WS + 1)
                    routed = 1
                # else: some other CSI (arrows etc.) — we drop it silently
                # rather than corrupt the shell with a partial sequence.
                # Swallow until a final byte (letter or '~').
                if (c >= 64 and c <= 126):
                    KEY_ST = 0
                    run_start = i + 1
                i = i + 1
            else:
                # ESC O <final> : F1..F4 -> workspace 1..4.
                if c == 80:             # 'P' = F1
                    workspace_switch(0)
                    routed = 1
                elif c == 81:           # 'Q' = F2
                    workspace_switch(1)
                    routed = 1
                elif c == 82:           # 'R' = F3
                    workspace_switch(2)
                    routed = 1
                elif c == 83:           # 'S' = F4
                    workspace_switch(3)
                    routed = 1
                KEY_ST = 0
                run_start = i + 1
                i = i + 1
        # Flush any trailing literal run (only when in ground state).
        if KEY_ST == 0:
            routed = key_route(run_start, total, fslot) | routed
    return routed


# Drain every window's stdout pipe into its grid. Returns 1 if any
# window produced output (the screen needs a re-present).
def daemon_pump_terms() -> int32:
    changed: int32 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if term_pump(wi) != 0:
            changed = 1
        wi = wi + 1
    return changed


def cmd_daemon_auto(autoflag: int32) -> int32:
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: daemon: cannot read /dev/fb geometry\n")
        return 1
    mp: Ptr[uint8] = "/dev/mouse"
    mfd: int32 = sys_open(cast[Ptr[char]](mp))
    if mfd < 0:
        write_str(2, "hamUId: daemon: cannot open /dev/mouse\n")
        return 1
    mouse_fd = mfd
    # Open /dev/cons for keystroke polling (best-effort: if it fails the
    # daemon still composites + spawns shells, just without key routing).
    font_init()
    cp: Ptr[uint8] = "/dev/cons"
    cons_fd = sys_open(cast[Ptr[char]](cp))
    scr_w: int64 = cast[int64](FBG_W)
    scr_h: int64 = cast[int64](FBG_H)
    # Cursor starts at screen centre.
    CUR_X = scr_w / 2
    CUR_Y = scr_h / 2
    # Announce so a test can detect the daemon came up and parse geometry.
    line: Array[96, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "DAEMON up screen="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(FBG_W, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(FBG_H, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)
    # First frame (backdrop + cursor at centre).
    daemon_present()
    # Optional auto-window: create one terminal window programmatically
    # (mouse-free) so a test can exercise the in-window shell. The rect
    # is a fixed 480x320 box on the RIGHT half of the screen — clear of
    # the kernel framebuffer text console, which renders an 80-column
    # (~640px-wide) region anchored at the top-left and would otherwise
    # repaint over a left-side window between the daemon's frames.
    if autoflag == 1 or autoflag == 2:
        daemon_spawn_window(720, 80, 480, 320)
        write_str(1, "DAEMON autowin created\n")
        daemon_present()
    # WM self-test (autoflag == 2): drive a title-drag move + close-box
    # click through synthetic packets so the gestures are exercised
    # deterministically without QEMU mouse injection.
    if autoflag == 2:
        daemon_wm_selftest(scr_w, scr_h)
        daemon_present()
    # PANEL self-test (autoflag == 3): drive the Applications menu open +
    # a menu-item launch through the SAME gesture machine, emitting the
    # PANEL serial markers, so a non-interactive test can assert the
    # launcher without QEMU mouse injection.
    if autoflag == 3:
        daemon_panel_selftest(scr_w, scr_h)
        daemon_present()
    # TERMINAL I/O self-test (autoflag == 5): create two windows, write a
    # sentinel command to each child's stdin pipe, pump stdout into the
    # terminal grid, and verify the sentinel string appears in the grid.
    # Also exercises the body-click focus-switch: clicking window 0's body
    # raises it to the top (emitting "WM focus window") and routes input
    # to its pipe. Does NOT enter the main loop — exits after the test.
    if autoflag == 5:
        daemon_terminal_selftest(scr_w, scr_h)
        return 0
    # TASKBAR / MINIMIZE / CLOCK self-test (autoflag == 6): exercises the
    # three new panel features: window-list taskbar, minimize/restore, and
    # live clock. Does NOT enter the main loop — exits after the test.
    if autoflag == 6:
        daemon_taskbar_selftest(scr_w, scr_h)
        return 0
    # VULKAN WINDOW self-test (autoflag == 8): create a normal composited
    # window, drive the kernel software rasterizer (SYS_VK_WINDOW_FRAME) to
    # render an animated triangle into that window's draw surface, composite
    # it, and assert the Vulkan pixels land inside the window body, the
    # backdrop shows outside it (proving windowed, not full-screen), and the
    # frame changes when the animation advances. Exits after the test.
    if autoflag == 8:
        daemon_vk_window_selftest(scr_w, scr_h)
        return 0
    # WORKSPACE self-test (autoflag == 9): create a window, switch virtual
    # desktops, and assert via composited-pixel sampling that the window is
    # only visible on its own workspace; also exercise the pager click and
    # the hotkey-path switch. Exits after the test.
    if autoflag == 9:
        daemon_workspace_selftest(scr_w, scr_h)
        return 0
    # DECORATION self-test (autoflag == 10): sample composited pixels to
    # verify the title-bar gradient, beveled border corners, the maximize
    # button, and the maximize/restore geometry toggle. Exits after.
    if autoflag == 10:
        daemon_decoration_selftest(scr_w, scr_h)
        return 0
    # CONTEXT-MENU self-test (autoflag == 11): verify the GNOME2 menu bar
    # opens, the right-click desktop + window context menus composite, and
    # their actions (New Terminal spawn, window Close) fire. Exits after.
    if autoflag == 11:
        daemon_ctxmenu_selftest(scr_w, scr_h)
        return 0
    # DESKTOP APPS self-test (autoflag == 12): built-in calculator, system
    # monitor, and window snapping/maximize. Exits after the test.
    if autoflag == 12:
        daemon_apps_selftest(scr_w, scr_h)
        return 0
    # Initial clock + system-monitor seed (before the first frame so the
    # panel shows a time and any System Monitor window shows live stats).
    clock_refresh(0)
    sysmon_refresh(0)
    # Main loop. Cooperative: yield every idle iteration so we never
    # monopolise the CPU and the spawned hamsh tasks still run.
    prev_wins: uint64 = DWIN_COUNT
    idle_ctr: uint64 = 0
    # Uptime centisecond counter, approximated from idle iterations.
    # Each sys_yield() is ~1-2ms on TCG; we add 2 each iteration.
    # clock_refresh only fires once per 100 cs anyway (1 second).
    loop_cs: uint64 = 0
    while True:
        ch: int32 = daemon_pump_mouse(scr_w, scr_h)
        # Route keystrokes to the focused window's shell, then drain
        # every shell's stdout into its terminal grid.
        daemon_pump_keys()
        tch: int32 = daemon_pump_terms()
        # Re-present when the mouse moved/clicked, a drag is in progress
        # (rubber band must track), a window was created, or any shell
        # emitted output (prompt / command echo).
        need: int32 = ch
        if tch != 0:
            need = 1
        if DRAG_ACTIVE != 0:
            need = 1
        if DWIN_COUNT != prev_wins:
            need = 1
            prev_wins = DWIN_COUNT
        # The kernel framebuffer console (the foreground hamsh's
        # heartbeat / log chatter) shares /dev/fb and repaints over the
        # desktop. As the screen owner, the daemon periodically forces a
        # full re-present so its desktop reasserts ownership even when
        # nothing in the model changed — keeping windows continuously
        # visible. (~once every 64 idle iterations.)
        idle_ctr = idle_ctr + 1
        loop_cs = loop_cs + 2
        if idle_ctr >= 64:
            need = 1
            idle_ctr = 0
            # Refresh the clock + system-monitor stats once per idle cycle
            # (~every second).
            clock_refresh(loop_cs)
            sysmon_refresh(loop_cs)
        if need != 0:
            daemon_present()
        # Log Out (System menu) requests a clean shutdown of the daemon so
        # the console returns to the foreground shell.
        if DAEMON_QUIT != 0:
            write_str(1, "DAEMON logout\n")
            break
        sys_yield()
    return 0


def usage(fd: int32):
    write_str(fd, "Usage: hamUId render <wid> | hamUId present <wid> | hamUId daemon [autowin|wmselftest|panelselftest|terminalselftest|taskbarselftest|vkwindowselftest|workspaceselftest|decorationselftest|ctxmenuselftest|appsselftest]\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        usage(2)
        return 1
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if cstr_eq(verb, "render") != 0:
        if argc < 3:
            write_str(2, "hamUId: render: missing wid\n")
            return 1
        wid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if wid < 1:
            write_str(2, "hamUId: render: bad wid\n")
            return 1
        return cmd_render(wid)
    if cstr_eq(verb, "present") != 0:
        if argc < 3:
            write_str(2, "hamUId: present: missing wid\n")
            return 1
        pwid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if pwid < 1:
            write_str(2, "hamUId: present: bad wid\n")
            return 1
        return cmd_present(pwid)
    if cstr_eq(verb, "daemon") != 0:
        # Optional `autowin` arg: immediately drag-create one terminal
        # window (mouse-free) so a non-interactive test can exercise the
        # in-window shell without driving QEMU mouse events.
        autoflag: int32 = 0
        if argc >= 3:
            a2: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
            if cstr_eq(a2, "autowin") != 0:
                autoflag = 1
            # `wmselftest` => autowin + a mouse-free move+close self-test.
            if cstr_eq(a2, "wmselftest") != 0:
                autoflag = 2
            # `panelselftest` => a mouse-free panel/menu open+launch test.
            if cstr_eq(a2, "panelselftest") != 0:
                autoflag = 3
            # `terminalselftest` => per-window stdin→stdout→grid I/O test.
            if cstr_eq(a2, "terminalselftest") != 0:
                autoflag = 5
            # `taskbarselftest` => taskbar/minimize/clock feature test.
            if cstr_eq(a2, "taskbarselftest") != 0:
                autoflag = 6
            # `vkwindowselftest` => kernel Vulkan rasterizer into a window.
            if cstr_eq(a2, "vkwindowselftest") != 0:
                autoflag = 8
            # `workspaceselftest` => MATE virtual desktops + pager.
            if cstr_eq(a2, "workspaceselftest") != 0:
                autoflag = 9
            # `decorationselftest` => themed window decorations + maximize.
            if cstr_eq(a2, "decorationselftest") != 0:
                autoflag = 10
            # `ctxmenuselftest` => right-click context menus + menu bar.
            if cstr_eq(a2, "ctxmenuselftest") != 0:
                autoflag = 11
            # `appsselftest` => built-in apps (calc/sysmon) + snapping test.
            if cstr_eq(a2, "appsselftest") != 0:
                autoflag = 12
        return cmd_daemon_auto(autoflag)
    usage(2)
    return 1

resize_last_w: int32 = -1
resize_last_h: int32 = -1


def _resize_emit_i64(pos: uint64, v: int64) -> uint64:
    if v < 0:
        resize_pub_buf[pos] = 45
        pos = pos + 1
        return pos + u64_to_dec(cast[uint64](-v), &resize_pub_buf[pos])
    return pos + u64_to_dec(cast[uint64](v), &resize_pub_buf[pos])


def _resize_pick_kind_rect(out_kind: Ptr[int32], out_x: Ptr[int64],
                           out_y: Ptr[int64], out_w: Ptr[int64],
                           out_h: Ptr[int64]):
    k: int32 = 0
    x: int64 = 0
    y: int64 = 0
    w: int64 = 0
    h: int64 = 0
    if RESIZE_SLOT >= 0 and GESTURE == 4:
        rs: uint64 = cast[uint64](RESIZE_SLOT)
        if rs < DWIN_COUNT:
            k = 1
            x = DWIN_X[rs]
            y = DWIN_Y[rs]
            w = DWIN_W[rs]
            h = DWIN_H[rs]
    if k == 0 and KMODE != 0 and KMODE_SLOT >= 0:
        ks: uint64 = cast[uint64](KMODE_SLOT)
        if ks < DWIN_COUNT:
            k = 2
            x = DWIN_X[ks]
            y = DWIN_Y[ks]
            w = DWIN_W[ks]
            h = DWIN_H[ks]
    out_kind[0] = k
    out_x[0] = x
    out_y[0] = y
    out_w[0] = w
    out_h[0] = h


def resize_publish_snapshot():
    kind: Array[1, int32]
    rx: Array[1, int64]
    ry: Array[1, int64]
    rw: Array[1, int64]
    rh: Array[1, int64]
    _resize_pick_kind_rect(&kind[0], &rx[0], &ry[0], &rw[0], &rh[0])
    pos: uint64 = 0
    verb: Ptr[uint8] = "resize "
    k: uint64 = 0
    while verb[k] != 0:
        resize_pub_buf[pos] = verb[k]
        pos = pos + 1
        k = k + 1
    pos = _resize_emit_i64(pos, cast[int64](kind[0]))
    resize_pub_buf[pos] = 32
    pos = pos + 1
    pos = _resize_emit_i64(pos, rx[0])
    resize_pub_buf[pos] = 32
    pos = pos + 1
    pos = _resize_emit_i64(pos, ry[0])
    resize_pub_buf[pos] = 32
    pos = pos + 1
    pos = _resize_emit_i64(pos, rw[0])
    resize_pub_buf[pos] = 32
    pos = pos + 1
    pos = _resize_emit_i64(pos, rh[0])
    resize_pub_buf[pos] = 10
    pos = pos + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &resize_pub_buf[0], pos)
    sys_close(fd)
    resize_last_kind = kind[0]
    resize_last_x = cast[int32](rx[0])
    resize_last_y = cast[int32](ry[0])
    resize_last_w = cast[int32](rw[0])
    resize_last_h = cast[int32](rh[0])



# user/hamUId.ad
#
# hamUI Phase 4b — the userland renderer.
#
# Consumes the Phase 4a kernel draw FILE SURFACE under
# /dev/wsys/<wid>/draw/ (docs/hamUI.md H-§G) and produces a composited
# frame. The kernel side is complete and load-bearing; this tool only
# reads/writes the cdev via open/read/write syscalls — it touches NO
# kernel code.
#
# CLI shape
# ---------
#   hamUId render <wid>
#       1. Read /dev/wsys/<wid>/draw       -> z-ascending layer listing.
#       2. For each layer read its kind/z/opacity/geometry and, per kind,
#          its markup or fb body.
#       3. Markup layers: parse hamML v1, rasterise into a per-layer
#          RGBA8888 buffer (rect fill, Bresenham line, embedded 8x16 mono
#          bitmap text, <image src="fb:LAYER"> blits).
#       4. Composite all layers in ascending z into a window-sized RGBA
#          target, alpha-blending per-pixel alpha * per-layer opacity.
#       5. Emit an AI-READABLE TEXT DUMP to stdout:
#            - "DUMP wid=<w> win=<W>x<H> layers=<n>"
#            - "PIX <x> <y> #rrggbb"  lines for a grid of probe coords
#            - a low-res ASCII-art view ("ART" lines), '#' where a pixel
#              is non-background, ' ' where background.
#          A CI grep can assert "the rect fill colour appears at the
#          rect's pixels" and "text-region probes are non-background".
#       6. Also writes the composited bytes into an fb layer named
#          "_screen" (created if absent) so the frame round-trips through
#          the cdev too — best-effort; the stdout dump is the test hook.
#
# There is NO physical framebuffer yet (Phase 4c) and NO BDF font store
# yet (Phase 4d), so this is a ONE-SHOT renderer with a compact built-in
# 8x16 mono font. sans/serif fall back to mono (per spec). A persistent
# boot daemon loop, dirty-rect diffing, hit-testing and the event stream
# are deliberately deferred to later phases.
#
# Adder quirks honoured (feedback_compiler_quirks.md U9): big buffers at
# module scope; string literals kept as call-site Ptr[uint8]; no adjacent
# string-literal concatenation.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
extern def sys_yield() -> int32
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_kill(pid: int32, sig: int32) -> int32
extern def sys_wsys_alloc(pid: uint64) -> int32
extern def sys_wsys_free(wid: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
# GPU track #183: ask the kernel to render native Vulkan frame `frame`
# into window `wid`'s draw-surface fb layer "vk" (lib/vk is kernel-only;
# this daemon composites the result like any other window).
extern def sys_vk_window_frame(wid: int32, reserved: int32,
                               frame: int64) -> int64


# ---- window + layer caps (mirror the kernel cdev surface) ----------
WIN_W: uint64 = 640
WIN_H: uint64 = 480
MAX_LAYERS: uint64 = 16          # WSYS_DRAW_MAX_LAYERS
FB_DIM: uint64 = 256             # fb layers cap at 256x256 (256 KiB)

# Background colour (opaque). 0x00 in the RGB channels, alpha 255.
BG_R: uint8 = 0
BG_G: uint8 = 0
BG_B: uint8 = 0


# ---- module-scope buffers ------------------------------------------
# Compositor target: WIN_W * WIN_H * 4 = 640*480*4 = 1,228,800 bytes.
target: Array[1228800, uint8]
# One scratch RGBA layer buffer, also window-sized, reused per layer.
layerbuf: Array[1228800, uint8]
# Raw markup / fb read buffer (markup cap is 8192; fb cap is 256 KiB).
markup_buf: Array[8192, uint8]
fb_read_buf: Array[262144, uint8]

# Decoded font: 95 glyphs * 16 rows = 1520 bytes, ASCII 0x20..0x7E.
font_glyphs: Array[1520, uint8]
font_ready: int32 = 0

# Layer table parsed from the draw listing.
LT_NAME: Array[512, uint8]       # MAX_LAYERS * 32 (WSYS_DRAW_NAME_CAP)
LT_KIND: Array[16, int32]        # 0 = markup, 1 = fb
LT_X: Array[16, int64]
LT_Y: Array[16, int64]
LT_W: Array[16, int64]
LT_H: Array[16, int64]
LT_OPAC: Array[16, int64]
LT_COUNT: uint64 = 0

# Scratch path builder.
path_buf: Array[256, uint8]
# Listing read buffer.
list_buf: Array[4096, uint8]
# Generic small line / number scratch.
num_buf: Array[64, uint8]


# ====================================================================
# String / number helpers (mirrors user/hamUI.ad idioms)
# ====================================================================

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] != b[i]:
        return 0
    return 1


def parse_uint(s: Ptr[uint8]) -> int32:
    if s[0] == 0:
        return -1
    n: int32 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int32](c) - 48
        i = i + 1
    return n


def u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    # Decimal, NO trailing newline. Returns the digit count.
    if value == 0:
        out[0] = 48
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    nw: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return nw


def hex_nibble(c: uint8) -> int32:
    # ASCII hex digit -> 0..15, or -1.
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 97 + 10
    if c >= 65 and c <= 70:
        return cast[int32](c) - 65 + 10
    return -1


# Parse a (possibly signed) decimal integer from buf[start..end). Stops
# at the first non-digit. Returns the value; *consumed via end pointer
# is not needed by callers here.
def parse_i64_span(buf: Ptr[uint8], start: uint64, end: uint64) -> int64:
    i: uint64 = start
    neg: int32 = 0
    if i < end and buf[i] == 45:                # '-'
        neg = 1
        i = i + 1
    v: int64 = 0
    while i < end:
        c: uint8 = buf[i]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[int64](cast[int32](c) - 48)
        i = i + 1
    if neg != 0:
        return 0 - v
    return v


# ====================================================================
# Embedded 8x16 mono font (ASCII 0x20..0x7E)
# Derived from drivers/video/console/fb_font_8x16.S (Linux VGA ROM
# font, GPL-2.0; a verbatim hardware font dump). Each glyph is 16 rows;
# row byte MSB = leftmost pixel.
# ====================================================================

def _font_hex(i: uint64) -> Ptr[uint8]:
    if i == 0:
        return "00000000000000000000000000000000"
    if i == 1:
        return "0000183c3c3c18181800181800000000"
    if i == 2:
        return "00666666240000000000000000000000"
    if i == 3:
        return "0000006c6cfe6c6c6cfe6c6c00000000"

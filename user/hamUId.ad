def font_init_sans():
    if font_sans_ready != 0:
        return
    g: uint64 = 0
    while g < 95:
        hexs: Ptr[uint8] = _font_hex_sans(g)
        r: uint64 = 0
        while r < 10:
            hi: int32 = hex_nibble(hexs[r * 2])
            lo: int32 = hex_nibble(hexs[r * 2 + 1])
            font_sans[g * 10 + r] = cast[uint8]((hi * 16) + lo)
            r = r + 1
        g = g + 1
    font_sans_ready = 1


# Serif derived from the sans table by ALGORITHMIC top/bottom serif
# spread (matches scripts/gen_bdf_fonts.py's gen_serif_bdf). Cheap +
# avoids duplicating 95 glyph literals. Top serif = OR-spread of row 0
# of the sans body (which is sans row 1, since sans row 0 is blank);
# bottom serif = OR-spread of sans row 8 (the last body row, since
# sans rows 8..9 are descender pad). 12 rows total:
#   row 0    blank
#   row 1    top-serif cap
#   rows 2..8  body (= sans rows 1..7)
#   row 9    bottom-serif cap
#   rows 10..11 blank descender
def _spread(b: uint8) -> uint8:
    v: int32 = cast[int32](b)
    cap: int32 = v | (v << 1) | (v >> 1)
    return cast[uint8](cap & 248)            # 0xF8 -> 5 leftmost bits


def font_init_serif():
    if font_serif_ready != 0:
        return
    # sans must be ready first.
    font_init_sans()
    g: uint64 = 0
    while g < 95:
        base: uint64 = g * 10
        out: uint64 = g * 12
        font_serif[out + 0]  = 0
        font_serif[out + 1]  = _spread(font_sans[base + 1])
        # body rows: sans rows 1..7 -> serif rows 2..8
        font_serif[out + 2]  = font_sans[base + 1]
        font_serif[out + 3]  = font_sans[base + 2]
        font_serif[out + 4]  = font_sans[base + 3]
        font_serif[out + 5]  = font_sans[base + 4]
        font_serif[out + 6]  = font_sans[base + 5]
        font_serif[out + 7]  = font_sans[base + 6]
        font_serif[out + 8]  = font_sans[base + 7]
        font_serif[out + 9]  = _spread(font_sans[base + 7])
        font_serif[out + 10] = 0
        font_serif[out + 11] = 0
        g = g + 1
    font_serif_ready = 1


# ====================================================================
# Compositor target helpers
# ====================================================================

def target_clear():
    # Fill the window-sized target with the opaque background colour.
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            target[o] = BG_R
            target[o + 1] = BG_G
            target[o + 2] = BG_B
            target[o + 3] = 255
            x = x + 1
        y = y + 1


def layerbuf_clear():
    # Zero (transparent) the per-layer RGBA scratch. Premultiplied: all
    # channels 0 = fully transparent.
    i: uint64 = 0
    n: uint64 = WIN_W * WIN_H * 4
    while i < n:
        layerbuf[i] = 0
        i = i + 1


# Set a layer-buffer pixel (premultiplied RGBA) with src-over blend onto
# whatever is already in the layer buffer. (r,g,b,a) are straight 0..255
# component values for the incoming colour; we premultiply on store.
def layer_put(x: int64, y: int64, r: uint8, g: uint8, b: uint8, a: uint8):
    if x < 0 or y < 0:
        return
    xu: uint64 = cast[uint64](x)
    yu: uint64 = cast[uint64](y)
    if xu >= WIN_W or yu >= WIN_H:
        return
    if a == 0:
        return
    o: uint64 = (yu * WIN_W + xu) * 4
    av: uint64 = cast[uint64](a)
    inv: uint64 = 255 - av
    # Premultiply the incoming colour by its own alpha, then src-over
    # against the existing premultiplied destination.
    sr: uint64 = (cast[uint64](r) * av) / 255
    sg: uint64 = (cast[uint64](g) * av) / 255
    sb: uint64 = (cast[uint64](b) * av) / 255
    dr: uint64 = cast[uint64](layerbuf[o])
    dg: uint64 = cast[uint64](layerbuf[o + 1])
    db: uint64 = cast[uint64](layerbuf[o + 2])
    da: uint64 = cast[uint64](layerbuf[o + 3])
    layerbuf[o] = cast[uint8](sr + (dr * inv) / 255)
    layerbuf[o + 1] = cast[uint8](sg + (dg * inv) / 255)
    layerbuf[o + 2] = cast[uint8](sb + (db * inv) / 255)
    layerbuf[o + 3] = cast[uint8](av + (da * inv) / 255)


# ====================================================================
# hamML colour parsing
# ====================================================================
# A parsed colour is returned via four out-bytes + a "present" flag.

def parse_color(buf: Ptr[uint8], start: uint64, end: uint64,
                out_r: Ptr[uint8], out_g: Ptr[uint8],
                out_b: Ptr[uint8], out_a: Ptr[uint8]) -> int32:
    # Supports "#rrggbb", "#rgb" and "rgba(r,g,b,a)" (a = 0..255).
    # Returns 1 on success.
    i: uint64 = start
    while i < end and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    if i >= end:
        return 0
    if buf[i] == 35:                                 # '#'
        i = i + 1
        # count hex digits available
        h0: uint64 = i
        while i < end and hex_nibble(buf[i]) >= 0:
            i = i + 1
        ndig: uint64 = i - h0
        if ndig >= 6:
            out_r[0] = cast[uint8]((hex_nibble(buf[h0]) * 16) + hex_nibble(buf[h0 + 1]))
            out_g[0] = cast[uint8]((hex_nibble(buf[h0 + 2]) * 16) + hex_nibble(buf[h0 + 3]))
            out_b[0] = cast[uint8]((hex_nibble(buf[h0 + 4]) * 16) + hex_nibble(buf[h0 + 5]))
            out_a[0] = 255
            return 1
        if ndig >= 3:
            # #rgb -> #rrggbb
            rr: int32 = hex_nibble(buf[h0])
            gg: int32 = hex_nibble(buf[h0 + 1])
            bb: int32 = hex_nibble(buf[h0 + 2])
            out_r[0] = cast[uint8](rr * 16 + rr)
            out_g[0] = cast[uint8](gg * 16 + gg)
            out_b[0] = cast[uint8](bb * 16 + bb)
            out_a[0] = 255
            return 1
        return 0
    # rgba( / rgb(
    if buf[i] == 114:                                # 'r'
        # skip to '('
        while i < end and buf[i] != 40:
            i = i + 1
        if i >= end:
            return 0
        i = i + 1
        comp: Array[4, int64]
        comp[0] = 0
        comp[1] = 0
        comp[2] = 0
        comp[3] = 255
        ci: uint64 = 0
        while i < end and buf[i] != 41 and ci < 4:
            while i < end and (buf[i] == 32 or buf[i] == 9):
                i = i + 1
            v: int64 = 0
            got: int32 = 0
            while i < end and buf[i] >= 48 and buf[i] <= 57:
                v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
                got = 1
                i = i + 1
            if got != 0:
                comp[ci] = v
                ci = ci + 1
            while i < end and buf[i] != 44 and buf[i] != 41:
                i = i + 1
            if i < end and buf[i] == 44:
                i = i + 1
        out_r[0] = cast[uint8](comp[0])
        out_g[0] = cast[uint8](comp[1])
        out_b[0] = cast[uint8](comp[2])
        out_a[0] = cast[uint8](comp[3])
        return 1
    return 0


# ====================================================================
# hamML attribute extraction
# ====================================================================
# Given a tag's attribute span [astart, aend) inside markup_buf, find an
# attribute named `name` and return its raw VALUE span via out_vs/out_ve.
# Returns 1 if found. Values may be unquoted (x=10) or quoted (fill="#f00").

def find_attr(astart: uint64, aend: uint64, name: Ptr[uint8],
              out_vs: Ptr[uint64], out_ve: Ptr[uint64]) -> int32:
    nlen: uint64 = strlen_u8(name)
    i: uint64 = astart
    while i < aend:
        # skip whitespace
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9 or
                            markup_buf[i] == 10 or markup_buf[i] == 13):
            i = i + 1
        # read an attribute name
        ns: uint64 = i
        while i < aend and markup_buf[i] != 61 and markup_buf[i] != 32 and \
              markup_buf[i] != 9 and markup_buf[i] != 10 and \
              markup_buf[i] != 13 and markup_buf[i] != 47 and \
              markup_buf[i] != 62:
            i = i + 1
        ne: uint64 = i
        # skip whitespace before '='
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
            i = i + 1
        if i < aend and markup_buf[i] == 61:           # '='
            i = i + 1
            while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
                i = i + 1
            vs: uint64 = 0
            ve: uint64 = 0
            if i < aend and (markup_buf[i] == 34 or markup_buf[i] == 39):
                q: uint8 = markup_buf[i]
                i = i + 1
                vs = i
                while i < aend and markup_buf[i] != q:
                    i = i + 1
                ve = i
                if i < aend:
                    i = i + 1
            else:
                vs = i
                while i < aend and markup_buf[i] != 32 and markup_buf[i] != 9 and \
                      markup_buf[i] != 10 and markup_buf[i] != 13 and \
                      markup_buf[i] != 47 and markup_buf[i] != 62:
                    i = i + 1
                ve = i
            # name match?
            if (ne - ns) == nlen:
                k: uint64 = 0
                matched: int32 = 1
                while k < nlen:
                    if markup_buf[ns + k] != name[k]:
                        matched = 0
                        k = nlen
                    else:
                        k = k + 1
                if matched != 0:
                    out_vs[0] = vs
                    out_ve[0] = ve
                    return 1
        else:
            # attribute with no value (rare); skip on
            i = ne + 1
    return 0


def attr_i64(astart: uint64, aend: uint64, name: Ptr[uint8],
             dflt: int64) -> int64:
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, name, &vs[0], &ve[0]) == 0:
        return dflt
    return parse_i64_span(&markup_buf[0], vs[0], ve[0])


# #444-followup Phase 4d — parse a hamML `font="<fam>"` attribute into
# the FONT_FAM_* constant. Accepts "mono", "sans", "serif"; falls back
# to FONT_FAM_MONO if attr absent or value unrecognised. Comparison is
# bytewise against the literal value span inside markup_buf.
def attr_font_family(astart: uint64, aend: uint64) -> int32:
    fkw: Ptr[uint8] = "font"
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, fkw, &vs[0], &ve[0]) == 0:
        return FONT_FAM_MONO
    n: uint64 = ve[0] - vs[0]
    if n == 4:
        if markup_buf[vs[0]] == 109 and markup_buf[vs[0]+1] == 111 and \
           markup_buf[vs[0]+2] == 110 and markup_buf[vs[0]+3] == 111:
            return FONT_FAM_MONO
        if markup_buf[vs[0]] == 115 and markup_buf[vs[0]+1] == 97 and \
           markup_buf[vs[0]+2] == 110 and markup_buf[vs[0]+3] == 115:
            return FONT_FAM_SANS
    if n == 5:
        if markup_buf[vs[0]] == 115 and markup_buf[vs[0]+1] == 101 and \
           markup_buf[vs[0]+2] == 114 and markup_buf[vs[0]+3] == 105 and \
           markup_buf[vs[0]+4] == 102:
            return FONT_FAM_SERIF
    return FONT_FAM_MONO


# ====================================================================
# Rasterising primitives into the current layer buffer
# ====================================================================

def raster_rect(x: int64, y: int64, w: int64, h: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    yy: int64 = y
    ymax: int64 = y + h
    while yy < ymax:
        xx: int64 = x
        xmax: int64 = x + w
        while xx < xmax:
            layer_put(xx, yy, r, g, b, a)
            xx = xx + 1
        yy = yy + 1


def iabs(v: int64) -> int64:
    if v < 0:
        return 0 - v
    return v


def raster_line(x0: int64, y0: int64, x1: int64, y1: int64, width: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Bresenham. `width` thickens by stamping a (width x width) block.
    dx: int64 = iabs(x1 - x0)
    dy: int64 = 0 - iabs(y1 - y0)
    sx: int64 = -1
    if x0 < x1:
        sx = 1
    sy: int64 = -1
    if y0 < y1:
        sy = 1
    err: int64 = dx + dy
    cx: int64 = x0
    cy: int64 = y0
    half: int64 = width / 2
    while True:
        # stamp a width x width block centred on (cx,cy)
        oy: int64 = 0 - half
        while oy <= half:
            ox: int64 = 0 - half
            while ox <= half:
                layer_put(cx + ox, cy + oy, r, g, b, a)
                ox = ox + 1
            oy = oy + 1
        if cx == x1 and cy == y1:
            break
        e2: int64 = err * 2
        if e2 >= dy:
            err = err + dy
            cx = cx + sx
        if e2 <= dx:
            err = err + dx
            cy = cy + sy


def raster_glyph(ch: uint8, x: int64, y: int64,
                 r: uint8, g: uint8, b: uint8, a: uint8):
    # 8x16 mono glyph; (x,y) is the TOP-LEFT of the cell.
    if ch < 32 or ch > 126:
        return
    gi: uint64 = cast[uint64](ch) - 32
    row: uint64 = 0
    while row < 16:
        bits: uint8 = font_glyphs[gi * 16 + row]
        col: uint64 = 0
        while col < 8:
            mask: uint8 = cast[uint8](128 >> col)
            if (bits & mask) != 0:
                layer_put(x + cast[int64](col), y + cast[int64](row), r, g, b, a)
            col = col + 1
        row = row + 1


# #444-followup Phase 4d — family-dispatched glyph renderer.
# family: 0=mono(8x16), 1=sans(6x10), 2=serif(6x12).
# Returns advance width in pixels (caller's x-step between glyphs).
def raster_glyph_fam(ch: uint8, x: int64, y: int64,
                     r: uint8, g: uint8, b: uint8, a: uint8,
                     family: int32) -> int64:
    if ch < 32 or ch > 126:
        if family == FONT_FAM_MONO:
            return 8
        return 6
    gi: uint64 = cast[uint64](ch) - 32
    if family == FONT_FAM_SANS:
        font_init_sans()
        row: uint64 = 0
        while row < 10:
            bits: uint8 = font_sans[gi * 10 + row]
            col: uint64 = 0
            while col < 6:
                mask: uint8 = cast[uint8](128 >> col)
                if (bits & mask) != 0:
                    layer_put(x + cast[int64](col), y + cast[int64](row), r, g, b, a)
                col = col + 1
            row = row + 1
        return 6
    if family == FONT_FAM_SERIF:
        font_init_serif()
        row: uint64 = 0
        while row < 12:
            bits: uint8 = font_serif[gi * 12 + row]
            col: uint64 = 0
            while col < 6:
                mask: uint8 = cast[uint8](128 >> col)
                if (bits & mask) != 0:
                    layer_put(x + cast[int64](col), y + cast[int64](row), r, g, b, a)
                col = col + 1
            row = row + 1
        return 6
    # fallthrough: mono
    raster_glyph(ch, x, y, r, g, b, a)
    return 8


def raster_text(text_s: uint64, text_e: uint64, x: int64, y: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Render markup_buf[text_s..text_e) as 8x16 mono. The hamML `y` is
    # the text BASELINE-ish anchor; we treat it as the cell top for the
    # mono font (good enough for v1 / AI-debug). Advance 8 px per glyph.
    cx: int64 = x
    i: uint64 = text_s
    while i < text_e:
        c: uint8 = markup_buf[i]
        if c == 10 or c == 13:
            i = i + 1
        else:
            raster_glyph(c, cx, y, r, g, b, a)
            cx = cx + 8
            i = i + 1


# #444-followup Phase 4d — family-aware multi-glyph text. Default
# (family=FONT_FAM_MONO) is byte-identical to raster_text(); other
# families render via raster_glyph_fam() with their own advance width.
def raster_text_fam(text_s: uint64, text_e: uint64, x: int64, y: int64,
                    r: uint8, g: uint8, b: uint8, a: uint8,
                    family: int32):
    if family == FONT_FAM_MONO:
        raster_text(text_s, text_e, x, y, r, g, b, a)
        return
    cx: int64 = x
    i: uint64 = text_s
    while i < text_e:
        c: uint8 = markup_buf[i]
        if c == 10 or c == 13:
            i = i + 1
        else:
            aw: int64 = raster_glyph_fam(c, cx, y, r, g, b, a, family)
            cx = cx + aw
            i = i + 1


# Blit a referenced fb LAYER's buffer into the current layer at (dx,dy).
# `src_slot` is the layer-table index of the referenced layer.
def raster_image_fb(src_slot: uint64, dx: int64, dy: int64,
                    dw: int64, dh: int64):
    # Read the source layer's fb body into fb_read_buf.
    nread: int64 = read_layer_fb(src_slot)
    if nread <= 0:
        return
    sw: int64 = LT_W[src_slot]
    sh: int64 = LT_H[src_slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    # default destination size = source size
    tw: int64 = dw
    th: int64 = dh
    if tw <= 0:
        tw = sw
    if th <= 0:
        th = sh
    yy: int64 = 0
    while yy < th:
        xx: int64 = 0
        while xx < tw:
            # nearest-neighbour sample
            srx: int64 = (xx * sw) / tw
            sry: int64 = (yy * sh) / th
            if srx < sw and sry < sh:
                so: uint64 = cast[uint64](sry * sw + srx) * 4
                if so + 3 < cast[uint64](nread):
                    pr: uint8 = fb_read_buf[so]
                    pg: uint8 = fb_read_buf[so + 1]
                    pb: uint8 = fb_read_buf[so + 2]
                    pa: uint8 = fb_read_buf[so + 3]
                    # fb is premultiplied; un-premultiply is unnecessary
                    # because layer_put premultiplies by `a` again. For a
                    # faithful blit we treat stored RGB as straight and
                    # pass alpha through.
                    layer_put(dx + xx, dy + yy, pr, pg, pb, pa)
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Path building + cdev reads
# ====================================================================

def build_path(wid: int32, layer: Ptr[uint8], leaf: Ptr[uint8]):
    # Compose "/dev/wsys/<wid>/draw[/<layer>][/<leaf>]" into path_buf.
    # layer NULL/empty -> ".../draw"; leaf NULL/empty -> no trailing leaf.
    p: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while p[j] != 0:
        path_buf[i] = p[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    d: Ptr[uint8] = "/draw"
    j = 0
    while d[j] != 0:
        path_buf[i] = d[j]
        i = i + 1
        j = j + 1
    if layer != cast[Ptr[uint8]](0) and layer[0] != 0:
        path_buf[i] = 47                              # '/'
        i = i + 1
        j = 0
        while layer[j] != 0:
            path_buf[i] = layer[j]
            i = i + 1
            j = j + 1
        if leaf != cast[Ptr[uint8]](0) and leaf[0] != 0:
            path_buf[i] = 47
            i = i + 1
            j = 0
            while leaf[j] != 0:
                path_buf[i] = leaf[j]
                i = i + 1
                j = j + 1
    path_buf[i] = 0


def build_wsys_leaf(wid: int32, leaf: Ptr[uint8]):
    # Compose "/dev/wsys/<wid>/<leaf>" into path_buf (no /draw segment).
    # Used for the per-window input-event leaves (pointer / keys).
    p: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while p[j] != 0:
        path_buf[i] = p[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    path_buf[i] = 47                                  # '/'
    i = i + 1
    j = 0
    while leaf[j] != 0:
        path_buf[i] = leaf[j]
        i = i + 1
        j = j + 1
    path_buf[i] = 0


def read_whole(fd: int32, buf: Ptr[uint8], cap: uint64) -> int64:
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    return cast[int64](total)


def layer_name_ptr(slot: uint64) -> Ptr[uint8]:
    return &LT_NAME[slot * 32]


def read_layer_markup(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "markup")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &markup_buf[0], 8192)
    sys_close(fd)
    return n


# read_layer_fb reads the layer at table-index `slot` into fb_read_buf.
# Returns bytes read.
read_fb_wid: int32 = 1
def read_layer_fb(slot: uint64) -> int64:
    build_path(read_fb_wid, layer_name_ptr(slot), "fb")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &fb_read_buf[0], 262144)
    sys_close(fd)
    return n


def read_layer_opacity(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "opacity")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return 255
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 255
    return parse_i64_span(&num_buf[0], 0, cast[uint64](n))


# EVLOOP: read the per-layer content generation counter for window `wid`'s
# "ui" layer — /dev/wsys/<wid>/draw/ui/gen, "<gen>\n". The read is PURE
# (never consumes the markup body, never bumps the counter), so it is the
# cheap "did the client repaint?" probe the event loop polls instead of
# unconditionally re-rasterizing bodies. Returns -1 when the layer (or its
# gen leaf) is not available.
def read_layer_gen_ui(wid: int32) -> int64:
    if wid < 2:
        return -1
    build_path(wid, "ui", "gen")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return -1
    return parse_i64_span(&num_buf[0], 0, cast[uint64](n))


# ====================================================================
# Parse the draw listing into the layer table
# ====================================================================
# Each listing line:
#   "<name>  z=<z>  kind=<markup|fb>  <x>x<y>..<x2>x<y2>  opacity=<o>"

def parse_listing(wid: int32) -> int32:
    build_path(wid, cast[Ptr[uint8]](0), cast[Ptr[uint8]](0))
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &list_buf[0], 4096)
    sys_close(fd)
    if n < 0:
        return -1
    total: uint64 = cast[uint64](n)
    LT_COUNT = 0
    i: uint64 = 0
    while i < total and LT_COUNT < MAX_LAYERS:
        ls: uint64 = i
        while i < total and list_buf[i] != 10:
            i = i + 1
        le: uint64 = i
        if i < total:
            i = i + 1
        if le > ls:
            parse_listing_line(ls, le)
    return 0


def parse_listing_line(ls: uint64, le: uint64):
    slot: uint64 = LT_COUNT
    # name = run up to first space
    p: uint64 = ls
    while p < le and list_buf[p] != 32:
        p = p + 1
    nlen: uint64 = p - ls
    if nlen >= 32:
        nlen = 31
    k: uint64 = 0
    while k < nlen:
        LT_NAME[slot * 32 + k] = list_buf[ls + k]
        k = k + 1
    LT_NAME[slot * 32 + nlen] = 0
    # find "kind=" -> markup/fb
    LT_KIND[slot] = 0
    kk: uint64 = find_substr(ls, le, "kind=")
    if kk < le:
        c: uint8 = list_buf[kk + 5]
        if c == 102:                                  # 'f' (fb)
            LT_KIND[slot] = 1
    # geometry "<x>x<y>..<x2>x<y2>": parse the two corner pairs.
    gg: uint64 = find_geom(ls, le)
    x0: int64 = 0
    y0: int64 = 0
    x1: int64 = 0
    y1: int64 = 0
    if gg < le:
        q: uint64 = gg
        x0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:          # 'x'
            q = q + 1
        if q < le:
            q = q + 1
        y0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 46:           # '.'
            q = q + 1
        while q < le and list_buf[q] == 46:
            q = q + 1
        x1 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:
            q = q + 1
        if q < le:
            q = q + 1
        y1 = parse_i64_span(&list_buf[0], q, le)
    LT_X[slot] = x0
    LT_Y[slot] = y0
    LT_W[slot] = x1 - x0
    LT_H[slot] = y1 - y0
    # opacity
    oo: uint64 = find_substr(ls, le, "opacity=")
    if oo < le:
        LT_OPAC[slot] = parse_i64_span(&list_buf[0], oo + 8, le)
    else:
        LT_OPAC[slot] = 255
    LT_COUNT = LT_COUNT + 1


def find_substr(ls: uint64, le: uint64, needle: Ptr[uint8]) -> uint64:
    nlen: uint64 = strlen_u8(needle)
    i: uint64 = ls
    while i + nlen <= le:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            if list_buf[i + k] != needle[k]:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return i
        i = i + 1
    return le


# Find the geometry field: the first run of digits that is FOLLOWED by an
# 'x' then digits then ".." . We locate it after the "kind=..." token by
# scanning for the ".." separator and backing up to its number start.
def find_geom(ls: uint64, le: uint64) -> uint64:
    # Find the ".." then walk backward to the start of <x>.
    dd: uint64 = le
    i: uint64 = ls
    while i + 1 < le:
        if list_buf[i] == 46 and list_buf[i + 1] == 46:
            dd = i
            i = le
        else:
            i = i + 1
    if dd >= le:
        return le
    # back up over "<x>x<y>" — find the start: skip back over digits,
    # one 'x', digits, to a leading space.
    j: uint64 = dd
    # j currently at first '.'; the char before is the last digit of y0.
    while j > ls and list_buf[j - 1] != 32:
        j = j - 1
    return j


# ====================================================================
# Layer rasterisation: parse hamML and draw into layerbuf
# ====================================================================

def slot_for_fbref(name_s: uint64, name_e: uint64) -> int64:
    # Match markup_buf[name_s..name_e) against a layer name in the table.
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        ll: uint64 = strlen_u8(lp)
        if ll == (name_e - name_s):
            k: uint64 = 0
            ok: int32 = 1
            while k < ll:
                if lp[k] != markup_buf[name_s + k]:
                    ok = 0
                    k = ll
                else:
                    k = k + 1
            if ok != 0:
                return cast[int64](si)
        si = si + 1
    return -1


def rasterise_markup(wid: int32, slot: uint64):
    n: int64 = read_layer_markup(wid, slot)
    if n <= 0:
        return
    total: uint64 = cast[uint64](n)
    # group translate accumulator (translate-only v1)
    gtx: int64 = 0
    gty: int64 = 0
    i: uint64 = 0
    while i < total:
        if markup_buf[i] != 60:                        # '<'
            i = i + 1
        else:
            ts: uint64 = i + 1
            # closing tag?
            if ts < total and markup_buf[ts] == 47:    # '</'
                # check for </group>
                if tag_is(ts + 1, total, "group"):
                    gtx = 0
                    gty = 0
                # skip to '>'
                while i < total and markup_buf[i] != 62:
                    i = i + 1
                i = i + 1
            else:
                # read tag name
                ne: uint64 = ts
                while ne < total and markup_buf[ne] != 32 and \
                      markup_buf[ne] != 9 and markup_buf[ne] != 10 and \
                      markup_buf[ne] != 13 and markup_buf[ne] != 62 and \
                      markup_buf[ne] != 47:
                    ne = ne + 1
                astart: uint64 = ne
                # find end of tag '>'
                te: uint64 = ne
                while te < total and markup_buf[te] != 62:
                    te = te + 1
                aend: uint64 = te
                # self-closing? trailing '/'
                # (we don't special-case; attrs parse the same)
                handle_tag(wid, ts, ne, astart, aend, gtx, gty,
                           &gtx, &gty, total)
                i = te + 1
    return


def tag_is(s: uint64, total: uint64, name: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(name)
    k: uint64 = 0
    while k < nlen:
        if s + k >= total:
            return 0
        if markup_buf[s + k] != name[k]:
            return 0
        k = k + 1
    return 1


def handle_tag(wid: int32, ns: uint64, ne: uint64,
               astart: uint64, aend: uint64,
               gtx: int64, gty: int64,
               gtx_out: Ptr[int64], gty_out: Ptr[int64],
               total: uint64):
    # default colours
    r: Array[1, uint8]
    g: Array[1, uint8]
    b: Array[1, uint8]
    a: Array[1, uint8]
    if tag_is(ns, total, "rect") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "line") != 0 and (ne - ns) == 4:
        x1: int64 = attr_i64(astart, aend, "x1", 0) + gtx
        y1: int64 = attr_i64(astart, aend, "y1", 0) + gty
        x2: int64 = attr_i64(astart, aend, "x2", 0) + gtx
        y2: int64 = attr_i64(astart, aend, "y2", 0) + gty
        wd: int64 = attr_i64(astart, aend, "width", 1)
        if wd < 1:
            wd = 1
        r[0] = 200
        g[0] = 200
        b[0] = 200
        a[0] = 255
        get_stroke(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_line(x1, y1, x2, y2, wd, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "text") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        # text content is between aend+1 ('>') and the next '<'
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        # #444-followup Phase 4d: select mono/sans/serif via the
        # optional font="..." attr. Missing attr = mono = the legacy
        # behaviour, preserving every existing hamML markup test.
        fam: int32 = attr_font_family(astart, aend)
        raster_text_fam(cs, ce, x, y, r[0], g[0], b[0], a[0], fam)
        return
    if tag_is(ns, total, "button") != 0 and (ne - ns) == 6:
        # draw a filled box + label text
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 64)
        h: int64 = attr_i64(astart, aend, "h", 20)
        r[0] = 80
        g[0] = 80
        b[0] = 80
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        raster_text(cs, ce, x + 4, y + 2, 255, 255, 255, 255)
        return
    if tag_is(ns, total, "input") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 100)
        h: int64 = attr_i64(astart, aend, "h", 18)
        raster_rect(x, y, w, h, 40, 40, 40, 255)
        # placeholder text
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "placeholder", &vs[0], &ve[0]) != 0:
            raster_text(vs[0], ve[0], x + 3, y + 1, 160, 160, 160, 255)
        return
    if tag_is(ns, total, "image") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "src", &vs[0], &ve[0]) != 0:
            # only "fb:<layer>" supported in v1
            s0: uint64 = vs[0]
            if (ve[0] - s0) > 3 and markup_buf[s0] == 102 and \
               markup_buf[s0 + 1] == 98 and markup_buf[s0 + 2] == 58:
                src_slot: int64 = slot_for_fbref(s0 + 3, ve[0])
                if src_slot >= 0:
                    raster_image_fb(cast[uint64](src_slot), x, y, w, h)
        return
    if tag_is(ns, total, "group") != 0 and (ne - ns) == 5:
        # transform="translate(dx,dy)"
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "transform", &vs[0], &ve[0]) != 0:
            tdx: Array[1, int64]
            tdy: Array[1, int64]
            tdx[0] = 0
            tdy[0] = 0
            parse_translate(vs[0], ve[0], &tdx[0], &tdy[0])
            gtx_out[0] = gtx + tdx[0]
            gty_out[0] = gty + tdy[0]
        return
    # <window ...> and unknown tags: ignore (metadata only).
    return


def get_fill(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
             b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "fill", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def get_stroke(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
               b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "stroke", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def apply_opacity(astart: uint64, aend: uint64, a: Ptr[uint8]):
    # per-element opacity 0..1 (float-shape) -> scale alpha. We accept
    # an integer 0..255 too (if value > 1). v1 keeps it simple: a value
    # "0".."1" with a dot is read as tenths/hundredths via the first two
    # fractional digits; otherwise treated as 0..255.
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "opacity", &vs[0], &ve[0]) == 0:
        return
    s: uint64 = vs[0]
    e: uint64 = ve[0]
    # whole part
    whole: int64 = parse_i64_span(&markup_buf[0], s, e)
    # fractional?
    di: uint64 = s
    while di < e and markup_buf[di] != 46:
        di = di + 1
    if di < e:
        # has a dot -> treat as 0..1 float; scale to 0..255
        # read up to two fractional digits
        f1: int64 = 0
        f2: int64 = 0
        if di + 1 < e and markup_buf[di + 1] >= 48 and markup_buf[di + 1] <= 57:
            f1 = cast[int64](cast[int32](markup_buf[di + 1]) - 48)
        if di + 2 < e and markup_buf[di + 2] >= 48 and markup_buf[di + 2] <= 57:
            f2 = cast[int64](cast[int32](markup_buf[di + 2]) - 48)
        frac: int64 = whole * 100 + f1 * 10 + f2     # 0..100 (clamp)
        if frac > 100:
            frac = 100
        a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](frac)) / 100)
    else:
        if whole >= 0 and whole <= 255:
            a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](whole)) / 255)


def parse_translate(s: uint64, e: uint64, dx: Ptr[int64], dy: Ptr[int64]):
    # "translate(DX,DY)"
    i: uint64 = s
    while i < e and markup_buf[i] != 40:               # '('
        i = i + 1
    if i >= e:
        return
    i = i + 1
    dx[0] = parse_i64_span(&markup_buf[0], i, e)
    while i < e and markup_buf[i] != 44:               # ','
        i = i + 1
    if i < e:
        i = i + 1
    dy[0] = parse_i64_span(&markup_buf[0], i, e)


# ====================================================================
# Composite the current layer buffer into the target with per-layer
# opacity. Both buffers are premultiplied RGBA.
# ====================================================================

def composite_layer(opac: int64):
    op: uint64 = cast[uint64](opac)
    if op > 255:
        op = 255
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            sa: uint64 = (cast[uint64](layerbuf[o + 3]) * op) / 255
            if sa != 0:
                sr: uint64 = (cast[uint64](layerbuf[o]) * op) / 255
                sg: uint64 = (cast[uint64](layerbuf[o + 1]) * op) / 255
                sb: uint64 = (cast[uint64](layerbuf[o + 2]) * op) / 255
                inv: uint64 = 255 - sa
                dr: uint64 = cast[uint64](target[o])
                dg: uint64 = cast[uint64](target[o + 1])
                db: uint64 = cast[uint64](target[o + 2])
                target[o] = cast[uint8](sr + (dr * inv) / 255)
                target[o + 1] = cast[uint8](sg + (dg * inv) / 255)
                target[o + 2] = cast[uint8](sb + (db * inv) / 255)
                target[o + 3] = 255
            x = x + 1
        y = y + 1


# ====================================================================
# Output: AI-readable text dump
# ====================================================================

def emit_hex_byte(v: uint8, out: Ptr[uint8]):
    hi: uint8 = cast[uint8]((cast[uint64](v) >> 4) & 15)
    lo: uint8 = cast[uint8](cast[uint64](v) & 15)
    if hi < 10:
        out[0] = 48 + hi
    else:
        out[0] = 97 + (hi - 10)
    if lo < 10:
        out[1] = 48 + lo
    else:
        out[1] = 97 + (lo - 10)


def emit_pix(x: uint64, y: uint64):
    # "PIX <x> <y> #rrggbb\n"
    o: uint64 = (y * WIN_W + x) * 4
    line: Array[40, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PIX "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(x, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(y, &line[p])
    line[p] = 32
    p = p + 1
    line[p] = 35                                       # '#'
    p = p + 1
    emit_hex_byte(target[o], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 1], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 2], &line[p])
    p = p + 2
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def is_bg(x: uint64, y: uint64) -> int32:
    o: uint64 = (y * WIN_W + x) * 4
    if target[o] == BG_R and target[o + 1] == BG_G and target[o + 2] == BG_B:
        return 1
    return 0


def count_nonbg_region(rx: uint64, ry: uint64, rw: uint64, rh: uint64) -> uint64:
    cnt: uint64 = 0
    y: uint64 = ry
    ymax: uint64 = ry + rh
    while y < ymax and y < WIN_H:
        x: uint64 = rx
        xmax: uint64 = rx + rw
        while x < xmax and x < WIN_W:
            if is_bg(x, y) == 0:
                cnt = cnt + 1
            x = x + 1
        y = y + 1
    return cnt


def emit_region(name: Ptr[uint8], rx: uint64, ry: uint64,
                rw: uint64, rh: uint64):
    # "REGION <name> <x> <y> <w> <h> nonbg=<count>\n" — a deterministic
    # test hook: lets a CI grep assert "the text band has >0 non-bg
    # pixels" without depending on the coarse probe grid landing on a
    # glyph stroke.
    cnt: uint64 = count_nonbg_region(rx, ry, rw, rh)
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "REGION "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    k = 0
    while name[k] != 0:
        line[p] = name[k]
        p = p + 1
        k = k + 1
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rx, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(ry, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rw, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rh, &line[p])
    sfx: Ptr[uint8] = " nonbg="
    k = 0
    while sfx[k] != 0:
        line[p] = sfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cnt, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def emit_ascii_art():
    # Downscale to ART_W x ART_H by sampling. '#' = non-background.
    ART_W: uint64 = 80
    ART_H: uint64 = 30
    line: Array[96, uint8]
    ry: uint64 = 0
    while ry < ART_H:
        p: uint64 = 0
        pfx: Ptr[uint8] = "ART "
        k: uint64 = 0
        while pfx[k] != 0:
            line[p] = pfx[k]
            p = p + 1
            k = k + 1
        rx: uint64 = 0
        while rx < ART_W:
            sx: uint64 = (rx * WIN_W) / ART_W
            sy: uint64 = (ry * WIN_H) / ART_H
            if is_bg(sx, sy) != 0:
                line[p] = 32                           # ' '
            else:
                line[p] = 35                           # '#'
            p = p + 1
            rx = rx + 1
        line[p] = 10
        p = p + 1
        sys_write(1, &line[0], p)
        ry = ry + 1


def emit_probe_grid():
    # A regular grid of probe pixels so a CI grep can assert colours at
    # known coordinates.
    PY: uint64 = 0
    while PY < WIN_H:
        PX: uint64 = 0
        while PX < WIN_W:
            emit_pix(PX, PY)
            PX = PX + 40
        PY = PY + 40


# ====================================================================
# Optional: write the composited frame into a "_screen" fb layer so the
# bytes round-trip through the cdev. Best-effort.
# ====================================================================

def write_screen_layer(wid: int32):
    # Ensure a "_screen" fb layer exists (256x256 max), then write a
    # downscaled copy of the target into its fb. ctl create is via
    # /dev/wsys/<wid>/draw/ctl.
    build_path(wid, cast[Ptr[uint8]](0), "ctl")
    cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if cf >= 0:
        cmd: Ptr[uint8] = "mklayer _screen fb 256 256\n"
        sys_write(cf, cmd, strlen_u8(cmd))
        sys_close(cf)
    # write fb: downscale target -> 256x256 into fb_read_buf, then write.
    yy: uint64 = 0
    while yy < FB_DIM:
        xx: uint64 = 0
        while xx < FB_DIM:
            sx: uint64 = (xx * WIN_W) / FB_DIM
            sy: uint64 = (yy * WIN_H) / FB_DIM
            so: uint64 = (sy * WIN_W + sx) * 4
            dout: uint64 = (yy * FB_DIM + xx) * 4
            fb_read_buf[dout] = target[so]
            fb_read_buf[dout + 1] = target[so + 1]
            fb_read_buf[dout + 2] = target[so + 2]
            fb_read_buf[dout + 3] = target[so + 3]
            xx = xx + 1
        yy = yy + 1
    build_path(wid, "_screen", "fb")
    wf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if wf >= 0:
        sys_write(wf, &fb_read_buf[0], FB_DIM * FB_DIM * 4)
        sys_close(wf)


# ====================================================================
# render <wid>
# ====================================================================

def cmd_render(wid: int32) -> int32:
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        write_str(2, "hamUId: cannot read /dev/wsys/<wid>/draw (no such wid?)\n")
        return 1
    target_clear()
    # Composite layers in listing order (kernel emits z-ascending).
    si: uint64 = 0
    while si < LT_COUNT:
        # Skip the synthetic _screen layer if present (avoid feedback).
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                # fb layer: read its pixels straight into the layer buf
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    # --- emit the AI-readable dump ---
    hdr: Array[96, uint8]
    p: uint64 = 0
    h0: Ptr[uint8] = "DUMP wid="
    k: uint64 = 0
    while h0[k] != 0:
        hdr[p] = h0[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &hdr[p])
    h1: Ptr[uint8] = " win=640x480 layers="
    k = 0
    while h1[k] != 0:
        hdr[p] = h1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(LT_COUNT, &hdr[p])
    hdr[p] = 10
    p = p + 1
    sys_write(1, &hdr[0], p)
    emit_probe_grid()
    # Deterministic region summaries (test hooks that don't depend on the
    # coarse probe grid landing on a specific glyph stroke). The "text"
    # band is to the RIGHT of any rect a chrome layer typically draws, so
    # a non-zero count there proves GLYPHS rasterised, not a rect.
    emit_region("text", 192, 32, 160, 32)
    emit_ascii_art()
    write_str(1, "DUMP END\n")
    # round-trip into _screen fb (best-effort; ignore errors)
    write_screen_layer(wid)
    return 0


def composite_fb_layer(wid: int32, slot: uint64):
    # Read the fb body and blit (with the layer geometry offset) into
    # the layer buffer.
    n: int64 = read_layer_fb(slot)
    if n <= 0:
        return
    sw: int64 = LT_W[slot]
    sh: int64 = LT_H[slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    ox: int64 = LT_X[slot]
    oy: int64 = LT_Y[slot]
    yy: int64 = 0
    while yy < sh:
        xx: int64 = 0
        while xx < sw:
            so: uint64 = cast[uint64](yy * sw + xx) * 4
            if so + 3 < cast[uint64](n):
                layer_put(ox + xx, oy + yy, fb_read_buf[so],
                          fb_read_buf[so + 1], fb_read_buf[so + 2],
                          fb_read_buf[so + 3])
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Phase 4c — physical presentation to /dev/fb
# ====================================================================
#
# `hamUId present <wid>` composites the window exactly like `render`
# (reusing the 4b compositor that fills `target` with the 640x480
# window frame), reads /dev/fb's geometry, scales the window frame to
# fit the screen with letterboxing (preserve aspect, centre, black
# bars), and writes it to /dev/fb as RGBA8888.
#
# We present one SCREEN ROW at a time into screen_row, then write the
# whole row to /dev/fb at the pixel offset (scr_y * scr_w) * 4. The
# kernel cdev repacks RGBA -> hardware pixel order per fb_pixfmt and
# honours fb_pitch, so userland only deals in RGBA8888. Row-at-a-time
# keeps userland memory bounded regardless of screen resolution.

SCREEN_ROW_MAXW: uint64 = 4096          # cap a single screen row at 4096 px
screen_row: Array[16384, uint8]         # SCREEN_ROW_MAXW * 4

# DEPERF — batched present band.
# The daemon present paths used to write the composed frame to /dev/fb ONE
# SCREEN ROW AT A TIME: a sys_write(2) per scanline, ~H syscalls for a full
# present (e.g. 800 on a 1280x800 screen) and one per row of every partial
# present. The /dev/fb cdev addresses pixels by file offset (off/4) and
# consumes any count at any offset (drivers/video/fb_cdev.ad::devfb_write),
# so a contiguous run of full-width rows can be coalesced into a SINGLE
# write. screen_band holds up to SCREEN_BAND_ROWS composed full-width rows;
# the present paths fill it then flush the whole band in one sys_write,
# cutting the full-screen present from ~H syscalls to ~ceil(H/BAND_ROWS).
# 4096 px * 64 rows * 4 B = 1 MiB; at 1280x800 a full present is 4 writes.
SCREEN_BAND_ROWS: uint64 = 64
screen_band: Array[1048576, uint8]      # SCREEN_ROW_MAXW * SCREEN_BAND_ROWS * 4

# Parsed /dev/fb geometry.
FBG_W: uint64 = 0
FBG_H: uint64 = 0
FBG_PITCH: uint64 = 0
FBG_BPP: uint64 = 0
FBG_PIXFMT: uint64 = 0


def read_fb_geometry() -> int32:
    # Read "WIDTH HEIGHT PITCH BPP PIXFMT\n" from /dev/fb. Returns 1 on
    # success (FBG_* populated), 0 on failure.
    p: Ptr[uint8] = "/dev/fb"
    fd: int32 = sys_open(cast[Ptr[char]](p))
    if fd < 0:
        return 0
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 0
    total: uint64 = cast[uint64](n)
    # Parse five space-separated decimals.
    pos: Array[1, uint64]
    pos[0] = 0
    FBG_W = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_H = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PITCH = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_BPP = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PIXFMT = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    if FBG_W == 0 or FBG_H == 0:
        return 0
    return 1


def next_dec(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip non-digits, then parse a run of decimal digits. Advances *pos.
    i: uint64 = pos[0]
    while i < total and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    return v


def composite_window(wid: int32) -> int32:
    # Run the 4b compositor: parse the layer listing, fill `target` with
    # the composited 640x480 window frame. Returns 0 on success, 1 if
    # the wid's draw listing can't be read.
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        return 1
    target_clear()
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    return 0


# ====================================================================
# Live markup-client body refresh
# ====================================================================
# A hamui client paints its whole window into its draw surface; the live
# daemon must rasterise that markup every frame and composite the result
# into the on-screen window body. daemon_markup_read_body() runs the SAME
# offline compositor (composite_window) to fill `target` with the client's
# 640x480 frame, then copies the body-sized top-left region of `target`
# into the per-slot markup_body_buf. window_render_self() later samples
# that buffer per body pixel (exactly like the vk body path). No second
# hamML parser: the offline rect/line/text/colour/fb machinery is reused
# verbatim. Returns 1 on success (buffer populated), 0 if the wid has no
# readable draw surface.

# Byte offset of body pixel (bx,by) for slot `wi` inside markup_body_buf.
# Each slot's sub-buffer is MB_W*MB_H*4 with a fixed MB_W row stride.
def markup_body_off(wi: uint64, bx: int64, by: int64) -> uint64:
    base: uint64 = cast[uint64](wi) * cast[uint64](MB_W * MB_H * 4)
    return base + cast[uint64]((by * MB_W + bx) * 4)


def daemon_markup_read_body(wi: uint64) -> int32:
    wid: int32 = DWIN_WID[wi]
    if wid < 2:
        return 0
    # Body geometry on screen: window minus the 2px border + title bar.
    body_w: int64 = DWIN_W[wi] - 4
    body_h: int64 = DWIN_H[wi] - title_h_of(wi) - 2
    if body_w <= 0 or body_h <= 0:
        markup_body_ready[wi] = 0
        return 0
    if body_w > MB_W:
        body_w = MB_W
    if body_h > MB_H:
        body_h = MB_H
    # Rasterise the client's whole window frame into `target` (640x480),
    # reusing the offline compositor. A window with no readable draw
    # listing (e.g. it never created a layer) fails here.
    if composite_window(wid) != 0:
        markup_body_ready[wi] = 0
        return 0
    # Copy the body-sized top-left region of `target` into this slot's
    # body buffer. The client paints in window-content coordinates so
    # (0,0) of `target` is the body's top-left.
    by: int64 = 0
    while by < body_h:
        bx: int64 = 0
        while bx < body_w:
            so: uint64 = cast[uint64](by * cast[int64](WIN_W) + bx) * 4
            dofo: uint64 = markup_body_off(wi, bx, by)
            markup_body_buf[dofo]     = target[so]
            markup_body_buf[dofo + 1] = target[so + 1]
            markup_body_buf[dofo + 2] = target[so + 2]
            markup_body_buf[dofo + 3] = 255
            bx = bx + 1
        by = by + 1
    markup_body_bw[wi] = body_w
    markup_body_bh[wi] = body_h
    markup_body_ready[wi] = 1
    EVL_STAT_BODY_READS = EVL_STAT_BODY_READS + 1
    return 1


# Does window `wi` publish a readable "ui" markup layer? Used to AUTO-FLAG
# a spawned program-backed window as a markup client the first time its
# client has painted, without the daemon needing to know the program kind.
def markup_client_probe(wi: uint64) -> int32:
    wid: int32 = DWIN_WID[wi]
    if wid < 2:
        return 0
    pui: Ptr[uint8] = "ui"
    pmk: Ptr[uint8] = "markup"
    build_path(wid, pui, pmk)
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return 0
    sys_close(fd)
    return 1


# Once-per-frame markup-client refresh. Called at the TOP of the present
# pass (from window_cache_sync) before any window surface is composited,
# so the rasterised body is current when window_render_self samples it.
# For each program-backed window we (a) auto-detect a "ui" markup layer
# and latch DWIN_MARKUP, then (b) re-rasterise its body. Built-in apps,
# vk windows and plain terminals are skipped. Only windows visible on the
# current workspace are refreshed (off-workspace bodies aren't sampled).
def markup_sync():
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) == 0:
            wi = wi + 1
            continue
        # Built-in procedural app or vk-bodied window: never a markup client.
        if DWIN_APP[wi] != APP_TERM or DWIN_VK[wi] != 0:
            wi = wi + 1
            continue
        # Auto-flag the first time the client publishes a "ui" layer. This
        # probe is a cheap open()+close() (NO body raster), so it stays on
        # every call — client auto-detect is unaffected by the throttle.
        newly_detected: int32 = 0
        if DWIN_MARKUP[wi] == 0 and markup_client_probe(wi) != 0:
            DWIN_MARKUP[wi] = 1
            newly_detected = 1
        # EVLOOP: the EXPENSIVE part — daemon_markup_read_body's
        # composite_window /dev/wsys file read — is GEN-GATED. A body
        # re-read runs only when:
        #   * the kernel's per-layer gen counter says the client repainted
        #     since our last rasterize (g != evl_gen[wi]),
        #   * the window was JUST detected as a markup client (so its
        #     content rasterises on the same present that detects it),
        #   * the cached body was invalidated (raise/close slot moves,
        #     resize), or
        #   * MARKUP_DUE forces a one-shot re-read of everything (first
        #     present, workspace switch, theme recolour).
        # Cursor-only and window-move presents pay ONE pure gen read per
        # markup window and ZERO body rasterizes when nothing changed.
        if DWIN_MARKUP[wi] != 0:
            # Read gen BEFORE the body so a client repaint racing the
            # rasterize bumps gen past evl_gen and re-triggers next frame.
            g: int64 = read_layer_gen_ui(DWIN_WID[wi])
            due: int32 = 0
            if MARKUP_DUE != 0 or newly_detected != 0:
                due = 1
            if markup_body_ready[wi] == 0:
                due = 1
            if g >= 0 and g != evl_gen[wi]:
                due = 1
            if due != 0:
                if daemon_markup_read_body(wi) != 0:
                    # Body content changed -> its surface cache is stale.
                    DWIN_CONTENT_DIRTY[wi] = 1
                    evl_gen[wi] = g
        wi = wi + 1
    # The one-shot force latch has been serviced by this present; clear it
    # so subsequent presents (cursor moves, window drags) are purely
    # gen-gated.
    MARKUP_DUE = 0


def cmd_present(wid: int32) -> int32:
    if composite_window(wid) != 0:
        write_str(2, "hamUId: present: cannot read /dev/wsys/<wid>/draw\n")
        return 1
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: present: cannot read /dev/fb geometry\n")
        return 1
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    # Aspect-preserving fit of WIN_W x WIN_H into sw x sh. Integer math:
    # scale numerator/denominator = min(sw/WIN_W, sh/WIN_H). To avoid
    # fractions we compute the destination content rectangle directly.
    #   fit_w = min(sw, sh * WIN_W / WIN_H)
    #   fit_h = min(sh, sw * WIN_H / WIN_W)
    fit_w: uint64 = sw
    fit_h: uint64 = (sw * WIN_H) / WIN_W
    if fit_h > sh:
        fit_h = sh
        fit_w = (sh * WIN_W) / WIN_H
    if fit_w > sw:
        fit_w = sw
    if fit_w == 0:
        fit_w = 1
    if fit_h == 0:
        fit_h = 1
    # Letterbox offsets (centre the content rect).
    ox: uint64 = (sw - fit_w) / 2
    oy: uint64 = (sh - fit_h) / 2
    # Open /dev/fb for writing the frame.
    pw: Ptr[uint8] = "/dev/fb"
    wf: int32 = sys_open_write(cast[Ptr[char]](pw))
    if wf < 0:
        write_str(2, "hamUId: present: cannot open /dev/fb for write\n")
        return 1
    # DEPERF batched present: compose up to SCREEN_BAND_ROWS letterboxed
    # rows into screen_band and flush the band in ONE contiguous sys_write
    # (the screen rows are adjacent, so the write cursor advances exactly
    # one band's worth of bytes per flush — no seek needed). ceil(H/B)
    # syscalls instead of H.
    row_bytes: uint64 = sw * 4
    band_rows: uint64 = SCREEN_BAND_ROWS
    sy: uint64 = 0
    while sy < sh:
        nrows: uint64 = band_rows
        if sy + nrows > sh:
            nrows = sh - sy
        ry: uint64 = 0
        while ry < nrows:
            scr_y: uint64 = sy + ry
            base: uint64 = ry * row_bytes
            # Clear this band row to black (letterbox bars).
            ci: uint64 = 0
            while ci < row_bytes:
                screen_band[base + ci] = 0
                ci = ci + 1
            # If this screen row is inside the content band, scale-sample
            # the window frame into it.
            if scr_y >= oy and scr_y < oy + fit_h:
                relq: uint64 = scr_y - oy
                srcy: uint64 = (relq * WIN_H) / fit_h
                if srcy >= WIN_H:
                    srcy = WIN_H - 1
                dx: uint64 = 0
                while dx < fit_w:
                    srcx: uint64 = (dx * WIN_W) / fit_w
                    if srcx >= WIN_W:
                        srcx = WIN_W - 1
                    so: uint64 = (srcy * WIN_W + srcx) * 4
                    doff: uint64 = base + (ox + dx) * 4
                    if (ox + dx) < sw:
                        screen_band[doff] = target[so]
                        screen_band[doff + 1] = target[so + 1]
                        screen_band[doff + 2] = target[so + 2]
                        screen_band[doff + 3] = 255
                    dx = dx + 1
            ry = ry + 1
        # Write the whole band at its pixel offset in the screen frame. The
        # fd cursor advances by the bytes written, so successive bands land
        # contiguously (no explicit lseek needed).
        sys_write(wf, &screen_band[0], row_bytes * nrows)
        sy = sy + nrows
    sys_close(wf)
    # Emit a deterministic AI/CI-readable summary line so a headless test
    # can assert the present happened even without screendump.
    emit_present_summary(wid, sw, sh, fit_w, fit_h, ox, oy)
    return 0


def emit_present_summary(wid: int32, sw: uint64, sh: uint64,
                         fit_w: uint64, fit_h: uint64,
                         ox: uint64, oy: uint64):
    # "PRESENT wid=<w> screen=<sw>x<sh> fit=<fw>x<fh> off=<ox>,<oy>\n"
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PRESENT wid="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &line[p])
    s1: Ptr[uint8] = " screen="
    k = 0
    while s1[k] != 0:
        line[p] = s1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(sw, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(sh, &line[p])
    s2: Ptr[uint8] = " fit="
    k = 0
    while s2[k] != 0:
        line[p] = s2[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(fit_w, &line[p])
    line[p] = 120
    p = p + 1
    p = p + u64_to_dec(fit_h, &line[p])
    s3: Ptr[uint8] = " off="
    k = 0
    while s3[k] != 0:
        line[p] = s3[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(ox, &line[p])
    line[p] = 44                                     # ','
    p = p + 1
    p = p + u64_to_dec(oy, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


# ====================================================================
# Phase 4c-interactive — the persistent daemon
# ====================================================================
#
#   hamUId daemon
#       A persistent present-loop that owns the physical framebuffer:
#         * opens /dev/fb (geometry once) and /dev/mouse,
#         * maintains a cursor position (starts at screen centre) driven
#           by the mouse dx/dy each iteration, clamped to screen bounds,
#         * composites a flat root backdrop + every window created by the
#           drag gesture + the cursor (a small arrow), and PRESENTS the
#           result to /dev/fb whenever anything changed,
#         * implements the canonical rio DRAG-TO-CREATE gesture: a
#           left-button-down at (x0,y0) begins a drag; while held a
#           rubber-band outline rectangle tracks the cursor; a
#           left-button-up at (x1,y1), if the swept rectangle exceeds a
#           small threshold, allocates a new wid (spawn detached
#           hamsh + sys_wsys_alloc, mirroring user/hamUI.ad's cmd_new)
#           and records the rectangle as a window so its chrome paints
#           where it was dragged.
#
#       It does NOT auto-start at boot — it is launched explicitly (by a
#       user or a test). It yields the CPU every idle iteration so it
#       never spins at 100%.
#
# The daemon owns the WHOLE physical screen (unlike `present`, which
# scales one 640x480 window). It composites directly at screen
# resolution one ROW at a time into screen_row (reused from `present`),
# computing each pixel from a tiny model — backdrop, the window table,
# the rubber band, and the cursor — so userland memory stays bounded
# regardless of screen size.

# Root backdrop colour (a calm slate so window chrome and the cursor
# stand out for screendump assertions). The "Change Background" desktop
# context-menu action cycles ROOT_* through BG_PALETTE (MATE lets you
# pick a solid colour from the right-click menu); BG_IDX selects the
# current entry.
ROOT_R: uint8 = 32
ROOT_G: uint8 = 48
ROOT_B: uint8 = 72

# Solid-colour backdrop palette (MATE-style). Each row is r,g,b. The
# desktop context menu's "Change Background" steps BG_IDX through these.
BG_COUNT: int32 = 5
BG_IDX:   int32 = 0
bg_palette: Array[15, uint8]
BG_PALETTE_INIT: int32 = 0


# Seed the backdrop palette (slate / teal / plum / forest / graphite).
def bg_palette_init():
    if BG_PALETTE_INIT != 0:
        return
    BG_PALETTE_INIT = 1
    bg_palette[0] = 32     # 0: slate (default)
    bg_palette[1] = 48
    bg_palette[2] = 72
    bg_palette[3] = 28     # 1: teal
    bg_palette[4] = 64
    bg_palette[5] = 70
    bg_palette[6] = 56     # 2: plum
    bg_palette[7] = 40
    bg_palette[8] = 76
    bg_palette[9] = 30     # 3: forest
    bg_palette[10] = 66
    bg_palette[11] = 46
    bg_palette[12] = 44    # 4: graphite
    bg_palette[13] = 46
    bg_palette[14] = 52


# Advance the desktop backdrop to the next palette entry (wraps). Emits a
# serial marker so a non-pixel test can assert the change fired.
def bg_cycle():
    bg_palette_init()
    BG_IDX = BG_IDX + 1
    if BG_IDX >= BG_COUNT:
        BG_IDX = 0
    base: uint64 = cast[uint64](BG_IDX) * 3
    ROOT_R = bg_palette[base]
    ROOT_G = bg_palette[base + 1]
    ROOT_B = bg_palette[base + 2]
    pfx: Ptr[uint8] = "DESK background "
    sys_write(1, pfx, strlen_u8(pfx))
    nb: Array[4, uint8]
    nb[0] = cast[uint8](BG_IDX) + 48
    nb[1] = 10
    sys_write(1, &nb[0], 2)


# ====================================================================
# DE image-wallpaper (PPM P6 backdrop)
# ====================================================================
# The compositor's root-window backdrop normally renders the solid
# ROOT_R/G/B colour from the palette above. When an image wallpaper is
# loaded, daemon_pixel samples the WALLPAPER_RGB buffer instead, centred
# on the screen (or top-left clipped when the image is larger than the
# screen — start simple, no scaling).
#
# Source format: NetPBM P6 (the simplest possible RGB bitmap, also the
# format `hamshot` emits). Header:
#
#     P6\n
#     <width> <height>\n          (whitespace-separated; comments allowed)
#     255\n                       (maxval — only 255 is accepted)
#     <raw 3*w*h bytes>           (R,G,B in row-major scanline order)
#
# Sizing: WALLPAPER_MAX_W * WALLPAPER_MAX_H * 3 bytes for the decoded
# RGB buffer. Cap is 640x480 (matches the default framebuffer and any
# committed sample image); a larger PPM is rejected at load. The read
# buffer is sized for the BIGGEST sane file (header + pixels).
#
# Runtime reload: the kernel records the requested path via the
# /dev/wsys/ctl `wallpaper <path>` verb; the compositor polls
# /dev/wsys/wallpaper for "<gen> <path>\n" once per main-loop tick and
# reloads on a gen bump.
WALLPAPER_MAX_W: uint64 = 640
WALLPAPER_MAX_H: uint64 = 480
WALLPAPER_MAX_BYTES: uint64 = 921600          # 640 * 480 * 3
WALLPAPER_FILE_CAP:  uint64 = 922112          # 921600 + 512 (PPM header slack)
WALLPAPER_PATH_CAP:  uint64 = 256

# Decoded RGB image.
wallpaper_rgb: Array[921600, uint8]
wallpaper_w:   uint64 = 0
wallpaper_h:   uint64 = 0
wallpaper_loaded: int32 = 0
# Last gen we loaded for (matches the kernel's wsys_wallpaper_gen).
wallpaper_gen_seen: uint64 = 0
# Slow polling: only check the kernel wallpaper file every Nth present
# tick to avoid hammering the namespace on the hot path.
WALLPAPER_POLL_EVERY: uint64 = 32
wallpaper_poll_tick:  uint64 = 0

# Raw-file read buffer (held at module scope per compiler quirk: no big
# locals). Sized for the worst-case PPM the compositor accepts.
wallpaper_read_buf: Array[922112, uint8]

# Last path we LOADED (so a redundant gen bump on the same path is still
# accepted, but we have one place to read the chosen path from for the
# selftest verb-dispatch test).
wallpaper_path_buf: Array[256, uint8]
wallpaper_path_len: uint64 = 0


# Skip ASCII whitespace + any '#'-to-end-of-line comments (PPM permits
# comments between header tokens). Returns the new offset.
def _ppm_skip_ws(buf: Ptr[uint8], pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end:
        c: uint8 = buf[p]
        if c == 32 or c == 9 or c == 10 or c == 13:
            p = p + 1
            continue
        if c == 35:                    # '#' comment to end of line
            while p < end and buf[p] != 10:
                p = p + 1
            continue
        break
    return p


# Parse one decimal token at buf[pos..end). On success writes the value
# through `out` and returns the offset of the first byte AFTER the token.
# On failure (no digits) returns `pos` unchanged.
def _ppm_parse_uint(buf: Ptr[uint8], pos: uint64, end: uint64,
                    out: Ptr[uint64]) -> uint64:
    p: uint64 = pos
    v: uint64 = 0
    seen: uint64 = 0
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c) - 48
        seen = seen + 1
        p = p + 1
    if seen == 0:
        return pos
    out[0] = v
    return p


# Parse the PPM bytes in buf[0..count) into (w, h) and copy the raw RGB
# scanlines into wallpaper_rgb. Returns 0 on success, negative on a
# format/size error. Caps width/height at WALLPAPER_MAX_W/H.
#
# Accepted shape: "P6\n<w> <h>\n255\n<raw RGB>". Whitespace between
# header tokens is flexible (one whitespace byte after "255" precedes
# the raw pixel data, matching the spec).
def ppm_parse_p6(buf: Ptr[uint8], count: uint64) -> int32:
    if count < 11:
        return -1
    if buf[0] != 80 or buf[1] != 54:           # "P6"
        return -1
    # Whitespace after the magic.
    if buf[2] != 32 and buf[2] != 9 and buf[2] != 10 and buf[2] != 13:
        return -1
    p: uint64 = 3
    p = _ppm_skip_ws(buf, p, count)
    w: uint64 = 0
    np: uint64 = _ppm_parse_uint(buf, p, count, &w)
    if np == p:
        return -2
    p = np
    p = _ppm_skip_ws(buf, p, count)
    h: uint64 = 0
    np = _ppm_parse_uint(buf, p, count, &h)
    if np == p:
        return -2
    p = np
    p = _ppm_skip_ws(buf, p, count)
    mx: uint64 = 0
    np = _ppm_parse_uint(buf, p, count, &mx)
    if np == p:
        return -2
    p = np
    if mx != 255:
        return -3
    # Exactly ONE whitespace byte separates the maxval from the binary
    # pixel block (P6 spec).
    if p >= count:
        return -4
    c0: uint8 = buf[p]
    if c0 != 32 and c0 != 9 and c0 != 10 and c0 != 13:
        return -4
    p = p + 1
    if w == 0 or h == 0:
        return -5
    if w > WALLPAPER_MAX_W or h > WALLPAPER_MAX_H:
        return -5
    nbytes: uint64 = w * h * 3
    if p + nbytes > count:
        return -6
    i: uint64 = 0
    while i < nbytes:
        wallpaper_rgb[i] = buf[p + i]
        i = i + 1
    wallpaper_w = w
    wallpaper_h = h
    wallpaper_loaded = 1
    return 0


# Try to load /etc/wallpaper.ppm (or the supplied path) into
# wallpaper_rgb. Returns 0 on success, negative on failure (file not
# present, header bad, dimensions over the cap, etc.). Failure is
# SILENT (the daemon falls back to the solid backdrop), aside from a
# one-line serial marker so a test can assert the path was attempted.
def wallpaper_load_path(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &wallpaper_read_buf[0], WALLPAPER_FILE_CAP)
    sys_close(fd)
    if n <= 0:
        return -1
    rc: int32 = ppm_parse_p6(&wallpaper_read_buf[0], cast[uint64](n))
    if rc != 0:
        wallpaper_loaded = 0
        wallpaper_w = 0
        wallpaper_h = 0
        return rc
    # Announce so the selftest / boot log can assert a load fired.
    pfx: Ptr[uint8] = "DESK wallpaper loaded "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[32, uint8]
    nw: uint64 = u64_to_dec(wallpaper_w, &wb[0])
    wb[nw] = 120                                       # 'x'
    nw = nw + 1
    nw = nw + u64_to_dec(wallpaper_h, &wb[nw])
    wb[nw] = 10
    nw = nw + 1
    sys_write(1, &wb[0], nw)
    return 0


# Compositor poll: read /dev/wsys/wallpaper for "<gen> <path>\n" and, on
# a gen bump from the kernel's `wallpaper <path>` verb, reload. Cheap
# (one open/read/close), but gated to every WALLPAPER_POLL_EVERY ticks
# so the present hot path isn't dominated by a namespace round-trip.
def wallpaper_poll_kernel():
    wallpaper_poll_tick = wallpaper_poll_tick + 1
    if (wallpaper_poll_tick % WALLPAPER_POLL_EVERY) != 0:
        return
    wp: Ptr[uint8] = "/dev/wsys/wallpaper"
    fd: int32 = sys_open(cast[Ptr[char]](wp))
    if fd < 0:
        return
    rb: Array[320, uint8]
    n: int64 = read_whole(fd, &rb[0], 320)
    sys_close(fd)
    if n <= 0:
        return
    total: uint64 = cast[uint64](n)
    # "<gen> <path>\n" — parse gen, then take the rest of the line minus
    # the trailing '\n' as path.
    pos: Array[1, uint64]
    pos[0] = 0
    g: uint64 = 0
    np: uint64 = _ppm_parse_uint(&rb[0], 0, total, &g)
    if np == 0:
        return
    if g == 0 or g == wallpaper_gen_seen:
        return
    # Skip the single space.
    if np >= total or rb[np] != 32:
        return
    np = np + 1
    # Path: rb[np..total) minus a trailing '\n'.
    pe: uint64 = total
    if pe > np and rb[pe - 1] == 10:
        pe = pe - 1
    if pe == np:
        return
    plen: uint64 = pe - np
    if plen >= WALLPAPER_PATH_CAP:
        return
    pbuf: Array[256, uint8]
    i: uint64 = 0
    while i < plen:
        pbuf[i] = rb[np + i]
        i = i + 1
    pbuf[plen] = 0
    if wallpaper_load_path(cast[Ptr[char]](&pbuf[0])) == 0:
        # Remember the loaded path for the verb-dispatch selftest.
        j: uint64 = 0
        while j < plen:
            wallpaper_path_buf[j] = pbuf[j]
            j = j + 1
        wallpaper_path_buf[plen] = 0
        wallpaper_path_len = plen
        wallpaper_gen_seen = g
        # The whole backdrop changed — force a full-screen recomposite
        # on the next frame so the new wallpaper lands at every pixel.
        damage_full()


# ====================================================================
# ROUND-4: themeable title-bar accent palette (MATE "Appearance")
# ====================================================================
# The active-window title-bar gradient reads a top/bottom RGB pair from
# the THEME accent palette instead of a fixed blue. The Settings app and a
# keyboard action cycle THEME_IDX through these named accents, persisting
# the choice for the session (in-memory). The gradient code in daemon_pixel
# reads ACCENT_TOP_*/ACCENT_BOT_*, which theme_apply() refreshes.
THEME_COUNT: int32 = 5
THEME_IDX:   int32 = 0
ACCENT_TOP_R: uint8 = 120
ACCENT_TOP_G: uint8 = 178
ACCENT_TOP_B: uint8 = 252
ACCENT_BOT_R: uint8 = 56
ACCENT_BOT_G: uint8 = 116
ACCENT_BOT_B: uint8 = 208
theme_palette: Array[30, uint8]
THEME_PALETTE_INIT: int32 = 0


def theme_palette_init():
    if THEME_PALETTE_INIT != 0:
        return
    THEME_PALETTE_INIT = 1
    theme_palette[0] = 120          # 0: Clearlooks Blue (default)
    theme_palette[1] = 178
    theme_palette[2] = 252
    theme_palette[3] = 56
    theme_palette[4] = 116
    theme_palette[5] = 208
    theme_palette[6] = 150          # 1: Graphite
    theme_palette[7] = 156
    theme_palette[8] = 168
    theme_palette[9] = 84
    theme_palette[10] = 90
    theme_palette[11] = 104
    theme_palette[12] = 130         # 2: Sage Green
    theme_palette[13] = 200
    theme_palette[14] = 140
    theme_palette[15] = 56
    theme_palette[16] = 130
    theme_palette[17] = 76
    theme_palette[18] = 240         # 3: Amber
    theme_palette[19] = 190
    theme_palette[20] = 90
    theme_palette[21] = 200
    theme_palette[22] = 120
    theme_palette[23] = 40
    theme_palette[24] = 200         # 4: Plum
    theme_palette[25] = 150
    theme_palette[26] = 230
    theme_palette[27] = 120
    theme_palette[28] = 70
    theme_palette[29] = 160


# Refresh the live accent endpoints from THEME_IDX.
def theme_apply():
    theme_palette_init()
    if THEME_IDX < 0:
        THEME_IDX = 0
    if THEME_IDX >= THEME_COUNT:
        THEME_IDX = 0
    base: uint64 = cast[uint64](THEME_IDX) * 6
    ACCENT_TOP_R = theme_palette[base]
    ACCENT_TOP_G = theme_palette[base + 1]
    ACCENT_TOP_B = theme_palette[base + 2]
    ACCENT_BOT_R = theme_palette[base + 3]
    ACCENT_BOT_G = theme_palette[base + 4]
    ACCENT_BOT_B = theme_palette[base + 5]
    # DEPERF #409: the title-bar accent just changed, so every focused
    # window's cached surface is stale. Invalidate all backbuffers.
    window_cache_invalidate_all()


# Advance the title-bar accent theme to the next entry (wraps). Emits a
# serial marker so a non-pixel test can assert the change fired.
def theme_cycle():
    theme_palette_init()
    THEME_IDX = THEME_IDX + 1
    if THEME_IDX >= THEME_COUNT:
        THEME_IDX = 0
    theme_apply()
    pfx: Ptr[uint8] = "DESK theme "
    sys_write(1, pfx, strlen_u8(pfx))
    tb: Array[4, uint8]
    tb[0] = cast[uint8](THEME_IDX) + 48
    tb[1] = 10
    sys_write(1, &tb[0], 2)


# Short accent name for the Settings display.
def theme_name(i: int32) -> Ptr[uint8]:
    if i == 0:
        n0: Ptr[uint8] = "Blue"
        return n0
    if i == 1:
        n1: Ptr[uint8] = "Graphite"
        return n1
    if i == 2:
        n2: Ptr[uint8] = "Sage"
        return n2
    if i == 3:
        n3: Ptr[uint8] = "Amber"
        return n3
    n4: Ptr[uint8] = "Plum"
    return n4


# ====================================================================
# ROUND-4: panel position preference (top / bottom)
# ====================================================================
# The MATE panel can live at the top or the bottom of the screen. The
# Settings app records the user's preference (PANEL_POS: 0 top, 1 bottom)
# so the choice persists for the session and is reported in the marker
# stream.
PANEL_POS: int32 = 0          # 0 = top (default), 1 = bottom


def panel_pos_toggle():
    if PANEL_POS == 0:
        PANEL_POS = 1
    else:
        PANEL_POS = 0
    pfx: Ptr[uint8] = "DESK panel-pos "
    sys_write(1, pfx, strlen_u8(pfx))
    pb: Array[4, uint8]
    pb[0] = cast[uint8](PANEL_POS) + 48
    pb[1] = 10
    sys_write(1, &pb[0], 2)


def panel_pos_name(p: int32) -> Ptr[uint8]:
    if p == 0:
        t0: Ptr[uint8] = "Top"
        return t0
    t1: Ptr[uint8] = "Bottom"
    return t1


# ROUND-7: focus model preference. 0 = click-to-focus (default, MATE's
# normal mode), 1 = focus-follows-mouse (the window under the pointer is
# raised/focused as the cursor moves, GNOME2's "sloppy"/focus-follows
# option). Toggled from the Settings app and consulted by the pointer
# pump so the choice takes effect live.
FOCUS_MODE: int32 = 0          # 0 = click-to-focus, 1 = follows-mouse


def focus_mode_toggle():
    if FOCUS_MODE == 0:
        FOCUS_MODE = 1
    else:
        FOCUS_MODE = 0
    pfx: Ptr[uint8] = "DESK focus-mode "
    sys_write(1, pfx, strlen_u8(pfx))
    fb: Array[4, uint8]
    fb[0] = cast[uint8](FOCUS_MODE) + 48
    fb[1] = 10
    sys_write(1, &fb[0], 2)


def focus_mode_name(p: int32) -> Ptr[uint8]:
    if p == 0:
        f0: Ptr[uint8] = "Click"
        return f0
    f1: Ptr[uint8] = "Follow"
    return f1


# ====================================================================
# ROUND-16: full THEME ENGINE (MATE "Appearance" colour scheme)
# ====================================================================
# Earlier rounds themed only the title-bar ACCENT. A real MATE theme also
# recolours the panel, the menus and the desktop backdrop together. The
# SCHEME selects a coordinated palette that mutates EVERY live colour the
# renderer reads — PANEL_*, PANEL_HI_*, PANEL_TXT_*, MENU_*, MENU_SEL_*,
# MENU_TXT_* and ROOT_* — so selecting a scheme recolours the running
# desktop chrome on the spot. Three built-in schemes:
#   0  Clearlooks  — the classic light/silver GNOME2 look (default)
#   1  Dark        — a dark slate scheme
#   2  HighContrast— black panel, white ink, vivid accent (a11y)
# Each scheme row in scheme_palette is 24 bytes:
#   0..2  PANEL_R/G/B          3..5  PANEL_HI_R/G/B
#   6..8  PANEL_TXT_R/G/B      9..11 MENU_R/G/B
#   12..14 MENU_SEL_R/G/B      15..17 MENU_TXT_R/G/B
#   18..20 ROOT_R/G/B          21..23 accent-bias (top-of-scheme accent)
SCHEME_COUNT: int32 = 3
SCHEME_IDX:   int32 = 0
scheme_palette: Array[72, uint8]
SCHEME_PALETTE_INIT: int32 = 0


def scheme_palette_init():
    if SCHEME_PALETTE_INIT != 0:
        return
    SCHEME_PALETTE_INIT = 1
    # --- scheme 0: Clearlooks (light/silver) ---
    scheme_palette[0]  = 46     # PANEL bg
    scheme_palette[1]  = 52
    scheme_palette[2]  = 64
    scheme_palette[3]  = 70     # PANEL hover hi
    scheme_palette[4]  = 90
    scheme_palette[5]  = 140
    scheme_palette[6]  = 235    # PANEL ink
    scheme_palette[7]  = 235
    scheme_palette[8]  = 240
    scheme_palette[9]  = 56     # MENU bg
    scheme_palette[10] = 62
    scheme_palette[11] = 78
    scheme_palette[12] = 70     # MENU sel
    scheme_palette[13] = 100
    scheme_palette[14] = 170
    scheme_palette[15] = 235    # MENU ink
    scheme_palette[16] = 235
    scheme_palette[17] = 240
    scheme_palette[18] = 32     # ROOT desktop
    scheme_palette[19] = 48
    scheme_palette[20] = 72
    scheme_palette[21] = 120    # accent-bias
    scheme_palette[22] = 178
    scheme_palette[23] = 252
    # --- scheme 1: Dark ---
    scheme_palette[24] = 28
    scheme_palette[25] = 30
    scheme_palette[26] = 34
    scheme_palette[27] = 52
    scheme_palette[28] = 58
    scheme_palette[29] = 78
    scheme_palette[30] = 210
    scheme_palette[31] = 212
    scheme_palette[32] = 218
    scheme_palette[33] = 34
    scheme_palette[34] = 36
    scheme_palette[35] = 42
    scheme_palette[36] = 56
    scheme_palette[37] = 70
    scheme_palette[38] = 110
    scheme_palette[39] = 208
    scheme_palette[40] = 210
    scheme_palette[41] = 216
    scheme_palette[42] = 18
    scheme_palette[43] = 20
    scheme_palette[44] = 24
    scheme_palette[45] = 90
    scheme_palette[46] = 130
    scheme_palette[47] = 180
    # --- scheme 2: HighContrast ---
    scheme_palette[48] = 0
    scheme_palette[49] = 0
    scheme_palette[50] = 0
    scheme_palette[51] = 255
    scheme_palette[52] = 255
    scheme_palette[53] = 0
    scheme_palette[54] = 255
    scheme_palette[55] = 255
    scheme_palette[56] = 255
    scheme_palette[57] = 0
    scheme_palette[58] = 0
    scheme_palette[59] = 0
    scheme_palette[60] = 255
    scheme_palette[61] = 255
    scheme_palette[62] = 0
    scheme_palette[63] = 255
    scheme_palette[64] = 255
    scheme_palette[65] = 255
    scheme_palette[66] = 0
    scheme_palette[67] = 0
    scheme_palette[68] = 0
    scheme_palette[69] = 255
    scheme_palette[70] = 255
    scheme_palette[71] = 0


# Apply SCHEME_IDX to the live chrome colour globals the renderer reads.
# This is the heart of the theme engine: after this returns, the next
# composited frame paints panel/menu/desktop in the chosen scheme. The
# title-bar ACCENT is left under THEME_IDX's control (a separate axis),
# except scheme_set() biases ACCENT to a scheme-appropriate default so a
# fresh scheme choice looks coordinated without a second click.
def scheme_apply():
    scheme_palette_init()
    if SCHEME_IDX < 0:
        SCHEME_IDX = 0
    if SCHEME_IDX >= SCHEME_COUNT:
        SCHEME_IDX = 0
    base: uint64 = cast[uint64](SCHEME_IDX) * 24
    PANEL_R = scheme_palette[base]
    PANEL_G = scheme_palette[base + 1]
    PANEL_B = scheme_palette[base + 2]
    PANEL_HI_R = scheme_palette[base + 3]
    PANEL_HI_G = scheme_palette[base + 4]
    PANEL_HI_B = scheme_palette[base + 5]
    PANEL_TXT_R = scheme_palette[base + 6]
    PANEL_TXT_G = scheme_palette[base + 7]
    PANEL_TXT_B = scheme_palette[base + 8]
    MENU_R = scheme_palette[base + 9]
    MENU_G = scheme_palette[base + 10]
    MENU_B = scheme_palette[base + 11]
    MENU_SEL_R = scheme_palette[base + 12]
    MENU_SEL_G = scheme_palette[base + 13]
    MENU_SEL_B = scheme_palette[base + 14]
    MENU_TXT_R = scheme_palette[base + 15]
    MENU_TXT_G = scheme_palette[base + 16]
    MENU_TXT_B = scheme_palette[base + 17]
    ROOT_R = scheme_palette[base + 18]
    ROOT_G = scheme_palette[base + 19]
    ROOT_B = scheme_palette[base + 20]
    # DEPERF #409: a scheme change recolours chrome the cached surfaces
    # depend on (and scheme_set then re-biases ACCENT); invalidate all
    # backbuffers so they re-render with the new palette.
    window_cache_invalidate_all()


# Select a scheme by index, applying it and biasing the title-bar accent
# to a coordinated endpoint (top colour from the scheme row, a darkened
# bottom). Also realigns BG_IDX off the desktop so the next bg_cycle is
# coherent. Emits a serial marker for non-pixel tests.
def scheme_set(idx: int32):
    SCHEME_IDX = idx
    scheme_apply()
    base: uint64 = cast[uint64](SCHEME_IDX) * 24
    ar: uint8 = scheme_palette[base + 21]
    ag: uint8 = scheme_palette[base + 22]
    ab: uint8 = scheme_palette[base + 23]
    ACCENT_TOP_R = ar
    ACCENT_TOP_G = ag
    ACCENT_TOP_B = ab
    # Bottom endpoint = ~55% of the top so the title gradient still reads.
    ACCENT_BOT_R = cast[uint8]((cast[int32](ar) * 9) / 16)
    ACCENT_BOT_G = cast[uint8]((cast[int32](ag) * 9) / 16)
    ACCENT_BOT_B = cast[uint8]((cast[int32](ab) * 9) / 16)
    pfx: Ptr[uint8] = "DESK scheme "
    sys_write(1, pfx, strlen_u8(pfx))
    sb: Array[4, uint8]
    sb[0] = cast[uint8](SCHEME_IDX) + 48
    sb[1] = 10
    sys_write(1, &sb[0], 2)


# Advance to the next colour scheme (wraps). Used by the Control Center
# Appearance row and exercised by the round-16 self-test.
def scheme_cycle():
    n: int32 = SCHEME_IDX + 1
    if n >= SCHEME_COUNT:
        n = 0
    scheme_set(n)


def scheme_name(i: int32) -> Ptr[uint8]:
    if i == 0:
        c0: Ptr[uint8] = "Clearlooks"
        return c0
    if i == 1:
        c1: Ptr[uint8] = "Dark"
        return c1
    c2: Ptr[uint8] = "HighContrast"
    return c2


# ====================================================================
# ROUND-16: UI scale (1x / 2x) — MATE "interface scaling" toggle
# ====================================================================
# A genuine session setting honoured by the Control Center's own metrics
# and reported in the marker stream. The framebuffer glyph is a fixed 8x16
# bitmap, so UI_SCALE drives a logical metric multiplier consulted via
# ui_scaled(); the Control Center lays itself out through it so the 2x
# setting visibly stretches its row pitch.
UI_SCALE: int32 = 1


def ui_scaled(n: int64) -> int64:
    if UI_SCALE <= 1:
        return n
    return n * 2


def ui_scale_toggle():
    if UI_SCALE == 1:
        UI_SCALE = 2
    else:
        UI_SCALE = 1
    pfx: Ptr[uint8] = "DESK ui-scale "
    sys_write(1, pfx, strlen_u8(pfx))
    ub: Array[4, uint8]
    ub[0] = cast[uint8](UI_SCALE) + 48
    ub[1] = 10
    sys_write(1, &ub[0], 2)


def ui_scale_name(s: int32) -> Ptr[uint8]:
    if s >= 2:
        s2: Ptr[uint8] = "2x"
        return s2
    s1: Ptr[uint8] = "1x"
    return s1


# ====================================================================
# ROUND-16: keyboard-shortcut registry (the Control Center "Keyboard"
# category lists every bound WM action with its chord).
# ====================================================================
KBD_SHORTCUT_COUNT: int64 = 8


def kbd_shortcut_chord(i: int64) -> Ptr[uint8]:
    if i == 0:
        a0: Ptr[uint8] = "Alt+Tab"
        return a0
    if i == 1:
        a1: Ptr[uint8] = "Alt+F2"
        return a1
    if i == 2:
        a2: Ptr[uint8] = "Alt+Space"
        return a2
    if i == 3:
        a3: Ptr[uint8] = "Ctrl+Alt+Right"
        return a3
    if i == 4:
        a4: Ptr[uint8] = "Ctrl+Alt+Left"
        return a4
    if i == 5:
        a5: Ptr[uint8] = "Ctrl+Alt+S+Right"
        return a5
    if i == 6:
        a6: Ptr[uint8] = "Super"
        return a6
    a7: Ptr[uint8] = "F11"
    return a7


def kbd_shortcut_action(i: int64) -> Ptr[uint8]:
    if i == 0:
        b0: Ptr[uint8] = "Cycle windows"
        return b0
    if i == 1:
        b1: Ptr[uint8] = "Run application"
        return b1
    if i == 2:
        b2: Ptr[uint8] = "Window menu"
        return b2
    if i == 3:
        b3: Ptr[uint8] = "Next workspace"
        return b3
    if i == 4:
        b4: Ptr[uint8] = "Prev workspace"
        return b4
    if i == 5:
        b5: Ptr[uint8] = "Move win to ws"
        return b5
    if i == 6:
        b6: Ptr[uint8] = "Applications menu"
        return b6
    b7: Ptr[uint8] = "Toggle fullscreen"
    return b7


# Arrange (tile) all visible windows on the current workspace into a grid
# that fills the work area below the panel — MATE's "arrange windows"
# desktop verb. Un-maximizes/un-snaps each first. Emits a marker.
def windows_arrange(scr_w: int64, scr_h: int64):
    # Count visible (non-minimized, current-workspace) windows.
    n: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) != 0:
            n = n + 1
        wi = wi + 1
    if n == 0:
        am0: Ptr[uint8] = "DESK arrange 0\n"
        sys_write(1, am0, strlen_u8(am0))
        return
    # Choose a near-square grid: cols = ceil(sqrt(n)).
    cols: int64 = 1
    while cols * cols < n:
        cols = cols + 1
    rows: int64 = (n + cols - 1) / cols
    work_y: int64 = PANEL_H
    work_h: int64 = scr_h - PANEL_H
    cell_w: int64 = scr_w / cols
    cell_h: int64 = work_h / rows
    gap: int64 = 6
    placed: int64 = 0
    wj: uint64 = 0
    while wj < DWIN_COUNT:
        if win_on_cur_ws(wj) != 0:
            col: int64 = placed % cols
            row: int64 = placed / cols
            nx: int64 = col * cell_w + gap
            ny: int64 = work_y + row * cell_h + gap
            nw: int64 = cell_w - gap * 2
            nh: int64 = cell_h - gap * 2
            if nw < 120:
                nw = 120
            if nh < 80:
                nh = 80
            DWIN_MAXED[wj] = 0
            DWIN_SNAP[wj] = 0
            DWIN_X[wj] = nx
            DWIN_Y[wj] = ny
            DWIN_W[wj] = nw
            DWIN_H[wj] = nh
            window_reflow(wj)
            placed = placed + 1
        wj = wj + 1
    am: Ptr[uint8] = "DESK arrange "
    sys_write(1, am, strlen_u8(am))
    ab: Array[4, uint8]
    ab[0] = cast[uint8](n) + 48
    ab[1] = 10
    sys_write(1, &ab[0], 2)

# Window chrome colours.
WIN_TITLE_R: uint8 = 64
WIN_TITLE_G: uint8 = 110
WIN_TITLE_B: uint8 = 200
# Focused (topmost) window: brighter title bar so the user can tell which
# window has keyboard focus at a glance.
WIN_TITLE_FOCUS_R: uint8 = 90
WIN_TITLE_FOCUS_G: uint8 = 150
WIN_TITLE_FOCUS_B: uint8 = 240
WIN_BODY_R: uint8 = 200
WIN_BODY_G: uint8 = 200
WIN_BODY_B: uint8 = 210
WIN_BORDER_R: uint8 = 240
WIN_BORDER_G: uint8 = 240
WIN_BORDER_B: uint8 = 250

TITLE_H: int64 = 18                      # window title-bar height (px)
DRAG_MIN: int64 = 12                     # min swept extent to spawn a win

# Close-box ([x]) colours: a red square with a white X glyph.
CLOSE_R: uint8 = 210
CLOSE_G: uint8 = 60
CLOSE_B: uint8 = 60
CLOSE_X_R: uint8 = 255
CLOSE_X_G: uint8 = 255
CLOSE_X_B: uint8 = 255

SIGTERM_D: int32 = 15

# ---- panel + Applications menu (GNOME2 / MATE classic launcher) -----
# A persistent horizontal PANEL bar along the TOP screen edge (the
# classic GNOME2 layout). At its left end sits an "Applications" menu
# button; clicking it drops a vertical menu of launchable programs.
# Clicking an entry spawns that program into a new window via the SAME
# spawn-into-window path the drag gesture uses; clicking off the menu
# dismisses it.
PANEL_H: int64 = 22                       # panel bar height (px)
PANEL_R: uint8 = 46                       # panel background (dark slate)
PANEL_G: uint8 = 52
PANEL_B: uint8 = 64
PANEL_HI_R: uint8 = 70                     # panel button hover/open tint
PANEL_HI_G: uint8 = 90
PANEL_HI_B: uint8 = 140
PANEL_TXT_R: uint8 = 235                   # panel label ink
PANEL_TXT_G: uint8 = 235
PANEL_TXT_B: uint8 = 240

# ---- ROUND-15: panel preferences (autohide) -----------------------
# MATE/GNOME2 panels expose an "Autohide" property: when on, the bar
# collapses to a thin sliver until the pointer touches the screen edge.
# PANEL_AUTOHIDE is the session preference (toggled from the panel's
# right-click context menu, ROUND-15); PANEL_HIDDEN tracks whether the
# bar is currently collapsed. panel_visible_h() is the single authority
# for how tall the painted bar is right now, so every panel hit-test and
# the work-area math collapse together.
PANEL_AUTOHIDE: int32 = 0       # 0 = always shown, 1 = autohide enabled
PANEL_HIDDEN: int32 = 0         # 1 while collapsed to the reveal sliver
PANEL_REVEAL_H: int64 = 2       # px of bar left poking out while hidden

# ---- ROUND-15: workspace-switch OSD popup -------------------------
# A transient centred "Workspace N" indicator shown for a few present
# cycles after a desktop switch (MATE's workspace-change OSD). OSD_TTL
# counts down once per present; while > 0 the popup paints. OSD_WS holds
# the 0-based workspace the popup names.
OSD_WS: int32 = 0
OSD_TTL: int32 = 0
OSD_TTL_MAX: int32 = 12
OSD_W: int64 = 160
OSD_H: int64 = 40
osd_lbl_buf: Array[16, uint8]   # "Workspace N" scratch for the OSD render

# ---- ROUND-15: "Add to Panel" launcher applets --------------------
# The panel context menu's "Add to Panel" pins a quick-launch applet (a
# small clickable icon on the bar, MATE's launcher applet). We track how
# many are pinned; the renderer draws QLAUNCH_COUNT icons just right of the
# Applications button. Clamped to QLAUNCH_MAX so the bar can't overflow.
QLAUNCH_COUNT: int32 = 0
QLAUNCH_MAX: int32 = 4


# ====================================================================
# ROUND-11: panel-position-aware work-area geometry
# ====================================================================
# Through round 10 every layout helper hard-coded the panel at the TOP of
# the screen (windows reserve PANEL_H at y==0). MATE/GNOME2's default
# layout puts a panel at the BOTTOM, and the panel-position setting can be
# flipped at runtime. These helpers are the single geometry authority for
# "where does usable desktop start, and how tall is it" so a bottom panel
# genuinely reserves the BOTTOM strip rather than the top. PANEL_POS is the
# session preference (0 = top, 1 = bottom) already exposed in Settings.
#
#   work_top(scr_h)  -> y of the first usable desktop row
#   work_h(scr_h)    -> usable desktop height (screen minus the panel)
#   panel_top_y(scr_h) -> y of the panel bar itself
# All three are pure functions of PANEL_POS + PANEL_H so callers stay tiny.
def work_top(scr_h: int64) -> int64:
    if PANEL_POS == 1:
        return 0                          # bottom panel: desktop starts at top
    return PANEL_H                        # top panel: desktop starts below it


def work_h(scr_h: int64) -> int64:
    return scr_h - PANEL_H


def panel_top_y(scr_h: int64) -> int64:
    if PANEL_POS == 1:
        return scr_h - PANEL_H            # bottom panel sits flush to the floor
    return 0                              # top panel sits flush to the ceiling


# ====================================================================
# ROUND-12: physically render + hit-test the panel at the CORRECT edge.
# ====================================================================
# Round 11 made the WORK AREA panel-position-aware, but the panel BAR and
# every panel hit-test still assumed a top anchor (compared an absolute Y
# against 0..PANEL_H). These helpers move the bar — and the menus that
# drop off it — to the configured edge.
#
# The renderer + every panel hit-test caches the live screen height in
# FBG_H (read_fb_geometry() populates it before any frame/selftest), so
# these zero-arg helpers can answer "where is the panel" without threading
# scr_h through dozens of call sites.
#
#   panel_y0()        -> absolute screen-Y of the panel's top row.
#   panel_local_y(y)  -> Y relative to the panel's top (0..PANEL_H-1 on bar).
#   on_panel_y(y)     -> 1 if absolute Y falls on the panel bar.
#   drop_anchor_y(h)  -> absolute screen-Y where a drop-down of pixel
#                        height `h` begins. A top panel drops DOWNWARD from
#                        its bottom edge; a bottom panel drops UPWARD so the
#                        list grows toward the screen centre (classic MATE).
#   drop_row_top(h,i,ih) -> absolute Y of row `i` (height `ih`) within a
#                        drop-down of total height `h`. For a top panel rows
#                        run downward from the anchor; for a bottom panel the
#                        anchor is the list's BOTTOM, so row 0 is highest.
def panel_y0() -> int64:
    return panel_top_y(cast[int64](FBG_H))


def panel_local_y(y: int64) -> int64:
    return y - panel_y0()


def on_panel_y(y: int64) -> int32:
    ly: int64 = panel_local_y(y)
    if ly >= 0 and ly < PANEL_H:
        return 1
    return 0


def drop_anchor_y(h: int64) -> int64:
    if PANEL_POS == 1:
        # Bottom panel: the list sits ABOVE the bar, its bottom flush to the
        # panel's top edge. Its top row is therefore panel_top - h.
        return panel_y0() - h
    # Top panel: the list hangs below the bar.
    return panel_y0() + PANEL_H


# Absolute Y of row `i` (each `ih` tall) inside a drop-down whose total
# height is `h`. Both panel positions lay rows out top-to-bottom on screen
# (row 0 is visually the first), so the only thing that changes is where
# the whole list is anchored — handled by drop_anchor_y.
def drop_row_top(h: int64, i: int64, ih: int64) -> int64:
    return drop_anchor_y(h) + i * ih


# ====================================================================
# ROUND-15: panel autohide
# ====================================================================
# panel_visible_h() is the live painted height of the panel bar: PANEL_H
# normally, but only the thin PANEL_REVEAL_H sliver while autohide has the
# bar collapsed. panel_autohide_update() decides whether the bar should be
# hidden given the current pointer Y: any pointer touching the panel's own
# edge band reveals it; otherwise (autohide on) it collapses. Returns 1 if
# the hidden state changed (the frame needs a re-present).
def panel_visible_h() -> int64:
    if PANEL_AUTOHIDE != 0 and PANEL_HIDDEN != 0:
        return PANEL_REVEAL_H
    return PANEL_H


# Toggle the autohide preference. Turning it OFF always re-reveals the bar.
def panel_autohide_toggle():
    if PANEL_AUTOHIDE != 0:
        PANEL_AUTOHIDE = 0
        PANEL_HIDDEN = 0
    else:
        PANEL_AUTOHIDE = 1
        PANEL_HIDDEN = 1
    ah: Ptr[uint8] = "PANEL autohide "
    sys_write(1, ah, strlen_u8(ah))
    ab: Array[4, uint8]
    ab[0] = cast[uint8](PANEL_AUTOHIDE) + 48
    ab[1] = 10
    sys_write(1, &ab[0], 2)


# Given the pointer's absolute Y, collapse/reveal an autohide panel. The
# reveal band is the strip of screen the panel occupies plus a few px so the
# bar pops out the instant the cursor reaches the edge. No-op unless
# autohide is enabled. Returns 1 if PANEL_HIDDEN flipped.
def panel_autohide_update(py: int64) -> int32:
    if PANEL_AUTOHIDE == 0:
        if PANEL_HIDDEN != 0:
            PANEL_HIDDEN = 0
            return 1
        return 0
    edge_y0: int64 = panel_y0()
    edge_y1: int64 = edge_y0 + PANEL_H
    inside: int32 = 0
    if py >= edge_y0 and py < edge_y1:
        inside = 1
    want_hidden: int32 = 1
    if inside != 0:
        want_hidden = 0
    if want_hidden != PANEL_HIDDEN:
        PANEL_HIDDEN = want_hidden
        return 1
    return 0


# ====================================================================
# ROUND-15: workspace-switch OSD popup
# ====================================================================
# osd_show_workspace() arms the transient "Workspace N" indicator naming
# `ws` (0-based) for OSD_TTL_MAX present cycles. osd_step() ticks the timer
# down once per present and returns 1 while the popup is still live (so the
# loop knows it must keep re-presenting to fade it). osd_active() answers
# whether the renderer should paint it. The popup is centred on the work
# area; osd_x0/osd_y0 give its top-left for BOTH panel positions.
def osd_show_workspace(ws: int32):
    OSD_WS = ws
    OSD_TTL = OSD_TTL_MAX
    # ROUND-17: the workspace indicator is the label OSD, not a slider.
    OSD_KIND = 0


def osd_active() -> int32:
    if OSD_TTL > 0:
        return 1
    return 0


def osd_step() -> int32:
    if OSD_TTL > 0:
        OSD_TTL = OSD_TTL - 1
    return osd_active()


def osd_x0(scr_w: int64) -> int64:
    return (scr_w - OSD_W) / 2


# Centre the popup vertically within the usable desktop (above a bottom
# panel, below a top panel) so it never lands under the bar.
def osd_y0(scr_h: int64) -> int64:
    return work_top(scr_h) + (work_h(scr_h) - OSD_H) / 2


# ====================================================================
# ROUND-15: window urgency / demand-attention blink
# ====================================================================
# window_set_urgent()/window_clear_urgent() flip a window's urgency hint;
# window_is_urgent() reads it. urgent_phase_step() advances the global
# blink phase once per present, and urgent_blink_on() reports whether the
# blink is on its LIT half this cycle — the taskbar renderer tints an
# urgent button on the lit half and leaves it normal on the dark half.
def window_set_urgent(slot: uint64):
    DWIN_URGENT[slot] = 1


def window_clear_urgent(slot: uint64):
    DWIN_URGENT[slot] = 0


def window_is_urgent(slot: uint64) -> int32:
    return DWIN_URGENT[slot]


def urgent_phase_step():
    URGENT_PHASE = URGENT_PHASE + 1
    if URGENT_PHASE >= URGENT_PERIOD:
        URGENT_PHASE = 0


# Lit on the first half of each blink cycle.
def urgent_blink_on() -> int32:
    if URGENT_PHASE < URGENT_PERIOD / 2:
        return 1
    return 0


# Pin a quick-launch applet to the panel (clamped). Returns 1 if it grew.
def panel_add_launcher() -> int32:
    if QLAUNCH_COUNT >= QLAUNCH_MAX:
        return 0
    QLAUNCH_COUNT = QLAUNCH_COUNT + 1
    al: Ptr[uint8] = "PANEL add-launcher "
    sys_write(1, al, strlen_u8(al))
    qb: Array[4, uint8]
    qb[0] = cast[uint8](QLAUNCH_COUNT) + 48
    qb[1] = 10
    sys_write(1, &qb[0], 2)
    return 1


# 1 if ANY listed window is currently demanding attention (so the loop can
# keep stepping the blink phase / re-presenting only when needed).
def any_window_urgent() -> int32:
    ui: uint64 = 0
    while ui < DWIN_COUNT:
        if DWIN_URGENT[ui] != 0:
            return 1
        ui = ui + 1
    return 0


# "Applications" button geometry (left end of the panel).
APPS_BTN_X: int64 = 4
APPS_BTN_W: int64 = 104                    # ~12 glyphs * 8px + padding

# Menu geometry: a vertical list dropping from just below the panel at
# the Applications button's left edge.
MENU_X: int64 = 4
MENU_W: int64 = 150
MENU_ITEM_H: int64 = 20                     # per-entry row height (px)
MENU_R: uint8 = 56                          # menu background
MENU_G: uint8 = 62
MENU_B: uint8 = 78
MENU_SEL_R: uint8 = 70                       # hovered item tint
MENU_SEL_G: uint8 = 100
MENU_SEL_B: uint8 = 170
MENU_TXT_R: uint8 = 235
MENU_TXT_G: uint8 = 235
MENU_TXT_B: uint8 = 240

MENU_OPEN: int32 = 0                         # 1 while the menu is dropped

# Menu entries: a parallel pair of (label, program-path) tables. Each
# program is a real built /bin/<name> binary (verified present in the
# build). Labels stay short so they fit MENU_W. String constants live
# inside menu_label()/menu_prog() (file-scope globals can't take string
# initialisers in Adder).
MENU_COUNT: uint64 = 18

# ---- taskbar (window-list buttons in the panel) -------------------
# Each open window gets a button on the panel, right of the
# Applications button. Buttons are TASKBAR_BTN_W pixels wide;
# minimized windows show their button in the dimmed tint, normal
# windows use the panel background; the focused (topmost) window
# gets the highlight tint.
TASKBAR_START_X: int64 = 112           # APPS_BTN_X + APPS_BTN_W + 4
TASKBAR_BTN_W:   int64 = 96           # fits ~10 chars at 8px + 16px padding
TASKBAR_BTN_H:   int64 = 20           # 1px top + 18px body + 1px bottom border
TASKBAR_BTN_Y:   int64 = 1            # top pixel within panel (1px border)

# Right-edge clock area: reserved on the right side of the panel.
# The clock string "HH:MM" is 5 chars * 8px + 8px padding each side = 56px.
CLOCK_W:  int64 = 56
CLOCK_PAD: int64 = 8                   # horizontal padding inside clock area

# Notification-area (system-tray): a small zone in the panel left of the
# clock holding status indicators — the GNOME2/MATE classic tray. Three
# cells: [0] network signal bars, [1] generic info dot, [2] ROUND-5 LIVE
# window-count badge (shows how many windows are open on the current
# workspace, updated every present). NOTIF_W is its total width; it sits
# just left of the workspace pager.
NOTIF_ICON: int64 = 14
NOTIF_PAD:  int64 = 3
NOTIF_CELLS: int64 = 3
# = NOTIF_CELLS*NOTIF_ICON + (NOTIF_CELLS+1)*NOTIF_PAD = 3*14 + 4*3 = 54.
NOTIF_W:    int64 = 54
# Live count of windows on the current workspace, refreshed each present so
# the tray badge tracks window open/close/minimize in real time.
NOTIF_WIN_COUNT: int64 = 0
# Scratch for the single-digit badge string.
notif_badge_buf: Array[4, uint8]

# ROUND-12: classic MATE "Show Desktop" applet — a small panel button that
# minimizes every window (and restores them on a second click). It sits on
# the panel just left of the clock zone. SHOWDESK_ON (declared with the
# other show-desktop state) drives a pressed/lit appearance.
SD_BTN_W: int64 = 18                   # show-desktop button width (px)

# Minimize-box geometry: a square just LEFT of the close box in the title bar.
MINIMIZE_BOX: int64 = 14              # same size as CLOSE_BOX
# Minimize box colours: yellow square with white dash.
MINIMIZE_R: uint8 = 200
MINIMIZE_G: uint8 = 160
MINIMIZE_B: uint8 = 40
MINIMIZE_DASH_R: uint8 = 255
MINIMIZE_DASH_G: uint8 = 255
MINIMIZE_DASH_B: uint8 = 255

# Clock background tint (darker than panel, so it reads as a separate zone).
CLOCK_R: uint8 = 36
CLOCK_G: uint8 = 42
CLOCK_B: uint8 = 54


# ====================================================================
# ROUND-7: clock calendar popup (drop-down monthly calendar)
# ====================================================================
# Clicking the panel clock toggles a small monthly calendar that drops
# from the clock zone, exactly like GNOME2/MATE's clock applet. The grid
# is a classic 7-column (Sun..Sat) month view; the current day-of-month
# is highlighted. The displayed month is parsed from /proc/realtime's
# YYYY-MM-DD when available; otherwise a neutral 30-day month is shown.
CAL_OPEN: int32 = 0                     # 1 while the calendar is dropped
CAL_W: int64 = 176                      # 7 cols * 24px + 8px frame
CAL_CELL_W: int64 = 24
CAL_CELL_H: int64 = 18
CAL_HEAD_H: int64 = 22                  # month-name header band
CAL_DOW_H: int64 = 16                   # day-of-week initials row
CAL_R: uint8 = 48                       # calendar body background
CAL_G: uint8 = 54
CAL_B: uint8 = 68
CAL_HEAD_R: uint8 = 34                   # header band (darker)
CAL_HEAD_G: uint8 = 40
CAL_HEAD_B: uint8 = 52
CAL_TXT_R: uint8 = 228
CAL_TXT_G: uint8 = 232
CAL_TXT_B: uint8 = 240

# Parsed current date (from /proc/realtime when readable, else a default).
CAL_YEAR:  int64 = 2026
CAL_MONTH: int64 = 1                    # 1..12
CAL_DAY:   int64 = 1                    # 1..31, the day to highlight
CAL_VALID: int32 = 0                    # 1 once parsed from a real clock
# Header strings live in cal_month_name(); scratch for the year digits.
cal_year_buf: Array[8, uint8]
cal_num_buf:  Array[4, uint8]


# ====================================================================
# ROUND-7: transient on-screen notification banner
# ====================================================================
# A lightweight notification API: notify_post() drops a banner at the
# top-right of the desktop (just under the panel) showing a title +
# message for NOTIFY_TTL frames, then it fades out over NOTIFY_FADE
# frames. notify_tick() ages it each present. Any window/applet can call
# notify_post() to surface a transient notice (MATE/libnotify feel).
NOTIFY_ACTIVE: int32 = 0                # 1 while a banner is on-screen
NOTIFY_AGE:    int64 = 0                # frames the current banner has lived
NOTIFY_TTL:    int64 = 180              # solid frames before fading begins
NOTIFY_FADE:   int64 = 60              # fade-out frames after the TTL
# P2a: wall-clock dismissal. With the P1a dirty-rect present, notify_tick
# still runs every loop iteration, but to be ROBUST against any future
# cadence change we expire the banner on a real monotonic time source
# (sys_get_jiffies, HZ=100 -> 100 jiffies = 1 s) rather than on a frame
# count alone. NOTIFY_POST_JIFFY is the post timestamp; the banner shows
# solid for NOTIFY_SOLID_JIFFIES then fades over NOTIFY_FADE_JIFFIES.
NOTIFY_POST_JIFFY:   uint64 = 0
NOTIFY_SOLID_JIFFIES: uint64 = 300     # ~3 s solid
NOTIFY_FADE_JIFFIES:  uint64 = 100     # ~1 s fade
extern def sys_get_jiffies() -> uint64
NOTIFY_W:      int64 = 260
NOTIFY_H:      int64 = 44
NOTIFY_R: uint8 = 40
NOTIFY_G: uint8 = 46
NOTIFY_B: uint8 = 60
NOTIFY_BORDER_R: uint8 = 110
NOTIFY_BORDER_G: uint8 = 150
NOTIFY_BORDER_B: uint8 = 230
# Title + body text buffers (capped; filled by notify_post()).
notify_title: Array[40, uint8]
notify_body:  Array[64, uint8]


# Copy a C string into a fixed buffer, truncating at cap-1, NUL-terminating.
def str_copy_cap(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while src[i] != 0 and i < cap - 1:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


# Post a transient notification banner with `title` and `body`. Resets the
# banner's age so it shows solid for NOTIFY_TTL frames, then fades. Emits a
# serial marker so non-graphical tests can observe the notice.
def notify_post(title: Ptr[uint8], body: Ptr[uint8]):
    str_copy_cap(&notify_title[0], title, 40)
    str_copy_cap(&notify_body[0], body, 64)
    NOTIFY_ACTIVE = 1
    NOTIFY_AGE = 0
    NOTIFY_POST_JIFFY = sys_get_jiffies()
    # ROUND-13: also persist into the message-tray history ring so the
    # notice survives the transient banner's fade-out.
    nhist_push(title, body)
    pfx: Ptr[uint8] = "NOTIFY "
    sys_write(1, pfx, strlen_u8(pfx))
    write_str(1, title)
    sp: Ptr[uint8] = ": "
    sys_write(1, sp, strlen_u8(sp))
    write_str(1, body)
    write_str(1, "\n")
    # DE pivot wave 7: republish the toast model so /bin/hamnotif sees
    # the new banner and poke its show-serial so it wakes immediately.
    notif_publish_snapshot()
    notif_poke_show()
    notif_last_alpha = 255


# Age the active banner one frame. Returns 1 if the banner is still
# on-screen (so the present loop re-paints), else 0 once it has expired.
def notify_tick() -> int32:
    if NOTIFY_ACTIVE == 0:
        return 0
    NOTIFY_AGE = NOTIFY_AGE + 1
    # Wall-clock dismissal: expire once the real elapsed time exceeds the
    # solid+fade budget, regardless of how many frames we presented. This
    # guarantees the "Welcome to Hamnix" banner goes away after ~4 s even
    # if the present cadence changes.
    elapsed: uint64 = sys_get_jiffies() - NOTIFY_POST_JIFFY
    if elapsed >= NOTIFY_SOLID_JIFFIES + NOTIFY_FADE_JIFFIES:
        NOTIFY_ACTIVE = 0
        # DE pivot wave 7: republish so /bin/hamnotif clears the toast.
        notif_publish_snapshot()
        notif_poke_show()
        notif_last_alpha = 0
        return 0
    return 1


# Current banner opacity as an 8-bit alpha (255 solid). Stays solid for
# NOTIFY_SOLID_JIFFIES of wall-clock, then ramps linearly to 0 across
# NOTIFY_FADE_JIFFIES — driven by the real time source so the fade is
# smooth and the dismissal is cadence-independent (P2a).
def notify_alpha() -> int64:
    elapsed: uint64 = sys_get_jiffies() - NOTIFY_POST_JIFFY
    if elapsed < NOTIFY_SOLID_JIFFIES:
        return 255
    fade_into: uint64 = elapsed - NOTIFY_SOLID_JIFFIES
    if fade_into >= NOTIFY_FADE_JIFFIES:
        return 0
    rem: uint64 = NOTIFY_FADE_JIFFIES - fade_into
    return cast[int64](rem * 255 / NOTIFY_FADE_JIFFIES)


# ====================================================================
# ROUND-8: MATE/GNOME2 session dialog + screen lock
# ====================================================================
# Choosing "Log Out" on the System menu no longer quits immediately —
# instead it raises a modal SESSION DIALOG centred on a dimmed desktop,
# exactly like gnome-session's logout chooser, offering:
#     row 0  Lock Screen   -> blank+lock the desktop (unlock by clicking)
#     row 1  Log Out       -> clean daemon shutdown (returns to the shell)
#     row 2  Shut Down     -> request a power-off (distinct intent marker)
#     row 3  Cancel        -> dismiss the dialog, do nothing
# A modal click-shield (like CTX_OPEN) intercepts the next press while it
# is up. Lock Screen drops a full-screen LOCK overlay that swallows all
# input until a click unlocks it (no password store yet, so a click is the
# unlock gesture — the lock surface itself is real and load-bearing).
SESSION_OPEN: int32 = 0                 # 1 while the session dialog is modal
SESSION_HOVER: int64 = -1               # row under the pointer (for highlight)
SESSION_ROWS: int64 = 4
SESSION_BTN_H: int64 = 30               # per-row button height
SESSION_PAD:  int64 = 16                # inner padding
SESSION_W:    int64 = 240
# Distinct shutdown intent the main loop acts on. 0 = none, 1 = log out,
# 2 = power-off. DAEMON_QUIT (set alongside) breaks the loop either way.
SESSION_INTENT: int32 = 0
# Screen-lock state. 1 = the desktop is locked behind the lock overlay.
LOCKED: int32 = 0


# Dialog rectangle geometry (centred). Total height = title strip + rows.
def session_total_h() -> int64:
    return SESSION_PAD * 2 + GLYPH_H + 8 + SESSION_ROWS * (SESSION_BTN_H + 6)


def session_x(scr_w: int64) -> int64:
    x: int64 = scr_w / 2 - SESSION_W / 2
    if x < 0:
        x = 0
    return x


def session_y(scr_h: int64) -> int64:
    y: int64 = scr_h / 2 - session_total_h() / 2
    if y < PANEL_H:
        y = PANEL_H
    return y


# Top y of session dialog button row `i`.
def session_row_y(scr_h: int64, i: int64) -> int64:
    base: int64 = session_y(scr_h) + SESSION_PAD + GLYPH_H + 8
    return base + i * (SESSION_BTN_H + 6)


# Label for session dialog row `i`.
def session_row_label(i: int64) -> Ptr[uint8]:
    if i == 0:
        s0: Ptr[uint8] = "Lock Screen"
        return s0
    if i == 1:
        s1: Ptr[uint8] = "Log Out"
        return s1
    if i == 2:
        s2: Ptr[uint8] = "Shut Down"
        return s2
    s3: Ptr[uint8] = "Cancel"
    return s3


# Row index (0..SESSION_ROWS-1) under screen point (px,py), or -1.
def session_row_at(px: int64, py: int64, scr_w: int64, scr_h: int64) -> int64:
    dx: int64 = session_x(scr_w) + SESSION_PAD
    dw: int64 = SESSION_W - SESSION_PAD * 2
    if px < dx or px >= dx + dw:
        return -1
    i: int64 = 0
    while i < SESSION_ROWS:
        ry: int64 = session_row_y(scr_h, i)
        if py >= ry and py < ry + SESSION_BTN_H:
            return i
        i = i + 1
    return -1


# Open the modal session dialog (called from the System menu "Log Out").
def session_open():
    SESSION_OPEN = 1
    SESSION_HOVER = -1
    pfx: Ptr[uint8] = "SESSION open\n"
    sys_write(1, pfx, strlen_u8(pfx))
    # DE pivot wave 8: republish + wake hamsessui so the dialog paints.
    sessui_publish_snapshot()
    sessui_poke_show()


# Lock the screen: drop the full-screen lock overlay and dismiss the
# dialog. Closes any open chrome so nothing peeks through the lock.
def session_lock():
    LOCKED = 1
    SESSION_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CTX_OPEN = 0
    CAL_OPEN = 0
    pfx: Ptr[uint8] = "SESSION lock\n"
    sys_write(1, pfx, strlen_u8(pfx))
    # DE pivot wave 5: republish state to /bin/hamlock and wake it so the
    # curtain paints immediately on the v2 client backbuffer.
    lock_publish_snapshot()
    lock_poke_show()


# Unlock the screen (any click on the lock overlay).
def session_unlock():
    LOCKED = 0
    pfx: Ptr[uint8] = "SESSION unlock\n"
    sys_write(1, pfx, strlen_u8(pfx))
    # DE pivot wave 5: republish + wake so hamlock clears the curtain.
    lock_publish_snapshot()
    lock_poke_show()


# Invoke the chosen session dialog row. Returns nothing; sets the loop
# shutdown flags for Log Out / Shut Down.
def session_invoke(i: int64):
    if i == 0:
        session_lock()
        # session_lock cleared SESSION_OPEN; tell hamsessui.
        sessui_publish_snapshot()
        sessui_poke_show()
        return
    if i == 1:
        SESSION_OPEN = 0
        SESSION_INTENT = 1                  # log out
        DAEMON_QUIT = 1
        lo: Ptr[uint8] = "SESSION logout\n"
        sys_write(1, lo, strlen_u8(lo))
        sessui_publish_snapshot()
        sessui_poke_show()
        return
    if i == 2:
        SESSION_OPEN = 0
        SESSION_INTENT = 2                  # power-off
        DAEMON_QUIT = 1
        sd: Ptr[uint8] = "SESSION shutdown\n"
        sys_write(1, sd, strlen_u8(sd))
        sessui_publish_snapshot()
        sessui_poke_show()
        return
    # Cancel.
    SESSION_OPEN = 0
    cc: Ptr[uint8] = "SESSION cancel\n"
    sys_write(1, cc, strlen_u8(cc))
    sessui_publish_snapshot()
    sessui_poke_show()


# ====================================================================
# ROUND-13: Run dialog (Alt-F2 / "Run Application")
# ====================================================================
# A centred modal text-entry box, exactly like MATE's "Run Application"
# (gnome-panel's Alt-F2). The user types a command/path; Enter spawns it
# in a fresh terminal window (reusing daemon_spawn_window_prog, the same
# path the Places file manager uses) and dismisses the dialog; Escape (or
# a click off the box) cancels. Backspace edits. The entry text is stored
# NUL-terminated so it can be handed straight to the spawn path as a
# Ptr[char] program argument.
RUN_OPEN: int32 = 0                    # 1 while the Run dialog is modal
RUN_LEN:  uint64 = 0                   # current command length
run_buf:  Array[128, uint8]            # typed command (NUL-terminated)
RUN_W:    int64 = 320                  # dialog width
RUN_PAD:  int64 = 14                   # inner padding
RUN_FIELD_H: int64 = 22                # text-field height


# Total pixel height of the Run dialog: title line + gap + field + gap +
# a one-line hint.
def run_total_h() -> int64:
    return RUN_PAD * 2 + GLYPH_H + 8 + RUN_FIELD_H + 8 + GLYPH_H


def run_x(scr_w: int64) -> int64:
    x: int64 = scr_w / 2 - RUN_W / 2
    if x < 0:
        x = 0
    return x


def run_y(scr_h: int64) -> int64:
    y: int64 = scr_h / 2 - run_total_h() / 2
    if y < PANEL_H:
        y = PANEL_H
    return y


# Open the Run dialog with an empty command. Closes any open menus so the
# modal entry owns the keyboard.
def run_open():
    RUN_OPEN = 1
    RUN_LEN = 0
    run_buf[0] = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    search_reset()
    ro: Ptr[uint8] = "RUN open\n"
    sys_write(1, ro, strlen_u8(ro))
    # DE pivot wave 4: republish state to /bin/hamrun and wake it.
    run_publish_snapshot()
    run_poke_show()


def run_cancel():
    RUN_OPEN = 0
    RUN_LEN = 0
    run_buf[0] = 0
    rc: Ptr[uint8] = "RUN cancel\n"
    sys_write(1, rc, strlen_u8(rc))
    # DE pivot wave 4: republish + wake so hamrun clears the popup.
    run_publish_snapshot()
    run_poke_show()


# Append one printable byte to the run command (capped at the buffer).
def run_push(c: uint8):
    if RUN_OPEN == 0:
        return
    if RUN_LEN >= 126:
        return
    run_buf[RUN_LEN] = c
    RUN_LEN = RUN_LEN + 1
    run_buf[RUN_LEN] = 0
    # DE pivot wave 4: republish + wake so hamrun re-renders the field.
    run_publish_snapshot()
    run_poke_show()


# Delete the last command byte (Backspace).
def run_backspace():
    if RUN_LEN > 0:
        RUN_LEN = RUN_LEN - 1
        run_buf[RUN_LEN] = 0
    # DE pivot wave 4: republish + wake on every edit.
    run_publish_snapshot()
    run_poke_show()


# ====================================================================
# ROUND-13: notification history / message tray
# ====================================================================
# Every notify_post() now ALSO appends to a ring of past notifications.
# The classic GNOME2/MATE "message tray" is opened from the info-dot tray
# icon (tray cell 1) and lists the recent notices in a drop panel anchored
# off the tray. This gives notifications persistence — they are no longer
# lost once the transient banner fades.
NHIST_MAX: int64 = 8                   # ring capacity
NHIST_COUNT: int64 = 0                 # how many slots are populated (<=MAX)
NHIST_HEAD: int64 = 0                  # next write slot (ring index)
nhist_title: Array[320, uint8]         # NHIST_MAX * 40
nhist_body:  Array[512, uint8]         # NHIST_MAX * 64
TRAY_OPEN: int32 = 0                   # 1 while the message-tray panel is up
TRAY_W:    int64 = 260                 # message-tray panel width
TRAY_ROW_H: int64 = 28                 # per-notice row height


# Record `title`/`body` into the notification-history ring.
def nhist_push(title: Ptr[uint8], body: Ptr[uint8]):
    base_t: uint64 = cast[uint64](NHIST_HEAD) * 40
    base_b: uint64 = cast[uint64](NHIST_HEAD) * 64
    str_copy_cap(&nhist_title[base_t], title, 40)
    str_copy_cap(&nhist_body[base_b], body, 64)
    NHIST_HEAD = NHIST_HEAD + 1
    if NHIST_HEAD >= NHIST_MAX:
        NHIST_HEAD = 0
    if NHIST_COUNT < NHIST_MAX:
        NHIST_COUNT = NHIST_COUNT + 1


# Title pointer for the `n`-th MOST-RECENT history entry (0 = newest).
def nhist_title_at(n: int64) -> Ptr[uint8]:
    idx: int64 = NHIST_HEAD - 1 - n
    while idx < 0:
        idx = idx + NHIST_MAX
    return &nhist_title[cast[uint64](idx) * 40]


# Body pointer for the `n`-th most-recent history entry.
def nhist_body_at(n: int64) -> Ptr[uint8]:
    idx: int64 = NHIST_HEAD - 1 - n
    while idx < 0:
        idx = idx + NHIST_MAX
    return &nhist_body[cast[uint64](idx) * 64]


# Clear the whole notification history.
def nhist_clear():
    NHIST_COUNT = 0
    NHIST_HEAD = 0
    nc: Ptr[uint8] = "TRAY clear\n"
    sys_write(1, nc, strlen_u8(nc))


# Total pixel height of the message-tray drop panel: a header row plus one
# row per recorded notice (or a single "No notifications" row when empty).
def tray_total_h() -> int64:
    rows: int64 = NHIST_COUNT
    if rows < 1:
        rows = 1
    return TRAY_ROW_H + rows * TRAY_ROW_H


def tray_x(scr_w: int64) -> int64:
    # Right-aligned under the tray icon area; clamp on-screen.
    x: int64 = scr_w - TRAY_W - 2
    if x < 0:
        x = 0
    return x


# 1 if screen pixel (x,y) lands on an INK pixel of the glyph string `s`
# laid out left-to-right at top-left origin (ox,oy), one 8x16 cell per
# character. Used to paint panel/menu labels into the compositor without
# any backing buffer. Out-of-range characters render as blank.
def str_ink(s: Ptr[uint8], ox: int64, oy: int64, x: int64, y: int64) -> int32:
    ly: int64 = y - oy
    if ly < 0 or ly >= GLYPH_H:
        return 0
    lx: int64 = x - ox
    if lx < 0:
        return 0
    col: int64 = lx / GLYPH_W
    ch: uint8 = s[cast[uint64](col)]
    if ch == 0:
        return 0
    if ch < 32 or ch > 126:
        return 0
    gx: int64 = lx - col * GLYPH_W           # 0..7
    gi: uint64 = cast[uint64](ch) - 32
    bits: uint8 = font_glyphs[gi * 16 + cast[uint64](ly)]
    mask: uint8 = cast[uint8](128 >> gx)
    if (bits & mask) != 0:
        return 1
    return 0


# Return the label string for menu entry `i`.
def menu_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        s0: Ptr[uint8] = "Terminal"
        return s0
    if i == 1:
        s1: Ptr[uint8] = "Text Editor"
        return s1
    if i == 2:
        s2: Ptr[uint8] = "Top"
        return s2
    if i == 3:
        s3: Ptr[uint8] = "Calculator"
        return s3
    if i == 4:
        s4: Ptr[uint8] = "System Monitor"
        return s4
    if i == 5:
        s5: Ptr[uint8] = "About Hamnix"
        return s5
    if i == 6:
        s6: Ptr[uint8] = "Calendar"
        return s6
    if i == 7:
        s7: Ptr[uint8] = "Date"
        return s7
    if i == 8:
        s8: Ptr[uint8] = "Files"
        return s8
    if i == 9:
        s9: Ptr[uint8] = "Disk Usage"
        return s9
    if i == 10:
        s10: Ptr[uint8] = "Log Viewer"
        return s10
    if i == 11:
        s11: Ptr[uint8] = "Snake"
        return s11
    if i == 12:
        s12: Ptr[uint8] = "2048"
        return s12
    if i == 13:
        s13: Ptr[uint8] = "Editor (hamUI)"
        return s13
    if i == 14:
        s14: Ptr[uint8] = "Screen Lock"
        return s14
    if i == 15:
        s15: Ptr[uint8] = "Screensaver"
        return s15
    if i == 16:
        s16: Ptr[uint8] = "Save Session"
        return s16
    s17: Ptr[uint8] = "Restore Session"
    return s17


# App kind for internal (in-process) menu entries, or -1 if the entry
# launches an external /bin program via the spawn path.
def menu_app(i: uint64) -> int32:
    if i == 1:
        return APP_EDITOR            # "Text Editor" — in-compositor (Kate-like)
    if i == 3:
        return APP_CALC
    if i == 4:
        return APP_SYSMON
    if i == 5:
        return APP_ABOUT
    if i == 8:
        return APP_FILEMGR           # "Files" — in-compositor icon grid
    return -1


# Return the program path for menu entry `i` (external entries only).
def menu_prog(i: uint64) -> Ptr[char]:
    if i == 0:
        p0: Ptr[char] = "/bin/hamsh"
        return p0
    if i == 1:
        p1: Ptr[char] = "/bin/vi"
        return p1
    if i == 2:
        p2: Ptr[char] = "/bin/top"
        return p2
    if i == 6:
        p6: Ptr[char] = "/bin/cal"
        return p6
    if i == 7:
        p7: Ptr[char] = "/bin/date"
        return p7
    if i == 8:
        p8: Ptr[char] = "/bin/hamfm"
        return p8
    if i == 9:
        p9: Ptr[char] = "/bin/hdu"
        return p9
    if i == 10:
        p10: Ptr[char] = "/bin/hlog"
        return p10
    if i == 11:
        p11: Ptr[char] = "/bin/hamsnake"
        return p11
    if i == 12:
        p12: Ptr[char] = "/bin/ham2048"
        return p12
    if i == 13:
        p13: Ptr[char] = "/bin/hamedit"
        return p13
    if i == 14:
        p14: Ptr[char] = "/bin/hamlock"
        return p14
    if i == 15:
        p15: Ptr[char] = "/bin/hamscreensaver"
        return p15
    # Save Session (16) / Restore Session (17) both spawn /bin/hamsession
    # with a "save" or "restore" argv[1] — see menu_launch().
    p1617: Ptr[char] = "/bin/hamsession"
    return p1617


# Total pixel height the dropped menu occupies.
def menu_total_h() -> int64:
    return cast[int64](MENU_COUNT) * MENU_ITEM_H


# 1 if (px,py) is inside the panel's Applications button.
def in_apps_btn(px: int64, py: int64) -> int32:
    if px >= APPS_BTN_X and px < APPS_BTN_X + APPS_BTN_W:
        if on_panel_y(py) != 0:
            return 1
    return 0


# 1 if (px,py) is anywhere on the panel bar.
def in_panel(px: int64, py: int64) -> int32:
    return on_panel_y(py)


# Index (0..MENU_COUNT-1) of the menu item under (px,py) while the menu
# is open, or -1 if not over an item. The menu drops off the panel edge.
def menu_item_at(px: int64, py: int64) -> int64:
    if MENU_OPEN == 0:
        return -1
    if px < MENU_X or px >= MENU_X + MENU_W:
        return -1
    h: int64 = menu_total_h()
    top: int64 = drop_anchor_y(h)
    if py < top or py >= top + h:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](menubar_count(MENU_BAR_OPEN)):
        return -1
    return idx


# ====================================================================
# MATE / GNOME2 menu BAR (Applications / Places / System)
# ====================================================================
# The single legacy "Applications" button is upgraded into the classic
# GNOME2 three-menu bar. MENU_BAR_OPEN selects which top-level menu (if
# any) is currently dropped:
#   -1 = closed
#    0 = Applications   1 = Places   2 = System
# Each top-level menu is a list of items. Items carry an ACTION kind so
# the click handler can do the right thing:
#   0 = launch a program  (path from menubar_item_prog)
#   1 = open a directory in the file manager (path arg)
#   2 = reload the DE / about / window action (system verbs)
MENU_BAR_OPEN: int32 = -1

# Top-level menu button labels + geometry. Buttons are laid out left to
# right from APPS_BTN_X; each is sized to its label width + padding.
MENUBAR_PAD: int64 = 10

# System-menu action codes (returned by menubar_item_action when kind==2).
SYSACT_RELOAD: int64 = 0
SYSACT_ABOUT:  int64 = 1


def menubar_label(m: int32) -> Ptr[uint8]:
    if m == 0:
        l0: Ptr[uint8] = "Applications"
        return l0
    if m == 1:
        l1: Ptr[uint8] = "Places"
        return l1
    l2: Ptr[uint8] = "System"
    return l2


# ====================================================================
# ROUND-7: GNOME2-classic categorised Applications menu
# ====================================================================
# The Applications drop-down (m==0) now lists CATEGORIES; hovering a
# category opens a submenu flyout to the right holding that category's
# apps (exactly MATE/GNOME2's two-level menu). Each submenu item maps to
# one of the existing flat Applications entries (0..MENU_COUNT-1) so the
# launcher code is reused verbatim.
APPCAT_COUNT: int64 = 4                 # Accessories / Games / System Tools / Help
SUBMENU_OPEN: int64 = -1                # category whose flyout is open, or -1
SUBMENU_W: int64 = 150


# Category name shown in the Applications drop-down.
def appcat_label(c: int64) -> Ptr[uint8]:
    if c == 0:
        a0: Ptr[uint8] = "Accessories"
        return a0
    if c == 1:
        a1: Ptr[uint8] = "System Tools"
        return a1
    if c == 2:
        a2: Ptr[uint8] = "Help"
        return a2
    g: Ptr[uint8] = "Games"
    return g


# Number of apps in category `c`.
def appcat_item_count(c: int64) -> int64:
    if c == 0:
        return 10                       # Terminal/Calc/Editor/Files/Calendar/Date/Editor(hamUI)/Screen Lock/Save Session/Restore Session
    if c == 1:
        return 5                        # Top / System Monitor / Disk Usage / Log Viewer / Screensaver
    if c == 2:
        return 1                        # About Hamnix
    return 2                            # Games: Snake / 2048


# Map (category c, submenu item k) to the flat Applications entry index
# (0..MENU_COUNT-1) so menu_launch() can be reused.
def appcat_flat_index(c: int64, k: int64) -> uint64:
    if c == 0:
        # Accessories: Terminal(0) Calculator(3) Editor(1) Files(8) Calendar(6) Date(7) Editor-hamUI(13) Screen Lock(14) Save Session(16) Restore Session(17)
        if k == 0:
            return 0
        if k == 1:
            return 3
        if k == 2:
            return 1
        if k == 3:
            return 8
        if k == 4:
            return 6
        if k == 5:
            return 7
        if k == 6:
            return 13
        if k == 7:
            return 14
        if k == 8:
            return 16
        return 17
    if c == 1:
        # System Tools: Top(2) System Monitor(4) Disk Usage(9) Log Viewer(10) Screensaver(15)
        if k == 0:
            return 2
        if k == 1:
            return 4
        if k == 2:
            return 9
        if k == 3:
            return 10
        return 15
    if c == 2:
        # Help: About Hamnix(5)
        return 5
    # Games: Snake(11) 2048(12)
    if k == 0:
        return 11
    return 12


# Label for submenu item `k` of category `c` (reuses the flat labels).
def appcat_item_label(c: int64, k: int64) -> Ptr[uint8]:
    return menu_label(appcat_flat_index(c, k))


# Total pixel height of category `c`'s submenu flyout.
def submenu_total_h(c: int64) -> int64:
    return appcat_item_count(c) * MENU_ITEM_H


# Top y of category `c`'s row inside the Applications drop-down. The
# drop-down is anchored off the panel edge (below a top panel, above a
# bottom panel) and is menubar_total_h() tall; row `c` is the c-th row.
def appcat_row_y(c: int64) -> int64:
    return drop_anchor_y(menubar_total_h()) + c * MENU_ITEM_H


# Left x of the submenu flyout (just right of the Applications drop-down).
def submenu_x() -> int64:
    return menubar_drop_x() + menubar_drop_w()


# Submenu item under (px,py) when category `c`'s flyout is open, or -1.
# The flyout's top aligns with its parent category row.
def submenu_item_at(c: int64, px: int64, py: int64) -> int64:
    sx: int64 = submenu_x()
    if px < sx or px >= sx + SUBMENU_W:
        return -1
    top: int64 = appcat_row_y(c)
    n: int64 = appcat_item_count(c)
    if py < top or py >= top + n * MENU_ITEM_H:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= n:
        return -1
    return idx


# Number of items in top-level menu `m`.
def menubar_count(m: int32) -> uint64:
    if m == 0:
        return cast[uint64](APPCAT_COUNT)   # Applications: category rows
    if m == 1:
        return 5                    # Home/Filesystem/Computer/Recent/Tmp
    if m == 2:
        return 9             # SysMon/About/Run/Reload/2 ws/Settings/RestoreSession/LogOut
    return 0


# Pixel width of top-level menu button `m` (label glyphs + padding).
def menubar_btn_w(m: int32) -> int64:
    n: int64 = cast[int64](strlen_u8(menubar_label(m)))
    return n * GLYPH_W + MENUBAR_PAD * 2


# Left x of top-level menu button `m`.
def menubar_btn_x(m: int32) -> int64:
    x: int64 = APPS_BTN_X
    i: int32 = 0
    while i < m:
        x = x + menubar_btn_w(i)
        i = i + 1
    return x


# Right edge x of the whole menu bar (start of the taskbar zone).
def menubar_end_x() -> int64:
    return menubar_btn_x(2) + menubar_btn_w(2)


# Which top-level menu button is under (px,py)? -1 if none. The bar
# lives in the panel's full height at the left end.
def menubar_btn_at(px: int64, py: int64) -> int32:
    if on_panel_y(py) == 0:
        return -1
    m: int32 = 0
    while m < 3:
        bx: int64 = menubar_btn_x(m)
        if px >= bx and px < bx + menubar_btn_w(m):
            return m
        m = m + 1
    return -1


# Drop-down geometry for the currently-open top-level menu.
def menubar_drop_x() -> int64:
    if MENU_BAR_OPEN < 0:
        return 0
    return menubar_btn_x(MENU_BAR_OPEN)


def menubar_drop_w() -> int64:
    # Wide enough for the legacy MENU_W on Applications, a bit narrower
    # for the short Places/System lists.
    if MENU_BAR_OPEN == 0:
        return MENU_W
    return 168


def menubar_total_h() -> int64:
    return cast[int64](menubar_count(MENU_BAR_OPEN)) * MENU_ITEM_H


# Label for item `i` of top-level menu `m`.
def menubar_item_label(m: int32, i: uint64) -> Ptr[uint8]:
    if m == 0:
        # ROUND-7: Applications rows are categories now.
        return appcat_label(cast[int64](i))
    if m == 1:
        if i == 0:
            p0: Ptr[uint8] = "Home"
            return p0
        if i == 1:
            p1: Ptr[uint8] = "Filesystem"
            return p1
        if i == 2:
            p2: Ptr[uint8] = "Computer"
            return p2
        if i == 3:
            p3: Ptr[uint8] = "Recent Documents"
            return p3
        p4: Ptr[uint8] = "Tmp"
        return p4
    if m == 2:
        if i == 0:
            s0: Ptr[uint8] = "System Monitor"
            return s0
        if i == 1:
            s1: Ptr[uint8] = "About Hamnix"
            return s1
        if i == 2:
            s2: Ptr[uint8] = "Run Application..."
            return s2
        if i == 3:
            s3: Ptr[uint8] = "Reload DE"
            return s3
        if i == 4:
            s4: Ptr[uint8] = "Next Workspace"
            return s4
        if i == 5:
            s5: Ptr[uint8] = "Prev Workspace"
            return s5
        if i == 6:
            s6: Ptr[uint8] = "Settings"
            return s6
        if i == 7:
            s8: Ptr[uint8] = "Restore Session"
            return s8
        s7: Ptr[uint8] = "Log Out"
        return s7
    e: Ptr[uint8] = ""
    return e


# Item under (px,py) for the open drop-down, or -1.
def menubar_item_at(px: int64, py: int64) -> int64:
    if MENU_BAR_OPEN < 0:
        return -1
    dx: int64 = menubar_drop_x()
    dw: int64 = menubar_drop_w()
    if px < dx or px >= dx + dw:
        return -1
    h: int64 = menubar_total_h()
    top: int64 = drop_anchor_y(h)
    if py < top or py >= top + h:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](menubar_count(MENU_BAR_OPEN)):
        return -1
    return idx


# ====================================================================
# MATE virtual workspaces
# ====================================================================
# ROUND-8: WS_COUNT is now a SESSION PREFERENCE (configurable from the
# Settings "Workspaces" row) rather than a fixed constant — exactly like
# MATE's "Number of workspaces" spinner. It is clamped to [WS_MIN,WS_MAX];
# the per-window DWIN_WS array still backs every window (max DMAX windows),
# so changing the count never reallocates anything.
WS_MIN: int32 = 1
WS_MAX: int32 = 8
WS_COUNT: int32 = 4
CUR_WS: int32 = 0

# ROUND-14: "Show windows from all workspaces" toggle (MATE's window-list +
# pager preference). When SHOW_ALL_WS != 0 the taskbar lists EVERY window
# regardless of which virtual desktop owns it; when 0 (the default) only
# windows on the current desktop appear on the window list. Pure preference
# flag — the renderer/hit-tester consult taskbar_lists_slot().
SHOW_ALL_WS: int32 = 0


# ROUND-14: add a virtual desktop (Add Workspace, from the pager menu).
# Steps WS_COUNT up by one, clamped at WS_MAX. Returns 1 if it grew.
def ws_count_add() -> int32:
    if WS_COUNT >= WS_MAX:
        return 0
    WS_COUNT = WS_COUNT + 1
    af: Ptr[uint8] = "DESK add-workspace "
    sys_write(1, af, strlen_u8(af))
    ab: Array[4, uint8]
    ab[0] = cast[uint8](WS_COUNT) + 48
    ab[1] = 10
    sys_write(1, &ab[0], 2)
    return 1


# ROUND-14: remove the last virtual desktop (Remove Workspace). Steps
# WS_COUNT down by one, clamped at WS_MIN. Any window or the active desktop
# that lived on the removed (now out-of-range) workspace folds back onto the
# new last desktop so nothing becomes unreachable. Returns 1 if it shrank.
def ws_count_remove() -> int32:
    if WS_COUNT <= WS_MIN:
        return 0
    WS_COUNT = WS_COUNT - 1
    if CUR_WS >= WS_COUNT:
        CUR_WS = WS_COUNT - 1
    ri: uint64 = 0
    while ri < DWIN_COUNT:
        if DWIN_WS[ri] >= WS_COUNT:
            DWIN_WS[ri] = WS_COUNT - 1
        ri = ri + 1
    rf: Ptr[uint8] = "DESK remove-workspace "
    sys_write(1, rf, strlen_u8(rf))
    rb: Array[4, uint8]
    rb[0] = cast[uint8](WS_COUNT) + 48
    rb[1] = 10
    sys_write(1, &rb[0], 2)
    return 1


# ROUND-14: toggle the "Show windows from all workspaces" preference and
# announce the new state for tests.
def show_all_ws_toggle():
    if SHOW_ALL_WS != 0:
        SHOW_ALL_WS = 0
    else:
        SHOW_ALL_WS = 1
    sf: Ptr[uint8] = "DESK show-all-ws "
    sys_write(1, sf, strlen_u8(sf))
    sb: Array[4, uint8]
    sb[0] = cast[uint8](SHOW_ALL_WS) + 48
    sb[1] = 10
    sys_write(1, &sb[0], 2)


# ROUND-14: should the taskbar list window `slot`? With SHOW_ALL_WS set,
# every window qualifies; otherwise only windows on the current desktop.
def taskbar_lists_slot(slot: uint64) -> int32:
    if SHOW_ALL_WS != 0:
        return 1
    # ROUND-20: a sticky window is listed on every workspace's taskbar.
    if DWIN_STICKY[slot] != 0:
        return 1
    if DWIN_WS[slot] == CUR_WS:
        return 1
    return 0

# Workspace-pager applet geometry: WS_COUNT little boxes in the panel,
# left of the clock. Each box is PAGER_CELL_W wide.
PAGER_CELL_W: int64 = 28
PAGER_PAD:    int64 = 4         # inner inset for the occupancy mini-map
PAGER_R: uint8 = 30            # pager cell background (darker than panel)
PAGER_G: uint8 = 34
PAGER_B: uint8 = 44
PAGER_CUR_R: uint8 = 70        # current-workspace cell highlight
PAGER_CUR_G: uint8 = 100
PAGER_CUR_B: uint8 = 170
PAGER_WIN_R: uint8 = 150       # mini window-occupancy marker
PAGER_WIN_G: uint8 = 200
PAGER_WIN_B: uint8 = 240


def pager_total_w() -> int64:
    return cast[int64](WS_COUNT) * PAGER_CELL_W


# ROUND-23: number of windows whose mini-marker the pager paints in
# workspace `ws`'s cell. This is the EXACT population the pager occupancy
# mini-map renders (a non-hidden window whose DWIN_WS == ws), so it is the
# single source of truth shared by the renderer's occupancy loop and the
# round-23 self-test that asserts the pager reflects per-workspace counts.
# A sticky window (Always on Visible Workspace) appears in EVERY cell, so it
# is counted for every workspace.
def pager_window_count(ws: int32) -> int64:
    n: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if DWIN_HIDDEN[wi] == 0:
            if DWIN_STICKY[wi] != 0 or DWIN_WS[wi] == ws:
                n = n + 1
        wi = wi + 1
    return n


# Left x of the ROUND-12 Show Desktop button (just left of the clock zone).
def sd_btn_x0(scr_w: int64) -> int64:
    return scr_w - CLOCK_W - SD_BTN_W


# Left x of the notification-area stub (just left of the Show Desktop btn).
def notif_x0(scr_w: int64) -> int64:
    return scr_w - CLOCK_W - SD_BTN_W - NOTIF_W


# Left x of the pager applet. The right-edge applet chain, from the right
# edge inward, is: clock, show-desktop button, notification stub, status-
# notifier zone, window-selector button, then this pager. Anchoring the
# pager to winsel_btn_x() (which itself trails statnot_x0) keeps every
# zone tiled left-to-right without the old overlap where the pager,
# status-notifier and notification stub all landed on the same pixels.
def pager_x0(scr_w: int64) -> int64:
    return winsel_btn_x(scr_w) - pager_total_w() - 4


# 1 if (px,py) lands on the panel's Show Desktop button.
def in_show_desktop_btn(px: int64, py: int64, scr_w: int64) -> int32:
    if on_panel_y(py) == 0:
        return 0
    x0: int64 = sd_btn_x0(scr_w)
    if px >= x0 and px < x0 + SD_BTN_W:
        return 1
    return 0


# ROUND-13: 1 if (px,py) lands on the notification-area info-dot icon
# (tray cell 1), which toggles the message-tray history panel. The whole
# tray zone is treated as the hit target so the click feels generous.
def in_tray_msg_btn(px: int64, py: int64, scr_w: int64) -> int32:
    if on_panel_y(py) == 0:
        return 0
    x0: int64 = notif_x0(scr_w)
    if px >= x0 and px < x0 + NOTIF_W:
        return 1
    return 0


# ROUND-13: 1 if (px,py) lands on the message-tray panel's [Clear] header
# affordance, while the tray is open.
def in_tray_clear_btn(px: int64, py: int64, scr_w: int64) -> int32:
    if TRAY_OPEN == 0:
        return 0
    tpx: int64 = tray_x(scr_w)
    tpy: int64 = drop_anchor_y(tray_total_h())
    cstr: Ptr[uint8] = "[Clear]"
    cw: int64 = cast[int64](strlen_u8(cstr)) * GLYPH_W
    cx0: int64 = tpx + TRAY_W - cw - 8
    if px >= cx0 and px < cx0 + cw and py >= tpy and py < tpy + TRAY_ROW_H:
        return 1
    return 0


# ROUND-13: 1 if (px,py) lands anywhere inside the open message-tray panel.
def in_tray_panel(px: int64, py: int64, scr_w: int64) -> int32:
    if TRAY_OPEN == 0:
        return 0
    tpx: int64 = tray_x(scr_w)
    tph: int64 = tray_total_h()
    tpy: int64 = drop_anchor_y(tph)
    if px >= tpx and px < tpx + TRAY_W and py >= tpy and py < tpy + tph:
        return 1
    return 0


# Pager cell index under (px,py), or -1.
def pager_cell_at(px: int64, py: int64, scr_w: int64) -> int64:
    if on_panel_y(py) == 0:
        return -1
    x0: int64 = pager_x0(scr_w)
    if px < x0 or px >= x0 + pager_total_w():
        return -1
    idx: int64 = (px - x0) / PAGER_CELL_W
    if idx < 0 or idx >= cast[int64](WS_COUNT):
        return -1
    return idx


# 1 if window `slot` is visible on the CURRENT workspace (right ws AND
# not minimized). Used by the compositor + hit-testers.
def win_on_cur_ws(slot: uint64) -> int32:
    # ROUND-20: a sticky window (Always on Visible Workspace) shows on
    # every desktop, so its own DWIN_WS is irrelevant for visibility.
    if DWIN_STICKY[slot] == 0 and DWIN_WS[slot] != CUR_WS:
        return 0
    if DWIN_HIDDEN[slot] != 0:
        return 0
    # ROUND-22: a member of a tab group is only visible when it is the
    # group's active tab. The whole compositor / taskbar / hit-test stack
    # consults this gate, so a group collapses to one visible window for
    # free.
    if DWIN_GROUP[slot] != 0 and DWIN_GROUP_ACTIVE[slot] == 0:
        return 0
    return 1


# Switch to workspace `ws` (clamped). Emits a serial marker for tests.
def workspace_switch(ws: int32):
    if ws < 0:
        ws = WS_COUNT - 1
    if ws >= WS_COUNT:
        ws = 0
    if ws == CUR_WS:
        return
    CUR_WS = ws
    # ROUND-15: pop the transient "Workspace N" OSD indicator.
    osd_show_workspace(ws)
    # Close any open menu / context menu when the desktop changes.
    MENU_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CTX_OPEN = 0
    pfx: Ptr[uint8] = "WS switch "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](CUR_WS + 1) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# Move window `slot` to workspace `ws` (clamped). Emits a marker.
def window_to_workspace(slot: uint64, ws: int32):
    if ws < 0 or ws >= WS_COUNT:
        return
    DWIN_WS[slot] = ws
    pfx: Ptr[uint8] = "WS move-window "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](ws + 1) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# ====================================================================
# ROUND-11: standard Ctrl-Alt-arrow workspace navigation helpers
# ====================================================================
# MATE/GNOME2 bind Ctrl-Alt-Left/Right to "switch to the adjacent
# workspace" and Ctrl-Alt-Shift-Left/Right to "move the active window to
# the adjacent workspace, following it there". Round 4-8 only offered the
# F-key bindings; these give the conventional arrow shortcuts a wrap-around
# adjacent-workspace target so the key path can call one helper per gesture.

# Index of the workspace `dir` steps from the current one (dir = -1 left,
# +1 right), wrapping around the WS_COUNT row. Pure function (no state).
def adjacent_ws(dir: int32) -> int32:
    w: int32 = CUR_WS + dir
    if w < 0:
        w = WS_COUNT - 1
    if w >= WS_COUNT:
        w = 0
    return w


# Switch to the workspace `dir` steps away (wrapping). Returns the new ws.
def workspace_step(dir: int32) -> int32:
    target: int32 = adjacent_ws(dir)
    workspace_switch(target)
    return target


# Move the focused window to the adjacent workspace (wrapping) AND follow it
# there, exactly like MATE's Ctrl-Alt-Shift-arrow. Returns the destination
# workspace, or -1 if there is no focused window to move.
def window_to_adjacent_ws(dir: int32) -> int32:
    slot: int64 = daemon_focus_slot()
    if slot < 0:
        return -1
    target: int32 = adjacent_ws(dir)
    window_to_workspace(cast[uint64](slot), target)
    workspace_switch(target)
    return target


# ROUND-8: change the number of virtual desktops (Settings "Workspaces"
# row). Steps WS_COUNT up by one, wrapping WS_MAX->WS_MIN. If the active
# desktop or any window now sits beyond the new edge, fold it back onto the
# last valid workspace so nothing becomes unreachable. Emits a marker.
def ws_count_cycle():
    WS_COUNT = WS_COUNT + 1
    if WS_COUNT > WS_MAX:
        WS_COUNT = WS_MIN
    # Fold the current workspace and every window back inside the new range.
    if CUR_WS >= WS_COUNT:
        CUR_WS = WS_COUNT - 1
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if DWIN_WS[wi] >= WS_COUNT:
            DWIN_WS[wi] = WS_COUNT - 1
        wi = wi + 1
    pfx: Ptr[uint8] = "DESK workspaces "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](WS_COUNT) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# ====================================================================
# ROUND-10: workspace pager drag-window-between-workspaces
# ====================================================================
# MATE's pager lets you DRAG a window's mini-marker from one workspace
# cell to another to relocate it across desktops (not just click-to-
# switch). We model this as a dedicated pager gesture: a left-press that
# lands on a pager cell arms PAGER_DRAG; if the release lands on a
# DIFFERENT cell we move the focused window of the source workspace onto
# the target desktop; if it lands on the SAME cell it falls back to the
# existing click-to-switch behaviour. PAGER_DRAG_FROM remembers the cell
# the press began on so the release can tell move from switch.
PAGER_DRAG:      int32 = 0             # 1 while a pager press is in flight
PAGER_DRAG_FROM: int64 = -1           # workspace cell the press began on


# Front-most (focus) window slot that lives on workspace `ws`, or -1 if
# that desktop is empty. Used as the pager-drag payload: dragging cell A
# onto cell B relocates A's focused window to B. Walks the stack from the
# front so the top-most window on that desktop is chosen.
def ws_focus_slot(ws: int32) -> int64:
    si: int64 = cast[int64](DWIN_COUNT) - 1
    while si >= 0:
        su: uint64 = cast[uint64](si)
        if DWIN_WS[su] == ws and DWIN_HIDDEN[su] == 0:
            return si
        si = si - 1
    # Fall back to a hidden window so a minimized-only desktop still drags.
    si = cast[int64](DWIN_COUNT) - 1
    while si >= 0:
        if DWIN_WS[cast[uint64](si)] == ws:
            return si
        si = si - 1
    return -1


# Drag the focused window of `from_ws` onto `to_ws`. Returns 1 if a window
# actually moved, else 0 (empty source or same workspace). Emits a marker.
def pager_drag_window(from_ws: int32, to_ws: int32) -> int32:
    if from_ws == to_ws:
        return 0
    if to_ws < 0 or to_ws >= WS_COUNT:
        return 0
    src: int64 = ws_focus_slot(from_ws)
    if src < 0:
        return 0
    window_to_workspace(cast[uint64](src), to_ws)
    pfx: Ptr[uint8] = "PAGER drag-window to "
    sys_write(1, pfx, strlen_u8(pfx))
    db: Array[4, uint8]
    db[0] = cast[uint8](to_ws + 1) + 48
    db[1] = 10
    sys_write(1, &db[0], 2)
    return 1


# ====================================================================
# ROUND-10: window-list (taskbar) grouping by application
# ====================================================================
# GNOME2/MATE's window-list groups several windows of the SAME application
# under one button with a count; clicking it cycles focus through that
# app's windows. We group by DWIN_APP, but terminals (APP_TERM) are all
# the same "app", which would over-collapse a desktop full of shells, so
# grouping only kicks in once a given app has GROUP_MIN-or-more windows.
# A grouped button shows the app's name plus a "(N)" multiplicity badge,
# and clicking it raises the next window of that group in round-robin
# (MATE's expand-on-click behaviour, collapsed to a focus-cycle here).
GROUP_MIN: uint64 = 2                  # windows-of-an-app before grouping
# Round-robin cursor per app kind so repeated clicks cycle the group.
GROUP_CURSOR: Array[8, int32]          # indexed by app kind (0..7)


# Number of windows whose app kind matches slot `slot`'s app (counting
# `slot` itself). Drives the grouping decision and the "(N)" badge.
def app_group_count(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    n: uint64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            n = n + 1
        i = i + 1
    return n


# 1 if slot `slot` belongs to a group that should collapse on the taskbar
# (its app kind has GROUP_MIN-or-more windows). Singletons stay ungrouped.
# Terminals (APP_TERM) are deliberately NEVER grouped: each is its own
# independent shell session (a distinct task, not multiple windows of one
# app), so they keep one taskbar button apiece, exactly like a row of
# separate xterms. Only the built-in DE applications collapse.
def is_grouped(slot: uint64) -> int32:
    if DWIN_APP[slot] == APP_TERM:
        return 0
    if app_group_count(slot) >= GROUP_MIN:
        return 1
    return 0


# The representative (group-leader) slot for an app kind: the LOWEST slot
# index whose app matches `app`. A grouped taskbar button is drawn once,
# on its leader; the other members of the group are folded behind it.
def group_leader_for_app(app: int32) -> int64:
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == app:
            return cast[int64](i)
        i = i + 1
    return -1


# 1 if slot `slot` is the leader of its (grouped) app — i.e. the first
# window of that kind. Non-grouped singletons are trivially their own
# leader. The taskbar renderer/hit-tester only emits a button for leaders.
def is_group_leader(slot: uint64) -> int32:
    if is_grouped(slot) == 0:
        return 1
    if group_leader_for_app(DWIN_APP[slot]) == cast[int64](slot):
        return 1
    return 0


# Cycle focus to the next window of slot `slot`'s app group (round-robin),
# skipping minimized windows where possible. Returns the UID of the window
# that was raised (stable across the raise reorder), or -1. Restores a
# minimized member before raising it.
def group_cycle(slot: uint64) -> int64:
    a: int32 = DWIN_APP[slot]
    cnt: uint64 = app_group_count(slot)
    if cnt == 0:
        return -1
    # Advance the per-app cursor and find the cursor-th window of this app.
    cur: int32 = GROUP_CURSOR[cast[uint64](a)]
    cur = cur + 1
    if cur >= cast[int32](cnt):
        cur = 0
    GROUP_CURSOR[cast[uint64](a)] = cur
    seen: int32 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            if seen == cur:
                if DWIN_HIDDEN[i] != 0:
                    DWIN_HIDDEN[i] = 0
                raised_uid: int32 = DWIN_UID[i]
                daemon_raise_slot(cast[int64](i))
                return cast[int64](raised_uid)
            seen = seen + 1
        i = i + 1
    return -1


# ====================================================================
# ROUND-11: window-list group action menu (minimize/restore/close all)
# ====================================================================
# Right-clicking a grouped taskbar button in MATE pops a small menu that
# acts on EVERY window of that group at once. These helpers implement the
# three actions. They take any member slot of the group, resolve the app
# kind, and walk every window of that kind. Each returns the number of
# windows it acted on so the caller (and the self-test) can confirm the
# whole group was processed.

# Minimize (hide) every window of slot `slot`'s app group. Returns count.
def group_minimize_all(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    n: uint64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            DWIN_HIDDEN[i] = 1
            n = n + 1
        i = i + 1
    gm: Ptr[uint8] = "WM group minimize-all\n"
    sys_write(1, gm, strlen_u8(gm))
    return n


# Restore (un-hide) every window of slot `slot`'s app group. Returns count.
def group_restore_all(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    n: uint64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            DWIN_HIDDEN[i] = 0
            n = n + 1
        i = i + 1
    gr: Ptr[uint8] = "WM group restore-all\n"
    sys_write(1, gr, strlen_u8(gr))
    return n


# Close every window of slot `slot`'s app group. Returns the count closed.
# daemon_close_slot() compacts the slot table, so we re-scan from the start
# after each close (slot indices shift) until no member of the app remains.
def group_close_all(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    closed: uint64 = 0
    guard: uint64 = 0
    while guard < 64:
        guard = guard + 1
        hit: int64 = -1
        i: uint64 = 0
        while i < DWIN_COUNT:
            if DWIN_APP[i] == a:
                hit = cast[int64](i)
                i = DWIN_COUNT
            else:
                i = i + 1
        if hit < 0:
            guard = 64
        else:
            daemon_close_slot(hit)
            closed = closed + 1
    gc: Ptr[uint8] = "WM group close-all\n"
    sys_write(1, gc, strlen_u8(gc))
    return closed


# ====================================================================
# ROUND-10: Applications menu type-to-search / filter
# ====================================================================
# MATE's modern menu lets you start typing to filter the application list.
# We add a one-line search box at the head of the Applications drop-down:
# when SEARCH_OPEN is set, keystrokes append to search_buf and the menu
# shows only the flat entries (0..MENU_COUNT-1) whose label contains the
# query as a case-insensitive substring. An empty query matches all
# entries (the menu behaves exactly as before). Enter launches the first
# match; Backspace edits; Escape clears + closes the search.
SEARCH_OPEN: int32 = 0                 # 1 while the search box is active
SEARCH_LEN:  uint64 = 0                # current query length
search_buf:  Array[32, uint8]          # query bytes (no NUL terminator)


# Lowercase an ASCII byte (A..Z -> a..z); other bytes pass through.
def to_lower_u8(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# 1 if the (case-insensitive) query in search_buf[0..SEARCH_LEN) occurs as
# a substring of NUL-terminated `s`. An empty query always matches.
def label_matches_search(s: Ptr[uint8]) -> int32:
    if SEARCH_LEN == 0:
        return 1
    slen: uint64 = strlen_u8(s)
    if SEARCH_LEN > slen:
        return 0
    last: uint64 = slen - SEARCH_LEN
    start: uint64 = 0
    while start <= last:
        k: uint64 = 0
        ok: int32 = 1
        while k < SEARCH_LEN:
            if to_lower_u8(s[start + k]) != to_lower_u8(search_buf[k]):
                ok = 0
                k = SEARCH_LEN
            else:
                k = k + 1
        if ok != 0:
            return 1
        start = start + 1
    return 0


# 1 if flat menu entry `i` matches the current search query.
def menu_search_match(i: uint64) -> int32:
    return label_matches_search(menu_label(i))


# Number of flat menu entries matching the current query (== MENU_COUNT
# when the query is empty).
def menu_search_count() -> uint64:
    n: uint64 = 0
    i: uint64 = 0
    while i < MENU_COUNT:
        if menu_search_match(i) != 0:
            n = n + 1
        i = i + 1
    return n


# The flat menu index of the `n`-th match (0-based), or MENU_COUNT if out
# of range. Used to map a clicked/Enter'd filtered-row back to its entry.
def menu_search_nth(n: uint64) -> uint64:
    seen: uint64 = 0
    i: uint64 = 0
    while i < MENU_COUNT:
        if menu_search_match(i) != 0:
            if seen == n:
                return i
            seen = seen + 1
        i = i + 1
    return MENU_COUNT


# Append one printable byte to the search query (capped at the buffer).
def search_push(c: uint8):
    if SEARCH_OPEN == 0:
        return
    if SEARCH_LEN >= 31:
        return
    search_buf[SEARCH_LEN] = c
    SEARCH_LEN = SEARCH_LEN + 1


# Delete the last query byte (Backspace).
def search_backspace():
    if SEARCH_LEN > 0:
        SEARCH_LEN = SEARCH_LEN - 1


# Clear the query and close the search box.
def search_reset():
    SEARCH_LEN = 0
    SEARCH_OPEN = 0


# 1 if the search filter should drive the Applications drop-down: the box
# is open AND the query is non-empty. With an empty query the menu keeps
# its normal category layout.
def search_active() -> int32:
    if SEARCH_OPEN != 0 and SEARCH_LEN > 0:
        return 1
    return 0


# Which filtered result row (0-based) is under (px,py) while the search
# filter is driving the Applications drop-down, or -1 if none. The result
# list drops from PANEL_H at the Applications-menu column, one row of
# MENU_ITEM_H per match.
def search_result_at(px: int64, py: int64) -> int64:
    if search_active() == 0:
        return -1
    if px < MENU_X or px >= MENU_X + MENU_W:
        return -1
    n: uint64 = menu_search_count()
    h: int64 = cast[int64](n) * MENU_ITEM_H
    top: int64 = drop_anchor_y(h)
    if py < top or py >= top + h:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](n):
        return -1
    return idx


# ====================================================================
# MATE Alt-Tab window cycler
# ====================================================================
# The atkbd driver emits VT220 function-key sequences with no modifier
# encoding, so a true Alt+Tab chord is unavailable. We bind the cycler to
# F5 (next) / F6 (previous) — the keyboard equivalent of the MATE alt-tab
# popup. Each press selects the next/previous VISIBLE window on the
# current workspace, and a release of the cycler (no key for a few idle
# frames) commits the selection by raising it. While cycling, an overlay
# popup centred on-screen lists the candidate windows with the selected
# one highlighted (exactly MATE's switcher chrome).
#
# CYCLE_OPEN: 1 while the switcher popup is showing.
# CYCLE_SEL : index into the visible-window order (0 = front-most).
# CYCLE_IDLE: idle frames since the last cycle keypress; when it reaches
#             CYCLE_COMMIT the selection is committed and the popup closes.
CYCLE_OPEN:    int32 = 0
CYCLE_SEL:     int64 = 0
CYCLE_IDLE:    int32 = 0
CYCLE_COMMIT:  int32 = 24          # idle frames before auto-commit
CYCLE_PRESSED: int32 = 0           # set by cycle_step, cleared each frame

# Switcher popup geometry.
CYC_ROW_H: int64 = 22
CYC_W:     int64 = 280
CYC_PAD:   int64 = 8
CYC_R: uint8 = 40
CYC_G: uint8 = 46
CYC_B: uint8 = 58
CYC_SEL_R: uint8 = 70
CYC_SEL_G: uint8 = 100
CYC_SEL_B: uint8 = 170
CYC_TXT_R: uint8 = 235
CYC_TXT_G: uint8 = 235
CYC_TXT_B: uint8 = 240


# Number of windows eligible for cycling (visible on the current ws).
def cycle_visible_count() -> int64:
    n: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) != 0:
            n = n + 1
        wi = wi + 1
    return n


# Map a cycler position to a real window slot, or -1. Round 5 switched the
# cycler to MOST-RECENTLY-USED order (mru_slot_for_pos): position 0 is the
# focused window, position 1 the one focused before it, etc. — so a single
# Alt+Tab toggles between your two last windows, exactly like MATE. The MRU
# resolver gracefully falls back to stacking order for windows it hasn't
# seen yet, so the very first cycle on a fresh desktop still lists them all.
def cycle_slot_for_pos(pos: int64) -> int64:
    return mru_slot_for_pos(pos)


# Advance the cycler by `dir` (+1 next, -1 previous). Opens the popup on
# the first press. Selection wraps around the visible-window list.
def cycle_step(dir: int64):
    n: int64 = cycle_visible_count()
    if n <= 0:
        return
    if CYCLE_OPEN == 0:
        CYCLE_OPEN = 1
        # Start on the SECOND window (MATE's first Alt+Tab jumps past the
        # already-focused front window) when more than one exists.
        if n > 1:
            CYCLE_SEL = 1
        else:
            CYCLE_SEL = 0
    else:
        CYCLE_SEL = CYCLE_SEL + dir
        if CYCLE_SEL >= n:
            CYCLE_SEL = 0
        if CYCLE_SEL < 0:
            CYCLE_SEL = n - 1
    CYCLE_IDLE = 0
    CYCLE_PRESSED = 1
    cm: Ptr[uint8] = "WM cycle "
    sys_write(1, cm, strlen_u8(cm))
    cb: Array[4, uint8]
    cb[0] = cast[uint8](CYCLE_SEL) + 48
    cb[1] = 10
    sys_write(1, &cb[0], 2)
    # DE pivot wave 3: republish the model + wake the hamcycler client.
    cycler_publish_snapshot()
    cycler_poke_show()


# Commit the cycler: raise the selected window to the front + close the
# popup. Emits a marker. No-op if the popup isn't open.
def cycle_commit():
    if CYCLE_OPEN == 0:
        return
    slot: int64 = cycle_slot_for_pos(CYCLE_SEL)
    CYCLE_OPEN = 0
    CYCLE_IDLE = 0
    if slot >= 0:
        # Un-minimize then raise the chosen window to focus.
        DWIN_HIDDEN[cast[uint64](slot)] = 0
        daemon_raise_slot(slot)
    # DE pivot wave 3: republish (now open=0) + wake the cycler client
    # so it clears its overlay.
    cycler_publish_snapshot()
    cycler_poke_show()
    rc: Ptr[uint8] = "WM cycle commit\n"
    sys_write(1, rc, strlen_u8(rc))


# ====================================================================
# MATE right-click context menus
# ====================================================================
# Two flavours, selected by CTX_KIND:
#   0 = desktop menu  (right-click empty desktop): New Terminal / Reload
#   1 = window menu   (right-click a title bar): window ops on CTX_SLOT
# CTX_OPEN gates rendering + hit-testing; CTX_X/CTX_Y is the top-left.
CTX_OPEN: int32 = 0
CTX_KIND: int32 = 0
CTX_SLOT: int64 = -1
# ROUND-14: scratch for the window-list menu's "WS N" target labels.
ctx_ws_buf: Array[8, uint8]
CTX_X: int64 = 0
CTX_Y: int64 = 0
CTX_ITEM_H: int64 = 20
# CTX_W is the menu-box width. It is NOT fixed: ctx_open_at() recomputes it
# from the widest *rendered* label of the menu kind being opened (each label
# is GLYPH_W px per char in the DE's fixed-width font) plus left+right
# padding, clamped to a sane minimum. The old fixed 200px box clipped the
# longer labels of some kinds (e.g. the panel menu's "Panel Preferences" /
# the window menu's "Always on Visible Workspace *"), which is exactly the
# truncation the user reported. A floor keeps short menus from looking cramped.
CTX_W: int64 = 200
CTX_PAD_L: int64 = 8    # left text inset (mirrors the str_ink draw at CTX_X+8)
CTX_PAD_R: int64 = 12   # right breathing room so the last glyph never touches
CTX_W_MIN: int64 = 160  # floor width for short menus
CTX_R: uint8 = 56
CTX_G: uint8 = 62
CTX_B: uint8 = 78
CTX_SEL_R: uint8 = 70
CTX_SEL_G: uint8 = 100
CTX_SEL_B: uint8 = 170


def ctx_count() -> uint64:
    if CTX_KIND == 0:
        # Open Terminal / Open File Manager / New Workspace / Settings /
        # Change Background / Arrange / Cascade / Reload.
        return 8
    # ROUND-14 window-list (taskbar) menu (5 fixed rows + one row per
    # workspace for the "Move to Workspace N" block):
    #   0 Minimize/Restore  1 Maximize/Restore  2 Shade/Unshade  3 Close
    #   4 a separator-style header "Move to Workspace:"  then WS_COUNT rows
    if CTX_KIND == 2:
        return cast[uint64](5 + WS_COUNT)
    # ROUND-14 pager (workspace-switcher) menu (3 rows):
    #   0 Add Workspace  1 Remove Workspace  2 Show All Workspaces (toggle)
    if CTX_KIND == 3:
        return 3
    # ROUND-15 panel (right-click the bar) menu (4 rows):
    #   0 Flip Panel Position  1 Autohide (toggle)  2 Add to Panel
    #   3 Panel Preferences
    if CTX_KIND == 4:
        return 4
    # ROUND-9/19/20/22/24 window menu (16 rows):
    #   0 Minimize  1 Maximize/Restore  2 Max Vert  3 Max Horiz
    #   4 Shade/Unshade  5 Always on Top  6 Always on Bottom
    #   7 Always on Visible Workspace  8 Resize  9 Move-Next-WS
    #   10 Move-Prev-WS  11 More Transparent  12 Less Transparent
    #   13 Fullscreen/Unfullscreen  14 Group/Ungroup  15 Close
    return 16


def ctx_item_label(i: uint64) -> Ptr[uint8]:
    if CTX_KIND == 0:
        if i == 0:
            d0: Ptr[uint8] = "Open Terminal"
            return d0
        if i == 1:
            dfm: Ptr[uint8] = "Open File Manager"
            return dfm
        if i == 2:
            dnw: Ptr[uint8] = "New Workspace"
            return dnw
        if i == 3:
            ds: Ptr[uint8] = "Settings"
            return ds
        if i == 4:
            d2: Ptr[uint8] = "Change Background"
            return d2
        if i == 5:
            d3: Ptr[uint8] = "Arrange Windows"
            return d3
        if i == 6:
            d4: Ptr[uint8] = "Cascade Windows"      # ROUND-20
            return d4
        d1: Ptr[uint8] = "Reload DE"
        return d1
    # ROUND-14 window-list (taskbar) per-window menu (acts on CTX_SLOT).
    if CTX_KIND == 2:
        if i == 0:
            # Minimize when visible, Restore (un-minimize) when hidden.
            if CTX_SLOT >= 0 and DWIN_HIDDEN[cast[uint64](CTX_SLOT)] != 0:
                tlr: Ptr[uint8] = "Restore"
                return tlr
            tlm: Ptr[uint8] = "Minimize"
            return tlm
        if i == 1:
            if CTX_SLOT >= 0 and DWIN_MAXED[cast[uint64](CTX_SLOT)] != 0:
                tlx: Ptr[uint8] = "Unmaximize"
                return tlx
            tlmx: Ptr[uint8] = "Maximize"
            return tlmx
        if i == 2:
            if CTX_SLOT >= 0 and DWIN_SHADED[cast[uint64](CTX_SLOT)] != 0:
                tlu: Ptr[uint8] = "Unshade"
                return tlu
            tls: Ptr[uint8] = "Shade"
            return tls
        if i == 3:
            tlc: Ptr[uint8] = "Close"
            return tlc
        if i == 4:
            tlh: Ptr[uint8] = "Move to Workspace:"
            return tlh
        # Rows 5.. are the workspace targets "Workspace N" (1-based label).
        wsn: int64 = cast[int64](i) - 5
        ctx_ws_buf[0] = 87          # 'W'
        ctx_ws_buf[1] = 83          # 'S'
        ctx_ws_buf[2] = 32          # ' '
        ctx_ws_buf[3] = cast[uint8](wsn + 1) + 48
        ctx_ws_buf[4] = 0
        # A trailing '*' marks the window's current workspace.
        if CTX_SLOT >= 0 and DWIN_WS[cast[uint64](CTX_SLOT)] == cast[int32](wsn):
            ctx_ws_buf[4] = 32      # ' '
            ctx_ws_buf[5] = 42      # '*'
            ctx_ws_buf[6] = 0
        return &ctx_ws_buf[0]
    # ROUND-14 pager (workspace-switcher) menu.
    if CTX_KIND == 3:
        if i == 0:
            pa: Ptr[uint8] = "Add Workspace"
            return pa
        if i == 1:
            pr: Ptr[uint8] = "Remove Workspace"
            return pr
        # Toggle row carries a trailing '*' when the preference is on.
        if SHOW_ALL_WS != 0:
            ps1: Ptr[uint8] = "Show All Workspaces *"
            return ps1
        ps0: Ptr[uint8] = "Show All Workspaces"
        return ps0
    # ROUND-15 panel (right-click the bar) menu.
    if CTX_KIND == 4:
        if i == 0:
            pf: Ptr[uint8] = "Flip Panel Position"
            return pf
        if i == 1:
            # The autohide toggle carries a trailing '*' while enabled.
            if PANEL_AUTOHIDE != 0:
                pah1: Ptr[uint8] = "Autohide *"
                return pah1
            pah0: Ptr[uint8] = "Autohide"
            return pah0
        if i == 2:
            pap: Ptr[uint8] = "Add to Panel"
            return pap
        ppp: Ptr[uint8] = "Panel Preferences"
        return ppp
    # window menu
    if i == 0:
        w0: Ptr[uint8] = "Minimize"
        return w0
    if i == 1:
        # Maximize vs Restore depends on the window's current state.
        if CTX_SLOT >= 0 and DWIN_MAXED[cast[uint64](CTX_SLOT)] != 0:
            wr: Ptr[uint8] = "Restore"
            return wr
        w1: Ptr[uint8] = "Maximize"
        return w1
    if i == 2:
        wmv: Ptr[uint8] = "Maximize Vertically"
        return wmv
    if i == 3:
        wmh: Ptr[uint8] = "Maximize Horizontally"
        return wmh
    if i == 4:
        # Shade vs Unshade depends on the window's current roll-up state.
        if CTX_SLOT >= 0 and DWIN_SHADED[cast[uint64](CTX_SLOT)] != 0:
            wus: Ptr[uint8] = "Unshade"
            return wus
        wsh: Ptr[uint8] = "Shade"
        return wsh
    if i == 5:
        # A leading check-mark when the window is already pinned.
        if CTX_SLOT >= 0 and DWIN_ONTOP[cast[uint64](CTX_SLOT)] != 0:
            wot1: Ptr[uint8] = "Always on Top *"
            return wot1
        wot0: Ptr[uint8] = "Always on Top"
        return wot0
    if i == 6:
        # ROUND-24: keep-below toggle (leading check '*' while pinned below).
        if CTX_SLOT >= 0 and DWIN_BELOW[cast[uint64](CTX_SLOT)] != 0:
            wbl1: Ptr[uint8] = "Always on Bottom *"
            return wbl1
        wbl0: Ptr[uint8] = "Always on Bottom"
        return wbl0
    if i == 7:
        # ROUND-20: sticky toggle (trailing '*' while sticky).
        if CTX_SLOT >= 0 and DWIN_STICKY[cast[uint64](CTX_SLOT)] != 0:
            wsk1: Ptr[uint8] = "Always on Visible Workspace *"
            return wsk1
        wsk0: Ptr[uint8] = "Always on Visible Workspace"
        return wsk0
    if i == 8:
        wz: Ptr[uint8] = "Resize"
        return wz
    if i == 9:
        w2: Ptr[uint8] = "Move to Next WS"
        return w2
    if i == 10:
        w3: Ptr[uint8] = "Move to Prev WS"
        return w3
    if i == 11:
        wmt: Ptr[uint8] = "More Transparent"
        return wmt
    if i == 12:
        wlt: Ptr[uint8] = "Less Transparent"
        return wlt
    if i == 13:
        # ROUND-22: Fullscreen vs Leave Fullscreen by current state.
        if CTX_SLOT >= 0 and DWIN_FULL[cast[uint64](CTX_SLOT)] != 0:
            wfu: Ptr[uint8] = "Leave Fullscreen"
            return wfu
        wfs: Ptr[uint8] = "Fullscreen"
        return wfs
    if i == 14:
        # ROUND-22: Group all windows vs Ungroup (when already grouped).
        if CTX_SLOT >= 0 and DWIN_GROUP[cast[uint64](CTX_SLOT)] != 0:
            wug: Ptr[uint8] = "Ungroup"
            return wug
        wgr: Ptr[uint8] = "Group Windows"
        return wgr
    w4: Ptr[uint8] = "Close"
    return w4


def ctx_total_h() -> int64:
    return cast[int64](ctx_count()) * CTX_ITEM_H


# ROUND-14: total height of a context menu of `kind` WITHOUT opening it, so
# the panel-anchored taskbar/pager menus can compute their drop-Y before
# ctx_open_at() commits CTX_KIND. Mirrors ctx_count()'s row counts.
def ctx_total_h_kind(kind: int32) -> int64:
    rows: int64 = 16
    if kind == 0:
        rows = 8
    elif kind == 2:
        rows = 5 + cast[int64](WS_COUNT)
    elif kind == 3:
        rows = 3
    elif kind == 4:
        rows = 4
    return rows * CTX_ITEM_H


# Compute the box width needed to fully contain the widest rendered label of
# the CURRENTLY-committed menu (CTX_KIND/CTX_SLOT must be set first). Each
# label is GLYPH_W px per character; we add left+right padding and clamp to a
# minimum. This is what stops the box from clipping its text (BUG 3).
def ctx_menu_width() -> int64:
    n: uint64 = ctx_count()
    maxw: int64 = 0
    i: uint64 = 0
    while i < n:
        lbl: Ptr[uint8] = ctx_item_label(i)
        w: int64 = cast[int64](strlen_u8(lbl)) * GLYPH_W
        if w > maxw:
            maxw = w
        i = i + 1
    box: int64 = maxw + CTX_PAD_L + CTX_PAD_R
    if box < CTX_W_MIN:
        box = CTX_W_MIN
    return box


# Context-menu item under (px,py), or -1.
def ctx_item_at(px: int64, py: int64) -> int64:
    if CTX_OPEN == 0:
        return -1
    if px < CTX_X or px >= CTX_X + CTX_W:
        return -1
    if py < CTX_Y or py >= CTX_Y + ctx_total_h():
        return -1
    idx: int64 = (py - CTX_Y) / CTX_ITEM_H
    if idx < 0 or idx >= cast[int64](ctx_count()):
        return -1
    return idx


# Open a context menu of `kind` anchored at (ax,ay), clamped on-screen.
def ctx_open_at(kind: int32, slot: int64, ax: int64, ay: int64,
                scr_w: int64, scr_h: int64):
    CTX_KIND = kind
    CTX_SLOT = slot
    CTX_OPEN = 1
    # Size the box to its widest label BEFORE clamping it on-screen, so no
    # label is ever clipped by a too-narrow box (BUG 3). CTX_KIND/CTX_SLOT are
    # already committed above, so ctx_menu_width() measures the right labels.
    CTX_W = ctx_menu_width()
    cx: int64 = ax
    cy: int64 = ay
    if cx + CTX_W > scr_w:
        cx = scr_w - CTX_W
    if cx < 0:
        cx = 0
    h: int64 = ctx_total_h()
    if cy + h > scr_h:
        cy = scr_h - h
    if cy < PANEL_H:
        cy = PANEL_H
    CTX_X = cx
    CTX_Y = cy


# ====================================================================
# MATE themed window decorations (Clearlooks-ish bevels + gradients)
# ====================================================================
# Title-bar gradient endpoints. Active (focused) window uses the blue
# gradient; inactive uses a muted grey-blue. The gradient runs top->bottom
# across TITLE_H rows.
TITLE_ACT_TOP_R: uint8 = 120
TITLE_ACT_TOP_G: uint8 = 178
TITLE_ACT_TOP_B: uint8 = 252
TITLE_ACT_BOT_R: uint8 = 56
TITLE_ACT_BOT_G: uint8 = 116
TITLE_ACT_BOT_B: uint8 = 208
TITLE_INA_TOP_R: uint8 = 150
TITLE_INA_TOP_G: uint8 = 156
TITLE_INA_TOP_B: uint8 = 168
TITLE_INA_BOT_R: uint8 = 108
TITLE_INA_BOT_G: uint8 = 114
TITLE_INA_BOT_B: uint8 = 128

# Beveled border tints: a light highlight on the top/left edges, a dark
# shadow on the bottom/right edges, framing a 1px mid line.
BEVEL_HI_R: uint8 = 250
BEVEL_HI_G: uint8 = 250
BEVEL_HI_B: uint8 = 255
BEVEL_LO_R: uint8 = 96
BEVEL_LO_G: uint8 = 100
BEVEL_LO_B: uint8 = 112
BEVEL_MID_R: uint8 = 176
BEVEL_MID_G: uint8 = 180
BEVEL_MID_B: uint8 = 192

# Maximize box: a square just LEFT of the minimize box (so the title-bar
# button order left-to-right at the right edge is [_][[]][X]).
MAXIMIZE_BOX: int64 = 14
MAX_BTN_R: uint8 = 110
MAX_BTN_G: uint8 = 180
MAX_BTN_B: uint8 = 110
MAX_GLYPH_R: uint8 = 255
MAX_GLYPH_G: uint8 = 255
MAX_GLYPH_B: uint8 = 255

# Hover highlight: the title-bar button currently under the cursor gets a
# brightened tint. HOVER_SLOT/HOVER_BTN identify it (btn: 0=close,
# 1=minimize, 2=maximize); -1 means nothing hovered.
HOVER_SLOT: int64 = -1
HOVER_BTN:  int32 = -1


# Linear-interpolate one colour channel from `a` (row 0) to `b`
# (row h-1) at integer row `row`.
def grad_chan(a: uint8, b: uint8, row: int64, h: int64) -> uint8:
    if h <= 1:
        return a
    av: int64 = cast[int64](a)
    bv: int64 = cast[int64](b)
    v: int64 = av + (bv - av) * row / (h - 1)
    if v < 0:
        v = 0
    if v > 255:
        v = 255
    return cast[uint8](v)


# Maximize-box geometry (left of the minimize box).
def maximize_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX - 2 - MINIMIZE_BOX \
        - 2 - MAXIMIZE_BOX


def maximize_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


def in_maximize_box(slot: uint64, px: int64, py: int64) -> int32:
    if title_h_of(slot) == 0:               # ROUND-22: fullscreen has no chrome
        return 0
    mx: int64 = maximize_box_x(slot)
    my: int64 = maximize_box_y(slot)
    if px >= mx and px < mx + MAXIMIZE_BOX and py >= my and py < my + MAXIMIZE_BOX:
        return 1
    return 0


# Toggle window `slot` between maximized (fills the work area below the
# panel) and its saved rectangle. Snap-aware: if the window is currently
# snapped (maximized OR half-tiled), this restores it to its float
# rectangle; otherwise it maximizes. Emits a serial marker for tests.
def window_toggle_maximize(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_SNAP[slot] != 0 or DWIN_MAXED[slot] != 0:
        # Restore the saved rectangle.
        DWIN_X[slot] = DWIN_SAVE_X[slot]
        DWIN_Y[slot] = DWIN_SAVE_Y[slot]
        DWIN_W[slot] = DWIN_SAVE_W[slot]
        DWIN_H[slot] = DWIN_SAVE_H[slot]
        DWIN_MAXED[slot] = 0
        DWIN_SNAP[slot] = 0
        rm: Ptr[uint8] = "WM restore window\n"
        sys_write(1, rm, strlen_u8(rm))
    else:
        # Save the current rectangle, then fill the work area.
        DWIN_SAVE_X[slot] = DWIN_X[slot]
        DWIN_SAVE_Y[slot] = DWIN_Y[slot]
        DWIN_SAVE_W[slot] = DWIN_W[slot]
        DWIN_SAVE_H[slot] = DWIN_H[slot]
        DWIN_X[slot] = 0
        DWIN_Y[slot] = PANEL_H
        DWIN_W[slot] = scr_w
        DWIN_H[slot] = scr_h - PANEL_H
        DWIN_MAXED[slot] = 1
        DWIN_SNAP[slot] = 1
        mm: Ptr[uint8] = "WM maximize window\n"
        sys_write(1, mm, strlen_u8(mm))
    # Re-derive the terminal grid geometry from the new body size so the
    # in-window shell uses the whole maximized body.
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows


# ====================================================================
# ROUND-9: window shading (roll-up), always-on-top, vert/horiz maximize
# ====================================================================
# Shade rolls a window up so only its title bar is visible; a second
# shade unrolls it back to its full height. Because the whole compositor
# and every hit-tester key off the live DWIN_H, shading simply collapses
# DWIN_H to the title-bar height (and stashes the real height) — no other
# path needs to know. The terminal grid is re-derived so the in-window
# shell pauses output cleanly while rolled up and reflows on unshade.
SHADE_H: int64 = 20                     # rolled-up height = TITLE_H (18) + 2 bevel


def window_toggle_shade(slot: uint64):
    if DWIN_SHADED[slot] != 0:
        # Unroll: restore the saved full height.
        DWIN_SHADED[slot] = 0
        DWIN_H[slot] = DWIN_SHADE_H[slot]
        window_reflow(slot)
        um: Ptr[uint8] = "WM unshade window\n"
        sys_write(1, um, strlen_u8(um))
    else:
        # Roll up: stash the live height, collapse to the title bar.
        DWIN_SHADE_H[slot] = DWIN_H[slot]
        DWIN_SHADED[slot] = 1
        DWIN_H[slot] = SHADE_H
        window_reflow(slot)
        sm: Ptr[uint8] = "WM shade window\n"
        sys_write(1, sm, strlen_u8(sm))


# Bubble every always-on-top window to the tail of the slot array (and sink
# every keep-below window to the head) so the back-to-front compositor paints
# (and the front-to-back hit-tester checks) above-windows over all normal
# windows and normal windows over all kept-below windows. A stable
# insertion-style pass preserves the relative order within each band AND
# amongst normal windows. Called after raises and before each present.
def enforce_ontop_order():
    if DWIN_COUNT < 2:
        return
    # Repeatedly pull the lowest normal/below window that sits ABOVE a pinned
    # window up past it (and sink kept-below windows the same way), until the
    # array is partitioned: kept-below ... normal ... always-on-top.
    moved: int32 = 1
    guard: int32 = 0
    while moved != 0 and guard < 64:
        moved = 0
        guard = guard + 1
        i: uint64 = 0
        while i + 1 < DWIN_COUNT:
            # Pinned-on-top below a non-top neighbour -> float the pin up.
            if DWIN_ONTOP[i] != 0 and DWIN_ONTOP[i + 1] == 0:
                slot_swap(i, i + 1)
                moved = 1
            # Kept-below window sitting above a non-below neighbour -> sink it.
            elif DWIN_BELOW[i] == 0 and DWIN_BELOW[i + 1] != 0:
                slot_swap(i, i + 1)
                moved = 1
            i = i + 1


# Toggle the always-on-top (keep-above) pin for `slot`. When pinning, the
# window is raised and floated above the normal stack; when un-pinning it
# stays where it is but no longer floats. Emits a marker.
def window_toggle_ontop(slot: uint64):
    if DWIN_ONTOP[slot] != 0:
        DWIN_ONTOP[slot] = 0
        om: Ptr[uint8] = "WM unpin ontop\n"
        sys_write(1, om, strlen_u8(om))
    else:
        DWIN_ONTOP[slot] = 1
        # On-top and below are mutually exclusive bands.
        DWIN_BELOW[slot] = 0
        pm: Ptr[uint8] = "WM pin ontop\n"
        sys_write(1, pm, strlen_u8(pm))
    enforce_ontop_order()


# Toggle the keep-below (always-on-bottom) pin for `slot`. The inverse of
# window_toggle_ontop: a kept-below window sinks beneath the normal stack and
# stays there across raises. Pinning below clears any on-top pin (a window is
# in exactly one band). Emits a marker.
def window_toggle_below(slot: uint64):
    if DWIN_BELOW[slot] != 0:
        DWIN_BELOW[slot] = 0
        bm: Ptr[uint8] = "WM unpin below\n"
        sys_write(1, bm, strlen_u8(bm))
    else:
        DWIN_BELOW[slot] = 1
        # Below and on-top are mutually exclusive bands.
        DWIN_ONTOP[slot] = 0
        pb: Ptr[uint8] = "WM pin below\n"
        sys_write(1, pb, strlen_u8(pb))
    enforce_ontop_order()


# ====================================================================
# ROUND-22: true fullscreen (F11)
# ====================================================================
# Distinct from maximize (which leaves the panel + title bar): fullscreen
# covers the WHOLE screen — including the panel strip — and drops the
# title bar so the body fills the frame edge-to-edge (presentations /
# video). title_h_of(slot) returns 0 for a fullscreen window so every
# compositor / hit-test path that keys off the title-bar band collapses
# for free; the body simply starts at the window top. The pre-fullscreen
# rectangle is parked in DWIN_FSAVE_* and a restore puts it back exactly.
# The window is bubbled to the very front so nothing (not even an
# always-on-top peer) paints over a fullscreen presentation.

# The live title-bar height for `slot`: 0 while fullscreen, else TITLE_H.
# Callers that draw / hit-test the title-bar band consult this so a
# fullscreen window has no chrome.
def title_h_of(slot: uint64) -> int64:
    if DWIN_FULL[slot] != 0:
        return 0
    if DWIN_CHROMELESS[slot] != 0:
        return 0
    return TITLE_H


def window_toggle_fullscreen(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_FULL[slot] != 0:
        # Leave fullscreen: restore the parked rectangle exactly.
        DWIN_FULL[slot] = 0
        DWIN_X[slot] = DWIN_FSAVE_X[slot]
        DWIN_Y[slot] = DWIN_FSAVE_Y[slot]
        DWIN_W[slot] = DWIN_FSAVE_W[slot]
        DWIN_H[slot] = DWIN_FSAVE_H[slot]
        window_reflow(slot)
        rf: Ptr[uint8] = "WM unfullscreen window\n"
        sys_write(1, rf, strlen_u8(rf))
        return
    # Enter fullscreen: park the current geometry, cover the whole screen.
    # A shaded window unshades first so the body is real before it grows.
    if DWIN_SHADED[slot] != 0:
        DWIN_SHADED[slot] = 0
        DWIN_H[slot] = DWIN_SHADE_H[slot]
    DWIN_FSAVE_X[slot] = DWIN_X[slot]
    DWIN_FSAVE_Y[slot] = DWIN_Y[slot]
    DWIN_FSAVE_W[slot] = DWIN_W[slot]
    DWIN_FSAVE_H[slot] = DWIN_H[slot]
    DWIN_FULL[slot] = 1
    DWIN_X[slot] = 0
    DWIN_Y[slot] = 0
    DWIN_W[slot] = scr_w
    DWIN_H[slot] = scr_h
    window_reflow(slot)
    # Bubble to the very front so the presentation owns the screen. Raise
    # uses array order; enforce_ontop_order then keeps pinned peers below a
    # fullscreen window because we clear the others' precedence by raising.
    daemon_raise_slot(cast[int64](slot))
    ff: Ptr[uint8] = "WM fullscreen window\n"
    sys_write(1, ff, strlen_u8(ff))


# ====================================================================
# ROUND-22: window tab-grouping (Mutter/Marco tabbed windows)
# ====================================================================
# Group several visible windows so they share one frame + a tab strip in
# the title bar; only the active member shows (win_on_cur_ws() already
# hides any grouped window whose ACTIVE flag is 0). Clicking a tab
# activates that member. A group of N members reuses the active member's
# rectangle, so the whole stack collapses to one window for the
# compositor / taskbar / hit-tester.

# How many live windows belong to group id `gid` (gid != 0).
def group_member_count(gid: int32) -> int64:
    if gid == 0:
        return 0
    n: int64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_GROUP[i] == gid:
            n = n + 1
        i = i + 1
    return n


# The tab ordinal (0-based, slot order) of group `gid`'s active member, or
# 0 if none is marked active (defensive). Mirrors group_tab_at's indexing
# so the rendered highlight lines up with the hit-test.
def group_active_ordinal(gid: int32) -> int64:
    if gid == 0:
        return 0
    ord: int64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_GROUP[i] == gid:
            if DWIN_GROUP_ACTIVE[i] != 0:
                return ord
            ord = ord + 1
        i = i + 1
    return 0


# Group every CURRENTLY-VISIBLE window on this workspace under one fresh
# group id, making the front-most (focused) one the active tab and parking
# the rest behind it (sharing the active member's rectangle). Returns the
# new group id, or 0 if there were fewer than two windows to group.
def group_visible_windows() -> int32:
    # Collect visible slots; need at least two to form a group.
    members: Array[8, uint64]
    n: int64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if win_on_cur_ws(i) != 0 and DWIN_GROUP[i] == 0:
            members[n] = i
            n = n + 1
        i = i + 1
    if n < 2:
        return 0
    gid: int32 = NEXT_GROUP
    NEXT_GROUP = NEXT_GROUP + 1
    # The front-most collected member (highest slot index) is the active
    # tab; align every other member to its rectangle so they nest.
    active: uint64 = members[n - 1]
    j: int64 = 0
    while j < n:
        s: uint64 = members[j]
        DWIN_GROUP[s] = gid
        if s == active:
            DWIN_GROUP_ACTIVE[s] = 1
        else:
            DWIN_GROUP_ACTIVE[s] = 0
            # Nest the inactive member under the active one's frame so a
            # later tab-switch reveals it in the right place.
            DWIN_X[s] = DWIN_X[active]
            DWIN_Y[s] = DWIN_Y[active]
            DWIN_W[s] = DWIN_W[active]
            DWIN_H[s] = DWIN_H[active]
            window_reflow(s)
        j = j + 1
    # DEPERF #409: every member just gained a title-bar tab strip (the
    # active member keeps its geometry, so it would NOT trip the auto-
    # refill); mark them all content-dirty so the strip renders.
    k: int64 = 0
    while k < n:
        DWIN_CONTENT_DIRTY[members[k]] = 1
        k = k + 1
    gm: Ptr[uint8] = "WM group "
    sys_write(1, gm, strlen_u8(gm))
    gb: Array[8, uint8]
    gn: uint64 = u64_to_dec(cast[uint64](n), &gb[0])
    sys_write(1, &gb[0], gn)
    nl: Ptr[uint8] = " windows\n"
    sys_write(1, nl, strlen_u8(nl))
    return gid


# Per-tab width inside the title bar's tab strip for group `gid`. The strip
# spans the active member's title-bar width (minus the right-side buttons).
def group_tab_w(active: uint64) -> int64:
    members: int64 = group_member_count(DWIN_GROUP[active])
    if members <= 0:
        return 0
    # Reserve the right title area for close/min/max boxes.
    strip_w: int64 = DWIN_W[active] - 4 - (CLOSE_BOX + 4) * 3
    if strip_w < members:
        strip_w = members
    return strip_w / members


# Hit-test the tab strip drawn across window `active`'s title bar (active is
# the visible group member). Returns the index (0-based, left to right
# amongst the group's members in slot order) of the tab under (px,py), or
# -1 if the point is not on a tab. The strip sits in the GROUP_TAB_H band at
# the BOTTOM of the title bar so it never fights the drag/close gestures
# that own the top of the bar.
def group_tab_at(active: uint64, px: int64, py: int64) -> int64:
    gid: int32 = DWIN_GROUP[active]
    if gid == 0 or DWIN_FULL[active] != 0:
        return -1
    members: int64 = group_member_count(gid)
    if members < 2:
        return -1
    bx: int64 = DWIN_X[active] + 2
    by: int64 = DWIN_Y[active] + TITLE_H - GROUP_TAB_H
    if py < by or py >= by + GROUP_TAB_H:
        return -1
    tw: int64 = group_tab_w(active)
    if tw <= 0:
        return -1
    rel: int64 = px - bx
    if rel < 0:
        return -1
    idx: int64 = rel / tw
    if idx >= members:
        return -1
    return idx


# Activate the `idx`-th member of group `gid` (slot order), hiding the rest.
# The newly active member inherits the previously active member's rectangle
# so the frame stays put. Returns the activated slot, or -1.
def group_activate_tab(gid: int32, idx: int64) -> int64:
    if gid == 0:
        return -1
    # Find the currently active member to copy its rectangle from.
    cur_active: int64 = -1
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_GROUP[i] == gid and DWIN_GROUP_ACTIVE[i] != 0:
            cur_active = cast[int64](i)
        i = i + 1
    # Walk members in slot order to the idx-th one.
    target: int64 = -1
    seen: int64 = 0
    i = 0
    while i < DWIN_COUNT:
        if DWIN_GROUP[i] == gid:
            if seen == idx:
                target = cast[int64](i)
            seen = seen + 1
        i = i + 1
    if target < 0:
        return -1
    ts: uint64 = cast[uint64](target)
    if cur_active >= 0:
        ca: uint64 = cast[uint64](cur_active)
        DWIN_GROUP_ACTIVE[ca] = 0
        # DEPERF #409: the previously-active member's tab highlight changes.
        DWIN_CONTENT_DIRTY[ca] = 1
        DWIN_X[ts] = DWIN_X[ca]
        DWIN_Y[ts] = DWIN_Y[ca]
        DWIN_W[ts] = DWIN_W[ca]
        DWIN_H[ts] = DWIN_H[ca]
    DWIN_GROUP_ACTIVE[ts] = 1
    window_reflow(ts)
    target = daemon_raise_slot(target)
    tm: Ptr[uint8] = "WM group-tab activate\n"
    sys_write(1, tm, strlen_u8(tm))
    return target


# Dissolve the group every member of `gid` belongs to (Ungroup): clear the
# flags so each window stands alone again. Members that were hidden behind
# the active tab become visible in place.
def group_dissolve(gid: int32):
    if gid == 0:
        return
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_GROUP[i] == gid:
            DWIN_GROUP[i] = 0
            DWIN_GROUP_ACTIVE[i] = 0
            # DEPERF #409: the tab strip disappears from each member.
            DWIN_CONTENT_DIRTY[i] = 1
        i = i + 1
    dm: Ptr[uint8] = "WM ungroup\n"
    sys_write(1, dm, strlen_u8(dm))


# ====================================================================
# ROUND-22: drag edge-flip to the adjacent workspace
# ====================================================================
# Holding a dragged window's title bar jammed against the extreme left or
# right screen margin for EFLIP_DWELL frames flips to the adjacent virtual
# desktop and CARRIES the window there — shuffling a window across
# workspaces with one continuous drag. The flip band sits INSIDE the
# half-tile snap edge so the two gestures never collide: snapping fires as
# the cursor merely nears the edge, the flip only fires once the cursor is
# jammed in the final EFLIP_BAND pixels and has dwelt there. Returns 1 if a
# flip happened this call (the caller re-presents). `slot` is the window
# being dragged; (cur_x) is the live cursor x.
def edge_flip_update(slot: uint64, cur_x: int64, scr_w: int64) -> int32:
    if EFLIP_COOLDOWN > 0:
        EFLIP_COOLDOWN = EFLIP_COOLDOWN - 1
        return 0
    side: int32 = 0
    if cur_x <= EFLIP_BAND:
        side = -1
    if cur_x >= scr_w - 1 - EFLIP_BAND:
        side = 1
    if side == 0:
        # Cursor left the flip band: reset the dwell.
        EFLIP_CTR = 0
        EFLIP_SIDE = 0
        return 0
    if side != EFLIP_SIDE:
        # Jammed at a new edge: restart the dwell count there.
        EFLIP_SIDE = side
        EFLIP_CTR = 1
        return 0
    EFLIP_CTR = EFLIP_CTR + 1
    if EFLIP_CTR < EFLIP_DWELL:
        return 0
    # Dwell satisfied: flip to the adjacent workspace (wrapping) and carry
    # the dragged window there so it follows the cursor onto the new desktop.
    target: int32 = CUR_WS + side
    if target < 0:
        target = WS_COUNT - 1
    if target >= WS_COUNT:
        target = 0
    if target == CUR_WS:
        return 0
    window_to_workspace(slot, target)
    workspace_switch(target)
    # Reset the dwell + suppress an immediate re-flip so one continuous edge
    # press flips exactly once per dwell window.
    EFLIP_CTR = 0
    EFLIP_SIDE = 0
    EFLIP_COOLDOWN = EFLIP_DWELL
    ef: Ptr[uint8] = "WM edge-flip\n"
    sys_write(1, ef, strlen_u8(ef))
    return 1


# ROUND-19: adjust window `slot`'s opacity by `delta` (signed, in 0..255
# units), clamped to [OPACITY_MIN, 255] so the window stays legible and
# can always return to fully opaque. Emits a marker carrying the new alpha
# so a non-pixel test can assert the adjust. Returns the new opacity.
def window_opacity_step(slot: uint64, delta: int32) -> int32:
    v: int32 = DWIN_OPACITY[slot] + delta
    if v > 255:
        v = 255
    if v < OPACITY_MIN:
        v = OPACITY_MIN
    DWIN_OPACITY[slot] = v
    op: Ptr[uint8] = "WM opacity "
    sys_write(1, op, strlen_u8(op))
    ob: Array[8, uint8]
    on: uint64 = u64_to_dec(cast[uint64](v), &ob[0])
    sys_write(1, &ob[0], on)
    return v


# Maximize the window VERTICALLY only (full work-area height, keep x/w),
# or restore if it is already vertically maximized. MATE's middle-click on
# the maximize button. The pre-stretch rectangle is saved in DWIN_SAVE_*.
def window_maximize_vert(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_MAXED[slot] != 0 or DWIN_SNAP[slot] != 0:
        # Already maximized/snapped: restore the float rectangle first.
        DWIN_X[slot] = DWIN_SAVE_X[slot]
        DWIN_Y[slot] = DWIN_SAVE_Y[slot]
        DWIN_W[slot] = DWIN_SAVE_W[slot]
        DWIN_H[slot] = DWIN_SAVE_H[slot]
        DWIN_MAXED[slot] = 0
        DWIN_SNAP[slot] = 0
        window_reflow(slot)
        rv: Ptr[uint8] = "WM restore window\n"
        sys_write(1, rv, strlen_u8(rv))
        return
    DWIN_SAVE_X[slot] = DWIN_X[slot]
    DWIN_SAVE_Y[slot] = DWIN_Y[slot]
    DWIN_SAVE_W[slot] = DWIN_W[slot]
    DWIN_SAVE_H[slot] = DWIN_H[slot]
    DWIN_Y[slot] = PANEL_H
    DWIN_H[slot] = scr_h - PANEL_H
    DWIN_SNAP[slot] = 8                 # 8 = vertical maximize sentinel
    window_reflow(slot)
    mv: Ptr[uint8] = "WM maxvert window\n"
    sys_write(1, mv, strlen_u8(mv))


# Maximize the window HORIZONTALLY only (full screen width, keep y/h), or
# restore if already horizontally maximized.
def window_maximize_horiz(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_MAXED[slot] != 0 or DWIN_SNAP[slot] != 0:
        DWIN_X[slot] = DWIN_SAVE_X[slot]
        DWIN_Y[slot] = DWIN_SAVE_Y[slot]
        DWIN_W[slot] = DWIN_SAVE_W[slot]
        DWIN_H[slot] = DWIN_SAVE_H[slot]
        DWIN_MAXED[slot] = 0
        DWIN_SNAP[slot] = 0
        window_reflow(slot)
        rh2: Ptr[uint8] = "WM restore window\n"
        sys_write(1, rh2, strlen_u8(rh2))
        return
    DWIN_SAVE_X[slot] = DWIN_X[slot]
    DWIN_SAVE_Y[slot] = DWIN_Y[slot]
    DWIN_SAVE_W[slot] = DWIN_W[slot]
    DWIN_SAVE_H[slot] = DWIN_H[slot]
    DWIN_X[slot] = 0
    DWIN_W[slot] = scr_w
    DWIN_SNAP[slot] = 9                 # 9 = horizontal maximize sentinel
    window_reflow(slot)
    mh: Ptr[uint8] = "WM maxhoriz window\n"
    sys_write(1, mh, strlen_u8(mh))


# ---- window snapping / edge tiling helpers -------------------------
# Recompute the per-window terminal grid geometry after a resize so the
# in-window shell/app reflows to the new body. Safe for app windows too.
def window_reflow(slot: uint64):
    body_w: int64 = DWIN_W[slot] - 4
    # ROUND-22: a fullscreen window has no title bar (title_h_of==0) so its
    # body grid fills the whole frame.
    body_h: int64 = DWIN_H[slot] - title_h_of(slot) - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    if DWIN_CUR_C[slot] >= cols:
        DWIN_CUR_C[slot] = 0
    if DWIN_CUR_R[slot] >= rows and rows > 0:
        DWIN_CUR_R[slot] = rows - 1
    # DEPERF #409: a reflow means this window's layout/size changed (shade,
    # snap, maximize, resize, group-nest) — its cached surface is stale.
    # (A geometry change usually trips the WCACHE_UW/UH mismatch too, but
    # mark it explicitly so a same-size-different-chrome reflow is covered.)
    DWIN_CONTENT_DIRTY[slot] = 1


# Apply snap mode `mode` to `slot` (1 max, 2 left half, 3 right half).
# Mode 0 restores to the saved float geometry. The float geometry is
# stashed in DWIN_SAVE_* the first time a float window is snapped (so
# repeated snaps don't lose the origin).
def snap_apply(slot: uint64, mode: int32, scr_w: int64, scr_h: int64):
    if mode == 0:
        if DWIN_SNAP[slot] != 0:
            DWIN_X[slot] = DWIN_SAVE_X[slot]
            DWIN_Y[slot] = DWIN_SAVE_Y[slot]
            DWIN_W[slot] = DWIN_SAVE_W[slot]
            DWIN_H[slot] = DWIN_SAVE_H[slot]
            DWIN_SNAP[slot] = 0
            DWIN_MAXED[slot] = 0
            window_reflow(slot)
        return
    if DWIN_SNAP[slot] == 0:
        DWIN_SAVE_X[slot] = DWIN_X[slot]
        DWIN_SAVE_Y[slot] = DWIN_Y[slot]
        DWIN_SAVE_W[slot] = DWIN_W[slot]
        DWIN_SAVE_H[slot] = DWIN_H[slot]
    # ROUND-11: respect the panel position. wt is the first usable row,
    # avail_h the usable height (screen minus the panel wherever it sits).
    wt: int64 = work_top(scr_h)
    avail_h: int64 = work_h(scr_h)
    if mode == 1:
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 1
    elif mode == 2:
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w / 2
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 0
    elif mode == 3:
        DWIN_X[slot] = scr_w / 2
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w - scr_w / 2
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 0
    elif mode == 4:
        # top-left quarter
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w / 2
        DWIN_H[slot] = avail_h / 2
        DWIN_MAXED[slot] = 0
    elif mode == 5:
        # top-right quarter
        DWIN_X[slot] = scr_w / 2
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w - scr_w / 2
        DWIN_H[slot] = avail_h / 2
        DWIN_MAXED[slot] = 0
    elif mode == 6:
        # bottom-left quarter
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt + avail_h / 2
        DWIN_W[slot] = scr_w / 2
        DWIN_H[slot] = avail_h - avail_h / 2
        DWIN_MAXED[slot] = 0
    elif mode == 7:
        # bottom-right quarter
        DWIN_X[slot] = scr_w / 2
        DWIN_Y[slot] = wt + avail_h / 2
        DWIN_W[slot] = scr_w - scr_w / 2
        DWIN_H[slot] = avail_h - avail_h / 2
        DWIN_MAXED[slot] = 0
    DWIN_SNAP[slot] = mode
    window_reflow(slot)


# ====================================================================
# ROUND-4: keyboard tiling (Super+arrow) + show-desktop toggle
# ====================================================================
# MATE binds Super+Left/Right to half-tiling and Super+Up to maximize. Our
# atkbd path lacks a Super modifier, so we drive the same snap machinery
# from a dedicated set of intercepted keys (wired in daemon_pump_keys):
#   '['            -> tile left half        ']'  -> tile right half
#   ESC O <P..S>   -> quarter tiles (handled in the key path)
# tile_focused() snaps the front-most window on the current workspace.
# A serial marker proves the action fired without pixel sampling.
def tile_focused(mode: int32, scr_w: int64, scr_h: int64):
    slot: int64 = daemon_focus_slot()
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    snap_apply(s, mode, scr_w, scr_h)
    pfx: Ptr[uint8] = "WM tile "
    sys_write(1, pfx, strlen_u8(pfx))
    tb: Array[4, uint8]
    tb[0] = cast[uint8](mode) + 48
    tb[1] = 10
    sys_write(1, &tb[0], 2)


# ====================================================================
# ROUND-5: interactive edge/corner snapping with a live preview overlay
# ====================================================================
# MATE/GNOME2 "edge tiling": while dragging a window's title bar, the
# cursor entering a screen edge or corner pops a translucent preview of
# where the window will land; releasing there commits the snap. This is
# the pointer-driven analogue of the round-4 keyboard tiling (F7-F12).
#
# snap_zone_for() classifies a cursor (cx,cy) into a snap MODE that maps
# 1:1 onto snap_apply()'s modes:
#   0 = no snap (float)        1 = maximize (top edge)
#   2 = left half              3 = right half
#   4 = top-left quarter       5 = top-right quarter
#   6 = bottom-left quarter    7 = bottom-right quarter
# Corners take priority over edges. SNAP_CORNER is a generous band so the
# corners are easy to hit; the plain top edge maximizes, the side edges
# half-tile, and the side edge NEAR a top/bottom corner quarter-tiles.
SNAP_CORNER: int64 = 48                # corner trigger band (px)
SNAP_PREVIEW_MODE: int32 = 0           # live preview zone during a move-drag
SNAP_PREVIEW_ON:   int32 = 0           # 1 while a snap preview is visible


def snap_zone_for(cx: int64, cy: int64, scr_w: int64, scr_h: int64) -> int32:
    near_top: int32 = 0
    near_bot: int32 = 0
    near_left: int32 = 0
    near_right: int32 = 0
    if cy <= PANEL_H + SNAP_CORNER:
        near_top = 1
    if cy >= scr_h - 1 - SNAP_CORNER:
        near_bot = 1
    if cx <= SNAP_CORNER:
        near_left = 1
    if cx >= scr_w - 1 - SNAP_CORNER:
        near_right = 1
    # Corners first (quarter tiles).
    if near_top != 0 and near_left != 0:
        return 4
    if near_top != 0 and near_right != 0:
        return 5
    if near_bot != 0 and near_left != 0:
        return 6
    if near_bot != 0 and near_right != 0:
        return 7
    # Plain top edge -> maximize.
    if cy <= PANEL_H + SNAP_EDGE:
        return 1
    # Side edges -> half tiles.
    if cx <= SNAP_EDGE:
        return 2
    if cx >= scr_w - 1 - SNAP_EDGE:
        return 3
    return 0


# Geometry of a snap zone: writes the target rect for `mode` into the four
# out-params so the compositor can paint a preview and tests can assert
# the landing rect WITHOUT applying it to a real window.
snapzone_x: int64 = 0
snapzone_y: int64 = 0
snapzone_w: int64 = 0
snapzone_h: int64 = 0


def snap_zone_rect(mode: int32, scr_w: int64, scr_h: int64):
    # ROUND-11: anchor previews to the panel-position-aware work area.
    wt: int64 = work_top(scr_h)
    avail_h: int64 = work_h(scr_h)
    half_w: int64 = scr_w / 2
    half_h: int64 = avail_h / 2
    snapzone_x = 0
    snapzone_y = wt
    snapzone_w = scr_w
    snapzone_h = avail_h
    if mode == 1:
        return
    if mode == 2:
        snapzone_w = half_w
        return
    if mode == 3:
        snapzone_x = half_w
        snapzone_w = scr_w - half_w
        return
    if mode == 4:
        snapzone_w = half_w
        snapzone_h = half_h
        return
    if mode == 5:
        snapzone_x = half_w
        snapzone_w = scr_w - half_w
        snapzone_h = half_h
        return
    if mode == 6:
        snapzone_y = wt + half_h
        snapzone_w = half_w
        snapzone_h = avail_h - half_h
        return
    if mode == 7:
        snapzone_x = half_w
        snapzone_y = wt + half_h
        snapzone_w = scr_w - half_w
        snapzone_h = avail_h - half_h
        return


# ====================================================================
# ROUND-5: most-recently-used (MRU) Alt-Tab order
# ====================================================================
# Round-3's cycler walked windows in stacking order. MATE's switcher uses
# MRU order: the most recently focused window is first, the one before it
# second, etc. — so a single Alt+Tab toggles between your two last
# windows. We track an MRU list of window IDs (stable across the slot
# swaps that daemon_raise_slot performs) and rebuild a per-cycle ordered
# slot list from it.
MRU_UID: Array[8, int32]               # MRU order of DWIN_UID, [0] = most recent
MRU_LEN: uint64 = 0


# Record that the window with daemon UID `uid` was just focused: move it to
# the front of the MRU list (de-duplicating).
def mru_touch(uid: int32):
    if uid <= 0:
        return
    # Find it; shift everything above it down by one.
    found: int64 = -1
    i: uint64 = 0
    while i < MRU_LEN:
        if MRU_UID[i] == uid:
            found = cast[int64](i)
        i = i + 1
    if found >= 0:
        j: uint64 = cast[uint64](found)
        while j > 0:
            MRU_UID[j] = MRU_UID[j - 1]
            j = j - 1
        MRU_UID[0] = uid
        return
    # New: prepend, growing the list (bounded by the window table size).
    if MRU_LEN < 8:
        k: uint64 = MRU_LEN
        while k > 0:
            MRU_UID[k] = MRU_UID[k - 1]
            k = k - 1
        MRU_UID[0] = uid
        MRU_LEN = MRU_LEN + 1
    else:
        m: uint64 = 7
        while m > 0:
            MRU_UID[m] = MRU_UID[m - 1]
            m = m - 1
        MRU_UID[0] = uid


# Drop a window UID from the MRU list (called when a window closes).
def mru_drop(uid: int32):
    i: uint64 = 0
    while i < MRU_LEN:
        if MRU_UID[i] == uid:
            j: uint64 = i
            while j + 1 < MRU_LEN:
                MRU_UID[j] = MRU_UID[j + 1]
                j = j + 1
            MRU_LEN = MRU_LEN - 1
            return
        i = i + 1


# Slot holding window UID `uid`, or -1.
def slot_for_uid(uid: int32) -> int64:
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_UID[i] == uid:
            return cast[int64](i)
        i = i + 1
    return -1


# Map a cycler position to a slot using MRU order, skipping any window not
# visible on the current workspace. Falls back to stacking order for any
# eligible window the MRU list hasn't seen yet (so brand-new windows still
# appear). Returns -1 past the end.
def mru_slot_for_pos(pos: int64) -> int64:
    seen: int64 = 0
    # First pass: MRU-ordered, current-workspace, visible.
    i: uint64 = 0
    while i < MRU_LEN:
        s: int64 = slot_for_uid(MRU_UID[i])
        if s >= 0 and win_on_cur_ws(cast[uint64](s)) != 0:
            if seen == pos:
                return s
            seen = seen + 1
        i = i + 1
    # Second pass: any visible window NOT already in the MRU list, in
    # stacking order (front-most first).
    si: int64 = cast[int64](DWIN_COUNT) - 1
    while si >= 0:
        su: uint64 = cast[uint64](si)
        if win_on_cur_ws(su) != 0:
            uidv: int32 = DWIN_UID[su]
            in_mru: int32 = 0
            mi: uint64 = 0
            while mi < MRU_LEN:
                if MRU_UID[mi] == uidv:
                    in_mru = 1
                mi = mi + 1
            if in_mru == 0:
                if seen == pos:
                    return si
                seen = seen + 1
        si = si - 1
    return -1


# Show-desktop toggle (MATE "Minimize all"). On the first invocation it
# minimizes every visible window on the current workspace and remembers
# the set; a second invocation restores exactly those. SHOWDESK_ON tracks
# whether we're currently in the minimized-all state.
SHOWDESK_ON: int32 = 0
showdesk_saved: Array[8, int32]    # 1 = this slot was minimized BY show-desktop


def show_desktop_toggle():
    if SHOWDESK_ON == 0:
        # Minimize every currently-visible window on this workspace.
        any_v: int32 = 0
        i: uint64 = 0
        while i < DWIN_COUNT:
            showdesk_saved[i] = 0
            if DWIN_WS[i] == CUR_WS and DWIN_HIDDEN[i] == 0:
                DWIN_HIDDEN[i] = 1
                showdesk_saved[i] = 1
                any_v = 1
            i = i + 1
        SHOWDESK_ON = 1
        sd: Ptr[uint8] = "WM show-desktop on\n"
        sys_write(1, sd, strlen_u8(sd))
    else:
        # Restore exactly the windows we minimized.
        i2: uint64 = 0
        while i2 < DWIN_COUNT:
            if showdesk_saved[i2] != 0:
                DWIN_HIDDEN[i2] = 0
                showdesk_saved[i2] = 0
            i2 = i2 + 1
        SHOWDESK_ON = 0
        sd2: Ptr[uint8] = "WM show-desktop off\n"
        sys_write(1, sd2, strlen_u8(sd2))


# Short title string shown on a built-in app window's title bar.
def window_title(slot: uint64) -> Ptr[uint8]:
    a: int32 = DWIN_APP[slot]
    if a == APP_CALC:
        t1: Ptr[uint8] = "Calculator"
        return t1
    if a == APP_SYSMON:
        t2: Ptr[uint8] = "System Monitor"
        return t2
    if a == APP_ABOUT:
        t3: Ptr[uint8] = "About Hamnix"
        return t3
    if a == APP_SETTINGS:
        t4: Ptr[uint8] = "Settings"
        return t4
    if a == APP_CTRLCENTER:
        t5: Ptr[uint8] = "Control Center"
        return t5
    if a == APP_FILEMGR:
        t6: Ptr[uint8] = "Files"
        return t6
    if a == APP_EDITOR:
        t7: Ptr[uint8] = "Text Editor"
        return t7
    t0: Ptr[uint8] = "Terminal"
    return t0


# ====================================================================
# ROUND-19: desktop icons (root-window launchers)
# ====================================================================
# Seed the built-in launcher icons in a vertical column down the left of
# the work area the first time the desktop comes up. Idempotent.
def dicons_init():
    if DICONS_INIT != 0:
        return
    col_x: int64 = 16
    top:   int64 = PANEL_H + 16
    i: int64 = 0
    while i < DICON_COUNT:
        DICON_X[i] = col_x
        DICON_Y[i] = top + i * DICON_CELL_H
        i = i + 1
    # 0 Home (file manager at /home)
    DICON_KIND[0] = 1
    DICON_APP[0]  = -1
    # 1 Filesystem (file manager at /)
    DICON_KIND[1] = 1
    DICON_APP[1]  = -1
    # 2 Terminal (fresh shell)
    DICON_KIND[2] = 2
    DICON_APP[2]  = -1
    # 3 Calculator (built-in app)
    DICON_KIND[3] = 0
    DICON_APP[3]  = APP_CALC
    # 4 System Monitor (built-in app)
    DICON_KIND[4] = 0
    DICON_APP[4]  = APP_SYSMON
    DICONS_INIT = 1


# Label string shown under desktop icon `i`.
def dicon_label(i: int64) -> Ptr[uint8]:
    if i == 0:
        l0: Ptr[uint8] = "Home"
        return l0
    if i == 1:
        l1: Ptr[uint8] = "Filesystem"
        return l1
    if i == 2:
        l2: Ptr[uint8] = "Terminal"
        return l2
    if i == 3:
        l3: Ptr[uint8] = "Calculator"
        return l3
    l4: Ptr[uint8] = "Monitor"
    return l4


# Badge tint for desktop icon `i` (the little coloured square that stands
# in for a real themed icon). Returned via three out-params.
def dicon_badge_rgb(i: int64, r: Ptr[uint8], g: Ptr[uint8], b: Ptr[uint8]):
    if i == 0:
        r[0] = 90
        g[0] = 150
        b[0] = 230          # Home: blue folder
    elif i == 1:
        r[0] = 120
        g[0] = 180
        b[0] = 120          # Filesystem: green disk
    elif i == 2:
        r[0] = 50
        g[0] = 54
        b[0] = 62           # Terminal: dark
    elif i == 3:
        r[0] = 200
        g[0] = 160
        b[0] = 70           # Calculator: amber
    else:
        r[0] = 180
        g[0] = 90
        b[0] = 90           # Monitor: red graph
    return


# Which desktop icon is under (px,py)? -1 if none. The hit target is the
# whole cell (badge + label band) so it is easy to grab. Icons are only
# hit-testable on the EMPTY desktop (callers gate on no-window-under).
def dicon_at(px: int64, py: int64) -> int64:
    i: int64 = 0
    while i < DICON_COUNT:
        ix: int64 = DICON_X[i]
        iy: int64 = DICON_Y[i]
        if px >= ix and px < ix + DICON_CELL_W \
           and py >= iy and py < iy + DICON_CELL_H:
            return i
        i = i + 1
    return -1


# Snap a coordinate to the icon drop grid.
def dicon_grid_snap(v: int64) -> int64:
    return (v / DICON_GRID) * DICON_GRID


# Launch desktop icon `i`'s target (double-click action).
def dicon_launch(i: int64, scr_w: int64, scr_h: int64):
    if i < 0 or i >= DICON_COUNT:
        return
    di: Ptr[uint8] = "DICON launch "
    sys_write(1, di, strlen_u8(di))
    write_str(1, dicon_label(i))
    sys_write(1, "\n", 1)
    # Cascade the new window down-right of the icon so it doesn't bury it.
    rx: int64 = DICON_X[i] + DICON_CELL_W + 24
    ry: int64 = DICON_Y[i]
    if ry < PANEL_H:
        ry = PANEL_H
    k: int32 = DICON_KIND[i]
    if k == 0:
        rw: int64 = 320
        rh: int64 = 220
        if DICON_APP[i] == APP_SYSMON:
            rw = 360
        if rx + rw > scr_w:
            rx = scr_w - rw
        if rx < 0:
            rx = 0
        daemon_spawn_app(DICON_APP[i], rx, ry, rw, rh)
    elif k == 1:
        if i == 0:
            places_open(cast[Ptr[char]]("/home"), scr_w, scr_h)
        else:
            places_open(cast[Ptr[char]]("/"), scr_w, scr_h)
    else:
        # KIND==2: the desktop "Terminal" launcher icon. Increment-3a of the
        # MATE-mirror DE rewrite: SPAWN the external /bin/hamterm as its OWN
        # process via daemon_spawn_terminal (the same separate-process path the
        # Applications-menu Terminal entry and the desktop right-click "Open
        # Terminal" use). Previously this launcher used daemon_spawn_window,
        # which spawns a raw /bin/hamsh (the rio drag-create gesture) with no
        # terminal toolkit chrome — the launcher button now opens the real
        # hamterm client. The rio drag-to-create gesture (daemon_spawn_window)
        # is intentionally left untouched.
        rw2: int64 = 480
        rh2: int64 = 320
        if rx + rw2 > scr_w:
            rx = scr_w - rw2
        if rx < 0:
            rx = 0
        daemon_spawn_terminal(rx, ry, rw2, rh2)


# ====================================================================
# ROUND-19: desktop system-monitor applet
# ====================================================================
# Read /dev/loadavg's 1-minute load (load*100 integer in the first field)
# and map it to a 0..100 CPU% on the uniprocessor (1.00 load == 100%).
def dmon_read_cpu_pct() -> int64:
    lp: Ptr[char] = "/dev/loadavg"
    fd: int32 = sys_open(lp)
    if fd < 0:
        return DMON_CPU_CUR             # keep the last value if unavailable
    n: int64 = sys_read(fd, &dmon_rd_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return DMON_CPU_CUR
    nu: uint64 = cast[uint64](n)
    i: uint64 = 0
    whole: int64 = 0
    frac: int64 = 0
    # integer part
    while i < nu and dmon_rd_buf[i] >= 48 and dmon_rd_buf[i] <= 57:
        whole = whole * 10 + cast[int64](dmon_rd_buf[i] - 48)
        i = i + 1
    # fractional part (two digits) after a '.'
    if i < nu and dmon_rd_buf[i] == 46:
        i = i + 1
        digs: int32 = 0
        while i < nu and digs < 2 and dmon_rd_buf[i] >= 48 \
              and dmon_rd_buf[i] <= 57:
            frac = frac * 10 + cast[int64](dmon_rd_buf[i] - 48)
            i = i + 1
            digs = digs + 1
        if digs == 1:
            frac = frac * 10
    pct: int64 = whole * 100 + frac      # load*100 == percent on 1 CPU
    if pct > 100:
        pct = 100
    if pct < 0:
        pct = 0
    return pct


# Push one CPU%/MEM% sample into the history ring (called once per second
# from the main loop). MEM% comes from the live sysmon percentage.
def dmon_push():
    cpu: int64 = dmon_read_cpu_pct()
    mem: int64 = sysmon_used_pct()
    DMON_CPU_CUR = cpu
    DMON_MEM_CUR = mem
    h: uint64 = cast[uint64](DMON_HEAD)
    dmon_cpu[h] = cast[uint8](cpu)
    dmon_mem[h] = cast[uint8](mem)
    DMON_HEAD = (DMON_HEAD + 1) % DMON_HIST
    if DMON_FILLED < DMON_HIST:
        DMON_FILLED = DMON_FILLED + 1


# Sample value at graph column `col` (0 = oldest visible .. DMON_HIST-1 =
# newest), reading from the ring. Returns CPU% if which==0 else MEM%.
def dmon_sample(col: int64, which: int32) -> int64:
    # newest is at HEAD-1; column DMON_HIST-1 maps to newest.
    idx: int64 = (DMON_HEAD - DMON_HIST + col + DMON_HIST * 4) % DMON_HIST
    iu: uint64 = cast[uint64](idx)
    if which == 0:
        return cast[int64](dmon_cpu[iu])
    return cast[int64](dmon_mem[iu])


# Top-left x/y of the desktop applet (top-right of the work area).
def dmon_x0(scr_w: int64) -> int64:
    x: int64 = scr_w - DMON_W - 12
    if x < 0:
        x = 0
    return x


def dmon_y0(scr_h: int64) -> int64:
    return work_top(scr_h) + 12


# 1 if (px,py) lands on the desktop monitor applet.
def in_dmon_applet(px: int64, py: int64, scr_w: int64, scr_h: int64) -> int32:
    x0: int64 = dmon_x0(scr_w)
    y0: int64 = dmon_y0(scr_h)
    if px >= x0 and px < x0 + DMON_W and py >= y0 and py < y0 + DMON_H:
        return 1
    return 0


# ====================================================================
# Built-in calculator app
# ====================================================================
# A 4x4 keypad below a one-line display. Cell layout (row-major 0..15):
#   row0:  7  8  9  /
#   row1:  4  5  6  *
#   row2:  1  2  3  -
#   row3:  0  C  =  +
# Returns the label byte for keypad cell `k` (0..15), or 0 if none.
def calc_key_label(k: int64) -> uint8:
    if k == 0:
        return 55          # '7'
    if k == 1:
        return 56          # '8'
    if k == 2:
        return 57          # '9'
    if k == 3:
        return 47          # '/'
    if k == 4:
        return 52          # '4'
    if k == 5:
        return 53          # '5'
    if k == 6:
        return 54          # '6'
    if k == 7:
        return 42          # '*'
    if k == 8:
        return 49          # '1'
    if k == 9:
        return 50          # '2'
    if k == 10:
        return 51          # '3'
    if k == 11:
        return 45          # '-'
    if k == 12:
        return 48          # '0'
    if k == 13:
        return 67          # 'C'
    if k == 14:
        return 61          # '='
    if k == 15:
        return 43          # '+'
    return 0


# Render the calculator current value into `out` as a NUL-terminated
# decimal string. Negative handled with a leading '-'. Returns the length.
def calc_format(slot: uint64, out: Ptr[uint8]) -> uint64:
    if CALC_ERR[slot] != 0:
        out[0] = 69        # 'E'
        out[1] = 114       # 'r'
        out[2] = 114       # 'r'
        out[3] = 0
        return 3
    v: int64 = CALC_CUR[slot]
    p: uint64 = 0
    if v < 0:
        out[0] = 45        # '-'
        p = 1
        v = 0 - v
    if v == 0:
        out[p] = 48
        p = p + 1
        out[p] = 0
        return p
    tmp: int64 = v
    digits: uint64 = 0
    while tmp > 0:
        digits = digits + 1
        tmp = tmp / 10
    end: uint64 = p + digits
    out[end] = 0
    w: uint64 = end
    while v > 0:
        w = w - 1
        out[w] = cast[uint8](v % 10) + 48
        v = v / 10
    return end


# Apply the pending operator of `slot` to ACC and CUR, leaving the result
# in both. Sets the error flag on divide-by-zero.
def calc_resolve(slot: uint64):
    op: int32 = CALC_OP[slot]
    a: int64 = CALC_ACC[slot]
    b: int64 = CALC_CUR[slot]
    r: int64 = b
    if op == 1:
        r = a + b
    elif op == 2:
        r = a - b
    elif op == 3:
        r = a * b
    elif op == 4:
        if b == 0:
            CALC_ERR[slot] = 1
            return
        r = a / b
    CALC_ACC[slot] = r
    CALC_CUR[slot] = r


# Handle a keypad press (label byte) for the calculator in `slot`.
def calc_press(slot: uint64, lbl: uint8):
    if lbl == 67:                              # 'C' clear
        CALC_ACC[slot] = 0
        CALC_CUR[slot] = 0
        CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        CALC_ERR[slot] = 0
        return
    if CALC_ERR[slot] != 0:
        return                                 # error sticks until cleared
    if lbl >= 48 and lbl <= 57:                # digit
        if CALC_FRESH[slot] != 0:
            CALC_CUR[slot] = 0
            CALC_FRESH[slot] = 0
        nv: int64 = CALC_CUR[slot] * 10 + cast[int64](lbl - 48)
        if nv < 1000000000:                    # clamp to 9 digits
            CALC_CUR[slot] = nv
        return
    if lbl == 61:                              # '=' resolve
        if CALC_OP[slot] != 0:
            calc_resolve(slot)
            CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        return
    # An operator: resolve any pending op first (chained arithmetic),
    # then latch the new op and start a fresh operand.
    newop: int32 = 0
    if lbl == 43:
        newop = 1
    elif lbl == 45:
        newop = 2
    elif lbl == 42:
        newop = 3
    elif lbl == 47:
        newop = 4
    if newop != 0:
        if CALC_OP[slot] != 0 and CALC_FRESH[slot] == 0:
            calc_resolve(slot)
        else:
            CALC_ACC[slot] = CALC_CUR[slot]
        CALC_OP[slot] = newop
        CALC_FRESH[slot] = 1


# Geometry of the calculator body inside window `slot`. Returns, via
# out-pointers, the body origin (bx,by), keypad cell size (cw,ch) and the
# display strip height (dh).
def calc_layout(slot: uint64, bx: Ptr[int64], by: Ptr[int64],
                cw: Ptr[int64], ch: Ptr[int64], dh: Ptr[int64]):
    body_x: int64 = DWIN_X[slot] + 2
    body_y: int64 = DWIN_Y[slot] + TITLE_H
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    disp_h: int64 = 36
    if disp_h > body_h / 2:
        disp_h = body_h / 2
    bx[0] = body_x
    by[0] = body_y
    cw[0] = body_w / 4
    ch[0] = (body_h - disp_h) / 4
    dh[0] = disp_h


# Keypad cell index (0..15) under (px,py) inside calculator `slot`, or -1.
def calc_cell_at(slot: uint64, px: int64, py: int64) -> int64:
    bx: Array[1, int64]
    by: Array[1, int64]
    cw: Array[1, int64]
    ch: Array[1, int64]
    dh: Array[1, int64]
    calc_layout(slot, &bx[0], &by[0], &cw[0], &ch[0], &dh[0])
    if cw[0] <= 0 or ch[0] <= 0:
        return -1
    kx0: int64 = bx[0]
    ky0: int64 = by[0] + dh[0]
    lx: int64 = px - kx0
    ly: int64 = py - ky0
    if lx < 0 or ly < 0:
        return -1
    col: int64 = lx / cw[0]
    row: int64 = ly / ch[0]
    if col < 0 or col > 3 or row < 0 or row > 3:
        return -1
    return row * 4 + col


# ====================================================================
# Built-in system-monitor app
# ====================================================================
# Append the C string at `s` into out starting at offset p; returns the
# new offset (no NUL written).
def sm_puts(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0:
        out[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# Append `v` as decimal into out at offset p; returns the new offset.
def sm_putnum(out: Ptr[uint8], p: uint64, v: uint64) -> uint64:
    if v == 0:
        out[p] = 48
        return p + 1
    digits: uint64 = 0
    tmp: uint64 = v
    while tmp > 0:
        digits = digits + 1
        tmp = tmp / 10
    end: uint64 = p + digits
    w: uint64 = end
    while v > 0:
        w = w - 1
        out[w] = cast[uint8](v % 10) + 48
        v = v / 10
    return end


# Scan sysmon_buf[0..n) for the line beginning with `key` (e.g.
# "MemTotal:") and parse the first integer that follows it. Returns the
# value, or 0 if the key was not found.
def sm_field(n: uint64, key: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    klen: uint64 = strlen_u8(key)
    while i < n:
        matched: int32 = 1
        j: uint64 = 0
        while j < klen:
            if i + j >= n or sysmon_buf[i + j] != key[j]:
                matched = 0
                break
            j = j + 1
        if matched != 0:
            k: uint64 = i + klen
            while k < n and (sysmon_buf[k] < 48 or sysmon_buf[k] > 57):
                k = k + 1
            v: uint64 = 0
            while k < n and sysmon_buf[k] >= 48 and sysmon_buf[k] <= 57:
                v = v * 10 + cast[uint64](sysmon_buf[k] - 48)
                k = k + 1
            return v
        while i < n and sysmon_buf[i] != 10:
            i = i + 1
        i = i + 1
    return 0


# Refresh the system-monitor display strings from /proc. Throttled to once
# per second (driven by the loop centisecond counter). Reads /proc/uptime
# and /proc/meminfo (MemTotal / MemFree).
def sysmon_refresh(cur_cs: uint64):
    if cur_cs < sysmon_last_cs + 100 and sysmon_last_cs != 0:
        return
    sysmon_last_cs = cur_cs
    # --- uptime ---
    up_secs: uint64 = 0
    up_path: Ptr[char] = "/proc/uptime"
    ufd: int32 = sys_open(up_path)
    if ufd >= 0:
        un: int64 = sys_read(ufd, &sysmon_buf[0], 1024)
        sys_close(ufd)
        cs_up: uint64 = 0
        kk: uint64 = 0
        unu: uint64 = cast[uint64](un)
        while kk < unu and sysmon_buf[kk] >= 48 and sysmon_buf[kk] <= 57:
            cs_up = cs_up * 10 + cast[uint64](sysmon_buf[kk] - 48)
            kk = kk + 1
        up_secs = cs_up / 100
    hh: uint64 = up_secs / 3600
    mm: uint64 = (up_secs / 60) % 60
    ss: uint64 = up_secs % 60
    p: uint64 = 0
    p = sm_puts(&sysmon_line1[0], p, "Uptime: ")
    p = sm_putnum(&sysmon_line1[0], p, hh)
    sysmon_line1[p] = 58
    p = p + 1
    sysmon_line1[p] = cast[uint8](mm / 10) + 48
    p = p + 1
    sysmon_line1[p] = cast[uint8](mm % 10) + 48
    p = p + 1
    sysmon_line1[p] = 58
    p = p + 1
    sysmon_line1[p] = cast[uint8](ss / 10) + 48
    p = p + 1
    sysmon_line1[p] = cast[uint8](ss % 10) + 48
    p = p + 1
    sysmon_line1[p] = 0
    # --- meminfo ---
    mem_total: uint64 = 0
    mem_free: uint64 = 0
    mi_path: Ptr[char] = "/proc/meminfo"
    mfd: int32 = sys_open(mi_path)
    if mfd >= 0:
        mn: int64 = sys_read(mfd, &sysmon_buf[0], 1024)
        sys_close(mfd)
        mnu: uint64 = cast[uint64](mn)
        mem_total = sm_field(mnu, "MemTotal:")
        mem_free = sm_field(mnu, "MemFree:")
    p = 0
    p = sm_puts(&sysmon_line2[0], p, "MemTotal: ")
    p = sm_putnum(&sysmon_line2[0], p, mem_total)
    p = sm_puts(&sysmon_line2[0], p, " kB")
    sysmon_line2[p] = 0
    p = 0
    p = sm_puts(&sysmon_line3[0], p, "MemFree:  ")
    p = sm_putnum(&sysmon_line3[0], p, mem_free)
    p = sm_puts(&sysmon_line3[0], p, " kB")
    sysmon_line3[p] = 0
    used_pct: uint64 = 0
    if mem_total > 0:
        used_pct = ((mem_total - mem_free) * 100) / mem_total
    p = 0
    p = sm_puts(&sysmon_line4[0], p, "MemUsed:  ")
    p = sm_putnum(&sysmon_line4[0], p, used_pct)
    sysmon_line4[p] = 37        # '%'
    p = p + 1
    sysmon_line4[p] = 0


# Parse the cached "MemUsed: NN%" percentage from sysmon_line4 for the bar.
def sysmon_used_pct() -> int64:
    i: uint64 = 0
    v: int64 = 0
    started: int32 = 0
    while sysmon_line4[i] != 0 and i < 48:
        c: uint8 = sysmon_line4[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[int64](c - 48)
            started = 1
        elif started != 0:
            break
        i = i + 1
    if v > 100:
        v = 100
    return v


# ====================================================================
# Built-in app body renderers
# ====================================================================
# Scratch for the calculator display string.
calc_disp_buf: Array[24, uint8]

# Calculator app theme.
CALC_BG_R: uint8 = 54
CALC_BG_G: uint8 = 58
CALC_BG_B: uint8 = 66
CALC_DISP_R: uint8 = 24
CALC_DISP_G: uint8 = 30
CALC_DISP_B: uint8 = 26
CALC_KEY_R: uint8 = 78
CALC_KEY_G: uint8 = 84
CALC_KEY_B: uint8 = 96
CALC_OPKEY_R: uint8 = 96            # operator keys tinted orange-ish
CALC_OPKEY_G: uint8 = 78
CALC_OPKEY_B: uint8 = 60

# System-monitor app theme.
SYSMON_BG_R: uint8 = 40
SYSMON_BG_G: uint8 = 46
SYSMON_BG_B: uint8 = 56


# Render the calculator body for window `slot` at body-pixel (x,y).
def app_calc_pixel(slot: uint64, x: int64, y: int64,
                   outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx: Array[1, int64]
    by: Array[1, int64]
    cw: Array[1, int64]
    ch: Array[1, int64]
    dh: Array[1, int64]
    calc_layout(slot, &bx[0], &by[0], &cw[0], &ch[0], &dh[0])
    r: uint8 = CALC_BG_R
    g: uint8 = CALC_BG_G
    b: uint8 = CALC_BG_B
    ly: int64 = y - by[0]
    # --- display strip across the top ---
    if ly < dh[0]:
        r = CALC_DISP_R
        g = CALC_DISP_G
        b = CALC_DISP_B
        if ly == dh[0] - 1:
            r = 16
            g = 18
            b = 16
        n: uint64 = calc_format(slot, &calc_disp_buf[0])
        pad: int64 = 6
        txt_w: int64 = cast[int64](n) * GLYPH_W
        ox: int64 = bx[0] + (cw[0] * 4) - pad - txt_w
        if ox < bx[0] + pad:
            ox = bx[0] + pad
        oy: int64 = by[0] + (dh[0] - GLYPH_H) / 2
        if str_ink(&calc_disp_buf[0], ox, oy, x, y) != 0:
            r = 120
            g = 240
            b = 140
        outr[0] = r
        outg[0] = g
        outb[0] = b
        return
    # --- keypad ---
    cell: int64 = calc_cell_at(slot, x, y)
    if cell >= 0:
        lbl: uint8 = calc_key_label(cell)
        is_op: int32 = 0
        if lbl == 43 or lbl == 45 or lbl == 42 or lbl == 47 or lbl == 61:
            is_op = 1
        if is_op != 0:
            r = CALC_OPKEY_R
            g = CALC_OPKEY_G
            b = CALC_OPKEY_B
        else:
            r = CALC_KEY_R
            g = CALC_KEY_G
            b = CALC_KEY_B
        # Hover highlight: brighten the cell under the cursor.
        hov: int64 = calc_cell_at(slot, CUR_X, CUR_Y)
        if hov == cell:
            r = add_clamp_u8(r, 34)
            g = add_clamp_u8(g, 34)
            b = add_clamp_u8(b, 34)
        # 1px inset border between keys.
        kx0: int64 = bx[0] + (cell % 4) * cw[0]
        ky0: int64 = by[0] + dh[0] + (cell / 4) * ch[0]
        klx: int64 = x - kx0
        kly: int64 = y - ky0
        if klx == 0 or kly == 0:
            r = sub_clamp_u8(r, 28)
            g = sub_clamp_u8(g, 28)
            b = sub_clamp_u8(b, 28)
        # Centred label glyph.
        gx0: int64 = kx0 + (cw[0] - GLYPH_W) / 2
        gy0: int64 = ky0 + (ch[0] - GLYPH_H) / 2
        kbuf: Array[2, uint8]
        kbuf[0] = lbl
        kbuf[1] = 0
        if str_ink(&kbuf[0], gx0, gy0, x, y) != 0:
            r = 235
            g = 235
            b = 240
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Render the system-monitor body for window `slot` at body-pixel (x,y).
def app_sysmon_pixel(slot: uint64, x: int64, y: int64,
                     outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = SYSMON_BG_R
    g: uint8 = SYSMON_BG_G
    b: uint8 = SYSMON_BG_B
    pad: int64 = 8
    tx: int64 = bx0 + pad
    h0: Ptr[uint8] = "Hamnix System Monitor"
    if str_ink(h0, tx, by0 + 8, x, y) != 0:
        r = 150
        g = 200
        b = 250
    if str_ink(&sysmon_line1[0], tx, by0 + 40, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line2[0], tx, by0 + 64, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line3[0], tx, by0 + 88, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line4[0], tx, by0 + 112, x, y) != 0:
        r = 180
        g = 240
        b = 180
    # A proportional memory-usage bar under the text.
    bar_y: int64 = by0 + 140
    bar_h: int64 = 14
    bar_x0: int64 = tx
    bar_w: int64 = DWIN_W[slot] - 4 - pad * 2
    if y >= bar_y and y < bar_y + bar_h and x >= bar_x0 and x < bar_x0 + bar_w:
        if x == bar_x0 or x == bar_x0 + bar_w - 1 or y == bar_y or y == bar_y + bar_h - 1:
            r = 200
            g = 200
            b = 210
        else:
            pct: int64 = sysmon_used_pct()
            fillw: int64 = ((bar_w - 2) * pct) / 100
            if x - (bar_x0 + 1) < fillw:
                r = 90
                g = 180
                b = 120
            else:
                r = 30
                g = 34
                b = 40
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Render the About card body.
def app_about_pixel(slot: uint64, x: int64, y: int64,
                    outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 44
    g: uint8 = 50
    b: uint8 = 62
    tx: int64 = bx0 + 12
    l0: Ptr[uint8] = "Hamnix Desktop"
    if str_ink(l0, tx, by0 + 16, x, y) != 0:
        r = 160
        g = 210
        b = 255
    l1: Ptr[uint8] = "A Plan 9 / MATE-flavoured DE"
    if str_ink(l1, tx, by0 + 44, x, y) != 0:
        r = 220
        g = 228
        b = 235
    l2: Ptr[uint8] = "Native windowing + compositor"
    if str_ink(l2, tx, by0 + 64, x, y) != 0:
        r = 220
        g = 228
        b = 235
    l3: Ptr[uint8] = "Use Applications to launch apps."
    if str_ink(l3, tx, by0 + 92, x, y) != 0:
        r = 200
        g = 208
        b = 215
    outr[0] = r
    outg[0] = g
    outb[0] = b


# ====================================================================
# ROUND-4: Settings / Preferences built-in app (APP_SETTINGS)
# ====================================================================
# A genuine in-process preferences window — no child process. Clickable
# rows let the user change session appearance + behaviour:
#   row 0: Theme accent  -> theme_cycle()        (title-bar colour)
#   row 1: Background     -> bg_cycle()           (desktop colour)
#   row 2: Panel position -> panel_pos_toggle()   (top / bottom pref)
#   row 3: Focus model    -> focus_mode_toggle()  (click / follows-mouse)
#   row 4: Workspaces     -> ws_count_cycle()     (number of desktops) [R8]
#   row 5: Reset          -> restore all defaults
# Choices persist in-memory for the session (the THEME_IDX / BG_IDX /
# PANEL_POS / FOCUS_MODE / WS_COUNT globals). Layout mirrors calc_layout's
# out-pointer pattern.
SET_ROWS:   int64 = 6
SET_ROW_H:  int64 = 28
SET_TOP_PAD: int64 = 14


# y of the top of settings row `i` (screen coords) for window `slot`.
def settings_row_y(slot: uint64, i: int64) -> int64:
    return DWIN_Y[slot] + TITLE_H + SET_TOP_PAD + i * SET_ROW_H


# Row index (0..SET_ROWS-1) under (px,py) inside settings window `slot`,
# or -1. Rows span the full body width inset by a small margin.
def settings_row_at(slot: uint64, px: int64, py: int64) -> int64:
    bx0: int64 = DWIN_X[slot] + 8
    bw:  int64 = DWIN_W[slot] - 16
    if px < bx0 or px >= bx0 + bw:
        return -1
    i: int64 = 0
    while i < SET_ROWS:
        ry: int64 = settings_row_y(slot, i)
        if py >= ry and py < ry + SET_ROW_H - 4:
            return i
        i = i + 1
    return -1


# Invoke settings row `i` for window `slot`.
def settings_press(slot: uint64, i: int64):
    if i == 0:
        theme_cycle()
    elif i == 1:
        bg_cycle()
    elif i == 2:
        panel_pos_toggle()
    elif i == 3:
        # ROUND-7: toggle the focus model (click-to-focus / follows-mouse).
        focus_mode_toggle()
    elif i == 4:
        # ROUND-8: change the number of virtual desktops.
        ws_count_cycle()
    elif i == 5:
        # Reset all session appearance + behaviour to defaults.
        THEME_IDX = 0
        theme_apply()
        BG_IDX = 0
        bg_palette_init()
        ROOT_R = bg_palette[0]
        ROOT_G = bg_palette[1]
        ROOT_B = bg_palette[2]
        PANEL_POS = 0
        FOCUS_MODE = 0
        WS_COUNT = 4
        if CUR_WS >= WS_COUNT:
            CUR_WS = WS_COUNT - 1
        rs: Ptr[uint8] = "SETTINGS reset\n"
        sys_write(1, rs, strlen_u8(rs))


# Render the Settings body. Each row paints its label on the left and its
# current value (right-aligned-ish) plus a faint row separator, with the
# value tinted by the live accent so the theme choice reads immediately.
def app_settings_pixel(slot: uint64, x: int64, y: int64,
                       outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 46
    g: uint8 = 52
    b: uint8 = 64
    tx: int64 = bx0 + 12
    # Title line.
    hd: Ptr[uint8] = "Appearance"
    if str_ink(hd, tx, by0 + 2, x, y) != 0:
        r = 170
        g = 210
        b = 255
    # Row backgrounds + a hover-less highlight band so rows read as buttons.
    rowi: int64 = 0
    while rowi < SET_ROWS:
        ry: int64 = settings_row_y(slot, rowi)
        rx0: int64 = DWIN_X[slot] + 8
        rw:  int64 = DWIN_W[slot] - 16
        if y >= ry and y < ry + SET_ROW_H - 4 and x >= rx0 and x < rx0 + rw:
            # button face
            r = 60
            g = 68
            b = 84
            if x == rx0 or x == rx0 + rw - 1 or y == ry or y == ry + SET_ROW_H - 5:
                r = 96
                g = 104
                b = 122
        rowi = rowi + 1
    # Row labels + values.
    lx: int64 = bx0 + 16
    vx: int64 = DWIN_X[slot] + DWIN_W[slot] - 8 - 9 * GLYPH_W
    y0: int64 = settings_row_y(slot, 0) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y1: int64 = settings_row_y(slot, 1) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y2: int64 = settings_row_y(slot, 2) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y3: int64 = settings_row_y(slot, 3) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y4: int64 = settings_row_y(slot, 4) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y5: int64 = settings_row_y(slot, 5) + (SET_ROW_H - 4 - GLYPH_H) / 2
    lbl0: Ptr[uint8] = "Theme"
    lbl1: Ptr[uint8] = "Background"
    lbl2: Ptr[uint8] = "Panel"
    lbl3: Ptr[uint8] = "Focus"
    lbl4: Ptr[uint8] = "Workspaces"
    lbl5: Ptr[uint8] = "Reset Defaults"
    if str_ink(lbl0, lx, y0, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl1, lx, y1, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl2, lx, y2, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl3, lx, y3, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl4, lx, y4, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl5, lx, y5, x, y) != 0:
        r = 225
        g = 230
        b = 238
    # Values, tinted by the accent so the theme choice is visible.
    if str_ink(theme_name(THEME_IDX), vx, y0, x, y) != 0:
        r = ACCENT_TOP_R
        g = ACCENT_TOP_G
        b = ACCENT_TOP_B
    bgv: Array[4, uint8]
    bgv[0] = cast[uint8](BG_IDX) + 48
    bgv[1] = 0
    if str_ink(&bgv[0], vx, y1, x, y) != 0:
        r = 180
        g = 220
        b = 180
    if str_ink(panel_pos_name(PANEL_POS), vx, y2, x, y) != 0:
        r = 230
        g = 210
        b = 150
    if str_ink(focus_mode_name(FOCUS_MODE), vx, y3, x, y) != 0:
        r = 210
        g = 190
        b = 240
    # ROUND-8: workspace-count value (a single digit, WS_MIN..WS_MAX).
    wsv: Array[4, uint8]
    wsv[0] = cast[uint8](WS_COUNT) + 48
    wsv[1] = 0
    if str_ink(&wsv[0], vx, y4, x, y) != 0:
        r = 150
        g = 200
        b = 230
    outr[0] = r
    outg[0] = g
    outb[0] = b


# ====================================================================
# ROUND-16: Control Center built-in app (APP_CTRLCENTER)
# ====================================================================
# A MATE-style control-center window: a left category sidebar
# (Appearance / Panel / Windows / Keyboard) and a right pane whose
# clickable rows live-apply settings. Unlike the flat Settings window,
# the Control Center groups the preferences the way mate-control-center
# does and drives the new theme engine (colour scheme + UI scale) plus a
# read-only keyboard-shortcut viewer.
CC_CAT_COUNT: int64 = 4
CC_SIDE_W:    int64 = 110         # left category sidebar width (px)
CC_ROW_H:     int64 = 26          # right-pane control row height (px)
CC_TOP_PAD:   int64 = 14
# Per-window selected category (0..CC_CAT_COUNT-1). Indexed by window slot.
CC_CAT: Array[8, int64]


def cc_cat_label(c: int64) -> Ptr[uint8]:
    if c == 0:
        a0: Ptr[uint8] = "Appearance"
        return a0
    if c == 1:
        a1: Ptr[uint8] = "Panel"
        return a1
    if c == 2:
        a2: Ptr[uint8] = "Windows"
        return a2
    k: Ptr[uint8] = "Keyboard"
    return k


# Number of clickable control rows in category `c` (Keyboard's rows are
# read-only viewer lines, one per shortcut).
def cc_cat_rows(c: int64) -> int64:
    if c == 0:
        return 4                  # Scheme / Accent / Background / UI Scale
    if c == 1:
        return 3                  # Position / Autohide / Workspaces
    if c == 2:
        return 1                  # Focus model
    return KBD_SHORTCUT_COUNT     # one row per shortcut (read-only)


# y of category `c`'s sidebar row (screen coords) for window `slot`.
def cc_side_row_y(slot: uint64, c: int64) -> int64:
    return DWIN_Y[slot] + TITLE_H + CC_TOP_PAD + c * (CC_ROW_H + 2)


# Sidebar category under (px,py) for window `slot`, or -1.
def cc_side_at(slot: uint64, px: int64, py: int64) -> int64:
    sx0: int64 = DWIN_X[slot] + 6
    if px < sx0 or px >= DWIN_X[slot] + CC_SIDE_W:
        return -1
    c: int64 = 0
    while c < CC_CAT_COUNT:
        ry: int64 = cc_side_row_y(slot, c)
        if py >= ry and py < ry + CC_ROW_H:
            return c
        c = c + 1
    return -1


# y of right-pane control row `i` (screen coords) for window `slot`. The
# row pitch is driven through ui_scaled() so the 2x UI scale visibly
# stretches the Control Center layout.
def cc_row_y(slot: uint64, i: int64) -> int64:
    rh: int64 = ui_scaled(CC_ROW_H)
    return DWIN_Y[slot] + TITLE_H + CC_TOP_PAD + GLYPH_H + 8 + i * (rh + 2)


# Right-pane control row under (px,py) for window `slot`, or -1. Only
# categories with clickable rows (0,1,2) return hits.
def cc_row_at(slot: uint64, px: int64, py: int64) -> int64:
    cat: int64 = CC_CAT[slot]
    if cat == 3:
        return -1                 # Keyboard category is read-only
    px0: int64 = DWIN_X[slot] + CC_SIDE_W + 8
    pw:  int64 = DWIN_X[slot] + DWIN_W[slot] - 8 - px0
    if px < px0 or px >= px0 + pw:
        return -1
    n: int64 = cc_cat_rows(cat)
    rh: int64 = ui_scaled(CC_ROW_H)
    i: int64 = 0
    while i < n:
        ry: int64 = cc_row_y(slot, i)
        if py >= ry and py < ry + rh - 4:
            return i
        i = i + 1
    return -1


# Right-pane row VALUE string for (category cat, row i). Returns a pointer
# into a small module-scope formatting buffer for numeric values.
cc_val_buf: Array[8, uint8]


def cc_row_value(cat: int64, i: int64) -> Ptr[uint8]:
    if cat == 0:
        if i == 0:
            return scheme_name(SCHEME_IDX)
        if i == 1:
            return theme_name(THEME_IDX)
        if i == 2:
            cc_val_buf[0] = cast[uint8](BG_IDX) + 48
            cc_val_buf[1] = 0
            return &cc_val_buf[0]
        return ui_scale_name(UI_SCALE)
    if cat == 1:
        if i == 0:
            return panel_pos_name(PANEL_POS)
        if i == 1:
            if PANEL_AUTOHIDE != 0:
                on: Ptr[uint8] = "On"
                return on
            off: Ptr[uint8] = "Off"
            return off
        cc_val_buf[0] = cast[uint8](WS_COUNT) + 48
        cc_val_buf[1] = 0
        return &cc_val_buf[0]
    if cat == 2:
        return focus_mode_name(FOCUS_MODE)
    e: Ptr[uint8] = ""
    return e


def cc_row_label(cat: int64, i: int64) -> Ptr[uint8]:
    if cat == 0:
        if i == 0:
            l0: Ptr[uint8] = "Colour Scheme"
            return l0
        if i == 1:
            l1: Ptr[uint8] = "Title Accent"
            return l1
        if i == 2:
            l2: Ptr[uint8] = "Background"
            return l2
        l3: Ptr[uint8] = "UI Scale"
        return l3
    if cat == 1:
        if i == 0:
            p0: Ptr[uint8] = "Position"
            return p0
        if i == 1:
            p1: Ptr[uint8] = "Autohide"
            return p1
        p2: Ptr[uint8] = "Workspaces"
        return p2
    if cat == 2:
        f0: Ptr[uint8] = "Focus Model"
        return f0
    e: Ptr[uint8] = ""
    return e


# Apply the click on right-pane control row `i` of category `cat`. Every
# action mutates a live global the renderer reads, so the desktop updates
# on the next frame (the theme engine recolours panel/menus/desktop).
def cc_row_press(cat: int64, i: int64, scr_w: int64, scr_h: int64):
    if cat == 0:
        if i == 0:
            scheme_cycle()
        elif i == 1:
            theme_cycle()
        elif i == 2:
            bg_cycle()
        else:
            ui_scale_toggle()
        return
    if cat == 1:
        if i == 0:
            panel_pos_toggle()
        elif i == 1:
            panel_autohide_toggle()
        else:
            ws_count_cycle()
        return
    if cat == 2:
        focus_mode_toggle()
        return


# Render the Control Center body.
def app_ctrlcenter_pixel(slot: uint64, x: int64, y: int64,
                         outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 44
    g: uint8 = 48
    b: uint8 = 58
    # Sidebar panel face.
    sx0: int64 = DWIN_X[slot] + 2
    sxe: int64 = DWIN_X[slot] + CC_SIDE_W
    if x >= sx0 and x < sxe:
        r = 36
        g = 40
        b = 50
    # Sidebar category rows.
    cat_sel: int64 = CC_CAT[slot]
    c: int64 = 0
    while c < CC_CAT_COUNT:
        ry: int64 = cc_side_row_y(slot, c)
        rx0: int64 = DWIN_X[slot] + 6
        rxe: int64 = DWIN_X[slot] + CC_SIDE_W - 2
        if y >= ry and y < ry + CC_ROW_H and x >= rx0 and x < rxe:
            if c == cat_sel:
                r = MENU_SEL_R
                g = MENU_SEL_G
                b = MENU_SEL_B
            else:
                r = 52
                g = 58
                b = 70
        c = c + 1
    # Sidebar category labels.
    c = 0
    while c < CC_CAT_COUNT:
        ly: int64 = cc_side_row_y(slot, c) + (CC_ROW_H - GLYPH_H) / 2
        if str_ink(cc_cat_label(c), DWIN_X[slot] + 12, ly, x, y) != 0:
            r = 230
            g = 232
            b = 240
        c = c + 1
    # Right pane header (the selected category name).
    px0: int64 = DWIN_X[slot] + CC_SIDE_W + 8
    hy: int64 = DWIN_Y[slot] + TITLE_H + CC_TOP_PAD
    if str_ink(cc_cat_label(cat_sel), px0, hy, x, y) != 0:
        r = ACCENT_TOP_R
        g = ACCENT_TOP_G
        b = ACCENT_TOP_B
    # Right pane: clickable control rows (cats 0,1,2) or shortcut viewer (3).
    if cat_sel == 3:
        # Keyboard-shortcut viewer: chord on the left, action on the right.
        ki: int64 = 0
        while ki < KBD_SHORTCUT_COUNT:
            kry: int64 = cc_row_y(slot, ki) + (ui_scaled(CC_ROW_H) - 4 - GLYPH_H) / 2
            if str_ink(kbd_shortcut_chord(ki), px0 + 4, kry, x, y) != 0:
                r = 200
                g = 220
                b = 150
            avx: int64 = px0 + 130
            if str_ink(kbd_shortcut_action(ki), avx, kry, x, y) != 0:
                r = 220
                g = 222
                b = 230
            ki = ki + 1
    else:
        n: int64 = cc_cat_rows(cat_sel)
        rh: int64 = ui_scaled(CC_ROW_H)
        i: int64 = 0
        while i < n:
            ry2: int64 = cc_row_y(slot, i)
            rx0: int64 = px0
            rxe: int64 = DWIN_X[slot] + DWIN_W[slot] - 8
            if y >= ry2 and y < ry2 + rh - 4 and x >= rx0 and x < rxe:
                r = 58
                g = 64
                b = 78
                if x == rx0 or x == rxe - 1 or y == ry2 or y == ry2 + rh - 5:
                    r = 92
                    g = 100
                    b = 118
            i = i + 1
        i = 0
        while i < n:
            rry: int64 = cc_row_y(slot, i) + (rh - 4 - GLYPH_H) / 2
            if str_ink(cc_row_label(cat_sel, i), px0 + 8, rry, x, y) != 0:
                r = 226
                g = 230
                b = 238
            vx2: int64 = DWIN_X[slot] + DWIN_W[slot] - 8 - 12 * GLYPH_W
            if str_ink(cc_row_value(cat_sel, i), vx2, rry, x, y) != 0:
                r = ACCENT_TOP_R
                g = ACCENT_TOP_G
                b = ACCENT_TOP_B
            i = i + 1
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Handle a body click in a Control Center window `slot` at (px,py).
def cc_click(slot: uint64, px: int64, py: int64, scr_w: int64, scr_h: int64):
    c: int64 = cc_side_at(slot, px, py)
    if c >= 0:
        CC_CAT[slot] = c
        cm: Ptr[uint8] = "CC category "
        sys_write(1, cm, strlen_u8(cm))
        cb: Array[4, uint8]
        cb[0] = cast[uint8](c) + 48
        cb[1] = 10
        sys_write(1, &cb[0], 2)
        return
    i: int64 = cc_row_at(slot, px, py)
    if i >= 0:
        cc_row_press(CC_CAT[slot], i, scr_w, scr_h)


# ====================================================================
# Built-in icon-grid file manager (APP_FILEMGR)
# ====================================================================
# A real desktop file manager drawn entirely in the compositor (like
# APP_SYSMON): the body shows the current directory as a GRID of icons —
# a folder glyph for directories, a document glyph for regular files —
# each with its name centred underneath. Single/double-clicking a folder
# cell enters it; an "Up" affordance (the first ".." cell) climbs to the
# parent; clicking a text file opens it in the APP_EDITOR window. The
# directory primitives are exactly the ones user/hamfm.ad used:
# p9_listdir to enumerate (and, lacking stat(2), to classify dir-vs-file)
# and sys_getcwd to seed the start path. State is per-window-slot so two
# file managers each keep their own location.
FM_MAX_ENTRIES: uint64 = 256          # entries shown per directory
FM_NAME_CAP:    uint64 = 48           # bytes kept per entry name
FM_PATH_CAP:    uint64 = 512          # max byte length of a path
FM_LIST_CAP:    uint64 = 16384        # raw listdir buffer

# Per-slot current path (NUL-terminated) + its live length.
FM_PATH:     Array[4096, uint8]       # DMAX * FM_PATH_CAP
FM_PATH_LEN: Array[8, uint64]
# Per-slot parsed entry table. Names live in a flat pool; the ".." up
# affordance is synthesised as entry 0 of every non-root directory so it
# is always reachable. FM_IS_DIR[slot*N + i] == 1 marks a directory cell.
FM_NAMES:   Array[98304, uint8]       # DMAX * FM_MAX_ENTRIES * FM_NAME_CAP
FM_NLEN:    Array[2048, uint64]       # DMAX * FM_MAX_ENTRIES
FM_IS_DIR:  Array[2048, int32]        # DMAX * FM_MAX_ENTRIES
FM_COUNT:   Array[8, uint64]          # live entries in this slot
# Raw listdir scratch (shared; populated then parsed synchronously).
fm_list_buf: Array[16384, uint8]
# Scratch full path builder (shared, used synchronously).
fm_full_path: Array[512, uint8]

# Grid geometry inside the window body.
FM_CELL_W:  int64 = 84                # cell footprint width
FM_CELL_H:  int64 = 72               # cell footprint height (icon + label)
FM_ICON:    int64 = 40               # icon glyph square
FM_HDR_H:   int64 = 22               # path-header band height
FM_PAD:     int64 = 8                # body padding


# Pointer to the first byte of slot's current-path buffer.
def fm_path_ptr(slot: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&FM_PATH[0]) + slot * FM_PATH_CAP)


# Pointer to the first byte of entry `i`'s name slot in `slot`.
def fm_name_ptr(slot: uint64, i: uint64) -> Ptr[uint8]:
    base: uint64 = (slot * FM_MAX_ENTRIES + i) * FM_NAME_CAP
    return cast[Ptr[uint8]](cast[uint64](&FM_NAMES[0]) + base)


# Set slot's current path to a NUL-terminated string (defaults to "/").
def fm_set_path(slot: uint64, s: Ptr[uint8]):
    dst: Ptr[uint8] = fm_path_ptr(slot)
    i: uint64 = 0
    while s[i] != 0 and i < FM_PATH_CAP - 1:
        dst[i] = s[i]
        i = i + 1
    if i == 0:
        dst[0] = 47                     # '/'
        i = 1
    dst[i] = 0
    FM_PATH_LEN[slot] = i


# Build fm_full_path = slot-path + "/" + name(i) (no double slash at root).
def fm_build_full(slot: uint64, i: uint64):
    src: Ptr[uint8] = fm_path_ptr(slot)
    j: uint64 = 0
    plen: uint64 = FM_PATH_LEN[slot]
    while j < plen and j < FM_PATH_CAP - 1:
        fm_full_path[j] = src[j]
        j = j + 1
    if j == 0 or fm_full_path[j - 1] != 47:
        fm_full_path[j] = 47
        j = j + 1
    nl: uint64 = FM_NLEN[slot * FM_MAX_ENTRIES + i]
    p: Ptr[uint8] = fm_name_ptr(slot, i)
    k: uint64 = 0
    while k < nl and j < FM_PATH_CAP - 1:
        fm_full_path[j] = p[k]
        j = j + 1
        k = k + 1
    fm_full_path[j] = 0


# Replace slot's path with its parent directory (root stays root).
def fm_go_parent(slot: uint64):
    dst: Ptr[uint8] = fm_path_ptr(slot)
    n: uint64 = FM_PATH_LEN[slot]
    if n <= 1:
        dst[0] = 47
        dst[1] = 0
        FM_PATH_LEN[slot] = 1
        return
    if dst[n - 1] == 47:
        n = n - 1
    while n > 1 and dst[n - 1] != 47:
        n = n - 1
    if n > 1:
        n = n - 1
    if n == 0:
        n = 1
    dst[n] = 0
    FM_PATH_LEN[slot] = n


# 1 if the full path just built in fm_full_path is itself a directory
# (a successful p9_listdir means a directory — same probe as hamfm).
def fm_probe_is_dir() -> int32:
    probe: Array[16, uint8]
    n: int64 = p9_listdir(cast[Ptr[char]](&fm_full_path[0]), &probe[0], 16)
    if n >= 0:
        return 1
    return 0


# (Re)enumerate slot's current directory into its entry table. Entry 0 is
# always a synthetic ".." up affordance for any non-root directory.
def fm_load_dir(slot: uint64):
    FM_COUNT[slot] = 0
    base_e: uint64 = slot * FM_MAX_ENTRIES
    # Synthetic ".." up affordance (skip at the filesystem root).
    if FM_PATH_LEN[slot] > 1:
        up: Ptr[uint8] = fm_name_ptr(slot, 0)
        up[0] = 46
        up[1] = 46
        up[2] = 0
        FM_NLEN[base_e + 0] = 2
        FM_IS_DIR[base_e + 0] = 1
        FM_COUNT[slot] = 1
    n: int64 = p9_listdir(cast[Ptr[char]](fm_path_ptr(slot)),
                           &fm_list_buf[0], FM_LIST_CAP)
    if n < 0:
        return
    nu: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < nu and FM_COUNT[slot] < FM_MAX_ENTRIES:
        c: uint8 = fm_list_buf[i]
        if c == 10 or c == 0:
            i = i + 1
            continue
        j: uint64 = i
        while j < nu:
            d: uint8 = fm_list_buf[j]
            if d == 10 or d == 0:
                j = j           # break below
                break
            j = j + 1
        nl: uint64 = j - i
        keep: int32 = 1
        if nl == 1 and fm_list_buf[i] == 46:
            keep = 0
        if nl == 2 and fm_list_buf[i] == 46 and fm_list_buf[i + 1] == 46:
            keep = 0
        if keep != 0:
            e: uint64 = FM_COUNT[slot]
            store: uint64 = nl
            if store > FM_NAME_CAP - 1:
                store = FM_NAME_CAP - 1
            dst: Ptr[uint8] = fm_name_ptr(slot, e)
            k: uint64 = 0
            while k < store:
                dst[k] = fm_list_buf[i + k]
                k = k + 1
            dst[store] = 0
            FM_NLEN[base_e + e] = store
            # Classify dir-vs-file via a p9_listdir probe on the full path.
            fm_build_full(slot, e)
            FM_IS_DIR[base_e + e] = fm_probe_is_dir()
            FM_COUNT[slot] = e + 1
        i = j + 1


# Columns that fit in slot's body width.
def fm_cols(slot: uint64) -> int64:
    bw: int64 = DWIN_W[slot] - 4 - FM_PAD * 2
    c: int64 = bw / FM_CELL_W
    if c < 1:
        c = 1
    return c


# Body-grid origin (top-left of the first cell, below the path header).
def fm_grid_x0(slot: uint64) -> int64:
    return DWIN_X[slot] + 2 + FM_PAD


def fm_grid_y0(slot: uint64) -> int64:
    return DWIN_Y[slot] + TITLE_H + FM_HDR_H


# Index of the grid cell under (px,py), or -1 if none / past the entries.
def fm_cell_at(slot: uint64, px: int64, py: int64) -> int64:
    gx0: int64 = fm_grid_x0(slot)
    gy0: int64 = fm_grid_y0(slot)
    if px < gx0 or py < gy0:
        return -1
    cols: int64 = fm_cols(slot)
    col: int64 = (px - gx0) / FM_CELL_W
    row: int64 = (py - gy0) / FM_CELL_H
    if col < 0 or col >= cols or row < 0:
        return -1
    idx: int64 = row * cols + col
    if idx < 0 or idx >= cast[int64](FM_COUNT[slot]):
        return -1
    return idx


# Open the entry at cell `i`: descend a directory (re-list), or route a
# regular file into the editor. Emits a serial marker so a self-test (and
# a human reading the log) can follow navigation.
def fm_open_cell(slot: uint64, i: int64, scr_w: int64, scr_h: int64):
    if i < 0 or i >= cast[int64](FM_COUNT[slot]):
        return
    iu: uint64 = cast[uint64](i)
    base_e: uint64 = slot * FM_MAX_ENTRIES
    # The synthetic ".." up affordance (entry 0 of a non-root directory).
    is_up: int32 = 0
    if i == 0 and FM_PATH_LEN[slot] > 1:
        nm: Ptr[uint8] = fm_name_ptr(slot, 0)
        if nm[0] == 46 and nm[1] == 46 and FM_NLEN[base_e + 0] == 2:
            is_up = 1
    if is_up != 0:
        fm_go_parent(slot)
        fm_load_dir(slot)
        mu: Ptr[uint8] = "FM up "
        sys_write(1, mu, strlen_u8(mu))
        sys_write(1, fm_path_ptr(slot), FM_PATH_LEN[slot])
        sys_write(1, "\n", 1)
        return
    if FM_IS_DIR[base_e + iu] != 0:
        fm_build_full(slot, iu)
        fm_set_path(slot, &fm_full_path[0])
        fm_load_dir(slot)
        md: Ptr[uint8] = "FM enter "
        sys_write(1, md, strlen_u8(md))
        sys_write(1, fm_path_ptr(slot), FM_PATH_LEN[slot])
        sys_write(1, "\n", 1)
        return
    # Regular file: open it in a new editor window rooted at this path.
    fm_build_full(slot, iu)
    mo: Ptr[uint8] = "FM open "
    sys_write(1, mo, strlen_u8(mo))
    sys_write(1, &fm_full_path[0], strlen_u8(&fm_full_path[0]))
    sys_write(1, "\n", 1)
    editor_open_path(&fm_full_path[0], scr_w, scr_h)


# Body click in a file manager window: navigate to the cell under (px,py).
def fm_click(slot: uint64, px: int64, py: int64, scr_w: int64, scr_h: int64):
    cell: int64 = fm_cell_at(slot, px, py)
    if cell >= 0:
        fm_open_cell(slot, cell, scr_w, scr_h)


# Draw one pixel of a file-manager body. Mirrors app_sysmon_pixel's
# per-pixel contract and reuses the desktop-icon look (beveled badge +
# centred label) so the grid matches the good-looking desktop icons.
def app_filemgr_pixel(slot: uint64, x: int64, y: int64,
                      outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 38
    g: uint8 = 42
    b: uint8 = 52
    # Path header band.
    if y >= by0 and y < by0 + FM_HDR_H:
        r = 28
        g = 32
        b = 40
        if str_ink(fm_path_ptr(slot), bx0 + FM_PAD, by0 + 4, x, y) != 0:
            r = 200
            g = 220
            b = 240
        outr[0] = r
        outg[0] = g
        outb[0] = b
        return
    # Icon grid.
    gx0: int64 = fm_grid_x0(slot)
    gy0: int64 = fm_grid_y0(slot)
    cols: int64 = fm_cols(slot)
    cnt: int64 = cast[int64](FM_COUNT[slot])
    base_e: uint64 = slot * FM_MAX_ENTRIES
    i: int64 = 0
    while i < cnt:
        col: int64 = i % cols
        row: int64 = i / cols
        cx: int64 = gx0 + col * FM_CELL_W
        cy: int64 = gy0 + row * FM_CELL_H
        if x >= cx and x < cx + FM_CELL_W and y >= cy and y < cy + FM_CELL_H:
            iu: uint64 = cast[uint64](i)
            isdir: int32 = FM_IS_DIR[base_e + iu]
            # Icon square centred near the cell top.
            ix0: int64 = cx + (FM_CELL_W - FM_ICON) / 2
            iy0: int64 = cy + 4
            if x >= ix0 and x < ix0 + FM_ICON and y >= iy0 and y < iy0 + FM_ICON:
                lx: int64 = x - ix0
                ly: int64 = y - iy0
                # Base tint: folder = warm gold, file = pale paper.
                if isdir != 0:
                    r = 220
                    g = 188
                    b = 96
                else:
                    r = 226
                    g = 230
                    b = 238
                inside: int32 = 0
                if isdir != 0:
                    # Folder shape: a tab strip across the top + the body.
                    # Tab occupies the left 60% of the top 8px; the body is
                    # the lower box. Anything outside is the window bg.
                    tab_h: int64 = 8
                    tabw: int64 = (FM_ICON * 6) / 10
                    if ly < tab_h:
                        if lx < tabw:
                            inside = 1
                    elif ly >= tab_h and ly < FM_ICON - 2 \
                         and lx >= 2 and lx < FM_ICON - 2:
                        inside = 1
                    if inside != 0:
                        # Bevel: light top/left, dark bottom/right.
                        if lx <= 2 or ly <= tab_h:
                            r = add_clamp_u8(r, 30)
                            g = add_clamp_u8(g, 26)
                            b = add_clamp_u8(b, 14)
                        elif lx >= FM_ICON - 3 or ly >= FM_ICON - 3:
                            r = sub_clamp_u8(r, 40)
                            g = sub_clamp_u8(g, 34)
                            b = sub_clamp_u8(b, 20)
                else:
                    # Document shape: a page with a dog-eared top-right
                    # corner and a couple of "text" rules across it.
                    ear: int64 = 12
                    margin: int64 = 6
                    if lx >= margin and lx < FM_ICON - margin \
                       and ly >= 2 and ly < FM_ICON - 2:
                        # Carve out the folded corner (top-right triangle).
                        relx: int64 = (FM_ICON - margin) - lx
                        if ly - 2 + relx > ear:
                            inside = 1
                    if inside != 0:
                        # Text rules: three thin dark lines down the page.
                        rely: int64 = ly - 12
                        if rely == 0 or rely == 8 or rely == 16:
                            if lx >= margin + 3 and lx < FM_ICON - margin - 3:
                                r = 120
                                g = 130
                                b = 150
                        if lx == margin or lx == FM_ICON - margin - 1 \
                           or ly == 2 or ly == FM_ICON - 3:
                            r = sub_clamp_u8(r, 60)
                            g = sub_clamp_u8(g, 60)
                            b = sub_clamp_u8(b, 60)
                if inside == 0:
                    r = 38
                    g = 42
                    b = 52
            else:
                # Label band: centre the (possibly clipped) entry name.
                nm: Ptr[uint8] = fm_name_ptr(slot, iu)
                nlen: int64 = cast[int64](FM_NLEN[base_e + iu])
                lblw: int64 = nlen * GLYPH_W
                lblx: int64 = cx + (FM_CELL_W - lblw) / 2
                if lblx < cx + 2:
                    lblx = cx + 2
                lbly: int64 = iy0 + FM_ICON + 4
                if str_ink(nm, lblx, lbly, x, y) != 0:
                    r = 232
                    g = 236
                    b = 244
            i = cnt                      # found the owning cell; stop
        else:
            i = i + 1
    outr[0] = r
    outg[0] = g
    outb[0] = b


# ====================================================================
# Built-in Kate-like GUI text editor (APP_EDITOR)
# ====================================================================
# A real in-compositor editor: a per-slot editable text buffer rendered
# in the DE's monospace font with a visible caret, line-by-line. Keystrokes
# reach it through the SAME focused-window key path the rest of the DE uses
# (key_route / key_process_chunk): printable bytes insert at the caret,
# Backspace deletes, Enter splits the line, the arrow keys move the caret.
# Ctrl-S saves the buffer back to the path it was opened with. The buffer
# is a flat byte array with embedded '\n' newlines; the caret is a single
# byte offset into it.
ED_BUF_CAP:  uint64 = 8192            # bytes per editor buffer
ED_PATH_CAP: uint64 = 512
ED_BUF:      Array[65536, uint8]      # DMAX * ED_BUF_CAP
ED_LEN:      Array[8, uint64]         # live byte length per slot
ED_CARET:    Array[8, uint64]         # caret byte offset per slot
ED_PATH:     Array[4096, uint8]       # DMAX * ED_PATH_CAP (file backing)
ED_PATH_LEN: Array[8, uint64]
ED_DIRTY:    Array[8, int32]          # 1 = unsaved edits
ED_HDR_H:   int64 = 22               # title/status band height
ED_PAD:     int64 = 8
ED_LINE_H:  int64 = 18               # line pitch (GLYPH_H + 2)


def ed_buf_ptr(slot: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&ED_BUF[0]) + slot * ED_BUF_CAP)


def ed_path_ptr(slot: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&ED_PATH[0]) + slot * ED_PATH_CAP)


# Reset slot's editor to an empty buffer with no backing file.
def ed_reset(slot: uint64):
    ED_LEN[slot] = 0
    ED_CARET[slot] = 0
    ED_PATH_LEN[slot] = 0
    ED_DIRTY[slot] = 0
    pp: Ptr[uint8] = ed_path_ptr(slot)
    pp[0] = 0


# Insert one byte at the caret, shifting the tail right. No-op if full.
def ed_insert(slot: uint64, c: uint8):
    n: uint64 = ED_LEN[slot]
    if n >= ED_BUF_CAP - 1:
        return
    buf: Ptr[uint8] = ed_buf_ptr(slot)
    car: uint64 = ED_CARET[slot]
    j: uint64 = n
    while j > car:
        buf[j] = buf[j - 1]
        j = j - 1
    buf[car] = c
    ED_LEN[slot] = n + 1
    ED_CARET[slot] = car + 1
    ED_DIRTY[slot] = 1


# Delete the byte just before the caret (Backspace), shifting the tail.
def ed_backspace(slot: uint64):
    car: uint64 = ED_CARET[slot]
    if car == 0:
        return
    buf: Ptr[uint8] = ed_buf_ptr(slot)
    n: uint64 = ED_LEN[slot]
    j: uint64 = car
    while j < n:
        buf[j - 1] = buf[j]
        j = j + 1
    ED_LEN[slot] = n - 1
    ED_CARET[slot] = car - 1
    ED_DIRTY[slot] = 1


# Move the caret one step. dir: 0 left, 1 right, 2 up, 3 down.
def ed_move(slot: uint64, dir: int32):
    buf: Ptr[uint8] = ed_buf_ptr(slot)
    n: uint64 = ED_LEN[slot]
    car: uint64 = ED_CARET[slot]
    if dir == 0:
        if car > 0:
            ED_CARET[slot] = car - 1
        return
    if dir == 1:
        if car < n:
            ED_CARET[slot] = car + 1
        return
    # Vertical: find the current column (bytes since the previous '\n').
    ls: uint64 = car
    while ls > 0 and buf[ls - 1] != 10:
        ls = ls - 1
    col: uint64 = car - ls                # column within the current line
    if dir == 2:
        # Up: previous line. ls-1 is the '\n' ending the previous line.
        if ls == 0:
            ED_CARET[slot] = 0
            return
        pe: uint64 = ls - 1                # end (the '\n') of the prev line
        ps: uint64 = pe
        while ps > 0 and buf[ps - 1] != 10:
            ps = ps - 1
        plen: uint64 = pe - ps            # prev line length (sans '\n')
        if col > plen:
            col = plen
        ED_CARET[slot] = ps + col
        return
    if dir == 3:
        # Down: next line begins after the next '\n' from the caret.
        le: uint64 = car
        while le < n and buf[le] != 10:
            le = le + 1
        if le >= n:
            ED_CARET[slot] = n            # already on the last line
            return
        ns: uint64 = le + 1               # start of the next line
        ne: uint64 = ns
        while ne < n and buf[ne] != 10:
            ne = ne + 1
        nlen: uint64 = ne - ns
        if col > nlen:
            col = nlen
        ED_CARET[slot] = ns + col
        return


# Set slot's backing-file path (NUL-terminated).
def ed_set_path(slot: uint64, s: Ptr[uint8]):
    dst: Ptr[uint8] = ed_path_ptr(slot)
    i: uint64 = 0
    while s[i] != 0 and i < ED_PATH_CAP - 1:
        dst[i] = s[i]
        i = i + 1
    dst[i] = 0
    ED_PATH_LEN[slot] = i


# Load a file's contents into slot's buffer (caret to start). Returns the
# bytes read (>= 0), or -1 on open failure.
def ed_load_path(slot: uint64, path: Ptr[uint8]) -> int64:
    ed_set_path(slot, path)
    ED_LEN[slot] = 0
    ED_CARET[slot] = 0
    ED_DIRTY[slot] = 0
    fd: int32 = sys_open(cast[Ptr[char]](path))
    if fd < 0:
        return -1
    buf: Ptr[uint8] = ed_buf_ptr(slot)
    total: uint64 = 0
    while total < ED_BUF_CAP - 1:
        want: uint64 = ED_BUF_CAP - 1 - total
        if want > 1024:
            want = 1024
        got: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](buf) + total),
                              want)
        if got <= 0:
            j: uint64 = total       # done
            j = j
            break
        total = total + cast[uint64](got)
    sys_close(fd)
    ED_LEN[slot] = total
    return cast[int64](total)


# Save slot's buffer back to its backing path. Returns the bytes written
# (>= 0), or -1 if there is no path / the write fails. sys_open_write
# creates+truncates the file (init/main.ad::tmpfs_open_for_write).
def ed_save(slot: uint64) -> int64:
    if ED_PATH_LEN[slot] == 0:
        return -1
    fd: int32 = sys_open_write(cast[Ptr[char]](ed_path_ptr(slot)))
    if fd < 0:
        return -1
    buf: Ptr[uint8] = ed_buf_ptr(slot)
    n: uint64 = ED_LEN[slot]
    off: uint64 = 0
    spins: int32 = 0
    while off < n:
        wn: int64 = sys_write(fd, cast[Ptr[uint8]](cast[uint64](buf) + off),
                              n - off)
        if wn > 0:
            off = off + cast[uint64](wn)
            spins = 0
        else:
            spins = spins + 1
            if spins > 4096:
                j: uint64 = off
                j = j
                break
            sys_yield()
    sys_close(fd)
    ED_DIRTY[slot] = 0
    ms: Ptr[uint8] = "ED save "
    sys_write(1, ms, strlen_u8(ms))
    sys_write(1, ed_path_ptr(slot), ED_PATH_LEN[slot])
    sys_write(1, "\n", 1)
    return cast[int64](off)


# Route one already-decoded editor keystroke into the focused editor slot.
# `c` is a literal byte (printable, 8/127 Backspace, 13/10 Enter, or the
# Ctrl-S control code 19). Returns 1 if it was consumed.
def ed_key(slot: uint64, c: uint8) -> int32:
    if c == 19:                          # Ctrl-S -> save
        ed_save(slot)
        return 1
    if c == 8 or c == 127:               # Backspace / DEL
        ed_backspace(slot)
        return 1
    if c == 13 or c == 10:               # Enter -> newline
        ed_insert(slot, 10)
        return 1
    if c == 9:                           # Tab -> a literal tab
        ed_insert(slot, 9)
        return 1
    if c >= 32 and c < 127:              # printable -> insert
        ed_insert(slot, c)
        return 1
    return 0


# Draw one pixel of an editor body. Renders the buffer line-by-line in the
# monospace font with a solid caret block at the caret position.
def app_editor_pixel(slot: uint64, x: int64, y: int64,
                     outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 24
    g: uint8 = 26
    b: uint8 = 32
    # Header band: the file name + a dirty '*' marker.
    if y >= by0 and y < by0 + ED_HDR_H:
        r = 40
        g = 44
        b = 54
        hx: int64 = bx0 + ED_PAD
        nm: Ptr[uint8] = ed_path_ptr(slot)
        if ED_PATH_LEN[slot] == 0:
            nm = "(untitled)"
        if str_ink(nm, hx, by0 + 4, x, y) != 0:
            r = 210
            g = 224
            b = 240
        if ED_DIRTY[slot] != 0:
            star: Ptr[uint8] = "*"
            sx: int64 = bx0 + DWIN_W[slot] - 4 - ED_PAD - GLYPH_W
            if str_ink(star, sx, by0 + 4, x, y) != 0:
                r = 240
                g = 200
                b = 120
        outr[0] = r
        outg[0] = g
        outb[0] = b
        return
    # Text area: walk the buffer mapping each byte to a (col,row) cell.
    tx0: int64 = bx0 + ED_PAD
    ty0: int64 = by0 + ED_HDR_H + 2
    if x < tx0 or y < ty0:
        outr[0] = r
        outg[0] = g
        outb[0] = b
        return
    buf: Ptr[uint8] = ed_buf_ptr(slot)
    n: uint64 = ED_LEN[slot]
    car: uint64 = ED_CARET[slot]
    col: int64 = 0
    rowpx: int64 = ty0
    bw: int64 = DWIN_W[slot] - 4 - ED_PAD * 2
    maxcols: int64 = bw / GLYPH_W
    if maxcols < 1:
        maxcols = 1
    i: uint64 = 0
    onechar: Array[2, uint8]
    onechar[1] = 0
    # Render until we have passed the pixel row `y` (early-out keeps the
    # per-pixel cost bounded by the visible line count).
    while i <= n:
        # Caret block: a solid bar at the caret's cell.
        if i == car:
            cgx: int64 = tx0 + col * GLYPH_W
            if x >= cgx and x < cgx + GLYPH_W \
               and y >= rowpx and y < rowpx + GLYPH_H:
                r = 120
                g = 200
                b = 255
        if i == n:
            i = n + 1                    # consumed the buffer
            break
        ch: uint8 = buf[i]
        if ch == 10:
            col = 0
            rowpx = rowpx + ED_LINE_H
            if rowpx > by0 + DWIN_H[slot]:
                i = n + 1
                break
        else:
            if ch >= 32 and ch < 127:
                onechar[0] = ch
                cgx2: int64 = tx0 + col * GLYPH_W
                if str_ink(&onechar[0], cgx2, rowpx, x, y) != 0:
                    # Don't overwrite the caret tint already chosen.
                    if i != car:
                        r = 222
                        g = 228
                        b = 236
                    else:
                        r = 20
                        g = 24
                        b = 30
            col = col + 1
            if col >= maxcols:
                col = 0
                rowpx = rowpx + ED_LINE_H
                if rowpx > by0 + DWIN_H[slot]:
                    i = n + 1
                    break
        i = i + 1
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Open a fresh editor window loaded with `path`'s contents (or empty when
# path is the NUL string). Used by the file manager's "open a text file".
def editor_open_path(path: Ptr[uint8], scr_w: int64, scr_h: int64):
    if DWIN_COUNT >= DMAX:
        return
    w: int64 = 560
    h: int64 = 400
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    step: int64 = (LAUNCH_CASCADE % 5) * 24
    rx: int64 = 120 + step
    ry: int64 = PANEL_H + 24 + step
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    daemon_spawn_app(APP_EDITOR, rx, ry, w, h)
    slot: uint64 = DWIN_COUNT - 1
    if path[0] != 0:
        ed_load_path(slot, path)
    pe: Ptr[uint8] = "ED open "
    sys_write(1, pe, strlen_u8(pe))
    if path[0] != 0:
        sys_write(1, path, strlen_u8(path))
    else:
        ut: Ptr[uint8] = "(untitled)"
        sys_write(1, ut, strlen_u8(ut))
    sys_write(1, "\n", 1)


# Dispatch a built-in app's body pixel to the right renderer.
def app_body_pixel(slot: uint64, x: int64, y: int64,
                   outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    a: int32 = DWIN_APP[slot]
    if a == APP_CALC:
        app_calc_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_SYSMON:
        app_sysmon_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_ABOUT:
        app_about_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_SETTINGS:
        app_settings_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_CTRLCENTER:
        app_ctrlcenter_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_FILEMGR:
        app_filemgr_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_EDITOR:
        app_editor_pixel(slot, x, y, outr, outg, outb)
    else:
        outr[0] = WIN_BODY_R
        outg[0] = WIN_BODY_G
        outb[0] = WIN_BODY_B


# ---- daemon window model -------------------------------------------
# Up to DMAX windows the daemon paints as chrome rectangles. We mirror
# the wsys cap (MAX_WINDOWS - 2 spawnable slots) but keep our own count.
DMAX: uint64 = 8
DWIN_X: Array[8, int64]
DWIN_Y: Array[8, int64]
DWIN_W: Array[8, int64]
DWIN_H: Array[8, int64]
DWIN_WID: Array[8, int32]
# ROUND-5: daemon-local stable window identity. Unlike DWIN_WID (the kernel
# wsys id, which is -1 for built-in app windows and when spawning fails),
# every window — terminal OR built-in app — gets a unique positive UID at
# creation. The MRU Alt-Tab list keys on this so focus history is tracked
# for ALL windows, not just real-process terminals.
DWIN_UID: Array[8, int32]
NEXT_UID: int32 = 1
DWIN_COUNT: uint64 = 0
# Minimize state: 1 = window is hidden to the taskbar, 0 = visible.
DWIN_HIDDEN: Array[8, int32]

# GPU track #183: per-window "Vulkan body" flag. 1 = this window's body
# is painted from the native-Vulkan-rendered image in vk_body_buf (read
# from the window's /dev/wsys/<wid>/draw/vk/fb draw-surface layer each
# frame) instead of the in-daemon terminal grid. Only one window carries
# the live vk body at a time in the self-test, but the model is general.
DWIN_VK: Array[8, int32]

# Markup-client flag: 1 = this window's body is painted from an external
# hamui client's "ui" markup layer (rasterised into markup_body_buf each
# frame) instead of an in-compositor procedural app or terminal grid.
DWIN_MARKUP: Array[8, int32]

# ---- MATE virtual workspaces (per-window) --------------------------
# Each window belongs to exactly one of WS_COUNT virtual desktops. Only
# windows whose DWIN_WS == CUR_WS are composited / hit-tested. The
# minimize bit is independent and still hides a window within its own
# workspace.
DWIN_WS: Array[8, int32]

# ---- MATE maximize / restore (per-window) --------------------------
# DWIN_MAXED == 1 means the window is maximized: its current geometry
# fills the work area (below the panel) and DWIN_SAVE_* holds the
# pre-maximize rectangle so Restore can put it back exactly.
DWIN_MAXED:  Array[8, int32]
DWIN_SAVE_X: Array[8, int64]
DWIN_SAVE_Y: Array[8, int64]
DWIN_SAVE_W: Array[8, int64]
DWIN_SAVE_H: Array[8, int64]

# ---- built-in DE application windows -------------------------------
# Beyond windows backed by a spawned child shell (DWIN_APP == APP_TERM),
# the daemon renders genuine built-in applications entirely in-process:
# their body is drawn by app-specific code and clicks/keys on the body
# route to app-specific handlers (no child process, no pipes). This makes
# the desktop useful out of the box like MATE's bundled utilities.
#   APP_TERM    — child shell + VT grid (the default)
#   APP_CALC    — pocket calculator (4x4 keypad + display, click+keyboard)
#   APP_SYSMON  — system monitor (reads /proc/uptime + /proc/meminfo)
#   APP_ABOUT   — static "About Hamnix" info card
APP_TERM:   int32 = 0
APP_CALC:   int32 = 1
APP_SYSMON: int32 = 2
APP_ABOUT:  int32 = 3
APP_SETTINGS: int32 = 4               # ROUND-4: theme/panel/background prefs
APP_CTRLCENTER: int32 = 5             # ROUND-16: categorised Control Center
APP_FILEMGR: int32 = 6                # icon-grid file manager (in-compositor)
APP_EDITOR:  int32 = 7                # Kate-like GUI text editor (in-compositor)
DWIN_APP: Array[8, int32]              # which app this window hosts

# Calculator state, tracked per-slot so multiple calculators each keep
# their own accumulator.
CALC_ACC:   Array[8, int64]           # running accumulator
CALC_CUR:   Array[8, int64]           # number currently being entered
CALC_OP:    Array[8, int32]           # pending op: 0 none,1 +,2 -,3 *,4 /
CALC_FRESH: Array[8, int32]           # 1 = next digit starts a new entry
CALC_ERR:   Array[8, int32]           # 1 = divide-by-zero / overflow flagged

# System-monitor scratch: re-read /proc each second so the figures stay
# live. Strings rendered straight into the body via str_ink.
sysmon_buf:   Array[1024, uint8]
sysmon_line1: Array[48, uint8]        # "Uptime: HH:MM:SS"
sysmon_line2: Array[48, uint8]        # "MemTotal: NNNN kB"
sysmon_line3: Array[48, uint8]        # "MemFree:  NNNN kB"
sysmon_line4: Array[48, uint8]        # "MemUsed:  NN%"
sysmon_last_cs: uint64 = 0

# ---- window snapping / edge tiling ---------------------------------
# Dragging a window's title bar to a screen edge snaps it (GNOME/MATE
# "edge tiling"): top edge -> maximize, left/right edge -> half-tile.
# The pre-snap geometry is stored in DWIN_SAVE_* (shared with the
# maximize feature) so a later restore returns the window to its float
# size. DWIN_SNAP: 0 float, 1 maximized, 2 left-half, 3 right-half.
DWIN_SNAP: Array[8, int32]
SNAP_EDGE: int64 = 8                  # px from an edge that triggers a snap

# ---- ROUND-9: window shading (roll-up) -----------------------------
# MATE/GNOME2 "shade" rolls a window up so only its title bar shows; a
# second shade unrolls it. DWIN_SHADED == 1 means the window is rolled
# up; DWIN_SHADE_H holds the full (un-shaded) height so unshade restores
# it exactly. While shaded the live DWIN_H is forced to the title-bar
# height so every existing draw / hit-test path naturally collapses to
# the bar without any special-casing in the compositor.
DWIN_SHADED:  Array[8, int32]
DWIN_SHADE_H: Array[8, int64]

# ---- ROUND-9: always-on-top (keep-above) ---------------------------
# DWIN_ONTOP == 1 pins the window above all normal windows regardless of
# raise/lower. The z-order is the array order, so enforce_ontop_order()
# bubbles every pinned window to the tail (front of the paint walk) after
# any raise and before each present. Pinned windows keep their relative
# order amongst themselves.
DWIN_ONTOP: Array[8, int32]

# ---- ROUND-24: keep-below (always-on-bottom) -----------------------
# DWIN_BELOW == 1 pins the window beneath all normal windows regardless of
# raise/lower (MATE/Marco's "Always on Bottom"). It is the inverse of
# DWIN_ONTOP: enforce_ontop_order() sinks every kept-below window to the
# HEAD of the slot array (back of the paint walk) so a normal raise can
# never tuck a window behind a kept-below peer. Kept-below windows keep
# their relative order amongst themselves. A window is either below, normal,
# or above — toggling one of the pins clears the opposite.
DWIN_BELOW: Array[8, int32]

# ---- ROUND-15: window urgency / demand-attention ------------------
# DWIN_URGENT == 1 marks a window whose taskbar button should pulse to
# draw the eye (MATE/GNOME2's "demands attention" / urgency hint). The
# pulse is driven by a free-running phase counter (URGENT_PHASE) that the
# main loop steps once per present; urgent_blink_on() returns 1 on the
# "lit" half of the cycle so the taskbar renderer can tint the button.
# Focusing/raising a window clears its urgency (the user has now seen it).
DWIN_URGENT: Array[8, int32]
URGENT_PHASE: int32 = 0
URGENT_PERIOD: int32 = 8          # phase ticks per full blink cycle

# ---- ROUND-19: per-window opacity (translucency) -------------------
# DWIN_OPACITY holds an 8-bit alpha (0..255) the compositor uses to blend
# each window's pixels over whatever is already painted behind it (the
# root or a lower window). 255 == fully opaque (the default, the original
# behaviour). MATE/Marco exposes per-window opacity via the window menu
# ("More/Less Transparent") and a keyboard binding; both drive
# window_opacity_step(). OPACITY_MIN keeps a window legible (never fully
# invisible) and OPACITY_STEP is the per-adjust delta.
DWIN_OPACITY: Array[8, int32]
OPACITY_MIN:  int32 = 64          # floor so a window never vanishes
OPACITY_STEP: int32 = 32          # per More/Less Transparent adjust

# ---- DEPERF #409: per-window backbuffer cache ----------------------
# The compositor is fully procedural: daemon_pixel() re-derives every
# window's surface (border + title bar + body glyphs/app paint) from
# model state for EVERY pixel it touches. A window that merely MOVED (a
# title-bar drag, a workspace shuffle) re-rasterises its identical
# content on every presented pixel even though nothing about its surface
# changed. To decouple "content changed" from "moved", each window keeps
# the last-rendered RGB of its own opaque surface in a cache buffer. A
# composite reads a cache-valid window straight from that buffer; only a
# CONTENT-dirty window (or one whose size changed) is re-rendered into
# its cache first via window_render_self(). A pure move reuses the cache
# verbatim — the surface is position-independent (rendered in window-
# LOCAL coordinates), so the same bytes simply land at the new offset.
#
# The cache is bounded: a slot caches a window only if its WxH fits the
# fixed WCACHE_W x WCACHE_H cap. Larger windows (e.g. a maximised window
# filling a big screen) fall back to the procedural path every frame —
# correct, just not accelerated. WCACHE_VALID[slot]==1 means the cache
# holds this window's current surface at WCACHE_UW/UH dimensions; any
# geometry/content change clears it. DWIN_CONTENT_DIRTY[slot]==1 means
# the window's SURFACE (not just its position) changed and the cache
# must be refilled before the next read.
WCACHE_W: int64 = 400             # max cacheable window width  (px)
WCACHE_H: int64 = 300             # max cacheable window height (px)
# Flat DMAX * WCACHE_W * WCACHE_H * 3 bytes = 8 * 400 * 300 * 3 = 2.88 MB.
WCACHE_RGB:   Array[2880000, uint8]
# DEPERF #410: full-screen SCENE cache (the composited scene WITHOUT the
# cursor sprite), RGBA8888 at the framebuffer's native pitch (FBG_W px per
# row, clamped to SCREEN_ROW_MAXW). The compositor evaluates daemon_pixel
# (the procedural scene graph) into THIS buffer ONLY for the damaged
# rectangle; the scanout present is then a plain memory BLIT of that rect
# (plus the cursor overlay) — no per-pixel scene-graph walk on the wire.
# A pure cursor move blits straight from SCENE_CACHE with ZERO daemon_pixel
# calls. Sized for 1920x1080x4 = 8,294,400 bytes (clamped to SCREEN_ROW_MAXW
# width like every other screen buffer here).
SCENE_CACHE:  Array[8294400, uint8]
SCENE_VALID:  int32 = 0            # 1 once a full scene build has run
SCENE_PITCH:  uint64 = 0          # px per SCENE_CACHE row (== clamped FBG_W)
WCACHE_VALID: Array[8, int32]     # 1 = WCACHE_RGB[slot] holds the surface
WCACHE_UW:    Array[8, int64]     # cached surface width  (== DWIN_W then)
WCACHE_UH:    Array[8, int64]     # cached surface height (== DWIN_H then)
# 1 = this window's SURFACE changed (output, focus chrome, app repaint,
# resize); the cache for it is stale and must be refilled before reuse.
# Initialised to 1 (lazily filled on first composite). A pure MOVE does
# NOT set this — the cached surface is still valid, only its offset moved.
DWIN_CONTENT_DIRTY: Array[8, int32]
# DEPERF #409 stats for the self-test: how many windows were re-rendered
# into their cache (content-dirty path) vs served straight from cache on
# the LAST window_cache_sync() pass. A pure move must yield rerendered==0.
WCACHE_LAST_RERENDERED: int64 = 0
WCACHE_LAST_REUSED:     int64 = 0

# ---- ROUND-19: desktop system-monitor applet -----------------------
# A small live CPU + memory bar-graph widget pinned to the top-right of
# the work area (on the root backdrop, like a MATE desktop applet / the
# panel's load-graph). It keeps a rolling history ring of CPU% and MEM%
# samples (one per second, pushed from the main loop's per-second tick)
# and plots them as a scrolling column graph. Clicking it opens the full
# System Monitor window. CPU% is derived from /dev/loadavg's 1-minute
# load (load*100, clamped to 100 on the uniprocessor); MEM% reuses the
# sysmon meminfo percentage.
DMON_HIST: int64 = 48             # samples in the ring (graph width)
dmon_cpu: Array[48, uint8]        # CPU% history (0..100)
dmon_mem: Array[48, uint8]        # MEM% history (0..100)
DMON_HEAD: int64 = 0              # next write index (ring)
DMON_FILLED: int64 = 0           # samples pushed so far (caps at DMON_HIST)
DMON_CPU_CUR: int64 = 0          # latest CPU% (for the numeric readout)
DMON_MEM_CUR: int64 = 0          # latest MEM%
DMON_W: int64 = 108              # widget width  (graph + frame)
DMON_H: int64 = 56               # widget height (two stacked graphs + label)
DMON_LAST_CS: uint64 = 0         # last push time (centiseconds)
dmon_rd_buf: Array[64, uint8]    # scratch for reading /dev/loadavg


# ---- ROUND-19: desktop icons (root-window launchers) ---------------
# Classic MATE/GNOME2 puts launcher icons on the desktop backdrop: a
# double-click opens the target, and an icon can be dragged to a new spot
# (snapping to a tidy grid). We ship a fixed set of built-in launchers.
# Each icon carries an APP_* (for in-process apps) or a -1 app with a
# Places directory / program intent encoded by DICON_KIND.
#   DICON_KIND: 0 = built-in app (DICON_APP), 1 = file-manager at a dir,
#               2 = terminal (fresh shell)
# DICON_X/Y are the icon cell's top-left on the root; the label sits below
# the glyph badge. Positions are grid-snapped on drop.
DICON_COUNT: int64 = 5
DICON_CELL_W: int64 = 76          # icon cell footprint (badge + label band)
DICON_CELL_H: int64 = 72
DICON_BADGE:  int64 = 40          # coloured badge square (the "icon")
DICON_GRID:   int64 = 8           # drop snaps to this pixel grid
DICON_X: Array[5, int64]
DICON_Y: Array[5, int64]
DICON_KIND: Array[5, int32]
DICON_APP:  Array[5, int32]
DICONS_INIT: int32 = 0
# Drag state: which icon (or -1) is being dragged + the grab offset.
DICON_DRAG: int64 = -1
DICON_OFF_X: int64 = 0
DICON_OFF_Y: int64 = 0
# Double-click-to-launch tracking (mirrors the title-bar dbl-click model).
DICON_LAST_FRAME: int64 = -1000
DICON_LAST_IDX:   int64 = -1

# ====================================================================
# ROUND-20 state: sticky windows, clipboard manager, window cascade,
# and quick two-pane tiling.
# ====================================================================

# ---- ROUND-20: sticky windows (Always on Visible Workspace) --------
# MATE/Marco's window menu has "Always on Visible Workspace": a sticky
# window shows on EVERY virtual desktop, not just the one it was opened
# on. DWIN_STICKY == 1 marks such a window. win_on_cur_ws() and the
# taskbar filter both treat a sticky window as belonging to whatever
# workspace is current, so switching desktops never hides it. The flag
# is mirrored across slot_copy / slot_swap like every other per-slot
# field so raise/close compaction preserves it.
DWIN_STICKY: Array[8, int32]

# ---- ROUND-20: clipboard / selection manager (Clipman) -------------
# MATE ships a clipboard-history applet (clipman): every text selection
# is remembered in a ring, the panel applet shows the most-recent entry,
# and the user can paste an older clipping. We model a fixed ring of
# CLIP_MAX entries, each up to CLIP_ENTRY_CAP-1 bytes + a NUL. CLIP_HEAD
# is the index of the MOST-RECENT entry; CLIP_COUNT is how many are live
# (caps at CLIP_MAX). clip_push() records a new clipping (de-duplicating
# an immediate repeat of the current head). CLIP_SEL is the entry the
# user has navigated to for pasting (0 == head/newest). The panel applet
# renders clip_current() truncated; the paste hotkey writes the selected
# entry into the focused window's stdin.
CLIP_MAX: int64 = 8
CLIP_ENTRY_CAP: int64 = 64
clip_ring: Array[512, uint8]        # CLIP_MAX * CLIP_ENTRY_CAP
CLIP_HEAD: int64 = 0                 # index of the newest entry
CLIP_COUNT: int64 = 0               # live entries (<= CLIP_MAX)
CLIP_SEL: int64 = 0                 # navigation offset from head (0 = newest)

# ---- ROUND-20: window cascade arrangement --------------------------
# Complements the existing grid windows_arrange() with MATE's classic
# "Cascade Windows": every visible window is set to a uniform size and
# staggered diagonally down-right from the work-area origin so each title
# bar stays clickable. CASCADE_STEP is the per-window diagonal offset.
CASCADE_STEP: int64 = 26

# ---- ROUND-20: quick two-pane tiling -------------------------------
# A single action that tiles the two most-recently-focused visible
# windows side-by-side (left half / right half), the way MATE users snap
# a pair with two Super+Left/Right presses — but in one keystroke. Reuses
# the existing snap_apply() left/right-half machinery so restore works.

# ====================================================================
# ROUND-21 state: smart window placement, window-to-window magnetic
# snapping (edge resistance), and keyboard move/resize mode (Marco's
# Alt-F7 "Move Window" / Alt-F8 "Resize Window").
# ====================================================================

# ---- ROUND-21: window-to-window magnetic snapping ------------------
# Marco/Mutter give a moving window "edge resistance": as its outer frame
# nears another visible window's edge (or a screen edge) the window snaps
# flush so adjacent windows sit pixel-perfect against each other. MAGNET
# is the capture distance in px; a candidate edge within MAGNET of the
# window's matching edge wins. The snap is applied to the live move-track
# position before it is committed to DWIN_X/Y, so the existing drag path
# and the WM move-done log both already see the snapped coordinates.
MAGNET: int64 = 10

# ---- ROUND-21: keyboard move/resize mode (Alt-F7 / Alt-F8) ---------
# MATE's Marco lets you move/resize the focused window from the keyboard:
# Alt-F7 enters Move mode, Alt-F8 enters Resize mode, the arrow keys then
# nudge the window, Enter commits and Escape cancels (restoring the pre-mode
# geometry). KMODE: 0 = off, 1 = move, 2 = resize. KMODE_SLOT is the window
# being driven; KMODE_SAVE_* holds the geometry captured on entry so a
# cancel restores it exactly. KSTEP is the per-arrow nudge in px.
KMODE: int32 = 0
KMODE_SLOT: int64 = -1
KMODE_SAVE_X: int64 = 0
KMODE_SAVE_Y: int64 = 0
KMODE_SAVE_W: int64 = 0
KMODE_SAVE_H: int64 = 0
KSTEP: int64 = 16
KWIN_MIN: int64 = 80                 # min window edge while keyboard-resizing

# ====================================================================
# ROUND-22 state: true fullscreen, drag edge-flip to adjacent workspace,
# and window tab-grouping (Mutter/Marco parity).
# ====================================================================

# ---- ROUND-22: true fullscreen (F11) -------------------------------
# Distinct from maximize: a fullscreen window covers the ENTIRE screen
# including the panel strip and drops its title bar so nothing chromes the
# content (presentations / video). DWIN_FULL == 1 marks such a window; the
# pre-fullscreen rectangle is parked in DWIN_FSAVE_* so the toggle restores
# it exactly. While fullscreen the live geometry is forced to (0,0)..
# (scr_w,scr_h) and title_h_of(slot) collapses to 0 so the body fills the
# frame and the compositor / hit-test paths need no special-casing. The
# fullscreen window is bubbled to the front (above even always-on-top) and
# the panel hides behind it.
DWIN_FULL:   Array[8, int32]
DWIN_FSAVE_X: Array[8, int64]
DWIN_FSAVE_Y: Array[8, int64]
DWIN_FSAVE_W: Array[8, int64]
DWIN_FSAVE_H: Array[8, int64]

# 2026-06-14 empty-windows DE bug fix: panel/overlay v2 clients
# (hampanel, hamtray, hamappmenu, hamcycler, hamcalpop, hamrun, hamlock,
# hamrband, hamnotif, hamsessui, hamdesktop, hamsysmon, hamctxmenu,
# hamsnap, hamresize, hamosd) ship their OWN visuals via the v2 blit
# protocol; they must NOT get the default decorated window chrome
# (title bar + border) that ate their entire panel-sized body height
# (panel = 22px tall, title bar = 18px → body was 2px high). When
# DWIN_CHROMELESS[slot]==1 the compositor returns title_h_of()==0,
# skips chrome paint, and places the v2 blit at (wx,wy) so the client
# backbuffer covers the whole window rect.
DWIN_CHROMELESS: Array[8, int32]


def mark_last_window_chromeless():
    # Helper: flip DWIN_CHROMELESS on for the most recently spawned
    # window. Called right after each pivot-wave spawn of a panel /
    # overlay v2 client so its hamui v2 backbuffer is blitted full-rect
    # without the decorated title bar swallowing the body.
    if DWIN_COUNT == 0:
        return
    slot: uint64 = DWIN_COUNT - 1
    DWIN_CHROMELESS[slot] = 1

# ---- ROUND-22: drag edge-flip to the adjacent workspace ------------
# Marco/Mutter "edge-flip": holding a window's title bar pinned hard
# against the extreme left/right screen margin for a short dwell flips to
# the adjacent virtual desktop and CARRIES the dragged window there, so you
# can shuffle a window across workspaces with one continuous drag. The flip
# band sits INSIDE the existing half-tile snap edge so the two gestures
# never collide: snapping triggers as the cursor nears the edge, the flip
# only triggers once the cursor is jammed in the final EFLIP_BAND pixels and
# has dwelt there EFLIP_DWELL frames. After a flip the dwell counter resets
# and the window keeps following the cursor on the new workspace.
EFLIP_BAND:  int64 = 3           # px from the very edge that arms a flip
EFLIP_DWELL: int32 = 8           # frames the cursor must dwell to flip
EFLIP_CTR:   int32 = 0           # consecutive frames cursor jammed at an edge
EFLIP_SIDE:  int32 = 0           # which edge is being held: -1 left, +1 right
EFLIP_COOLDOWN: int32 = 0        # frames to suppress re-flip after a flip

# ---- ROUND-22: window tab-grouping ---------------------------------
# Mutter/Marco let windows be grouped so they share one frame and a tab bar
# in the title selects which member shows (like browser tabs / tabbed window
# managers). DWIN_GROUP holds a stable non-zero group id (0 == ungrouped);
# every member of a group carries the same id. DWIN_GROUP_ACTIVE == 1 marks
# the single member of a group that is currently visible; win_on_cur_ws()
# hides any grouped window whose active flag is 0, so the whole compositor /
# taskbar / hit-test stack collapses a group to one window for free. Both
# fields travel with the slot in slot_copy / slot_swap, so the identity
# survives raise/close table compaction. group_tab_at() hit-tests the tab
# strip drawn across the title bar; clicking a tab activates that member.
DWIN_GROUP:        Array[8, int32]
DWIN_GROUP_ACTIVE: Array[8, int32]
NEXT_GROUP: int32 = 1            # next group id to hand out
GROUP_TAB_H: int64 = 14         # tab-strip band height inside the title bar

# Log Out (System menu): set to 1 to request a clean daemon shutdown so
# the console returns to the foreground shell.
DAEMON_QUIT: int32 = 0

# The native Vulkan window image is 192x192 RGBA8888 (matches lib's
# vk_window_demo VK_WIN_W/H). Module-scope flat buffer (Adder U9 quirk).
VK_BODY_W: int64 = 192
VK_BODY_H: int64 = 192
vk_body_buf: Array[147456, uint8]      # 192 * 192 * 4
vk_body_ready: int32 = 0               # 1 once vk_body_buf holds a frame

# ---- MARKUP-CLIENT window bodies -----------------------------------
# An EXTERNAL hamui client (a program built on lib/hamui.ad) paints its
# whole widget tree into the "ui" markup layer of its window's draw
# surface (/dev/wsys/<wid>/draw/ui/markup). Unlike the in-compositor
# procedural apps (APP_*), the daemon does NOT know how to draw such a
# window's body — it must RASTERISE the client's hamML and composite the
# result into the window body every frame. This is the OUTPUT half that
# makes lib/hamui.ad programs appear on screen as real windows.
#
# A window flagged DWIN_MARKUP[slot]==1 has its body sampled from
# markup_body_buf[slot] instead of app_body_pixel / the terminal grid.
# Each slot owns a body-sized RGBA8888 buffer; the client paints in its
# own logical surface coordinates (0,0 == window content top-left), so
# markup pixel (mx,my) maps to body screen pixel (body_x+mx, body_y+my).
# The buffer is capped at the WCACHE surface size (400x300) — bodies are
# strictly smaller than the window and windows cap at the cache size.
MB_W: int64 = 400                      # max markup-body width  (== WCACHE_W)
MB_H: int64 = 300                      # max markup-body height (== WCACHE_H)
# Flat per-slot RGBA: DMAX * MB_W * MB_H * 4 = 8 * 400 * 300 * 4 = 3.84 MB.
markup_body_buf:   Array[3840000, uint8]
markup_body_ready: Array[8, int32]     # 1 = slot buffer holds a frame
markup_body_bw:    Array[8, int64]     # actual rasterised body width  (px)
markup_body_bh:    Array[8, int64]     # actual rasterised body height (px)

# ---- live clock state ---------------------------------------------
# Updated once per second from /proc/realtime (wall clock) or
# /proc/uptime (monotonic fallback). The string is HH:MM (5 chars)
# or UUU:MM (uptime hours:minutes). Always NUL-terminated.
clock_str: Array[12, uint8]
clock_last_cs: uint64 = 0        # centiseconds at last clock refresh
# Full date string for the clock-applet hover tooltip ("YYYY-MM-DD HH:MM:SS"
# from /proc/realtime, or "Uptime H:MM:SS" fallback). NUL-terminated.
clock_date_str: Array[32, uint8]
CLOCK_HOVER: int32 = 0           # 1 while the cursor is over the clock zone

# ---- per-window terminal (in-daemon emulator) ----------------------
# Each window dragged out runs an interactive hamsh whose stdin/stdout
# are kernel pipes. The daemon owns the PARENT ends:
#   DWIN_IN_FD  — write end of the child's stdin pipe (keystrokes -> shell)
#   DWIN_OUT_FD — read  end of the child's stdout pipe (shell -> grid)
# and emulates a tiny VT into a per-window character GRID rendered into
# the window body by daemon_pixel. The grid is a flat DMAX*GRID_CELLS
# byte array; each cell holds one printable ASCII byte (0 == blank).
DWIN_IN_FD:  Array[8, int32]
DWIN_OUT_FD: Array[8, int32]
DWIN_PID:    Array[8, int32]
# Per-window WRITE fds to the kernel's structured input-event surface
# (/dev/wsys/<wid>/pointer and /dev/wsys/<wid>/keys). The compositor is
# the SOLE writer: it has already done pointer hit-test / focus routing,
# so it emits already-routed, window-space event lines here and the
# kernel buffers + wakes the blocked client reader. -1 = not yet opened;
# -2 = open attempted and failed (don't retry every event). Opened lazily
# the first time an event is routed to a window that owns a real wsys wid
# (>= 2); built-in app windows (wid -1) have no wsys backing and stay -1.
DWIN_PTR_FD:  Array[8, int32]
DWIN_KEYS_FD: Array[8, int32]
DWIN_COLS:   Array[8, int64]      # body_w / GLYPH_W
DWIN_ROWS:   Array[8, int64]      # body_h / GLYPH_H
DWIN_CUR_C:  Array[8, int64]      # cursor column
DWIN_CUR_R:  Array[8, int64]      # cursor row
# VT parser state per window: 0 = ground, 1 = saw ESC, 2 = in CSI.
DWIN_VT:     Array[8, int32]
# CSI numeric parameter accumulator (per window) for the cursor-positioning
# escape sequences term_feed now honours. DWIN_VT_P0 is the first parameter
# (e.g. ESC[<n>C), DWIN_VT_P1 the second (ESC[<row>;<col>H), DWIN_VT_PI the
# index of the parameter currently being accumulated (0 or 1), and
# DWIN_VT_SAW is 1 once any digit has been seen (a missing parameter then
# defaults to 1, the ANSI default, instead of 0).
DWIN_VT_P0:  Array[8, int64]
DWIN_VT_P1:  Array[8, int64]
DWIN_VT_PI:  Array[8, int32]
DWIN_VT_SAW: Array[8, int32]

GLYPH_W: int64 = 8
GLYPH_H: int64 = 16
# Grid cap per window: 128 cols * 64 rows. 8192 cells * 8 windows = 64 KiB.
GRID_COLS_MAX: int64 = 128
GRID_ROWS_MAX: int64 = 64
GRID_CELLS:    uint64 = 8192      # GRID_COLS_MAX * GRID_ROWS_MAX
term_grid: Array[65536, uint8]    # DMAX * GRID_CELLS

# Small scratch buffer for draining a child's stdout pipe each frame.
term_rx: Array[1024, uint8]
# Small scratch buffer for draining /dev/cons keystrokes each frame.
cons_rx: Array[256, uint8]
cons_fd: int32 = -1

# ---- cursor + drag state -------------------------------------------
CUR_X: int64 = 0
CUR_Y: int64 = 0
# P1a dirty-rect present state: the cursor position last painted to the
# framebuffer (so the cheap cursor-move fast path knows which 12x12 cell
# to erase), and a flag the main loop sets when something OTHER than the
# cursor changed and a full recomposite is required.
LAST_CUR_X: int64 = 0
LAST_CUR_Y: int64 = 0
DAMAGE_PENDING: int32 = 0
# EVLOOP: markup-client body reads are GEN-GATED, not frame-throttled.
# The kernel exports /dev/wsys/<N>/draw/<layer>/gen — a read-only per-layer
# content generation counter bumped +1 per successful markup/fb write
# (reading it never consumes the body). markup_sync() re-reads a window's
# body ONLY when its ui-layer gen differs from the last gen we rasterized
# (cached in evl_gen[]), when the client was newly detected, or when the
# cached body was invalidated (markup_body_ready==0). MARKUP_DUE stays as
# a one-shot "force re-read everything" latch (first present, workspace
# switch, theme recolour) — there is NO periodic every-N-frames re-read
# any more.
MARKUP_DUE:        int32 = 1     # force a body re-read on the first present
# evl_gen[wi]: ui-layer gen at the time of the slot's last successful body
# rasterize; -1 = never read / unknown (forces a read when gen is exposed).
evl_gen: Array[8, int64]         # DMAX slots
# Event-loop wait state: fds the daemon parks on in sys_waitfds.
evl_wait_fds: Array[64, int32]   # _VFS_NR_FDS cap
# Adaptive wait timeouts (ms): fast while a cycle overlay counts idle
# frames, anim while any time-based animation is live (notify fade, OSD
# TTL, urgent blink, drag, keyboard mode), idle otherwise (clock tick +
# sysmon refresh only need ~1s granularity; 250ms keeps them snappy).
EVL_TIMEOUT_FAST_MS: int64 = 10
EVL_TIMEOUT_ANIM_MS: int64 = 30
EVL_TIMEOUT_IDLE_MS: int64 = 250
EVL_LAST_HK_JIFFY: uint64 = 0    # once-per-second housekeeping gate
EVL_PREV_WINS: uint64 = 0        # window-count delta tracking across frames
EVL_NOTIFY_LAST_ALPHA: int64 = -1  # last painted notify alpha (-1 = none)
EVL_URGENT_LAST_ON: int32 = -1   # last painted urgent-blink phase
# Observable event-loop counters (read by the evloop selftest; also handy
# for ad-hoc perf triage). PRESENTS counts daemon_flush_damage presents,
# BODY_READS counts successful markup body rasterizes, WAITS counts parks.
EVL_STAT_WAITS: uint64 = 0
EVL_STAT_PRESENTS: uint64 = 0
EVL_STAT_BODY_READS: uint64 = 0
# ---- DEPERF: per-frame dirty-rectangle accumulator -----------------
# The main loop used to force a FULL-SCREEN recomposite (daemon_present,
# O(W*H*windows)) on nearly every event — a single shell line, a hover
# highlight, the once-a-second clock — which is why the desktop ran at
# ~1 fps and got worse with every window opened. Instead we now ACCUMULATE
# the union of the screen rectangles that actually changed this frame and
# present only that union via daemon_present_rect (area-scaled, O(area *
# windows)). A genuine whole-screen change (workspace switch, wallpaper /
# theme recolour, panel slide) still escalates to a full present by
# unioning the whole screen — see damage_full().
#
# DMG_VALID==0 means "no damage this frame". The union is the inclusive-
# exclusive box [DMG_X0,DMG_X1) x [DMG_Y0,DMG_Y1). DMG_FULL marks an
# explicit whole-screen escalation so the present path can pick the cheap
# full-screen writer (one contiguous write) over a row-seeked partial.
DMG_VALID: int32 = 0
DMG_FULL:  int32 = 0
DMG_X0: int64 = 0
DMG_Y0: int64 = 0
DMG_X1: int64 = 0
DMG_Y1: int64 = 0
# Stats for the deterministic DEPERF self-test: pixels covered by the LAST
# present (rect area, or W*H for a full present) and whether it was full.
DMG_LAST_AREA: int64 = 0
DMG_LAST_FULL: int32 = 0
# BUG 2 instrumentation: counts how many window-body evaluations daemon_pixel
# performed since DPIX_WIN_VISITS was last reset. With the occlusion skip, a
# pixel covered by an opaque top window evaluates only the visible top
# window(s), NOT every window in the stack — so this stays bounded by the
# number of windows ABOVE-and-including the topmost opaque coverer, not the
# total window count. The usability self-test resets it, presents a single
# pixel under a stack, and asserts the visit count does not grow with the
# number of fully-occluded windows beneath the top one.
DPIX_WIN_VISITS: int64 = 0
DRAG_ACTIVE: int32 = 0
DRAG_X0: int64 = 0
DRAG_Y0: int64 = 0
PREV_BTN_L: int32 = 0                     # previous-iteration left button
PREV_BTN_R: int32 = 0                     # previous-iteration right button

# ---- window-management gesture state -------------------------------
# A left-button-press is classified at the down-edge into one of these
# gestures, tracked by GESTURE:
#   0 = create  (press landed on empty desktop) — rubber-band + spawn
#   1 = move    (press landed on a window title bar) — relocate window
#   2 = close   (press landed on a window's close box) — destroy on up
#   3 = inert   (panel/body/menu press — no up-edge action)
#   4 = resize  (ROUND-6: press landed on a window border edge/corner)
GESTURE: int32 = 0
# For move: which window slot is being dragged + the cursor-to-window
# offset captured at the down-edge so the window tracks under the grab.
MOVE_SLOT: int64 = -1
MOVE_OFF_X: int64 = 0
MOVE_OFF_Y: int64 = 0
# For close: the slot the press landed on (the release must land on the
# SAME slot's close box to actually destroy it — rio-style).
CLOSE_SLOT: int64 = -1
# Close-box geometry: a square at the right end of the title bar.
CLOSE_BOX: int64 = 14                      # close-box side length (px)

# ---- ROUND-6: interactive window resize by dragging edges/corners --
# MATE/GNOME2 lets you grab any window EDGE or CORNER to resize. We add an
# 8-direction resize grip band around each window's outer frame. A press on
# the band starts GESTURE==4; while held, the grabbed edge(s) track the
# cursor (corners move two edges at once) down to a minimum body size; the
# opposite edge stays anchored so the window grows/shrinks the way the
# pointer pulls. The active resize draws a bright accent frame (like the
# snap preview) so the operation reads clearly without a real cursor theme.
#
# RESIZE_DIR encodes which handle was grabbed as a 4-bit mask:
#   bit0 (1) = left edge    bit1 (2) = right edge
#   bit2 (4) = top edge     bit3 (8) = bottom edge
# Corners set two bits (e.g. top-left = 1|4 = 5). 0 = no resize.
RESIZE_GRIP: int64 = 6                 # px-wide grab band around the frame
RESIZE_MIN_W: int64 = 96               # smallest window width  (px)
RESIZE_MIN_H: int64 = 64               # smallest window height (px)
RESIZE_SLOT: int64 = -1                # slot being resized, or -1
RESIZE_DIR:  int32 = 0                 # grabbed-edge mask (see above)
# Anchored opposite-edge coordinates captured at the down-edge so the held
# edges track the cursor while the far edges stay put.
RESIZE_FIX_X: int64 = 0                # anchored x (right when dragging left)
RESIZE_FIX_Y: int64 = 0                # anchored y (bottom when dragging top)
RESIZE_FIX_R: int64 = 0                # anchored right  x
RESIZE_FIX_B: int64 = 0                # anchored bottom y
# RESIZE_HOVER mirrors RESIZE_DIR for the cursor that is merely HOVERING a
# grip (no button down) so the compositor can hint the grip is live.
RESIZE_HOVER: int32 = 0

# Double-click-titlebar-to-maximize tracking. WM_FRAME is a monotonic
# frame counter the daemon main loop bumps each iteration. A title-bar
# press records its frame + slot; a second press on the SAME slot within
# DBLCLICK_FRAMES is a double-click and toggles maximize (MATE default).
WM_FRAME: int64 = 0
LAST_TCLICK_FRAME: int64 = -1000
LAST_TCLICK_SLOT:  int64 = -1
DBLCLICK_FRAMES:   int64 = 30          # ~double-click window in frames

# DE-perf FPS gate. When the file /etc/de-fps-test exists at daemon
# startup, FPS_GATE flips to 1 and every daemon_present() emits a
# "[fps] frame N" line to fd 1 (which the supervisor routes to serial).
# scripts/test_de_fps.sh greps the serial log for those lines and counts
# them over a known wall-clock window. Default 0 = no-op in normal boot.
FPS_GATE: int32 = 0
FPS_FRAME: int64 = 0
fps_line_buf: Array[64, uint8]

# Small mouse read buffer ("<dx> <dy> <buttons>\n" lines).
mouse_buf: Array[256, uint8]
# Scratch buffer for taskbar button number label (single digit + NUL).
taskbar_lbl_buf: Array[8, uint8]
# Scratch buffer for taskbar click serial output (digit + newline).
taskbar_click_buf: Array[4, uint8]


def iclamp(v: int64, lo: int64, hi: int64) -> int64:
    if v < lo:
        return lo
    if v > hi:
        return hi
    return v


def imin(a: int64, b: int64) -> int64:
    if a < b:
        return a
    return b


def imax(a: int64, b: int64) -> int64:
    if a > b:
        return a
    return b


# Subtract `d` from a uint8 channel, clamping at 0 (used for shadows).
def sub_clamp_u8(v: uint8, d: int64) -> uint8:
    iv: int64 = cast[int64](v) - d
    if iv < 0:
        iv = 0
    return cast[uint8](iv)


# Add `d` to a uint8 channel, clamping at 255 (hover/highlight tints).
def add_clamp_u8(v: uint8, d: int64) -> uint8:
    iv: int64 = cast[int64](v) + d
    if iv > 255:
        iv = 255
    return cast[uint8](iv)


# ---- taskbar hit-testing -------------------------------------------
# The taskbar zone begins just right of the GNOME2 menu bar
# (Applications/Places/System), whose total width is dynamic. The old
# fixed TASKBAR_START_X (sized for a single Applications button) would
# overlap the wider menu bar, so derive the start from menubar_end_x().
def taskbar_start_x() -> int64:
    s: int64 = menubar_end_x() + 4
    if s < TASKBAR_START_X:
        s = TASKBAR_START_X
    return s


# Left x-coordinate of the taskbar button for window `slot`.
# Buttons are laid out left-to-right starting at taskbar_start_x(),
# one per slot regardless of minimized state (all windows appear).
def taskbar_btn_x(slot: uint64) -> int64:
    return taskbar_start_x() + cast[int64](slot) * TASKBAR_BTN_W


# 1 if (px,py) is inside the taskbar button for window `slot`, else 0.
# Taskbar buttons live within the panel height.
def in_taskbar_btn(slot: uint64, px: int64, py: int64) -> int32:
    ly: int64 = panel_local_y(py)
    if ly < TASKBAR_BTN_Y or ly >= TASKBAR_BTN_Y + TASKBAR_BTN_H:
        return 0
    bx: int64 = taskbar_btn_x(slot)
    if px >= bx and px < bx + TASKBAR_BTN_W - 2:
        return 1
    return 0


# Return the taskbar slot (0..DWIN_COUNT-1) under (px,py), or -1.
# Clocks and the Applications button are excluded by TASKBAR_START_X.
def taskbar_slot_at(px: int64, py: int64, scr_w: int64) -> int64:
    if on_panel_y(py) == 0:
        return -1
    # Exclude clock area on the right.
    clock_x: int64 = scr_w - CLOCK_W
    if px >= clock_x:
        return -1
    if px < taskbar_start_x():
        return -1
    # ROUND-10: only group leaders own a taskbar button (grouped members
    # are folded behind their leader), so a hit on a non-leader slot's
    # nominal rect is ignored — only the painted leader buttons hit.
    i: uint64 = 0
    while i < DWIN_COUNT:
        if in_taskbar_btn(i, px, py) != 0 and is_group_leader(i) != 0 \
           and taskbar_lists_slot(i) != 0:
            return cast[int64](i)
        i = i + 1
    return -1


# ---- ROUND-7: clock-applet click zone + calendar toggle ------------
# 1 if (px,py) lands on the right-edge clock zone of the panel.
def in_clock_zone(px: int64, py: int64, scr_w: int64) -> int32:
    if on_panel_y(py) == 0:
        return 0
    clock_x: int64 = scr_w - CLOCK_W
    if px >= clock_x and px < scr_w:
        return 1
    return 0


# Left x of the dropped calendar popup, right-aligned under the clock and
# clamped on-screen.
def cal_drop_x(scr_w: int64) -> int64:
    cx: int64 = scr_w - CAL_W - 2
    if cx < 0:
        cx = 0
    return cx


# Top y of the calendar popup (drops off the panel edge, away from it).
def cal_drop_y() -> int64:
    return drop_anchor_y(cal_total_h())


# Toggle the calendar popup. Refreshes the highlighted day from the live
# clock state first so a freshly-opened calendar shows today.
def cal_toggle():
    if CAL_OPEN != 0:
        CAL_OPEN = 0
        cc: Ptr[uint8] = "CAL close\n"
        sys_write(1, cc, strlen_u8(cc))
    else:
        CAL_OPEN = 1
        # Close other panel drop-downs so chrome never overlaps.
        MENU_BAR_OPEN = -1
        MENU_OPEN = 0
        co: Ptr[uint8] = "CAL open "
        sys_write(1, co, strlen_u8(co))
        write_str(1, cal_month_name(CAL_MONTH))
        write_str(1, "\n")
    # DE pivot wave 4: republish + wake /bin/hamcalpop on every toggle.
    calpop_publish_snapshot()
    calpop_poke_show()


# ---- minimize-box hit-testing --------------------------------------
# The minimize box is a square just to the LEFT of the close box in
# the title bar. Returns its top-left x.
def minimize_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX - 2 - MINIMIZE_BOX


def minimize_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside the minimize box for window `slot`, else 0.
def in_minimize_box(slot: uint64, px: int64, py: int64) -> int32:
    if title_h_of(slot) == 0:               # ROUND-22: fullscreen has no chrome
        return 0
    mx: int64 = minimize_box_x(slot)
    my: int64 = minimize_box_y(slot)
    if px >= mx and px < mx + MINIMIZE_BOX and py >= my and py < my + MINIMIZE_BOX:
        return 1
    return 0


# ---- ROUND-7 calendar helpers --------------------------------------
# Parse two ASCII digit bytes into an int (e.g. '0','7' -> 7).
def digits2(a: uint8, b: uint8) -> int64:
    hi: int64 = 0
    if a >= 48 and a <= 57:
        hi = cast[int64](a) - 48
    lo: int64 = 0
    if b >= 48 and b <= 57:
        lo = cast[int64](b) - 48
    return hi * 10 + lo


# Parse four ASCII digit bytes into a year.
def digits4(a: uint8, b: uint8, c: uint8, d: uint8) -> int64:
    return digits2(a, b) * 100 + digits2(c, d)


# 1 if `y` is a leap year (Gregorian).
def is_leap(y: int64) -> int32:
    if y % 400 == 0:
        return 1
    if y % 100 == 0:
        return 0
    if y % 4 == 0:
        return 1
    return 0


# Number of days in month `m` (1..12) of year `y`.
def days_in_month(y: int64, m: int64) -> int64:
    if m == 2:
        if is_leap(y) != 0:
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    return 31


# Day-of-week (0=Sunday .. 6=Saturday) of the 1st of month `m`, year `y`,
# via a Sakamoto-style computation specialised to day-of-month 1.
def dow_first(y: int64, m: int64) -> int64:
    t0: int64 = 0
    if m == 1:
        t0 = 0
    elif m == 2:
        t0 = 3
    elif m == 3:
        t0 = 2
    elif m == 4:
        t0 = 5
    elif m == 5:
        t0 = 0
    elif m == 6:
        t0 = 3
    elif m == 7:
        t0 = 5
    elif m == 8:
        t0 = 1
    elif m == 9:
        t0 = 4
    elif m == 10:
        t0 = 6
    elif m == 11:
        t0 = 2
    else:
        t0 = 4
    yy: int64 = y
    if m < 3:
        yy = yy - 1
    w: int64 = (yy + yy / 4 - yy / 100 + yy / 400 + t0 + 1) % 7
    if w < 0:
        w = w + 7
    return w


# Three-letter month name for the calendar header.
def cal_month_name(m: int64) -> Ptr[uint8]:
    if m == 1:
        s: Ptr[uint8] = "January"
        return s
    if m == 2:
        s2: Ptr[uint8] = "February"
        return s2
    if m == 3:
        s3: Ptr[uint8] = "March"
        return s3
    if m == 4:
        s4: Ptr[uint8] = "April"
        return s4
    if m == 5:
        s5: Ptr[uint8] = "May"
        return s5
    if m == 6:
        s6: Ptr[uint8] = "June"
        return s6
    if m == 7:
        s7: Ptr[uint8] = "July"
        return s7
    if m == 8:
        s8: Ptr[uint8] = "August"
        return s8
    if m == 9:
        s9: Ptr[uint8] = "September"
        return s9
    if m == 10:
        s10: Ptr[uint8] = "October"
        return s10
    if m == 11:
        s11: Ptr[uint8] = "November"
        return s11
    s12: Ptr[uint8] = "December"
    return s12


# Single-letter day-of-week initials, column 0..6 = Sun..Sat.
def cal_dow_initial(col: int64) -> Ptr[uint8]:
    if col == 0:
        c0: Ptr[uint8] = "S"
        return c0
    if col == 1:
        c1: Ptr[uint8] = "M"
        return c1
    if col == 2:
        c2: Ptr[uint8] = "T"
        return c2
    if col == 3:
        c3: Ptr[uint8] = "W"
        return c3
    if col == 4:
        c4: Ptr[uint8] = "T"
        return c4
    if col == 5:
        c5: Ptr[uint8] = "F"
        return c5
    c6: Ptr[uint8] = "S"
    return c6


# Number of week-rows the current month needs (cells / 7, rounded up).
def cal_rows() -> int64:
    if CAL_MONTH < 1 or CAL_MONTH > 12:
        return 6
    lead: int64 = dow_first(CAL_YEAR, CAL_MONTH)
    total: int64 = lead + days_in_month(CAL_YEAR, CAL_MONTH)
    rows: int64 = (total + 6) / 7
    if rows < 4:
        rows = 4
    if rows > 6:
        rows = 6
    return rows


# Total pixel height of the calendar popup (header + dow row + day grid).
def cal_total_h() -> int64:
    return CAL_HEAD_H + CAL_DOW_H + cal_rows() * CAL_CELL_H + 4


# Day-of-month at calendar grid (row,col), or 0 if the cell is blank
# (leading/trailing pad outside the month).
def cal_day_at(row: int64, col: int64) -> int64:
    lead: int64 = dow_first(CAL_YEAR, CAL_MONTH)
    cell: int64 = row * 7 + col
    d: int64 = cell - lead + 1
    if d < 1 or d > days_in_month(CAL_YEAR, CAL_MONTH):
        return 0
    return d


# ---- live clock refresh --------------------------------------------
# Read /proc/realtime; extract HH:MM from the ISO-8601 timestamp.
# Fall back to /proc/uptime (uptime as H:MM) if realtime unavailable.
# Updates clock_str[] and clock_last_cs. Call once per second.
clock_read_buf: Array[64, uint8]

def clock_refresh(cur_cs: uint64):
    # Only refresh once per 100 centiseconds (1 second).
    if cur_cs < clock_last_cs + 100 and clock_last_cs != 0:
        return
    clock_last_cs = cur_cs
    # Try /proc/realtime first: line 1 is "YYYY-MM-DDTHH:MM:SSZ epoch\n"
    # HH is at offset 11, MM at 14 (after the 'T' at 10).
    rt_path: Ptr[char] = "/proc/realtime"
    rfd: int32 = sys_open(rt_path)
    if rfd >= 0:
        n: int64 = sys_read(rfd, &clock_read_buf[0], 64)
        sys_close(rfd)
        nu: uint64 = cast[uint64](n)
        # Check it's a real timestamp (starts with digit, not 'u' for unavailable)
        if nu >= 20 and clock_read_buf[0] != 117 and clock_read_buf[10] == 84:
            # offset 11: HH, offset 12: ':', offset 14: MM
            clock_str[0] = clock_read_buf[11]
            clock_str[1] = clock_read_buf[12]
            clock_str[2] = 58     # ':'
            clock_str[3] = clock_read_buf[14]
            clock_str[4] = clock_read_buf[15]
            clock_str[5] = 0
            # Tooltip date: "YYYY-MM-DD HH:MM:SS" (offsets 0..9 + space + 11..18).
            di: uint64 = 0
            while di < 10:
                clock_date_str[di] = clock_read_buf[di]
                di = di + 1
            clock_date_str[10] = 32       # space
            dj: uint64 = 0
            while dj < 8:
                clock_date_str[11 + dj] = clock_read_buf[11 + dj]
                dj = dj + 1
            clock_date_str[19] = 0
            # ROUND-7: also parse Y-M-D for the calendar popup. Offsets:
            # YYYY @0..3, MM @5..6, DD @8..9.
            CAL_YEAR = digits4(clock_read_buf[0], clock_read_buf[1],
                               clock_read_buf[2], clock_read_buf[3])
            CAL_MONTH = digits2(clock_read_buf[5], clock_read_buf[6])
            CAL_DAY = digits2(clock_read_buf[8], clock_read_buf[9])
            CAL_VALID = 1
            # DE pivot wave 4: refresh the published calpop model so
            # /bin/hamcalpop sees the new Y/M/D. Cheap (one /dev/wsys/ctl
            # write); only fires once a second.
            calpop_publish_snapshot()
            return
    # Fallback: /proc/uptime gives centiseconds. Convert to H:MM.
    up_path: Ptr[char] = "/proc/uptime"
    ufd: int32 = sys_open(up_path)
    if ufd >= 0:
        n2: int64 = sys_read(ufd, &clock_read_buf[0], 64)
        sys_close(ufd)
        cs_up: uint64 = 0
        k: uint64 = 0
        nu2: uint64 = cast[uint64](n2)
        while k < nu2 and clock_read_buf[k] >= 48 and clock_read_buf[k] <= 57:
            cs_up = cs_up * 10 + cast[uint64](clock_read_buf[k] - 48)
            k = k + 1
        secs: uint64 = cs_up / 100
        mins: uint64 = (secs / 60) % 60
        hrs:  uint64 = secs / 3600
        # Format H:MM (hours may be more than 2 digits for long uptimes).
        # Cap display to 3 digits of hours so the clock fits the panel.
        idx: uint64 = 0
        if hrs >= 100:
            clock_str[idx] = cast[uint8](hrs / 100) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8]((hrs / 10) % 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        elif hrs >= 10:
            clock_str[idx] = cast[uint8](hrs / 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        else:
            clock_str[idx] = cast[uint8](hrs) + 48
            idx = idx + 1
        clock_str[idx] = 58    # ':'
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins / 10) + 48
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins % 10) + 48
        idx = idx + 1
        clock_str[idx] = 0
        # Tooltip date: "Uptime HH:MM:SS".
        up_secs: uint64 = secs % 60
        up_pfx: Ptr[uint8] = "Uptime "
        dp: uint64 = 0
        while up_pfx[dp] != 0:
            clock_date_str[dp] = up_pfx[dp]
            dp = dp + 1
        dh: uint64 = hrs % 100
        clock_date_str[dp] = cast[uint8](dh / 10) + 48
        clock_date_str[dp + 1] = cast[uint8](dh % 10) + 48
        clock_date_str[dp + 2] = 58
        clock_date_str[dp + 3] = cast[uint8](mins / 10) + 48
        clock_date_str[dp + 4] = cast[uint8](mins % 10) + 48
        clock_date_str[dp + 5] = 58
        clock_date_str[dp + 6] = cast[uint8](up_secs / 10) + 48
        clock_date_str[dp + 7] = cast[uint8](up_secs % 10) + 48
        clock_date_str[dp + 8] = 0
        return
    # If both fail, show "??:??".
    clock_str[0] = 63    # '?'
    clock_str[1] = 63
    clock_str[2] = 58    # ':'
    clock_str[3] = 63
    clock_str[4] = 63
    clock_str[5] = 0
    clock_date_str[0] = 63
    clock_date_str[1] = 0


# ---- window-management hit-testing ---------------------------------
# The close box is a CLOSE_BOX-square inset 2px from the title bar's
# top-right corner. Returns its top-left (cx,cy) for window `slot`.
def close_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX


def close_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside window slot's close box, else 0.
def in_close_box(slot: uint64, px: int64, py: int64) -> int32:
    if title_h_of(slot) == 0:               # ROUND-22: fullscreen has no chrome
        return 0
    cx: int64 = close_box_x(slot)
    cy: int64 = close_box_y(slot)
    if px >= cx and px < cx + CLOSE_BOX and py >= cy and py < cy + CLOSE_BOX:
        return 1
    return 0


# 1 if (px,py) is on window slot's title bar (the band below the top
# border, above the body) — EXCLUDING the close box and minimize box.
# Used to start a move-drag.
def in_title_bar(slot: uint64, px: int64, py: int64) -> int32:
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    ww: int64 = DWIN_W[slot]
    if px < wx + 2 or px >= wx + ww - 2:
        return 0
    if title_h_of(slot) == 0:               # ROUND-22: fullscreen has no title
        return 0
    if py < wy + 2 or py >= wy + TITLE_H:
        return 0
    if in_close_box(slot, px, py) != 0:
        return 0
    if in_minimize_box(slot, px, py) != 0:
        return 0
    if in_maximize_box(slot, px, py) != 0:
        return 0
    return 1


# ---- ROUND-6: resize-grip hit-testing ------------------------------
# Return the resize-direction mask for window `slot` at (px,py): which
# edge(s)/corner the cursor is over within the RESIZE_GRIP band around the
# outer frame. 0 = not on a grip. The grip extends RESIZE_GRIP px INWARD
# from each frame edge and a couple px OUTWARD so the thin border is easy
# to grab. The TOP edge grip is suppressed across the title-bar buttons so
# resizing never fights the close/min/max boxes.
def resize_dir_at(slot: uint64, px: int64, py: int64) -> int32:
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    ww: int64 = DWIN_W[slot]
    wh: int64 = DWIN_H[slot]
    # Reject points well outside the (slightly grown) frame.
    if px < wx - 2 or px >= wx + ww + 2:
        return 0
    if py < wy - 2 or py >= wy + wh + 2:
        return 0
    near_left:  int32 = 0
    near_right: int32 = 0
    near_top:   int32 = 0
    near_bot:   int32 = 0
    if px <= wx + RESIZE_GRIP:
        near_left = 1
    if px >= wx + ww - 1 - RESIZE_GRIP:
        near_right = 1
    if py <= wy + RESIZE_GRIP:
        near_top = 1
    if py >= wy + wh - 1 - RESIZE_GRIP:
        near_bot = 1
    # The top grip overlaps the title-bar buttons; don't let it shadow them.
    if near_top != 0:
        if in_close_box(slot, px, py) != 0 or in_minimize_box(slot, px, py) != 0 \
           or in_maximize_box(slot, px, py) != 0:
            near_top = 0
    mask: int32 = 0
    if near_left != 0:
        mask = mask | 1
    if near_right != 0:
        mask = mask | 2
    if near_top != 0:
        mask = mask | 4
    if near_bot != 0:
        mask = mask | 8
    # A grip is only meaningful on an actual edge. A point deep in the body
    # (no edge near) returns 0 so body clicks still focus/route normally.
    return mask


# 1 if (px,py) is on a resize grip of window `slot` (any edge/corner).
def in_resize_grip(slot: uint64, px: int64, py: int64) -> int32:
    if resize_dir_at(slot, px, py) != 0:
        return 1
    return 0


# Begin an interactive resize of `slot` with grabbed-edge mask `dir`.
# Captures the anchored (opposite) edges so live tracking keeps them fixed.
def resize_begin(slot: int64, dir: int32):
    if slot < 0 or dir == 0:
        return
    s: uint64 = cast[uint64](slot)
    # A maximized/snapped window resizes as a now-floating window: clear the
    # snap flag (keep its current rect) so it detaches like MATE does.
    DWIN_SNAP[s] = 0
    DWIN_MAXED[s] = 0
    RESIZE_SLOT = slot
    RESIZE_DIR = dir
    RESIZE_FIX_X = DWIN_X[s]
    RESIZE_FIX_Y = DWIN_Y[s]
    RESIZE_FIX_R = DWIN_X[s] + DWIN_W[s]
    RESIZE_FIX_B = DWIN_Y[s] + DWIN_H[s]
    rb: Ptr[uint8] = "WM resize start\n"
    sys_write(1, rb, strlen_u8(rb))


# Track an in-flight resize: recompute the grabbed window's rectangle from
# the cursor and the anchored opposite edges, clamped to the work area and
# to RESIZE_MIN_W/H. Mirrors how MATE pulls the grabbed edge under the
# pointer while pinning the far edge.
def resize_track(scr_w: int64, scr_h: int64):
    if RESIZE_SLOT < 0:
        return
    s: uint64 = cast[uint64](RESIZE_SLOT)
    new_x: int64 = DWIN_X[s]
    new_y: int64 = DWIN_Y[s]
    new_w: int64 = DWIN_W[s]
    new_h: int64 = DWIN_H[s]
    # Horizontal edges.
    if (RESIZE_DIR & 1) != 0:
        # Left edge moves to the cursor; right edge (RESIZE_FIX_R) anchored.
        lx: int64 = iclamp(CUR_X, 0, RESIZE_FIX_R - RESIZE_MIN_W)
        new_x = lx
        new_w = RESIZE_FIX_R - lx
    elif (RESIZE_DIR & 2) != 0:
        # Right edge moves to the cursor; left edge (RESIZE_FIX_X) anchored.
        # The right edge is the INCLUSIVE pixel CUR_X, so width = CUR_X+1-X.
        rxr: int64 = iclamp(CUR_X + 1, RESIZE_FIX_X + RESIZE_MIN_W, scr_w)
        new_x = RESIZE_FIX_X
        new_w = rxr - RESIZE_FIX_X
    # Vertical edges (never above the panel).
    if (RESIZE_DIR & 4) != 0:
        # Top edge moves to the cursor; bottom (RESIZE_FIX_B) anchored.
        ty: int64 = iclamp(CUR_Y, PANEL_H, RESIZE_FIX_B - RESIZE_MIN_H)
        new_y = ty
        new_h = RESIZE_FIX_B - ty
    elif (RESIZE_DIR & 8) != 0:
        # Bottom edge moves to the cursor; top (RESIZE_FIX_Y) anchored.
        # The bottom edge is the INCLUSIVE pixel CUR_Y, so height = CUR_Y+1-Y.
        byb: int64 = iclamp(CUR_Y + 1, RESIZE_FIX_Y + RESIZE_MIN_H, scr_h)
        new_y = RESIZE_FIX_Y
        new_h = byb - RESIZE_FIX_Y
    if new_w < RESIZE_MIN_W:
        new_w = RESIZE_MIN_W
    if new_h < RESIZE_MIN_H:
        new_h = RESIZE_MIN_H
    DWIN_X[s] = new_x
    DWIN_Y[s] = new_y
    DWIN_W[s] = new_w
    DWIN_H[s] = new_h
    window_reflow(s)


# Finish an in-flight resize: log the final rectangle and clear state.
def resize_end():
    if RESIZE_SLOT < 0:
        RESIZE_DIR = 0
        return
    s: uint64 = cast[uint64](RESIZE_SLOT)
    rline: Array[80, uint8]
    rp: uint64 = 0
    rpfx: Ptr[uint8] = "WM resize done w="
    rk: uint64 = 0
    while rpfx[rk] != 0:
        rline[rp] = rpfx[rk]
        rp = rp + 1
        rk = rk + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_W[s]), &rline[rp])
    rp = rp - 1                              # drop u64_to_dec's newline
    hsfx: Ptr[uint8] = " h="
    hk: uint64 = 0
    while hsfx[hk] != 0:
        rline[rp] = hsfx[hk]
        rp = rp + 1
        hk = hk + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_H[s]), &rline[rp])
    sys_write(1, &rline[0], rp)
    RESIZE_SLOT = -1
    RESIZE_DIR = 0


# Topmost window slot whose rectangle contains (px,py), or -1. Windows
# paint back-to-front (slot 0 lowest), so the highest slot wins the
# hit-test.
def window_at(px: int64, py: int64) -> int64:
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        s: uint64 = cast[uint64](wi)
        # Skip minimized windows and windows not on the current workspace —
        # they have no visible surface on this desktop.
        if win_on_cur_ws(s) != 0:
            wx: int64 = DWIN_X[s]
            wy: int64 = DWIN_Y[s]
            if px >= wx and px < wx + DWIN_W[s] and py >= wy and py < wy + DWIN_H[s]:
                return wi
        wi = wi - 1
    return -1


# ---- per-window terminal emulator ----------------------------------
# Cell index for window `slot` at (col,row) into the flat term_grid.
def term_cell(slot: uint64, col: int64, row: int64) -> uint64:
    return slot * GRID_CELLS + cast[uint64](row * GRID_COLS_MAX + col)


# Clear a window's whole grid to blanks (0) and home the cursor.
def term_clear(slot: uint64):
    base: uint64 = slot * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[base + i] = 0
        i = i + 1
    DWIN_CUR_C[slot] = 0
    DWIN_CUR_R[slot] = 0
    DWIN_VT[slot] = 0


# Scroll the grid up one row (drop the top row, blank the new bottom).
def term_scroll(slot: uint64):
    rows: int64 = DWIN_ROWS[slot]
    cols: int64 = DWIN_COLS[slot]
    r: int64 = 0
    while r < rows - 1:
        c: int64 = 0
        while c < cols:
            src: uint64 = term_cell(slot, c, r + 1)
            dst: uint64 = term_cell(slot, c, r)
            term_grid[dst] = term_grid[src]
            c = c + 1
        r = r + 1
    # blank the last row
    c2: int64 = 0
    while c2 < cols:
        term_grid[term_cell(slot, c2, rows - 1)] = 0
        c2 = c2 + 1


def term_newline(slot: uint64):
    DWIN_CUR_R[slot] = DWIN_CUR_R[slot] + 1
    if DWIN_CUR_R[slot] >= DWIN_ROWS[slot]:
        term_scroll(slot)
        DWIN_CUR_R[slot] = DWIN_ROWS[slot] - 1


# Emit one printable byte into the grid at the cursor, advancing it
# (wrapping + scrolling as needed).
def term_putc(slot: uint64, ch: uint8):
    cols: int64 = DWIN_COLS[slot]
    if cols <= 0 or DWIN_ROWS[slot] <= 0:
        return
    if DWIN_CUR_C[slot] >= cols:
        DWIN_CUR_C[slot] = 0
        term_newline(slot)
    term_grid[term_cell(slot, DWIN_CUR_C[slot], DWIN_CUR_R[slot])] = ch
    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] + 1


# Clamp the cursor to the live grid after a CSI move.
def _term_clamp_cursor(slot: uint64):
    if DWIN_CUR_C[slot] < 0:
        DWIN_CUR_C[slot] = 0
    if DWIN_CUR_C[slot] >= DWIN_COLS[slot]:
        DWIN_CUR_C[slot] = DWIN_COLS[slot] - 1
        if DWIN_CUR_C[slot] < 0:
            DWIN_CUR_C[slot] = 0
    if DWIN_CUR_R[slot] < 0:
        DWIN_CUR_R[slot] = 0
    if DWIN_CUR_R[slot] >= DWIN_ROWS[slot]:
        DWIN_CUR_R[slot] = DWIN_ROWS[slot] - 1
        if DWIN_CUR_R[slot] < 0:
            DWIN_CUR_R[slot] = 0


# Act on a completed CSI sequence whose final byte is `fin`. The accumulated
# numeric parameters live in DWIN_VT_P0/P1; DWIN_VT_SAW says whether any
# digit was supplied (a missing parameter defaults to 1 for the cursor moves
# and to the home position for CUP). Honouring the cursor-positioning
# sequences is the fix for the 'cursor stuck at column 0' bug: hamsh's line
# editor repaints by emitting CR (column 0) then ESC[<n>C to park the cursor
# at its real column -- if we drop ESC[<n>C the caret never leaves column 0.
def _term_csi_dispatch(slot: uint64, fin: uint8):
    p0: int64 = DWIN_VT_P0[slot]
    p1: int64 = DWIN_VT_P1[slot]
    saw: int32 = DWIN_VT_SAW[slot]
    if fin == 67:                                # 'C' -- CUF: cursor forward
        d: int64 = p0
        if saw == 0 or d < 1:
            d = 1
        DWIN_CUR_C[slot] = DWIN_CUR_C[slot] + d
        _term_clamp_cursor(slot)
    elif fin == 68:                              # 'D' -- CUB: cursor back
        d: int64 = p0
        if saw == 0 or d < 1:
            d = 1
        DWIN_CUR_C[slot] = DWIN_CUR_C[slot] - d
        _term_clamp_cursor(slot)
    elif fin == 65:                              # 'A' -- CUU: cursor up
        d: int64 = p0
        if saw == 0 or d < 1:
            d = 1
        DWIN_CUR_R[slot] = DWIN_CUR_R[slot] - d
        _term_clamp_cursor(slot)
    elif fin == 66:                              # 'B' -- CUD: cursor down
        d: int64 = p0
        if saw == 0 or d < 1:
            d = 1
        DWIN_CUR_R[slot] = DWIN_CUR_R[slot] + d
        _term_clamp_cursor(slot)
    elif fin == 71:                              # 'G' -- CHA: absolute column
        col1: int64 = p0
        if saw == 0 or col1 < 1:
            col1 = 1
        DWIN_CUR_C[slot] = col1 - 1              # ANSI columns are 1-based
        _term_clamp_cursor(slot)
    elif fin == 100:                             # 'd' -- VPA: absolute row
        row1: int64 = p0
        if saw == 0 or row1 < 1:
            row1 = 1
        DWIN_CUR_R[slot] = row1 - 1
        _term_clamp_cursor(slot)
    elif fin == 72 or fin == 102:                # 'H'/'f' -- CUP: row;col
        rr: int64 = p0
        cc: int64 = p1
        if saw == 0 or rr < 1:
            rr = 1
        if cc < 1:
            cc = 1
        DWIN_CUR_R[slot] = rr - 1
        DWIN_CUR_C[slot] = cc - 1
        _term_clamp_cursor(slot)
    elif fin == 75:                              # 'K' -- EL: erase in line
        # p0: 0/none = cursor..EOL, 1 = BOL..cursor, 2 = whole line.
        mode: int64 = p0
        if saw == 0:
            mode = 0
        cstart: int64 = 0
        cend: int64 = DWIN_COLS[slot]
        if mode == 0:
            cstart = DWIN_CUR_C[slot]
        elif mode == 1:
            cend = DWIN_CUR_C[slot] + 1
        ec: int64 = cstart
        while ec < cend and ec < DWIN_COLS[slot]:
            if ec >= 0:
                term_grid[term_cell(slot, ec, DWIN_CUR_R[slot])] = 0
            ec = ec + 1
    # Any other final byte (e.g. 'J' erase-display, 'm' SGR colour): ignore
    # its effect but consume it -- same as the original swallow behaviour.


# Feed `n` bytes from buf into window slot's terminal, honouring a minimal
# control set + the cursor-positioning CSI escape sequences
# (CUU/CUD/CUF/CUB/CHA/VPA/CUP/EL). Other CSI sequences are swallowed so they
# don't corrupt the grid.
def term_feed(slot: uint64, buf: Ptr[uint8], n: int64):
    i: int64 = 0
    while i < n:
        c: uint8 = buf[cast[uint64](i)]
        st: int32 = DWIN_VT[slot]
        if st == 1:
            # saw ESC: '[' begins a CSI; anything else aborts to ground.
            if c == 91:                          # '['
                DWIN_VT[slot] = 2
                DWIN_VT_P0[slot] = 0
                DWIN_VT_P1[slot] = 0
                DWIN_VT_PI[slot] = 0
                DWIN_VT_SAW[slot] = 0
            else:
                DWIN_VT[slot] = 0
            i = i + 1
        elif st == 2:
            # in CSI: accumulate decimal parameters (separated by ';') until a
            # final byte in 0x40..0x7E ends the sequence, then act on it.
            if c >= 48 and c <= 57:              # '0'..'9'
                dig: int64 = cast[int64](c) - 48
                if DWIN_VT_PI[slot] == 0:
                    DWIN_VT_P0[slot] = DWIN_VT_P0[slot] * 10 + dig
                else:
                    DWIN_VT_P1[slot] = DWIN_VT_P1[slot] * 10 + dig
                DWIN_VT_SAW[slot] = 1
            elif c == 59:                        # ';' -- next parameter
                if DWIN_VT_PI[slot] == 0:
                    DWIN_VT_PI[slot] = 1
            elif c >= 64 and c <= 126:           # final byte
                _term_csi_dispatch(slot, c)
                DWIN_VT[slot] = 0
            # else: an intermediate byte (0x20..0x2F) -- consume, ignore.
            i = i + 1
        else:
            if c == 27:                          # ESC
                DWIN_VT[slot] = 1
            elif c == 10:                        # '\n' -> newline + CR
                DWIN_CUR_C[slot] = 0
                term_newline(slot)
            elif c == 13:                        # '\r' -> carriage return
                DWIN_CUR_C[slot] = 0
            elif c == 8:                         # backspace
                if DWIN_CUR_C[slot] > 0:
                    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] - 1
                    term_grid[term_cell(slot, DWIN_CUR_C[slot],
                                        DWIN_CUR_R[slot])] = 0
            elif c == 9:                         # tab -> advance to next 8
                nc: int64 = (DWIN_CUR_C[slot] / 8 + 1) * 8
                if nc >= DWIN_COLS[slot]:
                    nc = DWIN_COLS[slot] - 1
                DWIN_CUR_C[slot] = nc
            elif c >= 32 and c <= 126:           # printable ASCII
                term_putc(slot, c)
            # everything else (other control bytes): drop silently
            i = i + 1


# Drain a window's stdout pipe (non-blocking) into its grid. Returns 1
# if any bytes were consumed (the screen needs a re-present), else 0.
def term_pump(slot: uint64) -> int32:
    fd: int32 = DWIN_OUT_FD[slot]
    if fd < 0:
        return 0
    got: int32 = 0
    iters: int32 = 0
    while iters < 16:
        n: int64 = sys_read_nb(fd, &term_rx[0], 1024)
        iters = iters + 1
        if n < 0:
            # TRUE EOF: the child exited and no writer holds the pipe.
            # An EOF'd pipe reads as permanently "ready" to sys_waitfds,
            # so a dead child's stdout would otherwise hot-spin the event
            # loop forever. Close it and forget the fd; the window keeps
            # its last grid contents.
            sys_close(fd)
            DWIN_OUT_FD[slot] = -1
            break
        if n == 0:
            break
        term_feed(slot, &term_rx[0], n)
        got = 1
    return got


# DEPERF #409: render ONE window's own opaque surface pixel at absolute
# screen (x,y), assuming (x,y) lies inside the window's rectangle. Writes
# the window's border / title-bar / body colour into out{r,g,b}. This is
# position-aware only through window-LOCAL coordinates (lwx,lwy) and the
# absolute (x,y) the glyph hit-testers need; it does NOT consult the root,
# lower windows, the panel, the cursor, or translucency — those stay in
# daemon_pixel. Extracted verbatim from daemon_pixel's per-window block so
# the cached and the live paths are pixel-identical. Every pixel in the
# window rect is fully covered (border OR title OR body always assigns).
def window_render_self(wi: uint64, x: int64, y: int64,
                       outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    r: uint8 = WIN_BODY_R
    g: uint8 = WIN_BODY_G
    b: uint8 = WIN_BODY_B
    wx: int64 = DWIN_X[wi]
    wy: int64 = DWIN_Y[wi]
    ww: int64 = DWIN_W[wi]
    wh: int64 = DWIN_H[wi]
    # Local coordinates within the window rectangle.
    lwx: int64 = x - wx
    lwy: int64 = y - wy
    # --- Clearlooks-ish beveled border (2px) ---
    on_border: int32 = 0
    if lwx < 2 or lwx >= ww - 2 or lwy < 2 or lwy >= wh - 2:
        on_border = 1
    # Chromeless v2 panel/overlay windows: their backbuffer covers the
    # whole rect, so no chrome (border OR title) — the v2 blit owns
    # the pixel.
    if DWIN_CHROMELESS[wi] != 0:
        on_border = 0
    if on_border != 0:
        # Outer ring: light highlight on top/left, dark shadow on
        # bottom/right; the inner ring is the mid frame line.
        outer: int32 = 0
        if lwx == 0 or lwy == 0 or lwx == ww - 1 or lwy == wh - 1:
            outer = 1
        if outer != 0:
            if lwx == 0 or lwy == 0:
                r = BEVEL_HI_R
                g = BEVEL_HI_G
                b = BEVEL_HI_B
            else:
                r = BEVEL_LO_R
                g = BEVEL_LO_G
                b = BEVEL_LO_B
        else:
            r = BEVEL_MID_R
            g = BEVEL_MID_G
            b = BEVEL_MID_B
    else:
        if y < wy + title_h_of(cast[uint64](wi)):
            # --- vertical-gradient title bar (active vs inactive) ---
            trow: int64 = lwy - 2          # 0..TITLE_H-3 in the bar
            focused: int32 = 0
            if wi == DWIN_COUNT - 1:
                focused = 1
            if focused != 0:
                r = grad_chan(ACCENT_TOP_R, ACCENT_BOT_R, trow, TITLE_H - 2)
                g = grad_chan(ACCENT_TOP_G, ACCENT_BOT_G, trow, TITLE_H - 2)
                b = grad_chan(ACCENT_TOP_B, ACCENT_BOT_B, trow, TITLE_H - 2)
            else:
                r = grad_chan(TITLE_INA_TOP_R, TITLE_INA_BOT_R, trow, TITLE_H - 2)
                g = grad_chan(TITLE_INA_TOP_G, TITLE_INA_BOT_G, trow, TITLE_H - 2)
                b = grad_chan(TITLE_INA_TOP_B, TITLE_INA_BOT_B, trow, TITLE_H - 2)
            # Title text: a built-in app shows its name; a terminal
            # shows its 1-based window number. Left-aligned.
            tly: int64 = wy + (TITLE_H - GLYPH_H) / 2
            if DWIN_APP[wi] != APP_TERM:
                if str_ink(window_title(wi), wx + 6, tly, x, y) != 0:
                    r = 250
                    g = 250
                    b = 255
            else:
                twb: Array[4, uint8]
                twb[0] = cast[uint8](wi + 1) + 48
                twb[1] = 0
                if str_ink(&twb[0], wx + 6, tly, x, y) != 0:
                    r = 250
                    g = 250
                    b = 255
            # --- ROUND-22: group tab strip across the title bar ---
            # A grouped window draws a row of tab cells in the bottom
            # GROUP_TAB_H band of its title bar; the active member's
            # cell is lit, the rest are dim, separated by 1px dividers.
            if DWIN_GROUP[wi] != 0:
                gmc: int64 = group_member_count(DWIN_GROUP[wi])
                if gmc >= 2:
                    gsy: int64 = wy + TITLE_H - GROUP_TAB_H
                    gsx: int64 = wx + 2
                    gtw: int64 = group_tab_w(cast[uint64](wi))
                    if y >= gsy and y < wy + TITLE_H and gtw > 0:
                        rel: int64 = x - gsx
                        if rel >= 0 and rel < gtw * gmc:
                            ti: int64 = rel / gtw
                            incell: int64 = rel - ti * gtw
                            # Light the active member's tab (its
                            # ordinal among the group in slot order);
                            # dim the rest.
                            act_ord: int64 = group_active_ordinal(
                                DWIN_GROUP[wi])
                            if ti == act_ord:
                                r = 235
                                g = 235
                                b = 245
                            else:
                                r = 120
                                g = 130
                                b = 160
                            # 1px dark divider on each cell's right edge.
                            if incell == gtw - 1:
                                r = 40
                                g = 45
                                b = 60
            # --- close box (beveled red button + white X) ---
            cbx: int64 = close_box_x(wi)
            cby: int64 = close_box_y(wi)
            if x >= cbx and x < cbx + CLOSE_BOX and y >= cby and y < cby + CLOSE_BOX:
                lxp: int64 = x - cbx
                lyp: int64 = y - cby
                hov_c: int32 = 0
                if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 0:
                    hov_c = 1
                r = CLOSE_R
                g = CLOSE_G
                b = CLOSE_B
                if hov_c != 0:
                    r = 245
                    g = 110
                    b = 110
                # bevel: light top/left, dark bottom/right
                if lxp == 0 or lyp == 0:
                    r = 255
                    g = 180
                    b = 180
                elif lxp == CLOSE_BOX - 1 or lyp == CLOSE_BOX - 1:
                    r = 130
                    g = 30
                    b = 30
                inset: int64 = 3
                span: int64 = CLOSE_BOX - 1
                if lxp >= inset and lxp <= span - inset and lyp >= inset and lyp <= span - inset:
                    if lxp == lyp or lxp == span - lyp:
                        r = CLOSE_X_R
                        g = CLOSE_X_G
                        b = CLOSE_X_B
            # --- minimize box (beveled button + dash) ---
            mbx: int64 = minimize_box_x(wi)
            mby: int64 = minimize_box_y(wi)
            if x >= mbx and x < mbx + MINIMIZE_BOX and y >= mby and y < mby + MINIMIZE_BOX:
                lxm: int64 = x - mbx
                lym: int64 = y - mby
                hov_m: int32 = 0
                if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 1:
                    hov_m = 1
                r = MINIMIZE_R
                g = MINIMIZE_G
                b = MINIMIZE_B
                if hov_m != 0:
                    r = 240
                    g = 200
                    b = 80
                if lxm == 0 or lym == 0:
                    r = 255
                    g = 220
                    b = 120
                elif lxm == MINIMIZE_BOX - 1 or lym == MINIMIZE_BOX - 1:
                    r = 130
                    g = 100
                    b = 20
                dash_y: int64 = MINIMIZE_BOX - 4
                dash_x0: int64 = 3
                dash_x1: int64 = MINIMIZE_BOX - 4
                dash_h:  int64 = 2
                if lym >= dash_y and lym < dash_y + dash_h and lxm >= dash_x0 and lxm <= dash_x1:
                    r = MINIMIZE_DASH_R
                    g = MINIMIZE_DASH_G
                    b = MINIMIZE_DASH_B
            # --- maximize box (beveled button + square/restore glyph) ---
            xbx: int64 = maximize_box_x(wi)
            xby: int64 = maximize_box_y(wi)
            if x >= xbx and x < xbx + MAXIMIZE_BOX and y >= xby and y < xby + MAXIMIZE_BOX:
                lxx: int64 = x - xbx
                lyx: int64 = y - xby
                hov_x: int32 = 0
                if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 2:
                    hov_x = 1
                r = MAX_BTN_R
                g = MAX_BTN_G
                b = MAX_BTN_B
                if hov_x != 0:
                    r = 150
                    g = 220
                    b = 150
                if lxx == 0 or lyx == 0:
                    r = 190
                    g = 240
                    b = 190
                elif lxx == MAXIMIZE_BOX - 1 or lyx == MAXIMIZE_BOX - 1:
                    r = 40
                    g = 100
                    b = 40
                # Glyph: a hollow square (Maximize) or two offset
                # squares (Restore) drawn as box outlines.
                gi0: int64 = 3
                gi1: int64 = MAXIMIZE_BOX - 4
                on_glyph: int32 = 0
                if lxx >= gi0 and lxx <= gi1 and lyx >= gi0 and lyx <= gi1:
                    if lxx == gi0 or lxx == gi1 or lyx == gi0 or lyx == gi1:
                        on_glyph = 1
                    # the box's top edge is doubled to read as a titlebar
                    if lyx == gi0 + 1:
                        on_glyph = 1
                if on_glyph != 0:
                    r = MAX_GLYPH_R
                    g = MAX_GLYPH_G
                    b = MAX_GLYPH_B
        elif DWIN_MARKUP[wi] != 0:
            # --- external hamui client: rasterised "ui" markup body ---
            # markup_body_buf[wi] holds the client's frame, body-origin
            # at its top-left; markup_sync() refreshed it this present.
            # Pixels outside the rasterised region fall back to the plain
            # body colour (matches the vk path's out-of-image behaviour).
            r = WIN_BODY_R
            g = WIN_BODY_G
            b = WIN_BODY_B
            mbx0: int64 = wx + 2
            mby0: int64 = wy + title_h_of(cast[uint64](wi))
            mlx: int64 = x - mbx0
            mly: int64 = y - mby0
            if markup_body_ready[wi] != 0 and mlx >= 0 and mly >= 0 \
               and mlx < markup_body_bw[wi] and mly < markup_body_bh[wi] \
               and mlx < MB_W and mly < MB_H:
                mo: uint64 = markup_body_off(cast[uint64](wi), mlx, mly)
                r = markup_body_buf[mo]
                g = markup_body_buf[mo + 1]
                b = markup_body_buf[mo + 2]
        elif DWIN_APP[wi] != APP_TERM:
            # --- built-in application body (calc/sysmon/about) ---
            app_body_pixel(cast[uint64](wi), x, y, &r, &g, &b)
        elif DWIN_VK[wi] != 0:
            # --- native Vulkan image rendered into the body ---
            # The 192x192 RGBA frame (vk_body_buf) sits top-left
            # inside the body region; body pixels outside it fall
            # back to the plain body colour.
            r = WIN_BODY_R
            g = WIN_BODY_G
            b = WIN_BODY_B
            vbx0: int64 = wx + 2
            vby0: int64 = wy + title_h_of(cast[uint64](wi))
            vlx: int64 = x - vbx0
            vly: int64 = y - vby0
            if vk_body_ready != 0 and vlx >= 0 and vly >= 0 \
               and vlx < VK_BODY_W and vly < VK_BODY_H:
                vo: uint64 = cast[uint64](vly * VK_BODY_W + vlx) * 4
                r = vk_body_buf[vo]
                g = vk_body_buf[vo + 1]
                b = vk_body_buf[vo + 2]
        else:
            r = WIN_BODY_R
            g = WIN_BODY_G
            b = WIN_BODY_B
            # --- terminal text rendered into the body ---
            bx0: int64 = wx + 2
            by0: int64 = wy + title_h_of(cast[uint64](wi))
            lx: int64 = x - bx0           # pixel within body
            ly: int64 = y - by0
            if lx >= 0 and ly >= 0:
                col: int64 = lx / GLYPH_W
                row: int64 = ly / GLYPH_H
                if col < DWIN_COLS[wi] and row < DWIN_ROWS[wi]:
                    gx: int64 = lx - col * GLYPH_W   # 0..7
                    gy: int64 = ly - row * GLYPH_H   # 0..15
                    # Cursor block (inverse) at the cell cursor.
                    is_cur: int32 = 0
                    if col == DWIN_CUR_C[wi] and row == DWIN_CUR_R[wi]:
                        is_cur = 1
                    ce: uint64 = term_cell(cast[uint64](wi), col, row)
                    ch: uint8 = term_grid[ce]
                    on: int32 = 0
                    if ch >= 32 and ch <= 126:
                        gi: uint64 = cast[uint64](ch) - 32
                        bits: uint8 = font_glyphs[gi * 16
                                                  + cast[uint64](gy)]
                        mask: uint8 = cast[uint8](128 >> gx)
                        if (bits & mask) != 0:
                            on = 1
                    if is_cur != 0:
                        # Solid dark cursor block; glyph ink on it
                        # flips to body colour for legibility.
                        if on != 0:
                            r = WIN_BODY_R
                            g = WIN_BODY_G
                            b = WIN_BODY_B
                        else:
                            r = 24
                            g = 24
                            b = 24
                    elif on != 0:
                        r = 24
                        g = 24
                        b = 24
    outr[0] = r
    outg[0] = g
    outb[0] = b


# DEPERF #409: can window `wi` use the per-window cache this frame? Only
# windows whose surface fits the fixed WCACHE_W x WCACHE_H cap are cached;
# anything bigger (e.g. a maximised window on a large screen) falls back to
# the procedural path. Returns 1 if cacheable, else 0.
def window_cacheable(wi: uint64) -> int32:
    if DWIN_W[wi] <= 0 or DWIN_H[wi] <= 0:
        return 0
    if DWIN_W[wi] > WCACHE_W or DWIN_H[wi] > WCACHE_H:
        return 0
    return 1


# DEPERF #409: byte offset of window-local pixel (lx,ly) for slot `wi`
# inside the flat WCACHE_RGB buffer (3 bytes/pixel, packed per cap-sized
# slot so a window's row stride is WCACHE_W regardless of its real width).
def wcache_off(wi: uint64, lx: int64, ly: int64) -> uint64:
    base: uint64 = cast[uint64](wi) * cast[uint64](WCACHE_W * WCACHE_H * 3)
    return base + cast[uint64]((ly * WCACHE_W + lx) * 3)


# DEPERF #409: (re)render window `wi`'s whole surface into its cache slot
# and mark the cache valid for its current geometry. Called only when the
# window is cacheable and its cache is stale (content-dirty or geometry
# changed). After this the cache holds the exact bytes window_render_self
# would produce, so a later read is pixel-identical to the live path.
def window_cache_fill(wi: uint64):
    ww: int64 = DWIN_W[wi]
    wh: int64 = DWIN_H[wi]
    wx: int64 = DWIN_X[wi]
    wy: int64 = DWIN_Y[wi]
    cr: Array[1, uint8]
    cg: Array[1, uint8]
    cb: Array[1, uint8]
    ly: int64 = 0
    while ly < wh:
        lx: int64 = 0
        while lx < ww:
            window_render_self(wi, wx + lx, wy + ly, &cr[0], &cg[0], &cb[0])
            o: uint64 = wcache_off(wi, lx, ly)
            WCACHE_RGB[o] = cr[0]
            WCACHE_RGB[o + 1] = cg[0]
            WCACHE_RGB[o + 2] = cb[0]
            lx = lx + 1
        ly = ly + 1
    WCACHE_VALID[wi] = 1
    WCACHE_UW[wi] = ww
    WCACHE_UH[wi] = wh
    DWIN_CONTENT_DIRTY[wi] = 0


# DEPERF #409: ensure every visible window's cache is current before a
# composite pass. A window is refilled only if it is cacheable AND its
# cache is stale — invalid, content-dirty, or its width/height changed
# since the cache was filled (a resize). A pure MOVE leaves the cache
# valid (same WCACHE_UW/UH, not content-dirty) so it is reused verbatim.
# Records rerendered/reused counts for the self-test.
def window_cache_sync():
    # Refresh every markup-client window's body buffer BEFORE the surface
    # cache is (re)filled, so window_render_self samples a current frame.
    # markup_sync() marks a refreshed window content-dirty, which makes the
    # cache below treat it as stale and re-render its surface this pass.
    markup_sync()
    WCACHE_LAST_RERENDERED = 0
    WCACHE_LAST_REUSED = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) == 0:
            wi = wi + 1
            continue
        if window_cacheable(wi) == 0:
            # Uncacheable (too large): force the live procedural path.
            WCACHE_VALID[wi] = 0
            wi = wi + 1
            continue
        stale: int32 = 0
        if WCACHE_VALID[wi] == 0:
            stale = 1
        elif DWIN_CONTENT_DIRTY[wi] != 0:
            stale = 1
        elif WCACHE_UW[wi] != DWIN_W[wi] or WCACHE_UH[wi] != DWIN_H[wi]:
            stale = 1
        if stale != 0:
            window_cache_fill(wi)
            WCACHE_LAST_RERENDERED = WCACHE_LAST_RERENDERED + 1
        else:
            WCACHE_LAST_REUSED = WCACHE_LAST_REUSED + 1
        wi = wi + 1


# DEPERF #409: mark a window's SURFACE as changed so its cache is refilled
# on the next composite. Called wherever window CONTENT (not just position)
# changes: shell output, focus/hover chrome, app-body repaint, resize,
# title/group/opacity changes. A pure move must NOT call this.
def window_content_dirty(slot: uint64):
    if slot >= DWIN_COUNT:
        return
    DWIN_CONTENT_DIRTY[slot] = 1


# DEPERF #409: invalidate every window's cache (theme/scheme recolour,
# focus shuffle, or any global surface change). Forces a full refill.
def window_cache_invalidate_all():
    i: uint64 = 0
    while i < DMAX:
        WCACHE_VALID[i] = 0
        DWIN_CONTENT_DIRTY[i] = 1
        i = i + 1


# DE pivot helper: desktop-icon badges (root layer, under all windows).
# Hoisted out of daemon_pixel to keep the per-pixel cascade body small.
# Mutates *rp/*gp/*bp ONLY when this pixel falls inside an icon cell;
# otherwise the caller's colour passes through unchanged.
def dpix_root_icons(x: int64, y: int64,
                    rp: Ptr[uint8], gp: Ptr[uint8], bp: Ptr[uint8]):
    di: int64 = 0
    while di < DICON_COUNT:
        ix: int64 = DICON_X[di]
        iy: int64 = DICON_Y[di]
        if x >= ix and x < ix + DICON_CELL_W and y >= iy and y < iy + DICON_CELL_H:
            lx: int64 = x - ix
            ly: int64 = y - iy
            bx0: int64 = (DICON_CELL_W - DICON_BADGE) / 2
            by0: int64 = 4
            hot: int32 = 0
            if DICON_DRAG == di:
                hot = 1
            if lx >= bx0 and lx < bx0 + DICON_BADGE \
               and ly >= by0 and ly < by0 + DICON_BADGE:
                bxl: int64 = lx - bx0
                byl: int64 = ly - by0
                br: Array[1, uint8]
                bg: Array[1, uint8]
                bb: Array[1, uint8]
                dicon_badge_rgb(di, &br[0], &bg[0], &bb[0])
                rr: uint8 = br[0]
                gg: uint8 = bg[0]
                bbu: uint8 = bb[0]
                if bxl == 0 or byl == 0:
                    rr = add_clamp_u8(rr, 50)
                    gg = add_clamp_u8(gg, 50)
                    bbu = add_clamp_u8(bbu, 50)
                elif bxl == DICON_BADGE - 1 or byl == DICON_BADGE - 1:
                    rr = sub_clamp_u8(rr, 40)
                    gg = sub_clamp_u8(gg, 40)
                    bbu = sub_clamp_u8(bbu, 40)
                if hot != 0:
                    rr = add_clamp_u8(rr, 30)
                    gg = add_clamp_u8(gg, 30)
                    bbu = add_clamp_u8(bbu, 30)
                rp[0] = rr
                gp[0] = gg
                bp[0] = bbu
            else:
                lbl: Ptr[uint8] = dicon_label(di)
                lblw: int64 = cast[int64](strlen_u8(lbl)) * GLYPH_W
                lblx: int64 = ix + (DICON_CELL_W - lblw) / 2
                lbly: int64 = iy + by0 + DICON_BADGE + 4
                if str_ink(lbl, lblx, lbly, x, y) != 0:
                    rp[0] = 240
                    gp[0] = 240
                    bp[0] = 248
        di = di + 1


# DE pivot helper: desktop system-monitor applet on the root layer (CPU
# + MEM bars). Hoisted out of daemon_pixel to keep the cascade body small.
def dpix_root_dmon(x: int64, y: int64,
                   rp: Ptr[uint8], gp: Ptr[uint8], bp: Ptr[uint8]):
    dmx0: int64 = dmon_x0(cast[int64](FBG_W))
    dmy0: int64 = dmon_y0(cast[int64](FBG_H))
    if x >= dmx0 and x < dmx0 + DMON_W and y >= dmy0 and y < dmy0 + DMON_H:
        dlx: int64 = x - dmx0
        dly: int64 = y - dmy0
        if dlx == 0 or dlx == DMON_W - 1 or dly == 0 or dly == DMON_H - 1:
            rp[0] = 90
            gp[0] = 110
            bp[0] = 150
        else:
            rp[0] = cast[uint8]((cast[int32](rp[0]) + 24) / 2)
            gp[0] = cast[uint8]((cast[int32](gp[0]) + 28) / 2)
            bp[0] = cast[uint8]((cast[int32](bp[0]) + 36) / 2)
        gband: int64 = 22
        glx0: int64 = 4
        cpu_top: int64 = 3
        mem_top: int64 = cpu_top + gband + 2
        col: int64 = dlx - glx0
        if col >= 0 and col < DMON_HIST:
            if dly >= cpu_top and dly < cpu_top + gband:
                cv: int64 = dmon_sample(col, 0)
                fill_h: int64 = cv * gband / 100
                rowfb: int64 = (cpu_top + gband - 1) - dly
                if rowfb >= 0 and rowfb < fill_h:
                    rp[0] = 110
                    gp[0] = 200
                    bp[0] = 250
            elif dly >= mem_top and dly < mem_top + gband:
                mv: int64 = dmon_sample(col, 1)
                fill_h2: int64 = mv * gband / 100
                rowfb2: int64 = (mem_top + gband - 1) - dly
                if rowfb2 >= 0 and rowfb2 < fill_h2:
                    rp[0] = 250
                    gp[0] = 170
                    bp[0] = 110
        cl: Ptr[uint8] = "C"
        if str_ink(cl, dmx0 + DMON_W - 10, dmy0 + cpu_top, x, y) != 0:
            rp[0] = 200
            gp[0] = 230
            bp[0] = 250
        ml: Ptr[uint8] = "M"
        if str_ink(ml, dmx0 + DMON_W - 10, dmy0 + mem_top, x, y) != 0:
            rp[0] = 250
            gp[0] = 210
            bp[0] = 190


# Pixel-model query: what colour is screen pixel (x,y)? Writes r/g/b.
# Order (back to front): backdrop -> windows (in creation order) ->
# rubber band outline -> cursor. The cursor wins last so it's always
# visible.
def daemon_pixel(x: int64, y: int64,
                 outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    # DE pivot: this per-pixel cascade is being collapsed toward "presenter
    # only — every UI element is a v2 client." The following surfaces no
    # longer fan out here; their render moved to a standalone v2 client
    # (each client owns a window, negotiates hamui_set_protocol_v2(), and
    # ships pixels via hamui_v2_commit_rect / the #442(c) blit protocol).
    # The breadcrumb strings below are LOAD-BEARING — scripts/test_de_*_v2.sh
    # greps for them inside daemon_pixel's body and FAILS if a future
    # refactor silently re-inlines the surface. Do NOT remove.
    #   * panel chrome    EXTRACTED to /bin/hampanel   (DE pivot wave 1)
    #   * Applications menu rendering EXTRACTED -> /bin/hamappmenu (wave 2)
    #   * Alt-Tab cycler rendering EXTRACTED -> /bin/hamcycler  (wave 3)
    #   * clock calendar popup rendering EXTRACTED -> /bin/hamcalpop (w4)
    #   * Run dialog (Alt-F2) rendering EXTRACTED -> /bin/hamrun (wave 4b)
    #   * LOCK overlay rendering EXTRACTED -> /bin/hamlock      (wave 5)
    #   * notification banner rendering EXTRACTED -> /bin/hamnotif (wave 7)
    #   * Session dialog (End Session) rendering EXTRACTED -> /bin/hamsessui (wave 8)
    #   * desktop icons rendering EXTRACTED -> /bin/hamdesktop (wave 1 round 2)
    #   * system monitor applet rendering EXTRACTED -> /bin/hamsysmon (wave 2 round 2)
    #   * context menu rendering EXTRACTED -> /bin/hamctxmenu (wave 3 round 2)
    #   * snap-zone preview rendering EXTRACTED -> /bin/hamsnap (wave 4 round 2)
    #   * resize+kmode frame rendering EXTRACTED -> /bin/hamresize (wave 5 round 2)
    #   * OSD popup rendering EXTRACTED -> /bin/hamosd (wave 6 round 2)
    #   * message tray rendering EXTRACTED -> /bin/hamtray (wave 7 round 2)
    # Surfaces that REMAIN inline below are deliberately load-bearing
    # fallbacks — no v2 client exists for them yet (desktop icons, system-
    # monitor applet, right-click context menu, snap-zone preview, live
    # resize/keyboard-move frames, OSD popup, notification tray history).
    # They are next on the pivot's todo list; until each gets its own v2
    # client, this is the ONLY render path for them, so the code stays
    # even though the cascade is "supposed to be empty."
    # Cursor sprite is NEVER composited here (DEPERF #410) — it overlays
    # the cached scene at scanout time. Do not gate or re-introduce it.
    r: uint8 = ROOT_R
    g: uint8 = ROOT_G
    b: uint8 = ROOT_B
    # Image wallpaper: sample decoded RGB buffer centred on screen
    # (no scaling). Pixels outside the image rect keep the backdrop.
    if wallpaper_loaded != 0 and wallpaper_w > 0 and wallpaper_h > 0:
        sw: int64 = cast[int64](FBG_W)
        sh: int64 = cast[int64](FBG_H)
        iw: int64 = cast[int64](wallpaper_w)
        ih: int64 = cast[int64](wallpaper_h)
        ox: int64 = (sw - iw) / 2
        oy: int64 = (sh - ih) / 2
        ix: int64 = x - ox
        iy: int64 = y - oy
        if ix >= 0 and ix < iw and iy >= 0 and iy < ih:
            o: uint64 = (cast[uint64](iy) * wallpaper_w + cast[uint64](ix)) * 3
            r = wallpaper_rgb[o]
            g = wallpaper_rgb[o + 1]
            b = wallpaper_rgb[o + 2]
    # Desktop icons + system-monitor applet on the root (no v2 client yet).
    # Render delegated to helpers so the cascade body stays small.
    rgbtmp0: Array[3, uint8]
    rgbtmp0[0] = r
    rgbtmp0[1] = g
    rgbtmp0[2] = b
    # DE pivot wave 1: desktop icon rendering EXTRACTED to /bin/hamdesktop
    # DE pivot wave 2: system monitor applet rendering EXTRACTED to /bin/hamsysmon
    r = rgbtmp0[0]
    g = rgbtmp0[1]
    b = rgbtmp0[2]
    # --- windows (back to front) ---
    # BUG 2 occlusion skip: start compositing at the front-most OPAQUE
    # window covering (x,y); anything below is fully occluded. Translucent
    # windows can't occlude, so the scan stops at the topmost opaque
    # coverer and any translucent windows above are blended over it.
    wstart: uint64 = 0
    occ: uint64 = DWIN_COUNT
    while occ > 0:
        occ = occ - 1
        if win_on_cur_ws(occ) == 0:
            continue
        if DWIN_OPACITY[occ] < 255:
            continue                    # translucent: cannot occlude
        owx: int64 = DWIN_X[occ]
        owy: int64 = DWIN_Y[occ]
        if x >= owx and x < owx + DWIN_W[occ] \
           and y >= owy and y < owy + DWIN_H[occ]:
            wstart = occ                # first opaque coverer from the top
            break
    wi: uint64 = wstart
    while wi < DWIN_COUNT:
        # Skip minimized windows and windows not on the current workspace.
        if win_on_cur_ws(wi) == 0:
            wi = wi + 1
            continue
        wx: int64 = DWIN_X[wi]
        wy: int64 = DWIN_Y[wi]
        ww: int64 = DWIN_W[wi]
        wh: int64 = DWIN_H[wi]
        if x >= wx and x < wx + ww and y >= wy and y < wy + wh:
            # BUG 2 instrumentation (window-body evaluations, occluded
            # windows never reach here so this stays window-count-bounded).
            DPIX_WIN_VISITS = DPIX_WIN_VISITS + 1
            # Save the colour painted behind this window so a translucent
            # window can alpha-blend over it after rendering its own pixel.
            behind_r: uint8 = r
            behind_g: uint8 = g
            behind_b: uint8 = b
            # DEPERF #409 per-window backbuffer cache: when valid (filled
            # by window_cache_sync() this pass, not invalidated since),
            # read the cached RGB at the window-LOCAL offset. Otherwise
            # fall back to the live procedural renderer.
            lwx: int64 = x - wx
            lwy: int64 = y - wy
            if WCACHE_VALID[wi] != 0 and lwx >= 0 and lwy >= 0 \
               and lwx < WCACHE_UW[wi] and lwy < WCACHE_UH[wi]:
                co: uint64 = wcache_off(wi, lwx, lwy)
                r = WCACHE_RGB[co]
                g = WCACHE_RGB[co + 1]
                b = WCACHE_RGB[co + 2]
            else:
                cr2: Array[1, uint8]
                cg2: Array[1, uint8]
                cb2: Array[1, uint8]
                window_render_self(wi, x, y, &cr2[0], &cg2[0], &cb2[0])
                r = cr2[0]
                g = cg2[0]
                b = cb2[0]
            # Alpha-blend translucent windows over the saved backdrop;
            # opaque (a == 255) reduces to overwrite.
            wa: int32 = DWIN_OPACITY[wi]
            if wa < 255:
                ia: int32 = 255 - wa
                r = cast[uint8]((cast[int32](r) * wa
                                 + cast[int32](behind_r) * ia) / 255)
                g = cast[uint8]((cast[int32](g) * wa
                                 + cast[int32](behind_g) * ia) / 255)
                b = cast[uint8]((cast[int32](b) * wa
                                 + cast[int32](behind_b) * ia) / 255)
        wi = wi + 1
    # (panel chrome + Applications menu render EXTRACTED — see header.)
    # DE pivot wave 3: right-click context menu rendering EXTRACTED to /bin/hamctxmenu
    # DE pivot wave 4: snap-zone preview rendering EXTRACTED to /bin/hamsnap
    # DE pivot wave 5: resize + kmode frame rendering EXTRACTED to /bin/hamresize
    # (Alt-Tab cycler + calpop + notification banner EXTRACTED — see header.
    # Rubber-band 1px outline is HOISTED to scanout via
    # scene_blit_rect_outline so SCENE_CACHE stays valid; do not re-inline.)
    # DE pivot wave 6: OSD popup rendering EXTRACTED to /bin/hamosd
    # (LOCK overlay rendering EXTRACTED — see header.)
    # (Session dialog rendering EXTRACTED -> /bin/hamsessui — see header.
    #  The desktop dim behind the dialog is now handled by the compositor's
    #  damage path; the modal chrome itself is rasterised by hamsessui via
    #  the #442 (c) v2 blit protocol.)
    # DE pivot wave 7: message tray panel rendering EXTRACTED to /bin/hamtray
    # (Run dialog rendering EXTRACTED -> /bin/hamrun — see header.
    # Cursor sprite is NEVER composited here; overlay happens at scanout.)
    outr[0] = r
    outg[0] = g
    outb[0] = b


# DEPERF #410: cursor-sprite overlay. If screen pixel (x,y) lies under the
# 12x12 cursor arrow anchored at (CUR_X,CUR_Y), overwrite *r/*g/*b with the
# sprite colour and return 1; otherwise leave them and return 0. This is the
# same triangle mask daemon_pixel used to inline, now applied on top of a
# cached scene pixel during the scanout copy.
def cursor_pixel_over(x: int64, y: int64,
                      r: Ptr[uint8], g: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # DE perf: when the kernel-overlay cursor is live (KCURSOR_ACTIVE), the
    # kernel paints the sprite on top of every compositor write — so this
    # userland inline overlay would just duplicate the arrow (and leave a
    # stale ghost during slow presents where CUR_X/CUR_Y advanced between
    # the scene build and the on-the-wire blit). Back off so the kernel
    # path is the SOLE cursor renderer; the legacy overlay only runs as a
    # kernel-old fallback (no /dev/fbctl, or CURS unrecognised).
    if KCURSOR_ACTIVE != 0:
        return 0
    dx: int64 = x - CUR_X
    dy: int64 = y - CUR_Y
    if dx >= 0 and dy >= 0 and dx < 12 and dy < 12:
        # Triangle mask: the pixel is part of the cursor if dx <= dy.
        # That paints a downward-right pointer anchored at the hotspot.
        if dx <= dy:
            # 1px white outline at the hypotenuse-ish edge, black fill.
            if dx == dy or dy == 11 or dx == 0:
                r[0] = 255
                g[0] = 255
                b[0] = 255
            else:
                r[0] = 0
                g[0] = 0
                b[0] = 0
            return 1
    return 0


# Refresh the live tray window-count badge from the current model: how many
# windows are visible on the current workspace.
def notif_count_refresh():
    NOTIF_WIN_COUNT = cycle_visible_count()


# ====================================================================
# DEPERF — dirty-rectangle present via the /dev/fbctl RECT command
# ====================================================================
# The compositor composes each present (full frame or partial rect) into the
# CONTIGUOUS RGBA8888 band buffer screen_band (up to SCREEN_BAND_ROWS rows of
# up to SCREEN_ROW_MAXW px, packed at the rect's own pixel stride). The legacy
# present path then ships that band to /dev/fb with one lseek+sys_write PER
# CONTIGUOUS BAND. /dev/fb is offset-addressed, so a sub-width rect (a single
# window's frame) needs ONE seek+write PER ROW — H syscalls for an H-tall
# window.
#
# The kernel landed a binary RECT command on /dev/fbctl (magic-tagged, see
# drivers/video/fb_cdev.ad::_fbctl_rect_present): ONE 52-byte write names a
# rectangle in our own RGBA source frame plus where to land it on screen, and
# the kernel blits exactly that rectangle to scanout. So a whole band — even a
# sub-width window rect packed contiguously in screen_band — presents in a
# SINGLE syscall regardless of its height. That collapses the per-row
# seek+write loop of the partial path to one write per band.
#
# fbctl_fd is the persistent write fd to /dev/fbctl, opened once by
# fb_console_takeover() (the same fd that carries the suspend/resume verbs —
# the RECT magic disambiguates the two so they share the fd safely). It is
# -1 when /dev/fbctl is absent (old kernel / headless), in which case every
# present falls back to the bit-identical /dev/fb seek+write path below.
fbctl_fd: int32 = -1
FBCTL_RECT_HDRLEN_HUI: uint64 = 52
# Scratch for one 52-byte RECT header (little-endian, matches fb_cdev.ad).
fbctl_rect_hdr: Array[52, uint8]
# DE-perf cursor decouple: 24-byte CURS header (magic + i32 x + i32 y +
# u32 visible + u32 flags + u32 _pad). The kernel keeps the cursor sprite
# + position + saved underlay in fb_cdev.ad; we just push the new pointer
# coords on every mouse pump so the on-screen cursor advances at mouse-rx
# cadence even while the compositor's slow path (full present, window
# drag composite) is in flight on the same thread.
FBCTL_CURS_MAGIC_HUI:  uint32 = 0x53525543     # 'C','U','R','S' LE
FBCTL_CURS_HDRLEN_HUI: uint64 = 24
fbctl_curs_hdr: Array[24, uint8]
# 1 iff at least one CURS write has been acked by the kernel (proves the
# decoupled path is live; structural test_de_cursor_decouple asserts it
# alongside the grep guards).
FBCTL_CURS_PRESENTS: uint64 = 0
# Track whether the kernel cursor overlay is in use. When the kernel
# accepts a CURS write the compositor STOPS overlaying the cursor sprite
# in scene_blit_rect (cursor_pixel_over) — otherwise both the kernel and
# userland would paint the arrow, leaving a stale duplicate during slow
# presents. If the kernel is too old (no CURS support — write returns
# !=24) the legacy userland overlay takes over again so the cursor never
# disappears on a kernel-old boot.
KCURSOR_ACTIVE: int32 = 0
# Instrumentation: how many RECT presents the kernel has ACKED for us this
# session (a RECT write returns exactly FBCTL_RECT_HDRLEN_HUI=52 ONLY from
# the kernel's _fbctl_rect_present handler, so a non-zero count is proof the
# accelerated dirty-rect path actually fired through to the kernel). Used by
# the derect self-test (autoflag 44).
FBCTL_RECT_PRESENTS: uint64 = 0


def _put_u32_le(buf: Ptr[uint8], off: uint64, v: uint32):
    buf[off]     = cast[uint8](v & 0xff)
    buf[off + 1] = cast[uint8]((v >> 8) & 0xff)
    buf[off + 2] = cast[uint8]((v >> 16) & 0xff)
    buf[off + 3] = cast[uint8]((v >> 24) & 0xff)


def _put_u64_le(buf: Ptr[uint8], off: uint64, v: uint64):
    buf[off]     = cast[uint8](v & 0xff)
    buf[off + 1] = cast[uint8]((v >> 8) & 0xff)
    buf[off + 2] = cast[uint8]((v >> 16) & 0xff)
    buf[off + 3] = cast[uint8]((v >> 24) & 0xff)
    buf[off + 4] = cast[uint8]((v >> 32) & 0xff)
    buf[off + 5] = cast[uint8]((v >> 40) & 0xff)
    buf[off + 6] = cast[uint8]((v >> 48) & 0xff)
    buf[off + 7] = cast[uint8]((v >> 56) & 0xff)


# Present the rectangle [src_x0,src_y0]+(w x h) of a contiguous RGBA8888
# source frame (src_ptr, src_pitch_px pixels/row) to screen at (dst_x,dst_y)
# via ONE /dev/fbctl RECT write. Returns 1 on success (kernel consumed the
# 52-byte header), 0 if RECT is unavailable or the write did not land — the
# caller then takes the legacy /dev/fb seek+write path. Wire layout mirrors
# drivers/video/fb_cdev.ad exactly: u32 magic/dst_x/dst_y/w/h then u64
# src_ptr/src_pitch_px/src_x0/src_y0 (52 bytes).
def fbctl_present_rect(dst_x: uint64, dst_y: uint64, w: uint64, h: uint64,
                       src_ptr: uint64, src_pitch_px: uint64,
                       src_x0: uint64, src_y0: uint64) -> int32:
    if fbctl_fd < 0:
        return 0
    if w == 0 or h == 0 or src_ptr == 0 or src_pitch_px == 0:
        return 0
    _put_u32_le(&fbctl_rect_hdr[0], 0, 0x54434552)       # 'RECT' LE
    _put_u32_le(&fbctl_rect_hdr[0], 4, cast[uint32](dst_x))
    _put_u32_le(&fbctl_rect_hdr[0], 8, cast[uint32](dst_y))
    _put_u32_le(&fbctl_rect_hdr[0], 12, cast[uint32](w))
    _put_u32_le(&fbctl_rect_hdr[0], 16, cast[uint32](h))
    _put_u64_le(&fbctl_rect_hdr[0], 20, src_ptr)
    _put_u64_le(&fbctl_rect_hdr[0], 28, src_pitch_px)
    _put_u64_le(&fbctl_rect_hdr[0], 36, src_x0)
    _put_u64_le(&fbctl_rect_hdr[0], 44, src_y0)
    n: int64 = sys_write(fbctl_fd, &fbctl_rect_hdr[0], FBCTL_RECT_HDRLEN_HUI)
    if n == cast[int64](FBCTL_RECT_HDRLEN_HUI):
        FBCTL_RECT_PRESENTS = FBCTL_RECT_PRESENTS + 1
        return 1
    return 0


# ====================================================================
# DE perf: decouple cursor render from compositor hot path
# ====================================================================
# Push the live pointer position to the kernel cursor overlay. The kernel
# (drivers/video/fb_cdev.ad CURS command) erases the sprite from its old
# position, snapshots the new underlay, and paints the sprite at the new
# coords — entirely independent of the compositor's per-frame work. This
# means even when a slow daemon_present() (full-screen recomposite during
# a window drag) is in flight, a cursor move that arrived between two
# pumps WILL have already landed on screen via the kernel path.
#
# Wire layout (24 bytes, little-endian — matches FBCTL_CURS_HDRLEN /
# _fbctl_curs_command in fb_cdev.ad):
#   +0   u32  magic   = 0x53525543 ('C','U','R','S')
#   +4   i32  x       cursor x in screen pixels
#   +8   i32  y       cursor y
#   +12  u32  visible 0 = hide, 1 = show
#   +16  u32  flags   reserved (0)
#   +20  u32  _pad    reserved (0)
#
# Returns 1 if the kernel acked the command (KCURSOR_ACTIVE latches to 1
# so the legacy userland cursor_pixel_over overlay backs off and stops
# painting a duplicate arrow); 0 if /dev/fbctl is absent or the kernel
# is too old to recognise CURS (legacy overlay stays on as fallback).
def _put_i32_le(buf: Ptr[uint8], off: uint64, v: int32):
    u: uint32 = cast[uint32](v)
    buf[off]     = cast[uint8](u & 0xff)
    buf[off + 1] = cast[uint8]((u >> 8) & 0xff)
    buf[off + 2] = cast[uint8]((u >> 16) & 0xff)
    buf[off + 3] = cast[uint8]((u >> 24) & 0xff)


def kcursor_send(x: int64, y: int64, visible: int32) -> int32:
    if fbctl_fd < 0:
        return 0
    _put_u32_le(&fbctl_curs_hdr[0], 0, FBCTL_CURS_MAGIC_HUI)
    _put_i32_le(&fbctl_curs_hdr[0], 4, cast[int32](x))
    _put_i32_le(&fbctl_curs_hdr[0], 8, cast[int32](y))
    vv: uint32 = 0
    if visible != 0:
        vv = 1
    _put_u32_le(&fbctl_curs_hdr[0], 12, vv)
    _put_u32_le(&fbctl_curs_hdr[0], 16, 0)
    _put_u32_le(&fbctl_curs_hdr[0], 20, 0)
    n: int64 = sys_write(fbctl_fd, &fbctl_curs_hdr[0],
                         FBCTL_CURS_HDRLEN_HUI)
    if n == cast[int64](FBCTL_CURS_HDRLEN_HUI):
        FBCTL_CURS_PRESENTS = FBCTL_CURS_PRESENTS + 1
        KCURSOR_ACTIVE = 1
        return 1
    return 0


# Convenience: push the LIVE pointer position (CUR_X/CUR_Y) to the kernel
# overlay. Called from daemon_pump_mouse on every packet so the kernel
# cursor tracks at mouse-rx cadence, NOT at compositor present cadence.
def kcursor_push_live() -> int32:
    return kcursor_send(CUR_X, CUR_Y, 1)


# ====================================================================
# DEPERF #410 — cached-layer blit compositor
# ====================================================================
# SCENE_CACHE holds the composited cursor-FREE scene at SCENE_PITCH px per
# row (RGBA8888). daemon_pixel — the procedural scene-graph walk — is run
# ONLY to (re)fill a damaged rect of SCENE_CACHE; every scanout present is a
# plain memory BLIT of a cached rect (cursor overlaid on the wire). The only
# full-screen daemon_pixel pass is scene_build_full (startup / genuine full
# invalidation). A cursor move blits cached rows with ZERO daemon_pixel.

# Current SCENE_CACHE row stride in pixels (clamped FBG_W). Keeps SCENE_PITCH
# coherent with whatever resolution the live framebuffer reports.
def scene_pitch_now() -> uint64:
    sw: uint64 = FBG_W
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    return sw


# Byte offset of scene pixel (x,y) inside SCENE_CACHE (RGBA, SCENE_PITCH px
# stride). Caller guarantees (x,y) is in-bounds.
def scene_off(x: int64, y: int64) -> uint64:
    return cast[uint64]((y * cast[int64](SCENE_PITCH) + x)) * 4


# Re-evaluate the procedural scene (daemon_pixel) over the rectangle
# [x0,x1) x [y0,y1) and store the cursor-FREE result into SCENE_CACHE. This
# is the ONLY place daemon_pixel runs; its cost scales with the rect AREA.
# Clips to the screen. window_cache_sync() must have run before this so each
# window's surface cache is current.
def scene_build_rect(x0: int64, y0: int64, x1: int64, y1: int64):
    SCENE_PITCH = scene_pitch_now()
    sw: int64 = cast[int64](SCENE_PITCH)
    sh: int64 = cast[int64](FBG_H)
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > sw:
        x1 = sw
    if y1 > sh:
        y1 = sh
    if x0 >= x1 or y0 >= y1:
        return
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    yy: int64 = y0
    while yy < y1:
        xx: int64 = x0
        o: uint64 = scene_off(x0, yy)
        while xx < x1:
            daemon_pixel(xx, yy, &rr[0], &gg[0], &bb[0])
            SCENE_CACHE[o]     = rr[0]
            SCENE_CACHE[o + 1] = gg[0]
            SCENE_CACHE[o + 2] = bb[0]
            SCENE_CACHE[o + 3] = 255
            o = o + 4
            xx = xx + 1
        yy = yy + 1


# Build the WHOLE cursor-free scene into SCENE_CACHE (startup + genuine full
# invalidation). The single full-screen daemon_pixel pass.
def scene_build_full():
    SCENE_PITCH = scene_pitch_now()
    scene_build_rect(0, 0, cast[int64](SCENE_PITCH), cast[int64](FBG_H))
    SCENE_VALID = 1


# Blit the SCENE_CACHE rectangle [x0,x1) x [y0,y1) to scanout, overlaying the
# 12x12 cursor sprite where it intersects the rect. No daemon_pixel here — it
# is a pure copy of already-composited pixels. Uses the SAME screen_band +
# /dev/fbctl RECT (or /dev/fb seek+write fallback) machinery as the
# procedural present path. Caller has clipped the rect to the screen.
def scene_blit_rect(x0: int64, y0: int64, x1: int64, y1: int64):
    sw: int64 = cast[int64](FBG_W)
    rw: int64 = x1 - x0
    if rw > cast[int64](SCREEN_ROW_MAXW):
        rw = cast[int64](SCREEN_ROW_MAXW)
        x1 = x0 + rw
    seg_bytes: uint64 = cast[uint64](rw) * 4
    full_width: int32 = 0
    if x0 == 0 and x1 == sw and seg_bytes <= SCREEN_ROW_MAXW * 4:
        full_width = 1
    wf: int32 = -1
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    band_rows: int64 = cast[int64](SCREEN_BAND_ROWS)
    sy: int64 = y0
    while sy < y1:
        nrows: int64 = band_rows
        if sy + nrows > y1:
            nrows = y1 - sy
        bo: uint64 = 0
        ry: int64 = 0
        while ry < nrows:
            scr_y: int64 = sy + ry
            so: uint64 = scene_off(x0, scr_y)
            sx: int64 = x0
            while sx < x1:
                rr[0] = SCENE_CACHE[so]
                gg[0] = SCENE_CACHE[so + 1]
                bb[0] = SCENE_CACHE[so + 2]
                # Overlay the cursor sprite on the wire (never in the cache).
                cursor_pixel_over(sx, scr_y, &rr[0], &gg[0], &bb[0])
                screen_band[bo]     = rr[0]
                screen_band[bo + 1] = gg[0]
                screen_band[bo + 2] = bb[0]
                screen_band[bo + 3] = 255
                so = so + 4
                bo = bo + 4
                sx = sx + 1
            ry = ry + 1
        if fbctl_present_rect(cast[uint64](x0), cast[uint64](sy),
                              cast[uint64](rw), cast[uint64](nrows),
                              cast[uint64](&screen_band[0]),
                              cast[uint64](rw), 0, 0) == 0:
            if wf < 0:
                pw: Ptr[uint8] = "/dev/fb"
                wf = sys_open_write(cast[Ptr[char]](pw))
            if wf >= 0:
                if full_width != 0:
                    byte_off: int64 = (sy * sw + x0) * 4
                    sys_lseek(wf, byte_off, SEEK_SET_HUI)
                    sys_write(wf, &screen_band[0], seg_bytes * cast[uint64](nrows))
                else:
                    fr: int64 = 0
                    while fr < nrows:
                        rsy: int64 = sy + fr
                        byte_off2: int64 = (rsy * sw + x0) * 4
                        sys_lseek(wf, byte_off2, SEEK_SET_HUI)
                        sys_write(wf, &screen_band[cast[uint64](fr) * seg_bytes],
                                  seg_bytes)
                        fr = fr + 1
        sy = sy + nrows
    if wf >= 0:
        sys_close(wf)


# DE-perf FPS marker. No-op unless /etc/de-fps-test was present at daemon
# startup (FPS_GATE=1). Emits "[fps] frame N\n" to fd 1; scripts/test_de_fps.sh
# greps the serial log to count compositor frames over a wall-clock window.
def fps_marker():
    if FPS_GATE == 0:
        return
    p: uint64 = 0
    pfx: Ptr[uint8] = "[fps] frame "
    k: uint64 = 0
    while pfx[k] != 0:
        fps_line_buf[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](FPS_FRAME), &fps_line_buf[p])
    fps_line_buf[p] = 10
    p = p + 1
    sys_write(1, &fps_line_buf[0], p)
    FPS_FRAME = FPS_FRAME + 1


# Composite one screen frame from the daemon model and present it to
# /dev/fb, one row at a time (bounded userland memory). Returns 0 / 1.
def daemon_present() -> int32:
    fps_marker()
    notif_count_refresh()
    enforce_ontop_order()
    # DEPERF #409: refresh per-window backbuffers before compositing so
    # daemon_pixel reads cache-valid windows from their cached surface and
    # only content-dirty windows are re-rendered.
    window_cache_sync()
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    # DEPERF #410: full present = the ONE allowed full-screen daemon_pixel
    # pass. Re-evaluate the whole cursor-free scene into SCENE_CACHE, then
    # blit it (with the cursor sprite overlaid) to scanout. Every PARTIAL
    # present afterwards is a pure SCENE_CACHE blit — no scene-graph walk.
    scene_build_full()
    scene_blit_rect(0, 0, cast[int64](sw), cast[int64](sh))
    # A full-screen present supersedes any pending damage and re-seeds the
    # last-presented cursor position (for the cursor fast-path below).
    DAMAGE_PENDING = 0
    LAST_CUR_X = CUR_X
    LAST_CUR_Y = CUR_Y
    # DEPERF stats: a full present touched every screen pixel.
    DMG_LAST_AREA = cast[int64](sw) * cast[int64](sh)
    DMG_LAST_FULL = 1
    return 0


# --- P1a: dirty-rectangle present -----------------------------------
#
# Re-composite + present ONLY the screen rectangle [x0,x1) x [y0,y1).
# daemon_pixel evaluates the full scene graph for each pixel it touches,
# so the work scales with the rect AREA, not the whole screen. We seek
# /dev/fb to each row's pixel offset (row*W + x0)*4 and write that row's
# run — the DEV_FB cdev is offset-addressed, so a partial-row write lands
# exactly where seeked. This is the per-frame fast path: most frames only
# move the cursor (a 12x12 sprite) or dirty one window's content, so they
# touch a few hundred pixels instead of ~1M.
SEEK_SET_HUI: int32 = 0
extern def sys_lseek(fd: int32, offset: int64, whence: int32) -> int64


def daemon_present_rect(x0: int64, y0: int64, x1: int64, y1: int64) -> int32:
    # DEPERF #409: refresh per-window backbuffers before this partial
    # composite. A pure window move leaves every cache valid (rerendered==0)
    # so the rect is blitted from cache; a content-dirty window is refilled
    # once here, then read from cache for each pixel in the rect. markup_sync's
    # EXPENSIVE /dev/wsys body reads are GEN-GATED (EVLOOP: per-layer gen
    # counter, plus the one-shot MARKUP_DUE latch), so a window-move present
    # pays no markup body I/O when no client repainted.
    window_cache_sync()
    sw: int64 = cast[int64](FBG_W)
    sh: int64 = cast[int64](FBG_H)
    # Clip to the screen.
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > sw:
        x1 = sw
    if y1 > sh:
        y1 = sh
    if x0 >= x1 or y0 >= y1:
        return 0
    rw: int64 = x1 - x0
    if rw > cast[int64](SCREEN_ROW_MAXW):
        rw = cast[int64](SCREEN_ROW_MAXW)
        x1 = x0 + rw
    # DEPERF #410: if a full scene build hasn't run yet (cold cache), build the
    # whole cursor-free scene once so the blit below has valid pixels; after
    # that this path only touches the damaged rect.
    if SCENE_VALID == 0:
        scene_build_full()
    # Re-evaluate the procedural scene (daemon_pixel) over JUST this rect INTO
    # SCENE_CACHE — the ONLY scene-graph work, area-scaled — then blit the rect
    # (cursor overlaid) to scanout. No per-pixel scene walk on the wire.
    scene_build_rect(x0, y0, x1, y1)
    scene_blit_rect(x0, y0, x1, y1)
    # DEPERF stats: record the pixel area this partial present touched so
    # the perf self-test can assert it stays bounded by the changed region
    # (and does NOT grow with the number of open windows).
    DMG_LAST_AREA = rw * (y1 - y0)
    DMG_LAST_FULL = 0
    return 0


# DEPERF #410: blit a 12x12 cursor cell straight from SCENE_CACHE (cursor
# sprite overlaid by scene_blit_rect via CUR_X/CUR_Y). Clips to the screen.
# NO daemon_pixel, NO window_cache_sync, NO markup file I/O.
def scene_blit_cursor_cell(cx: int64, cy: int64):
    sw: int64 = cast[int64](FBG_W)
    sh: int64 = cast[int64](FBG_H)
    x0: int64 = cx
    y0: int64 = cy
    x1: int64 = cx + CURSOR_SPRITE
    y1: int64 = cy + CURSOR_SPRITE
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > sw:
        x1 = sw
    if y1 > sh:
        y1 = sh
    if x0 >= x1 or y0 >= y1:
        return
    scene_blit_rect(x0, y0, x1, y1)


# Move the software cursor cheaply: blit the rectangle the cursor just
# vacated (restoring the cached scene there — the sprite is NOT in
# SCENE_CACHE so it simply disappears) and the rectangle it now occupies
# (scene_blit_rect overlays the sprite at CUR_X/CUR_Y). Each is a 12x12
# memory copy — ~288 pixels total — with ZERO daemon_pixel calls, ZERO
# window-cache sync, and ZERO markup /dev/wsys file reads. This is the
# frozen-mouse fix: a pure pointer move never walks the scene graph or
# touches a file.
CURSOR_SPRITE: int64 = 12
def daemon_present_cursor_move() -> int32:
    # On a cold cache (no full build yet) fall back to a full present once so
    # SCENE_CACHE is valid; thereafter pure blits.
    if SCENE_VALID == 0:
        daemon_present()
        return 0
    ox: int64 = LAST_CUR_X
    oy: int64 = LAST_CUR_Y
    nx: int64 = CUR_X
    ny: int64 = CUR_Y
    # Erase the old cell first (CUR_X/CUR_Y already point at the new spot, so
    # the old cell gets the cursor-free cached scene), then draw the new cell.
    scene_blit_cursor_cell(ox, oy)
    scene_blit_cursor_cell(nx, ny)
    LAST_CUR_X = nx
    LAST_CUR_Y = ny
    return 0


# ====================================================================
# DEPERF — per-frame dirty-rectangle accumulation
# ====================================================================
# The main loop calls damage_rect() for each thing that changed this frame
# (a window emitting output, a hover highlight, a notification banner...),
# then calls daemon_flush_damage() once at the end of the frame to present
# the UNION of those rects via the area-scaled daemon_present_rect. This
# replaces the old "set full_need=1 -> daemon_present()" (full-screen,
# O(W*H*windows)) path that ran on almost every event.

def damage_reset():
    DMG_VALID = 0
    DMG_FULL = 0


# Union the inclusive-exclusive box [x0,x1) x [y0,y1) into the frame's
# accumulated damage. A degenerate (empty) box is ignored.
def damage_rect(x0: int64, y0: int64, x1: int64, y1: int64):
    if x0 >= x1 or y0 >= y1:
        return
    if DMG_VALID == 0:
        DMG_X0 = x0
        DMG_Y0 = y0
        DMG_X1 = x1
        DMG_Y1 = y1
        DMG_VALID = 1
        return
    if x0 < DMG_X0:
        DMG_X0 = x0
    if y0 < DMG_Y0:
        DMG_Y0 = y0
    if x1 > DMG_X1:
        DMG_X1 = x1
    if y1 > DMG_Y1:
        DMG_Y1 = y1


# Damage the on-screen rectangle of one window slot (its full frame —
# border + title + body). Used when a window emits output, gains/loses a
# hover highlight, or its focus chrome changes. O(window area), not screen.
def damage_window(slot: uint64):
    if slot >= DWIN_COUNT:
        return
    # DEPERF #409: damage_window is only ever raised when a window's SURFACE
    # changed (shell output, button-hover tint, app-body refresh, focus
    # chrome) — a pure MOVE escalates to damage_full instead and never lands
    # here. So mark the window content-dirty so its backbuffer is refilled
    # before the next composite. (A move's damage_full leaves caches valid,
    # which is exactly the fast path we want.)
    DWIN_CONTENT_DIRTY[slot] = 1
    damage_rect(DWIN_X[slot], DWIN_Y[slot],
                DWIN_X[slot] + DWIN_W[slot],
                DWIN_Y[slot] + DWIN_H[slot])


# Damage the full-width panel band (clock tick, taskbar urgency blink,
# tray applet refresh). The bar is PANEL_H tall and spans the screen width,
# so this is ~PANEL_H/H of a full present — a big win for the once-a-second
# clock/stat refresh that used to force a whole-screen recomposite.
def damage_panel():
    py0: int64 = panel_y0()
    damage_rect(0, py0, cast[int64](FBG_W), py0 + PANEL_H)


# Damage the desktop system-monitor applet rect (the CPU/MEM history graph
# painted on the root), refreshed once a second alongside the clock.
def damage_dmon_applet():
    dmx0: int64 = dmon_x0(cast[int64](FBG_W))
    dmy0: int64 = dmon_y0(cast[int64](FBG_H))
    damage_rect(dmx0, dmy0, dmx0 + DMON_W, dmy0 + DMON_H)


# Escalate to a whole-screen repaint (workspace switch, wallpaper / theme
# recolour, panel slide, any change whose extent we can't cheaply bound).
def damage_full():
    DMG_FULL = 1
    DMG_VALID = 1


# ====================================================================
# DE perf P0-B: damage-clip the interactive (drag / move / resize /
# menu) regime. Previously every motion packet during a drag / menu
# escalated to damage_full() -> daemon_present() -> scene_build_full()
# (the ~1267-line per-pixel cascade over the whole framebuffer). That
# threw out the #410 SCENE_CACHE every interactive frame. The helpers
# below convert each interactive state into damage_rect(old_bbox U
# new_bbox) so SCENE_CACHE stays valid for the unchanged pixels — only
# the dirty bbox(es) get rebuilt via scene_build_rect.
# ====================================================================

# Previous-frame bboxes for interactive states. Tracked across frames so
# the union (old, new) covers the trailing-edge area the moving object
# vacated (must be repainted with whatever sits beneath it).
PREV_RB_VALID:    int32 = 0
PREV_RB_X0:       int64 = 0
PREV_RB_Y0:       int64 = 0
PREV_RB_X1:       int64 = 0
PREV_RB_Y1:       int64 = 0
PREV_MOVE_VALID:  int32 = 0
PREV_MOVE_X0:     int64 = 0
PREV_MOVE_Y0:     int64 = 0
PREV_MOVE_X1:     int64 = 0
PREV_MOVE_Y1:     int64 = 0
PREV_RESIZE_VALID: int32 = 0
PREV_RESIZE_X0:   int64 = 0
PREV_RESIZE_Y0:   int64 = 0
PREV_RESIZE_X1:   int64 = 0
PREV_RESIZE_Y1:   int64 = 0
PREV_POPUP_VALID: int32 = 0
PREV_POPUP_X0:    int64 = 0
PREV_POPUP_Y0:    int64 = 0
PREV_POPUP_X1:    int64 = 0
PREV_POPUP_Y1:    int64 = 0


# Current-frame rubber-band bbox (1px outline of the in-progress drag
# rect), or (0,0,0,0) when no drag is active. The band is a 1-pixel-thick
# outline so the damage is O(perimeter), not O(area), but for simplicity
# we damage the bbox (the daemon_pixel cascade inside the bbox is the
# small cost, and the outline overlay below paints the visible 4 spans).
def rb_bbox(out_x0: Ptr[int64], out_y0: Ptr[int64],
            out_x1: Ptr[int64], out_y1: Ptr[int64]) -> int32:
    if DRAG_ACTIVE == 0:
        out_x0[0] = 0
        out_y0[0] = 0
        out_x1[0] = 0
        out_y1[0] = 0
        return 0
    out_x0[0] = imin(DRAG_X0, CUR_X)
    out_y0[0] = imin(DRAG_Y0, CUR_Y)
    # Outline is 1px wide so the [x0,x1) exclusive box must include the
    # right/bottom edge pixel — extend by +1 so the overlay paint clips
    # correctly.
    out_x1[0] = imax(DRAG_X0, CUR_X) + 1
    out_y1[0] = imax(DRAG_Y0, CUR_Y) + 1
    return 1


# Current-frame window-move bbox: the frame of the slot under MOVE_SLOT
# at its CURRENT position (DWIN_X/Y/W/H already moved by wm_button).
def move_bbox(out_x0: Ptr[int64], out_y0: Ptr[int64],
              out_x1: Ptr[int64], out_y1: Ptr[int64]) -> int32:
    if MOVE_SLOT < 0:
        out_x0[0] = 0
        out_y0[0] = 0
        out_x1[0] = 0
        out_y1[0] = 0
        return 0
    ms: uint64 = cast[uint64](MOVE_SLOT)
    if ms >= DWIN_COUNT:
        return 0
    out_x0[0] = DWIN_X[ms]
    out_y0[0] = DWIN_Y[ms]
    out_x1[0] = DWIN_X[ms] + DWIN_W[ms]
    out_y1[0] = DWIN_Y[ms] + DWIN_H[ms]
    return 1


# Current-frame resize bbox.
def resize_bbox(out_x0: Ptr[int64], out_y0: Ptr[int64],
                out_x1: Ptr[int64], out_y1: Ptr[int64]) -> int32:
    if RESIZE_SLOT < 0:
        out_x0[0] = 0
        out_y0[0] = 0
        out_x1[0] = 0
        out_y1[0] = 0
        return 0
    rs: uint64 = cast[uint64](RESIZE_SLOT)
    if rs >= DWIN_COUNT:
        return 0
    out_x0[0] = DWIN_X[rs]
    out_y0[0] = DWIN_Y[rs]
    out_x1[0] = DWIN_X[rs] + DWIN_W[rs]
    out_y1[0] = DWIN_Y[rs] + DWIN_H[rs]
    return 1


# Current-frame popup union bbox covering all open popup overlays
# (menubar drop, context menu, calendar drop, run dialog, cycler).
# Returns 1 if at least one popup is open + the union was computed,
# else 0. SESSION_OPEN / SEARCH_OPEN / KMODE escalate to full-screen
# upstream (rare states) so they are NOT folded into the popup union
# here — the upstream damage_full() takes care of them.
def popup_bbox(out_x0: Ptr[int64], out_y0: Ptr[int64],
               out_x1: Ptr[int64], out_y1: Ptr[int64]) -> int32:
    any_open: int32 = 0
    ax0: int64 = 0
    ay0: int64 = 0
    ax1: int64 = 0
    ay1: int64 = 0
    # Menubar drop (Applications / Places / System).
    if MENU_BAR_OPEN >= 0:
        mx0: int64 = menubar_drop_x()
        my0: int64 = 0
        mx1: int64 = mx0 + menubar_drop_w()
        # Drop covers the panel band + the menu drop height; just use the
        # full panel-rooted column down to a generous height (any submenu
        # flyout sits to the right but we union below).
        my1: int64 = drop_anchor_y(menubar_total_h()) + menubar_total_h()
        if any_open == 0:
            ax0 = mx0
            ay0 = my0
            ax1 = mx1
            ay1 = my1
            any_open = 1
        else:
            if mx0 < ax0:
                ax0 = mx0
            if my0 < ay0:
                ay0 = my0
            if mx1 > ax1:
                ax1 = mx1
            if my1 > ay1:
                ay1 = my1
        # Applications submenu flyout (if any).
        if MENU_BAR_OPEN == 0 and SUBMENU_OPEN >= 0:
            sx0: int64 = mx1
            sy0: int64 = drop_anchor_y(menubar_total_h())
            sx1: int64 = sx0 + SUBMENU_W
            sy1: int64 = sy0 + appcat_item_count(SUBMENU_OPEN) * MENU_ITEM_H
            if sx0 < ax0:
                ax0 = sx0
            if sy0 < ay0:
                ay0 = sy0
            if sx1 > ax1:
                ax1 = sx1
            if sy1 > ay1:
                ay1 = sy1
    # Right-click context menu.
    if CTX_OPEN != 0:
        cx0: int64 = CTX_X
        cy0: int64 = CTX_Y
        cx1: int64 = CTX_X + CTX_W
        cy1: int64 = CTX_Y + ctx_total_h()
        if any_open == 0:
            ax0 = cx0
            ay0 = cy0
            ax1 = cx1
            ay1 = cy1
            any_open = 1
        else:
            if cx0 < ax0:
                ax0 = cx0
            if cy0 < ay0:
                ay0 = cy0
            if cx1 > ax1:
                ax1 = cx1
            if cy1 > ay1:
                ay1 = cy1
    # Calendar drop.
    if CAL_OPEN != 0:
        kx0: int64 = cal_drop_x(cast[int64](FBG_W))
        ky0: int64 = cal_drop_y()
        kx1: int64 = kx0 + CAL_W
        ky1: int64 = ky0 + cal_total_h()
        if any_open == 0:
            ax0 = kx0
            ay0 = ky0
            ax1 = kx1
            ay1 = ky1
            any_open = 1
        else:
            if kx0 < ax0:
                ax0 = kx0
            if ky0 < ay0:
                ay0 = ky0
            if kx1 > ax1:
                ax1 = kx1
            if ky1 > ay1:
                ay1 = ky1
    # Run dialog.
    if RUN_OPEN != 0:
        rdx0: int64 = run_x(cast[int64](FBG_W))
        rdy0: int64 = run_y(cast[int64](FBG_H))
        rdx1: int64 = rdx0 + RUN_W
        rdy1: int64 = rdy0 + run_total_h()
        if any_open == 0:
            ax0 = rdx0
            ay0 = rdy0
            ax1 = rdx1
            ay1 = rdy1
            any_open = 1
        else:
            if rdx0 < ax0:
                ax0 = rdx0
            if rdy0 < ay0:
                ay0 = rdy0
            if rdx1 > ax1:
                ax1 = rdx1
            if rdy1 > ay1:
                ay1 = rdy1
    # Alt-tab cycler popup (centred). We damage a generous central bbox.
    if CYCLE_OPEN != 0:
        cn: int64 = cycle_visible_count()
        if cn < 1:
            cn = 1
        ch: int64 = cn * CYC_ROW_H + CYC_PAD * 2
        cxx: int64 = cast[int64](FBG_W) / 2 - CYC_W / 2
        cyy: int64 = cast[int64](FBG_H) / 2 - ch / 2
        if cxx < 0:
            cxx = 0
        if cyy < PANEL_H:
            cyy = PANEL_H
        cx0b: int64 = cxx
        cy0b: int64 = cyy
        cx1b: int64 = cxx + CYC_W
        cy1b: int64 = cyy + ch
        if any_open == 0:
            ax0 = cx0b
            ay0 = cy0b
            ax1 = cx1b
            ay1 = cy1b
            any_open = 1
        else:
            if cx0b < ax0:
                ax0 = cx0b
            if cy0b < ay0:
                ay0 = cy0b
            if cx1b > ax1:
                ax1 = cx1b
            if cy1b > ay1:
                ay1 = cy1b
    out_x0[0] = ax0
    out_y0[0] = ay0
    out_x1[0] = ax1
    out_y1[0] = ay1
    return any_open


# Damage union (prev-frame, current-frame) for one of the interactive
# states. Each helper reads its PREV_* globals (set at the end of the
# previous frame), unions with the CURRENT bbox, calls damage_rect for
# each, and updates PREV_* for the next frame.
def damage_rb_old_new() -> int32:
    nx0: Array[1, int64]
    ny0: Array[1, int64]
    nx1: Array[1, int64]
    ny1: Array[1, int64]
    cur_valid: int32 = rb_bbox(&nx0[0], &ny0[0], &nx1[0], &ny1[0])
    if PREV_RB_VALID != 0:
        damage_rect(PREV_RB_X0, PREV_RB_Y0, PREV_RB_X1, PREV_RB_Y1)
    if cur_valid != 0:
        damage_rect(nx0[0], ny0[0], nx1[0], ny1[0])
        PREV_RB_X0 = nx0[0]
        PREV_RB_Y0 = ny0[0]
        PREV_RB_X1 = nx1[0]
        PREV_RB_Y1 = ny1[0]
        PREV_RB_VALID = 1
    else:
        PREV_RB_VALID = 0
    return cur_valid | PREV_RB_VALID


def damage_move_old_new() -> int32:
    nx0: Array[1, int64]
    ny0: Array[1, int64]
    nx1: Array[1, int64]
    ny1: Array[1, int64]
    cur_valid: int32 = move_bbox(&nx0[0], &ny0[0], &nx1[0], &ny1[0])
    if PREV_MOVE_VALID != 0:
        damage_rect(PREV_MOVE_X0, PREV_MOVE_Y0, PREV_MOVE_X1, PREV_MOVE_Y1)
    if cur_valid != 0:
        damage_rect(nx0[0], ny0[0], nx1[0], ny1[0])
        PREV_MOVE_X0 = nx0[0]
        PREV_MOVE_Y0 = ny0[0]
        PREV_MOVE_X1 = nx1[0]
        PREV_MOVE_Y1 = ny1[0]
        PREV_MOVE_VALID = 1
    else:
        PREV_MOVE_VALID = 0
    return cur_valid | PREV_MOVE_VALID


def damage_resize_old_new() -> int32:
    nx0: Array[1, int64]
    ny0: Array[1, int64]
    nx1: Array[1, int64]
    ny1: Array[1, int64]
    cur_valid: int32 = resize_bbox(&nx0[0], &ny0[0], &nx1[0], &ny1[0])
    if PREV_RESIZE_VALID != 0:
        damage_rect(PREV_RESIZE_X0, PREV_RESIZE_Y0,
                    PREV_RESIZE_X1, PREV_RESIZE_Y1)
    if cur_valid != 0:
        damage_rect(nx0[0], ny0[0], nx1[0], ny1[0])
        PREV_RESIZE_X0 = nx0[0]
        PREV_RESIZE_Y0 = ny0[0]
        PREV_RESIZE_X1 = nx1[0]
        PREV_RESIZE_Y1 = ny1[0]
        PREV_RESIZE_VALID = 1
    else:
        PREV_RESIZE_VALID = 0
    return cur_valid | PREV_RESIZE_VALID


def damage_popup_old_new() -> int32:
    nx0: Array[1, int64]
    ny0: Array[1, int64]
    nx1: Array[1, int64]
    ny1: Array[1, int64]
    cur_valid: int32 = popup_bbox(&nx0[0], &ny0[0], &nx1[0], &ny1[0])
    if PREV_POPUP_VALID != 0:
        damage_rect(PREV_POPUP_X0, PREV_POPUP_Y0,
                    PREV_POPUP_X1, PREV_POPUP_Y1)
    if cur_valid != 0:
        damage_rect(nx0[0], ny0[0], nx1[0], ny1[0])
        PREV_POPUP_X0 = nx0[0]
        PREV_POPUP_Y0 = ny0[0]
        PREV_POPUP_X1 = nx1[0]
        PREV_POPUP_Y1 = ny1[0]
        PREV_POPUP_VALID = 1
    else:
        PREV_POPUP_VALID = 0
    return cur_valid | PREV_POPUP_VALID


# Paint a 1-pixel-thick rubber-band-style rectangle OUTLINE straight to
# /dev/fb after the damage rect has been blitted. This hoists the
# rubber-band edge test OUT of the per-pixel daemon_pixel cascade (which
# previously evaluated `if x==rx0 or x==rx1 or y==ry0 or y==ry1` at
# every screen pixel) into a tiny O(perimeter) overlay. SCENE_CACHE is
# NOT modified — the outline lives only on scanout, like the cursor
# sprite, so the next full present rebuilds the cache without it.
def scene_blit_rect_outline(x0: int64, y0: int64, x1: int64, y1: int64,
                            r: uint8, g: uint8, b: uint8):
    sw: int64 = cast[int64](FBG_W)
    sh: int64 = cast[int64](FBG_H)
    # Clip the outline rect to the screen.
    if x0 < 0:
        x0 = 0
    if y0 < 0:
        y0 = 0
    if x1 > sw:
        x1 = sw
    if y1 > sh:
        y1 = sh
    if x0 >= x1 or y0 >= y1:
        return
    rw: int64 = x1 - x0
    rh: int64 = y1 - y0
    if rw > cast[int64](SCREEN_ROW_MAXW):
        rw = cast[int64](SCREEN_ROW_MAXW)
        x1 = x0 + rw
    # Fill ONE row of the screen_band buffer with the outline colour
    # (RGBA, alpha=255). We reuse this row for the top + bottom 1px
    # spans, and emit single-pixel writes for the left + right 1px
    # spans. screen_band is 1 MiB so it comfortably holds one row.
    cap: uint64 = cast[uint64](rw) * 4
    fb: uint64 = 0
    while fb < cap:
        screen_band[fb]     = r
        screen_band[fb + 1] = g
        screen_band[fb + 2] = b
        screen_band[fb + 3] = 255
        fb = fb + 4
    wf: int32 = -1
    # --- top span: 1 row, full width ---
    if fbctl_present_rect(cast[uint64](x0), cast[uint64](y0),
                          cast[uint64](rw), 1,
                          cast[uint64](&screen_band[0]),
                          cast[uint64](rw), 0, 0) == 0:
        if wf < 0:
            pw: Ptr[uint8] = "/dev/fb"
            wf = sys_open_write(cast[Ptr[char]](pw))
        if wf >= 0:
            bo: int64 = (y0 * sw + x0) * 4
            sys_lseek(wf, bo, SEEK_SET_HUI)
            sys_write(wf, &screen_band[0], cap)
    # --- bottom span: 1 row, full width ---
    if rh >= 2:
        by: int64 = y1 - 1
        if fbctl_present_rect(cast[uint64](x0), cast[uint64](by),
                              cast[uint64](rw), 1,
                              cast[uint64](&screen_band[0]),
                              cast[uint64](rw), 0, 0) == 0:
            if wf < 0:
                pw2: Ptr[uint8] = "/dev/fb"
                wf = sys_open_write(cast[Ptr[char]](pw2))
            if wf >= 0:
                bo2: int64 = (by * sw + x0) * 4
                sys_lseek(wf, bo2, SEEK_SET_HUI)
                sys_write(wf, &screen_band[0], cap)
    # --- left + right spans: 1 column each, from y0+1 to y1-1 ---
    if rh >= 2:
        # Reuse the front 4 bytes of screen_band for a single pixel.
        screen_band[0] = r
        screen_band[1] = g
        screen_band[2] = b
        screen_band[3] = 255
        ly: int64 = y0 + 1
        ey: int64 = y1 - 1
        while ly < ey:
            # Left edge.
            if fbctl_present_rect(cast[uint64](x0), cast[uint64](ly),
                                  1, 1,
                                  cast[uint64](&screen_band[0]),
                                  1, 0, 0) == 0:
                if wf < 0:
                    pw3: Ptr[uint8] = "/dev/fb"
                    wf = sys_open_write(cast[Ptr[char]](pw3))
                if wf >= 0:
                    lbo: int64 = (ly * sw + x0) * 4
                    sys_lseek(wf, lbo, SEEK_SET_HUI)
                    sys_write(wf, &screen_band[0], 4)
            # Right edge (if rect is wider than 1).
            if rw >= 2:
                rxc: int64 = x1 - 1
                if fbctl_present_rect(cast[uint64](rxc), cast[uint64](ly),
                                      1, 1,
                                      cast[uint64](&screen_band[0]),
                                      1, 0, 0) == 0:
                    if wf < 0:
                        pw4: Ptr[uint8] = "/dev/fb"
                        wf = sys_open_write(cast[Ptr[char]](pw4))
                    if wf >= 0:
                        rbo: int64 = (ly * sw + rxc) * 4
                        sys_lseek(wf, rbo, SEEK_SET_HUI)
                        sys_write(wf, &screen_band[0], 4)
            ly = ly + 1
    if wf >= 0:
        sys_close(wf)


# Post-present overlay: republish the rubber-band model and let the
# /bin/hamrband v2 client rasterise the dashed outline into its own
# backbuffer (DE pivot wave 7 — RUBBER-BAND outline rendering EXTRACTED).
# The previous in-daemon scene_blit_rect_outline call is gone; the
# RENDER moved out into a separate-process client exactly like the
# panel/appmenu/cycler/calpop/run/lock waves before it. See
# rband_publish_snapshot() + rband_spawn() + rband_poke_set() below,
# the snapshot on /dev/wsys/rband, and the set verb on /dev/wsys/rband/set.
def post_present_overlays():
    # DE pivot wave 7: RUBBER-BAND outline rendering EXTRACTED into
    # /bin/hamrband. The previous in-daemon overlay paint is gone;
    # we just republish the model so the v2 client repaints.
    rband_publish_if_changed()
    # DE pivot wave 8: End Session dialog rendering EXTRACTED into
    # /bin/hamsessui. Republish (open, hover) diff on every frame so the
    # client repaints when the user moves between rows.
    sessui_publish_if_changed()
    # DE pivot wave 1 (round 2): desktop icon badges EXTRACTED into
    # /bin/hamdesktop. Republish (count, drag) diff per frame.
    desktop_publish_if_changed()
    # DE pivot wave 2 (round 2): system-monitor applet EXTRACTED into
    # /bin/hamsysmon. Republish (cpu, mem) diff per frame.
    sysmon_publish_if_changed()
    # DE pivot wave 3 (round 2): context menu EXTRACTED into /bin/hamctxmenu.
    ctxmenu_publish_if_changed()
    # DE pivot wave 4 (round 2): snap preview EXTRACTED into /bin/hamsnap.
    snap_publish_if_changed()
    # DE pivot wave 5 (round 2): resize/kmode frame EXTRACTED into /bin/hamresize.
    resize_publish_if_changed()
    # DE pivot wave 6 (round 2): OSD popup EXTRACTED into /bin/hamosd.
    osd_publish_if_changed()
    # DE pivot wave 7 (round 2): message tray EXTRACTED into /bin/hamtray.
    tray_publish_if_changed()
    # #442 (c): blit any v2 windows' kernel-side backbuffers directly to
    # scanout. v2 windows BYPASS the daemon_pixel cascade entirely — the
    # body pixels come straight from the kernel's per-window backbuffer
    # via /dev/wsys/<wid>/backbuffer. v0/v1 windows are untouched.
    v2_present_dirty_windows()


# ====================================================================
# #442 (c) RIO BLIT PROTOCOL — compositor adoption.
# ====================================================================
#
# For each daemon window flagged DWIN_PROTO_V2[slot] == 1, the
# compositor STOPS running daemon_pixel over its area. Instead it reads
# /dev/wsys/<wid>/bbstate to learn the v2 dirty rect, then reads the
# matching slice of /dev/wsys/<wid>/backbuffer and writes those pixels
# directly to /dev/fb at the window's screen position. ONE memcpy per
# damaged client rect; no per-pixel scene-graph walk.

DWIN_PROTO_V2: Array[8, int32]      # 1 = this window opted into v2

# Kernel-side backbuffer dims (must mirror the kernel constants in
# sys/src/9/port/devwsys.ad — same shape lib/hamui.ad exposes).
V2_BB_W: uint64 = 1280
V2_BB_H: uint64 = 800
V2_BB_STRIDE: uint64 = 5120
V2_BB_BYTES_PER_WIN: uint64 = 4096000

# Per-window last-seen v2 frame serial. The compositor skips a window
# whose serial has not advanced.
V2_LAST_SERIAL: Array[8, uint64]

# Scratch for the bbstate line + one row of backbuffer pixels.
v2_bbstate_buf: Array[256, uint8]
v2_row_buf: Array[8192, uint8]      # cap one v2 row (W*4 = 5120B) + slack


def v2_path_buf_for(wid: int32, leaf: Ptr[uint8], out: Ptr[uint8]):
    # "/dev/wsys/<wid>/<leaf>\0" into out[].
    i: uint64 = 0
    p: Ptr[uint8] = "/dev/wsys/"
    while p[i] != 0:
        out[i] = p[i]
        i = i + 1
    # decimal wid
    w: int32 = wid
    digs: Array[8, uint8]
    d: uint64 = 0
    if w == 0:
        digs[0] = 48
        d = 1
    while w > 0:
        digs[d] = cast[uint8](w % 10) + 48
        w = w / 10
        d = d + 1
    while d > 0:
        d = d - 1
        out[i] = digs[d]
        i = i + 1
    out[i] = 47                                  # '/'
    i = i + 1
    j: uint64 = 0
    while leaf[j] != 0:
        out[i] = leaf[j]
        i = i + 1
        j = j + 1
    out[i] = 0


def v2_parse_decimal_u64(buf: Ptr[uint8], pos: uint64, end: uint64,
                         out: Ptr[uint64]) -> uint64:
    # Skip leading whitespace, then read decimal digits into *out.
    # Returns the position just past the last digit consumed.
    p: uint64 = pos
    while p < end and (buf[p] == 32 or buf[p] == 9):
        p = p + 1
    v: uint64 = 0
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c) - 48
        p = p + 1
    out[0] = v
    return p


def v2_parse_decimal_i64(buf: Ptr[uint8], pos: uint64, end: uint64,
                         out: Ptr[int64]) -> uint64:
    p: uint64 = pos
    while p < end and (buf[p] == 32 or buf[p] == 9):
        p = p + 1
    neg: int32 = 0
    if p < end and buf[p] == 45:                # '-'
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[int64](c) - 48
        p = p + 1
    if neg != 0:
        v = -v
    out[0] = v
    return p


def v2_read_bbstate(wid: int32, ver_out: Ptr[uint64],
                    serial_out: Ptr[uint64],
                    x0_out: Ptr[int64], y0_out: Ptr[int64],
                    x1_out: Ptr[int64], y1_out: Ptr[int64]) -> int32:
    # Returns 1 on success (fields filled), 0 on read failure / wid unused.
    path_local: Array[64, uint8]
    v2_path_buf_for(wid, "bbstate", &path_local[0])
    fd: int32 = sys_open(cast[Ptr[char]](&path_local[0]))
    if fd < 0:
        return 0
    n: int64 = sys_read(fd, &v2_bbstate_buf[0], 256)
    sys_close(fd)
    if n <= 0:
        return 0
    end: uint64 = cast[uint64](n)
    pos: uint64 = 0
    pos = v2_parse_decimal_u64(&v2_bbstate_buf[0], pos, end, ver_out)
    pos = v2_parse_decimal_u64(&v2_bbstate_buf[0], pos, end, serial_out)
    pos = v2_parse_decimal_i64(&v2_bbstate_buf[0], pos, end, x0_out)
    pos = v2_parse_decimal_i64(&v2_bbstate_buf[0], pos, end, y0_out)
    pos = v2_parse_decimal_i64(&v2_bbstate_buf[0], pos, end, x1_out)
    pos = v2_parse_decimal_i64(&v2_bbstate_buf[0], pos, end, y1_out)
    return 1


def v2_blit_window_dirty_rect(slot: uint64, wid: int32,
                              dx0: int64, dy0: int64,
                              dx1: int64, dy1: int64):
    # Read the dirty rect's pixels out of /dev/wsys/<wid>/backbuffer and
    # write them straight to /dev/fb at the window's screen position
    # (body origin = window x+2, y+title_h). Done one row at a time so
    # the scratch stays bounded.
    if dx1 <= dx0 or dy1 <= dy0:
        return
    # Clip to backbuffer dims.
    cx0: int64 = dx0
    cy0: int64 = dy0
    cx1: int64 = dx1
    cy1: int64 = dy1
    if cx0 < 0:
        cx0 = 0
    if cy0 < 0:
        cy0 = 0
    if cx1 > cast[int64](V2_BB_W):
        cx1 = cast[int64](V2_BB_W)
    if cy1 > cast[int64](V2_BB_H):
        cy1 = cast[int64](V2_BB_H)
    if cx1 <= cx0 or cy1 <= cy0:
        return
    row_w: int64 = cx1 - cx0
    row_bytes: int64 = row_w * 4
    # v2_row_buf is sized 8192 to fit one full-screen-width row
    # (1280 px * 4 B = 5120 B) plus slack. Don't overflow it.
    if row_bytes > 8192:
        row_bytes = 8192
    # Open backbuffer for reading.
    bb_path: Array[64, uint8]
    v2_path_buf_for(wid, "backbuffer", &bb_path[0])
    bb_fd: int32 = sys_open(cast[Ptr[char]](&bb_path[0]))
    if bb_fd < 0:
        return
    # Open /dev/fb for writing.
    fbp: Ptr[uint8] = "/dev/fb"
    fb_fd: int32 = sys_open_write(cast[Ptr[char]](fbp))
    if fb_fd < 0:
        sys_close(bb_fd)
        return
    # Window screen origin (body-corner = x+2, y+title_h, or (x,y) for
    # chromeless panel/overlay clients whose backbuffer covers the
    # whole window rect).
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    bx0_screen: int64 = wx + 2
    by0_screen: int64 = wy + title_h_of(slot)
    if DWIN_CHROMELESS[slot] != 0:
        bx0_screen = wx
        by0_screen = wy
    sw: int64 = cast[int64](FBG_W)
    yy: int64 = cy0
    while yy < cy1:
        # Seek backbuffer to (yy, cx0).
        src_off: int64 = yy * cast[int64](V2_BB_STRIDE) + cx0 * 4
        sys_lseek(bb_fd, src_off, SEEK_SET_HUI)
        # SYS_READ caps at 4 KiB per call; loop to fill a full row when
        # the panel/window is wider than 1024 px.
        filled: int64 = 0
        while filled < row_bytes:
            want: int64 = row_bytes - filled
            nr: int64 = sys_read(bb_fd,
                                 &v2_row_buf[cast[uint64](filled)],
                                 cast[uint64](want))
            if nr <= 0:
                break
            filled = filled + nr
        if filled <= 0:
            break
        # Write to /dev/fb at (bx0_screen + (cx0 - dx0), by0_screen + (yy - dy0)).
        scr_y: int64 = by0_screen + (yy - dy0)
        scr_x: int64 = bx0_screen + (cx0 - dx0)
        if scr_y < 0 or scr_x < 0:
            yy = yy + 1
            continue
        if scr_y >= cast[int64](FBG_H):
            break
        # ALPHA-AWARE BLIT: pixels with alpha=0 are TRANSPARENT — skip
        # them so the daemon_pixel cascade (wallpaper / lower windows /
        # WIN_BODY grey for chromeless overlays) shows through. This is
        # the keystone fix for iter-4's full-screen v2 backbuffer
        # widening: overlay clients call hamui_v2_clear_transparent()
        # in _paint_closed(), and their committed-but-unpainted region
        # carries alpha=0 → unchanged on screen. Painted pixels carry
        # alpha=255 → written as before. We scan the row for runs of
        # alpha-nonzero pixels and write each run as one contiguous
        # sys_write (one lseek + one write per run keeps the syscall
        # count bounded by the panel/overlay shape, not the row width).
        row_px: int64 = filled / 4
        fb_row_base: int64 = scr_y * sw + scr_x
        px_i: int64 = 0
        while px_i < row_px:
            # Skip a run of transparent pixels.
            while px_i < row_px and v2_row_buf[cast[uint64](px_i * 4 + 3)] == 0:
                px_i = px_i + 1
            if px_i >= row_px:
                break
            run_start: int64 = px_i
            # Extend across opaque (alpha != 0) pixels.
            while px_i < row_px and v2_row_buf[cast[uint64](px_i * 4 + 3)] != 0:
                px_i = px_i + 1
            run_len: int64 = px_i - run_start
            if run_len <= 0:
                continue
            fb_px_off: int64 = fb_row_base + run_start
            fb_off: int64 = fb_px_off * 4
            sys_lseek(fb_fd, fb_off, SEEK_SET_HUI)
            sys_write(fb_fd, &v2_row_buf[cast[uint64](run_start * 4)],
                      cast[uint64](run_len * 4))
        yy = yy + 1
    sys_close(bb_fd)
    sys_close(fb_fd)


def v2_present_dirty_windows():
    # Per-frame: walk DWIN slots; for each window whose kernel-side
    # backbuffer reports v2 (wsys_win_version >= 2) AND whose frame
    # serial advanced since LAST_SERIAL[slot], blit the kernel dirty
    # rect to scanout. This is the architectural win: the entire
    # daemon_pixel cascade is SKIPPED for v2 windows.
    #
    # FIX 2026-06-14 (empty-windows DE bug): we used to gate on a
    # local DWIN_PROTO_V2[i] flag that was never set anywhere — every
    # v2 client's `version 2` wctl write succeeded kernel-side but the
    # compositor skipped them all, leaving panel/appmenu/desktop/etc
    # as empty grey decorations. Trust the kernel's wsys_win_version
    # (returned as ver_v from bbstate) as the single source of truth.
    # Also auto-flip the local mirror so legacy code paths that still
    # check DWIN_PROTO_V2 (input routing, etc.) see the right state.
    i: uint64 = 0
    while i < DWIN_COUNT:
        wid: int32 = DWIN_WID[i]
        if wid > 0:
            ver_v: uint64 = 0
            ser_v: uint64 = 0
            dx0v: int64 = 0
            dy0v: int64 = 0
            dx1v: int64 = 0
            dy1v: int64 = 0
            ok: int32 = v2_read_bbstate(wid, &ver_v, &ser_v,
                                        &dx0v, &dy0v, &dx1v, &dy1v)
            if ok != 0 and ver_v >= 2:
                if DWIN_PROTO_V2[i] == 0:
                    DWIN_PROTO_V2[i] = 1
                if ser_v != V2_LAST_SERIAL[i]:
                    v2_blit_window_dirty_rect(i, wid, dx0v, dy0v, dx1v, dy1v)
                    V2_LAST_SERIAL[i] = ser_v
        i = i + 1


def v2_window_mark_proto(slot: int32) -> int32:
    # Compositor verb: flip DWIN_PROTO_V2[slot] on. Used by the spawn-
    # path / drag-to-create path when a client signals v2 (e.g. via an
    # argv flag or the wctl `version 2` write the client itself does).
    # Returns 0 on success, -1 if slot is out of range.
    if slot < 0 or cast[uint64](slot) >= DWIN_COUNT:
        return -1
    DWIN_PROTO_V2[cast[uint64](slot)] = 1
    V2_LAST_SERIAL[cast[uint64](slot)] = 0
    return 0


# Present the union accumulated this frame. A full-screen escalation uses
# the contiguous full-screen writer; otherwise the area-scaled partial
# present touches only the changed rows. Resets the accumulator. Returns 1
# if anything was presented, else 0.
def daemon_flush_damage() -> int32:
    if DMG_VALID == 0:
        # No present this frame — still paint the rubber-band/menu
        # overlay if a drag began with nothing else changing, so the
        # outline is on screen even for the rare "drag started, no other
        # damage" frame. (No-op when nothing's in flight.)
        post_present_overlays()
        return 0
    EVL_STAT_PRESENTS = EVL_STAT_PRESENTS + 1
    if DMG_FULL != 0:
        daemon_present()
        damage_reset()
        # DE perf P0-B: rubber-band lives ONLY on scanout (not in
        # SCENE_CACHE) so SCENE_CACHE stays reusable for the unchanged
        # pixels across interactive frames.
        post_present_overlays()
        return 1
    daemon_present_rect(DMG_X0, DMG_Y0, DMG_X1, DMG_Y1)
    # The cursor sprite is composited by daemon_pixel inside the presented
    # rect, so re-seed the cursor fast-path origin if the cursor lay inside
    # the damage (otherwise its old cell may still hold a stale sprite that
    # only a later cursor move would erase). Cheap and keeps the fast path
    # coherent with partial presents.
    LAST_CUR_X = CUR_X
    LAST_CUR_Y = CUR_Y
    damage_reset()
    # DE perf P0-B: paint the rubber-band outline AFTER the cached
    # SCENE_CACHE rect has been blitted; the outline is overlay-only
    # (never enters SCENE_CACHE), exactly like the cursor sprite.
    post_present_overlays()
    return 1


# Spawn a detached program + bind it to a fresh wid, then record the
# dragged rectangle as a daemon window. Mirrors user/hamUI.ad::cmd_new.
# Returns the wid (>=2) on success, -1 on failure (still records the
# rectangle as a chrome-only window so the gesture is visibly honoured).
#
# `prog` is the absolute binary path to launch (e.g. "/bin/hamsh",
# "/bin/vi"); its stdin/stdout are wired to the daemon's pipe ends so the
# in-window VT emulator drives it exactly like the drag-out shell. This
# is the SINGLE spawn-into-window path: the drag-to-create gesture passes
# "/bin/hamsh"; the Applications menu passes whichever program was clicked.
arg_buf_d: Array[5, uint64]             # [hamsh, rc.de-user, prog, optional arg1, NULL]
in_pipe_d:  Array[2, int32]              # child stdin  pipe [r, w]
out_pipe_d: Array[2, int32]             # child stdout pipe [r, w]
# Optional single argv[1] for a spawned window program (e.g. the file
# manager's start directory). Empty string == no argument. A 1024-byte
# scratch so the caller's path survives into the child's argv.
spawn_arg1: Array[1024, uint8]
spawn_arg1_set: int32 = 0
# Set the optional argv[1] for the NEXT daemon_spawn_window_prog call.
# Copies the NUL-terminated string into spawn_arg1. Consumed (cleared)
# by that one spawn so it never leaks to a later window.
def spawn_set_arg1(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 1023:
        spawn_arg1[i] = s[i]
        i = i + 1
    spawn_arg1[i] = 0
    spawn_arg1_set = 1


# ====================================================================
# DE pivot wave 2 — Applications menu = /bin/hamappmenu (separate proc)
#
# This block is the compositor's half of the extraction. The cascading-
# menu rendering used to live inside daemon_pixel; it now runs in its
# own process (user/hamappmenu.ad), reading the catalogue snapshot from
# /dev/wsys/appmenu and writing the chosen prog to
# /dev/wsys/appmenu/launch. hamUId only does three things here:
#
#   1. appmenu_publish_snapshot() — pushes the catalogue to the kernel
#      once at startup via /dev/wsys/ctl `appmenu <payload>`.
#   2. appmenu_spawn() — launches /bin/hamappmenu when the Apps trigger
#      fires (used by the panel + the Apps hotkey).
#   3. appmenu_drain_launch() — polled per frame; reads the launch
#      snapshot from /dev/wsys/appmenu/launch and, on a serial bump,
#      spawns the chosen prog through daemon_spawn_window_prog.

appmenu_published: int32 = 0
appmenu_last_launch_serial: uint64 = 0
appmenu_pub_buf: Array[2048, uint8]
appmenu_launch_buf: Array[320, uint8]


def _appmenu_emit_cstr(buf: Ptr[uint8], pos: uint64,
                       s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    i: uint64 = 0
    while s[i] != 0:
        buf[p] = s[i]
        p = p + 1
        i = i + 1
    return p


def appmenu_publish_snapshot():
    # Compose "C <name>\n" per category then "I <cat> <prog> <label>\n"
    # per flat entry, scoped to entries that have an external prog path
    # (the in-compositor APP_* entries are stale anyway — they were the
    # old in-daemon_pixel path). One write to /dev/wsys/ctl plants the
    # full catalogue. Idempotent (a second call simply re-publishes).
    pos: uint64 = 0
    # Verb prefix: "appmenu "
    verb: Ptr[uint8] = "appmenu "
    pos = _appmenu_emit_cstr(&appmenu_pub_buf[0], pos, verb)
    # Categories.
    c: int64 = 0
    while c < APPCAT_COUNT:
        appmenu_pub_buf[pos] = 67                    # 'C'
        pos = pos + 1
        appmenu_pub_buf[pos] = 32
        pos = pos + 1
        pos = _appmenu_emit_cstr(&appmenu_pub_buf[0], pos, appcat_label(c))
        appmenu_pub_buf[pos] = 10
        pos = pos + 1
        c = c + 1
    # Items per category.
    c = 0
    while c < APPCAT_COUNT:
        n: int64 = appcat_item_count(c)
        k: int64 = 0
        while k < n:
            flat: uint64 = appcat_flat_index(c, k)
            appmenu_pub_buf[pos] = 73                # 'I'
            pos = pos + 1
            appmenu_pub_buf[pos] = 32
            pos = pos + 1
            # cat idx (u64_to_dec writes digits only, no newline)
            pos = pos + u64_to_dec(cast[uint64](c), &appmenu_pub_buf[pos])
            appmenu_pub_buf[pos] = 32
            pos = pos + 1
            # prog path
            pos = _appmenu_emit_cstr(&appmenu_pub_buf[0], pos,
                                     cast[Ptr[uint8]](menu_prog(flat)))
            appmenu_pub_buf[pos] = 32
            pos = pos + 1
            # label
            pos = _appmenu_emit_cstr(&appmenu_pub_buf[0], pos,
                                     menu_label(flat))
            appmenu_pub_buf[pos] = 10
            pos = pos + 1
            k = k + 1
        c = c + 1
    # Ship to /dev/wsys/ctl.
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &appmenu_pub_buf[0], pos)
    sys_close(fd)
    appmenu_published = 1


def appmenu_spawn(scr_w: int64, scr_h: int64):
    # Spawn /bin/hamappmenu in a small window anchored near the panel
    # button. The window is a normal DE window so the compositor
    # composites it like any other client. Republish the snapshot if it
    # hasn't been done yet (defensive — appmenu_publish_snapshot is
    # called from the daemon init, but startup ordering may shift).
    if appmenu_published == 0:
        appmenu_publish_snapshot()
    # Rect: 300x200, anchored 8px from the left, 28px from the top.
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamappmenu"),
                             8, 28, 300, 200)


def appmenu_drain_launch(scr_w: int64, scr_h: int64):
    # Snapshot read of /dev/wsys/appmenu/launch. On a serial bump, parse
    # out the program path and pump it through daemon_spawn_window_prog
    # so it appears as a fresh DE window. The launch slot itself is
    # idempotent — a re-read with the SAME serial is a no-op.
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/appmenu/launch"))
    if fd < 0:
        return
    n: int64 = sys_read_nb(fd, &appmenu_launch_buf[0], 320)
    sys_close(fd)
    if n <= 0:
        return
    cap: uint64 = cast[uint64](n)
    # Parse "<serial> <path>\n".
    p: uint64 = 0
    serial: uint64 = 0
    while p < cap and appmenu_launch_buf[p] >= 48 \
            and appmenu_launch_buf[p] <= 57:
        serial = serial * 10 + cast[uint64](appmenu_launch_buf[p] - 48)
        p = p + 1
    if serial == 0:
        return
    if serial == appmenu_last_launch_serial:
        return
    # Single separating space.
    if p < cap and appmenu_launch_buf[p] == 32:
        p = p + 1
    ps: uint64 = p
    while p < cap and appmenu_launch_buf[p] != 10:
        p = p + 1
    pe: uint64 = p
    if pe <= ps:
        appmenu_last_launch_serial = serial
        return
    # NUL-terminate the path in-place so we can pass it as Ptr[char].
    if pe < 320:
        appmenu_launch_buf[pe] = 0
    appmenu_last_launch_serial = serial
    # Anchor the new window at a fixed centre-screen rect; the
    # compositor's snap/place logic handles re-layout.
    rx: int64 = scr_w / 4
    ry: int64 = scr_h / 4
    rw: int64 = scr_w / 2
    rh: int64 = scr_h / 2
    if rw < 320:
        rw = 320
    if rh < 200:
        rh = 200
    daemon_spawn_window_prog(cast[Ptr[char]](&appmenu_launch_buf[ps]),
                             rx, ry, rw, rh)


# ====================================================================
# DE pivot wave 3 — Alt-Tab cycler = /bin/hamcycler (separate proc)
# ====================================================================
# The MATE-style window switcher overlay used to render inline in
# daemon_pixel. It now lives in /bin/hamcycler (user/hamcycler.ad), a
# v2 client that reads its model from /dev/wsys/cycler and is poked
# via /dev/wsys/cycler/show whenever F5/F6 step the selection. hamUId
# only does three things here:
#
#   1. cycler_publish_snapshot() — pushes the current open/sel + per-
#      candidate list to the kernel via /dev/wsys/ctl `cycler <open>
#      <sel> <payload>`. Called every time cycle_step / cycle_commit
#      mutates the switcher state.
#   2. cycler_spawn() — launches /bin/hamcycler once, on daemon startup
#      (same long-lived shape as hampanel). The client stays resident
#      for the whole session and re-paints from snapshot polls.
#   3. cycler_poke_show() — write to /dev/wsys/cycler/show to wake the
#      client immediately when the model just changed.
cycler_spawned: int32 = 0
cycler_pub_buf: Array[2048, uint8]


def _cycler_emit_cstr(buf: Ptr[uint8], pos: uint64,
                      s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while s[k] != 0:
        buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


def cycler_publish_snapshot():
    # Emit "cycler <open> <sel> W <wid0> <title0>\nW ...\n" into one
    # /dev/wsys/ctl write. The kernel parses the verb, the two ints,
    # then the rest as the snapshot body.
    pos: uint64 = 0
    verb: Ptr[uint8] = "cycler "
    pos = _cycler_emit_cstr(&cycler_pub_buf[0], pos, verb)
    pos = pos + u64_to_dec(cast[uint64](CYCLE_OPEN), &cycler_pub_buf[pos])
    cycler_pub_buf[pos] = 32
    pos = pos + 1
    sel_pub: uint64 = 0
    if CYCLE_SEL >= 0:
        sel_pub = cast[uint64](CYCLE_SEL)
    pos = pos + u64_to_dec(sel_pub, &cycler_pub_buf[pos])
    cycler_pub_buf[pos] = 32
    pos = pos + 1
    # One "W <wid> <title>\n" line per visible candidate, in cycler
    # display order (MRU). Truncate to fit; we cap at 9 candidates which
    # matches MAX_WINDOWS-1 anyway.
    cn: int64 = cycle_visible_count()
    row: int64 = 0
    while row < cn and row < 9 and pos + 96 < 2048:
        slot: int64 = cycle_slot_for_pos(row)
        if slot < 0:
            row = row + 1
            continue
        su: uint64 = cast[uint64](slot)
        cycler_pub_buf[pos] = 87                       # 'W'
        pos = pos + 1
        cycler_pub_buf[pos] = 32
        pos = pos + 1
        # wid (DWIN_WID is small).
        pos = pos + u64_to_dec(cast[uint64](DWIN_WID[su]),
                               &cycler_pub_buf[pos])
        cycler_pub_buf[pos] = 32
        pos = pos + 1
        # Title: Terminal slots get "Terminal <N>", everything else
        # uses window_title(slot).
        if DWIN_APP[su] == APP_TERM:
            tp: Ptr[uint8] = "Terminal "
            pos = _cycler_emit_cstr(&cycler_pub_buf[0], pos, tp)
            cycler_pub_buf[pos] = cast[uint8](su + 1) + 48
            pos = pos + 1
        else:
            pos = _cycler_emit_cstr(&cycler_pub_buf[0], pos,
                                    window_title(su))
        cycler_pub_buf[pos] = 10
        pos = pos + 1
        row = row + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &cycler_pub_buf[0], pos)
    sys_close(fd)


def cycler_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/cycler/show"))
    if fd < 0:
        return
    # One byte is enough — any write bumps the show serial.
    poke: Array[2, uint8]
    poke[0] = 49                                       # '1'
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def cycler_spawn(scr_w: int64, scr_h: int64):
    # Idempotent: only launch once. The cycler is a long-lived overlay
    # client; subsequent open/close transitions are driven by the
    # snapshot + show-serial pokes, not respawns.
    if cycler_spawned != 0:
        return
    # Anchor in the centre of the screen — that's where the legacy
    # cycler popup drew. 300x200 mirrors hamappmenu's window.
    wx: int64 = scr_w / 2 - 150
    wy: int64 = scr_h / 2 - 100
    if wx < 0:
        wx = 0
    if wy < PANEL_H:
        wy = PANEL_H
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamcycler"),
                             wx, wy, 300, 200)
    cycler_spawned = 1


# ====================================================================
# DE pivot wave 4 — clock calendar popup = /bin/hamcalpop (separate proc)
# ====================================================================
# The drop-down monthly calendar attached to the panel clock used to
# render inline in daemon_pixel. It now lives in /bin/hamcalpop
# (user/hamcalpop.ad), a v2 client that reads its model from
# /dev/wsys/calpop and is poked via /dev/wsys/calpop/show whenever
# cal_toggle / clock_refresh changes open/Y/M/D. hamUId only does
# three things here:
#
#   1. calpop_publish_snapshot() — pushes the current open + Y/M/D +
#      valid flag to the kernel via /dev/wsys/ctl `calpop <open>
#      <year> <month> <day> <valid>`. Called every time cal_toggle
#      mutates the popup state or clock_refresh re-parses Y/M/D.
#   2. calpop_spawn() — launches /bin/hamcalpop once, on daemon
#      startup (same long-lived shape as hamcycler). The client stays
#      resident for the whole session and re-paints from snapshot
#      polls.
#   3. calpop_poke_show() — write to /dev/wsys/calpop/show to wake
#      the client immediately when the model just changed.
calpop_spawned: int32 = 0
calpop_pub_buf: Array[128, uint8]


def _calpop_emit_cstr(buf: Ptr[uint8], pos: uint64,
                      s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while s[k] != 0:
        buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


def calpop_publish_snapshot():
    # Emit "calpop <open> <year> <month> <day> <valid>\n" into one
    # /dev/wsys/ctl write. The kernel parses the verb, the five ints,
    # and stores them for the snapshot read.
    pos: uint64 = 0
    verb: Ptr[uint8] = "calpop "
    pos = _calpop_emit_cstr(&calpop_pub_buf[0], pos, verb)
    pos = pos + u64_to_dec(cast[uint64](CAL_OPEN), &calpop_pub_buf[pos])
    calpop_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](CAL_YEAR), &calpop_pub_buf[pos])
    calpop_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](CAL_MONTH), &calpop_pub_buf[pos])
    calpop_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](CAL_DAY), &calpop_pub_buf[pos])
    calpop_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](CAL_VALID), &calpop_pub_buf[pos])
    calpop_pub_buf[pos] = 10
    pos = pos + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &calpop_pub_buf[0], pos)
    sys_close(fd)


def calpop_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/calpop/show"))
    if fd < 0:
        return
    # One byte is enough — any write bumps the show serial.
    poke: Array[2, uint8]
    poke[0] = 49                                       # '1'
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def calpop_spawn(scr_w: int64, scr_h: int64):
    # Idempotent: only launch once. The calpop client is long-lived;
    # subsequent open/close transitions are driven by snapshot + show-
    # serial pokes, not respawns.
    if calpop_spawned != 0:
        return
    # Anchor at the clock-drop position: CAL_W wide, right-aligned
    # under the panel clock, dropping off the panel edge. The legacy
    # cal_drop_x / cal_drop_y compute the exact position; we cap the
    # window height at the 6-row worst case (matches hamcalpop's
    # _hp_WIN_H = 150).
    wx: int64 = cal_drop_x(scr_w)
    wy: int64 = cal_drop_y()
    if wx < 0:
        wx = 0
    if wy < PANEL_H:
        wy = PANEL_H
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamcalpop"),
                             wx, wy, CAL_W, 150)
    calpop_spawned = 1


# ====================================================================
# DE pivot wave 4 — Run dialog = /bin/hamrun (separate proc)
# ====================================================================
# The MATE-style "Run Application..." (Alt-F2) modal text-entry dialog
# used to render inline in daemon_pixel. It now lives in /bin/hamrun
# (user/hamrun.ad), a v2 client that reads its model from /dev/wsys/run
# and is poked via /dev/wsys/run/show whenever a keystroke or open/cancel
# mutates the state. hamUId only does four things here:
#
#   1. run_publish_snapshot() — pushes the current open flag + typed text
#      to the kernel via /dev/wsys/ctl `run <open> <text>`. Called on
#      every dialog mutation (open/cancel/push/backspace/launch).
#   2. run_spawn() — launches /bin/hamrun once, on daemon startup. The
#      client stays resident for the whole session and re-paints from
#      snapshot polls.
#   3. run_poke_show() — write to /dev/wsys/run/show to wake the client
#      immediately when the model just changed.
#   4. run_drain_launch() — per-frame poll of /dev/wsys/run/launch. On a
#      serial bump, parse the path and spawn it through
#      daemon_spawn_window_prog (mirrors appmenu_drain_launch).
run_spawned: int32 = 0
run_pub_buf: Array[256, uint8]
run_launch_buf: Array[320, uint8]
run_last_launch_serial: uint64 = 0


def _run_emit_cstr(buf: Ptr[uint8], pos: uint64,
                   s: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while s[k] != 0:
        buf[p] = s[k]
        p = p + 1
        k = k + 1
    return p


def run_publish_snapshot():
    # Emit "run <open> <text>\n" into one /dev/wsys/ctl write. The kernel
    # parses the verb, the int, then the rest as the text. The text may
    # be empty (just "run 1 \n" when the user just opened the dialog).
    pos: uint64 = 0
    verb: Ptr[uint8] = "run "
    pos = _run_emit_cstr(&run_pub_buf[0], pos, verb)
    pos = pos + u64_to_dec(cast[uint64](RUN_OPEN), &run_pub_buf[pos])
    run_pub_buf[pos] = 32
    pos = pos + 1
    i: uint64 = 0
    while i < RUN_LEN and pos < 252:
        run_pub_buf[pos] = run_buf[i]
        pos = pos + 1
        i = i + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &run_pub_buf[0], pos)
    sys_close(fd)


def run_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/run/show"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49                                       # '1'
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def run_spawn(scr_w: int64, scr_h: int64):
    # Idempotent: only launch once. The Run dialog is a long-lived overlay
    # client; subsequent open/close transitions are driven by the snapshot
    # + show-serial pokes, not respawns.
    if run_spawned != 0:
        return
    # Anchor in the centre of the screen — that's where the legacy Run
    # dialog drew. 320x100 mirrors lib/hamui's window.
    wx: int64 = scr_w / 2 - 160
    wy: int64 = scr_h / 2 - 50
    if wx < 0:
        wx = 0
    if wy < PANEL_H:
        wy = PANEL_H
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamrun"),
                             wx, wy, 320, 100)
    run_spawned = 1


def run_drain_launch(scr_w: int64, scr_h: int64):
    # Snapshot read of /dev/wsys/run/launch. On a serial bump, parse the
    # program path and pump it through daemon_spawn_window_prog so it
    # appears as a fresh DE window (mirrors appmenu_drain_launch).
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/run/launch"))
    if fd < 0:
        return
    n: int64 = sys_read_nb(fd, &run_launch_buf[0], 320)
    sys_close(fd)
    if n <= 0:
        return
    cap: uint64 = cast[uint64](n)
    p: uint64 = 0
    serial: uint64 = 0
    while p < cap and run_launch_buf[p] >= 48 \
            and run_launch_buf[p] <= 57:
        serial = serial * 10 + cast[uint64](run_launch_buf[p] - 48)
        p = p + 1
    if serial == 0:
        return
    if serial == run_last_launch_serial:
        return
    if p < cap and run_launch_buf[p] == 32:
        p = p + 1
    ps: uint64 = p
    while p < cap and run_launch_buf[p] != 10:
        p = p + 1
    pe: uint64 = p
    if pe <= ps:
        run_last_launch_serial = serial
        return
    if pe < 320:
        run_launch_buf[pe] = 0
    run_last_launch_serial = serial
    # Cascade like run_launch did.
    w: int64 = 480
    h: int64 = 300
    step: int64 = (LAUNCH_CASCADE % 6) * 28
    rx: int64 = 100 + step
    ry: int64 = PANEL_H + 24 + step
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    daemon_spawn_window_prog(cast[Ptr[char]](&run_launch_buf[ps]),
                             rx, ry, w, h)


# ====================================================================
# DE pivot wave 5 — screen-lock overlay = /bin/hamlock (separate proc)
# ====================================================================
# The full-screen lock curtain ("Screen Locked / Click to unlock") used
# to render inline in daemon_pixel. It now lives in /bin/hamlock
# (user/hamlock.ad), a v2 client that reads its model from
# /dev/wsys/lock and is poked via /dev/wsys/lock/show whenever the lock
# state mutates (session_lock / session_unlock / a verify drain). hamUId
# only does four things here:
#
#   1. lock_publish_snapshot() — pushes the current locked flag + fails
#      counter to the kernel via /dev/wsys/ctl `lock <locked> <fails>`.
#      Called on every lock state mutation.
#   2. lock_spawn() — launches /bin/hamlock once, on daemon startup. The
#      client stays resident for the whole session and re-paints from
#      snapshot polls.
#   3. lock_poke_show() — write to /dev/wsys/lock/show to wake the client
#      immediately when the model just changed.
#   4. lock_drain_verify() — per-frame poll of /dev/wsys/lock/verify. On
#      a serial bump, run lock_pw_try against the typed password (the
#      secret stays in the compositor; only the RENDER moved out).
lock_spawned: int32 = 0
lock_pub_buf: Array[64, uint8]
lock_verify_buf: Array[192, uint8]
lock_last_verify_serial: uint64 = 0


# ====================================================================
# DE pivot wave 7 — notification toast = /bin/hamnotif (separate proc)
# ====================================================================
# The transient notification banner ("title + body" pop-up that appears
# top-right and fades after ~4 s) used to render inline in daemon_pixel.
# It now lives in /bin/hamnotif (user/hamnotif.ad), a v2 client that
# reads its model from /dev/wsys/notif and is poked via
# /dev/wsys/notif/show whenever the notification state mutates
# (notify_post arms a new banner, notify_tick lets the current one
# expire). hamUId only does three things here:
#
#   1. notif_publish_snapshot() — pushes <active>/<alpha>/<title>/<body>
#      to the kernel via /dev/wsys/ctl `notif <active> <alpha>
#      <title>\t<body>`. Called from notify_post() and from notify_tick()
#      whenever ACTIVE or ALPHA changes.
#   2. notif_spawn() — launches /bin/hamnotif once, on daemon startup.
#      The client stays resident for the whole session and re-paints
#      from snapshot polls.
#   3. notif_poke_show() — write to /dev/wsys/notif/show to wake the
#      client immediately when the model just changed.
#
# Like the cycler/run/lock waves, only the RENDER moved out. The
# notification queue + fade timer (notify_post/notify_tick/notify_alpha
# and the message-tray history ring) stay in the compositor; the client
# just rasterises whatever active/alpha/title/body the kernel snapshot
# advertises.
notif_spawned: int32 = 0
notif_pub_buf: Array[256, uint8]
notif_last_alpha: int64 = -1


def notif_publish_snapshot():
    # Emit "notif <active> <alpha> <title>\t<body>\n" into one
    # /dev/wsys/ctl write. The kernel parses the verb, the two ints, then
    # the title (up to TAB) and the body (TAB to '\n'). Hostowner-only,
    # matching the rest of the ctl.
    pos: uint64 = 0
    verb: Ptr[uint8] = "notif "
    k: uint64 = 0
    while verb[k] != 0:
        notif_pub_buf[pos] = verb[k]
        pos = pos + 1
        k = k + 1
    pos = pos + u64_to_dec(cast[uint64](NOTIFY_ACTIVE), &notif_pub_buf[pos])
    notif_pub_buf[pos] = 32
    pos = pos + 1
    alpha_now: int64 = 0
    if NOTIFY_ACTIVE != 0:
        alpha_now = notify_alpha()
    pos = pos + u64_to_dec(cast[uint64](alpha_now), &notif_pub_buf[pos])
    notif_pub_buf[pos] = 32
    pos = pos + 1
    # Title (NUL-terminated, capped at 40).
    ti: uint64 = 0
    while notify_title[ti] != 0 and pos < 250:
        notif_pub_buf[pos] = notify_title[ti]
        pos = pos + 1
        ti = ti + 1
    notif_pub_buf[pos] = 9                             # '\t'
    pos = pos + 1
    # Body (NUL-terminated, capped at 64).
    bi: uint64 = 0
    while notify_body[bi] != 0 and pos < 254:
        notif_pub_buf[pos] = notify_body[bi]
        pos = pos + 1
        bi = bi + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &notif_pub_buf[0], pos)
    sys_close(fd)


def notif_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/notif/show"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49                                       # '1'
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def notif_spawn(scr_w: int64, scr_h: int64):
    # Idempotent: only launch once. The toast client is long-lived; the
    # banner shows/hides via the snapshot + show-serial pokes, not via
    # respawns. Anchor matches the legacy render: top-right, just inside
    # the work area's top edge (the compositor still owns work_top()).
    if notif_spawned != 0:
        return
    nbx: int64 = scr_w - NOTIFY_W - 8
    if nbx < 0:
        nbx = 0
    nby: int64 = work_top(scr_h) + 8
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamnotif"),
                             nbx, nby, NOTIFY_W, NOTIFY_H)
    notif_spawned = 1


def notif_republish_if_changed():
    # Called from the main loop's notify_tick branch: republish + poke
    # whenever the on-screen alpha bucket changes (so the client sees the
    # fade), and whenever ACTIVE drops to 0 (so the client clears).
    if NOTIFY_ACTIVE == 0:
        if notif_last_alpha != 0:
            notif_publish_snapshot()
            notif_poke_show()
            notif_last_alpha = 0
        return
    a: int64 = notify_alpha()
    if a != notif_last_alpha:
        notif_publish_snapshot()
        notif_poke_show()
        notif_last_alpha = a


def lock_publish_snapshot():
    # Emit "lock <locked> <fails>\n" into one /dev/wsys/ctl write. The
    # kernel parses the verb + two small ints. Hostowner-only, matching
    # the rest of the ctl.
    pos: uint64 = 0
    verb: Ptr[uint8] = "lock "
    k: uint64 = 0
    while verb[k] != 0:
        lock_pub_buf[pos] = verb[k]
        pos = pos + 1
        k = k + 1
    pos = pos + u64_to_dec(cast[uint64](LOCKED), &lock_pub_buf[pos])
    lock_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](LOCK_FAILS), &lock_pub_buf[pos])
    lock_pub_buf[pos] = 10
    pos = pos + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &lock_pub_buf[0], pos)
    sys_close(fd)


def lock_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/lock/show"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49                                       # '1'
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def lock_spawn(scr_w: int64, scr_h: int64):
    # Idempotent: only launch once. The lock overlay is a long-lived
    # full-screen client; subsequent locked/unlocked transitions are
    # driven by the snapshot + show-serial pokes, not respawns.
    if lock_spawned != 0:
        return
    # Full-screen anchor at (0,0): the curtain has to cover everything
    # (panel, windows, applets) when LOCKED is set.
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamlock"),
                             0, 0, scr_w, scr_h)
    lock_spawned = 1


# ====================================================================
# DE pivot wave 8 — End Session dialog = /bin/hamsessui (separate process)
# ====================================================================
# The four-row modal (Lock Screen / Log Out / Shut Down / Cancel) used
# to be painted inline by daemon_pixel. It now lives in /bin/hamsessui
# (user/hamsessui.ad), a v2 client that reads its model from
# /dev/wsys/sessui and is woken by writes to /dev/wsys/sessui/show.
# The compositor still OWNS the action dispatch (session_invoke); only
# the RENDER moved out.
sessui_spawned: int32 = 0
sessui_pub_buf: Array[64, uint8]
# Track last-published state so the per-frame hover poll only republishes
# when something actually changed.
sessui_last_open: int32 = -1
sessui_last_hover: int32 = -2


def sessui_publish_snapshot():
    # Emit "sessui <open> <hover>\n" into one /dev/wsys/ctl write. The
    # hover may be -1 (no row hovered). Hostowner-only, matching the
    # rest of the ctl.
    pos: uint64 = 0
    verb: Ptr[uint8] = "sessui "
    k: uint64 = 0
    while verb[k] != 0:
        sessui_pub_buf[pos] = verb[k]
        pos = pos + 1
        k = k + 1
    pos = pos + u64_to_dec(cast[uint64](SESSION_OPEN), &sessui_pub_buf[pos])
    sessui_pub_buf[pos] = 32
    pos = pos + 1
    h: int64 = SESSION_HOVER
    if h < 0:
        sessui_pub_buf[pos] = 45                          # '-'
        pos = pos + 1
        pos = pos + u64_to_dec(cast[uint64](-h), &sessui_pub_buf[pos])
    else:
        pos = pos + u64_to_dec(cast[uint64](h), &sessui_pub_buf[pos])
    sessui_pub_buf[pos] = 10
    pos = pos + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &sessui_pub_buf[0], pos)
    sys_close(fd)
    sessui_last_open = SESSION_OPEN
    sessui_last_hover = cast[int32](SESSION_HOVER)


def sessui_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/sessui/show"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49                                          # '1'
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def sessui_spawn(scr_w: int64, scr_h: int64):
    # Idempotent: only launch once. The dialog client is a long-lived
    # overlay; open/cancel transitions are driven by the snapshot + show-
    # serial pokes, not respawns.
    if sessui_spawned != 0:
        return
    # Centre-ish anchor that matches the legacy SESSION_W=240 dialog box.
    dw: int64 = 240
    dh: int64 = 220
    dx: int64 = scr_w / 2 - dw / 2
    dy: int64 = scr_h / 2 - dh / 2
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamsessui"),
                             dx, dy, dw, dh)
    sessui_spawned = 1


def sessui_publish_if_changed():
    # Called from the daemon main loop; cheap diff against the last-
    # published (open, hover) so we don't ctl-write every frame.
    if SESSION_OPEN == sessui_last_open \
       and cast[int32](SESSION_HOVER) == sessui_last_hover:
        return
    sessui_publish_snapshot()
    sessui_poke_show()


# ====================================================================
# DE pivot wave 1 (round 2) — desktop icons = /bin/hamdesktop
# ====================================================================
# The desktop-icon badge grid (formerly dpix_root_icons inside
# daemon_pixel) now lives in /bin/hamdesktop. Compositor publishes a
# (count, drag) model + pokes /dev/wsys/desktop/show.
desktop_spawned: int32 = 0
desktop_pub_buf: Array[64, uint8]
desktop_last_count: int32 = -1
desktop_last_drag:  int32 = -2


def desktop_publish_snapshot():
    pos: uint64 = 0
    verb: Ptr[uint8] = "desktop "
    k: uint64 = 0
    while verb[k] != 0:
        desktop_pub_buf[pos] = verb[k]
        pos = pos + 1
        k = k + 1
    pos = pos + u64_to_dec(cast[uint64](DICON_COUNT), &desktop_pub_buf[pos])
    desktop_pub_buf[pos] = 32
    pos = pos + 1
    d: int64 = DICON_DRAG
    if d < 0:
        desktop_pub_buf[pos] = 45
        pos = pos + 1
        pos = pos + u64_to_dec(cast[uint64](-d), &desktop_pub_buf[pos])
    else:
        pos = pos + u64_to_dec(cast[uint64](d), &desktop_pub_buf[pos])
    desktop_pub_buf[pos] = 10
    pos = pos + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &desktop_pub_buf[0], pos)
    sys_close(fd)
    desktop_last_count = cast[int32](DICON_COUNT)
    desktop_last_drag = cast[int32](DICON_DRAG)


def desktop_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/desktop/show"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def desktop_spawn(scr_w: int64, scr_h: int64):
    if desktop_spawned != 0:
        return
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamdesktop"),
                             0, 0, scr_w, scr_h)
    desktop_spawned = 1


def desktop_publish_if_changed():
    if cast[int32](DICON_COUNT) == desktop_last_count \
       and cast[int32](DICON_DRAG) == desktop_last_drag:
        return
    desktop_publish_snapshot()
    desktop_poke_show()


# ====================================================================
# DE pivot wave 2 (round 2) — sysmon applet = /bin/hamsysmon
# ====================================================================
sysmon_spawned: int32 = 0
sysmon_pub_buf: Array[64, uint8]
sysmon_last_cpu: int32 = -1
sysmon_last_mem: int32 = -1


def sysmon_publish_snapshot():
    pos: uint64 = 0
    verb: Ptr[uint8] = "sysmon "
    k: uint64 = 0
    while verb[k] != 0:
        sysmon_pub_buf[pos] = verb[k]
        pos = pos + 1
        k = k + 1
    cpu_v: int64 = DMON_CPU_CUR
    if cpu_v < 0:
        cpu_v = 0
    if cpu_v > 100:
        cpu_v = 100
    mem_v: int64 = DMON_MEM_CUR
    if mem_v < 0:
        mem_v = 0
    if mem_v > 100:
        mem_v = 100
    pos = pos + u64_to_dec(cast[uint64](cpu_v), &sysmon_pub_buf[pos])
    sysmon_pub_buf[pos] = 32
    pos = pos + 1
    pos = pos + u64_to_dec(cast[uint64](mem_v), &sysmon_pub_buf[pos])
    sysmon_pub_buf[pos] = 10
    pos = pos + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    sys_write(fd, &sysmon_pub_buf[0], pos)
    sys_close(fd)
    sysmon_last_cpu = cast[int32](cpu_v)
    sysmon_last_mem = cast[int32](mem_v)


def sysmon_poke_show():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/sysmon/show"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49
    poke[1] = 10
    sys_write(fd, &poke[0], 2)
    sys_close(fd)


def sysmon_spawn(scr_w: int64, scr_h: int64):
    if sysmon_spawned != 0:
        return
    # Anchor near the top-right of the screen — sized like the legacy
    # DMON_W/DMON_H, but we don't depend on those globals.
    dw: int64 = 60
    dh: int64 = 50
    dx: int64 = scr_w - dw - 12
    dy: int64 = 12
    if dx < 0:
        dx = 0
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamsysmon"),
                             dx, dy, dw, dh)
    sysmon_spawned = 1


def sysmon_publish_if_changed():
    cpu_v: int32 = cast[int32](DMON_CPU_CUR)
    mem_v: int32 = cast[int32](DMON_MEM_CUR)
    if cpu_v == sysmon_last_cpu and mem_v == sysmon_last_mem:
        return
    sysmon_publish_snapshot()
    sysmon_poke_show()



def font_init():
    if font_ready != 0:
        return
    g: uint64 = 0
    while g < 95:
        hexs: Ptr[uint8] = _font_hex(g)
        r: uint64 = 0
        while r < 16:
            hi: int32 = hex_nibble(hexs[r * 2])
            lo: int32 = hex_nibble(hexs[r * 2 + 1])
            font_glyphs[g * 16 + r] = cast[uint8]((hi * 16) + lo)
            r = r + 1
        g = g + 1
    font_ready = 1


# ====================================================================
# Compositor target helpers
# ====================================================================

def target_clear():
    # Fill the window-sized target with the opaque background colour.
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            target[o] = BG_R
            target[o + 1] = BG_G
            target[o + 2] = BG_B
            target[o + 3] = 255
            x = x + 1
        y = y + 1


def layerbuf_clear():
    # Zero (transparent) the per-layer RGBA scratch. Premultiplied: all
    # channels 0 = fully transparent.
    i: uint64 = 0
    n: uint64 = WIN_W * WIN_H * 4
    while i < n:
        layerbuf[i] = 0
        i = i + 1


# Set a layer-buffer pixel (premultiplied RGBA) with src-over blend onto
# whatever is already in the layer buffer. (r,g,b,a) are straight 0..255
# component values for the incoming colour; we premultiply on store.
def layer_put(x: int64, y: int64, r: uint8, g: uint8, b: uint8, a: uint8):
    if x < 0 or y < 0:
        return
    xu: uint64 = cast[uint64](x)
    yu: uint64 = cast[uint64](y)
    if xu >= WIN_W or yu >= WIN_H:
        return
    if a == 0:
        return
    o: uint64 = (yu * WIN_W + xu) * 4
    av: uint64 = cast[uint64](a)
    inv: uint64 = 255 - av
    # Premultiply the incoming colour by its own alpha, then src-over
    # against the existing premultiplied destination.
    sr: uint64 = (cast[uint64](r) * av) / 255
    sg: uint64 = (cast[uint64](g) * av) / 255
    sb: uint64 = (cast[uint64](b) * av) / 255
    dr: uint64 = cast[uint64](layerbuf[o])
    dg: uint64 = cast[uint64](layerbuf[o + 1])
    db: uint64 = cast[uint64](layerbuf[o + 2])
    da: uint64 = cast[uint64](layerbuf[o + 3])
    layerbuf[o] = cast[uint8](sr + (dr * inv) / 255)
    layerbuf[o + 1] = cast[uint8](sg + (dg * inv) / 255)
    layerbuf[o + 2] = cast[uint8](sb + (db * inv) / 255)
    layerbuf[o + 3] = cast[uint8](av + (da * inv) / 255)


# ====================================================================
# hamML colour parsing
# ====================================================================
# A parsed colour is returned via four out-bytes + a "present" flag.

def parse_color(buf: Ptr[uint8], start: uint64, end: uint64,
                out_r: Ptr[uint8], out_g: Ptr[uint8],
                out_b: Ptr[uint8], out_a: Ptr[uint8]) -> int32:
    # Supports "#rrggbb", "#rgb" and "rgba(r,g,b,a)" (a = 0..255).
    # Returns 1 on success.
    i: uint64 = start
    while i < end and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    if i >= end:
        return 0
    if buf[i] == 35:                                 # '#'
        i = i + 1
        # count hex digits available
        h0: uint64 = i
        while i < end and hex_nibble(buf[i]) >= 0:
            i = i + 1
        ndig: uint64 = i - h0
        if ndig >= 6:
            out_r[0] = cast[uint8]((hex_nibble(buf[h0]) * 16) + hex_nibble(buf[h0 + 1]))
            out_g[0] = cast[uint8]((hex_nibble(buf[h0 + 2]) * 16) + hex_nibble(buf[h0 + 3]))
            out_b[0] = cast[uint8]((hex_nibble(buf[h0 + 4]) * 16) + hex_nibble(buf[h0 + 5]))
            out_a[0] = 255
            return 1
        if ndig >= 3:
            # #rgb -> #rrggbb
            rr: int32 = hex_nibble(buf[h0])
            gg: int32 = hex_nibble(buf[h0 + 1])
            bb: int32 = hex_nibble(buf[h0 + 2])
            out_r[0] = cast[uint8](rr * 16 + rr)
            out_g[0] = cast[uint8](gg * 16 + gg)
            out_b[0] = cast[uint8](bb * 16 + bb)
            out_a[0] = 255
            return 1
        return 0
    # rgba( / rgb(
    if buf[i] == 114:                                # 'r'
        # skip to '('
        while i < end and buf[i] != 40:
            i = i + 1
        if i >= end:
            return 0
        i = i + 1
        comp: Array[4, int64]
        comp[0] = 0
        comp[1] = 0
        comp[2] = 0
        comp[3] = 255
        ci: uint64 = 0
        while i < end and buf[i] != 41 and ci < 4:
            while i < end and (buf[i] == 32 or buf[i] == 9):
                i = i + 1
            v: int64 = 0
            got: int32 = 0
            while i < end and buf[i] >= 48 and buf[i] <= 57:
                v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
                got = 1
                i = i + 1
            if got != 0:
                comp[ci] = v
                ci = ci + 1
            while i < end and buf[i] != 44 and buf[i] != 41:
                i = i + 1
            if i < end and buf[i] == 44:
                i = i + 1
        out_r[0] = cast[uint8](comp[0])
        out_g[0] = cast[uint8](comp[1])
        out_b[0] = cast[uint8](comp[2])
        out_a[0] = cast[uint8](comp[3])
        return 1
    return 0


# ====================================================================
# hamML attribute extraction
# ====================================================================
# Given a tag's attribute span [astart, aend) inside markup_buf, find an
# attribute named `name` and return its raw VALUE span via out_vs/out_ve.
# Returns 1 if found. Values may be unquoted (x=10) or quoted (fill="#f00").

def find_attr(astart: uint64, aend: uint64, name: Ptr[uint8],
              out_vs: Ptr[uint64], out_ve: Ptr[uint64]) -> int32:
    nlen: uint64 = strlen_u8(name)
    i: uint64 = astart
    while i < aend:
        # skip whitespace
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9 or
                            markup_buf[i] == 10 or markup_buf[i] == 13):
            i = i + 1
        # read an attribute name
        ns: uint64 = i
        while i < aend and markup_buf[i] != 61 and markup_buf[i] != 32 and \
              markup_buf[i] != 9 and markup_buf[i] != 10 and \
              markup_buf[i] != 13 and markup_buf[i] != 47 and \
              markup_buf[i] != 62:
            i = i + 1
        ne: uint64 = i
        # skip whitespace before '='
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
            i = i + 1
        if i < aend and markup_buf[i] == 61:           # '='
            i = i + 1
            while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
                i = i + 1
            vs: uint64 = 0
            ve: uint64 = 0
            if i < aend and (markup_buf[i] == 34 or markup_buf[i] == 39):
                q: uint8 = markup_buf[i]
                i = i + 1
                vs = i
                while i < aend and markup_buf[i] != q:
                    i = i + 1
                ve = i
                if i < aend:
                    i = i + 1
            else:
                vs = i
                while i < aend and markup_buf[i] != 32 and markup_buf[i] != 9 and \
                      markup_buf[i] != 10 and markup_buf[i] != 13 and \
                      markup_buf[i] != 47 and markup_buf[i] != 62:
                    i = i + 1
                ve = i
            # name match?
            if (ne - ns) == nlen:
                k: uint64 = 0
                matched: int32 = 1
                while k < nlen:
                    if markup_buf[ns + k] != name[k]:
                        matched = 0
                        k = nlen
                    else:
                        k = k + 1
                if matched != 0:
                    out_vs[0] = vs
                    out_ve[0] = ve
                    return 1
        else:
            # attribute with no value (rare); skip on
            i = ne + 1
    return 0


def attr_i64(astart: uint64, aend: uint64, name: Ptr[uint8],
             dflt: int64) -> int64:
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, name, &vs[0], &ve[0]) == 0:
        return dflt
    return parse_i64_span(&markup_buf[0], vs[0], ve[0])


# ====================================================================
# Rasterising primitives into the current layer buffer
# ====================================================================

def raster_rect(x: int64, y: int64, w: int64, h: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    yy: int64 = y
    ymax: int64 = y + h
    while yy < ymax:
        xx: int64 = x
        xmax: int64 = x + w
        while xx < xmax:
            layer_put(xx, yy, r, g, b, a)
            xx = xx + 1
        yy = yy + 1


def iabs(v: int64) -> int64:
    if v < 0:
        return 0 - v
    return v


def raster_line(x0: int64, y0: int64, x1: int64, y1: int64, width: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Bresenham. `width` thickens by stamping a (width x width) block.
    dx: int64 = iabs(x1 - x0)
    dy: int64 = 0 - iabs(y1 - y0)
    sx: int64 = -1
    if x0 < x1:
        sx = 1
    sy: int64 = -1
    if y0 < y1:
        sy = 1
    err: int64 = dx + dy
    cx: int64 = x0
    cy: int64 = y0
    half: int64 = width / 2
    while True:
        # stamp a width x width block centred on (cx,cy)
        oy: int64 = 0 - half
        while oy <= half:
            ox: int64 = 0 - half
            while ox <= half:
                layer_put(cx + ox, cy + oy, r, g, b, a)
                ox = ox + 1
            oy = oy + 1
        if cx == x1 and cy == y1:
            break
        e2: int64 = err * 2
        if e2 >= dy:
            err = err + dy
            cx = cx + sx
        if e2 <= dx:
            err = err + dx
            cy = cy + sy


def raster_glyph(ch: uint8, x: int64, y: int64,
                 r: uint8, g: uint8, b: uint8, a: uint8):
    # 8x16 mono glyph; (x,y) is the TOP-LEFT of the cell.
    if ch < 32 or ch > 126:
        return
    gi: uint64 = cast[uint64](ch) - 32
    row: uint64 = 0
    while row < 16:
        bits: uint8 = font_glyphs[gi * 16 + row]
        col: uint64 = 0
        while col < 8:
            mask: uint8 = cast[uint8](128 >> col)
            if (bits & mask) != 0:
                layer_put(x + cast[int64](col), y + cast[int64](row), r, g, b, a)
            col = col + 1
        row = row + 1


def raster_text(text_s: uint64, text_e: uint64, x: int64, y: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Render markup_buf[text_s..text_e) as 8x16 mono. The hamML `y` is
    # the text BASELINE-ish anchor; we treat it as the cell top for the
    # mono font (good enough for v1 / AI-debug). Advance 8 px per glyph.
    cx: int64 = x
    i: uint64 = text_s
    while i < text_e:
        c: uint8 = markup_buf[i]
        if c == 10 or c == 13:
            i = i + 1
        else:
            raster_glyph(c, cx, y, r, g, b, a)
            cx = cx + 8
            i = i + 1


# Blit a referenced fb LAYER's buffer into the current layer at (dx,dy).
# `src_slot` is the layer-table index of the referenced layer.
def raster_image_fb(src_slot: uint64, dx: int64, dy: int64,
                    dw: int64, dh: int64):
    # Read the source layer's fb body into fb_read_buf.
    nread: int64 = read_layer_fb(src_slot)
    if nread <= 0:
        return
    sw: int64 = LT_W[src_slot]
    sh: int64 = LT_H[src_slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    # default destination size = source size
    tw: int64 = dw
    th: int64 = dh
    if tw <= 0:
        tw = sw
    if th <= 0:
        th = sh
    yy: int64 = 0
    while yy < th:
        xx: int64 = 0
        while xx < tw:
            # nearest-neighbour sample
            srx: int64 = (xx * sw) / tw
            sry: int64 = (yy * sh) / th
            if srx < sw and sry < sh:
                so: uint64 = cast[uint64](sry * sw + srx) * 4
                if so + 3 < cast[uint64](nread):
                    pr: uint8 = fb_read_buf[so]
                    pg: uint8 = fb_read_buf[so + 1]
                    pb: uint8 = fb_read_buf[so + 2]
                    pa: uint8 = fb_read_buf[so + 3]
                    # fb is premultiplied; un-premultiply is unnecessary
                    # because layer_put premultiplies by `a` again. For a
                    # faithful blit we treat stored RGB as straight and
                    # pass alpha through.
                    layer_put(dx + xx, dy + yy, pr, pg, pb, pa)
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Path building + cdev reads
# ====================================================================

def build_path(wid: int32, layer: Ptr[uint8], leaf: Ptr[uint8]):
    # Compose "/dev/wsys/<wid>/draw[/<layer>][/<leaf>]" into path_buf.
    # layer NULL/empty -> ".../draw"; leaf NULL/empty -> no trailing leaf.
    p: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while p[j] != 0:
        path_buf[i] = p[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    d: Ptr[uint8] = "/draw"
    j = 0
    while d[j] != 0:
        path_buf[i] = d[j]
        i = i + 1
        j = j + 1
    if layer != cast[Ptr[uint8]](0) and layer[0] != 0:
        path_buf[i] = 47                              # '/'
        i = i + 1
        j = 0
        while layer[j] != 0:
            path_buf[i] = layer[j]
            i = i + 1
            j = j + 1
        if leaf != cast[Ptr[uint8]](0) and leaf[0] != 0:
            path_buf[i] = 47
            i = i + 1
            j = 0
            while leaf[j] != 0:
                path_buf[i] = leaf[j]
                i = i + 1
                j = j + 1
    path_buf[i] = 0


def read_whole(fd: int32, buf: Ptr[uint8], cap: uint64) -> int64:
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    return cast[int64](total)


def layer_name_ptr(slot: uint64) -> Ptr[uint8]:
    return &LT_NAME[slot * 32]


def read_layer_markup(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "markup")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &markup_buf[0], 8192)
    sys_close(fd)
    return n


# read_layer_fb reads the layer at table-index `slot` into fb_read_buf.
# Returns bytes read.
read_fb_wid: int32 = 1
def read_layer_fb(slot: uint64) -> int64:
    build_path(read_fb_wid, layer_name_ptr(slot), "fb")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &fb_read_buf[0], 262144)
    sys_close(fd)
    return n


def read_layer_opacity(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "opacity")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return 255
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 255
    return parse_i64_span(&num_buf[0], 0, cast[uint64](n))


# ====================================================================
# Parse the draw listing into the layer table
# ====================================================================
# Each listing line:
#   "<name>  z=<z>  kind=<markup|fb>  <x>x<y>..<x2>x<y2>  opacity=<o>"

def parse_listing(wid: int32) -> int32:
    build_path(wid, cast[Ptr[uint8]](0), cast[Ptr[uint8]](0))
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &list_buf[0], 4096)
    sys_close(fd)
    if n < 0:
        return -1
    total: uint64 = cast[uint64](n)
    LT_COUNT = 0
    i: uint64 = 0
    while i < total and LT_COUNT < MAX_LAYERS:
        ls: uint64 = i
        while i < total and list_buf[i] != 10:
            i = i + 1
        le: uint64 = i
        if i < total:
            i = i + 1
        if le > ls:
            parse_listing_line(ls, le)
    return 0


def parse_listing_line(ls: uint64, le: uint64):
    slot: uint64 = LT_COUNT
    # name = run up to first space
    p: uint64 = ls
    while p < le and list_buf[p] != 32:
        p = p + 1
    nlen: uint64 = p - ls
    if nlen >= 32:
        nlen = 31
    k: uint64 = 0
    while k < nlen:
        LT_NAME[slot * 32 + k] = list_buf[ls + k]
        k = k + 1
    LT_NAME[slot * 32 + nlen] = 0
    # find "kind=" -> markup/fb
    LT_KIND[slot] = 0
    kk: uint64 = find_substr(ls, le, "kind=")
    if kk < le:
        c: uint8 = list_buf[kk + 5]
        if c == 102:                                  # 'f' (fb)
            LT_KIND[slot] = 1
    # geometry "<x>x<y>..<x2>x<y2>": parse the two corner pairs.
    gg: uint64 = find_geom(ls, le)
    x0: int64 = 0
    y0: int64 = 0
    x1: int64 = 0
    y1: int64 = 0
    if gg < le:
        q: uint64 = gg
        x0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:          # 'x'
            q = q + 1
        if q < le:
            q = q + 1
        y0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 46:           # '.'
            q = q + 1
        while q < le and list_buf[q] == 46:
            q = q + 1
        x1 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:
            q = q + 1
        if q < le:
            q = q + 1
        y1 = parse_i64_span(&list_buf[0], q, le)
    LT_X[slot] = x0
    LT_Y[slot] = y0
    LT_W[slot] = x1 - x0
    LT_H[slot] = y1 - y0
    # opacity
    oo: uint64 = find_substr(ls, le, "opacity=")
    if oo < le:
        LT_OPAC[slot] = parse_i64_span(&list_buf[0], oo + 8, le)
    else:
        LT_OPAC[slot] = 255
    LT_COUNT = LT_COUNT + 1


def find_substr(ls: uint64, le: uint64, needle: Ptr[uint8]) -> uint64:
    nlen: uint64 = strlen_u8(needle)
    i: uint64 = ls
    while i + nlen <= le:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            if list_buf[i + k] != needle[k]:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return i
        i = i + 1
    return le


# Find the geometry field: the first run of digits that is FOLLOWED by an
# 'x' then digits then ".." . We locate it after the "kind=..." token by
# scanning for the ".." separator and backing up to its number start.
def find_geom(ls: uint64, le: uint64) -> uint64:
    # Find the ".." then walk backward to the start of <x>.
    dd: uint64 = le
    i: uint64 = ls
    while i + 1 < le:
        if list_buf[i] == 46 and list_buf[i + 1] == 46:
            dd = i
            i = le
        else:
            i = i + 1
    if dd >= le:
        return le
    # back up over "<x>x<y>" — find the start: skip back over digits,
    # one 'x', digits, to a leading space.
    j: uint64 = dd
    # j currently at first '.'; the char before is the last digit of y0.
    while j > ls and list_buf[j - 1] != 32:
        j = j - 1
    return j


# ====================================================================
# Layer rasterisation: parse hamML and draw into layerbuf
# ====================================================================

def slot_for_fbref(name_s: uint64, name_e: uint64) -> int64:
    # Match markup_buf[name_s..name_e) against a layer name in the table.
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        ll: uint64 = strlen_u8(lp)
        if ll == (name_e - name_s):
            k: uint64 = 0
            ok: int32 = 1
            while k < ll:
                if lp[k] != markup_buf[name_s + k]:
                    ok = 0
                    k = ll
                else:
                    k = k + 1
            if ok != 0:
                return cast[int64](si)
        si = si + 1
    return -1


def rasterise_markup(wid: int32, slot: uint64):
    n: int64 = read_layer_markup(wid, slot)
    if n <= 0:
        return
    total: uint64 = cast[uint64](n)
    # group translate accumulator (translate-only v1)
    gtx: int64 = 0
    gty: int64 = 0
    i: uint64 = 0
    while i < total:
        if markup_buf[i] != 60:                        # '<'
            i = i + 1
        else:
            ts: uint64 = i + 1
            # closing tag?
            if ts < total and markup_buf[ts] == 47:    # '</'
                # check for </group>
                if tag_is(ts + 1, total, "group"):
                    gtx = 0
                    gty = 0
                # skip to '>'
                while i < total and markup_buf[i] != 62:
                    i = i + 1
                i = i + 1
            else:
                # read tag name
                ne: uint64 = ts
                while ne < total and markup_buf[ne] != 32 and \
                      markup_buf[ne] != 9 and markup_buf[ne] != 10 and \
                      markup_buf[ne] != 13 and markup_buf[ne] != 62 and \
                      markup_buf[ne] != 47:
                    ne = ne + 1
                astart: uint64 = ne
                # find end of tag '>'
                te: uint64 = ne
                while te < total and markup_buf[te] != 62:
                    te = te + 1
                aend: uint64 = te
                # self-closing? trailing '/'
                # (we don't special-case; attrs parse the same)
                handle_tag(wid, ts, ne, astart, aend, gtx, gty,
                           &gtx, &gty, total)
                i = te + 1
    return


def tag_is(s: uint64, total: uint64, name: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(name)
    k: uint64 = 0
    while k < nlen:
        if s + k >= total:
            return 0
        if markup_buf[s + k] != name[k]:
            return 0
        k = k + 1
    return 1


def handle_tag(wid: int32, ns: uint64, ne: uint64,
               astart: uint64, aend: uint64,
               gtx: int64, gty: int64,
               gtx_out: Ptr[int64], gty_out: Ptr[int64],
               total: uint64):
    # default colours
    r: Array[1, uint8]
    g: Array[1, uint8]
    b: Array[1, uint8]
    a: Array[1, uint8]
    if tag_is(ns, total, "rect") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "line") != 0 and (ne - ns) == 4:
        x1: int64 = attr_i64(astart, aend, "x1", 0) + gtx
        y1: int64 = attr_i64(astart, aend, "y1", 0) + gty
        x2: int64 = attr_i64(astart, aend, "x2", 0) + gtx
        y2: int64 = attr_i64(astart, aend, "y2", 0) + gty
        wd: int64 = attr_i64(astart, aend, "width", 1)
        if wd < 1:
            wd = 1
        r[0] = 200
        g[0] = 200
        b[0] = 200
        a[0] = 255
        get_stroke(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_line(x1, y1, x2, y2, wd, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "text") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        # text content is between aend+1 ('>') and the next '<'
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        raster_text(cs, ce, x, y, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "button") != 0 and (ne - ns) == 6:
        # draw a filled box + label text
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 64)
        h: int64 = attr_i64(astart, aend, "h", 20)
        r[0] = 80
        g[0] = 80
        b[0] = 80
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        raster_text(cs, ce, x + 4, y + 2, 255, 255, 255, 255)
        return
    if tag_is(ns, total, "input") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 100)
        h: int64 = attr_i64(astart, aend, "h", 18)
        raster_rect(x, y, w, h, 40, 40, 40, 255)
        # placeholder text
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "placeholder", &vs[0], &ve[0]) != 0:
            raster_text(vs[0], ve[0], x + 3, y + 1, 160, 160, 160, 255)
        return
    if tag_is(ns, total, "image") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "src", &vs[0], &ve[0]) != 0:
            # only "fb:<layer>" supported in v1
            s0: uint64 = vs[0]
            if (ve[0] - s0) > 3 and markup_buf[s0] == 102 and \
               markup_buf[s0 + 1] == 98 and markup_buf[s0 + 2] == 58:
                src_slot: int64 = slot_for_fbref(s0 + 3, ve[0])
                if src_slot >= 0:
                    raster_image_fb(cast[uint64](src_slot), x, y, w, h)
        return
    if tag_is(ns, total, "group") != 0 and (ne - ns) == 5:
        # transform="translate(dx,dy)"
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "transform", &vs[0], &ve[0]) != 0:
            tdx: Array[1, int64]
            tdy: Array[1, int64]
            tdx[0] = 0
            tdy[0] = 0
            parse_translate(vs[0], ve[0], &tdx[0], &tdy[0])
            gtx_out[0] = gtx + tdx[0]
            gty_out[0] = gty + tdy[0]
        return
    # <window ...> and unknown tags: ignore (metadata only).
    return


def get_fill(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
             b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "fill", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def get_stroke(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
               b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "stroke", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def apply_opacity(astart: uint64, aend: uint64, a: Ptr[uint8]):
    # per-element opacity 0..1 (float-shape) -> scale alpha. We accept
    # an integer 0..255 too (if value > 1). v1 keeps it simple: a value
    # "0".."1" with a dot is read as tenths/hundredths via the first two
    # fractional digits; otherwise treated as 0..255.
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "opacity", &vs[0], &ve[0]) == 0:
        return
    s: uint64 = vs[0]
    e: uint64 = ve[0]
    # whole part
    whole: int64 = parse_i64_span(&markup_buf[0], s, e)
    # fractional?
    di: uint64 = s
    while di < e and markup_buf[di] != 46:
        di = di + 1
    if di < e:
        # has a dot -> treat as 0..1 float; scale to 0..255
        # read up to two fractional digits
        f1: int64 = 0
        f2: int64 = 0
        if di + 1 < e and markup_buf[di + 1] >= 48 and markup_buf[di + 1] <= 57:
            f1 = cast[int64](cast[int32](markup_buf[di + 1]) - 48)
        if di + 2 < e and markup_buf[di + 2] >= 48 and markup_buf[di + 2] <= 57:
            f2 = cast[int64](cast[int32](markup_buf[di + 2]) - 48)
        frac: int64 = whole * 100 + f1 * 10 + f2     # 0..100 (clamp)
        if frac > 100:
            frac = 100
        a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](frac)) / 100)
    else:
        if whole >= 0 and whole <= 255:
            a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](whole)) / 255)


def parse_translate(s: uint64, e: uint64, dx: Ptr[int64], dy: Ptr[int64]):
    # "translate(DX,DY)"
    i: uint64 = s
    while i < e and markup_buf[i] != 40:               # '('
        i = i + 1
    if i >= e:
        return
    i = i + 1
    dx[0] = parse_i64_span(&markup_buf[0], i, e)
    while i < e and markup_buf[i] != 44:               # ','
        i = i + 1
    if i < e:
        i = i + 1
    dy[0] = parse_i64_span(&markup_buf[0], i, e)


# ====================================================================
# Composite the current layer buffer into the target with per-layer
# opacity. Both buffers are premultiplied RGBA.
# ====================================================================

def composite_layer(opac: int64):
    op: uint64 = cast[uint64](opac)
    if op > 255:
        op = 255
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            sa: uint64 = (cast[uint64](layerbuf[o + 3]) * op) / 255
            if sa != 0:
                sr: uint64 = (cast[uint64](layerbuf[o]) * op) / 255
                sg: uint64 = (cast[uint64](layerbuf[o + 1]) * op) / 255
                sb: uint64 = (cast[uint64](layerbuf[o + 2]) * op) / 255
                inv: uint64 = 255 - sa
                dr: uint64 = cast[uint64](target[o])
                dg: uint64 = cast[uint64](target[o + 1])
                db: uint64 = cast[uint64](target[o + 2])
                target[o] = cast[uint8](sr + (dr * inv) / 255)
                target[o + 1] = cast[uint8](sg + (dg * inv) / 255)
                target[o + 2] = cast[uint8](sb + (db * inv) / 255)
                target[o + 3] = 255
            x = x + 1
        y = y + 1


# ====================================================================
# Output: AI-readable text dump
# ====================================================================

def emit_hex_byte(v: uint8, out: Ptr[uint8]):
    hi: uint8 = cast[uint8]((cast[uint64](v) >> 4) & 15)
    lo: uint8 = cast[uint8](cast[uint64](v) & 15)
    if hi < 10:
        out[0] = 48 + hi
    else:
        out[0] = 97 + (hi - 10)
    if lo < 10:
        out[1] = 48 + lo
    else:
        out[1] = 97 + (lo - 10)


def emit_pix(x: uint64, y: uint64):
    # "PIX <x> <y> #rrggbb\n"
    o: uint64 = (y * WIN_W + x) * 4
    line: Array[40, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PIX "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(x, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(y, &line[p])
    line[p] = 32
    p = p + 1
    line[p] = 35                                       # '#'
    p = p + 1
    emit_hex_byte(target[o], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 1], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 2], &line[p])
    p = p + 2
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def is_bg(x: uint64, y: uint64) -> int32:
    o: uint64 = (y * WIN_W + x) * 4
    if target[o] == BG_R and target[o + 1] == BG_G and target[o + 2] == BG_B:
        return 1
    return 0


def count_nonbg_region(rx: uint64, ry: uint64, rw: uint64, rh: uint64) -> uint64:
    cnt: uint64 = 0
    y: uint64 = ry
    ymax: uint64 = ry + rh
    while y < ymax and y < WIN_H:
        x: uint64 = rx
        xmax: uint64 = rx + rw
        while x < xmax and x < WIN_W:
            if is_bg(x, y) == 0:
                cnt = cnt + 1
            x = x + 1
        y = y + 1
    return cnt


def emit_region(name: Ptr[uint8], rx: uint64, ry: uint64,
                rw: uint64, rh: uint64):
    # "REGION <name> <x> <y> <w> <h> nonbg=<count>\n" — a deterministic
    # test hook: lets a CI grep assert "the text band has >0 non-bg
    # pixels" without depending on the coarse probe grid landing on a
    # glyph stroke.
    cnt: uint64 = count_nonbg_region(rx, ry, rw, rh)
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "REGION "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    k = 0
    while name[k] != 0:
        line[p] = name[k]
        p = p + 1
        k = k + 1
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rx, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(ry, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rw, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rh, &line[p])
    sfx: Ptr[uint8] = " nonbg="
    k = 0
    while sfx[k] != 0:
        line[p] = sfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cnt, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def emit_ascii_art():
    # Downscale to ART_W x ART_H by sampling. '#' = non-background.
    ART_W: uint64 = 80
    ART_H: uint64 = 30
    line: Array[96, uint8]
    ry: uint64 = 0
    while ry < ART_H:
        p: uint64 = 0
        pfx: Ptr[uint8] = "ART "
        k: uint64 = 0
        while pfx[k] != 0:
            line[p] = pfx[k]
            p = p + 1
            k = k + 1
        rx: uint64 = 0
        while rx < ART_W:
            sx: uint64 = (rx * WIN_W) / ART_W
            sy: uint64 = (ry * WIN_H) / ART_H
            if is_bg(sx, sy) != 0:
                line[p] = 32                           # ' '
            else:
                line[p] = 35                           # '#'
            p = p + 1
            rx = rx + 1
        line[p] = 10
        p = p + 1
        sys_write(1, &line[0], p)
        ry = ry + 1


def emit_probe_grid():
    # A regular grid of probe pixels so a CI grep can assert colours at
    # known coordinates.
    PY: uint64 = 0
    while PY < WIN_H:
        PX: uint64 = 0
        while PX < WIN_W:
            emit_pix(PX, PY)
            PX = PX + 40
        PY = PY + 40


# ====================================================================
# Optional: write the composited frame into a "_screen" fb layer so the
# bytes round-trip through the cdev. Best-effort.
# ====================================================================

def write_screen_layer(wid: int32):
    # Ensure a "_screen" fb layer exists (256x256 max), then write a
    # downscaled copy of the target into its fb. ctl create is via
    # /dev/wsys/<wid>/draw/ctl.
    build_path(wid, cast[Ptr[uint8]](0), "ctl")
    cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if cf >= 0:
        cmd: Ptr[uint8] = "mklayer _screen fb 256 256\n"
        sys_write(cf, cmd, strlen_u8(cmd))
        sys_close(cf)
    # write fb: downscale target -> 256x256 into fb_read_buf, then write.
    yy: uint64 = 0
    while yy < FB_DIM:
        xx: uint64 = 0
        while xx < FB_DIM:
            sx: uint64 = (xx * WIN_W) / FB_DIM
            sy: uint64 = (yy * WIN_H) / FB_DIM
            so: uint64 = (sy * WIN_W + sx) * 4
            dout: uint64 = (yy * FB_DIM + xx) * 4
            fb_read_buf[dout] = target[so]
            fb_read_buf[dout + 1] = target[so + 1]
            fb_read_buf[dout + 2] = target[so + 2]
            fb_read_buf[dout + 3] = target[so + 3]
            xx = xx + 1
        yy = yy + 1
    build_path(wid, "_screen", "fb")
    wf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if wf >= 0:
        sys_write(wf, &fb_read_buf[0], FB_DIM * FB_DIM * 4)
        sys_close(wf)


# ====================================================================
# render <wid>
# ====================================================================

def cmd_render(wid: int32) -> int32:
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        write_str(2, "hamUId: cannot read /dev/wsys/<wid>/draw (no such wid?)\n")
        return 1
    target_clear()
    # Composite layers in listing order (kernel emits z-ascending).
    si: uint64 = 0
    while si < LT_COUNT:
        # Skip the synthetic _screen layer if present (avoid feedback).
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                # fb layer: read its pixels straight into the layer buf
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    # --- emit the AI-readable dump ---
    hdr: Array[96, uint8]
    p: uint64 = 0
    h0: Ptr[uint8] = "DUMP wid="
    k: uint64 = 0
    while h0[k] != 0:
        hdr[p] = h0[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &hdr[p])
    h1: Ptr[uint8] = " win=640x480 layers="
    k = 0
    while h1[k] != 0:
        hdr[p] = h1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(LT_COUNT, &hdr[p])
    hdr[p] = 10
    p = p + 1
    sys_write(1, &hdr[0], p)
    emit_probe_grid()
    # Deterministic region summaries (test hooks that don't depend on the
    # coarse probe grid landing on a specific glyph stroke). The "text"
    # band is to the RIGHT of any rect a chrome layer typically draws, so
    # a non-zero count there proves GLYPHS rasterised, not a rect.
    emit_region("text", 192, 32, 160, 32)
    emit_ascii_art()
    write_str(1, "DUMP END\n")
    # round-trip into _screen fb (best-effort; ignore errors)
    write_screen_layer(wid)
    return 0


def composite_fb_layer(wid: int32, slot: uint64):
    # Read the fb body and blit (with the layer geometry offset) into
    # the layer buffer.
    n: int64 = read_layer_fb(slot)
    if n <= 0:
        return
    sw: int64 = LT_W[slot]
    sh: int64 = LT_H[slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    ox: int64 = LT_X[slot]
    oy: int64 = LT_Y[slot]
    yy: int64 = 0
    while yy < sh:
        xx: int64 = 0
        while xx < sw:
            so: uint64 = cast[uint64](yy * sw + xx) * 4
            if so + 3 < cast[uint64](n):
                layer_put(ox + xx, oy + yy, fb_read_buf[so],
                          fb_read_buf[so + 1], fb_read_buf[so + 2],
                          fb_read_buf[so + 3])
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Phase 4c — physical presentation to /dev/fb
# ====================================================================
#
# `hamUId present <wid>` composites the window exactly like `render`
# (reusing the 4b compositor that fills `target` with the 640x480
# window frame), reads /dev/fb's geometry, scales the window frame to
# fit the screen with letterboxing (preserve aspect, centre, black
# bars), and writes it to /dev/fb as RGBA8888.
#
# We present one SCREEN ROW at a time into screen_row, then write the
# whole row to /dev/fb at the pixel offset (scr_y * scr_w) * 4. The
# kernel cdev repacks RGBA -> hardware pixel order per fb_pixfmt and
# honours fb_pitch, so userland only deals in RGBA8888. Row-at-a-time
# keeps userland memory bounded regardless of screen resolution.

SCREEN_ROW_MAXW: uint64 = 4096          # cap a single screen row at 4096 px
screen_row: Array[16384, uint8]         # SCREEN_ROW_MAXW * 4

# Parsed /dev/fb geometry.
FBG_W: uint64 = 0
FBG_H: uint64 = 0
FBG_PITCH: uint64 = 0
FBG_BPP: uint64 = 0
FBG_PIXFMT: uint64 = 0


def read_fb_geometry() -> int32:
    # Read "WIDTH HEIGHT PITCH BPP PIXFMT\n" from /dev/fb. Returns 1 on
    # success (FBG_* populated), 0 on failure.
    p: Ptr[uint8] = "/dev/fb"
    fd: int32 = sys_open(cast[Ptr[char]](p))
    if fd < 0:
        return 0
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 0
    total: uint64 = cast[uint64](n)
    # Parse five space-separated decimals.
    pos: Array[1, uint64]
    pos[0] = 0
    FBG_W = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_H = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PITCH = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_BPP = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PIXFMT = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    if FBG_W == 0 or FBG_H == 0:
        return 0
    return 1


def next_dec(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip non-digits, then parse a run of decimal digits. Advances *pos.
    i: uint64 = pos[0]
    while i < total and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    return v


def composite_window(wid: int32) -> int32:
    # Run the 4b compositor: parse the layer listing, fill `target` with
    # the composited 640x480 window frame. Returns 0 on success, 1 if
    # the wid's draw listing can't be read.
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        return 1
    target_clear()
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    return 0


def cmd_present(wid: int32) -> int32:
    if composite_window(wid) != 0:
        write_str(2, "hamUId: present: cannot read /dev/wsys/<wid>/draw\n")
        return 1
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: present: cannot read /dev/fb geometry\n")
        return 1
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    # Aspect-preserving fit of WIN_W x WIN_H into sw x sh. Integer math:
    # scale numerator/denominator = min(sw/WIN_W, sh/WIN_H). To avoid
    # fractions we compute the destination content rectangle directly.
    #   fit_w = min(sw, sh * WIN_W / WIN_H)
    #   fit_h = min(sh, sw * WIN_H / WIN_W)
    fit_w: uint64 = sw
    fit_h: uint64 = (sw * WIN_H) / WIN_W
    if fit_h > sh:
        fit_h = sh
        fit_w = (sh * WIN_W) / WIN_H
    if fit_w > sw:
        fit_w = sw
    if fit_w == 0:
        fit_w = 1
    if fit_h == 0:
        fit_h = 1
    # Letterbox offsets (centre the content rect).
    ox: uint64 = (sw - fit_w) / 2
    oy: uint64 = (sh - fit_h) / 2
    # Open /dev/fb for writing the frame.
    pw: Ptr[uint8] = "/dev/fb"
    wf: int32 = sys_open_write(cast[Ptr[char]](pw))
    if wf < 0:
        write_str(2, "hamUId: present: cannot open /dev/fb for write\n")
        return 1
    # Emit one screen row at a time.
    sy: uint64 = 0
    while sy < sh:
        # Clear row to black (letterbox bars).
        ci: uint64 = 0
        rb: uint64 = sw * 4
        while ci < rb:
            screen_row[ci] = 0
            ci = ci + 1
        # If this screen row is inside the content band, scale-sample the
        # window frame into it.
        if sy >= oy and sy < oy + fit_h:
            # Source row in the window (nearest-neighbour).
            relq: uint64 = sy - oy
            srcy: uint64 = (relq * WIN_H) / fit_h
            if srcy >= WIN_H:
                srcy = WIN_H - 1
            dx: uint64 = 0
            while dx < fit_w:
                srcx: uint64 = (dx * WIN_W) / fit_w
                if srcx >= WIN_W:
                    srcx = WIN_W - 1
                so: uint64 = (srcy * WIN_W + srcx) * 4
                doff: uint64 = (ox + dx) * 4
                if (ox + dx) < sw:
                    screen_row[doff] = target[so]
                    screen_row[doff + 1] = target[so + 1]
                    screen_row[doff + 2] = target[so + 2]
                    screen_row[doff + 3] = 255
                dx = dx + 1
        # Write this row at its pixel offset in the screen frame. The fd
        # cursor advances by the bytes written, so successive rows land
        # at the right offset automatically (no explicit lseek needed —
        # we write exactly sw*4 bytes per row, contiguously).
        sys_write(wf, &screen_row[0], sw * 4)
        sy = sy + 1
    sys_close(wf)
    # Emit a deterministic AI/CI-readable summary line so a headless test
    # can assert the present happened even without screendump.
    emit_present_summary(wid, sw, sh, fit_w, fit_h, ox, oy)
    return 0


def emit_present_summary(wid: int32, sw: uint64, sh: uint64,
                         fit_w: uint64, fit_h: uint64,
                         ox: uint64, oy: uint64):
    # "PRESENT wid=<w> screen=<sw>x<sh> fit=<fw>x<fh> off=<ox>,<oy>\n"
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PRESENT wid="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &line[p])
    s1: Ptr[uint8] = " screen="
    k = 0
    while s1[k] != 0:
        line[p] = s1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(sw, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(sh, &line[p])
    s2: Ptr[uint8] = " fit="
    k = 0
    while s2[k] != 0:
        line[p] = s2[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(fit_w, &line[p])
    line[p] = 120
    p = p + 1
    p = p + u64_to_dec(fit_h, &line[p])
    s3: Ptr[uint8] = " off="
    k = 0
    while s3[k] != 0:
        line[p] = s3[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(ox, &line[p])
    line[p] = 44                                     # ','
    p = p + 1
    p = p + u64_to_dec(oy, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


# ====================================================================
# Phase 4c-interactive — the persistent daemon
# ====================================================================
#
#   hamUId daemon
#       A persistent present-loop that owns the physical framebuffer:
#         * opens /dev/fb (geometry once) and /dev/mouse,
#         * maintains a cursor position (starts at screen centre) driven
#           by the mouse dx/dy each iteration, clamped to screen bounds,
#         * composites a flat root backdrop + every window created by the
#           drag gesture + the cursor (a small arrow), and PRESENTS the
#           result to /dev/fb whenever anything changed,
#         * implements the canonical rio DRAG-TO-CREATE gesture: a
#           left-button-down at (x0,y0) begins a drag; while held a
#           rubber-band outline rectangle tracks the cursor; a
#           left-button-up at (x1,y1), if the swept rectangle exceeds a
#           small threshold, allocates a new wid (sys_spawn detached
#           hamsh + sys_wsys_alloc, mirroring user/hamUI.ad's cmd_new)
#           and records the rectangle as a window so its chrome paints
#           where it was dragged.
#
#       It does NOT auto-start at boot — it is launched explicitly (by a
#       user or a test). It yields the CPU every idle iteration so it
#       never spins at 100%.
#
# The daemon owns the WHOLE physical screen (unlike `present`, which
# scales one 640x480 window). It composites directly at screen
# resolution one ROW at a time into screen_row (reused from `present`),
# computing each pixel from a tiny model — backdrop, the window table,
# the rubber band, and the cursor — so userland memory stays bounded
# regardless of screen size.

# Root backdrop colour (a calm slate so window chrome and the cursor
# stand out for screendump assertions). The "Change Background" desktop
# context-menu action cycles ROOT_* through BG_PALETTE (MATE lets you
# pick a solid colour from the right-click menu); BG_IDX selects the
# current entry.
ROOT_R: uint8 = 32
ROOT_G: uint8 = 48
ROOT_B: uint8 = 72

# Solid-colour backdrop palette (MATE-style). Each row is r,g,b. The
# desktop context menu's "Change Background" steps BG_IDX through these.
BG_COUNT: int32 = 5
BG_IDX:   int32 = 0
bg_palette: Array[15, uint8]
BG_PALETTE_INIT: int32 = 0


# Seed the backdrop palette (slate / teal / plum / forest / graphite).
def bg_palette_init():
    if BG_PALETTE_INIT != 0:
        return
    BG_PALETTE_INIT = 1
    bg_palette[0] = 32     # 0: slate (default)
    bg_palette[1] = 48
    bg_palette[2] = 72
    bg_palette[3] = 28     # 1: teal
    bg_palette[4] = 64
    bg_palette[5] = 70
    bg_palette[6] = 56     # 2: plum
    bg_palette[7] = 40
    bg_palette[8] = 76
    bg_palette[9] = 30     # 3: forest
    bg_palette[10] = 66
    bg_palette[11] = 46
    bg_palette[12] = 44    # 4: graphite
    bg_palette[13] = 46
    bg_palette[14] = 52


# Advance the desktop backdrop to the next palette entry (wraps). Emits a
# serial marker so a non-pixel test can assert the change fired.
def bg_cycle():
    bg_palette_init()
    BG_IDX = BG_IDX + 1
    if BG_IDX >= BG_COUNT:
        BG_IDX = 0
    base: uint64 = cast[uint64](BG_IDX) * 3
    ROOT_R = bg_palette[base]
    ROOT_G = bg_palette[base + 1]
    ROOT_B = bg_palette[base + 2]
    pfx: Ptr[uint8] = "DESK background "
    sys_write(1, pfx, strlen_u8(pfx))
    nb: Array[4, uint8]
    nb[0] = cast[uint8](BG_IDX) + 48
    nb[1] = 10
    sys_write(1, &nb[0], 2)


# ====================================================================
# ROUND-4: themeable title-bar accent palette (MATE "Appearance")
# ====================================================================
# The active-window title-bar gradient reads a top/bottom RGB pair from
# the THEME accent palette instead of a fixed blue. The Settings app and a
# keyboard action cycle THEME_IDX through these named accents, persisting
# the choice for the session (in-memory). The gradient code in daemon_pixel
# reads ACCENT_TOP_*/ACCENT_BOT_*, which theme_apply() refreshes.
THEME_COUNT: int32 = 5
THEME_IDX:   int32 = 0
ACCENT_TOP_R: uint8 = 120
ACCENT_TOP_G: uint8 = 178
ACCENT_TOP_B: uint8 = 252
ACCENT_BOT_R: uint8 = 56
ACCENT_BOT_G: uint8 = 116
ACCENT_BOT_B: uint8 = 208
theme_palette: Array[30, uint8]
THEME_PALETTE_INIT: int32 = 0


def theme_palette_init():
    if THEME_PALETTE_INIT != 0:
        return
    THEME_PALETTE_INIT = 1
    theme_palette[0] = 120          # 0: Clearlooks Blue (default)
    theme_palette[1] = 178
    theme_palette[2] = 252
    theme_palette[3] = 56
    theme_palette[4] = 116
    theme_palette[5] = 208
    theme_palette[6] = 150          # 1: Graphite
    theme_palette[7] = 156
    theme_palette[8] = 168
    theme_palette[9] = 84
    theme_palette[10] = 90
    theme_palette[11] = 104
    theme_palette[12] = 130         # 2: Sage Green
    theme_palette[13] = 200
    theme_palette[14] = 140
    theme_palette[15] = 56
    theme_palette[16] = 130
    theme_palette[17] = 76
    theme_palette[18] = 240         # 3: Amber
    theme_palette[19] = 190
    theme_palette[20] = 90
    theme_palette[21] = 200
    theme_palette[22] = 120
    theme_palette[23] = 40
    theme_palette[24] = 200         # 4: Plum
    theme_palette[25] = 150
    theme_palette[26] = 230
    theme_palette[27] = 120
    theme_palette[28] = 70
    theme_palette[29] = 160


# Refresh the live accent endpoints from THEME_IDX.
def theme_apply():
    theme_palette_init()
    if THEME_IDX < 0:
        THEME_IDX = 0
    if THEME_IDX >= THEME_COUNT:
        THEME_IDX = 0
    base: uint64 = cast[uint64](THEME_IDX) * 6
    ACCENT_TOP_R = theme_palette[base]
    ACCENT_TOP_G = theme_palette[base + 1]
    ACCENT_TOP_B = theme_palette[base + 2]
    ACCENT_BOT_R = theme_palette[base + 3]
    ACCENT_BOT_G = theme_palette[base + 4]
    ACCENT_BOT_B = theme_palette[base + 5]


# Advance the title-bar accent theme to the next entry (wraps). Emits a
# serial marker so a non-pixel test can assert the change fired.
def theme_cycle():
    theme_palette_init()
    THEME_IDX = THEME_IDX + 1
    if THEME_IDX >= THEME_COUNT:
        THEME_IDX = 0
    theme_apply()
    pfx: Ptr[uint8] = "DESK theme "
    sys_write(1, pfx, strlen_u8(pfx))
    tb: Array[4, uint8]
    tb[0] = cast[uint8](THEME_IDX) + 48
    tb[1] = 10
    sys_write(1, &tb[0], 2)


# Short accent name for the Settings display.
def theme_name(i: int32) -> Ptr[uint8]:
    if i == 0:
        n0: Ptr[uint8] = "Blue"
        return n0
    if i == 1:
        n1: Ptr[uint8] = "Graphite"
        return n1
    if i == 2:
        n2: Ptr[uint8] = "Sage"
        return n2
    if i == 3:
        n3: Ptr[uint8] = "Amber"
        return n3
    n4: Ptr[uint8] = "Plum"
    return n4


# ====================================================================
# ROUND-4: panel position preference (top / bottom)
# ====================================================================
# The MATE panel can live at the top or the bottom of the screen. The
# Settings app records the user's preference (PANEL_POS: 0 top, 1 bottom)
# so the choice persists for the session and is reported in the marker
# stream.
PANEL_POS: int32 = 0          # 0 = top (default), 1 = bottom


def panel_pos_toggle():
    if PANEL_POS == 0:
        PANEL_POS = 1
    else:
        PANEL_POS = 0
    pfx: Ptr[uint8] = "DESK panel-pos "
    sys_write(1, pfx, strlen_u8(pfx))
    pb: Array[4, uint8]
    pb[0] = cast[uint8](PANEL_POS) + 48
    pb[1] = 10
    sys_write(1, &pb[0], 2)


def panel_pos_name(p: int32) -> Ptr[uint8]:
    if p == 0:
        t0: Ptr[uint8] = "Top"
        return t0
    t1: Ptr[uint8] = "Bottom"
    return t1


# ROUND-7: focus model preference. 0 = click-to-focus (default, MATE's
# normal mode), 1 = focus-follows-mouse (the window under the pointer is
# raised/focused as the cursor moves, GNOME2's "sloppy"/focus-follows
# option). Toggled from the Settings app and consulted by the pointer
# pump so the choice takes effect live.
FOCUS_MODE: int32 = 0          # 0 = click-to-focus, 1 = follows-mouse


def focus_mode_toggle():
    if FOCUS_MODE == 0:
        FOCUS_MODE = 1
    else:
        FOCUS_MODE = 0
    pfx: Ptr[uint8] = "DESK focus-mode "
    sys_write(1, pfx, strlen_u8(pfx))
    fb: Array[4, uint8]
    fb[0] = cast[uint8](FOCUS_MODE) + 48
    fb[1] = 10
    sys_write(1, &fb[0], 2)


def focus_mode_name(p: int32) -> Ptr[uint8]:
    if p == 0:
        f0: Ptr[uint8] = "Click"
        return f0
    f1: Ptr[uint8] = "Follow"
    return f1


# Arrange (tile) all visible windows on the current workspace into a grid
# that fills the work area below the panel — MATE's "arrange windows"
# desktop verb. Un-maximizes/un-snaps each first. Emits a marker.
def windows_arrange(scr_w: int64, scr_h: int64):
    # Count visible (non-minimized, current-workspace) windows.
    n: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) != 0:
            n = n + 1
        wi = wi + 1
    if n == 0:
        am0: Ptr[uint8] = "DESK arrange 0\n"
        sys_write(1, am0, strlen_u8(am0))
        return
    # Choose a near-square grid: cols = ceil(sqrt(n)).
    cols: int64 = 1
    while cols * cols < n:
        cols = cols + 1
    rows: int64 = (n + cols - 1) / cols
    work_y: int64 = PANEL_H
    work_h: int64 = scr_h - PANEL_H
    cell_w: int64 = scr_w / cols
    cell_h: int64 = work_h / rows
    gap: int64 = 6
    placed: int64 = 0
    wj: uint64 = 0
    while wj < DWIN_COUNT:
        if win_on_cur_ws(wj) != 0:
            col: int64 = placed % cols
            row: int64 = placed / cols
            nx: int64 = col * cell_w + gap
            ny: int64 = work_y + row * cell_h + gap
            nw: int64 = cell_w - gap * 2
            nh: int64 = cell_h - gap * 2
            if nw < 120:
                nw = 120
            if nh < 80:
                nh = 80
            DWIN_MAXED[wj] = 0
            DWIN_SNAP[wj] = 0
            DWIN_X[wj] = nx
            DWIN_Y[wj] = ny
            DWIN_W[wj] = nw
            DWIN_H[wj] = nh
            window_reflow(wj)
            placed = placed + 1
        wj = wj + 1
    am: Ptr[uint8] = "DESK arrange "
    sys_write(1, am, strlen_u8(am))
    ab: Array[4, uint8]
    ab[0] = cast[uint8](n) + 48
    ab[1] = 10
    sys_write(1, &ab[0], 2)

# Window chrome colours.
WIN_TITLE_R: uint8 = 64
WIN_TITLE_G: uint8 = 110
WIN_TITLE_B: uint8 = 200
# Focused (topmost) window: brighter title bar so the user can tell which
# window has keyboard focus at a glance.
WIN_TITLE_FOCUS_R: uint8 = 90
WIN_TITLE_FOCUS_G: uint8 = 150
WIN_TITLE_FOCUS_B: uint8 = 240
WIN_BODY_R: uint8 = 200
WIN_BODY_G: uint8 = 200
WIN_BODY_B: uint8 = 210
WIN_BORDER_R: uint8 = 240
WIN_BORDER_G: uint8 = 240
WIN_BORDER_B: uint8 = 250

TITLE_H: int64 = 18                      # window title-bar height (px)
DRAG_MIN: int64 = 12                     # min swept extent to spawn a win

# Close-box ([x]) colours: a red square with a white X glyph.
CLOSE_R: uint8 = 210
CLOSE_G: uint8 = 60
CLOSE_B: uint8 = 60
CLOSE_X_R: uint8 = 255
CLOSE_X_G: uint8 = 255
CLOSE_X_B: uint8 = 255

SIGTERM_D: int32 = 15

# ---- panel + Applications menu (GNOME2 / MATE classic launcher) -----
# A persistent horizontal PANEL bar along the TOP screen edge (the
# classic GNOME2 layout). At its left end sits an "Applications" menu
# button; clicking it drops a vertical menu of launchable programs.
# Clicking an entry spawns that program into a new window via the SAME
# spawn-into-window path the drag gesture uses; clicking off the menu
# dismisses it.
PANEL_H: int64 = 22                       # panel bar height (px)
PANEL_R: uint8 = 46                       # panel background (dark slate)
PANEL_G: uint8 = 52
PANEL_B: uint8 = 64
PANEL_HI_R: uint8 = 70                     # panel button hover/open tint
PANEL_HI_G: uint8 = 90
PANEL_HI_B: uint8 = 140
PANEL_TXT_R: uint8 = 235                   # panel label ink
PANEL_TXT_G: uint8 = 235
PANEL_TXT_B: uint8 = 240


# ====================================================================
# ROUND-11: panel-position-aware work-area geometry
# ====================================================================
# Through round 10 every layout helper hard-coded the panel at the TOP of
# the screen (windows reserve PANEL_H at y==0). MATE/GNOME2's default
# layout puts a panel at the BOTTOM, and the panel-position setting can be
# flipped at runtime. These helpers are the single geometry authority for
# "where does usable desktop start, and how tall is it" so a bottom panel
# genuinely reserves the BOTTOM strip rather than the top. PANEL_POS is the
# session preference (0 = top, 1 = bottom) already exposed in Settings.
#
#   work_top(scr_h)  -> y of the first usable desktop row
#   work_h(scr_h)    -> usable desktop height (screen minus the panel)
#   panel_top_y(scr_h) -> y of the panel bar itself
# All three are pure functions of PANEL_POS + PANEL_H so callers stay tiny.
def work_top(scr_h: int64) -> int64:
    if PANEL_POS == 1:
        return 0                          # bottom panel: desktop starts at top
    return PANEL_H                        # top panel: desktop starts below it


def work_h(scr_h: int64) -> int64:
    return scr_h - PANEL_H


def panel_top_y(scr_h: int64) -> int64:
    if PANEL_POS == 1:
        return scr_h - PANEL_H            # bottom panel sits flush to the floor
    return 0                              # top panel sits flush to the ceiling


# ====================================================================
# ROUND-12: physically render + hit-test the panel at the CORRECT edge.
# ====================================================================
# Round 11 made the WORK AREA panel-position-aware, but the panel BAR and
# every panel hit-test still assumed a top anchor (compared an absolute Y
# against 0..PANEL_H). These helpers move the bar — and the menus that
# drop off it — to the configured edge.
#
# The renderer + every panel hit-test caches the live screen height in
# FBG_H (read_fb_geometry() populates it before any frame/selftest), so
# these zero-arg helpers can answer "where is the panel" without threading
# scr_h through dozens of call sites.
#
#   panel_y0()        -> absolute screen-Y of the panel's top row.
#   panel_local_y(y)  -> Y relative to the panel's top (0..PANEL_H-1 on bar).
#   on_panel_y(y)     -> 1 if absolute Y falls on the panel bar.
#   drop_anchor_y(h)  -> absolute screen-Y where a drop-down of pixel
#                        height `h` begins. A top panel drops DOWNWARD from
#                        its bottom edge; a bottom panel drops UPWARD so the
#                        list grows toward the screen centre (classic MATE).
#   drop_row_top(h,i,ih) -> absolute Y of row `i` (height `ih`) within a
#                        drop-down of total height `h`. For a top panel rows
#                        run downward from the anchor; for a bottom panel the
#                        anchor is the list's BOTTOM, so row 0 is highest.
def panel_y0() -> int64:
    return panel_top_y(cast[int64](FBG_H))


def panel_local_y(y: int64) -> int64:
    return y - panel_y0()


def on_panel_y(y: int64) -> int32:
    ly: int64 = panel_local_y(y)
    if ly >= 0 and ly < PANEL_H:
        return 1
    return 0


def drop_anchor_y(h: int64) -> int64:
    if PANEL_POS == 1:
        # Bottom panel: the list sits ABOVE the bar, its bottom flush to the
        # panel's top edge. Its top row is therefore panel_top - h.
        return panel_y0() - h
    # Top panel: the list hangs below the bar.
    return panel_y0() + PANEL_H


# Absolute Y of row `i` (each `ih` tall) inside a drop-down whose total
# height is `h`. Both panel positions lay rows out top-to-bottom on screen
# (row 0 is visually the first), so the only thing that changes is where
# the whole list is anchored — handled by drop_anchor_y.
def drop_row_top(h: int64, i: int64, ih: int64) -> int64:
    return drop_anchor_y(h) + i * ih


# "Applications" button geometry (left end of the panel).
APPS_BTN_X: int64 = 4
APPS_BTN_W: int64 = 104                    # ~12 glyphs * 8px + padding

# Menu geometry: a vertical list dropping from just below the panel at
# the Applications button's left edge.
MENU_X: int64 = 4
MENU_W: int64 = 150
MENU_ITEM_H: int64 = 20                     # per-entry row height (px)
MENU_R: uint8 = 56                          # menu background
MENU_G: uint8 = 62
MENU_B: uint8 = 78
MENU_SEL_R: uint8 = 70                       # hovered item tint
MENU_SEL_G: uint8 = 100
MENU_SEL_B: uint8 = 170
MENU_TXT_R: uint8 = 235
MENU_TXT_G: uint8 = 235
MENU_TXT_B: uint8 = 240

MENU_OPEN: int32 = 0                         # 1 while the menu is dropped

# Menu entries: a parallel pair of (label, program-path) tables. Each
# program is a real built /bin/<name> binary (verified present in the
# build). Labels stay short so they fit MENU_W. String constants live
# inside menu_label()/menu_prog() (file-scope globals can't take string
# initialisers in Adder).
MENU_COUNT: uint64 = 9

# ---- taskbar (window-list buttons in the panel) -------------------
# Each open window gets a button on the panel, right of the
# Applications button. Buttons are TASKBAR_BTN_W pixels wide;
# minimized windows show their button in the dimmed tint, normal
# windows use the panel background; the focused (topmost) window
# gets the highlight tint.
TASKBAR_START_X: int64 = 112           # APPS_BTN_X + APPS_BTN_W + 4
TASKBAR_BTN_W:   int64 = 96           # fits ~10 chars at 8px + 16px padding
TASKBAR_BTN_H:   int64 = 20           # 1px top + 18px body + 1px bottom border
TASKBAR_BTN_Y:   int64 = 1            # top pixel within panel (1px border)

# Right-edge clock area: reserved on the right side of the panel.
# The clock string "HH:MM" is 5 chars * 8px + 8px padding each side = 56px.
CLOCK_W:  int64 = 56
CLOCK_PAD: int64 = 8                   # horizontal padding inside clock area

# Notification-area (system-tray): a small zone in the panel left of the
# clock holding status indicators — the GNOME2/MATE classic tray. Three
# cells: [0] network signal bars, [1] generic info dot, [2] ROUND-5 LIVE
# window-count badge (shows how many windows are open on the current
# workspace, updated every present). NOTIF_W is its total width; it sits
# just left of the workspace pager.
NOTIF_ICON: int64 = 14
NOTIF_PAD:  int64 = 3
NOTIF_CELLS: int64 = 3
# = NOTIF_CELLS*NOTIF_ICON + (NOTIF_CELLS+1)*NOTIF_PAD = 3*14 + 4*3 = 54.
NOTIF_W:    int64 = 54
# Live count of windows on the current workspace, refreshed each present so
# the tray badge tracks window open/close/minimize in real time.
NOTIF_WIN_COUNT: int64 = 0
# Scratch for the single-digit badge string.
notif_badge_buf: Array[4, uint8]

# ROUND-12: classic MATE "Show Desktop" applet — a small panel button that
# minimizes every window (and restores them on a second click). It sits on
# the panel just left of the clock zone. SHOWDESK_ON (declared with the
# other show-desktop state) drives a pressed/lit appearance.
SD_BTN_W: int64 = 18                   # show-desktop button width (px)

# Minimize-box geometry: a square just LEFT of the close box in the title bar.
MINIMIZE_BOX: int64 = 14              # same size as CLOSE_BOX
# Minimize box colours: yellow square with white dash.
MINIMIZE_R: uint8 = 200
MINIMIZE_G: uint8 = 160
MINIMIZE_B: uint8 = 40
MINIMIZE_DASH_R: uint8 = 255
MINIMIZE_DASH_G: uint8 = 255
MINIMIZE_DASH_B: uint8 = 255

# Clock background tint (darker than panel, so it reads as a separate zone).
CLOCK_R: uint8 = 36
CLOCK_G: uint8 = 42
CLOCK_B: uint8 = 54


# ====================================================================
# ROUND-7: clock calendar popup (drop-down monthly calendar)
# ====================================================================
# Clicking the panel clock toggles a small monthly calendar that drops
# from the clock zone, exactly like GNOME2/MATE's clock applet. The grid
# is a classic 7-column (Sun..Sat) month view; the current day-of-month
# is highlighted. The displayed month is parsed from /proc/realtime's
# YYYY-MM-DD when available; otherwise a neutral 30-day month is shown.
CAL_OPEN: int32 = 0                     # 1 while the calendar is dropped
CAL_W: int64 = 176                      # 7 cols * 24px + 8px frame
CAL_CELL_W: int64 = 24
CAL_CELL_H: int64 = 18
CAL_HEAD_H: int64 = 22                  # month-name header band
CAL_DOW_H: int64 = 16                   # day-of-week initials row
CAL_R: uint8 = 48                       # calendar body background
CAL_G: uint8 = 54
CAL_B: uint8 = 68
CAL_HEAD_R: uint8 = 34                   # header band (darker)
CAL_HEAD_G: uint8 = 40
CAL_HEAD_B: uint8 = 52
CAL_TXT_R: uint8 = 228
CAL_TXT_G: uint8 = 232
CAL_TXT_B: uint8 = 240

# Parsed current date (from /proc/realtime when readable, else a default).
CAL_YEAR:  int64 = 2026
CAL_MONTH: int64 = 1                    # 1..12
CAL_DAY:   int64 = 1                    # 1..31, the day to highlight
CAL_VALID: int32 = 0                    # 1 once parsed from a real clock
# Header strings live in cal_month_name(); scratch for the year digits.
cal_year_buf: Array[8, uint8]
cal_num_buf:  Array[4, uint8]


# ====================================================================
# ROUND-7: transient on-screen notification banner
# ====================================================================
# A lightweight notification API: notify_post() drops a banner at the
# top-right of the desktop (just under the panel) showing a title +
# message for NOTIFY_TTL frames, then it fades out over NOTIFY_FADE
# frames. notify_tick() ages it each present. Any window/applet can call
# notify_post() to surface a transient notice (MATE/libnotify feel).
NOTIFY_ACTIVE: int32 = 0                # 1 while a banner is on-screen
NOTIFY_AGE:    int64 = 0                # frames the current banner has lived
NOTIFY_TTL:    int64 = 180              # solid frames before fading begins
NOTIFY_FADE:   int64 = 60              # fade-out frames after the TTL
NOTIFY_W:      int64 = 260
NOTIFY_H:      int64 = 44
NOTIFY_R: uint8 = 40
NOTIFY_G: uint8 = 46
NOTIFY_B: uint8 = 60
NOTIFY_BORDER_R: uint8 = 110
NOTIFY_BORDER_G: uint8 = 150
NOTIFY_BORDER_B: uint8 = 230
# Title + body text buffers (capped; filled by notify_post()).
notify_title: Array[40, uint8]
notify_body:  Array[64, uint8]


# Copy a C string into a fixed buffer, truncating at cap-1, NUL-terminating.
def str_copy_cap(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while src[i] != 0 and i < cap - 1:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


# Post a transient notification banner with `title` and `body`. Resets the
# banner's age so it shows solid for NOTIFY_TTL frames, then fades. Emits a
# serial marker so non-graphical tests can observe the notice.
def notify_post(title: Ptr[uint8], body: Ptr[uint8]):
    str_copy_cap(&notify_title[0], title, 40)
    str_copy_cap(&notify_body[0], body, 64)
    NOTIFY_ACTIVE = 1
    NOTIFY_AGE = 0
    pfx: Ptr[uint8] = "NOTIFY "
    sys_write(1, pfx, strlen_u8(pfx))
    write_str(1, title)
    sp: Ptr[uint8] = ": "
    sys_write(1, sp, strlen_u8(sp))
    write_str(1, body)
    write_str(1, "\n")


# Age the active banner one frame. Returns 1 if the banner is still
# on-screen (so the present loop re-paints), else 0 once it has expired.
def notify_tick() -> int32:
    if NOTIFY_ACTIVE == 0:
        return 0
    NOTIFY_AGE = NOTIFY_AGE + 1
    if NOTIFY_AGE >= NOTIFY_TTL + NOTIFY_FADE:
        NOTIFY_ACTIVE = 0
        return 0
    return 1


# Current banner opacity as an 8-bit alpha (255 solid). Stays solid for
# NOTIFY_TTL frames, then ramps linearly to 0 across NOTIFY_FADE frames.
def notify_alpha() -> int64:
    if NOTIFY_AGE < NOTIFY_TTL:
        return 255
    fade_into: int64 = NOTIFY_AGE - NOTIFY_TTL
    rem: int64 = NOTIFY_FADE - fade_into
    if rem < 0:
        rem = 0
    return rem * 255 / NOTIFY_FADE


# ====================================================================
# ROUND-8: MATE/GNOME2 session dialog + screen lock
# ====================================================================
# Choosing "Log Out" on the System menu no longer quits immediately —
# instead it raises a modal SESSION DIALOG centred on a dimmed desktop,
# exactly like gnome-session's logout chooser, offering:
#     row 0  Lock Screen   -> blank+lock the desktop (unlock by clicking)
#     row 1  Log Out       -> clean daemon shutdown (returns to the shell)
#     row 2  Shut Down     -> request a power-off (distinct intent marker)
#     row 3  Cancel        -> dismiss the dialog, do nothing
# A modal click-shield (like CTX_OPEN) intercepts the next press while it
# is up. Lock Screen drops a full-screen LOCK overlay that swallows all
# input until a click unlocks it (no password store yet, so a click is the
# unlock gesture — the lock surface itself is real and load-bearing).
SESSION_OPEN: int32 = 0                 # 1 while the session dialog is modal
SESSION_HOVER: int64 = -1               # row under the pointer (for highlight)
SESSION_ROWS: int64 = 4
SESSION_BTN_H: int64 = 30               # per-row button height
SESSION_PAD:  int64 = 16                # inner padding
SESSION_W:    int64 = 240
# Distinct shutdown intent the main loop acts on. 0 = none, 1 = log out,
# 2 = power-off. DAEMON_QUIT (set alongside) breaks the loop either way.
SESSION_INTENT: int32 = 0
# Screen-lock state. 1 = the desktop is locked behind the lock overlay.
LOCKED: int32 = 0


# Dialog rectangle geometry (centred). Total height = title strip + rows.
def session_total_h() -> int64:
    return SESSION_PAD * 2 + GLYPH_H + 8 + SESSION_ROWS * (SESSION_BTN_H + 6)


def session_x(scr_w: int64) -> int64:
    x: int64 = scr_w / 2 - SESSION_W / 2
    if x < 0:
        x = 0
    return x


def session_y(scr_h: int64) -> int64:
    y: int64 = scr_h / 2 - session_total_h() / 2
    if y < PANEL_H:
        y = PANEL_H
    return y


# Top y of session dialog button row `i`.
def session_row_y(scr_h: int64, i: int64) -> int64:
    base: int64 = session_y(scr_h) + SESSION_PAD + GLYPH_H + 8
    return base + i * (SESSION_BTN_H + 6)


# Label for session dialog row `i`.
def session_row_label(i: int64) -> Ptr[uint8]:
    if i == 0:
        s0: Ptr[uint8] = "Lock Screen"
        return s0
    if i == 1:
        s1: Ptr[uint8] = "Log Out"
        return s1
    if i == 2:
        s2: Ptr[uint8] = "Shut Down"
        return s2
    s3: Ptr[uint8] = "Cancel"
    return s3


# Row index (0..SESSION_ROWS-1) under screen point (px,py), or -1.
def session_row_at(px: int64, py: int64, scr_w: int64, scr_h: int64) -> int64:
    dx: int64 = session_x(scr_w) + SESSION_PAD
    dw: int64 = SESSION_W - SESSION_PAD * 2
    if px < dx or px >= dx + dw:
        return -1
    i: int64 = 0
    while i < SESSION_ROWS:
        ry: int64 = session_row_y(scr_h, i)
        if py >= ry and py < ry + SESSION_BTN_H:
            return i
        i = i + 1
    return -1


# Open the modal session dialog (called from the System menu "Log Out").
def session_open():
    SESSION_OPEN = 1
    SESSION_HOVER = -1
    pfx: Ptr[uint8] = "SESSION open\n"
    sys_write(1, pfx, strlen_u8(pfx))


# Lock the screen: drop the full-screen lock overlay and dismiss the
# dialog. Closes any open chrome so nothing peeks through the lock.
def session_lock():
    LOCKED = 1
    SESSION_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CTX_OPEN = 0
    CAL_OPEN = 0
    pfx: Ptr[uint8] = "SESSION lock\n"
    sys_write(1, pfx, strlen_u8(pfx))


# Unlock the screen (any click on the lock overlay).
def session_unlock():
    LOCKED = 0
    pfx: Ptr[uint8] = "SESSION unlock\n"
    sys_write(1, pfx, strlen_u8(pfx))


# Invoke the chosen session dialog row. Returns nothing; sets the loop
# shutdown flags for Log Out / Shut Down.
def session_invoke(i: int64):
    if i == 0:
        session_lock()
        return
    if i == 1:
        SESSION_OPEN = 0
        SESSION_INTENT = 1                  # log out
        DAEMON_QUIT = 1
        lo: Ptr[uint8] = "SESSION logout\n"
        sys_write(1, lo, strlen_u8(lo))
        return
    if i == 2:
        SESSION_OPEN = 0
        SESSION_INTENT = 2                  # power-off
        DAEMON_QUIT = 1
        sd: Ptr[uint8] = "SESSION shutdown\n"
        sys_write(1, sd, strlen_u8(sd))
        return
    # Cancel.
    SESSION_OPEN = 0
    cc: Ptr[uint8] = "SESSION cancel\n"
    sys_write(1, cc, strlen_u8(cc))


# 1 if screen pixel (x,y) lands on an INK pixel of the glyph string `s`
# laid out left-to-right at top-left origin (ox,oy), one 8x16 cell per
# character. Used to paint panel/menu labels into the compositor without
# any backing buffer. Out-of-range characters render as blank.
def str_ink(s: Ptr[uint8], ox: int64, oy: int64, x: int64, y: int64) -> int32:
    ly: int64 = y - oy
    if ly < 0 or ly >= GLYPH_H:
        return 0
    lx: int64 = x - ox
    if lx < 0:
        return 0
    col: int64 = lx / GLYPH_W
    ch: uint8 = s[cast[uint64](col)]
    if ch == 0:
        return 0
    if ch < 32 or ch > 126:
        return 0
    gx: int64 = lx - col * GLYPH_W           # 0..7
    gi: uint64 = cast[uint64](ch) - 32
    bits: uint8 = font_glyphs[gi * 16 + cast[uint64](ly)]
    mask: uint8 = cast[uint8](128 >> gx)
    if (bits & mask) != 0:
        return 1
    return 0


# Return the label string for menu entry `i`.
def menu_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        s0: Ptr[uint8] = "Terminal"
        return s0
    if i == 1:
        s1: Ptr[uint8] = "Editor (vi)"
        return s1
    if i == 2:
        s2: Ptr[uint8] = "Top"
        return s2
    if i == 3:
        s3: Ptr[uint8] = "Calculator"
        return s3
    if i == 4:
        s4: Ptr[uint8] = "System Monitor"
        return s4
    if i == 5:
        s5: Ptr[uint8] = "About Hamnix"
        return s5
    if i == 6:
        s6: Ptr[uint8] = "Calendar"
        return s6
    if i == 7:
        s7: Ptr[uint8] = "Date"
        return s7
    s8: Ptr[uint8] = "Files"
    return s8


# App kind for internal (in-process) menu entries, or -1 if the entry
# launches an external /bin program via the spawn path.
def menu_app(i: uint64) -> int32:
    if i == 3:
        return APP_CALC
    if i == 4:
        return APP_SYSMON
    if i == 5:
        return APP_ABOUT
    return -1


# Return the program path for menu entry `i` (external entries only).
def menu_prog(i: uint64) -> Ptr[char]:
    if i == 0:
        p0: Ptr[char] = "/bin/hamsh"
        return p0
    if i == 1:
        p1: Ptr[char] = "/bin/vi"
        return p1
    if i == 2:
        p2: Ptr[char] = "/bin/top"
        return p2
    if i == 6:
        p6: Ptr[char] = "/bin/cal"
        return p6
    if i == 7:
        p7: Ptr[char] = "/bin/date"
        return p7
    p8: Ptr[char] = "/bin/hamfm"
    return p8


# Total pixel height the dropped menu occupies.
def menu_total_h() -> int64:
    return cast[int64](MENU_COUNT) * MENU_ITEM_H


# 1 if (px,py) is inside the panel's Applications button.
def in_apps_btn(px: int64, py: int64) -> int32:
    if px >= APPS_BTN_X and px < APPS_BTN_X + APPS_BTN_W:
        if on_panel_y(py) != 0:
            return 1
    return 0


# 1 if (px,py) is anywhere on the panel bar.
def in_panel(px: int64, py: int64) -> int32:
    return on_panel_y(py)


# Index (0..MENU_COUNT-1) of the menu item under (px,py) while the menu
# is open, or -1 if not over an item. The menu drops off the panel edge.
def menu_item_at(px: int64, py: int64) -> int64:
    if MENU_OPEN == 0:
        return -1
    if px < MENU_X or px >= MENU_X + MENU_W:
        return -1
    h: int64 = menu_total_h()
    top: int64 = drop_anchor_y(h)
    if py < top or py >= top + h:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](menubar_count(MENU_BAR_OPEN)):
        return -1
    return idx


# ====================================================================
# MATE / GNOME2 menu BAR (Applications / Places / System)
# ====================================================================
# The single legacy "Applications" button is upgraded into the classic
# GNOME2 three-menu bar. MENU_BAR_OPEN selects which top-level menu (if
# any) is currently dropped:
#   -1 = closed
#    0 = Applications   1 = Places   2 = System
# Each top-level menu is a list of items. Items carry an ACTION kind so
# the click handler can do the right thing:
#   0 = launch a program  (path from menubar_item_prog)
#   1 = open a directory in the file manager (path arg)
#   2 = reload the DE / about / window action (system verbs)
MENU_BAR_OPEN: int32 = -1

# Top-level menu button labels + geometry. Buttons are laid out left to
# right from APPS_BTN_X; each is sized to its label width + padding.
MENUBAR_PAD: int64 = 10

# System-menu action codes (returned by menubar_item_action when kind==2).
SYSACT_RELOAD: int64 = 0
SYSACT_ABOUT:  int64 = 1


def menubar_label(m: int32) -> Ptr[uint8]:
    if m == 0:
        l0: Ptr[uint8] = "Applications"
        return l0
    if m == 1:
        l1: Ptr[uint8] = "Places"
        return l1
    l2: Ptr[uint8] = "System"
    return l2


# ====================================================================
# ROUND-7: GNOME2-classic categorised Applications menu
# ====================================================================
# The Applications drop-down (m==0) now lists CATEGORIES; hovering a
# category opens a submenu flyout to the right holding that category's
# apps (exactly MATE/GNOME2's two-level menu). Each submenu item maps to
# one of the existing flat Applications entries (0..MENU_COUNT-1) so the
# launcher code is reused verbatim.
APPCAT_COUNT: int64 = 3                 # Accessories / System Tools / Help
SUBMENU_OPEN: int64 = -1                # category whose flyout is open, or -1
SUBMENU_W: int64 = 150


# Category name shown in the Applications drop-down.
def appcat_label(c: int64) -> Ptr[uint8]:
    if c == 0:
        a0: Ptr[uint8] = "Accessories"
        return a0
    if c == 1:
        a1: Ptr[uint8] = "System Tools"
        return a1
    h: Ptr[uint8] = "Help"
    return h


# Number of apps in category `c`.
def appcat_item_count(c: int64) -> int64:
    if c == 0:
        return 6                        # Terminal/Calc/Editor/Files/Calendar/Date
    if c == 1:
        return 2                        # Top / System Monitor
    return 1                            # About Hamnix


# Map (category c, submenu item k) to the flat Applications entry index
# (0..MENU_COUNT-1) so menu_launch() can be reused.
def appcat_flat_index(c: int64, k: int64) -> uint64:
    if c == 0:
        # Accessories: Terminal(0) Calculator(3) Editor(1) Files(8) Calendar(6) Date(7)
        if k == 0:
            return 0
        if k == 1:
            return 3
        if k == 2:
            return 1
        if k == 3:
            return 8
        if k == 4:
            return 6
        return 7
    if c == 1:
        # System Tools: Top(2) System Monitor(4)
        if k == 0:
            return 2
        return 4
    # Help: About Hamnix(5)
    return 5


# Label for submenu item `k` of category `c` (reuses the flat labels).
def appcat_item_label(c: int64, k: int64) -> Ptr[uint8]:
    return menu_label(appcat_flat_index(c, k))


# Total pixel height of category `c`'s submenu flyout.
def submenu_total_h(c: int64) -> int64:
    return appcat_item_count(c) * MENU_ITEM_H


# Top y of category `c`'s row inside the Applications drop-down. The
# drop-down is anchored off the panel edge (below a top panel, above a
# bottom panel) and is menubar_total_h() tall; row `c` is the c-th row.
def appcat_row_y(c: int64) -> int64:
    return drop_anchor_y(menubar_total_h()) + c * MENU_ITEM_H


# Left x of the submenu flyout (just right of the Applications drop-down).
def submenu_x() -> int64:
    return menubar_drop_x() + menubar_drop_w()


# Submenu item under (px,py) when category `c`'s flyout is open, or -1.
# The flyout's top aligns with its parent category row.
def submenu_item_at(c: int64, px: int64, py: int64) -> int64:
    sx: int64 = submenu_x()
    if px < sx or px >= sx + SUBMENU_W:
        return -1
    top: int64 = appcat_row_y(c)
    n: int64 = appcat_item_count(c)
    if py < top or py >= top + n * MENU_ITEM_H:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= n:
        return -1
    return idx


# Number of items in top-level menu `m`.
def menubar_count(m: int32) -> uint64:
    if m == 0:
        return cast[uint64](APPCAT_COUNT)   # Applications: category rows
    if m == 1:
        return 3                    # Home / Filesystem / Tmp
    if m == 2:
        return 7                    # SysMon/About/Reload/2 ws/Settings/Log Out
    return 0


# Pixel width of top-level menu button `m` (label glyphs + padding).
def menubar_btn_w(m: int32) -> int64:
    n: int64 = cast[int64](strlen_u8(menubar_label(m)))
    return n * GLYPH_W + MENUBAR_PAD * 2


# Left x of top-level menu button `m`.
def menubar_btn_x(m: int32) -> int64:
    x: int64 = APPS_BTN_X
    i: int32 = 0
    while i < m:
        x = x + menubar_btn_w(i)
        i = i + 1
    return x


# Right edge x of the whole menu bar (start of the taskbar zone).
def menubar_end_x() -> int64:
    return menubar_btn_x(2) + menubar_btn_w(2)


# Which top-level menu button is under (px,py)? -1 if none. The bar
# lives in the panel's full height at the left end.
def menubar_btn_at(px: int64, py: int64) -> int32:
    if on_panel_y(py) == 0:
        return -1
    m: int32 = 0
    while m < 3:
        bx: int64 = menubar_btn_x(m)
        if px >= bx and px < bx + menubar_btn_w(m):
            return m
        m = m + 1
    return -1


# Drop-down geometry for the currently-open top-level menu.
def menubar_drop_x() -> int64:
    if MENU_BAR_OPEN < 0:
        return 0
    return menubar_btn_x(MENU_BAR_OPEN)


def menubar_drop_w() -> int64:
    # Wide enough for the legacy MENU_W on Applications, a bit narrower
    # for the short Places/System lists.
    if MENU_BAR_OPEN == 0:
        return MENU_W
    return 168


def menubar_total_h() -> int64:
    return cast[int64](menubar_count(MENU_BAR_OPEN)) * MENU_ITEM_H


# Label for item `i` of top-level menu `m`.
def menubar_item_label(m: int32, i: uint64) -> Ptr[uint8]:
    if m == 0:
        # ROUND-7: Applications rows are categories now.
        return appcat_label(cast[int64](i))
    if m == 1:
        if i == 0:
            p0: Ptr[uint8] = "Home"
            return p0
        if i == 1:
            p1: Ptr[uint8] = "Filesystem"
            return p1
        p2: Ptr[uint8] = "Tmp"
        return p2
    if m == 2:
        if i == 0:
            s0: Ptr[uint8] = "System Monitor"
            return s0
        if i == 1:
            s1: Ptr[uint8] = "About Hamnix"
            return s1
        if i == 2:
            s2: Ptr[uint8] = "Reload DE"
            return s2
        if i == 3:
            s3: Ptr[uint8] = "Next Workspace"
            return s3
        if i == 4:
            s4: Ptr[uint8] = "Prev Workspace"
            return s4
        if i == 5:
            s5: Ptr[uint8] = "Settings"
            return s5
        s6: Ptr[uint8] = "Log Out"
        return s6
    e: Ptr[uint8] = ""
    return e


# Item under (px,py) for the open drop-down, or -1.
def menubar_item_at(px: int64, py: int64) -> int64:
    if MENU_BAR_OPEN < 0:
        return -1
    dx: int64 = menubar_drop_x()
    dw: int64 = menubar_drop_w()
    if px < dx or px >= dx + dw:
        return -1
    h: int64 = menubar_total_h()
    top: int64 = drop_anchor_y(h)
    if py < top or py >= top + h:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](menubar_count(MENU_BAR_OPEN)):
        return -1
    return idx


# ====================================================================
# MATE virtual workspaces
# ====================================================================
# ROUND-8: WS_COUNT is now a SESSION PREFERENCE (configurable from the
# Settings "Workspaces" row) rather than a fixed constant — exactly like
# MATE's "Number of workspaces" spinner. It is clamped to [WS_MIN,WS_MAX];
# the per-window DWIN_WS array still backs every window (max DMAX windows),
# so changing the count never reallocates anything.
WS_MIN: int32 = 1
WS_MAX: int32 = 8
WS_COUNT: int32 = 4
CUR_WS: int32 = 0

# Workspace-pager applet geometry: WS_COUNT little boxes in the panel,
# left of the clock. Each box is PAGER_CELL_W wide.
PAGER_CELL_W: int64 = 28
PAGER_PAD:    int64 = 4         # inner inset for the occupancy mini-map
PAGER_R: uint8 = 30            # pager cell background (darker than panel)
PAGER_G: uint8 = 34
PAGER_B: uint8 = 44
PAGER_CUR_R: uint8 = 70        # current-workspace cell highlight
PAGER_CUR_G: uint8 = 100
PAGER_CUR_B: uint8 = 170
PAGER_WIN_R: uint8 = 150       # mini window-occupancy marker
PAGER_WIN_G: uint8 = 200
PAGER_WIN_B: uint8 = 240


def pager_total_w() -> int64:
    return cast[int64](WS_COUNT) * PAGER_CELL_W


# Left x of the ROUND-12 Show Desktop button (just left of the clock zone).
def sd_btn_x0(scr_w: int64) -> int64:
    return scr_w - CLOCK_W - SD_BTN_W


# Left x of the notification-area stub (just left of the Show Desktop btn).
def notif_x0(scr_w: int64) -> int64:
    return scr_w - CLOCK_W - SD_BTN_W - NOTIF_W


# Left x of the pager applet (just left of the notification area).
def pager_x0(scr_w: int64) -> int64:
    return scr_w - CLOCK_W - SD_BTN_W - NOTIF_W - pager_total_w() - 4


# 1 if (px,py) lands on the panel's Show Desktop button.
def in_show_desktop_btn(px: int64, py: int64, scr_w: int64) -> int32:
    if on_panel_y(py) == 0:
        return 0
    x0: int64 = sd_btn_x0(scr_w)
    if px >= x0 and px < x0 + SD_BTN_W:
        return 1
    return 0


# Pager cell index under (px,py), or -1.
def pager_cell_at(px: int64, py: int64, scr_w: int64) -> int64:
    if on_panel_y(py) == 0:
        return -1
    x0: int64 = pager_x0(scr_w)
    if px < x0 or px >= x0 + pager_total_w():
        return -1
    idx: int64 = (px - x0) / PAGER_CELL_W
    if idx < 0 or idx >= cast[int64](WS_COUNT):
        return -1
    return idx


# 1 if window `slot` is visible on the CURRENT workspace (right ws AND
# not minimized). Used by the compositor + hit-testers.
def win_on_cur_ws(slot: uint64) -> int32:
    if DWIN_WS[slot] != CUR_WS:
        return 0
    if DWIN_HIDDEN[slot] != 0:
        return 0
    return 1


# Switch to workspace `ws` (clamped). Emits a serial marker for tests.
def workspace_switch(ws: int32):
    if ws < 0:
        ws = WS_COUNT - 1
    if ws >= WS_COUNT:
        ws = 0
    if ws == CUR_WS:
        return
    CUR_WS = ws
    # Close any open menu / context menu when the desktop changes.
    MENU_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CTX_OPEN = 0
    pfx: Ptr[uint8] = "WS switch "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](CUR_WS + 1) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# Move window `slot` to workspace `ws` (clamped). Emits a marker.
def window_to_workspace(slot: uint64, ws: int32):
    if ws < 0 or ws >= WS_COUNT:
        return
    DWIN_WS[slot] = ws
    pfx: Ptr[uint8] = "WS move-window "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](ws + 1) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# ====================================================================
# ROUND-11: standard Ctrl-Alt-arrow workspace navigation helpers
# ====================================================================
# MATE/GNOME2 bind Ctrl-Alt-Left/Right to "switch to the adjacent
# workspace" and Ctrl-Alt-Shift-Left/Right to "move the active window to
# the adjacent workspace, following it there". Round 4-8 only offered the
# F-key bindings; these give the conventional arrow shortcuts a wrap-around
# adjacent-workspace target so the key path can call one helper per gesture.

# Index of the workspace `dir` steps from the current one (dir = -1 left,
# +1 right), wrapping around the WS_COUNT row. Pure function (no state).
def adjacent_ws(dir: int32) -> int32:
    w: int32 = CUR_WS + dir
    if w < 0:
        w = WS_COUNT - 1
    if w >= WS_COUNT:
        w = 0
    return w


# Switch to the workspace `dir` steps away (wrapping). Returns the new ws.
def workspace_step(dir: int32) -> int32:
    target: int32 = adjacent_ws(dir)
    workspace_switch(target)
    return target


# Move the focused window to the adjacent workspace (wrapping) AND follow it
# there, exactly like MATE's Ctrl-Alt-Shift-arrow. Returns the destination
# workspace, or -1 if there is no focused window to move.
def window_to_adjacent_ws(dir: int32) -> int32:
    slot: int64 = daemon_focus_slot()
    if slot < 0:
        return -1
    target: int32 = adjacent_ws(dir)
    window_to_workspace(cast[uint64](slot), target)
    workspace_switch(target)
    return target


# ROUND-8: change the number of virtual desktops (Settings "Workspaces"
# row). Steps WS_COUNT up by one, wrapping WS_MAX->WS_MIN. If the active
# desktop or any window now sits beyond the new edge, fold it back onto the
# last valid workspace so nothing becomes unreachable. Emits a marker.
def ws_count_cycle():
    WS_COUNT = WS_COUNT + 1
    if WS_COUNT > WS_MAX:
        WS_COUNT = WS_MIN
    # Fold the current workspace and every window back inside the new range.
    if CUR_WS >= WS_COUNT:
        CUR_WS = WS_COUNT - 1
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if DWIN_WS[wi] >= WS_COUNT:
            DWIN_WS[wi] = WS_COUNT - 1
        wi = wi + 1
    pfx: Ptr[uint8] = "DESK workspaces "
    sys_write(1, pfx, strlen_u8(pfx))
    wb: Array[4, uint8]
    wb[0] = cast[uint8](WS_COUNT) + 48
    wb[1] = 10
    sys_write(1, &wb[0], 2)


# ====================================================================
# ROUND-10: workspace pager drag-window-between-workspaces
# ====================================================================
# MATE's pager lets you DRAG a window's mini-marker from one workspace
# cell to another to relocate it across desktops (not just click-to-
# switch). We model this as a dedicated pager gesture: a left-press that
# lands on a pager cell arms PAGER_DRAG; if the release lands on a
# DIFFERENT cell we move the focused window of the source workspace onto
# the target desktop; if it lands on the SAME cell it falls back to the
# existing click-to-switch behaviour. PAGER_DRAG_FROM remembers the cell
# the press began on so the release can tell move from switch.
PAGER_DRAG:      int32 = 0             # 1 while a pager press is in flight
PAGER_DRAG_FROM: int64 = -1           # workspace cell the press began on


# Front-most (focus) window slot that lives on workspace `ws`, or -1 if
# that desktop is empty. Used as the pager-drag payload: dragging cell A
# onto cell B relocates A's focused window to B. Walks the stack from the
# front so the top-most window on that desktop is chosen.
def ws_focus_slot(ws: int32) -> int64:
    si: int64 = cast[int64](DWIN_COUNT) - 1
    while si >= 0:
        su: uint64 = cast[uint64](si)
        if DWIN_WS[su] == ws and DWIN_HIDDEN[su] == 0:
            return si
        si = si - 1
    # Fall back to a hidden window so a minimized-only desktop still drags.
    si = cast[int64](DWIN_COUNT) - 1
    while si >= 0:
        if DWIN_WS[cast[uint64](si)] == ws:
            return si
        si = si - 1
    return -1


# Drag the focused window of `from_ws` onto `to_ws`. Returns 1 if a window
# actually moved, else 0 (empty source or same workspace). Emits a marker.
def pager_drag_window(from_ws: int32, to_ws: int32) -> int32:
    if from_ws == to_ws:
        return 0
    if to_ws < 0 or to_ws >= WS_COUNT:
        return 0
    src: int64 = ws_focus_slot(from_ws)
    if src < 0:
        return 0
    window_to_workspace(cast[uint64](src), to_ws)
    pfx: Ptr[uint8] = "PAGER drag-window to "
    sys_write(1, pfx, strlen_u8(pfx))
    db: Array[4, uint8]
    db[0] = cast[uint8](to_ws + 1) + 48
    db[1] = 10
    sys_write(1, &db[0], 2)
    return 1


# ====================================================================
# ROUND-10: window-list (taskbar) grouping by application
# ====================================================================
# GNOME2/MATE's window-list groups several windows of the SAME application
# under one button with a count; clicking it cycles focus through that
# app's windows. We group by DWIN_APP, but terminals (APP_TERM) are all
# the same "app", which would over-collapse a desktop full of shells, so
# grouping only kicks in once a given app has GROUP_MIN-or-more windows.
# A grouped button shows the app's name plus a "(N)" multiplicity badge,
# and clicking it raises the next window of that group in round-robin
# (MATE's expand-on-click behaviour, collapsed to a focus-cycle here).
GROUP_MIN: uint64 = 2                  # windows-of-an-app before grouping
# Round-robin cursor per app kind so repeated clicks cycle the group.
GROUP_CURSOR: Array[8, int32]          # indexed by app kind (0..7)


# Number of windows whose app kind matches slot `slot`'s app (counting
# `slot` itself). Drives the grouping decision and the "(N)" badge.
def app_group_count(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    n: uint64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            n = n + 1
        i = i + 1
    return n


# 1 if slot `slot` belongs to a group that should collapse on the taskbar
# (its app kind has GROUP_MIN-or-more windows). Singletons stay ungrouped.
# Terminals (APP_TERM) are deliberately NEVER grouped: each is its own
# independent shell session (a distinct task, not multiple windows of one
# app), so they keep one taskbar button apiece, exactly like a row of
# separate xterms. Only the built-in DE applications collapse.
def is_grouped(slot: uint64) -> int32:
    if DWIN_APP[slot] == APP_TERM:
        return 0
    if app_group_count(slot) >= GROUP_MIN:
        return 1
    return 0


# The representative (group-leader) slot for an app kind: the LOWEST slot
# index whose app matches `app`. A grouped taskbar button is drawn once,
# on its leader; the other members of the group are folded behind it.
def group_leader_for_app(app: int32) -> int64:
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == app:
            return cast[int64](i)
        i = i + 1
    return -1


# 1 if slot `slot` is the leader of its (grouped) app — i.e. the first
# window of that kind. Non-grouped singletons are trivially their own
# leader. The taskbar renderer/hit-tester only emits a button for leaders.
def is_group_leader(slot: uint64) -> int32:
    if is_grouped(slot) == 0:
        return 1
    if group_leader_for_app(DWIN_APP[slot]) == cast[int64](slot):
        return 1
    return 0


# Cycle focus to the next window of slot `slot`'s app group (round-robin),
# skipping minimized windows where possible. Returns the UID of the window
# that was raised (stable across the raise reorder), or -1. Restores a
# minimized member before raising it.
def group_cycle(slot: uint64) -> int64:
    a: int32 = DWIN_APP[slot]
    cnt: uint64 = app_group_count(slot)
    if cnt == 0:
        return -1
    # Advance the per-app cursor and find the cursor-th window of this app.
    cur: int32 = GROUP_CURSOR[cast[uint64](a)]
    cur = cur + 1
    if cur >= cast[int32](cnt):
        cur = 0
    GROUP_CURSOR[cast[uint64](a)] = cur
    seen: int32 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            if seen == cur:
                if DWIN_HIDDEN[i] != 0:
                    DWIN_HIDDEN[i] = 0
                raised_uid: int32 = DWIN_UID[i]
                daemon_raise_slot(cast[int64](i))
                return cast[int64](raised_uid)
            seen = seen + 1
        i = i + 1
    return -1


# ====================================================================
# ROUND-11: window-list group action menu (minimize/restore/close all)
# ====================================================================
# Right-clicking a grouped taskbar button in MATE pops a small menu that
# acts on EVERY window of that group at once. These helpers implement the
# three actions. They take any member slot of the group, resolve the app
# kind, and walk every window of that kind. Each returns the number of
# windows it acted on so the caller (and the self-test) can confirm the
# whole group was processed.

# Minimize (hide) every window of slot `slot`'s app group. Returns count.
def group_minimize_all(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    n: uint64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            DWIN_HIDDEN[i] = 1
            n = n + 1
        i = i + 1
    gm: Ptr[uint8] = "WM group minimize-all\n"
    sys_write(1, gm, strlen_u8(gm))
    return n


# Restore (un-hide) every window of slot `slot`'s app group. Returns count.
def group_restore_all(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    n: uint64 = 0
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_APP[i] == a:
            DWIN_HIDDEN[i] = 0
            n = n + 1
        i = i + 1
    gr: Ptr[uint8] = "WM group restore-all\n"
    sys_write(1, gr, strlen_u8(gr))
    return n


# Close every window of slot `slot`'s app group. Returns the count closed.
# daemon_close_slot() compacts the slot table, so we re-scan from the start
# after each close (slot indices shift) until no member of the app remains.
def group_close_all(slot: uint64) -> uint64:
    a: int32 = DWIN_APP[slot]
    closed: uint64 = 0
    guard: uint64 = 0
    while guard < 64:
        guard = guard + 1
        hit: int64 = -1
        i: uint64 = 0
        while i < DWIN_COUNT:
            if DWIN_APP[i] == a:
                hit = cast[int64](i)
                i = DWIN_COUNT
            else:
                i = i + 1
        if hit < 0:
            guard = 64
        else:
            daemon_close_slot(hit)
            closed = closed + 1
    gc: Ptr[uint8] = "WM group close-all\n"
    sys_write(1, gc, strlen_u8(gc))
    return closed


# ====================================================================
# ROUND-10: Applications menu type-to-search / filter
# ====================================================================
# MATE's modern menu lets you start typing to filter the application list.
# We add a one-line search box at the head of the Applications drop-down:
# when SEARCH_OPEN is set, keystrokes append to search_buf and the menu
# shows only the flat entries (0..MENU_COUNT-1) whose label contains the
# query as a case-insensitive substring. An empty query matches all
# entries (the menu behaves exactly as before). Enter launches the first
# match; Backspace edits; Escape clears + closes the search.
SEARCH_OPEN: int32 = 0                 # 1 while the search box is active
SEARCH_LEN:  uint64 = 0                # current query length
search_buf:  Array[32, uint8]          # query bytes (no NUL terminator)


# Lowercase an ASCII byte (A..Z -> a..z); other bytes pass through.
def to_lower_u8(c: uint8) -> uint8:
    if c >= 65 and c <= 90:
        return c + 32
    return c


# 1 if the (case-insensitive) query in search_buf[0..SEARCH_LEN) occurs as
# a substring of NUL-terminated `s`. An empty query always matches.
def label_matches_search(s: Ptr[uint8]) -> int32:
    if SEARCH_LEN == 0:
        return 1
    slen: uint64 = strlen_u8(s)
    if SEARCH_LEN > slen:
        return 0
    last: uint64 = slen - SEARCH_LEN
    start: uint64 = 0
    while start <= last:
        k: uint64 = 0
        ok: int32 = 1
        while k < SEARCH_LEN:
            if to_lower_u8(s[start + k]) != to_lower_u8(search_buf[k]):
                ok = 0
                k = SEARCH_LEN
            else:
                k = k + 1
        if ok != 0:
            return 1
        start = start + 1
    return 0


# 1 if flat menu entry `i` matches the current search query.
def menu_search_match(i: uint64) -> int32:
    return label_matches_search(menu_label(i))


# Number of flat menu entries matching the current query (== MENU_COUNT
# when the query is empty).
def menu_search_count() -> uint64:
    n: uint64 = 0
    i: uint64 = 0
    while i < MENU_COUNT:
        if menu_search_match(i) != 0:
            n = n + 1
        i = i + 1
    return n


# The flat menu index of the `n`-th match (0-based), or MENU_COUNT if out
# of range. Used to map a clicked/Enter'd filtered-row back to its entry.
def menu_search_nth(n: uint64) -> uint64:
    seen: uint64 = 0
    i: uint64 = 0
    while i < MENU_COUNT:
        if menu_search_match(i) != 0:
            if seen == n:
                return i
            seen = seen + 1
        i = i + 1
    return MENU_COUNT


# Append one printable byte to the search query (capped at the buffer).
def search_push(c: uint8):
    if SEARCH_OPEN == 0:
        return
    if SEARCH_LEN >= 31:
        return
    search_buf[SEARCH_LEN] = c
    SEARCH_LEN = SEARCH_LEN + 1


# Delete the last query byte (Backspace).
def search_backspace():
    if SEARCH_LEN > 0:
        SEARCH_LEN = SEARCH_LEN - 1


# Clear the query and close the search box.
def search_reset():
    SEARCH_LEN = 0
    SEARCH_OPEN = 0


# 1 if the search filter should drive the Applications drop-down: the box
# is open AND the query is non-empty. With an empty query the menu keeps
# its normal category layout.
def search_active() -> int32:
    if SEARCH_OPEN != 0 and SEARCH_LEN > 0:
        return 1
    return 0


# Which filtered result row (0-based) is under (px,py) while the search
# filter is driving the Applications drop-down, or -1 if none. The result
# list drops from PANEL_H at the Applications-menu column, one row of
# MENU_ITEM_H per match.
def search_result_at(px: int64, py: int64) -> int64:
    if search_active() == 0:
        return -1
    if px < MENU_X or px >= MENU_X + MENU_W:
        return -1
    n: uint64 = menu_search_count()
    h: int64 = cast[int64](n) * MENU_ITEM_H
    top: int64 = drop_anchor_y(h)
    if py < top or py >= top + h:
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](n):
        return -1
    return idx


# ====================================================================
# MATE Alt-Tab window cycler
# ====================================================================
# The atkbd driver emits VT220 function-key sequences with no modifier
# encoding, so a true Alt+Tab chord is unavailable. We bind the cycler to
# F5 (next) / F6 (previous) — the keyboard equivalent of the MATE alt-tab
# popup. Each press selects the next/previous VISIBLE window on the
# current workspace, and a release of the cycler (no key for a few idle
# frames) commits the selection by raising it. While cycling, an overlay
# popup centred on-screen lists the candidate windows with the selected
# one highlighted (exactly MATE's switcher chrome).
#
# CYCLE_OPEN: 1 while the switcher popup is showing.
# CYCLE_SEL : index into the visible-window order (0 = front-most).
# CYCLE_IDLE: idle frames since the last cycle keypress; when it reaches
#             CYCLE_COMMIT the selection is committed and the popup closes.
CYCLE_OPEN:    int32 = 0
CYCLE_SEL:     int64 = 0
CYCLE_IDLE:    int32 = 0
CYCLE_COMMIT:  int32 = 24          # idle frames before auto-commit
CYCLE_PRESSED: int32 = 0           # set by cycle_step, cleared each frame

# Switcher popup geometry.
CYC_ROW_H: int64 = 22
CYC_W:     int64 = 280
CYC_PAD:   int64 = 8
CYC_R: uint8 = 40
CYC_G: uint8 = 46
CYC_B: uint8 = 58
CYC_SEL_R: uint8 = 70
CYC_SEL_G: uint8 = 100
CYC_SEL_B: uint8 = 170
CYC_TXT_R: uint8 = 235
CYC_TXT_G: uint8 = 235
CYC_TXT_B: uint8 = 240


# Number of windows eligible for cycling (visible on the current ws).
def cycle_visible_count() -> int64:
    n: int64 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if win_on_cur_ws(wi) != 0:
            n = n + 1
        wi = wi + 1
    return n


# Map a cycler position to a real window slot, or -1. Round 5 switched the
# cycler to MOST-RECENTLY-USED order (mru_slot_for_pos): position 0 is the
# focused window, position 1 the one focused before it, etc. — so a single
# Alt+Tab toggles between your two last windows, exactly like MATE. The MRU
# resolver gracefully falls back to stacking order for windows it hasn't
# seen yet, so the very first cycle on a fresh desktop still lists them all.
def cycle_slot_for_pos(pos: int64) -> int64:
    return mru_slot_for_pos(pos)


# Advance the cycler by `dir` (+1 next, -1 previous). Opens the popup on
# the first press. Selection wraps around the visible-window list.
def cycle_step(dir: int64):
    n: int64 = cycle_visible_count()
    if n <= 0:
        return
    if CYCLE_OPEN == 0:
        CYCLE_OPEN = 1
        # Start on the SECOND window (MATE's first Alt+Tab jumps past the
        # already-focused front window) when more than one exists.
        if n > 1:
            CYCLE_SEL = 1
        else:
            CYCLE_SEL = 0
    else:
        CYCLE_SEL = CYCLE_SEL + dir
        if CYCLE_SEL >= n:
            CYCLE_SEL = 0
        if CYCLE_SEL < 0:
            CYCLE_SEL = n - 1
    CYCLE_IDLE = 0
    CYCLE_PRESSED = 1
    cm: Ptr[uint8] = "WM cycle "
    sys_write(1, cm, strlen_u8(cm))
    cb: Array[4, uint8]
    cb[0] = cast[uint8](CYCLE_SEL) + 48
    cb[1] = 10
    sys_write(1, &cb[0], 2)


# Commit the cycler: raise the selected window to the front + close the
# popup. Emits a marker. No-op if the popup isn't open.
def cycle_commit():
    if CYCLE_OPEN == 0:
        return
    slot: int64 = cycle_slot_for_pos(CYCLE_SEL)
    CYCLE_OPEN = 0
    CYCLE_IDLE = 0
    if slot >= 0:
        # Un-minimize then raise the chosen window to focus.
        DWIN_HIDDEN[cast[uint64](slot)] = 0
        daemon_raise_slot(slot)
    rc: Ptr[uint8] = "WM cycle commit\n"
    sys_write(1, rc, strlen_u8(rc))


# ====================================================================
# MATE right-click context menus
# ====================================================================
# Two flavours, selected by CTX_KIND:
#   0 = desktop menu  (right-click empty desktop): New Terminal / Reload
#   1 = window menu   (right-click a title bar): window ops on CTX_SLOT
# CTX_OPEN gates rendering + hit-testing; CTX_X/CTX_Y is the top-left.
CTX_OPEN: int32 = 0
CTX_KIND: int32 = 0
CTX_SLOT: int64 = -1
CTX_X: int64 = 0
CTX_Y: int64 = 0
CTX_ITEM_H: int64 = 20
CTX_W: int64 = 200      # widened in R9 to fit "Maximize Horizontally"
CTX_R: uint8 = 56
CTX_G: uint8 = 62
CTX_B: uint8 = 78
CTX_SEL_R: uint8 = 70
CTX_SEL_G: uint8 = 100
CTX_SEL_B: uint8 = 170


def ctx_count() -> uint64:
    if CTX_KIND == 0:
        return 5                    # Terminal / Settings / Background / Arrange / Reload
    # ROUND-9 window menu (10 rows):
    #   0 Minimize  1 Maximize/Restore  2 Max Vert  3 Max Horiz
    #   4 Shade/Unshade  5 Always on Top  6 Resize
    #   7 Move-Next-WS  8 Move-Prev-WS  9 Close
    return 10


def ctx_item_label(i: uint64) -> Ptr[uint8]:
    if CTX_KIND == 0:
        if i == 0:
            d0: Ptr[uint8] = "Open Terminal"
            return d0
        if i == 1:
            ds: Ptr[uint8] = "Settings"
            return ds
        if i == 2:
            d2: Ptr[uint8] = "Change Background"
            return d2
        if i == 3:
            d3: Ptr[uint8] = "Arrange Windows"
            return d3
        d1: Ptr[uint8] = "Reload DE"
        return d1
    # window menu
    if i == 0:
        w0: Ptr[uint8] = "Minimize"
        return w0
    if i == 1:
        # Maximize vs Restore depends on the window's current state.
        if CTX_SLOT >= 0 and DWIN_MAXED[cast[uint64](CTX_SLOT)] != 0:
            wr: Ptr[uint8] = "Restore"
            return wr
        w1: Ptr[uint8] = "Maximize"
        return w1
    if i == 2:
        wmv: Ptr[uint8] = "Maximize Vertically"
        return wmv
    if i == 3:
        wmh: Ptr[uint8] = "Maximize Horizontally"
        return wmh
    if i == 4:
        # Shade vs Unshade depends on the window's current roll-up state.
        if CTX_SLOT >= 0 and DWIN_SHADED[cast[uint64](CTX_SLOT)] != 0:
            wus: Ptr[uint8] = "Unshade"
            return wus
        wsh: Ptr[uint8] = "Shade"
        return wsh
    if i == 5:
        # A leading check-mark when the window is already pinned.
        if CTX_SLOT >= 0 and DWIN_ONTOP[cast[uint64](CTX_SLOT)] != 0:
            wot1: Ptr[uint8] = "Always on Top *"
            return wot1
        wot0: Ptr[uint8] = "Always on Top"
        return wot0
    if i == 6:
        wz: Ptr[uint8] = "Resize"
        return wz
    if i == 7:
        w2: Ptr[uint8] = "Move to Next WS"
        return w2
    if i == 8:
        w3: Ptr[uint8] = "Move to Prev WS"
        return w3
    w4: Ptr[uint8] = "Close"
    return w4


def ctx_total_h() -> int64:
    return cast[int64](ctx_count()) * CTX_ITEM_H


# Context-menu item under (px,py), or -1.
def ctx_item_at(px: int64, py: int64) -> int64:
    if CTX_OPEN == 0:
        return -1
    if px < CTX_X or px >= CTX_X + CTX_W:
        return -1
    if py < CTX_Y or py >= CTX_Y + ctx_total_h():
        return -1
    idx: int64 = (py - CTX_Y) / CTX_ITEM_H
    if idx < 0 or idx >= cast[int64](ctx_count()):
        return -1
    return idx


# Open a context menu of `kind` anchored at (ax,ay), clamped on-screen.
def ctx_open_at(kind: int32, slot: int64, ax: int64, ay: int64,
                scr_w: int64, scr_h: int64):
    CTX_KIND = kind
    CTX_SLOT = slot
    CTX_OPEN = 1
    cx: int64 = ax
    cy: int64 = ay
    if cx + CTX_W > scr_w:
        cx = scr_w - CTX_W
    if cx < 0:
        cx = 0
    h: int64 = ctx_total_h()
    if cy + h > scr_h:
        cy = scr_h - h
    if cy < PANEL_H:
        cy = PANEL_H
    CTX_X = cx
    CTX_Y = cy


# ====================================================================
# MATE themed window decorations (Clearlooks-ish bevels + gradients)
# ====================================================================
# Title-bar gradient endpoints. Active (focused) window uses the blue
# gradient; inactive uses a muted grey-blue. The gradient runs top->bottom
# across TITLE_H rows.
TITLE_ACT_TOP_R: uint8 = 120
TITLE_ACT_TOP_G: uint8 = 178
TITLE_ACT_TOP_B: uint8 = 252
TITLE_ACT_BOT_R: uint8 = 56
TITLE_ACT_BOT_G: uint8 = 116
TITLE_ACT_BOT_B: uint8 = 208
TITLE_INA_TOP_R: uint8 = 150
TITLE_INA_TOP_G: uint8 = 156
TITLE_INA_TOP_B: uint8 = 168
TITLE_INA_BOT_R: uint8 = 108
TITLE_INA_BOT_G: uint8 = 114
TITLE_INA_BOT_B: uint8 = 128

# Beveled border tints: a light highlight on the top/left edges, a dark
# shadow on the bottom/right edges, framing a 1px mid line.
BEVEL_HI_R: uint8 = 250
BEVEL_HI_G: uint8 = 250
BEVEL_HI_B: uint8 = 255
BEVEL_LO_R: uint8 = 96
BEVEL_LO_G: uint8 = 100
BEVEL_LO_B: uint8 = 112
BEVEL_MID_R: uint8 = 176
BEVEL_MID_G: uint8 = 180
BEVEL_MID_B: uint8 = 192

# Maximize box: a square just LEFT of the minimize box (so the title-bar
# button order left-to-right at the right edge is [_][[]][X]).
MAXIMIZE_BOX: int64 = 14
MAX_BTN_R: uint8 = 110
MAX_BTN_G: uint8 = 180
MAX_BTN_B: uint8 = 110
MAX_GLYPH_R: uint8 = 255
MAX_GLYPH_G: uint8 = 255
MAX_GLYPH_B: uint8 = 255

# Hover highlight: the title-bar button currently under the cursor gets a
# brightened tint. HOVER_SLOT/HOVER_BTN identify it (btn: 0=close,
# 1=minimize, 2=maximize); -1 means nothing hovered.
HOVER_SLOT: int64 = -1
HOVER_BTN:  int32 = -1


# Linear-interpolate one colour channel from `a` (row 0) to `b`
# (row h-1) at integer row `row`.
def grad_chan(a: uint8, b: uint8, row: int64, h: int64) -> uint8:
    if h <= 1:
        return a
    av: int64 = cast[int64](a)
    bv: int64 = cast[int64](b)
    v: int64 = av + (bv - av) * row / (h - 1)
    if v < 0:
        v = 0
    if v > 255:
        v = 255
    return cast[uint8](v)


# Maximize-box geometry (left of the minimize box).
def maximize_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX - 2 - MINIMIZE_BOX \
        - 2 - MAXIMIZE_BOX


def maximize_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


def in_maximize_box(slot: uint64, px: int64, py: int64) -> int32:
    mx: int64 = maximize_box_x(slot)
    my: int64 = maximize_box_y(slot)
    if px >= mx and px < mx + MAXIMIZE_BOX and py >= my and py < my + MAXIMIZE_BOX:
        return 1
    return 0


# Toggle window `slot` between maximized (fills the work area below the
# panel) and its saved rectangle. Snap-aware: if the window is currently
# snapped (maximized OR half-tiled), this restores it to its float
# rectangle; otherwise it maximizes. Emits a serial marker for tests.
def window_toggle_maximize(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_SNAP[slot] != 0 or DWIN_MAXED[slot] != 0:
        # Restore the saved rectangle.
        DWIN_X[slot] = DWIN_SAVE_X[slot]
        DWIN_Y[slot] = DWIN_SAVE_Y[slot]
        DWIN_W[slot] = DWIN_SAVE_W[slot]
        DWIN_H[slot] = DWIN_SAVE_H[slot]
        DWIN_MAXED[slot] = 0
        DWIN_SNAP[slot] = 0
        rm: Ptr[uint8] = "WM restore window\n"
        sys_write(1, rm, strlen_u8(rm))
    else:
        # Save the current rectangle, then fill the work area.
        DWIN_SAVE_X[slot] = DWIN_X[slot]
        DWIN_SAVE_Y[slot] = DWIN_Y[slot]
        DWIN_SAVE_W[slot] = DWIN_W[slot]
        DWIN_SAVE_H[slot] = DWIN_H[slot]
        DWIN_X[slot] = 0
        DWIN_Y[slot] = PANEL_H
        DWIN_W[slot] = scr_w
        DWIN_H[slot] = scr_h - PANEL_H
        DWIN_MAXED[slot] = 1
        DWIN_SNAP[slot] = 1
        mm: Ptr[uint8] = "WM maximize window\n"
        sys_write(1, mm, strlen_u8(mm))
    # Re-derive the terminal grid geometry from the new body size so the
    # in-window shell uses the whole maximized body.
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows


# ====================================================================
# ROUND-9: window shading (roll-up), always-on-top, vert/horiz maximize
# ====================================================================
# Shade rolls a window up so only its title bar is visible; a second
# shade unrolls it back to its full height. Because the whole compositor
# and every hit-tester key off the live DWIN_H, shading simply collapses
# DWIN_H to the title-bar height (and stashes the real height) — no other
# path needs to know. The terminal grid is re-derived so the in-window
# shell pauses output cleanly while rolled up and reflows on unshade.
SHADE_H: int64 = 20                     # rolled-up height = TITLE_H (18) + 2 bevel


def window_toggle_shade(slot: uint64):
    if DWIN_SHADED[slot] != 0:
        # Unroll: restore the saved full height.
        DWIN_SHADED[slot] = 0
        DWIN_H[slot] = DWIN_SHADE_H[slot]
        window_reflow(slot)
        um: Ptr[uint8] = "WM unshade window\n"
        sys_write(1, um, strlen_u8(um))
    else:
        # Roll up: stash the live height, collapse to the title bar.
        DWIN_SHADE_H[slot] = DWIN_H[slot]
        DWIN_SHADED[slot] = 1
        DWIN_H[slot] = SHADE_H
        window_reflow(slot)
        sm: Ptr[uint8] = "WM shade window\n"
        sys_write(1, sm, strlen_u8(sm))


# Bubble every always-on-top window to the tail of the slot array so the
# back-to-front compositor paints (and the front-to-back hit-tester
# checks) them above all normal windows. A stable insertion-style pass
# preserves the relative order amongst pinned windows AND amongst normal
# windows. Called after raises and before each present.
def enforce_ontop_order():
    if DWIN_COUNT < 2:
        return
    # Repeatedly pull the lowest normal window that sits ABOVE a pinned
    # window up past it, until no normal window is above any pinned one.
    moved: int32 = 1
    guard: int32 = 0
    while moved != 0 and guard < 64:
        moved = 0
        guard = guard + 1
        i: uint64 = 0
        while i + 1 < DWIN_COUNT:
            # Pinned below, normal above -> swap so pinned floats up.
            if DWIN_ONTOP[i] != 0 and DWIN_ONTOP[i + 1] == 0:
                slot_swap(i, i + 1)
                moved = 1
            i = i + 1


# Toggle the always-on-top (keep-above) pin for `slot`. When pinning, the
# window is raised and floated above the normal stack; when un-pinning it
# stays where it is but no longer floats. Emits a marker.
def window_toggle_ontop(slot: uint64):
    if DWIN_ONTOP[slot] != 0:
        DWIN_ONTOP[slot] = 0
        om: Ptr[uint8] = "WM unpin ontop\n"
        sys_write(1, om, strlen_u8(om))
    else:
        DWIN_ONTOP[slot] = 1
        pm: Ptr[uint8] = "WM pin ontop\n"
        sys_write(1, pm, strlen_u8(pm))
    enforce_ontop_order()


# Maximize the window VERTICALLY only (full work-area height, keep x/w),
# or restore if it is already vertically maximized. MATE's middle-click on
# the maximize button. The pre-stretch rectangle is saved in DWIN_SAVE_*.
def window_maximize_vert(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_MAXED[slot] != 0 or DWIN_SNAP[slot] != 0:
        # Already maximized/snapped: restore the float rectangle first.
        DWIN_X[slot] = DWIN_SAVE_X[slot]
        DWIN_Y[slot] = DWIN_SAVE_Y[slot]
        DWIN_W[slot] = DWIN_SAVE_W[slot]
        DWIN_H[slot] = DWIN_SAVE_H[slot]
        DWIN_MAXED[slot] = 0
        DWIN_SNAP[slot] = 0
        window_reflow(slot)
        rv: Ptr[uint8] = "WM restore window\n"
        sys_write(1, rv, strlen_u8(rv))
        return
    DWIN_SAVE_X[slot] = DWIN_X[slot]
    DWIN_SAVE_Y[slot] = DWIN_Y[slot]
    DWIN_SAVE_W[slot] = DWIN_W[slot]
    DWIN_SAVE_H[slot] = DWIN_H[slot]
    DWIN_Y[slot] = PANEL_H
    DWIN_H[slot] = scr_h - PANEL_H
    DWIN_SNAP[slot] = 8                 # 8 = vertical maximize sentinel
    window_reflow(slot)
    mv: Ptr[uint8] = "WM maxvert window\n"
    sys_write(1, mv, strlen_u8(mv))


# Maximize the window HORIZONTALLY only (full screen width, keep y/h), or
# restore if already horizontally maximized.
def window_maximize_horiz(slot: uint64, scr_w: int64, scr_h: int64):
    if DWIN_MAXED[slot] != 0 or DWIN_SNAP[slot] != 0:
        DWIN_X[slot] = DWIN_SAVE_X[slot]
        DWIN_Y[slot] = DWIN_SAVE_Y[slot]
        DWIN_W[slot] = DWIN_SAVE_W[slot]
        DWIN_H[slot] = DWIN_SAVE_H[slot]
        DWIN_MAXED[slot] = 0
        DWIN_SNAP[slot] = 0
        window_reflow(slot)
        rh2: Ptr[uint8] = "WM restore window\n"
        sys_write(1, rh2, strlen_u8(rh2))
        return
    DWIN_SAVE_X[slot] = DWIN_X[slot]
    DWIN_SAVE_Y[slot] = DWIN_Y[slot]
    DWIN_SAVE_W[slot] = DWIN_W[slot]
    DWIN_SAVE_H[slot] = DWIN_H[slot]
    DWIN_X[slot] = 0
    DWIN_W[slot] = scr_w
    DWIN_SNAP[slot] = 9                 # 9 = horizontal maximize sentinel
    window_reflow(slot)
    mh: Ptr[uint8] = "WM maxhoriz window\n"
    sys_write(1, mh, strlen_u8(mh))


# ---- window snapping / edge tiling helpers -------------------------
# Recompute the per-window terminal grid geometry after a resize so the
# in-window shell/app reflows to the new body. Safe for app windows too.
def window_reflow(slot: uint64):
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    if DWIN_CUR_C[slot] >= cols:
        DWIN_CUR_C[slot] = 0
    if DWIN_CUR_R[slot] >= rows and rows > 0:
        DWIN_CUR_R[slot] = rows - 1


# Apply snap mode `mode` to `slot` (1 max, 2 left half, 3 right half).
# Mode 0 restores to the saved float geometry. The float geometry is
# stashed in DWIN_SAVE_* the first time a float window is snapped (so
# repeated snaps don't lose the origin).
def snap_apply(slot: uint64, mode: int32, scr_w: int64, scr_h: int64):
    if mode == 0:
        if DWIN_SNAP[slot] != 0:
            DWIN_X[slot] = DWIN_SAVE_X[slot]
            DWIN_Y[slot] = DWIN_SAVE_Y[slot]
            DWIN_W[slot] = DWIN_SAVE_W[slot]
            DWIN_H[slot] = DWIN_SAVE_H[slot]
            DWIN_SNAP[slot] = 0
            DWIN_MAXED[slot] = 0
            window_reflow(slot)
        return
    if DWIN_SNAP[slot] == 0:
        DWIN_SAVE_X[slot] = DWIN_X[slot]
        DWIN_SAVE_Y[slot] = DWIN_Y[slot]
        DWIN_SAVE_W[slot] = DWIN_W[slot]
        DWIN_SAVE_H[slot] = DWIN_H[slot]
    # ROUND-11: respect the panel position. wt is the first usable row,
    # avail_h the usable height (screen minus the panel wherever it sits).
    wt: int64 = work_top(scr_h)
    avail_h: int64 = work_h(scr_h)
    if mode == 1:
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 1
    elif mode == 2:
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w / 2
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 0
    elif mode == 3:
        DWIN_X[slot] = scr_w / 2
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w - scr_w / 2
        DWIN_H[slot] = avail_h
        DWIN_MAXED[slot] = 0
    elif mode == 4:
        # top-left quarter
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w / 2
        DWIN_H[slot] = avail_h / 2
        DWIN_MAXED[slot] = 0
    elif mode == 5:
        # top-right quarter
        DWIN_X[slot] = scr_w / 2
        DWIN_Y[slot] = wt
        DWIN_W[slot] = scr_w - scr_w / 2
        DWIN_H[slot] = avail_h / 2
        DWIN_MAXED[slot] = 0
    elif mode == 6:
        # bottom-left quarter
        DWIN_X[slot] = 0
        DWIN_Y[slot] = wt + avail_h / 2
        DWIN_W[slot] = scr_w / 2
        DWIN_H[slot] = avail_h - avail_h / 2
        DWIN_MAXED[slot] = 0
    elif mode == 7:
        # bottom-right quarter
        DWIN_X[slot] = scr_w / 2
        DWIN_Y[slot] = wt + avail_h / 2
        DWIN_W[slot] = scr_w - scr_w / 2
        DWIN_H[slot] = avail_h - avail_h / 2
        DWIN_MAXED[slot] = 0
    DWIN_SNAP[slot] = mode
    window_reflow(slot)


# ====================================================================
# ROUND-4: keyboard tiling (Super+arrow) + show-desktop toggle
# ====================================================================
# MATE binds Super+Left/Right to half-tiling and Super+Up to maximize. Our
# atkbd path lacks a Super modifier, so we drive the same snap machinery
# from a dedicated set of intercepted keys (wired in daemon_pump_keys):
#   '['            -> tile left half        ']'  -> tile right half
#   ESC O <P..S>   -> quarter tiles (handled in the key path)
# tile_focused() snaps the front-most window on the current workspace.
# A serial marker proves the action fired without pixel sampling.
def tile_focused(mode: int32, scr_w: int64, scr_h: int64):
    slot: int64 = daemon_focus_slot()
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    snap_apply(s, mode, scr_w, scr_h)
    pfx: Ptr[uint8] = "WM tile "
    sys_write(1, pfx, strlen_u8(pfx))
    tb: Array[4, uint8]
    tb[0] = cast[uint8](mode) + 48
    tb[1] = 10
    sys_write(1, &tb[0], 2)


# ====================================================================
# ROUND-5: interactive edge/corner snapping with a live preview overlay
# ====================================================================
# MATE/GNOME2 "edge tiling": while dragging a window's title bar, the
# cursor entering a screen edge or corner pops a translucent preview of
# where the window will land; releasing there commits the snap. This is
# the pointer-driven analogue of the round-4 keyboard tiling (F7-F12).
#
# snap_zone_for() classifies a cursor (cx,cy) into a snap MODE that maps
# 1:1 onto snap_apply()'s modes:
#   0 = no snap (float)        1 = maximize (top edge)
#   2 = left half              3 = right half
#   4 = top-left quarter       5 = top-right quarter
#   6 = bottom-left quarter    7 = bottom-right quarter
# Corners take priority over edges. SNAP_CORNER is a generous band so the
# corners are easy to hit; the plain top edge maximizes, the side edges
# half-tile, and the side edge NEAR a top/bottom corner quarter-tiles.
SNAP_CORNER: int64 = 48                # corner trigger band (px)
SNAP_PREVIEW_MODE: int32 = 0           # live preview zone during a move-drag
SNAP_PREVIEW_ON:   int32 = 0           # 1 while a snap preview is visible


def snap_zone_for(cx: int64, cy: int64, scr_w: int64, scr_h: int64) -> int32:
    near_top: int32 = 0
    near_bot: int32 = 0
    near_left: int32 = 0
    near_right: int32 = 0
    if cy <= PANEL_H + SNAP_CORNER:
        near_top = 1
    if cy >= scr_h - 1 - SNAP_CORNER:
        near_bot = 1
    if cx <= SNAP_CORNER:
        near_left = 1
    if cx >= scr_w - 1 - SNAP_CORNER:
        near_right = 1
    # Corners first (quarter tiles).
    if near_top != 0 and near_left != 0:
        return 4
    if near_top != 0 and near_right != 0:
        return 5
    if near_bot != 0 and near_left != 0:
        return 6
    if near_bot != 0 and near_right != 0:
        return 7
    # Plain top edge -> maximize.
    if cy <= PANEL_H + SNAP_EDGE:
        return 1
    # Side edges -> half tiles.
    if cx <= SNAP_EDGE:
        return 2
    if cx >= scr_w - 1 - SNAP_EDGE:
        return 3
    return 0


# Geometry of a snap zone: writes the target rect for `mode` into the four
# out-params so the compositor can paint a preview and tests can assert
# the landing rect WITHOUT applying it to a real window.
snapzone_x: int64 = 0
snapzone_y: int64 = 0
snapzone_w: int64 = 0
snapzone_h: int64 = 0


def snap_zone_rect(mode: int32, scr_w: int64, scr_h: int64):
    # ROUND-11: anchor previews to the panel-position-aware work area.
    wt: int64 = work_top(scr_h)
    avail_h: int64 = work_h(scr_h)
    half_w: int64 = scr_w / 2
    half_h: int64 = avail_h / 2
    snapzone_x = 0
    snapzone_y = wt
    snapzone_w = scr_w
    snapzone_h = avail_h
    if mode == 1:
        return
    if mode == 2:
        snapzone_w = half_w
        return
    if mode == 3:
        snapzone_x = half_w
        snapzone_w = scr_w - half_w
        return
    if mode == 4:
        snapzone_w = half_w
        snapzone_h = half_h
        return
    if mode == 5:
        snapzone_x = half_w
        snapzone_w = scr_w - half_w
        snapzone_h = half_h
        return
    if mode == 6:
        snapzone_y = wt + half_h
        snapzone_w = half_w
        snapzone_h = avail_h - half_h
        return
    if mode == 7:
        snapzone_x = half_w
        snapzone_y = wt + half_h
        snapzone_w = scr_w - half_w
        snapzone_h = avail_h - half_h
        return


# ====================================================================
# ROUND-5: most-recently-used (MRU) Alt-Tab order
# ====================================================================
# Round-3's cycler walked windows in stacking order. MATE's switcher uses
# MRU order: the most recently focused window is first, the one before it
# second, etc. — so a single Alt+Tab toggles between your two last
# windows. We track an MRU list of window IDs (stable across the slot
# swaps that daemon_raise_slot performs) and rebuild a per-cycle ordered
# slot list from it.
MRU_UID: Array[8, int32]               # MRU order of DWIN_UID, [0] = most recent
MRU_LEN: uint64 = 0


# Record that the window with daemon UID `uid` was just focused: move it to
# the front of the MRU list (de-duplicating).
def mru_touch(uid: int32):
    if uid <= 0:
        return
    # Find it; shift everything above it down by one.
    found: int64 = -1
    i: uint64 = 0
    while i < MRU_LEN:
        if MRU_UID[i] == uid:
            found = cast[int64](i)
        i = i + 1
    if found >= 0:
        j: uint64 = cast[uint64](found)
        while j > 0:
            MRU_UID[j] = MRU_UID[j - 1]
            j = j - 1
        MRU_UID[0] = uid
        return
    # New: prepend, growing the list (bounded by the window table size).
    if MRU_LEN < 8:
        k: uint64 = MRU_LEN
        while k > 0:
            MRU_UID[k] = MRU_UID[k - 1]
            k = k - 1
        MRU_UID[0] = uid
        MRU_LEN = MRU_LEN + 1
    else:
        m: uint64 = 7
        while m > 0:
            MRU_UID[m] = MRU_UID[m - 1]
            m = m - 1
        MRU_UID[0] = uid


# Drop a window UID from the MRU list (called when a window closes).
def mru_drop(uid: int32):
    i: uint64 = 0
    while i < MRU_LEN:
        if MRU_UID[i] == uid:
            j: uint64 = i
            while j + 1 < MRU_LEN:
                MRU_UID[j] = MRU_UID[j + 1]
                j = j + 1
            MRU_LEN = MRU_LEN - 1
            return
        i = i + 1


# Slot holding window UID `uid`, or -1.
def slot_for_uid(uid: int32) -> int64:
    i: uint64 = 0
    while i < DWIN_COUNT:
        if DWIN_UID[i] == uid:
            return cast[int64](i)
        i = i + 1
    return -1


# Map a cycler position to a slot using MRU order, skipping any window not
# visible on the current workspace. Falls back to stacking order for any
# eligible window the MRU list hasn't seen yet (so brand-new windows still
# appear). Returns -1 past the end.
def mru_slot_for_pos(pos: int64) -> int64:
    seen: int64 = 0
    # First pass: MRU-ordered, current-workspace, visible.
    i: uint64 = 0
    while i < MRU_LEN:
        s: int64 = slot_for_uid(MRU_UID[i])
        if s >= 0 and win_on_cur_ws(cast[uint64](s)) != 0:
            if seen == pos:
                return s
            seen = seen + 1
        i = i + 1
    # Second pass: any visible window NOT already in the MRU list, in
    # stacking order (front-most first).
    si: int64 = cast[int64](DWIN_COUNT) - 1
    while si >= 0:
        su: uint64 = cast[uint64](si)
        if win_on_cur_ws(su) != 0:
            uidv: int32 = DWIN_UID[su]
            in_mru: int32 = 0
            mi: uint64 = 0
            while mi < MRU_LEN:
                if MRU_UID[mi] == uidv:
                    in_mru = 1
                mi = mi + 1
            if in_mru == 0:
                if seen == pos:
                    return si
                seen = seen + 1
        si = si - 1
    return -1


# Show-desktop toggle (MATE "Minimize all"). On the first invocation it
# minimizes every visible window on the current workspace and remembers
# the set; a second invocation restores exactly those. SHOWDESK_ON tracks
# whether we're currently in the minimized-all state.
SHOWDESK_ON: int32 = 0
showdesk_saved: Array[8, int32]    # 1 = this slot was minimized BY show-desktop


def show_desktop_toggle():
    if SHOWDESK_ON == 0:
        # Minimize every currently-visible window on this workspace.
        any_v: int32 = 0
        i: uint64 = 0
        while i < DWIN_COUNT:
            showdesk_saved[i] = 0
            if DWIN_WS[i] == CUR_WS and DWIN_HIDDEN[i] == 0:
                DWIN_HIDDEN[i] = 1
                showdesk_saved[i] = 1
                any_v = 1
            i = i + 1
        SHOWDESK_ON = 1
        sd: Ptr[uint8] = "WM show-desktop on\n"
        sys_write(1, sd, strlen_u8(sd))
    else:
        # Restore exactly the windows we minimized.
        i2: uint64 = 0
        while i2 < DWIN_COUNT:
            if showdesk_saved[i2] != 0:
                DWIN_HIDDEN[i2] = 0
                showdesk_saved[i2] = 0
            i2 = i2 + 1
        SHOWDESK_ON = 0
        sd2: Ptr[uint8] = "WM show-desktop off\n"
        sys_write(1, sd2, strlen_u8(sd2))


# Short title string shown on a built-in app window's title bar.
def window_title(slot: uint64) -> Ptr[uint8]:
    a: int32 = DWIN_APP[slot]
    if a == APP_CALC:
        t1: Ptr[uint8] = "Calculator"
        return t1
    if a == APP_SYSMON:
        t2: Ptr[uint8] = "System Monitor"
        return t2
    if a == APP_ABOUT:
        t3: Ptr[uint8] = "About Hamnix"
        return t3
    if a == APP_SETTINGS:
        t4: Ptr[uint8] = "Settings"
        return t4
    t0: Ptr[uint8] = "Terminal"
    return t0


# ====================================================================
# Built-in calculator app
# ====================================================================
# A 4x4 keypad below a one-line display. Cell layout (row-major 0..15):
#   row0:  7  8  9  /
#   row1:  4  5  6  *
#   row2:  1  2  3  -
#   row3:  0  C  =  +
# Returns the label byte for keypad cell `k` (0..15), or 0 if none.
def calc_key_label(k: int64) -> uint8:
    if k == 0:
        return 55          # '7'
    if k == 1:
        return 56          # '8'
    if k == 2:
        return 57          # '9'
    if k == 3:
        return 47          # '/'
    if k == 4:
        return 52          # '4'
    if k == 5:
        return 53          # '5'
    if k == 6:
        return 54          # '6'
    if k == 7:
        return 42          # '*'
    if k == 8:
        return 49          # '1'
    if k == 9:
        return 50          # '2'
    if k == 10:
        return 51          # '3'
    if k == 11:
        return 45          # '-'
    if k == 12:
        return 48          # '0'
    if k == 13:
        return 67          # 'C'
    if k == 14:
        return 61          # '='
    if k == 15:
        return 43          # '+'
    return 0


# Render the calculator current value into `out` as a NUL-terminated
# decimal string. Negative handled with a leading '-'. Returns the length.
def calc_format(slot: uint64, out: Ptr[uint8]) -> uint64:
    if CALC_ERR[slot] != 0:
        out[0] = 69        # 'E'
        out[1] = 114       # 'r'
        out[2] = 114       # 'r'
        out[3] = 0
        return 3
    v: int64 = CALC_CUR[slot]
    p: uint64 = 0
    if v < 0:
        out[0] = 45        # '-'
        p = 1
        v = 0 - v
    if v == 0:
        out[p] = 48
        p = p + 1
        out[p] = 0
        return p
    tmp: int64 = v
    digits: uint64 = 0
    while tmp > 0:
        digits = digits + 1
        tmp = tmp / 10
    end: uint64 = p + digits
    out[end] = 0
    w: uint64 = end
    while v > 0:
        w = w - 1
        out[w] = cast[uint8](v % 10) + 48
        v = v / 10
    return end


# Apply the pending operator of `slot` to ACC and CUR, leaving the result
# in both. Sets the error flag on divide-by-zero.
def calc_resolve(slot: uint64):
    op: int32 = CALC_OP[slot]
    a: int64 = CALC_ACC[slot]
    b: int64 = CALC_CUR[slot]
    r: int64 = b
    if op == 1:
        r = a + b
    elif op == 2:
        r = a - b
    elif op == 3:
        r = a * b
    elif op == 4:
        if b == 0:
            CALC_ERR[slot] = 1
            return
        r = a / b
    CALC_ACC[slot] = r
    CALC_CUR[slot] = r


# Handle a keypad press (label byte) for the calculator in `slot`.
def calc_press(slot: uint64, lbl: uint8):
    if lbl == 67:                              # 'C' clear
        CALC_ACC[slot] = 0
        CALC_CUR[slot] = 0
        CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        CALC_ERR[slot] = 0
        return
    if CALC_ERR[slot] != 0:
        return                                 # error sticks until cleared
    if lbl >= 48 and lbl <= 57:                # digit
        if CALC_FRESH[slot] != 0:
            CALC_CUR[slot] = 0
            CALC_FRESH[slot] = 0
        nv: int64 = CALC_CUR[slot] * 10 + cast[int64](lbl - 48)
        if nv < 1000000000:                    # clamp to 9 digits
            CALC_CUR[slot] = nv
        return
    if lbl == 61:                              # '=' resolve
        if CALC_OP[slot] != 0:
            calc_resolve(slot)
            CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        return
    # An operator: resolve any pending op first (chained arithmetic),
    # then latch the new op and start a fresh operand.
    newop: int32 = 0
    if lbl == 43:
        newop = 1
    elif lbl == 45:
        newop = 2
    elif lbl == 42:
        newop = 3
    elif lbl == 47:
        newop = 4
    if newop != 0:
        if CALC_OP[slot] != 0 and CALC_FRESH[slot] == 0:
            calc_resolve(slot)
        else:
            CALC_ACC[slot] = CALC_CUR[slot]
        CALC_OP[slot] = newop
        CALC_FRESH[slot] = 1


# Geometry of the calculator body inside window `slot`. Returns, via
# out-pointers, the body origin (bx,by), keypad cell size (cw,ch) and the
# display strip height (dh).
def calc_layout(slot: uint64, bx: Ptr[int64], by: Ptr[int64],
                cw: Ptr[int64], ch: Ptr[int64], dh: Ptr[int64]):
    body_x: int64 = DWIN_X[slot] + 2
    body_y: int64 = DWIN_Y[slot] + TITLE_H
    body_w: int64 = DWIN_W[slot] - 4
    body_h: int64 = DWIN_H[slot] - TITLE_H - 2
    disp_h: int64 = 36
    if disp_h > body_h / 2:
        disp_h = body_h / 2
    bx[0] = body_x
    by[0] = body_y
    cw[0] = body_w / 4
    ch[0] = (body_h - disp_h) / 4
    dh[0] = disp_h


# Keypad cell index (0..15) under (px,py) inside calculator `slot`, or -1.
def calc_cell_at(slot: uint64, px: int64, py: int64) -> int64:
    bx: Array[1, int64]
    by: Array[1, int64]
    cw: Array[1, int64]
    ch: Array[1, int64]
    dh: Array[1, int64]
    calc_layout(slot, &bx[0], &by[0], &cw[0], &ch[0], &dh[0])
    if cw[0] <= 0 or ch[0] <= 0:
        return -1
    kx0: int64 = bx[0]
    ky0: int64 = by[0] + dh[0]
    lx: int64 = px - kx0
    ly: int64 = py - ky0
    if lx < 0 or ly < 0:
        return -1
    col: int64 = lx / cw[0]
    row: int64 = ly / ch[0]
    if col < 0 or col > 3 or row < 0 or row > 3:
        return -1
    return row * 4 + col


# ====================================================================
# Built-in system-monitor app
# ====================================================================
# Append the C string at `s` into out starting at offset p; returns the
# new offset (no NUL written).
def sm_puts(out: Ptr[uint8], p: uint64, s: Ptr[uint8]) -> uint64:
    k: uint64 = 0
    while s[k] != 0:
        out[p] = s[k]
        p = p + 1
        k = k + 1
    return p


# Append `v` as decimal into out at offset p; returns the new offset.
def sm_putnum(out: Ptr[uint8], p: uint64, v: uint64) -> uint64:
    if v == 0:
        out[p] = 48
        return p + 1
    digits: uint64 = 0
    tmp: uint64 = v
    while tmp > 0:
        digits = digits + 1
        tmp = tmp / 10
    end: uint64 = p + digits
    w: uint64 = end
    while v > 0:
        w = w - 1
        out[w] = cast[uint8](v % 10) + 48
        v = v / 10
    return end


# Scan sysmon_buf[0..n) for the line beginning with `key` (e.g.
# "MemTotal:") and parse the first integer that follows it. Returns the
# value, or 0 if the key was not found.
def sm_field(n: uint64, key: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    klen: uint64 = strlen_u8(key)
    while i < n:
        matched: int32 = 1
        j: uint64 = 0
        while j < klen:
            if i + j >= n or sysmon_buf[i + j] != key[j]:
                matched = 0
                break
            j = j + 1
        if matched != 0:
            k: uint64 = i + klen
            while k < n and (sysmon_buf[k] < 48 or sysmon_buf[k] > 57):
                k = k + 1
            v: uint64 = 0
            while k < n and sysmon_buf[k] >= 48 and sysmon_buf[k] <= 57:
                v = v * 10 + cast[uint64](sysmon_buf[k] - 48)
                k = k + 1
            return v
        while i < n and sysmon_buf[i] != 10:
            i = i + 1
        i = i + 1
    return 0


# Refresh the system-monitor display strings from /proc. Throttled to once
# per second (driven by the loop centisecond counter). Reads /proc/uptime
# and /proc/meminfo (MemTotal / MemFree).
def sysmon_refresh(cur_cs: uint64):
    if cur_cs < sysmon_last_cs + 100 and sysmon_last_cs != 0:
        return
    sysmon_last_cs = cur_cs
    # --- uptime ---
    up_secs: uint64 = 0
    up_path: Ptr[char] = "/proc/uptime"
    ufd: int32 = sys_open(up_path)
    if ufd >= 0:
        un: int64 = sys_read(ufd, &sysmon_buf[0], 1024)
        sys_close(ufd)
        cs_up: uint64 = 0
        kk: uint64 = 0
        unu: uint64 = cast[uint64](un)
        while kk < unu and sysmon_buf[kk] >= 48 and sysmon_buf[kk] <= 57:
            cs_up = cs_up * 10 + cast[uint64](sysmon_buf[kk] - 48)
            kk = kk + 1
        up_secs = cs_up / 100
    hh: uint64 = up_secs / 3600
    mm: uint64 = (up_secs / 60) % 60
    ss: uint64 = up_secs % 60
    p: uint64 = 0
    p = sm_puts(&sysmon_line1[0], p, "Uptime: ")
    p = sm_putnum(&sysmon_line1[0], p, hh)
    sysmon_line1[p] = 58
    p = p + 1
    sysmon_line1[p] = cast[uint8](mm / 10) + 48
    p = p + 1
    sysmon_line1[p] = cast[uint8](mm % 10) + 48
    p = p + 1
    sysmon_line1[p] = 58
    p = p + 1
    sysmon_line1[p] = cast[uint8](ss / 10) + 48
    p = p + 1
    sysmon_line1[p] = cast[uint8](ss % 10) + 48
    p = p + 1
    sysmon_line1[p] = 0
    # --- meminfo ---
    mem_total: uint64 = 0
    mem_free: uint64 = 0
    mi_path: Ptr[char] = "/proc/meminfo"
    mfd: int32 = sys_open(mi_path)
    if mfd >= 0:
        mn: int64 = sys_read(mfd, &sysmon_buf[0], 1024)
        sys_close(mfd)
        mnu: uint64 = cast[uint64](mn)
        mem_total = sm_field(mnu, "MemTotal:")
        mem_free = sm_field(mnu, "MemFree:")
    p = 0
    p = sm_puts(&sysmon_line2[0], p, "MemTotal: ")
    p = sm_putnum(&sysmon_line2[0], p, mem_total)
    p = sm_puts(&sysmon_line2[0], p, " kB")
    sysmon_line2[p] = 0
    p = 0
    p = sm_puts(&sysmon_line3[0], p, "MemFree:  ")
    p = sm_putnum(&sysmon_line3[0], p, mem_free)
    p = sm_puts(&sysmon_line3[0], p, " kB")
    sysmon_line3[p] = 0
    used_pct: uint64 = 0
    if mem_total > 0:
        used_pct = ((mem_total - mem_free) * 100) / mem_total
    p = 0
    p = sm_puts(&sysmon_line4[0], p, "MemUsed:  ")
    p = sm_putnum(&sysmon_line4[0], p, used_pct)
    sysmon_line4[p] = 37        # '%'
    p = p + 1
    sysmon_line4[p] = 0


# Parse the cached "MemUsed: NN%" percentage from sysmon_line4 for the bar.
def sysmon_used_pct() -> int64:
    i: uint64 = 0
    v: int64 = 0
    started: int32 = 0
    while sysmon_line4[i] != 0 and i < 48:
        c: uint8 = sysmon_line4[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[int64](c - 48)
            started = 1
        elif started != 0:
            break
        i = i + 1
    if v > 100:
        v = 100
    return v


# ====================================================================
# Built-in app body renderers
# ====================================================================
# Scratch for the calculator display string.
calc_disp_buf: Array[24, uint8]

# Calculator app theme.
CALC_BG_R: uint8 = 54
CALC_BG_G: uint8 = 58
CALC_BG_B: uint8 = 66
CALC_DISP_R: uint8 = 24
CALC_DISP_G: uint8 = 30
CALC_DISP_B: uint8 = 26
CALC_KEY_R: uint8 = 78
CALC_KEY_G: uint8 = 84
CALC_KEY_B: uint8 = 96
CALC_OPKEY_R: uint8 = 96            # operator keys tinted orange-ish
CALC_OPKEY_G: uint8 = 78
CALC_OPKEY_B: uint8 = 60

# System-monitor app theme.
SYSMON_BG_R: uint8 = 40
SYSMON_BG_G: uint8 = 46
SYSMON_BG_B: uint8 = 56


# Render the calculator body for window `slot` at body-pixel (x,y).
def app_calc_pixel(slot: uint64, x: int64, y: int64,
                   outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx: Array[1, int64]
    by: Array[1, int64]
    cw: Array[1, int64]
    ch: Array[1, int64]
    dh: Array[1, int64]
    calc_layout(slot, &bx[0], &by[0], &cw[0], &ch[0], &dh[0])
    r: uint8 = CALC_BG_R
    g: uint8 = CALC_BG_G
    b: uint8 = CALC_BG_B
    ly: int64 = y - by[0]
    # --- display strip across the top ---
    if ly < dh[0]:
        r = CALC_DISP_R
        g = CALC_DISP_G
        b = CALC_DISP_B
        if ly == dh[0] - 1:
            r = 16
            g = 18
            b = 16
        n: uint64 = calc_format(slot, &calc_disp_buf[0])
        pad: int64 = 6
        txt_w: int64 = cast[int64](n) * GLYPH_W
        ox: int64 = bx[0] + (cw[0] * 4) - pad - txt_w
        if ox < bx[0] + pad:
            ox = bx[0] + pad
        oy: int64 = by[0] + (dh[0] - GLYPH_H) / 2
        if str_ink(&calc_disp_buf[0], ox, oy, x, y) != 0:
            r = 120
            g = 240
            b = 140
        outr[0] = r
        outg[0] = g
        outb[0] = b
        return
    # --- keypad ---
    cell: int64 = calc_cell_at(slot, x, y)
    if cell >= 0:
        lbl: uint8 = calc_key_label(cell)
        is_op: int32 = 0
        if lbl == 43 or lbl == 45 or lbl == 42 or lbl == 47 or lbl == 61:
            is_op = 1
        if is_op != 0:
            r = CALC_OPKEY_R
            g = CALC_OPKEY_G
            b = CALC_OPKEY_B
        else:
            r = CALC_KEY_R
            g = CALC_KEY_G
            b = CALC_KEY_B
        # Hover highlight: brighten the cell under the cursor.
        hov: int64 = calc_cell_at(slot, CUR_X, CUR_Y)
        if hov == cell:
            r = add_clamp_u8(r, 34)
            g = add_clamp_u8(g, 34)
            b = add_clamp_u8(b, 34)
        # 1px inset border between keys.
        kx0: int64 = bx[0] + (cell % 4) * cw[0]
        ky0: int64 = by[0] + dh[0] + (cell / 4) * ch[0]
        klx: int64 = x - kx0
        kly: int64 = y - ky0
        if klx == 0 or kly == 0:
            r = sub_clamp_u8(r, 28)
            g = sub_clamp_u8(g, 28)
            b = sub_clamp_u8(b, 28)
        # Centred label glyph.
        gx0: int64 = kx0 + (cw[0] - GLYPH_W) / 2
        gy0: int64 = ky0 + (ch[0] - GLYPH_H) / 2
        kbuf: Array[2, uint8]
        kbuf[0] = lbl
        kbuf[1] = 0
        if str_ink(&kbuf[0], gx0, gy0, x, y) != 0:
            r = 235
            g = 235
            b = 240
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Render the system-monitor body for window `slot` at body-pixel (x,y).
def app_sysmon_pixel(slot: uint64, x: int64, y: int64,
                     outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = SYSMON_BG_R
    g: uint8 = SYSMON_BG_G
    b: uint8 = SYSMON_BG_B
    pad: int64 = 8
    tx: int64 = bx0 + pad
    h0: Ptr[uint8] = "Hamnix System Monitor"
    if str_ink(h0, tx, by0 + 8, x, y) != 0:
        r = 150
        g = 200
        b = 250
    if str_ink(&sysmon_line1[0], tx, by0 + 40, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line2[0], tx, by0 + 64, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line3[0], tx, by0 + 88, x, y) != 0:
        r = 220
        g = 230
        b = 235
    if str_ink(&sysmon_line4[0], tx, by0 + 112, x, y) != 0:
        r = 180
        g = 240
        b = 180
    # A proportional memory-usage bar under the text.
    bar_y: int64 = by0 + 140
    bar_h: int64 = 14
    bar_x0: int64 = tx
    bar_w: int64 = DWIN_W[slot] - 4 - pad * 2
    if y >= bar_y and y < bar_y + bar_h and x >= bar_x0 and x < bar_x0 + bar_w:
        if x == bar_x0 or x == bar_x0 + bar_w - 1 or y == bar_y or y == bar_y + bar_h - 1:
            r = 200
            g = 200
            b = 210
        else:
            pct: int64 = sysmon_used_pct()
            fillw: int64 = ((bar_w - 2) * pct) / 100
            if x - (bar_x0 + 1) < fillw:
                r = 90
                g = 180
                b = 120
            else:
                r = 30
                g = 34
                b = 40
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Render the About card body.
def app_about_pixel(slot: uint64, x: int64, y: int64,
                    outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 44
    g: uint8 = 50
    b: uint8 = 62
    tx: int64 = bx0 + 12
    l0: Ptr[uint8] = "Hamnix Desktop"
    if str_ink(l0, tx, by0 + 16, x, y) != 0:
        r = 160
        g = 210
        b = 255
    l1: Ptr[uint8] = "A Plan 9 / MATE-flavoured DE"
    if str_ink(l1, tx, by0 + 44, x, y) != 0:
        r = 220
        g = 228
        b = 235
    l2: Ptr[uint8] = "Native windowing + compositor"
    if str_ink(l2, tx, by0 + 64, x, y) != 0:
        r = 220
        g = 228
        b = 235
    l3: Ptr[uint8] = "Use Applications to launch apps."
    if str_ink(l3, tx, by0 + 92, x, y) != 0:
        r = 200
        g = 208
        b = 215
    outr[0] = r
    outg[0] = g
    outb[0] = b


# ====================================================================
# ROUND-4: Settings / Preferences built-in app (APP_SETTINGS)
# ====================================================================
# A genuine in-process preferences window — no child process. Clickable
# rows let the user change session appearance + behaviour:
#   row 0: Theme accent  -> theme_cycle()        (title-bar colour)
#   row 1: Background     -> bg_cycle()           (desktop colour)
#   row 2: Panel position -> panel_pos_toggle()   (top / bottom pref)
#   row 3: Focus model    -> focus_mode_toggle()  (click / follows-mouse)
#   row 4: Workspaces     -> ws_count_cycle()     (number of desktops) [R8]
#   row 5: Reset          -> restore all defaults
# Choices persist in-memory for the session (the THEME_IDX / BG_IDX /
# PANEL_POS / FOCUS_MODE / WS_COUNT globals). Layout mirrors calc_layout's
# out-pointer pattern.
SET_ROWS:   int64 = 6
SET_ROW_H:  int64 = 28
SET_TOP_PAD: int64 = 14


# y of the top of settings row `i` (screen coords) for window `slot`.
def settings_row_y(slot: uint64, i: int64) -> int64:
    return DWIN_Y[slot] + TITLE_H + SET_TOP_PAD + i * SET_ROW_H


# Row index (0..SET_ROWS-1) under (px,py) inside settings window `slot`,
# or -1. Rows span the full body width inset by a small margin.
def settings_row_at(slot: uint64, px: int64, py: int64) -> int64:
    bx0: int64 = DWIN_X[slot] + 8
    bw:  int64 = DWIN_W[slot] - 16
    if px < bx0 or px >= bx0 + bw:
        return -1
    i: int64 = 0
    while i < SET_ROWS:
        ry: int64 = settings_row_y(slot, i)
        if py >= ry and py < ry + SET_ROW_H - 4:
            return i
        i = i + 1
    return -1


# Invoke settings row `i` for window `slot`.
def settings_press(slot: uint64, i: int64):
    if i == 0:
        theme_cycle()
    elif i == 1:
        bg_cycle()
    elif i == 2:
        panel_pos_toggle()
    elif i == 3:
        # ROUND-7: toggle the focus model (click-to-focus / follows-mouse).
        focus_mode_toggle()
    elif i == 4:
        # ROUND-8: change the number of virtual desktops.
        ws_count_cycle()
    elif i == 5:
        # Reset all session appearance + behaviour to defaults.
        THEME_IDX = 0
        theme_apply()
        BG_IDX = 0
        bg_palette_init()
        ROOT_R = bg_palette[0]
        ROOT_G = bg_palette[1]
        ROOT_B = bg_palette[2]
        PANEL_POS = 0
        FOCUS_MODE = 0
        WS_COUNT = 4
        if CUR_WS >= WS_COUNT:
            CUR_WS = WS_COUNT - 1
        rs: Ptr[uint8] = "SETTINGS reset\n"
        sys_write(1, rs, strlen_u8(rs))


# Render the Settings body. Each row paints its label on the left and its
# current value (right-aligned-ish) plus a faint row separator, with the
# value tinted by the live accent so the theme choice reads immediately.
def app_settings_pixel(slot: uint64, x: int64, y: int64,
                       outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    bx0: int64 = DWIN_X[slot] + 2
    by0: int64 = DWIN_Y[slot] + TITLE_H
    r: uint8 = 46
    g: uint8 = 52
    b: uint8 = 64
    tx: int64 = bx0 + 12
    # Title line.
    hd: Ptr[uint8] = "Appearance"
    if str_ink(hd, tx, by0 + 2, x, y) != 0:
        r = 170
        g = 210
        b = 255
    # Row backgrounds + a hover-less highlight band so rows read as buttons.
    rowi: int64 = 0
    while rowi < SET_ROWS:
        ry: int64 = settings_row_y(slot, rowi)
        rx0: int64 = DWIN_X[slot] + 8
        rw:  int64 = DWIN_W[slot] - 16
        if y >= ry and y < ry + SET_ROW_H - 4 and x >= rx0 and x < rx0 + rw:
            # button face
            r = 60
            g = 68
            b = 84
            if x == rx0 or x == rx0 + rw - 1 or y == ry or y == ry + SET_ROW_H - 5:
                r = 96
                g = 104
                b = 122
        rowi = rowi + 1
    # Row labels + values.
    lx: int64 = bx0 + 16
    vx: int64 = DWIN_X[slot] + DWIN_W[slot] - 8 - 9 * GLYPH_W
    y0: int64 = settings_row_y(slot, 0) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y1: int64 = settings_row_y(slot, 1) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y2: int64 = settings_row_y(slot, 2) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y3: int64 = settings_row_y(slot, 3) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y4: int64 = settings_row_y(slot, 4) + (SET_ROW_H - 4 - GLYPH_H) / 2
    y5: int64 = settings_row_y(slot, 5) + (SET_ROW_H - 4 - GLYPH_H) / 2
    lbl0: Ptr[uint8] = "Theme"
    lbl1: Ptr[uint8] = "Background"
    lbl2: Ptr[uint8] = "Panel"
    lbl3: Ptr[uint8] = "Focus"
    lbl4: Ptr[uint8] = "Workspaces"
    lbl5: Ptr[uint8] = "Reset Defaults"
    if str_ink(lbl0, lx, y0, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl1, lx, y1, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl2, lx, y2, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl3, lx, y3, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl4, lx, y4, x, y) != 0:
        r = 225
        g = 230
        b = 238
    if str_ink(lbl5, lx, y5, x, y) != 0:
        r = 225
        g = 230
        b = 238
    # Values, tinted by the accent so the theme choice is visible.
    if str_ink(theme_name(THEME_IDX), vx, y0, x, y) != 0:
        r = ACCENT_TOP_R
        g = ACCENT_TOP_G
        b = ACCENT_TOP_B
    bgv: Array[4, uint8]
    bgv[0] = cast[uint8](BG_IDX) + 48
    bgv[1] = 0
    if str_ink(&bgv[0], vx, y1, x, y) != 0:
        r = 180
        g = 220
        b = 180
    if str_ink(panel_pos_name(PANEL_POS), vx, y2, x, y) != 0:
        r = 230
        g = 210
        b = 150
    if str_ink(focus_mode_name(FOCUS_MODE), vx, y3, x, y) != 0:
        r = 210
        g = 190
        b = 240
    # ROUND-8: workspace-count value (a single digit, WS_MIN..WS_MAX).
    wsv: Array[4, uint8]
    wsv[0] = cast[uint8](WS_COUNT) + 48
    wsv[1] = 0
    if str_ink(&wsv[0], vx, y4, x, y) != 0:
        r = 150
        g = 200
        b = 230
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Dispatch a built-in app's body pixel to the right renderer.
def app_body_pixel(slot: uint64, x: int64, y: int64,
                   outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    a: int32 = DWIN_APP[slot]
    if a == APP_CALC:
        app_calc_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_SYSMON:
        app_sysmon_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_ABOUT:
        app_about_pixel(slot, x, y, outr, outg, outb)
    elif a == APP_SETTINGS:
        app_settings_pixel(slot, x, y, outr, outg, outb)
    else:
        outr[0] = WIN_BODY_R
        outg[0] = WIN_BODY_G
        outb[0] = WIN_BODY_B


# ---- daemon window model -------------------------------------------
# Up to DMAX windows the daemon paints as chrome rectangles. We mirror
# the wsys cap (MAX_WINDOWS - 2 spawnable slots) but keep our own count.
DMAX: uint64 = 8
DWIN_X: Array[8, int64]
DWIN_Y: Array[8, int64]
DWIN_W: Array[8, int64]
DWIN_H: Array[8, int64]
DWIN_WID: Array[8, int32]
# ROUND-5: daemon-local stable window identity. Unlike DWIN_WID (the kernel
# wsys id, which is -1 for built-in app windows and when spawning fails),
# every window — terminal OR built-in app — gets a unique positive UID at
# creation. The MRU Alt-Tab list keys on this so focus history is tracked
# for ALL windows, not just real-process terminals.
DWIN_UID: Array[8, int32]
NEXT_UID: int32 = 1
DWIN_COUNT: uint64 = 0
# Minimize state: 1 = window is hidden to the taskbar, 0 = visible.
DWIN_HIDDEN: Array[8, int32]

# GPU track #183: per-window "Vulkan body" flag. 1 = this window's body
# is painted from the native-Vulkan-rendered image in vk_body_buf (read
# from the window's /dev/wsys/<wid>/draw/vk/fb draw-surface layer each
# frame) instead of the in-daemon terminal grid. Only one window carries
# the live vk body at a time in the self-test, but the model is general.
DWIN_VK: Array[8, int32]

# ---- MATE virtual workspaces (per-window) --------------------------
# Each window belongs to exactly one of WS_COUNT virtual desktops. Only
# windows whose DWIN_WS == CUR_WS are composited / hit-tested. The
# minimize bit is independent and still hides a window within its own
# workspace.
DWIN_WS: Array[8, int32]

# ---- MATE maximize / restore (per-window) --------------------------
# DWIN_MAXED == 1 means the window is maximized: its current geometry
# fills the work area (below the panel) and DWIN_SAVE_* holds the
# pre-maximize rectangle so Restore can put it back exactly.
DWIN_MAXED:  Array[8, int32]
DWIN_SAVE_X: Array[8, int64]
DWIN_SAVE_Y: Array[8, int64]
DWIN_SAVE_W: Array[8, int64]
DWIN_SAVE_H: Array[8, int64]

# ---- built-in DE application windows -------------------------------
# Beyond windows backed by a spawned child shell (DWIN_APP == APP_TERM),
# the daemon renders genuine built-in applications entirely in-process:
# their body is drawn by app-specific code and clicks/keys on the body
# route to app-specific handlers (no child process, no pipes). This makes
# the desktop useful out of the box like MATE's bundled utilities.
#   APP_TERM    — child shell + VT grid (the default)
#   APP_CALC    — pocket calculator (4x4 keypad + display, click+keyboard)
#   APP_SYSMON  — system monitor (reads /proc/uptime + /proc/meminfo)
#   APP_ABOUT   — static "About Hamnix" info card
APP_TERM:   int32 = 0
APP_CALC:   int32 = 1
APP_SYSMON: int32 = 2
APP_ABOUT:  int32 = 3
APP_SETTINGS: int32 = 4               # ROUND-4: theme/panel/background prefs
DWIN_APP: Array[8, int32]              # which app this window hosts

# Calculator state, tracked per-slot so multiple calculators each keep
# their own accumulator.
CALC_ACC:   Array[8, int64]           # running accumulator
CALC_CUR:   Array[8, int64]           # number currently being entered
CALC_OP:    Array[8, int32]           # pending op: 0 none,1 +,2 -,3 *,4 /
CALC_FRESH: Array[8, int32]           # 1 = next digit starts a new entry
CALC_ERR:   Array[8, int32]           # 1 = divide-by-zero / overflow flagged

# System-monitor scratch: re-read /proc each second so the figures stay
# live. Strings rendered straight into the body via str_ink.
sysmon_buf:   Array[1024, uint8]
sysmon_line1: Array[48, uint8]        # "Uptime: HH:MM:SS"
sysmon_line2: Array[48, uint8]        # "MemTotal: NNNN kB"
sysmon_line3: Array[48, uint8]        # "MemFree:  NNNN kB"
sysmon_line4: Array[48, uint8]        # "MemUsed:  NN%"
sysmon_last_cs: uint64 = 0

# ---- window snapping / edge tiling ---------------------------------
# Dragging a window's title bar to a screen edge snaps it (GNOME/MATE
# "edge tiling"): top edge -> maximize, left/right edge -> half-tile.
# The pre-snap geometry is stored in DWIN_SAVE_* (shared with the
# maximize feature) so a later restore returns the window to its float
# size. DWIN_SNAP: 0 float, 1 maximized, 2 left-half, 3 right-half.
DWIN_SNAP: Array[8, int32]
SNAP_EDGE: int64 = 8                  # px from an edge that triggers a snap

# ---- ROUND-9: window shading (roll-up) -----------------------------
# MATE/GNOME2 "shade" rolls a window up so only its title bar shows; a
# second shade unrolls it. DWIN_SHADED == 1 means the window is rolled
# up; DWIN_SHADE_H holds the full (un-shaded) height so unshade restores
# it exactly. While shaded the live DWIN_H is forced to the title-bar
# height so every existing draw / hit-test path naturally collapses to
# the bar without any special-casing in the compositor.
DWIN_SHADED:  Array[8, int32]
DWIN_SHADE_H: Array[8, int64]

# ---- ROUND-9: always-on-top (keep-above) ---------------------------
# DWIN_ONTOP == 1 pins the window above all normal windows regardless of
# raise/lower. The z-order is the array order, so enforce_ontop_order()
# bubbles every pinned window to the tail (front of the paint walk) after
# any raise and before each present. Pinned windows keep their relative
# order amongst themselves.
DWIN_ONTOP: Array[8, int32]

# Log Out (System menu): set to 1 to request a clean daemon shutdown so
# the console returns to the foreground shell.
DAEMON_QUIT: int32 = 0

# The native Vulkan window image is 192x192 RGBA8888 (matches lib's
# vk_window_demo VK_WIN_W/H). Module-scope flat buffer (Adder U9 quirk).
VK_BODY_W: int64 = 192
VK_BODY_H: int64 = 192
vk_body_buf: Array[147456, uint8]      # 192 * 192 * 4
vk_body_ready: int32 = 0               # 1 once vk_body_buf holds a frame

# ---- live clock state ---------------------------------------------
# Updated once per second from /proc/realtime (wall clock) or
# /proc/uptime (monotonic fallback). The string is HH:MM (5 chars)
# or UUU:MM (uptime hours:minutes). Always NUL-terminated.
clock_str: Array[12, uint8]
clock_last_cs: uint64 = 0        # centiseconds at last clock refresh
# Full date string for the clock-applet hover tooltip ("YYYY-MM-DD HH:MM:SS"
# from /proc/realtime, or "Uptime H:MM:SS" fallback). NUL-terminated.
clock_date_str: Array[32, uint8]
CLOCK_HOVER: int32 = 0           # 1 while the cursor is over the clock zone

# ---- per-window terminal (in-daemon emulator) ----------------------
# Each window dragged out runs an interactive hamsh whose stdin/stdout
# are kernel pipes. The daemon owns the PARENT ends:
#   DWIN_IN_FD  — write end of the child's stdin pipe (keystrokes -> shell)
#   DWIN_OUT_FD — read  end of the child's stdout pipe (shell -> grid)
# and emulates a tiny VT into a per-window character GRID rendered into
# the window body by daemon_pixel. The grid is a flat DMAX*GRID_CELLS
# byte array; each cell holds one printable ASCII byte (0 == blank).
DWIN_IN_FD:  Array[8, int32]
DWIN_OUT_FD: Array[8, int32]
DWIN_PID:    Array[8, int32]
DWIN_COLS:   Array[8, int64]      # body_w / GLYPH_W
DWIN_ROWS:   Array[8, int64]      # body_h / GLYPH_H
DWIN_CUR_C:  Array[8, int64]      # cursor column
DWIN_CUR_R:  Array[8, int64]      # cursor row
# VT parser state per window: 0 = ground, 1 = saw ESC, 2 = in CSI.
DWIN_VT:     Array[8, int32]

GLYPH_W: int64 = 8
GLYPH_H: int64 = 16
# Grid cap per window: 128 cols * 64 rows. 8192 cells * 8 windows = 64 KiB.
GRID_COLS_MAX: int64 = 128
GRID_ROWS_MAX: int64 = 64
GRID_CELLS:    uint64 = 8192      # GRID_COLS_MAX * GRID_ROWS_MAX
term_grid: Array[65536, uint8]    # DMAX * GRID_CELLS

# Small scratch buffer for draining a child's stdout pipe each frame.
term_rx: Array[1024, uint8]
# Small scratch buffer for draining /dev/cons keystrokes each frame.
cons_rx: Array[256, uint8]
cons_fd: int32 = -1

# ---- cursor + drag state -------------------------------------------
CUR_X: int64 = 0
CUR_Y: int64 = 0
DRAG_ACTIVE: int32 = 0
DRAG_X0: int64 = 0
DRAG_Y0: int64 = 0
PREV_BTN_L: int32 = 0                     # previous-iteration left button
PREV_BTN_R: int32 = 0                     # previous-iteration right button

# ---- window-management gesture state -------------------------------
# A left-button-press is classified at the down-edge into one of these
# gestures, tracked by GESTURE:
#   0 = create  (press landed on empty desktop) — rubber-band + spawn
#   1 = move    (press landed on a window title bar) — relocate window
#   2 = close   (press landed on a window's close box) — destroy on up
#   3 = inert   (panel/body/menu press — no up-edge action)
#   4 = resize  (ROUND-6: press landed on a window border edge/corner)
GESTURE: int32 = 0
# For move: which window slot is being dragged + the cursor-to-window
# offset captured at the down-edge so the window tracks under the grab.
MOVE_SLOT: int64 = -1
MOVE_OFF_X: int64 = 0
MOVE_OFF_Y: int64 = 0
# For close: the slot the press landed on (the release must land on the
# SAME slot's close box to actually destroy it — rio-style).
CLOSE_SLOT: int64 = -1
# Close-box geometry: a square at the right end of the title bar.
CLOSE_BOX: int64 = 14                      # close-box side length (px)

# ---- ROUND-6: interactive window resize by dragging edges/corners --
# MATE/GNOME2 lets you grab any window EDGE or CORNER to resize. We add an
# 8-direction resize grip band around each window's outer frame. A press on
# the band starts GESTURE==4; while held, the grabbed edge(s) track the
# cursor (corners move two edges at once) down to a minimum body size; the
# opposite edge stays anchored so the window grows/shrinks the way the
# pointer pulls. The active resize draws a bright accent frame (like the
# snap preview) so the operation reads clearly without a real cursor theme.
#
# RESIZE_DIR encodes which handle was grabbed as a 4-bit mask:
#   bit0 (1) = left edge    bit1 (2) = right edge
#   bit2 (4) = top edge     bit3 (8) = bottom edge
# Corners set two bits (e.g. top-left = 1|4 = 5). 0 = no resize.
RESIZE_GRIP: int64 = 6                 # px-wide grab band around the frame
RESIZE_MIN_W: int64 = 96               # smallest window width  (px)
RESIZE_MIN_H: int64 = 64               # smallest window height (px)
RESIZE_SLOT: int64 = -1                # slot being resized, or -1
RESIZE_DIR:  int32 = 0                 # grabbed-edge mask (see above)
# Anchored opposite-edge coordinates captured at the down-edge so the held
# edges track the cursor while the far edges stay put.
RESIZE_FIX_X: int64 = 0                # anchored x (right when dragging left)
RESIZE_FIX_Y: int64 = 0                # anchored y (bottom when dragging top)
RESIZE_FIX_R: int64 = 0                # anchored right  x
RESIZE_FIX_B: int64 = 0                # anchored bottom y
# RESIZE_HOVER mirrors RESIZE_DIR for the cursor that is merely HOVERING a
# grip (no button down) so the compositor can hint the grip is live.
RESIZE_HOVER: int32 = 0

# Double-click-titlebar-to-maximize tracking. WM_FRAME is a monotonic
# frame counter the daemon main loop bumps each iteration. A title-bar
# press records its frame + slot; a second press on the SAME slot within
# DBLCLICK_FRAMES is a double-click and toggles maximize (MATE default).
WM_FRAME: int64 = 0
LAST_TCLICK_FRAME: int64 = -1000
LAST_TCLICK_SLOT:  int64 = -1
DBLCLICK_FRAMES:   int64 = 30          # ~double-click window in frames

# Small mouse read buffer ("<dx> <dy> <buttons>\n" lines).
mouse_buf: Array[256, uint8]
# Scratch buffer for taskbar button number label (single digit + NUL).
taskbar_lbl_buf: Array[8, uint8]
# Scratch buffer for taskbar click serial output (digit + newline).
taskbar_click_buf: Array[4, uint8]


def iclamp(v: int64, lo: int64, hi: int64) -> int64:
    if v < lo:
        return lo
    if v > hi:
        return hi
    return v


def imin(a: int64, b: int64) -> int64:
    if a < b:
        return a
    return b


def imax(a: int64, b: int64) -> int64:
    if a > b:
        return a
    return b


# Subtract `d` from a uint8 channel, clamping at 0 (used for shadows).
def sub_clamp_u8(v: uint8, d: int64) -> uint8:
    iv: int64 = cast[int64](v) - d
    if iv < 0:
        iv = 0
    return cast[uint8](iv)


# Add `d` to a uint8 channel, clamping at 255 (hover/highlight tints).
def add_clamp_u8(v: uint8, d: int64) -> uint8:
    iv: int64 = cast[int64](v) + d
    if iv > 255:
        iv = 255
    return cast[uint8](iv)


# ---- taskbar hit-testing -------------------------------------------
# The taskbar zone begins just right of the GNOME2 menu bar
# (Applications/Places/System), whose total width is dynamic. The old
# fixed TASKBAR_START_X (sized for a single Applications button) would
# overlap the wider menu bar, so derive the start from menubar_end_x().
def taskbar_start_x() -> int64:
    s: int64 = menubar_end_x() + 4
    if s < TASKBAR_START_X:
        s = TASKBAR_START_X
    return s


# Left x-coordinate of the taskbar button for window `slot`.
# Buttons are laid out left-to-right starting at taskbar_start_x(),
# one per slot regardless of minimized state (all windows appear).
def taskbar_btn_x(slot: uint64) -> int64:
    return taskbar_start_x() + cast[int64](slot) * TASKBAR_BTN_W


# 1 if (px,py) is inside the taskbar button for window `slot`, else 0.
# Taskbar buttons live within the panel height.
def in_taskbar_btn(slot: uint64, px: int64, py: int64) -> int32:
    ly: int64 = panel_local_y(py)
    if ly < TASKBAR_BTN_Y or ly >= TASKBAR_BTN_Y + TASKBAR_BTN_H:
        return 0
    bx: int64 = taskbar_btn_x(slot)
    if px >= bx and px < bx + TASKBAR_BTN_W - 2:
        return 1
    return 0


# Return the taskbar slot (0..DWIN_COUNT-1) under (px,py), or -1.
# Clocks and the Applications button are excluded by TASKBAR_START_X.
def taskbar_slot_at(px: int64, py: int64, scr_w: int64) -> int64:
    if on_panel_y(py) == 0:
        return -1
    # Exclude clock area on the right.
    clock_x: int64 = scr_w - CLOCK_W
    if px >= clock_x:
        return -1
    if px < taskbar_start_x():
        return -1
    # ROUND-10: only group leaders own a taskbar button (grouped members
    # are folded behind their leader), so a hit on a non-leader slot's
    # nominal rect is ignored — only the painted leader buttons hit.
    i: uint64 = 0
    while i < DWIN_COUNT:
        if in_taskbar_btn(i, px, py) != 0 and is_group_leader(i) != 0:
            return cast[int64](i)
        i = i + 1
    return -1


# ---- ROUND-7: clock-applet click zone + calendar toggle ------------
# 1 if (px,py) lands on the right-edge clock zone of the panel.
def in_clock_zone(px: int64, py: int64, scr_w: int64) -> int32:
    if on_panel_y(py) == 0:
        return 0
    clock_x: int64 = scr_w - CLOCK_W
    if px >= clock_x and px < scr_w:
        return 1
    return 0


# Left x of the dropped calendar popup, right-aligned under the clock and
# clamped on-screen.
def cal_drop_x(scr_w: int64) -> int64:
    cx: int64 = scr_w - CAL_W - 2
    if cx < 0:
        cx = 0
    return cx


# Top y of the calendar popup (drops off the panel edge, away from it).
def cal_drop_y() -> int64:
    return drop_anchor_y(cal_total_h())


# Toggle the calendar popup. Refreshes the highlighted day from the live
# clock state first so a freshly-opened calendar shows today.
def cal_toggle():
    if CAL_OPEN != 0:
        CAL_OPEN = 0
        cc: Ptr[uint8] = "CAL close\n"
        sys_write(1, cc, strlen_u8(cc))
    else:
        CAL_OPEN = 1
        # Close other panel drop-downs so chrome never overlaps.
        MENU_BAR_OPEN = -1
        MENU_OPEN = 0
        co: Ptr[uint8] = "CAL open "
        sys_write(1, co, strlen_u8(co))
        write_str(1, cal_month_name(CAL_MONTH))
        write_str(1, "\n")


# ---- minimize-box hit-testing --------------------------------------
# The minimize box is a square just to the LEFT of the close box in
# the title bar. Returns its top-left x.
def minimize_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX - 2 - MINIMIZE_BOX


def minimize_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside the minimize box for window `slot`, else 0.
def in_minimize_box(slot: uint64, px: int64, py: int64) -> int32:
    mx: int64 = minimize_box_x(slot)
    my: int64 = minimize_box_y(slot)
    if px >= mx and px < mx + MINIMIZE_BOX and py >= my and py < my + MINIMIZE_BOX:
        return 1
    return 0


# ---- ROUND-7 calendar helpers --------------------------------------
# Parse two ASCII digit bytes into an int (e.g. '0','7' -> 7).
def digits2(a: uint8, b: uint8) -> int64:
    hi: int64 = 0
    if a >= 48 and a <= 57:
        hi = cast[int64](a) - 48
    lo: int64 = 0
    if b >= 48 and b <= 57:
        lo = cast[int64](b) - 48
    return hi * 10 + lo


# Parse four ASCII digit bytes into a year.
def digits4(a: uint8, b: uint8, c: uint8, d: uint8) -> int64:
    return digits2(a, b) * 100 + digits2(c, d)


# 1 if `y` is a leap year (Gregorian).
def is_leap(y: int64) -> int32:
    if y % 400 == 0:
        return 1
    if y % 100 == 0:
        return 0
    if y % 4 == 0:
        return 1
    return 0


# Number of days in month `m` (1..12) of year `y`.
def days_in_month(y: int64, m: int64) -> int64:
    if m == 2:
        if is_leap(y) != 0:
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    return 31


# Day-of-week (0=Sunday .. 6=Saturday) of the 1st of month `m`, year `y`,
# via a Sakamoto-style computation specialised to day-of-month 1.
def dow_first(y: int64, m: int64) -> int64:
    t0: int64 = 0
    if m == 1:
        t0 = 0
    elif m == 2:
        t0 = 3
    elif m == 3:
        t0 = 2
    elif m == 4:
        t0 = 5
    elif m == 5:
        t0 = 0
    elif m == 6:
        t0 = 3
    elif m == 7:
        t0 = 5
    elif m == 8:
        t0 = 1
    elif m == 9:
        t0 = 4
    elif m == 10:
        t0 = 6
    elif m == 11:
        t0 = 2
    else:
        t0 = 4
    yy: int64 = y
    if m < 3:
        yy = yy - 1
    w: int64 = (yy + yy / 4 - yy / 100 + yy / 400 + t0 + 1) % 7
    if w < 0:
        w = w + 7
    return w


# Three-letter month name for the calendar header.
def cal_month_name(m: int64) -> Ptr[uint8]:
    if m == 1:
        s: Ptr[uint8] = "January"
        return s
    if m == 2:
        s2: Ptr[uint8] = "February"
        return s2
    if m == 3:
        s3: Ptr[uint8] = "March"
        return s3
    if m == 4:
        s4: Ptr[uint8] = "April"
        return s4
    if m == 5:
        s5: Ptr[uint8] = "May"
        return s5
    if m == 6:
        s6: Ptr[uint8] = "June"
        return s6
    if m == 7:
        s7: Ptr[uint8] = "July"
        return s7
    if m == 8:
        s8: Ptr[uint8] = "August"
        return s8
    if m == 9:
        s9: Ptr[uint8] = "September"
        return s9
    if m == 10:
        s10: Ptr[uint8] = "October"
        return s10
    if m == 11:
        s11: Ptr[uint8] = "November"
        return s11
    s12: Ptr[uint8] = "December"
    return s12


# Single-letter day-of-week initials, column 0..6 = Sun..Sat.
def cal_dow_initial(col: int64) -> Ptr[uint8]:
    if col == 0:
        c0: Ptr[uint8] = "S"
        return c0
    if col == 1:
        c1: Ptr[uint8] = "M"
        return c1
    if col == 2:
        c2: Ptr[uint8] = "T"
        return c2
    if col == 3:
        c3: Ptr[uint8] = "W"
        return c3
    if col == 4:
        c4: Ptr[uint8] = "T"
        return c4
    if col == 5:
        c5: Ptr[uint8] = "F"
        return c5
    c6: Ptr[uint8] = "S"
    return c6


# Number of week-rows the current month needs (cells / 7, rounded up).
def cal_rows() -> int64:
    if CAL_MONTH < 1 or CAL_MONTH > 12:
        return 6
    lead: int64 = dow_first(CAL_YEAR, CAL_MONTH)
    total: int64 = lead + days_in_month(CAL_YEAR, CAL_MONTH)
    rows: int64 = (total + 6) / 7
    if rows < 4:
        rows = 4
    if rows > 6:
        rows = 6
    return rows


# Total pixel height of the calendar popup (header + dow row + day grid).
def cal_total_h() -> int64:
    return CAL_HEAD_H + CAL_DOW_H + cal_rows() * CAL_CELL_H + 4


# Day-of-month at calendar grid (row,col), or 0 if the cell is blank
# (leading/trailing pad outside the month).
def cal_day_at(row: int64, col: int64) -> int64:
    lead: int64 = dow_first(CAL_YEAR, CAL_MONTH)
    cell: int64 = row * 7 + col
    d: int64 = cell - lead + 1
    if d < 1 or d > days_in_month(CAL_YEAR, CAL_MONTH):
        return 0
    return d


# ---- live clock refresh --------------------------------------------
# Read /proc/realtime; extract HH:MM from the ISO-8601 timestamp.
# Fall back to /proc/uptime (uptime as H:MM) if realtime unavailable.
# Updates clock_str[] and clock_last_cs. Call once per second.
clock_read_buf: Array[64, uint8]

def clock_refresh(cur_cs: uint64):
    # Only refresh once per 100 centiseconds (1 second).
    if cur_cs < clock_last_cs + 100 and clock_last_cs != 0:
        return
    clock_last_cs = cur_cs
    # Try /proc/realtime first: line 1 is "YYYY-MM-DDTHH:MM:SSZ epoch\n"
    # HH is at offset 11, MM at 14 (after the 'T' at 10).
    rt_path: Ptr[char] = "/proc/realtime"
    rfd: int32 = sys_open(rt_path)
    if rfd >= 0:
        n: int64 = sys_read(rfd, &clock_read_buf[0], 64)
        sys_close(rfd)
        nu: uint64 = cast[uint64](n)
        # Check it's a real timestamp (starts with digit, not 'u' for unavailable)
        if nu >= 20 and clock_read_buf[0] != 117 and clock_read_buf[10] == 84:
            # offset 11: HH, offset 12: ':', offset 14: MM
            clock_str[0] = clock_read_buf[11]
            clock_str[1] = clock_read_buf[12]
            clock_str[2] = 58     # ':'
            clock_str[3] = clock_read_buf[14]
            clock_str[4] = clock_read_buf[15]
            clock_str[5] = 0
            # Tooltip date: "YYYY-MM-DD HH:MM:SS" (offsets 0..9 + space + 11..18).
            di: uint64 = 0
            while di < 10:
                clock_date_str[di] = clock_read_buf[di]
                di = di + 1
            clock_date_str[10] = 32       # space
            dj: uint64 = 0
            while dj < 8:
                clock_date_str[11 + dj] = clock_read_buf[11 + dj]
                dj = dj + 1
            clock_date_str[19] = 0
            # ROUND-7: also parse Y-M-D for the calendar popup. Offsets:
            # YYYY @0..3, MM @5..6, DD @8..9.
            CAL_YEAR = digits4(clock_read_buf[0], clock_read_buf[1],
                               clock_read_buf[2], clock_read_buf[3])
            CAL_MONTH = digits2(clock_read_buf[5], clock_read_buf[6])
            CAL_DAY = digits2(clock_read_buf[8], clock_read_buf[9])
            CAL_VALID = 1
            return
    # Fallback: /proc/uptime gives centiseconds. Convert to H:MM.
    up_path: Ptr[char] = "/proc/uptime"
    ufd: int32 = sys_open(up_path)
    if ufd >= 0:
        n2: int64 = sys_read(ufd, &clock_read_buf[0], 64)
        sys_close(ufd)
        cs_up: uint64 = 0
        k: uint64 = 0
        nu2: uint64 = cast[uint64](n2)
        while k < nu2 and clock_read_buf[k] >= 48 and clock_read_buf[k] <= 57:
            cs_up = cs_up * 10 + cast[uint64](clock_read_buf[k] - 48)
            k = k + 1
        secs: uint64 = cs_up / 100
        mins: uint64 = (secs / 60) % 60
        hrs:  uint64 = secs / 3600
        # Format H:MM (hours may be more than 2 digits for long uptimes).
        # Cap display to 3 digits of hours so the clock fits the panel.
        idx: uint64 = 0
        if hrs >= 100:
            clock_str[idx] = cast[uint8](hrs / 100) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8]((hrs / 10) % 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        elif hrs >= 10:
            clock_str[idx] = cast[uint8](hrs / 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        else:
            clock_str[idx] = cast[uint8](hrs) + 48
            idx = idx + 1
        clock_str[idx] = 58    # ':'
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins / 10) + 48
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins % 10) + 48
        idx = idx + 1
        clock_str[idx] = 0
        # Tooltip date: "Uptime HH:MM:SS".
        up_secs: uint64 = secs % 60
        up_pfx: Ptr[uint8] = "Uptime "
        dp: uint64 = 0
        while up_pfx[dp] != 0:
            clock_date_str[dp] = up_pfx[dp]
            dp = dp + 1
        dh: uint64 = hrs % 100
        clock_date_str[dp] = cast[uint8](dh / 10) + 48
        clock_date_str[dp + 1] = cast[uint8](dh % 10) + 48
        clock_date_str[dp + 2] = 58
        clock_date_str[dp + 3] = cast[uint8](mins / 10) + 48
        clock_date_str[dp + 4] = cast[uint8](mins % 10) + 48
        clock_date_str[dp + 5] = 58
        clock_date_str[dp + 6] = cast[uint8](up_secs / 10) + 48
        clock_date_str[dp + 7] = cast[uint8](up_secs % 10) + 48
        clock_date_str[dp + 8] = 0
        return
    # If both fail, show "??:??".
    clock_str[0] = 63    # '?'
    clock_str[1] = 63
    clock_str[2] = 58    # ':'
    clock_str[3] = 63
    clock_str[4] = 63
    clock_str[5] = 0
    clock_date_str[0] = 63
    clock_date_str[1] = 0


# ---- window-management hit-testing ---------------------------------
# The close box is a CLOSE_BOX-square inset 2px from the title bar's
# top-right corner. Returns its top-left (cx,cy) for window `slot`.
def close_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX


def close_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside window slot's close box, else 0.
def in_close_box(slot: uint64, px: int64, py: int64) -> int32:
    cx: int64 = close_box_x(slot)
    cy: int64 = close_box_y(slot)
    if px >= cx and px < cx + CLOSE_BOX and py >= cy and py < cy + CLOSE_BOX:
        return 1
    return 0


# 1 if (px,py) is on window slot's title bar (the band below the top
# border, above the body) — EXCLUDING the close box and minimize box.
# Used to start a move-drag.
def in_title_bar(slot: uint64, px: int64, py: int64) -> int32:
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    ww: int64 = DWIN_W[slot]
    if px < wx + 2 or px >= wx + ww - 2:
        return 0
    if py < wy + 2 or py >= wy + TITLE_H:
        return 0
    if in_close_box(slot, px, py) != 0:
        return 0
    if in_minimize_box(slot, px, py) != 0:
        return 0
    if in_maximize_box(slot, px, py) != 0:
        return 0
    return 1


# ---- ROUND-6: resize-grip hit-testing ------------------------------
# Return the resize-direction mask for window `slot` at (px,py): which
# edge(s)/corner the cursor is over within the RESIZE_GRIP band around the
# outer frame. 0 = not on a grip. The grip extends RESIZE_GRIP px INWARD
# from each frame edge and a couple px OUTWARD so the thin border is easy
# to grab. The TOP edge grip is suppressed across the title-bar buttons so
# resizing never fights the close/min/max boxes.
def resize_dir_at(slot: uint64, px: int64, py: int64) -> int32:
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    ww: int64 = DWIN_W[slot]
    wh: int64 = DWIN_H[slot]
    # Reject points well outside the (slightly grown) frame.
    if px < wx - 2 or px >= wx + ww + 2:
        return 0
    if py < wy - 2 or py >= wy + wh + 2:
        return 0
    near_left:  int32 = 0
    near_right: int32 = 0
    near_top:   int32 = 0
    near_bot:   int32 = 0
    if px <= wx + RESIZE_GRIP:
        near_left = 1
    if px >= wx + ww - 1 - RESIZE_GRIP:
        near_right = 1
    if py <= wy + RESIZE_GRIP:
        near_top = 1
    if py >= wy + wh - 1 - RESIZE_GRIP:
        near_bot = 1
    # The top grip overlaps the title-bar buttons; don't let it shadow them.
    if near_top != 0:
        if in_close_box(slot, px, py) != 0 or in_minimize_box(slot, px, py) != 0 \
           or in_maximize_box(slot, px, py) != 0:
            near_top = 0
    mask: int32 = 0
    if near_left != 0:
        mask = mask | 1
    if near_right != 0:
        mask = mask | 2
    if near_top != 0:
        mask = mask | 4
    if near_bot != 0:
        mask = mask | 8
    # A grip is only meaningful on an actual edge. A point deep in the body
    # (no edge near) returns 0 so body clicks still focus/route normally.
    return mask


# 1 if (px,py) is on a resize grip of window `slot` (any edge/corner).
def in_resize_grip(slot: uint64, px: int64, py: int64) -> int32:
    if resize_dir_at(slot, px, py) != 0:
        return 1
    return 0


# Begin an interactive resize of `slot` with grabbed-edge mask `dir`.
# Captures the anchored (opposite) edges so live tracking keeps them fixed.
def resize_begin(slot: int64, dir: int32):
    if slot < 0 or dir == 0:
        return
    s: uint64 = cast[uint64](slot)
    # A maximized/snapped window resizes as a now-floating window: clear the
    # snap flag (keep its current rect) so it detaches like MATE does.
    DWIN_SNAP[s] = 0
    DWIN_MAXED[s] = 0
    RESIZE_SLOT = slot
    RESIZE_DIR = dir
    RESIZE_FIX_X = DWIN_X[s]
    RESIZE_FIX_Y = DWIN_Y[s]
    RESIZE_FIX_R = DWIN_X[s] + DWIN_W[s]
    RESIZE_FIX_B = DWIN_Y[s] + DWIN_H[s]
    rb: Ptr[uint8] = "WM resize start\n"
    sys_write(1, rb, strlen_u8(rb))


# Track an in-flight resize: recompute the grabbed window's rectangle from
# the cursor and the anchored opposite edges, clamped to the work area and
# to RESIZE_MIN_W/H. Mirrors how MATE pulls the grabbed edge under the
# pointer while pinning the far edge.
def resize_track(scr_w: int64, scr_h: int64):
    if RESIZE_SLOT < 0:
        return
    s: uint64 = cast[uint64](RESIZE_SLOT)
    new_x: int64 = DWIN_X[s]
    new_y: int64 = DWIN_Y[s]
    new_w: int64 = DWIN_W[s]
    new_h: int64 = DWIN_H[s]
    # Horizontal edges.
    if (RESIZE_DIR & 1) != 0:
        # Left edge moves to the cursor; right edge (RESIZE_FIX_R) anchored.
        lx: int64 = iclamp(CUR_X, 0, RESIZE_FIX_R - RESIZE_MIN_W)
        new_x = lx
        new_w = RESIZE_FIX_R - lx
    elif (RESIZE_DIR & 2) != 0:
        # Right edge moves to the cursor; left edge (RESIZE_FIX_X) anchored.
        # The right edge is the INCLUSIVE pixel CUR_X, so width = CUR_X+1-X.
        rxr: int64 = iclamp(CUR_X + 1, RESIZE_FIX_X + RESIZE_MIN_W, scr_w)
        new_x = RESIZE_FIX_X
        new_w = rxr - RESIZE_FIX_X
    # Vertical edges (never above the panel).
    if (RESIZE_DIR & 4) != 0:
        # Top edge moves to the cursor; bottom (RESIZE_FIX_B) anchored.
        ty: int64 = iclamp(CUR_Y, PANEL_H, RESIZE_FIX_B - RESIZE_MIN_H)
        new_y = ty
        new_h = RESIZE_FIX_B - ty
    elif (RESIZE_DIR & 8) != 0:
        # Bottom edge moves to the cursor; top (RESIZE_FIX_Y) anchored.
        # The bottom edge is the INCLUSIVE pixel CUR_Y, so height = CUR_Y+1-Y.
        byb: int64 = iclamp(CUR_Y + 1, RESIZE_FIX_Y + RESIZE_MIN_H, scr_h)
        new_y = RESIZE_FIX_Y
        new_h = byb - RESIZE_FIX_Y
    if new_w < RESIZE_MIN_W:
        new_w = RESIZE_MIN_W
    if new_h < RESIZE_MIN_H:
        new_h = RESIZE_MIN_H
    DWIN_X[s] = new_x
    DWIN_Y[s] = new_y
    DWIN_W[s] = new_w
    DWIN_H[s] = new_h
    window_reflow(s)


# Finish an in-flight resize: log the final rectangle and clear state.
def resize_end():
    if RESIZE_SLOT < 0:
        RESIZE_DIR = 0
        return
    s: uint64 = cast[uint64](RESIZE_SLOT)
    rline: Array[80, uint8]
    rp: uint64 = 0
    rpfx: Ptr[uint8] = "WM resize done w="
    rk: uint64 = 0
    while rpfx[rk] != 0:
        rline[rp] = rpfx[rk]
        rp = rp + 1
        rk = rk + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_W[s]), &rline[rp])
    rp = rp - 1                              # drop u64_to_dec's newline
    hsfx: Ptr[uint8] = " h="
    hk: uint64 = 0
    while hsfx[hk] != 0:
        rline[rp] = hsfx[hk]
        rp = rp + 1
        hk = hk + 1
    rp = rp + u64_to_dec(cast[uint64](DWIN_H[s]), &rline[rp])
    sys_write(1, &rline[0], rp)
    RESIZE_SLOT = -1
    RESIZE_DIR = 0


# Topmost window slot whose rectangle contains (px,py), or -1. Windows
# paint back-to-front (slot 0 lowest), so the highest slot wins the
# hit-test.
def window_at(px: int64, py: int64) -> int64:
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        s: uint64 = cast[uint64](wi)
        # Skip minimized windows and windows not on the current workspace —
        # they have no visible surface on this desktop.
        if win_on_cur_ws(s) != 0:
            wx: int64 = DWIN_X[s]
            wy: int64 = DWIN_Y[s]
            if px >= wx and px < wx + DWIN_W[s] and py >= wy and py < wy + DWIN_H[s]:
                return wi
        wi = wi - 1
    return -1


# ---- per-window terminal emulator ----------------------------------
# Cell index for window `slot` at (col,row) into the flat term_grid.
def term_cell(slot: uint64, col: int64, row: int64) -> uint64:
    return slot * GRID_CELLS + cast[uint64](row * GRID_COLS_MAX + col)


# Clear a window's whole grid to blanks (0) and home the cursor.
def term_clear(slot: uint64):
    base: uint64 = slot * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[base + i] = 0
        i = i + 1
    DWIN_CUR_C[slot] = 0
    DWIN_CUR_R[slot] = 0
    DWIN_VT[slot] = 0


# Scroll the grid up one row (drop the top row, blank the new bottom).
def term_scroll(slot: uint64):
    rows: int64 = DWIN_ROWS[slot]
    cols: int64 = DWIN_COLS[slot]
    r: int64 = 0
    while r < rows - 1:
        c: int64 = 0
        while c < cols:
            src: uint64 = term_cell(slot, c, r + 1)
            dst: uint64 = term_cell(slot, c, r)
            term_grid[dst] = term_grid[src]
            c = c + 1
        r = r + 1
    # blank the last row
    c2: int64 = 0
    while c2 < cols:
        term_grid[term_cell(slot, c2, rows - 1)] = 0
        c2 = c2 + 1


def term_newline(slot: uint64):
    DWIN_CUR_R[slot] = DWIN_CUR_R[slot] + 1
    if DWIN_CUR_R[slot] >= DWIN_ROWS[slot]:
        term_scroll(slot)
        DWIN_CUR_R[slot] = DWIN_ROWS[slot] - 1


# Emit one printable byte into the grid at the cursor, advancing it
# (wrapping + scrolling as needed).
def term_putc(slot: uint64, ch: uint8):
    cols: int64 = DWIN_COLS[slot]
    if cols <= 0 or DWIN_ROWS[slot] <= 0:
        return
    if DWIN_CUR_C[slot] >= cols:
        DWIN_CUR_C[slot] = 0
        term_newline(slot)
    term_grid[term_cell(slot, DWIN_CUR_C[slot], DWIN_CUR_R[slot])] = ch
    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] + 1


# Feed `n` bytes from buf into window slot's terminal, honouring a
# minimal control set + swallowing CSI escape sequences so they don't
# corrupt the grid.
def term_feed(slot: uint64, buf: Ptr[uint8], n: int64):
    i: int64 = 0
    while i < n:
        c: uint8 = buf[cast[uint64](i)]
        st: int32 = DWIN_VT[slot]
        if st == 1:
            # saw ESC: '[' begins a CSI; anything else aborts to ground.
            if c == 91:                          # '['
                DWIN_VT[slot] = 2
            else:
                DWIN_VT[slot] = 0
            i = i + 1
        elif st == 2:
            # in CSI: consume parameter/intermediate bytes until a final
            # byte in 0x40..0x7E ends the sequence (we ignore its effect).
            if c >= 64 and c <= 126:
                DWIN_VT[slot] = 0
            i = i + 1
        else:
            if c == 27:                          # ESC
                DWIN_VT[slot] = 1
            elif c == 10:                        # '\n' -> newline + CR
                DWIN_CUR_C[slot] = 0
                term_newline(slot)
            elif c == 13:                        # '\r' -> carriage return
                DWIN_CUR_C[slot] = 0
            elif c == 8:                         # backspace
                if DWIN_CUR_C[slot] > 0:
                    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] - 1
                    term_grid[term_cell(slot, DWIN_CUR_C[slot],
                                        DWIN_CUR_R[slot])] = 0
            elif c == 9:                         # tab -> advance to next 8
                nc: int64 = (DWIN_CUR_C[slot] / 8 + 1) * 8
                if nc >= DWIN_COLS[slot]:
                    nc = DWIN_COLS[slot] - 1
                DWIN_CUR_C[slot] = nc
            elif c >= 32 and c <= 126:           # printable ASCII
                term_putc(slot, c)
            # everything else (other control bytes): drop silently
            i = i + 1


# Drain a window's stdout pipe (non-blocking) into its grid. Returns 1
# if any bytes were consumed (the screen needs a re-present), else 0.
def term_pump(slot: uint64) -> int32:
    fd: int32 = DWIN_OUT_FD[slot]
    if fd < 0:
        return 0
    got: int32 = 0
    iters: int32 = 0
    while iters < 16:
        n: int64 = sys_read_nb(fd, &term_rx[0], 1024)
        iters = iters + 1
        if n <= 0:
            break
        term_feed(slot, &term_rx[0], n)
        got = 1
    return got


# Pixel-model query: what colour is screen pixel (x,y)? Writes r/g/b.
# Order (back to front): backdrop -> windows (in creation order) ->
# rubber band outline -> cursor. The cursor wins last so it's always
# visible.
def daemon_pixel(x: int64, y: int64,
                 outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    r: uint8 = ROOT_R
    g: uint8 = ROOT_G
    b: uint8 = ROOT_B
    # --- windows (back to front) ---
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        # Skip minimized windows and windows not on the current workspace.
        if win_on_cur_ws(wi) == 0:
            wi = wi + 1
            continue
        wx: int64 = DWIN_X[wi]
        wy: int64 = DWIN_Y[wi]
        ww: int64 = DWIN_W[wi]
        wh: int64 = DWIN_H[wi]
        if x >= wx and x < wx + ww and y >= wy and y < wy + wh:
            # Local coordinates within the window rectangle.
            lwx: int64 = x - wx
            lwy: int64 = y - wy
            # --- Clearlooks-ish beveled border (2px) ---
            on_border: int32 = 0
            if lwx < 2 or lwx >= ww - 2 or lwy < 2 or lwy >= wh - 2:
                on_border = 1
            if on_border != 0:
                # Outer ring: light highlight on top/left, dark shadow on
                # bottom/right; the inner ring is the mid frame line.
                outer: int32 = 0
                if lwx == 0 or lwy == 0 or lwx == ww - 1 or lwy == wh - 1:
                    outer = 1
                if outer != 0:
                    if lwx == 0 or lwy == 0:
                        r = BEVEL_HI_R
                        g = BEVEL_HI_G
                        b = BEVEL_HI_B
                    else:
                        r = BEVEL_LO_R
                        g = BEVEL_LO_G
                        b = BEVEL_LO_B
                else:
                    r = BEVEL_MID_R
                    g = BEVEL_MID_G
                    b = BEVEL_MID_B
            else:
                if y < wy + TITLE_H:
                    # --- vertical-gradient title bar (active vs inactive) ---
                    trow: int64 = lwy - 2          # 0..TITLE_H-3 in the bar
                    focused: int32 = 0
                    if wi == DWIN_COUNT - 1:
                        focused = 1
                    if focused != 0:
                        r = grad_chan(ACCENT_TOP_R, ACCENT_BOT_R, trow, TITLE_H - 2)
                        g = grad_chan(ACCENT_TOP_G, ACCENT_BOT_G, trow, TITLE_H - 2)
                        b = grad_chan(ACCENT_TOP_B, ACCENT_BOT_B, trow, TITLE_H - 2)
                    else:
                        r = grad_chan(TITLE_INA_TOP_R, TITLE_INA_BOT_R, trow, TITLE_H - 2)
                        g = grad_chan(TITLE_INA_TOP_G, TITLE_INA_BOT_G, trow, TITLE_H - 2)
                        b = grad_chan(TITLE_INA_TOP_B, TITLE_INA_BOT_B, trow, TITLE_H - 2)
                    # Title text: a built-in app shows its name; a terminal
                    # shows its 1-based window number. Left-aligned.
                    tly: int64 = wy + (TITLE_H - GLYPH_H) / 2
                    if DWIN_APP[wi] != APP_TERM:
                        if str_ink(window_title(wi), wx + 6, tly, x, y) != 0:
                            r = 250
                            g = 250
                            b = 255
                    else:
                        twb: Array[4, uint8]
                        twb[0] = cast[uint8](wi + 1) + 48
                        twb[1] = 0
                        if str_ink(&twb[0], wx + 6, tly, x, y) != 0:
                            r = 250
                            g = 250
                            b = 255
                    # --- close box (beveled red button + white X) ---
                    cbx: int64 = close_box_x(wi)
                    cby: int64 = close_box_y(wi)
                    if x >= cbx and x < cbx + CLOSE_BOX and y >= cby and y < cby + CLOSE_BOX:
                        lxp: int64 = x - cbx
                        lyp: int64 = y - cby
                        hov_c: int32 = 0
                        if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 0:
                            hov_c = 1
                        r = CLOSE_R
                        g = CLOSE_G
                        b = CLOSE_B
                        if hov_c != 0:
                            r = 245
                            g = 110
                            b = 110
                        # bevel: light top/left, dark bottom/right
                        if lxp == 0 or lyp == 0:
                            r = 255
                            g = 180
                            b = 180
                        elif lxp == CLOSE_BOX - 1 or lyp == CLOSE_BOX - 1:
                            r = 130
                            g = 30
                            b = 30
                        inset: int64 = 3
                        span: int64 = CLOSE_BOX - 1
                        if lxp >= inset and lxp <= span - inset and lyp >= inset and lyp <= span - inset:
                            if lxp == lyp or lxp == span - lyp:
                                r = CLOSE_X_R
                                g = CLOSE_X_G
                                b = CLOSE_X_B
                    # --- minimize box (beveled button + dash) ---
                    mbx: int64 = minimize_box_x(wi)
                    mby: int64 = minimize_box_y(wi)
                    if x >= mbx and x < mbx + MINIMIZE_BOX and y >= mby and y < mby + MINIMIZE_BOX:
                        lxm: int64 = x - mbx
                        lym: int64 = y - mby
                        hov_m: int32 = 0
                        if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 1:
                            hov_m = 1
                        r = MINIMIZE_R
                        g = MINIMIZE_G
                        b = MINIMIZE_B
                        if hov_m != 0:
                            r = 240
                            g = 200
                            b = 80
                        if lxm == 0 or lym == 0:
                            r = 255
                            g = 220
                            b = 120
                        elif lxm == MINIMIZE_BOX - 1 or lym == MINIMIZE_BOX - 1:
                            r = 130
                            g = 100
                            b = 20
                        dash_y: int64 = MINIMIZE_BOX - 4
                        dash_x0: int64 = 3
                        dash_x1: int64 = MINIMIZE_BOX - 4
                        dash_h:  int64 = 2
                        if lym >= dash_y and lym < dash_y + dash_h and lxm >= dash_x0 and lxm <= dash_x1:
                            r = MINIMIZE_DASH_R
                            g = MINIMIZE_DASH_G
                            b = MINIMIZE_DASH_B
                    # --- maximize box (beveled button + square/restore glyph) ---
                    xbx: int64 = maximize_box_x(wi)
                    xby: int64 = maximize_box_y(wi)
                    if x >= xbx and x < xbx + MAXIMIZE_BOX and y >= xby and y < xby + MAXIMIZE_BOX:
                        lxx: int64 = x - xbx
                        lyx: int64 = y - xby
                        hov_x: int32 = 0
                        if HOVER_SLOT == cast[int64](wi) and HOVER_BTN == 2:
                            hov_x = 1
                        r = MAX_BTN_R
                        g = MAX_BTN_G
                        b = MAX_BTN_B
                        if hov_x != 0:
                            r = 150
                            g = 220
                            b = 150
                        if lxx == 0 or lyx == 0:
                            r = 190
                            g = 240
                            b = 190
                        elif lxx == MAXIMIZE_BOX - 1 or lyx == MAXIMIZE_BOX - 1:
                            r = 40
                            g = 100
                            b = 40
                        # Glyph: a hollow square (Maximize) or two offset
                        # squares (Restore) drawn as box outlines.
                        gi0: int64 = 3
                        gi1: int64 = MAXIMIZE_BOX - 4
                        on_glyph: int32 = 0
                        if lxx >= gi0 and lxx <= gi1 and lyx >= gi0 and lyx <= gi1:
                            if lxx == gi0 or lxx == gi1 or lyx == gi0 or lyx == gi1:
                                on_glyph = 1
                            # the box's top edge is doubled to read as a titlebar
                            if lyx == gi0 + 1:
                                on_glyph = 1
                        if on_glyph != 0:
                            r = MAX_GLYPH_R
                            g = MAX_GLYPH_G
                            b = MAX_GLYPH_B
                elif DWIN_APP[wi] != APP_TERM:
                    # --- built-in application body (calc/sysmon/about) ---
                    app_body_pixel(cast[uint64](wi), x, y, &r, &g, &b)
                elif DWIN_VK[wi] != 0:
                    # --- native Vulkan image rendered into the body ---
                    # The 192x192 RGBA frame (vk_body_buf) sits top-left
                    # inside the body region; body pixels outside it fall
                    # back to the plain body colour.
                    r = WIN_BODY_R
                    g = WIN_BODY_G
                    b = WIN_BODY_B
                    vbx0: int64 = wx + 2
                    vby0: int64 = wy + TITLE_H
                    vlx: int64 = x - vbx0
                    vly: int64 = y - vby0
                    if vk_body_ready != 0 and vlx >= 0 and vly >= 0 \
                       and vlx < VK_BODY_W and vly < VK_BODY_H:
                        vo: uint64 = cast[uint64](vly * VK_BODY_W + vlx) * 4
                        r = vk_body_buf[vo]
                        g = vk_body_buf[vo + 1]
                        b = vk_body_buf[vo + 2]
                else:
                    r = WIN_BODY_R
                    g = WIN_BODY_G
                    b = WIN_BODY_B
                    # --- terminal text rendered into the body ---
                    bx0: int64 = wx + 2
                    by0: int64 = wy + TITLE_H
                    lx: int64 = x - bx0           # pixel within body
                    ly: int64 = y - by0
                    if lx >= 0 and ly >= 0:
                        col: int64 = lx / GLYPH_W
                        row: int64 = ly / GLYPH_H
                        if col < DWIN_COLS[wi] and row < DWIN_ROWS[wi]:
                            gx: int64 = lx - col * GLYPH_W   # 0..7
                            gy: int64 = ly - row * GLYPH_H   # 0..15
                            # Cursor block (inverse) at the cell cursor.
                            is_cur: int32 = 0
                            if col == DWIN_CUR_C[wi] and row == DWIN_CUR_R[wi]:
                                is_cur = 1
                            ce: uint64 = term_cell(cast[uint64](wi), col, row)
                            ch: uint8 = term_grid[ce]
                            on: int32 = 0
                            if ch >= 32 and ch <= 126:
                                gi: uint64 = cast[uint64](ch) - 32
                                bits: uint8 = font_glyphs[gi * 16
                                                          + cast[uint64](gy)]
                                mask: uint8 = cast[uint8](128 >> gx)
                                if (bits & mask) != 0:
                                    on = 1
                            if is_cur != 0:
                                # Solid dark cursor block; glyph ink on it
                                # flips to body colour for legibility.
                                if on != 0:
                                    r = WIN_BODY_R
                                    g = WIN_BODY_G
                                    b = WIN_BODY_B
                                else:
                                    r = 24
                                    g = 24
                                    b = 24
                            elif on != 0:
                                r = 24
                                g = 24
                                b = 24
        wi = wi + 1
    # --- panel bar (always on top of windows; classic top panel) ---
    # Painted after windows so it is never obscured; the cursor still
    # wins last. The GNOME2 menu BAR (Applications / Places / System) sits
    # at the left, the window-list taskbar in the middle, then the
    # workspace pager and the live clock at the right.
    if on_panel_y(y) != 0:
        # ROUND-12: render the bar in PANEL-LOCAL Y so it lands on the
        # configured edge. `py` is 0..PANEL_H-1 within the bar; all the
        # bar-internal geometry (borders, glyph baselines, tray icons,
        # pager mini-map) is expressed against it, while the menubar/
        # taskbar/pager/clock hit-testers still take the ABSOLUTE (x,y).
        py: int64 = panel_local_y(y)
        r = PANEL_R
        g = PANEL_G
        b = PANEL_B
        aly: int64 = (PANEL_H - GLYPH_H) / 2
        # 1px border on the side facing the desktop so the panel reads as a
        # distinct bar (bottom edge for a top panel, top edge for a bottom).
        edge_ly: int64 = PANEL_H - 1
        if PANEL_POS == 1:
            edge_ly = 0
        if py == edge_ly:
            r = 24
            g = 28
            b = 36
        # --- menu bar: three top-level buttons ---
        mb: int32 = menubar_btn_at(x, y)
        if mb >= 0:
            # Highlight the button whose menu is open (or hovered).
            if mb == MENU_BAR_OPEN:
                r = PANEL_HI_R
                g = PANEL_HI_G
                b = PANEL_HI_B
            elif menubar_btn_at(CUR_X, CUR_Y) == mb:
                r = cast[uint8](cast[int32](PANEL_R) + 16)
                g = cast[uint8](cast[int32](PANEL_G) + 16)
                b = cast[uint8](cast[int32](PANEL_B) + 16)
            if py == edge_ly:
                r = 24
                g = 28
                b = 36
            mblx: int64 = menubar_btn_x(mb) + MENUBAR_PAD
            if str_ink(menubar_label(mb), mblx, aly, x, py) != 0:
                r = PANEL_TXT_R
                g = PANEL_TXT_G
                b = PANEL_TXT_B
        # --- taskbar: one button per window on the CURRENT workspace ---
        tb_scr_w: int64 = cast[int64](FBG_W)
        pgr_x: int64 = pager_x0(tb_scr_w)
        clock_x: int64 = tb_scr_w - CLOCK_W
        tbi: uint64 = 0
        while tbi < DWIN_COUNT:
            tbx: int64 = taskbar_btn_x(tbi)
            tbe: int64 = tbx + TASKBAR_BTN_W - 2
            # Only paint buttons for windows on the current workspace and
            # only if they don't overlap the pager zone. ROUND-10: a grouped
            # app collapses to a single button on its group leader; the
            # other members of the group are folded behind it.
            if DWIN_WS[tbi] == CUR_WS and tbx < pgr_x and is_group_leader(tbi) != 0:
                if x >= tbx and x < tbe and py >= TASKBAR_BTN_Y and py < TASKBAR_BTN_Y + TASKBAR_BTN_H:
                    # Focused: topmost visible window gets highlight tint.
                    if tbi == DWIN_COUNT - 1 and DWIN_HIDDEN[tbi] == 0:
                        r = PANEL_HI_R
                        g = PANEL_HI_G
                        b = PANEL_HI_B
                    elif DWIN_HIDDEN[tbi] != 0:
                        # Minimized: slightly lighter background.
                        r = cast[uint8](cast[int32](PANEL_R) + 20)
                        g = cast[uint8](cast[int32](PANEL_G) + 20)
                        b = cast[uint8](cast[int32](PANEL_B) + 20)
                    # else: plain panel colour remains from above.
                    # 1px right edge separator between buttons.
                    if x == tbe - 1:
                        r = 24
                        g = 28
                        b = 36
                    # Label: a grouped button shows "<n>(N)" where n is the
                    # leader's window number and N the group size; a single
                    # window just shows its 1-based number.
                    taskbar_lbl_buf[0] = cast[uint8](tbi + 1) + 48
                    taskbar_lbl_buf[1] = 0
                    if is_grouped(tbi) != 0:
                        gcnt: uint64 = app_group_count(tbi)
                        taskbar_lbl_buf[1] = 40                 # '('
                        taskbar_lbl_buf[2] = cast[uint8](gcnt) + 48
                        taskbar_lbl_buf[3] = 41                 # ')'
                        taskbar_lbl_buf[4] = 0
                    if str_ink(&taskbar_lbl_buf[0], tbx + 4, aly, x, py) != 0:
                        r = PANEL_TXT_R
                        g = PANEL_TXT_G
                        b = PANEL_TXT_B
            tbi = tbi + 1
        # --- workspace pager applet (WS_COUNT mini desktops) ---
        if x >= pgr_x and x < pgr_x + pager_total_w():
            cell: int64 = (x - pgr_x) / PAGER_CELL_W
            cx0: int64 = pgr_x + cell * PAGER_CELL_W
            lcx: int64 = x - cx0
            lcy: int64 = py
            # Cell background: current workspace highlighted.
            if cast[int32](cell) == CUR_WS:
                r = PAGER_CUR_R
                g = PAGER_CUR_G
                b = PAGER_CUR_B
            else:
                r = PAGER_R
                g = PAGER_G
                b = PAGER_B
            # 1px separators between cells + edge border.
            if lcx == 0 or lcx == PAGER_CELL_W - 1 or py == 0 or py == PANEL_H - 1:
                r = 24
                g = 28
                b = 36
            # Mini window-occupancy markers: each window on this workspace
            # gets a tiny rect inside the cell mapped from screen space.
            iw: int64 = pgr_x                       # silence unused warns
            tw: uint64 = 0
            while tw < DWIN_COUNT:
                if DWIN_WS[tw] == cast[int32](cell) and DWIN_HIDDEN[tw] == 0:
                    # Map window rect into the cell's inner area.
                    inx0: int64 = cx0 + PAGER_PAD
                    iny0: int64 = PAGER_PAD
                    innw: int64 = PAGER_CELL_W - PAGER_PAD * 2
                    innh: int64 = PANEL_H - PAGER_PAD * 2
                    sw_i: int64 = tb_scr_w
                    sh_i: int64 = cast[int64](FBG_H)
                    mwx0: int64 = inx0 + DWIN_X[tw] * innw / sw_i
                    mwy0: int64 = iny0 + DWIN_Y[tw] * innh / sh_i
                    mwx1: int64 = inx0 + (DWIN_X[tw] + DWIN_W[tw]) * innw / sw_i
                    mwy1: int64 = iny0 + (DWIN_Y[tw] + DWIN_H[tw]) * innh / sh_i
                    if x >= mwx0 and x <= mwx1 and py >= mwy0 and py <= mwy1:
                        if lcx > 0 and lcx < PAGER_CELL_W - 1 and py > 0 and py < PANEL_H - 1:
                            r = PAGER_WIN_R
                            g = PAGER_WIN_G
                            b = PAGER_WIN_B
                tw = tw + 1
            iw = iw + lcy        # keep iw/lcy referenced
        # --- notification-area stub (system tray): two status icons ---
        ntf_x: int64 = notif_x0(tb_scr_w)
        if x >= ntf_x and x < ntf_x + NOTIF_W:
            # Icon 0 = network (green stepped bars), icon 1 = generic info
            # dot (blue). Drawn as tiny glyph-mosaics so the tray reads as
            # real status indicators without a backing image store.
            icon_y: int64 = (PANEL_H - NOTIF_ICON) / 2
            rel: int64 = x - ntf_x - NOTIF_PAD
            slot_i: int64 = rel / (NOTIF_ICON + NOTIF_PAD)
            ix: int64 = rel - slot_i * (NOTIF_ICON + NOTIF_PAD)
            iy: int64 = py - icon_y
            if slot_i == 0 and ix >= 0 and ix < NOTIF_ICON and iy >= 0 and iy < NOTIF_ICON:
                # Network: three rising bars (signal strength).
                bar: int64 = ix / 4               # 0,1,2 across the icon
                bar_top: int64 = NOTIF_ICON - 3 - bar * 4
                if iy >= bar_top and (ix % 4) < 3:
                    r = 110
                    g = 210
                    b = 120
            elif slot_i == 1 and ix >= 0 and ix < NOTIF_ICON and iy >= 0 and iy < NOTIF_ICON:
                # Info dot: a filled blue diamond.
                cxr: int64 = NOTIF_ICON / 2
                ddx: int64 = ix - cxr
                ddy: int64 = iy - cxr
                if iabs(ddx) + iabs(ddy) <= cxr - 1:
                    r = 110
                    g = 160
                    b = 235
            elif slot_i == 2 and ix >= 0 and ix < NOTIF_ICON and iy >= 0 and iy < NOTIF_ICON:
                # ROUND-5 LIVE window-count badge: an accent square with the
                # current visible-window count drawn inside it. Updates every
                # present from NOTIF_WIN_COUNT, so the tray reads live.
                r = ACCENT_BOT_R
                g = ACCENT_BOT_G
                b = ACCENT_BOT_B
                if ix == 0 or ix == NOTIF_ICON - 1 or iy == 0 or iy == NOTIF_ICON - 1:
                    r = ACCENT_TOP_R
                    g = ACCENT_TOP_G
                    b = ACCENT_TOP_B
                # Centre a single digit (clamped 0..9) in the badge.
                badge_d: int64 = NOTIF_WIN_COUNT
                if badge_d > 9:
                    badge_d = 9
                notif_badge_buf[0] = cast[uint8](badge_d) + 48
                notif_badge_buf[1] = 0
                bgx: int64 = ntf_x + NOTIF_PAD + 2 * (NOTIF_ICON + NOTIF_PAD) \
                    + (NOTIF_ICON - GLYPH_W) / 2
                bgy: int64 = icon_y + (NOTIF_ICON - GLYPH_H) / 2
                if str_ink(&notif_badge_buf[0], bgx, bgy, x, py) != 0:
                    r = 250
                    g = 250
                    b = 255
        # --- ROUND-12: Show Desktop applet button ---
        sd_x: int64 = sd_btn_x0(tb_scr_w)
        if x >= sd_x and x < sd_x + SD_BTN_W:
            # Hovered or active (desktop shown) gets the panel highlight; a
            # 1px desktop-facing edge keeps the bar's frame consistent.
            if SHOWDESK_ON != 0:
                r = PANEL_HI_R
                g = PANEL_HI_G
                b = PANEL_HI_B
            elif in_show_desktop_btn(CUR_X, CUR_Y, tb_scr_w) != 0:
                r = cast[uint8](cast[int32](PANEL_R) + 16)
                g = cast[uint8](cast[int32](PANEL_G) + 16)
                b = cast[uint8](cast[int32](PANEL_B) + 16)
            if py == edge_ly:
                r = 24
                g = 28
                b = 36
            # A tiny "monitor showing the desktop" glyph: a 10x8 framed box
            # centred in the button, drawn in pale ink.
            gw_sd: int64 = 10
            gh_sd: int64 = 8
            gx0: int64 = sd_x + (SD_BTN_W - gw_sd) / 2
            gy0: int64 = (PANEL_H - gh_sd) / 2
            lxs: int64 = x - gx0
            lys: int64 = py - gy0
            if lxs >= 0 and lxs < gw_sd and lys >= 0 and lys < gh_sd:
                if lxs == 0 or lxs == gw_sd - 1 or lys == 0 or lys == gh_sd - 1:
                    r = 220
                    g = 224
                    b = 232
                elif lxs == 2 and lys >= 2:
                    # A little desktop "fold" mark inside the frame.
                    r = 180
                    g = 188
                    b = 205
        # --- live clock on the right edge of the panel ---
        if x >= clock_x and x < tb_scr_w:
            r = CLOCK_R
            g = CLOCK_G
            b = CLOCK_B
            if py == edge_ly:
                r = 24
                g = 28
                b = 36
            if str_ink(&clock_str[0], clock_x + CLOCK_PAD, aly, x, py) != 0:
                r = PANEL_TXT_R
                g = PANEL_TXT_G
                b = PANEL_TXT_B
    # --- clock-applet date tooltip (shown while hovering the clock) ---
    if CLOCK_HOVER != 0:
        tt_len: int64 = cast[int64](strlen_u8(&clock_date_str[0]))
        if tt_len > 0:
            tt_w: int64 = tt_len * GLYPH_W + 12
            tt_h: int64 = GLYPH_H + 8
            tt_x: int64 = cast[int64](FBG_W) - tt_w - 2
            tt_y: int64 = drop_anchor_y(tt_h)
            if PANEL_POS == 1:
                tt_y = tt_y - 2                  # gap above a bottom panel
            else:
                tt_y = tt_y + 2                  # gap below a top panel
            if tt_x < 0:
                tt_x = 0
            if x >= tt_x and x < tt_x + tt_w and y >= tt_y and y < tt_y + tt_h:
                # Pale-yellow tooltip body with a thin dark frame (MATE feel).
                r = 250
                g = 248
                b = 200
                if x == tt_x or x == tt_x + tt_w - 1 or y == tt_y or y == tt_y + tt_h - 1:
                    r = 90
                    g = 88
                    b = 60
                tt_oy: int64 = tt_y + (tt_h - GLYPH_H) / 2
                if str_ink(&clock_date_str[0], tt_x + 6, tt_oy, x, y) != 0:
                    r = 30
                    g = 30
                    b = 30
    # --- menu-bar drop-down (Applications / Places / System) ---
    # --- ROUND-10: Applications type-to-search filtered result list ---
    # When the search box has a query, the Applications drop-down is
    # replaced by a flat list of matching entries (categories hidden).
    if MENU_BAR_OPEN == 0 and search_active() != 0:
        srn: uint64 = menu_search_count()
        srtop: int64 = drop_anchor_y(cast[int64](srn) * MENU_ITEM_H)
        srx: int64 = menubar_drop_x()
        srw: int64 = menubar_drop_w()
        srbot: int64 = srtop + cast[int64](srn) * MENU_ITEM_H
        if srbot < srtop + MENU_ITEM_H:
            srbot = srtop + MENU_ITEM_H        # always show one (empty) row
        if x >= srx and x < srx + srw and y >= srtop and y < srbot:
            r = MENU_R
            g = MENU_G
            b = MENU_B
            if x == srx + srw - 1 or y == srbot - 1 or x == srx:
                r = 24
                g = 28
                b = 36
            sritem: int64 = (y - srtop) / MENU_ITEM_H
            srhov: int64 = search_result_at(CUR_X, CUR_Y)
            if sritem == srhov and srhov >= 0:
                on_edge_sr: int32 = 0
                if x == srx + srw - 1 or x == srx:
                    on_edge_sr = 1
                if on_edge_sr == 0:
                    r = MENU_SEL_R
                    g = MENU_SEL_G
                    b = MENU_SEL_B
            if sritem >= 0 and sritem < cast[int64](srn):
                srflat: uint64 = menu_search_nth(cast[uint64](sritem))
                if srflat < MENU_COUNT:
                    srlbl: Ptr[uint8] = menu_label(srflat)
                    sroy: int64 = srtop + sritem * MENU_ITEM_H \
                                  + (MENU_ITEM_H - GLYPH_H) / 2
                    if str_ink(srlbl, srx + 8, sroy, x, y) != 0:
                        r = MENU_TXT_R
                        g = MENU_TXT_G
                        b = MENU_TXT_B
    if MENU_BAR_OPEN >= 0 and search_active() == 0:
        mtop: int64 = drop_anchor_y(menubar_total_h())
        mdx: int64 = menubar_drop_x()
        mdw: int64 = menubar_drop_w()
        mbot: int64 = mtop + menubar_total_h()
        if x >= mdx and x < mdx + mdw and y >= mtop and y < mbot:
            r = MENU_R
            g = MENU_G
            b = MENU_B
            # 1px frame.
            if x == mdx + mdw - 1 or y == mbot - 1 or x == mdx:
                r = 24
                g = 28
                b = 36
            item: int64 = (y - mtop) / MENU_ITEM_H
            hov: int64 = menubar_item_at(CUR_X, CUR_Y)
            # ROUND-7: the category whose submenu is open also reads selected.
            sel_row: int32 = 0
            if item == hov and hov >= 0:
                sel_row = 1
            if MENU_BAR_OPEN == 0 and item == SUBMENU_OPEN and item >= 0:
                sel_row = 1
            if sel_row != 0:
                on_edge_m: int32 = 0
                if x == mdx + mdw - 1 or x == mdx:
                    on_edge_m = 1
                if on_edge_m == 0:
                    r = MENU_SEL_R
                    g = MENU_SEL_G
                    b = MENU_SEL_B
            if item >= 0 and item < cast[int64](menubar_count(MENU_BAR_OPEN)):
                ilbl: Ptr[uint8] = menubar_item_label(MENU_BAR_OPEN,
                                                      cast[uint64](item))
                ioy: int64 = mtop + item * MENU_ITEM_H + (MENU_ITEM_H - GLYPH_H) / 2
                if str_ink(ilbl, mdx + 8, ioy, x, y) != 0:
                    r = MENU_TXT_R
                    g = MENU_TXT_G
                    b = MENU_TXT_B
                # ROUND-7: a ">" submenu indicator on Applications categories.
                if MENU_BAR_OPEN == 0:
                    arr: Ptr[uint8] = ">"
                    if str_ink(arr, mdx + mdw - GLYPH_W - 6, ioy, x, y) != 0:
                        r = MENU_TXT_R
                        g = MENU_TXT_G
                        b = MENU_TXT_B
    # --- ROUND-7: Applications category submenu flyout ---
    if MENU_BAR_OPEN == 0 and SUBMENU_OPEN >= 0:
        sx: int64 = submenu_x()
        stop: int64 = appcat_row_y(SUBMENU_OPEN)
        sn: int64 = appcat_item_count(SUBMENU_OPEN)
        sbot: int64 = stop + sn * MENU_ITEM_H
        if x >= sx and x < sx + SUBMENU_W and y >= stop and y < sbot:
            r = MENU_R
            g = MENU_G
            b = MENU_B
            if x == sx + SUBMENU_W - 1 or y == sbot - 1 or x == sx or y == stop:
                r = 24
                g = 28
                b = 36
            sitem: int64 = (y - stop) / MENU_ITEM_H
            shov: int64 = submenu_item_at(SUBMENU_OPEN, CUR_X, CUR_Y)
            if sitem == shov and shov >= 0:
                on_edge_s: int32 = 0
                if x == sx + SUBMENU_W - 1 or x == sx:
                    on_edge_s = 1
                if on_edge_s == 0:
                    r = MENU_SEL_R
                    g = MENU_SEL_G
                    b = MENU_SEL_B
            if sitem >= 0 and sitem < sn:
                slbl: Ptr[uint8] = appcat_item_label(SUBMENU_OPEN, sitem)
                soy: int64 = stop + sitem * MENU_ITEM_H + (MENU_ITEM_H - GLYPH_H) / 2
                if str_ink(slbl, sx + 8, soy, x, y) != 0:
                    r = MENU_TXT_R
                    g = MENU_TXT_G
                    b = MENU_TXT_B
    # --- right-click context menu (desktop or window) ---
    if CTX_OPEN != 0:
        ctop: int64 = CTX_Y
        cbot: int64 = CTX_Y + ctx_total_h()
        if x >= CTX_X and x < CTX_X + CTX_W and y >= ctop and y < cbot:
            r = CTX_R
            g = CTX_G
            b = CTX_B
            if x == CTX_X + CTX_W - 1 or y == cbot - 1 or x == CTX_X or y == ctop:
                r = 24
                g = 28
                b = 36
            citem: int64 = (y - ctop) / CTX_ITEM_H
            chov: int64 = ctx_item_at(CUR_X, CUR_Y)
            if citem == chov and chov >= 0:
                on_edge_c: int32 = 0
                if x == CTX_X + CTX_W - 1 or x == CTX_X:
                    on_edge_c = 1
                if on_edge_c == 0:
                    r = CTX_SEL_R
                    g = CTX_SEL_G
                    b = CTX_SEL_B
            if citem >= 0 and citem < cast[int64](ctx_count()):
                clbl: Ptr[uint8] = ctx_item_label(cast[uint64](citem))
                coy: int64 = ctop + citem * CTX_ITEM_H + (CTX_ITEM_H - GLYPH_H) / 2
                if str_ink(clbl, CTX_X + 8, coy, x, y) != 0:
                    r = MENU_TXT_R
                    g = MENU_TXT_G
                    b = MENU_TXT_B
    # --- ROUND-5: live snap-zone preview (edge/corner tiling) ---
    # While dragging a window into an edge/corner, a translucent accent
    # rectangle shows where it will land. We fake alpha by averaging the
    # already-composited pixel with the accent colour, and draw a 2px solid
    # accent border so the target reads clearly (MATE/GNOME edge tiling).
    if SNAP_PREVIEW_ON != 0 and SNAP_PREVIEW_MODE != 0:
        snap_zone_rect(SNAP_PREVIEW_MODE, cast[int64](FBG_W), cast[int64](FBG_H))
        if x >= snapzone_x and x < snapzone_x + snapzone_w \
           and y >= snapzone_y and y < snapzone_y + snapzone_h:
            pr_r: uint8 = ACCENT_TOP_R
            pr_g: uint8 = ACCENT_TOP_G
            pr_b: uint8 = ACCENT_TOP_B
            on_border: int32 = 0
            if x < snapzone_x + 2 or x >= snapzone_x + snapzone_w - 2:
                on_border = 1
            if y < snapzone_y + 2 or y >= snapzone_y + snapzone_h - 2:
                on_border = 1
            if on_border != 0:
                # Solid bright accent border.
                r = pr_r
                g = pr_g
                b = pr_b
            else:
                # 50/50 tint over the existing pixel (cheap translucency).
                r = cast[uint8]((cast[int32](r) + cast[int32](pr_r)) / 2)
                g = cast[uint8]((cast[int32](g) + cast[int32](pr_g)) / 2)
                b = cast[uint8]((cast[int32](b) + cast[int32](pr_b)) / 2)
    # --- ROUND-6: live resize frame ---
    # While a window is being resized, paint a 2px bright accent rectangle
    # around its current (live-tracking) frame so the operation reads as a
    # deliberate resize, exactly like MATE's resize outline.
    if RESIZE_SLOT >= 0 and GESTURE == 4:
        rs: uint64 = cast[uint64](RESIZE_SLOT)
        rfx: int64 = DWIN_X[rs]
        rfy: int64 = DWIN_Y[rs]
        rfw: int64 = DWIN_W[rs]
        rfh: int64 = DWIN_H[rs]
        if x >= rfx and x < rfx + rfw and y >= rfy and y < rfy + rfh:
            on_rframe: int32 = 0
            if x < rfx + 2 or x >= rfx + rfw - 2:
                on_rframe = 1
            if y < rfy + 2 or y >= rfy + rfh - 2:
                on_rframe = 1
            if on_rframe != 0:
                r = ACCENT_TOP_R
                g = ACCENT_TOP_G
                b = ACCENT_TOP_B
    # --- alt-tab switcher popup (centred window list, MATE-style) ---
    if CYCLE_OPEN != 0:
        cyc_n: int64 = cycle_visible_count()
        if cyc_n > 0:
            cyc_h: int64 = cyc_n * CYC_ROW_H + CYC_PAD * 2
            cyc_x: int64 = cast[int64](FBG_W) / 2 - CYC_W / 2
            cyc_y: int64 = cast[int64](FBG_H) / 2 - cyc_h / 2
            if cyc_x < 0:
                cyc_x = 0
            if cyc_y < PANEL_H:
                cyc_y = PANEL_H
            if x >= cyc_x and x < cyc_x + CYC_W and y >= cyc_y and y < cyc_y + cyc_h:
                r = CYC_R
                g = CYC_G
                b = CYC_B
                # 1px frame.
                if x == cyc_x or x == cyc_x + CYC_W - 1 or y == cyc_y or y == cyc_y + cyc_h - 1:
                    r = 16
                    g = 18
                    b = 24
                # Row under (x,y), if inside the padded list area.
                row_in_y: int64 = y - cyc_y - CYC_PAD
                if row_in_y >= 0:
                    crow: int64 = row_in_y / CYC_ROW_H
                    if crow >= 0 and crow < cyc_n:
                        if crow == CYCLE_SEL:
                            on_edge_cy: int32 = 0
                            if x == cyc_x or x == cyc_x + CYC_W - 1:
                                on_edge_cy = 1
                            if on_edge_cy == 0:
                                r = CYC_SEL_R
                                g = CYC_SEL_G
                                b = CYC_SEL_B
                        cslot: int64 = cycle_slot_for_pos(crow)
                        if cslot >= 0:
                            cs_u: uint64 = cast[uint64](cslot)
                            ctly: int64 = cyc_y + CYC_PAD + crow * CYC_ROW_H \
                                + (CYC_ROW_H - GLYPH_H) / 2
                            if DWIN_APP[cs_u] != APP_TERM:
                                if str_ink(window_title(cs_u), cyc_x + CYC_PAD + 4, ctly, x, y) != 0:
                                    r = CYC_TXT_R
                                    g = CYC_TXT_G
                                    b = CYC_TXT_B
                            else:
                                ctwb: Array[16, uint8]
                                tp: Ptr[uint8] = "Terminal "
                                tk: uint64 = 0
                                while tp[tk] != 0:
                                    ctwb[tk] = tp[tk]
                                    tk = tk + 1
                                ctwb[tk] = cast[uint8](cs_u + 1) + 48
                                ctwb[tk + 1] = 0
                                if str_ink(&ctwb[0], cyc_x + CYC_PAD + 4, ctly, x, y) != 0:
                                    r = CYC_TXT_R
                                    g = CYC_TXT_G
                                    b = CYC_TXT_B
    # --- rubber band (1px outline of the in-progress drag rect) ---
    if DRAG_ACTIVE != 0:
        rx0: int64 = imin(DRAG_X0, CUR_X)
        ry0: int64 = imin(DRAG_Y0, CUR_Y)
        rx1: int64 = imax(DRAG_X0, CUR_X)
        ry1: int64 = imax(DRAG_Y0, CUR_Y)
        if x >= rx0 and x <= rx1 and y >= ry0 and y <= ry1:
            on_edge: int32 = 0
            if x == rx0 or x == rx1 or y == ry0 or y == ry1:
                on_edge = 1
            if on_edge != 0:
                r = 255
                g = 255
                b = 0
    # --- ROUND-7: clock calendar popup (monthly grid) ---
    if CAL_OPEN != 0:
        cax: int64 = cal_drop_x(cast[int64](FBG_W))
        cay: int64 = cal_drop_y()
        cah: int64 = cal_total_h()
        if x >= cax and x < cax + CAL_W and y >= cay and y < cay + cah:
            r = CAL_R
            g = CAL_G
            b = CAL_B
            # 1px outer frame.
            if x == cax or x == cax + CAL_W - 1 or y == cay or y == cay + cah - 1:
                r = 20
                g = 24
                b = 32
            ly_cal: int64 = y - cay
            # Header band: "<Month> <Year>".
            if ly_cal < CAL_HEAD_H:
                r = CAL_HEAD_R
                g = CAL_HEAD_G
                b = CAL_HEAD_B
                hoy: int64 = cay + (CAL_HEAD_H - GLYPH_H) / 2
                if str_ink(cal_month_name(CAL_MONTH), cax + 8, hoy, x, y) != 0:
                    r = 170
                    g = 210
                    b = 255
                # Year, right-aligned (4 digits).
                cal_year_buf[0] = cast[uint8](CAL_YEAR / 1000 % 10) + 48
                cal_year_buf[1] = cast[uint8](CAL_YEAR / 100 % 10) + 48
                cal_year_buf[2] = cast[uint8](CAL_YEAR / 10 % 10) + 48
                cal_year_buf[3] = cast[uint8](CAL_YEAR % 10) + 48
                cal_year_buf[4] = 0
                yrx: int64 = cax + CAL_W - 8 - 4 * GLYPH_W
                if str_ink(&cal_year_buf[0], yrx, hoy, x, y) != 0:
                    r = 170
                    g = 210
                    b = 255
            else:
                # Day-of-week initials row.
                grid_top: int64 = cay + CAL_HEAD_H + CAL_DOW_H
                gx0: int64 = cax + 4
                if y >= cay + CAL_HEAD_H and y < grid_top:
                    col_d: int64 = (x - gx0) / CAL_CELL_W
                    if col_d >= 0 and col_d < 7 and x >= gx0 and x < gx0 + 7 * CAL_CELL_W:
                        doy: int64 = cay + CAL_HEAD_H + (CAL_DOW_H - GLYPH_H) / 2
                        dlx: int64 = gx0 + col_d * CAL_CELL_W + (CAL_CELL_W - GLYPH_W) / 2
                        if str_ink(cal_dow_initial(col_d), dlx, doy, x, y) != 0:
                            r = 150
                            g = 170
                            b = 200
                elif y >= grid_top:
                    # Day grid cells.
                    row_c: int64 = (y - grid_top) / CAL_CELL_H
                    col_c: int64 = (x - gx0) / CAL_CELL_W
                    if row_c >= 0 and row_c < cal_rows() and col_c >= 0 and col_c < 7 \
                       and x >= gx0 and x < gx0 + 7 * CAL_CELL_W:
                        dval: int64 = cal_day_at(row_c, col_c)
                        is_today: int32 = 0
                        if CAL_VALID != 0 and dval == CAL_DAY and dval != 0:
                            is_today = 1
                        cell_x0: int64 = gx0 + col_c * CAL_CELL_W
                        cell_y0: int64 = grid_top + row_c * CAL_CELL_H
                        if is_today != 0:
                            # Highlight today's cell with the accent fill.
                            r = MENU_SEL_R
                            g = MENU_SEL_G
                            b = MENU_SEL_B
                        if dval != 0:
                            cal_num_buf[0] = 0
                            cal_num_buf[1] = 0
                            cal_num_buf[2] = 0
                            ndig: int64 = 0
                            if dval >= 10:
                                cal_num_buf[0] = cast[uint8](dval / 10) + 48
                                cal_num_buf[1] = cast[uint8](dval % 10) + 48
                                cal_num_buf[2] = 0
                                ndig = 2
                            else:
                                cal_num_buf[0] = cast[uint8](dval) + 48
                                cal_num_buf[1] = 0
                                ndig = 1
                            dnx: int64 = cell_x0 + (CAL_CELL_W - ndig * GLYPH_W) / 2
                            dny: int64 = cell_y0 + (CAL_CELL_H - GLYPH_H) / 2
                            ink_v: int32 = str_ink(&cal_num_buf[0], dnx, dny, x, y)
                            if ink_v != 0:
                                r = CAL_TXT_R
                                g = CAL_TXT_G
                                b = CAL_TXT_B
    # --- ROUND-7: transient notification banner (top-right, fades out) ---
    if NOTIFY_ACTIVE != 0:
        nbx: int64 = cast[int64](FBG_W) - NOTIFY_W - 8
        # Sit just inside the work area's top edge (below a top panel, or
        # flush near the ceiling when the panel is at the bottom).
        nby: int64 = work_top(cast[int64](FBG_H)) + 8
        if nbx < 0:
            nbx = 0
        if x >= nbx and x < nbx + NOTIFY_W and y >= nby and y < nby + NOTIFY_H:
            alpha: int64 = notify_alpha()
            br: uint8 = NOTIFY_R
            bg: uint8 = NOTIFY_G
            bb: uint8 = NOTIFY_B
            on_nframe: int32 = 0
            if x == nbx or x == nbx + NOTIFY_W - 1 or y == nby or y == nby + NOTIFY_H - 1:
                on_nframe = 1
            if x == nbx + 1 or x == nbx + NOTIFY_W - 2 or y == nby + 1 or y == nby + NOTIFY_H - 2:
                on_nframe = 1
            if on_nframe != 0:
                br = NOTIFY_BORDER_R
                bg = NOTIFY_BORDER_G
                bb = NOTIFY_BORDER_B
            # Title on the first text line, body on the second.
            tnx: int64 = nbx + 10
            tny: int64 = nby + 5
            if str_ink(&notify_title[0], tnx, tny, x, y) != 0:
                br = 255
                bg = 255
                bb = 255
            bny: int64 = nby + 5 + GLYPH_H + 2
            if str_ink(&notify_body[0], tnx, bny, x, y) != 0:
                br = 200
                bg = 210
                bb = 225
            # Alpha-blend the banner over whatever was composited beneath.
            r = cast[uint8]((cast[int64](br) * alpha + cast[int64](r) * (255 - alpha)) / 255)
            g = cast[uint8]((cast[int64](bg) * alpha + cast[int64](g) * (255 - alpha)) / 255)
            b = cast[uint8]((cast[int64](bb) * alpha + cast[int64](b) * (255 - alpha)) / 255)
    # --- ROUND-8: full-screen LOCK overlay ---
    # When locked, paint a dark curtain over the whole desktop with a
    # centred "Screen Locked" / "Click to unlock" message. This sits above
    # every window, panel applet and notification.
    if LOCKED != 0:
        r = 14
        g = 16
        b = 24
        sw_l: int64 = cast[int64](FBG_W)
        sh_l: int64 = cast[int64](FBG_H)
        lt: Ptr[uint8] = "Screen Locked"
        lt_w: int64 = cast[int64](strlen_u8(lt)) * GLYPH_W
        lt_x: int64 = sw_l / 2 - lt_w / 2
        lt_y: int64 = sh_l / 2 - GLYPH_H
        if str_ink(lt, lt_x, lt_y, x, y) != 0:
            r = 220
            g = 228
            b = 245
        lh: Ptr[uint8] = "Click to unlock"
        lh_w: int64 = cast[int64](strlen_u8(lh)) * GLYPH_W
        lh_x: int64 = sw_l / 2 - lh_w / 2
        lh_y: int64 = sh_l / 2 + GLYPH_H
        if str_ink(lh, lh_x, lh_y, x, y) != 0:
            r = 140
            g = 150
            b = 170
    # --- ROUND-8: modal session dialog (Lock / Log Out / Shut Down / Cancel) ---
    if SESSION_OPEN != 0 and LOCKED == 0:
        sw_d: int64 = cast[int64](FBG_W)
        sh_d: int64 = cast[int64](FBG_H)
        dx0: int64 = session_x(sw_d)
        dy0: int64 = session_y(sh_d)
        dh0: int64 = session_total_h()
        # Dim the entire desktop behind the dialog (50% black wash).
        r = cast[uint8](cast[int64](r) / 2)
        g = cast[uint8](cast[int64](g) / 2)
        b = cast[uint8](cast[int64](b) / 2)
        if x >= dx0 and x < dx0 + SESSION_W and y >= dy0 and y < dy0 + dh0:
            # Dialog body.
            r = 52
            g = 58
            b = 72
            # Beveled frame.
            if x == dx0 or x == dx0 + SESSION_W - 1 or y == dy0 or y == dy0 + dh0 - 1:
                r = 120
                g = 150
                b = 210
            # Title strip text.
            sttl: Ptr[uint8] = "End Session"
            sttx: int64 = dx0 + SESSION_PAD
            stty: int64 = dy0 + SESSION_PAD
            if str_ink(sttl, sttx, stty, x, y) != 0:
                r = 200
                g = 215
                b = 245
            # Button rows.
            ri: int64 = 0
            while ri < SESSION_ROWS:
                rby: int64 = session_row_y(sh_d, ri)
                rbx: int64 = dx0 + SESSION_PAD
                rbw: int64 = SESSION_W - SESSION_PAD * 2
                if y >= rby and y < rby + SESSION_BTN_H and x >= rbx and x < rbx + rbw:
                    # Button face; the hovered row is brighter (MATE hover).
                    if ri == SESSION_HOVER:
                        r = 86
                        g = 110
                        b = 150
                    else:
                        r = 66
                        g = 74
                        b = 92
                    if x == rbx or x == rbx + rbw - 1 or y == rby or y == rby + SESSION_BTN_H - 1:
                        r = 110
                        g = 124
                        b = 150
                    # Centred button label.
                    slbl: Ptr[uint8] = session_row_label(ri)
                    slw: int64 = cast[int64](strlen_u8(slbl)) * GLYPH_W
                    slx: int64 = rbx + (rbw - slw) / 2
                    sly: int64 = rby + (SESSION_BTN_H - GLYPH_H) / 2
                    if str_ink(slbl, slx, sly, x, y) != 0:
                        r = 235
                        g = 240
                        b = 248
                ri = ri + 1
    # --- cursor (a small filled arrow / triangle) ---
    dx: int64 = x - CUR_X
    dy: int64 = y - CUR_Y
    if dx >= 0 and dy >= 0 and dx < 12 and dy < 12:
        # Triangle mask: the pixel is part of the cursor if dx <= dy.
        # That paints a downward-right pointer anchored at the hotspot.
        if dx <= dy:
            # 1px white outline at the hypotenuse-ish edge, black fill.
            if dx == dy or dy == 11 or dx == 0:
                r = 255
                g = 255
                b = 255
            else:
                r = 0
                g = 0
                b = 0
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Refresh the live tray window-count badge from the current model: how many
# windows are visible on the current workspace.
def notif_count_refresh():
    NOTIF_WIN_COUNT = cycle_visible_count()


# Composite one screen frame from the daemon model and present it to
# /dev/fb, one row at a time (bounded userland memory). Returns 0 / 1.
def daemon_present() -> int32:
    notif_count_refresh()
    enforce_ontop_order()
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    pw: Ptr[uint8] = "/dev/fb"
    wf: int32 = sys_open_write(cast[Ptr[char]](pw))
    if wf < 0:
        return 1
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    sy: uint64 = 0
    while sy < sh:
        sx: uint64 = 0
        while sx < sw:
            daemon_pixel(cast[int64](sx), cast[int64](sy),
                         &rr[0], &gg[0], &bb[0])
            o: uint64 = sx * 4
            screen_row[o] = rr[0]
            screen_row[o + 1] = gg[0]
            screen_row[o + 2] = bb[0]
            screen_row[o + 3] = 255
            sx = sx + 1
        sys_write(wf, &screen_row[0], sw * 4)
        sy = sy + 1
    sys_close(wf)
    return 0


# Spawn a detached program + bind it to a fresh wid, then record the
# dragged rectangle as a daemon window. Mirrors user/hamUI.ad::cmd_new.
# Returns the wid (>=2) on success, -1 on failure (still records the
# rectangle as a chrome-only window so the gesture is visibly honoured).
#
# `prog` is the absolute binary path to launch (e.g. "/bin/hamsh",
# "/bin/vi"); its stdin/stdout are wired to the daemon's pipe ends so the
# in-window VT emulator drives it exactly like the drag-out shell. This
# is the SINGLE spawn-into-window path: the drag-to-create gesture passes
# "/bin/hamsh"; the Applications menu passes whichever program was clicked.
arg_buf_d: Array[2, uint64]
in_pipe_d:  Array[2, int32]              # child stdin  pipe [r, w]
out_pipe_d: Array[2, int32]             # child stdout pipe [r, w]
def daemon_spawn_window_prog(prog: Ptr[char],
                             rx: int64, ry: int64, rw: int64, rh: int64):
    if DWIN_COUNT >= DMAX:
        return
    slot: uint64 = DWIN_COUNT
    # Two kernel pipes wire the child's stdio to this daemon:
    #   in_pipe:  parent writes [1], child reads  [0]  (keystrokes)
    #   out_pipe: child writes  [1], parent reads [0]  (shell output)
    in_ok:  int32 = sys_pipe(&in_pipe_d[0])
    out_ok: int32 = sys_pipe(&out_pipe_d[0])
    child_in:  int32 = -1
    child_out: int32 = -1
    parent_in_w:  int32 = -1
    parent_out_r: int32 = -1
    if in_ok == 0 and out_ok == 0:
        child_in     = in_pipe_d[0]      # child stdin  = read end
        parent_in_w  = in_pipe_d[1]      # parent keeps write end
        child_out    = out_pipe_d[1]     # child stdout = write end
        parent_out_r = out_pipe_d[0]     # parent keeps read end
    wid: int32 = -1
    arg_buf_d[0] = cast[uint64](prog)
    arg_buf_d[1] = 0
    pid: int32 = -1
    if child_in >= 0 and child_out >= 0:
        # Real pipe fds -> the legacy integer-fd spawn path dups them into
        # the child's fd 0/1 (and binds /fd/0,1,2 on its private namespace),
        # so the spawned program talks to OUR pipes, not the serial console.
        pid = sys_spawn(prog, &arg_buf_d[0],
                        child_in, child_out, cast[Ptr[uint64]](0))
    else:
        # Pipe allocation failed — fall back to the detached spawn so the
        # gesture still produces a (headless) window.
        pid = sys_spawn(prog, &arg_buf_d[0],
                        -2, -2, cast[Ptr[uint64]](0))
    if pid >= 0:
        wid = sys_wsys_alloc(cast[uint64](pid))
        if wid < 0:
            # Table full / dup — reap the child so we don't leak it.
            sys_kill(pid, SIGTERM_D)
    # The child has its own dup'd copies now; close OUR copies of the
    # child ends so the pipe EOF/refcounts stay correct.
    if child_in >= 0:
        sys_close(child_in)
    if child_out >= 0:
        sys_close(child_out)
    # Record the window + its terminal state.
    DWIN_X[slot] = rx
    DWIN_Y[slot] = ry
    DWIN_W[slot] = rw
    DWIN_H[slot] = rh
    DWIN_WID[slot] = wid
    DWIN_UID[slot] = NEXT_UID
    NEXT_UID = NEXT_UID + 1
    DWIN_PID[slot] = pid
    DWIN_IN_FD[slot]  = parent_in_w
    DWIN_OUT_FD[slot] = parent_out_r
    # Grid geometry from the body region (window minus 2px border + title).
    body_w: int64 = rw - 4
    body_h: int64 = rh - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    DWIN_HIDDEN[slot] = 0
    DWIN_VK[slot] = 0
    DWIN_APP[slot] = APP_TERM
    DWIN_SNAP[slot] = 0
    DWIN_SHADED[slot] = 0
    DWIN_SHADE_H[slot] = rh
    DWIN_ONTOP[slot] = 0
    # New windows open on the CURRENT workspace, un-maximized.
    DWIN_WS[slot] = CUR_WS
    DWIN_MAXED[slot] = 0
    DWIN_SAVE_X[slot] = rx
    DWIN_SAVE_Y[slot] = ry
    DWIN_SAVE_W[slot] = rw
    DWIN_SAVE_H[slot] = rh
    term_clear(slot)
    DWIN_COUNT = DWIN_COUNT + 1
    # If we got a real wid, plant a chrome layer on its draw surface so
    # the window is real on the wsys side too (best-effort).
    if wid >= 2:
        build_path(wid, cast[Ptr[uint8]](0), "ctl")
        cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
        if cf >= 0:
            cmd: Ptr[uint8] = "mklayer chrome markup\n"
            sys_write(cf, cmd, strlen_u8(cmd))
            sys_close(cf)


# Backwards-compatible drag-to-create spawn: launches an interactive
# hamsh into the dragged rectangle (the classic rio gesture). Delegates
# to the generalised path so there is one spawn implementation.
def daemon_spawn_window(rx: int64, ry: int64, rw: int64, rh: int64):
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamsh"), rx, ry, rw, rh)


# Open a built-in (in-process) application window of the given app kind.
# Unlike daemon_spawn_window_prog these have NO child process or pipes —
# their body is drawn and their input handled entirely inside the daemon.
def daemon_spawn_app(app: int32, rx: int64, ry: int64, rw: int64, rh: int64):
    if DWIN_COUNT >= DMAX:
        return
    slot: uint64 = DWIN_COUNT
    DWIN_X[slot] = rx
    DWIN_Y[slot] = ry
    DWIN_W[slot] = rw
    DWIN_H[slot] = rh
    DWIN_WID[slot] = -1
    DWIN_UID[slot] = NEXT_UID
    NEXT_UID = NEXT_UID + 1
    DWIN_PID[slot] = -1
    DWIN_IN_FD[slot]  = -1
    DWIN_OUT_FD[slot] = -1
    DWIN_VK[slot] = 0
    DWIN_APP[slot] = app
    DWIN_SNAP[slot] = 0
    DWIN_SHADED[slot] = 0
    DWIN_SHADE_H[slot] = rh
    DWIN_ONTOP[slot] = 0
    DWIN_HIDDEN[slot] = 0
    DWIN_WS[slot] = CUR_WS
    DWIN_MAXED[slot] = 0
    DWIN_SAVE_X[slot] = rx
    DWIN_SAVE_Y[slot] = ry
    DWIN_SAVE_W[slot] = rw
    DWIN_SAVE_H[slot] = rh
    body_w: int64 = rw - 4
    body_h: int64 = rh - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    term_clear(slot)
    if app == APP_CALC:
        CALC_ACC[slot] = 0
        CALC_CUR[slot] = 0
        CALC_OP[slot] = 0
        CALC_FRESH[slot] = 1
        CALC_ERR[slot] = 0
    DWIN_COUNT = DWIN_COUNT + 1


# Launch menu entry `i` into a fresh window. Each launch is cascaded a
# little down-right of the previous so several apps don't stack exactly
# on top of one another. The rectangle is clamped to stay below the panel
# and inside the framebuffer. Reuses the single spawn-into-window path.
LAUNCH_CASCADE: int64 = 0
def menu_launch(i: uint64, scr_w: int64, scr_h: int64):
    if i >= MENU_COUNT:
        return
    app: int32 = menu_app(i)
    w: int64 = 480
    h: int64 = 320
    # Built-in apps get sizes tuned to their layout.
    if app == APP_CALC:
        w = 220
        h = 300
    elif app == APP_SYSMON:
        w = 360
        h = 220
    elif app == APP_ABOUT:
        w = 360
        h = 180
    # Cascade origin: step 28px per launch, wrapping after a few steps.
    step: int64 = (LAUNCH_CASCADE % 6) * 28
    rx: int64 = 80 + step
    ry: int64 = PANEL_H + 20 + step
    # Clamp so the window fits on-screen below the panel.
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    if app >= 0:
        daemon_spawn_app(app, rx, ry, w, h)
    else:
        daemon_spawn_window_prog(menu_prog(i), rx, ry, w, h)
    # Emit a deterministic serial marker so a self-test can assert the
    # launch fired (label, not path, to keep the marker human-readable).
    pfx: Ptr[uint8] = "PANEL launch "
    sys_write(1, pfx, strlen_u8(pfx))
    lbl: Ptr[uint8] = menu_label(i)
    sys_write(1, lbl, strlen_u8(lbl))
    nl: Ptr[uint8] = "\n"
    sys_write(1, nl, 1)
    # ROUND-7: surface a transient "launching" notification banner.
    notify_post("Launching", lbl)


# Copy ALL per-slot window state (geometry, terminal fds/state, and the
# character grid) from slot `src` to slot `dst`. Used to compact the
# window table when a window is destroyed and to reorder for raise.
def slot_copy(dst: uint64, src: uint64):
    if dst == src:
        return
    DWIN_X[dst]      = DWIN_X[src]
    DWIN_Y[dst]      = DWIN_Y[src]
    DWIN_W[dst]      = DWIN_W[src]
    DWIN_H[dst]      = DWIN_H[src]
    DWIN_WID[dst]    = DWIN_WID[src]
    DWIN_UID[dst]    = DWIN_UID[src]
    DWIN_PID[dst]    = DWIN_PID[src]
    DWIN_IN_FD[dst]  = DWIN_IN_FD[src]
    DWIN_OUT_FD[dst] = DWIN_OUT_FD[src]
    DWIN_COLS[dst]   = DWIN_COLS[src]
    DWIN_ROWS[dst]   = DWIN_ROWS[src]
    DWIN_CUR_C[dst]  = DWIN_CUR_C[src]
    DWIN_CUR_R[dst]  = DWIN_CUR_R[src]
    DWIN_VT[dst]     = DWIN_VT[src]
    DWIN_HIDDEN[dst] = DWIN_HIDDEN[src]
    DWIN_VK[dst]     = DWIN_VK[src]
    DWIN_WS[dst]     = DWIN_WS[src]
    DWIN_MAXED[dst]  = DWIN_MAXED[src]
    DWIN_SAVE_X[dst] = DWIN_SAVE_X[src]
    DWIN_SAVE_Y[dst] = DWIN_SAVE_Y[src]
    DWIN_SAVE_W[dst] = DWIN_SAVE_W[src]
    DWIN_SAVE_H[dst] = DWIN_SAVE_H[src]
    DWIN_APP[dst]    = DWIN_APP[src]
    DWIN_SNAP[dst]   = DWIN_SNAP[src]
    DWIN_SHADED[dst]  = DWIN_SHADED[src]
    DWIN_SHADE_H[dst] = DWIN_SHADE_H[src]
    DWIN_ONTOP[dst]   = DWIN_ONTOP[src]
    CALC_ACC[dst]    = CALC_ACC[src]
    CALC_CUR[dst]    = CALC_CUR[src]
    CALC_OP[dst]     = CALC_OP[src]
    CALC_FRESH[dst]  = CALC_FRESH[src]
    CALC_ERR[dst]    = CALC_ERR[src]
    # Move the character grid wholesale (GRID_CELLS bytes).
    sb: uint64 = src * GRID_CELLS
    db: uint64 = dst * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[db + i] = term_grid[sb + i]
        i = i + 1


# Raise window `slot` to the topmost paint position (last slot). The
# windows above it slide down one slot so paint/hit-test order stays a
# simple back-to-front array walk. MOVE_SLOT is rebased to the new
# position so an in-flight move keeps tracking the right window.
def daemon_raise_slot(slot: int64) -> int64:
    if slot < 0:
        return slot
    last: uint64 = DWIN_COUNT - 1
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return cast[int64](s)
    if s == last:
        # Already front-most: still record the focus in the MRU list.
        mru_touch(DWIN_UID[s])
        return cast[int64](s)
    # Stash the window being raised in the spare slot just past the
    # table (DMAX-sized arrays always have room: DWIN_COUNT <= DMAX, and
    # we hold the raised window aside while shifting), using slot DMAX-1
    # is unsafe when full — instead shift up then place at `last`.
    # Save raised window into temporaries via the spawn scratch grid is
    # complex; simplest correct approach: bubble it up with swaps.
    raised_uid: int32 = DWIN_UID[s]
    cur: uint64 = s
    while cur < last:
        slot_swap(cur, cur + 1)
        cur = cur + 1
    # Record the now-focused window at the head of the MRU list.
    mru_touch(raised_uid)
    return cast[int64](last)


# Swap two slots' full state. Implemented via a scratch slot would need
# extra grid storage; instead swap field-by-field and the grid cell-by-
# cell (bounded: GRID_CELLS per call, DMAX small).
def slot_swap(a: uint64, b: uint64):
    if a == b:
        return
    t0: int64 = DWIN_X[a]
    DWIN_X[a] = DWIN_X[b]
    DWIN_X[b] = t0
    t1: int64 = DWIN_Y[a]
    DWIN_Y[a] = DWIN_Y[b]
    DWIN_Y[b] = t1
    t2: int64 = DWIN_W[a]
    DWIN_W[a] = DWIN_W[b]
    DWIN_W[b] = t2
    t3: int64 = DWIN_H[a]
    DWIN_H[a] = DWIN_H[b]
    DWIN_H[b] = t3
    i0: int32 = DWIN_WID[a]
    DWIN_WID[a] = DWIN_WID[b]
    DWIN_WID[b] = i0
    iu: int32 = DWIN_UID[a]
    DWIN_UID[a] = DWIN_UID[b]
    DWIN_UID[b] = iu
    i1: int32 = DWIN_PID[a]
    DWIN_PID[a] = DWIN_PID[b]
    DWIN_PID[b] = i1
    i2: int32 = DWIN_IN_FD[a]
    DWIN_IN_FD[a] = DWIN_IN_FD[b]
    DWIN_IN_FD[b] = i2
    i3: int32 = DWIN_OUT_FD[a]
    DWIN_OUT_FD[a] = DWIN_OUT_FD[b]
    DWIN_OUT_FD[b] = i3
    t4: int64 = DWIN_COLS[a]
    DWIN_COLS[a] = DWIN_COLS[b]
    DWIN_COLS[b] = t4
    t5: int64 = DWIN_ROWS[a]
    DWIN_ROWS[a] = DWIN_ROWS[b]
    DWIN_ROWS[b] = t5
    t6: int64 = DWIN_CUR_C[a]
    DWIN_CUR_C[a] = DWIN_CUR_C[b]
    DWIN_CUR_C[b] = t6
    t7: int64 = DWIN_CUR_R[a]
    DWIN_CUR_R[a] = DWIN_CUR_R[b]
    DWIN_CUR_R[b] = t7
    i4: int32 = DWIN_VT[a]
    DWIN_VT[a] = DWIN_VT[b]
    DWIN_VT[b] = i4
    i5: int32 = DWIN_HIDDEN[a]
    DWIN_HIDDEN[a] = DWIN_HIDDEN[b]
    DWIN_HIDDEN[b] = i5
    i6: int32 = DWIN_VK[a]
    DWIN_VK[a] = DWIN_VK[b]
    DWIN_VK[b] = i6
    i7: int32 = DWIN_WS[a]
    DWIN_WS[a] = DWIN_WS[b]
    DWIN_WS[b] = i7
    i8: int32 = DWIN_MAXED[a]
    DWIN_MAXED[a] = DWIN_MAXED[b]
    DWIN_MAXED[b] = i8
    sx0: int64 = DWIN_SAVE_X[a]
    DWIN_SAVE_X[a] = DWIN_SAVE_X[b]
    DWIN_SAVE_X[b] = sx0
    sy0: int64 = DWIN_SAVE_Y[a]
    DWIN_SAVE_Y[a] = DWIN_SAVE_Y[b]
    DWIN_SAVE_Y[b] = sy0
    sw0: int64 = DWIN_SAVE_W[a]
    DWIN_SAVE_W[a] = DWIN_SAVE_W[b]
    DWIN_SAVE_W[b] = sw0
    sh0: int64 = DWIN_SAVE_H[a]
    DWIN_SAVE_H[a] = DWIN_SAVE_H[b]
    DWIN_SAVE_H[b] = sh0
    i9: int32 = DWIN_APP[a]
    DWIN_APP[a] = DWIN_APP[b]
    DWIN_APP[b] = i9
    i10: int32 = DWIN_SNAP[a]
    DWIN_SNAP[a] = DWIN_SNAP[b]
    DWIN_SNAP[b] = i10
    i11: int32 = DWIN_SHADED[a]
    DWIN_SHADED[a] = DWIN_SHADED[b]
    DWIN_SHADED[b] = i11
    sh9: int64 = DWIN_SHADE_H[a]
    DWIN_SHADE_H[a] = DWIN_SHADE_H[b]
    DWIN_SHADE_H[b] = sh9
    i12: int32 = DWIN_ONTOP[a]
    DWIN_ONTOP[a] = DWIN_ONTOP[b]
    DWIN_ONTOP[b] = i12
    c0: int64 = CALC_ACC[a]
    CALC_ACC[a] = CALC_ACC[b]
    CALC_ACC[b] = c0
    c1: int64 = CALC_CUR[a]
    CALC_CUR[a] = CALC_CUR[b]
    CALC_CUR[b] = c1
    c2: int32 = CALC_OP[a]
    CALC_OP[a] = CALC_OP[b]
    CALC_OP[b] = c2
    c3: int32 = CALC_FRESH[a]
    CALC_FRESH[a] = CALC_FRESH[b]
    CALC_FRESH[b] = c3
    c4: int32 = CALC_ERR[a]
    CALC_ERR[a] = CALC_ERR[b]
    CALC_ERR[b] = c4
    ab: uint64 = a * GRID_CELLS
    bb: uint64 = b * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        g: uint8 = term_grid[ab + i]
        term_grid[ab + i] = term_grid[bb + i]
        term_grid[bb + i] = g
        i = i + 1


# Destroy window `slot`: tear down its hamsh child + pipes, free the wid
# binding, then compact the table so paint order stays contiguous. Any
# in-flight move/close referencing a shifted slot is reset by the caller.
def daemon_close_slot(slot: int64):
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return
    # Tear down the child shell + the daemon's pipe ends so we don't leak
    # the process or the fds. SIGTERM the bound pid (best-effort), free
    # the wsys slot, and close both parent pipe ends.
    # Forget this window in the MRU Alt-Tab list before it's gone.
    mru_drop(DWIN_UID[s])
    pid: int32 = DWIN_PID[s]
    if pid > 0:
        sys_kill(pid, SIGTERM_D)
    wid: int32 = DWIN_WID[s]
    if wid >= 2:
        sys_wsys_free(wid)
    infd: int32 = DWIN_IN_FD[s]
    if infd >= 0:
        sys_close(infd)
    outfd: int32 = DWIN_OUT_FD[s]
    if outfd >= 0:
        sys_close(outfd)
    # Compact: slide every higher slot down by one so paint order stays
    # a contiguous 0..DWIN_COUNT-1 back-to-front walk.
    last: uint64 = DWIN_COUNT - 1
    j: uint64 = s
    while j < last:
        slot_copy(j, j + 1)
        j = j + 1
    DWIN_COUNT = DWIN_COUNT - 1


# Consume all currently-available mouse packets, updating CUR_X/CUR_Y
# and tracking the left-button edge for the drag gesture. Returns 1 if
# anything changed (cursor moved or button edge), else 0. The /dev/mouse
# fd is held in the mouse_fd global (opened once in cmd_daemon).
mouse_fd: int32 = -1
def daemon_pump_mouse(scr_w: int64, scr_h: int64) -> int32:
    changed: int32 = 0
    iters: int32 = 0
    while iters < 64:
        n: int64 = sys_read_nb(mouse_fd, &mouse_buf[0], 256)
        iters = iters + 1
        if n <= 0:
            break
        i: uint64 = 0
        total: uint64 = cast[uint64](n)
        while i < total:
            ls: uint64 = i
            while i < total and mouse_buf[i] != 10:
                i = i + 1
            le: uint64 = i
            if i < total:
                i = i + 1
            if le > ls:
                changed = daemon_apply_packet(ls, le, scr_w, scr_h) | changed
    return changed


def daemon_apply_packet(ls: uint64, le: uint64,
                        scr_w: int64, scr_h: int64) -> int32:
    # Parse "<dx> <dy> <buttons>" (space-separated, possibly signed).
    pos: Array[1, uint64]
    pos[0] = ls
    dx: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    dy: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    btn: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    # /dev/mouse already reports screen-space deltas: the PS/2 driver
    # (drivers/input/auxmouse.ad) negates the protocol's up-positive Y
    # into framebuffer-down-positive at the single conversion point, so
    # here we just integrate both axes directly. (Negating again was a
    # double-negation that inverted vertical cursor motion.)
    CUR_X = iclamp(CUR_X + dx, 0, scr_w - 1)
    CUR_Y = iclamp(CUR_Y + dy, 0, scr_h - 1)
    lbtn: int32 = 0
    if (btn & 1) != 0:
        lbtn = 1
    # Right button is bit 1 (PS/2 button-2). Drives the context menus.
    rbtn: int32 = 0
    if (btn & 2) != 0:
        rbtn = 1
    # Update the title-bar button hover state every packet so decorations
    # highlight under the moving cursor.
    update_hover()
    # ROUND-7: focus-follows-mouse. When enabled and no gesture is in
    # flight, the window under the pointer is raised to the top so it
    # gains focus as the cursor passes over it (GNOME2 "sloppy" focus).
    focus_follow_step(lbtn, scr_w, scr_h)
    wm_rbutton(rbtn, scr_w, scr_h)
    PREV_BTN_R = rbtn
    # Drive the gesture state machine off the integrated cursor + button
    # state. wm_button() handles the press/drag/release edges (move,
    # close, create) using CUR_X/CUR_Y and PREV_BTN_L.
    wm_button(lbtn, scr_w, scr_h)
    PREV_BTN_L = lbtn
    return 1


# Recompute which title-bar button (if any) the cursor is hovering so the
# ROUND-7: focus-follows-mouse state. The UID last auto-focused by a
# motion-over so we only raise when the hovered window actually changes
# (avoids thrashing the z-order on every motion packet).
FOCUS_FOLLOW_UID: int32 = -1


# When FOCUS_MODE is follows-mouse, raise the window under the pointer so
# it gains focus as the cursor passes over it. Suppressed while a button
# is held (a drag/resize is in flight), while any menu/popup is open, or
# while the pointer is over the panel — matching GNOME2 sloppy focus,
# which never re-focuses through the panel or mid-gesture.
def focus_follow_step(lbtn: int32, scr_w: int64, scr_h: int64):
    if FOCUS_MODE == 0:
        FOCUS_FOLLOW_UID = -1
        return
    if lbtn != 0 or PREV_BTN_L != 0:
        return
    if RESIZE_SLOT >= 0 or DRAG_ACTIVE != 0 or GESTURE == 4:
        return
    if MENU_BAR_OPEN >= 0 or CTX_OPEN != 0 or CAL_OPEN != 0 or CYCLE_OPEN != 0:
        return
    if in_panel(CUR_X, CUR_Y) != 0:
        return
    hit: int64 = window_at(CUR_X, CUR_Y)
    if hit < 0:
        FOCUS_FOLLOW_UID = -1
        return
    hu: uint64 = cast[uint64](hit)
    huid: int32 = DWIN_UID[hu]
    if huid == FOCUS_FOLLOW_UID:
        return
    FOCUS_FOLLOW_UID = huid
    # Only raise if it isn't already the front-most window.
    if hit != cast[int64](DWIN_COUNT) - 1:
        daemon_raise_slot(hit)
        ff: Ptr[uint8] = "FOCUS follow raise\n"
        sys_write(1, ff, strlen_u8(ff))


# decoration code can brighten it. Scans the topmost window down.
def update_hover():
    HOVER_SLOT = -1
    HOVER_BTN = -1
    RESIZE_HOVER = 0
    # ROUND-8: while the modal session dialog is up, track which button row
    # the cursor rests on so the renderer can highlight it (MATE feel). The
    # dialog is modal, so nothing else needs hover state.
    if SESSION_OPEN != 0:
        SESSION_HOVER = session_row_at(CUR_X, CUR_Y,
                                       cast[int64](FBG_W), cast[int64](FBG_H))
        return
    # Clock-applet hover: 1 while the cursor is over the right-edge clock
    # zone in the panel (drives the date tooltip).
    clk_x: int64 = cast[int64](FBG_W) - CLOCK_W
    if on_panel_y(CUR_Y) != 0 and CUR_X >= clk_x and CUR_X < cast[int64](FBG_W):
        CLOCK_HOVER = 1
    else:
        CLOCK_HOVER = 0
    # ROUND-7: Applications category submenu follows the hovered row. When
    # the Applications drop-down is open and the cursor rests on a category
    # row, that category's flyout opens; hovering inside the open flyout
    # keeps it up so the user can travel to an item.
    if MENU_BAR_OPEN == 0:
        chov: int64 = menubar_item_at(CUR_X, CUR_Y)
        if chov >= 0 and chov < APPCAT_COUNT:
            SUBMENU_OPEN = chov
        elif SUBMENU_OPEN >= 0:
            # Keep the flyout open only while the cursor stays within it.
            if submenu_item_at(SUBMENU_OPEN, CUR_X, CUR_Y) < 0:
                SUBMENU_OPEN = -1
    else:
        SUBMENU_OPEN = -1
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        s: uint64 = cast[uint64](wi)
        if win_on_cur_ws(s) != 0:
            if in_close_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 0
                return
            if in_minimize_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 1
                return
            if in_maximize_box(s, CUR_X, CUR_Y) != 0:
                HOVER_SLOT = wi
                HOVER_BTN = 2
                return
            # ROUND-6: resize-grip hover hint (the topmost window wins).
            rdh: int32 = resize_dir_at(s, CUR_X, CUR_Y)
            if rdh != 0:
                RESIZE_HOVER = rdh
                return
        wi = wi - 1


# Open a file-manager window rooted at `dir` (Places menu action). Uses
# the generalised spawn path with hamfm + the directory as argv[1].
fm_arg_buf: Array[2, uint64]
def places_open(dir: Ptr[char], scr_w: int64, scr_h: int64):
    if DWIN_COUNT >= DMAX:
        return
    w: int64 = 480
    h: int64 = 320
    step: int64 = (LAUNCH_CASCADE % 6) * 28
    rx: int64 = 80 + step
    ry: int64 = PANEL_H + 20 + step
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamfm"), rx, ry, w, h)
    # Feed a "cd <dir>\n" — hamfm reads a path on stdin/argv; we route the
    # directory to the just-spawned window's child stdin so it opens there.
    sl: uint64 = DWIN_COUNT - 1
    wfd: int32 = DWIN_IN_FD[sl]
    if wfd >= 0:
        cmd: Ptr[uint8] = "cd "
        sys_write(wfd, cmd, strlen_u8(cmd))
        sys_write(wfd, cast[Ptr[uint8]](dir), strlen_u8(cast[Ptr[uint8]](dir)))
        nl: Ptr[uint8] = "\n"
        sys_write(wfd, nl, 1)
    pfx: Ptr[uint8] = "PLACES open "
    sys_write(1, pfx, strlen_u8(pfx))
    sys_write(1, cast[Ptr[uint8]](dir), strlen_u8(cast[Ptr[uint8]](dir)))
    sys_write(1, "\n", 1)


# Open the built-in "About Hamnix" info card (System menu). This is a
# real in-process DE window drawn by app_about_pixel — no child process.
def system_about(scr_w: int64, scr_h: int64):
    rw: int64 = 360
    rh: int64 = 180
    rx: int64 = scr_w / 2 - rw / 2
    ry: int64 = scr_h / 2 - rh / 2
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    if rx + rw > scr_w:
        rx = scr_w - rw
    daemon_spawn_app(APP_ABOUT, rx, ry, rw, rh)
    pfx: Ptr[uint8] = "SYSTEM about\n"
    sys_write(1, pfx, strlen_u8(pfx))


# Invoke item `i` of the open menu-bar drop-down `m`.
def menubar_invoke(m: int32, i: uint64, scr_w: int64, scr_h: int64):
    if m == 0:
        # ROUND-7: Applications rows are categories — they open a submenu
        # flyout rather than launching directly (handled in wm_button).
        SUBMENU_OPEN = cast[int64](i)
        return
    if m == 1:
        if i == 0:
            places_open(cast[Ptr[char]]("/home"), scr_w, scr_h)
        elif i == 1:
            places_open(cast[Ptr[char]]("/"), scr_w, scr_h)
        else:
            places_open(cast[Ptr[char]]("/tmp"), scr_w, scr_h)
        return
    if m == 2:
        if i == 0:
            # System Monitor: open the built-in live-stats app window.
            smx: int64 = 100
            smy: int64 = PANEL_H + 30
            smw: int64 = 360
            smh: int64 = 220
            if smx + smw > scr_w:
                smx = scr_w - smw
            daemon_spawn_app(APP_SYSMON, smx, smy, smw, smh)
            sm: Ptr[uint8] = "SYSTEM launch System Monitor\n"
            sys_write(1, sm, strlen_u8(sm))
        elif i == 1:
            system_about(scr_w, scr_h)
        elif i == 2:
            # Reload DE: re-seed the desktop chrome state (a real action —
            # closes all menus + re-presents). A serial marker proves it.
            MENU_BAR_OPEN = -1
            MENU_OPEN = 0
            CTX_OPEN = 0
            rl: Ptr[uint8] = "SYSTEM reload DE\n"
            sys_write(1, rl, strlen_u8(rl))
        elif i == 3:
            workspace_switch(CUR_WS + 1)
        elif i == 4:
            workspace_switch(CUR_WS - 1)
        elif i == 5:
            # Settings: open the built-in preferences window.
            stx: int64 = 120
            sty: int64 = PANEL_H + 30
            stw: int64 = 320
            sth: int64 = 200
            if stx + stw > scr_w:
                stx = scr_w - stw
            daemon_spawn_app(APP_SETTINGS, stx, sty, stw, sth)
            st: Ptr[uint8] = "SYSTEM launch Settings\n"
            sys_write(1, st, strlen_u8(st))
        else:
            # ROUND-8: Log Out now raises the modal SESSION DIALOG (Lock
            # Screen / Log Out / Shut Down / Cancel) instead of quitting
            # outright, matching gnome-session's logout chooser.
            session_open()
            lo: Ptr[uint8] = "SYSTEM Log Out\n"
            sys_write(1, lo, strlen_u8(lo))
        return


# Invoke item `i` of the open right-click context menu.
def ctx_invoke(i: uint64, scr_w: int64, scr_h: int64):
    if CTX_KIND == 0:
        # Desktop menu: Open Terminal / Settings / Change Background /
        # Arrange / Reload.
        if i == 0:
            rx: int64 = CTX_X
            ry: int64 = CTX_Y
            if ry < PANEL_H:
                ry = PANEL_H
            daemon_spawn_window(rx, ry, 480, 320)
            nt: Ptr[uint8] = "CTX new-terminal\n"
            sys_write(1, nt, strlen_u8(nt))
        elif i == 1:
            # Settings: open the built-in preferences window (ROUND-5).
            stx: int64 = CTX_X
            sty: int64 = CTX_Y
            if sty < PANEL_H:
                sty = PANEL_H
            stw: int64 = 320
            sth: int64 = 200
            if stx + stw > scr_w:
                stx = scr_w - stw
            if stx < 0:
                stx = 0
            daemon_spawn_app(APP_SETTINGS, stx, sty, stw, sth)
            cs: Ptr[uint8] = "CTX settings\n"
            sys_write(1, cs, strlen_u8(cs))
        elif i == 2:
            bg_cycle()
        elif i == 3:
            windows_arrange(scr_w, scr_h)
        else:
            MENU_BAR_OPEN = -1
            MENU_OPEN = 0
            rl: Ptr[uint8] = "SYSTEM reload DE\n"
            sys_write(1, rl, strlen_u8(rl))
        return
    # Window menu — act on CTX_SLOT.
    if CTX_SLOT < 0:
        return
    s: uint64 = cast[uint64](CTX_SLOT)
    if s >= DWIN_COUNT:
        return
    if i == 0:
        DWIN_HIDDEN[s] = 1
        mm: Ptr[uint8] = "WM minimize window\n"
        sys_write(1, mm, strlen_u8(mm))
    elif i == 1:
        window_toggle_maximize(s, scr_w, scr_h)
    elif i == 2:
        window_maximize_vert(s, scr_w, scr_h)
    elif i == 3:
        window_maximize_horiz(s, scr_w, scr_h)
    elif i == 4:
        window_toggle_shade(s)
    elif i == 5:
        window_toggle_ontop(s)
    elif i == 6:
        # ROUND-6: arm an interactive resize from the bottom-right corner.
        # The pointer then drags the SE grip (like picking "Resize" in MATE's
        # window menu and grabbing the corner). Warp the tracked cursor to
        # the corner so the first motion pulls from there.
        CUR_X = DWIN_X[s] + DWIN_W[s] - 1
        CUR_Y = DWIN_Y[s] + DWIN_H[s] - 1
        resize_begin(CTX_SLOT, 2 | 8)        # right + bottom edges (SE corner)
        GESTURE = 4
        PREV_BTN_L = 1                        # treat as a held resize drag
    elif i == 7:
        window_to_workspace(s, CUR_WS + 1)
    elif i == 8:
        nws: int32 = CUR_WS - 1
        if nws < 0:
            nws = WS_COUNT - 1
        window_to_workspace(s, nws)
    else:
        daemon_close_slot(CTX_SLOT)
        cw: Ptr[uint8] = "WM close window\n"
        sys_write(1, cw, strlen_u8(cw))


# Right-button gesture machine. On the DOWN edge it opens a context menu:
# over a window's title bar -> the window menu; over the empty desktop ->
# the desktop menu. A left click elsewhere dismisses it (handled in
# wm_button). Factored out so the self-test can drive it directly.
def wm_rbutton(rbtn: int32, scr_w: int64, scr_h: int64):
    if rbtn != 0 and PREV_BTN_R == 0:
        # Right-click while a context menu is open closes it (toggle).
        if CTX_OPEN != 0:
            CTX_OPEN = 0
            return
        # ROUND-11: right-click a GROUPED taskbar button to act on the whole
        # group at once (MATE's window-list group menu). We toggle the group:
        # if every member is already minimized, restore them all; otherwise
        # minimize them all. This must be checked BEFORE the panel early-out
        # below, since taskbar buttons live inside the panel bar.
        rtslot: int64 = taskbar_slot_at(CUR_X, CUR_Y, scr_w)
        if rtslot >= 0:
            rts: uint64 = cast[uint64](rtslot)
            if is_grouped(rts) != 0:
                # Is the group fully minimized already?
                ga: int32 = DWIN_APP[rts]
                all_hidden: int32 = 1
                gi: uint64 = 0
                while gi < DWIN_COUNT:
                    if DWIN_APP[gi] == ga and DWIN_HIDDEN[gi] == 0:
                        all_hidden = 0
                    gi = gi + 1
                if all_hidden != 0:
                    group_restore_all(rts)
                else:
                    group_minimize_all(rts)
                return
        # Right-click on the panel does nothing (reserved).
        if in_panel(CUR_X, CUR_Y) != 0:
            return
        hit: int64 = window_at(CUR_X, CUR_Y)
        if hit >= 0 and in_title_bar(cast[uint64](hit), CUR_X, CUR_Y) != 0:
            ctx_open_at(1, hit, CUR_X, CUR_Y, scr_w, scr_h)
            wm: Ptr[uint8] = "CTX window-menu\n"
            sys_write(1, wm, strlen_u8(wm))
        else:
            ctx_open_at(0, -1, CUR_X, CUR_Y, scr_w, scr_h)
            dm: Ptr[uint8] = "CTX desktop-menu\n"
            sys_write(1, dm, strlen_u8(dm))


# Gesture state machine, driven by the current left-button level (lbtn:
# 0/1) and the absolute cursor at CUR_X/CUR_Y. Detects the press edge
# (against PREV_BTN_L), tracks an in-flight move while held, and resolves
# move/close/create on the release edge. Factored out so the daemon
# self-test can drive it directly with absolute coordinates (no /dev/mouse
# packet round-trip).
def wm_button(lbtn: int32, scr_w: int64, scr_h: int64):
    # --- left-button DOWN edge: classify the gesture ---
    if lbtn != 0 and PREV_BTN_L == 0:
        # ROUND-8: a LOCKED screen swallows every click (the click is the
        # unlock gesture). Nothing else on the desktop can be reached while
        # locked, so this shields ahead of all other handlers.
        if LOCKED != 0:
            session_unlock()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # ROUND-8: the modal SESSION DIALOG eats the next click — either a
        # button row fires its action, or a click outside the dialog cancels.
        if SESSION_OPEN != 0:
            srow: int64 = session_row_at(CUR_X, CUR_Y, scr_w, scr_h)
            if srow >= 0:
                session_invoke(srow)
            else:
                SESSION_OPEN = 0
                cc: Ptr[uint8] = "SESSION cancel\n"
                sys_write(1, cc, strlen_u8(cc))
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # CONTEXT MENU first — an open right-click menu eats the next click.
        if CTX_OPEN != 0:
            ci: int64 = ctx_item_at(CUR_X, CUR_Y)
            CTX_OPEN = 0                        # any click closes it
            if ci >= 0:
                ctx_invoke(cast[uint64](ci), scr_w, scr_h)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # PANEL / MENU BAR next — desktop chrome intercepts the press before
        # any window/drag-create logic so the launcher never also starts a
        # rubber-band window.
        #   * press on a top-level menu button -> toggle that drop-down
        #   * press on an open drop-down item  -> invoke it + close the menu
        #   * press elsewhere while a menu is open -> dismiss it
        mbhit: int32 = menubar_btn_at(CUR_X, CUR_Y)
        if mbhit >= 0:
            SUBMENU_OPEN = -1
            # ROUND-10: opening the Applications menu fresh arms its type-to-
            # search box (empty query => the menu shows every entry); any
            # close or other menu clears it.
            search_reset()
            if MENU_BAR_OPEN == mbhit:
                MENU_BAR_OPEN = -1
                mc: Ptr[uint8] = "PANEL close menu\n"
                sys_write(1, mc, strlen_u8(mc))
            else:
                MENU_BAR_OPEN = mbhit
                if mbhit == 0:
                    SEARCH_OPEN = 1
                mo: Ptr[uint8] = "PANEL open menu "
                sys_write(1, mo, strlen_u8(mo))
                write_str(1, menubar_label(mbhit))
                write_str(1, "\n")
            DRAG_ACTIVE = 0
            GESTURE = 3                        # panel: no up-edge action
            return
        if MENU_BAR_OPEN >= 0:
            # ROUND-10: while the Applications search filter is active, a
            # click on a filtered result row launches that entry and closes
            # the menu (MATE type-to-launch).
            if MENU_BAR_OPEN == 0 and search_active() != 0:
                srn: int64 = search_result_at(CUR_X, CUR_Y)
                if srn >= 0:
                    sflat: uint64 = menu_search_nth(cast[uint64](srn))
                    MENU_BAR_OPEN = -1
                    SUBMENU_OPEN = -1
                    search_reset()
                    if sflat < MENU_COUNT:
                        menu_launch(sflat, scr_w, scr_h)
                    DRAG_ACTIVE = 0
                    GESTURE = 3
                    return
                # A click off the result list closes the menu + search.
                MENU_BAR_OPEN = -1
                SUBMENU_OPEN = -1
                search_reset()
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            # ROUND-7: a click inside an open Applications submenu flyout
            # launches that category's app and closes the whole menu.
            if MENU_BAR_OPEN == 0 and SUBMENU_OPEN >= 0:
                sk: int64 = submenu_item_at(SUBMENU_OPEN, CUR_X, CUR_Y)
                if sk >= 0:
                    flat: uint64 = appcat_flat_index(SUBMENU_OPEN, sk)
                    MENU_BAR_OPEN = -1
                    SUBMENU_OPEN = -1
                    menu_launch(flat, scr_w, scr_h)
                    DRAG_ACTIVE = 0
                    GESTURE = 3
                    return
            mi: int64 = menubar_item_at(CUR_X, CUR_Y)
            opened: int32 = MENU_BAR_OPEN
            # A click on an Applications category row only opens its flyout
            # (it never launches directly), so keep the menu open there.
            if opened == 0 and mi >= 0 and mi < APPCAT_COUNT:
                SUBMENU_OPEN = mi
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            MENU_BAR_OPEN = -1                   # any other click closes the menu
            SUBMENU_OPEN = -1
            if mi >= 0:
                menubar_invoke(opened, cast[uint64](mi), scr_w, scr_h)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- ROUND-12: Show Desktop applet click ---
        if in_show_desktop_btn(CUR_X, CUR_Y, scr_w) != 0:
            show_desktop_toggle()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- ROUND-7: clock-applet click toggles the calendar popup ---
        if in_clock_zone(CUR_X, CUR_Y, scr_w) != 0:
            cal_toggle()
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # A click anywhere else while the calendar is open dismisses it
        # (clicks landing inside the popup are handled just below).
        if CAL_OPEN != 0:
            cdx: int64 = cal_drop_x(scr_w)
            cdy: int64 = cal_drop_y()
            if CUR_X >= cdx and CUR_X < cdx + CAL_W \
               and CUR_Y >= cdy and CUR_Y < cdy + cal_total_h():
                # Click inside the calendar: swallow it (the popup stays up).
                DRAG_ACTIVE = 0
                GESTURE = 3
                return
            CAL_OPEN = 0
            cc: Ptr[uint8] = "CAL close\n"
            sys_write(1, cc, strlen_u8(cc))
        # --- workspace pager press: arm a pager gesture (ROUND-10) ---
        # A press on a pager cell starts GESTURE==5. The up-edge decides:
        # release on a DIFFERENT cell drags the source desktop's focused
        # window there; release on the SAME cell switches to it (the old
        # click-to-switch behaviour). This is MATE's drag-window-between-
        # workspaces directly on the pager mini-map.
        pcell: int64 = pager_cell_at(CUR_X, CUR_Y, scr_w)
        if pcell >= 0:
            PAGER_DRAG = 1
            PAGER_DRAG_FROM = pcell
            GESTURE = 5
            DRAG_ACTIVE = 0
            return
        # --- taskbar button click: raise/restore the clicked window ---
        # ROUND-10: a grouped app's button cycles focus through the group;
        # a singleton button raises/restores its one window as before.
        tslot: int64 = taskbar_slot_at(CUR_X, CUR_Y, scr_w)
        if tslot >= 0:
            ts: uint64 = cast[uint64](tslot)
            if is_grouped(ts) != 0:
                grs: int64 = group_cycle(ts)             # returns raised UID
                tb_pfx3: Ptr[uint8] = "TASKBAR group-cycle uid "
                sys_write(1, tb_pfx3, strlen_u8(tb_pfx3))
                gv: uint64 = 0
                if grs >= 0:
                    gv = cast[uint64](grs)
                tgl: Array[24, uint8]
                tgn: uint64 = u64_to_dec(gv, &tgl[0])
                sys_write(1, &tgl[0], tgn)
            elif DWIN_HIDDEN[ts] != 0:
                # Restore: un-minimize then raise to focus.
                DWIN_HIDDEN[ts] = 0
                daemon_raise_slot(tslot)
                tb_pfx: Ptr[uint8] = "TASKBAR restore "
                sys_write(1, tb_pfx, strlen_u8(tb_pfx))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            else:
                # Raise the window (give it focus).
                daemon_raise_slot(tslot)
                tb_pfx2: Ptr[uint8] = "TASKBAR raise "
                sys_write(1, tb_pfx2, strlen_u8(tb_pfx2))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        if in_panel(CUR_X, CUR_Y) != 0:
            # Press on the panel bar (not the button) — swallow it so the
            # panel can never start a drag-create underneath itself.
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # Hit-test the topmost window under the cursor. A press on a
        # window's close box arms a close; a press on its title bar
        # starts a move (and raises it on top); anything else (empty
        # desktop, or a window body) begins a rubber-band create drag.
        hit: int64 = window_at(CUR_X, CUR_Y)
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1
        DRAG_ACTIVE = 0
        started_wm: int32 = 0
        if hit >= 0:
            hs: uint64 = cast[uint64](hit)
            if in_close_box(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 2                  # close: confirm on the up-edge
                CLOSE_SLOT = hit
                started_wm = 1
            elif in_minimize_box(hs, CUR_X, CUR_Y) != 0:
                # Minimize on press (immediate, no release confirm needed).
                DWIN_HIDDEN[hs] = 1
                GESTURE = 3                  # minimize: no further up-edge
                started_wm = 1
                mm: Ptr[uint8] = "WM minimize window\n"
                sys_write(1, mm, strlen_u8(mm))
            elif in_maximize_box(hs, CUR_X, CUR_Y) != 0:
                # Maximize / restore toggle (immediate on press).
                window_toggle_maximize(hs, scr_w, scr_h)
                GESTURE = 3                  # no further up-edge action
                started_wm = 1
            elif resize_dir_at(hs, CUR_X, CUR_Y) != 0:
                # ROUND-6: press on a window edge/corner grip -> resize.
                # Raise it first so the resize frame is on top, then arm the
                # interactive resize from the grabbed edge mask.
                hit = daemon_raise_slot(hit)
                hs = cast[uint64](hit)
                rdir: int32 = resize_dir_at(hs, CUR_X, CUR_Y)
                GESTURE = 4
                resize_begin(hit, rdir)
                started_wm = 1
            elif in_title_bar(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 1                  # move
                # Double-click the title bar -> toggle maximize (MATE
                # default). Detect a second press on the SAME window within
                # DBLCLICK_FRAMES of the previous title-bar press.
                dbl: int32 = 0
                if LAST_TCLICK_SLOT == hit \
                   and WM_FRAME - LAST_TCLICK_FRAME <= DBLCLICK_FRAMES:
                    dbl = 1
                LAST_TCLICK_SLOT = hit
                LAST_TCLICK_FRAME = WM_FRAME
                if dbl != 0:
                    window_toggle_maximize(cast[uint64](hit), scr_w, scr_h)
                    GESTURE = 3              # no move after a double-click
                    started_wm = 1
                    dm2: Ptr[uint8] = "WM dblclick maximize\n"
                    sys_write(1, dm2, strlen_u8(dm2))
                    # Reset so a third quick press doesn't re-trigger.
                    LAST_TCLICK_SLOT = -1
                    return
                # Raise the grabbed window to the top so it tracks above
                # the others, then capture the cursor->origin offset.
                hit = daemon_raise_slot(hit)
                hs = cast[uint64](hit)
                # If the window is snapped/maximized, un-snap it to its
                # float size first so dragging detaches it (GNOME feel).
                # Keep the cursor roughly over the title after the resize.
                if DWIN_SNAP[hs] != 0:
                    snap_apply(hs, 0, scr_w, scr_h)
                    if CUR_X > DWIN_X[hs] + DWIN_W[hs]:
                        DWIN_X[hs] = CUR_X - DWIN_W[hs] / 2
                        if DWIN_X[hs] < 0:
                            DWIN_X[hs] = 0
                MOVE_SLOT = hit
                MOVE_OFF_X = CUR_X - DWIN_X[hs]
                MOVE_OFF_Y = CUR_Y - DWIN_Y[hs]
                started_wm = 1
                m1: Ptr[uint8] = "WM move start\n"
                sys_write(1, m1, strlen_u8(m1))
            else:
                # Press inside a window body (not title, not close-box):
                # raise the window to the top to give it keyboard focus.
                # We do NOT start a rubber-band drag — the user clicked
                # inside an existing window to interact with its shell.
                # For built-in app windows, also route the click to the
                # app so e.g. the calculator keypad responds.
                if DWIN_APP[hs] == APP_CALC:
                    cell: int64 = calc_cell_at(hs, CUR_X, CUR_Y)
                    if cell >= 0:
                        calc_press(hs, calc_key_label(cell))
                        ck: Ptr[uint8] = "CALC key\n"
                        sys_write(1, ck, strlen_u8(ck))
                elif DWIN_APP[hs] == APP_SETTINGS:
                    srow: int64 = settings_row_at(hs, CUR_X, CUR_Y)
                    if srow >= 0:
                        settings_press(hs, srow)
                        sk: Ptr[uint8] = "SETTINGS row\n"
                        sys_write(1, sk, strlen_u8(sk))
                hit = daemon_raise_slot(hit)
                GESTURE = 3                  # body-focus: no up-edge action
                started_wm = 1
                m2: Ptr[uint8] = "WM focus window\n"
                sys_write(1, m2, strlen_u8(m2))
        if started_wm == 0:
            # No window-management gesture -> the empty-desktop
            # rubber-band create drag (unchanged behaviour).
            GESTURE = 0
            DRAG_ACTIVE = 1
            DRAG_X0 = CUR_X
            DRAG_Y0 = CUR_Y
    # --- button held: a move tracks the window under the grab ---
    if lbtn != 0 and GESTURE == 1 and MOVE_SLOT >= 0:
        ms: uint64 = cast[uint64](MOVE_SLOT)
        nx: int64 = CUR_X - MOVE_OFF_X
        ny: int64 = CUR_Y - MOVE_OFF_Y
        # Clamp so the window stays on-screen and never draws outside the
        # framebuffer. The top is clamped to PANEL_H so a window's title
        # bar can never slide under the panel and become un-grabbable.
        nx = iclamp(nx, 0, scr_w - DWIN_W[ms])
        ny = iclamp(ny, PANEL_H, scr_h - DWIN_H[ms])
        if nx < 0:
            nx = 0
        if ny < PANEL_H:
            ny = PANEL_H
        DWIN_X[ms] = nx
        DWIN_Y[ms] = ny
        # ROUND-5: live snap preview. As the cursor enters a screen edge or
        # corner during a title-bar drag, light up a translucent preview of
        # where the window would land if released now (MATE/GNOME edge
        # tiling). SNAP_PREVIEW_MODE/_ON drive the compositor overlay.
        pz: int32 = snap_zone_for(CUR_X, CUR_Y, scr_w, scr_h)
        SNAP_PREVIEW_MODE = pz
        if pz != 0:
            SNAP_PREVIEW_ON = 1
        else:
            SNAP_PREVIEW_ON = 0
    # --- button held: a resize tracks the grabbed edge under the cursor ---
    if lbtn != 0 and GESTURE == 4 and RESIZE_SLOT >= 0:
        resize_track(scr_w, scr_h)
    # --- left-button UP edge: resolve the gesture ---
    if lbtn == 0 and PREV_BTN_L != 0:
        if GESTURE == 5:
            # ROUND-10: pager gesture resolves on release. Release on a
            # different cell drags the source desktop's focused window
            # there; release on the same cell switches workspace.
            rcell: int64 = pager_cell_at(CUR_X, CUR_Y, scr_w)
            if rcell >= 0 and rcell != PAGER_DRAG_FROM \
               and PAGER_DRAG_FROM >= 0:
                pager_drag_window(cast[int32](PAGER_DRAG_FROM),
                                  cast[int32](rcell))
            else:
                workspace_switch(cast[int32](PAGER_DRAG_FROM))
            PAGER_DRAG = 0
            PAGER_DRAG_FROM = -1
        elif GESTURE == 2:
            # Close only if the release lands in the SAME window's close
            # box (rio-style click cancellation on drag-off).
            if CLOSE_SLOT >= 0:
                cs: uint64 = cast[uint64](CLOSE_SLOT)
                if cs < DWIN_COUNT and in_close_box(cs, CUR_X, CUR_Y) != 0:
                    daemon_close_slot(CLOSE_SLOT)
                    m2: Ptr[uint8] = "WM close window\n"
                    sys_write(1, m2, strlen_u8(m2))
        elif GESTURE == 1 and MOVE_SLOT >= 0:
            # Move finished — log the window's final origin so a
            # non-pixel test can assert it relocated.
            mvs: uint64 = cast[uint64](MOVE_SLOT)
            mline: Array[64, uint8]
            mp: uint64 = 0
            mpfx: Ptr[uint8] = "WM move done x="
            mk: uint64 = 0
            while mpfx[mk] != 0:
                mline[mp] = mpfx[mk]
                mp = mp + 1
                mk = mk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_X[mvs]), &mline[mp])
            # drop u64_to_dec's trailing newline, append " y="
            mp = mp - 1
            ysfx: Ptr[uint8] = " y="
            yk: uint64 = 0
            while ysfx[yk] != 0:
                mline[mp] = ysfx[yk]
                mp = mp + 1
                yk = yk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_Y[mvs]), &mline[mp])
            sys_write(1, &mline[0], mp)
            # --- edge/corner tiling: snap based on where the release landed.
            # ROUND-5 routes through snap_zone_for() so corners quarter-tile
            # (the pointer analogue of round-4's keyboard tiling): top edge
            # maximizes, sides half-tile, the four corners quarter-tile.
            zmode: int32 = snap_zone_for(CUR_X, CUR_Y, scr_w, scr_h)
            if zmode != 0:
                snap_apply(mvs, zmode, scr_w, scr_h)
                sn: Ptr[uint8] = "WM snap "
                sys_write(1, sn, strlen_u8(sn))
                zb: Array[4, uint8]
                zb[0] = cast[uint8](zmode) + 48
                zb[1] = 10
                sys_write(1, &zb[0], 2)
            # Clear any live snap preview now the drag has resolved.
            SNAP_PREVIEW_ON = 0
            SNAP_PREVIEW_MODE = 0
        elif GESTURE == 4 and RESIZE_SLOT >= 0:
            # ROUND-6: resize finished — commit the final rectangle.
            resize_track(scr_w, scr_h)
            resize_end()
        elif GESTURE == 0 and DRAG_ACTIVE != 0:
            # Empty-desktop drag -> maybe spawn a window.
            rx0: int64 = imin(DRAG_X0, CUR_X)
            ry0: int64 = imin(DRAG_Y0, CUR_Y)
            rx1: int64 = imax(DRAG_X0, CUR_X)
            ry1: int64 = imax(DRAG_Y0, CUR_Y)
            rw: int64 = rx1 - rx0
            rh: int64 = ry1 - ry0
            if rw >= DRAG_MIN and rh >= DRAG_MIN:
                daemon_spawn_window(rx0, ry0, rw, rh)
        # Reset all gesture state.
        DRAG_ACTIVE = 0
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1
        RESIZE_SLOT = -1
        RESIZE_DIR = 0
        SNAP_PREVIEW_ON = 0
        SNAP_PREVIEW_MODE = 0
        PAGER_DRAG = 0
        PAGER_DRAG_FROM = -1


def next_signed(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip up to a sign or digit, parse a (possibly signed) decimal.
    i: uint64 = pos[0]
    while i < total and buf[i] != 45 and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    neg: int32 = 0
    if i < total and buf[i] == 45:
        neg = 1
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    if neg != 0:
        return 0 - v
    return v


# Mouse-free WM self-test: drive a title-bar drag-move then a close-box
# click on the just-created autowin by calling the real gesture machine
# (wm_button) directly with ABSOLUTE cursor coordinates. This exercises
# the identical move/close/raise code paths a /dev/mouse packet would,
# but skips the packet string encode/decode round-trip entirely so the
# coordinates are exact and the result is deterministic.
def daemon_wm_selftest(scr_w: int64, scr_h: int64):
    if DWIN_COUNT == 0:
        return
    s: uint64 = DWIN_COUNT - 1
    PREV_BTN_L = 0
    # --- title-bar press: position the cursor inside the title bar (not
    # on the close box) and assert the left button down-edge. ---
    CUR_X = iclamp(DWIN_X[s] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[s] + TITLE_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- drag: relocate the cursor LEFT 200 / UP 30 with the button held;
    # wm_button tracks the grabbed window to follow. ---
    CUR_X = iclamp(CUR_X - 200, 0, scr_w - 1)
    CUR_Y = iclamp(CUR_Y - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- release: finalise the move (emits "WM move done x= y="). ---
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # The move raised the grabbed window to the top, so re-resolve its
    # slot (raise_slot bubbles it to DWIN_COUNT-1).
    cs: uint64 = DWIN_COUNT - 1
    # --- close: move the cursor onto the (relocated) window's close box,
    # then press+release inside it to destroy the window. ---
    CUR_X = iclamp(close_box_x(cs) + CLOSE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(close_box_y(cs) + CLOSE_BOX / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)       # press in close box -> arm close
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)       # release in close box -> destroy
    PREV_BTN_L = 0
    write_str(1, "DAEMON wm selftest done\n")


# Mouse-free PANEL/MENU self-test: drives the launcher through the SAME
# gesture machine (wm_button) real /dev/mouse packets reach, with
# absolute cursor coordinates. Sequence:
#   1. click the Applications button  -> "PANEL open menu"
#   2. click the first menu item      -> launches Terminal, closes menu
#                                        ("PANEL launch Terminal", a window)
#   3. click the button + an off-menu spot to prove open/dismiss is stable.
# Emits "DAEMON panel selftest done" at the end. No QEMU mouse injection.
def daemon_panel_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    MENU_OPEN = 0
    # --- click the Applications button: open the menu ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- ROUND-7: hover the first category (Accessories) to open its
    # submenu flyout, then click its first item (Terminal) to launch. ---
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    update_hover()                       # opens SUBMENU_OPEN = 0
    sxc: int64 = submenu_x() + SUBMENU_W / 2
    CUR_X = iclamp(sxc, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- re-open, then dismiss by clicking an off-menu desktop spot ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # Click far down on the empty desktop -> menu dismisses (no launch).
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "DAEMON panel selftest done\n")


# Terminal I/O self-test.
#
# Verifies the per-window stdin→shell→stdout→grid pipeline without a
# physical display or mouse, using the SAME pipe fds daemon_spawn_window
# created. Sequence:
#   1. Create one autowin (hamsh with real pipes).
#   2. Write "echo HAMUI_TERM_TEST\n" immediately to its stdin pipe.
#      The command sits in the pipe buffer until hamsh reads it.
#      (hamsh skips the getty-flush loop when stdin is DEVFD_PIPE_R,
#      so the bytes are NOT discarded — they arrive on the first
#      sys_read_nb(0,...) poll inside ed_readline.)
#   3. Non-blocking poll (sys_read_nb + sys_yield) the stdout pipe
#      until "HAMUI_TERM_TEST" appears in the terminal grid or the
#      idle counter (200000 empty reads) is exhausted.
#   4. Check the grid. PASS if the sentinel is present.
#
# Also verifies the focus-switch routing: create a SECOND window, click
# its body (synthetic wm_button on its body area) and confirm the focus
# slot switches, then route a second sentinel to that window.
#
# Emits "TERM IO PASS" / "TERM IO FAIL <reason>" on stdout.
# autoflag=5 in cmd_daemon_auto activates this test.
#
# ---- Taskbar / minimize / clock self-test (autoflag == 6) ----------
# Exercises the three new panel features deterministically without
# QEMU mouse injection:
#
#   1. TASKBAR: create two windows, assert DWIN_COUNT == 2, assert each
#      taskbar_btn_x() is within the panel, emit "TASKBAR 2 windows".
#   2. FOCUS via taskbar: simulate a taskbar click on slot 0 (lower window)
#      and assert it becomes the topmost slot (daemon_focus_slot()==1 after
#      raise), emit "TASKBAR focus OK".
#   3. MINIMIZE: simulate a minimize-box click on the topmost window, assert
#      DWIN_HIDDEN becomes 1, emit "TASKBAR minimize OK".
#   4. RESTORE: simulate a taskbar click on the minimized window, assert
#      DWIN_HIDDEN becomes 0, emit "TASKBAR restore OK".
#   5. CLOCK: call clock_refresh(0), assert clock_str is non-empty (not all
#      '?'), emit "TASKBAR clock OK" or "TASKBAR clock UNAVAILABLE".
#
# Emits "TASKBAR PASS" at the end.  autoflag==6 activates this test.
def daemon_taskbar_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    # --- Step 1: create two windows ---
    daemon_spawn_window(200, 80, 300, 200)
    daemon_spawn_window(300, 120, 300, 200)
    if DWIN_COUNT < 2:
        write_str(1, "TASKBAR FAIL: fewer than 2 windows spawned\n")
        return
    write_str(1, "TASKBAR 2 windows\n")
    # Assert taskbar buttons are within the screen (not off-screen).
    tb0x: int64 = taskbar_btn_x(0)
    tb1x: int64 = taskbar_btn_x(1)
    if tb0x < taskbar_start_x() or tb1x <= tb0x:
        write_str(1, "TASKBAR FAIL: bad button geometry\n")
        return
    write_str(1, "TASKBAR geometry OK\n")
    # --- Step 2: taskbar click on slot 0 to raise it ---
    # After two spawns, slot 0 = first window, slot 1 = topmost.
    # Click the taskbar button for slot 0.
    CUR_X = iclamp(tb0x + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise slot 0 should now be at DWIN_COUNT-1 (topmost / focused).
    new_top: int64 = daemon_focus_slot()
    if new_top < 0:
        write_str(1, "TASKBAR FAIL: no focused window after taskbar raise\n")
        return
    write_str(1, "TASKBAR focus OK\n")
    # --- Step 3: minimize the topmost window via its minimize box ---
    top_s: uint64 = cast[uint64](new_top)
    mx: int64 = iclamp(minimize_box_x(top_s) + MINIMIZE_BOX / 2, 0, scr_w - 1)
    my: int64 = iclamp(minimize_box_y(top_s) + MINIMIZE_BOX / 2, 0, scr_h - 1)
    CUR_X = mx
    CUR_Y = my
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_HIDDEN[top_s] == 0:
        write_str(1, "TASKBAR FAIL: minimize did not set DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR minimize OK\n")
    # --- Step 4: restore via taskbar click ---
    # The minimized window is still at slot top_s in the table.
    rst_tbx: int64 = taskbar_btn_x(top_s)
    CUR_X = iclamp(rst_tbx + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After restore DWIN_HIDDEN should be 0 (the window is visible again).
    # The slot may have been raised, so scan all slots for HIDDEN==0.
    all_visible: int32 = 1
    ci: uint64 = 0
    while ci < DWIN_COUNT:
        if DWIN_HIDDEN[ci] != 0:
            all_visible = 0
        ci = ci + 1
    if all_visible == 0:
        write_str(1, "TASKBAR FAIL: restore did not clear DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR restore OK\n")
    # --- Step 5: clock refresh ---
    clock_refresh(0)
    # The clock string should be non-empty (first char is a digit or '?').
    clk_ok: int32 = 0
    if clock_str[0] != 0:
        clk_ok = 1
    if clk_ok != 0:
        if clock_str[0] == 63:
            write_str(1, "TASKBAR clock UNAVAILABLE\n")
        else:
            write_str(1, "TASKBAR clock OK\n")
    else:
        write_str(1, "TASKBAR FAIL: clock_str empty after refresh\n")
        return
    write_str(1, "TASKBAR PASS\n")


# ====================================================================
# WORKSPACE self-test (autoflag == 9)
# ====================================================================
# Verifies MATE virtual desktops + the pager applet deterministically,
# sampling composited pixels so it works with no GUI:
#   1. Create a window on workspace 1; sample a body pixel -> visible.
#   2. Switch to workspace 2 (via workspace_switch); the SAME body pixel
#      must now be the desktop backdrop (window hidden by ws filter).
#   3. Switch back to workspace 1; the body pixel is visible again.
#   4. Pager click: synthesise a left-click on pager cell 3 and assert
#      CUR_WS becomes 2 (0-based) i.e. desktop 3.
#   5. F-key hotkey path: call workspace_switch directly via the same
#      entry the key pump uses; assert it lands.
# Emits "[DE_ws] PASS" / "[DE_ws] FAIL <reason>".
def daemon_workspace_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    # --- Step 1: window on workspace 1 (CUR_WS==0) ---
    win_x: int64 = 300
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 220
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[DE_ws] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    # A body pixel (clear of title bar + borders).
    bx: int64 = DWIN_X[sl] + DWIN_W[sl] / 2
    by: int64 = DWIN_Y[sl] + TITLE_H + 30
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    s1: uint64 = daemon_screen_sample(bx, by)
    if s1 == bg:
        write_str(1, "[DE_ws] FAIL window not visible on its own workspace\n")
        return
    write_str(1, "[DE_ws] window visible on ws1\n")
    # --- Step 2: switch to workspace 2; body pixel must be backdrop ---
    workspace_switch(1)
    if CUR_WS != 1:
        write_str(1, "[DE_ws] FAIL workspace_switch did not change CUR_WS\n")
        return
    s2: uint64 = daemon_screen_sample(bx, by)
    if s2 != bg:
        write_str(1, "[DE_ws] FAIL window still visible after ws switch\n")
        return
    write_str(1, "[DE_ws] window hidden on ws2\n")
    # --- Step 3: switch back; window visible again ---
    workspace_switch(0)
    s3: uint64 = daemon_screen_sample(bx, by)
    if s3 == bg:
        write_str(1, "[DE_ws] FAIL window not restored on ws1\n")
        return
    write_str(1, "[DE_ws] window restored on ws1\n")
    # --- Step 4: pager click switches workspace ---
    px0: int64 = pager_x0(scr_w)
    cell3_cx: int64 = px0 + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    CUR_X = iclamp(cell3_cx, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CUR_WS != 2:
        write_str(1, "[DE_ws] FAIL pager click did not switch workspace\n")
        return
    write_str(1, "[DE_ws] pager click OK\n")
    # --- Step 5: hotkey-path workspace switch (same entry the key pump uses) ---
    workspace_switch(0)
    if CUR_WS != 0:
        write_str(1, "[DE_ws] FAIL hotkey-path switch failed\n")
        return
    write_str(1, "[DE_ws] hotkey path OK\n")
    daemon_present()
    write_str(1, "[DE_ws] PASS\n")


# ====================================================================
# DECORATION self-test (autoflag == 10)
# ====================================================================
# Verifies the MATE-style themed window decorations by sampling pixels:
#   1. Title-bar gradient: the top row and bottom row of an active
#      window's title bar must differ (a real gradient, not a flat fill).
#   2. Beveled border: the top-left outer corner is the light highlight
#      tint, the bottom-right outer corner is the dark shadow tint.
#   3. Maximize button: a pixel inside the maximize box is the button
#      colour (green-ish), and the box hit-tests true.
#   4. Maximize/restore toggle: click the maximize box; the window fills
#      the work area; click again; it returns to its saved rectangle.
# Emits "[DE_deco] PASS" / "[DE_deco] FAIL <reason>".
def daemon_decoration_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    win_x: int64 = 200
    win_y: int64 = 140
    win_w: int64 = 360
    win_h: int64 = 240
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[DE_deco] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wx: int64 = DWIN_X[sl]
    wy: int64 = DWIN_Y[sl]
    ww: int64 = DWIN_W[sl]
    wh: int64 = DWIN_H[sl]
    # --- Step 1: title-bar gradient (top vs bottom rows differ) ---
    tx: int64 = wx + ww / 2          # mid title bar, clear of buttons + text
    top_px: uint64 = daemon_screen_sample(tx, wy + 3)
    bot_px: uint64 = daemon_screen_sample(tx, wy + TITLE_H - 2)
    if top_px == bot_px:
        write_str(1, "[DE_deco] FAIL title bar is flat (no gradient)\n")
        return
    write_str(1, "[DE_deco] title gradient OK\n")
    # --- Step 2: beveled border corners ---
    tl: uint64 = daemon_screen_sample(wx, wy)
    br: uint64 = daemon_screen_sample(wx + ww - 1, wy + wh - 1)
    hi: uint64 = (cast[uint64](BEVEL_HI_R) << 16) \
        | (cast[uint64](BEVEL_HI_G) << 8) | cast[uint64](BEVEL_HI_B)
    lo: uint64 = (cast[uint64](BEVEL_LO_R) << 16) \
        | (cast[uint64](BEVEL_LO_G) << 8) | cast[uint64](BEVEL_LO_B)
    if tl != hi:
        write_str(1, "[DE_deco] FAIL top-left corner not highlight bevel\n")
        return
    if br != lo:
        write_str(1, "[DE_deco] FAIL bottom-right corner not shadow bevel\n")
        return
    write_str(1, "[DE_deco] beveled border OK\n")
    # --- Step 3: maximize button present ---
    if in_maximize_box(sl, maximize_box_x(sl) + 1, maximize_box_y(sl) + 1) == 0:
        write_str(1, "[DE_deco] FAIL maximize box hit-test failed\n")
        return
    write_str(1, "[DE_deco] maximize button OK\n")
    # --- Step 4: maximize/restore toggle via the maximize box click ---
    sav_w: int64 = DWIN_W[sl]
    sav_h: int64 = DWIN_H[sl]
    CUR_X = iclamp(maximize_box_x(sl) + MAXIMIZE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(maximize_box_y(sl) + MAXIMIZE_BOX / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_MAXED[sl] == 0:
        write_str(1, "[DE_deco] FAIL maximize did not set MAXED\n")
        return
    if DWIN_W[sl] != scr_w or DWIN_H[sl] != scr_h - PANEL_H:
        write_str(1, "[DE_deco] FAIL maximized geometry wrong\n")
        return
    write_str(1, "[DE_deco] maximize OK\n")
    # Restore: click the (relocated) maximize box again.
    CUR_X = iclamp(maximize_box_x(sl) + MAXIMIZE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(maximize_box_y(sl) + MAXIMIZE_BOX / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_MAXED[sl] != 0:
        write_str(1, "[DE_deco] FAIL restore did not clear MAXED\n")
        return
    if DWIN_W[sl] != sav_w or DWIN_H[sl] != sav_h:
        write_str(1, "[DE_deco] FAIL restore geometry not original\n")
        return
    write_str(1, "[DE_deco] restore OK\n")
    daemon_present()
    write_str(1, "[DE_deco] PASS\n")


# ====================================================================
# CONTEXT-MENU self-test (autoflag == 11)
# ====================================================================
# Verifies right-click context menus + the GNOME2 menu bar:
#   1. Menu bar: three top-level buttons hit-test (Applications/Places/
#      System); open Applications via wm_button + assert MENU_BAR_OPEN.
#   2. Desktop context menu: right-click empty desktop (wm_rbutton) opens
#      a 2-item menu (CTX_OPEN, CTX_KIND==0); sample a menu pixel to prove
#      it composites; left-click item 0 spawns a New Terminal window.
#   3. Window context menu: right-click a window title bar opens the
#      window menu (CTX_KIND==1); left-click "Close" destroys the window.
# Emits "[DE_ctx] PASS" / "[DE_ctx] FAIL <reason>".
def daemon_ctxmenu_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    MENU_BAR_OPEN = -1
    CTX_OPEN = 0
    # --- Step 1: menu bar hit-test + open ---
    if menubar_btn_at(menubar_btn_x(0) + 2, PANEL_H / 2) != 0:
        write_str(1, "[DE_ctx] FAIL Applications button hit-test\n")
        return
    if menubar_btn_at(menubar_btn_x(2) + 2, PANEL_H / 2) != 2:
        write_str(1, "[DE_ctx] FAIL System button hit-test\n")
        return
    write_str(1, "[DE_ctx] menu bar geometry OK\n")
    CUR_X = iclamp(menubar_btn_x(0) + 4, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if MENU_BAR_OPEN != 0:
        write_str(1, "[DE_ctx] FAIL Applications menu did not open\n")
        return
    write_str(1, "[DE_ctx] Applications menu open\n")
    # Close it again (click the same button).
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- Step 2: desktop context menu via right-click ---
    CUR_X = iclamp(scr_w / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h / 2, 0, scr_h - 1)
    PREV_BTN_R = 0
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    wm_rbutton(0, scr_w, scr_h)
    PREV_BTN_R = 0
    if CTX_OPEN == 0 or CTX_KIND != 0:
        write_str(1, "[DE_ctx] FAIL desktop context menu did not open\n")
        return
    # Sample a pixel inside the menu body to prove it composites.
    msx: int64 = CTX_X + CTX_W / 2
    msy: int64 = CTX_Y + CTX_ITEM_H / 2
    mpx: uint64 = daemon_screen_sample(msx, msy)
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    if mpx == bg:
        write_str(1, "[DE_ctx] FAIL context menu not composited\n")
        return
    write_str(1, "[DE_ctx] desktop context menu OK\n")
    # Left-click item 0 (New Terminal) -> spawns a window.
    before: uint64 = DWIN_COUNT
    CUR_X = iclamp(CTX_X + CTX_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(CTX_Y + CTX_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT <= before:
        write_str(1, "[DE_ctx] FAIL New Terminal did not spawn a window\n")
        return
    if CTX_OPEN != 0:
        write_str(1, "[DE_ctx] FAIL context menu did not close on click\n")
        return
    write_str(1, "[DE_ctx] New Terminal spawned\n")
    # --- Step 3: window context menu -> Close ---
    sl: uint64 = DWIN_COUNT - 1
    # Right-click the window's title bar.
    CUR_X = iclamp(DWIN_X[sl] + 40, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[sl] + TITLE_H / 2, 0, scr_h - 1)
    PREV_BTN_R = 0
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    wm_rbutton(0, scr_w, scr_h)
    PREV_BTN_R = 0
    if CTX_OPEN == 0 or CTX_KIND != 1:
        write_str(1, "[DE_ctx] FAIL window context menu did not open\n")
        return
    write_str(1, "[DE_ctx] window context menu OK\n")
    # Click the LAST item ("Close").
    last_item: int64 = cast[int64](ctx_count()) - 1
    wcnt: uint64 = DWIN_COUNT
    CUR_X = iclamp(CTX_X + CTX_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(CTX_Y + last_item * CTX_ITEM_H + CTX_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT >= wcnt:
        write_str(1, "[DE_ctx] FAIL Close did not destroy the window\n")
        return
    write_str(1, "[DE_ctx] window closed via context menu\n")
    daemon_present()
    write_str(1, "[DE_ctx] PASS\n")


# ---- Desktop-apps + snapping self-test (autoflag == 12) ------------
# Exercises the new built-in apps and window snapping deterministically
# (no mouse injection): a calculator computes 7+8=15 + a div-by-zero
# guard, the System Monitor refreshes live stats, and a window snaps to
# the left half then maximizes/restores. Emits "APPS PASS" on success,
# "APPS FAIL <reason>" otherwise.
apps_test_buf: Array[24, uint8]
def daemon_apps_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: calculator window + 7 + 8 = 15 ---
    daemon_spawn_app(APP_CALC, 100, 80, 220, 300)
    if DWIN_COUNT == 0:
        write_str(1, "APPS FAIL: calc not spawned\n")
        return
    cs: uint64 = DWIN_COUNT - 1
    if DWIN_APP[cs] != APP_CALC:
        write_str(1, "APPS FAIL: window is not a calculator\n")
        return
    write_str(1, "APPS calc window OK\n")
    calc_press(cs, 55)            # '7'
    calc_press(cs, 43)            # '+'
    calc_press(cs, 56)            # '8'
    calc_press(cs, 61)            # '='
    n: uint64 = calc_format(cs, &apps_test_buf[0])
    if n != 2 or apps_test_buf[0] != 49 or apps_test_buf[1] != 53:
        write_str(1, "APPS FAIL: 7+8 did not equal 15\n")
        return
    write_str(1, "APPS calc 7+8=15 OK\n")
    # Divide-by-zero -> error flag.
    calc_press(cs, 67)            # 'C'
    calc_press(cs, 53)            # '5'
    calc_press(cs, 47)            # '/'
    calc_press(cs, 48)            # '0'
    calc_press(cs, 61)            # '='
    if CALC_ERR[cs] == 0:
        write_str(1, "APPS FAIL: div-by-zero not flagged\n")
        return
    write_str(1, "APPS calc div0 OK\n")
    # --- Step 2: system monitor refresh ---
    daemon_spawn_app(APP_SYSMON, 360, 80, 360, 220)
    sysmon_refresh(0)
    if sysmon_line1[0] == 0:
        write_str(1, "APPS FAIL: sysmon line empty\n")
        return
    write_str(1, "APPS sysmon OK\n")
    # --- Step 3: snapping (left half, then maximize toggle/restore) ---
    sm_slot: uint64 = DWIN_COUNT - 1
    float_x: int64 = DWIN_X[sm_slot]
    float_w: int64 = DWIN_W[sm_slot]
    snap_apply(sm_slot, 2, scr_w, scr_h)   # left half
    if DWIN_X[sm_slot] != 0 or DWIN_W[sm_slot] != scr_w / 2 or DWIN_SNAP[sm_slot] != 2:
        write_str(1, "APPS FAIL: left-snap geometry wrong\n")
        return
    write_str(1, "APPS snap-left OK\n")
    # Toggle maximize while snapped restores to the saved float geometry.
    window_toggle_maximize(sm_slot, scr_w, scr_h)
    if DWIN_SNAP[sm_slot] != 0 or DWIN_X[sm_slot] != float_x or DWIN_W[sm_slot] != float_w:
        write_str(1, "APPS FAIL: restore from snap wrong\n")
        return
    write_str(1, "APPS restore OK\n")
    # Toggle maximize from float -> maximized full-screen.
    window_toggle_maximize(sm_slot, scr_w, scr_h)
    if DWIN_W[sm_slot] != scr_w or DWIN_SNAP[sm_slot] != 1:
        write_str(1, "APPS FAIL: maximize geometry wrong\n")
        return
    write_str(1, "APPS maximize OK\n")
    write_str(1, "APPS PASS\n")


# ====================================================================
# ROUND-3 MATE-feel self-test (autoflag == 13)
# ====================================================================
# Exercises the round-3 desktop features deterministically, mouse-free:
#   1. ALT-TAB CYCLER: with 3 windows, cycle_step(1) opens the switcher
#      selecting window 2, a second step selects window 3, cycle_commit()
#      raises the selected window to the front. Asserts CYCLE_OPEN toggles
#      and the chosen window lands on top.
#   2. DOUBLE-CLICK MAXIMIZE: two title-bar presses on the same window
#      within DBLCLICK_FRAMES toggles maximize (DWIN_SNAP==1).
#   3. CHANGE BACKGROUND: bg_cycle() advances ROOT_* to a new palette
#      entry (the colour actually changes).
#   4. ARRANGE WINDOWS: windows_arrange() un-maximizes + tiles all visible
#      windows into a grid (no window left maximized; geometry changed).
#   5. NOTIFICATION + PAGER geometry: the tray sits left of the clock and
#      right of the pager without overlap.
# Emits "[DE3] PASS" / "[DE3] FAIL <reason>".
def daemon_round3_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    CYCLE_OPEN = 0
    bg_palette_init()
    # --- Step 1: three windows + alt-tab cycler ---
    daemon_spawn_window(120, 80, 280, 180)
    daemon_spawn_window(220, 120, 280, 180)
    daemon_spawn_window(320, 160, 280, 180)
    if DWIN_COUNT < 3:
        write_str(1, "[DE3] FAIL fewer than 3 windows\n")
        return
    front_wid_before: int32 = DWIN_WID[DWIN_COUNT - 1]
    cycle_step(1)
    if CYCLE_OPEN == 0:
        write_str(1, "[DE3] FAIL cycler did not open\n")
        return
    if CYCLE_SEL != 1:
        write_str(1, "[DE3] FAIL cycler start sel wrong\n")
        return
    cycle_step(1)
    if CYCLE_SEL != 2:
        write_str(1, "[DE3] FAIL cycler advance wrong\n")
        return
    # The window we'll commit to is the one at cycler position 2.
    target_slot: int64 = cycle_slot_for_pos(2)
    target_wid: int32 = -1
    if target_slot >= 0:
        target_wid = DWIN_WID[cast[uint64](target_slot)]
    cycle_commit()
    if CYCLE_OPEN != 0:
        write_str(1, "[DE3] FAIL cycler did not close on commit\n")
        return
    # The committed window must now be the front-most (topmost) window.
    if DWIN_WID[DWIN_COUNT - 1] != target_wid:
        write_str(1, "[DE3] FAIL committed window not raised\n")
        return
    if front_wid_before == DWIN_WID[DWIN_COUNT - 1]:
        write_str(1, "[DE3] FAIL focus unchanged after cycle\n")
        return
    write_str(1, "[DE3] cycler OK\n")
    # --- Step 2: double-click title bar -> maximize ---
    top2: uint64 = DWIN_COUNT - 1
    DWIN_SNAP[top2] = 0
    DWIN_MAXED[top2] = 0
    tcx: int64 = iclamp(DWIN_X[top2] + 30, 0, scr_w - 1)
    tcy: int64 = iclamp(DWIN_Y[top2] + 4, 0, scr_h - 1)
    CUR_X = tcx
    CUR_Y = tcy
    # First click on the title bar.
    LAST_TCLICK_SLOT = -1
    WM_FRAME = 100
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # Second click shortly after (same slot, within DBLCLICK_FRAMES).
    WM_FRAME = 110
    # Re-aim at the (possibly raised) top window's title bar.
    top2 = DWIN_COUNT - 1
    CUR_X = iclamp(DWIN_X[top2] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[top2] + 4, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    maxed_any: int32 = 0
    di3: uint64 = 0
    while di3 < DWIN_COUNT:
        if DWIN_SNAP[di3] == 1 or DWIN_MAXED[di3] != 0:
            maxed_any = 1
        di3 = di3 + 1
    if maxed_any == 0:
        write_str(1, "[DE3] FAIL double-click did not maximize\n")
        return
    write_str(1, "[DE3] dblclick maximize OK\n")
    # --- Step 3: change background ---
    bgr0: uint8 = ROOT_R
    bgg0: uint8 = ROOT_G
    bgb0: uint8 = ROOT_B
    bg_cycle()
    if ROOT_R == bgr0 and ROOT_G == bgg0 and ROOT_B == bgb0:
        write_str(1, "[DE3] FAIL background did not change\n")
        return
    write_str(1, "[DE3] background OK\n")
    # --- Step 4: arrange windows (un-maximizes + tiles) ---
    windows_arrange(scr_w, scr_h)
    still_maxed: int32 = 0
    da: uint64 = 0
    while da < DWIN_COUNT:
        if DWIN_SNAP[da] != 0 or DWIN_MAXED[da] != 0:
            still_maxed = 1
        da = da + 1
    if still_maxed != 0:
        write_str(1, "[DE3] FAIL arrange left a window maximized\n")
        return
    write_str(1, "[DE3] arrange OK\n")
    # --- Step 5: notification-area + pager geometry (no overlap) ---
    ntfx: int64 = notif_x0(scr_w)
    pgx: int64 = pager_x0(scr_w)
    clkx: int64 = scr_w - CLOCK_W
    if pgx + pager_total_w() > ntfx:
        write_str(1, "[DE3] FAIL pager overlaps notification area\n")
        return
    if ntfx + NOTIF_W > clkx:
        write_str(1, "[DE3] FAIL notification overlaps clock\n")
        return
    write_str(1, "[DE3] tray geometry OK\n")
    daemon_present()
    write_str(1, "[DE3] PASS\n")


# ====================================================================
# ROUND-4 MATE-feel self-test (autoflag == 14)
# ====================================================================
# Mouse-free exercise of the round-4 features for CI:
#   1. THEME accent cycling: theme_cycle() changes the live ACCENT_* the
#      title-bar gradient reads; wraps after THEME_COUNT.
#   2. BACKGROUND + PANEL position prefs (persist in-memory).
#   3. KEYBOARD TILING: tile_focused() half/quarter-tiles the focused
#      window (DWIN_SNAP set to the requested mode, geometry within the
#      work area); restore via snap_apply(...,0,...).
#   4. SHOW-DESKTOP toggle minimizes all visible windows then restores
#      exactly that set.
#   5. MOVE-WINDOW-TO-WORKSPACE with wrap-around (window leaves CUR_WS).
#   6. SETTINGS app: settings_press() drives each row (theme/bg/panel).
# Emits "[DE4] PASS" / "[DE4] FAIL <reason>".
def daemon_round4_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    SHOWDESK_ON = 0
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: theme accent cycling ---
    a_top0: uint8 = ACCENT_TOP_R
    a_bot0: uint8 = ACCENT_BOT_B
    theme_cycle()
    if ACCENT_TOP_R == a_top0 and ACCENT_BOT_B == a_bot0:
        write_str(1, "[DE4] FAIL theme accent did not change\n")
        return
    if THEME_IDX != 1:
        write_str(1, "[DE4] FAIL theme idx wrong\n")
        return
    # Wrap: cycle THEME_COUNT-1 more times to come back to 0.
    twrap: int32 = 1
    while twrap < THEME_COUNT:
        theme_cycle()
        twrap = twrap + 1
    if THEME_IDX != 0:
        write_str(1, "[DE4] FAIL theme did not wrap\n")
        return
    write_str(1, "[DE4] theme OK\n")
    # --- Step 2: background + panel position prefs ---
    bgr0: uint8 = ROOT_R
    bgg0: uint8 = ROOT_G
    bgb0: uint8 = ROOT_B
    bg_cycle()
    if ROOT_R == bgr0 and ROOT_G == bgg0 and ROOT_B == bgb0:
        write_str(1, "[DE4] FAIL background did not change\n")
        return
    if PANEL_POS != 0:
        write_str(1, "[DE4] FAIL panel pos not default\n")
        return
    panel_pos_toggle()
    if PANEL_POS != 1:
        write_str(1, "[DE4] FAIL panel pos did not toggle\n")
        return
    panel_pos_toggle()
    if PANEL_POS != 0:
        write_str(1, "[DE4] FAIL panel pos did not toggle back\n")
        return
    write_str(1, "[DE4] prefs OK\n")
    # --- Step 3: keyboard tiling (half + quarter) ---
    daemon_spawn_window(140, 90, 300, 200)
    if DWIN_COUNT < 1:
        write_str(1, "[DE4] FAIL no window for tiling\n")
        return
    tslot: uint64 = DWIN_COUNT - 1
    # Left half (mode 2).
    tile_focused(2, scr_w, scr_h)
    if DWIN_SNAP[tslot] != 2:
        write_str(1, "[DE4] FAIL left-half tile mode wrong\n")
        return
    if DWIN_X[tslot] != 0 or DWIN_W[tslot] != scr_w / 2:
        write_str(1, "[DE4] FAIL left-half geometry wrong\n")
        return
    # Top-right quarter (mode 5).
    tile_focused(5, scr_w, scr_h)
    if DWIN_SNAP[tslot] != 5:
        write_str(1, "[DE4] FAIL quarter tile mode wrong\n")
        return
    qexp_x: int64 = scr_w / 2
    qexp_h: int64 = (scr_h - PANEL_H) / 2
    if DWIN_X[tslot] != qexp_x or DWIN_Y[tslot] != PANEL_H \
       or DWIN_H[tslot] != qexp_h:
        write_str(1, "[DE4] FAIL quarter geometry wrong\n")
        return
    # Restore to float.
    snap_apply(tslot, 0, scr_w, scr_h)
    if DWIN_SNAP[tslot] != 0:
        write_str(1, "[DE4] FAIL tile restore failed\n")
        return
    write_str(1, "[DE4] tiling OK\n")
    # --- Step 4: show-desktop toggle ---
    daemon_spawn_window(200, 120, 280, 180)
    vis_before: int64 = 0
    ci: uint64 = 0
    while ci < DWIN_COUNT:
        if win_on_cur_ws(ci) != 0:
            vis_before = vis_before + 1
        ci = ci + 1
    if vis_before < 2:
        write_str(1, "[DE4] FAIL fewer than 2 visible windows\n")
        return
    show_desktop_toggle()
    vis_mid: int64 = 0
    cj: uint64 = 0
    while cj < DWIN_COUNT:
        if win_on_cur_ws(cj) != 0:
            vis_mid = vis_mid + 1
        cj = cj + 1
    if vis_mid != 0:
        write_str(1, "[DE4] FAIL show-desktop did not minimize all\n")
        return
    show_desktop_toggle()
    vis_after: int64 = 0
    ck: uint64 = 0
    while ck < DWIN_COUNT:
        if win_on_cur_ws(ck) != 0:
            vis_after = vis_after + 1
        ck = ck + 1
    if vis_after != vis_before:
        write_str(1, "[DE4] FAIL show-desktop did not restore set\n")
        return
    write_str(1, "[DE4] show-desktop OK\n")
    # --- Step 5: move focused window to next workspace (wrap-around) ---
    mslot: uint64 = DWIN_COUNT - 1
    DWIN_WS[mslot] = WS_COUNT - 1          # force the wrap edge
    CUR_WS = WS_COUNT - 1
    nws3: int32 = CUR_WS + 1
    if nws3 >= WS_COUNT:
        nws3 = 0
    window_to_workspace(mslot, nws3)
    if DWIN_WS[mslot] != 0:
        write_str(1, "[DE4] FAIL move-to-workspace wrap wrong\n")
        return
    if win_on_cur_ws(mslot) != 0:
        write_str(1, "[DE4] FAIL window still visible after move\n")
        return
    CUR_WS = 0
    write_str(1, "[DE4] move-to-ws OK\n")
    # --- Step 6: Settings app rows ---
    sx: int64 = 120
    sy: int64 = PANEL_H + 30
    daemon_spawn_app(APP_SETTINGS, sx, sy, 320, 200)
    sslot: uint64 = DWIN_COUNT - 1
    if DWIN_APP[sslot] != APP_SETTINGS:
        write_str(1, "[DE4] FAIL settings window not created\n")
        return
    # Theme row.
    th0: int32 = THEME_IDX
    settings_press(sslot, 0)
    if THEME_IDX == th0:
        write_str(1, "[DE4] FAIL settings theme row inert\n")
        return
    # Panel row.
    pp0: int32 = PANEL_POS
    settings_press(sslot, 2)
    if PANEL_POS == pp0:
        write_str(1, "[DE4] FAIL settings panel row inert\n")
        return
    # Row hit-test: the row-2 centre must map back to row 2.
    rcy: int64 = settings_row_y(sslot, 2) + 4
    rcx: int64 = DWIN_X[sslot] + 20
    if settings_row_at(sslot, rcx, rcy) != 2:
        write_str(1, "[DE4] FAIL settings row hit-test wrong\n")
        return
    # Reset row restores defaults (Reset is the last row; ROUND-8 added a
    # Workspaces row so Reset moved to index 5).
    settings_press(sslot, 5)
    if THEME_IDX != 0 or PANEL_POS != 0 or BG_IDX != 0:
        write_str(1, "[DE4] FAIL settings reset did not restore defaults\n")
        return
    write_str(1, "[DE4] settings OK\n")
    daemon_present()
    write_str(1, "[DE4] PASS\n")


# ====================================================================
# ROUND-5 MATE-feel self-test (autoflag == 15)
# ====================================================================
# Mouse-free exercise of the round-5 features for CI:
#   1. MRU Alt-Tab order: focusing windows reorders the cycler so a single
#      cycle toggles between the two most-recently-used windows (not just
#      stacking order); closing one drops it from the MRU list.
#   2. EDGE/CORNER snap classification: snap_zone_for() maps cursor points
#      to maximize / half / quarter modes, and snap_zone_rect() yields the
#      matching landing geometry.
#   3. LIVE SNAP PREVIEW: a title-bar drag into a corner lights up
#      SNAP_PREVIEW_ON with the right mode; the release commits a quarter
#      tile via the real gesture machine.
#   4. LIVE TRAY BADGE: notif_count_refresh() tracks the visible-window
#      count and the tray reserves a third cell for it.
#   5. PAGER click-to-switch: a synthesized panel left-click on a pager
#      cell switches the current workspace.
#   6. DESKTOP CONTEXT MENU: the round-5 desktop menu now offers a Settings
#      row that spawns the preferences window.
# Emits "[DE5] PASS" / "[DE5] FAIL <reason>".
def daemon_round5_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    SNAP_PREVIEW_ON = 0
    SNAP_PREVIEW_MODE = 0
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: MRU Alt-Tab order ---
    daemon_spawn_window(120, 80, 280, 180)     # slot 0
    daemon_spawn_window(220, 120, 280, 180)    # slot 1
    daemon_spawn_window(320, 160, 280, 180)    # slot 2
    if DWIN_COUNT < 3:
        write_str(1, "[DE5] FAIL fewer than 3 windows\n")
        return
    # Focus order: raise slot 0, then slot for the original middle window,
    # establishing a deterministic MRU history independent of stacking.
    uid_a: int32 = DWIN_UID[0]
    uid_b: int32 = DWIN_UID[1]
    uid_c: int32 = DWIN_UID[2]
    daemon_raise_slot(slot_for_uid(uid_a))     # MRU: [a]
    daemon_raise_slot(slot_for_uid(uid_c))     # MRU: [c, a]
    daemon_raise_slot(slot_for_uid(uid_b))     # MRU: [b, c, a]
    # Cycler position 0 must be the most-recently-focused window (b),
    # position 1 the one before it (c).
    p0: int64 = mru_slot_for_pos(0)
    p1: int64 = mru_slot_for_pos(1)
    p2: int64 = mru_slot_for_pos(2)
    if p0 < 0 or DWIN_UID[cast[uint64](p0)] != uid_b:
        write_str(1, "[DE5] FAIL MRU pos0 not most-recent\n")
        return
    if p1 < 0 or DWIN_UID[cast[uint64](p1)] != uid_c:
        write_str(1, "[DE5] FAIL MRU pos1 wrong\n")
        return
    if p2 < 0 or DWIN_UID[cast[uint64](p2)] != uid_a:
        write_str(1, "[DE5] FAIL MRU pos2 wrong\n")
        return
    # A single Alt+Tab (open at pos 1) commits the second-most-recent (c).
    CYCLE_OPEN = 0
    cycle_step(1)
    if CYCLE_OPEN == 0 or CYCLE_SEL != 1:
        write_str(1, "[DE5] FAIL cycler did not open at MRU pos1\n")
        return
    cycle_commit()
    if DWIN_UID[DWIN_COUNT - 1] != uid_c:
        write_str(1, "[DE5] FAIL Alt-Tab did not raise MRU window\n")
        return
    write_str(1, "[DE5] MRU OK\n")
    # MRU drop on close: closing the front window (c) removes it from MRU.
    mru_len_before: uint64 = MRU_LEN
    daemon_close_slot(cast[int64](DWIN_COUNT - 1))
    if MRU_LEN >= mru_len_before:
        write_str(1, "[DE5] FAIL MRU not pruned on close\n")
        return
    di: uint64 = 0
    while di < MRU_LEN:
        if MRU_UID[di] == uid_c:
            write_str(1, "[DE5] FAIL closed window still in MRU\n")
            return
        di = di + 1
    write_str(1, "[DE5] MRU-drop OK\n")
    # --- Step 2: edge/corner snap-zone classification + geometry ---
    # Top edge -> maximize (1).
    if snap_zone_for(scr_w / 2, PANEL_H + 1, scr_w, scr_h) != 1:
        write_str(1, "[DE5] FAIL top edge not maximize\n")
        return
    # Left edge (mid-height) -> left half (2).
    if snap_zone_for(1, scr_h / 2, scr_w, scr_h) != 2:
        write_str(1, "[DE5] FAIL left edge not half\n")
        return
    # Right edge -> right half (3).
    if snap_zone_for(scr_w - 1, scr_h / 2, scr_w, scr_h) != 3:
        write_str(1, "[DE5] FAIL right edge not half\n")
        return
    # Top-left corner -> quarter (4).
    if snap_zone_for(1, PANEL_H + 1, scr_w, scr_h) != 4:
        write_str(1, "[DE5] FAIL TL corner not quarter\n")
        return
    # Bottom-right corner -> quarter (7).
    if snap_zone_for(scr_w - 1, scr_h - 1, scr_w, scr_h) != 7:
        write_str(1, "[DE5] FAIL BR corner not quarter\n")
        return
    # Centre -> no snap (0).
    if snap_zone_for(scr_w / 2, scr_h / 2, scr_w, scr_h) != 0:
        write_str(1, "[DE5] FAIL centre snaps\n")
        return
    # snap_zone_rect for the top-right quarter must match snap_apply mode 5.
    snap_zone_rect(5, scr_w, scr_h)
    if snapzone_x != scr_w / 2 or snapzone_y != PANEL_H \
       or snapzone_h != (scr_h - PANEL_H) / 2:
        write_str(1, "[DE5] FAIL quarter rect geometry wrong\n")
        return
    write_str(1, "[DE5] snap-zones OK\n")
    # --- Step 3: live snap preview during a real title-bar drag ---
    daemon_spawn_window(200, 120, 300, 200)
    ds: uint64 = DWIN_COUNT - 1
    DWIN_SNAP[ds] = 0
    DWIN_MAXED[ds] = 0
    PREV_BTN_L = 0
    # Press on the title bar.
    CUR_X = iclamp(DWIN_X[ds] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[ds] + 4, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # Drag the cursor into the top-left corner: the preview must light up
    # with the quarter mode (4).
    CUR_X = 2
    CUR_Y = PANEL_H + 2
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if SNAP_PREVIEW_ON == 0 or SNAP_PREVIEW_MODE != 4:
        write_str(1, "[DE5] FAIL snap preview not active in corner\n")
        return
    # Release: commits the quarter snap, clears the preview.
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if SNAP_PREVIEW_ON != 0:
        write_str(1, "[DE5] FAIL snap preview not cleared on release\n")
        return
    # The dragged window (now front-most) must be top-left quarter-tiled.
    fs: uint64 = DWIN_COUNT - 1
    if DWIN_SNAP[fs] != 4:
        write_str(1, "[DE5] FAIL drag did not corner-snap\n")
        return
    if DWIN_X[fs] != 0 or DWIN_Y[fs] != PANEL_H \
       or DWIN_W[fs] != scr_w / 2 or DWIN_H[fs] != (scr_h - PANEL_H) / 2:
        write_str(1, "[DE5] FAIL corner-snap geometry wrong\n")
        return
    write_str(1, "[DE5] drag-snap OK\n")
    # --- Step 4: live tray window-count badge ---
    notif_count_refresh()
    cnt_before: int64 = NOTIF_WIN_COUNT
    if cnt_before != cycle_visible_count():
        write_str(1, "[DE5] FAIL tray badge count mismatch\n")
        return
    daemon_spawn_window(150, 100, 260, 160)
    notif_count_refresh()
    if NOTIF_WIN_COUNT != cnt_before + 1:
        write_str(1, "[DE5] FAIL tray badge did not track new window\n")
        return
    # The tray must reserve a third cell for the badge.
    if NOTIF_CELLS < 3:
        write_str(1, "[DE5] FAIL tray has no badge cell\n")
        return
    write_str(1, "[DE5] tray-badge OK\n")
    # --- Step 5: pager click-to-switch ---
    CUR_WS = 0
    pcx: int64 = pager_x0(scr_w) + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    pcy: int64 = PANEL_H / 2
    # Confirm the hit-test lands on cell 2, then drive a real panel click.
    if pager_cell_at(pcx, pcy, scr_w) != 2:
        write_str(1, "[DE5] FAIL pager hit-test wrong\n")
        return
    CUR_X = pcx
    CUR_Y = pcy
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CUR_WS != 2:
        write_str(1, "[DE5] FAIL pager click did not switch workspace\n")
        return
    CUR_WS = 0
    write_str(1, "[DE5] pager-click OK\n")
    # --- Step 6: desktop context menu Settings row ---
    PREV_BTN_R = 0
    CUR_X = scr_w / 2
    CUR_Y = scr_h / 2
    wm_rbutton(1, scr_w, scr_h)
    PREV_BTN_R = 1
    if CTX_OPEN == 0 or CTX_KIND != 0:
        write_str(1, "[DE5] FAIL desktop menu did not open\n")
        return
    if ctx_count() != 5:
        write_str(1, "[DE5] FAIL desktop menu missing Settings row\n")
        return
    # Row 1 must be the Settings entry.
    lbl1: Ptr[uint8] = ctx_item_label(1)
    if cstr_eq(lbl1, "Settings") == 0:
        write_str(1, "[DE5] FAIL row1 is not Settings\n")
        return
    set_before: uint64 = DWIN_COUNT
    ctx_invoke(1, scr_w, scr_h)
    if DWIN_COUNT != set_before + 1:
        write_str(1, "[DE5] FAIL Settings row did not spawn window\n")
        return
    if DWIN_APP[DWIN_COUNT - 1] != APP_SETTINGS:
        write_str(1, "[DE5] FAIL spawned window is not Settings app\n")
        return
    CTX_OPEN = 0
    write_str(1, "[DE5] ctxmenu-settings OK\n")
    daemon_present()
    write_str(1, "[DE5] PASS\n")


# ====================================================================
# ROUND-6 MATE-feel self-test (autoflag == 16)
# ====================================================================
# Mouse-free exercise of the round-6 window-resize features for CI. With no
# runtime observability on this host, the test drives the REAL gesture
# machine (wm_button / resize_*) and the REAL hit-testers with synthetic
# absolute coordinates, asserting geometry after each step:
#   1. GRIP hit-testing: resize_dir_at() classifies the 8 edge/corner grips
#      and returns 0 deep in the body and across the title-bar buttons.
#   2. EDGE resize: a drag on the right edge widens the window while the left
#      edge stays anchored; a drag on the bottom edge grows the height.
#   3. CORNER resize: a drag on the SE corner moves two edges at once; the
#      opposite (top-left) corner stays pinned.
#   4. MINIMUM size: dragging an edge past the opposite one clamps to
#      RESIZE_MIN_W / RESIZE_MIN_H, never inverting the rectangle.
#   5. SNAP DETACH: resizing a maximized window clears its snap flag so it
#      becomes a normal floating window again (MATE behaviour).
#   6. WINDOW MENU "Resize": the window context menu now offers a Resize row
#      that arms an interactive SE-corner resize via the gesture machine.
# Emits "[DE6] PASS" / "[DE6] FAIL <reason>".
def daemon_round6_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    SNAP_PREVIEW_ON = 0
    SNAP_PREVIEW_MODE = 0
    RESIZE_SLOT = -1
    RESIZE_DIR = 0
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: resize-grip hit classification ---
    daemon_spawn_window(200, 120, 300, 200)    # slot 0
    if DWIN_COUNT < 1:
        write_str(1, "[DE6] FAIL no window spawned\n")
        return
    s0: uint64 = DWIN_COUNT - 1
    # Force a known float rectangle independent of cascade placement.
    DWIN_X[s0] = 200
    DWIN_Y[s0] = 120
    DWIN_W[s0] = 300
    DWIN_H[s0] = 200
    DWIN_SNAP[s0] = 0
    DWIN_MAXED[s0] = 0
    wx0: int64 = DWIN_X[s0]
    wy0: int64 = DWIN_Y[s0]
    ww0: int64 = DWIN_W[s0]
    wh0: int64 = DWIN_H[s0]
    # Right edge (mid-height) -> mask bit1 (2) only.
    if resize_dir_at(s0, wx0 + ww0 - 1, wy0 + wh0 / 2) != 2:
        write_str(1, "[DE6] FAIL right-edge grip mask wrong\n")
        return
    # Left edge -> mask bit0 (1).
    if resize_dir_at(s0, wx0, wy0 + wh0 / 2) != 1:
        write_str(1, "[DE6] FAIL left-edge grip mask wrong\n")
        return
    # Bottom edge -> mask bit3 (8).
    if resize_dir_at(s0, wx0 + ww0 / 2, wy0 + wh0 - 1) != 8:
        write_str(1, "[DE6] FAIL bottom-edge grip mask wrong\n")
        return
    # SE corner -> bits 2|8 = 10.
    if resize_dir_at(s0, wx0 + ww0 - 1, wy0 + wh0 - 1) != 10:
        write_str(1, "[DE6] FAIL SE-corner grip mask wrong\n")
        return
    # NW corner -> bits 1|4 = 5.
    if resize_dir_at(s0, wx0, wy0) != 5:
        write_str(1, "[DE6] FAIL NW-corner grip mask wrong\n")
        return
    # Deep body centre -> no grip (0).
    if resize_dir_at(s0, wx0 + ww0 / 2, wy0 + wh0 / 2) != 0:
        write_str(1, "[DE6] FAIL body centre is a grip\n")
        return
    # The close box sits at the top-right; its grip is suppressed so the
    # close button still wins there (mask must NOT include the top bit set
    # alone over the button — resize_dir_at returns 0 across the box).
    cbx: int64 = close_box_x(s0)
    cby: int64 = close_box_y(s0)
    if resize_dir_at(s0, cbx + 1, cby + 1) != 0:
        write_str(1, "[DE6] FAIL top grip shadows close box\n")
        return
    write_str(1, "[DE6] grips OK\n")
    # --- Step 2: right-edge resize widens, left edge anchored ---
    PREV_BTN_L = 0
    CUR_X = wx0 + ww0 - 1
    CUR_Y = wy0 + wh0 / 2
    wm_button(1, scr_w, scr_h)                 # press the right grip
    PREV_BTN_L = 1
    if GESTURE != 4 or RESIZE_SLOT < 0:
        write_str(1, "[DE6] FAIL right-edge press did not start resize\n")
        return
    # Drag the cursor 80px to the right.
    CUR_X = wx0 + ww0 - 1 + 80
    CUR_Y = wy0 + wh0 / 2
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    rsz: uint64 = cast[uint64](RESIZE_SLOT)
    if DWIN_X[rsz] != wx0:
        write_str(1, "[DE6] FAIL right-resize moved the left edge\n")
        return
    if DWIN_W[rsz] != ww0 + 80:
        write_str(1, "[DE6] FAIL right-resize width wrong\n")
        return
    wm_button(0, scr_w, scr_h)                 # release: commit
    PREV_BTN_L = 0
    if RESIZE_SLOT >= 0:
        write_str(1, "[DE6] FAIL resize state not cleared on release\n")
        return
    # Refresh the working rectangle after the widen.
    ww1: int64 = DWIN_W[s0]
    wh1: int64 = DWIN_H[s0]
    write_str(1, "[DE6] edge-resize OK\n")
    # --- Step 3: SE-corner resize moves two edges, NW corner pinned ---
    PREV_BTN_L = 0
    CUR_X = DWIN_X[s0] + DWIN_W[s0] - 1
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] - 1
    fixx: int64 = DWIN_X[s0]
    fixy: int64 = DWIN_Y[s0]
    wm_button(1, scr_w, scr_h)                 # grab the SE corner
    PREV_BTN_L = 1
    if RESIZE_DIR != 10:
        write_str(1, "[DE6] FAIL SE corner grip dir wrong\n")
        return
    # Pull the corner +60 right, +40 down.
    CUR_X = CUR_X + 60
    CUR_Y = CUR_Y + 40
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if DWIN_X[s0] != fixx or DWIN_Y[s0] != fixy:
        write_str(1, "[DE6] FAIL SE resize moved the NW corner\n")
        return
    if DWIN_W[s0] != ww1 + 60 or DWIN_H[s0] != wh1 + 40:
        write_str(1, "[DE6] FAIL SE resize geometry wrong\n")
        return
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "[DE6] corner-resize OK\n")
    # --- Step 4: minimum-size clamp (drag the right edge far left) ---
    ax: int64 = DWIN_X[s0]
    PREV_BTN_L = 0
    CUR_X = DWIN_X[s0] + DWIN_W[s0] - 1
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] / 2
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # Drag the right edge way past the left edge: width must clamp, never go
    # negative, and the left edge must stay pinned.
    CUR_X = DWIN_X[s0] - 500
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if DWIN_W[s0] < RESIZE_MIN_W:
        write_str(1, "[DE6] FAIL width fell below the minimum\n")
        return
    if DWIN_X[s0] != ax:
        write_str(1, "[DE6] FAIL min-clamp moved the anchored edge\n")
        return
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "[DE6] min-size OK\n")
    # --- Step 5: resizing a maximized window detaches the snap ---
    window_toggle_maximize(s0, scr_w, scr_h)
    if DWIN_SNAP[s0] == 0:
        write_str(1, "[DE6] FAIL window did not maximize for detach test\n")
        return
    PREV_BTN_L = 0
    # Grab the bottom edge of the now-maximized window.
    CUR_X = DWIN_X[s0] + DWIN_W[s0] / 2
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] - 1
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    if DWIN_SNAP[s0] != 0 or DWIN_MAXED[s0] != 0:
        write_str(1, "[DE6] FAIL resize did not detach maximized snap\n")
        return
    CUR_Y = CUR_Y - 50
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "[DE6] snap-detach OK\n")
    # --- Step 6: window-menu "Resize" row arms a corner resize ---
    # ROUND-9 grew the window menu to ten rows; Resize is now row 6.
    CTX_KIND = 1
    CTX_SLOT = cast[int64](s0)
    if ctx_count() != 10:
        write_str(1, "[DE6] FAIL window menu is not ten rows\n")
        return
    lbl2: Ptr[uint8] = ctx_item_label(6)
    if cstr_eq(lbl2, "Resize") == 0:
        write_str(1, "[DE6] FAIL window menu row6 is not Resize\n")
        return
    # Invoke it: this should arm an SE-corner resize (GESTURE 4, dir 10).
    RESIZE_SLOT = -1
    RESIZE_DIR = 0
    GESTURE = 0
    ctx_invoke(6, scr_w, scr_h)
    if GESTURE != 4 or RESIZE_SLOT != cast[int64](s0) or RESIZE_DIR != 10:
        write_str(1, "[DE6] FAIL Resize menu row did not arm a resize\n")
        return
    # A subsequent drag + release through the gesture machine must resize +
    # then clear the state cleanly.
    mw0: int64 = DWIN_W[s0]
    CUR_X = DWIN_X[s0] + DWIN_W[s0] - 1 + 40
    CUR_Y = DWIN_Y[s0] + DWIN_H[s0] - 1
    wm_button(1, scr_w, scr_h)                 # held (PREV_BTN_L set by invoke)
    PREV_BTN_L = 1
    if DWIN_W[s0] != mw0 + 40:
        write_str(1, "[DE6] FAIL menu-armed resize did not track\n")
        return
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if RESIZE_SLOT >= 0 or GESTURE == 4:
        write_str(1, "[DE6] FAIL menu-armed resize not cleared\n")
        return
    CTX_OPEN = 0
    write_str(1, "[DE6] menu-resize OK\n")
    daemon_present()
    write_str(1, "[DE6] PASS\n")


# ====================================================================
# ROUND-7 MATE-feel self-test (autoflag == 17)
# ====================================================================
# Exercises, with synthetic inputs (no QEMU mouse/keyboard), the five
# new GNOME2/MATE features added this round:
#   1. Categorised Applications menu: category count + labels, submenu
#      open-on-hover, the (category,item)->flat-app mapping, and a click
#      inside a submenu flyout that launches the mapped app.
#   2. Clock calendar popup: click toggles it; the month grid layout +
#      day-of-week arithmetic (leap years, first-of-month weekday) are
#      verified against known dates.
#   3. Window-list taskbar grouping / raise (re-verifies the round-6
#      taskbar still raises a lower window via a synthetic click).
#   4. Focus model setting: the Settings "Focus" row toggles FOCUS_MODE,
#      and focus-follows-mouse raises the hovered window.
#   5. Notification banner: notify_post() arms a solid banner; notify_tick()
#      ages it through its TTL into a fade and finally expires.
# Emits "[DE7] PASS" / "[DE7] FAIL <reason>".
def daemon_round7_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    FOCUS_FOLLOW_UID = -1
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: categorised Applications menu ---
    if menubar_count(0) != cast[uint64](APPCAT_COUNT):
        write_str(1, "[DE7] FAIL Applications is not category-count rows\n")
        return
    cl0: Ptr[uint8] = menubar_item_label(0, 0)
    if cstr_eq(cl0, "Accessories") == 0:
        write_str(1, "[DE7] FAIL category 0 is not Accessories\n")
        return
    cl1: Ptr[uint8] = menubar_item_label(0, 1)
    if cstr_eq(cl1, "System Tools") == 0:
        write_str(1, "[DE7] FAIL category 1 is not System Tools\n")
        return
    # Accessories first item maps to flat entry 0 (Terminal).
    if appcat_flat_index(0, 0) != 0:
        write_str(1, "[DE7] FAIL Accessories item0 is not Terminal\n")
        return
    al0: Ptr[uint8] = appcat_item_label(0, 0)
    if cstr_eq(al0, "Terminal") == 0:
        write_str(1, "[DE7] FAIL Accessories item0 label wrong\n")
        return
    # System Tools item1 maps to flat entry 4 (System Monitor).
    if appcat_flat_index(1, 1) != 4:
        write_str(1, "[DE7] FAIL System Tools item1 is not System Monitor\n")
        return
    write_str(1, "[DE7] app-categories OK\n")
    # Open Applications via the menu-bar button, then hover its first
    # category row: the submenu flyout must open on that category.
    CUR_X = iclamp(menubar_btn_x(0) + 4, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if MENU_BAR_OPEN != 0:
        write_str(1, "[DE7] FAIL Applications menu did not open\n")
        return
    # Hover category 0 (Accessories) -> SUBMENU_OPEN becomes 0.
    CUR_X = iclamp(menubar_drop_x() + menubar_drop_w() / 2, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    update_hover()
    if SUBMENU_OPEN != 0:
        write_str(1, "[DE7] FAIL hovering Accessories did not open submenu\n")
        return
    # The submenu hit-test maps its first row back to item 0.
    sxc: int64 = submenu_x() + SUBMENU_W / 2
    if submenu_item_at(0, sxc, appcat_row_y(0) + MENU_ITEM_H / 2) != 0:
        write_str(1, "[DE7] FAIL submenu item0 hit-test wrong\n")
        return
    write_str(1, "[DE7] submenu-hover OK\n")
    # Click submenu item 0 (Terminal): a window spawns + the menu closes.
    before: uint64 = DWIN_COUNT
    CUR_X = iclamp(sxc, 0, scr_w - 1)
    CUR_Y = iclamp(appcat_row_y(0) + MENU_ITEM_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_COUNT <= before:
        write_str(1, "[DE7] FAIL submenu launch did not spawn a window\n")
        return
    if MENU_BAR_OPEN >= 0 or SUBMENU_OPEN >= 0:
        write_str(1, "[DE7] FAIL submenu launch did not close the menu\n")
        return
    write_str(1, "[DE7] submenu-launch OK\n")
    # --- Step 2: clock calendar popup + date arithmetic ---
    # 2026-06-03 is a Wednesday; June 1 2026 is a Monday (dow 1).
    CAL_YEAR = 2026
    CAL_MONTH = 6
    CAL_DAY = 3
    CAL_VALID = 1
    if dow_first(2026, 6) != 1:
        write_str(1, "[DE7] FAIL June 2026 does not start on Monday\n")
        return
    # 2000 is a leap year; 1900 is not; 2024 is.
    if is_leap(2000) == 0:
        write_str(1, "[DE7] FAIL leap-year computation wrong (2000)\n")
        return
    if is_leap(1900) != 0:
        write_str(1, "[DE7] FAIL leap-year computation wrong (1900)\n")
        return
    if is_leap(2024) == 0:
        write_str(1, "[DE7] FAIL leap-year computation wrong (2024)\n")
        return
    if days_in_month(2024, 2) != 29:
        write_str(1, "[DE7] FAIL Feb 2024 is not 29 days\n")
        return
    if days_in_month(2026, 2) != 28:
        write_str(1, "[DE7] FAIL Feb 2026 is not 28 days\n")
        return
    # June 2026: lead=1, so grid (row0,col1) is day 1; (row0,col0) is blank.
    if cal_day_at(0, 1) != 1:
        write_str(1, "[DE7] FAIL calendar day-1 cell wrong\n")
        return
    if cal_day_at(0, 0) != 0:
        write_str(1, "[DE7] FAIL calendar leading pad not blank\n")
        return
    # 30 days; the last day (30) sits at cell index lead+29 = 30 -> row4,col2.
    if cal_day_at(4, 2) != 30:
        write_str(1, "[DE7] FAIL calendar last-day cell wrong\n")
        return
    # The clock-applet click zone toggles the popup.
    if in_clock_zone(scr_w - 4, PANEL_H / 2, scr_w) == 0:
        write_str(1, "[DE7] FAIL clock zone hit-test wrong\n")
        return
    CUR_X = iclamp(scr_w - 4, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CAL_OPEN == 0:
        write_str(1, "[DE7] FAIL clock click did not open the calendar\n")
        return
    # A click off the calendar (the empty desktop) dismisses it.
    CUR_X = iclamp(scr_w / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 40, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if CAL_OPEN != 0:
        write_str(1, "[DE7] FAIL off-calendar click did not dismiss it\n")
        return
    write_str(1, "[DE7] calendar OK\n")
    # --- Step 3: taskbar grouping/raise still works ---
    daemon_spawn_window(60, 200, 300, 180)        # slot s_a
    s_a: uint64 = DWIN_COUNT - 1
    daemon_spawn_window(120, 240, 300, 180)       # slot s_b (now topmost)
    if DWIN_COUNT < 2:
        write_str(1, "[DE7] FAIL fewer than 2 windows for taskbar test\n")
        return
    uid_a: int32 = DWIN_UID[s_a]
    # Click s_a's taskbar button: it must raise to topmost.
    tbx: int64 = taskbar_btn_x(s_a) + 4
    CUR_X = iclamp(tbx, 0, scr_w - 1)
    CUR_Y = iclamp(TASKBAR_BTN_Y + TASKBAR_BTN_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    top_slot: uint64 = DWIN_COUNT - 1
    if DWIN_UID[top_slot] != uid_a:
        write_str(1, "[DE7] FAIL taskbar click did not raise the window\n")
        return
    write_str(1, "[DE7] taskbar-raise OK\n")
    # --- Step 4: focus model setting + focus-follows-mouse ---
    sx2: int64 = 140
    sy2: int64 = PANEL_H + 30
    daemon_spawn_app(APP_SETTINGS, sx2, sy2, 320, 220)
    sset: uint64 = DWIN_COUNT - 1
    if DWIN_APP[sset] != APP_SETTINGS:
        write_str(1, "[DE7] FAIL settings window not created\n")
        return
    # SET_ROWS is 6 since ROUND-8 (Theme/Background/Panel/Focus/Workspaces/
    # Reset); the Focus row is still row 3.
    if SET_ROWS != 6:
        write_str(1, "[DE7] FAIL settings does not have 6 rows\n")
        return
    fm0: int32 = FOCUS_MODE
    settings_press(sset, 3)
    if FOCUS_MODE == fm0:
        write_str(1, "[DE7] FAIL Focus row did not toggle the focus model\n")
        return
    # The row-3 centre must hit-test back to row 3.
    rcy: int64 = settings_row_y(sset, 3) + 4
    rcx: int64 = DWIN_X[sset] + 20
    if settings_row_at(sset, rcx, rcy) != 3:
        write_str(1, "[DE7] FAIL settings Focus row hit-test wrong\n")
        return
    write_str(1, "[DE7] focus-setting OK\n")
    # Focus-follows-mouse: enable it, then move the pointer over a LOWER
    # window's body; it must auto-raise to topmost.
    FOCUS_MODE = 1
    FOCUS_FOLLOW_UID = -1
    # Two fresh windows so we know the z-order: spawn lo then hi.
    daemon_spawn_window(80, 120, 260, 160)        # lo
    lo: uint64 = DWIN_COUNT - 1
    lo_uid: int32 = DWIN_UID[lo]
    daemon_spawn_window(360, 120, 260, 160)       # hi (topmost)
    if DWIN_UID[DWIN_COUNT - 1] == lo_uid:
        write_str(1, "[DE7] FAIL follow-mouse setup z-order wrong\n")
        return
    # Hover lo's body (no button held). focus_follow_step raises it.
    CUR_X = iclamp(DWIN_X[lo] + DWIN_W[lo] / 2, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[lo] + TITLE_H + 20, 0, scr_h - 1)
    PREV_BTN_L = 0
    update_hover()
    focus_follow_step(0, scr_w, scr_h)
    if DWIN_UID[DWIN_COUNT - 1] != lo_uid:
        write_str(1, "[DE7] FAIL focus-follows-mouse did not raise hovered window\n")
        return
    # With click-to-focus, the same hover must NOT raise.
    FOCUS_MODE = 0
    FOCUS_FOLLOW_UID = -1
    daemon_spawn_window(420, 200, 240, 150)       # new topmost
    top_uid: int32 = DWIN_UID[DWIN_COUNT - 1]
    CUR_X = iclamp(DWIN_X[lo] + DWIN_W[lo] / 2, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[lo] + TITLE_H + 20, 0, scr_h - 1)
    update_hover()
    focus_follow_step(0, scr_w, scr_h)
    if DWIN_UID[DWIN_COUNT - 1] != top_uid:
        write_str(1, "[DE7] FAIL click-to-focus wrongly raised on hover\n")
        return
    write_str(1, "[DE7] follow-mouse OK\n")
    # --- Step 5: transient notification banner lifecycle ---
    NOTIFY_ACTIVE = 0
    notify_post("Test", "hello")
    if NOTIFY_ACTIVE == 0:
        write_str(1, "[DE7] FAIL notify_post did not arm the banner\n")
        return
    if NOTIFY_AGE != 0:
        write_str(1, "[DE7] FAIL notify_post did not reset the banner age\n")
        return
    if notify_alpha() != 255:
        write_str(1, "[DE7] FAIL fresh banner is not fully solid\n")
        return
    # Tick up to just before the TTL: still solid + active.
    tk: int64 = 0
    while tk < NOTIFY_TTL - 1:
        notify_tick()
        tk = tk + 1
    if NOTIFY_ACTIVE == 0:
        write_str(1, "[DE7] FAIL banner expired before its TTL\n")
        return
    if notify_alpha() != 255:
        write_str(1, "[DE7] FAIL banner faded before its TTL\n")
        return
    # Push one tick into the fade window: alpha must drop below solid.
    notify_tick()
    notify_tick()
    if notify_alpha() >= 255:
        write_str(1, "[DE7] FAIL banner did not begin fading after TTL\n")
        return
    # Tick out the rest of the fade: the banner expires.
    tk2: int64 = 0
    while tk2 < NOTIFY_FADE + 2:
        notify_tick()
        tk2 = tk2 + 1
    if NOTIFY_ACTIVE != 0:
        write_str(1, "[DE7] FAIL banner did not expire after the fade\n")
        return
    write_str(1, "[DE7] notify OK\n")
    daemon_present()
    write_str(1, "[DE7] PASS\n")


# ====================================================================
# ROUND-8 MATE-feel self-test (autoflag == 18)
# ====================================================================
# Exercises, with synthetic inputs (no QEMU mouse/keyboard), the two new
# GNOME2/MATE features added this round:
#   1. Session dialog + screen lock: the System menu "Log Out" raises the
#      modal session dialog; its rows hit-test correctly; clicking "Lock
#      Screen" locks the desktop and a subsequent click unlocks; "Shut Down"
#      and "Log Out" set the loop's quit flag with the right intent; a click
#      outside the dialog cancels it.
#   2. Settings "Workspaces" row: SET_ROWS grew to 6; the Workspaces row
#      (index 4) cycles WS_COUNT through [WS_MIN..WS_MAX] and folds the
#      current workspace + any out-of-range windows back into range.
# Emits "[DE8] PASS" / "[DE8] FAIL <reason>".
def daemon_round8_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    SESSION_INTENT = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # --- Step 1: session dialog geometry + rows ---
    if SESSION_ROWS != 4:
        write_str(1, "[DE8] FAIL session dialog is not four rows\n")
        return
    sl0: Ptr[uint8] = session_row_label(0)
    if cstr_eq(sl0, "Lock Screen") == 0:
        write_str(1, "[DE8] FAIL session row0 is not Lock Screen\n")
        return
    sl1: Ptr[uint8] = session_row_label(1)
    if cstr_eq(sl1, "Log Out") == 0:
        write_str(1, "[DE8] FAIL session row1 is not Log Out\n")
        return
    sl2: Ptr[uint8] = session_row_label(2)
    if cstr_eq(sl2, "Shut Down") == 0:
        write_str(1, "[DE8] FAIL session row2 is not Shut Down\n")
        return
    sl3: Ptr[uint8] = session_row_label(3)
    if cstr_eq(sl3, "Cancel") == 0:
        write_str(1, "[DE8] FAIL session row3 is not Cancel\n")
        return
    write_str(1, "[DE8] session-rows OK\n")
    # The System menu "Log Out" (m=2, item 6) opens the dialog.
    menubar_invoke(2, 6, scr_w, scr_h)
    if SESSION_OPEN == 0:
        write_str(1, "[DE8] FAIL System Log Out did not open the session dialog\n")
        return
    # Each row's centre must hit-test back to itself.
    dcx: int64 = session_x(scr_w) + SESSION_W / 2
    ri: int64 = 0
    while ri < SESSION_ROWS:
        rcy: int64 = session_row_y(scr_h, ri) + SESSION_BTN_H / 2
        if session_row_at(dcx, rcy, scr_w, scr_h) != ri:
            write_str(1, "[DE8] FAIL session row hit-test wrong\n")
            return
        ri = ri + 1
    # A point above the first row (outside the button band) is not a row.
    above_y: int64 = session_row_y(scr_h, 0) - 4
    if session_row_at(dcx, above_y, scr_w, scr_h) != -1:
        write_str(1, "[DE8] FAIL session off-row hit-test wrong\n")
        return
    write_str(1, "[DE8] session-hittest OK\n")
    # --- Step 2: hover highlight tracks the pointed-at row ---
    CUR_X = iclamp(dcx, 0, scr_w - 1)
    CUR_Y = iclamp(session_row_y(scr_h, 2) + SESSION_BTN_H / 2, 0, scr_h - 1)
    update_hover()
    if SESSION_HOVER != 2:
        write_str(1, "[DE8] FAIL session hover did not track row 2\n")
        return
    write_str(1, "[DE8] session-hover OK\n")
    # --- Step 3: Lock Screen via a synthetic click on row 0 ---
    CUR_X = iclamp(dcx, 0, scr_w - 1)
    CUR_Y = iclamp(session_row_y(scr_h, 0) + SESSION_BTN_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if LOCKED == 0:
        write_str(1, "[DE8] FAIL Lock Screen click did not lock the desktop\n")
        return
    if SESSION_OPEN != 0:
        write_str(1, "[DE8] FAIL locking did not dismiss the dialog\n")
        return
    # While locked, ANY click unlocks (and is otherwise swallowed).
    CUR_X = iclamp(scr_w / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if LOCKED != 0:
        write_str(1, "[DE8] FAIL click did not unlock the screen\n")
        return
    write_str(1, "[DE8] lock-unlock OK\n")
    # --- Step 4: Cancel — a click outside the dialog dismisses it ---
    SESSION_OPEN = 0
    session_open()
    if SESSION_OPEN == 0:
        write_str(1, "[DE8] FAIL session_open did not arm the dialog\n")
        return
    # Click far outside the dialog box (top-left corner of the work area).
    CUR_X = iclamp(2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if SESSION_OPEN != 0:
        write_str(1, "[DE8] FAIL outside click did not cancel the dialog\n")
        return
    if DAEMON_QUIT != 0 or LOCKED != 0:
        write_str(1, "[DE8] FAIL cancel wrongly triggered quit/lock\n")
        return
    write_str(1, "[DE8] session-cancel OK\n")
    # --- Step 5: Shut Down + Log Out intents drive the quit flag ---
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    SESSION_OPEN = 1
    session_invoke(2)                       # Shut Down
    if DAEMON_QUIT == 0 or SESSION_INTENT != 2:
        write_str(1, "[DE8] FAIL Shut Down did not request a power-off\n")
        return
    if SESSION_OPEN != 0:
        write_str(1, "[DE8] FAIL Shut Down did not close the dialog\n")
        return
    SESSION_INTENT = 0
    DAEMON_QUIT = 0
    SESSION_OPEN = 1
    session_invoke(1)                       # Log Out
    if DAEMON_QUIT == 0 or SESSION_INTENT != 1:
        write_str(1, "[DE8] FAIL Log Out did not request a logout\n")
        return
    DAEMON_QUIT = 0
    SESSION_INTENT = 0
    write_str(1, "[DE8] session-intents OK\n")
    # --- Step 6: Settings "Workspaces" row reconfigures WS_COUNT ---
    if SET_ROWS != 6:
        write_str(1, "[DE8] FAIL Settings does not have six rows\n")
        return
    sx2: int64 = 120
    sy2: int64 = PANEL_H + 30
    daemon_spawn_app(APP_SETTINGS, sx2, sy2, 320, 220)
    sset: uint64 = DWIN_COUNT - 1
    if DWIN_APP[sset] != APP_SETTINGS:
        write_str(1, "[DE8] FAIL settings window not created\n")
        return
    # Row 4 is Workspaces; the row-4 centre must hit-test back to row 4.
    r4y: int64 = settings_row_y(sset, 4) + 4
    r4x: int64 = DWIN_X[sset] + 20
    if settings_row_at(sset, r4x, r4y) != 4:
        write_str(1, "[DE8] FAIL Workspaces row hit-test wrong\n")
        return
    ws0: int32 = WS_COUNT
    settings_press(sset, 4)
    if WS_COUNT != ws0 + 1:
        write_str(1, "[DE8] FAIL Workspaces row did not increment the count\n")
        return
    write_str(1, "[DE8] ws-row OK\n")
    # Cycle from the maximum and assert it wraps to the minimum.
    WS_COUNT = WS_MAX
    ws_count_cycle()
    if WS_COUNT != WS_MIN:
        write_str(1, "[DE8] FAIL Workspaces count did not wrap to the minimum\n")
        return
    # Shrinking the desktop count must fold the active workspace + an out-of
    # range window back into the new range so nothing is unreachable.
    WS_COUNT = 4
    CUR_WS = 3
    daemon_spawn_window(80, 120, 200, 140)
    fw: uint64 = DWIN_COUNT - 1
    DWIN_WS[fw] = 3
    WS_COUNT = WS_MAX                       # so the next cycle wraps to WS_MIN
    ws_count_cycle()                        # WS_COUNT -> WS_MIN (==1)
    if WS_COUNT != WS_MIN:
        write_str(1, "[DE8] FAIL fold-setup did not reach the minimum\n")
        return
    if CUR_WS >= WS_COUNT:
        write_str(1, "[DE8] FAIL current workspace not folded into range\n")
        return
    if DWIN_WS[fw] >= WS_COUNT:
        write_str(1, "[DE8] FAIL window workspace not folded into range\n")
        return
    write_str(1, "[DE8] ws-fold OK\n")
    # Restore a sane default count for the present pass.
    WS_COUNT = 4
    CUR_WS = 0
    daemon_present()
    write_str(1, "[DE8] PASS\n")


# ====================================================================
# ROUND-9 MATE-feel self-test (autoflag == 19)
# ====================================================================
# Mouse-free exercise of the round-9 window-management polish for CI. As
# with the earlier rounds there is no runtime observability on this host,
# so the test drives the REAL window-menu (ctx_invoke), the REAL gesture
# machine (wm_button), and the REAL z-order machinery with synthetic
# coordinates, asserting state after each step:
#   1. Window menu grew to ten rows in the new MATE order, with the four
#      new entries (Max Vert, Max Horiz, Shade, Always on Top) at the
#      expected indices and dynamic Shade/Unshade + Always-on-Top labels.
#   2. SHADE: invoking "Shade" rolls the focused window up to its title
#      bar (DWIN_H collapses to SHADE_H, the full height is stashed), and
#      a second invoke unshades it back to the exact original height.
#   3. ALWAYS-ON-TOP: pinning a back window then presenting floats it above
#      a normal front window in the slot array (the paint/hit-test order);
#      un-pinning leaves it pinned-free; a later raise of a normal window
#      can no longer cover the pinned one.
#   4. MAXIMIZE VERT/HORIZ: the menu rows stretch the window in exactly one
#      axis (work-area height / full screen width) and a re-invoke restores
#      the saved float rectangle.
# Emits "[DE9] PASS" / "[DE9] FAIL <reason>".
def daemon_round9_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    theme_apply()
    bg_palette_init()
    # A single fresh terminal window to operate on.
    daemon_spawn_window(80, PANEL_H + 24, 360, 240)
    if DWIN_COUNT == 0:
        write_str(1, "[DE9] FAIL no window spawned\n")
        return
    s0: uint64 = DWIN_COUNT - 1
    # --- Step 1: the window menu carries the ten round-9 rows ---
    CTX_KIND = 1
    CTX_SLOT = cast[int64](s0)
    if ctx_count() != 10:
        write_str(1, "[DE9] FAIL window menu is not ten rows\n")
        return
    lmv: Ptr[uint8] = ctx_item_label(2)
    if cstr_eq(lmv, "Maximize Vertically") == 0:
        write_str(1, "[DE9] FAIL row2 is not Maximize Vertically\n")
        return
    lmh: Ptr[uint8] = ctx_item_label(3)
    if cstr_eq(lmh, "Maximize Horizontally") == 0:
        write_str(1, "[DE9] FAIL row3 is not Maximize Horizontally\n")
        return
    lsh: Ptr[uint8] = ctx_item_label(4)
    if cstr_eq(lsh, "Shade") == 0:
        write_str(1, "[DE9] FAIL row4 is not Shade\n")
        return
    lot: Ptr[uint8] = ctx_item_label(5)
    if cstr_eq(lot, "Always on Top") == 0:
        write_str(1, "[DE9] FAIL row5 is not Always on Top\n")
        return
    write_str(1, "[DE9] window-menu rows OK\n")
    # --- Step 2: Shade rolls up; the row label flips to Unshade ---
    h_before: int64 = DWIN_H[s0]
    ctx_invoke(4, scr_w, scr_h)                 # Shade
    if DWIN_SHADED[s0] == 0:
        write_str(1, "[DE9] FAIL Shade did not set the shaded flag\n")
        return
    if DWIN_H[s0] != SHADE_H:
        write_str(1, "[DE9] FAIL shaded window did not collapse to the title bar\n")
        return
    if DWIN_SHADE_H[s0] != h_before:
        write_str(1, "[DE9] FAIL shade did not stash the full height\n")
        return
    lsh2: Ptr[uint8] = ctx_item_label(4)
    if cstr_eq(lsh2, "Unshade") == 0:
        write_str(1, "[DE9] FAIL shaded row label is not Unshade\n")
        return
    ctx_invoke(4, scr_w, scr_h)                 # Unshade
    if DWIN_SHADED[s0] != 0:
        write_str(1, "[DE9] FAIL Unshade did not clear the shaded flag\n")
        return
    if DWIN_H[s0] != h_before:
        write_str(1, "[DE9] FAIL unshade did not restore the full height\n")
        return
    write_str(1, "[DE9] shade-roll OK\n")
    # --- Step 3: Always-on-Top floats a window above the normal stack ---
    # Spawn a second window so we have a clear z-order: s0 (back), s1 (front).
    daemon_spawn_window(140, PANEL_H + 60, 360, 240)
    if DWIN_COUNT < 2:
        write_str(1, "[DE9] FAIL second window not spawned\n")
        return
    s1: uint64 = DWIN_COUNT - 1
    # Identify the two windows by UID so we can find them after reorders.
    uid_back: int32 = DWIN_UID[s0]
    uid_front: int32 = DWIN_UID[s1]
    # The newest window is front-most (last slot).
    if DWIN_UID[DWIN_COUNT - 1] != uid_front:
        write_str(1, "[DE9] FAIL front window is not the newest\n")
        return
    # Pin the BACK window on top via its window menu, then present so the
    # ontop reorder runs. The pinned window must now be front-most.
    CTX_SLOT = slot_for_uid(uid_back)
    if CTX_SLOT < 0:
        write_str(1, "[DE9] FAIL lost the back window\n")
        return
    ctx_invoke(5, scr_w, scr_h)                 # Always on Top
    bslot: int64 = slot_for_uid(uid_back)
    if bslot < 0 or DWIN_ONTOP[cast[uint64](bslot)] == 0:
        write_str(1, "[DE9] FAIL Always on Top did not set the pin\n")
        return
    enforce_ontop_order()
    if DWIN_UID[DWIN_COUNT - 1] != uid_back:
        write_str(1, "[DE9] FAIL pinned window did not float to the front\n")
        return
    # The ontop-row label now carries the active-state marker.
    CTX_SLOT = slot_for_uid(uid_back)
    lot2: Ptr[uint8] = ctx_item_label(5)
    if cstr_eq(lot2, "Always on Top *") == 0:
        write_str(1, "[DE9] FAIL pinned ontop row missing the marker\n")
        return
    # Raising the OTHER (normal) window must NOT cover the pinned one once
    # the order is re-enforced: the pin stays front-most.
    nslot: int64 = slot_for_uid(uid_front)
    daemon_raise_slot(nslot)
    enforce_ontop_order()
    if DWIN_UID[DWIN_COUNT - 1] != uid_back:
        write_str(1, "[DE9] FAIL normal raise wrongly covered the pinned window\n")
        return
    # Un-pin: the window is no longer forced above the normal stack.
    CTX_SLOT = slot_for_uid(uid_back)
    ctx_invoke(5, scr_w, scr_h)                 # Always on Top (toggle off)
    uslot: int64 = slot_for_uid(uid_back)
    if uslot < 0 or DWIN_ONTOP[cast[uint64](uslot)] != 0:
        write_str(1, "[DE9] FAIL un-pin did not clear the ontop flag\n")
        return
    write_str(1, "[DE9] always-on-top OK\n")
    # --- Step 4: vertical + horizontal maximize via the menu rows ---
    tslot: int64 = slot_for_uid(uid_front)
    t: uint64 = cast[uint64](tslot)
    fx: int64 = DWIN_X[t]
    fy: int64 = DWIN_Y[t]
    fw: int64 = DWIN_W[t]
    fh: int64 = DWIN_H[t]
    CTX_SLOT = tslot
    ctx_invoke(2, scr_w, scr_h)                 # Maximize Vertically
    if DWIN_Y[t] != PANEL_H or DWIN_H[t] != scr_h - PANEL_H:
        write_str(1, "[DE9] FAIL vertical maximize geometry wrong\n")
        return
    if DWIN_X[t] != fx or DWIN_W[t] != fw:
        write_str(1, "[DE9] FAIL vertical maximize changed the x axis\n")
        return
    ctx_invoke(2, scr_w, scr_h)                 # restore
    if DWIN_X[t] != fx or DWIN_Y[t] != fy or DWIN_W[t] != fw or DWIN_H[t] != fh:
        write_str(1, "[DE9] FAIL vertical restore geometry wrong\n")
        return
    ctx_invoke(3, scr_w, scr_h)                 # Maximize Horizontally
    if DWIN_X[t] != 0 or DWIN_W[t] != scr_w:
        write_str(1, "[DE9] FAIL horizontal maximize geometry wrong\n")
        return
    if DWIN_Y[t] != fy or DWIN_H[t] != fh:
        write_str(1, "[DE9] FAIL horizontal maximize changed the y axis\n")
        return
    ctx_invoke(3, scr_w, scr_h)                 # restore
    if DWIN_X[t] != fx or DWIN_Y[t] != fy or DWIN_W[t] != fw or DWIN_H[t] != fh:
        write_str(1, "[DE9] FAIL horizontal restore geometry wrong\n")
        return
    write_str(1, "[DE9] maximize-axes OK\n")
    CTX_OPEN = 0
    daemon_present()
    write_str(1, "[DE9] PASS\n")


# ====================================================================
# ROUND-10 MATE-feel self-test
# ====================================================================
# Exercises, mouse-free, the three round-10 features:
#   1. WORKSPACE PAGER drag-window-between-workspaces: dragging a desktop
#      cell onto another moves that desktop's focused window across; a
#      same-cell "drag" still switches workspace.
#   2. WINDOW-LIST GROUPING: several windows of one app collapse to a
#      single group-leader taskbar button with an (N) count; clicking it
#      round-robin cycles focus through the group; singletons stay solo.
#   3. APPLICATIONS MENU SEARCH/FILTER: a case-insensitive substring query
#      filters the flat app list, Enter/click launches the n-th match.
# Emits "[DE10] PASS" / "[DE10] FAIL <reason>".
def daemon_round10_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PAGER_DRAG = 0
    PAGER_DRAG_FROM = -1
    SEARCH_OPEN = 0
    SEARCH_LEN = 0
    GROUP_CURSOR[0] = 0
    GROUP_CURSOR[1] = 0
    GROUP_CURSOR[2] = 0
    GROUP_CURSOR[3] = 0
    GROUP_CURSOR[4] = 0
    theme_apply()
    bg_palette_init()

    # ---------------- Step 1: pager drag-window-between-workspaces -------
    # One window on workspace 0; drag cell 0 -> cell 2 relocates it.
    daemon_spawn_window(80, PANEL_H + 24, 360, 240)
    if DWIN_COUNT == 0:
        write_str(1, "[DE10] FAIL no window spawned\n")
        return
    w0: uint64 = DWIN_COUNT - 1
    if DWIN_WS[w0] != 0:
        write_str(1, "[DE10] FAIL fresh window not on workspace 0\n")
        return
    # ws_focus_slot finds the front window of a desktop.
    if ws_focus_slot(0) != cast[int64](w0):
        write_str(1, "[DE10] FAIL ws_focus_slot(0) wrong\n")
        return
    if ws_focus_slot(2) != -1:
        write_str(1, "[DE10] FAIL ws 2 should be empty\n")
        return
    # Same-cell pager gesture is a no-op move (returns 0).
    if pager_drag_window(1, 1) != 0:
        write_str(1, "[DE10] FAIL same-cell drag should not move\n")
        return
    # Empty-source drag is a no-op too.
    if pager_drag_window(3, 2) != 0:
        write_str(1, "[DE10] FAIL empty-source drag should not move\n")
        return
    # Real drag cell 0 -> cell 2.
    if pager_drag_window(0, 2) == 0:
        write_str(1, "[DE10] FAIL pager drag did not move the window\n")
        return
    if DWIN_WS[w0] != 2:
        write_str(1, "[DE10] FAIL window did not land on workspace 2\n")
        return
    # It is no longer visible on the (still current) workspace 0.
    if win_on_cur_ws(w0) != 0:
        write_str(1, "[DE10] FAIL moved window still on workspace 0\n")
        return
    write_str(1, "[DE10] pager-drag OK\n")

    # ---------------- Step 2: window-list grouping ----------------------
    # Bring the test window back to ws 0, then add two calculators so the
    # CALC app forms a 2-strong group and the lone terminal stays solo.
    window_to_workspace(w0, 0)
    daemon_spawn_app(APP_CALC, 100, PANEL_H + 40, 220, 300)
    daemon_spawn_app(APP_CALC, 140, PANEL_H + 60, 220, 300)
    if DWIN_COUNT < 3:
        write_str(1, "[DE10] FAIL calculators not spawned\n")
        return
    # Find the two calc slots + the terminal slot.
    c_first: int64 = -1
    c_second: int64 = -1
    term_slot: int64 = -1
    gi: uint64 = 0
    while gi < DWIN_COUNT:
        if DWIN_APP[gi] == APP_CALC:
            if c_first < 0:
                c_first = cast[int64](gi)
            else:
                c_second = cast[int64](gi)
        elif DWIN_APP[gi] == APP_TERM:
            term_slot = cast[int64](gi)
        gi = gi + 1
    if c_first < 0 or c_second < 0 or term_slot < 0:
        write_str(1, "[DE10] FAIL could not locate group test windows\n")
        return
    cf: uint64 = cast[uint64](c_first)
    cs: uint64 = cast[uint64](c_second)
    ts: uint64 = cast[uint64](term_slot)
    # Two calculators => grouped; the single terminal => not grouped.
    if app_group_count(cf) != 2:
        write_str(1, "[DE10] FAIL calc group count is not 2\n")
        return
    if is_grouped(cf) == 0 or is_grouped(cs) == 0:
        write_str(1, "[DE10] FAIL calculators not grouped\n")
        return
    if is_grouped(ts) != 0:
        write_str(1, "[DE10] FAIL lone terminal wrongly grouped\n")
        return
    # The lower-index calc slot is the group leader; the other is folded.
    if is_group_leader(cf) == 0:
        write_str(1, "[DE10] FAIL first calc is not the group leader\n")
        return
    if is_group_leader(cs) != 0:
        write_str(1, "[DE10] FAIL second calc wrongly a leader\n")
        return
    # The taskbar hit-test only resolves leaders (folded members ignored).
    if taskbar_slot_at(taskbar_btn_x(cf) + 4, TASKBAR_BTN_Y + 2, scr_w) \
       != cast[int64](cf):
        write_str(1, "[DE10] FAIL taskbar did not hit the group leader\n")
        return
    if taskbar_slot_at(taskbar_btn_x(cs) + 4, TASKBAR_BTN_Y + 2, scr_w) != -1:
        write_str(1, "[DE10] FAIL folded member is still hit-testable\n")
        return
    # Clicking the group cycles focus round-robin through its members.
    # group_cycle returns the raised window's UID (stable across reorders);
    # two successive cycles must raise two DIFFERENT calculator windows.
    GROUP_CURSOR[APP_CALC] = 0
    g_a: int64 = group_cycle(cf)
    if g_a < 0:
        write_str(1, "[DE10] FAIL first group cycle raised nothing\n")
        return
    ga_slot: int64 = slot_for_uid(cast[int32](g_a))
    if ga_slot < 0 or DWIN_APP[cast[uint64](ga_slot)] != APP_CALC:
        write_str(1, "[DE10] FAIL group cycle raised a non-calc window\n")
        return
    # The cycled window must be front-most (focused) after the raise.
    if DWIN_UID[DWIN_COUNT - 1] != cast[int32](g_a):
        write_str(1, "[DE10] FAIL group cycle did not focus its window\n")
        return
    g_b: int64 = group_cycle(cf)
    if g_b < 0:
        write_str(1, "[DE10] FAIL second group cycle raised nothing\n")
        return
    gb_slot: int64 = slot_for_uid(cast[int32](g_b))
    if gb_slot < 0 or DWIN_APP[cast[uint64](gb_slot)] != APP_CALC:
        write_str(1, "[DE10] FAIL second cycle raised a non-calc window\n")
        return
    if g_a == g_b:
        write_str(1, "[DE10] FAIL group cycle did not advance to a new window\n")
        return
    write_str(1, "[DE10] grouping OK\n")

    # ---------------- Step 3: Applications menu search/filter -----------
    MENU_BAR_OPEN = 0
    SEARCH_OPEN = 1
    SEARCH_LEN = 0
    # Empty query matches every flat entry.
    if menu_search_count() != MENU_COUNT:
        write_str(1, "[DE10] FAIL empty query did not match all entries\n")
        return
    if search_active() != 0:
        write_str(1, "[DE10] FAIL empty query should not be active filter\n")
        return
    # Type "cal" (case-insensitive). Matches "Calculator" and "Calendar".
    search_push(67)             # 'C'
    search_push(97)             # 'a'
    search_push(108)            # 'l'
    if search_active() == 0:
        write_str(1, "[DE10] FAIL non-empty query is not active\n")
        return
    if menu_search_count() != 2:
        write_str(1, "[DE10] FAIL 'cal' did not match exactly 2 entries\n")
        return
    # The matches are Calculator (flat 3) and Calendar (flat 6).
    m0: uint64 = menu_search_nth(0)
    m1: uint64 = menu_search_nth(1)
    if m0 != 3 or m1 != 6:
        write_str(1, "[DE10] FAIL 'cal' match indices wrong\n")
        return
    if cstr_eq(menu_label(m0), "Calculator") == 0:
        write_str(1, "[DE10] FAIL first match is not Calculator\n")
        return
    # Case-insensitive: a capital still matches the lowercase label.
    search_push(99)             # 'c' -> query "calc"
    if menu_search_count() != 1:
        write_str(1, "[DE10] FAIL 'calc' did not narrow to 1\n")
        return
    if menu_search_nth(0) != 3:
        write_str(1, "[DE10] FAIL 'calc' match is not Calculator\n")
        return
    # Backspace widens the query back to two matches.
    search_backspace()          # back to "cal"
    if menu_search_count() != 2:
        write_str(1, "[DE10] FAIL backspace did not widen the filter\n")
        return
    # A non-matching query yields zero results.
    search_push(122)            # 'z' -> "calz"
    if menu_search_count() != 0:
        write_str(1, "[DE10] FAIL non-matching query still matched\n")
        return
    if menu_search_nth(0) != MENU_COUNT:
        write_str(1, "[DE10] FAIL out-of-range nth not clamped\n")
        return
    # Reset closes the box and clears the query.
    search_reset()
    if SEARCH_OPEN != 0 or SEARCH_LEN != 0 or search_active() != 0:
        write_str(1, "[DE10] FAIL search_reset did not clear state\n")
        return
    write_str(1, "[DE10] menu-search OK\n")

    MENU_BAR_OPEN = -1
    daemon_present()
    write_str(1, "[DE10] PASS\n")


# ====================================================================
# ROUND-11 self-test (autoflag == 21)
# ====================================================================
# Asserts the three round-11 features WITHOUT QEMU mouse/key injection:
#   1. Panel-position-aware work area: a top panel reserves the top strip,
#      a bottom panel reserves the bottom strip, and snap/maximize land in
#      the correct half of the screen for each panel position.
#   2. Window-list group actions: minimize-all / restore-all / close-all
#      act on every window of a grouped app.
#   3. Standard Ctrl-Alt-arrow workspace navigation + Ctrl-Alt-Shift-arrow
#      move-window-to-adjacent-workspace, with row wrap-around.
# Emits "[DE11] PASS" / "[DE11] FAIL <reason>".
def daemon_round11_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    SEARCH_OPEN = 0
    SEARCH_LEN = 0
    GROUP_CURSOR[APP_CALC] = 0
    theme_apply()
    bg_palette_init()

    # ---------------- Step 1: panel-position-aware work area ------------
    # Top panel (default): the usable desktop starts BELOW the panel.
    PANEL_POS = 0
    if work_top(scr_h) != PANEL_H:
        write_str(1, "[DE11] FAIL top panel work_top wrong\n")
        return
    if panel_top_y(scr_h) != 0:
        write_str(1, "[DE11] FAIL top panel not at y=0\n")
        return
    if work_h(scr_h) != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL work_h wrong\n")
        return
    # Bottom panel (GNOME2 default): desktop starts at the top edge and the
    # panel bar sits flush to the floor.
    PANEL_POS = 1
    if work_top(scr_h) != 0:
        write_str(1, "[DE11] FAIL bottom panel work_top should be 0\n")
        return
    if panel_top_y(scr_h) != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom panel not flush to floor\n")
        return
    if work_h(scr_h) != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom panel work_h wrong\n")
        return
    # Maximize under a BOTTOM panel: window must start at y==0 and stop
    # short of the panel (so the bottom panel is never covered).
    daemon_spawn_window(80, 40, 360, 240)
    if DWIN_COUNT == 0:
        write_str(1, "[DE11] FAIL no window spawned\n")
        return
    w0: uint64 = DWIN_COUNT - 1
    snap_apply(w0, 1, scr_w, scr_h)            # maximize
    if DWIN_Y[w0] != 0:
        write_str(1, "[DE11] FAIL bottom-panel maximize did not start at top\n")
        return
    if DWIN_H[w0] != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom-panel maximize covered the panel\n")
        return
    # Bottom-left quarter under a bottom panel: top of the lower half.
    snap_apply(w0, 6, scr_w, scr_h)
    if DWIN_Y[w0] != work_h(scr_h) / 2:
        write_str(1, "[DE11] FAIL bottom-panel quarter Y wrong\n")
        return
    # Now flip to a TOP panel and maximize: the window must start at PANEL_H.
    PANEL_POS = 0
    snap_apply(w0, 1, scr_w, scr_h)
    if DWIN_Y[w0] != PANEL_H:
        write_str(1, "[DE11] FAIL top-panel maximize did not clear the panel\n")
        return
    if DWIN_H[w0] != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL top-panel maximize height wrong\n")
        return
    # The live snap preview rect must track the panel position too.
    PANEL_POS = 1
    snap_zone_rect(1, scr_w, scr_h)
    if snapzone_y != 0 or snapzone_h != scr_h - PANEL_H:
        write_str(1, "[DE11] FAIL bottom-panel snap preview wrong\n")
        return
    PANEL_POS = 0
    snap_zone_rect(1, scr_w, scr_h)
    if snapzone_y != PANEL_H:
        write_str(1, "[DE11] FAIL top-panel snap preview wrong\n")
        return
    # Un-snap and clean up before the group test.
    snap_apply(w0, 0, scr_w, scr_h)
    write_str(1, "[DE11] panel-pos OK\n")

    # ---------------- Step 2: window-list group actions -----------------
    # Two calculators form a group; the lone terminal stays solo.
    daemon_spawn_app(APP_CALC, 100, PANEL_H + 40, 220, 300)
    daemon_spawn_app(APP_CALC, 140, PANEL_H + 60, 220, 300)
    if DWIN_COUNT < 3:
        write_str(1, "[DE11] FAIL calculators not spawned\n")
        return
    c_a: int64 = -1
    c_b: int64 = -1
    term_s: int64 = -1
    gi: uint64 = 0
    while gi < DWIN_COUNT:
        if DWIN_APP[gi] == APP_CALC:
            if c_a < 0:
                c_a = cast[int64](gi)
            else:
                c_b = cast[int64](gi)
        elif DWIN_APP[gi] == APP_TERM:
            term_s = cast[int64](gi)
        gi = gi + 1
    if c_a < 0 or c_b < 0 or term_s < 0:
        write_str(1, "[DE11] FAIL could not locate group test windows\n")
        return
    ca: uint64 = cast[uint64](c_a)
    if app_group_count(ca) != 2:
        write_str(1, "[DE11] FAIL calc group count is not 2\n")
        return
    # minimize-all hides both calculators (count 2) and leaves the terminal.
    if group_minimize_all(ca) != 2:
        write_str(1, "[DE11] FAIL minimize-all count wrong\n")
        return
    gj: uint64 = 0
    while gj < DWIN_COUNT:
        if DWIN_APP[gj] == APP_CALC and DWIN_HIDDEN[gj] == 0:
            write_str(1, "[DE11] FAIL a calculator stayed visible\n")
            return
        if DWIN_APP[gj] == APP_TERM and DWIN_HIDDEN[gj] != 0:
            write_str(1, "[DE11] FAIL terminal wrongly minimized\n")
            return
        gj = gj + 1
    # restore-all un-hides both calculators again.
    if group_restore_all(ca) != 2:
        write_str(1, "[DE11] FAIL restore-all count wrong\n")
        return
    gk: uint64 = 0
    while gk < DWIN_COUNT:
        if DWIN_APP[gk] == APP_CALC and DWIN_HIDDEN[gk] != 0:
            write_str(1, "[DE11] FAIL a calculator stayed minimized\n")
            return
        gk = gk + 1
    # close-all destroys every calculator window; the terminal survives.
    before: uint64 = DWIN_COUNT
    # re-find a calc slot (slots are stable until we close).
    ca2: int64 = -1
    gl: uint64 = 0
    while gl < DWIN_COUNT:
        if DWIN_APP[gl] == APP_CALC:
            ca2 = cast[int64](gl)
            gl = DWIN_COUNT
        else:
            gl = gl + 1
    if ca2 < 0:
        write_str(1, "[DE11] FAIL lost the calc group before close-all\n")
        return
    if group_close_all(cast[uint64](ca2)) != 2:
        write_str(1, "[DE11] FAIL close-all count wrong\n")
        return
    if DWIN_COUNT != before - 2:
        write_str(1, "[DE11] FAIL close-all window count wrong\n")
        return
    gm2: uint64 = 0
    while gm2 < DWIN_COUNT:
        if DWIN_APP[gm2] == APP_CALC:
            write_str(1, "[DE11] FAIL a calculator survived close-all\n")
            return
        gm2 = gm2 + 1
    write_str(1, "[DE11] group-actions OK\n")

    # ---------------- Step 3: Ctrl-Alt-arrow workspace nav --------------
    WS_COUNT = 4
    CUR_WS = 0
    # adjacent_ws wraps the row.
    if adjacent_ws(1) != 1:
        write_str(1, "[DE11] FAIL adjacent right wrong\n")
        return
    if adjacent_ws(-1) != WS_COUNT - 1:
        write_str(1, "[DE11] FAIL adjacent left did not wrap\n")
        return
    # Ctrl-Alt-Right then -Right walks 0 -> 1 -> 2.
    if workspace_step(1) != 1 or CUR_WS != 1:
        write_str(1, "[DE11] FAIL workspace_step right wrong\n")
        return
    if workspace_step(1) != 2 or CUR_WS != 2:
        write_str(1, "[DE11] FAIL second workspace_step wrong\n")
        return
    # Ctrl-Alt-Left wraps from 0 to the last workspace.
    CUR_WS = 0
    if workspace_step(-1) != WS_COUNT - 1 or CUR_WS != WS_COUNT - 1:
        write_str(1, "[DE11] FAIL workspace_step left wrap wrong\n")
        return
    # Ctrl-Alt-Shift-Right: move the focused window to the next workspace AND
    # follow it there. With one window on ws 0, it should land on ws 1 and
    # the active workspace becomes 1 too.
    CUR_WS = 0
    fs11: int64 = daemon_focus_slot()
    if fs11 < 0:
        write_str(1, "[DE11] FAIL no focused window for move test\n")
        return
    window_to_workspace(cast[uint64](fs11), 0)
    dest: int32 = window_to_adjacent_ws(1)
    if dest != 1 or CUR_WS != 1:
        write_str(1, "[DE11] FAIL move-to-adjacent did not follow window\n")
        return
    if DWIN_WS[cast[uint64](fs11)] != 1:
        write_str(1, "[DE11] FAIL window did not land on adjacent ws\n")
        return
    # And the wrap direction: from ws 0, Ctrl-Alt-Shift-Left -> last ws.
    CUR_WS = 0
    fs12: int64 = daemon_focus_slot()
    window_to_workspace(cast[uint64](fs12), 0)
    dest2: int32 = window_to_adjacent_ws(-1)
    if dest2 != WS_COUNT - 1 or DWIN_WS[cast[uint64](fs12)] != WS_COUNT - 1:
        write_str(1, "[DE11] FAIL move-to-adjacent left wrap wrong\n")
        return
    write_str(1, "[DE11] kbd-workspace OK\n")

    CUR_WS = 0
    PANEL_POS = 0
    daemon_present()
    write_str(1, "[DE11] PASS\n")


# ====================================================================
# ROUND-12 self-test (autoflag == 22)
# ====================================================================
# Round 11 made the WORK AREA panel-position-aware; round 12 finishes the
# job by physically rendering and HIT-TESTING the panel bar (menu buttons,
# taskbar, pager, tray, clock, Show Desktop) at the configured edge, and
# flipping the menu drop-downs to grow AWAY from the panel. It also adds a
# classic MATE "Show Desktop" panel applet.
#
# This test injects NO QEMU mouse/keys — it asserts geometry + actions for
# BOTH panel positions so a top-panel regression can never slip through:
#   1. panel_y0 / panel_local_y / on_panel_y / drop_anchor_y are correct
#      for a top AND a bottom panel.
#   2. Every panel hit-test (menubar_btn_at, in_apps_btn, in_clock_zone,
#      pager_cell_at, taskbar_slot_at, menubar_item_at) resolves at the
#      panel's REAL edge for each position, and rejects the opposite edge.
#   3. Menu drop-downs anchor below a top panel and above a bottom panel.
#   4. The Show Desktop applet: geometry sits left of the clock without
#      overlap, hit-tests on the bar for both positions, and its toggle
#      minimizes every visible window then restores exactly those.
# Emits "[DE12] PASS" / "[DE12] FAIL <reason>".
def daemon_round12_selftest(scr_w: int64, scr_h: int64):
    CUR_WS = 0
    PREV_BTN_L = 0
    PREV_BTN_R = 0
    CYCLE_OPEN = 0
    MRU_LEN = 0
    CTX_OPEN = 0
    MENU_BAR_OPEN = -1
    SUBMENU_OPEN = -1
    CAL_OPEN = 0
    NOTIFY_ACTIVE = 0
    FOCUS_MODE = 0
    SESSION_OPEN = 0
    LOCKED = 0
    DAEMON_QUIT = 0
    WS_COUNT = 4
    THEME_IDX = 0
    BG_IDX = 0
    PANEL_POS = 0
    SEARCH_OPEN = 0
    SEARCH_LEN = 0
    SHOWDESK_ON = 0
    theme_apply()
    bg_palette_init()

    # ---------------- Step 1: panel-local Y mapping ---------------------
    # Top panel: bar occupies absolute rows 0..PANEL_H-1.
    PANEL_POS = 0
    if panel_y0() != 0:
        write_str(1, "[DE12] FAIL top panel_y0 not 0\n")
        return
    if panel_local_y(0) != 0 or panel_local_y(PANEL_H - 1) != PANEL_H - 1:
        write_str(1, "[DE12] FAIL top panel_local_y wrong\n")
        return
    if on_panel_y(PANEL_H / 2) == 0:
        write_str(1, "[DE12] FAIL top panel mid not on bar\n")
        return
    if on_panel_y(scr_h - 1) != 0:
        write_str(1, "[DE12] FAIL top panel floor wrongly on bar\n")
        return
    # Bottom panel: bar occupies absolute rows scr_h-PANEL_H..scr_h-1.
    PANEL_POS = 1
    bot_y0: int64 = scr_h - PANEL_H
    if panel_y0() != bot_y0:
        write_str(1, "[DE12] FAIL bottom panel_y0 wrong\n")
        return
    if panel_local_y(bot_y0) != 0 or panel_local_y(scr_h - 1) != PANEL_H - 1:
        write_str(1, "[DE12] FAIL bottom panel_local_y wrong\n")
        return
    if on_panel_y(bot_y0 + PANEL_H / 2) == 0:
        write_str(1, "[DE12] FAIL bottom panel mid not on bar\n")
        return
    if on_panel_y(0) != 0 or on_panel_y(PANEL_H / 2) != 0:
        write_str(1, "[DE12] FAIL bottom panel ceiling wrongly on bar\n")
        return
    write_str(1, "[DE12] panel-local-Y OK\n")

    # ---------------- Step 2: drop-down anchoring flips -----------------
    # A drop-down of height H hangs BELOW a top panel and ABOVE a bottom one.
    drop_h: int64 = 5 * MENU_ITEM_H
    PANEL_POS = 0
    if drop_anchor_y(drop_h) != PANEL_H:
        write_str(1, "[DE12] FAIL top drop-down does not hang below the bar\n")
        return
    if drop_row_top(drop_h, 2, MENU_ITEM_H) != PANEL_H + 2 * MENU_ITEM_H:
        write_str(1, "[DE12] FAIL top drop-down row layout wrong\n")
        return
    PANEL_POS = 1
    if drop_anchor_y(drop_h) != bot_y0 - drop_h:
        write_str(1, "[DE12] FAIL bottom drop-down does not rise above the bar\n")
        return
    # The list's bottom row must butt against the panel's top edge.
    if drop_anchor_y(drop_h) + drop_h != bot_y0:
        write_str(1, "[DE12] FAIL bottom drop-down not flush to the bar\n")
        return
    write_str(1, "[DE12] drop-anchor OK\n")

    # ---------------- Step 3: panel hit-tests track the edge ------------
    # Pick an X firmly inside the Applications (menu button 0) zone and an X
    # inside the clock zone; assert each resolves on the bar's REAL edge and
    # NOT on the opposite (now-empty) edge.
    app_x: int64 = menubar_btn_x(0) + MENUBAR_PAD
    clk_x: int64 = scr_w - 4
    top_mid: int64 = PANEL_H / 2
    bot_mid: int64 = bot_y0 + PANEL_H / 2

    PANEL_POS = 0
    if menubar_btn_at(app_x, top_mid) != 0:
        write_str(1, "[DE12] FAIL top: Applications not hit on top edge\n")
        return
    if menubar_btn_at(app_x, bot_mid) >= 0:
        write_str(1, "[DE12] FAIL top: Applications wrongly hit on floor\n")
        return
    if in_apps_btn(APPS_BTN_X + 2, top_mid) == 0:
        write_str(1, "[DE12] FAIL top: in_apps_btn missed top edge\n")
        return
    if in_clock_zone(clk_x, top_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL top: clock zone missed top edge\n")
        return
    if in_clock_zone(clk_x, bot_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL top: clock zone hit the floor\n")
        return

    PANEL_POS = 1
    if menubar_btn_at(app_x, bot_mid) != 0:
        write_str(1, "[DE12] FAIL bottom: Applications not hit on floor\n")
        return
    if menubar_btn_at(app_x, top_mid) >= 0:
        write_str(1, "[DE12] FAIL bottom: Applications wrongly hit on ceiling\n")
        return
    if in_apps_btn(APPS_BTN_X + 2, bot_mid) == 0:
        write_str(1, "[DE12] FAIL bottom: in_apps_btn missed the floor\n")
        return
    if in_clock_zone(clk_x, bot_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL bottom: clock zone missed the floor\n")
        return
    if in_clock_zone(clk_x, top_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL bottom: clock zone hit the ceiling\n")
        return

    # Pager cell hit-test follows the edge too (cell 2 mid-cell).
    pcx: int64 = pager_x0(scr_w) + 2 * PAGER_CELL_W + PAGER_CELL_W / 2
    PANEL_POS = 0
    if pager_cell_at(pcx, top_mid, scr_w) != 2:
        write_str(1, "[DE12] FAIL top: pager cell 2 missed top edge\n")
        return
    if pager_cell_at(pcx, bot_mid, scr_w) >= 0:
        write_str(1, "[DE12] FAIL top: pager hit the floor\n")
        return
    PANEL_POS = 1
    if pager_cell_at(pcx, bot_mid, scr_w) != 2:
        write_str(1, "[DE12] FAIL bottom: pager cell 2 missed the floor\n")
        return
    if pager_cell_at(pcx, top_mid, scr_w) >= 0:
        write_str(1, "[DE12] FAIL bottom: pager hit the ceiling\n")
        return

    # An open drop-down's item hit-test resolves an item only off the live
    # edge. Open System (menu 2), pick the 3rd row, and probe it at the
    # anchored position for both panel positions.
    MENU_BAR_OPEN = 2
    mrow_h: int64 = menubar_total_h()
    sysx: int64 = menubar_drop_x() + 4
    PANEL_POS = 0
    pry_top: int64 = drop_anchor_y(mrow_h) + 2 * MENU_ITEM_H + MENU_ITEM_H / 2
    if menubar_item_at(sysx, pry_top) != 2:
        write_str(1, "[DE12] FAIL top: System row 2 hit-test wrong\n")
        return
    PANEL_POS = 1
    pry_bot: int64 = drop_anchor_y(mrow_h) + 2 * MENU_ITEM_H + MENU_ITEM_H / 2
    if menubar_item_at(sysx, pry_bot) != 2:
        write_str(1, "[DE12] FAIL bottom: System row 2 hit-test wrong\n")
        return
    if pry_bot >= bot_y0:
        write_str(1, "[DE12] FAIL bottom: drop row should be ABOVE the bar\n")
        return
    MENU_BAR_OPEN = -1
    write_str(1, "[DE12] hit-test OK\n")

    # ---------------- Step 4: Show Desktop applet -----------------------
    # Geometry: the button sits left of the clock and right of the tray with
    # no overlap, on BOTH edges.
    sdx: int64 = sd_btn_x0(scr_w)
    if sdx + SD_BTN_W > scr_w - CLOCK_W:
        write_str(1, "[DE12] FAIL Show Desktop overlaps the clock\n")
        return
    if notif_x0(scr_w) + NOTIF_W > sdx:
        write_str(1, "[DE12] FAIL tray overlaps Show Desktop\n")
        return
    sd_mid_x: int64 = sdx + SD_BTN_W / 2
    PANEL_POS = 0
    if in_show_desktop_btn(sd_mid_x, top_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL top: Show Desktop missed the bar\n")
        return
    if in_show_desktop_btn(sd_mid_x, bot_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL top: Show Desktop hit the floor\n")
        return
    PANEL_POS = 1
    if in_show_desktop_btn(sd_mid_x, bot_mid, scr_w) == 0:
        write_str(1, "[DE12] FAIL bottom: Show Desktop missed the floor\n")
        return
    if in_show_desktop_btn(sd_mid_x, top_mid, scr_w) != 0:
        write_str(1, "[DE12] FAIL bottom: Show Desktop hit the ceiling\n")
        return

    # Action: spawn two windows, toggle show-desktop -> both minimized and
    # SHOWDESK_ON; toggle again -> both restored, SHOWDESK_ON cleared.
    PANEL_POS = 0
    CUR_WS = 0
    daemon_spawn_window(80, PANEL_H + 24, 320, 200)
    daemon_spawn_window(120, PANEL_H + 60, 320, 200)
    if DWIN_COUNT < 2:
        write_str(1, "[DE12] FAIL show-desktop test windows not spawned\n")
        return
    vis_before: int64 = 0
    si: uint64 = 0
    while si < DWIN_COUNT:
        if DWIN_WS[si] == CUR_WS and DWIN_HIDDEN[si] == 0:
            vis_before = vis_before + 1
        si = si + 1
    if vis_before < 2:
        write_str(1, "[DE12] FAIL fewer than 2 visible windows pre-toggle\n")
        return
    show_desktop_toggle()
    if SHOWDESK_ON == 0:
        write_str(1, "[DE12] FAIL show-desktop did not arm\n")
        return
    sj: uint64 = 0
    while sj < DWIN_COUNT:
        if DWIN_WS[sj] == CUR_WS and DWIN_HIDDEN[sj] == 0:
            write_str(1, "[DE12] FAIL a window stayed visible after show-desktop\n")
            return
        sj = sj + 1
    show_desktop_toggle()
    if SHOWDESK_ON != 0:
        write_str(1, "[DE12] FAIL show-desktop did not disarm\n")
        return
    vis_after: int64 = 0
    sk: uint64 = 0
    while sk < DWIN_COUNT:
        if DWIN_WS[sk] == CUR_WS and DWIN_HIDDEN[sk] == 0:
            vis_after = vis_after + 1
        sk = sk + 1
    if vis_after != vis_before:
        write_str(1, "[DE12] FAIL show-desktop did not restore the windows\n")
        return
    write_str(1, "[DE12] show-desktop OK\n")

    CUR_WS = 0
    PANEL_POS = 0
    MENU_BAR_OPEN = -1
    daemon_present()
    write_str(1, "[DE12] PASS\n")


# Scratch buffer for the stdin command we inject.
term_test_cmd: Array[32, uint8]

def daemon_terminal_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: first autowin (hamsh + pipes) ---
    daemon_spawn_window(120, 80, 400, 240)
    if DWIN_COUNT == 0:
        write_str(1, "TERM IO FAIL no window spawned\n")
        return
    sl0: uint64 = DWIN_COUNT - 1
    infd: int32 = DWIN_IN_FD[sl0]
    outfd: int32 = DWIN_OUT_FD[sl0]
    if infd < 0:
        write_str(1, "TERM IO FAIL no stdin pipe for window 0\n")
        return
    if outfd < 0:
        write_str(1, "TERM IO FAIL no stdout pipe for window 0\n")
        return
    # --- Step 2: write the sentinel command to hamsh stdin ---
    # The command bytes sit in the pipe buffer until hamsh starts and
    # calls sys_read_nb(0,...). Since we patched hamsh to skip the
    # getty-style flush loop for pipe-backed stdin (DEVFD_PIPE_R), the
    # bytes are NOT discarded by the flush window — hamsh picks them up
    # on the very first readline poll pass.
    cmd_s: Ptr[uint8] = "echo HAMUI_TERM_TEST\n"
    sys_write(infd, cmd_s, strlen_u8(cmd_s))
    # --- Step 3: Non-blocking poll loop until the sentinel appears ---
    # We use sys_read_nb + sys_yield so the hamsh process gets CPU time
    # to start up and process the command. We stop as soon as the
    # sentinel appears in the grid. Idle = consecutive empty reads; we
    # cap at IDLE_MAX to bound run time (each yield is very fast on TCG).
    # On TCG hamsh may take thousands of scheduler rounds to start — a
    # large IDLE_MAX (200000) is safe and still completes well within
    # the 120s QEMU timeout.
    found0: int32 = 0
    idle0: int32 = 0
    while idle0 < 200000 and found0 == 0:
        n: int64 = sys_read_nb(outfd, &term_rx[0], 1024)
        if n > 0:
            idle0 = 0
            term_feed(sl0, &term_rx[0], n)
            if term_grid_contains(sl0, "HAMUI_TERM_TEST") != 0:
                found0 = 1
        else:
            idle0 = idle0 + 1
            sys_yield()
    if found0 == 0:
        write_str(1, "TERM IO FAIL sentinel not in window 0 grid\n")
        return
    write_str(1, "TERM IO window0 OK\n")
    # --- Step 4: focus-switch test ---
    # Create a second window so we can verify focus routing changes.
    daemon_spawn_window(200, 160, 400, 240)
    if DWIN_COUNT < 2:
        # Only one window was created (table full or spawn failed); skip
        # the two-window focus routing test.
        write_str(1, "TERM IO PASS (single-window)\n")
        return
    # Simulate a body-click on the FIRST window (slot 0) to raise it.
    # The first window is now slot 0 (two windows: 0 and 1, where 1 is
    # topmost after creation). Compute a point inside its body area.
    bclick_x: int64 = DWIN_X[0] + DWIN_W[0] / 2
    bclick_y: int64 = DWIN_Y[0] + TITLE_H + DWIN_H[0] / 2
    bclick_x = iclamp(bclick_x, 0, scr_w - 1)
    bclick_y = iclamp(bclick_y, 0, scr_h - 1)
    # Synthetic mouse click on the first window's body: press + release.
    CUR_X = bclick_x
    CUR_Y = bclick_y
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise the first window becomes the topmost slot; confirm focus.
    new_focus: int64 = daemon_focus_slot()
    focus_x: int64 = DWIN_X[cast[uint64](new_focus)]
    focus_y: int64 = DWIN_Y[cast[uint64](new_focus)]
    # The raised window's origin should match what we clicked into.
    in_raised: int32 = 0
    if bclick_x >= focus_x and bclick_x < focus_x + DWIN_W[cast[uint64](new_focus)]:
        if bclick_y >= focus_y and bclick_y < focus_y + DWIN_H[cast[uint64](new_focus)]:
            in_raised = 1
    if in_raised == 0:
        write_str(1, "TERM IO FAIL focus did not switch to clicked window\n")
        return
    write_str(1, "TERM IO focus-switch OK\n")
    # Route a second sentinel to the newly-focused window and confirm it
    # arrives in that window's grid.
    new_infd: int32 = DWIN_IN_FD[cast[uint64](new_focus)]
    if new_infd >= 0:
        new_outfd: int32 = DWIN_OUT_FD[cast[uint64](new_focus)]
        cmd2: Ptr[uint8] = "echo HAMUI_TERM_TEST2\n"
        sys_write(new_infd, cmd2, strlen_u8(cmd2))
        found2: int32 = 0
        idle2: int32 = 0
        while idle2 < 200000 and found2 == 0:
            n2: int64 = sys_read_nb(new_outfd, &term_rx[0], 1024)
            if n2 > 0:
                idle2 = 0
                term_feed(cast[uint64](new_focus), &term_rx[0], n2)
                if term_grid_contains(cast[uint64](new_focus), "HAMUI_TERM_TEST2") != 0:
                    found2 = 1
            else:
                idle2 = idle2 + 1
                sys_yield()
        if found2 == 0:
            write_str(1, "TERM IO FAIL sentinel2 not in focused window grid\n")
            return
    write_str(1, "TERM IO window1 OK\n")
    write_str(1, "TERM IO PASS\n")


# ====================================================================
# GPU track #183 — native Vulkan output INTO a real desktop window
# ====================================================================
#
# daemon_vk_window_selftest creates a NORMAL composited window at a known
# on-screen position whose BODY is filled by the native kernel-side
# lib/vk software rasterizer (a rotating triangle). Each frame the daemon
# asks the kernel to render the next frame into the window's draw-surface
# "vk" fb layer (sys_vk_window_frame), reads that layer back into
# vk_body_buf, marks the window as vk-bodied, composites the WHOLE screen
# through the SAME daemon_present path every other window uses, and
# samples the composited result to prove:
#   * inside the window's body rect the screen shows the Vulkan colours,
#   * OUTSIDE the window the screen shows the desktop backdrop (proving
#     it is WINDOWED, not a full-screen takeover),
#   * frame N and frame N+1 differ at a pixel the rotation moves (live
#     animation, not a static blit).
# All assertions read the composited frame through daemon_pixel — the
# exact value written to /dev/fb at that screen pixel — so they are
# unforgeable. Markers print as "[vk-window] ..." lines.

# Read window `wid`'s "vk" draw-surface fb layer into vk_body_buf. The
# layer is RGBA8888, up to VK_BODY_W x VK_BODY_H. Returns the bytes read.
def daemon_vk_read_body(wid: int32) -> int64:
    vp: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while vp[j] != 0:
        path_buf[i] = vp[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    sfx: Ptr[uint8] = "/draw/vk/fb"
    j = 0
    while sfx[j] != 0:
        path_buf[i] = sfx[j]
        i = i + 1
        j = j + 1
    path_buf[i] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &vk_body_buf[0],
                          cast[uint64](VK_BODY_W * VK_BODY_H * 4))
    sys_close(fd)
    return n


# Sample the composited screen colour at (sx,sy) into r/g/b via the SAME
# daemon_pixel path that fills /dev/fb. Returns packed 0xRRGGBB.
def daemon_screen_sample(sx: int64, sy: int64) -> uint64:
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    daemon_pixel(sx, sy, &rr[0], &gg[0], &bb[0])
    return (cast[uint64](rr[0]) << 16) | (cast[uint64](gg[0]) << 8) \
        | cast[uint64](bb[0])


def daemon_vk_window_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: create a normal window at a fixed on-screen position.
    # 320x260 box on the RIGHT half (clear of the kernel fb text console
    # which paints the top-left). Body is 192x192-friendly.
    win_x: int64 = 700
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 260
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    # A chrome-only window (no child shell): the body is the Vulkan image.
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[vk-window] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[vk-window] FAIL no wid for window\n")
        return
    DWIN_VK[sl] = 1
    # Body origin in screen space (where the Vulkan image lands).
    body_x: int64 = DWIN_X[sl] + 2
    body_y: int64 = DWIN_Y[sl] + TITLE_H
    # A pixel near the body centre (inside the 192x192 vk image) and a
    # pixel clearly OUTSIDE the window (the desktop backdrop).
    in_x: int64 = body_x + VK_BODY_W / 2
    in_y: int64 = body_y + VK_BODY_H / 2
    out_x: int64 = DWIN_X[sl] - 40
    out_y: int64 = DWIN_Y[sl] + 30
    if out_x < 0:
        out_x = 4
        out_y = 4
    # Animation-probe pixel: just left of body centre, on the orbit the
    # rotating triangle sweeps through, so a frame change toggles it.
    an_x: int64 = body_x + VK_BODY_W / 2 - 20
    an_y: int64 = body_y + VK_BODY_H / 2

    # --- Step 2: render frame 0, read it back, composite, sample. ---
    if sys_vk_window_frame(wid, 0, 0) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(0)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer\n")
        return
    vk_body_ready = 1
    daemon_present()
    in0: uint64 = daemon_screen_sample(in_x, in_y)
    out0: uint64 = daemon_screen_sample(out_x, out_y)
    an0: uint64 = daemon_screen_sample(an_x, an_y)
    # The backdrop colour packed for comparison.
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    # (a) Outside the window must be the desktop backdrop -> WINDOWED.
    if out0 == bg:
        write_str(1, "[vk-window] OK windowed (backdrop outside window)\n")
    else:
        write_str(1, "[vk-window] FAIL area outside window is not backdrop\n")
        return
    # (b) Inside the body must NOT be the backdrop and NOT the plain body
    #     fill — it must be Vulkan-rendered content.
    bodyfill: uint64 = (cast[uint64](WIN_BODY_R) << 16) \
        | (cast[uint64](WIN_BODY_G) << 8) | cast[uint64](WIN_BODY_B)
    if in0 != bg and in0 != bodyfill:
        write_str(1, "[vk-window] OK vulkan pixels inside window body\n")
    else:
        write_str(1, "[vk-window] FAIL body pixel is not vulkan content\n")
        return

    # --- Step 3: render a LATER frame, re-composite, prove animation. ---
    # Step several frames so the rotation visibly moves the probe pixel.
    if sys_vk_window_frame(wid, 0, 6) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(6)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer (frame 6)\n")
        return
    daemon_present()
    an6: uint64 = daemon_screen_sample(an_x, an_y)
    in6: uint64 = daemon_screen_sample(in_x, in_y)
    if an6 != an0 or in6 != in0:
        write_str(1, "[vk-window] OK animation (frame differs)\n")
    else:
        write_str(1, "[vk-window] FAIL frames identical (no animation)\n")
        return
    # Final present so a screendump catches the windowed Vulkan frame.
    daemon_present()
    write_str(1, "[vk-window] PASS\n")


# Scan window `slot`'s terminal grid for the NUL-terminated ASCII string
# `needle`. Returns 1 if found at any position (across row boundaries via
# grid linearisation), else 0.
def term_grid_contains(slot: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(needle)
    if nlen == 0:
        return 1
    base: uint64 = slot * GRID_CELLS
    cells: uint64 = cast[uint64](DWIN_ROWS[slot] * GRID_COLS_MAX)
    if cells > GRID_CELLS:
        cells = GRID_CELLS
    i: uint64 = 0
    while i + nlen <= cells:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            gc: uint8 = term_grid[base + i + k]
            nc: uint8 = needle[k]
            if gc != nc:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


# Focused window = the most-recently-created one (topmost). Returns its
# slot index, or -1 if there are no windows.
def daemon_focus_slot() -> int64:
    if DWIN_COUNT == 0:
        return -1
    return cast[int64](DWIN_COUNT) - 1


# Keyboard escape-sequence interception state for WM hotkeys. The atkbd
# driver emits VT220 sequences (no modifier encoding):
#   F1..F4   -> ESC O P / Q / R / S   -> switch to workspace 1..4
#   PageUp   -> ESC [ 5 ~             -> previous workspace
#   PageDown -> ESC [ 6 ~             -> next workspace
#   Shift+F1 -> ESC [ 2 5 ~           -> shade/unshade focused window (R9)
#   Shift+F2 -> ESC [ 2 6 ~           -> always-on-top toggle focused win (R9)
# We run a tiny 3-state matcher across reads so a sequence straddling a
# read boundary is still caught. A matched hotkey is CONSUMED (not routed
# to the focused shell); all other bytes pass through unchanged.
# KEY_ST: 0 = ground, 1 = saw ESC, 2 = saw ESC '[', 3 = saw ESC 'O'.
#   F5/F6  -> ESC [ 1 5 ~ / ESC [ 1 7 ~  -> alt-tab cycler next / prev
# In st==2 we accumulate the CSI numeric parameter (KEY_CSI_PARAM) across
# digits and only dispatch on the final '~', so multi-digit codes (15/17)
# don't collide with the single-digit PageUp/PageDown (5/6).
KEY_ST: int32 = 0
KEY_CSI_PARAM: int32 = 0
# ROUND-11: the CSI modifier sub-parameter (the value after ';' in a
# sequence like ESC [ 1 ; 7 C). xterm encodes modifiers as 1+bitmask:
#   2 = Shift  3 = Alt  5 = Ctrl  7 = Ctrl+Alt  8 = Ctrl+Alt+Shift
# We use it to recognise the standard MATE workspace shortcuts on the
# arrow keys (final bytes C = Right, D = Left). KEY_CSI_SEMI flips to 1
# once we have seen the ';' so subsequent digits land in KEY_CSI_MOD.
KEY_CSI_MOD: int32 = 0
KEY_CSI_SEMI: int32 = 0
# Pending pass-through bytes that were part of an aborted sequence.
key_passthru: Array[8, uint8]


# Route a run of literal bytes from cons_rx[a..b) to the focused window.
def key_route(a: uint64, b: uint64, fslot: int64) -> int32:
    if b <= a or fslot < 0:
        return 0
    fs: uint64 = cast[uint64](fslot)
    wfd: int32 = DWIN_IN_FD[fs]
    if wfd < 0:
        # No child pipe: a built-in calculator window is keyboard-usable
        # too — feed digit/operator keystrokes straight to its handler.
        if DWIN_APP[fs] == APP_CALC:
            ki: uint64 = a
            routed_k: int32 = 0
            while ki < b:
                kc: uint8 = cons_rx[ki]
                if (kc >= 48 and kc <= 57) or kc == 43 or kc == 45 \
                   or kc == 42 or kc == 47 or kc == 61 or kc == 67 \
                   or kc == 99:
                    if kc == 99:                 # 'c' lowercase clears too
                        kc = 67
                    calc_press(fs, kc)
                    routed_k = 1
                elif kc == 13 or kc == 10:       # Enter == '=' on the calc
                    calc_press(fs, 61)
                    routed_k = 1
                ki = ki + 1
            return routed_k
        return 0
    sys_write(wfd, &cons_rx[a], b - a)
    return 1


# Drain /dev/cons (non-blocking). WM hotkey escape sequences (F1..F4,
# PageUp/PageDown) are intercepted to drive workspaces; everything else is
# routed to the focused window's child-stdin pipe. Returns 1 if anything
# was routed OR a workspace hotkey fired (the screen needs a re-present).
def daemon_pump_keys(scr_w: int64, scr_h: int64) -> int32:
    if cons_fd < 0:
        return 0
    fslot: int64 = daemon_focus_slot()
    routed: int32 = 0
    iters: int32 = 0
    while iters < 16:
        n: int64 = sys_read_nb(cons_fd, &cons_rx[0], 256)
        iters = iters + 1
        if n <= 0:
            break
        total: uint64 = cast[uint64](n)
        i: uint64 = 0
        run_start: uint64 = 0           # start of the current literal run
        while i < total:
            c: uint8 = cons_rx[i]
            st: int32 = KEY_ST
            if st == 0:
                # ROUND-10: while the Applications search box is open, ground-
                # state printable bytes filter the menu instead of reaching
                # the focused shell. ESC still begins a sequence (so it can
                # close the menu on ESC '[' fallthrough or a bare ESC below).
                if SEARCH_OPEN != 0 and c != 27:
                    # Flush any pending literal run first (defensive).
                    routed = key_route(run_start, i, fslot) | routed
                    if c == 8 or c == 127:           # Backspace / DEL
                        search_backspace()
                    elif c == 13 or c == 10:         # Enter -> launch 1st match
                        if menu_search_count() > 0:
                            sfl: uint64 = menu_search_nth(0)
                            MENU_BAR_OPEN = -1
                            SUBMENU_OPEN = -1
                            search_reset()
                            if sfl < MENU_COUNT:
                                menu_launch(sfl, scr_w, scr_h)
                    elif c >= 32 and c < 127:        # printable -> append
                        search_push(c)
                    routed = 1
                    run_start = i + 1
                    i = i + 1
                    continue
                if c == 27:             # ESC: flush the literal run, begin
                    routed = key_route(run_start, i, fslot) | routed
                    KEY_ST = 1
                i = i + 1
            elif st == 1:
                if c == 91:             # '['
                    KEY_ST = 2
                    KEY_CSI_PARAM = 0   # begin a fresh CSI parameter
                    KEY_CSI_MOD = 0     # ROUND-11: fresh modifier sub-param
                    KEY_CSI_SEMI = 0
                elif c == 79:           # 'O'
                    KEY_ST = 3
                else:
                    # ROUND-10: a bare ESC (ESC followed by a non-CSI byte)
                    # closes an open Applications search/menu.
                    if SEARCH_OPEN != 0:
                        MENU_BAR_OPEN = -1
                        SUBMENU_OPEN = -1
                        search_reset()
                        routed = 1
                    KEY_ST = 0          # not a tracked sequence: drop ESC+c
                    run_start = i + 1
                i = i + 1
            elif st == 2:
                # ESC [ <digits> ~ : accumulate the numeric parameter, then
                # dispatch on the final '~'. Codes:
                #   5 = PageUp  -> prev workspace   6 = PageDown -> next ws
                #  15 = F5      -> cycle next      17 = F6       -> cycle prev
                if c >= 48 and c <= 57:
                    if KEY_CSI_SEMI != 0:
                        # ROUND-11: digits after ';' build the modifier param.
                        KEY_CSI_MOD = KEY_CSI_MOD * 10 + (cast[int32](c) - 48)
                    else:
                        KEY_CSI_PARAM = KEY_CSI_PARAM * 10 + (cast[int32](c) - 48)
                elif c == 59:           # ';' -> a modifier sub-param follows
                    KEY_CSI_SEMI = 1
                elif c == 67 or c == 68:
                    # ROUND-11: arrow finals C (Right) / D (Left). MATE's
                    # standard workspace shortcuts. dir = +1 for Right, -1
                    # for Left. The xterm modifier byte (KEY_CSI_MOD) selects:
                    #   7 (Ctrl+Alt)        -> switch to the adjacent workspace
                    #   8 (Ctrl+Alt+Shift)  -> move the focused window there
                    # Unmodified / other arrows are left for the shell, so we
                    # only consume the Ctrl-Alt(+Shift) variants.
                    dir11: int32 = 1
                    if c == 68:
                        dir11 = -1
                    if KEY_CSI_MOD == 8:
                        window_to_adjacent_ws(dir11)
                        routed = 1
                    elif KEY_CSI_MOD == 7:
                        workspace_step(dir11)
                        routed = 1
                    KEY_ST = 0
                    run_start = i + 1
                elif c == 126:          # '~' final byte: dispatch
                    if KEY_CSI_PARAM == 5:
                        workspace_switch(CUR_WS - 1)
                    elif KEY_CSI_PARAM == 6:
                        workspace_switch(CUR_WS + 1)
                    elif KEY_CSI_PARAM == 15:
                        cycle_step(1)
                    elif KEY_CSI_PARAM == 17:
                        cycle_step(-1)
                    elif KEY_CSI_PARAM == 1:
                        tile_focused(4, scr_w, scr_h)   # Home  -> top-left 1/4
                    elif KEY_CSI_PARAM == 2:
                        tile_focused(6, scr_w, scr_h)   # Insert-> bot-left 1/4
                    elif KEY_CSI_PARAM == 3:
                        tile_focused(7, scr_w, scr_h)   # Delete-> bot-right 1/4
                    elif KEY_CSI_PARAM == 4:
                        tile_focused(5, scr_w, scr_h)   # End   -> top-right 1/4
                    elif KEY_CSI_PARAM == 18:
                        tile_focused(2, scr_w, scr_h)   # F7    -> left half
                    elif KEY_CSI_PARAM == 19:
                        tile_focused(3, scr_w, scr_h)   # F8    -> right half
                    elif KEY_CSI_PARAM == 20:
                        tile_focused(1, scr_w, scr_h)   # F9    -> maximize
                    elif KEY_CSI_PARAM == 21:
                        show_desktop_toggle()           # F10   -> show desktop
                    elif KEY_CSI_PARAM == 23:
                        kms: int64 = daemon_focus_slot()  # F11 -> win to next ws
                        if kms >= 0:
                            nws2: int32 = CUR_WS + 1
                            if nws2 >= WS_COUNT:
                                nws2 = 0
                            window_to_workspace(cast[uint64](kms), nws2)
                    elif KEY_CSI_PARAM == 24:
                        kmp: int64 = daemon_focus_slot()  # F12 -> win to prev ws
                        if kmp >= 0:
                            pws: int32 = CUR_WS - 1
                            if pws < 0:
                                pws = WS_COUNT - 1
                            window_to_workspace(cast[uint64](kmp), pws)
                    elif KEY_CSI_PARAM == 25:
                        ksh: int64 = daemon_focus_slot()  # Shift+F1 -> shade
                        if ksh >= 0:
                            window_toggle_shade(cast[uint64](ksh))
                    elif KEY_CSI_PARAM == 26:
                        kot: int64 = daemon_focus_slot()  # Shift+F2 -> on-top
                        if kot >= 0:
                            window_toggle_ontop(cast[uint64](kot))
                    routed = 1
                    KEY_ST = 0
                    run_start = i + 1
                # Any other final byte (letter): some other CSI (arrows
                # etc.) — drop it rather than corrupt the shell.
                if c != 126 and (c >= 64 and c <= 126):
                    KEY_ST = 0
                    run_start = i + 1
                i = i + 1
            else:
                # ESC O <final> : F1..F4 -> workspace 1..4.
                if c == 80:             # 'P' = F1
                    workspace_switch(0)
                    routed = 1
                elif c == 81:           # 'Q' = F2
                    workspace_switch(1)
                    routed = 1
                elif c == 82:           # 'R' = F3
                    workspace_switch(2)
                    routed = 1
                elif c == 83:           # 'S' = F4
                    workspace_switch(3)
                    routed = 1
                KEY_ST = 0
                run_start = i + 1
                i = i + 1
        # Flush any trailing literal run (only when in ground state).
        if KEY_ST == 0:
            routed = key_route(run_start, total, fslot) | routed
    return routed


# Drain every window's stdout pipe into its grid. Returns 1 if any
# window produced output (the screen needs a re-present).
def daemon_pump_terms() -> int32:
    changed: int32 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if term_pump(wi) != 0:
            changed = 1
        wi = wi + 1
    return changed


def cmd_daemon_auto(autoflag: int32) -> int32:
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: daemon: cannot read /dev/fb geometry\n")
        return 1
    mp: Ptr[uint8] = "/dev/mouse"
    mfd: int32 = sys_open(cast[Ptr[char]](mp))
    if mfd < 0:
        write_str(2, "hamUId: daemon: cannot open /dev/mouse\n")
        return 1
    mouse_fd = mfd
    # Open /dev/cons for keystroke polling (best-effort: if it fails the
    # daemon still composites + spawns shells, just without key routing).
    font_init()
    # ROUND-4: seed the title-bar accent + background palettes so the
    # themeable chrome starts from a known default (Clearlooks Blue).
    theme_apply()
    bg_palette_init()
    cp: Ptr[uint8] = "/dev/cons"
    cons_fd = sys_open(cast[Ptr[char]](cp))
    scr_w: int64 = cast[int64](FBG_W)
    scr_h: int64 = cast[int64](FBG_H)
    # Cursor starts at screen centre.
    CUR_X = scr_w / 2
    CUR_Y = scr_h / 2
    # Announce so a test can detect the daemon came up and parse geometry.
    line: Array[96, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "DAEMON up screen="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(FBG_W, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(FBG_H, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)
    # First frame (backdrop + cursor at centre).
    daemon_present()
    # Optional auto-window: create one terminal window programmatically
    # (mouse-free) so a test can exercise the in-window shell. The rect
    # is a fixed 480x320 box on the RIGHT half of the screen — clear of
    # the kernel framebuffer text console, which renders an 80-column
    # (~640px-wide) region anchored at the top-left and would otherwise
    # repaint over a left-side window between the daemon's frames.
    if autoflag == 1 or autoflag == 2:
        daemon_spawn_window(720, 80, 480, 320)
        write_str(1, "DAEMON autowin created\n")
        daemon_present()
    # WM self-test (autoflag == 2): drive a title-drag move + close-box
    # click through synthetic packets so the gestures are exercised
    # deterministically without QEMU mouse injection.
    if autoflag == 2:
        daemon_wm_selftest(scr_w, scr_h)
        daemon_present()
    # PANEL self-test (autoflag == 3): drive the Applications menu open +
    # a menu-item launch through the SAME gesture machine, emitting the
    # PANEL serial markers, so a non-interactive test can assert the
    # launcher without QEMU mouse injection.
    if autoflag == 3:
        daemon_panel_selftest(scr_w, scr_h)
        daemon_present()
    # TERMINAL I/O self-test (autoflag == 5): create two windows, write a
    # sentinel command to each child's stdin pipe, pump stdout into the
    # terminal grid, and verify the sentinel string appears in the grid.
    # Also exercises the body-click focus-switch: clicking window 0's body
    # raises it to the top (emitting "WM focus window") and routes input
    # to its pipe. Does NOT enter the main loop — exits after the test.
    if autoflag == 5:
        daemon_terminal_selftest(scr_w, scr_h)
        return 0
    # TASKBAR / MINIMIZE / CLOCK self-test (autoflag == 6): exercises the
    # three new panel features: window-list taskbar, minimize/restore, and
    # live clock. Does NOT enter the main loop — exits after the test.
    if autoflag == 6:
        daemon_taskbar_selftest(scr_w, scr_h)
        return 0
    # VULKAN WINDOW self-test (autoflag == 8): create a normal composited
    # window, drive the kernel software rasterizer (SYS_VK_WINDOW_FRAME) to
    # render an animated triangle into that window's draw surface, composite
    # it, and assert the Vulkan pixels land inside the window body, the
    # backdrop shows outside it (proving windowed, not full-screen), and the
    # frame changes when the animation advances. Exits after the test.
    if autoflag == 8:
        daemon_vk_window_selftest(scr_w, scr_h)
        return 0
    # WORKSPACE self-test (autoflag == 9): create a window, switch virtual
    # desktops, and assert via composited-pixel sampling that the window is
    # only visible on its own workspace; also exercise the pager click and
    # the hotkey-path switch. Exits after the test.
    if autoflag == 9:
        daemon_workspace_selftest(scr_w, scr_h)
        return 0
    # DECORATION self-test (autoflag == 10): sample composited pixels to
    # verify the title-bar gradient, beveled border corners, the maximize
    # button, and the maximize/restore geometry toggle. Exits after.
    if autoflag == 10:
        daemon_decoration_selftest(scr_w, scr_h)
        return 0
    # CONTEXT-MENU self-test (autoflag == 11): verify the GNOME2 menu bar
    # opens, the right-click desktop + window context menus composite, and
    # their actions (New Terminal spawn, window Close) fire. Exits after.
    if autoflag == 11:
        daemon_ctxmenu_selftest(scr_w, scr_h)
        return 0
    # DESKTOP APPS self-test (autoflag == 12): built-in calculator, system
    # monitor, and window snapping/maximize. Exits after the test.
    if autoflag == 12:
        daemon_apps_selftest(scr_w, scr_h)
        return 0
    # ROUND-3 MATE-feel self-test (autoflag == 13): alt-tab cycler,
    # double-click-titlebar maximize, change-background, arrange-windows,
    # and notification-area geometry. Exits after the test.
    if autoflag == 13:
        daemon_round3_selftest(scr_w, scr_h)
        return 0
    # ROUND-4 MATE-feel self-test (autoflag == 14): theme accent cycling,
    # background + panel-position prefs, keyboard half/quarter tiling,
    # show-desktop toggle, move-window-to-workspace, and the Settings app.
    if autoflag == 14:
        daemon_round4_selftest(scr_w, scr_h)
        return 0
    # ROUND-5 MATE-feel self-test (autoflag == 15): MRU Alt-Tab order,
    # edge/corner drag snapping + live preview, live tray window-count
    # badge, pager click-to-switch, and the desktop context-menu Settings
    # row. Exits after the test.
    if autoflag == 15:
        daemon_round5_selftest(scr_w, scr_h)
        return 0
    # ROUND-6 MATE-feel self-test (autoflag == 16): interactive window
    # resize by dragging edges/corners (8-direction grips, minimum sizes,
    # opposite-edge anchoring), the window-menu "Resize" entry, and the
    # live resize frame. Exits after the test.
    if autoflag == 16:
        daemon_round6_selftest(scr_w, scr_h)
        return 0
    # ROUND-7 MATE-feel self-test (autoflag == 17): categorised Applications
    # menu with submenu flyouts, clock calendar popup + date arithmetic,
    # taskbar grouping/raise, the Settings focus-model row + focus-follows-
    # mouse, and the transient notification-banner lifecycle. Exits after.
    if autoflag == 17:
        daemon_round7_selftest(scr_w, scr_h)
        return 0
    # ROUND-8 MATE-feel self-test (autoflag == 18): the modal session dialog
    # (Lock Screen / Log Out / Shut Down / Cancel) + screen lock overlay, and
    # the Settings "Workspaces" row that reconfigures the number of virtual
    # desktops. Exits after the test.
    if autoflag == 18:
        daemon_round8_selftest(scr_w, scr_h)
        return 0
    # ROUND-9 MATE-feel self-test (autoflag == 19): window shading (roll-up
    # to the title bar + unshade), always-on-top z-order pinning, and the
    # vertical/horizontal maximize window-menu rows. Exits after the test.
    if autoflag == 19:
        daemon_round9_selftest(scr_w, scr_h)
        return 0
    # ROUND-10 MATE-feel self-test (autoflag == 20): workspace pager
    # drag-window-between-workspaces, window-list grouping (collapse same-
    # app windows to one (N) button + click-to-cycle), and the Applications
    # menu type-to-search filter. Exits after the test.
    if autoflag == 20:
        daemon_round10_selftest(scr_w, scr_h)
        return 0
    # ROUND-11 MATE-feel self-test (autoflag == 21): panel-position-aware
    # work area (top vs bottom panel reserves the right strip; snap/maximize
    # + live preview follow it), window-list group actions (minimize/restore/
    # close-all), and the standard Ctrl-Alt-arrow workspace navigation +
    # Ctrl-Alt-Shift-arrow move-window-to-adjacent-workspace. Exits after.
    if autoflag == 21:
        daemon_round11_selftest(scr_w, scr_h)
        return 0
    # ROUND-12 MATE-feel self-test (autoflag == 22): the panel BAR + all its
    # hit-tests now render at the configured edge (top OR bottom), the menu
    # drop-downs grow away from the panel, and a classic Show Desktop applet
    # minimizes/restores every window. Asserts BOTH panel positions. Exits.
    if autoflag == 22:
        daemon_round12_selftest(scr_w, scr_h)
        return 0
    # Initial clock + system-monitor seed (before the first frame so the
    # panel shows a time and any System Monitor window shows live stats).
    clock_refresh(0)
    sysmon_refresh(0)
    # ROUND-7: greet the user with a transient notification banner so the
    # notification surface is exercised on every real boot of the DE.
    notify_post("Welcome to Hamnix", "Click Applications to launch an app")
    # Main loop. Cooperative: yield every idle iteration so we never
    # monopolise the CPU and the spawned hamsh tasks still run.
    prev_wins: uint64 = DWIN_COUNT
    idle_ctr: uint64 = 0
    # Uptime centisecond counter, approximated from idle iterations.
    # Each sys_yield() is ~1-2ms on TCG; we add 2 each iteration.
    # clock_refresh only fires once per 100 cs anyway (1 second).
    loop_cs: uint64 = 0
    while True:
        WM_FRAME = WM_FRAME + 1
        ch: int32 = daemon_pump_mouse(scr_w, scr_h)
        # Route keystrokes to the focused window's shell, then drain
        # every shell's stdout into its terminal grid.
        daemon_pump_keys(scr_w, scr_h)
        # Alt-tab cycler: while the switcher popup is up, count idle frames
        # since the last cycle keypress; auto-commit (raise the selection)
        # once the user stops pressing F5/F6 (MATE releases on key-up).
        if CYCLE_OPEN != 0:
            if CYCLE_PRESSED != 0:
                CYCLE_IDLE = 0
            else:
                CYCLE_IDLE = CYCLE_IDLE + 1
                if CYCLE_IDLE >= CYCLE_COMMIT:
                    cycle_commit()
            ch = 1
        CYCLE_PRESSED = 0
        tch: int32 = daemon_pump_terms()
        # Re-present when the mouse moved/clicked, a drag is in progress
        # (rubber band must track), a window was created, or any shell
        # emitted output (prompt / command echo).
        need: int32 = ch
        if tch != 0:
            need = 1
        if DRAG_ACTIVE != 0:
            need = 1
        if DWIN_COUNT != prev_wins:
            need = 1
            prev_wins = DWIN_COUNT
        # The kernel framebuffer console (the foreground hamsh's
        # heartbeat / log chatter) shares /dev/fb and repaints over the
        # desktop. As the screen owner, the daemon periodically forces a
        # full re-present so its desktop reasserts ownership even when
        # nothing in the model changed — keeping windows continuously
        # visible. (~once every 64 idle iterations.)
        idle_ctr = idle_ctr + 1
        loop_cs = loop_cs + 2
        # ROUND-7: age any on-screen notification banner; while it is up we
        # re-present every frame so its fade animates smoothly.
        if notify_tick() != 0:
            need = 1
        if idle_ctr >= 64:
            need = 1
            idle_ctr = 0
            # Refresh the clock + system-monitor stats once per idle cycle
            # (~every second).
            clock_refresh(loop_cs)
            sysmon_refresh(loop_cs)
        if need != 0:
            daemon_present()
        # Log Out / Shut Down (ROUND-8 session dialog) request a clean
        # shutdown of the daemon so the console returns to the foreground
        # shell. SESSION_INTENT distinguishes the two for the boot scripts.
        if DAEMON_QUIT != 0:
            if SESSION_INTENT == 2:
                write_str(1, "DAEMON shutdown\n")
            else:
                write_str(1, "DAEMON logout\n")
            break
        sys_yield()
    return 0


def usage(fd: int32):
    write_str(fd, "Usage: hamUId render <wid> | hamUId present <wid> | hamUId daemon [autowin|wmselftest|panelselftest|terminalselftest|taskbarselftest|vkwindowselftest|workspaceselftest|decorationselftest|ctxmenuselftest|appsselftest|round3selftest|round4selftest|round5selftest|round6selftest|round7selftest|round8selftest|round9selftest|round10selftest|round11selftest|round12selftest]\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        usage(2)
        return 1
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if cstr_eq(verb, "render") != 0:
        if argc < 3:
            write_str(2, "hamUId: render: missing wid\n")
            return 1
        wid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if wid < 1:
            write_str(2, "hamUId: render: bad wid\n")
            return 1
        return cmd_render(wid)
    if cstr_eq(verb, "present") != 0:
        if argc < 3:
            write_str(2, "hamUId: present: missing wid\n")
            return 1
        pwid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if pwid < 1:
            write_str(2, "hamUId: present: bad wid\n")
            return 1
        return cmd_present(pwid)
    if cstr_eq(verb, "daemon") != 0:
        # Optional `autowin` arg: immediately drag-create one terminal
        # window (mouse-free) so a non-interactive test can exercise the
        # in-window shell without driving QEMU mouse events.
        autoflag: int32 = 0
        if argc >= 3:
            a2: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
            if cstr_eq(a2, "autowin") != 0:
                autoflag = 1
            # `wmselftest` => autowin + a mouse-free move+close self-test.
            if cstr_eq(a2, "wmselftest") != 0:
                autoflag = 2
            # `panelselftest` => a mouse-free panel/menu open+launch test.
            if cstr_eq(a2, "panelselftest") != 0:
                autoflag = 3
            # `terminalselftest` => per-window stdin→stdout→grid I/O test.
            if cstr_eq(a2, "terminalselftest") != 0:
                autoflag = 5
            # `taskbarselftest` => taskbar/minimize/clock feature test.
            if cstr_eq(a2, "taskbarselftest") != 0:
                autoflag = 6
            # `vkwindowselftest` => kernel Vulkan rasterizer into a window.
            if cstr_eq(a2, "vkwindowselftest") != 0:
                autoflag = 8
            # `workspaceselftest` => MATE virtual desktops + pager.
            if cstr_eq(a2, "workspaceselftest") != 0:
                autoflag = 9
            # `decorationselftest` => themed window decorations + maximize.
            if cstr_eq(a2, "decorationselftest") != 0:
                autoflag = 10
            # `ctxmenuselftest` => right-click context menus + menu bar.
            if cstr_eq(a2, "ctxmenuselftest") != 0:
                autoflag = 11
            # `appsselftest` => built-in apps (calc/sysmon) + snapping test.
            if cstr_eq(a2, "appsselftest") != 0:
                autoflag = 12
            # `round3selftest` => alt-tab cycler, dblclick maximize,
            # change-background, arrange-windows, tray geometry.
            if cstr_eq(a2, "round3selftest") != 0:
                autoflag = 13
            # `round4selftest` => theme accent, prefs, keyboard tiling,
            # show-desktop, move-to-workspace, Settings app.
            if cstr_eq(a2, "round4selftest") != 0:
                autoflag = 14
            # `round5selftest` => MRU alt-tab, drag edge/corner snapping +
            # live preview, live tray badge, pager click, ctx-menu Settings.
            if cstr_eq(a2, "round5selftest") != 0:
                autoflag = 15
            # `round6selftest` => interactive window resize by edges/corners,
            # the window-menu Resize entry, and the live resize frame.
            if cstr_eq(a2, "round6selftest") != 0:
                autoflag = 16
            # `round7selftest` => categorised Applications menu + submenus,
            # clock calendar popup, taskbar raise, focus-model setting +
            # focus-follows-mouse, transient notification banner.
            if cstr_eq(a2, "round7selftest") != 0:
                autoflag = 17
            # `round8selftest` => session dialog (lock/logout/shutdown/cancel),
            # screen-lock overlay, and the Settings Workspaces-count row.
            if cstr_eq(a2, "round8selftest") != 0:
                autoflag = 18
            # `round9selftest` => window shading (roll-up), always-on-top
            # z-order pinning, and vertical/horizontal maximize menu rows.
            if cstr_eq(a2, "round9selftest") != 0:
                autoflag = 19
            # `round10selftest` => workspace pager drag-window-between-
            # workspaces, window-list grouping (collapse + click-to-cycle),
            # and the Applications menu type-to-search filter.
            if cstr_eq(a2, "round10selftest") != 0:
                autoflag = 20
            # `round11selftest` => panel-position-aware work area (top/bottom
            # panel), window-list group actions (minimize/restore/close-all),
            # and standard Ctrl-Alt(+Shift)-arrow workspace navigation/move.
            if cstr_eq(a2, "round11selftest") != 0:
                autoflag = 21
            # `round12selftest` => the panel BAR + every panel hit-test now
            # render at the configured edge (top OR bottom), drop-downs grow
            # away from the bar, and a Show Desktop applet minimizes/restores
            # all windows. Asserts BOTH panel positions.
            if cstr_eq(a2, "round12selftest") != 0:
                autoflag = 22
        return cmd_daemon_auto(autoflag)
    usage(2)
    return 1

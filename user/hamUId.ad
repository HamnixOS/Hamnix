    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/resize/show"))
    if fd < 0:
        return
    poke: Array[2, uint8]
    poke[0] = 49
    poke[1] = 10
    sys_write(fd, &poke[0], 2)

def font_init():
    if font_ready != 0:
        return
    g: uint64 = 0
    while g < 95:
        hexs: Ptr[uint8] = _font_hex(g)
        r: uint64 = 0
        while r < 16:
            hi: int32 = hex_nibble(hexs[r * 2])
            lo: int32 = hex_nibble(hexs[r * 2 + 1])
            font_glyphs[g * 16 + r] = cast[uint8]((hi * 16) + lo)
            r = r + 1
        g = g + 1
    font_ready = 1


# ====================================================================
# Compositor target helpers
# ====================================================================

def target_clear():
    # Fill the window-sized target with the opaque background colour.
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            target[o] = BG_R
            target[o + 1] = BG_G
            target[o + 2] = BG_B
            target[o + 3] = 255
            x = x + 1
        y = y + 1


def layerbuf_clear():
    # Zero (transparent) the per-layer RGBA scratch. Premultiplied: all
    # channels 0 = fully transparent.
    i: uint64 = 0
    n: uint64 = WIN_W * WIN_H * 4
    while i < n:
        layerbuf[i] = 0
        i = i + 1


# Set a layer-buffer pixel (premultiplied RGBA) with src-over blend onto
# whatever is already in the layer buffer. (r,g,b,a) are straight 0..255
# component values for the incoming colour; we premultiply on store.
def layer_put(x: int64, y: int64, r: uint8, g: uint8, b: uint8, a: uint8):
    if x < 0 or y < 0:
        return
    xu: uint64 = cast[uint64](x)
    yu: uint64 = cast[uint64](y)
    if xu >= WIN_W or yu >= WIN_H:
        return
    if a == 0:
        return
    o: uint64 = (yu * WIN_W + xu) * 4
    av: uint64 = cast[uint64](a)
    inv: uint64 = 255 - av
    # Premultiply the incoming colour by its own alpha, then src-over
    # against the existing premultiplied destination.
    sr: uint64 = (cast[uint64](r) * av) / 255
    sg: uint64 = (cast[uint64](g) * av) / 255
    sb: uint64 = (cast[uint64](b) * av) / 255
    dr: uint64 = cast[uint64](layerbuf[o])
    dg: uint64 = cast[uint64](layerbuf[o + 1])
    db: uint64 = cast[uint64](layerbuf[o + 2])
    da: uint64 = cast[uint64](layerbuf[o + 3])
    layerbuf[o] = cast[uint8](sr + (dr * inv) / 255)
    layerbuf[o + 1] = cast[uint8](sg + (dg * inv) / 255)
    layerbuf[o + 2] = cast[uint8](sb + (db * inv) / 255)
    layerbuf[o + 3] = cast[uint8](av + (da * inv) / 255)


# ====================================================================
# hamML colour parsing
# ====================================================================
# A parsed colour is returned via four out-bytes + a "present" flag.

def parse_color(buf: Ptr[uint8], start: uint64, end: uint64,
                out_r: Ptr[uint8], out_g: Ptr[uint8],
                out_b: Ptr[uint8], out_a: Ptr[uint8]) -> int32:
    # Supports "#rrggbb", "#rgb" and "rgba(r,g,b,a)" (a = 0..255).
    # Returns 1 on success.
    i: uint64 = start
    while i < end and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    if i >= end:
        return 0
    if buf[i] == 35:                                 # '#'
        i = i + 1
        # count hex digits available
        h0: uint64 = i
        while i < end and hex_nibble(buf[i]) >= 0:
            i = i + 1
        ndig: uint64 = i - h0
        if ndig >= 6:
            out_r[0] = cast[uint8]((hex_nibble(buf[h0]) * 16) + hex_nibble(buf[h0 + 1]))
            out_g[0] = cast[uint8]((hex_nibble(buf[h0 + 2]) * 16) + hex_nibble(buf[h0 + 3]))
            out_b[0] = cast[uint8]((hex_nibble(buf[h0 + 4]) * 16) + hex_nibble(buf[h0 + 5]))
            out_a[0] = 255
            return 1
        if ndig >= 3:
            # #rgb -> #rrggbb
            rr: int32 = hex_nibble(buf[h0])
            gg: int32 = hex_nibble(buf[h0 + 1])
            bb: int32 = hex_nibble(buf[h0 + 2])
            out_r[0] = cast[uint8](rr * 16 + rr)
            out_g[0] = cast[uint8](gg * 16 + gg)
            out_b[0] = cast[uint8](bb * 16 + bb)
            out_a[0] = 255
            return 1
        return 0
    # rgba( / rgb(
    if buf[i] == 114:                                # 'r'
        # skip to '('
        while i < end and buf[i] != 40:
            i = i + 1
        if i >= end:
            return 0
        i = i + 1
        comp: Array[4, int64]
        comp[0] = 0
        comp[1] = 0
        comp[2] = 0
        comp[3] = 255
        ci: uint64 = 0
        while i < end and buf[i] != 41 and ci < 4:
            while i < end and (buf[i] == 32 or buf[i] == 9):
                i = i + 1
            v: int64 = 0
            got: int32 = 0
            while i < end and buf[i] >= 48 and buf[i] <= 57:
                v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
                got = 1
                i = i + 1
            if got != 0:
                comp[ci] = v
                ci = ci + 1
            while i < end and buf[i] != 44 and buf[i] != 41:
                i = i + 1
            if i < end and buf[i] == 44:
                i = i + 1
        out_r[0] = cast[uint8](comp[0])
        out_g[0] = cast[uint8](comp[1])
        out_b[0] = cast[uint8](comp[2])
        out_a[0] = cast[uint8](comp[3])
        return 1
    return 0


# ====================================================================
# hamML attribute extraction
# ====================================================================
# Given a tag's attribute span [astart, aend) inside markup_buf, find an
# attribute named `name` and return its raw VALUE span via out_vs/out_ve.
# Returns 1 if found. Values may be unquoted (x=10) or quoted (fill="#f00").

def find_attr(astart: uint64, aend: uint64, name: Ptr[uint8],
              out_vs: Ptr[uint64], out_ve: Ptr[uint64]) -> int32:
    nlen: uint64 = strlen_u8(name)
    i: uint64 = astart
    while i < aend:
        # skip whitespace
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9 or
                            markup_buf[i] == 10 or markup_buf[i] == 13):
            i = i + 1
        # read an attribute name
        ns: uint64 = i
        while i < aend and markup_buf[i] != 61 and markup_buf[i] != 32 and \
              markup_buf[i] != 9 and markup_buf[i] != 10 and \
              markup_buf[i] != 13 and markup_buf[i] != 47 and \
              markup_buf[i] != 62:
            i = i + 1
        ne: uint64 = i
        # skip whitespace before '='
        while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
            i = i + 1
        if i < aend and markup_buf[i] == 61:           # '='
            i = i + 1
            while i < aend and (markup_buf[i] == 32 or markup_buf[i] == 9):
                i = i + 1
            vs: uint64 = 0
            ve: uint64 = 0
            if i < aend and (markup_buf[i] == 34 or markup_buf[i] == 39):
                q: uint8 = markup_buf[i]
                i = i + 1
                vs = i
                while i < aend and markup_buf[i] != q:
                    i = i + 1
                ve = i
                if i < aend:
                    i = i + 1
            else:
                vs = i
                while i < aend and markup_buf[i] != 32 and markup_buf[i] != 9 and \
                      markup_buf[i] != 10 and markup_buf[i] != 13 and \
                      markup_buf[i] != 47 and markup_buf[i] != 62:
                    i = i + 1
                ve = i
            # name match?
            if (ne - ns) == nlen:
                k: uint64 = 0
                matched: int32 = 1
                while k < nlen:
                    if markup_buf[ns + k] != name[k]:
                        matched = 0
                        k = nlen
                    else:
                        k = k + 1
                if matched != 0:
                    out_vs[0] = vs
                    out_ve[0] = ve
                    return 1
        else:
            # attribute with no value (rare); skip on
            i = ne + 1
    return 0


def attr_i64(astart: uint64, aend: uint64, name: Ptr[uint8],
             dflt: int64) -> int64:
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, name, &vs[0], &ve[0]) == 0:
        return dflt
    return parse_i64_span(&markup_buf[0], vs[0], ve[0])


# ====================================================================
# Rasterising primitives into the current layer buffer
# ====================================================================

def raster_rect(x: int64, y: int64, w: int64, h: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    yy: int64 = y
    ymax: int64 = y + h
    while yy < ymax:
        xx: int64 = x
        xmax: int64 = x + w
        while xx < xmax:
            layer_put(xx, yy, r, g, b, a)
            xx = xx + 1
        yy = yy + 1


def iabs(v: int64) -> int64:
    if v < 0:
        return 0 - v
    return v


def raster_line(x0: int64, y0: int64, x1: int64, y1: int64, width: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Bresenham. `width` thickens by stamping a (width x width) block.
    dx: int64 = iabs(x1 - x0)
    dy: int64 = 0 - iabs(y1 - y0)
    sx: int64 = -1
    if x0 < x1:
        sx = 1
    sy: int64 = -1
    if y0 < y1:
        sy = 1
    err: int64 = dx + dy
    cx: int64 = x0
    cy: int64 = y0
    half: int64 = width / 2
    while True:
        # stamp a width x width block centred on (cx,cy)
        oy: int64 = 0 - half
        while oy <= half:
            ox: int64 = 0 - half
            while ox <= half:
                layer_put(cx + ox, cy + oy, r, g, b, a)
                ox = ox + 1
            oy = oy + 1
        if cx == x1 and cy == y1:
            break
        e2: int64 = err * 2
        if e2 >= dy:
            err = err + dy
            cx = cx + sx
        if e2 <= dx:
            err = err + dx
            cy = cy + sy


def raster_glyph(ch: uint8, x: int64, y: int64,
                 r: uint8, g: uint8, b: uint8, a: uint8):
    # 8x16 mono glyph; (x,y) is the TOP-LEFT of the cell.
    if ch < 32 or ch > 126:
        return
    gi: uint64 = cast[uint64](ch) - 32
    row: uint64 = 0
    while row < 16:
        bits: uint8 = font_glyphs[gi * 16 + row]
        col: uint64 = 0
        while col < 8:
            mask: uint8 = cast[uint8](128 >> col)
            if (bits & mask) != 0:
                layer_put(x + cast[int64](col), y + cast[int64](row), r, g, b, a)
            col = col + 1
        row = row + 1


def raster_text(text_s: uint64, text_e: uint64, x: int64, y: int64,
                r: uint8, g: uint8, b: uint8, a: uint8):
    # Render markup_buf[text_s..text_e) as 8x16 mono. The hamML `y` is
    # the text BASELINE-ish anchor; we treat it as the cell top for the
    # mono font (good enough for v1 / AI-debug). Advance 8 px per glyph.
    cx: int64 = x
    i: uint64 = text_s
    while i < text_e:
        c: uint8 = markup_buf[i]
        if c == 10 or c == 13:
            i = i + 1
        else:
            raster_glyph(c, cx, y, r, g, b, a)
            cx = cx + 8
            i = i + 1


# Blit a referenced fb LAYER's buffer into the current layer at (dx,dy).
# `src_slot` is the layer-table index of the referenced layer.
def raster_image_fb(src_slot: uint64, dx: int64, dy: int64,
                    dw: int64, dh: int64):
    # Read the source layer's fb body into fb_read_buf.
    nread: int64 = read_layer_fb(src_slot)
    if nread <= 0:
        return
    sw: int64 = LT_W[src_slot]
    sh: int64 = LT_H[src_slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    # default destination size = source size
    tw: int64 = dw
    th: int64 = dh
    if tw <= 0:
        tw = sw
    if th <= 0:
        th = sh
    yy: int64 = 0
    while yy < th:
        xx: int64 = 0
        while xx < tw:
            # nearest-neighbour sample
            srx: int64 = (xx * sw) / tw
            sry: int64 = (yy * sh) / th
            if srx < sw and sry < sh:
                so: uint64 = cast[uint64](sry * sw + srx) * 4
                if so + 3 < cast[uint64](nread):
                    pr: uint8 = fb_read_buf[so]
                    pg: uint8 = fb_read_buf[so + 1]
                    pb: uint8 = fb_read_buf[so + 2]
                    pa: uint8 = fb_read_buf[so + 3]
                    # fb is premultiplied; un-premultiply is unnecessary
                    # because layer_put premultiplies by `a` again. For a
                    # faithful blit we treat stored RGB as straight and
                    # pass alpha through.
                    layer_put(dx + xx, dy + yy, pr, pg, pb, pa)
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Path building + cdev reads
# ====================================================================

def build_path(wid: int32, layer: Ptr[uint8], leaf: Ptr[uint8]):
    # Compose "/dev/wsys/<wid>/draw[/<layer>][/<leaf>]" into path_buf.
    # layer NULL/empty -> ".../draw"; leaf NULL/empty -> no trailing leaf.
    p: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while p[j] != 0:
        path_buf[i] = p[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    d: Ptr[uint8] = "/draw"
    j = 0
    while d[j] != 0:
        path_buf[i] = d[j]
        i = i + 1
        j = j + 1
    if layer != cast[Ptr[uint8]](0) and layer[0] != 0:
        path_buf[i] = 47                              # '/'
        i = i + 1
        j = 0
        while layer[j] != 0:
            path_buf[i] = layer[j]
            i = i + 1
            j = j + 1
        if leaf != cast[Ptr[uint8]](0) and leaf[0] != 0:
            path_buf[i] = 47
            i = i + 1
            j = 0
            while leaf[j] != 0:
                path_buf[i] = leaf[j]
                i = i + 1
                j = j + 1
    path_buf[i] = 0


def read_whole(fd: int32, buf: Ptr[uint8], cap: uint64) -> int64:
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    return cast[int64](total)


def layer_name_ptr(slot: uint64) -> Ptr[uint8]:
    return &LT_NAME[slot * 32]


def read_layer_markup(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "markup")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &markup_buf[0], 8192)
    sys_close(fd)
    return n


# read_layer_fb reads the layer at table-index `slot` into fb_read_buf.
# Returns bytes read.
read_fb_wid: int32 = 1
def read_layer_fb(slot: uint64) -> int64:
    build_path(read_fb_wid, layer_name_ptr(slot), "fb")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &fb_read_buf[0], 262144)
    sys_close(fd)
    return n


def read_layer_opacity(wid: int32, slot: uint64) -> int64:
    build_path(wid, layer_name_ptr(slot), "opacity")
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return 255
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 255
    return parse_i64_span(&num_buf[0], 0, cast[uint64](n))


# ====================================================================
# Parse the draw listing into the layer table
# ====================================================================
# Each listing line:
#   "<name>  z=<z>  kind=<markup|fb>  <x>x<y>..<x2>x<y2>  opacity=<o>"

def parse_listing(wid: int32) -> int32:
    build_path(wid, cast[Ptr[uint8]](0), cast[Ptr[uint8]](0))
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &list_buf[0], 4096)
    sys_close(fd)
    if n < 0:
        return -1
    total: uint64 = cast[uint64](n)
    LT_COUNT = 0
    i: uint64 = 0
    while i < total and LT_COUNT < MAX_LAYERS:
        ls: uint64 = i
        while i < total and list_buf[i] != 10:
            i = i + 1
        le: uint64 = i
        if i < total:
            i = i + 1
        if le > ls:
            parse_listing_line(ls, le)
    return 0


def parse_listing_line(ls: uint64, le: uint64):
    slot: uint64 = LT_COUNT
    # name = run up to first space
    p: uint64 = ls
    while p < le and list_buf[p] != 32:
        p = p + 1
    nlen: uint64 = p - ls
    if nlen >= 32:
        nlen = 31
    k: uint64 = 0
    while k < nlen:
        LT_NAME[slot * 32 + k] = list_buf[ls + k]
        k = k + 1
    LT_NAME[slot * 32 + nlen] = 0
    # find "kind=" -> markup/fb
    LT_KIND[slot] = 0
    kk: uint64 = find_substr(ls, le, "kind=")
    if kk < le:
        c: uint8 = list_buf[kk + 5]
        if c == 102:                                  # 'f' (fb)
            LT_KIND[slot] = 1
    # geometry "<x>x<y>..<x2>x<y2>": parse the two corner pairs.
    gg: uint64 = find_geom(ls, le)
    x0: int64 = 0
    y0: int64 = 0
    x1: int64 = 0
    y1: int64 = 0
    if gg < le:
        q: uint64 = gg
        x0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:          # 'x'
            q = q + 1
        if q < le:
            q = q + 1
        y0 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 46:           # '.'
            q = q + 1
        while q < le and list_buf[q] == 46:
            q = q + 1
        x1 = parse_i64_span(&list_buf[0], q, le)
        while q < le and list_buf[q] != 120:
            q = q + 1
        if q < le:
            q = q + 1
        y1 = parse_i64_span(&list_buf[0], q, le)
    LT_X[slot] = x0
    LT_Y[slot] = y0
    LT_W[slot] = x1 - x0
    LT_H[slot] = y1 - y0
    # opacity
    oo: uint64 = find_substr(ls, le, "opacity=")
    if oo < le:
        LT_OPAC[slot] = parse_i64_span(&list_buf[0], oo + 8, le)
    else:
        LT_OPAC[slot] = 255
    LT_COUNT = LT_COUNT + 1


def find_substr(ls: uint64, le: uint64, needle: Ptr[uint8]) -> uint64:
    nlen: uint64 = strlen_u8(needle)
    i: uint64 = ls
    while i + nlen <= le:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            if list_buf[i + k] != needle[k]:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return i
        i = i + 1
    return le


# Find the geometry field: the first run of digits that is FOLLOWED by an
# 'x' then digits then ".." . We locate it after the "kind=..." token by
# scanning for the ".." separator and backing up to its number start.
def find_geom(ls: uint64, le: uint64) -> uint64:
    # Find the ".." then walk backward to the start of <x>.
    dd: uint64 = le
    i: uint64 = ls
    while i + 1 < le:
        if list_buf[i] == 46 and list_buf[i + 1] == 46:
            dd = i
            i = le
        else:
            i = i + 1
    if dd >= le:
        return le
    # back up over "<x>x<y>" — find the start: skip back over digits,
    # one 'x', digits, to a leading space.
    j: uint64 = dd
    # j currently at first '.'; the char before is the last digit of y0.
    while j > ls and list_buf[j - 1] != 32:
        j = j - 1
    return j


# ====================================================================
# Layer rasterisation: parse hamML and draw into layerbuf
# ====================================================================

def slot_for_fbref(name_s: uint64, name_e: uint64) -> int64:
    # Match markup_buf[name_s..name_e) against a layer name in the table.
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        ll: uint64 = strlen_u8(lp)
        if ll == (name_e - name_s):
            k: uint64 = 0
            ok: int32 = 1
            while k < ll:
                if lp[k] != markup_buf[name_s + k]:
                    ok = 0
                    k = ll
                else:
                    k = k + 1
            if ok != 0:
                return cast[int64](si)
        si = si + 1
    return -1


def rasterise_markup(wid: int32, slot: uint64):
    n: int64 = read_layer_markup(wid, slot)
    if n <= 0:
        return
    total: uint64 = cast[uint64](n)
    # group translate accumulator (translate-only v1)
    gtx: int64 = 0
    gty: int64 = 0
    i: uint64 = 0
    while i < total:
        if markup_buf[i] != 60:                        # '<'
            i = i + 1
        else:
            ts: uint64 = i + 1
            # closing tag?
            if ts < total and markup_buf[ts] == 47:    # '</'
                # check for </group>
                if tag_is(ts + 1, total, "group"):
                    gtx = 0
                    gty = 0
                # skip to '>'
                while i < total and markup_buf[i] != 62:
                    i = i + 1
                i = i + 1
            else:
                # read tag name
                ne: uint64 = ts
                while ne < total and markup_buf[ne] != 32 and \
                      markup_buf[ne] != 9 and markup_buf[ne] != 10 and \
                      markup_buf[ne] != 13 and markup_buf[ne] != 62 and \
                      markup_buf[ne] != 47:
                    ne = ne + 1
                astart: uint64 = ne
                # find end of tag '>'
                te: uint64 = ne
                while te < total and markup_buf[te] != 62:
                    te = te + 1
                aend: uint64 = te
                # self-closing? trailing '/'
                # (we don't special-case; attrs parse the same)
                handle_tag(wid, ts, ne, astart, aend, gtx, gty,
                           &gtx, &gty, total)
                i = te + 1
    return


def tag_is(s: uint64, total: uint64, name: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(name)
    k: uint64 = 0
    while k < nlen:
        if s + k >= total:
            return 0
        if markup_buf[s + k] != name[k]:
            return 0
        k = k + 1
    return 1


def handle_tag(wid: int32, ns: uint64, ne: uint64,
               astart: uint64, aend: uint64,
               gtx: int64, gty: int64,
               gtx_out: Ptr[int64], gty_out: Ptr[int64],
               total: uint64):
    # default colours
    r: Array[1, uint8]
    g: Array[1, uint8]
    b: Array[1, uint8]
    a: Array[1, uint8]
    if tag_is(ns, total, "rect") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "line") != 0 and (ne - ns) == 4:
        x1: int64 = attr_i64(astart, aend, "x1", 0) + gtx
        y1: int64 = attr_i64(astart, aend, "y1", 0) + gty
        x2: int64 = attr_i64(astart, aend, "x2", 0) + gtx
        y2: int64 = attr_i64(astart, aend, "y2", 0) + gty
        wd: int64 = attr_i64(astart, aend, "width", 1)
        if wd < 1:
            wd = 1
        r[0] = 200
        g[0] = 200
        b[0] = 200
        a[0] = 255
        get_stroke(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_line(x1, y1, x2, y2, wd, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "text") != 0 and (ne - ns) == 4:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        r[0] = 255
        g[0] = 255
        b[0] = 255
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        # text content is between aend+1 ('>') and the next '<'
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        raster_text(cs, ce, x, y, r[0], g[0], b[0], a[0])
        return
    if tag_is(ns, total, "button") != 0 and (ne - ns) == 6:
        # draw a filled box + label text
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 64)
        h: int64 = attr_i64(astart, aend, "h", 20)
        r[0] = 80
        g[0] = 80
        b[0] = 80
        a[0] = 255
        get_fill(astart, aend, &r[0], &g[0], &b[0], &a[0])
        raster_rect(x, y, w, h, r[0], g[0], b[0], a[0])
        cs: uint64 = aend + 1
        ce: uint64 = cs
        while ce < total and markup_buf[ce] != 60:
            ce = ce + 1
        raster_text(cs, ce, x + 4, y + 2, 255, 255, 255, 255)
        return
    if tag_is(ns, total, "input") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 100)
        h: int64 = attr_i64(astart, aend, "h", 18)
        raster_rect(x, y, w, h, 40, 40, 40, 255)
        # placeholder text
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "placeholder", &vs[0], &ve[0]) != 0:
            raster_text(vs[0], ve[0], x + 3, y + 1, 160, 160, 160, 255)
        return
    if tag_is(ns, total, "image") != 0 and (ne - ns) == 5:
        x: int64 = attr_i64(astart, aend, "x", 0) + gtx
        y: int64 = attr_i64(astart, aend, "y", 0) + gty
        w: int64 = attr_i64(astart, aend, "w", 0)
        h: int64 = attr_i64(astart, aend, "h", 0)
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "src", &vs[0], &ve[0]) != 0:
            # only "fb:<layer>" supported in v1
            s0: uint64 = vs[0]
            if (ve[0] - s0) > 3 and markup_buf[s0] == 102 and \
               markup_buf[s0 + 1] == 98 and markup_buf[s0 + 2] == 58:
                src_slot: int64 = slot_for_fbref(s0 + 3, ve[0])
                if src_slot >= 0:
                    raster_image_fb(cast[uint64](src_slot), x, y, w, h)
        return
    if tag_is(ns, total, "group") != 0 and (ne - ns) == 5:
        # transform="translate(dx,dy)"
        vs: Array[1, uint64]
        ve: Array[1, uint64]
        if find_attr(astart, aend, "transform", &vs[0], &ve[0]) != 0:
            tdx: Array[1, int64]
            tdy: Array[1, int64]
            tdx[0] = 0
            tdy[0] = 0
            parse_translate(vs[0], ve[0], &tdx[0], &tdy[0])
            gtx_out[0] = gtx + tdx[0]
            gty_out[0] = gty + tdy[0]
        return
    # <window ...> and unknown tags: ignore (metadata only).
    return


def get_fill(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
             b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "fill", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def get_stroke(astart: uint64, aend: uint64, r: Ptr[uint8], g: Ptr[uint8],
               b: Ptr[uint8], a: Ptr[uint8]):
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "stroke", &vs[0], &ve[0]) != 0:
        parse_color(&markup_buf[0], vs[0], ve[0], r, g, b, a)
    apply_opacity(astart, aend, a)


def apply_opacity(astart: uint64, aend: uint64, a: Ptr[uint8]):
    # per-element opacity 0..1 (float-shape) -> scale alpha. We accept
    # an integer 0..255 too (if value > 1). v1 keeps it simple: a value
    # "0".."1" with a dot is read as tenths/hundredths via the first two
    # fractional digits; otherwise treated as 0..255.
    vs: Array[1, uint64]
    ve: Array[1, uint64]
    if find_attr(astart, aend, "opacity", &vs[0], &ve[0]) == 0:
        return
    s: uint64 = vs[0]
    e: uint64 = ve[0]
    # whole part
    whole: int64 = parse_i64_span(&markup_buf[0], s, e)
    # fractional?
    di: uint64 = s
    while di < e and markup_buf[di] != 46:
        di = di + 1
    if di < e:
        # has a dot -> treat as 0..1 float; scale to 0..255
        # read up to two fractional digits
        f1: int64 = 0
        f2: int64 = 0
        if di + 1 < e and markup_buf[di + 1] >= 48 and markup_buf[di + 1] <= 57:
            f1 = cast[int64](cast[int32](markup_buf[di + 1]) - 48)
        if di + 2 < e and markup_buf[di + 2] >= 48 and markup_buf[di + 2] <= 57:
            f2 = cast[int64](cast[int32](markup_buf[di + 2]) - 48)
        frac: int64 = whole * 100 + f1 * 10 + f2     # 0..100 (clamp)
        if frac > 100:
            frac = 100
        a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](frac)) / 100)
    else:
        if whole >= 0 and whole <= 255:
            a[0] = cast[uint8]((cast[uint64](a[0]) * cast[uint64](whole)) / 255)


def parse_translate(s: uint64, e: uint64, dx: Ptr[int64], dy: Ptr[int64]):
    # "translate(DX,DY)"
    i: uint64 = s
    while i < e and markup_buf[i] != 40:               # '('
        i = i + 1
    if i >= e:
        return
    i = i + 1
    dx[0] = parse_i64_span(&markup_buf[0], i, e)
    while i < e and markup_buf[i] != 44:               # ','
        i = i + 1
    if i < e:
        i = i + 1
    dy[0] = parse_i64_span(&markup_buf[0], i, e)


# ====================================================================
# Composite the current layer buffer into the target with per-layer
# opacity. Both buffers are premultiplied RGBA.
# ====================================================================

def composite_layer(opac: int64):
    op: uint64 = cast[uint64](opac)
    if op > 255:
        op = 255
    y: uint64 = 0
    while y < WIN_H:
        x: uint64 = 0
        while x < WIN_W:
            o: uint64 = (y * WIN_W + x) * 4
            sa: uint64 = (cast[uint64](layerbuf[o + 3]) * op) / 255
            if sa != 0:
                sr: uint64 = (cast[uint64](layerbuf[o]) * op) / 255
                sg: uint64 = (cast[uint64](layerbuf[o + 1]) * op) / 255
                sb: uint64 = (cast[uint64](layerbuf[o + 2]) * op) / 255
                inv: uint64 = 255 - sa
                dr: uint64 = cast[uint64](target[o])
                dg: uint64 = cast[uint64](target[o + 1])
                db: uint64 = cast[uint64](target[o + 2])
                target[o] = cast[uint8](sr + (dr * inv) / 255)
                target[o + 1] = cast[uint8](sg + (dg * inv) / 255)
                target[o + 2] = cast[uint8](sb + (db * inv) / 255)
                target[o + 3] = 255
            x = x + 1
        y = y + 1


# ====================================================================
# Output: AI-readable text dump
# ====================================================================

def emit_hex_byte(v: uint8, out: Ptr[uint8]):
    hi: uint8 = cast[uint8]((cast[uint64](v) >> 4) & 15)
    lo: uint8 = cast[uint8](cast[uint64](v) & 15)
    if hi < 10:
        out[0] = 48 + hi
    else:
        out[0] = 97 + (hi - 10)
    if lo < 10:
        out[1] = 48 + lo
    else:
        out[1] = 97 + (lo - 10)


def emit_pix(x: uint64, y: uint64):
    # "PIX <x> <y> #rrggbb\n"
    o: uint64 = (y * WIN_W + x) * 4
    line: Array[40, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PIX "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(x, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(y, &line[p])
    line[p] = 32
    p = p + 1
    line[p] = 35                                       # '#'
    p = p + 1
    emit_hex_byte(target[o], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 1], &line[p])
    p = p + 2
    emit_hex_byte(target[o + 2], &line[p])
    p = p + 2
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def is_bg(x: uint64, y: uint64) -> int32:
    o: uint64 = (y * WIN_W + x) * 4
    if target[o] == BG_R and target[o + 1] == BG_G and target[o + 2] == BG_B:
        return 1
    return 0


def count_nonbg_region(rx: uint64, ry: uint64, rw: uint64, rh: uint64) -> uint64:
    cnt: uint64 = 0
    y: uint64 = ry
    ymax: uint64 = ry + rh
    while y < ymax and y < WIN_H:
        x: uint64 = rx
        xmax: uint64 = rx + rw
        while x < xmax and x < WIN_W:
            if is_bg(x, y) == 0:
                cnt = cnt + 1
            x = x + 1
        y = y + 1
    return cnt


def emit_region(name: Ptr[uint8], rx: uint64, ry: uint64,
                rw: uint64, rh: uint64):
    # "REGION <name> <x> <y> <w> <h> nonbg=<count>\n" — a deterministic
    # test hook: lets a CI grep assert "the text band has >0 non-bg
    # pixels" without depending on the coarse probe grid landing on a
    # glyph stroke.
    cnt: uint64 = count_nonbg_region(rx, ry, rw, rh)
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "REGION "
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    k = 0
    while name[k] != 0:
        line[p] = name[k]
        p = p + 1
        k = k + 1
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rx, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(ry, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rw, &line[p])
    line[p] = 32
    p = p + 1
    p = p + u64_to_dec(rh, &line[p])
    sfx: Ptr[uint8] = " nonbg="
    k = 0
    while sfx[k] != 0:
        line[p] = sfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cnt, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


def emit_ascii_art():
    # Downscale to ART_W x ART_H by sampling. '#' = non-background.
    ART_W: uint64 = 80
    ART_H: uint64 = 30
    line: Array[96, uint8]
    ry: uint64 = 0
    while ry < ART_H:
        p: uint64 = 0
        pfx: Ptr[uint8] = "ART "
        k: uint64 = 0
        while pfx[k] != 0:
            line[p] = pfx[k]
            p = p + 1
            k = k + 1
        rx: uint64 = 0
        while rx < ART_W:
            sx: uint64 = (rx * WIN_W) / ART_W
            sy: uint64 = (ry * WIN_H) / ART_H
            if is_bg(sx, sy) != 0:
                line[p] = 32                           # ' '
            else:
                line[p] = 35                           # '#'
            p = p + 1
            rx = rx + 1
        line[p] = 10
        p = p + 1
        sys_write(1, &line[0], p)
        ry = ry + 1


def emit_probe_grid():
    # A regular grid of probe pixels so a CI grep can assert colours at
    # known coordinates.
    PY: uint64 = 0
    while PY < WIN_H:
        PX: uint64 = 0
        while PX < WIN_W:
            emit_pix(PX, PY)
            PX = PX + 40
        PY = PY + 40


# ====================================================================
# Optional: write the composited frame into a "_screen" fb layer so the
# bytes round-trip through the cdev. Best-effort.
# ====================================================================

def write_screen_layer(wid: int32):
    # Ensure a "_screen" fb layer exists (256x256 max), then write a
    # downscaled copy of the target into its fb. ctl create is via
    # /dev/wsys/<wid>/draw/ctl.
    build_path(wid, cast[Ptr[uint8]](0), "ctl")
    cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if cf >= 0:
        cmd: Ptr[uint8] = "mklayer _screen fb 256 256\n"
        sys_write(cf, cmd, strlen_u8(cmd))
        sys_close(cf)
    # write fb: downscale target -> 256x256 into fb_read_buf, then write.
    yy: uint64 = 0
    while yy < FB_DIM:
        xx: uint64 = 0
        while xx < FB_DIM:
            sx: uint64 = (xx * WIN_W) / FB_DIM
            sy: uint64 = (yy * WIN_H) / FB_DIM
            so: uint64 = (sy * WIN_W + sx) * 4
            dout: uint64 = (yy * FB_DIM + xx) * 4
            fb_read_buf[dout] = target[so]
            fb_read_buf[dout + 1] = target[so + 1]
            fb_read_buf[dout + 2] = target[so + 2]
            fb_read_buf[dout + 3] = target[so + 3]
            xx = xx + 1
        yy = yy + 1
    build_path(wid, "_screen", "fb")
    wf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
    if wf >= 0:
        sys_write(wf, &fb_read_buf[0], FB_DIM * FB_DIM * 4)
        sys_close(wf)


# ====================================================================
# render <wid>
# ====================================================================

def cmd_render(wid: int32) -> int32:
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        write_str(2, "hamUId: cannot read /dev/wsys/<wid>/draw (no such wid?)\n")
        return 1
    target_clear()
    # Composite layers in listing order (kernel emits z-ascending).
    si: uint64 = 0
    while si < LT_COUNT:
        # Skip the synthetic _screen layer if present (avoid feedback).
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                # fb layer: read its pixels straight into the layer buf
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    # --- emit the AI-readable dump ---
    hdr: Array[96, uint8]
    p: uint64 = 0
    h0: Ptr[uint8] = "DUMP wid="
    k: uint64 = 0
    while h0[k] != 0:
        hdr[p] = h0[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &hdr[p])
    h1: Ptr[uint8] = " win=640x480 layers="
    k = 0
    while h1[k] != 0:
        hdr[p] = h1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(LT_COUNT, &hdr[p])
    hdr[p] = 10
    p = p + 1
    sys_write(1, &hdr[0], p)
    emit_probe_grid()
    # Deterministic region summaries (test hooks that don't depend on the
    # coarse probe grid landing on a specific glyph stroke). The "text"
    # band is to the RIGHT of any rect a chrome layer typically draws, so
    # a non-zero count there proves GLYPHS rasterised, not a rect.
    emit_region("text", 192, 32, 160, 32)
    emit_ascii_art()
    write_str(1, "DUMP END\n")
    # round-trip into _screen fb (best-effort; ignore errors)
    write_screen_layer(wid)
    return 0


def composite_fb_layer(wid: int32, slot: uint64):
    # Read the fb body and blit (with the layer geometry offset) into
    # the layer buffer.
    n: int64 = read_layer_fb(slot)
    if n <= 0:
        return
    sw: int64 = LT_W[slot]
    sh: int64 = LT_H[slot]
    if sw > cast[int64](FB_DIM):
        sw = cast[int64](FB_DIM)
    if sh > cast[int64](FB_DIM):
        sh = cast[int64](FB_DIM)
    ox: int64 = LT_X[slot]
    oy: int64 = LT_Y[slot]
    yy: int64 = 0
    while yy < sh:
        xx: int64 = 0
        while xx < sw:
            so: uint64 = cast[uint64](yy * sw + xx) * 4
            if so + 3 < cast[uint64](n):
                layer_put(ox + xx, oy + yy, fb_read_buf[so],
                          fb_read_buf[so + 1], fb_read_buf[so + 2],
                          fb_read_buf[so + 3])
            xx = xx + 1
        yy = yy + 1


# ====================================================================
# Phase 4c — physical presentation to /dev/fb
# ====================================================================
#
# `hamUId present <wid>` composites the window exactly like `render`
# (reusing the 4b compositor that fills `target` with the 640x480
# window frame), reads /dev/fb's geometry, scales the window frame to
# fit the screen with letterboxing (preserve aspect, centre, black
# bars), and writes it to /dev/fb as RGBA8888.
#
# We present one SCREEN ROW at a time into screen_row, then write the
# whole row to /dev/fb at the pixel offset (scr_y * scr_w) * 4. The
# kernel cdev repacks RGBA -> hardware pixel order per fb_pixfmt and
# honours fb_pitch, so userland only deals in RGBA8888. Row-at-a-time
# keeps userland memory bounded regardless of screen resolution.

SCREEN_ROW_MAXW: uint64 = 4096          # cap a single screen row at 4096 px
screen_row: Array[16384, uint8]         # SCREEN_ROW_MAXW * 4

# Parsed /dev/fb geometry.
FBG_W: uint64 = 0
FBG_H: uint64 = 0
FBG_PITCH: uint64 = 0
FBG_BPP: uint64 = 0
FBG_PIXFMT: uint64 = 0


def read_fb_geometry() -> int32:
    # Read "WIDTH HEIGHT PITCH BPP PIXFMT\n" from /dev/fb. Returns 1 on
    # success (FBG_* populated), 0 on failure.
    p: Ptr[uint8] = "/dev/fb"
    fd: int32 = sys_open(cast[Ptr[char]](p))
    if fd < 0:
        return 0
    n: int64 = read_whole(fd, &num_buf[0], 64)
    sys_close(fd)
    if n <= 0:
        return 0
    total: uint64 = cast[uint64](n)
    # Parse five space-separated decimals.
    pos: Array[1, uint64]
    pos[0] = 0
    FBG_W = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_H = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PITCH = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_BPP = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    FBG_PIXFMT = cast[uint64](next_dec(&num_buf[0], &pos[0], total))
    if FBG_W == 0 or FBG_H == 0:
        return 0
    return 1


def next_dec(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip non-digits, then parse a run of decimal digits. Advances *pos.
    i: uint64 = pos[0]
    while i < total and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    return v


def composite_window(wid: int32) -> int32:
    # Run the 4b compositor: parse the layer listing, fill `target` with
    # the composited 640x480 window frame. Returns 0 on success, 1 if
    # the wid's draw listing can't be read.
    font_init()
    read_fb_wid = wid
    if parse_listing(wid) < 0:
        return 1
    target_clear()
    si: uint64 = 0
    while si < LT_COUNT:
        lp: Ptr[uint8] = layer_name_ptr(si)
        if cstr_eq(lp, "_screen") == 0:
            layerbuf_clear()
            if LT_KIND[si] == 1:
                composite_fb_layer(wid, si)
            else:
                rasterise_markup(wid, si)
            composite_layer(LT_OPAC[si])
        si = si + 1
    return 0


def cmd_present(wid: int32) -> int32:
    if composite_window(wid) != 0:
        write_str(2, "hamUId: present: cannot read /dev/wsys/<wid>/draw\n")
        return 1
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: present: cannot read /dev/fb geometry\n")
        return 1
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    # Aspect-preserving fit of WIN_W x WIN_H into sw x sh. Integer math:
    # scale numerator/denominator = min(sw/WIN_W, sh/WIN_H). To avoid
    # fractions we compute the destination content rectangle directly.
    #   fit_w = min(sw, sh * WIN_W / WIN_H)
    #   fit_h = min(sh, sw * WIN_H / WIN_W)
    fit_w: uint64 = sw
    fit_h: uint64 = (sw * WIN_H) / WIN_W
    if fit_h > sh:
        fit_h = sh
        fit_w = (sh * WIN_W) / WIN_H
    if fit_w > sw:
        fit_w = sw
    if fit_w == 0:
        fit_w = 1
    if fit_h == 0:
        fit_h = 1
    # Letterbox offsets (centre the content rect).
    ox: uint64 = (sw - fit_w) / 2
    oy: uint64 = (sh - fit_h) / 2
    # Open /dev/fb for writing the frame.
    pw: Ptr[uint8] = "/dev/fb"
    wf: int32 = sys_open_write(cast[Ptr[char]](pw))
    if wf < 0:
        write_str(2, "hamUId: present: cannot open /dev/fb for write\n")
        return 1
    # Emit one screen row at a time.
    sy: uint64 = 0
    while sy < sh:
        # Clear row to black (letterbox bars).
        ci: uint64 = 0
        rb: uint64 = sw * 4
        while ci < rb:
            screen_row[ci] = 0
            ci = ci + 1
        # If this screen row is inside the content band, scale-sample the
        # window frame into it.
        if sy >= oy and sy < oy + fit_h:
            # Source row in the window (nearest-neighbour).
            relq: uint64 = sy - oy
            srcy: uint64 = (relq * WIN_H) / fit_h
            if srcy >= WIN_H:
                srcy = WIN_H - 1
            dx: uint64 = 0
            while dx < fit_w:
                srcx: uint64 = (dx * WIN_W) / fit_w
                if srcx >= WIN_W:
                    srcx = WIN_W - 1
                so: uint64 = (srcy * WIN_W + srcx) * 4
                doff: uint64 = (ox + dx) * 4
                if (ox + dx) < sw:
                    screen_row[doff] = target[so]
                    screen_row[doff + 1] = target[so + 1]
                    screen_row[doff + 2] = target[so + 2]
                    screen_row[doff + 3] = 255
                dx = dx + 1
        # Write this row at its pixel offset in the screen frame. The fd
        # cursor advances by the bytes written, so successive rows land
        # at the right offset automatically (no explicit lseek needed —
        # we write exactly sw*4 bytes per row, contiguously).
        sys_write(wf, &screen_row[0], sw * 4)
        sy = sy + 1
    sys_close(wf)
    # Emit a deterministic AI/CI-readable summary line so a headless test
    # can assert the present happened even without screendump.
    emit_present_summary(wid, sw, sh, fit_w, fit_h, ox, oy)
    return 0


def emit_present_summary(wid: int32, sw: uint64, sh: uint64,
                         fit_w: uint64, fit_h: uint64,
                         ox: uint64, oy: uint64):
    # "PRESENT wid=<w> screen=<sw>x<sh> fit=<fw>x<fh> off=<ox>,<oy>\n"
    line: Array[128, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "PRESENT wid="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(cast[uint64](wid), &line[p])
    s1: Ptr[uint8] = " screen="
    k = 0
    while s1[k] != 0:
        line[p] = s1[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(sw, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(sh, &line[p])
    s2: Ptr[uint8] = " fit="
    k = 0
    while s2[k] != 0:
        line[p] = s2[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(fit_w, &line[p])
    line[p] = 120
    p = p + 1
    p = p + u64_to_dec(fit_h, &line[p])
    s3: Ptr[uint8] = " off="
    k = 0
    while s3[k] != 0:
        line[p] = s3[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(ox, &line[p])
    line[p] = 44                                     # ','
    p = p + 1
    p = p + u64_to_dec(oy, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)


# ====================================================================
# Phase 4c-interactive — the persistent daemon
# ====================================================================
#
#   hamUId daemon
#       A persistent present-loop that owns the physical framebuffer:
#         * opens /dev/fb (geometry once) and /dev/mouse,
#         * maintains a cursor position (starts at screen centre) driven
#           by the mouse dx/dy each iteration, clamped to screen bounds,
#         * composites a flat root backdrop + every window created by the
#           drag gesture + the cursor (a small arrow), and PRESENTS the
#           result to /dev/fb whenever anything changed,
#         * implements the canonical rio DRAG-TO-CREATE gesture: a
#           left-button-down at (x0,y0) begins a drag; while held a
#           rubber-band outline rectangle tracks the cursor; a
#           left-button-up at (x1,y1), if the swept rectangle exceeds a
#           small threshold, allocates a new wid (sys_spawn detached
#           hamsh + sys_wsys_alloc, mirroring user/hamUI.ad's cmd_new)
#           and records the rectangle as a window so its chrome paints
#           where it was dragged.
#
#       It does NOT auto-start at boot — it is launched explicitly (by a
#       user or a test). It yields the CPU every idle iteration so it
#       never spins at 100%.
#
# The daemon owns the WHOLE physical screen (unlike `present`, which
# scales one 640x480 window). It composites directly at screen
# resolution one ROW at a time into screen_row (reused from `present`),
# computing each pixel from a tiny model — backdrop, the window table,
# the rubber band, and the cursor — so userland memory stays bounded
# regardless of screen size.

# Root backdrop colour (a calm slate so window chrome and the cursor
# stand out for screendump assertions).
ROOT_R: uint8 = 32
ROOT_G: uint8 = 48
ROOT_B: uint8 = 72

# Window chrome colours.
WIN_TITLE_R: uint8 = 64
WIN_TITLE_G: uint8 = 110
WIN_TITLE_B: uint8 = 200
# Focused (topmost) window: brighter title bar so the user can tell which
# window has keyboard focus at a glance.
WIN_TITLE_FOCUS_R: uint8 = 90
WIN_TITLE_FOCUS_G: uint8 = 150
WIN_TITLE_FOCUS_B: uint8 = 240
WIN_BODY_R: uint8 = 200
WIN_BODY_G: uint8 = 200
WIN_BODY_B: uint8 = 210
WIN_BORDER_R: uint8 = 240
WIN_BORDER_G: uint8 = 240
WIN_BORDER_B: uint8 = 250

TITLE_H: int64 = 18                      # window title-bar height (px)
DRAG_MIN: int64 = 12                     # min swept extent to spawn a win

# Close-box ([x]) colours: a red square with a white X glyph.
CLOSE_R: uint8 = 210
CLOSE_G: uint8 = 60
CLOSE_B: uint8 = 60
CLOSE_X_R: uint8 = 255
CLOSE_X_G: uint8 = 255
CLOSE_X_B: uint8 = 255

SIGTERM_D: int32 = 15

# ---- panel + Applications menu (GNOME2 / MATE classic launcher) -----
# A persistent horizontal PANEL bar along the TOP screen edge (the
# classic GNOME2 layout). At its left end sits an "Applications" menu
# button; clicking it drops a vertical menu of launchable programs.
# Clicking an entry spawns that program into a new window via the SAME
# spawn-into-window path the drag gesture uses; clicking off the menu
# dismisses it.
PANEL_H: int64 = 22                       # panel bar height (px)
PANEL_R: uint8 = 46                       # panel background (dark slate)
PANEL_G: uint8 = 52
PANEL_B: uint8 = 64
PANEL_HI_R: uint8 = 70                     # panel button hover/open tint
PANEL_HI_G: uint8 = 90
PANEL_HI_B: uint8 = 140
PANEL_TXT_R: uint8 = 235                   # panel label ink
PANEL_TXT_G: uint8 = 235
PANEL_TXT_B: uint8 = 240

# "Applications" button geometry (left end of the panel).
APPS_BTN_X: int64 = 4
APPS_BTN_W: int64 = 104                    # ~12 glyphs * 8px + padding

# Menu geometry: a vertical list dropping from just below the panel at
# the Applications button's left edge.
MENU_X: int64 = 4
MENU_W: int64 = 150
MENU_ITEM_H: int64 = 20                     # per-entry row height (px)
MENU_R: uint8 = 56                          # menu background
MENU_G: uint8 = 62
MENU_B: uint8 = 78
MENU_SEL_R: uint8 = 70                       # hovered item tint
MENU_SEL_G: uint8 = 100
MENU_SEL_B: uint8 = 170
MENU_TXT_R: uint8 = 235
MENU_TXT_G: uint8 = 235
MENU_TXT_B: uint8 = 240

MENU_OPEN: int32 = 0                         # 1 while the menu is dropped

# Menu entries: a parallel pair of (label, program-path) tables. Each
# program is a real built /bin/<name> binary (verified present in the
# build). Labels stay short so they fit MENU_W. String constants live
# inside menu_label()/menu_prog() (file-scope globals can't take string
# initialisers in Adder).
MENU_COUNT: uint64 = 6

# ---- taskbar (window-list buttons in the panel) -------------------
# Each open window gets a button on the panel, right of the
# Applications button. Buttons are TASKBAR_BTN_W pixels wide;
# minimized windows show their button in the dimmed tint, normal
# windows use the panel background; the focused (topmost) window
# gets the highlight tint.
TASKBAR_START_X: int64 = 112           # APPS_BTN_X + APPS_BTN_W + 4
TASKBAR_BTN_W:   int64 = 96           # fits ~10 chars at 8px + 16px padding
TASKBAR_BTN_H:   int64 = 20           # 1px top + 18px body + 1px bottom border
TASKBAR_BTN_Y:   int64 = 1            # top pixel within panel (1px border)

# Right-edge clock area: reserved on the right side of the panel.
# The clock string "HH:MM" is 5 chars * 8px + 8px padding each side = 56px.
CLOCK_W:  int64 = 56
CLOCK_PAD: int64 = 8                   # horizontal padding inside clock area

# Minimize-box geometry: a square just LEFT of the close box in the title bar.
MINIMIZE_BOX: int64 = 14              # same size as CLOSE_BOX
# Minimize box colours: yellow square with white dash.
MINIMIZE_R: uint8 = 200
MINIMIZE_G: uint8 = 160
MINIMIZE_B: uint8 = 40
MINIMIZE_DASH_R: uint8 = 255
MINIMIZE_DASH_G: uint8 = 255
MINIMIZE_DASH_B: uint8 = 255

# Clock background tint (darker than panel, so it reads as a separate zone).
CLOCK_R: uint8 = 36
CLOCK_G: uint8 = 42
CLOCK_B: uint8 = 54


# 1 if screen pixel (x,y) lands on an INK pixel of the glyph string `s`
# laid out left-to-right at top-left origin (ox,oy), one 8x16 cell per
# character. Used to paint panel/menu labels into the compositor without
# any backing buffer. Out-of-range characters render as blank.
def str_ink(s: Ptr[uint8], ox: int64, oy: int64, x: int64, y: int64) -> int32:
    ly: int64 = y - oy
    if ly < 0 or ly >= GLYPH_H:
        return 0
    lx: int64 = x - ox
    if lx < 0:
        return 0
    col: int64 = lx / GLYPH_W
    ch: uint8 = s[cast[uint64](col)]
    if ch == 0:
        return 0
    if ch < 32 or ch > 126:
        return 0
    gx: int64 = lx - col * GLYPH_W           # 0..7
    gi: uint64 = cast[uint64](ch) - 32
    bits: uint8 = font_glyphs[gi * 16 + cast[uint64](ly)]
    mask: uint8 = cast[uint8](128 >> gx)
    if (bits & mask) != 0:
        return 1
    return 0


# Return the label string for menu entry `i`.
def menu_label(i: uint64) -> Ptr[uint8]:
    if i == 0:
        s0: Ptr[uint8] = "Terminal"
        return s0
    if i == 1:
        s1: Ptr[uint8] = "Editor (vi)"
        return s1
    if i == 2:
        s2: Ptr[uint8] = "Top"
        return s2
    if i == 3:
        s3: Ptr[uint8] = "Calendar"
        return s3
    if i == 4:
        s4: Ptr[uint8] = "Date"
        return s4
    s5: Ptr[uint8] = "Files"
    return s5


# Return the program path for menu entry `i`.
def menu_prog(i: uint64) -> Ptr[char]:
    if i == 0:
        p0: Ptr[char] = "/bin/hamsh"
        return p0
    if i == 1:
        p1: Ptr[char] = "/bin/vi"
        return p1
    if i == 2:
        p2: Ptr[char] = "/bin/top"
        return p2
    if i == 3:
        p3: Ptr[char] = "/bin/cal"
        return p3
    if i == 4:
        p4: Ptr[char] = "/bin/date"
        return p4
    p5: Ptr[char] = "/bin/hamfm"
    return p5


# Total pixel height the dropped menu occupies.
def menu_total_h() -> int64:
    return cast[int64](MENU_COUNT) * MENU_ITEM_H


# 1 if (px,py) is inside the panel's Applications button.
def in_apps_btn(px: int64, py: int64) -> int32:
    if px >= APPS_BTN_X and px < APPS_BTN_X + APPS_BTN_W:
        if py >= 0 and py < PANEL_H:
            return 1
    return 0


# 1 if (px,py) is anywhere on the panel bar.
def in_panel(px: int64, py: int64) -> int32:
    if py >= 0 and py < PANEL_H:
        return 1
    return 0


# Index (0..MENU_COUNT-1) of the menu item under (px,py) while the menu
# is open, or -1 if not over an item. The menu drops from PANEL_H down.
def menu_item_at(px: int64, py: int64) -> int64:
    if MENU_OPEN == 0:
        return -1
    if px < MENU_X or px >= MENU_X + MENU_W:
        return -1
    top: int64 = PANEL_H
    if py < top or py >= top + menu_total_h():
        return -1
    idx: int64 = (py - top) / MENU_ITEM_H
    if idx < 0 or idx >= cast[int64](MENU_COUNT):
        return -1
    return idx


# ---- daemon window model -------------------------------------------
# Up to DMAX windows the daemon paints as chrome rectangles. We mirror
# the wsys cap (MAX_WINDOWS - 2 spawnable slots) but keep our own count.
DMAX: uint64 = 8
DWIN_X: Array[8, int64]
DWIN_Y: Array[8, int64]
DWIN_W: Array[8, int64]
DWIN_H: Array[8, int64]
DWIN_WID: Array[8, int32]
DWIN_COUNT: uint64 = 0
# Minimize state: 1 = window is hidden to the taskbar, 0 = visible.
DWIN_HIDDEN: Array[8, int32]

# GPU track #183: per-window "Vulkan body" flag. 1 = this window's body
# is painted from the native-Vulkan-rendered image in vk_body_buf (read
# from the window's /dev/wsys/<wid>/draw/vk/fb draw-surface layer each
# frame) instead of the in-daemon terminal grid. Only one window carries
# the live vk body at a time in the self-test, but the model is general.
DWIN_VK: Array[8, int32]
# The native Vulkan window image is 192x192 RGBA8888 (matches lib/vk's
# vk_window_demo VK_WIN_W/H). Module-scope flat buffer (Adder U9 quirk).
VK_BODY_W: int64 = 192
VK_BODY_H: int64 = 192
vk_body_buf: Array[147456, uint8]      # 192 * 192 * 4
vk_body_ready: int32 = 0               # 1 once vk_body_buf holds a frame

# ---- live clock state ---------------------------------------------
# Updated once per second from /proc/realtime (wall clock) or
# /proc/uptime (monotonic fallback). The string is HH:MM (5 chars)
# or UUU:MM (uptime hours:minutes). Always NUL-terminated.
clock_str: Array[12, uint8]
clock_last_cs: uint64 = 0        # centiseconds at last clock refresh

# ---- per-window terminal (in-daemon emulator) ----------------------
# Each window dragged out runs an interactive hamsh whose stdin/stdout
# are kernel pipes. The daemon owns the PARENT ends:
#   DWIN_IN_FD  — write end of the child's stdin pipe (keystrokes -> shell)
#   DWIN_OUT_FD — read  end of the child's stdout pipe (shell -> grid)
# and emulates a tiny VT into a per-window character GRID rendered into
# the window body by daemon_pixel. The grid is a flat DMAX*GRID_CELLS
# byte array; each cell holds one printable ASCII byte (0 == blank).
DWIN_IN_FD:  Array[8, int32]
DWIN_OUT_FD: Array[8, int32]
DWIN_PID:    Array[8, int32]
DWIN_COLS:   Array[8, int64]      # body_w / GLYPH_W
DWIN_ROWS:   Array[8, int64]      # body_h / GLYPH_H
DWIN_CUR_C:  Array[8, int64]      # cursor column
DWIN_CUR_R:  Array[8, int64]      # cursor row
# VT parser state per window: 0 = ground, 1 = saw ESC, 2 = in CSI.
DWIN_VT:     Array[8, int32]

GLYPH_W: int64 = 8
GLYPH_H: int64 = 16
# Grid cap per window: 128 cols * 64 rows. 8192 cells * 8 windows = 64 KiB.
GRID_COLS_MAX: int64 = 128
GRID_ROWS_MAX: int64 = 64
GRID_CELLS:    uint64 = 8192      # GRID_COLS_MAX * GRID_ROWS_MAX
term_grid: Array[65536, uint8]    # DMAX * GRID_CELLS

# Small scratch buffer for draining a child's stdout pipe each frame.
term_rx: Array[1024, uint8]
# Small scratch buffer for draining /dev/cons keystrokes each frame.
cons_rx: Array[256, uint8]
cons_fd: int32 = -1

# ---- cursor + drag state -------------------------------------------
CUR_X: int64 = 0
CUR_Y: int64 = 0
DRAG_ACTIVE: int32 = 0
DRAG_X0: int64 = 0
DRAG_Y0: int64 = 0
PREV_BTN_L: int32 = 0                     # previous-iteration left button

# ---- window-management gesture state -------------------------------
# A left-button-press is classified at the down-edge into one of three
# gestures, tracked by GESTURE:
#   0 = create  (press landed on empty desktop) — rubber-band + spawn
#   1 = move    (press landed on a window title bar) — relocate window
#   2 = close   (press landed on a window's close box) — destroy on up
GESTURE: int32 = 0
# For move: which window slot is being dragged + the cursor-to-window
# offset captured at the down-edge so the window tracks under the grab.
MOVE_SLOT: int64 = -1
MOVE_OFF_X: int64 = 0
MOVE_OFF_Y: int64 = 0
# For close: the slot the press landed on (the release must land on the
# SAME slot's close box to actually destroy it — rio-style).
CLOSE_SLOT: int64 = -1
# Close-box geometry: a square at the right end of the title bar.
CLOSE_BOX: int64 = 14                      # close-box side length (px)

# Small mouse read buffer ("<dx> <dy> <buttons>\n" lines).
mouse_buf: Array[256, uint8]
# Scratch buffer for taskbar button number label (single digit + NUL).
taskbar_lbl_buf: Array[4, uint8]
# Scratch buffer for taskbar click serial output (digit + newline).
taskbar_click_buf: Array[4, uint8]


def iclamp(v: int64, lo: int64, hi: int64) -> int64:
    if v < lo:
        return lo
    if v > hi:
        return hi
    return v


def imin(a: int64, b: int64) -> int64:
    if a < b:
        return a
    return b


def imax(a: int64, b: int64) -> int64:
    if a > b:
        return a
    return b


# ---- taskbar hit-testing -------------------------------------------
# Left x-coordinate of the taskbar button for window `slot`.
# Buttons are laid out left-to-right starting at TASKBAR_START_X,
# one per slot regardless of minimized state (all windows appear).
def taskbar_btn_x(slot: uint64) -> int64:
    return TASKBAR_START_X + cast[int64](slot) * TASKBAR_BTN_W


# 1 if (px,py) is inside the taskbar button for window `slot`, else 0.
# Taskbar buttons live within the panel height.
def in_taskbar_btn(slot: uint64, px: int64, py: int64) -> int32:
    if py < TASKBAR_BTN_Y or py >= TASKBAR_BTN_Y + TASKBAR_BTN_H:
        return 0
    bx: int64 = taskbar_btn_x(slot)
    if px >= bx and px < bx + TASKBAR_BTN_W - 2:
        return 1
    return 0


# Return the taskbar slot (0..DWIN_COUNT-1) under (px,py), or -1.
# Clocks and the Applications button are excluded by TASKBAR_START_X.
def taskbar_slot_at(px: int64, py: int64, scr_w: int64) -> int64:
    if py < 0 or py >= PANEL_H:
        return -1
    # Exclude clock area on the right.
    clock_x: int64 = scr_w - CLOCK_W
    if px >= clock_x:
        return -1
    if px < TASKBAR_START_X:
        return -1
    i: uint64 = 0
    while i < DWIN_COUNT:
        if in_taskbar_btn(i, px, py) != 0:
            return cast[int64](i)
        i = i + 1
    return -1


# ---- minimize-box hit-testing --------------------------------------
# The minimize box is a square just to the LEFT of the close box in
# the title bar. Returns its top-left x.
def minimize_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX - 2 - MINIMIZE_BOX


def minimize_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside the minimize box for window `slot`, else 0.
def in_minimize_box(slot: uint64, px: int64, py: int64) -> int32:
    mx: int64 = minimize_box_x(slot)
    my: int64 = minimize_box_y(slot)
    if px >= mx and px < mx + MINIMIZE_BOX and py >= my and py < my + MINIMIZE_BOX:
        return 1
    return 0


# ---- live clock refresh --------------------------------------------
# Read /proc/realtime; extract HH:MM from the ISO-8601 timestamp.
# Fall back to /proc/uptime (uptime as H:MM) if realtime unavailable.
# Updates clock_str[] and clock_last_cs. Call once per second.
clock_read_buf: Array[64, uint8]

def clock_refresh(cur_cs: uint64):
    # Only refresh once per 100 centiseconds (1 second).
    if cur_cs < clock_last_cs + 100 and clock_last_cs != 0:
        return
    clock_last_cs = cur_cs
    # Try /proc/realtime first: line 1 is "YYYY-MM-DDTHH:MM:SSZ epoch\n"
    # HH is at offset 11, MM at 14 (after the 'T' at 10).
    rt_path: Ptr[char] = "/proc/realtime"
    rfd: int32 = sys_open(rt_path)
    if rfd >= 0:
        n: int64 = sys_read(rfd, &clock_read_buf[0], 64)
        sys_close(rfd)
        nu: uint64 = cast[uint64](n)
        # Check it's a real timestamp (starts with digit, not 'u' for unavailable)
        if nu >= 20 and clock_read_buf[0] != 117 and clock_read_buf[10] == 84:
            # offset 11: HH, offset 12: ':', offset 14: MM
            clock_str[0] = clock_read_buf[11]
            clock_str[1] = clock_read_buf[12]
            clock_str[2] = 58     # ':'
            clock_str[3] = clock_read_buf[14]
            clock_str[4] = clock_read_buf[15]
            clock_str[5] = 0
            return
    # Fallback: /proc/uptime gives centiseconds. Convert to H:MM.
    up_path: Ptr[char] = "/proc/uptime"
    ufd: int32 = sys_open(up_path)
    if ufd >= 0:
        n2: int64 = sys_read(ufd, &clock_read_buf[0], 64)
        sys_close(ufd)
        cs_up: uint64 = 0
        k: uint64 = 0
        nu2: uint64 = cast[uint64](n2)
        while k < nu2 and clock_read_buf[k] >= 48 and clock_read_buf[k] <= 57:
            cs_up = cs_up * 10 + cast[uint64](clock_read_buf[k] - 48)
            k = k + 1
        secs: uint64 = cs_up / 100
        mins: uint64 = (secs / 60) % 60
        hrs:  uint64 = secs / 3600
        # Format H:MM (hours may be more than 2 digits for long uptimes).
        # Cap display to 3 digits of hours so the clock fits the panel.
        idx: uint64 = 0
        if hrs >= 100:
            clock_str[idx] = cast[uint8](hrs / 100) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8]((hrs / 10) % 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        elif hrs >= 10:
            clock_str[idx] = cast[uint8](hrs / 10) + 48
            idx = idx + 1
            clock_str[idx] = cast[uint8](hrs % 10) + 48
            idx = idx + 1
        else:
            clock_str[idx] = cast[uint8](hrs) + 48
            idx = idx + 1
        clock_str[idx] = 58    # ':'
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins / 10) + 48
        idx = idx + 1
        clock_str[idx] = cast[uint8](mins % 10) + 48
        idx = idx + 1
        clock_str[idx] = 0
        return
    # If both fail, show "??:??".
    clock_str[0] = 63    # '?'
    clock_str[1] = 63
    clock_str[2] = 58    # ':'
    clock_str[3] = 63
    clock_str[4] = 63
    clock_str[5] = 0


# ---- window-management hit-testing ---------------------------------
# The close box is a CLOSE_BOX-square inset 2px from the title bar's
# top-right corner. Returns its top-left (cx,cy) for window `slot`.
def close_box_x(slot: uint64) -> int64:
    return DWIN_X[slot] + DWIN_W[slot] - 2 - CLOSE_BOX


def close_box_y(slot: uint64) -> int64:
    return DWIN_Y[slot] + 2


# 1 if (px,py) is inside window slot's close box, else 0.
def in_close_box(slot: uint64, px: int64, py: int64) -> int32:
    cx: int64 = close_box_x(slot)
    cy: int64 = close_box_y(slot)
    if px >= cx and px < cx + CLOSE_BOX and py >= cy and py < cy + CLOSE_BOX:
        return 1
    return 0


# 1 if (px,py) is on window slot's title bar (the band below the top
# border, above the body) — EXCLUDING the close box and minimize box.
# Used to start a move-drag.
def in_title_bar(slot: uint64, px: int64, py: int64) -> int32:
    wx: int64 = DWIN_X[slot]
    wy: int64 = DWIN_Y[slot]
    ww: int64 = DWIN_W[slot]
    if px < wx + 2 or px >= wx + ww - 2:
        return 0
    if py < wy + 2 or py >= wy + TITLE_H:
        return 0
    if in_close_box(slot, px, py) != 0:
        return 0
    if in_minimize_box(slot, px, py) != 0:
        return 0
    return 1


# Topmost window slot whose rectangle contains (px,py), or -1. Windows
# paint back-to-front (slot 0 lowest), so the highest slot wins the
# hit-test.
def window_at(px: int64, py: int64) -> int64:
    wi: int64 = cast[int64](DWIN_COUNT) - 1
    while wi >= 0:
        s: uint64 = cast[uint64](wi)
        # Skip minimized (hidden) windows — they have no visible surface.
        if DWIN_HIDDEN[s] == 0:
            wx: int64 = DWIN_X[s]
            wy: int64 = DWIN_Y[s]
            if px >= wx and px < wx + DWIN_W[s] and py >= wy and py < wy + DWIN_H[s]:
                return wi
        wi = wi - 1
    return -1


# ---- per-window terminal emulator ----------------------------------
# Cell index for window `slot` at (col,row) into the flat term_grid.
def term_cell(slot: uint64, col: int64, row: int64) -> uint64:
    return slot * GRID_CELLS + cast[uint64](row * GRID_COLS_MAX + col)


# Clear a window's whole grid to blanks (0) and home the cursor.
def term_clear(slot: uint64):
    base: uint64 = slot * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[base + i] = 0
        i = i + 1
    DWIN_CUR_C[slot] = 0
    DWIN_CUR_R[slot] = 0
    DWIN_VT[slot] = 0


# Scroll the grid up one row (drop the top row, blank the new bottom).
def term_scroll(slot: uint64):
    rows: int64 = DWIN_ROWS[slot]
    cols: int64 = DWIN_COLS[slot]
    r: int64 = 0
    while r < rows - 1:
        c: int64 = 0
        while c < cols:
            src: uint64 = term_cell(slot, c, r + 1)
            dst: uint64 = term_cell(slot, c, r)
            term_grid[dst] = term_grid[src]
            c = c + 1
        r = r + 1
    # blank the last row
    c2: int64 = 0
    while c2 < cols:
        term_grid[term_cell(slot, c2, rows - 1)] = 0
        c2 = c2 + 1


def term_newline(slot: uint64):
    DWIN_CUR_R[slot] = DWIN_CUR_R[slot] + 1
    if DWIN_CUR_R[slot] >= DWIN_ROWS[slot]:
        term_scroll(slot)
        DWIN_CUR_R[slot] = DWIN_ROWS[slot] - 1


# Emit one printable byte into the grid at the cursor, advancing it
# (wrapping + scrolling as needed).
def term_putc(slot: uint64, ch: uint8):
    cols: int64 = DWIN_COLS[slot]
    if cols <= 0 or DWIN_ROWS[slot] <= 0:
        return
    if DWIN_CUR_C[slot] >= cols:
        DWIN_CUR_C[slot] = 0
        term_newline(slot)
    term_grid[term_cell(slot, DWIN_CUR_C[slot], DWIN_CUR_R[slot])] = ch
    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] + 1


# Feed `n` bytes from buf into window slot's terminal, honouring a
# minimal control set + swallowing CSI escape sequences so they don't
# corrupt the grid.
def term_feed(slot: uint64, buf: Ptr[uint8], n: int64):
    i: int64 = 0
    while i < n:
        c: uint8 = buf[cast[uint64](i)]
        st: int32 = DWIN_VT[slot]
        if st == 1:
            # saw ESC: '[' begins a CSI; anything else aborts to ground.
            if c == 91:                          # '['
                DWIN_VT[slot] = 2
            else:
                DWIN_VT[slot] = 0
            i = i + 1
        elif st == 2:
            # in CSI: consume parameter/intermediate bytes until a final
            # byte in 0x40..0x7E ends the sequence (we ignore its effect).
            if c >= 64 and c <= 126:
                DWIN_VT[slot] = 0
            i = i + 1
        else:
            if c == 27:                          # ESC
                DWIN_VT[slot] = 1
            elif c == 10:                        # '\n' -> newline + CR
                DWIN_CUR_C[slot] = 0
                term_newline(slot)
            elif c == 13:                        # '\r' -> carriage return
                DWIN_CUR_C[slot] = 0
            elif c == 8:                         # backspace
                if DWIN_CUR_C[slot] > 0:
                    DWIN_CUR_C[slot] = DWIN_CUR_C[slot] - 1
                    term_grid[term_cell(slot, DWIN_CUR_C[slot],
                                        DWIN_CUR_R[slot])] = 0
            elif c == 9:                         # tab -> advance to next 8
                nc: int64 = (DWIN_CUR_C[slot] / 8 + 1) * 8
                if nc >= DWIN_COLS[slot]:
                    nc = DWIN_COLS[slot] - 1
                DWIN_CUR_C[slot] = nc
            elif c >= 32 and c <= 126:           # printable ASCII
                term_putc(slot, c)
            # everything else (other control bytes): drop silently
            i = i + 1


# Drain a window's stdout pipe (non-blocking) into its grid. Returns 1
# if any bytes were consumed (the screen needs a re-present), else 0.
def term_pump(slot: uint64) -> int32:
    fd: int32 = DWIN_OUT_FD[slot]
    if fd < 0:
        return 0
    got: int32 = 0
    iters: int32 = 0
    while iters < 16:
        n: int64 = sys_read_nb(fd, &term_rx[0], 1024)
        iters = iters + 1
        if n <= 0:
            break
        term_feed(slot, &term_rx[0], n)
        got = 1
    return got


# Pixel-model query: what colour is screen pixel (x,y)? Writes r/g/b.
# Order (back to front): backdrop -> windows (in creation order) ->
# rubber band outline -> cursor. The cursor wins last so it's always
# visible.
def daemon_pixel(x: int64, y: int64,
                 outr: Ptr[uint8], outg: Ptr[uint8], outb: Ptr[uint8]):
    r: uint8 = ROOT_R
    g: uint8 = ROOT_G
    b: uint8 = ROOT_B
    # --- windows (back to front) ---
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        # Skip minimized windows — they are hidden to the taskbar.
        if DWIN_HIDDEN[wi] != 0:
            wi = wi + 1
            continue
        wx: int64 = DWIN_X[wi]
        wy: int64 = DWIN_Y[wi]
        ww: int64 = DWIN_W[wi]
        wh: int64 = DWIN_H[wi]
        if x >= wx and x < wx + ww and y >= wy and y < wy + wh:
            # border (2px), title bar, or body.
            on_border: int32 = 0
            if x < wx + 2 or x >= wx + ww - 2 or y < wy + 2 or y >= wy + wh - 2:
                on_border = 1
            if on_border != 0:
                r = WIN_BORDER_R
                g = WIN_BORDER_G
                b = WIN_BORDER_B
            else:
                if y < wy + TITLE_H:
                    # Focused window (topmost slot) gets a brighter title bar
                    # so the user can tell which window owns keyboard input.
                    if wi == DWIN_COUNT - 1:
                        r = WIN_TITLE_FOCUS_R
                        g = WIN_TITLE_FOCUS_G
                        b = WIN_TITLE_FOCUS_B
                    else:
                        r = WIN_TITLE_R
                        g = WIN_TITLE_G
                        b = WIN_TITLE_B
                    # Close box overlay at the title bar's right end.
                    cbx: int64 = close_box_x(wi)
                    cby: int64 = close_box_y(wi)
                    if x >= cbx and x < cbx + CLOSE_BOX and y >= cby and y < cby + CLOSE_BOX:
                        r = CLOSE_R
                        g = CLOSE_G
                        b = CLOSE_B
                        # Draw an 'X': the two diagonals of the box (2px
                        # inset) in white.
                        lxp: int64 = x - cbx
                        lyp: int64 = y - cby
                        inset: int64 = 2
                        span: int64 = CLOSE_BOX - 1
                        if lxp >= inset and lxp <= span - inset and lyp >= inset and lyp <= span - inset:
                            if lxp == lyp or lxp == span - lyp:
                                r = CLOSE_X_R
                                g = CLOSE_X_G
                                b = CLOSE_X_B
                    # Minimize box: yellow square just left of the close box.
                    mbx: int64 = minimize_box_x(wi)
                    mby: int64 = minimize_box_y(wi)
                    if x >= mbx and x < mbx + MINIMIZE_BOX and y >= mby and y < mby + MINIMIZE_BOX:
                        r = MINIMIZE_R
                        g = MINIMIZE_G
                        b = MINIMIZE_B
                        # Draw a horizontal dash centred in the box.
                        lxm: int64 = x - mbx
                        lym: int64 = y - mby
                        dash_y: int64 = MINIMIZE_BOX / 2
                        dash_x0: int64 = 3
                        dash_x1: int64 = MINIMIZE_BOX - 4
                        dash_h:  int64 = 2
                        if lym >= dash_y and lym < dash_y + dash_h and lxm >= dash_x0 and lxm <= dash_x1:
                            r = MINIMIZE_DASH_R
                            g = MINIMIZE_DASH_G
                            b = MINIMIZE_DASH_B
                elif DWIN_VK[wi] != 0:
                    # --- native Vulkan image rendered into the body ---
                    # The 192x192 RGBA frame (vk_body_buf) sits top-left
                    # inside the body region; body pixels outside it fall
                    # back to the plain body colour.
                    r = WIN_BODY_R
                    g = WIN_BODY_G
                    b = WIN_BODY_B
                    vbx0: int64 = wx + 2
                    vby0: int64 = wy + TITLE_H
                    vlx: int64 = x - vbx0
                    vly: int64 = y - vby0
                    if vk_body_ready != 0 and vlx >= 0 and vly >= 0 \
                       and vlx < VK_BODY_W and vly < VK_BODY_H:
                        vo: uint64 = cast[uint64](vly * VK_BODY_W + vlx) * 4
                        r = vk_body_buf[vo]
                        g = vk_body_buf[vo + 1]
                        b = vk_body_buf[vo + 2]
                else:
                    r = WIN_BODY_R
                    g = WIN_BODY_G
                    b = WIN_BODY_B
                    # --- terminal text rendered into the body ---
                    bx0: int64 = wx + 2
                    by0: int64 = wy + TITLE_H
                    lx: int64 = x - bx0           # pixel within body
                    ly: int64 = y - by0
                    if lx >= 0 and ly >= 0:
                        col: int64 = lx / GLYPH_W
                        row: int64 = ly / GLYPH_H
                        if col < DWIN_COLS[wi] and row < DWIN_ROWS[wi]:
                            gx: int64 = lx - col * GLYPH_W   # 0..7
                            gy: int64 = ly - row * GLYPH_H   # 0..15
                            # Cursor block (inverse) at the cell cursor.
                            is_cur: int32 = 0
                            if col == DWIN_CUR_C[wi] and row == DWIN_CUR_R[wi]:
                                is_cur = 1
                            ce: uint64 = term_cell(cast[uint64](wi), col, row)
                            ch: uint8 = term_grid[ce]
                            on: int32 = 0
                            if ch >= 32 and ch <= 126:
                                gi: uint64 = cast[uint64](ch) - 32
                                bits: uint8 = font_glyphs[gi * 16
                                                          + cast[uint64](gy)]
                                mask: uint8 = cast[uint8](128 >> gx)
                                if (bits & mask) != 0:
                                    on = 1
                            if is_cur != 0:
                                # Solid dark cursor block; glyph ink on it
                                # flips to body colour for legibility.
                                if on != 0:
                                    r = WIN_BODY_R
                                    g = WIN_BODY_G
                                    b = WIN_BODY_B
                                else:
                                    r = 24
                                    g = 24
                                    b = 24
                            elif on != 0:
                                r = 24
                                g = 24
                                b = 24
        wi = wi + 1
    # --- panel bar (always on top of windows; classic top panel) ---
    # Painted after windows so it is never obscured; the cursor still
    # wins last. The Applications button at the left end tints when the
    # menu is open. Its label and a right-aligned clock-ish title render
    # as glyph ink.
    if y >= 0 and y < PANEL_H:
        r = PANEL_R
        g = PANEL_G
        b = PANEL_B
        on_btn: int32 = in_apps_btn(x, y)
        if on_btn != 0:
            if MENU_OPEN != 0:
                r = PANEL_HI_R
                g = PANEL_HI_G
                b = PANEL_HI_B
        # 1px bottom border so the panel reads as a distinct bar.
        if y == PANEL_H - 1:
            r = 24
            g = 28
            b = 36
        # "Applications" label, vertically centred in the panel.
        albl: Ptr[uint8] = "Applications"
        aly: int64 = (PANEL_H - GLYPH_H) / 2
        if str_ink(albl, APPS_BTN_X + 6, aly, x, y) != 0:
            r = PANEL_TXT_R
            g = PANEL_TXT_G
            b = PANEL_TXT_B
        # --- taskbar: one button per window (right of Applications) ---
        # Each button renders in the panel; focused window is highlighted,
        # minimized windows show a dimmed tint, visible ones are plain.
        tb_scr_w: int64 = cast[int64](FBG_W)
        clock_x: int64 = tb_scr_w - CLOCK_W
        tbi: uint64 = 0
        while tbi < DWIN_COUNT:
            tbx: int64 = taskbar_btn_x(tbi)
            tbe: int64 = tbx + TASKBAR_BTN_W - 2
            # Only paint button if it doesn't overlap the clock zone.
            if tbx < clock_x:
                if x >= tbx and x < tbe and y >= TASKBAR_BTN_Y and y < TASKBAR_BTN_Y + TASKBAR_BTN_H:
                    # Focused: topmost visible window gets highlight tint.
                    if tbi == DWIN_COUNT - 1 and DWIN_HIDDEN[tbi] == 0:
                        r = PANEL_HI_R
                        g = PANEL_HI_G
                        b = PANEL_HI_B
                    elif DWIN_HIDDEN[tbi] != 0:
                        # Minimized: slightly lighter background.
                        r = cast[uint8](cast[int32](PANEL_R) + 20)
                        g = cast[uint8](cast[int32](PANEL_G) + 20)
                        b = cast[uint8](cast[int32](PANEL_B) + 20)
                    # else: plain panel colour remains from above.
                    # 1px right edge separator between buttons.
                    if x == tbe - 1:
                        r = 24
                        g = 28
                        b = 36
                    # Window number label (1-based: slot 0 = "1").
                    taskbar_lbl_buf[0] = cast[uint8](tbi + 1) + 48
                    taskbar_lbl_buf[1] = 0
                    if str_ink(&taskbar_lbl_buf[0], tbx + 4, aly, x, y) != 0:
                        r = PANEL_TXT_R
                        g = PANEL_TXT_G
                        b = PANEL_TXT_B
            tbi = tbi + 1
        # --- live clock on the right edge of the panel ---
        if x >= clock_x and x < tb_scr_w:
            r = CLOCK_R
            g = CLOCK_G
            b = CLOCK_B
            if y == PANEL_H - 1:
                r = 24
                g = 28
                b = 36
            if str_ink(&clock_str[0], clock_x + CLOCK_PAD, aly, x, y) != 0:
                r = PANEL_TXT_R
                g = PANEL_TXT_G
                b = PANEL_TXT_B
    # --- Applications menu (drops below the panel when open) ---
    if MENU_OPEN != 0:
        mtop: int64 = PANEL_H
        mbot: int64 = mtop + menu_total_h()
        if x >= MENU_X and x < MENU_X + MENU_W and y >= mtop and y < mbot:
            r = MENU_R
            g = MENU_G
            b = MENU_B
            # 1px right + bottom border for the menu frame.
            if x == MENU_X + MENU_W - 1 or y == mbot - 1 or x == MENU_X:
                r = 24
                g = 28
                b = 36
            # Hovered item highlight (the item under the cursor).
            item: int64 = (y - mtop) / MENU_ITEM_H
            hov: int64 = menu_item_at(CUR_X, CUR_Y)
            if item == hov and hov >= 0:
                on_edge_m: int32 = 0
                if x == MENU_X + MENU_W - 1 or x == MENU_X:
                    on_edge_m = 1
                if on_edge_m == 0:
                    r = MENU_SEL_R
                    g = MENU_SEL_G
                    b = MENU_SEL_B
            # Item label ink.
            if item >= 0 and item < cast[int64](MENU_COUNT):
                ilbl: Ptr[uint8] = menu_label(cast[uint64](item))
                ioy: int64 = mtop + item * MENU_ITEM_H + (MENU_ITEM_H - GLYPH_H) / 2
                if str_ink(ilbl, MENU_X + 8, ioy, x, y) != 0:
                    r = MENU_TXT_R
                    g = MENU_TXT_G
                    b = MENU_TXT_B
    # --- rubber band (1px outline of the in-progress drag rect) ---
    if DRAG_ACTIVE != 0:
        rx0: int64 = imin(DRAG_X0, CUR_X)
        ry0: int64 = imin(DRAG_Y0, CUR_Y)
        rx1: int64 = imax(DRAG_X0, CUR_X)
        ry1: int64 = imax(DRAG_Y0, CUR_Y)
        if x >= rx0 and x <= rx1 and y >= ry0 and y <= ry1:
            on_edge: int32 = 0
            if x == rx0 or x == rx1 or y == ry0 or y == ry1:
                on_edge = 1
            if on_edge != 0:
                r = 255
                g = 255
                b = 0
    # --- cursor (a small filled arrow / triangle) ---
    dx: int64 = x - CUR_X
    dy: int64 = y - CUR_Y
    if dx >= 0 and dy >= 0 and dx < 12 and dy < 12:
        # Triangle mask: the pixel is part of the cursor if dx <= dy.
        # That paints a downward-right pointer anchored at the hotspot.
        if dx <= dy:
            # 1px white outline at the hypotenuse-ish edge, black fill.
            if dx == dy or dy == 11 or dx == 0:
                r = 255
                g = 255
                b = 255
            else:
                r = 0
                g = 0
                b = 0
    outr[0] = r
    outg[0] = g
    outb[0] = b


# Composite one screen frame from the daemon model and present it to
# /dev/fb, one row at a time (bounded userland memory). Returns 0 / 1.
def daemon_present() -> int32:
    sw: uint64 = FBG_W
    sh: uint64 = FBG_H
    if sw > SCREEN_ROW_MAXW:
        sw = SCREEN_ROW_MAXW
    pw: Ptr[uint8] = "/dev/fb"
    wf: int32 = sys_open_write(cast[Ptr[char]](pw))
    if wf < 0:
        return 1
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    sy: uint64 = 0
    while sy < sh:
        sx: uint64 = 0
        while sx < sw:
            daemon_pixel(cast[int64](sx), cast[int64](sy),
                         &rr[0], &gg[0], &bb[0])
            o: uint64 = sx * 4
            screen_row[o] = rr[0]
            screen_row[o + 1] = gg[0]
            screen_row[o + 2] = bb[0]
            screen_row[o + 3] = 255
            sx = sx + 1
        sys_write(wf, &screen_row[0], sw * 4)
        sy = sy + 1
    sys_close(wf)
    return 0


# Spawn a detached program + bind it to a fresh wid, then record the
# dragged rectangle as a daemon window. Mirrors user/hamUI.ad::cmd_new.
# Returns the wid (>=2) on success, -1 on failure (still records the
# rectangle as a chrome-only window so the gesture is visibly honoured).
#
# `prog` is the absolute binary path to launch (e.g. "/bin/hamsh",
# "/bin/vi"); its stdin/stdout are wired to the daemon's pipe ends so the
# in-window VT emulator drives it exactly like the drag-out shell. This
# is the SINGLE spawn-into-window path: the drag-to-create gesture passes
# "/bin/hamsh"; the Applications menu passes whichever program was clicked.
arg_buf_d: Array[2, uint64]
in_pipe_d:  Array[2, int32]              # child stdin  pipe [r, w]
out_pipe_d: Array[2, int32]             # child stdout pipe [r, w]
def daemon_spawn_window_prog(prog: Ptr[char],
                             rx: int64, ry: int64, rw: int64, rh: int64):
    if DWIN_COUNT >= DMAX:
        return
    slot: uint64 = DWIN_COUNT
    # Two kernel pipes wire the child's stdio to this daemon:
    #   in_pipe:  parent writes [1], child reads  [0]  (keystrokes)
    #   out_pipe: child writes  [1], parent reads [0]  (shell output)
    in_ok:  int32 = sys_pipe(&in_pipe_d[0])
    out_ok: int32 = sys_pipe(&out_pipe_d[0])
    child_in:  int32 = -1
    child_out: int32 = -1
    parent_in_w:  int32 = -1
    parent_out_r: int32 = -1
    if in_ok == 0 and out_ok == 0:
        child_in     = in_pipe_d[0]      # child stdin  = read end
        parent_in_w  = in_pipe_d[1]      # parent keeps write end
        child_out    = out_pipe_d[1]     # child stdout = write end
        parent_out_r = out_pipe_d[0]     # parent keeps read end
    wid: int32 = -1
    arg_buf_d[0] = cast[uint64](prog)
    arg_buf_d[1] = 0
    pid: int32 = -1
    if child_in >= 0 and child_out >= 0:
        # Real pipe fds -> the legacy integer-fd spawn path dups them into
        # the child's fd 0/1 (and binds /fd/0,1,2 on its private namespace),
        # so the spawned program talks to OUR pipes, not the serial console.
        pid = sys_spawn(prog, &arg_buf_d[0],
                        child_in, child_out, cast[Ptr[uint64]](0))
    else:
        # Pipe allocation failed — fall back to the detached spawn so the
        # gesture still produces a (headless) window.
        pid = sys_spawn(prog, &arg_buf_d[0],
                        -2, -2, cast[Ptr[uint64]](0))
    if pid >= 0:
        wid = sys_wsys_alloc(cast[uint64](pid))
        if wid < 0:
            # Table full / dup — reap the child so we don't leak it.
            sys_kill(pid, SIGTERM_D)
    # The child has its own dup'd copies now; close OUR copies of the
    # child ends so the pipe EOF/refcounts stay correct.
    if child_in >= 0:
        sys_close(child_in)
    if child_out >= 0:
        sys_close(child_out)
    # Record the window + its terminal state.
    DWIN_X[slot] = rx
    DWIN_Y[slot] = ry
    DWIN_W[slot] = rw
    DWIN_H[slot] = rh
    DWIN_WID[slot] = wid
    DWIN_PID[slot] = pid
    DWIN_IN_FD[slot]  = parent_in_w
    DWIN_OUT_FD[slot] = parent_out_r
    # Grid geometry from the body region (window minus 2px border + title).
    body_w: int64 = rw - 4
    body_h: int64 = rh - TITLE_H - 2
    cols: int64 = body_w / GLYPH_W
    rows: int64 = body_h / GLYPH_H
    if cols > GRID_COLS_MAX:
        cols = GRID_COLS_MAX
    if rows > GRID_ROWS_MAX:
        rows = GRID_ROWS_MAX
    if cols < 0:
        cols = 0
    if rows < 0:
        rows = 0
    DWIN_COLS[slot] = cols
    DWIN_ROWS[slot] = rows
    DWIN_HIDDEN[slot] = 0
    term_clear(slot)
    DWIN_COUNT = DWIN_COUNT + 1
    # If we got a real wid, plant a chrome layer on its draw surface so
    # the window is real on the wsys side too (best-effort).
    if wid >= 2:
        build_path(wid, cast[Ptr[uint8]](0), "ctl")
        cf: int32 = sys_open_write(cast[Ptr[char]](&path_buf[0]))
        if cf >= 0:
            cmd: Ptr[uint8] = "mklayer chrome markup\n"
            sys_write(cf, cmd, strlen_u8(cmd))
            sys_close(cf)


# Backwards-compatible drag-to-create spawn: launches an interactive
# hamsh into the dragged rectangle (the classic rio gesture). Delegates
# to the generalised path so there is one spawn implementation.
def daemon_spawn_window(rx: int64, ry: int64, rw: int64, rh: int64):
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/hamsh"), rx, ry, rw, rh)


# Launch menu entry `i` into a fresh window. Each launch is cascaded a
# little down-right of the previous so several apps don't stack exactly
# on top of one another. The rectangle is clamped to stay below the panel
# and inside the framebuffer. Reuses the single spawn-into-window path.
LAUNCH_CASCADE: int64 = 0
def menu_launch(i: uint64, scr_w: int64, scr_h: int64):
    if i >= MENU_COUNT:
        return
    w: int64 = 480
    h: int64 = 320
    # Cascade origin: step 28px per launch, wrapping after a few steps.
    step: int64 = (LAUNCH_CASCADE % 6) * 28
    rx: int64 = 80 + step
    ry: int64 = PANEL_H + 20 + step
    # Clamp so the window fits on-screen below the panel.
    if w > scr_w - 8:
        w = scr_w - 8
    if h > scr_h - PANEL_H - 8:
        h = scr_h - PANEL_H - 8
    if rx + w > scr_w:
        rx = scr_w - w
    if ry + h > scr_h:
        ry = scr_h - h
    if rx < 0:
        rx = 0
    if ry < PANEL_H:
        ry = PANEL_H
    LAUNCH_CASCADE = LAUNCH_CASCADE + 1
    daemon_spawn_window_prog(menu_prog(i), rx, ry, w, h)
    # Emit a deterministic serial marker so a self-test can assert the
    # launch fired (label, not path, to keep the marker human-readable).
    pfx: Ptr[uint8] = "PANEL launch "
    sys_write(1, pfx, strlen_u8(pfx))
    lbl: Ptr[uint8] = menu_label(i)
    sys_write(1, lbl, strlen_u8(lbl))
    nl: Ptr[uint8] = "\n"
    sys_write(1, nl, 1)


# Copy ALL per-slot window state (geometry, terminal fds/state, and the
# character grid) from slot `src` to slot `dst`. Used to compact the
# window table when a window is destroyed and to reorder for raise.
def slot_copy(dst: uint64, src: uint64):
    if dst == src:
        return
    DWIN_X[dst]      = DWIN_X[src]
    DWIN_Y[dst]      = DWIN_Y[src]
    DWIN_W[dst]      = DWIN_W[src]
    DWIN_H[dst]      = DWIN_H[src]
    DWIN_WID[dst]    = DWIN_WID[src]
    DWIN_PID[dst]    = DWIN_PID[src]
    DWIN_IN_FD[dst]  = DWIN_IN_FD[src]
    DWIN_OUT_FD[dst] = DWIN_OUT_FD[src]
    DWIN_COLS[dst]   = DWIN_COLS[src]
    DWIN_ROWS[dst]   = DWIN_ROWS[src]
    DWIN_CUR_C[dst]  = DWIN_CUR_C[src]
    DWIN_CUR_R[dst]  = DWIN_CUR_R[src]
    DWIN_VT[dst]     = DWIN_VT[src]
    DWIN_HIDDEN[dst] = DWIN_HIDDEN[src]
    # Move the character grid wholesale (GRID_CELLS bytes).
    sb: uint64 = src * GRID_CELLS
    db: uint64 = dst * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        term_grid[db + i] = term_grid[sb + i]
        i = i + 1


# Raise window `slot` to the topmost paint position (last slot). The
# windows above it slide down one slot so paint/hit-test order stays a
# simple back-to-front array walk. MOVE_SLOT is rebased to the new
# position so an in-flight move keeps tracking the right window.
def daemon_raise_slot(slot: int64) -> int64:
    if slot < 0:
        return slot
    last: uint64 = DWIN_COUNT - 1
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT or s == last:
        return cast[int64](s)
    # Stash the window being raised in the spare slot just past the
    # table (DMAX-sized arrays always have room: DWIN_COUNT <= DMAX, and
    # we hold the raised window aside while shifting), using slot DMAX-1
    # is unsafe when full — instead shift up then place at `last`.
    # Save raised window into temporaries via the spawn scratch grid is
    # complex; simplest correct approach: bubble it up with swaps.
    cur: uint64 = s
    while cur < last:
        slot_swap(cur, cur + 1)
        cur = cur + 1
    return cast[int64](last)


# Swap two slots' full state. Implemented via a scratch slot would need
# extra grid storage; instead swap field-by-field and the grid cell-by-
# cell (bounded: GRID_CELLS per call, DMAX small).
def slot_swap(a: uint64, b: uint64):
    if a == b:
        return
    t0: int64 = DWIN_X[a]
    DWIN_X[a] = DWIN_X[b]
    DWIN_X[b] = t0
    t1: int64 = DWIN_Y[a]
    DWIN_Y[a] = DWIN_Y[b]
    DWIN_Y[b] = t1
    t2: int64 = DWIN_W[a]
    DWIN_W[a] = DWIN_W[b]
    DWIN_W[b] = t2
    t3: int64 = DWIN_H[a]
    DWIN_H[a] = DWIN_H[b]
    DWIN_H[b] = t3
    i0: int32 = DWIN_WID[a]
    DWIN_WID[a] = DWIN_WID[b]
    DWIN_WID[b] = i0
    i1: int32 = DWIN_PID[a]
    DWIN_PID[a] = DWIN_PID[b]
    DWIN_PID[b] = i1
    i2: int32 = DWIN_IN_FD[a]
    DWIN_IN_FD[a] = DWIN_IN_FD[b]
    DWIN_IN_FD[b] = i2
    i3: int32 = DWIN_OUT_FD[a]
    DWIN_OUT_FD[a] = DWIN_OUT_FD[b]
    DWIN_OUT_FD[b] = i3
    t4: int64 = DWIN_COLS[a]
    DWIN_COLS[a] = DWIN_COLS[b]
    DWIN_COLS[b] = t4
    t5: int64 = DWIN_ROWS[a]
    DWIN_ROWS[a] = DWIN_ROWS[b]
    DWIN_ROWS[b] = t5
    t6: int64 = DWIN_CUR_C[a]
    DWIN_CUR_C[a] = DWIN_CUR_C[b]
    DWIN_CUR_C[b] = t6
    t7: int64 = DWIN_CUR_R[a]
    DWIN_CUR_R[a] = DWIN_CUR_R[b]
    DWIN_CUR_R[b] = t7
    i4: int32 = DWIN_VT[a]
    DWIN_VT[a] = DWIN_VT[b]
    DWIN_VT[b] = i4
    i5: int32 = DWIN_HIDDEN[a]
    DWIN_HIDDEN[a] = DWIN_HIDDEN[b]
    DWIN_HIDDEN[b] = i5
    ab: uint64 = a * GRID_CELLS
    bb: uint64 = b * GRID_CELLS
    i: uint64 = 0
    while i < GRID_CELLS:
        g: uint8 = term_grid[ab + i]
        term_grid[ab + i] = term_grid[bb + i]
        term_grid[bb + i] = g
        i = i + 1


# Destroy window `slot`: tear down its hamsh child + pipes, free the wid
# binding, then compact the table so paint order stays contiguous. Any
# in-flight move/close referencing a shifted slot is reset by the caller.
def daemon_close_slot(slot: int64):
    if slot < 0:
        return
    s: uint64 = cast[uint64](slot)
    if s >= DWIN_COUNT:
        return
    # Tear down the child shell + the daemon's pipe ends so we don't leak
    # the process or the fds. SIGTERM the bound pid (best-effort), free
    # the wsys slot, and close both parent pipe ends.
    pid: int32 = DWIN_PID[s]
    if pid > 0:
        sys_kill(pid, SIGTERM_D)
    wid: int32 = DWIN_WID[s]
    if wid >= 2:
        sys_wsys_free(wid)
    infd: int32 = DWIN_IN_FD[s]
    if infd >= 0:
        sys_close(infd)
    outfd: int32 = DWIN_OUT_FD[s]
    if outfd >= 0:
        sys_close(outfd)
    # Compact: slide every higher slot down by one so paint order stays
    # a contiguous 0..DWIN_COUNT-1 back-to-front walk.
    last: uint64 = DWIN_COUNT - 1
    j: uint64 = s
    while j < last:
        slot_copy(j, j + 1)
        j = j + 1
    DWIN_COUNT = DWIN_COUNT - 1


# Consume all currently-available mouse packets, updating CUR_X/CUR_Y
# and tracking the left-button edge for the drag gesture. Returns 1 if
# anything changed (cursor moved or button edge), else 0. The /dev/mouse
# fd is held in the mouse_fd global (opened once in cmd_daemon).
mouse_fd: int32 = -1
def daemon_pump_mouse(scr_w: int64, scr_h: int64) -> int32:
    changed: int32 = 0
    iters: int32 = 0
    while iters < 64:
        n: int64 = sys_read_nb(mouse_fd, &mouse_buf[0], 256)
        iters = iters + 1
        if n <= 0:
            break
        i: uint64 = 0
        total: uint64 = cast[uint64](n)
        while i < total:
            ls: uint64 = i
            while i < total and mouse_buf[i] != 10:
                i = i + 1
            le: uint64 = i
            if i < total:
                i = i + 1
            if le > ls:
                changed = daemon_apply_packet(ls, le, scr_w, scr_h) | changed
    return changed


def daemon_apply_packet(ls: uint64, le: uint64,
                        scr_w: int64, scr_h: int64) -> int32:
    # Parse "<dx> <dy> <buttons>" (space-separated, possibly signed).
    pos: Array[1, uint64]
    pos[0] = ls
    dx: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    dy: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    btn: int64 = next_signed(&mouse_buf[0], &pos[0], le)
    # /dev/mouse already reports screen-space deltas: the PS/2 driver
    # (drivers/input/auxmouse.ad) negates the protocol's up-positive Y
    # into framebuffer-down-positive at the single conversion point, so
    # here we just integrate both axes directly. (Negating again was a
    # double-negation that inverted vertical cursor motion.)
    CUR_X = iclamp(CUR_X + dx, 0, scr_w - 1)
    CUR_Y = iclamp(CUR_Y + dy, 0, scr_h - 1)
    lbtn: int32 = 0
    if (btn & 1) != 0:
        lbtn = 1
    # Drive the gesture state machine off the integrated cursor + button
    # state. wm_button() handles the press/drag/release edges (move,
    # close, create) using CUR_X/CUR_Y and PREV_BTN_L.
    wm_button(lbtn, scr_w, scr_h)
    PREV_BTN_L = lbtn
    return 1


# Gesture state machine, driven by the current left-button level (lbtn:
# 0/1) and the absolute cursor at CUR_X/CUR_Y. Detects the press edge
# (against PREV_BTN_L), tracks an in-flight move while held, and resolves
# move/close/create on the release edge. Factored out so the daemon
# self-test can drive it directly with absolute coordinates (no /dev/mouse
# packet round-trip).
def wm_button(lbtn: int32, scr_w: int64, scr_h: int64):
    # --- left-button DOWN edge: classify the gesture ---
    if lbtn != 0 and PREV_BTN_L == 0:
        # PANEL / MENU first — desktop chrome intercepts the press before
        # any window/drag-create logic so the launcher never also starts a
        # rubber-band window.
        #   * press on the Applications button -> toggle the menu (and stop)
        #   * press on an open menu item        -> launch it + close the menu
        #   * press anywhere else while the menu is open -> dismiss it
        #   * press elsewhere on the panel bar  -> swallow (no window action)
        if in_apps_btn(CUR_X, CUR_Y) != 0:
            if MENU_OPEN != 0:
                MENU_OPEN = 0
                mc: Ptr[uint8] = "PANEL close menu\n"
                sys_write(1, mc, strlen_u8(mc))
            else:
                MENU_OPEN = 1
                mo: Ptr[uint8] = "PANEL open menu\n"
                sys_write(1, mo, strlen_u8(mo))
            DRAG_ACTIVE = 0
            GESTURE = 3                        # panel: no up-edge action
            return
        if MENU_OPEN != 0:
            mi: int64 = menu_item_at(CUR_X, CUR_Y)
            MENU_OPEN = 0                       # any click closes the menu
            if mi >= 0:
                menu_launch(cast[uint64](mi), scr_w, scr_h)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # --- taskbar button click: raise/restore the clicked window ---
        tslot: int64 = taskbar_slot_at(CUR_X, CUR_Y, scr_w)
        if tslot >= 0:
            ts: uint64 = cast[uint64](tslot)
            if DWIN_HIDDEN[ts] != 0:
                # Restore: un-minimize then raise to focus.
                DWIN_HIDDEN[ts] = 0
                daemon_raise_slot(tslot)
                tb_pfx: Ptr[uint8] = "TASKBAR restore "
                sys_write(1, tb_pfx, strlen_u8(tb_pfx))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            else:
                # Raise the window (give it focus).
                daemon_raise_slot(tslot)
                tb_pfx2: Ptr[uint8] = "TASKBAR raise "
                sys_write(1, tb_pfx2, strlen_u8(tb_pfx2))
                taskbar_click_buf[0] = cast[uint8](ts + 1) + 48
                taskbar_click_buf[1] = 10
                sys_write(1, &taskbar_click_buf[0], 2)
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        if in_panel(CUR_X, CUR_Y) != 0:
            # Press on the panel bar (not the button) — swallow it so the
            # panel can never start a drag-create underneath itself.
            DRAG_ACTIVE = 0
            GESTURE = 3
            return
        # Hit-test the topmost window under the cursor. A press on a
        # window's close box arms a close; a press on its title bar
        # starts a move (and raises it on top); anything else (empty
        # desktop, or a window body) begins a rubber-band create drag.
        hit: int64 = window_at(CUR_X, CUR_Y)
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1
        DRAG_ACTIVE = 0
        started_wm: int32 = 0
        if hit >= 0:
            hs: uint64 = cast[uint64](hit)
            if in_close_box(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 2                  # close: confirm on the up-edge
                CLOSE_SLOT = hit
                started_wm = 1
            elif in_minimize_box(hs, CUR_X, CUR_Y) != 0:
                # Minimize on press (immediate, no release confirm needed).
                DWIN_HIDDEN[hs] = 1
                GESTURE = 3                  # minimize: no further up-edge
                started_wm = 1
                mm: Ptr[uint8] = "WM minimize window\n"
                sys_write(1, mm, strlen_u8(mm))
            elif in_title_bar(hs, CUR_X, CUR_Y) != 0:
                GESTURE = 1                  # move
                # Raise the grabbed window to the top so it tracks above
                # the others, then capture the cursor->origin offset.
                hit = daemon_raise_slot(hit)
                hs = cast[uint64](hit)
                MOVE_SLOT = hit
                MOVE_OFF_X = CUR_X - DWIN_X[hs]
                MOVE_OFF_Y = CUR_Y - DWIN_Y[hs]
                started_wm = 1
                m1: Ptr[uint8] = "WM move start\n"
                sys_write(1, m1, strlen_u8(m1))
            else:
                # Press inside a window body (not title, not close-box):
                # raise the window to the top to give it keyboard focus.
                # We do NOT start a rubber-band drag — the user clicked
                # inside an existing window to interact with its shell.
                hit = daemon_raise_slot(hit)
                GESTURE = 3                  # body-focus: no up-edge action
                started_wm = 1
                m2: Ptr[uint8] = "WM focus window\n"
                sys_write(1, m2, strlen_u8(m2))
        if started_wm == 0:
            # No window-management gesture -> the empty-desktop
            # rubber-band create drag (unchanged behaviour).
            GESTURE = 0
            DRAG_ACTIVE = 1
            DRAG_X0 = CUR_X
            DRAG_Y0 = CUR_Y
    # --- button held: a move tracks the window under the grab ---
    if lbtn != 0 and GESTURE == 1 and MOVE_SLOT >= 0:
        ms: uint64 = cast[uint64](MOVE_SLOT)
        nx: int64 = CUR_X - MOVE_OFF_X
        ny: int64 = CUR_Y - MOVE_OFF_Y
        # Clamp so the window stays on-screen and never draws outside the
        # framebuffer. The top is clamped to PANEL_H so a window's title
        # bar can never slide under the panel and become un-grabbable.
        nx = iclamp(nx, 0, scr_w - DWIN_W[ms])
        ny = iclamp(ny, PANEL_H, scr_h - DWIN_H[ms])
        if nx < 0:
            nx = 0
        if ny < PANEL_H:
            ny = PANEL_H
        DWIN_X[ms] = nx
        DWIN_Y[ms] = ny
    # --- left-button UP edge: resolve the gesture ---
    if lbtn == 0 and PREV_BTN_L != 0:
        if GESTURE == 2:
            # Close only if the release lands in the SAME window's close
            # box (rio-style click cancellation on drag-off).
            if CLOSE_SLOT >= 0:
                cs: uint64 = cast[uint64](CLOSE_SLOT)
                if cs < DWIN_COUNT and in_close_box(cs, CUR_X, CUR_Y) != 0:
                    daemon_close_slot(CLOSE_SLOT)
                    m2: Ptr[uint8] = "WM close window\n"
                    sys_write(1, m2, strlen_u8(m2))
        elif GESTURE == 1 and MOVE_SLOT >= 0:
            # Move finished — log the window's final origin so a
            # non-pixel test can assert it relocated.
            mvs: uint64 = cast[uint64](MOVE_SLOT)
            mline: Array[64, uint8]
            mp: uint64 = 0
            mpfx: Ptr[uint8] = "WM move done x="
            mk: uint64 = 0
            while mpfx[mk] != 0:
                mline[mp] = mpfx[mk]
                mp = mp + 1
                mk = mk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_X[mvs]), &mline[mp])
            # drop u64_to_dec's trailing newline, append " y="
            mp = mp - 1
            ysfx: Ptr[uint8] = " y="
            yk: uint64 = 0
            while ysfx[yk] != 0:
                mline[mp] = ysfx[yk]
                mp = mp + 1
                yk = yk + 1
            mp = mp + u64_to_dec(cast[uint64](DWIN_Y[mvs]), &mline[mp])
            sys_write(1, &mline[0], mp)
        elif GESTURE == 0 and DRAG_ACTIVE != 0:
            # Empty-desktop drag -> maybe spawn a window.
            rx0: int64 = imin(DRAG_X0, CUR_X)
            ry0: int64 = imin(DRAG_Y0, CUR_Y)
            rx1: int64 = imax(DRAG_X0, CUR_X)
            ry1: int64 = imax(DRAG_Y0, CUR_Y)
            rw: int64 = rx1 - rx0
            rh: int64 = ry1 - ry0
            if rw >= DRAG_MIN and rh >= DRAG_MIN:
                daemon_spawn_window(rx0, ry0, rw, rh)
        # Reset all gesture state.
        DRAG_ACTIVE = 0
        GESTURE = 0
        MOVE_SLOT = -1
        CLOSE_SLOT = -1


def next_signed(buf: Ptr[uint8], pos: Ptr[uint64], total: uint64) -> int64:
    # Skip up to a sign or digit, parse a (possibly signed) decimal.
    i: uint64 = pos[0]
    while i < total and buf[i] != 45 and (buf[i] < 48 or buf[i] > 57):
        i = i + 1
    neg: int32 = 0
    if i < total and buf[i] == 45:
        neg = 1
        i = i + 1
    v: int64 = 0
    while i < total and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[int64](cast[int32](buf[i]) - 48)
        i = i + 1
    pos[0] = i
    if neg != 0:
        return 0 - v
    return v


# Mouse-free WM self-test: drive a title-bar drag-move then a close-box
# click on the just-created autowin by calling the real gesture machine
# (wm_button) directly with ABSOLUTE cursor coordinates. This exercises
# the identical move/close/raise code paths a /dev/mouse packet would,
# but skips the packet string encode/decode round-trip entirely so the
# coordinates are exact and the result is deterministic.
def daemon_wm_selftest(scr_w: int64, scr_h: int64):
    if DWIN_COUNT == 0:
        return
    s: uint64 = DWIN_COUNT - 1
    PREV_BTN_L = 0
    # --- title-bar press: position the cursor inside the title bar (not
    # on the close box) and assert the left button down-edge. ---
    CUR_X = iclamp(DWIN_X[s] + 30, 0, scr_w - 1)
    CUR_Y = iclamp(DWIN_Y[s] + TITLE_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- drag: relocate the cursor LEFT 200 / UP 30 with the button held;
    # wm_button tracks the grabbed window to follow. ---
    CUR_X = iclamp(CUR_X - 200, 0, scr_w - 1)
    CUR_Y = iclamp(CUR_Y - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    # --- release: finalise the move (emits "WM move done x= y="). ---
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # The move raised the grabbed window to the top, so re-resolve its
    # slot (raise_slot bubbles it to DWIN_COUNT-1).
    cs: uint64 = DWIN_COUNT - 1
    # --- close: move the cursor onto the (relocated) window's close box,
    # then press+release inside it to destroy the window. ---
    CUR_X = iclamp(close_box_x(cs) + CLOSE_BOX / 2, 0, scr_w - 1)
    CUR_Y = iclamp(close_box_y(cs) + CLOSE_BOX / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)       # press in close box -> arm close
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)       # release in close box -> destroy
    PREV_BTN_L = 0
    write_str(1, "DAEMON wm selftest done\n")


# Mouse-free PANEL/MENU self-test: drives the launcher through the SAME
# gesture machine (wm_button) real /dev/mouse packets reach, with
# absolute cursor coordinates. Sequence:
#   1. click the Applications button  -> "PANEL open menu"
#   2. click the first menu item      -> launches Terminal, closes menu
#                                        ("PANEL launch Terminal", a window)
#   3. click the button + an off-menu spot to prove open/dismiss is stable.
# Emits "DAEMON panel selftest done" at the end. No QEMU mouse injection.
def daemon_panel_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    MENU_OPEN = 0
    # --- click the Applications button: open the menu ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- click the FIRST menu item: launch it + auto-close the menu ---
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H + MENU_ITEM_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # --- re-open, then dismiss by clicking an off-menu desktop spot ---
    CUR_X = iclamp(APPS_BTN_X + APPS_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # Click far down on the empty desktop -> menu dismisses (no launch).
    CUR_X = iclamp(MENU_X + MENU_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(scr_h - 30, 0, scr_h - 1)
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    write_str(1, "DAEMON panel selftest done\n")


# Terminal I/O self-test.
#
# Verifies the per-window stdin→shell→stdout→grid pipeline without a
# physical display or mouse, using the SAME pipe fds daemon_spawn_window
# created. Sequence:
#   1. Create one autowin (hamsh with real pipes).
#   2. Write "echo HAMUI_TERM_TEST\n" immediately to its stdin pipe.
#      The command sits in the pipe buffer until hamsh reads it.
#      (hamsh skips the getty-flush loop when stdin is DEVFD_PIPE_R,
#      so the bytes are NOT discarded — they arrive on the first
#      sys_read_nb(0,...) poll inside ed_readline.)
#   3. Non-blocking poll (sys_read_nb + sys_yield) the stdout pipe
#      until "HAMUI_TERM_TEST" appears in the terminal grid or the
#      idle counter (200000 empty reads) is exhausted.
#   4. Check the grid. PASS if the sentinel is present.
#
# Also verifies the focus-switch routing: create a SECOND window, click
# its body (synthetic wm_button on its body area) and confirm the focus
# slot switches, then route a second sentinel to that window.
#
# Emits "TERM IO PASS" / "TERM IO FAIL <reason>" on stdout.
# autoflag=5 in cmd_daemon_auto activates this test.
#
# ---- Taskbar / minimize / clock self-test (autoflag == 6) ----------
# Exercises the three new panel features deterministically without
# QEMU mouse injection:
#
#   1. TASKBAR: create two windows, assert DWIN_COUNT == 2, assert each
#      taskbar_btn_x() is within the panel, emit "TASKBAR 2 windows".
#   2. FOCUS via taskbar: simulate a taskbar click on slot 0 (lower window)
#      and assert it becomes the topmost slot (daemon_focus_slot()==1 after
#      raise), emit "TASKBAR focus OK".
#   3. MINIMIZE: simulate a minimize-box click on the topmost window, assert
#      DWIN_HIDDEN becomes 1, emit "TASKBAR minimize OK".
#   4. RESTORE: simulate a taskbar click on the minimized window, assert
#      DWIN_HIDDEN becomes 0, emit "TASKBAR restore OK".
#   5. CLOCK: call clock_refresh(0), assert clock_str is non-empty (not all
#      '?'), emit "TASKBAR clock OK" or "TASKBAR clock UNAVAILABLE".
#
# Emits "TASKBAR PASS" at the end.  autoflag==6 activates this test.
def daemon_taskbar_selftest(scr_w: int64, scr_h: int64):
    PREV_BTN_L = 0
    # --- Step 1: create two windows ---
    daemon_spawn_window(200, 80, 300, 200)
    daemon_spawn_window(300, 120, 300, 200)
    if DWIN_COUNT < 2:
        write_str(1, "TASKBAR FAIL: fewer than 2 windows spawned\n")
        return
    write_str(1, "TASKBAR 2 windows\n")
    # Assert taskbar buttons are within the screen (not off-screen).
    tb0x: int64 = taskbar_btn_x(0)
    tb1x: int64 = taskbar_btn_x(1)
    if tb0x < TASKBAR_START_X or tb1x <= tb0x:
        write_str(1, "TASKBAR FAIL: bad button geometry\n")
        return
    write_str(1, "TASKBAR geometry OK\n")
    # --- Step 2: taskbar click on slot 0 to raise it ---
    # After two spawns, slot 0 = first window, slot 1 = topmost.
    # Click the taskbar button for slot 0.
    CUR_X = iclamp(tb0x + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise slot 0 should now be at DWIN_COUNT-1 (topmost / focused).
    new_top: int64 = daemon_focus_slot()
    if new_top < 0:
        write_str(1, "TASKBAR FAIL: no focused window after taskbar raise\n")
        return
    write_str(1, "TASKBAR focus OK\n")
    # --- Step 3: minimize the topmost window via its minimize box ---
    top_s: uint64 = cast[uint64](new_top)
    mx: int64 = iclamp(minimize_box_x(top_s) + MINIMIZE_BOX / 2, 0, scr_w - 1)
    my: int64 = iclamp(minimize_box_y(top_s) + MINIMIZE_BOX / 2, 0, scr_h - 1)
    CUR_X = mx
    CUR_Y = my
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    if DWIN_HIDDEN[top_s] == 0:
        write_str(1, "TASKBAR FAIL: minimize did not set DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR minimize OK\n")
    # --- Step 4: restore via taskbar click ---
    # The minimized window is still at slot top_s in the table.
    rst_tbx: int64 = taskbar_btn_x(top_s)
    CUR_X = iclamp(rst_tbx + TASKBAR_BTN_W / 2, 0, scr_w - 1)
    CUR_Y = iclamp(PANEL_H / 2, 0, scr_h - 1)
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After restore DWIN_HIDDEN should be 0 (the window is visible again).
    # The slot may have been raised, so scan all slots for HIDDEN==0.
    all_visible: int32 = 1
    ci: uint64 = 0
    while ci < DWIN_COUNT:
        if DWIN_HIDDEN[ci] != 0:
            all_visible = 0
        ci = ci + 1
    if all_visible == 0:
        write_str(1, "TASKBAR FAIL: restore did not clear DWIN_HIDDEN\n")
        return
    write_str(1, "TASKBAR restore OK\n")
    # --- Step 5: clock refresh ---
    clock_refresh(0)
    # The clock string should be non-empty (first char is a digit or '?').
    clk_ok: int32 = 0
    if clock_str[0] != 0:
        clk_ok = 1
    if clk_ok != 0:
        if clock_str[0] == 63:
            write_str(1, "TASKBAR clock UNAVAILABLE\n")
        else:
            write_str(1, "TASKBAR clock OK\n")
    else:
        write_str(1, "TASKBAR FAIL: clock_str empty after refresh\n")
        return
    write_str(1, "TASKBAR PASS\n")


# Scratch buffer for the stdin command we inject.
term_test_cmd: Array[32, uint8]

def daemon_terminal_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: first autowin (hamsh + pipes) ---
    daemon_spawn_window(120, 80, 400, 240)
    if DWIN_COUNT == 0:
        write_str(1, "TERM IO FAIL no window spawned\n")
        return
    sl0: uint64 = DWIN_COUNT - 1
    infd: int32 = DWIN_IN_FD[sl0]
    outfd: int32 = DWIN_OUT_FD[sl0]
    if infd < 0:
        write_str(1, "TERM IO FAIL no stdin pipe for window 0\n")
        return
    if outfd < 0:
        write_str(1, "TERM IO FAIL no stdout pipe for window 0\n")
        return
    # --- Step 2: write the sentinel command to hamsh stdin ---
    # The command bytes sit in the pipe buffer until hamsh starts and
    # calls sys_read_nb(0,...). Since we patched hamsh to skip the
    # getty-style flush loop for pipe-backed stdin (DEVFD_PIPE_R), the
    # bytes are NOT discarded by the flush window — hamsh picks them up
    # on the very first readline poll pass.
    cmd_s: Ptr[uint8] = "echo HAMUI_TERM_TEST\n"
    sys_write(infd, cmd_s, strlen_u8(cmd_s))
    # --- Step 3: Non-blocking poll loop until the sentinel appears ---
    # We use sys_read_nb + sys_yield so the hamsh process gets CPU time
    # to start up and process the command. We stop as soon as the
    # sentinel appears in the grid. Idle = consecutive empty reads; we
    # cap at IDLE_MAX to bound run time (each yield is very fast on TCG).
    # On TCG hamsh may take thousands of scheduler rounds to start — a
    # large IDLE_MAX (200000) is safe and still completes well within
    # the 120s QEMU timeout.
    found0: int32 = 0
    idle0: int32 = 0
    while idle0 < 200000 and found0 == 0:
        n: int64 = sys_read_nb(outfd, &term_rx[0], 1024)
        if n > 0:
            idle0 = 0
            term_feed(sl0, &term_rx[0], n)
            if term_grid_contains(sl0, "HAMUI_TERM_TEST") != 0:
                found0 = 1
        else:
            idle0 = idle0 + 1
            sys_yield()
    if found0 == 0:
        write_str(1, "TERM IO FAIL sentinel not in window 0 grid\n")
        return
    write_str(1, "TERM IO window0 OK\n")
    # --- Step 4: focus-switch test ---
    # Create a second window so we can verify focus routing changes.
    daemon_spawn_window(200, 160, 400, 240)
    if DWIN_COUNT < 2:
        # Only one window was created (table full or spawn failed); skip
        # the two-window focus routing test.
        write_str(1, "TERM IO PASS (single-window)\n")
        return
    # Simulate a body-click on the FIRST window (slot 0) to raise it.
    # The first window is now slot 0 (two windows: 0 and 1, where 1 is
    # topmost after creation). Compute a point inside its body area.
    bclick_x: int64 = DWIN_X[0] + DWIN_W[0] / 2
    bclick_y: int64 = DWIN_Y[0] + TITLE_H + DWIN_H[0] / 2
    bclick_x = iclamp(bclick_x, 0, scr_w - 1)
    bclick_y = iclamp(bclick_y, 0, scr_h - 1)
    # Synthetic mouse click on the first window's body: press + release.
    CUR_X = bclick_x
    CUR_Y = bclick_y
    PREV_BTN_L = 0
    wm_button(1, scr_w, scr_h)
    PREV_BTN_L = 1
    wm_button(0, scr_w, scr_h)
    PREV_BTN_L = 0
    # After raise the first window becomes the topmost slot; confirm focus.
    new_focus: int64 = daemon_focus_slot()
    focus_x: int64 = DWIN_X[cast[uint64](new_focus)]
    focus_y: int64 = DWIN_Y[cast[uint64](new_focus)]
    # The raised window's origin should match what we clicked into.
    in_raised: int32 = 0
    if bclick_x >= focus_x and bclick_x < focus_x + DWIN_W[cast[uint64](new_focus)]:
        if bclick_y >= focus_y and bclick_y < focus_y + DWIN_H[cast[uint64](new_focus)]:
            in_raised = 1
    if in_raised == 0:
        write_str(1, "TERM IO FAIL focus did not switch to clicked window\n")
        return
    write_str(1, "TERM IO focus-switch OK\n")
    # Route a second sentinel to the newly-focused window and confirm it
    # arrives in that window's grid.
    new_infd: int32 = DWIN_IN_FD[cast[uint64](new_focus)]
    if new_infd >= 0:
        new_outfd: int32 = DWIN_OUT_FD[cast[uint64](new_focus)]
        cmd2: Ptr[uint8] = "echo HAMUI_TERM_TEST2\n"
        sys_write(new_infd, cmd2, strlen_u8(cmd2))
        found2: int32 = 0
        idle2: int32 = 0
        while idle2 < 200000 and found2 == 0:
            n2: int64 = sys_read_nb(new_outfd, &term_rx[0], 1024)
            if n2 > 0:
                idle2 = 0
                term_feed(cast[uint64](new_focus), &term_rx[0], n2)
                if term_grid_contains(cast[uint64](new_focus), "HAMUI_TERM_TEST2") != 0:
                    found2 = 1
            else:
                idle2 = idle2 + 1
                sys_yield()
        if found2 == 0:
            write_str(1, "TERM IO FAIL sentinel2 not in focused window grid\n")
            return
    write_str(1, "TERM IO window1 OK\n")
    write_str(1, "TERM IO PASS\n")


# ====================================================================
# GPU track #183 — native Vulkan output INTO a real desktop window
# ====================================================================
#
# daemon_vk_window_selftest creates a NORMAL composited window at a known
# on-screen position whose BODY is filled by the native kernel-side
# lib/vk software rasterizer (a rotating triangle). Each frame the daemon
# asks the kernel to render the next frame into the window's draw-surface
# "vk" fb layer (sys_vk_window_frame), reads that layer back into
# vk_body_buf, marks the window as vk-bodied, composites the WHOLE screen
# through the SAME daemon_present path every other window uses, and
# samples the composited result to prove:
#   * inside the window's body rect the screen shows the Vulkan colours,
#   * OUTSIDE the window the screen shows the desktop backdrop (proving
#     it is WINDOWED, not a full-screen takeover),
#   * frame N and frame N+1 differ at a pixel the rotation moves (live
#     animation, not a static blit).
# All assertions read the composited frame through daemon_pixel — the
# exact value written to /dev/fb at that screen pixel — so they are
# unforgeable. Markers print as "[vk-window] ..." lines.

# Read window `wid`'s "vk" draw-surface fb layer into vk_body_buf. The
# layer is RGBA8888, up to VK_BODY_W x VK_BODY_H. Returns the bytes read.
def daemon_vk_read_body(wid: int32) -> int64:
    vp: Ptr[uint8] = "/dev/wsys/"
    i: uint64 = 0
    j: uint64 = 0
    while vp[j] != 0:
        path_buf[i] = vp[j]
        i = i + 1
        j = j + 1
    nb: uint64 = u64_to_dec(cast[uint64](wid), &path_buf[i])
    i = i + nb
    sfx: Ptr[uint8] = "/draw/vk/fb"
    j = 0
    while sfx[j] != 0:
        path_buf[i] = sfx[j]
        i = i + 1
        j = j + 1
    path_buf[i] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]))
    if fd < 0:
        return -1
    n: int64 = read_whole(fd, &vk_body_buf[0],
                          cast[uint64](VK_BODY_W * VK_BODY_H * 4))
    sys_close(fd)
    return n


# Sample the composited screen colour at (sx,sy) into r/g/b via the SAME
# daemon_pixel path that fills /dev/fb. Returns packed 0xRRGGBB.
def daemon_screen_sample(sx: int64, sy: int64) -> uint64:
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    daemon_pixel(sx, sy, &rr[0], &gg[0], &bb[0])
    return (cast[uint64](rr[0]) << 16) | (cast[uint64](gg[0]) << 8) \
        | cast[uint64](bb[0])


def daemon_vk_window_selftest(scr_w: int64, scr_h: int64):
    # --- Step 1: create a normal window at a fixed on-screen position.
    # 320x260 box on the RIGHT half (clear of the kernel fb text console
    # which paints the top-left). Body is 192x192-friendly.
    win_x: int64 = 700
    win_y: int64 = 120
    win_w: int64 = 320
    win_h: int64 = 260
    if win_x + win_w > scr_w:
        win_x = scr_w - win_w - 8
    if win_x < 0:
        win_x = 8
    # A chrome-only window (no child shell): the body is the Vulkan image.
    daemon_spawn_window_prog(cast[Ptr[char]]("/bin/true"),
                             win_x, win_y, win_w, win_h)
    if DWIN_COUNT == 0:
        write_str(1, "[vk-window] FAIL no window spawned\n")
        return
    sl: uint64 = DWIN_COUNT - 1
    wid: int32 = DWIN_WID[sl]
    if wid < 2:
        write_str(1, "[vk-window] FAIL no wid for window\n")
        return
    DWIN_VK[sl] = 1
    # Body origin in screen space (where the Vulkan image lands).
    body_x: int64 = DWIN_X[sl] + 2
    body_y: int64 = DWIN_Y[sl] + TITLE_H
    # A pixel near the body centre (inside the 192x192 vk image) and a
    # pixel clearly OUTSIDE the window (the desktop backdrop).
    in_x: int64 = body_x + VK_BODY_W / 2
    in_y: int64 = body_y + VK_BODY_H / 2
    out_x: int64 = DWIN_X[sl] - 40
    out_y: int64 = DWIN_Y[sl] + 30
    if out_x < 0:
        out_x = 4
        out_y = 4
    # Animation-probe pixel: just left of body centre, on the orbit the
    # rotating triangle sweeps through, so a frame change toggles it.
    an_x: int64 = body_x + VK_BODY_W / 2 - 20
    an_y: int64 = body_y + VK_BODY_H / 2

    # --- Step 2: render frame 0, read it back, composite, sample. ---
    if sys_vk_window_frame(wid, 0, 0) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(0)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer\n")
        return
    vk_body_ready = 1
    daemon_present()
    in0: uint64 = daemon_screen_sample(in_x, in_y)
    out0: uint64 = daemon_screen_sample(out_x, out_y)
    an0: uint64 = daemon_screen_sample(an_x, an_y)
    # The backdrop colour packed for comparison.
    bg: uint64 = (cast[uint64](ROOT_R) << 16) \
        | (cast[uint64](ROOT_G) << 8) | cast[uint64](ROOT_B)
    # (a) Outside the window must be the desktop backdrop -> WINDOWED.
    if out0 == bg:
        write_str(1, "[vk-window] OK windowed (backdrop outside window)\n")
    else:
        write_str(1, "[vk-window] FAIL area outside window is not backdrop\n")
        return
    # (b) Inside the body must NOT be the backdrop and NOT the plain body
    #     fill — it must be Vulkan-rendered content.
    bodyfill: uint64 = (cast[uint64](WIN_BODY_R) << 16) \
        | (cast[uint64](WIN_BODY_G) << 8) | cast[uint64](WIN_BODY_B)
    if in0 != bg and in0 != bodyfill:
        write_str(1, "[vk-window] OK vulkan pixels inside window body\n")
    else:
        write_str(1, "[vk-window] FAIL body pixel is not vulkan content\n")
        return

    # --- Step 3: render a LATER frame, re-composite, prove animation. ---
    # Step several frames so the rotation visibly moves the probe pixel.
    if sys_vk_window_frame(wid, 0, 6) != 0:
        write_str(1, "[vk-window] FAIL sys_vk_window_frame(6)\n")
        return
    if daemon_vk_read_body(wid) <= 0:
        write_str(1, "[vk-window] FAIL cannot read vk draw layer (frame 6)\n")
        return
    daemon_present()
    an6: uint64 = daemon_screen_sample(an_x, an_y)
    in6: uint64 = daemon_screen_sample(in_x, in_y)
    if an6 != an0 or in6 != in0:
        write_str(1, "[vk-window] OK animation (frame differs)\n")
    else:
        write_str(1, "[vk-window] FAIL frames identical (no animation)\n")
        return
    # Final present so a screendump catches the windowed Vulkan frame.
    daemon_present()
    write_str(1, "[vk-window] PASS\n")


# Scan window `slot`'s terminal grid for the NUL-terminated ASCII string
# `needle`. Returns 1 if found at any position (across row boundaries via
# grid linearisation), else 0.
def term_grid_contains(slot: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(needle)
    if nlen == 0:
        return 1
    base: uint64 = slot * GRID_CELLS
    cells: uint64 = cast[uint64](DWIN_ROWS[slot] * GRID_COLS_MAX)
    if cells > GRID_CELLS:
        cells = GRID_CELLS
    i: uint64 = 0
    while i + nlen <= cells:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            gc: uint8 = term_grid[base + i + k]
            nc: uint8 = needle[k]
            if gc != nc:
                ok = 0
                k = nlen
            else:
                k = k + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


# Focused window = the most-recently-created one (topmost). Returns its
# slot index, or -1 if there are no windows.
def daemon_focus_slot() -> int64:
    if DWIN_COUNT == 0:
        return -1
    return cast[int64](DWIN_COUNT) - 1


# Drain /dev/cons (non-blocking) and route each keystroke byte to the
# focused window's child-stdin pipe. Bytes are dropped when there is no
# window (no background REPL competes for them — the daemon owns the
# physical keyboard while it runs). Returns 1 if bytes were routed.
def daemon_pump_keys() -> int32:
    if cons_fd < 0:
        return 0
    fslot: int64 = daemon_focus_slot()
    routed: int32 = 0
    iters: int32 = 0
    while iters < 16:
        n: int64 = sys_read_nb(cons_fd, &cons_rx[0], 256)
        iters = iters + 1
        if n <= 0:
            break
        if fslot >= 0:
            wfd: int32 = DWIN_IN_FD[cast[uint64](fslot)]
            if wfd >= 0:
                sys_write(wfd, &cons_rx[0], cast[uint64](n))
                routed = 1
        # else: no window — drop the bytes.
    return routed


# Drain every window's stdout pipe into its grid. Returns 1 if any
# window produced output (the screen needs a re-present).
def daemon_pump_terms() -> int32:
    changed: int32 = 0
    wi: uint64 = 0
    while wi < DWIN_COUNT:
        if term_pump(wi) != 0:
            changed = 1
        wi = wi + 1
    return changed


def cmd_daemon_auto(autoflag: int32) -> int32:
    if read_fb_geometry() == 0:
        write_str(2, "hamUId: daemon: cannot read /dev/fb geometry\n")
        return 1
    mp: Ptr[uint8] = "/dev/mouse"
    mfd: int32 = sys_open(cast[Ptr[char]](mp))
    if mfd < 0:
        write_str(2, "hamUId: daemon: cannot open /dev/mouse\n")
        return 1
    mouse_fd = mfd
    # Open /dev/cons for keystroke polling (best-effort: if it fails the
    # daemon still composites + spawns shells, just without key routing).
    font_init()
    cp: Ptr[uint8] = "/dev/cons"
    cons_fd = sys_open(cast[Ptr[char]](cp))
    scr_w: int64 = cast[int64](FBG_W)
    scr_h: int64 = cast[int64](FBG_H)
    # Cursor starts at screen centre.
    CUR_X = scr_w / 2
    CUR_Y = scr_h / 2
    # Announce so a test can detect the daemon came up and parse geometry.
    line: Array[96, uint8]
    p: uint64 = 0
    pfx: Ptr[uint8] = "DAEMON up screen="
    k: uint64 = 0
    while pfx[k] != 0:
        line[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = p + u64_to_dec(FBG_W, &line[p])
    line[p] = 120                                    # 'x'
    p = p + 1
    p = p + u64_to_dec(FBG_H, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(1, &line[0], p)
    # First frame (backdrop + cursor at centre).
    daemon_present()
    # Optional auto-window: create one terminal window programmatically
    # (mouse-free) so a test can exercise the in-window shell. The rect
    # is a fixed 480x320 box on the RIGHT half of the screen — clear of
    # the kernel framebuffer text console, which renders an 80-column
    # (~640px-wide) region anchored at the top-left and would otherwise
    # repaint over a left-side window between the daemon's frames.
    if autoflag == 1 or autoflag == 2:
        daemon_spawn_window(720, 80, 480, 320)
        write_str(1, "DAEMON autowin created\n")
        daemon_present()
    # WM self-test (autoflag == 2): drive a title-drag move + close-box
    # click through synthetic packets so the gestures are exercised
    # deterministically without QEMU mouse injection.
    if autoflag == 2:
        daemon_wm_selftest(scr_w, scr_h)
        daemon_present()
    # PANEL self-test (autoflag == 3): drive the Applications menu open +
    # a menu-item launch through the SAME gesture machine, emitting the
    # PANEL serial markers, so a non-interactive test can assert the
    # launcher without QEMU mouse injection.
    if autoflag == 3:
        daemon_panel_selftest(scr_w, scr_h)
        daemon_present()
    # TERMINAL I/O self-test (autoflag == 5): create two windows, write a
    # sentinel command to each child's stdin pipe, pump stdout into the
    # terminal grid, and verify the sentinel string appears in the grid.
    # Also exercises the body-click focus-switch: clicking window 0's body
    # raises it to the top (emitting "WM focus window") and routes input
    # to its pipe. Does NOT enter the main loop — exits after the test.
    if autoflag == 5:
        daemon_terminal_selftest(scr_w, scr_h)
        return 0
    # TASKBAR / MINIMIZE / CLOCK self-test (autoflag == 6): exercises the
    # three new panel features: window-list taskbar, minimize/restore, and
    # live clock. Does NOT enter the main loop — exits after the test.
    if autoflag == 6:
        daemon_taskbar_selftest(scr_w, scr_h)
        return 0
    # VULKAN WINDOW self-test (autoflag == 8): create a normal composited
    # window, drive the kernel software rasterizer (SYS_VK_WINDOW_FRAME) to
    # render an animated triangle into that window's draw surface, composite
    # it, and assert the Vulkan pixels land inside the window body, the
    # backdrop shows outside it (proving windowed, not full-screen), and the
    # frame changes when the animation advances. Exits after the test.
    if autoflag == 8:
        daemon_vk_window_selftest(scr_w, scr_h)
        return 0
    # Initial clock seed (before the first frame so the panel shows a time).
    clock_refresh(0)
    # Main loop. Cooperative: yield every idle iteration so we never
    # monopolise the CPU and the spawned hamsh tasks still run.
    prev_wins: uint64 = DWIN_COUNT
    idle_ctr: uint64 = 0
    # Uptime centisecond counter, approximated from idle iterations.
    # Each sys_yield() is ~1-2ms on TCG; we add 2 each iteration.
    # clock_refresh only fires once per 100 cs anyway (1 second).
    loop_cs: uint64 = 0
    while True:
        ch: int32 = daemon_pump_mouse(scr_w, scr_h)
        # Route keystrokes to the focused window's shell, then drain
        # every shell's stdout into its terminal grid.
        daemon_pump_keys()
        tch: int32 = daemon_pump_terms()
        # Re-present when the mouse moved/clicked, a drag is in progress
        # (rubber band must track), a window was created, or any shell
        # emitted output (prompt / command echo).
        need: int32 = ch
        if tch != 0:
            need = 1
        if DRAG_ACTIVE != 0:
            need = 1
        if DWIN_COUNT != prev_wins:
            need = 1
            prev_wins = DWIN_COUNT
        # The kernel framebuffer console (the foreground hamsh's
        # heartbeat / log chatter) shares /dev/fb and repaints over the
        # desktop. As the screen owner, the daemon periodically forces a
        # full re-present so its desktop reasserts ownership even when
        # nothing in the model changed — keeping windows continuously
        # visible. (~once every 64 idle iterations.)
        idle_ctr = idle_ctr + 1
        loop_cs = loop_cs + 2
        if idle_ctr >= 64:
            need = 1
            idle_ctr = 0
            # Refresh the clock once per idle cycle (~every second).
            clock_refresh(loop_cs)
        if need != 0:
            daemon_present()
        sys_yield()
    return 0


def usage(fd: int32):
    write_str(fd, "Usage: hamUId render <wid> | hamUId present <wid> | hamUId daemon [autowin|wmselftest|panelselftest|terminalselftest|taskbarselftest|vkwindowselftest]\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        usage(2)
        return 1
    verb: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if cstr_eq(verb, "render") != 0:
        if argc < 3:
            write_str(2, "hamUId: render: missing wid\n")
            return 1
        wid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if wid < 1:
            write_str(2, "hamUId: render: bad wid\n")
            return 1
        return cmd_render(wid)
    if cstr_eq(verb, "present") != 0:
        if argc < 3:
            write_str(2, "hamUId: present: missing wid\n")
            return 1
        pwid: int32 = parse_uint(cast[Ptr[uint8]](argv[2]))
        if pwid < 1:
            write_str(2, "hamUId: present: bad wid\n")
            return 1
        return cmd_present(pwid)
    if cstr_eq(verb, "daemon") != 0:
        # Optional `autowin` arg: immediately drag-create one terminal
        # window (mouse-free) so a non-interactive test can exercise the
        # in-window shell without driving QEMU mouse events.
        autoflag: int32 = 0
        if argc >= 3:
            a2: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
            if cstr_eq(a2, "autowin") != 0:
                autoflag = 1
            # `wmselftest` => autowin + a mouse-free move+close self-test.
            if cstr_eq(a2, "wmselftest") != 0:
                autoflag = 2
            # `panelselftest` => a mouse-free panel/menu open+launch test.
            if cstr_eq(a2, "panelselftest") != 0:
                autoflag = 3
            # `terminalselftest` => per-window stdin→stdout→grid I/O test.
            if cstr_eq(a2, "terminalselftest") != 0:
                autoflag = 5
            # `taskbarselftest` => taskbar/minimize/clock feature test.
            if cstr_eq(a2, "taskbarselftest") != 0:
                autoflag = 6
            # `vkwindowselftest` => kernel Vulkan rasterizer into a window.
            if cstr_eq(a2, "vkwindowselftest") != 0:
                autoflag = 8
        return cmd_daemon_auto(autoflag)
    usage(2)
    return 1

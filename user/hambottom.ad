# user/hambottom.ad
#
# hambottom — DE bottom panel (MATE-style taskbar / window-list strip).
#
# WHAT IT IS
# ----------
# Hamnix's MATE-mirror DE has a top panel (Apps menu + system tray +
# clock) provided by /bin/hampanel. The classic MATE layout also runs a
# BOTTOM panel: a "Show Desktop" button on the far left, a horizontal
# window list across the middle, and a 1..4 workspace switcher on the
# right. This file is the bottom-panel client.
#
# DESIGN
# ------
#   * Like hampanel, hambottom is a hamui v2 client. We negotiate the
#     #442 (c) v2 blit protocol via hamui_set_protocol_v2() and ship
#     dirty rects through hamui_v2_commit_rect().
#   * The window list comes from /dev/wsys/session — the same read-only
#     snapshot hampanel parses (one line per active wid, leading int is
#     the wid). No new kernel IPC is needed: the bottom panel is a
#     read-only observer of the same model.
#   * Show Desktop and the workspace cells are click hot-zones, polled
#     via our /dev/wsys/<wid>/pointer like the Apps button on hampanel.
#     For now, the workspace switcher is a static 1..4 indicator with
#     workspace 1 highlighted — the kernel-side workspace model is not
#     in tree yet, and the brief allows static rendering.
#   * Pure backbuffer paint; no malloc; module-scope fixed arrays only,
#     matching the rest of the v2 client family.
#
# COMPOSITOR HAND-OFF
# -------------------
# hamUId spawns /bin/hambottom at startup (alongside /bin/hampanel) and
# marks the window chromeless. The window is positioned at the BOTTOM
# of the screen (y = FBG_H - PANEL_H) so it mirrors the top panel.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2,
    hamui_v2_is_active, hamui_v2_clear, hamui_v2_fill_rect,
    hamui_v2_set_pixel, hamui_v2_commit_rect
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()


# --- panel geometry (v2 backbuffer-local coords) --------------------
# Backbuffer cap is 1280x800 (HAMUI_V2_BB_W/H); we paint a 1280x24 strip.
PANEL_W: int32 = 1280
PANEL_H: int32 = 24

# Palette mirrors hampanel.
BG_R: uint8 = 46
BG_G: uint8 = 52
BG_B: uint8 = 64
EDGE_R: uint8 = 24
EDGE_G: uint8 = 28
EDGE_B: uint8 = 36
INK_R: uint8 = 235
INK_G: uint8 = 235
INK_B: uint8 = 240
HI_R: uint8 = 70
HI_G: uint8 = 90
HI_B: uint8 = 140
ACCENT_R: uint8 = 110
ACCENT_G: uint8 = 160
ACCENT_B: uint8 = 220

# Layout — Show Desktop on the left, workspace switcher on the right,
# window-list buttons in between.
SD_BTN_X: int32 = 0
SD_BTN_W: int32 = 56

WS_COUNT: int32 = 4
WS_CELL_W: int32 = 22
WS_CELL_GAP: int32 = 2
# Workspace switcher right-anchored; 4*22 + 3*2 = 94 px wide, plus 5 px margin.
WS_GROUP_W: int32 = 94
WS_GROUP_X: int32 = 1181            # 1280 - 94 - 5
WS_ACTIVE: int32 = 1                # static for now (workspace 1)

WINLIST_X: int32 = 60
WINLIST_W: int32 = 1116             # 60 .. WS_GROUP_X - 4

WIN_BTN_W:  int32 = 96
WIN_BTN_PAD: int32 = 3


# --- module-scope buffers (no malloc) -------------------------------
sess_buf: Array[2048, uint8]
win_wids: Array[16, int32]
win_count: int32 = 0
last_sess_hash: uint64 = 0

ptr_path: Array[64, uint8]
ptr_buf:  Array[256, uint8]
ptr_fd: int32 = -1
last_sd_press: int32 = 0
last_ws_press: int32 = 0


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# ---------------- tiny 5x7 font (digits + a few letters) -------------
GLYPH_W: int32 = 5
GLYPH_H: int32 = 7
GLYPH_COUNT: int32 = 16
glyph_rows: Array[112, uint8]
font_inited: int32 = 0


def font_init():
    if font_inited != 0:
        return
    # '0' (0)
    glyph_rows[0] = 0x0E
    glyph_rows[1] = 0x11
    glyph_rows[2] = 0x13
    glyph_rows[3] = 0x15
    glyph_rows[4] = 0x19
    glyph_rows[5] = 0x11
    glyph_rows[6] = 0x0E
    # '1' (1)
    glyph_rows[7] = 0x04
    glyph_rows[8] = 0x0C
    glyph_rows[9] = 0x04
    glyph_rows[10] = 0x04
    glyph_rows[11] = 0x04
    glyph_rows[12] = 0x04
    glyph_rows[13] = 0x0E
    # '2' (2)
    glyph_rows[14] = 0x0E
    glyph_rows[15] = 0x11
    glyph_rows[16] = 0x01
    glyph_rows[17] = 0x02
    glyph_rows[18] = 0x04
    glyph_rows[19] = 0x08
    glyph_rows[20] = 0x1F
    # '3' (3)
    glyph_rows[21] = 0x0E
    glyph_rows[22] = 0x11
    glyph_rows[23] = 0x01
    glyph_rows[24] = 0x06
    glyph_rows[25] = 0x01
    glyph_rows[26] = 0x11
    glyph_rows[27] = 0x0E
    # '4' (4)
    glyph_rows[28] = 0x02
    glyph_rows[29] = 0x06
    glyph_rows[30] = 0x0A
    glyph_rows[31] = 0x12
    glyph_rows[32] = 0x1F
    glyph_rows[33] = 0x02
    glyph_rows[34] = 0x02
    # '5' (5)
    glyph_rows[35] = 0x1F
    glyph_rows[36] = 0x10
    glyph_rows[37] = 0x1E
    glyph_rows[38] = 0x01
    glyph_rows[39] = 0x01
    glyph_rows[40] = 0x11
    glyph_rows[41] = 0x0E
    # '6' (6)
    glyph_rows[42] = 0x0E
    glyph_rows[43] = 0x10
    glyph_rows[44] = 0x10
    glyph_rows[45] = 0x1E
    glyph_rows[46] = 0x11
    glyph_rows[47] = 0x11
    glyph_rows[48] = 0x0E
    # '7' (7)
    glyph_rows[49] = 0x1F
    glyph_rows[50] = 0x01
    glyph_rows[51] = 0x02
    glyph_rows[52] = 0x04
    glyph_rows[53] = 0x04
    glyph_rows[54] = 0x04
    glyph_rows[55] = 0x04
    # '8' (8)
    glyph_rows[56] = 0x0E
    glyph_rows[57] = 0x11
    glyph_rows[58] = 0x11
    glyph_rows[59] = 0x0E
    glyph_rows[60] = 0x11
    glyph_rows[61] = 0x11
    glyph_rows[62] = 0x0E
    # '9' (9)
    glyph_rows[63] = 0x0E
    glyph_rows[64] = 0x11
    glyph_rows[65] = 0x11
    glyph_rows[66] = 0x0F
    glyph_rows[67] = 0x01
    glyph_rows[68] = 0x01
    glyph_rows[69] = 0x0E
    # 'D' (10)
    glyph_rows[70] = 0x1E
    glyph_rows[71] = 0x11
    glyph_rows[72] = 0x11
    glyph_rows[73] = 0x11
    glyph_rows[74] = 0x11
    glyph_rows[75] = 0x11
    glyph_rows[76] = 0x1E
    # 'W' (11)
    glyph_rows[77] = 0x11
    glyph_rows[78] = 0x11
    glyph_rows[79] = 0x11
    glyph_rows[80] = 0x15
    glyph_rows[81] = 0x15
    glyph_rows[82] = 0x1B
    glyph_rows[83] = 0x11
    # ' ' / fallback (12)
    glyph_rows[84] = 0x00
    glyph_rows[85] = 0x00
    glyph_rows[86] = 0x00
    glyph_rows[87] = 0x00
    glyph_rows[88] = 0x00
    glyph_rows[89] = 0x00
    glyph_rows[90] = 0x00
    # '#' (13)
    glyph_rows[91] = 0x0A
    glyph_rows[92] = 0x1F
    glyph_rows[93] = 0x0A
    glyph_rows[94] = 0x0A
    glyph_rows[95] = 0x1F
    glyph_rows[96] = 0x0A
    glyph_rows[97] = 0x00
    # '-' (14, unused but reserved)
    glyph_rows[98] = 0x00
    glyph_rows[99] = 0x00
    glyph_rows[100] = 0x00
    glyph_rows[101] = 0x1F
    glyph_rows[102] = 0x00
    glyph_rows[103] = 0x00
    glyph_rows[104] = 0x00
    # '.' (15, unused but reserved)
    glyph_rows[105] = 0x00
    glyph_rows[106] = 0x00
    glyph_rows[107] = 0x00
    glyph_rows[108] = 0x00
    glyph_rows[109] = 0x00
    glyph_rows[110] = 0x04
    glyph_rows[111] = 0x00
    font_inited = 1


def _glyph_for(c: uint8) -> Ptr[uint8]:
    idx: int32 = 12                  # default = space/fallback
    if c >= 48 and c <= 57:
        idx = cast[int32](c - 48)    # '0'..'9' → 0..9
    elif c == 68:
        idx = 10                     # 'D'
    elif c == 87:
        idx = 11                     # 'W'
    elif c == 35:
        idx = 13                     # '#'
    return &glyph_rows[idx * GLYPH_H]


def _draw_glyph(x: int32, y: int32, c: uint8,
                r: uint8, g: uint8, b: uint8):
    rows: Ptr[uint8] = _glyph_for(c)
    row: int32 = 0
    while row < GLYPH_H:
        bits: uint8 = rows[row]
        col: int32 = 0
        while col < GLYPH_W:
            mask: uint8 = cast[uint8](1 << cast[uint32](GLYPH_W - 1 - col))
            if (bits & mask) != 0:
                hamui_v2_set_pixel(x + col, y + row, r, g, b)
            col = col + 1
        row = row + 1


# ---------------- chrome paint --------------------------------------
def _paint_background():
    hamui_v2_clear(BG_R, BG_G, BG_B)
    # 1px top edge (this panel sits at the BOTTOM of the screen — the
    # desktop is above us, so the visible edge is the top one).
    hamui_v2_fill_rect(0, 0, PANEL_W, 1, EDGE_R, EDGE_G, EDGE_B)


def _paint_show_desktop():
    # Background bar.
    hamui_v2_fill_rect(SD_BTN_X, 1, SD_BTN_W, PANEL_H - 1,
                       HI_R, HI_G, HI_B)
    # Right separator.
    hamui_v2_fill_rect(SD_BTN_X + SD_BTN_W - 1, 1, 1, PANEL_H - 1,
                       EDGE_R, EDGE_G, EDGE_B)
    # Centre a 'D' glyph as the Show Desktop icon.
    tx: int32 = SD_BTN_X + (SD_BTN_W - GLYPH_W) / 2
    ty: int32 = (PANEL_H - GLYPH_H) / 2 + 1
    _draw_glyph(tx, ty, 68, INK_R, INK_G, INK_B)


def _paint_winlist():
    # Wash the winlist region in the panel bg.
    hamui_v2_fill_rect(WINLIST_X, 1, WINLIST_W, PANEL_H - 1,
                       BG_R, BG_G, BG_B)
    i: int32 = 0
    while i < win_count:
        bx: int32 = WINLIST_X + i * (WIN_BTN_W + WIN_BTN_PAD)
        if bx + WIN_BTN_W > WINLIST_X + WINLIST_W:
            return
        # Button body — slightly lighter than the panel bg.
        hamui_v2_fill_rect(bx, 3, WIN_BTN_W, PANEL_H - 6,
                           cast[uint8](cast[int32](BG_R) + 20),
                           cast[uint8](cast[int32](BG_G) + 20),
                           cast[uint8](cast[int32](BG_B) + 24))
        # Border (top, bottom).
        hamui_v2_fill_rect(bx, 3, WIN_BTN_W, 1, EDGE_R, EDGE_G, EDGE_B)
        hamui_v2_fill_rect(bx, PANEL_H - 4, WIN_BTN_W, 1,
                           EDGE_R, EDGE_G, EDGE_B)
        # Label: "# <wid>" rendered as '#' + wid digits.
        wid_v: int32 = win_wids[i]
        gx: int32 = bx + 6
        gy: int32 = (PANEL_H - GLYPH_H) / 2 + 1
        _draw_glyph(gx, gy, 35, INK_R, INK_G, INK_B)        # '#'
        # Up to two digits.
        if wid_v > 99:
            wid_v = 99
        if wid_v < 0:
            wid_v = 0
        dx: int32 = gx + (GLYPH_W + 2)
        if wid_v >= 10:
            d1: uint8 = cast[uint8](wid_v / 10) + 48
            d2: uint8 = cast[uint8](wid_v % 10) + 48
            _draw_glyph(dx, gy, d1, INK_R, INK_G, INK_B)
            _draw_glyph(dx + GLYPH_W + 1, gy, d2, INK_R, INK_G, INK_B)
        else:
            d1: uint8 = cast[uint8](wid_v) + 48
            _draw_glyph(dx, gy, d1, INK_R, INK_G, INK_B)
        i = i + 1


def _paint_workspaces():
    # Wash the workspace group region.
    hamui_v2_fill_rect(WS_GROUP_X, 1, WS_GROUP_W, PANEL_H - 1,
                       BG_R, BG_G, BG_B)
    i: int32 = 0
    while i < WS_COUNT:
        cx: int32 = WS_GROUP_X + i * (WS_CELL_W + WS_CELL_GAP)
        # Cell body.
        rr: uint8 = cast[uint8](cast[int32](BG_R) + 16)
        gg: uint8 = cast[uint8](cast[int32](BG_G) + 16)
        bb: uint8 = cast[uint8](cast[int32](BG_B) + 20)
        if (i + 1) == WS_ACTIVE:
            rr = ACCENT_R
            gg = ACCENT_G
            bb = ACCENT_B
        hamui_v2_fill_rect(cx, 3, WS_CELL_W, PANEL_H - 6, rr, gg, bb)
        # Border.
        hamui_v2_fill_rect(cx, 3, WS_CELL_W, 1, EDGE_R, EDGE_G, EDGE_B)
        hamui_v2_fill_rect(cx, PANEL_H - 4, WS_CELL_W, 1,
                           EDGE_R, EDGE_G, EDGE_B)
        hamui_v2_fill_rect(cx, 3, 1, PANEL_H - 6, EDGE_R, EDGE_G, EDGE_B)
        hamui_v2_fill_rect(cx + WS_CELL_W - 1, 3, 1, PANEL_H - 6,
                           EDGE_R, EDGE_G, EDGE_B)
        # Digit label '1'..'4'.
        c: uint8 = cast[uint8](i + 1) + 48
        gx: int32 = cx + (WS_CELL_W - GLYPH_W) / 2
        gy: int32 = (PANEL_H - GLYPH_H) / 2 + 1
        _draw_glyph(gx, gy, c, INK_R, INK_G, INK_B)
        i = i + 1


# ---------------- /dev/wsys/session poll ----------------------------
def update_winlist() -> int32:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/session"))
    if fd < 0:
        if win_count == 0:
            return 0
        win_count = 0
        last_sess_hash = 0
        return 1
    n: int64 = sys_read(fd, &sess_buf[0], 2048)
    sys_close(fd)
    if n <= 0:
        if win_count == 0:
            return 0
        win_count = 0
        last_sess_hash = 0
        return 1
    # Rolling hash; skip paint if unchanged.
    h: uint64 = 14695981039346656037
    i: int64 = 0
    while i < n:
        h = h ^ cast[uint64](sess_buf[i])
        h = h * 1099511628211
        i = i + 1
    if h == last_sess_hash:
        return 0
    last_sess_hash = h
    new_count: int32 = 0
    j: int64 = 0
    while j < n and new_count < 16:
        while j < n and (sess_buf[j] == 32 or sess_buf[j] == 9):
            j = j + 1
        if j >= n:
            break
        if sess_buf[j] >= 48 and sess_buf[j] <= 57:
            v: int32 = 0
            while j < n and sess_buf[j] >= 48 and sess_buf[j] <= 57:
                v = v * 10 + cast[int32](sess_buf[j] - 48)
                j = j + 1
            win_wids[new_count] = v
            new_count = new_count + 1
        while j < n and sess_buf[j] != 10:
            j = j + 1
        if j < n:
            j = j + 1
    win_count = new_count
    return 1


# ---------------- pointer poll --------------------------------------
def _open_pointer(wid: int32):
    pfx: Ptr[uint8] = "/dev/wsys/"
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        ptr_path[p] = pfx[k]
        p = p + 1
        k = k + 1
    v: uint32 = cast[uint32](wid)
    if v == 0:
        ptr_path[p] = 48
        p = p + 1
    else:
        tmp: Array[12, uint8]
        t: uint64 = 0
        while v != 0:
            tmp[t] = cast[uint8](v % 10) + 48
            v = v / 10
            t = t + 1
        while t > 0:
            t = t - 1
            ptr_path[p] = tmp[t]
            p = p + 1
    suf: Ptr[uint8] = "/pointer"
    k = 0
    while suf[k] != 0:
        ptr_path[p] = suf[k]
        p = p + 1
        k = k + 1
    ptr_path[p] = 0
    ptr_fd = sys_open(cast[Ptr[char]](&ptr_path[0]))


def poll_pointer():
    if ptr_fd < 0:
        return
    n: int64 = sys_read(ptr_fd, &ptr_buf[0], 256)
    if n <= 0:
        return
    pressed_sd: int32 = 0
    pressed_ws: int32 = 0
    new_ws_active: int32 = WS_ACTIVE
    i: int64 = 0
    while i < n:
        if ptr_buf[i] == 77 and i + 4 < n:
            j: int64 = i + 2
            btns: int32 = 0
            while j < n and ptr_buf[j] >= 48 and ptr_buf[j] <= 57:
                btns = btns * 10 + cast[int32](ptr_buf[j] - 48)
                j = j + 1
            while j < n and ptr_buf[j] == 32:
                j = j + 1
            xv: int32 = 0
            while j < n and ptr_buf[j] >= 48 and ptr_buf[j] <= 57:
                xv = xv * 10 + cast[int32](ptr_buf[j] - 48)
                j = j + 1
            while j < n and ptr_buf[j] == 32:
                j = j + 1
            yv: int32 = 0
            while j < n and ptr_buf[j] >= 48 and ptr_buf[j] <= 57:
                yv = yv * 10 + cast[int32](ptr_buf[j] - 48)
                j = j + 1
            if (btns & 1) != 0 and yv >= 0 and yv < PANEL_H:
                if xv >= SD_BTN_X and xv < SD_BTN_X + SD_BTN_W:
                    pressed_sd = 1
                elif xv >= WS_GROUP_X and xv < WS_GROUP_X + WS_GROUP_W:
                    pressed_ws = 1
                    # Which cell?
                    rel: int32 = xv - WS_GROUP_X
                    cell: int32 = rel / (WS_CELL_W + WS_CELL_GAP)
                    if cell >= 0 and cell < WS_COUNT:
                        new_ws_active = cell + 1
            i = j
        else:
            i = i + 1
    # Edge-detect Show Desktop: log only (real minimise-all is a future
    # /dev/wsys/ctl verb; the brief allows a static workspace switcher
    # and a button hot-zone for now).
    if pressed_sd != 0 and last_sd_press == 0:
        _puts(1, "HAMBOTTOM show-desktop\n")
    last_sd_press = pressed_sd
    # Workspace cell click: locally update the active highlight so the
    # user sees the switcher respond.
    if pressed_ws != 0 and last_ws_press == 0:
        if new_ws_active != WS_ACTIVE:
            WS_ACTIVE = new_ws_active
            _paint_workspaces()
            hamui_v2_commit_rect(WS_GROUP_X, 0, WS_GROUP_W, PANEL_H)
            _puts(1, "HAMBOTTOM workspace switch\n")
    last_ws_press = pressed_ws


# ---------------- main ----------------------------------------------
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    font_init()

    # Self-discover OUR wid via /dev/wsys/self.
    wid: int32 = 1
    self_path: Ptr[uint8] = "/dev/wsys/self"
    sfd: int32 = sys_open(cast[Ptr[char]](&self_path[0]))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            sv: int32 = 0
            sii: uint64 = 0
            while sii < cast[uint64](sn) and sbuf[sii] >= 48 and sbuf[sii] <= 57:
                sv = sv * 10 + cast[int32](sbuf[sii]) - 48
                sii = sii + 1
            if sv >= 1:
                wid = sv
    if wid <= 1 and argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v: int32 = 0
        i: uint64 = 0
        while ap[i] >= 48 and ap[i] <= 57:
            v = v * 10 + cast[int32](ap[i]) - 48
            i = i + 1
        if v >= 1:
            wid = v

    root_dummy: int32 = 0
    bound: int32 = hamui_window_on(root_dummy, wid)
    if bound < 0:
        _puts(2, "hambottom: could not bind window\n")
        return 1

    if hamui_set_protocol_v2() < 0:
        _puts(2, "hambottom: could not enable v2 protocol\n")
        return 1
    if hamui_v2_is_active() == 0:
        _puts(2, "hambottom: v2 negotiation reported inactive\n")
        return 1

    _open_pointer(wid)

    update_winlist()
    _paint_background()
    _paint_show_desktop()
    _paint_winlist()
    _paint_workspaces()
    hamui_v2_commit_rect(0, 0, PANEL_W, PANEL_H)
    _puts(1, "HAMBOTTOM ready\n")

    while True:
        if update_winlist() != 0:
            _paint_winlist()
            hamui_v2_commit_rect(WINLIST_X, 0, WINLIST_W, PANEL_H)
        poll_pointer()
        sys_yield()

    return 0

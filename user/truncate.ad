# user/truncate.ad
#
# Hamnix `truncate -s SIZE FILE...`: set each file's size to exactly
# SIZE bytes. Growing zero-fills the new tail; shrinking discards the
# bytes past SIZE. SIZE is a plain byte count or carries a K / M suffix
# (1K = 1024, 1M = 1048576).
#
# Usage:
#   truncate -s SIZE FILE...
#
# Implementation note: tmpfs has no userland ftruncate syscall, so we
# realise the new size through the open-write + seek-write path that
# every other tool uses:
#   * existing content is read first (the open-for-write truncates to
#     0, so we must capture it),
#   * the first min(old, SIZE) bytes are written back verbatim,
#   * to GROW, we seek to SIZE-1 and write a single zero byte — tmpfs
#     reads unallocated chunks as zeros, so the gap is a real
#     zero-filled hole and the file's logical size becomes SIZE.
# Files larger than CAP are handled up to CAP bytes of preserved
# content (the grow/shrink size itself is unbounded by CAP).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_lseek(fd: int32, offset: int64, whence: int32) -> int64
extern def sys_close(fd: int32) -> int32


SEEK_SET: int32 = 0
CAP: uint64 = 16384

content: Array[16384, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Parse "100", "4K", "2M" into a byte count. Returns -1 on parse error
# (so a legitimate size of 0 — truncate to empty — is allowed).
def parse_size(s: Ptr[uint8]) -> int64:
    v: uint64 = 0
    i: uint64 = 0
    saw: int32 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c >= 48 and c <= 57:
            v = v * 10 + cast[uint64](c - 48)
            saw = 1
            i = i + 1
        elif c == 107 or c == 75:               # 'k' / 'K'
            v = v * 1024
            i = i + 1
            break
        elif c == 109 or c == 77:               # 'm' / 'M'
            v = v * 1048576
            i = i + 1
            break
        else:
            return -1
    if s[i] != 0:
        return -1
    if saw == 0:
        return -1
    return cast[int64](v)


def write_all(fd: int32, p: Ptr[uint8], n: uint64) -> int32:
    wrote: uint64 = 0
    while wrote < n:
        wr: int64 = sys_write(fd, cast[Ptr[uint8]](
                                  cast[uint64](p) + wrote), n - wrote)
        if wr <= 0:
            return -1
        wrote = wrote + cast[uint64](wr)
    return 0


# Resize `path` to `size` bytes. Returns 0 on success, -1 on error.
def truncate_one(path: Ptr[char], size: uint64) -> int32:
    # Capture existing content (open-for-write would truncate it away).
    old_len: uint64 = 0
    in_fd: int32 = sys_open(path)
    if in_fd >= 0:
        while old_len < CAP:
            n: int64 = sys_read(in_fd, cast[Ptr[uint8]](
                                    cast[uint64](&content[0]) + old_len),
                                CAP - old_len)
            if n <= 0:
                break
            old_len = old_len + cast[uint64](n)
        sys_close(in_fd)
    # (A missing file is created at the requested size — GNU behaviour.)

    out_fd: int32 = sys_open_write(path)
    if out_fd < 0:
        write_str(2, "truncate: cannot open ")
        write_str(2, cast[Ptr[uint8]](path))
        write_str(2, "\n")
        return -1

    keep: uint64 = old_len
    if keep > size:
        keep = size
    if keep > 0:
        if write_all(out_fd, &content[0], keep) != 0:
            sys_close(out_fd)
            write_str(2, "truncate: write error\n")
            return -1

    if size > keep:
        # Grow: seek to SIZE-1 and write one zero byte so the file's
        # logical size becomes exactly SIZE (the gap reads as zeros).
        z: uint8 = 0
        sk: int64 = sys_lseek(out_fd, cast[int64](size - 1), SEEK_SET)
        if sk < 0:
            sys_close(out_fd)
            write_str(2, "truncate: cannot seek ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, "\n")
            return -1
        if write_all(out_fd, &z, 1) != 0:
            sys_close(out_fd)
            write_str(2, "truncate: write error\n")
            return -1
    sys_close(out_fd)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Require: -s SIZE then one or more files.
    if argc < 4:
        write_str(2, "truncate: usage: truncate -s SIZE FILE...\n")
        return 1
    flag: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    size_arg: Ptr[uint8] = cast[Ptr[uint8]](0)
    file_start: int32 = 0
    if flag[0] == 45 and flag[1] == 115 and flag[2] == 0:        # "-s"
        size_arg = cast[Ptr[uint8]](argv[2])
        file_start = 3
    elif flag[0] == 45 and flag[1] == 115:                       # "-sSIZE"
        size_arg = cast[Ptr[uint8]](cast[uint64](flag) + 2)
        file_start = 2
    else:
        write_str(2, "truncate: -s SIZE is required\n")
        return 1

    sz: int64 = parse_size(size_arg)
    if sz < 0:
        write_str(2, "truncate: invalid size\n")
        return 1
    size: uint64 = cast[uint64](sz)

    rc: int32 = 0
    i: int32 = file_start
    while i < argc:
        if truncate_one(cast[Ptr[char]](argv[cast[uint64](i)]), size) != 0:
            rc = 1
        i = i + 1
    return rc

# user/hamconvert_host.ad — HOST driver + render harness for HamConvert, the
# unit-converter utility (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamconvertcore.ad) with KNOWN
# conversions and asserts each is exact within a tight relative epsilon:
#   1 inch = 25.4 mm, 1 mile = 1.609344 km, 100 C = 212 F = 373.15 K,
#   0 C = 32 F = 273.15 K, 1 kg = 2.2046226 lb, 1 US gallon = 3.785411784 l,
#   1 hectare = 10000 m2, 1 hour = 3600 s, 1 GB = 1e9 bytes (KB=1000),
#   60 mph = 96.56064 km/h, plus the affine temperature round-trip C->F->C == C.
# It also exercises the keyboard edge (digit entry + category paging) and renders
# the LENGTH, TEMPERATURE and DATA views to three PPMs for a human/agent to LOOK
# at (a category sidebar, from/to unit lists, the big result and quick table).
#
# USAGE (built to build/host/hamconvert_host):
#   hamconvert_host LENGTH.ppm TEMP.ppm DATA.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamconvertcore import hamconvert_init, hamconvert_build_scene, \
    hamconvert_convert, hamconvert_fmt, hamconvert_set_category, \
    hamconvert_set_from, hamconvert_set_to, hamconvert_set_input_str, \
    hamconvert_result, hamconvert_key_line, hamconvert_category, \
    hamconvert_from, hamconvert_to, hamconvert_input_ptr, \
    CAT_LENGTH, CAT_MASS, CAT_TEMP, CAT_VOLUME, CAT_AREA, CAT_TIME, \
    CAT_DATA, CAT_SPEED


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamconvert_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def _fabs(x: float64) -> float64:
    if x < 0.0:
        return 0.0 - x
    return x


# Assert got ~= exp within a tight relative epsilon and print OK/BAD + the value.
fmtb: Array[48, uint8]


def _check(tag: Ptr[uint8], got: float64, exp: float64):
    tol: float64 = _fabs(exp) * 0.000000001 + 0.000000001
    hamconvert_fmt(got, &fmtb[0])
    _o_str(cast[Ptr[uint8]]("CONV "))
    _o_str(tag)
    if _fabs(got - exp) <= tol:
        _o_str(cast[Ptr[uint8]](" OK "))
    else:
        _o_str(cast[Ptr[uint8]](" BAD "))
    _o_str(&fmtb[0])
    _o_ch(10)


# Feed one keypress via the "d <code>" wire line.
kl: Array[16, uint8]


def _press(code: int32):
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    hamconvert_key_line(&kl[0], p)


def _kv(tag: Ptr[uint8], v: int64):
    _o_str(tag)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]](
            "usage: hamconvert_host LENGTH.ppm TEMP.ppm DATA.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 480
    H: int32 = 560
    hamconvert_init()

    # ---- (1) LENGTH: inch->mm (25.4) and mile->km (1.609344) --------------
    _check(cast[Ptr[uint8]]("inch_mm"),
           hamconvert_convert(CAT_LENGTH, 4, 0, 1.0), 25.4)
    _check(cast[Ptr[uint8]]("mile_km"),
           hamconvert_convert(CAT_LENGTH, 7, 3, 1.0), 1.609344)
    _check(cast[Ptr[uint8]]("m_cm"),
           hamconvert_convert(CAT_LENGTH, 2, 1, 1.0), 100.0)

    # ---- (2) TEMPERATURE (affine) -----------------------------------------
    _check(cast[Ptr[uint8]]("100C_F"),
           hamconvert_convert(CAT_TEMP, 0, 1, 100.0), 212.0)
    _check(cast[Ptr[uint8]]("100C_K"),
           hamconvert_convert(CAT_TEMP, 0, 2, 100.0), 373.15)
    _check(cast[Ptr[uint8]]("0C_F"),
           hamconvert_convert(CAT_TEMP, 0, 1, 0.0), 32.0)
    _check(cast[Ptr[uint8]]("0C_K"),
           hamconvert_convert(CAT_TEMP, 0, 2, 0.0), 273.15)
    _check(cast[Ptr[uint8]]("212F_C"),
           hamconvert_convert(CAT_TEMP, 1, 0, 212.0), 100.0)
    # round-trip: 37 C -> F -> C == 37
    tf: float64 = hamconvert_convert(CAT_TEMP, 0, 1, 37.0)
    tc: float64 = hamconvert_convert(CAT_TEMP, 1, 0, tf)
    _check(cast[Ptr[uint8]]("37C_roundtrip"), tc, 37.0)

    # ---- (3) MASS: kg->lb (2.2046226...) ----------------------------------
    _check(cast[Ptr[uint8]]("kg_lb"),
           hamconvert_convert(CAT_MASS, 2, 5, 1.0), 2.2046226218487757)

    # ---- (4) VOLUME: US gallon->l (3.785411784) ---------------------------
    _check(cast[Ptr[uint8]]("gal_l"),
           hamconvert_convert(CAT_VOLUME, 8, 1, 1.0), 3.785411784)

    # ---- (5) AREA: hectare->m2 (10000) ------------------------------------
    _check(cast[Ptr[uint8]]("hectare_m2"),
           hamconvert_convert(CAT_AREA, 4, 2, 1.0), 10000.0)

    # ---- (6) TIME: hour->s (3600) -----------------------------------------
    _check(cast[Ptr[uint8]]("hour_s"),
           hamconvert_convert(CAT_TIME, 3, 1, 1.0), 3600.0)

    # ---- (7) DATA: GB->byte (1e9, decimal SI KB=1000) ---------------------
    _check(cast[Ptr[uint8]]("GB_byte"),
           hamconvert_convert(CAT_DATA, 4, 1, 1.0), 1000000000.0)

    # ---- (8) SPEED: 60 mph->km/h (96.56064) -------------------------------
    _check(cast[Ptr[uint8]]("60mph_kmh"),
           hamconvert_convert(CAT_SPEED, 2, 1, 60.0), 96.56064)
    _o_flush()

    # ---- keyboard edge: enter "25" and page category ----------------------
    hamconvert_set_category(CAT_LENGTH)
    hamconvert_set_input_str(cast[Ptr[uint8]]("0"))
    _press(50)                                          # '2'
    _press(53)                                          # '5'
    _o_str(cast[Ptr[uint8]]("INPUT_AFTER_KEYS "))
    _o_str(hamconvert_input_ptr())
    _o_ch(10)
    _kv(cast[Ptr[uint8]]("CAT_BEFORE"), cast[int64](hamconvert_category()))
    _press(93)                                          # ']' next category
    _kv(cast[Ptr[uint8]]("CAT_AFTER"), cast[int64](hamconvert_category()))
    _o_flush()

    # ---- (A) render LENGTH view: 12 inch -> foot --------------------------
    hamconvert_set_category(CAT_LENGTH)
    hamconvert_set_from(4)                               # inch
    hamconvert_set_to(5)                                # foot
    hamconvert_set_input_str(cast[Ptr[uint8]]("12"))
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _kv(cast[Ptr[uint8]]("LENGTH_PRIMS"), cast[int64](prims))
    _kv(cast[Ptr[uint8]]("LENGTH_CAT"), cast[int64](hamconvert_category()))
    _kv(cast[Ptr[uint8]]("PIX_TITLEBAR"), cast[int64](hamui_host_pixel(4, 4)))
    hamconvert_fmt(hamconvert_result(), &fmtb[0])
    _o_str(cast[Ptr[uint8]]("LENGTH_RESULT "))
    _o_str(&fmtb[0])
    _o_ch(10)
    _o_flush()

    # ---- (B) render TEMPERATURE view: 100 C -> F --------------------------
    hamconvert_set_category(CAT_TEMP)
    hamconvert_set_from(0)                               # Celsius
    hamconvert_set_to(1)                                # Fahrenheit
    hamconvert_set_input_str(cast[Ptr[uint8]]("100"))
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    hamconvert_fmt(hamconvert_result(), &fmtb[0])
    _o_str(cast[Ptr[uint8]]("TEMP_RESULT "))
    _o_str(&fmtb[0])
    _o_ch(10)
    _o_flush()

    # ---- (C) render DATA view: 1 GB -> MB ---------------------------------
    hamconvert_set_category(CAT_DATA)
    hamconvert_set_from(4)                               # GB
    hamconvert_set_to(3)                                # MB
    hamconvert_set_input_str(cast[Ptr[uint8]]("1"))
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))
    hamconvert_fmt(hamconvert_result(), &fmtb[0])
    _o_str(cast[Ptr[uint8]]("DATA_RESULT "))
    _o_str(&fmtb[0])
    _o_ch(10)
    _o_flush()
    return 0

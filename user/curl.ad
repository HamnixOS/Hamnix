# user/curl.ad — fetch a URL over HTTP/HTTPS and write the body out.
#
# Native Adder front-end over user/http9.ad (HTTP-over-the-/net file
# tree; ARCH §10 — there are no BSD sockets). Usage:
#
#   curl URL                 write the response body to stdout
#   curl -i URL              include the response headers in the output
#   curl -o FILE URL         write the body to FILE instead of stdout
#   curl -L URL              follow a single 3xx Location redirect
#
# Exit status: 0 on a 2xx/3xx response, 22 on an HTTP status >= 400
# (mirrors curl's --fail-ish behaviour at the smallest scope), and a
# small non-zero code on a transport / parse failure.
#
# Compiler-quirk discipline (memory/feedback_compiler_quirks.md U9):
# every large buffer is a top-level BSS Array — never a frame local.
# String literals are materialised inline; no adjacent string concat.

from user.http9 import http_get, http_find_header

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32


# 1 MiB response cap — comfortably covers index.json + small pages.
RESP_CAP: uint64 = 1048576
resp_buf:  Array[1048576, uint8]
# Scratch for a followed redirect's Location target.
loc_buf:   Array[2048, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, value: int64):
    if value < 0:
        sys_write(fd, "-", 1)
        value = 0 - value
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = cast[uint64](value)
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def _write_full(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    written: uint64 = 0
    while written < count:
        room: uint64 = count - written
        ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](buf) + written)
        rc: int64 = sys_write(fd, ptr, room)
        if rc < 0:
            return rc
        if rc == 0:
            return cast[int64](written)
        written = written + cast[uint64](rc)
    return cast[int64](written)


def _is_flag(s: Ptr[uint8], f: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while s[i] != 0 and f[i] != 0:
        if s[i] != f[i]:
            return 0
        i = i + 1
    if s[i] == 0 and f[i] == 0:
        return 1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    inc_headers: int32 = 0
    follow:      int32 = 0
    out_path: Ptr[uint8] = cast[Ptr[uint8]](0)
    url:      Ptr[uint8] = cast[Ptr[uint8]](0)

    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if _is_flag(a, "-i") != 0:
            inc_headers = 1
        elif _is_flag(a, "-L") != 0:
            follow = 1
        elif _is_flag(a, "-o") != 0:
            i = i + 1
            if i >= argc:
                write_str(2, "curl: option -o requires a FILE argument\n")
                return 2
            out_path = cast[Ptr[uint8]](argv[cast[uint64](i)])
        else:
            url = a
        i = i + 1

    if cast[uint64](url) == 0:
        write_str(2, "usage: curl [-i] [-L] [-o FILE] URL\n")
        return 2

    status:   int64 = 0
    body_off: uint64 = 0
    body_len: uint64 = 0
    fetch_url: Ptr[uint8] = url
    redirects: int32 = 0

    while True:
        rc: int64 = http_get(fetch_url, &resp_buf[0], RESP_CAP,
                             &status, &body_off, &body_len)
        if rc < 0:
            if rc == -1:
                write_str(2, "curl: malformed or unsupported URL\n")
            elif rc == -2:
                write_str(2, "curl: could not connect to host\n")
            elif rc == -7:
                write_str(2, "curl: malformed chunked transfer-encoding\n")
            else:
                write_str(2, "curl: transport error fetching URL\n")
            return 7

        # Follow a single 3xx Location redirect when -L is set.
        if follow != 0 and status >= 300 and status < 400 and redirects < 1:
            if http_find_header(&resp_buf[0], body_off,
                                "location", &loc_buf[0], 2048) != 0:
                fetch_url = &loc_buf[0]
                redirects = redirects + 1
                continue
        break

    if inc_headers != 0:
        # The header block is resp_buf[0 .. body_off).
        _write_full(1, &resp_buf[0], body_off)

    out_fd: int32 = 1
    opened: int32 = 0
    if cast[uint64](out_path) != 0:
        out_fd = sys_open_write(cast[Ptr[char]](out_path))
        if out_fd < 0:
            write_str(2, "curl: cannot open output file ")
            write_str(2, out_path)
            write_str(2, "\n")
            return 3
        opened = 1

    body_ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](&resp_buf[0]) + body_off)
    if _write_full(out_fd, body_ptr, body_len) < 0:
        if opened != 0:
            sys_close(out_fd)
        write_str(2, "curl: write error\n")
        return 4
    if opened != 0:
        sys_close(out_fd)

    if status >= 400:
        write_str(2, "curl: server returned HTTP ")
        write_dec(2, status)
        write_str(2, "\n")
        return 22

    return 0

# user/hamangrybirds_host.ad — HOST driver + render harness for the Angry-Birds
# slingshot game (built for the x86_64-linux Adder target; runs directly on the
# dev host, no QEMU).
#
# It drives the SAME core the native app ships (lib/hamangrycore.ad): builds a
# level, RASTERIZES the scene with lib/hamui_host.ad's parser+font rasterizer
# into an RGB framebuffer written out as a binary PPM a human/agent can LOOK at
# (scripts/test_hamangrybirds_host.sh converts it to PNG). Then it runs SCRIPTED
# physics — set an aim, launch, step the simulation, and assert the game
# evolved: the bird ARCS (rises above the launch line then descends), a PIG
# block CLEARS on impact + scores, running the aim/power controls clamps, and
# clearing the last pig is a WIN. It also dumps the raw scene display list +
# sampled pixel colours to stdout so the gate can assert on layout/colour.
#
# USAGE (built to build/host/hamangrybirds_host):
#   hamangrybirds_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamangrycore import hangry_reset, hangry_reload_level, \
    hangry_build_scene, hangry_draw_overlay, hangry_step, hangry_launch, \
    hangry_set_aim, hangry_test_hitwall, hangry_angle_delta, \
    hangry_power_delta, hangry_ctrl_press, hangry_btn_at, \
    hangry_state, hangry_level, hangry_score, hangry_birds_left, \
    hangry_bird_active, hangry_bird_cx, hangry_bird_cy, hangry_min_y, \
    hangry_start_y, hangry_aim_angle, hangry_aim_power, \
    hangry_blocks_alive, hangry_pigs_alive


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hangry_build_scene()
    hangry_draw_overlay()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamangrybirds_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 480
    H: int32 = 360

    # DETERMINISTIC: fresh game (level 0), render the AIM frame a human can look
    # at (slingshot + tower + pig + aim preview + controls).
    hangry_reset()
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _o_kv(cast[Ptr[uint8]]("LEVEL0"), cast[int64](hangry_level()))
    _o_kv(cast[Ptr[uint8]]("STATE0"), cast[int64](hangry_state()))
    _o_kv(cast[Ptr[uint8]]("SCORE0"), cast[int64](hangry_score()))
    _o_kv(cast[Ptr[uint8]]("BIRDS0"), cast[int64](hangry_birds_left()))
    _o_kv(cast[Ptr[uint8]]("BLOCKS0"), cast[int64](hangry_blocks_alive()))
    _o_kv(cast[Ptr[uint8]]("PIGS0"), cast[int64](hangry_pigs_alive()))
    _o_kv(cast[Ptr[uint8]]("ANGLE0"), cast[int64](hangry_aim_angle()))
    _o_kv(cast[Ptr[uint8]]("POWER0"), cast[int64](hangry_aim_power()))

    # Sampled pixels (proves the RASTERIZER, not just the builder).
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))               # sky navy-blue
    _o_hexcol(hamui_host_pixel(4, 4))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 240 330 "))           # ground green
    _o_hexcol(hamui_host_pixel(240, 330))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 70 250 "))            # bird body (red) at sling
    _o_hexcol(hamui_host_pixel(70, 250))
    _o_ch(10)

    # Dump the raw scene display list so the gate can assert layout/colour.
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- CONTROL CLAMPS -------------------------------------------------
    # Aim/power controls clamp at their bounds (angle 10..80, power 0..5).
    hangry_set_aim(80, 5)
    hangry_angle_delta(5)              # already max -> stays 80
    hangry_power_delta(1)             # already max -> stays 5
    _o_kv(cast[Ptr[uint8]]("ANGLE_MAX"), cast[int64](hangry_aim_angle()))
    _o_kv(cast[Ptr[uint8]]("POWER_MAX"), cast[int64](hangry_aim_power()))
    hangry_set_aim(10, 0)
    hangry_angle_delta(0 - 5)          # already min -> stays 10
    hangry_power_delta(0 - 1)         # already min -> stays 0
    _o_kv(cast[Ptr[uint8]]("ANGLE_MIN"), cast[int64](hangry_aim_angle()))
    _o_kv(cast[Ptr[uint8]]("POWER_MIN"), cast[int64](hangry_aim_power()))

    # Control-row hit-test: Launch is button 5.
    lb: int64 = hangry_btn_at(cast[int64](8 + 5 * (72 + 6) + 4), 336)
    _o_kv(cast[Ptr[uint8]]("BTN_LAUNCH"), lb)

    # ---- ARC: a lobbed shot rises above the launch line then falls -------
    # Fresh level, no blocks in the way — a steep shot must climb well above
    # the launch height (smaller y) before gravity pulls it back down.
    hangry_reset()
    hangry_test_hitwall()             # replace blocks (we only want the arc now)
    # But move the wall out of the arc's early path is unnecessary: aim STEEP so
    # the bird goes nearly straight up-and-over. Use a fresh clean field:
    hangry_reload_level()             # restore level-0 blocks (far to the right)
    hangry_set_aim(75, 2)
    starty: int32 = hangry_start_y()
    hangry_launch()
    _o_kv(cast[Ptr[uint8]]("FLY_STATE"), cast[int64](hangry_state()))
    steps: int32 = 0
    while hangry_bird_active() != 0 and steps < 400:
        hangry_step()
        steps = steps + 1
    _o_kv(cast[Ptr[uint8]]("ARC_STARTY"), cast[int64](starty))
    _o_kv(cast[Ptr[uint8]]("ARC_MINY"), cast[int64](hangry_min_y()))
    _o_kv(cast[Ptr[uint8]]("ARC_ENDCY"), cast[int64](hangry_bird_cy()))
    _o_kv(cast[Ptr[uint8]]("ARC_STEPS"), cast[int64](steps))

    # ---- HIT: a bird into the guaranteed pig wall clears it + scores -----
    hangry_test_hitwall()
    _o_kv(cast[Ptr[uint8]]("HIT_PIGS_BEFORE"), cast[int64](hangry_pigs_alive()))
    score_before: int32 = hangry_score()
    hangry_set_aim(20, 5)             # flat, fast — cannot miss the tall wall
    hangry_launch()
    hsteps: int32 = 0
    while hangry_bird_active() != 0 and hsteps < 400:
        hangry_step()
        hsteps = hsteps + 1
    _o_kv(cast[Ptr[uint8]]("HIT_PIGS_AFTER"), cast[int64](hangry_pigs_alive()))
    _o_kv(cast[Ptr[uint8]]("HIT_SCORE_DELTA"),
          cast[int64](hangry_score() - score_before))
    _o_kv(cast[Ptr[uint8]]("HIT_STATE"), cast[int64](hangry_state()))

    # Render the AFTER frame (post win, overlay visible) to a PNG.
    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_kv(cast[Ptr[uint8]]("PRIMS2"), cast[int64](prims2))

    # ---- NEXT LEVEL: New on a WIN advances the level ---------------------
    hangry_ctrl_press(0)              # New -> next level (we are in S_WIN)
    _o_kv(cast[Ptr[uint8]]("NEXT_LEVEL"), cast[int64](hangry_level()))
    _o_kv(cast[Ptr[uint8]]("NEXT_STATE"), cast[int64](hangry_state()))
    _o_kv(cast[Ptr[uint8]]("NEXT_PIGS"), cast[int64](hangry_pigs_alive()))

    # ---- LOSE: exhaust every bird against the pig wall without clearing --
    hangry_reset()
    hangry_test_hitwall()
    # Aim straight DOWN-ish into the ground so no bird ever reaches the wall.
    guard: int32 = 0
    while hangry_state() != 3 and guard < 12:
        hangry_set_aim(80, 0)         # weak, steep -> lands short of the wall
        if hangry_state() == 0:
            hangry_launch()
            g2: int32 = 0
            while hangry_bird_active() != 0 and g2 < 400:
                hangry_step()
                g2 = g2 + 1
        guard = guard + 1
    _o_kv(cast[Ptr[uint8]]("LOSE_STATE"), cast[int64](hangry_state()))
    _o_kv(cast[Ptr[uint8]]("LOSE_BIRDS"), cast[int64](hangry_birds_left()))
    _o_kv(cast[Ptr[uint8]]("LOSE_PIGS"), cast[int64](hangry_pigs_alive()))
    _o_flush()
    return 0

# user/realpath.ad
#
# Hamnix `realpath PATH...`: print the absolute, canonicalised form of
# each argument. A relative path is anchored to the calling task's CWD
# (via SYS_GETCWD, the same primitive pwd/find/ls use). The result is
# lexically canonical: redundant slashes are collapsed, "." components
# are dropped, and ".." pops the previous component. This matches GNU
# `realpath -s` (no symlink dereference, which Hamnix's per-task
# namespace makes a path-only operation anyway).
#
# One canonical path is printed per argument, each on its own line.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64


PATH_CAP: uint64 = 1024

# Working buffers: the joined cwd+arg input, and the canonical output.
inbuf:  Array[1024, uint8]
outbuf: Array[1024, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Canonicalise the absolute path in `inbuf` (length `ilen`) into
# `outbuf`. inbuf must start with '/'. Returns the output length.
def canonicalize(ilen: uint64) -> uint64:
    # outbuf always holds an absolute path; outlen tracks bytes used.
    # comp_starts[] records the index in outbuf of each component's
    # leading '/', so ".." can pop the last one.
    comp_starts: Array[256, uint64]
    ncomp: uint64 = 0
    outlen: uint64 = 0
    outbuf[0] = 47                              # leading '/'
    outlen = 1

    i: uint64 = 0
    while i < ilen:
        # Skip run of slashes.
        while i < ilen and inbuf[i] == 47:
            i = i + 1
        if i >= ilen:
            break
        # Component spans [i, j).
        j: uint64 = i
        while j < ilen and inbuf[j] != 47:
            j = j + 1
        clen: uint64 = j - i
        # "." -> drop.
        if clen == 1 and inbuf[i] == 46:
            i = j
        elif clen == 2 and inbuf[i] == 46 and inbuf[i + 1] == 46:
            # ".." -> pop last component if any.
            if ncomp > 0:
                ncomp = ncomp - 1
                outlen = comp_starts[ncomp]
                if outlen == 0:
                    outlen = 1                  # never below root "/"
            i = j
        else:
            # Real component — append "/<comp>" (skip the slash if we're
            # right after the root and outlen==1).
            comp_starts[ncomp] = outlen
            ncomp = ncomp + 1
            if outlen > 1:
                if outlen + 1 < PATH_CAP:
                    outbuf[outlen] = 47
                    outlen = outlen + 1
            # Re-record start now that the slash (if any) is placed:
            # comp_starts must point at the '/' so a future ".." trims
            # back to it. For the first component after root, the start
            # is index 1 (no leading slash beyond root's).
            comp_starts[ncomp - 1] = outlen - 1
            if outlen == 1:
                comp_starts[ncomp - 1] = 1
            k: uint64 = i
            while k < j and outlen + 1 < PATH_CAP:
                outbuf[outlen] = inbuf[k]
                outlen = outlen + 1
                k = k + 1
            i = j
    outbuf[outlen] = 0
    return outlen


def resolve_one(arg: Ptr[uint8]) -> int32:
    ilen: uint64 = 0
    if arg[0] == 47:
        # Already absolute — copy as-is.
        n: uint64 = strlen_u8(arg)
        if n >= PATH_CAP:
            n = PATH_CAP - 1
        i: uint64 = 0
        while i < n:
            inbuf[i] = arg[i]
            i = i + 1
        ilen = n
    else:
        # Relative — anchor to CWD.
        cn: int64 = sys_getcwd(&inbuf[0], PATH_CAP)
        if cn <= 0:
            return -1
        ilen = cast[uint64](cn - 1)             # strip NUL
        # Append "/<arg>".
        if ilen + 1 < PATH_CAP:
            inbuf[ilen] = 47
            ilen = ilen + 1
        an: uint64 = strlen_u8(arg)
        ai: uint64 = 0
        while ai < an and ilen < PATH_CAP - 1:
            inbuf[ilen] = arg[ai]
            ilen = ilen + 1
            ai = ai + 1
    inbuf[ilen] = 0
    olen: uint64 = canonicalize(ilen)
    sys_write(1, &outbuf[0], olen)
    sys_write(1, "\n", 1)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "realpath: missing operand\n")
        return 1
    rc: int32 = 0
    i: int32 = 1
    while i < argc:
        if resolve_one(cast[Ptr[uint8]](argv[cast[uint64](i)])) != 0:
            rc = 1
        i = i + 1
    return rc

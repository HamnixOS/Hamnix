# user/hamctl_resize_host.ad — HOST render harness proving the Control Center
# RELAYOUTS on window resize (built for x86_64-linux; runs on the dev host, no
# QEMU). Renders the SAME core the native app ships (lib/hamctlcore.ad) at
# several window sizes and probes a pixel deep in the (formerly black) gutter.
#
# For each target size it emits TWO renders:
#   * BUG  — build the scene at the DEFAULT 520x400 layout into a larger
#            framebuffer (what the app did before it handled the "r <w> <h>"
#            resize event): the gutter beyond 520x400 is uninitialised BLACK.
#   * FIX  — call hamctl_set_win_size(w, h) first so the scene fills the whole
#            client rect: the same probe pixel is the toolkit background, never
#            black.
#
# USAGE (built to build/host/hamctl_resize_host):
#   hamctl_resize_host OUTDIR
# Writes OUTDIR/ctl_resize_<label>_{bug,fix}.ppm and prints PROBE lines.

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamctlcore import hamctl_init, hamctl_build_scene, \
    hamctl_set_datetime, hamctl_set_display, hamctl_set_kb_layout, \
    hamctl_set_sound, hamctl_set_power, hamctl_set_net, \
    hamctl_about_clear, hamctl_about_add, \
    hamctl_set_win_size, hamctl_win_w, hamctl_win_h


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]
path_buf: Array[256, uint8]


def _pstr(pos: uint64, s: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        path_buf[pos] = s[i]
        pos = pos + 1
        i = i + 1
    return pos


def _write_ppm(dir: Ptr[uint8], label: Ptr[uint8], kind: Ptr[uint8]):
    p: uint64 = _pstr(0, dir)
    p = _pstr(p, cast[Ptr[uint8]]("/ctl_resize_"))
    p = _pstr(p, label)
    p = _pstr(p, cast[Ptr[uint8]]("_"))
    p = _pstr(p, kind)
    p = _pstr(p, cast[Ptr[uint8]](".ppm"))
    path_buf[p] = 0
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]), 577, 420)
    if fd < 0:
        return
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)


# Probe a pixel and print "PROBE <label> <kind> <px> <py> <hexcolor>".
def _probe(label: Ptr[uint8], kind: Ptr[uint8], px: int32, py: int32):
    _o_str(cast[Ptr[uint8]]("PROBE "))
    _o_str(label)
    _o_ch(32)
    _o_str(kind)
    _o_ch(32)
    _o_dec(cast[int64](px))
    _o_ch(32)
    _o_dec(cast[int64](py))
    _o_ch(32)
    _o_hexcol(hamui_host_pixel(px, py))
    _o_ch(10)
    _o_flush()


def _seed():
    hamctl_init()
    hamctl_set_datetime(cast[Ptr[uint8]]("Sun Jul 12  14:30"))
    hamctl_set_display(1024, 768, 4096, 32)
    hamctl_set_kb_layout(cast[Ptr[uint8]]("us"))
    hamctl_set_sound(0, cast[Ptr[uint8]]("No audio device"))
    hamctl_set_power(cast[Ptr[uint8]]("0:12:34"),
                     cast[Ptr[uint8]]("AC (no battery)"))
    hamctl_set_net(cast[Ptr[uint8]]("192.168.1.50"),
                   cast[Ptr[uint8]]("255.255.255.0"),
                   cast[Ptr[uint8]]("192.168.1.1"),
                   cast[Ptr[uint8]]("192.168.1.1"),
                   cast[Ptr[uint8]]("dhcp"))
    hamctl_about_clear()
    hamctl_about_add(cast[Ptr[uint8]]("Host"), cast[Ptr[uint8]]("hamnix"))
    hamctl_about_add(cast[Ptr[uint8]]("Memory"), cast[Ptr[uint8]]("2048 MB"))


# Render + probe one target size. Probe point is deep in the region that only
# exists at the LARGER size (px,py near the bottom-right of the client rect).
def _case(dir: Ptr[uint8], label: Ptr[uint8], w: int32, h: int32):
    px: int32 = w - 6
    py: int32 = h - 6

    # BUG: keep the default 520x400 layout, rasterize into the larger fb.
    hamctl_set_win_size(520, 400)
    hamctl_build_scene()
    hamui_host_begin(w, h)
    hamui_host_rasterize()
    _write_ppm(dir, label, cast[Ptr[uint8]]("bug"))
    _probe(label, cast[Ptr[uint8]]("bug"), px, py)

    # FIX: relayout to the new size first.
    hamctl_set_win_size(w, h)
    hamctl_build_scene()
    hamui_host_begin(w, h)
    hamui_host_rasterize()
    _write_ppm(dir, label, cast[Ptr[uint8]]("fix"))
    _probe(label, cast[Ptr[uint8]]("fix"), px, py)
    # Also confirm the toolkit reports the live size.
    _o_str(cast[Ptr[uint8]]("SIZE "))
    _o_str(label)
    _o_ch(32)
    _o_dec(cast[int64](hamctl_win_w()))
    _o_ch(32)
    _o_dec(cast[int64](hamctl_win_h()))
    _o_ch(10)
    _o_flush()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _o_str(cast[Ptr[uint8]]("usage: hamctl_resize_host OUTDIR\n"))
        _o_flush()
        return 2
    dir: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    _seed()
    _case(dir, cast[Ptr[uint8]]("small"), 340, 300)
    _case(dir, cast[Ptr[uint8]]("medium"), 700, 520)
    _case(dir, cast[Ptr[uint8]]("odd"), 611, 543)
    _case(dir, cast[Ptr[uint8]]("large"), 1024, 720)
    return 0

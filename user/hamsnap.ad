# user/hamsnap.ad
#
# hamsnap — DE pivot wave 4: live snap-zone preview (edge/corner tiling
# hint shown during a window move-drag) extracted from daemon_pixel.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2, hamui_set_protocol_v2_dims,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


_hs_active: int32 = 0
_hs_mode:   int32 = 0
_hs_x:      int32 = 0
_hs_y:      int32 = 0
_hs_w:      int32 = 0
_hs_h:      int32 = 0
_hs_gen:    uint64 = 0
_hs_show_serial:      uint64 = 0
_hs_last_show_serial: uint64 = 0xffffffffffffffff
_hs_last_gen:         uint64 = 0xffffffffffffffff


_hs_WIN_W: int32 = 800
_hs_WIN_H: int32 = 600


_hs_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _read_snap() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/snap"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hs_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hs_snap_buf[p] >= 48 and _hs_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hs_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _parse_i64(pos: Ptr[uint64], end: uint64) -> int64:
    p: uint64 = pos[0]
    neg: int32 = 0
    if p < end and _hs_snap_buf[p] == 45:
        neg = 1
        p = p + 1
    v: int64 = 0
    while p < end and _hs_snap_buf[p] >= 48 and _hs_snap_buf[p] <= 57:
        v = v * 10 + cast[int64](_hs_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    if neg != 0:
        return -v
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hs_snap_buf[p] == 32 or _hs_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    show_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    a_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    m_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    x_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    y_v: int64 = _parse_i64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    w_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    h_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _hs_show_serial = show_v
    _hs_active = cast[int32](a_v)
    _hs_mode = cast[int32](m_v)
    _hs_x = cast[int32](x_v)
    _hs_y = cast[int32](y_v)
    _hs_w = cast[int32](w_v)
    _hs_h = cast[int32](h_v)
    _hs_gen = gen_v
    changed: int32 = 0
    if _hs_show_serial != _hs_last_show_serial:
        changed = 1
    if _hs_gen != _hs_last_gen:
        changed = 1
    _hs_last_show_serial = _hs_show_serial
    _hs_last_gen = _hs_gen
    return changed


def _paint():
    hamui_v2_clear_transparent()
    if _hs_active == 0 or _hs_mode == 0 or _hs_w <= 0 or _hs_h <= 0:
        hamui_v2_commit_rect(0, 0, _hs_WIN_W, _hs_WIN_H)
        return
    sx: int32 = _hs_x
    sy: int32 = _hs_y
    sw: int32 = _hs_w
    sh: int32 = _hs_h
    if sx < 0:
        sx = 0
    if sy < 0:
        sy = 0
    if sx + sw > _hs_WIN_W:
        sw = _hs_WIN_W - sx
    if sy + sh > _hs_WIN_H:
        sh = _hs_WIN_H - sy
    # 2px accent border + tint body.
    hamui_v2_fill_rect(sx, sy, sw, sh, 80, 100, 130)
    hamui_v2_fill_rect(sx, sy, sw, 2, 200, 220, 250)
    hamui_v2_fill_rect(sx, sy + sh - 2, sw, 2, 200, 220, 250)
    hamui_v2_fill_rect(sx, sy, 2, sh, 200, 220, 250)
    hamui_v2_fill_rect(sx + sw - 2, sy, 2, sh, 200, 220, 250)
    hamui_v2_commit_rect(0, 0, _hs_WIN_W, _hs_WIN_H)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    sfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/self"))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamsnap: could not bind window\n")
        return 1
    if hamui_set_protocol_v2_dims(_hs_WIN_W, _hs_WIN_H) < 0:
        _puts(2, "hamsnap: v2 negotiate failed\n")
        return 1

    n0: int64 = _read_snap()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMSNAP ready\n"
    sys_write(1, rdy, _strlen(rdy))

    while True:
        n: int64 = _read_snap()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

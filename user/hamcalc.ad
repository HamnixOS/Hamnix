# user/hamcalc.ad
#
# hamcalc — a real, working integer calculator built entirely on the hamui
# widget toolkit (lib/hamui.ad). It is a genuine consumer of the
# GTK/Qt-style retained-mode API: it builds a widget tree once, binds a
# window, then drives the toolkit's pull-based event loop (hamui_step +
# sys_yield) forever, mutating calculator state and pushing the rendered
# display back into the widgets via hamui_set_text / hamui_status_set.
#
# LAYOUT:
#   - a big display statusbar across the top, showing the current operand
#     while typing, or the running result.
#   - a 4-column grid of buttons: digits 0-9, the four operators + - * /,
#     '=' to compute, and 'C' to clear everything.
#
# SEMANTICS (a simple immediate-execution calculator, integer math):
#   - typing a digit appends to the current operand (capped so the fixed
#     display buffer can never overflow).
#   - pressing an operator applies any already-pending operator to the
#     accumulator and the just-entered operand, stores the new pending
#     operator, and starts a fresh operand.
#   - '=' applies the pending operator and shows the result; the result
#     becomes the accumulator for chained operations.
#   - 'C' resets everything to 0.
#   - divide-by-zero shows "ERR" and latches an error state until 'C'.
#
# All arithmetic is signed 64-bit integer. Negatives are rendered with a
# leading '-' by the int->decimal routine.

from lib.hamui import (
    hamui_init, hamui_fixed, hamui_grid, hamui_button,
    hamui_label, hamui_statusbar, hamui_status_set, hamui_grid_attach,
    hamui_add, hamui_fixed_place, hamui_set_size, hamui_set_text,
    hamui_window, hamui_step, hamui_signalled, hamui_set_title
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_yield() -> int32


# ---- tiny stdout helpers (for the boot/diagnostic line) -----------------
def _c_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _c_puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _c_strlen(s))


# ====================================================================
# CALCULATOR STATE (module scope — no malloc, fixed arrays only)
# ====================================================================
# acc       : the accumulator (left-hand value of any pending op)
# operand   : the value currently being entered
# pending   : pending operator: 0=none 1='+' 2='-' 3='*' 4='/'
# entering  : nonzero while the user is keying digits into `operand`
# err       : nonzero once a divide-by-zero (or similar) latched; cleared by C
# show_res  : nonzero when the display should show `acc` (result), else operand
acc:      int64 = 0
operand:  int64 = 0
pending:  int32 = 0
entering: int32 = 0
err:      int32 = 0
show_res: int32 = 0

# how many digits have been keyed into `operand`; capped to keep the display
# buffer safely small.
opdigits: int32 = 0
MAXDIGITS: int32 = 15

# rendered-display scratch (sign + up to ~19 digits + slack + NUL)
disp_buf: Array[32, uint8]

# button widget ids (set at build time)
b_dig:  Array[10, int32]            # b_dig[d] is the button for digit d
b_add:  int32 = 0
b_sub:  int32 = 0
b_mul:  int32 = 0
b_div:  int32 = 0
b_eq:   int32 = 0
b_clr:  int32 = 0
disp:   int32 = 0


# ---- int64 -> decimal into disp_buf, NUL-terminated -----------------
def _c_render(v: int64):
    if err != 0:
        disp_buf[0] = 69                # 'E'
        disp_buf[1] = 82                # 'R'
        disp_buf[2] = 82                # 'R'
        disp_buf[3] = 0
        return
    if v == 0:
        disp_buf[0] = 48                # '0'
        disp_buf[1] = 0
        return
    neg: int32 = 0
    uv: uint64 = 0
    if v < 0:
        neg = 1
        uv = cast[uint64](0 - v)
    else:
        uv = cast[uint64](v)
    tmp: Array[24, uint8]
    t: uint64 = 0
    while uv != 0:
        tmp[t] = cast[uint8](uv % 10) + 48
        uv = uv / 10
        t = t + 1
    p: uint64 = 0
    if neg != 0:
        disp_buf[p] = 45                # '-'
        p = p + 1
    while t > 0:
        t = t - 1
        disp_buf[p] = tmp[t]
        p = p + 1
    disp_buf[p] = 0


def _c_refresh():
    if show_res != 0 or entering == 0:
        _c_render(acc)
    else:
        _c_render(operand)
    hamui_status_set(disp, &disp_buf[0])


# ---- state transitions ----------------------------------------------
def _c_clear():
    acc = 0
    operand = 0
    pending = 0
    entering = 0
    err = 0
    show_res = 1
    opdigits = 0


# Append decimal digit d (0..9) to the operand currently being entered.
def _c_digit(d: int32):
    if err != 0:
        return
    if entering == 0:
        operand = 0
        opdigits = 0
        entering = 1
        show_res = 0
    if opdigits >= MAXDIGITS:
        return
    operand = operand * 10 + cast[int64](d)
    opdigits = opdigits + 1


# Apply the pending operator to (acc, operand), storing into acc. Sets err
# on divide-by-zero. Called by both operator buttons and '='.
def _c_apply():
    if pending == 0:
        acc = operand
        return
    if pending == 1:
        acc = acc + operand
    elif pending == 2:
        acc = acc - operand
    elif pending == 3:
        acc = acc * operand
    elif pending == 4:
        if operand == 0:
            err = 1
            return
        acc = acc / operand


# Operator pressed (op: 1..4). Fold any pending op first, then arm `op`.
def _c_operator(op: int32):
    if err != 0:
        return
    if entering != 0:
        _c_apply()
    elif pending == 0:
        # no operand keyed since last result: operate on the shown acc
        acc = acc
    # (if not entering and a pending op already exists, keep acc as-is)
    pending = op
    entering = 0
    show_res = 1
    operand = 0
    opdigits = 0


# '=' pressed: fold pending op and present the result.
def _c_equals():
    if err != 0:
        return
    if entering != 0:
        _c_apply()
    pending = 0
    entering = 0
    show_res = 1
    operand = 0
    opdigits = 0


# ====================================================================
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    root: int32 = hamui_fixed()

    title: int32 = hamui_label("hamcalc - hamui")
    hamui_fixed_place(title, 20, 14)
    hamui_add(root, title)

    # big display across the top
    disp = hamui_statusbar("0")
    hamui_set_size(disp, 360, 40)
    hamui_fixed_place(disp, 20, 40)
    hamui_add(root, disp)

    # button grid. Layout (col,row):
    #   row0: 7 8 9 /
    #   row1: 4 5 6 *
    #   row2: 1 2 3 -
    #   row3: C 0 = +
    grid: int32 = hamui_grid()
    hamui_fixed_place(grid, 20, 96)
    hamui_add(root, grid)

    # helper-free explicit wiring keeps each button id captured in a global.
    # digit buttons
    d7: int32 = hamui_button("7")
    hamui_set_size(d7, 84, 70)
    hamui_grid_attach(grid, d7, 0, 0, 1, 1)
    b_dig[7] = d7
    d8: int32 = hamui_button("8")
    hamui_set_size(d8, 84, 70)
    hamui_grid_attach(grid, d8, 1, 0, 1, 1)
    b_dig[8] = d8
    d9: int32 = hamui_button("9")
    hamui_set_size(d9, 84, 70)
    hamui_grid_attach(grid, d9, 2, 0, 1, 1)
    b_dig[9] = d9

    d4: int32 = hamui_button("4")
    hamui_set_size(d4, 84, 70)
    hamui_grid_attach(grid, d4, 0, 1, 1, 1)
    b_dig[4] = d4
    d5: int32 = hamui_button("5")
    hamui_set_size(d5, 84, 70)
    hamui_grid_attach(grid, d5, 1, 1, 1, 1)
    b_dig[5] = d5
    d6: int32 = hamui_button("6")
    hamui_set_size(d6, 84, 70)
    hamui_grid_attach(grid, d6, 2, 1, 1, 1)
    b_dig[6] = d6

    d1: int32 = hamui_button("1")
    hamui_set_size(d1, 84, 70)
    hamui_grid_attach(grid, d1, 0, 2, 1, 1)
    b_dig[1] = d1
    d2: int32 = hamui_button("2")
    hamui_set_size(d2, 84, 70)
    hamui_grid_attach(grid, d2, 1, 2, 1, 1)
    b_dig[2] = d2
    d3: int32 = hamui_button("3")
    hamui_set_size(d3, 84, 70)
    hamui_grid_attach(grid, d3, 2, 2, 1, 1)
    b_dig[3] = d3

    bc: int32 = hamui_button("C")
    hamui_set_size(bc, 84, 70)
    hamui_grid_attach(grid, bc, 0, 3, 1, 1)
    b_clr = bc
    d0: int32 = hamui_button("0")
    hamui_set_size(d0, 84, 70)
    hamui_grid_attach(grid, d0, 1, 3, 1, 1)
    b_dig[0] = d0
    be: int32 = hamui_button("=")
    hamui_set_size(be, 84, 70)
    hamui_grid_attach(grid, be, 2, 3, 1, 1)
    b_eq = be

    # operator column (col 3)
    bdiv: int32 = hamui_button("/")
    hamui_set_size(bdiv, 84, 70)
    hamui_grid_attach(grid, bdiv, 3, 0, 1, 1)
    b_div = bdiv
    bmul: int32 = hamui_button("*")
    hamui_set_size(bmul, 84, 70)
    hamui_grid_attach(grid, bmul, 3, 1, 1, 1)
    b_mul = bmul
    bsub: int32 = hamui_button("-")
    hamui_set_size(bsub, 84, 70)
    hamui_grid_attach(grid, bsub, 3, 2, 1, 1)
    b_sub = bsub
    badd: int32 = hamui_button("+")
    hamui_set_size(badd, 84, 70)
    hamui_grid_attach(grid, badd, 3, 3, 1, 1)
    b_add = badd

    hint: int32 = hamui_label("integer calc: tap digits, an op, '=' computes, C clears")
    hamui_fixed_place(hint, 20, 392)
    hamui_add(root, hint)

    sb: int32 = hamui_statusbar("hamcalc")
    hamui_set_size(sb, 640, 20)
    hamui_fixed_place(sb, 0, 460)
    hamui_add(root, sb)

    # Taskbar/SSD title MUST be set BEFORE hamui_window() — _h_win_setup()
    # reads it on the window's first ctl write, and otherwise falls back to
    # the generic "Hamnix" default (QA #96: the taskbar entry read "Hamnix").
    hamui_set_title(cast[Ptr[uint8]]("Calculator"))
    wid: int32 = hamui_window(root)
    if wid < 0:
        _c_puts(2, "hamcalc: could not allocate a window\n")
        return 1

    _c_clear()
    _c_refresh()
    _c_puts(1, "HAMCALC ready\n")

    # --- event loop ---------------------------------------------------
    while True:
        hamui_step()

        changed: int32 = 0

        # digit buttons
        di: uint64 = 0
        while di < 10:
            if hamui_signalled(b_dig[di]) != 0:
                _c_digit(cast[int32](di))
                changed = 1
            di = di + 1

        # operator buttons
        if hamui_signalled(b_add) != 0:
            _c_operator(1)
            changed = 1
        if hamui_signalled(b_sub) != 0:
            _c_operator(2)
            changed = 1
        if hamui_signalled(b_mul) != 0:
            _c_operator(3)
            changed = 1
        if hamui_signalled(b_div) != 0:
            _c_operator(4)
            changed = 1
        if hamui_signalled(b_eq) != 0:
            _c_equals()
            changed = 1
        if hamui_signalled(b_clr) != 0:
            _c_clear()
            changed = 1

        if changed != 0:
            _c_refresh()

        sys_yield()

    return 0

# user/ps.ad
#
# Minimal Hamnix `ps`: dumps the three /proc snapshots the M16.36
# kernel exposes (version, uptime, tasks) onto stdout. Equivalent in
# spirit to `cat /proc/version /proc/uptime /proc/tasks` on Linux,
# bundled into one binary so hamsh can demo it without per-file
# coreutils.
#
# Reads each /proc file by re-opening it, draining via 128-byte
# SYS_READ calls, and writing to stdout. Re-opens (rather than one
# big buffer) so the kernel's snapshot semantics are honest — uptime
# read AFTER tasks reflects the moment we opened it, which matches
# what users expect from /proc.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


CHUNK: uint64 = 128


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def cat_proc(path: Ptr[char]) -> int32:
    # Open + drain + close. Errors come out as a single line on stderr
    # so the rest of the run still produces useful output if one of
    # the entries goes missing in a future kernel.
    fd: int32 = sys_open(path)
    if fd < 0:
        write_str(2, "[ps] open failed: ")
        write_str(2, cast[Ptr[uint8]](path))
        write_str(2, "\n")
        return -1
    buf: Array[128, uint8]
    while True:
        n: int64 = sys_read(fd, &buf[0], CHUNK)
        if n <= 0:
            break
        sys_write(1, &buf[0], cast[uint64](n))
    sys_close(fd)
    return 0


def main() -> int32:
    write_str(1, "--- /proc/version ---\n")
    cat_proc("/proc/version")
    write_str(1, "--- /proc/uptime ---\n")
    cat_proc("/proc/uptime")
    write_str(1, "--- /proc/tasks ---\n")
    cat_proc("/proc/tasks")
    return 0

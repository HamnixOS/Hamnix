# user/hamecho.ad
#
# hamecho — Increment-1 of the MATE-mirror DE rewrite: the FIRST desktop
# app that runs as its OWN process (not drawn inside the hamUId monolith).
# It is the minimal, deterministic proof-of-spine the compositor spawns,
# allocates a wid for, and routes focus-gated keyboard input to.
#
# WHAT IT PROVES (the component split)
# ------------------------------------
#   * A program that is a SEPARATE PROCESS appears as a real composited
#     window. Its body pixels come from a hamui "ui" markup layer
#     (lib/hamui.ad), rasterised by the LIVE compositor — exactly the
#     keystone path, but for an app the compositor *spawned* rather than a
#     synthetic in-daemon injection.
#   * Keyboard input reaches it ONLY through the per-window event file
#     /dev/wsys/<wid>/keys that the compositor's focus router writes. The
#     boot/serial shell never sees those keystrokes (the compositor holds
#     the exclusive console-input grab — drivers/video/fb_cdev.ad "grab"
#     verb + kernel/sched/core.ad console_input_grab).
#
# HONEST SCOPE
# ------------
# This is the minimal echo client the brief allows as the proof vehicle:
# every key code it receives on its /dev/wsys/<wid>/keys stream is echoed to
# stdout as `ECHO <code>\n`. The compositor wires this app's stdout to a
# pipe it owns (DWIN_OUT_FD), so the spine self-test can drain that pipe and
# observe that a routed keystroke actually crossed into THIS process — an
# end-to-end input-ownership proof, not a same-process simulation. A full
# PTY terminal is a larger lift; hamterm.ad is the richer (self-wid) app and
# remains the next increment's target for the lag bug specifically.
#
# WINDOWING
# ---------
# Like user/hamde.ad, a hamui client never self-allocates a wid (the
# kernel's SYS_WSYS_ALLOC is hostowner-only). The compositor hands us our
# wid as argv[1] when it spawns us; standalone runs default to wid 1.

from lib.hamui import (
    hamui_init, hamui_fixed, hamui_label, hamui_add, hamui_set_size,
    hamui_fixed_place, hamui_set_text, hamui_window_on, hamui_render
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()


# --- module-scope buffers (no malloc; fixed arrays only) -------------
# Path scratch for /dev/wsys/<wid>/keys.
keys_path: Array[64, uint8]
# Raw read scratch from the keys event stream.
kev_buf:   Array[256, uint8]
# stdout echo line scratch ("ECHO <code>\n").
echo_buf:  Array[32, uint8]
# Composed body label ("keys: N").
body_buf:  Array[40, uint8]

keys_count: uint64 = 0


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# Append the unsigned decimal of v at out[pos..]; returns the new position.
def _put_dec(out: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    if v == 0:
        out[pos] = 48
        return pos + 1
    tmp: Array[20, uint8]
    t: uint64 = 0
    while v != 0:
        tmp[t] = cast[uint8](v % 10) + 48
        v = v / 10
        t = t + 1
    p: uint64 = pos
    while t > 0:
        t = t - 1
        out[p] = tmp[t]
        p = p + 1
    return p


# Build "/dev/wsys/<wid>/keys" into keys_path.
def _build_keys_path(wid: int32):
    pfx: Ptr[uint8] = "/dev/wsys/"
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        keys_path[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = _put_dec(&keys_path[0], p, cast[uint64](wid))
    sfx: Ptr[uint8] = "/keys"
    k = 0
    while sfx[k] != 0:
        keys_path[p] = sfx[k]
        p = p + 1
        k = k + 1
    keys_path[p] = 0


# Parse "<type> <code>\n" event lines out of a freshly-read chunk and, for
# every 'd' (press) line, echo "ECHO <code>\n" to stdout and bump the
# received-key counter. Returns 1 if any key was consumed.
def _drain_keys_chunk(n: uint64) -> int32:
    i: uint64 = 0
    consumed: int32 = 0
    while i < n:
        # type byte
        t: uint8 = kev_buf[i]
        i = i + 1
        # skip the single space
        if i < n and kev_buf[i] == 32:
            i = i + 1
        # parse the decimal code
        code: uint64 = 0
        have: int32 = 0
        while i < n and kev_buf[i] >= 48 and kev_buf[i] <= 57:
            code = code * 10 + cast[uint64](kev_buf[i] - 48)
            i = i + 1
            have = 1
        # consume to end-of-line
        while i < n and kev_buf[i] != 10:
            i = i + 1
        if i < n:
            i = i + 1                          # eat the '\n'
        if t == 100 and have != 0:             # 'd' = press
            ep: uint64 = 0
            pfx: Ptr[uint8] = "ECHO "
            kk: uint64 = 0
            while pfx[kk] != 0:
                echo_buf[ep] = pfx[kk]
                ep = ep + 1
                kk = kk + 1
            ep = _put_dec(&echo_buf[0], ep, code)
            echo_buf[ep] = 10
            ep = ep + 1
            sys_write(1, &echo_buf[0], ep)
            keys_count = keys_count + 1
            consumed = 1
    return consumed


# Repaint the body label so the window shows how many keys it has received.
def _refresh_body(lbl: int32):
    pfx: Ptr[uint8] = "keys: "
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        body_buf[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = _put_dec(&body_buf[0], p, keys_count)
    body_buf[p] = 0
    hamui_set_text(lbl, &body_buf[0])


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()

    # --- widget tree (fixed container so a headless render can sample) ---
    root: int32 = hamui_fixed()

    title: int32 = hamui_label("hamecho - separate process")
    hamui_fixed_place(title, 12, 12)
    hamui_add(root, title)

    body: int32 = hamui_label("keys: 0")
    hamui_set_size(body, 240, 24)
    hamui_fixed_place(body, 12, 48)
    hamui_add(root, body)

    # --- discover OUR compositor-allocated wid -----------------------
    # The compositor allocates our wid AFTER it spawns us (SYS_WSYS_ALLOC
    # runs post-spawn), so the wid cannot be handed to us as an exec argv.
    # We learn it at runtime by reading /dev/wsys/self, which the kernel
    # renders as "<wid>\n" for the CALLING task ("0\n" if we own none).
    # argv[1] is still honoured as an explicit override for standalone
    # runs; a standalone run with neither falls back to wid 1.
    wid: int32 = 1
    sp: Ptr[uint8] = "/dev/wsys/self"
    sfd: int32 = sys_open(cast[Ptr[char]](sp))
    if sfd >= 0:
        self_buf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &self_buf[0], 16)
        sys_close(sfd)
        if sn > 0:
            sv: int32 = 0
            si: uint64 = 0
            while si < cast[uint64](sn) and self_buf[si] >= 48 \
                    and self_buf[si] <= 57:
                sv = sv * 10 + cast[int32](self_buf[si]) - 48
                si = si + 1
            if sv >= 2:
                wid = sv
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v: int32 = 0
        i: uint64 = 0
        while ap[i] >= 48 and ap[i] <= 57:
            v = v * 10 + cast[int32](ap[i]) - 48
            i = i + 1
        if v >= 1:
            wid = v

    bound: int32 = hamui_window_on(root, wid)
    if bound < 0:
        _puts(2, "hamecho: could not bind window\n")
        return 1

    # Open our OWN read handle on the per-window keys event stream. The
    # compositor's focus router writes routed key presses here for the
    # FOCUSED window only; the boot shell (which reads /dev/cons) never sees
    # them because the compositor holds the exclusive console-input grab.
    _build_keys_path(wid)
    kfd: int32 = sys_open(cast[Ptr[char]](&keys_path[0]))

    # Paint the body markup BEFORE announcing readiness. The compositor's
    # spine self-test proceeds to composite the moment it sees "HAMECHO
    # ready", so our "ui" markup body must already be published to the
    # draw surface by then — otherwise the daemon could sample an empty
    # layer and miss-detect the markup client.
    hamui_render()

    # "HAMECHO ready wid=<N>\n" — the wid suffix lets the spine self-test
    # log show which wid the child actually bound (self-discovery proof).
    rl: Array[40, uint8]
    rp: uint64 = 0
    rpfx: Ptr[uint8] = "HAMECHO ready wid="
    rk: uint64 = 0
    while rpfx[rk] != 0:
        rl[rp] = rpfx[rk]
        rp = rp + 1
        rk = rk + 1
    rp = _put_dec(&rl[0], rp, cast[uint64](wid))
    rl[rp] = 10
    rp = rp + 1
    sys_write(1, &rl[0], rp)

    # --- event loop --------------------------------------------------
    # NOTE: we deliberately do NOT call hamui_step() — its internal
    # _h_poll_keys() would drain /dev/wsys/<wid>/keys into the toolkit's own
    # widget dispatch and RACE our raw read below for the same ring bytes.
    # hamecho owns the keys stream directly (kfd) so it can echo each routed
    # code to stdout for the spine self-test, then repaints via hamui_render.
    while True:
        if kfd >= 0:
            n: int64 = sys_read_nb(kfd, &kev_buf[0], 256)
            if n > 0:
                if _drain_keys_chunk(cast[uint64](n)) != 0:
                    _refresh_body(body)
                    hamui_render()
        sys_yield()

    return 0

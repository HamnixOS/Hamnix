# user/hamnotify.ad
#
# `hamnotify` — the libnotify-shape CLI sender for the DE notification
# pipeline. Usage:
#
#   hamnotify "title" "body" [icon]
#
# Opens /dev/wsys/post (the kernel-side inbox ring in devwsys) and writes
# one record of the form "<title>\t<body>\t<icon>\n". The compositor's
# main loop (user/hamUId.ad, daemon_pixel) polls /dev/wsys/post, drains
# the head slot, and pumps it through notify_post() — which arms a
# top-right toast banner that fades after ~4 s.
#
# This is the MATE/GNOME2 `notify-send` shape: anyone (PID1 rc.boot.full,
# a user script, a service daemon) can post a desktop notification
# without speaking to the compositor directly. The hostowner-gated
# /dev/wsys/ctl `notif <active> <alpha> <title>\t<body>` verb is the
# COMPOSITOR's path; this CLI is the broad-audience path.
#
# Exit codes:
#   0 — record posted
#   1 — bad usage
#   2 — could not open /dev/wsys/post
#   3 — short write

extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

TITLE_MAX: uint64 = 40
BODY_MAX:  uint64 = 64
ICON_MAX:  uint64 = 32

# title + \t + body + \t + icon + \n
out_buf: Array[160, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _copy_capped(dst: Ptr[uint8], dst_off: uint64,
                 src: Ptr[uint8], cap: uint64) -> uint64:
    n: uint64 = _strlen(src)
    if n > cap:
        n = cap
    i: uint64 = 0
    while i < n:
        dst[dst_off + i] = src[i]
        i = i + 1
    return dst_off + n


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _puts(2, "usage: hamnotify <title> <body> [icon]\n")
        return 1
    title: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    body:  Ptr[uint8] = cast[Ptr[uint8]](argv[2])
    icon:  Ptr[uint8] = cast[Ptr[uint8]]("")
    if argc >= 4:
        icon = cast[Ptr[uint8]](argv[3])

    n: uint64 = 0
    n = _copy_capped(&out_buf[0], n, title, TITLE_MAX)
    out_buf[n] = 9                                # '\t'
    n = n + 1
    n = _copy_capped(&out_buf[0], n, body, BODY_MAX)
    out_buf[n] = 9                                # '\t'
    n = n + 1
    n = _copy_capped(&out_buf[0], n, icon, ICON_MAX)
    out_buf[n] = 10                               # '\n'
    n = n + 1

    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/post"))
    if fd < 0:
        _puts(2, "hamnotify: cannot open /dev/wsys/post\n")
        return 2
    w: int64 = sys_write(fd, &out_buf[0], n)
    sys_close(fd)
    if w < cast[int64](n):
        _puts(2, "hamnotify: short write to /dev/wsys/post\n")
        return 3
    return 0

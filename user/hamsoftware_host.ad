# user/hamsoftware_host.ad — HOST driver + render harness for the "Software"
# app (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hampkgcore.ad) with the
# category sidebar TURNED ON and a FIXTURE package index — the exact plain-text
# lines `hpm search` / `hpm list` / `hpm show` emit — so the whole Synaptic-shape
# GUI (category rail + list + live search + detail pane) renders + hit-tests to
# PNGs a human/agent can LOOK at, all without a repo or QEMU. The native driver
# (user/hamsoftware.ad) feeds these same core parsers with REAL hpm output.
#
# USAGE (built to build/host/hamsoftware_host):
#   hamsoftware_host LIST.ppm CAT.ppm DETAIL.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hampkgcore import hampkg_init, hampkg_build_scene, hampkg_reset_list, \
    hampkg_installed_reset, hampkg_add_search_line, hampkg_mark_installed_line, \
    hampkg_detail_reset, hampkg_detail_line, hampkg_set_search, \
    hampkg_hit, hampkg_count, hampkg_filt_count, hampkg_sel_pkg, \
    hampkg_selected_name, hampkg_selected_name_len, hampkg_set_status, \
    hampkg_set_sidebar, hampkg_cat, hampkg_cat_count, hampkg_add_pkg, \
    hampkg_set_size


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _feed_search(s: Ptr[uint8]):
    hampkg_add_search_line(s, _slen(s))


def _feed_list(s: Ptr[uint8]):
    hampkg_mark_installed_line(s, _slen(s))


def _feed_detail(s: Ptr[uint8]):
    hampkg_detail_line(s, _slen(s))


def _render(w: int32, h: int32) -> int32:
    hampkg_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]]("usage: hamsoftware_host LIST.ppm CAT.ppm DETAIL.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 772                                       # 640 + SIDE_W (132)
    H: int32 = 430
    hampkg_init()
    hampkg_set_sidebar(1)                                # enable the category rail

    # ---- fixture index: exactly what `hpm search ""` prints -------------
    hampkg_reset_list()
    _feed_search(cast[Ptr[uint8]]("hamnix-base  1.0  -  core system base"))
    _feed_search(cast[Ptr[uint8]]("hamnix-desktop  1.0  -  MATE-style desktop environment"))
    _feed_search(cast[Ptr[uint8]]("hambrowse  0.9  -  native web browser"))
    _feed_search(cast[Ptr[uint8]]("hamnix-hamnotes  1.0  -  sticky-note scratchpad"))
    _feed_search(cast[Ptr[uint8]]("hamnix-hamcalc  1.0  -  calculator"))
    _feed_search(cast[Ptr[uint8]]("webkitgtk  4.1  -  web content engine"))

    # ---- installed state: what `hpm list` prints ------------------------
    # hambrowse is installed at 0.8 while 0.9 is available => UPGRADABLE.
    hampkg_installed_reset()
    _feed_list(cast[Ptr[uint8]]("hamnix-base  1.0  #hamnix-system"))
    _feed_list(cast[Ptr[uint8]]("hamnix-hamnotes  1.0  #hamnix-system"))
    _feed_list(cast[Ptr[uint8]]("hambrowse  0.8  #hamnix-system"))

    hampkg_set_status(cast[Ptr[uint8]]("6 packages in the index"), 23)

    # ---- (1) full list view (category = All) ----------------------------
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("COUNT "))
    _o_dec(cast[int64](hampkg_count()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("FILT_ALL "))
    _o_dec(cast[int64](hampkg_filt_count()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CAT_ALL "))
    _o_dec(cast[int64](hampkg_cat_count(0)))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CAT_INST "))
    _o_dec(cast[int64](hampkg_cat_count(1)))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CAT_AVAIL "))
    _o_dec(cast[int64](hampkg_cat_count(2)))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CAT_UPGRAD "))
    _o_dec(cast[int64](hampkg_cat_count(3)))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_dec(cast[int64](hamui_host_pixel(4, 4)))          # header bar pixel
    _o_ch(10)
    _o_flush()

    # ---- (2) click the "Installed" category row in the sidebar ----------
    # sidebar rows sit at x 0..132, y = 106 + row*30; "Installed" = row 1.
    chit: int32 = hampkg_hit(40, 145)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("CAT_HIT "))
    _o_dec(cast[int64](chit))                            # expect 6 (category change)
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CAT_SEL "))
    _o_dec(cast[int64](hampkg_cat()))                    # expect 1 (Installed)
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("FILT_INST "))
    _o_dec(cast[int64](hampkg_filt_count()))             # expect 3 installed
    _o_ch(10)
    _o_flush()

    # ---- (3) back to All, select a package + show its detail pane --------
    hampkg_hit(40, 115)                                  # sidebar row 0 = All
    hampkg_set_search(cast[Ptr[uint8]](""), 0)           # clear text filter
    _render(W, H)                                        # rebuild filt (full)
    # list is shifted right by SIDE_W; click row 2 = hambrowse (x in list col)
    hres: int32 = hampkg_hit(160, 184)
    _o_str(cast[Ptr[uint8]]("HIT "))
    _o_dec(cast[int64](hres))                            # 5 = row-selected
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEL "))
    _o_dec(cast[int64](hampkg_sel_pkg()))                # expect index 2
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEL_NAME "))
    _o_flush()
    sys_write(1, hampkg_selected_name(), hampkg_selected_name_len())
    sys_write(1, cast[Ptr[uint8]]("\n"), 1)

    # feed the `hpm show hambrowse` output into the detail pane
    hampkg_detail_reset()
    _feed_detail(cast[Ptr[uint8]]("name: hambrowse"))
    _feed_detail(cast[Ptr[uint8]]("version: 0.9"))
    _feed_detail(cast[Ptr[uint8]]("size: 512000"))
    _feed_detail(cast[Ptr[uint8]]("target: #hamnix-system"))
    _feed_detail(cast[Ptr[uint8]]("depends: webkitgtk, hamnix-base"))
    _feed_detail(cast[Ptr[uint8]]("description: native web browser"))
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- (4) installed-app REGISTRY scenario ----------------------------
    # The native driver (user/hamsoftware.ad) enumerates /etc/hamde/apps/
    # *.desktop into the SAME core via hampkg_add_pkg — one installed row per
    # app, so the window is populated with every installed app OFFLINE (no
    # `hpm refresh` needed). p9_listdir is native-only, so here we drive the
    # exact core API the scan uses with a registry-shaped fixture: friendly
    # display Names (INCLUDING multi-word "Coin Dash" / "Control Center" that
    # the whitespace-splitting search-line parser would truncate) each added
    # as an installed package. Proves the app enumerates >1 distinct app and
    # keeps multi-word names intact.
    hampkg_reset_list()
    hampkg_add_pkg(cast[Ptr[uint8]]("Snake"), 5,
                   cast[Ptr[uint8]]("app"), 3,
                   cast[Ptr[uint8]]("Games"), 5, 1)
    hampkg_add_pkg(cast[Ptr[uint8]]("Tetris"), 6,
                   cast[Ptr[uint8]]("app"), 3,
                   cast[Ptr[uint8]]("Games"), 5, 1)
    hampkg_add_pkg(cast[Ptr[uint8]]("Coin Dash"), 9,
                   cast[Ptr[uint8]]("app"), 3,
                   cast[Ptr[uint8]]("Games"), 5, 1)
    hampkg_add_pkg(cast[Ptr[uint8]]("Chess"), 5,
                   cast[Ptr[uint8]]("app"), 3,
                   cast[Ptr[uint8]]("Games"), 5, 1)
    hampkg_add_pkg(cast[Ptr[uint8]]("Terminal"), 8,
                   cast[Ptr[uint8]]("app"), 3,
                   cast[Ptr[uint8]]("System"), 6, 1)
    hampkg_add_pkg(cast[Ptr[uint8]]("Text Editor"), 11,
                   cast[Ptr[uint8]]("app"), 3,
                   cast[Ptr[uint8]]("Accessories"), 11, 1)
    hampkg_add_pkg(cast[Ptr[uint8]]("Control Center"), 14,
                   cast[Ptr[uint8]]("app"), 3,
                   cast[Ptr[uint8]]("Settings"), 8, 1)
    _render(W, H)
    _o_str(cast[Ptr[uint8]]("REG_COUNT "))
    _o_dec(cast[int64](hampkg_count()))                  # expect 7
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("REG_INST "))
    _o_dec(cast[int64](hampkg_cat_count(1)))             # all 7 installed
    _o_ch(10)
    # click list row 2 (offset past sidebar) -> "Coin Dash" selected, whole
    # multi-word name preserved (would be "Coin" if tokenised).
    hampkg_hit(160, 184)
    _o_str(cast[Ptr[uint8]]("REG_SEL_NAME "))
    _o_flush()
    sys_write(1, hampkg_selected_name(), hampkg_selected_name_len())
    sys_write(1, cast[Ptr[uint8]]("\n"), 1)
    _o_flush()

    # ---- (5) MAXIMIZE: a compositor resize event grows the content rect; the
    # scene must STRETCH to fill (no gaps to the right of / below the fixed
    # design size). Drive hampkg_set_size like the native driver does on an
    # `r <w> <h>` event, render at the new size, and dump the scene so the gate
    # can assert the background + status bar fill the maximized window. ------
    hampkg_set_size(1024, 700)
    _render(1024, 700)
    _o_str(cast[Ptr[uint8]]("SCENE-MAX-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-MAX-END\n"))
    _o_flush()
    return 0

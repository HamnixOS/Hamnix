# user/hamnotes_click_host.ad — HOST, QEMU-free gate for the #315 click-to-
# position + selection wiring in the Notes app (lib/hamnotescore.ad). Built for
# x86_64-linux; runs on the dev host in milliseconds.
#
# It seeds a known title + multi-line body, then drives the SAME hit-test the
# compositor feeds pointer events into (hamnotes_hit / hamnotes_drag) at pixels
# computed from the PROPORTIONAL glyph advances, and asserts the caret lands on
# the clicked glyph (NOT pinned to the buffer end — the user-reported bug) and
# that a click-drag builds the right selection range. Two PPMs are written to
# LOOK at: the title field with a MID-TEXT caret, and the body with a selection
# highlight band.
#
# USAGE (built to build/host/hamnotes_click):
#   hamnotes_click TITLE.ppm BODY.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes
from lib.hamtextbox import htb_text_width
from lib.hamnotescore import hamnotes_build_scene, hamnotes_set_text, \
    hamnotes_set_cur_title, hamnotes_hit, hamnotes_drag, hamnotes_title_caret, \
    hamnotes_body_caret, hamnotes_focus, hamnotes_sel_active, hamnotes_sel_len, \
    hamnotes_title_ptr, hamnotes_text_ptr

# Layout constants (mirror lib/hamnotescore.ad — text left edges + row pitch).
_TIT_TX: int32 = 158            # TIT_X + 6
_TIT_TY: int32 = 76             # TIT_Y + 6
_BODY_TX: int32 = 156           # TA_X + 4
_BODY_TY: int32 = 104           # TA_Y + 4
_LINE_H: int32 = 16

_W: int32 = 480
_H: int32 = 300

obuf: Array[256, uint8]
obuf_n: uint64 = 0
fail: int32 = 0


def _o_ch(c: uint8):
    if obuf_n < 255:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _expect(name: Ptr[uint8], got: int64, want: int64):
    if got == want:
        _o_str(cast[Ptr[uint8]]("PASS "))
    else:
        _o_str(cast[Ptr[uint8]]("FAIL "))
        fail = 1
    _o_str(name)
    _o_str(cast[Ptr[uint8]](" got="))
    _o_dec(got)
    _o_str(cast[Ptr[uint8]](" want="))
    _o_dec(want)
    _o_ch(10)
    _o_flush()


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]):
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return
    hamnotes_build_scene()
    hamui_host_begin(_W, _H)
    hamui_host_rasterize()
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)


# Pixel X of the caret sitting before glyph `k` of a run whose left edge is x0.
def _caret_px(x0: int32, buf: Ptr[uint8], k: uint64) -> int32:
    return x0 + htb_text_width(buf, k)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamnotes_click TITLE.ppm BODY.ppm\n"))
        _o_flush()
        return 2

    # Seed a known note: title "Groceries", body "Buy milk\nCall Sam".
    ttl: Ptr[uint8] = cast[Ptr[uint8]]("Groceries")
    hamnotes_set_cur_title(ttl, 9)
    body: Ptr[uint8] = cast[Ptr[uint8]]("Buy milk\nCall Sam")
    hamnotes_set_text(body, 17)

    tp: Ptr[uint8] = hamnotes_title_ptr()
    bp: Ptr[uint8] = hamnotes_text_ptr()

    # ---- (1) TITLE click-to-position: click at caret-4's pixel -> caret 4 ---
    # (Groc|eries) — proves the caret is NOT stuck at the end (9).
    px4: int32 = _caret_px(_TIT_TX, tp, 4)
    hamnotes_hit(cast[int64](px4), cast[int64](_TIT_TY))
    _expect(cast[Ptr[uint8]]("title_focus"), cast[int64](hamnotes_focus()), 1)
    _expect(cast[Ptr[uint8]]("title_caret_mid"),
            cast[int64](hamnotes_title_caret()), 4)
    # a click PAST the end clamps to the last glyph, never overshoots.
    pend: int32 = _caret_px(_TIT_TX, tp, 9) + 40
    hamnotes_hit(cast[int64](pend), cast[int64](_TIT_TY))
    _expect(cast[Ptr[uint8]]("title_caret_end"),
            cast[int64](hamnotes_title_caret()), 9)

    # put the caret back mid-text for the screenshot.
    hamnotes_hit(cast[int64](px4), cast[int64](_TIT_TY))
    _write_ppm(cast[Ptr[char]](argv[1]))               # TITLE.ppm: caret in "Groc|eries"

    # ---- (2) BODY click-to-position on the SECOND visual row --------------
    # Row1 = "Call Sam" starting at buffer index 9. Click at col 4 ("Call|").
    row1: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](bp) + 9)
    by: int32 = _BODY_TY + _LINE_H                        # second row
    bpx4: int32 = _caret_px(_BODY_TX, row1, 4)
    hamnotes_hit(cast[int64](bpx4), cast[int64](by))
    _expect(cast[Ptr[uint8]]("body_focus"), cast[int64](hamnotes_focus()), 0)
    _expect(cast[Ptr[uint8]]("body_caret_row1_col4"),
            cast[int64](hamnotes_body_caret()), 13)     # 9 + 4

    # ---- (3) BODY selection: press at col0, drag to col4 -> [9,13) ---------
    bpx0: int32 = _caret_px(_BODY_TX, row1, 0)
    hamnotes_hit(cast[int64](bpx0), cast[int64](by))    # press: caret+anchor at 9
    _expect(cast[Ptr[uint8]]("body_press_col0"),
            cast[int64](hamnotes_body_caret()), 9)
    hamnotes_drag(cast[int64](bpx4), cast[int64](by))   # drag to 13
    _expect(cast[Ptr[uint8]]("body_sel_active"),
            cast[int64](hamnotes_sel_active()), 1)
    _expect(cast[Ptr[uint8]]("body_sel_len"),
            cast[int64](hamnotes_sel_len()), 4)          # "Call"
    _write_ppm(cast[Ptr[char]](argv[2]))               # BODY.ppm: "Call" highlighted

    if fail != 0:
        _o_str(cast[Ptr[uint8]]("[notes-click] RESULT FAIL\n"))
    else:
        _o_str(cast[Ptr[uint8]]("[notes-click] RESULT PASS\n"))
    _o_flush()
    return fail

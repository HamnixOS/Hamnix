# user/hambrowse_gfx_window.ad — HOST driver that renders a COMPLETE browser
# WINDOW (chrome + scrolled page viewport) exactly as the native on-device
# browser does, and dumps it to a PPM/PNG for eyeballing.
#
# Where user/hambrowse_host_gfx.ad renders only the bare document canvas, this
# drives the SHARED window compositor lib/browserwin.ad — the very function
# user/hambrowse.ad's emit() calls to paint the compositor v2 blit backbuffer —
# into a plain BSS RGBA buffer. So build/host/gfx_native_browser.png is a
# faithful, QEMU-free preview of the on-device window: proportional AA text, a
# real decoded PNG <img>, and the title/address/status chrome.
#
# Built for x86_64-linux. No sockets / Plan 9: reads argv + font/HTML files and
# writes one PPM.
#
#   hambrowse_gfx_window FILE.html OUT.ppm [WIDTH] [HEIGHT]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.htmlengine import he_layout, he_n_images, he_img_name_ptr, \
    he_img_name_len
from lib.htmlpage import htmlpage_render, htmlpage_doc_height
from lib.htmlpaint import htmlpaint_load_ttf
from lib.font_ttf import FACE_TT_SANS, FACE_TT_SANS_BOLD, FACE_TT_SERIF, \
    FACE_TT_MONO
from lib.png import png_decode, png_width, png_height, png_rgba_ptr
from lib.htmlimg import htmlimg_reset, htmlimg_add
from lib.browserwin import browserwin_paint


FILE_CAP: uint64 = 262144
html_buf: Array[262144, uint8]
FONT_CAP: uint64 = 262144
ttsans_buf:  Array[262144, uint8]
ttsansb_buf: Array[262144, uint8]
ttserif_buf: Array[262144, uint8]
ttmono_buf:  Array[262144, uint8]
png_file_buf: Array[262144, uint8]
img_path: Array[1024, uint8]

# The composited window buffer (RGBA8888) + the RGB scratch for the PPM body.
WIN_MAX_W: uint64 = 1000
WIN_MAX_H: uint64 = 800
win_rgba: Array[3200000, uint8]     # 1000*800*4
ppm_rgb:  Array[2400000, uint8]     # 1000*800*3
ppm_hdr:  Array[64, uint8]


def _slurp(path: Ptr[char], dst: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        return -1
    got: uint64 = 0
    while got < cap - 1:
        n: int64 = sys_read(fd, &dst[got], cap - 1 - got)
        if n <= 0:
            break
        got = got + cast[uint64](n)
    sys_close(fd)
    return cast[int64](got)


def _atoi(s: Ptr[uint8]) -> int32:
    v: int32 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[int32](s[i]) - 48
        i = i + 1
    return v


# Resolve an <img src> against the HTML file's directory (mirror of the host gfx
# driver): absolute "/..." verbatim, else joined onto the dir of htmlpath; strip
# a "file://" prefix.
def _resolve_img_path(htmlpath: Ptr[char], src: Ptr[uint8], slen: uint64):
    soff: uint64 = 0
    if slen >= 7 and src[0] == 102 and src[1] == 105 and src[2] == 108 and \
       src[3] == 101 and src[4] == 58 and src[5] == 47 and src[6] == 47:
        soff = 7
    p: uint64 = 0
    if slen > soff and src[soff] == 47:
        j: uint64 = soff
        while j < slen and p < 1023:
            img_path[p] = src[j]
            p = p + 1
            j = j + 1
    else:
        hp: Ptr[uint8] = cast[Ptr[uint8]](htmlpath)
        i: uint64 = 0
        last_slash: int64 = -1
        while hp[i] != 0:
            if hp[i] == 47:
                last_slash = cast[int64](i)
            i = i + 1
        k: uint64 = 0
        while cast[int64](k) <= last_slash and p < 1023:
            img_path[p] = hp[k]
            p = p + 1
            k = k + 1
        j2: uint64 = soff
        while j2 < slen and p < 1023:
            img_path[p] = src[j2]
            p = p + 1
            j2 = j2 + 1
    img_path[p] = 0


def _decode_images(htmlpath: Ptr[char]):
    htmlimg_reset()
    ni: uint64 = he_n_images()
    idx: uint64 = 0
    while idx < ni:
        nm: Ptr[uint8] = he_img_name_ptr(idx)
        nl: uint64 = he_img_name_len(idx)
        _resolve_img_path(htmlpath, nm, nl)
        got: int64 = _slurp(cast[Ptr[char]](&img_path[0]), &png_file_buf[0],
                            FILE_CAP)
        if got > 0:
            if png_decode(&png_file_buf[0], cast[uint64](got)) == 0:
                htmlimg_add(nm, nl, png_width(), png_height(), png_rgba_ptr())
        idx = idx + 1


def _write_ppm(path: Ptr[char], w: int32, h: int32) -> int32:
    fd: int32 = sys_open(path, 577, 420)             # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    p: uint64 = 0
    ppm_hdr[p] = 80                                  # 'P'
    p = p + 1
    ppm_hdr[p] = 54                                  # '6'
    p = p + 1
    ppm_hdr[p] = 10
    p = p + 1
    p = p + _dec(w, &ppm_hdr[p])
    ppm_hdr[p] = 32
    p = p + 1
    p = p + _dec(h, &ppm_hdr[p])
    ppm_hdr[p] = 10
    p = p + 1
    ppm_hdr[p] = 50                                  # '2'
    p = p + 1
    ppm_hdr[p] = 53                                  # '5'
    p = p + 1
    ppm_hdr[p] = 53                                  # '5'
    p = p + 1
    ppm_hdr[p] = 10
    p = p + 1
    sys_write(fd, &ppm_hdr[0], p)
    # Repack RGBA -> RGB.
    npx: uint64 = cast[uint64](w) * cast[uint64](h)
    i: uint64 = 0
    while i < npx:
        ppm_rgb[i * 3]     = win_rgba[i * 4]
        ppm_rgb[i * 3 + 1] = win_rgba[i * 4 + 1]
        ppm_rgb[i * 3 + 2] = win_rgba[i * 4 + 2]
        i = i + 1
    sys_write(fd, &ppm_rgb[0], npx * 3)
    sys_close(fd)
    return 0


def _dec(v: int32, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    x: uint32 = cast[uint32](v)
    digs: Array[16, uint8]
    n: uint64 = 0
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    w: uint64 = n
    j: uint64 = 0
    while n > 0:
        n = n - 1
        out[j] = digs[n]
        j = j + 1
    return w


# stdout helpers for the gate dump.
obuf: Array[256, uint8]


def _o_line(s: Ptr[uint8], v: int64):
    p: uint64 = 0
    while s[p] != 0:
        obuf[p] = s[p]
        p = p + 1
    if v < 0:
        obuf[p] = 45
        p = p + 1
        v = 0 - v
    p = p + _dec(cast[int32](v), &obuf[p])
    obuf[p] = 10
    p = p + 1
    sys_write(1, &obuf[0], p)


# Sample a window pixel: "PIX x y R G B".
def _pix(x: int32, y: int32, w: int32):
    o: uint64 = (cast[uint64](y) * cast[uint64](w) + cast[uint64](x)) * 4
    b: Array[64, uint8]
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("PIX ")
    while pre[p] != 0:
        b[p] = pre[p]
        p = p + 1
    p = p + _dec(x, &b[p])
    b[p] = 32
    p = p + 1
    p = p + _dec(y, &b[p])
    b[p] = 32
    p = p + 1
    p = p + _dec(cast[int32](win_rgba[o]), &b[p])
    b[p] = 32
    p = p + 1
    p = p + _dec(cast[int32](win_rgba[o + 1]), &b[p])
    b[p] = 32
    p = p + 1
    p = p + _dec(cast[int32](win_rgba[o + 2]), &b[p])
    b[p] = 10
    p = p + 1
    sys_write(1, &b[0], p)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        sys_write(2, cast[Ptr[uint8]]("usage: hambrowse_gfx_window FILE.html OUT.ppm [W] [H]\n"), 54)
        return 2
    htmlp: Ptr[char] = cast[Ptr[char]](argv[1])
    outp: Ptr[char] = cast[Ptr[char]](argv[2])

    win_w: int32 = 880
    win_h: int32 = 600
    if argc >= 4:
        t: int32 = _atoi(cast[Ptr[uint8]](argv[3]))
        if t >= 200 and cast[uint64](t) <= WIN_MAX_W:
            win_w = t
    if argc >= 5:
        t2: int32 = _atoi(cast[Ptr[uint8]](argv[4]))
        if t2 >= 200 and cast[uint64](t2) <= WIN_MAX_H:
            win_h = t2

    # Fonts (the pixel renderer needs the TrueType faces).
    ts: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-sans.ttf"), &ttsans_buf[0], FONT_CAP)
    tb: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-sans-bold.ttf"), &ttsansb_buf[0], FONT_CAP)
    tr: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-serif.ttf"), &ttserif_buf[0], FONT_CAP)
    tm: int64 = _slurp(cast[Ptr[char]]("fonts/dejavu-mono.ttf"), &ttmono_buf[0], FONT_CAP)
    if ts <= 0 or tb <= 0 or tr <= 0 or tm <= 0:
        sys_write(2, cast[Ptr[uint8]]("cannot read fonts/*.ttf\n"), 24)
        return 1
    htmlpaint_load_ttf(FACE_TT_SANS, &ttsans_buf[0], cast[uint64](ts))
    htmlpaint_load_ttf(FACE_TT_SANS_BOLD, &ttsansb_buf[0], cast[uint64](tb))
    htmlpaint_load_ttf(FACE_TT_SERIF, &ttserif_buf[0], cast[uint64](tr))
    htmlpaint_load_ttf(FACE_TT_MONO, &ttmono_buf[0], cast[uint64](tm))

    # HTML.
    hn: int64 = _slurp(htmlp, &html_buf[0], FILE_CAP)
    if hn < 0:
        sys_write(2, cast[Ptr[uint8]]("cannot open HTML\n"), 17)
        return 1

    # Constrain the engine's page width to the window content width so the
    # laid-out column matches what the window shows.
    bw = win_w
    bh = win_h
    src_ptr = &html_buf[0]
    src_len = cast[uint64](hn)

    # Two-pass layout around image decode (record <img> -> decode -> size boxes).
    he_layout()
    _decode_images(htmlp)
    he_layout()
    doc_h: int32 = htmlpage_render()

    # Composite the full window via the SHARED compositor (same code as native).
    # Optional args 6/7 drive the Back/Forward button state so the chrome's
    # nav-history rendering (enabled vs greyed) can be eyeballed on the host.
    addr: Ptr[uint8] = cast[Ptr[uint8]]("file://tests/fixtures/page.html")
    status: Ptr[uint8] = cast[Ptr[uint8]]("host parity render")
    can_back: int32 = 0
    can_fwd: int32 = 0
    if argc >= 6:
        can_back = _atoi(cast[Ptr[uint8]](argv[5]))
    if argc >= 7:
        can_fwd = _atoi(cast[Ptr[uint8]](argv[6]))
    # #315: optional args 8/9 = URL selection [lo,hi); when present the address
    # bar renders FOCUSED with the span highlighted + a caret, so the host PNG
    # proves the URL-selection rendering (else unfocused, caret at end).
    addr_focus: int32 = 0
    sel_lo: int32 = 0
    sel_hi: int32 = 0
    if argc >= 9:
        sel_lo = _atoi(cast[Ptr[uint8]](argv[7]))
        sel_hi = _atoi(cast[Ptr[uint8]](argv[8]))
        if sel_hi > sel_lo:
            addr_focus = 1
    a_sel: int32 = 0
    if addr_focus != 0 and sel_hi > sel_lo:
        a_sel = 1
    browserwin_paint(&win_rgba[0], win_w, win_h, win_w, win_h, 0, doc_h,
                     addr, _slen(addr), addr_focus, status, _slen(status),
                     can_back, can_fwd, cast[uint64](sel_hi), a_sel,
                     cast[uint64](sel_lo), cast[uint64](sel_hi))
    _o_line(cast[Ptr[uint8]]("CANBACK "), cast[int64](can_back))
    _o_line(cast[Ptr[uint8]]("CANFWD "), cast[int64](can_fwd))

    _o_line(cast[Ptr[uint8]]("WIN "), cast[int64](win_w))
    _o_line(cast[Ptr[uint8]]("WINH "), cast[int64](win_h))
    _o_line(cast[Ptr[uint8]]("DOCH "), cast[int64](doc_h))
    # Sample a title-bar pixel (should be the dark blue chrome) and a content
    # pixel band so the gate can assert chrome vs page.
    _pix(2, 2, win_w)
    _pix(win_w / 2, 60, win_w)

    if _write_ppm(outp, win_w, win_h) != 0:
        sys_write(2, cast[Ptr[uint8]]("cannot write PPM\n"), 17)
        return 1
    _o_line(cast[Ptr[uint8]]("WROTE "), cast[int64](win_w) * cast[int64](win_h) * 3)
    return 0


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n

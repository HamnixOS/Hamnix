# user/hamnotesscene_host.ad — HOST driver + render harness for the Notes
# scratchpad (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamnotescore.ad): renders the
# empty pad, then feeds a SCRIPTED string of keystrokes (each as the "d <code>"
# wire line the compositor delivers) through the pure key handler — including a
# backspace edit and a newline — and re-renders. Asserts the buffer length and
# dumps the scene + sampled pixels. Reads argv, writes two PPMs.
#
# USAGE (built to build/host/hamnotes_host):
#   hamnotes_host BEFORE.ppm AFTER.ppm [TEXT]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamnotescore import hamnotes_build_scene, hamnotes_key, \
    hamnotes_key_line, hamnotes_len, hamnotes_dirty, hamnotes_mark_saved


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamnotes_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Feed one keypress via the "d <code>" wire line (exercises the parser too).
kl: Array[16, uint8]


def _press(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    return hamnotes_key_line(&kl[0], p)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamnotes_host BEFORE.ppm AFTER.ppm [TEXT]\n"))
        _o_flush()
        return 2

    W: int32 = 360
    H: int32 = 280

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("LEN0 "))
    _o_dec(cast[int64](hamnotes_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))                  # sticky bar #c0a000
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 60 "))
    _o_hexcol(hamui_host_pixel(20, 60))                # paper #fffef0
    _o_ch(10)
    _o_flush()

    # ---- SCRIPTED KEYSTROKES --------------------------------------------
    # Default: "Buy milk" + Enter + "Call Sam" then a backspace edit.
    keys: Ptr[uint8] = cast[Ptr[uint8]]("Buy milk\nCall Sam")
    if argc >= 4:
        keys = cast[Ptr[uint8]](argv[3])
    i: uint64 = 0
    while keys[i] != 0:
        _press(cast[int32](keys[i]))
        i = i + 1
    # a backspace edit (deletes the trailing 'm' of "Sam")
    _press(8)

    _o_str(cast[Ptr[uint8]]("LEN1 "))
    _o_dec(cast[int64](hamnotes_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DIRTY "))
    _o_dec(cast[int64](hamnotes_dirty()))
    _o_ch(10)
    hamnotes_mark_saved()
    _o_str(cast[Ptr[uint8]]("DIRTY_AFTER_SAVE "))
    _o_dec(cast[int64](hamnotes_dirty()))
    _o_ch(10)
    _o_flush()

    # Re-render WITH the typed text, then dump the fresh scene + write the PPM.
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()
    return 0

# user/hamnotesscene_host.ad — HOST driver + render harness for the Notes app
# (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamnotescore.ad) AND exercises
# the persistence end-to-end against the REAL host filesystem: it points the
# notes root at a scratch dir, renders the empty pad, types a scripted note,
# fires SAVE (Ctrl-S) which writes note-0.txt, fires NEW (Ctrl-N) which starts
# a blank note-1, then pages back (Prev) which RELOADS note-0 off disk — proving
# a saved note survives leaving it. Four PPMs are written for a human/agent to
# LOOK at, and the on-disk byte counts + buffer lengths are dumped for asserts.
#
# USAGE (built to build/host/hamnotes_host):
#   hamnotes_host ROOTDIR BEFORE.ppm AFTER.ppm NEW.ppm RELOAD.ppm [TEXT]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamnotescore import hamnotes_build_scene, hamnotes_key, \
    hamnotes_key_line, hamnotes_len, hamnotes_dirty, hamnotes_mark_saved, \
    hamnotes_set_root, hamnotes_set_text, hamnotes_text_ptr, \
    hamnotes_take_action, hamnotes_new_note, hamnotes_switch, \
    hamnotes_flash_saved, hamnotes_cur_idx, hamnotes_notepath, \
    hamnotes_statepath, hamnotes_state_encode, hamnotes_state_decode


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamnotes_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# ---- host-side persistence (mirrors user/hamnotesscene.ad) ----------------
path_buf: Array[192, uint8]
state_buf: Array[48, uint8]
load_buf: Array[2048, uint8]


def _save_current():
    hamnotes_notepath(&path_buf[0], hamnotes_cur_idx())
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]), 577, 420)
    if fd < 0:
        return
    sys_write(fd, hamnotes_text_ptr(), hamnotes_len())
    sys_close(fd)
    hamnotes_mark_saved()


def _load_current():
    hamnotes_notepath(&path_buf[0], hamnotes_cur_idx())
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]), 0, 0)   # O_RDONLY
    if fd < 0:
        hamnotes_set_text(&load_buf[0], 0)
        return
    total: uint64 = 0
    while total < 2048:
        r: int64 = sys_read(fd, &load_buf[total], 2048 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    hamnotes_set_text(&load_buf[0], total)


def _save_state():
    hamnotes_statepath(&path_buf[0])
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]), 577, 420)
    if fd < 0:
        return
    n: uint64 = hamnotes_state_encode(&state_buf[0])
    sys_write(fd, &state_buf[0], n)
    sys_close(fd)


# Read note-<idx>.txt straight off disk into a scratch buffer; returns length.
raw_buf: Array[2048, uint8]


def _read_file_len(idx: int32) -> int64:
    hamnotes_notepath(&path_buf[0], idx)
    fd: int32 = sys_open(cast[Ptr[char]](&path_buf[0]), 0, 0)
    if fd < 0:
        return -1
    total: int64 = 0
    while total < 2048:
        r: int64 = sys_read(fd, &raw_buf[total], 2048 - cast[uint64](total))
        if r <= 0:
            break
        total = total + r
    sys_close(fd)
    return total


def _dispatch(act: int32):
    if act == 1:                                       # Save
        _save_current()
        _save_state()
        hamnotes_flash_saved()
    elif act == 2:                                     # New
        _save_current()
        hamnotes_new_note()
        _save_current()
        _save_state()
    elif act == 3:                                     # Prev
        _save_current()
        hamnotes_switch(-1)
        _load_current()
        _save_state()
    elif act == 4:                                     # Next
        _save_current()
        hamnotes_switch(1)
        _load_current()
        _save_state()


# Feed one keypress via the "d <code>" wire line (exercises the parser too),
# then drain + dispatch any action it requested. Returns 1 if the buffer/state
# changed.
kl: Array[16, uint8]


def _press(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    ch: int32 = hamnotes_key_line(&kl[0], p)
    if ch == 1:
        act: int32 = hamnotes_take_action()
        if act != 0:
            _dispatch(act)
    return ch


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 6:
        _o_str(cast[Ptr[uint8]]("usage: hamnotes_host ROOTDIR BEFORE.ppm AFTER.ppm NEW.ppm RELOAD.ppm [TEXT]\n"))
        _o_flush()
        return 2

    hamnotes_set_root(cast[Ptr[uint8]](argv[1]))

    W: int32 = 360
    H: int32 = 280

    # ---- (1) empty pad: toolbar + blank paper --------------------------
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("LEN0 "))
    _o_dec(cast[int64](hamnotes_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_hexcol(hamui_host_pixel(4, 4))                  # sticky bar #c0a000
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 20 120 "))
    _o_hexcol(hamui_host_pixel(20, 120))               # paper #fffef0
    _o_ch(10)
    _o_flush()

    # ---- (2) type a scripted note + a backspace edit -------------------
    keys: Ptr[uint8] = cast[Ptr[uint8]]("Buy milk\nCall Sam")
    if argc >= 7:
        keys = cast[Ptr[uint8]](argv[6])
    i: uint64 = 0
    while keys[i] != 0:
        _press(cast[int32](keys[i]))
        i = i + 1
    _press(8)                                          # backspace: "Sam"->"Sa"

    _o_str(cast[Ptr[uint8]]("LEN1 "))
    _o_dec(cast[int64](hamnotes_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DIRTY "))
    _o_dec(cast[int64](hamnotes_dirty()))
    _o_ch(10)

    # ---- (3) SAVE (Ctrl-S) then confirm bytes hit the disk -------------
    _press(19)                                         # Ctrl-S -> _dispatch save
    _o_str(cast[Ptr[uint8]]("DIRTY_AFTER_SAVE "))
    _o_dec(cast[int64](hamnotes_dirty()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("FILE0_LEN "))
    _o_dec(_read_file_len(0))                          # bytes persisted for note-0
    _o_ch(10)
    _o_flush()

    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))               # AFTER.ppm: saved note

    # ---- (4) NEW (Ctrl-N): fresh blank note ----------------------------
    _press(14)                                         # Ctrl-N -> _dispatch new
    _o_str(cast[Ptr[uint8]]("LEN_AFTER_NEW "))
    _o_dec(cast[int64](hamnotes_len()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("IDX_AFTER_NEW "))
    _o_dec(cast[int64](hamnotes_cur_idx()))
    _o_ch(10)
    _o_flush()

    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[4]))               # NEW.ppm: blank pad

    # ---- (5) page back (Prev): RELOAD note-0 from disk -----------------
    _dispatch(3)                                        # Prev -> load note-0
    _o_str(cast[Ptr[uint8]]("IDX_AFTER_PREV "))
    _o_dec(cast[int64](hamnotes_cur_idx()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("LEN_AFTER_RELOAD "))
    _o_dec(cast[int64](hamnotes_len()))
    _o_ch(10)
    _o_flush()

    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[5]))               # RELOAD.ppm: note-0 back

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()
    return 0

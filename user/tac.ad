# user/tac.ad
#
# Hamnix `tac`: write stdin to stdout LAST line first (the reverse of
# `cat`). Each line keeps its bytes in order; only the line ORDER is
# reversed. A trailing fragment without a final newline is treated as
# its own line and emitted (with a synthetic newline). Bounded by an
# 8 KiB stdin buffer and 512 tracked lines, mirroring tail.ad's model.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

INPUT_MAX: uint64 = 8192
INDEX_MAX: uint64 = 512

input_buf:   Array[8192, uint8]
line_starts: Array[512, uint32]
line_ends:   Array[512, uint32]    # exclusive end, NOT counting '\n'


def main() -> int32:
    total: uint64 = 0
    while total < INPUT_MAX:
        n: int64 = sys_read(0, &input_buf[total], INPUT_MAX - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)

    # Index lines. We store the content bounds (exclusive of '\n') so
    # we can re-emit each line followed by exactly one newline.
    nlines: uint64 = 0
    start: uint64 = 0
    i: uint64 = 0
    while i < total:
        if input_buf[i] == 10:
            line_starts[nlines] = cast[uint32](start)
            line_ends[nlines] = cast[uint32](i)
            nlines = nlines + 1
            if nlines >= INDEX_MAX:
                break
            start = i + 1
        i = i + 1
    if nlines < INDEX_MAX and start < total:
        line_starts[nlines] = cast[uint32](start)
        line_ends[nlines] = cast[uint32](total)
        nlines = nlines + 1

    # Emit in reverse.
    if nlines == 0:
        return 0
    idx: uint64 = nlines
    while idx > 0:
        idx = idx - 1
        s: uint32 = line_starts[idx]
        e: uint32 = line_ends[idx]
        if e > s:
            sys_write(1, &input_buf[s], cast[uint64](e - s))
        sys_write(1, "\n", 1)
    return 0

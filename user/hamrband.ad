# user/hamrband.ad
#
# hamrband — DE pivot wave 7: the rubber-band drag-to-create overlay
# extracted out of user/hamUId.ad's post_present_overlays into a
# standalone hamui v2 client (matches the wave-1..6 hampanel /
# hamappmenu / hamcycler / hamcalpop / hamrun / hamlock pattern).
#
# Wire model
# ----------
# 1. The compositor publishes the rubber-band model via the
#    `rband <active> <x0> <y0> <x1> <y1>` verb on /dev/wsys/ctl. The
#    snapshot is served at /dev/wsys/rband as one line:
#       "<set_serial> <active> <x0> <y0> <x1> <y1> <gen>\n"
# 2. The compositor spawns /bin/hamrband once at startup. On every drag
#    move the band rect changes; the compositor republishes the model
#    and bumps the set serial by writing to /dev/wsys/rband/set.
# 3. We open OUR /dev/wsys/<wid>/wctl, write "version 2\n" to opt into
#    the rio v2 blit protocol, then rasterise the dashed 1-pixel outline
#    rectangle into our backbuffer via the lib/hamui v2 API. The
#    compositor blits our backbuffer to /dev/fb each frame.
# 4. While `active` is 0 we leave the backbuffer cleared-to-black so the
#    overlay is "off". When `active` flips to 1 we paint the dashed
#    outline at (x0,y0)-(x1,y1) (clipped to the backbuffer).
#
# Why the gesture still lives in the compositor
# ---------------------------------------------
# Like the cycler/run/lock waves, only the RENDER moved out. The
# DRAG_ACTIVE state machine + DRAG_X0/Y0 anchor + the spawn-on-release
# decision still all live in user/hamUId.ad — those drive the kernel
# publishes that wake this client.
#
# WHAT THIS REPLACES
# ------------------
# The post-present scene_blit_rect_outline(rx0, ry0, rx1, ry1, 255,255,0)
# call inside post_present_overlays in user/hamUId.ad. That paint is
# gone; this file is its replacement.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2,
    hamui_v2_clear, hamui_v2_fill_rect, hamui_v2_commit_rect,
    hamui_v2_is_active,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


# --- model storage --------------------------------------------------
_hrb_active: int32 = 0
_hrb_x0: int64 = 0
_hrb_y0: int64 = 0
_hrb_x1: int64 = 0
_hrb_y1: int64 = 0
_hrb_gen: uint64 = 0
_hrb_set_serial:      uint64 = 0
_hrb_last_set_serial: uint64 = 0xffffffffffffffff
_hrb_last_gen:        uint64 = 0xffffffffffffffff


# --- layout (backbuffer is fixed at 320x200 in lib/hamui v2) --------
_hrb_WIN_W: int32 = 320
_hrb_WIN_H: int32 = 200


# --- scratch --------------------------------------------------------
_hrb_snap_buf: Array[256, uint8]


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


# --- snapshot parser ------------------------------------------------
def _read_rband_snapshot() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/rband"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_hrb_snap_buf[0], 256)
    sys_close(fd)
    return n


def _parse_u64(pos: Ptr[uint64], end: uint64) -> uint64:
    p: uint64 = pos[0]
    v: uint64 = 0
    while p < end and _hrb_snap_buf[p] >= 48 and _hrb_snap_buf[p] <= 57:
        v = v * 10 + cast[uint64](_hrb_snap_buf[p] - 48)
        p = p + 1
    pos[0] = p
    return v


def _skip_ws(pos: uint64, end: uint64) -> uint64:
    p: uint64 = pos
    while p < end and (_hrb_snap_buf[p] == 32 or _hrb_snap_buf[p] == 9):
        p = p + 1
    return p


def _parse_snapshot(n: uint64) -> int32:
    # Returns 1 if anything CHANGED since the last parse (gen or
    # set_serial differ), 0 otherwise.
    if n == 0:
        return 0
    pos: Array[1, uint64]
    pos[0] = 0
    set_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    active_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    x0_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    y0_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    x1_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    y1_v: uint64 = _parse_u64(&pos[0], n)
    pos[0] = _skip_ws(pos[0], n)
    gen_v: uint64 = _parse_u64(&pos[0], n)
    _hrb_set_serial = set_v
    _hrb_active = cast[int32](active_v)
    _hrb_x0 = cast[int64](x0_v)
    _hrb_y0 = cast[int64](y0_v)
    _hrb_x1 = cast[int64](x1_v)
    _hrb_y1 = cast[int64](y1_v)
    _hrb_gen = gen_v
    changed: int32 = 0
    if _hrb_set_serial != _hrb_last_set_serial:
        changed = 1
    if _hrb_gen != _hrb_last_gen:
        changed = 1
    _hrb_last_set_serial = _hrb_set_serial
    _hrb_last_gen = _hrb_gen
    return changed


# --- dashed-outline render -----------------------------------------
# A 1-pixel rectangle outline whose top + bottom + left + right edges
# are drawn as 4-on / 4-off dashed segments. Mirrors the legacy yellow
# (255,255,0) outline the compositor used to paint via
# scene_blit_rect_outline.
_hrb_DASH_ON: int32 = 4
_hrb_DASH_OFF: int32 = 4


def _clip_int(v: int64, lo: int32, hi: int32) -> int32:
    if v < cast[int64](lo):
        return lo
    if v > cast[int64](hi):
        return hi
    return cast[int32](v)


def _draw_dashed_h(x0: int32, x1: int32, y: int32,
                   r: uint8, g: uint8, b: uint8):
    if y < 0 or y >= _hrb_WIN_H:
        return
    period: int32 = _hrb_DASH_ON + _hrb_DASH_OFF
    x: int32 = x0
    while x < x1:
        run: int32 = _hrb_DASH_ON
        if x + run > x1:
            run = x1 - x
        if run > 0:
            hamui_v2_fill_rect(x, y, run, 1, r, g, b)
        x = x + period


def _draw_dashed_v(x: int32, y0: int32, y1: int32,
                   r: uint8, g: uint8, b: uint8):
    if x < 0 or x >= _hrb_WIN_W:
        return
    period: int32 = _hrb_DASH_ON + _hrb_DASH_OFF
    y: int32 = y0
    while y < y1:
        run: int32 = _hrb_DASH_ON
        if y + run > y1:
            run = y1 - y
        if run > 0:
            hamui_v2_fill_rect(x, y, 1, run, r, g, b)
        y = y + period


def _paint_off():
    # Band inactive: clear the backbuffer to black (the kernel-side
    # present is a no-op on an unchanged buffer).
    hamui_v2_clear(0, 0, 0)
    hamui_v2_commit_rect(0, 0, _hrb_WIN_W, _hrb_WIN_H)


def _paint_on():
    # Clear then paint the dashed outline. Coords arrive in absolute
    # screen pixels; clip to the backbuffer (the window is anchored at
    # screen (0,0) so backbuffer-local == screen-local for the top-left
    # 320x200 region).
    hamui_v2_clear(0, 0, 0)
    cx0: int32 = _clip_int(_hrb_x0, 0, _hrb_WIN_W)
    cy0: int32 = _clip_int(_hrb_y0, 0, _hrb_WIN_H)
    cx1: int32 = _clip_int(_hrb_x1, 0, _hrb_WIN_W)
    cy1: int32 = _clip_int(_hrb_y1, 0, _hrb_WIN_H)
    if cx1 <= cx0 or cy1 <= cy0:
        hamui_v2_commit_rect(0, 0, _hrb_WIN_W, _hrb_WIN_H)
        return
    # Yellow dashed edges, matching the legacy
    # scene_blit_rect_outline(.., 255, 255, 0) ink colour.
    r: uint8 = 255
    g: uint8 = 255
    b: uint8 = 0
    # Top + bottom edges (top inclusive, bottom = cy1-1).
    _draw_dashed_h(cx0, cx1, cy0, r, g, b)
    if cy1 - 1 != cy0:
        _draw_dashed_h(cx0, cx1, cy1 - 1, r, g, b)
    # Left + right edges (left inclusive, right = cx1-1).
    _draw_dashed_v(cx0, cy0, cy1, r, g, b)
    if cx1 - 1 != cx0:
        _draw_dashed_v(cx1 - 1, cy0, cy1, r, g, b)
    hamui_v2_commit_rect(0, 0, _hrb_WIN_W, _hrb_WIN_H)


def _paint():
    if _hrb_active != 0:
        _paint_on()
    else:
        _paint_off()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    # Self-discover OUR wid via /dev/wsys/self (same shape hamlock uses).
    # argv[1] may override for tests.
    wid: int32 = 1
    self_path: Ptr[uint8] = "/dev/wsys/self"
    sfd: int32 = sys_open(cast[Ptr[char]](self_path))
    if sfd >= 0:
        sbuf: Array[16, uint8]
        sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
        sys_close(sfd)
        if sn > 0:
            v: int32 = 0
            i: uint64 = 0
            while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                v = v * 10 + cast[int32](sbuf[i]) - 48
                i = i + 1
            if v >= 2:
                wid = v
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        v2: int32 = 0
        i2: uint64 = 0
        while ap[i2] >= 48 and ap[i2] <= 57:
            v2 = v2 * 10 + cast[int32](ap[i2]) - 48
            i2 = i2 + 1
        if v2 >= 1:
            wid = v2

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamrband: could not bind window\n")
        return 1
    if hamui_set_protocol_v2() < 0:
        _puts(2, "hamrband: v2 negotiate failed\n")
        return 1

    # Initial paint from whatever the compositor has already published.
    n0: int64 = _read_rband_snapshot()
    if n0 > 0:
        _parse_snapshot(cast[uint64](n0))
    _paint()
    rdy: Ptr[uint8] = "HAMRBAND ready\n"
    sys_write(1, rdy, _strlen(rdy))

    # Long-lived event loop: poll the snapshot. On a gen or set_serial
    # bump repaint. The compositor pokes /dev/wsys/rband/set whenever
    # the band state changes (no socket: we just resample the snapshot).
    while True:
        n: int64 = _read_rband_snapshot()
        if n > 0:
            if _parse_snapshot(cast[uint64](n)) != 0:
                _paint()
        sys_yield()

    return 0

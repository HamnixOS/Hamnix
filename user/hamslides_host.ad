# user/hamslides_host.ad — HOST driver + render harness for HamSlides, the office
# PRESENTATION app (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hamslidescore.ad) end-to-end
# against the REAL host filesystem: it builds a small DECK by typing a title +
# bullets through the KEY path, adds a second slide, asserts the deck model,
# renders the EDIT view (thumbnail rail + large current slide), SAVES it
# (Ctrl-S -> a HAMSLIDES1 container on disk), CLEARS the deck, then RE-OPENS the
# file off disk (Ctrl-O) — proving titles AND bullets survive a save->load
# round-trip. It then toggles PRESENT view and renders that too. Two PPMs
# (EDIT + PRESENT) are written for a human/agent to LOOK at.
#
# USAGE (built to build/host/hamslides_host):
#   hamslides_host DOCPATH EDIT.ppm PRESENT.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamslidescore import hamslides_init, hamslides_build_scene, \
    hamslides_set_fname, hamslides_key_line, hamslides_take_action, \
    hamslides_serialize, hamslides_deserialize, hamslides_clear, \
    hamslides_slide_count, hamslides_cur, hamslides_view, \
    hamslides_bullet_count, hamslides_title_ptr, hamslides_title_len, \
    hamslides_bullet_ptr, hamslides_bullet_len, hamslides_set_present


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hamslides_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# ---- host-side persistence (mirrors user/hamslides.ad) --------------------
ser_buf: Array[16384, uint8]
doc_path: Array[192, uint8]


def _set_docpath(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 191:
        doc_path[i] = s[i]
        i = i + 1
    doc_path[i] = 0


def _save_doc():
    fd: int32 = sys_open(cast[Ptr[char]](&doc_path[0]), 577, 420)
    if fd < 0:
        return
    n: uint64 = hamslides_serialize(&ser_buf[0])
    sys_write(fd, &ser_buf[0], n)
    sys_close(fd)


def _load_doc():
    fd: int32 = sys_open(cast[Ptr[char]](&doc_path[0]), 0, 0)   # O_RDONLY
    if fd < 0:
        hamslides_deserialize(&ser_buf[0], 0)
        return
    total: uint64 = 0
    while total < 16384:
        r: int64 = sys_read(fd, &ser_buf[total], 16384 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    hamslides_deserialize(&ser_buf[0], total)


raw_buf: Array[16384, uint8]


def _file_len() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]](&doc_path[0]), 0, 0)
    if fd < 0:
        return -1
    total: int64 = 0
    while total < 16384:
        r: int64 = sys_read(fd, &raw_buf[total], 16384 - cast[uint64](total))
        if r <= 0:
            break
        total = total + r
    sys_close(fd)
    return total


def _dispatch(act: int32):
    if act == 1:
        _save_doc()
    elif act == 2:
        _load_doc()


# Feed one keypress via the "d <code>" wire line, then drain+dispatch action.
kl: Array[16, uint8]


def _press(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code < 0:
        kl[p] = 45
        p = p + 1
        code = 0 - code
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    ch: int32 = hamslides_key_line(&kl[0], p)
    if ch == 1:
        act: int32 = hamslides_take_action()
        if act != 0:
            _dispatch(act)
    return ch


# Type a NUL-terminated ASCII string through the key path.
def _type(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _press(cast[int32](s[i]))
        i = i + 1


# Dump a title/bullet as `<tag> <text>`.
def _dump_title(tag: Ptr[uint8], s: uint64):
    _o_str(tag)
    _o_ch(32)
    ptr: Ptr[uint8] = hamslides_title_ptr(s)
    ln: uint64 = hamslides_title_len(s)
    i: uint64 = 0
    while i < ln:
        _o_ch(ptr[i])
        i = i + 1
    _o_ch(10)


def _dump_bullet(tag: Ptr[uint8], s: uint64, b: uint64):
    _o_str(tag)
    _o_ch(32)
    ptr: Ptr[uint8] = hamslides_bullet_ptr(s, b)
    ln: uint64 = hamslides_bullet_len(s, b)
    i: uint64 = 0
    while i < ln:
        _o_ch(ptr[i])
        i = i + 1
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]](
            "usage: hamslides_host DOCPATH EDIT.ppm PRESENT.ppm\n"))
        _o_flush()
        return 2

    _set_docpath(cast[Ptr[uint8]](argv[1]))
    hamslides_init()
    hamslides_set_fname(cast[Ptr[uint8]]("talk.hamslides"))

    W: int32 = 680
    H: int32 = 440

    # ---- (1) build slide 1 by TYPING through the key path --------------
    # Focus starts on the title. Type a title, Enter to the first bullet, then
    # two bullets (Enter between them).
    _type(cast[Ptr[uint8]]("Welcome to HamSlides"))
    _press(13)                                         # Enter -> first bullet
    _type(cast[Ptr[uint8]]("Native presentation app"))
    _press(13)                                         # Enter -> second bullet
    _type(cast[Ptr[uint8]]("Edit and present decks"))

    # ---- (2) add a SECOND slide (Ctrl-N) and populate it ---------------
    _press(14)                                         # Ctrl-N -> new slide, focus title
    _type(cast[Ptr[uint8]]("Features"))
    _press(13)
    _type(cast[Ptr[uint8]]("Thumbnail rail"))
    _press(13)
    _type(cast[Ptr[uint8]]("Save and load .hamslides"))

    # ---- (3) assert the deck model -------------------------------------
    _o_str(cast[Ptr[uint8]]("NSLIDES "))
    _o_dec(cast[int64](hamslides_slide_count()))       # 2
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CUR "))
    _o_dec(cast[int64](hamslides_cur()))               # 1 (on slide 2)
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("S0_NBUL "))
    _o_dec(cast[int64](hamslides_bullet_count(0)))     # 2
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("S1_NBUL "))
    _o_dec(cast[int64](hamslides_bullet_count(1)))     # 2
    _o_ch(10)
    _dump_title(cast[Ptr[uint8]]("S0_TITLE"), 0)       # Welcome to HamSlides
    _dump_bullet(cast[Ptr[uint8]]("S0_B0"), 0, 0)      # Native presentation app
    _dump_bullet(cast[Ptr[uint8]]("S0_B1"), 0, 1)      # Edit and present decks
    _dump_title(cast[Ptr[uint8]]("S1_TITLE"), 1)       # Features
    _o_flush()

    # ---- (4) navigate to slide 1 + render the EDIT view ----------------
    # PageUp is CSI 5~; feed the real escape sequence to move to the prev slide.
    _press(27)                                         # ESC
    _press(91)                                         # [
    _press(53)                                         # 5
    _press(126)                                        # ~  -> PageUp -> prev
    _o_str(cast[Ptr[uint8]]("CUR_AFTER_PGUP "))
    _o_dec(cast[int64](hamslides_cur()))               # 0
    _o_ch(10)
    _o_flush()

    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("EDIT_PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX_TITLEBAR "))
    _o_dec(cast[int64](hamui_host_pixel(4, 4)))        # dark indigo title bar
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("EDIT_VIEW "))
    _o_dec(cast[int64](hamslides_view()))              # 0 = EDIT
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- (5) SAVE (Ctrl-S) ---------------------------------------------
    _press(19)
    _o_str(cast[Ptr[uint8]]("FILE_LEN "))
    _o_dec(_file_len())
    _o_ch(10)
    _o_flush()

    # ---- (6) CLEAR, then RE-OPEN off disk (round-trip proof) -----------
    hamslides_clear()
    _o_str(cast[Ptr[uint8]]("NSLIDES_AFTER_CLEAR "))
    _o_dec(cast[int64](hamslides_slide_count()))       # 1
    _o_ch(10)
    _press(15)                                         # Ctrl-O -> _load_doc
    _o_str(cast[Ptr[uint8]]("NSLIDES_AFTER_OPEN "))
    _o_dec(cast[int64](hamslides_slide_count()))       # 2 again
    _o_ch(10)
    _dump_title(cast[Ptr[uint8]]("S0_TITLE_RELOAD"), 0)  # Welcome to HamSlides
    _dump_bullet(cast[Ptr[uint8]]("S0_B0_RELOAD"), 0, 0) # Native presentation app
    _dump_title(cast[Ptr[uint8]]("S1_TITLE_RELOAD"), 1)  # Features
    _o_str(cast[Ptr[uint8]]("S1_NBUL_RELOAD "))
    _o_dec(cast[int64](hamslides_bullet_count(1)))       # 2
    _o_ch(10)
    _o_flush()

    # ---- (7) PRESENT view: toggle + render -----------------------------
    hamslides_set_present(1)
    _o_str(cast[Ptr[uint8]]("PRESENT_VIEW "))
    _o_dec(cast[int64](hamslides_view()))              # 1 = PRESENT
    _o_ch(10)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))
    _o_str(cast[Ptr[uint8]]("PRESENT_PIX "))
    _o_dec(cast[int64](hamui_host_pixel(4, 60)))       # accent title band pixel
    _o_ch(10)
    # advance the presentation with Space, then Left to go back
    _press(32)                                         # Space -> next
    _o_str(cast[Ptr[uint8]]("PRESENT_CUR_AFTER_SPACE "))
    _o_dec(cast[int64](hamslides_cur()))               # 1
    _o_ch(10)
    _press(27)                                         # ESC -> exit present
    _o_str(cast[Ptr[uint8]]("VIEW_AFTER_ESC "))
    _o_dec(cast[int64](hamslides_view()))              # 0 = EDIT
    _o_ch(10)
    _o_flush()
    return 0

# user/sdlpong.ad — the hamSDL demo game, DEVICE build (x86_64-adder-user).
#
# A thin driver: it wires the hamSDL device backend (lib/hamsdl_dev.ad) to the
# shared, target-agnostic game in lib/sdlpong.ad. All drawing, input and timing
# go through the PUBLIC hamSDL API — this file contains NO game logic and NO raw
# transport of its own, proving the library is a complete game surface. The
# HOST render gate (user/sdlpong_host.ad) drives the same lib/sdlpong.ad.

from lib.hamsdl import sdl_poll_event, sdl_set_fps, sdl_frame_ms, \
    SDL_QUIT, SDL_KEYDOWN
from lib.hamsdl_dev import sdl_dev_init, sdl_dev_pump, sdl_dev_present, \
    sdl_dev_delay
from lib.sdlpong import pong_init, pong_key, pong_update, pong_render


PONG_W: int32 = 320
PONG_H: int32 = 360


def main() -> int32:
    wid: int32 = sdl_dev_init(cast[Ptr[uint8]]("hamSDL Pong"),
                              260, 120, PONG_W, PONG_H)
    if wid < 0:
        return 1
    pong_init(PONG_W, PONG_H)
    sdl_set_fps(30)
    pong_render()
    sdl_dev_present()

    kind: int32 = 0
    key: int32 = 0
    ex: int32 = 0
    ey: int32 = 0
    ebtn: int32 = 0
    while True:
        sdl_dev_pump()
        while sdl_poll_event(&kind, &key, &ex, &ey, &ebtn) == 1:
            if kind == SDL_QUIT:
                return 0
            if kind == SDL_KEYDOWN:
                pong_key(key)
        pong_update()
        pong_render()
        sdl_dev_present()
        sdl_dev_delay(cast[uint64](sdl_frame_ms()))
    return 0

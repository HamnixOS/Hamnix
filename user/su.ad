# user/su.ad
#
# Switch user. `su <name>` authenticates as <name> via the kernel
# /dev/auth cdev, then drops THIS process into that identity and execs
# a login shell. With no argument it defaults to the `hostowner`
# (uid 1) — like real `su` defaults to root.
#
# Plan-9-shape identity change: after /dev/auth verifies the password,
# we call SYS_SETUID_AUTH(authfd). That syscall recovers the fd's
# verified-uid and sets our uid/gid to it — the gate is the PASSWORD
# PROOF carried in the fd, not our prior uid, so su works whether the
# caller was the hostowner or a regular user. We then source the target's
# per-user namespace recipe (so a regular user gets the restricted view),
# chdir to their home, and exec /bin/hamsh.
#
# Usage:
#   su            — become the `hostowner`
#   su <name>     — become <name>

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_setuid_auth(authfd: int32) -> int32
extern def sys_getuid() -> uint32
extern def sys_chdir(path: Ptr[char]) -> int32
extern def sys_execve_env(path: Ptr[char], argv: Ptr[uint64],
                          envp: Ptr[uint64]) -> int32

from lib.passwd.passwd import (
    passwd_parse, passwd_lookup_by_name, passwd_entry_home,
)


pw_buf:   Array[4096, uint8]
target:   Array[64, uint8]
pass_buf: Array[128, uint8]
authresp: Array[64, uint8]
home_buf: Array[128, uint8]
env_str:  Array[128, uint8]       # "HAMNIX_NEWSHELL_USER=<name>"

PW_MAX: uint64 = 128


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def render_u32(v: uint32, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digits: Array[12, uint8]
    n: uint64 = 0
    vv: uint64 = cast[uint64](v)
    while vv != 0:
        digits[n] = cast[uint8](vv % 10) + 48
        vv = vv / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def copy_cstr(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def wipe(buf: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while i < cap:
        buf[i] = 0
        i = i + 1


def read_password(buf: Ptr[uint8], cap: uint64) -> uint64:
    # Raw byte read from fd 0, no echo. Stops at '\n', drops '\r'.
    n: uint64 = 0
    while n + 1 < cap:
        c: Array[1, uint8]
        rr: int64 = sys_read(0, &c[0], 1)
        if rr <= 0:
            break
        if c[0] == 10:
            break
        if c[0] == 13:
            continue
        buf[n] = c[0]
        n = n + 1
    buf[n] = 0
    return n


def auth_write_line(fd: int32, prefix: Ptr[uint8], plen: uint64,
                    payload: Ptr[uint8], paylen: uint64) -> int64:
    line: Array[256, uint8]
    p: uint64 = 0
    while p < plen and p + 2 < 256:
        line[p] = prefix[p]
        p = p + 1
    j: uint64 = 0
    while j < paylen and p + 2 < 256:
        line[p] = payload[j]
        p = p + 1
        j = j + 1
    line[p] = 10
    p = p + 1
    return sys_write(fd, &line[0], p)


def build_env_str():
    # "HAMNIX_NEWSHELL_USER=<target>" so the exec'd hamsh sources the
    # per-user namespace recipe (/etc/users/<target>.ns, else default.ns).
    pre: Ptr[uint8] = "HAMNIX_NEWSHELL_USER="
    p: uint64 = 0
    while pre[p] != 0 and p + 1 < 128:
        env_str[p] = pre[p]
        p = p + 1
    k: uint64 = 0
    while target[k] != 0 and p + 1 < 128:
        env_str[p] = target[k]
        p = p + 1
        k = k + 1
    env_str[p] = 0


def exec_shell_as_target():
    # Source the target's per-user namespace recipe (login-shape), chdir
    # to their home, and exec /bin/hamsh. We resolve the home from the
    # already-slurped /etc/passwd parse.
    idx: int32 = passwd_lookup_by_name(&target[0])
    if idx >= 0:
        copy_cstr(&home_buf[0], passwd_entry_home(idx), 128)
        sys_chdir(cast[Ptr[char]](&home_buf[0]))
    build_env_str()
    argbuf: Array[2, uint64]
    argbuf[0] = cast[uint64]("/bin/hamsh")
    argbuf[1] = 0
    envbuf: Array[2, uint64]
    envbuf[0] = cast[uint64](&env_str[0])
    envbuf[1] = 0
    sys_execve_env("/bin/hamsh", &argbuf[0], &envbuf[0])
    write_str(2, "su: exec /bin/hamsh failed\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc >= 2:
        copy_cstr(&target[0], cast[Ptr[uint8]](argv[1]), 64)
    else:
        copy_cstr(&target[0], "hostowner", 64)             # hostowner default

    # Slurp /etc/passwd (for the home lookup post-auth; also lets us
    # confirm the user exists, though we don't leak that before auth).
    fd: int32 = sys_open("/etc/passwd")
    total: uint64 = 0
    if fd >= 0:
        while total < 4096:
            n: int64 = sys_read(fd, &pw_buf[total], 4096 - total)
            if n <= 0:
                break
            total = total + cast[uint64](n)
        sys_close(fd)
    passwd_parse(&pw_buf[0], total)

    # Prompt for the target's password (no echo).
    write_str(1, "Password: ")
    plen: uint64 = read_password(&pass_buf[0], PW_MAX)
    write_str(1, "\n")

    # Authenticate via /dev/auth.
    afd: int32 = sys_open("/dev/auth")
    if afd < 0:
        write_str(2, "su: cannot open /dev/auth\n")
        wipe(&pass_buf[0], PW_MAX)
        return 1
    user_prefix: Ptr[uint8] = "user "
    pass_prefix: Ptr[uint8] = "pass "
    auth_write_line(afd, user_prefix, 5, &target[0], strlen_u8(&target[0]))
    auth_write_line(afd, pass_prefix, 5, &pass_buf[0], plen)
    rn: int64 = sys_read(afd, &authresp[0], 64)
    wipe(&pass_buf[0], PW_MAX)

    if rn < 2 or authresp[0] != 111 or authresp[1] != 107:   # not "ok"
        sys_close(afd)
        write_str(2, "su: Authentication failure\n")
        return 1

    # Authenticated. Drop into the target's identity via the fd's
    # verified slot, then close the fd and exec the shell.
    su_rc: int32 = sys_setuid_auth(afd)
    sys_close(afd)
    if su_rc < 0:
        write_str(2, "su: identity change failed\n")
        return 1

    # Deterministic identity-change proof: print our post-setuid uid.
    # The nested login shell's interactive stdin is unreliable under
    # spawn/execve, so this line is what the test asserts on.
    uid_now: uint32 = sys_getuid()
    ubuf: Array[16, uint8]
    write_str(1, "su: switched to uid ")
    ub: uint64 = render_u32(uid_now, &ubuf[0])
    sys_write(1, &ubuf[0], ub)
    write_str(1, " (")
    write_str(1, &target[0])
    write_str(1, ")\n")

    exec_shell_as_target()
    return 1

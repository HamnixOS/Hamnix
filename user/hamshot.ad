# user/hamshot.ad
#
# hamshot — the MATE-screenshot equivalent for the Hamnix desktop.
# A plain CLI (no GUI) that grabs the LIVE framebuffer pixels and
# writes a P6 PPM image file, viewable with user/hamview.ad.
#
#   hamshot [outfile]          default outfile: /tmp/screenshot.ppm
#
# HOW IT WORKS (pure Plan 9 file ops, no ioctls):
#   1. read /dev/fb        -> one geometry line
#                             "WIDTH HEIGHT PITCH BPP PIXFMT\n"
#   2. read /dev/fbpix     -> the raw framebuffer bytes, streamed
#                             sequentially one scanline (PITCH bytes)
#                             at a time. /dev/fbpix is the read-only
#                             pixel leaf (drivers/video/fb_cdev.ad
#                             devfbpix_read): size = PITCH * HEIGHT,
#                             EOF past the end.
#   3. convert each scanline's first WIDTH pixels from the hardware
#      pixel format to packed RGB and append to the outfile after a
#      "P6\nW H\n255\n" header.
#
# PIXEL FORMATS (mirrors fb_text.ad's fb_present_rgba_row packing):
#   bpp 32, pixfmt 0 (RGB / EFI PixelRedGreenBlue...): bytes R,G,B,X
#   bpp 32, pixfmt 1 (BGR / EFI PixelBlueGreenRed...): bytes B,G,R,X
#     (the common GOP case — 32-bit BGRX)
#   bpp 24: 3 bytes per pixel, stored B,G,R (fb_text's 24bpp store
#     writes b,g,r regardless of pixfmt — see fb_present_rgba_row).
#
# ADDER QUIRKS HONOURED
#   * No heap — fixed module-level Array buffers, streamed per
#     scanline (never a whole frame in memory). Globals are prefixed
#     _hshot_ (the global namespace is shared across imports).
#   * Strings are Ptr[uint8]; no adjacent-literal concatenation; no
#     module-scope string-literal globals.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       user/hamshot.ad -o build/user/hamshot.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32

# One scanline of raw framebuffer bytes. 16384 covers up to 4096-pixel-
# wide 32bpp scanlines (incl. typical GOP pitch padding).
_hshot_row_in:  Array[16384, uint8]
# One scanline of converted RGB bytes (3 * up to 4096 pixels).
_hshot_row_out: Array[12288, uint8]

_HSHOT_ROW_IN_CAP:  uint64 = 16384
_HSHOT_ROW_OUT_CAP: uint64 = 12288


def _hshot_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _hshot_puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _hshot_strlen(s))


def _hshot_put_u64(out: Ptr[uint8], pos: uint64, value: uint64) -> uint64:
    # Render `value` in decimal at out[pos..]; returns the new pos.
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    if v == 0:
        digits[0] = 48
        n = 1
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    p: uint64 = pos
    while n > 0:
        n = n - 1
        out[p] = digits[n]
        p = p + 1
    return p


def _hshot_print_u64(fd: int32, value: uint64):
    tmp: Array[24, uint8]
    n: uint64 = _hshot_put_u64(&tmp[0], 0, value)
    sys_write(fd, &tmp[0], n)


def _hshot_parse_u64(buf: Ptr[uint8], pos: Ptr[uint64],
                     limit: uint64) -> uint64:
    # Skip spaces, then parse a decimal run. Advances *pos.
    p: uint64 = pos[0]
    while p < limit and buf[p] == 32:
        p = p + 1
    v: uint64 = 0
    while p < limit and buf[p] >= 48 and buf[p] <= 57:
        v = v * 10 + cast[uint64](buf[p]) - 48
        p = p + 1
    pos[0] = p
    return v


def _hshot_read_full(fd: int32, buf: Ptr[uint8], want: uint64) -> int64:
    # Read exactly `want` bytes (looping over short reads). Returns the
    # byte count on success, 0 on clean EOF at a boundary, -1 on error
    # or truncated tail.
    got: uint64 = 0
    while got < want:
        n: int64 = sys_read(fd, &buf[got], want - got)
        if n < 0:
            return -1
        if n == 0:
            if got == 0:
                return 0
            return -1
        got = got + cast[uint64](n)
    return cast[int64](got)


def _hshot_write_full(fd: int32, buf: Ptr[uint8], count: uint64) -> int32:
    # Write all `count` bytes (looping over short writes). 0 ok, -1 err.
    done: uint64 = 0
    while done < count:
        n: int64 = sys_write(fd, &buf[done], count - done)
        if n <= 0:
            return -1
        done = done + cast[uint64](n)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    outpath: Ptr[char] = cast[Ptr[char]]("/tmp/screenshot.ppm")
    if argc > 1:
        outpath = cast[Ptr[char]](argv[1])

    # ---- (1) geometry from /dev/fb ---------------------------------
    gfd: int32 = sys_open("/dev/fb")
    if gfd < 0:
        _hshot_puts(2, "hamshot: cannot open /dev/fb\n")
        return 1
    geo: Array[64, uint8]
    gn: int64 = sys_read(gfd, &geo[0], 63)
    sys_close(gfd)
    if gn <= 0:
        _hshot_puts(2, "hamshot: no framebuffer (geometry read failed)\n")
        return 1
    glen: uint64 = cast[uint64](gn)
    gpos: uint64 = 0
    w:      uint64 = _hshot_parse_u64(&geo[0], &gpos, glen)
    h:      uint64 = _hshot_parse_u64(&geo[0], &gpos, glen)
    pitch:  uint64 = _hshot_parse_u64(&geo[0], &gpos, glen)
    bpp:    uint64 = _hshot_parse_u64(&geo[0], &gpos, glen)
    pixfmt: uint64 = _hshot_parse_u64(&geo[0], &gpos, glen)
    if w == 0 or h == 0 or pitch == 0:
        _hshot_puts(2, "hamshot: bad /dev/fb geometry\n")
        return 1
    if bpp != 32 and bpp != 24:
        _hshot_puts(2, "hamshot: unsupported bpp\n")
        return 1
    bytespp: uint64 = bpp / 8
    if pitch > _HSHOT_ROW_IN_CAP or w * 3 > _HSHOT_ROW_OUT_CAP:
        _hshot_puts(2, "hamshot: framebuffer too wide for the row buffer\n")
        return 1
    if w * bytespp > pitch:
        _hshot_puts(2, "hamshot: geometry inconsistent (w*bpp > pitch)\n")
        return 1

    # ---- (2) open the pixel stream + the outfile --------------------
    pfd: int32 = sys_open("/dev/fbpix")
    if pfd < 0:
        _hshot_puts(2, "hamshot: cannot open /dev/fbpix\n")
        return 1
    ofd: int32 = sys_open_write(outpath)
    if ofd < 0:
        _hshot_puts(2, "hamshot: cannot create outfile\n")
        sys_close(pfd)
        return 1

    # ---- (3) P6 header: "P6\nW H\n255\n" ----------------------------
    hdr: Array[48, uint8]
    hp: uint64 = 0
    hdr[hp] = 80                                  # 'P'
    hp = hp + 1
    hdr[hp] = 54                                  # '6'
    hp = hp + 1
    hdr[hp] = 10                                  # '\n'
    hp = hp + 1
    hp = _hshot_put_u64(&hdr[0], hp, w)
    hdr[hp] = 32                                  # ' '
    hp = hp + 1
    hp = _hshot_put_u64(&hdr[0], hp, h)
    hdr[hp] = 10                                  # '\n'
    hp = hp + 1
    hdr[hp] = 50                                  # '2'
    hp = hp + 1
    hdr[hp] = 53                                  # '5'
    hp = hp + 1
    hdr[hp] = 53                                  # '5'
    hp = hp + 1
    hdr[hp] = 10                                  # '\n'
    hp = hp + 1
    if _hshot_write_full(ofd, &hdr[0], hp) != 0:
        _hshot_puts(2, "hamshot: header write failed\n")
        sys_close(ofd)
        sys_close(pfd)
        return 1

    # ---- (4) stream scanlines: read PITCH bytes, emit 3*W RGB -------
    y: uint64 = 0
    while y < h:
        rn: int64 = _hshot_read_full(pfd, &_hshot_row_in[0], pitch)
        if rn != cast[int64](pitch):
            _hshot_puts(2, "hamshot: short read from /dev/fbpix\n")
            sys_close(ofd)
            sys_close(pfd)
            return 1
        x: uint64 = 0
        op: uint64 = 0
        while x < w:
            so: uint64 = x * bytespp
            r: uint8 = 0
            g: uint8 = 0
            b: uint8 = 0
            if bpp == 32 and pixfmt == 0:
                # RGB byte order: R,G,B,X
                r = _hshot_row_in[so]
                g = _hshot_row_in[so + 1]
                b = _hshot_row_in[so + 2]
            else:
                # BGR byte order: B,G,R[,X] — the common 32-bit GOP
                # BGRX case, and fb_text's 24bpp store order.
                b = _hshot_row_in[so]
                g = _hshot_row_in[so + 1]
                r = _hshot_row_in[so + 2]
            _hshot_row_out[op]     = r
            _hshot_row_out[op + 1] = g
            _hshot_row_out[op + 2] = b
            op = op + 3
            x = x + 1
        if _hshot_write_full(ofd, &_hshot_row_out[0], op) != 0:
            _hshot_puts(2, "hamshot: pixel write failed\n")
            sys_close(ofd)
            sys_close(pfd)
            return 1
        y = y + 1

    sys_close(ofd)
    sys_close(pfd)

    _hshot_puts(1, "hamshot: wrote ")
    _hshot_print_u64(1, w)
    _hshot_puts(1, "x")
    _hshot_print_u64(1, h)
    _hshot_puts(1, " -> ")
    _hshot_puts(1, cast[Ptr[uint8]](outpath))
    _hshot_puts(1, "\n")
    return 0

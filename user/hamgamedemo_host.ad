# user/hamgamedemo_host.ad — "Coin Dash", the hamGame demo HOST render + drive
# harness (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME game the device app ships (lib/hamgamedemo.ad) through the SAME
# public hamGame API, but with the HOST backend (lib/hamgame_host.ad): it renders
# frames to binary PPMs a human/agent can LOOK at, feeds SCRIPTED input (both raw
# queue pushes and DE arrow-key wire lines through the shared parser), advances a
# scripted clock so delta-time animation is deterministic, and dumps the game
# state + sampled pixels so scripts/test_hamgame_host.sh can assert on layout,
# colour, motion, timing, input and collision WITHOUT eyeballing.
#
# USAGE (built to build/host/hamgamedemo_host): hamgamedemo_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamgame import game_poll_event, game_push_event, \
    game_feed_keys_buffer, game_clock_tick, game_flip_scene, \
    game_draw_text_bold, game_draw_int, game_rgb, \
    GAME_KEYDOWN, GAMEK_LEFT
from lib.hamgame_host import game_host_present, game_host_write_ppm, \
    game_host_pixel, game_host_advance, game_host_ticks
from lib.hamgamedemo import gd_init, gd_key, gd_update, gd_render, \
    gd_display_surf, gd_get_score, gd_get_frame, \
    gd_player_x, gd_player_y, gd_coin_x, gd_coin_y, gd_place_coin_on_player


GDW: int32 = 240
GDH: int32 = 240


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                            # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _o_pix(label: Ptr[uint8], x: int32, y: int32):
    _o_str(label)
    _o_hexcol(game_host_pixel(x, y))
    _o_ch(10)


# Feed the 3 press lines the compositor delivers for one arrow escape sequence:
# "d 27" (ESC), "d 91" ('['), "d <final>" (A/B/C/D).
def _feed_arrow(final: uint8):
    kb: Array[16, uint8]
    kb[0] = 100                                          # 'd'
    kb[1] = 32
    kb[2] = 50                                           # '2'
    kb[3] = 55                                           # '7'  -> 27 ESC
    kb[4] = 10
    kb[5] = 100
    kb[6] = 32
    kb[7] = 57                                           # '9'
    kb[8] = 49                                           # '1'  -> 91 '['
    kb[9] = 10
    kb[10] = 100
    kb[11] = 32
    # final as two ASCII digits (65..68 are all two-digit)
    kb[12] = cast[uint8](final / 10) + 48
    kb[13] = cast[uint8](final % 10) + 48
    kb[14] = 10
    game_feed_keys_buffer(&kb[0], 15)


def _drain_keys():
    kind: int32 = 0
    key: int32 = 0
    ax: int32 = 0
    ay: int32 = 0
    abtn: int32 = 0
    while game_poll_event(&kind, &key, &ax, &ay, &abtn) == 1:
        if kind == GAME_KEYDOWN:
            gd_key(key)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamgamedemo_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    gd_init(GDW, GDH)

    # ---- BEFORE frame ---------------------------------------------------
    # Compose pixels onto the display Surface, emit the display-image scene
    # verb (game_flip_scene), overlay HUD glyphs, then register+rasterize.
    gd_render()
    game_flip_scene(gd_display_surf())
    game_draw_text_bold(8, 6, cast[Ptr[uint8]]("Coin Dash"),
                        game_rgb(230, 236, 245))
    game_draw_int(GDW - 28, 6, gd_get_score(), game_rgb(240, 210, 90))
    prims: int32 = game_host_present(gd_display_surf())
    game_host_write_ppm(cast[Ptr[char]](argv[1]))

    px0: int32 = gd_player_x()
    py0: int32 = gd_player_y()
    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _o_kv(cast[Ptr[uint8]]("PLAYERX0"), cast[int64](px0))
    _o_kv(cast[Ptr[uint8]]("PLAYERY0"), cast[int64](py0))
    _o_kv(cast[Ptr[uint8]]("COINX0"), cast[int64](gd_coin_x()))
    _o_kv(cast[Ptr[uint8]]("COINY0"), cast[int64](gd_coin_y()))
    _o_kv(cast[Ptr[uint8]]("SCORE0"), cast[int64](gd_get_score()))
    # Sampled pixels prove the RASTERIZER blitted the display Surface.
    _o_pix(cast[Ptr[uint8]]("PIX_BG 2 120 "), 2, 120)             # dark backdrop
    _o_pix(cast[Ptr[uint8]]("PIX_PLAYER 120 208 "), 120, 208)    # avatar body
    _o_pix(cast[Ptr[uint8]]("PIX_COIN 120 38 "), 120, 38)        # coin body
    _o_flush()

    # ---- INPUT (wire parser): RIGHT arrow slides the player right --------
    _feed_arrow(67)                                       # 'C' = RIGHT
    _drain_keys()
    _o_kv(cast[Ptr[uint8]]("PLAYERX1"), cast[int64](gd_player_x()))

    # ---- INPUT (wire parser): UP arrow slides the player up --------------
    _feed_arrow(65)                                       # 'A' = UP
    _drain_keys()
    _o_kv(cast[Ptr[uint8]]("PLAYERY1"), cast[int64](gd_player_y()))

    # ---- INPUT (raw queue): a LEFT keydown slides the player back left ----
    game_push_event(GAME_KEYDOWN, GAMEK_LEFT, 0, 0, 0)
    _drain_keys()
    _o_kv(cast[Ptr[uint8]]("PLAYERX2"), cast[int64](gd_player_x()))

    # ---- TIMING: delta-time animates the avatar spritesheet frame --------
    # Establish the clock baseline (first tick is always dt=0), then advance the
    # scripted clock past the 200ms animation threshold and tick again.
    game_clock_tick(game_host_ticks())
    f_before: int32 = gd_get_frame()
    game_host_advance(250)                                # > the 200ms threshold
    dt: uint64 = game_clock_tick(game_host_ticks())
    gd_update(cast[int32](dt))
    f_after: int32 = gd_get_frame()
    _o_kv(cast[Ptr[uint8]]("FRAME_BEFORE"), cast[int64](f_before))
    _o_kv(cast[Ptr[uint8]]("FRAME_AFTER"), cast[int64](f_after))

    # ---- COLLISION / scoring: drop the coin on the player, then update ----
    s_before: int32 = gd_get_score()
    gd_place_coin_on_player()
    gd_update(0)                                          # dt=0: no extra anim
    s_after: int32 = gd_get_score()
    _o_kv(cast[Ptr[uint8]]("SCOREHIT_BEFORE"), cast[int64](s_before))
    _o_kv(cast[Ptr[uint8]]("SCOREHIT_AFTER"), cast[int64](s_after))
    _o_flush()

    # ---- AFTER frame (post input + motion + score) ----------------------
    gd_render()
    game_flip_scene(gd_display_surf())
    game_draw_text_bold(8, 6, cast[Ptr[uint8]]("Coin Dash"),
                        game_rgb(230, 236, 245))
    game_draw_int(GDW - 28, 6, gd_get_score(), game_rgb(240, 210, 90))
    game_host_present(gd_display_surf())
    game_host_write_ppm(cast[Ptr[char]](argv[2]))
    return 0

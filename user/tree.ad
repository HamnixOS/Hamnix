# user/tree.ad
#
# Hamnix `tree` — the classic Unix recursive directory lister.
#
#   tree [options] [path]
#
# WHAT IT DOES
#   Prints the root path on the first line, then walks the directory
#   recursively, drawing each entry with box-drawing connectors:
#
#       root
#       ├── a
#       │   └── b
#       └── c
#
#   Entries are sorted by name within each directory. A footer line
#   summarises the counts: "N directories, M files".
#
# OPTIONS
#   -L <n>   maximum display depth (levels). 0 means only the root.
#   -d       list directories only.
#   -a       include dotfiles (default: skip names beginning with '.').
#
# FILESYSTEM FACTS (this OS)
#   There is NO stat(2) for directory-entry types and NO sys_fstat. As
#   in user/hdu.ad / user/hamfm.ad / user/find.ad, a directory is
#   detected by p9_listdir SUCCEEDING (>= 0) on the full path; it fails
#   (< 0) on a regular file. Recursion + children are bounded (MAX_DEPTH
#   levels, MAX_ENTRIES children per dir) to keep memory fixed and avoid
#   runaway recursion. This is a real, in-process tool — it NEVER spawns
#   a child process.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64
from lib.p9 import p9_listdir


# --- capacity --------------------------------------------------------
MAX_DEPTH:   uint64 = 32            # recursion depth cap
MAX_ENTRIES: uint64 = 256          # immediate children handled per dir
NAME_CAP:    uint64 = 64           # bytes stored per entry name
PATH_CAP:    uint64 = 1024         # max byte length of a constructed path

# Per-level listdir buffer (MAX_DEPTH slices of 4096 bytes each) so a
# nested recursion never clobbers a parent frame's directory listing.
list_buf: Array[131072, uint8]     # MAX_DEPTH * 4096
LIST_SLICE: uint64 = 4096

# Per-level child-path scratch (MAX_DEPTH slices of PATH_CAP) so building
# a child's full path doesn't disturb the parent's path.
path_buf: Array[32768, uint8]      # MAX_DEPTH * 1024

# Per-level entry name table + ordering. Each level gets its own slice of
# the names pool / name_len / order arrays so the recursion is re-entrant.
names:    Array[1048576, uint8]    # MAX_DEPTH * MAX_ENTRIES * NAME_CAP
name_len: Array[8192, uint64]      # MAX_DEPTH * MAX_ENTRIES
order:    Array[8192, uint64]      # MAX_DEPTH * MAX_ENTRIES

# Prefix string built up across recursion levels ("│   " / "    " runs).
prefix:     Array[4096, uint8]
prefix_len: uint64 = 0

# Options + running counts.
opt_max_depth: int32 = -1          # -L; -1 means unlimited
opt_dirs_only: int32 = 0           # -d
opt_all:       int32 = 0           # -a
n_dirs:  uint64 = 0
n_files: uint64 = 0


# ====================================================================
# Small string helpers
# ====================================================================
def cstr_len(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_cstr(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, cstr_len(s))


def write_dec(fd: int32, v: uint64):
    if v == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[20, uint8]
    di: uint64 = 0
    while v > 0:
        digits[di] = cast[uint8]((v % 10) + 48)
        v = v / 10
        di = di + 1
    while di > 0:
        di = di - 1
        sys_write(fd, &digits[di], 1)


# Pointer to entry `i`'s name slot at recursion `depth`.
def name_ptr(depth: uint64, i: uint64) -> Ptr[uint8]:
    base: uint64 = (depth * MAX_ENTRIES + i) * NAME_CAP
    return cast[Ptr[uint8]](cast[uint64](&names[0]) + base)


# Pointer to the listdir buffer slice for this recursion `depth`.
def list_slice(depth: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&list_buf[0]) + depth * LIST_SLICE)


# Pointer to the path-construction scratch slice for this `depth`.
def path_slice(depth: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&path_buf[0]) + depth * PATH_CAP)


# ====================================================================
# Directory-type probe (mirrors user/hdu.ad / user/find.ad)
# ====================================================================
# 1 if `path` (NUL-terminated) is itself a directory: p9_listdir
# succeeds (>= 0) on a directory, fails on a regular file. Uses a small
# scratch at the deepest list slice so it never clobbers a live listing.
probe_buf: Array[256, uint8]

def path_is_dir(path: Ptr[char]) -> int32:
    n: int64 = p9_listdir(path, &probe_buf[0], 256)
    if n >= 0:
        return 1
    return 0


# ====================================================================
# Recursive tree walk
# ====================================================================
# List directory `path` (NUL-terminated) at recursion `depth`, parse its
# immediate children into this level's name table, sort by name, then for
# each kept child print the connector + name and recurse if it is a dir.
def walk(path: Ptr[char], depth: uint64):
    if depth >= MAX_DEPTH:
        return
    lb: Ptr[uint8] = list_slice(depth)
    n: int64 = p9_listdir(path, lb, LIST_SLICE)
    if n < 0:
        return
    nu: uint64 = cast[uint64](n)

    # Record this directory's path in the per-depth slot so the -d
    # look-ahead in is_last() can rebuild sibling paths.
    dp: Ptr[uint8] = &cur_dir_path[depth * PATH_CAP]
    dl: uint64 = cstr_len(cast[Ptr[uint8]](path))
    if dl > PATH_CAP - 1:
        dl = PATH_CAP - 1
    di: uint64 = 0
    while di < dl:
        dp[di] = cast[uint8](path[di])
        di = di + 1
    dp[dl] = 0

    # --- parse names into this level's slice of the name table ------
    count: uint64 = 0
    i: uint64 = 0
    while i < nu:
        c: uint8 = lb[i]
        if c == 10 or c == 0:
            i = i + 1
            continue
        j: uint64 = i
        while j < nu:
            d: uint8 = lb[j]
            if d == 10 or d == 0:
                break
            j = j + 1
        nl: uint64 = j - i
        keep: int32 = 1
        # Always skip "." and "..".
        if nl == 1 and lb[i] == 46:
            keep = 0
        if nl == 2 and lb[i] == 46 and lb[i + 1] == 46:
            keep = 0
        # Skip dotfiles unless -a.
        if keep != 0 and opt_all == 0 and lb[i] == 46:
            keep = 0
        if keep != 0 and count < MAX_ENTRIES:
            store: uint64 = nl
            if store > NAME_CAP - 1:
                store = NAME_CAP - 1
            dst: Ptr[uint8] = name_ptr(depth, count)
            k: uint64 = 0
            while k < store:
                dst[k] = lb[i + k]
                k = k + 1
            dst[store] = 0
            name_len[depth * MAX_ENTRIES + count] = store
            count = count + 1
        i = j + 1

    # --- sort `order` by name (selection sort, bounded) -------------
    a: uint64 = 0
    while a < count:
        order[depth * MAX_ENTRIES + a] = a
        a = a + 1
    a = 0
    while a < count:
        best: uint64 = a
        b: uint64 = a + 1
        while b < count:
            if name_cmp(depth, order[depth * MAX_ENTRIES + b],
                        order[depth * MAX_ENTRIES + best]) < 0:
                best = b
            b = b + 1
        if best != a:
            tmp: uint64 = order[depth * MAX_ENTRIES + a]
            order[depth * MAX_ENTRIES + a] = order[depth * MAX_ENTRIES + best]
            order[depth * MAX_ENTRIES + best] = tmp
        a = a + 1

    # --- print each child + recurse ---------------------------------
    plen: uint64 = cstr_len(cast[Ptr[uint8]](path))
    e: uint64 = 0
    while e < count:
        ent: uint64 = order[depth * MAX_ENTRIES + e]
        np: Ptr[uint8] = name_ptr(depth, ent)
        nl: uint64 = name_len[depth * MAX_ENTRIES + ent]

        # Build the child's full path into this depth's path scratch.
        pp: Ptr[uint8] = path_slice(depth)
        w: uint64 = 0
        while w < plen and w < PATH_CAP - 2:
            pp[w] = cast[uint8](path[w])
            w = w + 1
        if w == 0 or pp[w - 1] != 47:
            pp[w] = 47
            w = w + 1
        k: uint64 = 0
        while k < nl and w < PATH_CAP - 1:
            pp[w] = np[k]
            w = w + 1
            k = k + 1
        pp[w] = 0
        cp: Ptr[char] = cast[Ptr[char]](pp)
        is_dir: int32 = path_is_dir(cp)

        # In -d mode skip non-directories entirely.
        if opt_dirs_only != 0 and is_dir == 0:
            e = e + 1
            continue

        last: int32 = 0
        if is_last(depth, count, e) != 0:
            last = 1

        # Emit the prefix accumulated by ancestors, then the connector.
        sys_write(1, &prefix[0], prefix_len)
        if last != 0:
            write_cstr(1, cast[Ptr[uint8]]("└── "))
        else:
            write_cstr(1, cast[Ptr[uint8]]("├── "))
        sys_write(1, np, nl)
        sys_write(1, "\n", 1)

        if is_dir != 0:
            n_dirs = n_dirs + 1
            # Recurse unless we've hit the -L depth limit.
            allow: int32 = 1
            if opt_max_depth >= 0:
                if cast[int32](depth) + 1 > opt_max_depth:
                    allow = 0
            if allow != 0:
                saved: uint64 = prefix_len
                push_prefix(last)
                walk(cp, depth + 1)
                prefix_len = saved
        else:
            n_files = n_files + 1
        e = e + 1


# Compare two entry names (by index) at `depth`. Returns <0, 0, >0.
def name_cmp(depth: uint64, ia: uint64, ib: uint64) -> int32:
    pa: Ptr[uint8] = name_ptr(depth, ia)
    pb: Ptr[uint8] = name_ptr(depth, ib)
    i: uint64 = 0
    while pa[i] != 0 and pb[i] != 0:
        if pa[i] < pb[i]:
            return -1
        if pa[i] > pb[i]:
            return 1
        i = i + 1
    if pa[i] == 0 and pb[i] == 0:
        return 0
    if pa[i] == 0:
        return -1
    return 1


# 1 if entry at display position `e` is the last printed child. With -d
# active a later sibling that is a file should NOT count, so scan ahead.
def is_last(depth: uint64, count: uint64, e: uint64) -> int32:
    if opt_dirs_only == 0:
        if e + 1 >= count:
            return 1
        return 0
    # -d: last iff no later sibling is a directory.
    t: uint64 = e + 1
    while t < count:
        ent: uint64 = order[depth * MAX_ENTRIES + t]
        np: Ptr[uint8] = name_ptr(depth, ent)
        nl: uint64 = name_len[depth * MAX_ENTRIES + ent]
        # Build the sibling path into a dedicated scratch (path_slice
        # holds the current child path and must not be clobbered).
        sib: Ptr[uint8] = &sib_buf[0]
        plen: uint64 = cstr_len(cast[Ptr[uint8]](&cur_dir_path[depth * PATH_CAP]))
        bp: Ptr[uint8] = &cur_dir_path[depth * PATH_CAP]
        w: uint64 = 0
        while w < plen and w < PATH_CAP - 2:
            sib[w] = bp[w]
            w = w + 1
        if w == 0 or sib[w - 1] != 47:
            sib[w] = 47
            w = w + 1
        k: uint64 = 0
        while k < nl and w < PATH_CAP - 1:
            sib[w] = np[k]
            w = w + 1
            k = k + 1
        sib[w] = 0
        if path_is_dir(cast[Ptr[char]](sib)) != 0:
            return 0
        t = t + 1
    return 1


# Dedicated scratch for the -d look-ahead in is_last(): the parent dir
# path per depth, plus a sibling-path build buffer.
cur_dir_path: Array[32768, uint8]   # MAX_DEPTH * PATH_CAP
sib_buf:      Array[1024, uint8]


# Append the continuation prefix for the child level: "    " (4 spaces)
# under a last parent, "│   " under a non-last parent.
def push_prefix(parent_last: int32):
    add: Ptr[uint8] = cast[Ptr[uint8]]("\xe2\x94\x82   ")   # "│   "
    if parent_last != 0:
        add = cast[Ptr[uint8]]("    ")
    al: uint64 = cstr_len(add)
    k: uint64 = 0
    while k < al and prefix_len < 4095:
        prefix[prefix_len] = add[k]
        prefix_len = prefix_len + 1
        k = k + 1


# ====================================================================
# Main
# ====================================================================
def parse_uint(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    i: uint64 = 0
    if s[0] == 0:
        return -1
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int32](c - 48)
        i = i + 1
    return n


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    root: Ptr[char] = cast[Ptr[char]](".")
    have_path: int32 = 0

    # --- option parsing ---------------------------------------------
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[ai])
        if a[0] == 45 and a[1] != 0:                # starts with '-'
            if a[1] == 76 and a[2] == 0:            # "-L"
                if ai + 1 < argc:
                    v: int32 = parse_uint(cast[Ptr[uint8]](argv[ai + 1]))
                    if v < 0:
                        write_cstr(2, cast[Ptr[uint8]]("tree: invalid -L argument\n"))
                        return 1
                    opt_max_depth = v
                    ai = ai + 1
                else:
                    write_cstr(2, cast[Ptr[uint8]]("tree: -L requires an argument\n"))
                    return 1
            elif a[1] == 100 and a[2] == 0:         # "-d"
                opt_dirs_only = 1
            elif a[1] == 97 and a[2] == 0:          # "-a"
                opt_all = 1
            else:
                write_cstr(2, cast[Ptr[uint8]]("tree: unknown option\n"))
                return 1
        else:
            root = cast[Ptr[char]](a)
            have_path = 1
        ai = ai + 1

    # Default path: the current working directory if available, else ".".
    cwd: Array[1024, uint8]
    if have_path == 0:
        cn: int64 = sys_getcwd(&cwd[0], 1024)
        if cn > 0:
            root = cast[Ptr[char]](&cwd[0])

    # --- print the root line ----------------------------------------
    write_cstr(1, cast[Ptr[uint8]](root))
    sys_write(1, "\n", 1)

    # Stash the root path into the depth-0 dir-path slot so the -d
    # look-ahead in is_last() can rebuild sibling paths.
    rp: Ptr[uint8] = &cur_dir_path[0]
    rl: uint64 = cstr_len(cast[Ptr[uint8]](root))
    if rl > PATH_CAP - 1:
        rl = PATH_CAP - 1
    ci: uint64 = 0
    while ci < rl:
        rp[ci] = cast[uint8](root[ci])
        ci = ci + 1
    rp[rl] = 0

    # Only descend if the root itself is a directory and -L allows it.
    if path_is_dir(root) != 0:
        do_walk: int32 = 1
        if opt_max_depth == 0:
            do_walk = 0
        if do_walk != 0:
            prefix_len = 0
            walk(root, 0)

    # --- footer summary ---------------------------------------------
    write_dec(1, n_dirs)
    if n_dirs == 1:
        write_cstr(1, cast[Ptr[uint8]](" directory, "))
    else:
        write_cstr(1, cast[Ptr[uint8]](" directories, "))
    write_dec(1, n_files)
    if n_files == 1:
        write_cstr(1, cast[Ptr[uint8]](" file\n"))
    else:
        write_cstr(1, cast[Ptr[uint8]](" files\n"))
    return 0

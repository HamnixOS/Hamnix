# user/hamchessscene_host.ad — HOST driver + render harness for the Chess
# scene app (built for the x86_64-linux Adder target; runs directly on the
# dev host, no QEMU).
#
# It drives the SAME core the native app ships (lib/hamchesscore.ad): sets the
# opening position, builds the scene display list, and RASTERIZES it with
# lib/hamui_host.ad's parser+font rasterizer into a binary PPM a human/agent
# can LOOK at (scripts/test_hamchess_host.sh converts it to PNG). It then plays
# scripted moves through the pure rules engine and asserts: a legal move applies
# + flips the turn, an illegal move is rejected, selection produces legal-move
# hints, and the classic FOOL'S MATE reaches checkmate (Black wins) — rendering
# the mate position to a second PNG. Raw scene + sampled pixels go to stdout.
#
# USAGE (built to build/host/hamchess_host):
#   hamchess_host START.ppm MATE.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hamchesscore import hchess_reset, hchess_build_scene, \
    hchess_try_move, hchess_turn, hchess_piece_at, hchess_in_check, \
    hchess_outcome, hchess_winner, hchess_legal_count, hchess_legal_total, \
    hchess_select, hchess_selected, hchess_sq_at, hchess_click, \
    hchess_btn_at


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)              # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _render(w: int32, h: int32) -> int32:
    hchess_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def _kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: hamchess_host START.ppm MATE.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 360
    H: int32 = 470

    hchess_reset()

    # --- Select a white pawn so the START frame shows selection + move dots.
    hchess_select(52)                                  # e2 (rank6 file4)
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    _kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _kv(cast[Ptr[uint8]]("TURN0"), cast[int64](hchess_turn()))
    _kv(cast[Ptr[uint8]]("OUTCOME0"), cast[int64](hchess_outcome()))
    # Piece census: e1 white king (60) = 6, e8 black king (4) = -6,
    # e2 white pawn (52) = 1, d8 black queen (3) = -5.
    _kv(cast[Ptr[uint8]]("WKING"), cast[int64](hchess_piece_at(60)))
    _kv(cast[Ptr[uint8]]("BKING"), cast[int64](hchess_piece_at(4)))
    _kv(cast[Ptr[uint8]]("WPAWN_E2"), cast[int64](hchess_piece_at(52)))
    _kv(cast[Ptr[uint8]]("BQUEEN_D8"), cast[int64](hchess_piece_at(3)))
    # A knight on b1 (57) has exactly 2 legal opening moves (a3, c3).
    _kv(cast[Ptr[uint8]]("KNIGHT_B1_MOVES"), cast[int64](hchess_legal_count(57)))
    # e2 pawn: 2 legal opening moves (e3, e4).
    _kv(cast[Ptr[uint8]]("PAWN_E2_MOVES"), cast[int64](hchess_legal_count(52)))
    # Selection state for the START render.
    _kv(cast[Ptr[uint8]]("SELECTED"), cast[int64](hchess_selected()))
    # Total legal opening moves for White is 20.
    _kv(cast[Ptr[uint8]]("OPENING_MOVES"), cast[int64](hchess_legal_total()))

    # Sampled pixels prove the RASTERIZER drew a real board.
    _o_str(cast[Ptr[uint8]]("PIX 25 61 "))
    _o_hexcol(hamui_host_pixel(25, 61))                # a8 light square corner
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 65 61 "))
    _o_hexcol(hamui_host_pixel(65, 61))                # b8 dark square corner
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 185 221 "))
    _o_hexcol(hamui_host_pixel(185, 221))              # empty middle light square
    _o_ch(10)
    _o_flush()

    # Dump the raw scene display list so the gate can assert layout/colour.
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # --- ILLEGAL move rejected: white king e1(60) -> e2(52) is blocked by its
    #     own pawn; try_move must return 0 and NOT flip the turn.
    ill: int32 = hchess_try_move(60, 52)
    _kv(cast[Ptr[uint8]]("ILLEGAL_RC"), cast[int64](ill))
    _kv(cast[Ptr[uint8]]("TURN_AFTER_ILLEGAL"), cast[int64](hchess_turn()))

    # --- LEGAL move applies + flips the turn: click-drive e2->e4 through the
    #     pointer path. e2 pixel center: file4 -> x=20+4*40+20=200; rank6 ->
    #     y=56+6*40+20=316. e4 = rank4 file4 -> x=200 y=56+4*40+20=236.
    hchess_reset()
    c1: int32 = hchess_click(200, 316)                 # select e2
    _kv(cast[Ptr[uint8]]("CLICK_SELECT_RC"), cast[int64](c1))
    _kv(cast[Ptr[uint8]]("SELECT_SQ"), cast[int64](hchess_selected()))
    c2: int32 = hchess_click(200, 236)                 # move to e4
    _kv(cast[Ptr[uint8]]("CLICK_MOVE_RC"), cast[int64](c2))
    _kv(cast[Ptr[uint8]]("E4_PIECE"), cast[int64](hchess_piece_at(36)))   # e4 = rank4 file4
    _kv(cast[Ptr[uint8]]("E2_EMPTY"), cast[int64](hchess_piece_at(52)))
    _kv(cast[Ptr[uint8]]("TURN_AFTER_MOVE"), cast[int64](hchess_turn()))

    # --- FOOL'S MATE: 1. f3 e5  2. g4 Qh4#  -> Black checkmates White.
    hchess_reset()
    m1: int32 = hchess_try_move(53, 45)                # f2-f3  (white)
    m2: int32 = hchess_try_move(12, 28)                # e7-e5  (black)
    m3: int32 = hchess_try_move(54, 38)                # g2-g4  (white)
    # Before the mating move White is NOT yet in check.
    _kv(cast[Ptr[uint8]]("PREMATE_WCHECK"), cast[int64](hchess_in_check(1)))
    m4: int32 = hchess_try_move(3, 39)                 # Qd8-h4# (black)
    _kv(cast[Ptr[uint8]]("MOVE_F3"), cast[int64](m1))
    _kv(cast[Ptr[uint8]]("MOVE_E5"), cast[int64](m2))
    _kv(cast[Ptr[uint8]]("MOVE_G4"), cast[int64](m3))
    _kv(cast[Ptr[uint8]]("MOVE_QH4"), cast[int64](m4))
    _kv(cast[Ptr[uint8]]("MATE_WCHECK"), cast[int64](hchess_in_check(1)))
    _kv(cast[Ptr[uint8]]("MATE_OUTCOME"), cast[int64](hchess_outcome()))
    _kv(cast[Ptr[uint8]]("MATE_WINNER"), cast[int64](hchess_winner()))
    _kv(cast[Ptr[uint8]]("MATE_WHITE_MOVES"), cast[int64](hchess_legal_total()))
    # A move attempt after mate is rejected (game is over).
    _kv(cast[Ptr[uint8]]("POSTMATE_RC"), cast[int64](hchess_try_move(60, 61)))

    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _kv(cast[Ptr[uint8]]("PRIMS2"), cast[int64](prims2))
    # Dump the MATE scene display list so the gate can grep the result banner.
    _o_str(cast[Ptr[uint8]]("MATE-SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("MATE-SCENE-END\n"))
    _o_flush()
    return 0

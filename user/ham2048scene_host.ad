# user/ham2048scene_host.ad — HOST driver + render harness for the 2048
# scene app (built for the x86_64-linux Adder target; runs directly on the
# dev host, no QEMU).
#
# It drives the SAME core the native app ships (lib/ham2048core.ad): seeds the
# LCG DETERMINISTICALLY, resets + lays out the board, builds the scene display
# list, and RASTERIZES it with lib/hamui_host.ad's parser+8x16-font rasterizer
# into an RGB framebuffer written out as a binary PPM a human/agent can LOOK
# at (scripts/test_ham2048_host.sh converts it to PNG). Then it feeds SCRIPTED
# input (keyboard "d <code>" lines + an on-screen pointer press) through the
# core's pure input handlers and asserts the game state changed, rendering a
# second "after" PPM. It also dumps the raw scene display list + sampled pixel
# colours to stdout so the gate can assert on layout/colour without eyeballing.
#
# No sockets, no Plan 9: it only reads argv + writes two files. This is a TEST
# shim; the native window transport lives in user/ham2048scene.ad.
#
# USAGE (built to build/host/ham2048_host):
#   ham2048_host BEFORE.ppm AFTER.ppm [KEYS]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length, hamscene_fill
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.ham2048core import h2048_reset, h2048_layout, h2048_build_scene, \
    h2048_key_line, h2048_btn_at, h2048_ctrl_press, h2048_score, \
    h2048_nonempty, h2048_gameover, _fmt, \
    h2048_test_clear, h2048_test_set, h2048_move_start, h2048_anim_active, \
    h2048_anim_advance, h2048_build_scene_anim, h2048_anim_count, \
    h2048_anim_px, h2048_anim_py, h2048_anim_phase, h2048_anim_frame, \
    h2048_draw_overlay, h2048_won, h2048_win_overlay, \
    _tile_x


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                          # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC = 1|0x40|0x200 = 0x241, mode 0644 = 420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


# Render the current scene into the framebuffer and dump raw scene + samples.
def _render(w: int32, h: int32) -> int32:
    h2048_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Feed one keyboard press for ASCII byte `code` through the core's key-line
# parser (constructs the "d <code>" wire line the compositor delivers).
kl: Array[16, uint8]


def _press(code: int32) -> int32:
    kl[0] = 100                                        # 'd'
    kl[1] = 32
    p: uint64 = 2
    if code >= 100:
        kl[p] = cast[uint8](code / 100) + 48
        p = p + 1
    if code >= 10:
        kl[p] = cast[uint8]((code / 10) % 10) + 48
        p = p + 1
    kl[p] = cast[uint8](code % 10) + 48
    p = p + 1
    return h2048_key_line(&kl[0], p)


# ---- tile-number formatting regression check ----------------------------
# The "junk after the number" bug was an unterminated tile-number buffer:
# _fmt wrote the digits but no NUL, so the scene glyph sink over-read the
# stack bytes that followed. Prove the fix DETERMINISTICALLY (independent of
# real stack luck) by handing _fmt a buffer PRE-POISONED with non-zero bytes
# — pre-fix that garbage survives past the digits; the correct _fmt writes a
# NUL so a to-NUL scan reads back EXACTLY the digits and nothing else.
def _fmt_poisoned_clean(v: int32) -> int32:
    tb: Array[16, uint8]
    k: uint64 = 0
    while k < 16:
        tb[k] = 238                                    # 0xEE poison
        k = k + 1
    n: uint64 = _fmt(v, &tb[0])
    # Walk to the first NUL: every byte read must be an ASCII digit, and the
    # NUL must fall exactly after the `n` digits (no leaked poison byte).
    i: uint64 = 0
    while tb[i] != 0:
        if tb[i] < 48 or tb[i] > 57:                   # non-digit => over-read
            return 0
        i = i + 1
    if i != n:
        return 0
    return 1


# ---- built-scene bold-glyph scanner -------------------------------------
# Every bold-glyphs line (`glyphs x y "..." #color b`) in the display list is
# a tile number (or the "2048" title) and must quote ONLY ASCII digits. After
# a BUTTON move this catches any junk the render leaked past the digits.
def _bold_glyphs_digits_only() -> int32:
    buf: Ptr[uint8] = hamscene_bufptr()
    n: uint64 = hamscene_length()
    i: uint64 = 0
    while i < n:
        ls: uint64 = i
        le: uint64 = i
        while le < n and buf[le] != 10:
            le = le + 1
        # Is this a bold-glyphs line? prefix "glyphs " and a trailing " b".
        isg: int32 = 0
        if le - ls >= 9 and buf[ls] == 103 and buf[ls + 1] == 108 and \
           buf[ls + 2] == 121 and buf[ls + 3] == 112 and buf[ls + 4] == 104 \
           and buf[ls + 5] == 115 and buf[ls + 6] == 32:
            if buf[le - 1] == 98 and buf[le - 2] == 32:
                isg = 1
        if isg == 1:
            # Scan the quoted substring; every char must be an ASCII digit.
            q: uint64 = ls
            while q < le and buf[q] != 34:
                q = q + 1
            q = q + 1                                  # first char in quotes
            while q < le and buf[q] != 34:
                if buf[q] < 48 or buf[q] > 57:
                    return 0
                q = q + 1
        i = le + 1
    return 1


# Render the CURRENT animation frame into the framebuffer.
def _render_anim(w: int32, h: int32) -> int32:
    h2048_build_scene_anim()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Build "<prefix><f>.ppm" into `out` (NUL-terminated).
spath: Array[128, uint8]


def _slide_path(prefix: Ptr[uint8], f: int32) -> Ptr[char]:
    p: uint64 = 0
    k: uint64 = 0
    while prefix[k] != 0 and p < 100:
        spath[p] = prefix[k]
        p = p + 1
        k = k + 1
    # decimal f
    if f == 0:
        spath[p] = 48
        p = p + 1
    else:
        d: Array[8, uint8]
        n: uint64 = 0
        x: uint32 = cast[uint32](f)
        while x > 0:
            d[n] = cast[uint8](x % 10) + 48
            x = x / 10
            n = n + 1
        while n > 0:
            n = n - 1
            spath[p] = d[n]
            p = p + 1
    suf: Ptr[uint8] = cast[Ptr[uint8]](".ppm")
    j: uint64 = 0
    while suf[j] != 0:
        spath[p] = suf[j]
        p = p + 1
        j = j + 1
    spath[p] = 0
    return cast[Ptr[char]](&spath[0])


def _streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


# SLIDE MODE: `ham2048_host slide OUT_PREFIX`. Sets up a DETERMINISTIC board
# with a single tile parked at row0/col3, starts a LEFT move (slides it to
# col0), then renders EVERY animation frame to <OUT_PREFIX><f>.ppm and dumps
# the moving tile's interpolated pixel-x per frame so the gate can prove tiles
# occupy INTERMEDIATE positions (not just the before/after snapped cells).
def _slide_main(prefix: Ptr[uint8]) -> int32:
    W: int32 = 360
    H: int32 = 470
    h2048_layout()
    h2048_test_clear()
    h2048_test_set(3, 2)                               # row0, col3
    ch: int32 = h2048_move_start(2)                    # slide LEFT

    fromx: int32 = _tile_x(3)
    tox: int32 = _tile_x(0)
    _o_str(cast[Ptr[uint8]]("SLIDECHANGED "))
    _o_dec(cast[int64](ch))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SLIDEN "))
    _o_dec(cast[int64](h2048_anim_count()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SLIDEFROMX "))
    _o_dec(cast[int64](fromx))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SLIDETOX "))
    _o_dec(cast[int64](tox))
    _o_ch(10)
    _o_flush()

    f: int32 = 0
    while True:
        # Report + render the current frame.
        px: int32 = h2048_anim_px(0)
        py: int32 = h2048_anim_py(0)
        _o_str(cast[Ptr[uint8]]("SLIDEFRAME "))
        _o_dec(cast[int64](f))
        _o_str(cast[Ptr[uint8]](" PHASE "))
        _o_dec(cast[int64](h2048_anim_phase()))
        _o_str(cast[Ptr[uint8]](" AFRAME "))
        _o_dec(cast[int64](h2048_anim_frame()))
        _o_str(cast[Ptr[uint8]](" TILE0X "))
        _o_dec(cast[int64](px))
        _o_str(cast[Ptr[uint8]](" TILE0Y "))
        _o_dec(cast[int64](py))
        _o_ch(10)
        _o_flush()
        _render_anim(W, H)
        _write_ppm(_slide_path(prefix, f))
        if h2048_anim_active() == 0:
            f = f + 1
            return 0
        h2048_anim_advance()
        f = f + 1
        if f > 32:                                     # safety bound
            return 0
    return 0


# GROW MODE: `ham2048_host grow [N]`. Plays N (default 120) MOVES through the
# real move+animation path — exactly what the user does over a long game — and
# after each move (animation settled) records the built display-list SIZE and
# the moving-tile count. It reports those metrics at move 5 and at move N so the
# gate can assert the per-move work stays BOUNDED (SEG@N ~= SEG@5) rather than
# climbing with move count (the "slows down after a few turns" bug class). To
# keep going after a game fills up it resets on game-over and continues.
def _grow_main(n: int32, leak: int32) -> int32:
    h2048_layout()
    h2048_reset()
    seg5:  uint64 = 0
    anim5: int32 = 0
    segN:  uint64 = 0
    animN: int32 = 0
    segmax: uint64 = 0
    animmax: int32 = 0
    m: int32 = 1
    while m <= n:
        if h2048_gameover() != 0:
            h2048_reset()
        dir: int32 = m % 4                             # cycle up/down/left/right
        h2048_move_start(dir)
        # Drain the animation to the settled frame (what _run_anim does live).
        guard: int32 = 0
        while h2048_anim_active() != 0 and guard < 64:
            h2048_build_scene_anim()
            h2048_anim_advance()
            guard = guard + 1
        # Settled static frame: this is the steady-state per-move render.
        h2048_build_scene()
        # CONTROL (leak != 0): simulate the reported bug class by APPENDING m
        # extra display-list primitives per move WITHOUT the begin() reset —
        # the display list then grows linearly with move count. Proves the
        # bounded-growth gate below has teeth: with this leak SEGN >> SEG5;
        # the real (leak == 0) path keeps SEGN ~= SEG5. The real app NEVER
        # does this (hamscene_begin resets the buffer every frame).
        if leak != 0:
            lk: int32 = 0
            while lk < m:
                hamscene_fill(0, 0, 1, 1, cast[Ptr[uint8]]("#000000"))
                lk = lk + 1
        seg: uint64 = hamscene_length()
        an:  int32 = h2048_anim_count()
        if seg > segmax:
            segmax = seg
        if an > animmax:
            animmax = an
        if m == 5:
            seg5 = seg
            anim5 = an
        if m == n:
            segN = seg
            animN = an
        m = m + 1
    _o_str(cast[Ptr[uint8]]("GROWMOVES "))
    _o_dec(cast[int64](n))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEG5 "))
    _o_dec(cast[int64](seg5))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEGN "))
    _o_dec(cast[int64](segN))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEGMAX "))
    _o_dec(cast[int64](segmax))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("ANIM5 "))
    _o_dec(cast[int64](anim5))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("ANIMN "))
    _o_dec(cast[int64](animN))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("ANIMMAX "))
    _o_dec(cast[int64](animmax))
    _o_ch(10)
    _o_flush()
    return 0


# Build "<prefix><suffix>" (both NUL-terminated) into spath; return it.
def _suf_path(prefix: Ptr[uint8], suffix: Ptr[uint8]) -> Ptr[char]:
    p: uint64 = 0
    k: uint64 = 0
    while prefix[k] != 0 and p < 100:
        spath[p] = prefix[k]
        p = p + 1
        k = k + 1
    j: uint64 = 0
    while suffix[j] != 0 and p < 124:
        spath[p] = suffix[j]
        p = p + 1
        j = j + 1
    spath[p] = 0
    return cast[Ptr[char]](&spath[0])


# Build the settled scene + the win/lose OVERLAY on top, then rasterize.
def _render_overlay(w: int32, h: int32) -> int32:
    h2048_build_scene()
    h2048_draw_overlay()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


# Dump the raw scene display list so the gate can grep the overlay tokens.
def _dump_scene():
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


# WIN MODE: `ham2048_host win OUT_PREFIX`. Sets two adjacent 1024 tiles, slides
# LEFT to MERGE into 2048 (reaching the win), asserts won + win_overlay, renders
# the "YOU WIN!" overlay, then DISMISSES it with a move press (play continues),
# and finally proves New clears the win state to a fresh 2-tile board.
def _win_main(prefix: Ptr[uint8]) -> int32:
    W: int32 = 360
    H: int32 = 470
    h2048_layout()
    h2048_test_clear()
    h2048_test_set(0, 1024)
    h2048_test_set(1, 1024)
    ch: int32 = h2048_move_start(2)                    # LEFT -> 1024+1024=2048
    _o_str(cast[Ptr[uint8]]("WINMOVE "))
    _o_dec(cast[int64](ch))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("WON "))
    _o_dec(cast[int64](h2048_won()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("WINOVERLAY "))
    _o_dec(cast[int64](h2048_win_overlay()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("WINSCORE "))
    _o_dec(cast[int64](h2048_score()))
    _o_ch(10)
    _o_flush()
    _render_overlay(W, H)
    _write_ppm(_suf_path(prefix, cast[Ptr[uint8]]("win.ppm")))
    _dump_scene()

    # DISMISS: a move press while the banner is up is consumed (no move) and
    # clears the overlay so the player keeps going.
    d1: int32 = h2048_move_start(0)
    _o_str(cast[Ptr[uint8]]("DISMISS_RC "))
    _o_dec(cast[int64](d1))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("WINOVERLAY_AFTER "))
    _o_dec(cast[int64](h2048_win_overlay()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("WON_AFTER "))
    _o_dec(cast[int64](h2048_won()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("GAMEOVER_AFTER "))
    _o_dec(cast[int64](h2048_gameover()))
    _o_ch(10)

    # PLAY CONTINUES: a real move now changes the board (returns 1).
    h2048_test_set(4, 2)
    h2048_test_set(5, 2)
    ch2: int32 = h2048_move_start(2)
    _o_str(cast[Ptr[uint8]]("CONTINUE "))
    _o_dec(cast[int64](ch2))
    _o_ch(10)
    _o_flush()
    _render_overlay(W, H)
    _write_ppm(_suf_path(prefix, cast[Ptr[uint8]]("cont.ppm")))

    # NEW clears the win state to a fresh 2-tile board.
    h2048_ctrl_press(0)
    _o_str(cast[Ptr[uint8]]("NEW_WON "))
    _o_dec(cast[int64](h2048_won()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NEW_WINOVERLAY "))
    _o_dec(cast[int64](h2048_win_overlay()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NEW_NONEMPTY "))
    _o_dec(cast[int64](h2048_nonempty()))
    _o_ch(10)
    _o_flush()
    return 0


# LOSE MODE: `ham2048_host lose OUT_PREFIX`. Fills a DEAD checkerboard board
# (2/4 by cell parity: full, no equal adjacent pair, no move changes it), drives
# a move press to flag game over, asserts + renders the "GAME OVER" overlay, then
# proves New clears game-over to a fresh 2-tile board.
def _lose_main(prefix: Ptr[uint8]) -> int32:
    W: int32 = 360
    H: int32 = 470
    h2048_layout()
    h2048_test_clear()
    i: int32 = 0
    while i < 16:
        r: int32 = i / 4
        c: int32 = i % 4
        v: int32 = 2
        if (r + c) % 2 == 1:
            v = 4
        h2048_test_set(i, v)
        i = i + 1
    rc: int32 = h2048_move_start(0)                    # no-op on a dead board
    _o_str(cast[Ptr[uint8]]("LOSEMOVE "))
    _o_dec(cast[int64](rc))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("GAMEOVER "))
    _o_dec(cast[int64](h2048_gameover()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NONEMPTY "))
    _o_dec(cast[int64](h2048_nonempty()))
    _o_ch(10)
    _o_flush()
    _render_overlay(W, H)
    _write_ppm(_suf_path(prefix, cast[Ptr[uint8]]("over.ppm")))
    _dump_scene()

    # NEW clears game-over to a fresh 2-tile board.
    h2048_ctrl_press(0)
    _o_str(cast[Ptr[uint8]]("NEW_GAMEOVER "))
    _o_dec(cast[int64](h2048_gameover()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NEW_NONEMPTY "))
    _o_dec(cast[int64](h2048_nonempty()))
    _o_ch(10)
    _o_flush()
    _render_overlay(W, H)
    _write_ppm(_suf_path(prefix, cast[Ptr[uint8]]("new.ppm")))
    return 0


def _parse_dec(s: Ptr[uint8]) -> int32:
    v: int32 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[int32](s[i]) - 48
        i = i + 1
    return v


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc >= 2 and _streq(cast[Ptr[uint8]](argv[1]),
                            cast[Ptr[uint8]]("grow") ) == 1:
        n: int32 = 120
        if argc >= 3:
            n = _parse_dec(cast[Ptr[uint8]](argv[2]))
        if n < 6:
            n = 6
        rc: int32 = _grow_main(n, 0)
        # Render the after-many-moves board so a human/agent can LOOK at it and
        # confirm tiles still render (AA text + bevels) after a long game.
        if argc >= 4:
            h2048_build_scene()
            hamui_host_begin(360, 470)
            hamui_host_rasterize()
            _write_ppm(cast[Ptr[char]](argv[3]))
        return rc

    if argc >= 2 and _streq(cast[Ptr[uint8]](argv[1]),
                            cast[Ptr[uint8]]("growleak") ) == 1:
        nl: int32 = 120
        if argc >= 3:
            nl = _parse_dec(cast[Ptr[uint8]](argv[2]))
        if nl < 6:
            nl = 6
        return _grow_main(nl, 1)

    if argc >= 3 and _streq(cast[Ptr[uint8]](argv[1]),
                            cast[Ptr[uint8]]("slide")) == 1:
        return _slide_main(cast[Ptr[uint8]](argv[2]))

    if argc >= 3 and _streq(cast[Ptr[uint8]](argv[1]),
                            cast[Ptr[uint8]]("win")) == 1:
        return _win_main(cast[Ptr[uint8]](argv[2]))

    if argc >= 3 and _streq(cast[Ptr[uint8]](argv[1]),
                            cast[Ptr[uint8]]("lose")) == 1:
        return _lose_main(cast[Ptr[uint8]](argv[2]))

    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: ham2048_host BEFORE.ppm AFTER.ppm [KEYS]\n"))
        _o_str(cast[Ptr[uint8]]("       ham2048_host slide OUT_PREFIX\n"))
        _o_flush()
        return 2

    # DETERMINISTIC: do NOT seed from a clock; use the fixed default LCG state.
    h2048_layout()
    h2048_reset()

    W: int32 = 360
    H: int32 = 470
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))

    # Summary + a few sampled pixels (proves the RASTERIZER, not just builder).
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCORE0 "))
    _o_dec(cast[int64](h2048_score()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NONEMPTY0 "))
    _o_dec(cast[int64](h2048_nonempty()))
    _o_ch(10)
    # Backdrop pixel (top-left) must be the 2048 beige #faf8ef.
    _o_str(cast[Ptr[uint8]]("PIX 0 0 "))
    _o_hexcol(hamui_host_pixel(0, 0))
    _o_ch(10)
    # Board backing panel (between tiles) must be #bbada0.
    _o_str(cast[Ptr[uint8]]("PIX 16 74 "))
    _o_hexcol(hamui_host_pixel(16, 74))
    _o_ch(10)
    # An empty tile's corner must be #cdc1b4 (the fill 23 81 71x71 tile).
    _o_str(cast[Ptr[uint8]]("PIX 26 84 "))
    _o_hexcol(hamui_host_pixel(26, 84))
    _o_ch(10)
    # The spawned "2" tile corner (fill 104 162) must be #eee4da.
    _o_str(cast[Ptr[uint8]]("PIX 108 166 "))
    _o_hexcol(hamui_host_pixel(108, 166))
    _o_ch(10)
    _o_flush()

    # Dump the raw scene display list so the gate can assert layout/colour.
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()

    # ---- SCRIPTED INPUT -------------------------------------------------
    # 1) On-screen pointer: a press in the control row must hit-test a button.
    #    Default geometry: CTRL_Y=435, _btn_x(1)=81, BTN_W=59 -> (90,440)=Up.
    b: int64 = h2048_btn_at(90, 440)
    _o_str(cast[Ptr[uint8]]("BTNAT 90 440 "))
    _o_dec(b)
    _o_ch(10)

    # 2) Keyboard: replay KEYS (default a fixed sequence) through the parser.
    keys: Ptr[uint8] = cast[Ptr[uint8]]("wasd")
    if argc >= 4:
        keys = cast[Ptr[uint8]](argv[3])
    changed: int32 = 0
    i: uint64 = 0
    while keys[i] != 0:
        if _press(cast[int32](keys[i])) == 1:
            changed = 1
        i = i + 1
    # Also drive the hit-tested control button (Up move) via the core API.
    if b >= 0:
        h2048_ctrl_press(b)

    prims2: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))

    _o_str(cast[Ptr[uint8]]("KEYCHANGED "))
    _o_dec(cast[int64](changed))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SCORE1 "))
    _o_dec(cast[int64](h2048_score()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NONEMPTY1 "))
    _o_dec(cast[int64](h2048_nonempty()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("GAMEOVER1 "))
    _o_dec(cast[int64](h2048_gameover()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PRIMS2 "))
    _o_dec(cast[int64](prims2))
    _o_ch(10)

    # ---- TILE-NUMBER CORRUPTION REGRESSION (the button-path junk bug) ----
    # (a) The formatter itself must NUL-terminate against a poisoned buffer.
    _o_str(cast[Ptr[uint8]]("FMTCLEAN "))
    _o_dec(cast[int64](_fmt_poisoned_clean(32)))
    _o_ch(10)

    # (b) Drive a move through the BUTTON/click path ONLY (h2048_ctrl_press,
    #     the same entry the pointer hit-test invokes), rebuild the scene, and
    #     assert every bold tile-number glyph quotes ONLY digits — no trailing
    #     junk. This is the exact user repro (buttons corrupt, keyboard clean).
    h2048_reset()
    bup: int64 = h2048_btn_at(90, 440)                 # Up button
    if bup >= 0:
        h2048_ctrl_press(bup)
    h2048_build_scene()
    _o_str(cast[Ptr[uint8]]("BTNTILECLEAN "))
    _o_dec(cast[int64](_bold_glyphs_digits_only()))
    _o_ch(10)

    # (c) Byte-for-byte: a KEYBOARD move must render the identical bold-glyph
    #     verdict as the BUTTON move (both clean).
    h2048_reset()
    _press(119)                                        # 'w' = Up via keyboard
    h2048_build_scene()
    _o_str(cast[Ptr[uint8]]("KBTILECLEAN "))
    _o_dec(cast[int64](_bold_glyphs_digits_only()))
    _o_ch(10)
    _o_flush()
    return 0

# user/crontab.ad
#
# Hamnix `crontab` — the management CLI for the cron daemon (user/crond.ad).
# The active crontab lives at a single well-known path:
#
#   /var/cron/crontab
#
# under the RAM-backed writable /var tmpfs subtree — the same namespace
# convention sshd uses for /var/lib/ssh (there is no global mutable /etc
# in this OS). The /var/cron directory is created on demand here.
#
# USAGE
#
#   crontab FILE      install FILE as the crontab (overwrite)
#   crontab -l        list the current crontab to stdout
#   crontab -r        remove the current crontab
#
# `crontab -e` (spawn an editor) is intentionally NOT supported — there
# is no editor dependency. Install from a file instead.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_mkdir(path: Ptr[char]) -> int32
extern def sys_unlink(path: Ptr[char]) -> int32


BUF_CAP: uint64 = 4096
data: Array[4096, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def crontab_path() -> Ptr[char]:
    # Function-local literal (string-literal module globals unsupported).
    return cast[Ptr[char]]("/var/cron/crontab")


def cron_dir() -> Ptr[char]:
    return cast[Ptr[char]]("/var/cron")


# Ensure /var/cron exists. -17 (EEXIST) is benign; any other negative is
# reported but not fatal (the subsequent open will surface the real
# error). /var itself is pre-created by the kernel's tmpfs skeleton.
def ensure_dir():
    rc: int32 = sys_mkdir(cron_dir())
    if rc != 0 and rc != -17:
        write_str(2, "crontab: warning: cannot create /var/cron\n")


# Stream a file fd to stdout. Returns 0 always (best-effort drain).
def cat_fd(fd: int32) -> int32:
    while True:
        n: int64 = sys_read(fd, &data[0], BUF_CAP)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        wrote: uint64 = 0
        while wrote < nu:
            w: int64 = sys_write(1, cast[Ptr[uint8]](
                cast[uint64](&data[0]) + wrote), nu - wrote)
            if w <= 0:
                break
            wrote = wrote + cast[uint64](w)
    return 0


# crontab -l
def do_list() -> int32:
    fd: int32 = sys_open(crontab_path())
    if fd < 0:
        write_str(2, "crontab: no crontab installed\n")
        return 1
    cat_fd(fd)
    sys_close(fd)
    return 0


# crontab -r
def do_remove() -> int32:
    rc: int32 = sys_unlink(crontab_path())
    if rc != 0:
        write_str(2, "crontab: no crontab to remove\n")
        return 1
    return 0


# crontab FILE — copy FILE onto the crontab path.
def do_install(src: Ptr[char]) -> int32:
    in_fd: int32 = sys_open(src)
    if in_fd < 0:
        write_str(2, "crontab: cannot open ")
        write_str(2, cast[Ptr[uint8]](src))
        write_str(2, "\n")
        return 1
    ensure_dir()
    out_fd: int32 = sys_open_write(crontab_path())
    if out_fd < 0:
        sys_close(in_fd)
        write_str(2, "crontab: cannot write /var/cron/crontab\n")
        return 1
    while True:
        n: int64 = sys_read(in_fd, &data[0], BUF_CAP)
        if n <= 0:
            break
        nu: uint64 = cast[uint64](n)
        wrote: uint64 = 0
        while wrote < nu:
            w: int64 = sys_write(out_fd, cast[Ptr[uint8]](
                cast[uint64](&data[0]) + wrote), nu - wrote)
            if w <= 0:
                sys_close(in_fd)
                sys_close(out_fd)
                write_str(2, "crontab: short write to /var/cron/crontab\n")
                return 1
            wrote = wrote + cast[uint64](w)
    sys_close(in_fd)
    sys_close(out_fd)
    write_str(1, "crontab: installed\n")
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "crontab: usage: crontab FILE | -l | -r\n")
        return 1
    a1: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    if a1[0] == 45 and a1[1] == 108 and a1[2] == 0:        # "-l"
        return do_list()
    if a1[0] == 45 and a1[1] == 114 and a1[2] == 0:        # "-r"
        return do_remove()
    if a1[0] == 45:
        write_str(2, "crontab: unknown flag (use FILE | -l | -r)\n")
        return 1
    return do_install(cast[Ptr[char]](argv[1]))

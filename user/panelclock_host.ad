# user/panelclock_host.ad — HOST driver + render harness for the DE panel's
# MATE-style clock applet (lib/panelclock.ad drawn through lib/hamscene.ad and
# rasterized by lib/hamui_host.ad). Built for the x86_64-linux Adder target;
# runs directly on the dev host, no QEMU.
#
# It renders the clock string for a FIXED epoch into a small panel-strip scene,
# rasterizes it to an RGB framebuffer written as a binary PPM a human/agent can
# LOOK at (scripts/test_de_panel_clock_host.sh converts it to PNG), and dumps
# the raw scene display list + the formatted strings so the gate can assert on
# the date/time text without eyeballing.
#
# No sockets, no Plan 9: it only reads argv + writes one file.
#
# USAGE (built to build/host/panelclock_host):
#   panelclock_host OUT.ppm [EPOCH]

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_begin, hamscene_fill, hamscene_stroke, \
    hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes
from lib.panelclock import panelclock_format, panelclock_time, \
    panelclock_render, panelclock_width, panelclock_year, panelclock_month, \
    panelclock_day, panelclock_weekday


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: uint64):
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    while v > 0:
        digs[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    # O_WRONLY|O_CREAT|O_TRUNC = 577, mode 0644 = 420.
    fd: int32 = sys_open(path, 577, 420)
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _parse_epoch(s: Ptr[uint8]) -> uint64:
    v: uint64 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[uint64](s[i]) - 48
        i = i + 1
    return v


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _o_str(cast[Ptr[uint8]]("usage: panelclock_host OUT.ppm [EPOCH]\n"))
        _o_flush()
        return 2

    # DETERMINISTIC default epoch: 1752330600 = Sat Jul 12 2025 14:30:00 UTC.
    epoch: uint64 = 1752330600
    if argc >= 3:
        epoch = _parse_epoch(cast[Ptr[uint8]](argv[2]))

    # A panel strip (top bar) with the clock right-aligned, MATE-style.
    W: int32 = 240
    H: int32 = 28
    hamscene_begin()
    # Panel face (#b8b4ac, the DE's MATE grey) + a darker bottom edge.
    hamscene_fill(0, 0, W, H, cast[Ptr[uint8]]("#b8b4ac"))
    hamscene_stroke(0, 0, W, H, 1, cast[Ptr[uint8]]("#707070"))
    # Render the full date+time clock, right-aligned within the strip.
    fg: Ptr[uint8] = cast[Ptr[uint8]]("#202020")
    cw: int32 = panelclock_width(epoch)
    cx: int32 = W - cw - 8
    if cx < 4:
        cx = 4
    panelclock_render(cx, 6, epoch, 0, fg)

    hamui_host_begin(W, H)
    prims: int32 = hamui_host_rasterize()
    _write_ppm(cast[Ptr[char]](argv[1]))

    # ---- text/date assertions dump -------------------------------------
    full: Array[24, uint8]
    panelclock_format(epoch, &full[0])
    _o_str(cast[Ptr[uint8]]("EPOCH "))
    _o_dec(epoch)
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("FULL "))
    _o_str(&full[0])
    _o_ch(10)
    tonly: Array[8, uint8]
    panelclock_time(epoch, &tonly[0])
    _o_str(cast[Ptr[uint8]]("TIME "))
    _o_str(&tonly[0])
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("YEAR "))
    _o_dec(panelclock_year(epoch))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("MONTH "))
    _o_dec(panelclock_month(epoch))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DAY "))
    _o_dec(panelclock_day(epoch))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("WDAY "))
    _o_dec(panelclock_weekday(epoch))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[uint64](prims))
    _o_ch(10)
    _o_flush()

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()
    return 0

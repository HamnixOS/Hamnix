# user/hdu.ad
#
# Hamnix `hdu` — an ncdu-style interactive disk-usage browser.
#
#   hdu [DIR]         # measure DIR (or the current working directory, or /)
#
# WHAT IT DOES
#   Recursively sums the on-disk size of every immediate child of the
#   current directory: a regular file contributes its byte length, a
#   subdirectory contributes the total of everything underneath it. The
#   children are shown sorted LARGEST-FIRST, each row carrying a
#   human-readable size, a proportional bar and the name. A `..` row goes
#   up; Enter / Right descends into the selected subdirectory (which is
#   then re-measured). It is a real, in-process tool — it NEVER spawns a
#   child (a detached rfork from a windowed child hits a known-buggy path
#   in this OS).
#
# INPUT MODEL (copied verbatim from user/hamfm.ad)
#   hdu owns the raw console: fd 0/1/2 are bound to the raw console with
#   NO kernel line-cooking and NO echo. It reads one keystroke at a time
#   off fd 0 with sys_read_nb + sys_yield and repaints the whole screen
#   with ANSI escapes on every state change. Arrow keys arrive a byte at
#   a time (ESC '[' A/B/C/D) and are reassembled by a tiny state machine;
#   PgUp/PgDn arrive as ESC '[' <n> '~' with a numeric accumulator.
#
# FILESYSTEM FACTS (this OS)
#   * There is NO stat(2) for directory-entry types. As in user/hamfm.ad
#     and user/find.ad, a directory is detected by p9_listdir SUCCEEDING
#     (>= 0) on the full path; it fails (< 0) on a regular file.
#   * There is NO sys_fstat either. File SIZE is taken exactly as
#     user/stat.ad does it: sys_open + sys_lseek(fd, 0, SEEK_END) returns
#     the byte length (the glibc fstat-via-lseek / `wc -c` mechanism).
#
# KEYS
#   j / Down        move the cursor down
#   k / Up          move the cursor up
#   Enter / Right   descend into the selected subdirectory (re-measures);
#                   selecting `..` ascends
#   l               same as Right (descend)
#   h / Left        ascend to the parent directory
#   r               re-scan the current directory
#   PgDn / PgUp     page the list
#   q               quit (restores the cursor, clears the screen, exit 0)

extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_lseek(fd: int32, offset: int64, whence: int32) -> int64
extern def sys_yield() -> int32
from lib.p9 import p9_listdir, p9_chan_dir_mode
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64


# --- capacity --------------------------------------------------------
MAX_ENTRIES: uint64 = 256           # immediate children we can hold per dir
NAME_CAP:    uint64 = 64            # bytes stored per entry name
PATH_CAP:    uint64 = 1024          # max byte length of the current path
LIST_CAP:    uint64 = 65536         # raw listdir buffer size
SCREEN_ROWS: uint64 = 20            # visible listing rows
SEEK_END:    int32 = 2
MAX_DEPTH:   uint64 = 32            # recursion depth cap for the size walk
BAR_WIDTH:   uint64 = 20            # cells in the proportional bar

# Current directory path, NUL-terminated.
cur_path: Array[1024, uint8]
cur_path_len: uint64 = 0

# Raw listdir output + the parsed entry table. Each entry's name is
# stored NUL-terminated in a fixed-width slot of the names pool.
list_buf: Array[65536, uint8]
names: Array[16384, uint8]          # MAX_ENTRIES * NAME_CAP = 256 * 64
name_len: Array[256, uint64]        # live byte count of each entry name
entry_size: Array[256, uint64]      # recursive size of each entry, bytes
entry_dir: Array[256, int32]        # 1 if the entry is a directory
order: Array[256, uint64]           # entry indices sorted largest-first
num_entries: uint64 = 0
truncated: int32 = 0                # 1 if this dir had > MAX_ENTRIES children
total_size: uint64 = 0             # sum of all immediate children (the bar scale)

# Cursor + viewport for the LIST. Row 0 is always the synthetic "..".
cursor: uint64 = 0                  # selected row (0 == "..")
top: uint64 = 0                    # first row shown on screen

# A scratch full path (current path + "/" + a name), NUL-terminated.
full_path: Array[1088, uint8]

# A separate path scratch for the recursive walk, kept per depth level so
# nested recursion doesn't clobber a parent frame's buffer.
walk_path: Array[8192, uint8]      # MAX_DEPTH * 256

running: int32 = 1

# A short status message for the bottom bar.
status_msg: Array[128, uint8]
status_len: uint64 = 0

# Escape-parser state: 0 ground, 1 saw ESC, 2 saw ESC[ (CSI).
esc_state: int32 = 0
esc_param: uint64 = 0

# A scratch listdir buffer used by the recursive walk so it never reuses
# the top-level list_buf (which holds the current dir we're displaying).
scan_buf: Array[8192, uint8]       # MAX_DEPTH * 256 for re-entrant listdir


# ====================================================================
# Small string helpers
# ====================================================================
def cstr_len(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_cstr(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, cstr_len(s))


# Pointer to the first byte of entry `i`'s name slot.
def name_ptr(i: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&names[0]) + i * NAME_CAP)


def set_status(s: Ptr[uint8]):
    n: uint64 = cstr_len(s)
    if n > 127:
        n = 127
    i: uint64 = 0
    while i < n:
        status_msg[i] = s[i]
        i = i + 1
    status_len = n


# ====================================================================
# Path construction
# ====================================================================
# Build full_path = cur_path + "/" + name(i), NUL-terminated. Avoids a
# double slash when cur_path is exactly "/".
def build_full_path(i: uint64):
    j: uint64 = 0
    while j < cur_path_len and j < PATH_CAP:
        full_path[j] = cur_path[j]
        j = j + 1
    if j == 0 or full_path[j - 1] != 47:
        full_path[j] = 47
        j = j + 1
    nl: uint64 = name_len[i]
    p: Ptr[uint8] = name_ptr(i)
    k: uint64 = 0
    while k < nl and j < 1087:
        full_path[j] = p[k]
        j = j + 1
        k = k + 1
    full_path[j] = 0


# Replace cur_path with its parent directory. Root ("/") stays root.
def go_parent():
    if cur_path_len <= 1:
        cur_path[0] = 47
        cur_path[1] = 0
        cur_path_len = 1
        return
    n: uint64 = cur_path_len
    if cur_path[n - 1] == 47:
        n = n - 1
    while n > 1 and cur_path[n - 1] != 47:
        n = n - 1
    if n > 1:
        n = n - 1
    if n == 0:
        n = 1
    cur_path[n] = 0
    cur_path_len = n


# Set cur_path to a NUL-terminated string.
def set_cur_path(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < PATH_CAP - 1:
        cur_path[i] = s[i]
        i = i + 1
    if i == 0:
        cur_path[0] = 47
        i = 1
    cur_path[i] = 0
    cur_path_len = i


# ====================================================================
# Directory-type probe (mirrors user/hamfm.ad / user/find.ad)
# ====================================================================
# 1 if `path` (NUL-terminated) is itself a directory.
#
# A p9_listdir probe is NOT a reliable dir test: sys_open+sys_read on a
# regular file returns its CONTENTS (>= 0), so a content-bearing file
# would be misclassified as a directory and recursed into as garbage
# entries. Ask the kernel to flip the opened fd into Dir-record mode:
# namec_chan_set_p9_dir_mode only accepts DEV_DIR_FILE pool chans (real
# directories) and returns -1 for any other backing. Mirrors the fixed
# user/tar.ad / user/cp.ad path_is_dir. (`depth` retained for the ABI.)
def path_is_dir(path: Ptr[char], depth: uint64) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    d: int32 = p9_chan_dir_mode(fd, 1, path)
    sys_close(fd)
    if d == 0:
        return 1
    return 0


# Byte size of a regular file via open + lseek(SEEK_END) — exactly the
# mechanism user/stat.ad uses (this OS has no fstat/stat). Returns 0 if
# the size can't be determined.
def file_size(path: Ptr[char]) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    sz: int64 = sys_lseek(fd, 0, SEEK_END)
    sys_close(fd)
    if sz < 0:
        return 0
    return cast[uint64](sz)


# ====================================================================
# Recursive size walk (the engine, generalised from user/du.ad)
# ====================================================================
# Recursively sum the byte size of everything under directory `path`
# (NUL-terminated). `depth` selects a per-level scratch slice of
# walk_path / scan_buf so nested calls don't clobber a parent frame.
# Bounded by MAX_DEPTH; a too-deep subtree simply stops summing deeper.
def dir_size(path: Ptr[char], depth: uint64) -> uint64:
    if depth >= MAX_DEPTH:
        return 0
    # Per-level listdir buffer.
    lb: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](&scan_buf[0]) + depth * 256)
    n: int64 = p9_listdir(path, lb, 256)
    if n < 0:
        # Not a directory after all (race or a non-dir): size it as a file.
        return file_size(path)
    # Per-level child-path scratch: copy `path` in, remember its length.
    pp: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](&walk_path[0]) + depth * 256)
    base: uint64 = 0
    while path[base] != 0 and base < 250:
        pp[base] = cast[uint8](path[base])
        base = base + 1
    # Ensure a trailing separator (unless path already ends in '/').
    if base == 0 or pp[base - 1] != 47:
        pp[base] = 47
        base = base + 1
    nu: uint64 = cast[uint64](n)
    total: uint64 = 0
    i: uint64 = 0
    while i < nu:
        c: uint8 = lb[i]
        if c == 10 or c == 0:
            i = i + 1
            continue
        # Collect one child name [i, j).
        j: uint64 = i
        while j < nu:
            d: uint8 = lb[j]
            if d == 10 or d == 0:
                break
            j = j + 1
        nl: uint64 = j - i
        # Skip "." and "..".
        skip: int32 = 0
        if nl == 1 and lb[i] == 46:
            skip = 1
        if nl == 2 and lb[i] == 46 and lb[i + 1] == 46:
            skip = 1
        if skip == 0:
            # Build the child path into pp[base..].
            k: uint64 = 0
            w: uint64 = base
            while k < nl and w < 255:
                pp[w] = lb[i + k]
                w = w + 1
                k = k + 1
            pp[w] = 0
            cp: Ptr[char] = cast[Ptr[char]](pp)
            if path_is_dir(cp, depth + 1) != 0:
                total = total + dir_size(cp, depth + 1)
            else:
                total = total + file_size(cp)
        i = j + 1
    return total


# ====================================================================
# Load + measure the current directory
# ====================================================================
# Parse cur_path's immediate children into the entry table, measure each
# child's recursive size, mark dir/file, then build the largest-first
# order. Mirrors user/hamfm.ad's load_dir() split logic.
def load_dir():
    num_entries = 0
    truncated = 0
    total_size = 0
    cursor = 0
    top = 0
    n: int64 = p9_listdir(cast[Ptr[char]](&cur_path[0]), &list_buf[0], LIST_CAP)
    if n < 0:
        set_status(cast[Ptr[uint8]]("listdir failed"))
        return
    nu: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < nu:
        c: uint8 = list_buf[i]
        if c == 10 or c == 0:
            i = i + 1
            continue
        j: uint64 = i
        while j < nu:
            d: uint8 = list_buf[j]
            if d == 10 or d == 0:
                break
            j = j + 1
        nl: uint64 = j - i
        keep: int32 = 1
        if nl == 1 and list_buf[i] == 46:
            keep = 0
        if nl == 2 and list_buf[i] == 46 and list_buf[i + 1] == 46:
            keep = 0
        if keep != 0:
            if num_entries < MAX_ENTRIES:
                store: uint64 = nl
                if store > NAME_CAP - 1:
                    store = NAME_CAP - 1
                dst: Ptr[uint8] = name_ptr(num_entries)
                k: uint64 = 0
                while k < store:
                    dst[k] = list_buf[i + k]
                    k = k + 1
                dst[store] = 0
                name_len[num_entries] = store
                num_entries = num_entries + 1
            else:
                truncated = 1
        i = j + 1

    # Measure each immediate child.
    e: uint64 = 0
    while e < num_entries:
        build_full_path(e)
        fp: Ptr[char] = cast[Ptr[char]](&full_path[0])
        if path_is_dir(fp, 0) != 0:
            entry_dir[e] = 1
            entry_size[e] = dir_size(fp, 0)
        else:
            entry_dir[e] = 0
            entry_size[e] = file_size(fp)
        total_size = total_size + entry_size[e]
        order[e] = e
        e = e + 1

    sort_order()


# Selection sort of `order` by entry_size, largest first. num_entries is
# capped at 256 so O(n^2) is fine and keeps memory bounded (no heap).
def sort_order():
    a: uint64 = 0
    while a < num_entries:
        best: uint64 = a
        b: uint64 = a + 1
        while b < num_entries:
            if entry_size[order[b]] > entry_size[order[best]]:
                best = b
            b = b + 1
        if best != a:
            tmp: uint64 = order[a]
            order[a] = order[best]
            order[best] = tmp
        a = a + 1


# ====================================================================
# Human-readable size formatting
# ====================================================================
# Append v's decimal digits to buf[*pos], advancing *pos.
def put_dec(buf: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    if v == 0:
        buf[pos] = 48
        return pos + 1
    digits: Array[20, uint8]
    di: uint64 = 0
    while v > 0:
        digits[di] = cast[uint8]((v % 10) + 48)
        v = v / 10
        di = di + 1
    p: uint64 = pos
    while di > 0:
        di = di - 1
        buf[p] = digits[di]
        p = p + 1
    return p


# Write a right-justified, human-readable size into buf (NUL-terminated),
# e.g. "  4.0 KiB", "123 B", " 12 MiB". Uses one decimal for K/M/G when
# the value is small. Returns nothing; buf must hold >= 16 bytes.
def fmt_size(buf: Ptr[uint8], nbytes: uint64):
    pos: uint64 = 0
    unit: Ptr[uint8] = cast[Ptr[uint8]]("B  ")
    whole: uint64 = nbytes
    frac: uint64 = 0
    has_frac: int32 = 0
    if nbytes >= 1073741824:                         # >= 1 GiB
        whole = nbytes / 1073741824
        frac = ((nbytes % 1073741824) * 10) / 1073741824
        unit = cast[Ptr[uint8]]("GiB")
        has_frac = 1
    elif nbytes >= 1048576:                          # >= 1 MiB
        whole = nbytes / 1048576
        frac = ((nbytes % 1048576) * 10) / 1048576
        unit = cast[Ptr[uint8]]("MiB")
        has_frac = 1
    elif nbytes >= 1024:                             # >= 1 KiB
        whole = nbytes / 1024
        frac = ((nbytes % 1024) * 10) / 1024
        unit = cast[Ptr[uint8]]("KiB")
        has_frac = 1
    # Build the number string first, then right-pad to a fixed width.
    num: Array[24, uint8]
    np: uint64 = 0
    np = put_dec(&num[0], np, whole)
    if has_frac != 0:
        num[np] = 46                                # '.'
        np = np + 1
        num[np] = cast[uint8](frac + 48)
        np = np + 1
    num[np] = 32                                    # space before unit
    np = np + 1
    # Right-justify the number+unit into a 10-wide field.
    total_chars: uint64 = np + 3                     # number + ' ' + 3-char unit
    pad: uint64 = 0
    if total_chars < 10:
        pad = 10 - total_chars
    while pad > 0:
        buf[pos] = 32
        pos = pos + 1
        pad = pad - 1
    k: uint64 = 0
    while k < np:
        buf[pos] = num[k]
        pos = pos + 1
        k = k + 1
    u: uint64 = 0
    while u < 3:
        buf[pos] = unit[u]
        pos = pos + 1
        u = u + 1
    buf[pos] = 0


# ====================================================================
# Rendering
# ====================================================================
def scroll_to_cursor():
    if cursor < top:
        top = cursor
    else:
        if cursor >= top + SCREEN_ROWS:
            top = cursor - SCREEN_ROWS + 1


# Draw a proportional bar of BAR_WIDTH cells for `bytes` out of
# `total_size` into the output (filled with '#', empty with ' ').
def draw_bar(nbytes: uint64):
    filled: uint64 = 0
    if total_size > 0:
        filled = (nbytes * BAR_WIDTH) / total_size
    if filled > BAR_WIDTH:
        filled = BAR_WIDTH
    write_cstr(1, cast[Ptr[uint8]]("["))
    c: uint64 = 0
    while c < BAR_WIDTH:
        if c < filled:
            write_cstr(1, cast[Ptr[uint8]]("#"))
        else:
            write_cstr(1, cast[Ptr[uint8]](" "))
        c = c + 1
    write_cstr(1, cast[Ptr[uint8]]("]"))


# Total visible rows = 1 synthetic ".." + num_entries.
def total_rows() -> uint64:
    return num_entries + 1


def redraw():
    write_cstr(1, cast[Ptr[uint8]]("\x1b[?25l\x1b[H"))
    scroll_to_cursor()
    # Header: tool name + current path + total, reverse video.
    write_cstr(1, cast[Ptr[uint8]]("\r\x1b[K\x1b[7m hdu  "))
    sys_write(1, &cur_path[0], cur_path_len)
    write_cstr(1, cast[Ptr[uint8]]("   total "))
    tbuf: Array[16, uint8]
    fmt_size(&tbuf[0], total_size)
    write_cstr(1, cast[Ptr[uint8]](&tbuf[0]))
    write_cstr(1, cast[Ptr[uint8]]("\x1b[0m\r\n"))

    tr: uint64 = total_rows()
    r: uint64 = 0
    while r < SCREEN_ROWS:
        idx: uint64 = top + r
        write_cstr(1, cast[Ptr[uint8]]("\r\x1b[K"))
        if idx < tr:
            sel: int32 = 0
            if idx == cursor:
                sel = 1
            if sel != 0:
                write_cstr(1, cast[Ptr[uint8]]("\x1b[7m"))
            if idx == 0:
                # Synthetic parent entry.
                write_cstr(1, cast[Ptr[uint8]]("                  /.. (parent directory)"))
            else:
                ei: uint64 = order[idx - 1]
                sbuf: Array[16, uint8]
                fmt_size(&sbuf[0], entry_size[ei])
                write_cstr(1, cast[Ptr[uint8]](&sbuf[0]))
                write_cstr(1, cast[Ptr[uint8]](" "))
                draw_bar(entry_size[ei])
                write_cstr(1, cast[Ptr[uint8]](" "))
                sys_write(1, name_ptr(ei), name_len[ei])
                if entry_dir[ei] != 0:
                    write_cstr(1, cast[Ptr[uint8]]("/"))
            if sel != 0:
                write_cstr(1, cast[Ptr[uint8]]("\x1b[0m"))
        write_cstr(1, cast[Ptr[uint8]]("\r\n"))
        r = r + 1

    # Status / help bar.
    write_cstr(1, cast[Ptr[uint8]]("\r\x1b[K\x1b[7m j/k move  Enter/l descend  h/.. up  r rescan  PgUp/PgDn page  q quit "))
    if truncated != 0:
        write_cstr(1, cast[Ptr[uint8]](" | >256 entries (capped)"))
    if status_len > 0:
        write_cstr(1, cast[Ptr[uint8]](" | "))
        sys_write(1, &status_msg[0], status_len)
    write_cstr(1, cast[Ptr[uint8]]("\x1b[0m"))
    write_cstr(1, cast[Ptr[uint8]]("\x1b[H"))
    write_cstr(1, cast[Ptr[uint8]]("\x1b[?25h"))


# ====================================================================
# Actions
# ====================================================================
def cursor_down():
    if cursor + 1 < total_rows():
        cursor = cursor + 1


def cursor_up():
    if cursor > 0:
        cursor = cursor - 1


def page_down():
    tr: uint64 = total_rows()
    cursor = cursor + SCREEN_ROWS
    if tr == 0:
        cursor = 0
    elif cursor >= tr:
        cursor = tr - 1
    scroll_to_cursor()


def page_up():
    if cursor > SCREEN_ROWS:
        cursor = cursor - SCREEN_ROWS
    else:
        cursor = 0
    scroll_to_cursor()


def ascend():
    go_parent()
    status_len = 0
    load_dir()
    # Sync marker for a driving test: emit AFTER the re-measure completes.
    write_cstr(1, cast[Ptr[uint8]]("HDU_ASCEND\n"))


# Descend into the selected row. Row 0 is the synthetic "..".
def descend_selected():
    if cursor == 0:
        ascend()
        return
    ei: uint64 = order[cursor - 1]
    if entry_dir[ei] == 0:
        set_status(cast[Ptr[uint8]]("not a directory"))
        return
    build_full_path(ei)
    set_cur_path(cast[Ptr[uint8]](&full_path[0]))
    status_len = 0
    load_dir()
    write_cstr(1, cast[Ptr[uint8]]("HDU_DESCEND\n"))


def rescan():
    status_len = 0
    # Preserve the cursor position across a manual rescan when possible.
    saved: uint64 = cursor
    load_dir()
    if saved < total_rows():
        cursor = saved
    scroll_to_cursor()
    write_cstr(1, cast[Ptr[uint8]]("HDU_RESCAN\n"))


# ====================================================================
# Key dispatch + escape state machine (modelled on user/hamfm.ad)
# ====================================================================
def dispatch(c: uint8):
    if c == 113:                        # 'q' — quit
        running = 0
    elif c == 106:                      # 'j' — down
        cursor_down()
    elif c == 107:                      # 'k' — up
        cursor_up()
    elif c == 13 or c == 10:            # Enter — descend
        descend_selected()
    elif c == 108:                      # 'l' — descend (vi-right)
        descend_selected()
    elif c == 104:                      # 'h' — ascend (vi-left)
        ascend()
    elif c == 114:                      # 'r' — rescan
        rescan()


def feed_byte(c: uint8):
    if esc_state == 1:
        if c == 91:                     # '[' — CSI
            esc_state = 2
            esc_param = 0
            return
        esc_state = 0
        dispatch(c)
        return
    if esc_state == 2:
        if c >= 48 and c <= 57:         # accumulate a numeric parameter
            esc_param = esc_param * 10 + cast[uint64](c - 48)
            return
        esc_state = 0
        if c == 65:                     # Up
            cursor_up()
        elif c == 66:                   # Down
            cursor_down()
        elif c == 67:                   # Right — descend
            descend_selected()
        elif c == 68:                   # Left — ascend
            ascend()
        elif c == 126:                  # '~' — PgUp/PgDn finalizer
            if esc_param == 6:          # ESC [ 6 ~ — Page Down
                page_down()
            elif esc_param == 5:        # ESC [ 5 ~ — Page Up
                page_up()
        return
    if c == 27:
        esc_state = 1
        return
    dispatch(c)


# ====================================================================
# Main loop
# ====================================================================
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Starting directory: argv[1] if given, else the cwd, else "/".
    if argc >= 2:
        set_cur_path(cast[Ptr[uint8]](argv[1]))
    else:
        cwd: Array[1024, uint8]
        cn: int64 = sys_getcwd(&cwd[0], 1024)
        if cn > 0:
            set_cur_path(cast[Ptr[uint8]](&cwd[0]))
        else:
            set_cur_path(cast[Ptr[uint8]]("/"))

    load_dir()

    # Readiness banner: a stable one-line marker emitted to stdout BEFORE
    # the first repaint so a driving test can poll the serial log and only
    # send navigation keys once hdu owns the raw console (no ANSI so it
    # survives screen clears in the log). Mirrors hamfm's HAMFM_READY.
    write_cstr(1, cast[Ptr[uint8]]("HDU_READY\n"))

    write_cstr(1, cast[Ptr[uint8]]("\x1b[2J\x1b[H"))
    redraw()

    rb: Array[1, uint8]
    while running != 0:
        n: int64 = sys_read_nb(0, &rb[0], 1)
        if n < 0:
            break
        if n == 0:
            sys_yield()
            continue
        feed_byte(rb[0])
        if running != 0:
            redraw()

    write_cstr(1, cast[Ptr[uint8]]("\x1b[2J\x1b[H\x1b[?25h"))
    return 0

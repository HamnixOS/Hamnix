# user/paste.ad
#
# Hamnix `paste`: merge corresponding lines of files, writing them
# out separated by a delimiter (default TAB). Mirrors GNU `paste`
# for the common cases.
#
# Usage:
#   paste FILE1 FILE2 ...        # column-merge: line N of each file
#                                 # joined by the delimiter, one row
#                                 # per N. Short files contribute an
#                                 # empty field once exhausted.
#   paste -d DELIM ...           # use DELIM's bytes (cycled) as the
#                                 # separators instead of TAB.
#   paste -s FILE ...            # serial: each file's lines joined
#                                 # onto a SINGLE output line.
#
# We support up to MAX_FILES inputs; each file is read fully into a
# per-file buffer (bounded by FILE_CAP). This matches GNU output
# byte-for-byte for inputs within those bounds.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


MAX_FILES: uint64 = 8
FILE_CAP:  uint64 = 8192
DELIM_CAP: uint64 = 16

# One contiguous backing store: file i occupies bytes
# [i*FILE_CAP, i*FILE_CAP + flen[i]). Per-file read cursor + length
# are tracked in parallel arrays.
filebuf: Array[65536, uint8]              # MAX_FILES * FILE_CAP
flen:    Array[8, uint64]
fpos:    Array[8, uint64]                 # serial-mode / column-mode cursor
fopen:   Array[8, int32]                  # 1 if this slot loaded ok

# Delimiter byte set (defaults to a single TAB).
delim:    Array[16, uint8]
delim_len: uint64 = 1


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Load file at `path` into slot `idx`. Returns 1 on success, 0 if the
# open failed (slot's flen stays 0 and is treated as an empty file).
def load_file(idx: uint64, path: Ptr[char]) -> int32:
    base: uint64 = cast[uint64](&filebuf[0]) + idx * FILE_CAP
    flen[idx] = 0
    fpos[idx] = 0
    fd: int32 = sys_open(path)
    if fd < 0:
        write_str(2, "paste: cannot open ")
        write_str(2, cast[Ptr[uint8]](path))
        write_str(2, "\n")
        fopen[idx] = 0
        return 0
    total: uint64 = 0
    while total < FILE_CAP:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](base + total),
                            FILE_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    flen[idx] = total
    fopen[idx] = 1
    return 1


# Emit the next line of slot `idx` (content only, NO trailing newline),
# advancing fpos past the consumed newline. Returns 1 if a line (even
# an empty trailing fragment) was emitted, 0 if the file is exhausted.
def emit_next_line(idx: uint64) -> int32:
    base: uint64 = cast[uint64](&filebuf[0]) + idx * FILE_CAP
    p: uint64 = fpos[idx]
    end: uint64 = flen[idx]
    if p >= end:
        return 0
    j: uint64 = p
    while j < end and filebuf[idx * FILE_CAP + j] != 10:
        j = j + 1
    if j > p:
        sys_write(1, cast[Ptr[uint8]](base + p), j - p)
    if j < end:
        fpos[idx] = j + 1                  # skip the newline
    else:
        fpos[idx] = end                    # trailing fragment consumed
    return 1


def emit_delim(which: uint64):
    # GNU cycles through the delimiter set; `which` is the 0-based
    # separator position on the current row.
    d: uint8 = delim[which % delim_len]
    sys_write(1, &d, 1)


# Column (paste-paste) mode: one output row per line-index until every
# file is exhausted. A file that has run out contributes an empty field.
def paste_columns(nfiles: uint64):
    while True:
        any: int32 = 0
        # First pass: is there any remaining content across all files?
        k: uint64 = 0
        while k < nfiles:
            if fpos[k] < flen[k]:
                any = 1
            k = k + 1
        if any == 0:
            break
        c: uint64 = 0
        while c < nfiles:
            if c != 0:
                emit_delim(c - 1)
            emit_next_line(c)              # empty field if exhausted
            c = c + 1
        sys_write(1, "\n", 1)


# Serial mode: each file's lines are joined onto one line with the
# delimiter, then a newline ends that file's row.
def paste_serial(nfiles: uint64):
    f: uint64 = 0
    while f < nfiles:
        first: int32 = 1
        sep: uint64 = 0
        while fpos[f] < flen[f]:
            if first == 0:
                emit_delim(sep)
                sep = sep + 1
            emit_next_line(f)
            first = 0
        sys_write(1, "\n", 1)
        f = f + 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    delim[0] = 9                           # default TAB
    delim_len = 1
    serial: int32 = 0

    # Parse leading flags: -d DELIM and -s. Stop at the first non-flag.
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] != 45 or a[1] == 0:
            break
        if a[1] == 115 and a[2] == 0:                  # "-s"
            serial = 1
            ai = ai + 1
        elif a[1] == 100:                              # "-d..."
            dsrc: Ptr[uint8] = cast[Ptr[uint8]](0)
            if a[2] != 0:
                dsrc = cast[Ptr[uint8]](cast[uint64](a) + 2)   # "-dDELIM"
            else:
                if ai + 1 >= argc:
                    write_str(2, "paste: option requires an argument -- d\n")
                    return 1
                ai = ai + 1
                dsrc = cast[Ptr[uint8]](argv[cast[uint64](ai)])
            dl: uint64 = strlen_u8(dsrc)
            if dl == 0:
                dl = 1
                delim[0] = 0               # GNU: empty -d means NUL? we keep
            if dl > DELIM_CAP:
                dl = DELIM_CAP
            di: uint64 = 0
            while di < dl:
                delim[di] = dsrc[di]
                di = di + 1
            delim_len = dl
            ai = ai + 1
        else:
            write_str(2, "paste: unknown flag\n")
            return 1

    if ai >= argc:
        write_str(2, "paste: missing operand\n")
        return 1

    # Load each remaining argv as a file (up to MAX_FILES).
    nfiles: uint64 = 0
    while ai < argc and nfiles < MAX_FILES:
        load_file(nfiles, cast[Ptr[char]](argv[cast[uint64](ai)]))
        nfiles = nfiles + 1
        ai = ai + 1

    if serial != 0:
        paste_serial(nfiles)
    else:
        paste_columns(nfiles)
    return 0

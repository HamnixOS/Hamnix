# user/haminbox.ad
#
# haminbox — the MATE-style notification INBOX / message tray, as a
# SCENE-mode client (docs/de_scene_file_arch.md). It replaces the legacy
# hamUId-blit history panel (user/hamtray.ad), which paints nothing in the
# production runlevel-5 scene DE. It follows user/hamabout.ad exactly: it
# `newwindow`s, sets geometry/decorate/z/title, emits a scene display list,
# and reads its OWN input from /dev/wsys/<wid>/event + /keys.
#
# DATA SOURCE: the notification HISTORY is maintained by the panel broker
# (user/hampanelscene.ad) as a small append-style log in tmpfs:
#
#   /tmp/hamnix-notif.log   one record per line:  "<title>\t<body>\n"
#
# The panel writes the most-recent-LAST list (capped) every time it drains a
# new /dev/wsys/post record; the inbox reads the whole file at startup and
# lists the entries newest-first. Clicking the inbox spawns it ON DEMAND from
# the panel's tray applet, so it is short-lived (LIFETIME == VISIBILITY):
# Escape, a click on Close, or a click outside the window dismisses it.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
extern def sys_exit(code: int32)

from lib.hamui import hamscene_begin, hamscene_fill, hamscene_rect, \
    hamscene_glyphs, hamscene_glyphs_bold, hamscene_stroke, hamscene_commit


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Parse "m <x> <y> <buttons> ..." → 1 + fills bx/by/bbtn; else 0.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[3, int64]
    v: uint64 = 0
    while v < 3:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc2: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc2 = acc2 * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            return 0
        if neg != 0:
            acc2 = 0 - acc2
        vals[v] = acc2
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    return 1


# ====================================================================
# HISTORY (parsed from /tmp/hamnix-notif.log into fixed buffers).
# ====================================================================
MAX_ROWS: uint64 = 8
ROW_CAP:  uint64 = 96                  # rendered "title — body" length cap
row_text: Array[768, uint8]           # 8 * 96
row_len:  Array[8, uint64]
n_rows: uint64 = 0

LOG_CAP: uint64 = 2048
log_buf: Array[2048, uint8]


# Append byte `c` to row `r`'s buffer (capped).
def _row_put(r: uint64, p: uint64, c: uint8) -> uint64:
    if p >= ROW_CAP - 1:
        return p
    row_text[r * ROW_CAP + p] = c
    return p + 1


def _load_history():
    n_rows = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/tmp/hamnix-notif.log"))
    if fd < 0:
        return
    total: uint64 = 0
    while total < LOG_CAP:
        r: int64 = sys_read(fd, cast[Ptr[uint8]](
            cast[uint64](&log_buf[0]) + total), LOG_CAP - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    # The file is oldest-first; we want newest-first, capped to MAX_ROWS.
    # First split into line spans (start offsets) in pass 1, then render the
    # last MAX_ROWS in reverse.
    starts: Array[64, uint64]
    nlines: uint64 = 0
    i: uint64 = 0
    ls: uint64 = 0
    while i <= total:
        atend: int32 = 0
        if i == total:
            atend = 1
        if atend == 1 or log_buf[i] == 10:
            if i > ls:
                if nlines < 64:
                    starts[nlines] = ls
                    nlines = nlines + 1
            ls = i + 1
        i = i + 1
    # Render the newest MAX_ROWS lines, newest-first.
    take: uint64 = nlines
    if take > MAX_ROWS:
        take = MAX_ROWS
    k: uint64 = 0
    while k < take:
        src_line: uint64 = nlines - 1 - k        # newest first
        s: uint64 = starts[src_line]
        # find end of this line
        e: uint64 = s
        while e < total and log_buf[e] != 10:
            e = e + 1
        # format "<title> — <body>", converting the tab to " — ".
        p: uint64 = 0
        j: uint64 = s
        seen_tab: int32 = 0
        while j < e:
            c: uint8 = log_buf[j]
            if c == 9 and seen_tab == 0:
                seen_tab = 1
                p = _row_put(k, p, 32)
                p = _row_put(k, p, 45)            # '-'
                p = _row_put(k, p, 32)
            elif c != 9:
                p = _row_put(k, p, c)
            j = j + 1
        row_text[k * ROW_CAP + p] = 0
        row_len[k] = p
        k = k + 1
    n_rows = take


def row_ptr(r: uint64) -> Ptr[uint8]:
    return cast[Ptr[uint8]](cast[uint64](&row_text[0]) + r * ROW_CAP)


# ====================================================================
# LAYOUT + RENDER
# ====================================================================
WIN_W: int32 = 420
WIN_H: int32 = 320
PAD:   int32 = 16
TITLE_H: int32 = 26
ROW_H: int32 = 26

BTN_W: int32 = 90
BTN_H: int32 = 30
BTN_X: int32 = 0
BTN_Y: int32 = 0


def _layout():
    BTN_X = WIN_W - PAD - BTN_W
    BTN_Y = WIN_H - PAD - BTN_H


def emit_scene(wid: int32):
    hamscene_begin()
    hamscene_fill(0, 0, WIN_W, WIN_H, cast[Ptr[uint8]]("#34384a"))
    hamscene_stroke(0, 0, WIN_W, WIN_H, 1, cast[Ptr[uint8]]("#78aad2"))

    # Header.
    hamscene_glyphs_bold(PAD, PAD, cast[Ptr[uint8]]("Notifications"),
                         cast[Ptr[uint8]]("#e8f0ff"))
    hamscene_fill(PAD, PAD + TITLE_H - 4, WIN_W - PAD * 2, 1,
                  cast[Ptr[uint8]]("#5a6280"))

    if n_rows == 0:
        hamscene_glyphs(PAD, PAD + TITLE_H + 8,
                        cast[Ptr[uint8]]("No notifications."),
                        cast[Ptr[uint8]]("#aab8d8"))
    else:
        y0: int32 = PAD + TITLE_H + 6
        r: uint64 = 0
        while r < n_rows:
            ry: int32 = y0 + cast[int32](r) * ROW_H
            # Row card.
            hamscene_fill(PAD, ry, WIN_W - PAD * 2, ROW_H - 4,
                          cast[Ptr[uint8]]("#3c4256"))
            # Bullet + text.
            hamscene_fill(PAD + 4, ry + 8, 5, 5, cast[Ptr[uint8]]("#6e96e6"))
            hamscene_glyphs(PAD + 16, ry + 5, row_ptr(r),
                            cast[Ptr[uint8]]("#d8e0f0"))
            r = r + 1

    # Close button.
    hamscene_fill(BTN_X, BTN_Y, BTN_W, BTN_H, cast[Ptr[uint8]]("#e6e8ec"))
    hamscene_stroke(BTN_X, BTN_Y, BTN_W, BTN_H, 1,
                    cast[Ptr[uint8]]("#808080"))
    lbl: Ptr[uint8] = cast[Ptr[uint8]]("Close")
    lw: int32 = cast[int32](_slen(lbl)) * 8
    hamscene_glyphs(BTN_X + (BTN_W - lw) / 2, BTN_Y + (BTN_H - 8) / 2, lbl,
                    cast[Ptr[uint8]]("#202020"))

    hamscene_commit(wid)


def _in_close(lx: int64, ly: int64) -> int32:
    if lx >= cast[int64](BTN_X) and lx < cast[int64](BTN_X + BTN_W) and \
       ly >= cast[int64](BTN_Y) and ly < cast[int64](BTN_Y + BTN_H):
        return 1
    return 0


def _outside(lx: int64, ly: int64) -> int32:
    if lx < 0 or lx >= cast[int64](WIN_W) or \
       ly < 0 or ly >= cast[int64](WIN_H):
        return 1
    return 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    _load_history()
    _layout()

    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[haminbox] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp:  Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 300 60 420 320\n"))
        sys_close(cfd)
    # Undecorated so it stays out of the taskbar; it draws its own frame.
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 0\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 9\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Notifications\n"))
        sys_close(cfdt)

    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[haminbox] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    btn_down: int32 = 0
    evbuf: Array[256, uint8]
    kbuf:  Array[256, uint8]
    while True:
        # --- KEYBOARD: Escape dismisses.
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                ki: uint64 = 0
                while ki < cast[uint64](kr):
                    if kbuf[ki] == 27:
                        sys_exit(0)
                    if kbuf[ki] == 100:                  # 'd' press line
                        kj: uint64 = ki + 1
                        while kj < cast[uint64](kr) and kbuf[kj] == 32:
                            kj = kj + 1
                        code: int32 = 0
                        while kj < cast[uint64](kr) and kbuf[kj] >= 48 and \
                              kbuf[kj] <= 57:
                            code = code * 10 + cast[int32](kbuf[kj]) - 48
                            kj = kj + 1
                        if code == 27:
                            sys_exit(0)
                    ki = ki + 1

        # --- POINTER: blocking read of /event (parks off-runqueue).
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    if _in_close(bx, by) != 0:
                                        sys_exit(0)
                                    if _outside(bx, by) != 0:
                                        sys_exit(0)
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

# user/js.ad
#
# Hamnix native `js`: evaluate JavaScript on the native (x86_64-adder-user)
# target, INSIDE Hamnix, via the pure engine lib/jsengine.ad — the SAME lexer +
# parser + tree-walking evaluator the host driver (user/js_host.ad) and the
# native browser use. This is the OS scripting engine as a first-class tool.
#
#   js FILE.js        evaluate a script file, print its console.log output
#   js                run a built-in self-test snippet (the boot gate uses this)
#
# NOTE: the native user stack is a single 4 KiB page and the evaluator recurses
# per AST/JS-call depth, so DEEP JS recursion is bounded on the native target.
# The built-in snippet is deliberately shallow (loops, arrays, objects, JSON,
# string/Math builtins — no deep recursion). The host driver (normal 8 MiB
# stack) runs the full suite incl. recursive fib in scripts/test_jsengine_host.sh.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.jsengine import js_init, js_eval, js_out_len, js_error


FILE_CAP: uint64 = 131072
file_buf: Array[131072, uint8]
file_len: uint64 = 0

# Built-in shallow self-test (no deep recursion — safe on the 4 KiB stack).
DEMO: Array[512, uint8]


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _read_file(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    file_len = 0
    while file_len < FILE_CAP - 1:
        n: int64 = sys_read(fd, &file_buf[file_len], FILE_CAP - 1 - file_len)
        if n <= 0:
            break
        file_len = file_len + cast[uint64](n)
    sys_close(fd)
    return 0


def _build_demo():
    # Assemble the demo source at runtime (adjacent string literals are not
    # supported by the compiler, so copy fragments into one buffer).
    p: int32 = 0
    p = _demo_put(p, cast[Ptr[uint8]]("var a=[1,2,3,4]; a.push(5);\n"))
    p = _demo_put(p, cast[Ptr[uint8]]("var sq=a.map(function(n){return n*n;});\n"))
    p = _demo_put(p, cast[Ptr[uint8]]("var o={name:'hamnix',n:a.length};\n"))
    p = _demo_put(p, cast[Ptr[uint8]]("var s=0; for(var i=0;i<a.length;i++){s+=a[i];}\n"))
    p = _demo_put(p, cast[Ptr[uint8]]("console.log('JS-OK', o.name, 'sum='+s, 'sq='+sq.join(','));\n"))
    p = _demo_put(p, cast[Ptr[uint8]]("console.log('json='+JSON.stringify(o));\n"))
    p = _demo_put(p, cast[Ptr[uint8]]("console.log('math='+Math.max(3,9,2), 'up='+'abc'.toUpperCase());\n"))
    DEMO[p] = 0


def _demo_put(p: int32, s: Ptr[uint8]) -> int32:
    i: int32 = 0
    while s[i] != 0:
        DEMO[p] = s[i]
        p = p + 1
        i = i + 1
    return p


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    js_init()
    src: Ptr[uint8] = 0
    slen: uint64 = 0
    if argc >= 2:
        if _read_file(cast[Ptr[char]](argv[1])) != 0:
            _write_str(2, cast[Ptr[uint8]]("js: cannot open file\n"))
            return 1
        src = &file_buf[0]
        slen = file_len
    else:
        _build_demo()
        src = &DEMO[0]
        slen = _slen(&DEMO[0])
    out: Ptr[uint8] = js_eval(src, slen)
    sys_write(1, out, js_out_len())
    if js_error() != 0:
        return 1
    return 0

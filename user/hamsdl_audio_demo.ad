# user/hamsdl_audio_demo.ad — NATIVE (x86_64-adder-user) demo/dual-target proof
# for the hamSDL audio API. Wires the DEVICE backend (lib/hamsdl_audio_dev.ad) to
# the shared registry (lib/hamsdl_audio.ad): open the sink, load a SFX, play it,
# then stream a music clip on loop and pump it — exactly the calls a real hamSDL
# game makes on device. Its job in CI is to keep the DEVICE half of the audio
# dual-target seam compiling (mirrors how user/sdlpong.ad guards hamSDL's video
# seam); scripts/test_hamsdl_audio_host.sh compiles it for x86_64-adder-user.

from lib.hamsdl_audio import sdl_set_volume
from lib.hamsdl_audio_dev import sdl_audio_init, sdl_load_sound, \
    sdl_play_sound, sdl_play_music, sdl_stop_music, sdl_audio_pump


def main() -> int32:
    if sdl_audio_init() != 0:
        return 1
    sdl_set_volume(96)

    # Load a one-shot sound effect and play it.
    if sdl_load_sound(cast[Ptr[uint8]]("blip"),
                      cast[Ptr[char]]("/usr/share/sounds/test.wav")) >= 0:
        sdl_play_sound(cast[Ptr[uint8]]("blip"))

    # Start looping background music, then service the loop each "frame".
    sdl_play_music(cast[Ptr[char]]("/usr/share/sounds/test.wav"), 1)
    i: int32 = 0
    while i < 4:
        sdl_audio_pump()
        i = i + 1
    sdl_stop_music()
    return 0

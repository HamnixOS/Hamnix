# user/sdlpong_host.ad — the hamSDL demo game, HOST render + drive harness
# (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME game the device app ships (lib/sdlpong.ad) through the SAME
# public hamSDL API, but with the HOST backend (lib/hamsdl_host.ad): it renders
# frames to binary PPMs a human/agent can LOOK at, feeds SCRIPTED input (both
# raw queue pushes and DE wire lines through the shared parser), and dumps the
# game state + sampled pixels so scripts/test_hamsdl_host.sh can assert on
# layout, colour, motion (timing) and input WITHOUT eyeballing.
#
# USAGE (built to build/host/sdlpong_host):  sdlpong_host BEFORE.ppm AFTER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamsdl import sdl_poll_event, sdl_push_event, sdl_feed_keys_buffer, \
    sdl_feed_event_buffer, SDL_KEYDOWN, SDL_MOUSEBUTTONDOWN, \
    SDLK_LEFT, SDLK_RIGHT
from lib.hamsdl_host import sdl_host_present, sdl_host_write_ppm, \
    sdl_host_pixel
from lib.sdlpong import pong_init, pong_key, pong_update, pong_render, \
    pong_test_place, pong_paddle_center_x, pong_ball_x, pong_ball_y, \
    pong_paddle_x, pong_paddle_y, pong_score, pong_misses


W: int32 = 320
H: int32 = 360


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)                                            # '#'
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_kv(k: Ptr[uint8], v: int64):
    _o_str(k)
    _o_ch(32)
    _o_dec(v)
    _o_ch(10)


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _dump_scene():
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: sdlpong_host BEFORE.ppm AFTER.ppm\n"))
        _o_flush()
        return 2

    pong_init(W, H)

    # ---- BEFORE frame ---------------------------------------------------
    pong_render()
    prims: int32 = sdl_host_present(W, H)
    sdl_host_write_ppm(cast[Ptr[char]](argv[1]))

    bx0: int32 = pong_ball_x()
    by0: int32 = pong_ball_y()
    px0: int32 = pong_paddle_x()
    _o_kv(cast[Ptr[uint8]]("PRIMS"), cast[int64](prims))
    _o_kv(cast[Ptr[uint8]]("BALLX0"), cast[int64](bx0))
    _o_kv(cast[Ptr[uint8]]("BALLY0"), cast[int64](by0))
    _o_kv(cast[Ptr[uint8]]("PADDLEX0"), cast[int64](px0))
    _o_kv(cast[Ptr[uint8]]("SCORE0"), cast[int64](pong_score()))
    # Sampled pixels prove the RASTERIZER ran (not just the builder).
    _o_str(cast[Ptr[uint8]]("PIX 0 0 "))
    _o_hexcol(sdl_host_pixel(0, 0))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 160 46 "))               # ball centre
    _o_hexcol(sdl_host_pixel(160, 46))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 160 336 "))              # paddle centre
    _o_hexcol(sdl_host_pixel(160, 336))
    _o_ch(10)
    _o_flush()
    _dump_scene()

    # ---- MOTION (timing/update) proof: advance the world, count moves ----
    moved: int32 = 0
    lastx: int32 = bx0
    lasty: int32 = by0
    f: int32 = 0
    while f < 40:
        pong_update()
        if pong_ball_x() != lastx or pong_ball_y() != lasty:
            moved = moved + 1
        lastx = pong_ball_x()
        lasty = pong_ball_y()
        f = f + 1
    _o_kv(cast[Ptr[uint8]]("MOVED"), cast[int64](moved))
    _o_kv(cast[Ptr[uint8]]("BALLX1"), cast[int64](pong_ball_x()))
    _o_kv(cast[Ptr[uint8]]("BALLY1"), cast[int64](pong_ball_y()))

    # ---- INPUT proof (raw queue): three KEYDOWN LEFT slide the paddle ----
    sdl_push_event(SDL_KEYDOWN, SDLK_LEFT, 0, 0, 0)
    sdl_push_event(SDL_KEYDOWN, SDLK_LEFT, 0, 0, 0)
    sdl_push_event(SDL_KEYDOWN, SDLK_LEFT, 0, 0, 0)
    kind: int32 = 0
    key: int32 = 0
    ax: int32 = 0
    ay: int32 = 0
    abtn: int32 = 0
    while sdl_poll_event(&kind, &key, &ax, &ay, &abtn) == 1:
        if kind == SDL_KEYDOWN:
            pong_key(key)
    _o_kv(cast[Ptr[uint8]]("PADDLEX1"), cast[int64](pong_paddle_x()))

    # ---- INPUT proof (wire parser): an ESC-[-C arrow -> SDLK_RIGHT event --
    # Feed the exact 3 press lines the compositor delivers for a RIGHT arrow.
    keybuf: Array[16, uint8]
    keybuf[0] = 100                                       # 'd'
    keybuf[1] = 32
    keybuf[2] = 50                                        # '2'
    keybuf[3] = 55                                        # '7'  -> 27 ESC
    keybuf[4] = 10
    keybuf[5] = 100
    keybuf[6] = 32
    keybuf[7] = 57                                        # '9'
    keybuf[8] = 49                                        # '1'  -> 91 '['
    keybuf[9] = 10
    keybuf[10] = 100
    keybuf[11] = 32
    keybuf[12] = 54                                       # '6'
    keybuf[13] = 55                                       # '7'  -> 67 'C' RIGHT
    keybuf[14] = 10
    sdl_feed_keys_buffer(&keybuf[0], 15)
    arrow_right: int32 = 0
    while sdl_poll_event(&kind, &key, &ax, &ay, &abtn) == 1:
        if kind == SDL_KEYDOWN and key == SDLK_RIGHT:
            arrow_right = 1
            pong_key(key)
    _o_kv(cast[Ptr[uint8]]("ARROWRIGHT"), cast[int64](arrow_right))
    _o_kv(cast[Ptr[uint8]]("PADDLEX2"), cast[int64](pong_paddle_x()))

    # ---- INPUT proof (pointer parser): a left-click edge -> BUTTONDOWN ----
    evbuf: Array[16, uint8]
    evbuf[0] = 109                                        # 'm'
    evbuf[1] = 32
    evbuf[2] = 53                                         # '5'
    evbuf[3] = 48                                         # '0' -> x=50
    evbuf[4] = 32
    evbuf[5] = 54
    evbuf[6] = 48                                         # y=60
    evbuf[7] = 32
    evbuf[8] = 49                                         # btn=1 (left down)
    evbuf[9] = 10
    sdl_feed_event_buffer(&evbuf[0], 10)
    clickdown: int32 = 0
    clickx: int32 = 0
    while sdl_poll_event(&kind, &key, &ax, &ay, &abtn) == 1:
        if kind == SDL_MOUSEBUTTONDOWN:
            clickdown = 1
            clickx = ax
    _o_kv(cast[Ptr[uint8]]("CLICKDOWN"), cast[int64](clickdown))
    _o_kv(cast[Ptr[uint8]]("CLICKX"), cast[int64](clickx))

    # ---- SCORING proof: drop the ball onto a centred paddle, save it -----
    pong_paddle_center_x(W / 2)
    ppy: int32 = pong_paddle_y()
    pong_test_place(W / 2 - 6, ppy - 12, 0, 4)            # just above, descending
    s_before: int32 = pong_score()
    pong_update()                                         # should land + score
    s_after: int32 = pong_score()
    _o_kv(cast[Ptr[uint8]]("SCOREHIT_BEFORE"), cast[int64](s_before))
    _o_kv(cast[Ptr[uint8]]("SCOREHIT_AFTER"), cast[int64](s_after))
    _o_kv(cast[Ptr[uint8]]("MISSES"), cast[int64](pong_misses()))
    _o_flush()

    # ---- AFTER frame (post input + motion) ------------------------------
    pong_render()
    sdl_host_present(W, H)
    sdl_host_write_ppm(cast[Ptr[char]](argv[2]))
    return 0

# user/hamangrybirds.ad — NATIVE driver for the Angry-Birds-style slingshot
# physics game ("Ham Angry Birds").
#
# The game + physics state machine, layout, scene display-list builder and pure
# input handlers all live in lib/hamangrycore.ad (extern-free, target-agnostic)
# so they can ALSO be exercised + rendered on the developer's host (see
# user/hamangrybirds_host.ad + docs/hamui_dual_target.md). This file keeps ONLY
# the Hamnix-only transport: opening a wsys window, reading its /keys + /event
# files, a jiffy-paced physics tick WHILE a bird is in flight, and committing
# the built scene to /dev/wsys/<wid>/scene via lib/hamui.ad's hamscene_commit().
#
# RENDER: sky/ground, a slingshot on the left (with a dotted aim preview), a
# stacked structure of destructible wood/stone blocks + pig targets on the
# right, the bird, and a control row (New / Aim- / Aim+ / Pwr- / Pwr+ / Launch).
# INPUT: /keys (W/S or Up/Down aim angle, A/D or Left/Right power, Space/Enter
# launch, R/N new) and /event (pointer presses hit-test the control buttons).
# The physics only ticks while a bird flies, so an idle window commits nothing.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamsceneloop import hamscene_park
from lib.hamui import hamscene_commit
from lib.hamangrycore import hangry_reset, hangry_build_scene, \
    hangry_draw_overlay, hangry_step, hangry_bird_active, \
    hangry_key_line, hangry_btn_at, hangry_ctrl_press, parse_pointer, \
    _slen, _u64_to_dec


# Advance the physics every ~33 ms (3 jiffies at 100Hz) so the arc is smooth.
TICK_JIFFIES: uint64 = 3
# Re-poll the park (pointer + tick clock) ~every 16 ms; a keystroke wakes it.
PARK_MS: int64 = 16


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def emit_scene(wid: int32):
    hangry_build_scene()
    hangry_draw_overlay()
    hamscene_commit(wid)


btn_down: int32 = 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamangry] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp:  Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 300 100 480 360\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Ham Angry Birds\n"))
        sys_close(cfdt)

    hangry_reset()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamangry] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
    evbuf: Array[256, uint8]
    kbuf:  Array[256, uint8]
    last_tick: uint64 = sys_get_jiffies()
    while True:
        changed: int32 = 0
        # --- KEYBOARD: non-blocking drain of /keys, apply press lines.
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if hangry_key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1
        # --- POINTER: NON-BLOCKING drain of /event, hit-test the buttons.
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    b: int64 = hangry_btn_at(bx, by)
                                    if b >= 0:
                                        hangry_ctrl_press(b)
                                        changed = 1
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        # --- TICK: advance the physics on the fixed jiffy cadence while a bird
        # is in flight.
        now: uint64 = sys_get_jiffies()
        if now - last_tick >= TICK_JIFFIES:
            last_tick = now
            if hangry_bird_active() != 0:
                if hangry_step() != 0:
                    changed = 1
        if changed != 0:
            emit_scene(wid)
        # Park OFF the runqueue: a keystroke wakes us instantly, the timeout
        # bounds the pointer re-poll AND paces the flight tick above.
        hamscene_park(kfd, PARK_MS)
    return 0

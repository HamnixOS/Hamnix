# user/column.ad
#
# Hamnix `column`: format input text into multiple columns. A faithful
# subset of util-linux `column`.
#
# Modes:
#   default ("fill columns"): pack non-empty input lines into as many
#     equal-width columns as fit in the output width (default 80),
#     padding each entry to the longest entry + a 2-space gap. Fill
#     down-then-across (column-major), like `ls` multi-column output.
#   -t        table mode: each input line is a row of whitespace-
#             separated fields; print aligned into a table where each
#             output column is as wide as the widest field in it,
#             separated by two spaces.
#   -s <sep>  (with -t) split fields on the given delimiter char
#             instead of whitespace.
#   -c <width> override the total output width used by fill mode.
#
# Input comes from stdin (fd 0) or a single file argument. The whole
# input is buffered into fixed arrays: up to MAX_LINES lines of up to
# MAX_LINE bytes each; excess is dropped rather than crashing.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


MAX_LINES: uint64 = 4096
MAX_LINE: uint64 = 1024
MAX_FIELDS: uint64 = 64

# Flat store of every input line. linebuf is a single contiguous block;
# line_off[i]/line_len[i] index a line's bytes within it. A bump pointer
# (store_used) packs lines back-to-back so we don't need a 2-D array.
linebuf: Array[4194304, uint8]    # MAX_LINES * MAX_LINE
line_off: Array[4096, uint64]
line_len: Array[4096, uint64]
nlines: uint64 = 0
store_used: uint64 = 0

# Read buffer used while collecting a single logical line.
cur: Array[1024, uint8]
curlen: uint64 = 0

# Per-column widths for -t table mode.
colw: Array[64, uint64]
ncols: uint64 = 0

# A small scratch for padding spaces.
spaces: Array[256, uint8]

outwidth: uint64 = 80
table_mode: int32 = 0
have_sep: int32 = 0
sep: uint8 = 32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_uint(s: Ptr[uint8]) -> int64:
    if s[0] == 0:
        return -1
    n: int64 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int64](c - 48)
        i = i + 1
    return n


def emit_spaces(count: uint64):
    # Write `count` spaces, chunking through the spaces scratch buffer.
    left: uint64 = count
    while left > 0:
        take: uint64 = left
        if take > 256:
            take = 256
        sys_write(1, &spaces[0], take)
        left = left - take


def store_line():
    # Commit the current accumulated line (cur[0..curlen]) into the flat
    # store. Drops the line if either cap is exceeded.
    if nlines >= MAX_LINES:
        curlen = 0
        return
    if store_used + curlen > 4194304:
        # No room left; drop quietly.
        curlen = 0
        return
    line_off[nlines] = store_used
    line_len[nlines] = curlen
    i: uint64 = 0
    while i < curlen:
        linebuf[store_used + i] = cur[i]
        i = i + 1
    store_used = store_used + curlen
    nlines = nlines + 1
    curlen = 0


def read_all(fd: int32):
    # Read fd to EOF, splitting on '\n' into stored lines. A final line
    # without a trailing newline is still committed.
    chunk: Array[256, uint8]
    saw: int32 = 0
    while True:
        n: int64 = sys_read(fd, &chunk[0], 256)
        if n <= 0:
            break
        bi: uint64 = 0
        while bi < cast[uint64](n):
            c: uint8 = chunk[bi]
            saw = 1
            if c == 10:
                store_line()
            else:
                if curlen + 1 < MAX_LINE:
                    cur[curlen] = c
                    curlen = curlen + 1
            bi = bi + 1
    if curlen > 0:
        store_line()


# ---------------------------------------------------------------------------
# Fill mode (column-major, down-then-across).
# ---------------------------------------------------------------------------

def is_blank_line(idx: uint64) -> int32:
    # util-linux column skips empty input lines in fill mode.
    if line_len[idx] == 0:
        return 1
    return 0


def fill_mode():
    # Collect indices of non-empty lines.
    # We reuse the stored order; build a compact list in colw-sized scratch
    # is not enough, so index directly with a running counter.
    # First pass: count non-empty lines and find the widest entry.
    count: uint64 = 0
    maxw: uint64 = 0
    i: uint64 = 0
    while i < nlines:
        if is_blank_line(i) == 0:
            count = count + 1
            if line_len[i] > maxw:
                maxw = line_len[i]
        i = i + 1
    if count == 0:
        return

    gap: uint64 = 2
    colwidth: uint64 = maxw + gap

    # How many columns fit. At least one.
    cols: uint64 = 1
    if colwidth > 0 and outwidth >= colwidth:
        cols = outwidth / colwidth
    if cols == 0:
        cols = 1
    if cols > count:
        cols = count

    # Rows needed = ceil(count / cols). column-major fill.
    rows: uint64 = (count + cols - 1) / cols
    if rows == 0:
        rows = 1

    # Build a compact array of non-empty line indices on the fly via a
    # mapping function: the k-th non-empty line.
    # To avoid a second index array we walk and select; small N is fine.
    r: uint64 = 0
    while r < rows:
        c: uint64 = 0
        while c < cols:
            # column-major index into the non-empty sequence.
            seq: uint64 = c * rows + r
            if seq < count:
                idx: uint64 = nth_nonblank(seq)
                ln: uint64 = line_len[idx]
                sys_write(1, &linebuf[line_off[idx]], ln)
                # Pad unless this is the last column on the row.
                is_last: int32 = 0
                if c + 1 >= cols:
                    is_last = 1
                else:
                    # Also "last" if no further entry exists on this row.
                    nxt: uint64 = (c + 1) * rows + r
                    if nxt >= count:
                        is_last = 1
                if is_last == 0:
                    emit_spaces(colwidth - ln)
            c = c + 1
        sys_write(1, "\n", 1)
        r = r + 1


def nth_nonblank(k: uint64) -> uint64:
    # Return the stored index of the k-th (0-based) non-empty line.
    seen: uint64 = 0
    i: uint64 = 0
    while i < nlines:
        if is_blank_line(i) == 0:
            if seen == k:
                return i
            seen = seen + 1
        i = i + 1
    return 0


# ---------------------------------------------------------------------------
# Table mode.
# ---------------------------------------------------------------------------

def is_field_sep(c: uint8) -> int32:
    if have_sep != 0:
        if c == sep:
            return 1
        return 0
    # Default: any ASCII whitespace.
    if c == 32 or c == 9:
        return 1
    return 0


def field_count(idx: uint64) -> uint64:
    # Count fields in a stored line.
    off: uint64 = line_off[idx]
    ln: uint64 = line_len[idx]
    fields: uint64 = 0
    i: uint64 = 0
    in_field: int32 = 0
    if have_sep != 0:
        # Delimiter-separated: empty fields count; N seps => N+1 fields.
        if ln == 0:
            return 0
        fields = 1
        while i < ln:
            if linebuf[off + i] == sep:
                fields = fields + 1
            i = i + 1
        return fields
    # Whitespace: collapse runs; leading/trailing ws ignored.
    while i < ln:
        c: uint8 = linebuf[off + i]
        if is_field_sep(c) != 0:
            in_field = 0
        else:
            if in_field == 0:
                fields = fields + 1
                in_field = 1
        i = i + 1
    return fields


def field_bounds(idx: uint64, want: uint64, start: Ptr[uint64], length: Ptr[uint64]) -> int32:
    # Locate the `want`-th (0-based) field of stored line idx. Sets
    # start (offset into linebuf) and length. Returns 1 if found else 0.
    off: uint64 = line_off[idx]
    ln: uint64 = line_len[idx]
    i: uint64 = 0
    fno: uint64 = 0
    if have_sep != 0:
        fstart: uint64 = 0
        while True:
            # Find end of current field (next sep or end).
            j: uint64 = fstart
            while j < ln and linebuf[off + j] != sep:
                j = j + 1
            if fno == want:
                start[0] = off + fstart
                length[0] = j - fstart
                return 1
            if j >= ln:
                return 0
            fstart = j + 1
            fno = fno + 1
        return 0
    # Whitespace mode.
    in_field: int32 = 0
    fstart2: uint64 = 0
    while i <= ln:
        is_end: int32 = 0
        if i == ln:
            is_end = 1
        sep_here: int32 = 0
        if i < ln:
            if is_field_sep(linebuf[off + i]) != 0:
                sep_here = 1
        if in_field != 0 and (is_end != 0 or sep_here != 0):
            # field [fstart2, i)
            if fno == want:
                start[0] = off + fstart2
                length[0] = i - fstart2
                return 1
            fno = fno + 1
            in_field = 0
        elif in_field == 0 and sep_here == 0 and is_end == 0:
            in_field = 1
            fstart2 = i
        i = i + 1
    return 0


def table_mode_run():
    # First pass: determine the max number of columns and per-column widths.
    ncols = 0
    z: uint64 = 0
    while z < MAX_FIELDS:
        colw[z] = 0
        z = z + 1

    i: uint64 = 0
    while i < nlines:
        if line_len[i] == 0:
            i = i + 1
            continue
        fc: uint64 = field_count(i)
        if fc > MAX_FIELDS:
            fc = MAX_FIELDS
        if fc > ncols:
            ncols = fc
        f: uint64 = 0
        while f < fc:
            st: uint64 = 0
            ln: uint64 = 0
            if field_bounds(i, f, &st, &ln) != 0:
                if ln > colw[f]:
                    colw[f] = ln
            f = f + 1
        i = i + 1

    # Second pass: print each row aligned.
    i = 0
    while i < nlines:
        if line_len[i] == 0:
            # Preserve blank lines as blank output lines.
            sys_write(1, "\n", 1)
            i = i + 1
            continue
        fc: uint64 = field_count(i)
        if fc > MAX_FIELDS:
            fc = MAX_FIELDS
        f: uint64 = 0
        while f < fc:
            st: uint64 = 0
            ln: uint64 = 0
            if field_bounds(i, f, &st, &ln) != 0:
                sys_write(1, &linebuf[st], ln)
            else:
                ln = 0
            if f + 1 < fc:
                # Pad to column width, then a 2-space gap.
                if colw[f] > ln:
                    emit_spaces(colw[f] - ln)
                emit_spaces(2)
            f = f + 1
        sys_write(1, "\n", 1)
        i = i + 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Init spaces scratch.
    si: uint64 = 0
    while si < 256:
        spaces[si] = 32
        si = si + 1

    path: Ptr[char] = cast[Ptr[char]](0)
    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if a[0] == 45 and a[1] == 116 and a[2] == 0:        # -t
            table_mode = 1
        elif a[0] == 45 and a[1] == 115:                    # -s[sep] / -s sep
            if a[2] != 0:
                sep = a[2]
                have_sep = 1
            else:
                if i + 1 >= argc:
                    write_str(2, "column: -s needs an argument\n")
                    return 1
                i = i + 1
                sv: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
                if sv[0] == 0:
                    write_str(2, "column: empty separator\n")
                    return 1
                sep = sv[0]
                have_sep = 1
        elif a[0] == 45 and a[1] == 99:                     # -c[width] / -c width
            wstr: Ptr[uint8] = cast[Ptr[uint8]](0)
            if a[2] != 0:
                wstr = cast[Ptr[uint8]](cast[uint64](a) + 2)
            else:
                if i + 1 >= argc:
                    write_str(2, "column: -c needs an argument\n")
                    return 1
                i = i + 1
                wstr = cast[Ptr[uint8]](argv[cast[uint64](i)])
            wv: int64 = parse_uint(wstr)
            if wv <= 0:
                write_str(2, "column: bad width\n")
                return 1
            outwidth = cast[uint64](wv)
        elif a[0] == 45 and a[1] != 0:
            write_str(2, "column: unknown flag\n")
            return 1
        else:
            # A file argument (first one wins).
            path = cast[Ptr[char]](argv[cast[uint64](i)])
        i = i + 1

    fd: int32 = 0
    if cast[uint64](path) != 0:
        fd = sys_open(path)
        if fd < 0:
            write_str(2, "column: cannot open ")
            write_str(2, cast[Ptr[uint8]](path))
            write_str(2, "\n")
            return 1
    read_all(fd)
    if cast[uint64](path) != 0:
        sys_close(fd)

    if table_mode != 0:
        table_mode_run()
    else:
        fill_mode()
    return 0

# user/wc.ad
#
# Minimal Hamnix `wc`. Reads stdin to EOF and reports counts. With no
# flags it writes "<lines> <words> <byte_ct>\n" — the same three
# columns, in the same order, as POSIX wc. A "word" is a run of
# non-whitespace separated by whitespace; the line count is the number
# of newline bytes seen.
#
# Flags (QA-by-using): `-l` (lines only), `-w` (words only), `-c`
# (bytes only), `-m` (chars — same as bytes here, ASCII/byte streams).
# Flags may be combined (`-lw`) and select which columns print, in the
# canonical wc order (lines, words, bytes). Without any count flag all
# three print. Any argv token starting with `-` is parsed as flags;
# everything else is ignored (Hamnix wc reads stdin only — no file
# operands yet).

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def is_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


def put_dec(n: uint64):
    if n == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    i: uint64 = 0
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    # Reverse-print.
    out: Array[24, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Parse flags: -l lines, -w words, -c bytes, -m chars (==bytes for
    # byte streams). Combinable (`-lw`). Any non-flag operand is
    # ignored (stdin-only). No count flag selected => print all three.
    want_l: int32 = 0
    want_w: int32 = 0
    want_c: int32 = 0
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[ai])
        if a[0] == 45 and a[1] != 0:      # '-' followed by flag letters
            fi: uint64 = 1
            while a[fi] != 0:
                f: uint8 = a[fi]
                if f == 108:              # 'l'
                    want_l = 1
                elif f == 119:            # 'w'
                    want_w = 1
                elif f == 99 or f == 109:  # 'c' / 'm'
                    want_c = 1
                fi = fi + 1
        ai = ai + 1
    if want_l == 0 and want_w == 0 and want_c == 0:
        want_l = 1
        want_w = 1
        want_c = 1

    buf: Array[1024, uint8]
    lines: uint64 = 0
    words: uint64 = 0
    byte_ct: uint64 = 0
    in_word: int32 = 0
    while True:
        n: int64 = sys_read(0, &buf[0], 1024)
        if n <= 0:
            break
        i: uint64 = 0
        while i < cast[uint64](n):
            c: uint8 = buf[i]
            byte_ct = byte_ct + 1
            if c == 10:
                lines = lines + 1
            if is_ws(c) != 0:
                in_word = 0
            else:
                if in_word == 0:
                    words = words + 1
                    in_word = 1
            i = i + 1
    # Emit only the selected columns, space-separated in canonical
    # wc order (lines, words, bytes), then a newline.
    printed: int32 = 0
    if want_l != 0:
        put_dec(lines)
        printed = 1
    if want_w != 0:
        if printed != 0:
            sys_write(1, " ", 1)
        put_dec(words)
        printed = 1
    if want_c != 0:
        if printed != 0:
            sys_write(1, " ", 1)
        put_dec(byte_ct)
        printed = 1
    sys_write(1, "\n", 1)
    return 0

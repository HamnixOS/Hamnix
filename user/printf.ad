# user/printf.ad
#
# Hamnix `printf FMT ARGS...`: minimal coreutils-style printf.
# Supports %s, %d, and \n / \t / \\ backslash escapes. Unknown
# conversions / escapes are emitted literally (matches GNU printf's
# fallback for `printf %q`-style outliers without growing our scope).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_int(s: Ptr[uint8]) -> int64:
    # Accept an optional leading '-' to keep %d useful with negative
    # ARGV. Non-digit body chars stop parsing (we trust the shell).
    i: uint64 = 0
    neg: int64 = 1
    if s[0] == 45:
        neg = -1
        i = 1
    n: int64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            break
        n = n * 10 + cast[int64](c - 48)
        i = i + 1
    return n * neg


def put_dec(n: int64):
    if n == 0:
        sys_write(1, "0", 1)
        return
    if n < 0:
        sys_write(1, "-", 1)
        n = -n
    digits: Array[24, uint8]
    i: uint64 = 0
    v: uint64 = cast[uint64](n)
    while v != 0:
        digits[i] = cast[uint8](v % 10) + 48
        v = v / 10
        i = i + 1
    out: Array[24, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        return 0
    fmt: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    arg_i: int32 = 2
    i: uint64 = 0
    while fmt[i] != 0:
        c: uint8 = fmt[i]
        if c == 92 and fmt[i + 1] != 0:
            # Backslash escape — consume both bytes.
            e: uint8 = fmt[i + 1]
            if e == 110:
                sys_write(1, "\n", 1)
            elif e == 116:
                sys_write(1, "\t", 1)
            elif e == 92:
                sys_write(1, "\\", 1)
            else:
                sys_write(1, &fmt[i], 2)
            i = i + 2
        elif c == 37 and fmt[i + 1] != 0:
            spec: uint8 = fmt[i + 1]
            if spec == 115 and arg_i < argc:
                write_str(1, cast[Ptr[uint8]](argv[cast[uint64](arg_i)]))
                arg_i = arg_i + 1
            elif spec == 100 and arg_i < argc:
                put_dec(parse_int(cast[Ptr[uint8]](argv[cast[uint64](arg_i)])))
                arg_i = arg_i + 1
            else:
                sys_write(1, &fmt[i], 2)
            i = i + 2
        else:
            sys_write(1, &fmt[i], 1)
            i = i + 1
    return 0

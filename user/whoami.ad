# user/whoami.ad
#
# Hamnix is still single-user; uid 0 is the only identity the kernel
# tracks. Hard-code "root" so scripts that grep for a user name find
# something stable, matching what real coreutils does when nothing
# but uid 0 exists in /etc/passwd.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def main() -> int32:
    sys_write(1, "root\n", 5)
    return 0

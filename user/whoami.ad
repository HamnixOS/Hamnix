# user/whoami.ad
#
# Print the current user's name. Resolves the live uid (SYS_GETUID)
# against /etc/passwd — there is NO uid 0 in Hamnix's model (uid 1 =
# hostowner, >= 1000 regular), so the old hard-coded "root" was wrong.
# Falls back to the numeric uid if /etc/passwd has no matching entry.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_getuid() -> uint32

from lib.passwd.passwd import (
    passwd_parse, passwd_entry_name, passwd_lookup_by_uid,
)


pw_buf: Array[4096, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def render_u32(v: uint32, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digits: Array[12, uint8]
    n: uint64 = 0
    vv: uint64 = cast[uint64](v)
    while vv != 0:
        digits[n] = cast[uint8](vv % 10) + 48
        vv = vv / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def main() -> int32:
    uid: uint32 = sys_getuid()

    # Read /etc/passwd and find the entry whose uid matches.
    fd: int32 = sys_open("/etc/passwd")
    if fd >= 0:
        total: uint64 = 0
        while total < 4096:
            n: int64 = sys_read(fd, &pw_buf[total], 4096 - total)
            if n <= 0:
                break
            total = total + cast[uint64](n)
        sys_close(fd)
        passwd_parse(&pw_buf[0], total)
        idx: int32 = passwd_lookup_by_uid(uid)
        if idx >= 0:
            nm: Ptr[uint8] = passwd_entry_name(idx)
            write_str(1, nm)
            write_str(1, "\n")
            return 0

    # Fallback: print the numeric uid.
    ubuf: Array[16, uint8]
    ub: uint64 = render_u32(uid, &ubuf[0])
    ubuf[ub] = 10                                            # '\n'
    sys_write(1, &ubuf[0], ub + 1)
    return 0

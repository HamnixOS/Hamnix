# user/clear.ad
#
# ANSI clear-screen + cursor-home. The hamsh framebuffer console (and
# any serial terminal we attach to QEMU) honours both sequences, so
# one sys_write empties the visible scrollback region and parks the
# cursor at (0,0) without needing a TIOCGWINSZ-style query.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def main() -> int32:
    sys_write(1, "\x1b[2J\x1b[H", 7)
    return 0

# user/nice_demo.ad
#
# #151 / CFS-lite priority test driver. Spawns two CPU-bound sibling
# tasks that share one CPU:
#   - /bin/nice_lo  re-nices itself to +19 (low priority)
#   - /bin/nice_hi  re-nices itself to -20 (high priority)
# Both run an identical fixed wall-clock counting loop and print their
# iteration count. The parent does NOT waitpid them, so all three tasks
# are runnable; on -smp 1 the two hogs genuinely contend for the single
# CPU, and the weighted-fair scheduler must hand the nice -20 task a much
# larger share — it finishes the window with many more iterations.
#
# test_sched_fair.sh boots this via hamsh, captures both "[nice] hi
# iters=" / "[nice] lo iters=" lines, and asserts hi > lo by a clear
# margin (the end-to-end CPU-share proof).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_exit(code: uint64)
extern def sys_get_jiffies() -> uint64


lo_argv: Array[2, uint64]
hi_argv: Array[2, uint64]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "[nice] demo: spawning low(+19) and high(-20) CPU hogs\n")

    lo_path: Ptr[uint8] = cast[Ptr[uint8]]("/bin/nice_lo")
    lo_argv[0] = cast[uint64](lo_path)
    lo_argv[1] = 0
    clo: int32 = sys_spawn(cast[Ptr[char]](lo_path), &lo_argv[0],
                           -1, -1, cast[Ptr[uint64]](0))
    if clo < 0:
        write_str(1, "[nice] FAIL: could not spawn nice_lo\n")
        sys_exit(1)
        return 1

    hi_path: Ptr[uint8] = cast[Ptr[uint8]]("/bin/nice_hi")
    hi_argv[0] = cast[uint64](hi_path)
    hi_argv[1] = 0
    chi: int32 = sys_spawn(cast[Ptr[char]](hi_path), &hi_argv[0],
                           -1, -1, cast[Ptr[uint64]](0))
    if chi < 0:
        write_str(1, "[nice] FAIL: could not spawn nice_hi\n")
        sys_exit(1)
        return 1

    write_str(1, "[nice] demo: both hogs spawned; they share one CPU\n")
    # The parent exits; the two hogs run their bounded windows and print
    # their own iter counts. Exiting (rather than spinning) keeps the
    # parent from stealing CPU share from the very tasks under test.
    sys_exit(0)
    return 0

# user/init.ad
#
# Hamnix V3.5 userspace init — PID 1. Plants the canonical Plan 9
# namespace bindings, then execs /bin/hamsh to give the user a shell.
#
# WHY THIS EXISTS (V3.5 layering shift)
# -------------------------------------
# Through V3 the kernel hard-coded path routes for `/srv`, `/n`, and
# `/proc/<pid>/ns` directly in fs/vfs.ad — i.e. it baked the path
# names into the source-of-truth dispatcher. That works, but it is
# the Linux way: kernel knows the path shape, kernel knows the file
# shape, kernel decides everything.
#
# The Plan 9 way (now restored in V3.5) is layered:
#
#   1. Kernel exposes DEVICES under `#X` aliases (`#s` srv, `#p`
#      proc, `#c` cons, `#/` root-dir slot). The kernel knows
#      letters, not paths.
#
#   2. Userspace `init` (this program) reads a recipe (V0: hard-coded
#      below) and does the binds. After init runs, opens of `/srv`,
#      `/proc`, `/n` rewrite through chan_resolve_prefix to the `#X`
#      forms and dispatch via vfs.ad::_open_hash_alias.
#
#   3. init exec's `/bin/hamsh` so the user gets the shell prompt
#      that all the existing tests drive over the serial port.
#
# Future V1+ extension: read /lib/namespace from disk (Plan 9 hosts
# this at /lib/namespace; ns(1) parses the same syntax). For V3.5 the
# recipe is hard-coded so this binary has zero filesystem dependency
# beyond the cpio archive that already ships /bin/hamsh.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       user/init.ad -o build/user/init.elf
#
# The cpio packer in scripts/build_initramfs.py recognises init.elf
# specifically and installs it at /init (the kernel's first-task
# entrypoint), so we don't need a build_user.sh special-case beyond
# adding the file to its glob list.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char],
                    flag: int32) -> int32
extern def sys_execve(path: Ptr[char], argv: Ptr[uint64]) -> int32
extern def sys_exit(code: uint64)


MREPL: int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Recipe storage. Each entry is (new, old) — the Plan 9 bind contract
# is `bind new old`, meaning "graft `new` onto `old`'s contents". Top-
# level arrays sidestep Adder's nested-frame Array bug. We don't store
# the literal strings here (Adder string literals are global already);
# instead recipe_apply walks an explicit list of (new, old) pairs.

# V0 hard-coded recipe. Order matters only insofar as later binds win
# over earlier ones on path collision (MREPL semantics), but the
# defaults don't collide so the order is purely aesthetic. Mirrors a
# slimmed-down /lib/namespace from a 9front workstation:
#
#   bind '#s' /srv          — name-server directory
#   bind '#p' /proc         — per-task introspection (status / ns / ...)
#   bind '#/' /n            — conventional mount-point parent
#
# `#c` (console) is intentionally NOT bound to /dev because vfs.ad
# already ships /dev/cons as a direct cdev. Adding `bind '#c' /dev`
# would graft the SINGLE-FILE device tree onto a directory that
# already has /dev/null, /dev/cpuinfo, etc., which would shadow them
# (the longest-prefix matcher would route every /dev/X open through
# `#c` and ENOENT them). The V3.5 design treats /dev as the
# "byte-source pile" — Layer 1 — and the `#`-namespace as Layer 2;
# they coexist without binding into each other.


def recipe_apply() -> int32:
    # Apply the V0 hard-coded recipe. Returns 0 on success, -1 on the
    # first failure (after logging a diagnostic to stderr). The kernel
    # treats sys_bind failure as fatal-to-the-namespace — we surface
    # the error but DO NOT exit, because hamsh can still run without
    # the canonical bindings (it'll just not see `/srv` etc.). A
    # production init would either retry or panic; V0 is permissive.
    write_str(1, "[init] applying V0 namespace recipe\n")

    rc: int32 = sys_bind("/srv", "#s", MREPL)
    if rc != 0:
        write_str(2, "[init] WARN: bind '#s' -> /srv failed\n")
    else:
        write_str(1, "[init]   bind '#s' /srv ok\n")

    rc = sys_bind("/proc", "#p", MREPL)
    if rc != 0:
        write_str(2, "[init] WARN: bind '#p' -> /proc failed\n")
    else:
        write_str(1, "[init]   bind '#p' /proc ok\n")

    rc = sys_bind("/n", "#/", MREPL)
    if rc != 0:
        write_str(2, "[init] WARN: bind '#/' -> /n failed\n")
    else:
        write_str(1, "[init]   bind '#/' /n ok\n")

    write_str(1, "[init] recipe applied\n")
    return 0


# argv array for the hamsh exec — must live at module scope (top-level
# Array storage rule). Slot 0 is the path; slot 1 is the NUL terminator
# Plan 9 / Linux execve expects.
hamsh_argv: Array[2, uint64]


def main() -> int32:
    write_str(1, "[init] hamnix V3.5 userspace init starting (pid 1)\n")

    # Step 1: build the canonical namespace.
    recipe_apply()

    # Step 2: hand off to hamsh. execve replaces the current task
    # image — the kernel keeps PID 1 but loads hamsh's PT_LOAD over
    # init's, so from the kernel's point of view PID 1 IS the shell
    # afterward. If exec fails (e.g. /bin/hamsh missing) we fall
    # through to the exit path so the test harness sees a clean halt
    # rather than a runaway loop.
    write_str(1, "[init] exec'ing /bin/hamsh\n")
    hamsh_argv[0] = cast[uint64](&"/bin/hamsh"[0])
    hamsh_argv[1] = 0
    sys_execve("/bin/hamsh", &hamsh_argv[0])

    write_str(2, "[init] FATAL: exec /bin/hamsh failed\n")
    return 1

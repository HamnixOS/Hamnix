# user/hammath.ad — NATIVE driver for HamMath, the expression-calculator scene
# app.
#
# The expression EVALUATOR, keypad state machine, layout, scene display-list
# builder and pure keyboard+pointer input handlers live in lib/hammathcore.ad
# (extern-free, target-agnostic) so they can ALSO be exercised + rendered on the
# dev host (see user/hammath_host.ad + docs/hamui_dual_target.md). This file
# keeps ONLY the Hamnix-only transport: opening a wsys window, reading its
# /keys + /event files, and committing the built scene to /dev/wsys/<wid>/scene
# via lib/hamui.ad's hamscene_commit(). Structure mirrors user/hamcalcscene.ad.
#
# RENDER: a display bar over a 5x4 expression-calculator keypad (C ( ) /, 7 8 9
# *, 4 5 6 -, 1 2 3 +, 0 . <- =).
# INPUT: /keys (digits/operators/parens/=/C/./backspace) + /event (pointer press
# hit-tests the clicked key; press/release edges sink the button). Event-driven:
# parks on /keys. RESIZE-AWARE.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamsceneloop import hamscene_park, HAMSCENE_IDLE_MS
from lib.hamui import hamscene_commit
from lib.hammathcore import hammath_init, hammath_clear, hammath_build_scene, \
    hammath_key_line, hammath_resize_line, hammath_key_at, hammath_press_at, \
    hammath_release, parse_pointer, _slen, _u64_to_dec


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Build the display list (core) and publish it to /dev/wsys/<wid>/scene.
def emit_scene(wid: int32):
    hammath_build_scene()
    hamscene_commit(wid)


btn_down: int32 = 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hammath] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 610 110 200 300\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title HamMath\n"))
        sys_close(cfdt)

    keysp: Array[64, uint8]
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    hammath_init()
    hammath_clear()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hammath] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    evbuf: Array[256, uint8]
    kbuf:  Array[256, uint8]
    while True:
        changed: int32 = 0
        # --- KEYBOARD: non-blocking drain of /keys, apply press lines.
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if hammath_key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1
        # --- POINTER + RESIZE: NON-BLOCKING drain of /event.
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            if hammath_resize_line(&evbuf[ls], i - ls) == 1:
                                changed = 1
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                now_down: int32 = 0
                                if (bbtn & 1) != 0:
                                    now_down = 1
                                if now_down != 0 and btn_down == 0:
                                    # PRESS EDGE: apply the clicked key once.
                                    k: int64 = hammath_key_at(bx, by)
                                    if k >= 0:
                                        hammath_press_at(k)
                                        changed = 1
                                elif now_down == 0 and btn_down != 0:
                                    # RELEASE EDGE: clear the sink once.
                                    if hammath_release() == 1:
                                        changed = 1
                                btn_down = now_down
                        ls = i + 1
                    i = i + 1
        if changed != 0:
            emit_scene(wid)
        hamscene_park(kfd, HAMSCENE_IDLE_MS)
    return 0

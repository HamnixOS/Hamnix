# user/hampkgscene_host.ad — HOST driver + render harness for the Package
# Manager GUI (built for x86_64-linux; runs on the dev host, no QEMU).
#
# Drives the SAME core the native app ships (lib/hampkgcore.ad) with a FIXTURE
# package index — the exact plain-text lines `hpm search` / `hpm list` /
# `hpm show` emit — so the whole GUI renders + hit-tests to PNGs a human/agent
# can LOOK at, and the list/search/detail behaviour is asserted, all without a
# repo or QEMU. The native driver (user/hampkgscene.ad) feeds these same core
# parsers with REAL hpm output.
#
# USAGE (built to build/host/hampkg_host):
#   hampkg_host LIST.ppm SEARCH.ppm DETAIL.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.hampkgcore import hampkg_init, hampkg_build_scene, hampkg_reset_list, \
    hampkg_installed_reset, hampkg_add_search_line, hampkg_mark_installed_line, \
    hampkg_detail_reset, hampkg_detail_line, hampkg_set_search, \
    hampkg_hit, hampkg_count, hampkg_filt_count, hampkg_sel_pkg, \
    hampkg_selected_name, hampkg_selected_name_len, hampkg_set_status, \
    hampkg_build_hud


obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


ppm_hdr: Array[64, uint8]
hudbuf: Array[80, uint8]


# Dump the current status-bar HUD string (model-derived live counts) preceded
# by `tag`, so the gate can assert the exact figures for the active filter.
def _dump_hud(tag: Ptr[uint8]):
    _o_str(tag)
    _o_flush()
    hl: uint64 = hampkg_build_hud(&hudbuf[0], 80)
    sys_write(1, &hudbuf[0], hl)
    sys_write(1, cast[Ptr[uint8]]("\n"), 1)


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _feed_search(s: Ptr[uint8]):
    hampkg_add_search_line(s, _slen(s))


def _feed_list(s: Ptr[uint8]):
    hampkg_mark_installed_line(s, _slen(s))


def _feed_detail(s: Ptr[uint8]):
    hampkg_detail_line(s, _slen(s))


def _render(w: int32, h: int32) -> int32:
    hampkg_build_scene()
    hamui_host_begin(w, h)
    return hamui_host_rasterize()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _o_str(cast[Ptr[uint8]]("usage: hampkg_host LIST.ppm SEARCH.ppm DETAIL.ppm\n"))
        _o_flush()
        return 2

    W: int32 = 640
    H: int32 = 430
    hampkg_init()

    # ---- fixture index: exactly what `hpm search ""` prints -------------
    hampkg_reset_list()
    _feed_search(cast[Ptr[uint8]]("hamnix-base  1.0  -  core system base"))
    _feed_search(cast[Ptr[uint8]]("hamnix-desktop  1.0  -  MATE-style desktop environment"))
    _feed_search(cast[Ptr[uint8]]("hambrowse  0.9  -  native web browser"))
    _feed_search(cast[Ptr[uint8]]("hamnix-hamnotes  1.0  -  sticky-note scratchpad"))
    _feed_search(cast[Ptr[uint8]]("hamnix-hamcalc  1.0  -  calculator"))
    _feed_search(cast[Ptr[uint8]]("webkitgtk  4.1  -  web content engine"))

    # ---- installed state: what `hpm list` prints ------------------------
    hampkg_installed_reset()
    _feed_list(cast[Ptr[uint8]]("hamnix-base  1.0  #hamnix-system"))
    _feed_list(cast[Ptr[uint8]]("hamnix-hamnotes  1.0  #hamnix-system"))

    hampkg_set_status(cast[Ptr[uint8]]("6 packages in the index"), 23)

    # ---- (1) full list view --------------------------------------------
    prims: int32 = _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[1]))
    _o_str(cast[Ptr[uint8]]("PRIMS "))
    _o_dec(cast[int64](prims))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("COUNT "))
    _o_dec(cast[int64](hampkg_count()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("FILT_ALL "))
    _o_dec(cast[int64](hampkg_filt_count()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("PIX 4 4 "))
    _o_dec(cast[int64](hamui_host_pixel(4, 4)))          # header bar pixel
    _o_ch(10)
    _o_flush()
    _dump_hud(cast[Ptr[uint8]]("HUD "))                  # full view: 6 listed

    # ---- (2) live search filter: "web" -> hambrowse + webkitgtk --------
    hampkg_set_search(cast[Ptr[uint8]]("web"), 3)
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[2]))
    _o_str(cast[Ptr[uint8]]("FILT_WEB "))
    _o_dec(cast[int64](hampkg_filt_count()))             # expect 2
    _o_ch(10)
    _o_flush()
    _dump_hud(cast[Ptr[uint8]]("HUD_WEB "))              # filter: 2 listed

    # ---- (3) select a package + show its detail pane -------------------
    hampkg_set_search(cast[Ptr[uint8]](""), 0)           # clear filter
    _render(W, H)                                        # rebuild filt (full)
    hres: int32 = hampkg_hit(20, 184)                    # click row 2 = hambrowse
    _o_str(cast[Ptr[uint8]]("HIT "))
    _o_dec(cast[int64](hres))                            # 5 = row-selected
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEL "))
    _o_dec(cast[int64](hampkg_sel_pkg()))                # expect index 2
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("SEL_NAME "))
    _o_flush()                                          # flush before the raw name write
    sys_write(1, hampkg_selected_name(), hampkg_selected_name_len())
    sys_write(1, cast[Ptr[uint8]]("\n"), 1)

    # feed the `hpm show hambrowse` output into the detail pane
    hampkg_detail_reset()
    _feed_detail(cast[Ptr[uint8]]("name: hambrowse"))
    _feed_detail(cast[Ptr[uint8]]("version: 0.9"))
    _feed_detail(cast[Ptr[uint8]]("size: 512000"))
    _feed_detail(cast[Ptr[uint8]]("target: #hamnix-system"))
    _feed_detail(cast[Ptr[uint8]]("depends: webkitgtk, hamnix-base"))
    _feed_detail(cast[Ptr[uint8]]("description: native web browser"))
    _render(W, H)
    _write_ppm(cast[Ptr[char]](argv[3]))

    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN\n"))
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()
    return 0

# user/toprender_host.ad — HOST unit-test driver for the pure `top` model +
# renderer (lib/toprender.ad). Built for x86_64-linux: runs directly on the
# host, no QEMU. Feeds synthetic /proc/toptable snapshots and asserts the
# parse, the %CPU delta, the CPU-descending sort, and that the rendered frame
# carries the expected header + a cursor-home control. scripts/test_top_host.sh
# asserts on the PASS/FAIL/RESULT markers, and also compiles NATIVE top.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.toprender import (
    tr_ingest, tr_render, tr_count, tr_cpu_tenths_at, tr_order_at, tr_pid_at,
)


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _w(s: Ptr[uint8]):
    sys_write(1, s, _slen(s))


fail_count: int32 = 0


def _report(name: Ptr[uint8], ok: int32):
    if ok != 0:
        _w(cast[Ptr[uint8]]("PASS "))
    else:
        _w(cast[Ptr[uint8]]("FAIL "))
        fail_count = fail_count + 1
    _w(name)
    _w(cast[Ptr[uint8]]("\n"))


# Does haystack[0..hlen) contain the NUL-terminated needle?
def _contains(hay: Ptr[uint8], hlen: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = _slen(needle)
    if nlen == 0:
        return 1
    i: uint64 = 0
    while i + nlen <= hlen:
        k: uint64 = 0
        while k < nlen and hay[i + k] == needle[k]:
            k = k + 1
        if k == nlen:
            return 1
        i = i + 1
    return 0


frame: Array[16384, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # Snapshot 1 (t=1000 jiffies). Three tasks; ticks are cumulative CPU.
    snap1: Ptr[uint8] = cast[Ptr[uint8]](
        "now 1000 hz 100 memtotal 200000 memfree 150000\n"
        "1\tS\t50\t4000\t0\tinit\n"
        "7\tR\t300\t20000\t100\thamsh\n"
        "9\tS\t10\t8000\t200\ttop\n")
    tr_ingest(snap1, _slen(snap1))
    _report(cast[Ptr[uint8]]("ingest_count3"), cast[int32](tr_count() == 3))
    # First feed has no previous snapshot -> all %CPU == 0.
    _report(cast[Ptr[uint8]]("firstfeed_cpu0"),
            cast[int32](tr_cpu_tenths_at(0) == 0 and tr_cpu_tenths_at(1) == 0))

    lav: Ptr[uint8] = cast[Ptr[uint8]]("0.50 0.20 0.10 1/3 42\n")

    # Snapshot 2 (t=1100 jiffies, 100 jiffies later). pid 7 burned 300->370
    # (70 ticks over 100 jiffies = 70.0%); pid 9 burned 10->35 (25.0%); pid 1
    # unchanged (0%). %CPU tenths: 700 / 250 / 0.
    snap2: Ptr[uint8] = cast[Ptr[uint8]](
        "now 1100 hz 100 memtotal 200000 memfree 150000\n"
        "1\tS\t50\t4000\t0\tinit\n"
        "7\tR\t370\t20000\t100\thamsh\n"
        "9\tS\t35\t8000\t200\ttop\n")
    tr_ingest(snap2, _slen(snap2))

    # Find the row index of each pid to check its computed %CPU.
    i7: uint64 = 99
    i9: uint64 = 99
    i1: uint64 = 99
    ii: uint64 = 0
    while ii < tr_count():
        if tr_pid_at(ii) == 7:
            i7 = ii
        if tr_pid_at(ii) == 9:
            i9 = ii
        if tr_pid_at(ii) == 1:
            i1 = ii
        ii = ii + 1
    _report(cast[Ptr[uint8]]("cpu_pid7_700"),
            cast[int32](i7 != 99 and tr_cpu_tenths_at(i7) == 700))
    _report(cast[Ptr[uint8]]("cpu_pid9_250"),
            cast[int32](i9 != 99 and tr_cpu_tenths_at(i9) == 250))
    _report(cast[Ptr[uint8]]("cpu_pid1_0"),
            cast[int32](i1 != 99 and tr_cpu_tenths_at(i1) == 0))

    # Render, then check the sort order (pid 7 first, pid 9 second, pid 1 last)
    # and that the frame carries the header + cursor-home control.
    n: uint64 = tr_render(&frame[0], 16384, lav, _slen(lav))
    _report(cast[Ptr[uint8]]("sort_pid7_first"),
            cast[int32](tr_pid_at(tr_order_at(0)) == 7))
    _report(cast[Ptr[uint8]]("sort_pid9_second"),
            cast[int32](tr_pid_at(tr_order_at(1)) == 9))
    _report(cast[Ptr[uint8]]("sort_pid1_last"),
            cast[int32](tr_pid_at(tr_order_at(2)) == 1))
    _report(cast[Ptr[uint8]]("frame_home"),
            _contains(&frame[0], n, cast[Ptr[uint8]]("\x1b[H")))
    _report(cast[Ptr[uint8]]("frame_header"),
            _contains(&frame[0], n, cast[Ptr[uint8]]("%CPU")))
    _report(cast[Ptr[uint8]]("frame_task"),
            _contains(&frame[0], n, cast[Ptr[uint8]]("hamsh")))
    _report(cast[Ptr[uint8]]("frame_load"),
            _contains(&frame[0], n, cast[Ptr[uint8]]("load average: 0.50 0.20 0.10")))
    # %CPU 70.0 for pid 7 should appear as "70.0".
    _report(cast[Ptr[uint8]]("frame_cpu70"),
            _contains(&frame[0], n, cast[Ptr[uint8]]("70.0")))

    if fail_count == 0:
        _w(cast[Ptr[uint8]]("RESULT ok\n"))
        return 0
    _w(cast[Ptr[uint8]]("RESULT bad\n"))
    return 1

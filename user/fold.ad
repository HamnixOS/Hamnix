# user/fold.ad
#
# Hamnix `fold`: wrap each input line to no more than WIDTH bytes,
# inserting a newline at the wrap boundary. Mirrors coreutils `fold`
# at byte granularity (no -s word-boundary mode, no -b vs column
# distinction — every byte counts as one column). Flags:
#   -w N    set the wrap width (default 80)
#   -wN     same, glued form
# Existing newlines in the input reset the column counter.

extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def parse_int(s: Ptr[uint8]) -> int64:
    if s[0] == 0:
        return -1
    n: int64 = 0
    i: uint64 = 0
    while s[i] != 0:
        c: uint8 = s[i]
        if c < 48 or c > 57:
            return -1
        n = n * 10 + cast[int64](c - 48)
        i = i + 1
    return n


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    width: int64 = 80
    i: int32 = 1
    while i < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](i)])
        if a[0] == 45 and a[1] == 119:          # "-w..."
            if a[2] != 0:
                # Glued: -wN
                width = parse_int(cast[Ptr[uint8]](cast[uint64](a) + 2))
            else:
                # Separate: -w N
                if i + 1 >= argc:
                    write_str(2, "fold: -w needs an argument\n")
                    return 1
                i = i + 1
                width = parse_int(cast[Ptr[uint8]](argv[cast[uint64](i)]))
            if width <= 0:
                write_str(2, "fold: bad width\n")
                return 1
        elif a[0] == 45 and a[1] != 0:
            write_str(2, "fold: unknown flag\n")
            return 1
        i = i + 1

    chunk: Array[256, uint8]
    col: int64 = 0
    while True:
        n: int64 = sys_read(0, &chunk[0], 256)
        if n <= 0:
            break
        bi: uint64 = 0
        while bi < cast[uint64](n):
            c: uint8 = chunk[bi]
            if c == 10:
                sys_write(1, "\n", 1)
                col = 0
            else:
                if col >= width:
                    sys_write(1, "\n", 1)
                    col = 0
                sys_write(1, &chunk[bi], 1)
                col = col + 1
            bi = bi + 1
    return 0

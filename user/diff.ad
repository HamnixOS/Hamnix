# user/diff.ad - line-oriented diff with proper LCS alignment.
#
# Computes a longest-common-subsequence alignment of the two files'
# LINES (not a naive byte-by-byte or line-by-line lockstep compare),
# then renders either the traditional "normal" diff script or, with
# -u, a unified diff (--- / +++ header, @@ hunk headers, 3 lines of
# context). Exit status: 0 = identical, 1 = differences, 2 = trouble.
#
# Usage:  diff [-u] FILE1 FILE2
#
# Both files are slurped into bounded buffers and split on '\n'. Up to
# MAXL lines per file are diffed (excess lines are truncated). The LCS
# is an O(na*nb) dynamic program over a static table; fine for the
# small inputs the native userland deals with.

# sys_open: the adder-user runtime thunk reads only %rdi (path) and opens
# read-only; the host (x86_64-linux) thunk is a raw open(2) needing
# flags/mode in %rsi/%rdx. Declaring all three args satisfies both — the
# kernel ignores the extras, the host gets O_RDONLY (flags=0, mode=0).
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


FILE_CAP: uint64 = 32768
MAXL:     uint64 = 256          # max lines per file the DP handles
CTX:      int64  = 3            # unified-diff context lines

buf_a: Array[32768, uint8]
buf_b: Array[32768, uint8]
len_a: uint64 = 0
len_b: uint64 = 0

# Per-line spans (byte offset of first char, byte length, no newline).
a_off: Array[256, uint64]
a_len: Array[256, uint64]
b_off: Array[256, uint64]
b_len: Array[256, uint64]
na: uint64 = 0                  # line count in A
nb: uint64 = 0                  # line count in B

# File-path pointers (as raw addresses), so unified() can print the labels.
gpa: uint64 = 0
gpb: uint64 = 0

# LCS DP table: dp[i*(MAXL+1) + j] = LCS length of A[i..na) and B[j..nb).
# Dimensions (MAXL+1) x (MAXL+1) = 257*257 = 66049.
dp: Array[66049, int32]

# Edit script. Each entry touches A (op_a >= 0), B (op_b >= 0), or both
# (a common line).  op_a / op_b hold the 0-based line index on that side.
op_a: Array[512, int64]
op_b: Array[512, int64]
nops: uint64 = 0


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def emit_dec(fd: int32, v: uint64):
    if v == 0:
        sys_write(fd, "0", 1)
        return
    out: Array[24, uint8]
    n: uint64 = 0
    while v != 0:
        out[23 - n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    sys_write(fd, cast[Ptr[uint8]](cast[uint64](&out[0]) + 24 - n), n)


def load_file(b: Ptr[uint8], path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        write_str(2, "diff: cannot open ")
        write_str(2, cast[Ptr[uint8]](path))
        write_str(2, "\n")
        return -1
    total: uint64 = 0
    while total < FILE_CAP:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](
                                cast[uint64](b) + total),
                            FILE_CAP - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


# Split buffer `b` of `len` bytes into line spans. A trailing chunk with
# no closing '\n' still counts as a line. Returns the line count (<=MAXL).
def split_lines(b: Ptr[uint8], len: uint64,
                off: Ptr[uint64], ln: Ptr[uint64]) -> uint64:
    count: uint64 = 0
    i: uint64 = 0
    while i < len and count < MAXL:
        start: uint64 = i
        while i < len and b[i] != 10:
            i = i + 1
        off[count] = start
        ln[count] = i - start
        count = count + 1
        if i < len:
            i = i + 1                # step over the '\n'
    return count


# Byte-equality of A-line `i` and B-line `j`.
def line_eq(i: uint64, j: uint64) -> int32:
    if a_len[i] != b_len[j]:
        return 0
    ab: uint64 = a_off[i]
    bb: uint64 = b_off[j]
    k: uint64 = 0
    while k < a_len[i]:
        if buf_a[ab + k] != buf_b[bb + k]:
            return 0
        k = k + 1
    return 1


def dp_at(i: uint64, j: uint64) -> int32:
    return dp[i * (MAXL + 1) + j]


def dp_set(i: uint64, j: uint64, v: int32):
    dp[i * (MAXL + 1) + j] = v


# Fill the LCS table bottom-up.
def build_dp():
    ii: int64 = cast[int64](na)
    while ii >= 0:
        i: uint64 = cast[uint64](ii)
        jj: int64 = cast[int64](nb)
        while jj >= 0:
            j: uint64 = cast[uint64](jj)
            if i == na or j == nb:
                dp_set(i, j, 0)
            elif line_eq(i, j) != 0:
                dp_set(i, j, dp_at(i + 1, j + 1) + 1)
            else:
                d: int32 = dp_at(i + 1, j)
                r: int32 = dp_at(i, j + 1)
                if d >= r:
                    dp_set(i, j, d)
                else:
                    dp_set(i, j, r)
            jj = jj - 1
        ii = ii - 1


# Walk the DP forward to produce the edit script.
def build_script():
    nops = 0
    i: uint64 = 0
    j: uint64 = 0
    while i < na and j < nb:
        if line_eq(i, j) != 0:
            op_a[nops] = cast[int64](i)
            op_b[nops] = cast[int64](j)
            nops = nops + 1
            i = i + 1
            j = j + 1
        elif dp_at(i + 1, j) >= dp_at(i, j + 1):
            op_a[nops] = cast[int64](i)         # deletion from A
            op_b[nops] = -1
            nops = nops + 1
            i = i + 1
        else:
            op_a[nops] = -1                     # insertion from B
            op_b[nops] = cast[int64](j)
            nops = nops + 1
            j = j + 1
    while i < na:
        op_a[nops] = cast[int64](i)
        op_b[nops] = -1
        nops = nops + 1
        i = i + 1
    while j < nb:
        op_a[nops] = -1
        op_b[nops] = cast[int64](j)
        nops = nops + 1
        j = j + 1


def is_change(k: uint64) -> int32:
    if op_a[k] < 0 or op_b[k] < 0:
        return 1
    return 0


def emit_a_line(prefix: Ptr[uint8], i: uint64):
    write_str(1, prefix)
    if a_len[i] > 0:
        sys_write(1, cast[Ptr[uint8]](cast[uint64](&buf_a[0]) + a_off[i]),
                  a_len[i])
    sys_write(1, "\n", 1)


def emit_b_line(prefix: Ptr[uint8], j: uint64):
    write_str(1, prefix)
    if b_len[j] > 0:
        sys_write(1, cast[Ptr[uint8]](cast[uint64](&buf_b[0]) + b_off[j]),
                  b_len[j])
    sys_write(1, "\n", 1)


# Print a "start,count" range, collapsing to "start" when count == 1
# (GNU unified convention).
def emit_range(start: uint64, count: uint64):
    emit_dec(1, start)
    if count != 1:
        sys_write(1, ",", 1)
        emit_dec(1, count)


# ---- unified (-u) output -------------------------------------------------

def unified() -> int32:
    # No header at all when the files are identical (GNU prints nothing).
    ck: uint64 = 0
    changed: int32 = 0
    while ck < nops:
        if is_change(ck) != 0:
            changed = 1
            ck = nops
        else:
            ck = ck + 1
    if changed == 0:
        return 0
    # Header (path labels; the cross-check ignores these).
    write_str(1, "--- ")
    write_str(1, cast[Ptr[uint8]](gpa))
    write_str(1, "\n+++ ")
    write_str(1, cast[Ptr[uint8]](gpb))
    write_str(1, "\n")

    any: int32 = 0
    # Running count of A/B lines consumed before script index k.
    k: uint64 = 0
    aconsumed: uint64 = 0
    bconsumed: uint64 = 0
    # apre[k]/bpre[k] would be handy; recompute lazily instead.
    while k < nops:
        if is_change(k) == 0:
            aconsumed = aconsumed + 1
            bconsumed = bconsumed + 1
            k = k + 1
            continue
        any = 1
        # Start a hunk: back up CTX context (common) entries.
        lo: uint64 = k
        a_lo: uint64 = aconsumed
        b_lo: uint64 = bconsumed
        c: int64 = 0
        while lo > 0 and is_change(lo - 1) == 0 and c < CTX:
            lo = lo - 1
            a_lo = a_lo - 1
            b_lo = b_lo - 1
            c = c + 1
        # Extend across changes separated by <= 2*CTX common lines.
        last_change: uint64 = k
        j: uint64 = k + 1
        while j < nops:
            if is_change(j) != 0:
                last_change = j
                j = j + 1
                continue
            # count run of commons; peek for a nearby next change
            run: int64 = 0
            p: uint64 = j
            while p < nops and is_change(p) == 0:
                run = run + 1
                p = p + 1
            if p < nops and run <= 2 * CTX:
                # merge: commons stay in-hunk, continue past them
                last_change = p
                j = p + 1
            else:
                break
        # Trailing context: up to CTX commons after last_change.
        hi: uint64 = last_change
        c = 0
        while hi + 1 < nops and is_change(hi + 1) == 0 and c < CTX:
            hi = hi + 1
            c = c + 1
        # Count A/B touches within [lo, hi].
        a_count: uint64 = 0
        b_count: uint64 = 0
        t: uint64 = lo
        while t <= hi:
            if op_a[t] >= 0:
                a_count = a_count + 1
            if op_b[t] >= 0:
                b_count = b_count + 1
            t = t + 1
        # Hunk header.
        write_str(1, "@@ -")
        a_start: uint64 = a_lo
        if a_count > 0:
            a_start = a_lo + 1
        emit_range(a_start, a_count)
        write_str(1, " +")
        b_start: uint64 = b_lo
        if b_count > 0:
            b_start = b_lo + 1
        emit_range(b_start, b_count)
        write_str(1, " @@\n")
        # Hunk body.
        t = lo
        while t <= hi:
            if is_change(t) == 0:
                emit_a_line(" ", cast[uint64](op_a[t]))
            elif op_a[t] >= 0:
                emit_a_line("-", cast[uint64](op_a[t]))
            else:
                emit_b_line("+", cast[uint64](op_b[t]))
            t = t + 1
        # Resume after the hunk.
        aconsumed = a_lo + a_count
        bconsumed = b_lo + b_count
        k = hi + 1
    if any != 0:
        return 1
    return 0


# ---- normal (default) output ---------------------------------------------

def emit_norm_range(start: uint64, count: uint64):
    # count >= 1 assumed. "s" if single line else "s,e".
    emit_dec(1, start)
    if count > 1:
        sys_write(1, ",", 1)
        emit_dec(1, start + count - 1)


def normal() -> int32:
    any: int32 = 0
    k: uint64 = 0
    apos: uint64 = 0            # 0-based A lines consumed
    bpos: uint64 = 0            # 0-based B lines consumed
    while k < nops:
        if is_change(k) == 0:
            apos = apos + 1
            bpos = bpos + 1
            k = k + 1
            continue
        any = 1
        a_anchor: uint64 = apos
        b_anchor: uint64 = bpos
        # Gather a maximal run of changes.
        ndel: uint64 = 0
        nins: uint64 = 0
        r: uint64 = k
        while r < nops and is_change(r) != 0:
            if op_a[r] >= 0:
                ndel = ndel + 1
            else:
                nins = nins + 1
            r = r + 1
        # Command line.
        if ndel > 0 and nins == 0:
            emit_norm_range(a_anchor + 1, ndel)
            sys_write(1, "d", 1)
            emit_dec(1, b_anchor)
            sys_write(1, "\n", 1)
        elif ndel == 0 and nins > 0:
            emit_dec(1, a_anchor)
            sys_write(1, "a", 1)
            emit_norm_range(b_anchor + 1, nins)
            sys_write(1, "\n", 1)
        else:
            emit_norm_range(a_anchor + 1, ndel)
            sys_write(1, "c", 1)
            emit_norm_range(b_anchor + 1, nins)
            sys_write(1, "\n", 1)
        # Body: deleted A lines, then (for change) separator, then B lines.
        t: uint64 = k
        while t < r:
            if op_a[t] >= 0:
                emit_a_line("< ", cast[uint64](op_a[t]))
            t = t + 1
        if ndel > 0 and nins > 0:
            write_str(1, "---\n")
        t = k
        while t < r:
            if op_b[t] >= 0:
                emit_b_line("> ", cast[uint64](op_b[t]))
            t = t + 1
        apos = a_anchor + ndel
        bpos = b_anchor + nins
        k = r
    return any


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    unified_mode: int32 = 0
    f1: int32 = 0
    f2: int32 = 0
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] == 45 and a[1] != 0:
            k: uint64 = 1
            while a[k] != 0:
                if a[k] == 117:            # 'u'
                    unified_mode = 1
                else:
                    write_str(2, "diff: unknown flag\n")
                    return 2
                k = k + 1
        else:
            if f1 == 0:
                f1 = ai
            elif f2 == 0:
                f2 = ai
        ai = ai + 1

    if f1 == 0 or f2 == 0:
        write_str(2, "diff: usage: diff [-u] FILE1 FILE2\n")
        return 2

    gpa = argv[cast[uint64](f1)]
    gpb = argv[cast[uint64](f2)]

    ra: int64 = load_file(&buf_a[0], cast[Ptr[char]](gpa))
    if ra < 0:
        return 2
    rb: int64 = load_file(&buf_b[0], cast[Ptr[char]](gpb))
    if rb < 0:
        return 2
    len_a = cast[uint64](ra)
    len_b = cast[uint64](rb)

    na = split_lines(&buf_a[0], len_a, &a_off[0], &a_len[0])
    nb = split_lines(&buf_b[0], len_b, &b_off[0], &b_len[0])

    build_dp()
    build_script()

    if unified_mode != 0:
        return unified()
    return normal()

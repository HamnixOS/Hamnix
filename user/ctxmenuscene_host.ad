# user/ctxmenuscene_host.ad — HOST driver + render harness for the MATE
# context menus (built for the x86_64-linux Adder target; runs on the dev
# host, no QEMU).
#
# Draws the SAME menu model the native compositor ships (lib/ctxmenucore.ad)
# through lib/hamscene.ad and RASTERIZES it with lib/hamui_host.ad into PPMs a
# human/agent can LOOK at:
#   * PANEL menu   (Add to Panel... / Properties / Reset All Panels / ...)
#   * APPLET menu  (Preferences / Move / Remove From Panel / Lock To Panel)
#   * CHOOSER      (Add to Panel applet picker)
# It also dumps the raw scene display list (so a gate greps the LABELS) plus
# hit-test / width assertions — all in milliseconds.
#
# No sockets, no Plan 9: reads argv + writes files. TEST shim only.
#
# USAGE (built to build/host/ctxmenu_host):
#   ctxmenu_host PANEL.ppm APPLET.ppm CHOOSER.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.hamscene import hamscene_bufptr, hamscene_length
from lib.hamui_host import hamui_host_begin, hamui_host_rasterize, \
    hamui_host_ppm_header, hamui_host_fb_ptr, hamui_host_fb_bytes, \
    hamui_host_pixel
from lib.ctxmenucore import ctxm_build_scene, ctxm_width, ctxm_item_at, \
    ctxm_kind_count, CTXM_KIND_PANEL, CTXM_KIND_APPLET, CTXM_KIND_CHOOSER, \
    CTXM_APPLET_CLOCK, CTXM_ITEM_H, \
    ctxm_choice_init, ctxm_choice_set_filter, ctxm_choice_layout, \
    ctxm_choice_build_scene, ctxm_choice_row_count, ctxm_choice_row_kind, \
    ctxm_choice_row_cat, ctxm_choice_row_name, ctxm_choice_row_applet, \
    ctxm_choice_cat_name, ctxm_choice_content_h, ctxm_choice_w, \
    ctxm_choice_hit, ctxm_choice_count, ctxm_choice_filter_len, \
    ctxm_choice_filter_push, ctxm_choice_filter_backspace, \
    ctxm_choice_filter_ptr, \
    CTXM_CC_ROW_SEARCH, CTXM_CC_ROW_HEADER, CTXM_CC_ROW_ENTRY


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- PPM writer ----------------------------------------------------------
ppm_hdr: Array[64, uint8]


def _write_ppm(path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path, 577, 420)               # O_WRONLY|O_CREAT|O_TRUNC
    if fd < 0:
        return -1
    hlen: uint64 = hamui_host_ppm_header(&ppm_hdr[0])
    sys_write(fd, &ppm_hdr[0], hlen)
    sys_write(fd, hamui_host_fb_ptr(), hamui_host_fb_bytes())
    sys_close(fd)
    return 0


W: int32 = 320
H: int32 = 240


# Render one menu kind (hovering `hover`) to a PPM + dump its scene.
def _render_menu(kind: int32, applet: int32, locked: int32,
                 bx: int32, by: int32, hover: int32,
                 tag: Ptr[uint8], path: Ptr[char]):
    ctxm_build_scene(kind, bx, by, hover, locked, applet, W, H)
    hamui_host_begin(W, H)
    prims: int32 = hamui_host_rasterize()
    _write_ppm(path)
    _o_str(cast[Ptr[uint8]]("MENU "))
    _o_str(tag)
    _o_str(cast[Ptr[uint8]](" prims="))
    _o_dec(cast[int64](prims))
    _o_str(cast[Ptr[uint8]](" count="))
    _o_dec(cast[int64](ctxm_kind_count(kind)))
    _o_str(cast[Ptr[uint8]](" width="))
    _o_dec(cast[int64](ctxm_width(kind, locked)))
    _o_ch(10)
    _o_flush()
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN "))
    _o_str(tag)
    _o_ch(10)
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


# Chooser-v2 (searchable Add-to-Panel DIALOG) canvas + anchor.
CW: int32 = 400
CH: int32 = 560
CBX: int32 = 30
CBY: int32 = 20


# Render the searchable chooser (hovering ENTRY row `hover`) + dump its row
# model so a gate can assert the search box, category headers, per-applet
# name/description rows, and the live filter.
def _render_choice(tag: Ptr[uint8], hover: int32, path: Ptr[char]):
    ctxm_choice_layout()
    ctxm_choice_build_scene(CBX, CBY, hover, CW, CH)
    hamui_host_begin(CW, CH)
    prims: int32 = hamui_host_rasterize()
    _write_ppm(path)
    _o_str(cast[Ptr[uint8]]("CHOICE "))
    _o_str(tag)
    _o_str(cast[Ptr[uint8]](" prims="))
    _o_dec(cast[int64](prims))
    _o_str(cast[Ptr[uint8]](" rows="))
    _o_dec(cast[int64](ctxm_choice_row_count()))
    _o_str(cast[Ptr[uint8]](" applets="))
    _o_dec(cast[int64](ctxm_choice_count()))
    _o_str(cast[Ptr[uint8]](" width="))
    _o_dec(cast[int64](ctxm_choice_w()))
    _o_str(cast[Ptr[uint8]](" height="))
    _o_dec(cast[int64](ctxm_choice_content_h()))
    _o_str(cast[Ptr[uint8]](" filter="))
    _o_dec(cast[int64](ctxm_choice_filter_len()))
    _o_ch(10)
    _o_flush()
    i: uint64 = 0
    while i < ctxm_choice_row_count():
        k: int32 = ctxm_choice_row_kind(i)
        _o_str(cast[Ptr[uint8]]("CROW "))
        _o_str(tag)
        _o_ch(32)
        _o_dec(cast[int64](i))
        _o_ch(32)
        if k == CTXM_CC_ROW_SEARCH:
            _o_str(cast[Ptr[uint8]]("SEARCH"))
        elif k == CTXM_CC_ROW_HEADER:
            _o_str(cast[Ptr[uint8]]("HEADER "))
            _o_str(ctxm_choice_cat_name(ctxm_choice_row_cat(i)))
        else:
            _o_str(cast[Ptr[uint8]]("ENTRY "))
            _o_str(ctxm_choice_row_name(i))
            _o_str(cast[Ptr[uint8]]("  ["))
            _o_str(ctxm_choice_cat_name(ctxm_choice_row_cat(i)))
            _o_ch(93)
        _o_ch(10)
        _o_flush()
        i = i + 1
    _o_str(cast[Ptr[uint8]]("SCENE-BEGIN "))
    _o_str(tag)
    _o_ch(10)
    _o_flush()
    sys_write(1, hamscene_bufptr(), hamscene_length())
    _o_str(cast[Ptr[uint8]]("SCENE-END\n"))
    _o_flush()


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 6:
        _o_str(cast[Ptr[uint8]]("usage: ctxmenu_host PANEL.ppm APPLET.ppm CHOOSER.ppm CHOICE_FULL.ppm CHOICE_FILTERED.ppm\n"))
        _o_flush()
        return 2

    # PANEL menu — hover row 0 ("Add to Panel...").
    _render_menu(CTXM_KIND_PANEL, 0, 0, 40, 60, 0,
                 cast[Ptr[uint8]]("PANEL"), cast[Ptr[char]](argv[1]))
    # APPLET menu for the Clock — hover row 0 ("Preferences").
    _render_menu(CTXM_KIND_APPLET, CTXM_APPLET_CLOCK, 0, 40, 60, 0,
                 cast[Ptr[uint8]]("APPLET"), cast[Ptr[char]](argv[2]))
    # Add-to-Panel CHOOSER — hover row 2 ("Clock").
    _render_menu(CTXM_KIND_CHOOSER, 0, 0, 40, 60, 2,
                 cast[Ptr[uint8]]("CHOOSER"), cast[Ptr[char]](argv[3]))

    # ---- hit-test assertions (menu box top-left at 40,60) ---------------
    # Row 0 spans y=[60,80); its centre (50,70) must map to item 0.
    i0: int64 = ctxm_item_at(CTXM_KIND_PANEL, 0, 40, 60, 50, 70)
    _o_str(cast[Ptr[uint8]]("HIT panel 50 70 "))
    _o_dec(i0)
    _o_ch(10)
    # Row 3 ("Delete This Panel") centre: 60 + 3*20 + 10 = 130.
    i3: int64 = ctxm_item_at(CTXM_KIND_PANEL, 0, 40, 60, 50, 130)
    _o_str(cast[Ptr[uint8]]("HIT panel 50 130 "))
    _o_dec(i3)
    _o_ch(10)
    # A point above the box misses.
    im: int64 = ctxm_item_at(CTXM_KIND_PANEL, 0, 40, 60, 50, 10)
    _o_str(cast[Ptr[uint8]]("HIT panel 50 10 "))
    _o_dec(im)
    _o_ch(10)
    # Applet menu Lock row (3) centre y=130.
    ial: int64 = ctxm_item_at(CTXM_KIND_APPLET, 0, 40, 60, 50, 130)
    _o_str(cast[Ptr[uint8]]("HIT applet 50 130 "))
    _o_dec(ial)
    _o_ch(10)
    _o_flush()

    # Sampled selection-blue pixel inside PANEL row 0 (re-render panel last so
    # the framebuffer holds it). Row 0 fill spans y=[60,80), x=[41,41+w-2).
    ctxm_build_scene(CTXM_KIND_PANEL, 40, 60, 0, 0, 0, W, H)
    hamui_host_begin(W, H)
    hamui_host_rasterize()
    # Sample the left inset of row 0 (x=44), before the text at x=52 — pure
    # selection fill, no glyph pixels.
    _o_str(cast[Ptr[uint8]]("PIX 44 70 "))
    _o_hexcol(hamui_host_pixel(44, 70))                # selection blue #4a6fa5
    _o_ch(10)
    _o_flush()

    # ---- searchable Add-to-Panel CHOOSER (v2 DIALOG) --------------------
    ctxm_choice_init()
    # FULL dialog (no filter). Hover the first entry (row after the search +
    # first header) so the PNG shows a selection highlight.
    ctxm_choice_set_filter(cast[Ptr[uint8]](""))
    _render_choice(cast[Ptr[uint8]]("FULL"), 2, cast[Ptr[char]](argv[4]))
    # FILTERED: typing "work" narrows the list to the Workspace Switcher.
    ctxm_choice_init()
    ctxm_choice_set_filter(cast[Ptr[uint8]]("work"))
    _render_choice(cast[Ptr[uint8]]("FILTERED"), -1, cast[Ptr[char]](argv[5]))

    # Hit-test on the FULL dialog: the search row (row 0) sits just below the
    # title; a click on the first entry maps to an ENTRY row.
    ctxm_choice_init()
    ctxm_choice_set_filter(cast[Ptr[uint8]](""))
    ctxm_choice_layout()
    hs: int64 = ctxm_choice_hit(CBX, CBY, CBX + 40, CBY + 30)
    _o_str(cast[Ptr[uint8]]("CHIT search "))
    _o_dec(hs)
    _o_ch(10)
    hmiss: int64 = ctxm_choice_hit(CBX, CBY, CBX - 5, CBY + 30)
    _o_str(cast[Ptr[uint8]]("CHIT miss "))
    _o_dec(hmiss)
    _o_ch(10)
    # Row 2 is the first ENTRY; report its kind + inserted applet id.
    _o_str(cast[Ptr[uint8]]("CKIND row2 "))
    _o_dec(cast[int64](ctxm_choice_row_kind(2)))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CAPPLET row2 "))
    _o_dec(cast[int64](ctxm_choice_row_applet(2)))
    _o_ch(10)

    # --- LIVE TYPING: the on-device keystroke edit path (push/backspace) the
    #     chooser's keyboard loop drives. Typing "W","o","r","k","x" then
    #     Backspace leaves "work" and narrows the layout to the 3 rows the
    #     FILTERED render proves (search + header + Workspace Switcher). ---
    ctxm_choice_init()
    ctxm_choice_set_filter(cast[Ptr[uint8]](""))
    ctxm_choice_layout()
    ctxm_choice_filter_push(87)                      # 'W' -> lowercased 'w'
    ctxm_choice_filter_push(111)                     # 'o'
    ctxm_choice_filter_push(114)                     # 'r'
    ctxm_choice_filter_push(107)                     # 'k'
    ctxm_choice_filter_push(120)                     # 'x' (no match)
    ctxm_choice_filter_backspace()                   # delete 'x' -> "work"
    ctxm_choice_layout()
    _o_str(cast[Ptr[uint8]]("CTYPE filter=\""))
    _o_str(ctxm_choice_filter_ptr())
    _o_str(cast[Ptr[uint8]]("\" len="))
    _o_dec(cast[int64](ctxm_choice_filter_len()))
    _o_str(cast[Ptr[uint8]](" rows="))
    _o_dec(cast[int64](ctxm_choice_row_count()))
    _o_ch(10)
    _o_flush()
    return 0

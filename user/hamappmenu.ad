# user/hamappmenu.ad
#
# hamappmenu — the DE Applications menu, a separate-process v2 client the
# compositor (hamUId) spawns when the Apps trigger fires (panel button click,
# Apps hotkey). MATE-STYLE: a single vertical column with
#
#   * a SEARCH box at the very top,
#   * a RECENT section (most-recently-launched apps), and
#   * apps GROUPED BY CATEGORY under bold headers
#     (Accessories / Graphics / Internet / Office / Games / System /
#      Settings / Other),
#
# replacing the old cascading category-column-plus-hover-flyout that only
# revealed a category's apps on hover and had no search or recent memory.
#
# Wire model
# ----------
# 1. hamUId publishes the catalogue snapshot at /dev/wsys/appmenu (read here
#    for wire-protocol compat so the serial-bump machinery sees a reader).
# 2. hamUId spawns /bin/hamappmenu when the Apps trigger fires.
# 3. We open OUR /dev/wsys/<wid>/wctl, opt into the rio blit protocol
#    (hamui_set_protocol_v2*), then rasterise the menu into the client
#    backbuffer with lib/hamui.ad's hamui_v2_* family.
# 4. On click we write the chosen prog path to /dev/wsys/appmenu/launch and
#    exit; hamUId observes the serial bump and spawns the program.
#
# Catalogue model
# ---------------
# DATA-DRIVEN from /etc/hamde/apps/*.desktop (freedesktop Desktop Entry files,
# parsed by lib/desktopentry.ad). Each entry's `Categories=` string is handed
# to lib/appmenucore.ad, which owns the MATE bucket classification, the search
# filter, the recent list, the single-column ROW LAYOUT, and the hit-test —
# the SAME pure model the host render gate (scripts/test_de_appmenu_menu_host.sh)
# proves visually. This client walks that row model and paints it with hamui v2
# blits. If the directory yields no entries, a small built-in fallback set is
# planted so the menu is never empty.

from lib.hamui import (
    hamui_init, hamui_window_on, hamui_set_protocol_v2, hamui_set_protocol_v2_dims,
    hamui_v2_clear, hamui_v2_clear_transparent, hamui_v2_fill_rect,
    hamui_v2_commit_rect, hamui_v2_is_active, hamui_window_wid,
)
from lib.p9 import p9_listdir
from lib.desktopentry import (
    desktop_parse, desktop_name_ptr, desktop_name_len,
    desktop_prog_ptr, desktop_cats_ptr, desktop_name_is_entry,
    desktop_liveonly,
)
from lib.appmenucore import (
    amc_reset, amc_add, amc_mark_launch, amc_layout,
    amc_row_count, amc_row_kind, amc_row_cat, amc_row_y,
    amc_row_label, amc_row_glyph, amc_row_prog, amc_row_prog_len,
    amc_cat_rgb, amc_hit, amc_content_h, amc_box_w, amc_app_count,
    amc_filter_ptr, amc_filter_len, amc_filter_push, amc_filter_backspace,
    amc_set_open_cat, amc_open_cat, amc_child_layout, amc_child_count,
    amc_child_app, amc_child_hit, amc_child_x, amc_child_y,
    amc_child_w, amc_child_h, amc_app_prog, amc_app_prog_len,
    amc_app_name, amc_app_glyph, amc_app_cat,
    AMC_ROW_SEARCH, AMC_ROW_HEADER, AMC_ROW_APP, AMC_ROW_CATBTN, AMC_ROW_H,
    AMC_CHILD_W,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_yield()
extern def sys_exit(code: int32)


# ====================================================================
# Window geometry
# ====================================================================
# The menu BOX is 208 wide (from the core). To contain a category's hover
# FLY-OUT (a child popup opened to the RIGHT of the box, like the panel's
# "Linux apps ▸" submenu) the WINDOW is always sized GROWN wide = box + child;
# the region to the right of the box is cleared TRANSPARENT (alpha 0, skipped
# by the compositor's v2 blit) when no fly-out is open, so a closed menu looks
# exactly like a plain-width box. Height fits the laid-out content, clamped to
# a screen-friendly max; the fly-out is clamped inside that height.
_am_BOX_W:   int32 = 208                  # the menu box proper
_am_WIN_W:   int32 = 208                  # backing window (grown to hold fly-out)
_am_WIN_H:   int32 = 200
_am_BOX_H:   int32 = 200
_am_MAX_H:   int32 = 452


# ====================================================================
# DATA-DRIVEN catalogue scan (/etc/hamde/apps/*.desktop)
# ====================================================================
_dd_listbuf: Array[4096, uint8]
_dd_filebuf: Array[2048, uint8]
_dd_path:    Array[160, uint8]


def _dd_apps_dir() -> Ptr[uint8]:
    return "/etc/hamde/apps"


def _dd_build_path(name: Ptr[uint8], nlen: uint64):
    dir: Ptr[uint8] = _dd_apps_dir()
    p: uint64 = 0
    while dir[p] != 0:
        _dd_path[p] = dir[p]
        p = p + 1
    _dd_path[p] = 47
    p = p + 1
    k: uint64 = 0
    while k < nlen and p < 159:
        _dd_path[p] = name[k]
        p = p + 1
        k = k + 1
    _dd_path[p] = 0


# First glyph of a name (upper-cased) as the icon-chip letter.
def _dd_glyph(name: Ptr[uint8]) -> uint8:
    c: uint8 = name[0]
    if c >= 97 and c <= 122:
        return c - 32
    if c == 0:
        return 63                                    # '?'
    return c


# Live-medium probe: /etc/installer-medium is planted in the cpio ONLY by
# scripts/build_installer_img.sh, so it is present on the LIVE/installer boot
# and absent on every installed boot (see etc/rc.boot). Cached (0 unknown,
# 1 live, 2 installed) so the per-entry filter is a single syscall at most.
_dd_live_state: int32 = 0
def _dd_is_live() -> int32:
    if _dd_live_state == 0:
        fd: int32 = sys_open(cast[Ptr[char]]("/etc/installer-medium"))
        if fd >= 0:
            sys_close(fd)
            _dd_live_state = 1
        else:
            _dd_live_state = 2
    if _dd_live_state == 1:
        return 1
    return 0


# Scan the catalogue directory into the core model. Returns app count added.
def _dd_scan() -> int32:
    amc_reset()
    n: int64 = p9_listdir(cast[Ptr[char]](_dd_apps_dir()), &_dd_listbuf[0], 4096)
    if n <= 0:
        return 0
    added: int32 = 0
    cap: uint64 = cast[uint64](n)
    i: uint64 = 0
    while i < cap:
        e: uint64 = i
        while e < cap and _dd_listbuf[e] != 10:
            e = e + 1
        nm: Array[64, uint8]
        nl: uint64 = 0
        k: uint64 = i
        while k < e and nl < 63:
            nm[nl] = _dd_listbuf[k]
            nl = nl + 1
            k = k + 1
        nm[nl] = 0
        if nl > 0 and desktop_name_is_entry(&nm[0]) != 0:
            _dd_build_path(&nm[0], nl)
            fd: int32 = sys_open(cast[Ptr[char]](&_dd_path[0]))
            if fd >= 0:
                rn: int64 = sys_read(fd, &_dd_filebuf[0], 2047)
                sys_close(fd)
                if rn > 0:
                    if desktop_parse(&_dd_filebuf[0], cast[uint64](rn)) != 0:
                        # Live-only entries (the installer launcher) appear on
                        # the live medium ONLY, never on an installed system.
                        if desktop_liveonly() == 0 or _dd_is_live() != 0:
                            np: Ptr[uint8] = desktop_name_ptr()
                            amc_add(np, desktop_prog_ptr(), desktop_cats_ptr(),
                                    _dd_glyph(np))
                            added = added + 1
        i = e + 1
    return added


# Fallback set when /etc/hamde/apps is empty (matches the shipped native apps).
def _seed_fallback():
    amc_reset()
    amc_add("Calculator", "/bin/calculator", "Utility;", 67)
    amc_add("Terminal", "/bin/hamterm", "System;TerminalEmulator;", 84)
    amc_add("Files", "/bin/hamfm", "System;FileManager;", 70)
    amc_add("Text Editor", "/bin/hamedit", "Utility;TextEditor;", 69)
    amc_add("Image Viewer", "/bin/hamview", "Graphics;Viewer;", 86)
    amc_add("Web Browser", "/bin/hambrowse", "Network;WebBrowser;", 87)
    amc_add("System Monitor", "/bin/hammonscene", "System;Monitor;", 77)
    amc_add("Package Manager", "/bin/hpm", "System;PackageManager;", 80)
    amc_add("Control Center", "/bin/hamctl", "Settings;", 67)


def _build_catalogue():
    added: int32 = _dd_scan()
    if added <= 0:
        _seed_fallback()


# ====================================================================
# scratch buffers
# ====================================================================
_am_snap_buf:   Array[2080, uint8]
_am_ptr_buf:    Array[512, uint8]
_am_launch_buf: Array[128, uint8]

# Hovered main-box row (-1 = none) and hovered fly-out child row (-1 = none).
_am_HOVER_ROW:   int32 = -1
_am_CHILD_HOVER: int32 = -1


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _puts(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _strlen(s))


def _put_dec(out: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    if v == 0:
        out[pos] = 48
        return pos + 1
    tmp: Array[20, uint8]
    t: uint64 = 0
    while v != 0:
        tmp[t] = cast[uint8](v % 10) + 48
        v = v / 10
        t = t + 1
    p: uint64 = pos
    while t > 0:
        t = t - 1
        out[p] = tmp[t]
        p = p + 1
    return p


# ====================================================================
# Snapshot reader (wire-protocol compat)
# ====================================================================
# OPEN /dev/wsys/appmenu so hamUId's serial-bump machinery sees a reader; the
# parsed catalogue is intentionally ignored in favour of the .desktop scan.
def _read_appmenu_snapshot() -> int64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/appmenu"))
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, &_am_snap_buf[0], 2080)
    sys_close(fd)
    return n


# ====================================================================
# 4x6 block glyph rendering (no kernel font in the v2 blit path)
# ====================================================================
def _draw_text(x: int32, y: int32, max_w: int32,
               label: Ptr[uint8], len: uint64,
               fr: uint8, fg: uint8, fb: uint8):
    i: uint64 = 0
    cx: int32 = x
    while i < len and cx + 4 <= x + max_w:
        c: uint8 = label[i]
        if c != 32:
            hamui_v2_fill_rect(cx, y, 4, 6, fr, fg, fb)
        cx = cx + 6
        i = i + 1


# A category colour chip (icon box) with the app's glyph letter centred.
def _draw_icon_box(x: int32, y: int32, glyph: uint8,
                   ir: uint8, ig: uint8, ib: uint8):
    sz: int32 = 12
    hamui_v2_fill_rect(x, y, sz, sz, ir, ig, ib)
    hamui_v2_fill_rect(x, y, sz, 1,
                       cast[uint8](cast[int32](ir) * 60 / 100),
                       cast[uint8](cast[int32](ig) * 60 / 100),
                       cast[uint8](cast[int32](ib) * 60 / 100))
    hamui_v2_fill_rect(x, y + sz - 1, sz, 1,
                       cast[uint8](cast[int32](ir) * 60 / 100),
                       cast[uint8](cast[int32](ig) * 60 / 100),
                       cast[uint8](cast[int32](ib) * 60 / 100))
    if glyph != 32:
        hamui_v2_fill_rect(x + 4, y + 3, 4, 6, 240, 240, 240)


# ====================================================================
# Paint — walk the core's single-column row model.
# ====================================================================
# Draw one launchable app row (Recent apps + fly-out child apps share this):
# an optional selection highlight, a category colour chip, then the name.
def _draw_app_row(bx: int32, ry: int32, w: int32, cat: int32, glyph: uint8,
                  name: Ptr[uint8], nlen: uint64, sel: int32):
    tr: uint8 = 46
    tg: uint8 = 43
    tb: uint8 = 40
    if sel != 0:
        hamui_v2_fill_rect(bx + 1, ry, w - 2, AMC_ROW_H, 74, 111, 165)
        tr = 255
        tg = 255
        tb = 255
    rgb: Array[3, uint8]
    amc_cat_rgb(cat, &rgb[0])
    iy: int32 = ry + (AMC_ROW_H - 12) / 2
    _draw_icon_box(bx + 10, iy, glyph, rgb[0], rgb[1], rgb[2])
    _draw_text(bx + 28, ry + 6, w - 34, name, nlen, tr, tg, tb)


def _paint_menu():
    w: int32 = amc_box_w()
    # Window is grown wide to hold a fly-out; clear it transparent so anything
    # outside the box (and the box's right margin) shows the desktop, then
    # paint the cream box body over the box region only.
    hamui_v2_clear_transparent()
    hamui_v2_fill_rect(0, 0, w, _am_BOX_H, 237, 233, 227)      # cream body
    hamui_v2_fill_rect(w - 1, 0, 1, _am_BOX_H, 143, 139, 133)  # box r-edge
    i: uint64 = 0
    rc: uint64 = amc_row_count()
    while i < rc:
        ry: int32 = amc_row_y(i)
        if ry >= _am_BOX_H:
            i = i + 1
            continue
        kind: int32 = amc_row_kind(i)
        if kind == AMC_ROW_SEARCH:
            # White search field + the live filter text (or a placeholder tick).
            hamui_v2_fill_rect(4, ry + 3, w - 8, AMC_ROW_H - 5, 255, 255, 255)
            hamui_v2_fill_rect(4, ry + 3, w - 8, 1, 143, 139, 133)
            hamui_v2_fill_rect(8, ry + 8, 5, 5, 154, 148, 140)   # magnifier
            fl: uint64 = amc_filter_len()
            if fl > 0:
                _draw_text(20, ry + 6, w - 26, amc_filter_ptr(), fl,
                           46, 43, 40)
        elif kind == AMC_ROW_HEADER:
            hamui_v2_fill_rect(1, ry, w - 2, AMC_ROW_H, 220, 214, 204)
            lbl: Ptr[uint8] = amc_row_label(i)
            # Faux-bold: draw the block label twice, 1px apart.
            _draw_text(10, ry + 6, w - 16, lbl, _strlen(lbl), 90, 84, 76)
            _draw_text(11, ry + 6, w - 16, lbl, _strlen(lbl), 90, 84, 76)
        elif kind == AMC_ROW_CATBTN:
            # A category PARENT BUTTON: chip + bold label + a ">" chevron.
            # Highlighted while hovered OR while its fly-out is open.
            catv: int32 = amc_row_cat(i)
            hot: int32 = 0
            if cast[int32](i) == _am_HOVER_ROW or catv == amc_open_cat():
                hot = 1
            lr: uint8 = 46
            lg: uint8 = 43
            lb: uint8 = 40
            if hot != 0:
                hamui_v2_fill_rect(1, ry, w - 2, AMC_ROW_H, 74, 111, 165)
                lr = 255
                lg = 255
                lb = 255
            else:
                hamui_v2_fill_rect(1, ry, w - 2, AMC_ROW_H, 227, 221, 211)
            rgb2: Array[3, uint8]
            amc_cat_rgb(catv, &rgb2[0])
            iy2: int32 = ry + (AMC_ROW_H - 12) / 2
            _draw_icon_box(10, iy2, 32, rgb2[0], rgb2[1], rgb2[2])
            lbl3: Ptr[uint8] = amc_row_label(i)
            _draw_text(28, ry + 6, w - 44, lbl3, _strlen(lbl3), lr, lg, lb)
            _draw_text(11, ry + 6, w - 44, lbl3, _strlen(lbl3), lr, lg, lb)
            # ">" chevron at the right edge.
            gt: Array[2, uint8]
            gt[0] = 62
            gt[1] = 0
            _draw_text(w - 14, ry + 6, 8, &gt[0], 1, lr, lg, lb)
        else:
            sel: int32 = 0
            if cast[int32](i) == _am_HOVER_ROW:
                sel = 1
            _draw_app_row(0, ry, w, amc_row_cat(i), amc_row_glyph(i),
                          amc_row_label(i), _strlen(amc_row_label(i)), sel)
        i = i + 1
    # ---- CHILD FLY-OUT: the open category's apps, aligned to its parent ----
    oc: int32 = amc_open_cat()
    if oc >= 0:
        amc_child_layout(0, 0, _am_WIN_W, _am_BOX_H)
        cx: int32 = amc_child_x()
        cy: int32 = amc_child_y()
        cw: int32 = amc_child_w()
        chh: int32 = amc_child_h()
        hamui_v2_fill_rect(cx, cy, cw, chh, 237, 233, 227)        # cream
        hamui_v2_fill_rect(cx, cy, cw, 1, 143, 139, 133)          # frame
        hamui_v2_fill_rect(cx, cy + chh - 1, cw, 1, 143, 139, 133)
        hamui_v2_fill_rect(cx, cy, 1, chh, 143, 139, 133)
        hamui_v2_fill_rect(cx + cw - 1, cy, 1, chh, 143, 139, 133)
        ci: uint64 = 0
        cc: uint64 = amc_child_count()
        while ci < cc:
            ai: uint64 = cast[uint64](amc_child_app(ci))
            cry: int32 = cy + cast[int32](ci) * AMC_ROW_H
            csel: int32 = 0
            if cast[int32](ci) == _am_CHILD_HOVER:
                csel = 1
            _draw_app_row(cx, cry, cw, amc_app_cat(ai), amc_app_glyph(ai),
                          amc_app_name(ai), _strlen(amc_app_name(ai)), csel)
            ci = ci + 1
    hamui_v2_commit_rect(0, 0, _am_WIN_W, _am_WIN_H)
    # SCENE-FILE DE: composite our v2 backbuffer by emitting a `buffer` scene
    # line + commit (see _am_present_buffer). Without this the menu window maps
    # but never appears — the click-does-nothing bug.
    _am_present_buffer(hamui_window_wid(), _am_WIN_W, _am_WIN_H)


# ====================================================================
# Launch emit
# ====================================================================
def _emit_launch_path(buf: Ptr[uint8], plen: uint64) -> int32:
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/appmenu/launch"))
    if fd < 0:
        return -1
    j: uint64 = 0
    while j < plen and j < 127:
        _am_launch_buf[j] = buf[j]
        j = j + 1
    _am_launch_buf[j] = 10
    j = j + 1
    sys_write(fd, &_am_launch_buf[0], j)
    sys_close(fd)
    return 0


# ====================================================================
# Drag-to-panel: create a launcher shortcut (#283)
# ====================================================================
# A press-and-DRAG on an app entry (as opposed to a plain click, which
# launches) writes the app's Exec + label to a filesystem sidecar the scene
# panel (hampanelscene) polls; the panel then appends a persistent launcher
# widget next to its Applications menu. This is a PURELY CLIENT-SIDE handshake
# — the compositor (devwsys) routes pointer events to the window UNDER the
# cursor with no cross-window grab, so the menu cannot itself observe a drop
# landing on the panel window; a shared /tmp sidecar bridges the two clients
# without any kernel/devwsys change. The gesture reads as "drag an app out of
# the menu onto the panel to pin it".
_am_DROP_PATH:  Ptr[uint8] = "/tmp/hamnix-panel-drop"
_am_drop_buf:   Array[128, uint8]
# Press-tracking for the drag gesture. _am_press_prog<0 means no app-row press
# is in flight; otherwise it holds the pending launch (prog ptr/len + label) to
# fire on release-in-place, or to convert into a drop if the pointer drags off.
_am_press_active: int32 = 0
_am_press_x:      int32 = 0
_am_press_y:      int32 = 0
_am_press_kind:   int32 = 0              # 1 = main-box app row, 2 = fly-out child
_am_press_ref:    int32 = -1            # main row index OR child app index
_am_DRAG_PX:      int32 = 14              # drag threshold (px, any direction)


def _emit_drop(prog: Ptr[uint8], plen: uint64,
               label: Ptr[uint8], llen: uint64) -> int32:
    fd: int32 = sys_open_write(cast[Ptr[char]](_am_DROP_PATH))
    if fd < 0:
        return -1
    p: uint64 = 0
    j: uint64 = 0
    while j < plen and p < 100:
        _am_drop_buf[p] = prog[j]
        p = p + 1
        j = j + 1
    _am_drop_buf[p] = 32                  # ' ' separates exec from label
    p = p + 1
    j = 0
    while j < llen and p < 126:
        c: uint8 = label[j]
        if c == 32:                       # collapse label spaces to '_'
            c = 95
        _am_drop_buf[p] = c
        p = p + 1
        j = j + 1
    _am_drop_buf[p] = 10
    p = p + 1
    sys_write(fd, &_am_drop_buf[0], p)
    sys_close(fd)
    return 0


# ====================================================================
# Pointer poll
# ====================================================================
_am_ptr_fd: int32 = -1
_am_prev_btn:   int32 = 0
_am_last_x:     int32 = 0
_am_last_y:     int32 = 0


def _build_ptr_path(wid: int32, out: Ptr[uint8]):
    pfx: Ptr[uint8] = "/dev/wsys/"
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        out[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = _put_dec(out, p, cast[uint64](wid))
    sfx: Ptr[uint8] = "/pointer"
    k = 0
    while sfx[k] != 0:
        out[p] = sfx[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def _parse_signed_field(pos: Ptr[uint64], end: uint64) -> int32:
    p: uint64 = pos[0]
    neg: int32 = 0
    if p < end and _am_ptr_buf[p] == 45:
        neg = 1
        p = p + 1
    v: int32 = 0
    while p < end and _am_ptr_buf[p] >= 48 and _am_ptr_buf[p] <= 57:
        v = v * 10 + cast[int32](_am_ptr_buf[p]) - 48
        p = p + 1
    pos[0] = p
    if neg != 0:
        return -v
    return v


def _ptr_skip_ws(pos: Ptr[uint64], end: uint64):
    p: uint64 = pos[0]
    while p < end and (_am_ptr_buf[p] == 32 or _am_ptr_buf[p] == 9):
        p = p + 1
    pos[0] = p


def _ptr_skip_line(pos: Ptr[uint64], end: uint64):
    p: uint64 = pos[0]
    while p < end and _am_ptr_buf[p] != 10:
        p = p + 1
    if p < end:
        p = p + 1
    pos[0] = p


# Drain pointer events. Encoded result:
#   >= 0  — chosen APP row index; launch amc_row_prog(row)
#   == -1 — nothing, keep polling
#   == -2 — dismiss without launching
def _drain_pointer(wid: int32) -> int32:
    if _am_ptr_fd < 0:
        ppath: Array[64, uint8]
        _build_ptr_path(wid, &ppath[0])
        _am_ptr_fd = sys_open(cast[Ptr[char]](&ppath[0]))
    if _am_ptr_fd < 0:
        return -1
    result: int32 = -1
    redraw: int32 = 0
    n: int64 = sys_read_nb(_am_ptr_fd, &_am_ptr_buf[0], 512)
    while n > 0:
        cap: uint64 = cast[uint64](n)
        pos: Array[1, uint64]
        pos[0] = 0
        while pos[0] < cap:
            if pos[0] >= cap:
                break
            t: uint8 = _am_ptr_buf[pos[0]]
            pos[0] = pos[0] + 1
            if pos[0] < cap and _am_ptr_buf[pos[0]] == 32:
                pos[0] = pos[0] + 1
            x: int32 = _parse_signed_field(&pos[0], cap)
            _ptr_skip_ws(&pos[0], cap)
            y: int32 = _parse_signed_field(&pos[0], cap)
            _ptr_skip_ws(&pos[0], cap)
            btn: int32 = _parse_signed_field(&pos[0], cap)
            _ptr_skip_line(&pos[0], cap)
            _am_last_x = x
            _am_last_y = y
            # Hover tracking. A CATBTN under the pointer opens/switches its
            # hover fly-out (MATE style, mirroring the panel's "Linux apps ▸");
            # staying over the open fly-out keeps it; moving onto any other
            # box row closes it. Recent-app rows get the usual highlight.
            hrow: int64 = amc_hit(0, 0, x, y)
            nh: int32 = -1
            if hrow >= 0 and amc_row_kind(cast[uint64](hrow)) == AMC_ROW_APP:
                nh = cast[int32](hrow)
            elif hrow >= 0 and amc_row_kind(cast[uint64](hrow)) == AMC_ROW_CATBTN:
                nh = cast[int32](hrow)
            if nh != _am_HOVER_ROW:
                _am_HOVER_ROW = nh
                redraw = 1
            # fly-out open/switch/close.
            chit: int64 = amc_child_hit(x, y)
            newcat: int32 = amc_open_cat()
            if hrow >= 0 and amc_row_kind(cast[uint64](hrow)) == AMC_ROW_CATBTN:
                newcat = amc_row_cat(cast[uint64](hrow))
            elif chit >= 0:
                newcat = amc_open_cat()          # keep — pointer over child
            elif hrow >= 0:
                newcat = -1                      # over search/recent/header
            if newcat != amc_open_cat():
                amc_set_open_cat(newcat)
                amc_child_layout(0, 0, _am_WIN_W, _am_BOX_H)
                redraw = 1
            # child-row hover highlight.
            nch: int32 = -1
            if amc_open_cat() >= 0 and chit >= 0:
                nch = (y - amc_child_y()) / AMC_ROW_H
            if nch != _am_CHILD_HOVER:
                _am_CHILD_HOVER = nch
                redraw = 1
            if t == 100:                  # 'd' press
                if (btn & 1) != 0 and (_am_prev_btn & 1) == 0:
                    # A press on an APP entry (fly-out child or main-box row)
                    # ARMS a press: a release-in-place launches it, but a drag
                    # past the threshold turns it into a launcher DROP on the
                    # panel (#283). CATBTN toggles / outside-dismiss stay on the
                    # press edge (no drag semantics).
                    _am_press_active = 0
                    _am_press_kind = 0
                    _am_press_ref = -1
                    cah: int64 = amc_child_hit(x, y)
                    if cah >= 0:
                        _am_press_active = 1
                        _am_press_kind = 2
                        _am_press_ref = cast[int32](cah)
                        _am_press_x = x
                        _am_press_y = y
                    else:
                        ch: int64 = amc_hit(0, 0, x, y)
                        if ch >= 0 and amc_row_kind(cast[uint64](ch)) == AMC_ROW_APP:
                            _am_press_active = 1
                            _am_press_kind = 1
                            _am_press_ref = cast[int32](ch)
                            _am_press_x = x
                            _am_press_y = y
                        elif ch >= 0 and amc_row_kind(cast[uint64](ch)) == AMC_ROW_CATBTN:
                            # tap toggles the fly-out (also works without hover).
                            if amc_open_cat() == amc_row_cat(cast[uint64](ch)):
                                amc_set_open_cat(-1)
                            else:
                                amc_set_open_cat(amc_row_cat(cast[uint64](ch)))
                            redraw = 1
                        elif ch < 0:
                            result = -2   # click outside the box dismisses
                _am_prev_btn = btn
            elif t == 117:                # 'u' release
                if _am_press_active != 0 and (btn & 1) == 0:
                    # Release in place (no drag past threshold) = LAUNCH.
                    if _am_press_kind == 2:
                        result = 100000 + _am_press_ref
                    elif _am_press_kind == 1:
                        result = _am_press_ref
                    _am_press_active = 0
                    _am_press_kind = 0
                _am_prev_btn = btn
            else:                         # motion
                if _am_press_active != 0 and (btn & 1) != 0:
                    dx: int32 = x - _am_press_x
                    if dx < 0:
                        dx = -dx
                    dy: int32 = y - _am_press_y
                    if dy < 0:
                        dy = -dy
                    if dx >= _am_DRAG_PX or dy >= _am_DRAG_PX:
                        # DRAGGED off the entry -> emit a launcher drop for the
                        # panel to pick up, then dismiss (the drop persists).
                        if _am_press_kind == 2:
                            aidx: uint64 = cast[uint64](_am_press_ref)
                            _emit_drop(amc_app_prog(aidx), amc_app_prog_len(aidx),
                                       amc_app_name(aidx), _strlen(amc_app_name(aidx)))
                        elif _am_press_kind == 1:
                            urp: uint64 = cast[uint64](_am_press_ref)
                            _emit_drop(amc_row_prog(urp), amc_row_prog_len(urp),
                                       amc_row_label(urp), _strlen(amc_row_label(urp)))
                        _am_press_active = 0
                        _am_press_kind = 0
                        result = -2       # dismiss; the drop is already written
                _am_prev_btn = btn
        n = sys_read_nb(_am_ptr_fd, &_am_ptr_buf[0], 512)
    if redraw != 0:
        _paint_menu()
    return result


# ====================================================================
# Keyboard poll — live search typing
# ====================================================================
# The compositor routes physical keystrokes to the FOCUSED window's
# /dev/wsys/<wid>/keys stream as press lines "d <code>\n" (raw ASCII code;
# see sys/src/9/port/devwsys.ad wsys_route_key_byte). This menu auto-focuses
# on its first commit, so opening + reading that stream feeds typed chars into
# the EXISTING lib/appmenucore filter (amc_filter_push/backspace) and re-runs
# the layout — the identical filter the host gate proves visually.
_am_keys_fd:  int32 = -1
_am_keybuf:   Array[256, uint8]
# ESC-sequence swallow (arrow keys arrive as ESC '[' 'A' — three press lines):
# a lone ESC dismisses the menu, but an ESC that begins an arrow sequence must
# not. esc_pending resolves within the drain; a still-pending ESC at end-of-
# drain was standalone.
_am_esc_pending:   int32 = 0
_am_arrow_consume: int32 = 0


def _build_keys_path(wid: int32, out: Ptr[uint8]):
    pfx: Ptr[uint8] = "/dev/wsys/"
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        out[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = _put_dec(out, p, cast[uint64](wid))
    sfx: Ptr[uint8] = "/keys"
    k = 0
    while sfx[k] != 0:
        out[p] = sfx[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def _build_ctl_path(wid: int32, out: Ptr[uint8]):
    pfx: Ptr[uint8] = "/dev/wsys/"
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        out[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = _put_dec(out, p, cast[uint64](wid))
    sfx: Ptr[uint8] = "/ctl"
    k = 0
    while sfx[k] != 0:
        out[p] = sfx[k]
        p = p + 1
        k = k + 1
    out[p] = 0


def _build_scene_path(wid: int32, out: Ptr[uint8]):
    pfx: Ptr[uint8] = "/dev/wsys/"
    p: uint64 = 0
    k: uint64 = 0
    while pfx[k] != 0:
        out[p] = pfx[k]
        p = p + 1
        k = k + 1
    p = _put_dec(out, p, cast[uint64](wid))
    sfx: Ptr[uint8] = "/scene"
    k = 0
    while sfx[k] != 0:
        out[p] = sfx[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# SCENE-FILE DE present: the kernel scene compositor (owns /dev/fb at rl5) only
# z-blits windows whose SCENE is non-empty; the only scene verb that carries
# pixels is `buffer <x> <y> <w> <h>`, which copies our kernel-side v2 backbuffer
# (populated by hamui_v2_commit_rect's 'B' blit) into the window's scene cache.
# WITHOUT this a pure-v2 window is INVISIBLE under the scene compositor — the
# exact "Applications menu doesn't open" bug: the panel spawned us, we mapped a
# window and blitted our menu into the v2 backbuffer, but never told the scene
# compositor to composite it. Mirrors hambrowse's _present_buffer. Must run
# after every hamui_v2_commit_rect (see _paint_menu).
_am_scene_line: Array[80, uint8]
def _am_present_buffer(wid: int32, w: int32, h: int32):
    p: uint64 = 0
    pre: Ptr[uint8] = "buffer 0 0 "
    a: uint64 = 0
    while pre[a] != 0:
        _am_scene_line[p] = pre[a]
        p = p + 1
        a = a + 1
    p = _put_dec(&_am_scene_line[0], p, cast[uint64](w))
    _am_scene_line[p] = 32
    p = p + 1
    p = _put_dec(&_am_scene_line[0], p, cast[uint64](h))
    _am_scene_line[p] = 10
    p = p + 1
    scenep: Array[64, uint8]
    _build_scene_path(wid, &scenep[0])
    sfd: int32 = sys_open_write(cast[Ptr[char]](&scenep[0]))
    if sfd >= 0:
        sys_write(sfd, &_am_scene_line[0], p)
        sys_close(sfd)
    # Poke `commit`: presents the scene (compositing our backbuffer) AND resets
    # the scene write cursor so the next frame starts fresh.
    cp: Array[64, uint8]
    _build_ctl_path(wid, &cp[0])
    cfd: int32 = sys_open_write(cast[Ptr[char]](&cp[0]))
    if cfd >= 0:
        sys_write(cfd, cast[Ptr[uint8]]("commit\n"), 7)
        sys_close(cfd)


# Self-allocate an OWNED top-level window. Used when we were spawned DIRECTLY
# (e.g. by the scene panel's Applications button) rather than through the
# compositor's daemon_spawn_window_prog, which would pre-allocate our wid and
# hand it back via /dev/wsys/self. Mirrors lib/hamui's _h_alloc_wid_from_ctl:
# write `newwindow` to /dev/wsys/ctl, read the assigned wid back. Returns the
# wid (>=2) or -1 on failure.
def _am_newwindow_once() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    nw: Ptr[uint8] = "newwindow\n"
    sys_write(wfd, nw, _strlen(nw))
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[16, uint8]
    rn: int64 = sys_read(rfd, &rbuf[0], 15)
    sys_close(rfd)
    v: int32 = 0
    j: uint64 = 0
    while j < cast[uint64](rn) and rbuf[j] >= 48 and rbuf[j] <= 57:
        v = v * 10 + cast[int32](rbuf[j]) - 48
        j = j + 1
    if v >= 2:
        return v
    return -1


# Bounded-retry wrapper: a single write-then-read `newwindow` can transiently
# fail early in boot (the compositor's window table momentarily full while many
# DE clients start, or the readback racing the alloc). Rather than give up and
# leave the Applications button dead, retry a bounded number of times, yielding
# between attempts so the compositor drains. Returns the wid (>=2) or -1.
def _am_newwindow() -> int32:
    t: int32 = 0
    while t < 8:
        w: int32 = _am_newwindow_once()
        if w >= 2:
            return w
        t = t + 1
        sys_yield()
    return -1


# Position our freshly-allocated window at (x,y) with our content dims and
# lift it above the panel bar (z 14). No `decorate` verb -> borderless, so it
# reads as a drop-down menu, not a titled app window.
def _am_place_window(wid: int32, x: int32, y: int32):
    path: Array[64, uint8]
    _build_ctl_path(wid, &path[0])
    fd: int32 = sys_open_write(cast[Ptr[char]](&path[0]))
    if fd < 0:
        return
    b: Array[80, uint8]
    p: uint64 = 0
    g: Ptr[uint8] = "geometry "
    k: uint64 = 0
    while g[k] != 0:
        b[p] = g[k]
        p = p + 1
        k = k + 1
    p = _put_dec(&b[0], p, cast[uint64](x))
    b[p] = 32
    p = p + 1
    p = _put_dec(&b[0], p, cast[uint64](y))
    b[p] = 32
    p = p + 1
    p = _put_dec(&b[0], p, cast[uint64](_am_WIN_W))
    b[p] = 32
    p = p + 1
    p = _put_dec(&b[0], p, cast[uint64](_am_WIN_H))
    b[p] = 10
    p = p + 1
    sys_write(fd, &b[0], p)
    z: Ptr[uint8] = "z 14\n"
    sys_write(fd, z, _strlen(z))
    # Alpha-keyed present: the menu window is grown wide to hold a hover
    # fly-out, so the un-hovered fly-out band (and any margin) is painted
    # transparent (alpha 0). Keyed compositing shows the desktop through those
    # pixels instead of a solid black box — mirrors the scene panel's `keyed 1`.
    ky: Ptr[uint8] = "keyed 1\n"
    sys_write(fd, ky, _strlen(ky))
    sys_close(fd)


# First AMC_ROW_APP row in the current (possibly filtered) layout, or -1.
def _am_first_app_row() -> int64:
    i: uint64 = 0
    rc: uint64 = amc_row_count()
    while i < rc:
        if amc_row_kind(i) == AMC_ROW_APP:
            return cast[int64](i)
        i = i + 1
    return -1


# Apply one decoded key code. Returns:
#   0  nothing / swallowed
#   1  filter changed -> repaint
#   2  activate first filtered row (launch)
#  -2  dismiss the menu
def _am_key_apply(code: int32) -> int32:
    if _am_arrow_consume != 0:                        # 3rd byte of ESC [ X
        _am_arrow_consume = 0
        return 0
    if _am_esc_pending != 0:
        _am_esc_pending = 0
        if code == 91:                               # '[' -> arrow sequence
            _am_arrow_consume = 1
            return 0
        return -2                                    # standalone ESC = dismiss
    if code == 27:                                   # ESC -> pending
        _am_esc_pending = 1
        return 0
    if code == 13 or code == 10:                     # Enter -> launch first row
        return 2
    if code == 8 or code == 127:                     # Backspace / DEL
        amc_filter_backspace()
        amc_layout()
        _am_HOVER_ROW = -1
        return 1
    if code >= 32 and code < 127:                    # printable -> append
        amc_filter_push(cast[uint8](code))
        amc_layout()
        _am_HOVER_ROW = -1
        return 1
    return 0


# Drain the /keys stream. Returns the strongest action seen this pass:
#   0 nothing, 1 repaint, 2 launch-first, -2 dismiss.
def _drain_keys_am(wid: int32) -> int32:
    if _am_keys_fd < 0:
        kpath: Array[64, uint8]
        _build_keys_path(wid, &kpath[0])
        _am_keys_fd = sys_open(cast[Ptr[char]](&kpath[0]))
    if _am_keys_fd < 0:
        return 0
    act: int32 = 0
    n: int64 = sys_read_nb(_am_keys_fd, &_am_keybuf[0], 256)
    while n > 0:
        cap: uint64 = cast[uint64](n)
        i: uint64 = 0
        while i < cap:
            t: uint8 = _am_keybuf[i]                  # 'd' press
            i = i + 1
            if i < cap and _am_keybuf[i] == 32:
                i = i + 1
            code: int32 = 0
            have: int32 = 0
            while i < cap and _am_keybuf[i] >= 48 and _am_keybuf[i] <= 57:
                code = code * 10 + cast[int32](_am_keybuf[i]) - 48
                i = i + 1
                have = 1
            while i < cap and _am_keybuf[i] != 10:
                i = i + 1
            if i < cap:
                i = i + 1
            if t == 100 and have != 0:
                rc: int32 = _am_key_apply(code)
                if rc == -2:
                    return -2
                if rc == 2:
                    act = 2
                elif rc == 1 and act == 0:
                    act = 1
        n = sys_read_nb(_am_keys_fd, &_am_keybuf[0], 256)
    # A lone ESC left pending (nothing followed it) dismisses.
    if _am_esc_pending != 0:
        _am_esc_pending = 0
        return -2
    return act


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    hamui_init()
    wid: int32 = 1
    # argv[1] disambiguates HOW we get our window:
    #   * "-self"  -> the SCENE PANEL spawned us directly (its Applications
    #                 button). NO wid was pre-allocated for us, and we must
    #                 NOT consult /dev/wsys/self: its ancestor walk-up
    #                 (devwsys _wsys_wid_for_pid_or_ancestor) would return the
    #                 PANEL's OWN wid (the panel is our parent and owns a
    #                 window), so we'd bind the panel's window instead of
    #                 creating our own dropdown and NO menu would appear — the
    #                 intermittent "Applications menu doesn't open" bug. Force
    #                 self-allocation via _am_newwindow(), exactly like the
    #                 reliable haminbox/hamcalscene popups.
    #   * a NUMBER  -> a legacy explicit wid handed by the compositor path.
    force_self: int32 = 0
    if argc > 1:
        ap: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if ap[0] == 45:                                  # '-' => "-self"
            force_self = 1
        else:
            v2: int32 = 0
            i2: uint64 = 0
            while ap[i2] >= 48 and ap[i2] <= 57:
                v2 = v2 * 10 + cast[int32](ap[i2]) - 48
                i2 = i2 + 1
            if v2 >= 1:
                wid = v2
    # Compositor (Super-key / legacy menubar -> daemon_spawn_window_prog) path:
    # the wid was pre-allocated against an ANCESTOR (the rc-running hamsh), so
    # discover it via /dev/wsys/self's parent-chain walk-up. SKIPPED for the
    # panel-direct "-self" spawn (see above) and when a numeric wid was given.
    if force_self == 0 and wid < 2:
        self_path: Ptr[uint8] = "/dev/wsys/self"
        sfd: int32 = sys_open(cast[Ptr[char]](self_path))
        if sfd >= 0:
            sbuf: Array[16, uint8]
            sn: int64 = sys_read_nb(sfd, &sbuf[0], 16)
            sys_close(sfd)
            if sn > 0:
                v: int32 = 0
                i: uint64 = 0
                while i < cast[uint64](sn) and sbuf[i] >= 48 and sbuf[i] <= 57:
                    v = v * 10 + cast[int32](sbuf[i]) - 48
                    i = i + 1
                if v >= 2:
                    wid = v

    # Build the catalogue: DATA-DRIVEN from /etc/hamde/apps/*.desktop, grouped
    # by category with a search box + recent section by lib/appmenucore. Read
    # the compositor snapshot for wire-protocol compat.
    _build_catalogue()
    _read_appmenu_snapshot()
    amc_layout()

    # Size the window to the laid-out content (clamped). The BOX is box_w wide;
    # the WINDOW is grown wide = box + child fly-out (child opens to the right,
    # overlapping the box frame by 1px) so a hover fly-out is always contained.
    # The extra width is transparent until a category is hovered.
    ch: int32 = amc_content_h()
    if ch > _am_MAX_H:
        ch = _am_MAX_H
    if ch < AMC_ROW_H:
        ch = AMC_ROW_H
    _am_BOX_W = amc_box_w()
    _am_BOX_H = ch
    _am_WIN_W = _am_BOX_W - 1 + AMC_CHILD_W
    _am_WIN_H = ch

    # If neither /dev/wsys/self nor argv handed us a compositor-allocated wid
    # (wid still < 2), we were spawned DIRECTLY (the scene panel's Applications
    # button spawns us like any other scene client). Self-allocate an owned
    # window and anchor it just below the top panel bar, at the left edge under
    # the Apps button. The compositor-spawned path (Super key / legacy menubar
    # -> daemon_spawn_window_prog) still pre-allocates the wid, so this is a
    # no-op there and that behaviour is unchanged.
    if wid < 2:
        wid = _am_newwindow()
        if wid < 2:
            _puts(2, "hamappmenu: newwindow alloc failed\n")
            return 1
        _am_place_window(wid, 8, 28)

    bound: int32 = hamui_window_on(0, wid)
    if bound < 0:
        _puts(2, "hamappmenu: could not bind window\n")
        return 1

    if hamui_set_protocol_v2_dims(_am_WIN_W, _am_WIN_H) < 0:
        _puts(2, "hamappmenu: v2 negotiate failed\n")
        return 1

    _paint_menu()
    rdy: Ptr[uint8] = "HAMAPPMENU ready\n"
    sys_write(1, rdy, _strlen(rdy))

    # Event loop. Pointer events drive hover repaint + click -> launch;
    # keyboard events drive live search typing (append/backspace re-run the
    # filter + repaint, Enter launches the first filtered app, Esc dismisses).
    while True:
        rc: int32 = _drain_pointer(wid)
        if rc >= 100000:
            # A fly-out click: rc-100000 is the chosen APP INDEX.
            aidx: uint64 = cast[uint64](rc - 100000)
            amc_mark_launch(amc_app_prog(aidx))
            _emit_launch_path(amc_app_prog(aidx), amc_app_prog_len(aidx))
            sys_exit(0)
        elif rc >= 0:
            urc: uint64 = cast[uint64](rc)
            amc_mark_launch(amc_row_prog(urc))
            _emit_launch_path(amc_row_prog(urc), amc_row_prog_len(urc))
            sys_exit(0)
        elif rc == -2:
            sys_exit(0)
        krc: int32 = _drain_keys_am(wid)
        if krc == -2:
            sys_exit(0)
        elif krc == 2:
            arow: int64 = _am_first_app_row()
            if arow >= 0:
                ur2: uint64 = cast[uint64](arow)
                amc_mark_launch(amc_row_prog(ur2))
                _emit_launch_path(amc_row_prog(ur2), amc_row_prog_len(ur2))
                sys_exit(0)
        elif krc == 1:
            _paint_menu()
        sys_yield()

    return 0

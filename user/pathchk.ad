# user/pathchk.ad
#
# Hamnix `pathchk`: check whether each PATH operand is a valid, usable
# file name, matching coreutils `pathchk` for the common flags:
#
#   (default) : reject an empty name; reject a name longer than PATH_MAX
#               (4096) or a component longer than NAME_MAX (255).
#   -p        : use the POSIX minimum limits (PATH_MAX 256, NAME_MAX 14)
#               and reject any character outside the POSIX portable file-
#               name set [-A-Za-z0-9._/].
#   -P        : additionally reject an empty name and any component that
#               begins with '-' (which would be mistaken for an option).
#
# Exit status is 1 if ANY operand fails a check (with a diagnostic on
# stderr), 0 otherwise — the exact contract scripts branch on before
# creating a file portably.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def diag(path: Ptr[uint8], msg: Ptr[uint8]):
    write_str(2, "pathchk: ")
    write_str(2, msg)
    write_str(2, " '")
    write_str(2, path)
    write_str(2, "'\n")


# Is c in the POSIX portable filename character set (per component;
# '/' is the separator and handled outside this check)?
def is_portable(c: uint8) -> int32:
    if c >= 65 and c <= 90:                      # A-Z
        return 1
    if c >= 97 and c <= 122:                     # a-z
        return 1
    if c >= 48 and c <= 57:                      # 0-9
        return 1
    if c == 46 or c == 95 or c == 45:            # . _ -
        return 1
    return 0


# Check one operand. Returns 0 if OK, 1 if it fails a check.
def check_one(path: Ptr[uint8], posix: int32, extra: int32) -> int32:
    n: uint64 = strlen_u8(path)

    if n == 0:
        # -P and -p both reject empty; the default also rejects it.
        diag(path, "empty file name")
        return 1

    path_max: uint64 = 4096
    name_max: uint64 = 255
    if posix != 0:
        path_max = 256
        name_max = 14

    if n > path_max:
        diag(path, "limit exceeded: file name too long")
        return 1

    # Walk components between '/' separators.
    comp_start: uint64 = 0
    i: uint64 = 0
    while i <= n:
        at_end: int32 = 0
        if i == n:
            at_end = 1
        if at_end != 0 or path[i] == 47:         # '/'
            comp_len: uint64 = i - comp_start
            if comp_len > name_max:
                diag(path, "limit exceeded: component too long")
                return 1
            if extra != 0 and comp_len > 0 and path[comp_start] == 45:
                diag(path, "leading '-' in a component")
                return 1
            comp_start = i + 1
        else:
            if posix != 0 and is_portable(path[i]) == 0:
                diag(path, "nonportable character in file name")
                return 1
        i = i + 1

    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    posix: int32 = 0
    extra: int32 = 0
    ai: int32 = 1

    # Parse leading flags (-p, -P, --). Everything after is an operand.
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if a[0] != 45 or a[1] == 0:              # not "-..." -> operand
            break
        if a[1] == 45 and a[2] == 0:             # "--"
            ai = ai + 1
            break
        j: uint64 = 1
        while a[j] != 0:
            if a[j] == 112:                       # 'p'
                posix = 1
            elif a[j] == 80:                      # 'P'
                extra = 1
            j = j + 1
        ai = ai + 1

    if ai >= argc:
        write_str(2, "pathchk: missing operand\n")
        return 1

    fail: int32 = 0
    while ai < argc:
        p: Ptr[uint8] = cast[Ptr[uint8]](argv[cast[uint64](ai)])
        if check_one(p, posix, extra) != 0:
            fail = 1
        ai = ai + 1
    return fail

# user/losetup.ad
#
# losetup — attach/detach a file as a loop block device.
#
# Usage:
#   losetup /dev/loop0 disk.img   attach disk.img to the first free slot
#   losetup -d /dev/loop0         detach loop slot 0
#   losetup -a                    list attached loop devices
#
# Plan-9 native: there is NO LOOP_SET_FD ioctl. losetup just opens the
# global control file /dev/loop/ctl and writes a verb line:
#   attach <path>\n   /   detach <N>\n
# The kernel (drivers/block/loop.ad) does the work and registers the
# loop device under /dev/blk/loopN. `-a` reads the ctl file, which
# renders one "loopN <bytes>" line per attached device.
#
# The /dev/loopN argument in the attach/detach forms is accepted for
# Linux-losetup compatibility; the trailing digit selects the slot for
# detach. On attach the kernel always picks the first free slot, so the
# device argument names the EXPECTED slot.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


# Command-line scratch. A verb line is "attach <path>\n" or
# "detach <N>\n"; paths are bounded by the cpio/ext4 path limit, so 512
# bytes is plenty.
ctl_line: Array[512, uint8]
ls_buf:   Array[512, uint8]


def _append(dst: Ptr[uint8], at: uint64, src: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while src[i] != 0:
        dst[at] = src[i]
        at = at + 1
        i = i + 1
    return at


def _last_digit(s: Ptr[uint8]) -> uint8:
    # Return the last byte of `s` if it is a decimal digit, else '0'.
    n: uint64 = strlen_u8(s)
    if n == 0:
        return 48
    c: uint8 = s[n - 1]
    if c >= 48 and c <= 57:
        return c
    return 48


def do_list() -> int32:
    fd: int32 = sys_open("/dev/loop/ctl")
    if fd < 0:
        write_str(2, "losetup: cannot open /dev/loop/ctl\n")
        return 1
    n: int64 = sys_read(fd, &ls_buf[0], 512)
    sys_close(fd)
    if n > 0:
        sys_write(1, &ls_buf[0], cast[uint64](n))
    return 0


def do_ctl(line: Ptr[uint8], line_len: uint64) -> int32:
    fd: int32 = sys_open_write("/dev/loop/ctl")
    if fd < 0:
        write_str(2, "losetup: cannot open /dev/loop/ctl\n")
        return 1
    w: int64 = sys_write(fd, line, line_len)
    sys_close(fd)
    if w < 0:
        write_str(2, "losetup: operation failed\n")
        return 1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        write_str(2, "losetup: usage: losetup /dev/loopN img | -d /dev/loopN | -a\n")
        return 1

    a1: Ptr[uint8] = cast[Ptr[uint8]](argv[1])

    # losetup -a lists the attached devices.
    if a1[0] == 45 and a1[1] == 97 and a1[2] == 0:
        return do_list()

    # losetup -d /dev/loopN detaches the slot named by the trailing digit.
    if a1[0] == 45 and a1[1] == 100 and a1[2] == 0:
        if argc < 3:
            write_str(2, "losetup: -d needs a /dev/loopN argument\n")
            return 1
        dev: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
        at: uint64 = 0
        at = _append(&ctl_line[0], at, "detach ")
        ctl_line[at] = _last_digit(dev)
        at = at + 1
        ctl_line[at] = 10
        at = at + 1
        return do_ctl(&ctl_line[0], at)

    # losetup /dev/loopN img attaches img to the first free slot.
    if argc < 3:
        write_str(2, "losetup: attach needs an image file argument\n")
        return 1
    img: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
    aat: uint64 = 0
    aat = _append(&ctl_line[0], aat, "attach ")
    aat = _append(&ctl_line[0], aat, img)
    ctl_line[aat] = 10
    aat = aat + 1
    rc: int32 = do_ctl(&ctl_line[0], aat)
    # On success report which loop device the image landed on by echoing
    # the device argument; the kernel picks the first free slot.
    if rc == 0:
        write_str(1, cast[Ptr[uint8]](argv[1]))
        write_str(1, ": ")
        write_str(1, img)
        write_str(1, "\n")
    return rc

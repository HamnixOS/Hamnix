# user/unlink.ad
#
# Hamnix `unlink FILE`: call the unlink primitive on exactly one operand,
# matching coreutils `unlink`. Unlike `rm`, it takes ONE argument, does
# no globbing / recursion / prompting, and is the thin, scriptable front
# end to the raw unlink(2)-equivalent. Too many or too few operands is a
# usage error (exit 1); an unlink failure prints a diagnostic and exits 1.

extern def sys_unlink(path: Ptr[char]) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc != 2:
        write_str(2, "unlink: usage: unlink FILE\n")
        return 1
    path: Ptr[char] = cast[Ptr[char]](argv[1])
    rc: int32 = sys_unlink(path)
    if rc != 0:
        write_str(2, "unlink: cannot unlink ")
        write_str(2, cast[Ptr[uint8]](path))
        write_str(2, "\n")
        return 1
    return 0

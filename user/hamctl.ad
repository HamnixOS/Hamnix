# user/hamctl.ad — NATIVE driver for the Control Center hub (/bin/hamctl).
#
# REWRITE (was a lib/hamui-toolkit, mostly read-only first cut): this is the
# scene-DE, DUAL-TARGET Control Center. The category model, page layout, scene
# builder and pure pointer handler live in lib/hamctlcore.ad (extern-free,
# host-renderable — see user/hamctl_host.ad + docs/hamui_dual_target.md) so the
# whole hub renders on the dev host to a PNG. This file keeps ONLY the Hamnix
# transport + the real I/O the three capplets need:
#
#   Appearance  — on a swatch click, write a solid-colour PPM and set it as
#                 the wallpaper via /dev/wsys/ctl.
#   Date & Time — format the current time from the #137-correct clock
#                 (/dev/stat btime + /dev/time uptime) with the chosen UTC
#                 offset; persist the offset to /tmp/hamnix-tz.conf.
#   About       — read hostname (/dev/hostname), kernel (/dev/version),
#                 uptime (/proc/uptime), memory (/proc/meminfo), CPU count
#                 (/dev/stat cpuN lines) and process count (/proc/tasks).

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
# Network-config syscall (same bridge ifconfig uses). op 0 = GET (a1 = 24-byte
# buffer), op 3 = SET_DNS (a1 = dnsip DNS server). See do_netcfg.
extern def sys_netcfg(op: uint64, a1: uint64, a2: uint64) -> int64

from lib.hamui import hamscene_commit
from lib.p9 import spawn_detached
from lib.hamctlcore import hamctl_init, hamctl_build_scene, hamctl_click, \
    hamctl_set_datetime, hamctl_swatch, hamctl_sw_r, hamctl_sw_g, hamctl_sw_b, \
    hamctl_tz, hamctl_about_clear, hamctl_about_add, parse_pointer, \
    hamctl_resize_line, \
    hamctl_set_display, hamctl_disp_scale, hamctl_ms_speed, hamctl_ms_primary, \
    hamctl_ms_natural, hamctl_kb_delay, hamctl_kb_rate, hamctl_set_kb_layout, \
    _ctl_slen, _ctl_u64_to_dec, ACT_CAT, ACT_WALL, ACT_TZ, ACT_DISPLAY, \
    ACT_MOUSE, ACT_KBD, ACT_WALLIMG, hamctl_image_rgb, hamctl_image_sel, \
    hamctl_set_sound, hamctl_snd_vol, hamctl_snd_mute, hamctl_snd_set, \
    hamctl_set_power, \
    hamctl_set_net, hamctl_net_dns_pref, ACT_SOUND, ACT_LOCK, ACT_LOGOUT, \
    ACT_SHUTDOWN, ACT_REBOOT, ACT_NET
from lib.panelclock import panelclock_format


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _ctl_slen(s))


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _ctl_u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# ---- generic file slurp --------------------------------------------------
slurp_buf: Array[4096, uint8]


def _slurp(path: Ptr[char]) -> uint64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    total: uint64 = 0
    while total < 4095:
        r: int64 = sys_read(fd, &slurp_buf[total], 4095 - total)
        if r <= 0:
            break
        total = total + cast[uint64](r)
    sys_close(fd)
    slurp_buf[total] = 0
    return total


# ---- wallpaper -----------------------------------------------------------
ppm_buf: Array[9300, uint8]


def _write_wallpaper_ppm(r: int32, g: int32, b: int32) -> int32:
    p: uint64 = 0
    hdr: Ptr[uint8] = cast[Ptr[uint8]]("P6\n64 48\n255\n")
    k: uint64 = 0
    while hdr[k] != 0:
        ppm_buf[p] = hdr[k]
        p = p + 1
        k = k + 1
    px: uint64 = 0
    while px < 64 * 48:
        ppm_buf[p] = cast[uint8](r)
        ppm_buf[p+1] = cast[uint8](g)
        ppm_buf[p+2] = cast[uint8](b)
        p = p + 3
        px = px + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-wallpaper.ppm"))
    if fd < 0:
        return 0
    sys_write(fd, &ppm_buf[0], p)
    sys_close(fd)
    return 1


# Render the procedurally-generated image `img` to the shared PPM buffer at
# the 64x48 reference resolution (matches _write_wallpaper_ppm) and write it
# to /tmp/hamnix-wallpaper.ppm. Same law as the capplet thumbnail + host gate.
def _write_wallpaper_image_ppm(img: int32) -> int32:
    p: uint64 = 0
    hdr: Ptr[uint8] = cast[Ptr[uint8]]("P6\n64 48\n255\n")
    k: uint64 = 0
    while hdr[k] != 0:
        ppm_buf[p] = hdr[k]
        p = p + 1
        k = k + 1
    rgb: Array[3, uint8]
    py: int32 = 0
    while py < 48:
        px: int32 = 0
        while px < 64:
            hamctl_image_rgb(img, px, py, 64, 48, &rgb[0])
            ppm_buf[p] = rgb[0]
            ppm_buf[p+1] = rgb[1]
            ppm_buf[p+2] = rgb[2]
            p = p + 3
            px = px + 1
        py = py + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-wallpaper.ppm"))
    if fd < 0:
        return 0
    sys_write(fd, &ppm_buf[0], p)
    sys_close(fd)
    return 1


# Persist the chosen wallpaper so a login/boot hook can re-apply it after
# /tmp is cleared. kind 0 = colour swatch <n>, kind 1 = image <n>. The DE can
# `cat /tmp/hamnix-wallpaper.conf` at rl5 and re-run the PPM write + ctl verb.
def _persist_wallpaper(kind: int32, n: int32):
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-wallpaper.conf"))
    if fd < 0:
        return
    line: Array[24, uint8]
    p: uint64 = 0
    if kind == 1:
        line[0] = 105                                   # 'i'
        line[1] = 109                                   # 'm'
        line[2] = 103                                   # 'g'
    else:
        line[0] = 99                                    # 'c'
        line[1] = 111                                  # 'o'
        line[2] = 108                                   # 'l'
    line[3] = 32                                         # ' '
    p = 4
    p = p + _ctl_u64_to_dec(cast[uint64](n), &line[p])
    line[p] = 10
    p = p + 1
    sys_write(fd, &line[0], p)
    sys_close(fd)


def _wsys_wallpaper_apply():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if fd < 0:
        return
    _writeall(fd, cast[Ptr[uint8]]("wallpaper /tmp/hamnix-wallpaper.ppm\n"))
    sys_close(fd)
    _writeall(1, cast[Ptr[uint8]]("[hamctl] wallpaper applied\n"))


def _apply_wallpaper():
    i: uint64 = cast[uint64](hamctl_swatch())
    if _write_wallpaper_ppm(hamctl_sw_r(i), hamctl_sw_g(i), hamctl_sw_b(i)) == 0:
        return
    _persist_wallpaper(0, cast[int32](i))
    _wsys_wallpaper_apply()


def _apply_wallpaper_image():
    img: int32 = hamctl_image_sel()
    if _write_wallpaper_image_ppm(img) == 0:
        return
    _persist_wallpaper(1, img)
    _wsys_wallpaper_apply()


# ---- date & time ---------------------------------------------------------
def _read_btime() -> uint64:
    n: uint64 = _slurp(cast[Ptr[char]]("/dev/stat"))
    i: uint64 = 0
    while i + 6 < n:
        if (i == 0 or slurp_buf[i - 1] == 10) and slurp_buf[i] == 98 \
                and slurp_buf[i+1] == 116 and slurp_buf[i+2] == 105 \
                and slurp_buf[i+3] == 109 and slurp_buf[i+4] == 101 \
                and slurp_buf[i+5] == 32:
            j: uint64 = i + 6
            v: uint64 = 0
            while j < n and slurp_buf[j] >= 48 and slurp_buf[j] <= 57:
                v = v * 10 + cast[uint64](slurp_buf[j]) - 48
                j = j + 1
            return v
        i = i + 1
    return 0


def _read_uptime_ns() -> uint64:
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/time"))
    if fd < 0:
        return 0
    buf: Array[32, uint8]
    r: int64 = sys_read(fd, &buf[0], 31)
    sys_close(fd)
    if r <= 0:
        return 0
    v: uint64 = 0
    i: uint64 = 0
    while i < cast[uint64](r) and buf[i] >= 48 and buf[i] <= 57:
        v = v * 10 + cast[uint64](buf[i]) - 48
        i = i + 1
    return v


def _now_epoch() -> uint64:
    return _read_btime() + _read_uptime_ns() / 1000000000


def _refresh_datetime():
    ep: uint64 = _now_epoch()
    adj: uint64 = ep + cast[uint64](hamctl_tz() * 3600)
    buf: Array[32, uint8]
    panelclock_format(adj, &buf[0])
    hamctl_set_datetime(&buf[0])


def _persist_tz():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/tmp/hamnix-tz.conf"))
    if fd < 0:
        return
    line: Array[32, uint8]
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("offset ")
    k: uint64 = 0
    while pre[k] != 0:
        line[p] = pre[k]
        p = p + 1
        k = k + 1
    v: int32 = hamctl_tz()
    if v < 0:
        line[p] = 45
        p = p + 1
        v = 0 - v
    p = p + _ctl_u64_to_dec(cast[uint64](v), &line[p])
    line[p] = 10
    p = p + 1
    sys_write(fd, &line[0], p)
    sys_close(fd)


# ---- about ---------------------------------------------------------------
# Find token `key` at line-start in slurp_buf and copy the next whitespace-
# delimited field into out; returns 1 on success.
def _field_after(key: Ptr[uint8], n: uint64, out: Ptr[uint8], cap: uint64) -> int32:
    kl: uint64 = _ctl_slen(key)
    i: uint64 = 0
    while i + kl < n:
        atls: int32 = 0
        if i == 0 or slurp_buf[i - 1] == 10:
            atls = 1
        fmatch: int32 = 0
        if atls == 1:
            fmatch = 1
            m: uint64 = 0
            while m < kl:
                if slurp_buf[i + m] != key[m]:
                    fmatch = 0
                    m = kl
                else:
                    m = m + 1
        if fmatch == 1:
            j: uint64 = i + kl
            while j < n and (slurp_buf[j] == 32 or slurp_buf[j] == 9 \
                    or slurp_buf[j] == 58):
                j = j + 1
            o: uint64 = 0
            while j < n and slurp_buf[j] != 10 and slurp_buf[j] != 32 \
                    and o < cap - 1:
                out[o] = slurp_buf[j]
                o = o + 1
                j = j + 1
            out[o] = 0
            return 1
        i = i + 1
    return 0


def _count_cpus() -> uint64:
    n: uint64 = _slurp(cast[Ptr[char]]("/dev/stat"))
    cnt: uint64 = 0
    i: uint64 = 0
    while i + 4 < n:
        # a "cpuN " line (digit right after "cpu") is one online CPU.
        if (i == 0 or slurp_buf[i - 1] == 10) and slurp_buf[i] == 99 \
                and slurp_buf[i+1] == 112 and slurp_buf[i+2] == 117 \
                and slurp_buf[i+3] >= 48 and slurp_buf[i+3] <= 57:
            cnt = cnt + 1
        i = i + 1
    return cnt


def _count_procs() -> uint64:
    n: uint64 = _slurp(cast[Ptr[char]]("/proc/tasks"))
    cnt: uint64 = 0
    i: uint64 = 0
    # one process per newline-terminated row.
    while i < n:
        if slurp_buf[i] == 10:
            cnt = cnt + 1
        i = i + 1
    return cnt


tmpv: Array[72, uint8]


def _refresh_about():
    hamctl_about_clear()
    # Hostname
    if _slurp(cast[Ptr[char]]("/dev/hostname")) > 0:
        i: uint64 = 0
        while slurp_buf[i] != 0 and slurp_buf[i] != 10 and i < 71:
            tmpv[i] = slurp_buf[i]
            i = i + 1
        tmpv[i] = 0
        hamctl_about_add(cast[Ptr[uint8]]("Host"), &tmpv[0])
    else:
        hamctl_about_add(cast[Ptr[uint8]]("Host"), cast[Ptr[uint8]]("hamnix"))
    # Hamnix product version (matches /etc/os-release VERSION)
    hamctl_about_add(cast[Ptr[uint8]]("Hamnix"), cast[Ptr[uint8]]("0.1 (native)"))
    # Kernel version banner
    if _slurp(cast[Ptr[char]]("/dev/version")) > 0:
        i2: uint64 = 0
        while slurp_buf[i2] != 0 and slurp_buf[i2] != 10 and i2 < 71:
            tmpv[i2] = slurp_buf[i2]
            i2 = i2 + 1
        tmpv[i2] = 0
        hamctl_about_add(cast[Ptr[uint8]]("Kernel"), &tmpv[0])
    # Uptime H:MM:SS from /proc/uptime whole seconds
    upn: uint64 = _slurp(cast[Ptr[char]]("/proc/uptime"))
    if upn > 0:
        secs: uint64 = 0
        i3: uint64 = 0
        while i3 < upn and slurp_buf[i3] >= 48 and slurp_buf[i3] <= 57:
            secs = secs * 10 + cast[uint64](slurp_buf[i3]) - 48
            i3 = i3 + 1
        hh: uint64 = secs / 3600
        mm: uint64 = (secs % 3600) / 60
        ss: uint64 = secs % 60
        p: uint64 = 0
        p = p + _ctl_u64_to_dec(hh, &tmpv[p])
        tmpv[p] = 58
        p = p + 1
        tmpv[p] = cast[uint8](mm / 10) + 48
        tmpv[p+1] = cast[uint8](mm % 10) + 48
        tmpv[p+2] = 58
        p = p + 3
        tmpv[p] = cast[uint8](ss / 10) + 48
        tmpv[p+1] = cast[uint8](ss % 10) + 48
        p = p + 2
        tmpv[p] = 0
        hamctl_about_add(cast[Ptr[uint8]]("Uptime"), &tmpv[0])
    # Memory total (MemTotal, KB) -> MB
    mn: uint64 = _slurp(cast[Ptr[char]]("/proc/meminfo"))
    memv: Array[32, uint8]
    if mn > 0 and _field_after(cast[Ptr[uint8]]("MemTotal"), mn, &memv[0], 32) == 1:
        kb: uint64 = 0
        q: uint64 = 0
        while memv[q] >= 48 and memv[q] <= 57:
            kb = kb * 10 + cast[uint64](memv[q]) - 48
            q = q + 1
        mb: uint64 = kb / 1024
        p2: uint64 = _ctl_u64_to_dec(mb, &tmpv[0])
        tmpv[p2] = 32
        tmpv[p2+1] = 77                                 # 'M'
        tmpv[p2+2] = 66                                 # 'B'
        tmpv[p2+3] = 0
        hamctl_about_add(cast[Ptr[uint8]]("Memory"), &tmpv[0])
    # CPU count
    nc: uint64 = _count_cpus()
    if nc > 0:
        pc: uint64 = _ctl_u64_to_dec(nc, &tmpv[0])
        tmpv[pc] = 0
        hamctl_about_add(cast[Ptr[uint8]]("CPUs"), &tmpv[0])
    # Process count
    np: uint64 = _count_procs()
    if np > 0:
        pp: uint64 = _ctl_u64_to_dec(np, &tmpv[0])
        tmpv[pp] = 0
        hamctl_about_add(cast[Ptr[uint8]]("Processes"), &tmpv[0])


# ---- display read-out ----------------------------------------------------
# /dev/fb emits one whitespace line "W H PITCH BPP PIXFMT" (see devfb_read /
# user/hamshot.ad). Parse the first four fields into the core read-out.
def _read_display():
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/fb"))
    if fd < 0:
        return
    buf: Array[64, uint8]
    r: int64 = sys_read(fd, &buf[0], 63)
    sys_close(fd)
    if r <= 0:
        return
    n: uint64 = cast[uint64](r)
    vals: Array[4, int32]
    vi: uint64 = 0
    i: uint64 = 0
    while vi < 4:
        while i < n and (buf[i] == 32 or buf[i] == 9 or buf[i] == 10):
            i = i + 1
        acc: int32 = 0
        got: int32 = 0
        while i < n and buf[i] >= 48 and buf[i] <= 57:
            acc = acc * 10 + cast[int32](buf[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            vi = 4
        else:
            vals[vi] = acc
            vi = vi + 1
    hamctl_set_display(vals[0], vals[1], vals[2], vals[3])


# ---- keyboard layout read-out --------------------------------------------
# /dev/kbmap (if the console driver exposes it) names the active layout; else
# fall back to "us". Only the FIRST whitespace token is used.
def _read_kb_layout():
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/kbmap"))
    if fd < 0:
        hamctl_set_kb_layout(cast[Ptr[uint8]]("us"))
        return
    buf: Array[32, uint8]
    r: int64 = sys_read(fd, &buf[0], 31)
    sys_close(fd)
    if r <= 0:
        hamctl_set_kb_layout(cast[Ptr[uint8]]("us"))
        return
    o: uint64 = 0
    while o < cast[uint64](r) and buf[o] != 32 and buf[o] != 10 \
            and buf[o] != 9 and o < 15:
        o = o + 1
    buf[o] = 0
    if o == 0:
        hamctl_set_kb_layout(cast[Ptr[uint8]]("us"))
    else:
        hamctl_set_kb_layout(&buf[0])


# ---- config persistence (Plan 9-shape config files the DE can read) -------
cfg_buf: Array[256, uint8]


def _cfg_kv_int(pos: uint64, key: Ptr[uint8], val: int32) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while key[k] != 0:
        cfg_buf[p] = key[k]
        p = p + 1
        k = k + 1
    cfg_buf[p] = 32
    p = p + 1
    v: int32 = val
    if v < 0:
        cfg_buf[p] = 45
        p = p + 1
        v = 0 - v
    p = p + _ctl_u64_to_dec(cast[uint64](v), &cfg_buf[p])
    cfg_buf[p] = 10
    p = p + 1
    return p


def _cfg_kv_str(pos: uint64, key: Ptr[uint8], val: Ptr[uint8]) -> uint64:
    p: uint64 = pos
    k: uint64 = 0
    while key[k] != 0:
        cfg_buf[p] = key[k]
        p = p + 1
        k = k + 1
    cfg_buf[p] = 32
    p = p + 1
    j: uint64 = 0
    while val[j] != 0:
        cfg_buf[p] = val[j]
        p = p + 1
        j = j + 1
    cfg_buf[p] = 10
    p = p + 1
    return p


def _cfg_write(path: Ptr[char], len: uint64):
    fd: int32 = sys_open_write(path)
    if fd < 0:
        return
    sys_write(fd, &cfg_buf[0], len)
    sys_close(fd)


def _persist_display():
    p: uint64 = 0
    p = _cfg_kv_int(p, cast[Ptr[uint8]]("scale"), hamctl_disp_scale())
    _cfg_write(cast[Ptr[char]]("/tmp/hamnix-display.conf"), p)
    _writeall(1, cast[Ptr[uint8]]("[hamctl] display.conf written\n"))


mcfg_line: Array[32, uint8]


def _push_mouse_kernel():
    # LIVE SINK: push the pointer prefs into the kernel /dev/mouse router as
    # a `cfg <speed> <primary> <natural>` control line, so a capplet change
    # takes effect immediately (speed scale, L/R swap, Natural-scroll invert)
    # without a reboot. See sys/src/9/port/devmouse.ad::devmouse_write and
    # lib/hammouse_cfg.ad. Best-effort: if /dev/mouse can't be opened for
    # write the persisted /tmp file is still the record.
    p: uint64 = 0
    mcfg_line[p] = 99                                # 'c'
    p = p + 1
    mcfg_line[p] = 102                               # 'f'
    p = p + 1
    mcfg_line[p] = 103                               # 'g'
    p = p + 1
    mcfg_line[p] = 32                                # ' '
    p = p + 1
    p = p + _ctl_u64_to_dec(cast[uint64](hamctl_ms_speed()), &mcfg_line[p])
    mcfg_line[p] = 32
    p = p + 1
    p = p + _ctl_u64_to_dec(cast[uint64](hamctl_ms_primary()), &mcfg_line[p])
    mcfg_line[p] = 32
    p = p + 1
    p = p + _ctl_u64_to_dec(cast[uint64](hamctl_ms_natural()), &mcfg_line[p])
    mcfg_line[p] = 10                                # '\n'
    p = p + 1
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/mouse"))
    if fd < 0:
        return
    sys_write(fd, &mcfg_line[0], p)
    sys_close(fd)


def _persist_mouse():
    p: uint64 = 0
    p = _cfg_kv_int(p, cast[Ptr[uint8]]("speed"), hamctl_ms_speed())
    pri: Ptr[uint8] = cast[Ptr[uint8]]("left")
    if hamctl_ms_primary() != 0:
        pri = cast[Ptr[uint8]]("right")
    p = _cfg_kv_str(p, cast[Ptr[uint8]]("primary"), pri)
    scr: Ptr[uint8] = cast[Ptr[uint8]]("standard")
    if hamctl_ms_natural() != 0:
        scr = cast[Ptr[uint8]]("natural")
    p = _cfg_kv_str(p, cast[Ptr[uint8]]("scroll"), scr)
    _cfg_write(cast[Ptr[char]]("/tmp/hamnix-mouse.conf"), p)
    # Also apply live to the kernel /dev/mouse router (the sink).
    _push_mouse_kernel()
    _writeall(1, cast[Ptr[uint8]]("[hamctl] mouse.conf written + pushed to /dev/mouse\n"))


def _persist_kbd():
    p: uint64 = 0
    p = _cfg_kv_int(p, cast[Ptr[uint8]]("delay"), hamctl_kb_delay())
    p = _cfg_kv_int(p, cast[Ptr[uint8]]("rate"), hamctl_kb_rate())
    _cfg_write(cast[Ptr[char]]("/tmp/hamnix-kbd.conf"), p)
    _writeall(1, cast[Ptr[uint8]]("[hamctl] kbd.conf written\n"))


# ---- sound read-out + LIVE mixer sink (#279) ------------------------------
# Hamnix HAS a native audio device: the Intel HDA driver + software mixer,
# exposed as the Plan-9 /dev/audio (data + status) and /dev/audioctl (ctl)
# cdevs. This capplet is a LIVE control, not a record-only pref:
#   * _probe_sound opens /dev/audio, and if present reads back the current
#     master volume + mute from the status line to seed the slider/toggle.
#   * _persist_sound writes the pref file AND pushes `master <pct>` +
#     `mute`/`unmute` to /dev/audioctl (_push_sound_kernel), so moving the
#     slider changes the real HDA output level — no ioctl, no syscall, just
#     Plan-9 ctl-file writes.

# Parse the unsigned decimal that follows the first occurrence of NUL-term
# token `key` (whitespace-delimited) inside slurp_buf[0..n). Returns -1 if
# the key is not present.
def _snd_stat_val(n: uint64, key: Ptr[uint8]) -> int32:
    klen: uint64 = _ctl_slen(key)
    if klen == 0 or n == 0:
        return -1
    i: uint64 = 0
    while i + klen <= n:
        # match key at i AND ensure it is a whole token (preceded by start
        # or a space, followed by a space).
        j: uint64 = 0
        ok: int32 = 1
        while j < klen:
            if slurp_buf[i + j] != key[j]:
                ok = 0
                break
            j = j + 1
        if ok != 0 and (i == 0 or slurp_buf[i - 1] == 32) \
           and (i + klen < n) and slurp_buf[i + klen] == 32:
            # skip spaces to the number
            k: uint64 = i + klen
            while k < n and slurp_buf[k] == 32:
                k = k + 1
            if k < n and slurp_buf[k] >= 48 and slurp_buf[k] <= 57:
                v: int32 = 0
                while k < n and slurp_buf[k] >= 48 and slurp_buf[k] <= 57:
                    v = v * 10 + cast[int32](slurp_buf[k]) - 48
                    k = k + 1
                return v
        i = i + 1
    return -1


def _probe_sound():
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/audio"))
    if fd >= 0:
        sys_close(fd)
        hamctl_set_sound(1, cast[Ptr[uint8]]("/dev/audio"))
        # Seed the slider/toggle from the live mixer state (status line:
        # "loaded .. cap .. master <pct> streams .. mute <0|1>").
        n: uint64 = _slurp(cast[Ptr[char]]("/dev/audio"))
        mv: int32 = _snd_stat_val(n, cast[Ptr[uint8]]("master"))
        mu: int32 = _snd_stat_val(n, cast[Ptr[uint8]]("mute"))
        if mv >= 0:
            if mu < 0:
                mu = 0
            hamctl_snd_set(mv, mu)
        return
    hamctl_set_sound(0, cast[Ptr[uint8]]("No audio device"))


# LIVE SINK: push the sound prefs into the kernel mixer via /dev/audioctl.
# `master <vol>` sets the master output gain (0..100 %); `mute` / `unmute`
# latch the master mute without destroying the stored level. Best-effort:
# if /dev/audioctl can't be opened the persisted /tmp file is still the
# record. Plan-9 ctl-file writes only — NO ioctl, NO new syscall.
def _push_sound_kernel():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/dev/audioctl"))
    if fd < 0:
        return
    line: Array[32, uint8]
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("master ")
    j: uint64 = 0
    while pre[j] != 0:
        line[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _ctl_u64_to_dec(cast[uint64](hamctl_snd_vol()), &line[p])
    line[p] = 10                                    # '\n'
    p = p + 1
    _writeall(fd, &line[0])
    if hamctl_snd_mute() != 0:
        _writeall(fd, cast[Ptr[uint8]]("mute\n"))
    else:
        _writeall(fd, cast[Ptr[uint8]]("unmute\n"))
    sys_close(fd)


def _persist_sound():
    p: uint64 = 0
    p = _cfg_kv_int(p, cast[Ptr[uint8]]("volume"), hamctl_snd_vol())
    p = _cfg_kv_int(p, cast[Ptr[uint8]]("mute"), hamctl_snd_mute())
    _cfg_write(cast[Ptr[char]]("/tmp/hamnix-sound.conf"), p)
    # LIVE: drive the real HDA master level/mute through /dev/audioctl.
    _push_sound_kernel()
    _writeall(1, cast[Ptr[uint8]]("[hamctl] sound.conf written + pushed to /dev/audioctl\n"))


# ---- power / session read-out + REAL actions -----------------------------
pw_up: Array[24, uint8]


def _fmt_uptime(out: Ptr[uint8]) -> uint64:
    upn: uint64 = _slurp(cast[Ptr[char]]("/proc/uptime"))
    secs: uint64 = 0
    i: uint64 = 0
    while i < upn and slurp_buf[i] >= 48 and slurp_buf[i] <= 57:
        secs = secs * 10 + cast[uint64](slurp_buf[i]) - 48
        i = i + 1
    hh: uint64 = secs / 3600
    mm: uint64 = (secs % 3600) / 60
    ss: uint64 = secs % 60
    p: uint64 = 0
    p = p + _ctl_u64_to_dec(hh, &out[p])
    out[p] = 58
    p = p + 1
    out[p] = cast[uint8](mm / 10) + 48
    out[p+1] = cast[uint8](mm % 10) + 48
    out[p+2] = 58
    p = p + 3
    out[p] = cast[uint8](ss / 10) + 48
    out[p+1] = cast[uint8](ss % 10) + 48
    p = p + 2
    out[p] = 0
    return p


def _refresh_power():
    _fmt_uptime(&pw_up[0])
    # No ACPI battery device exists on Hamnix — report the honest source.
    hamctl_set_power(&pw_up[0], cast[Ptr[uint8]]("AC (no battery)"))


def _act_lock():
    argbuf: Array[2, uint64]
    argbuf[0] = cast[uint64](cast[Ptr[char]]("/bin/hamlock"))
    argbuf[1] = 0
    spawn_detached(cast[Ptr[char]]("/bin/hamlock"), &argbuf[0],
                   -2, -2, cast[Ptr[uint64]](0))
    _writeall(1, cast[Ptr[uint8]]("[hamctl] lock -> /bin/hamlock\n"))


def _act_logout():
    fd: int32 = sys_open_write(cast[Ptr[char]]("/proc/svc/ctl"))
    if fd >= 0:
        _writeall(fd, cast[Ptr[uint8]]("runlevel 3\n"))
        sys_close(fd)
    _writeall(1, cast[Ptr[uint8]]("[hamctl] logout -> runlevel 3\n"))


def _act_power(verb: Ptr[uint8]):
    fd: int32 = sys_open(cast[Ptr[char]]("/dev/reboot"))
    if fd >= 0:
        _writeall(fd, verb)
        sys_close(fd)
    _writeall(1, cast[Ptr[uint8]]("[hamctl] power -> /dev/reboot\n"))


# ---- network read-out (SYS_NETCFG GET) + REAL DNS sink (SET_DNS) ---------
net_addr_s: Array[24, uint8]
net_mask_s: Array[24, uint8]
net_gw_s:   Array[24, uint8]
net_dns_s:  Array[24, uint8]
net_src_s:  Array[16, uint8]


# Format 4 octets cfg[o..o+3] as "a.b.c.d" into out; NUL-terminated.
def _fmt_ip(cfg: Ptr[uint8], o: uint64, out: Ptr[uint8]):
    p: uint64 = 0
    q: uint64 = 0
    while q < 4:
        p = p + _ctl_u64_to_dec(cast[uint64](cfg[o + q]), &out[p])
        if q < 3:
            out[p] = 46                                 # '.'
            p = p + 1
        q = q + 1
    out[p] = 0


def _ctl_strcpy_local(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    i: uint64 = 0
    while src[i] != 0 and i < cap - 1:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def _read_network():
    cfg: Array[24, uint8]
    if sys_netcfg(0, cast[uint64](&cfg[0]), 0) != 0:
        hamctl_set_net(cast[Ptr[uint8]]("(error)"), cast[Ptr[uint8]]("-"),
                       cast[Ptr[uint8]]("-"), cast[Ptr[uint8]]("-"),
                       cast[Ptr[uint8]]("none"))
        return
    if cfg[16] == 1:
        _fmt_ip(&cfg[0], 0, &net_addr_s[0])
    else:
        _ctl_strcpy_local(&net_addr_s[0], cast[Ptr[uint8]]("(unset)"), 24)
    if cfg[17] == 1:
        _fmt_ip(&cfg[0], 4, &net_mask_s[0])
    else:
        _ctl_strcpy_local(&net_mask_s[0], cast[Ptr[uint8]]("(unset)"), 24)
    if cfg[18] == 1:
        _fmt_ip(&cfg[0], 8, &net_gw_s[0])
    else:
        _ctl_strcpy_local(&net_gw_s[0], cast[Ptr[uint8]]("(none)"), 24)
    if cfg[19] == 1:
        _fmt_ip(&cfg[0], 12, &net_dns_s[0])
    else:
        _ctl_strcpy_local(&net_dns_s[0], cast[Ptr[uint8]]("(none)"), 24)
    src: Ptr[uint8] = cast[Ptr[uint8]]("none")
    if cfg[20] == 1:
        src = cast[Ptr[uint8]]("dhcp")
    elif cfg[20] == 2:
        src = cast[Ptr[uint8]]("static")
    _ctl_strcpy_local(&net_src_s[0], src, 16)
    hamctl_set_net(&net_addr_s[0], &net_mask_s[0], &net_gw_s[0],
                   &net_dns_s[0], src)


# REAL SINK: latch a static DNS server in the live kernel resolver via
# SYS_NETCFG SET_DNS (op 3), exactly as `ifconfig dns <addr>` does. pref 1 =
# 8.8.8.8 (Google), 2 = 1.1.1.1 (Cloudflare). Then persist + re-read so the
# capplet shows the new "(static)" source immediately.
def _apply_net_dns():
    pref: int32 = hamctl_net_dns_pref()
    dnsip: uint64 = 0
    if pref == 1:
        dnsip = (8 << 24) | (8 << 16) | (8 << 8) | 8         # 8.8.8.8
    elif pref == 2:
        dnsip = (1 << 24) | (1 << 16) | (1 << 8) | 1         # 1.1.1.1
    else:
        return
    if sys_netcfg(3, dnsip, 0) != 0:
        _writeall(1, cast[Ptr[uint8]]("[hamctl] SET_DNS failed\n"))
        return
    # Persist the choice for a boot/login re-apply hook.
    p: uint64 = 0
    p = _cfg_kv_int(p, cast[Ptr[uint8]]("dns_pref"), pref)
    _cfg_write(cast[Ptr[char]]("/tmp/hamnix-net.conf"), p)
    _writeall(1, cast[Ptr[uint8]]("[hamctl] DNS set (SYS_NETCFG SET_DNS) + net.conf written\n"))
    _read_network()


def emit_scene(wid: int32):
    hamctl_build_scene()
    hamscene_commit(wid)


btn_down: int32 = 0


def main() -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamctl] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        _writeall(cfd, cast[Ptr[uint8]]("geometry 200 100 520 400\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("title Control Center\n"))
        sys_close(cfd3)
    cfd4: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd4 >= 0:
        _writeall(cfd4, cast[Ptr[uint8]]("z 7\n"))
        sys_close(cfd4)

    hamctl_init()
    _refresh_datetime()
    _refresh_about()
    _read_display()
    _read_kb_layout()
    _probe_sound()
    _refresh_power()
    _read_network()
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamctl] scene window ready\n"))

    evbuf: Array[256, uint8]
    ticks: uint64 = 0
    while True:
        changed: int32 = 0
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            # A window CONTENT-size change ("r <w> <h>") from
                            # the compositor: relayout to the new size so the
                            # scene fills the whole client rect (no black
                            # gutter at non-default / non-maximized sizes).
                            if hamctl_resize_line(&evbuf[ls], i - ls) == 1:
                                changed = 1
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            if parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn) == 1:
                                nd: int32 = 0
                                if (bbtn & 1) != 0:
                                    nd = 1
                                if nd == 1 and btn_down == 0:
                                    act: int32 = hamctl_click(bx, by)
                                    if act == ACT_WALL:
                                        _apply_wallpaper()
                                        changed = 1
                                    elif act == ACT_WALLIMG:
                                        _apply_wallpaper_image()
                                        changed = 1
                                    elif act == ACT_TZ:
                                        _persist_tz()
                                        _refresh_datetime()
                                        changed = 1
                                    elif act == ACT_DISPLAY:
                                        _persist_display()
                                        changed = 1
                                    elif act == ACT_MOUSE:
                                        _persist_mouse()
                                        changed = 1
                                    elif act == ACT_KBD:
                                        _persist_kbd()
                                        changed = 1
                                    elif act == ACT_SOUND:
                                        _persist_sound()
                                        changed = 1
                                    elif act == ACT_NET:
                                        _apply_net_dns()
                                        changed = 1
                                    elif act == ACT_LOCK:
                                        _act_lock()
                                    elif act == ACT_LOGOUT:
                                        _act_logout()
                                    elif act == ACT_SHUTDOWN:
                                        _act_power(cast[Ptr[uint8]]("poweroff\n"))
                                    elif act == ACT_REBOOT:
                                        _act_power(cast[Ptr[uint8]]("reboot\n"))
                                    elif act == ACT_CAT:
                                        changed = 1
                                btn_down = nd
                        ls = i + 1
                    i = i + 1
        # periodic clock refresh (~every 30 ticks) so Date & Time stays live
        ticks = ticks + 1
        if ticks % 30 == 0:
            _refresh_datetime()
            _refresh_power()
            changed = 1
        if changed != 0:
            emit_scene(wid)
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

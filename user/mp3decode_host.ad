# user/mp3decode_host.ad — HOST harness for the native MP3 decoder
# (built for x86_64-linux; runs on the dev host, NO QEMU).
#
# It drives the SAME lib/mp3decode.ad the native player ships: reads a .mp3 on
# argv, decodes the whole file to PCM, DUMPS the extracted format (rate,
# channels), the decoded sample-frame count, an additive PCM checksum and the
# peak sample, then writes the raw s16le PCM to a file. scripts/
# test_mp3decode_host.sh checks all of that against an ffmpeg reference over the
# same file (RMS + correlation + sample values) — a deterministic decoder
# correctness signal, no audio hardware needed.
#
# USAGE (built to build/host/mp3decode_host):
#   mp3decode_host FILE.mp3 OUT.pcm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.mp3decode import mp3decode_parse, mp3decode_ok, mp3decode_rate, \
    mp3decode_channels, mp3decode_bits, mp3decode_nframes, mp3decode_data_len, \
    mp3decode_pcm_ptr, mp3decode_duration_ms, mp3decode_peak

FILE_CAP: uint64 = 4194304
filebuf: Array[4194304, uint8]
filelen: uint64 = 0

obuf: Array[1024, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 1023:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: uint64):
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 3:
        _o_str(cast[Ptr[uint8]]("usage: mp3decode_host FILE.mp3 OUT.pcm\n"))
        _o_flush()
        return 2
    path: Ptr[char] = cast[Ptr[char]](argv[1])
    fd: int32 = sys_open(path, 0, 0)                     # O_RDONLY
    if fd < 0:
        _o_str(cast[Ptr[uint8]]("FAIL cannot open input\n"))
        _o_flush()
        return 1
    while filelen < FILE_CAP:
        r: int64 = sys_read(fd, &filebuf[filelen], FILE_CAP - filelen)
        if r <= 0:
            break
        filelen = filelen + cast[uint64](r)
    sys_close(fd)

    _o_str(cast[Ptr[uint8]]("FILELEN "))
    _o_dec(filelen)
    _o_ch(10)

    ok: int32 = mp3decode_parse(&filebuf[0], filelen)
    _o_str(cast[Ptr[uint8]]("DECODE_OK "))
    _o_dec(cast[uint64](ok))
    _o_ch(10)
    if ok == 0:
        _o_flush()
        return 1

    _o_str(cast[Ptr[uint8]]("RATE "))
    _o_dec(cast[uint64](mp3decode_rate()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("CHANNELS "))
    _o_dec(cast[uint64](mp3decode_channels()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("BITS "))
    _o_dec(cast[uint64](mp3decode_bits()))
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("NFRAMES "))
    _o_dec(mp3decode_nframes())
    _o_ch(10)
    _o_str(cast[Ptr[uint8]]("DURATION_MS "))
    _o_dec(mp3decode_duration_ms())
    _o_ch(10)

    dl: uint64 = mp3decode_data_len()
    _o_str(cast[Ptr[uint8]]("DATALEN "))
    _o_dec(dl)
    _o_ch(10)

    base: Ptr[uint8] = mp3decode_pcm_ptr()
    csum: uint64 = 0
    k: uint64 = 0
    while k < dl:
        csum = (csum + cast[uint64](base[k])) & 4294967295
        k = k + 1
    _o_str(cast[Ptr[uint8]]("PCM_CHECKSUM "))
    _o_dec(csum)
    _o_ch(10)

    pk: uint32 = mp3decode_peak(0, dl)
    _o_str(cast[Ptr[uint8]]("PCM_PEAK "))
    _o_dec(cast[uint64](pk))
    _o_ch(10)
    _o_flush()

    # write raw PCM
    ofd: int32 = sys_open(cast[Ptr[char]](argv[2]), 577, 420)   # WRONLY|CREAT|TRUNC
    if ofd >= 0:
        written: uint64 = 0
        while written < dl:
            chunk: uint64 = dl - written
            if chunk > 65536:
                chunk = 65536
            sys_write(ofd, &base[written], chunk)
            written = written + chunk
        sys_close(ofd)
    return 0

# user/hamaudiobook.ad — NATIVE driver for the hamaudiobook player, the FIRST
# Hamnix app that ships ONLY in the software repo (255.one) and is installed via
# `hpm install hamnix-hamaudiobook` / the Software app — NOT pre-installed in the
# base image.
#
# The player's UI STATE, LAYOUT, scene builder, pure input handlers, the resume
# state-file serialize/lookup, and the sleep-timer deadline math all live in the
# extern-free, dual-target lib/hamaudiobookcore.ad (host-tested by
# scripts/test_hamaudiobook_host.sh). This file keeps ONLY the Hamnix-only side:
#   * open a wsys window, read its /keys + /event, commit the scene;
#   * READ the book file into memory + decode (lib/wavdecode / lib/mp3decode);
#   * STREAM decoded PCM to the native HDA sink (echo verbs to /dev/audioctl,
#     stage samples to /dev/audio, `start`) — the SAME Plan-9 file path
#     aplay/hamaudioscene use (no ioctls, no sockets, just file writes);
#   * PERSIST the per-book playback offset to /var/hamaudiobook.state and RESUME
#     from it when the same book is reopened (the defining audiobook feature);
#   * POLL the sleep timer against the 100 Hz jiffies clock and stop playback
#     (+ save) when it fires (night mode).
#
# USAGE:  hamaudiobook [book.mp3|book.wav]  (defaults to
#         /usr/share/sounds/test.mp3). Resume is keyed on the file path.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32

from lib.hamsceneloop import hamscene_park, HAMSCENE_IDLE_MS
from lib.hamui import hamscene_commit
from lib.wavdecode import wavdecode_parse, wavdecode_ok, wavdecode_rate, \
    wavdecode_channels, wavdecode_bits, wavdecode_data_off, wavdecode_data_len, \
    wavdecode_frame_bytes, wavdecode_duration_ms, wavdecode_peak
from lib.mp3decode import mp3decode_parse, mp3decode_ok, mp3decode_rate, \
    mp3decode_channels, mp3decode_data_len, mp3decode_duration_ms, \
    mp3decode_pcm_ptr, mp3decode_peak
from lib.hamaudiobookcore import hamaudiobook_init, hamaudiobook_set_name, \
    hamaudiobook_set_format, hamaudiobook_set_duration_ms, \
    hamaudiobook_set_position_ms, hamaudiobook_set_level, \
    hamaudiobook_set_playing, hamaudiobook_is_playing, \
    hamaudiobook_set_resumed, hamaudiobook_duration_ms, \
    hamaudiobook_take_command, hamaudiobook_seek_ms, \
    hamaudiobook_skip_target_ms, \
    hamaudiobook_key_line, hamaudiobook_handle_pointer_line, \
    hamaudiobook_build_scene_at, hamaudiobook_layout, \
    hamaudiobook_state_upsert, hamaudiobook_state_lookup, \
    hamaudiobook_sleep_cycle, hamaudiobook_sleep_arm, \
    hamaudiobook_sleep_is_armed, hamaudiobook_sleep_expired, \
    HAMAUDIOBOOK_CMD_PLAYPAUSE, HAMAUDIOBOOK_CMD_STOP, HAMAUDIOBOOK_CMD_SEEK, \
    HAMAUDIOBOOK_CMD_SKIPBACK, HAMAUDIOBOOK_CMD_SKIPFWD, HAMAUDIOBOOK_CMD_SLEEP, \
    SKIP_MS

FILE_CAP: uint64 = 327680
au_filebuf: Array[327680, uint8]
au_filelen: uint64 = 0

HDA_CAP: uint64 = 262144

play_start_j: uint64 = 0
play_base_ms: uint64 = 0

ctlfd_g: int32 = -1
src_is_mp3: int32 = 0

# Path of the currently-open book (resume is keyed on this). Held as a uint64
# because x86 globals need an integer initializer; cast to Ptr[char] at use.
book_path: uint64 = 0

# Resume state file, read into memory + rewritten on save. The path literal is
# inlined at each open (a cast-wrapped string can't initialize an x86 global).
STATE_CAP: uint64 = 8192
statebuf: Array[8192, uint8]
statelen: uint64 = 0


# ---- format-agnostic PCM source accessors --------------------------------
def _src_base() -> Ptr[uint8]:
    if src_is_mp3 != 0:
        return mp3decode_pcm_ptr()
    return &au_filebuf[0]


def _src_off() -> uint64:
    if src_is_mp3 != 0:
        return 0
    return wavdecode_data_off()


def _src_len() -> uint64:
    if src_is_mp3 != 0:
        return mp3decode_data_len()
    return wavdecode_data_len()


def _src_rate() -> uint32:
    if src_is_mp3 != 0:
        return mp3decode_rate()
    return wavdecode_rate()


def _src_channels() -> uint32:
    if src_is_mp3 != 0:
        return mp3decode_channels()
    return wavdecode_channels()


def _src_bits() -> uint32:
    if src_is_mp3 != 0:
        return 16
    return wavdecode_bits()


def _src_frame_bytes() -> uint64:
    return cast[uint64](_src_channels()) * (cast[uint64](_src_bits()) / 8)


def _src_duration_ms() -> uint64:
    if src_is_mp3 != 0:
        return mp3decode_duration_ms()
    return wavdecode_duration_ms()


def _src_peak(dataoff: uint64, n: uint64) -> uint32:
    if src_is_mp3 != 0:
        return mp3decode_peak(dataoff, n)
    return wavdecode_peak(&au_filebuf[0], wavdecode_data_off() + dataoff, n)


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    if value == 0:
        out[0] = 48
        out[1] = 0
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    out[written] = 0
    return written


# ---- resume state file ---------------------------------------------------
def _state_load():
    statelen = 0
    fd: int32 = sys_open(cast[Ptr[char]]("/var/hamaudiobook.state"))
    if fd < 0:
        return
    while statelen < STATE_CAP:
        r: int64 = sys_read(fd, &statebuf[statelen], STATE_CAP - statelen)
        if r <= 0:
            break
        statelen = statelen + cast[uint64](r)
    sys_close(fd)


# Save `offset_ms` for the current book: upsert the in-memory table, rewrite
# the whole file (small; one line per book).
def _state_save(offset_ms: uint64):
    if book_path == 0:
        return
    statelen = hamaudiobook_state_upsert(&statebuf[0], statelen, STATE_CAP,
                                         cast[Ptr[uint8]](book_path), offset_ms)
    fd: int32 = sys_open_write(cast[Ptr[char]]("/var/hamaudiobook.state"))
    if fd < 0:
        return
    sys_write(fd, &statebuf[0], statelen)
    sys_close(fd)


# ---- wsys window transport -----------------------------------------------
def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# The scene's live sleep-timer readout counts down against the WALL clock (the
# same jiffies*10 ms the deadline was armed with) — NOT the playback position —
# so emit reads the clock itself here rather than threading the play cursor in.
def emit_scene(wid: int32):
    hamaudiobook_build_scene_at(sys_get_jiffies() * 10)
    hamscene_commit(wid)


# ---- HDA control ---------------------------------------------------------
def _ctl_verb(verb: Ptr[uint8], value: uint64):
    if ctlfd_g < 0:
        return
    line: Array[48, uint8]
    p: uint64 = 0
    j: uint64 = 0
    while verb[j] != 0:
        line[p] = verb[j]
        p = p + 1
        j = j + 1
    line[p] = 32
    p = p + 1
    p = p + _u64_to_dec(value, &line[p])
    line[p] = 10
    p = p + 1
    sys_write(ctlfd_g, &line[0], p)


def _ctl_word(s: Ptr[uint8]):
    if ctlfd_g >= 0:
        _writeall(ctlfd_g, s)


def _stage_and_start(from_byte: uint64):
    data_len: uint64 = _src_len()
    if from_byte >= data_len:
        return
    _ctl_word(cast[Ptr[uint8]]("reset\n"))
    audfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/audio"))
    if audfd < 0:
        return
    span: uint64 = data_len - from_byte
    if span > HDA_CAP:
        span = HDA_CAP
    fb: uint64 = _src_frame_bytes()
    if fb > 0:
        span = (span / fb) * fb
    base: uint64 = cast[uint64](_src_base()) + _src_off() + from_byte
    written: uint64 = 0
    while written < span:
        chunk: uint64 = span - written
        if chunk > 4096:
            chunk = 4096
        sys_write(audfd, cast[Ptr[uint8]](base + written), chunk)
        written = written + chunk
    sys_close(audfd)
    _ctl_word(cast[Ptr[uint8]]("start\n"))


def _level_at(cur_byte: uint64) -> uint32:
    data_len: uint64 = _src_len()
    if cur_byte >= data_len:
        return 0
    win: uint64 = 2048
    if cur_byte + win > data_len:
        win = data_len - cur_byte
    return _src_peak(cur_byte, win)


def _ms_to_bytes(ms: uint64) -> uint64:
    rate: uint64 = cast[uint64](_src_rate())
    fb: uint64 = _src_frame_bytes()
    return ms * rate * fb / 1000


def _basename(path: Ptr[char]) -> Ptr[uint8]:
    nm: Ptr[uint8] = cast[Ptr[uint8]](path)
    base: Ptr[uint8] = nm
    z: uint64 = 0
    while nm[z] != 0:
        if nm[z] == 47:
            base = &nm[z + 1]
        z = z + 1
    return base


def _load_and_decode(path: Ptr[char]) -> int32:
    au_filelen = 0
    infd: int32 = sys_open(path)
    if infd >= 0:
        while au_filelen < FILE_CAP:
            r: int64 = sys_read(infd, &au_filebuf[au_filelen],
                                FILE_CAP - au_filelen)
            if r <= 0:
                break
            au_filelen = au_filelen + cast[uint64](r)
        sys_close(infd)

    src_is_mp3 = 0
    plen: uint64 = 0
    while cast[Ptr[uint8]](path)[plen] != 0:
        plen = plen + 1
    if plen >= 4:
        e0: uint8 = cast[Ptr[uint8]](path)[plen - 3]
        e1: uint8 = cast[Ptr[uint8]](path)[plen - 2]
        e2: uint8 = cast[Ptr[uint8]](path)[plen - 1]
        if (e0 == 109 or e0 == 77) and (e1 == 112 or e1 == 80) and e2 == 51:
            src_is_mp3 = 1

    ok: int32 = 0
    if src_is_mp3 != 0:
        ok = mp3decode_parse(&au_filebuf[0], au_filelen)
    elif au_filelen >= 44:
        ok = wavdecode_parse(&au_filebuf[0], au_filelen)
    if ok != 0:
        hamaudiobook_set_format(_src_rate(), _src_channels())
        hamaudiobook_set_duration_ms(_src_duration_ms())
        hamaudiobook_set_name(_basename(path))
    else:
        hamaudiobook_set_name(cast[Ptr[uint8]]("(unreadable book)"))
    return ok


def _configure_format():
    if ctlfd_g < 0:
        return
    _ctl_verb(cast[Ptr[uint8]]("rate"), cast[uint64](_src_rate()))
    _ctl_verb(cast[Ptr[uint8]]("channels"), cast[uint64](_src_channels()))
    if _src_bits() == 8:
        _ctl_word(cast[Ptr[uint8]]("format u8\n"))
    else:
        _ctl_word(cast[Ptr[uint8]]("format s16le\n"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)

    hamaudiobook_init()

    if argc >= 2:
        book_path = argv[1]
    else:
        book_path = cast[uint64](cast[Ptr[char]]("/usr/share/sounds/test.mp3"))

    ok: int32 = _load_and_decode(cast[Ptr[char]](book_path))

    # --- RESUME: read the saved offset for this book (if any) ---
    _state_load()
    saved_ms: uint64 = hamaudiobook_state_lookup(&statebuf[0], statelen,
                                                 cast[Ptr[uint8]](book_path))
    cur_byte: uint64 = 0
    if ok != 0 and saved_ms > 0 and saved_ms < _src_duration_ms():
        play_base_ms = saved_ms
        cur_byte = _ms_to_bytes(saved_ms)
        hamaudiobook_set_position_ms(saved_ms)
        hamaudiobook_set_resumed(1, saved_ms)

    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamaudiobook] FAIL newwindow\n"))
        return 1

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    wcfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if wcfd >= 0:
        _writeall(wcfd, cast[Ptr[uint8]]("geometry 460 160 380 280\n"))
        _writeall(wcfd, cast[Ptr[uint8]]("decorate 1\n"))
        _writeall(wcfd, cast[Ptr[uint8]]("z 6\n"))
        _writeall(wcfd, cast[Ptr[uint8]]("title Audiobook\n"))
        sys_close(wcfd)

    hamaudiobook_layout(380, 280)

    ctlfd_g = sys_open_write(cast[Ptr[char]]("/dev/audioctl"))
    if ctlfd_g >= 0 and ok != 0:
        _configure_format()

    now_ms: uint64 = play_base_ms
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamaudiobook] scene window ready\n"))

    kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))

    # Autoplay from the resume point (or the start) so a bare launch produces
    # sound and the on-device gate hears playback.
    if ok != 0:
        _stage_and_start(cur_byte)
        play_start_j = sys_get_jiffies()
        hamaudiobook_set_playing(1)
        _writeall(1, cast[Ptr[uint8]]("[hamaudiobook] playing\n"))
        emit_scene(wid)

    evbuf: Array[256, uint8]
    kbuf: Array[256, uint8]
    while True:
        changed: int32 = 0

        # --- KEYBOARD ---
        if kfd >= 0:
            kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
            if kr > 0:
                kls: uint64 = 0
                ki: uint64 = 0
                while ki <= cast[uint64](kr):
                    katend: int32 = 0
                    if ki == cast[uint64](kr):
                        katend = 1
                    if katend == 1 or kbuf[ki] == 10:
                        if ki > kls:
                            if hamaudiobook_key_line(&kbuf[kls], ki - kls) == 1:
                                changed = 1
                        kls = ki + 1
                    ki = ki + 1

        # --- POINTER ---
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        if efd >= 0:
            r2: int64 = sys_read_nb(efd, &evbuf[0], 255)
            sys_close(efd)
            if r2 > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r2):
                    atend: int32 = 0
                    if i == cast[uint64](r2):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            if hamaudiobook_handle_pointer_line(&evbuf[ls],
                                                                i - ls) == 1:
                                changed = 1
                        ls = i + 1
                    i = i + 1

        # --- drain one queued command ---
        cmd: int32 = hamaudiobook_take_command()
        if cmd == HAMAUDIOBOOK_CMD_PLAYPAUSE:
            if hamaudiobook_is_playing() != 0:
                play_base_ms = play_base_ms + \
                    (sys_get_jiffies() - play_start_j) * 10
                _ctl_word(cast[Ptr[uint8]]("stop\n"))
                hamaudiobook_set_playing(0)
                _state_save(play_base_ms)              # remember where we paused
            else:
                cur_byte = _ms_to_bytes(play_base_ms)
                _stage_and_start(cur_byte)
                play_start_j = sys_get_jiffies()
                hamaudiobook_set_playing(1)
            changed = 1
        elif cmd == HAMAUDIOBOOK_CMD_STOP:
            if hamaudiobook_is_playing() != 0:
                play_base_ms = play_base_ms + \
                    (sys_get_jiffies() - play_start_j) * 10
            _ctl_word(cast[Ptr[uint8]]("stop\n"))
            _state_save(play_base_ms)                  # save before rewind
            _ctl_word(cast[Ptr[uint8]]("reset\n"))
            hamaudiobook_set_playing(0)
            play_base_ms = 0
            cur_byte = 0
            hamaudiobook_set_position_ms(0)
            hamaudiobook_set_level(0)
            changed = 1
        elif cmd == HAMAUDIOBOOK_CMD_SEEK:
            play_base_ms = hamaudiobook_seek_ms()
            cur_byte = _ms_to_bytes(play_base_ms)
            if hamaudiobook_is_playing() != 0:
                _stage_and_start(cur_byte)
                play_start_j = sys_get_jiffies()
            hamaudiobook_set_position_ms(play_base_ms)
            hamaudiobook_set_level(_level_at(cur_byte))
            _state_save(play_base_ms)
            changed = 1
        elif cmd == HAMAUDIOBOOK_CMD_SKIPBACK or cmd == HAMAUDIOBOOK_CMD_SKIPFWD:
            # Current playing position, then jump ±30s (clamped).
            nowp: uint64 = play_base_ms
            if hamaudiobook_is_playing() != 0:
                nowp = play_base_ms + (sys_get_jiffies() - play_start_j) * 10
            back: int32 = 0
            if cmd == HAMAUDIOBOOK_CMD_SKIPBACK:
                back = 1
            play_base_ms = hamaudiobook_skip_target_ms(nowp, SKIP_MS, back)
            cur_byte = _ms_to_bytes(play_base_ms)
            if hamaudiobook_is_playing() != 0:
                _stage_and_start(cur_byte)
                play_start_j = sys_get_jiffies()
            hamaudiobook_set_position_ms(play_base_ms)
            hamaudiobook_set_level(_level_at(cur_byte))
            _state_save(play_base_ms)
            changed = 1
        elif cmd == HAMAUDIOBOOK_CMD_SLEEP:
            hamaudiobook_sleep_cycle()
            hamaudiobook_sleep_arm(sys_get_jiffies() * 10)
            changed = 1

        # --- advance position while playing ---
        if hamaudiobook_is_playing() != 0:
            now_ms = play_base_ms + (sys_get_jiffies() - play_start_j) * 10
            dur: uint64 = hamaudiobook_duration_ms()
            # Sleep timer fires: stop + save + disarm-visible (stays paused).
            if hamaudiobook_sleep_is_armed() != 0 and \
                    hamaudiobook_sleep_expired(sys_get_jiffies() * 10) != 0:
                _ctl_word(cast[Ptr[uint8]]("stop\n"))
                hamaudiobook_set_playing(0)
                play_base_ms = now_ms
                _state_save(play_base_ms)
                hamaudiobook_set_position_ms(now_ms)
                changed = 1
                _writeall(1, cast[Ptr[uint8]]("[hamaudiobook] sleep timer -> paused\n"))
            elif dur > 0 and now_ms >= dur:
                _ctl_word(cast[Ptr[uint8]]("stop\n"))
                _ctl_word(cast[Ptr[uint8]]("reset\n"))
                hamaudiobook_set_playing(0)
                play_base_ms = 0
                cur_byte = 0
                hamaudiobook_set_position_ms(0)
                hamaudiobook_set_level(0)
                _state_save(0)                         # finished -> back to start
                changed = 1
                _writeall(1, cast[Ptr[uint8]]("[hamaudiobook] EOF -> idle\n"))
            else:
                hamaudiobook_set_position_ms(now_ms)
                cur_byte = _ms_to_bytes(now_ms)
                hamaudiobook_set_level(_level_at(cur_byte))
                changed = 1
        else:
            now_ms = play_base_ms

        if changed != 0:
            emit_scene(wid)
        hamscene_park(kfd, HAMSCENE_IDLE_MS)
    return 0

# user/x11/x11test.ad — self-contained X11 round-trip test.
#
# This binary runs INSIDE the Hamnix guest as /init.  It spawns
# x11srv (TCP listener on port 6000) and xfill (TCP client) as two
# separate processes, waits for both to print their PASS sentinel, then
# exits 0. Because both processes share the same /net stack inside the
# guest we don't need any host-side TCP connection.
#
# Boot pipeline:
#   1. build x11srv.elf + xfill.elf (build_user.sh adds them)
#   2. embed x11test.elf as /init in initramfs
#   3. boot QEMU — x11test spawns server + client, reads pipes,
#      asserts both print PASS, then prints "[x11test] PASS".
#
# Log sentinels (grep targets):
#   "[x11test] spawning server"
#   "[x11test] spawning client"
#   "[x11test] server PASS"
#   "[x11test] client PASS"
#   "[x11test] PASS"
#
# Adder quirks: module-scope buffers for all pipes + scratch.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_yield() -> int32


# -------------------------------------------------------------------
# Module-scope state
# -------------------------------------------------------------------

# Pipe fd pairs [read, write] for server stdout and client stdout.
srv_pipe: Array[2, int32]
cli_pipe: Array[2, int32]

# Spawn argv: [path, NULL].
srv_argv: Array[2, uint64]
cli_argv: Array[2, uint64]

# Read buffers for pipe data.
srv_buf: Array[2048, uint8]
cli_buf: Array[2048, uint8]
# Use Array[1, uint64] so we can take &srv_len[0] as Ptr[uint64] (Adder idiom).
srv_len: Array[1, uint64]
cli_len: Array[1, uint64]

# Scratch.
scr: Array[64, uint8]


# -------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------

from lib.p9 import spawn

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def buf_contains(buf: Ptr[uint8], len: uint64, needle: Ptr[uint8]) -> int32:
    # Naive substring search: returns 1 if needle appears in buf[0..len).
    nlen: uint64 = strlen_u8(needle)
    if nlen == 0:
        return 1
    if nlen > len:
        return 0
    limit: uint64 = len - nlen + 1
    i: uint64 = 0
    while i < limit:
        j: uint64 = 0
        found: int32 = 1
        while j < nlen:
            if buf[i + j] != needle[j]:
                found = 0
                break
            j = j + 1
        if found != 0:
            return 1
        i = i + 1
    return 0


def drain_pipe(pipe_rd: int32, buf: Ptr[uint8],
               buf_len: Ptr[uint64], cap: uint64):
    # Non-blocking drain of pipe_rd into buf starting at *buf_len.
    # Uses sys_read_nb so we don't block waiting for data.
    attempts: int32 = 0
    while attempts < 16:
        space: uint64 = cap - buf_len[0]
        if space == 0:
            break
        chunk: uint64 = 64
        if chunk > space:
            chunk = space
        n: int64 = sys_read_nb(pipe_rd, &buf[buf_len[0]], chunk)
        if n <= 0:
            break
        buf_len[0] = buf_len[0] + cast[uint64](n)
        attempts = attempts + 1


# -------------------------------------------------------------------
# Main
# -------------------------------------------------------------------

def main() -> int32:
    write_str(1, "[x11test] starting\n")

    # Create pipes for server and client stdout.
    p1: int32 = sys_pipe(&srv_pipe[0])
    p2: int32 = sys_pipe(&cli_pipe[0])
    if p1 < 0 or p2 < 0:
        write_str(2, "[x11test] pipe() failed\n")
        return 1

    # Spawn x11srv — its stdout goes to srv_pipe[1].
    write_str(1, "[x11test] spawning server\n")
    srv_path: Ptr[char] = "/bin/x11srv"
    srv_argv[0] = cast[uint64](cast[Ptr[char]]("/bin/x11srv"))
    srv_argv[1] = 0
    srv_pid: int32 = spawn(srv_path, &srv_argv[0],
                               -1, srv_pipe[1],
                               cast[Ptr[uint64]](0))
    if srv_pid < 0:
        write_str(2, "[x11test] spawn x11srv failed\n")
        return 1
    sys_close(srv_pipe[1])   # parent closes write end

    # Wait for x11srv to announce the port. The server prints
    # "[x11srv] listening" before blocking in net_accept. Poll the
    # pipe until we see that sentinel, yielding between attempts so
    # the server process gets scheduled. Up to 3000 rounds (generous
    # on slow TCG). This replaces the old 500-blind-yield approach and
    # ensures xfill connects while the server is inside tcp_accept's
    # polling loop — eliminating the accept-timeout race entirely.
    srv_ready_s: Ptr[uint8] = "[x11srv] listening"
    srv_ready: int32 = 0
    w2: int32 = 0
    while w2 < 3000:
        drain_pipe(srv_pipe[0], &srv_buf[0], &srv_len[0], 2048)
        if buf_contains(&srv_buf[0], srv_len[0], srv_ready_s) != 0:
            srv_ready = 1
            break
        sys_yield()
        w2 = w2 + 1
    if srv_ready == 0:
        write_str(2, "[x11test] FAIL: server did not print listening\n")
        return 1
    write_str(1, "[x11test] server ready\n")

    # Spawn xfill — its stdout goes to cli_pipe[1].
    write_str(1, "[x11test] spawning client\n")
    cli_path: Ptr[char] = "/bin/xfill"
    cli_argv[0] = cast[uint64](cast[Ptr[char]]("/bin/xfill"))
    cli_argv[1] = 0
    cli_pid: int32 = spawn(cli_path, &cli_argv[0],
                               -1, cli_pipe[1],
                               cast[Ptr[uint64]](0))
    if cli_pid < 0:
        write_str(2, "[x11test] spawn xfill failed\n")
        return 1
    sys_close(cli_pipe[1])   # parent closes write end

    # Poll both pipes until we see PASS sentinels (or timeout).
    # 5000 yield rounds — generous for the slow TCG host. The full
    # X11 round-trip (TCP handshake + ~10 request/reply messages)
    # adds up quickly under TCG. Each round yields once.
    srv_pass: int32 = 0
    cli_pass: int32 = 0
    rounds: int32 = 0

    while rounds < 5000:
        srv_pass_s: Ptr[uint8] = "[x11srv] PASS"
        cli_pass_s: Ptr[uint8] = "[xfill] PASS"

        drain_pipe(srv_pipe[0], &srv_buf[0], &srv_len[0], 2048)
        drain_pipe(cli_pipe[0], &cli_buf[0], &cli_len[0], 2048)

        if srv_pass == 0:
            if buf_contains(&srv_buf[0], srv_len[0], srv_pass_s) != 0:
                srv_pass = 1
                write_str(1, "[x11test] server PASS\n")

        if cli_pass == 0:
            if buf_contains(&cli_buf[0], cli_len[0], cli_pass_s) != 0:
                cli_pass = 1
                write_str(1, "[x11test] client PASS\n")

        if srv_pass != 0 and cli_pass != 0:
            break

        sys_yield()
        rounds = rounds + 1

    if srv_pass == 0:
        write_str(2, "[x11test] FAIL: server did not PASS\n")
        # Dump what we got for debugging.
        write_str(2, "[x11test] server output:\n")
        sys_write(2, &srv_buf[0], srv_len[0])
        return 1

    if cli_pass == 0:
        write_str(2, "[x11test] FAIL: client did not PASS\n")
        write_str(2, "[x11test] client output:\n")
        sys_write(2, &cli_buf[0], cli_len[0])
        return 1

    # Echo captured child output to the console so the per-request
    # protocol sentinels ([x11srv] listening/CreateWindow/MapWindow/
    # PolyFillRectangle/PASS, [xfill] connected/fill1 sent/PASS) reach
    # the kernel log even on success — the child stdout is a pipe, not
    # the console, so without this they'd only surface on failure.
    write_str(1, "[x11test] server output:\n")
    sys_write(1, &srv_buf[0], srv_len[0])
    write_str(1, "[x11test] client output:\n")
    sys_write(1, &cli_buf[0], cli_len[0])

    write_str(1, "[x11test] PASS\n")
    return 0

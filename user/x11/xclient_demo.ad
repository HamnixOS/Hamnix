# user/x11/xclient_demo.ad — purpose-built X11 demo app.
#
# A standalone X11 client that speaks the raw X11 wire protocol over a
# TCP connection to localhost:6000 (DISPLAY=:0).  It is NOT Xlib-based;
# it drives the protocol directly over the Plan-9 /net/tcp file tree via
# net_dial — no sockets, no glibc, no Xlib.
#
# This binary is the "real client" for scripts/test_x11_app.sh: it
# connects to a running x11srv instance, creates a window, draws a
# gradient-style two-colour fill (purple + cyan), then signals the server
# to flush its framebuffer to the hamUId wsys compositor layer.
#
# Sequence of X11 operations:
#   1. Connect via net_dial(127.0.0.1, 6000).
#   2. Connection-setup handshake — send 12-byte header, parse reply.
#   3. CreateWindow     — 400x300 window at (20, 20).
#   4. MapWindow        — request the window to be shown.
#   5. Wait for Expose  — server confirms window is mapped.
#   6. CreateGC #1      — fg=0x9900cc (purple).
#   7. PolyFillRect #1  — fill full 400x300 with purple.
#   8. CreateGC #2      — fg=0x00ccaa (cyan-green).
#   9. PolyFillRect #2  — fill a 200x150 block at (100, 75) with cyan.
#  10. InternAtom "X11SRV_DONE" — signals x11srv to flush to hamUId.
#
# Sentinels (grep targets):
#   "[xclient_demo] connected"
#   "[xclient_demo] setup done"
#   "[xclient_demo] window created"
#   "[xclient_demo] exposed"
#   "[xclient_demo] draw sent"
#   "[xclient_demo] done"
#   "[xclient_demo] PASS"

from user.net9 import net_dial
from user.x11.x11proto import (
    x11_put16, x11_put32, x11_get16_le, x11_get32_le,
    X_ROOT_WINDOW_ID, X_ROOT_VISUAL_ID, X_RESOURCE_BASE,
    X_CreateWindow, X_MapWindow, X_CreateGC, X_PolyFillRectangle,
    X_GetGeometry, X_InternAtom, X_QueryExtension,
    X_Reply, X_Error, X_Expose,
    ExposureMask,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


# -------------------------------------------------------------------
# Module-scope buffers (Adder U9: no large locals)
# -------------------------------------------------------------------

req_buf: Array[512, uint8]
rep_buf: Array[512, uint8]
scratch: Array[64, uint8]

resource_base: uint32 = 0
resource_mask: uint32 = 0
next_id: uint32 = 1


# -------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def read_exact(fd: int32, buf: Ptr[uint8], count: uint64) -> int32:
    got: uint64 = 0
    while got < count:
        n: int64 = sys_read(fd, &buf[got], count - got)
        if n <= 0:
            return 0
        got = got + cast[uint64](n)
    return 1


def send_all(fd: int32, buf: Ptr[uint8], count: uint64) -> int32:
    sent: uint64 = 0
    while sent < count:
        n: int64 = sys_write(fd, &buf[sent], count - sent)
        if n <= 0:
            return 0
        sent = sent + cast[uint64](n)
    return 1


def new_id() -> uint32:
    id: uint32 = resource_base | next_id
    next_id = next_id + 1
    return id


# -------------------------------------------------------------------
# Connection setup
# -------------------------------------------------------------------

def send_setup(fd: int32) -> int32:
    i: uint64 = 0
    while i < 12:
        req_buf[i] = 0
        i = i + 1
    req_buf[0] = 108       # 'l' = LSBFirst
    x11_put16(&req_buf[0], 2, 11)    # major version
    x11_put16(&req_buf[0], 4, 0)     # minor version
    return send_all(fd, &req_buf[0], 12)


def recv_setup(fd: int32) -> int32:
    if read_exact(fd, &rep_buf[0], 8) == 0:
        write_str(2, "[xclient_demo] setup prefix read failed\n")
        return 0
    if rep_buf[0] != 1:
        write_str(2, "[xclient_demo] server refused connection\n")
        return 0
    add_units: uint32 = x11_get16_le(&rep_buf[0], 6)
    add_bytes: uint64 = cast[uint64](add_units) * 4
    if add_bytes > 504:
        add_bytes = 504
    if read_exact(fd, &rep_buf[8], add_bytes) == 0:
        write_str(2, "[xclient_demo] setup body read failed\n")
        return 0
    resource_base = x11_get32_le(&rep_buf[0], 8 + 4)
    resource_mask = x11_get32_le(&rep_buf[0], 8 + 8)
    return 1


# -------------------------------------------------------------------
# CreateWindow (opcode 1)
# -------------------------------------------------------------------

def send_create_window(fd: int32, wid: uint32,
                       x: uint16, y: uint16,
                       w: uint16, h: uint16) -> int32:
    i: uint64 = 0
    while i < 32:
        req_buf[i] = 0
        i = i + 1
    req_buf[0] = 1
    req_buf[1] = 24         # depth=24
    x11_put16(&req_buf[0], 2, 8)     # length = 32/4 = 8
    x11_put32(&req_buf[0], 4, wid)
    x11_put32(&req_buf[0], 8, X_ROOT_WINDOW_ID)
    x11_put16(&req_buf[0], 12, x)
    x11_put16(&req_buf[0], 14, y)
    x11_put16(&req_buf[0], 16, w)
    x11_put16(&req_buf[0], 18, h)
    x11_put16(&req_buf[0], 20, 0)    # border-width
    x11_put16(&req_buf[0], 22, 1)    # InputOutput
    x11_put32(&req_buf[0], 24, X_ROOT_VISUAL_ID)
    x11_put32(&req_buf[0], 28, 0)    # value-mask
    return send_all(fd, &req_buf[0], 32)


# -------------------------------------------------------------------
# MapWindow (opcode 8)
# -------------------------------------------------------------------

def send_map_window(fd: int32, wid: uint32) -> int32:
    i: uint64 = 0
    while i < 8:
        req_buf[i] = 0
        i = i + 1
    req_buf[0] = 8
    req_buf[1] = 0
    x11_put16(&req_buf[0], 2, 2)    # length = 8/4 = 2
    x11_put32(&req_buf[0], 4, wid)
    return send_all(fd, &req_buf[0], 8)


# -------------------------------------------------------------------
# Wait for Expose event (type 12)
# -------------------------------------------------------------------

def wait_expose(fd: int32) -> int32:
    attempts: int32 = 0
    while attempts < 16:
        if read_exact(fd, &rep_buf[0], 32) == 0:
            return 0
        if rep_buf[0] == 12:
            return 1
        attempts = attempts + 1
    return 0


# -------------------------------------------------------------------
# CreateGC (opcode 55) with foreground colour
# -------------------------------------------------------------------

def send_create_gc(fd: int32, gid: uint32, drawable: uint32,
                   fg: uint32) -> int32:
    i: uint64 = 0
    while i < 20:
        req_buf[i] = 0
        i = i + 1
    req_buf[0] = 55
    req_buf[1] = 0
    x11_put16(&req_buf[0], 2, 5)    # length = 20/4 = 5
    x11_put32(&req_buf[0], 4, gid)
    x11_put32(&req_buf[0], 8, drawable)
    x11_put32(&req_buf[0], 12, 4)   # GCForeground bit
    x11_put32(&req_buf[0], 16, fg)
    return send_all(fd, &req_buf[0], 20)


# -------------------------------------------------------------------
# PolyFillRectangle (opcode 70)
# -------------------------------------------------------------------

def send_poly_fill_rect(fd: int32, drawable: uint32, gc: uint32,
                        x: uint16, y: uint16,
                        w: uint16, h: uint16) -> int32:
    i: uint64 = 0
    while i < 20:
        req_buf[i] = 0
        i = i + 1
    req_buf[0] = 70
    req_buf[1] = 0
    x11_put16(&req_buf[0], 2, 5)    # length = 20/4 = 5
    x11_put32(&req_buf[0], 4, drawable)
    x11_put32(&req_buf[0], 8, gc)
    x11_put16(&req_buf[0], 12, x)
    x11_put16(&req_buf[0], 14, y)
    x11_put16(&req_buf[0], 16, w)
    x11_put16(&req_buf[0], 18, h)
    return send_all(fd, &req_buf[0], 20)


# -------------------------------------------------------------------
# InternAtom "X11SRV_DONE" — done sentinel (opcode 16)
# -------------------------------------------------------------------

def send_intern_atom_done(fd: int32) -> int32:
    name: Ptr[uint8] = "X11SRV_DONE"
    name_len: uint64 = 11
    name_padded: uint64 = 12
    total: uint64 = 8 + name_padded
    i: uint64 = 0
    while i < total:
        req_buf[i] = 0
        i = i + 1
    req_buf[0] = 16
    req_buf[1] = 0
    x11_put16(&req_buf[0], 2, cast[uint16](total / 4))
    x11_put16(&req_buf[0], 4, cast[uint16](name_len))
    i = 0
    while i < name_len:
        req_buf[8 + i] = name[i]
        i = i + 1
    return send_all(fd, &req_buf[0], total)


# -------------------------------------------------------------------
# Main
# -------------------------------------------------------------------

def main() -> int32:
    write_str(1, "[xclient_demo] connecting to 127.0.0.1:6000\n")

    fd: int32 = net_dial(127, 0, 0, 1, 6000)
    if fd < 0:
        write_str(2, "[xclient_demo] net_dial failed\n")
        return 1

    write_str(1, "[xclient_demo] connected\n")

    if send_setup(fd) == 0:
        write_str(2, "[xclient_demo] send_setup failed\n")
        sys_close(fd)
        return 1

    if recv_setup(fd) == 0:
        write_str(2, "[xclient_demo] recv_setup failed\n")
        sys_close(fd)
        return 1

    write_str(1, "[xclient_demo] setup done\n")

    # Allocate resource IDs.
    win_id: uint32 = new_id()
    gc1_id: uint32 = new_id()
    gc2_id: uint32 = new_id()

    # CreateWindow: 400x300 at (20, 20).
    if send_create_window(fd, win_id, 20, 20, 400, 300) == 0:
        write_str(2, "[xclient_demo] CreateWindow failed\n")
        sys_close(fd)
        return 1
    write_str(1, "[xclient_demo] window created\n")

    # MapWindow.
    if send_map_window(fd, win_id) == 0:
        write_str(2, "[xclient_demo] MapWindow failed\n")
        sys_close(fd)
        return 1

    # Wait for Expose event.
    if wait_expose(fd) == 0:
        write_str(2, "[xclient_demo] no Expose event\n")
        sys_close(fd)
        return 1

    write_str(1, "[xclient_demo] exposed\n")

    # CreateGC #1: purple bg fill fg=0x9900cc.
    if send_create_gc(fd, gc1_id, win_id, 10027212) == 0:
        write_str(2, "[xclient_demo] CreateGC1 failed\n")
        sys_close(fd)
        return 1

    # PolyFillRect #1: full 400x300 purple background.
    if send_poly_fill_rect(fd, win_id, gc1_id, 0, 0, 400, 300) == 0:
        write_str(2, "[xclient_demo] fill1 failed\n")
        sys_close(fd)
        return 1

    # CreateGC #2: cyan-green fg=0x00ccaa.
    if send_create_gc(fd, gc2_id, win_id, 52394) == 0:
        write_str(2, "[xclient_demo] CreateGC2 failed\n")
        sys_close(fd)
        return 1

    # PolyFillRect #2: 200x150 cyan-green inner rectangle.
    if send_poly_fill_rect(fd, win_id, gc2_id, 100, 75, 200, 150) == 0:
        write_str(2, "[xclient_demo] fill2 failed\n")
        sys_close(fd)
        return 1

    write_str(1, "[xclient_demo] draw sent\n")

    # Done sentinel — tells x11srv to flush the framebuffer to hamUId.
    if send_intern_atom_done(fd) == 0:
        write_str(2, "[xclient_demo] done sentinel failed\n")
        sys_close(fd)
        return 1

    # Read the InternAtom reply (32 bytes).
    read_exact(fd, &rep_buf[0], 32)

    sys_close(fd)
    write_str(1, "[xclient_demo] done\n")
    write_str(1, "[xclient_demo] PASS\n")
    return 0

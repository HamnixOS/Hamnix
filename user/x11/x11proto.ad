# user/x11/x11proto.ad — X11 core protocol constants and wire helpers.
#
# Covers the minimal subset needed by x11srv.ad and xfill.ad:
#   • Connection setup (client byte-order byte, protocol version, auth)
#   • Reply/event/error codes
#   • Request opcodes (CreateWindow, MapWindow, CreateGC, PolyFillRectangle,
#     GetGeometry, InternAtom stub)
#   • Visual / depth table (single TrueColor 24-bit visual)
#   • Byte-packing helpers (little-endian, as used when client sends LSB)
#
# NO imports — this file is a pure constants+helpers library included by
# the server and client via `from user.x11.x11proto import ...`.
#
# Adder compiler quirks (feedback_compiler_quirks.md):
#   * No nested Array inside structs — all multi-byte protocol fields are
#     encoded byte-by-byte.
#   * String literals as Ptr[uint8] call-site constants; no globals that
#     hold string literals (U9 bug).
#   * Big flat byte Arrays at module scope.

# -------------------------------------------------------------------
# X11 protocol constants
# -------------------------------------------------------------------

# Request opcodes (X11 core protocol §A.2).
X_CreateWindow:        uint8 = 1
X_ChangeWindowAttrs:   uint8 = 2
X_GetWindowAttrs:      uint8 = 3
X_DestroyWindow:       uint8 = 4
X_MapWindow:           uint8 = 8
X_UnmapWindow:         uint8 = 10
X_CreateGC:            uint8 = 55
X_FreeGC:              uint8 = 60
X_ClearArea:           uint8 = 61
X_CopyArea:            uint8 = 62
X_PolyFillRectangle:   uint8 = 70
X_PutImage:            uint8 = 72
X_InternAtom:          uint8 = 16
X_GetAtomName:         uint8 = 17
X_GetGeometry:         uint8 = 14
X_QueryExtension:      uint8 = 98

# Reply / event / error codes.
X_Error:   uint8 = 0
X_Reply:   uint8 = 1
X_Expose:  uint8 = 12
X_KeyPress: uint8 = 2

# Error codes.
BadRequest:   uint8 = 1
BadValue:     uint8 = 2
BadWindow:    uint8 = 3
BadAtom:      uint8 = 5
BadGC:        uint8 = 13
BadMatch:     uint8 = 8
BadLength:    uint8 = 16
BadImplementation: uint8 = 17

# Visual class.
TrueColor:    uint8 = 4

# GC value mask bits (used in CreateGC / ChangeGC bitmask).
GCFunction:     uint32 = 1
GCForeground:   uint32 = 4
GCBackground:   uint32 = 8
GCLineWidth:    uint32 = 16

# Window event masks.
ExposureMask:      uint32 = 32768
StructureNotifyMask: uint32 = 131072

# Connection setup reply success code.
X_CONN_SUCCESS: uint8 = 1

# -------------------------------------------------------------------
# Fixed IDs the server exposes (single-resource implementation).
# -------------------------------------------------------------------

# The server's sole root window, visual, screen, colormap.
X_ROOT_WINDOW_ID:   uint32 = 1
X_ROOT_VISUAL_ID:   uint32 = 1
X_ROOT_COLORMAP_ID: uint32 = 1
X_SCREEN_W:         uint16 = 640
X_SCREEN_H:         uint16 = 480
X_SCREEN_MM_W:      uint16 = 200        # mm, approximate
X_SCREEN_MM_H:      uint16 = 150

# Resource ID bases (server allocates from 0x00a00000 upward).
X_RESOURCE_BASE:    uint32 = 10485760   # 0x00a00000

# -------------------------------------------------------------------
# Byte-order helper: put a 16-bit LE integer into buf at pos.
# -------------------------------------------------------------------

def x11_put16(buf: Ptr[uint8], pos: uint64, v: uint16):
    buf[pos]     = cast[uint8](v & 255)
    buf[pos + 1] = cast[uint8]((v >> 8) & 255)


def x11_put32(buf: Ptr[uint8], pos: uint64, v: uint32):
    buf[pos]     = cast[uint8](v & 255)
    buf[pos + 1] = cast[uint8]((v >> 8) & 255)
    buf[pos + 2] = cast[uint8]((v >> 16) & 255)
    buf[pos + 3] = cast[uint8]((v >> 24) & 255)


def x11_get16_le(buf: Ptr[uint8], pos: uint64) -> uint32:
    return cast[uint32](buf[pos]) | (cast[uint32](buf[pos + 1]) << 8)


def x11_get32_le(buf: Ptr[uint8], pos: uint64) -> uint32:
    b0: uint32 = cast[uint32](buf[pos])
    b1: uint32 = cast[uint32](buf[pos + 1])
    b2: uint32 = cast[uint32](buf[pos + 2])
    b3: uint32 = cast[uint32](buf[pos + 3])
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)


# -------------------------------------------------------------------
# Connection setup helper: build the ConnSetupReply success body.
#
# X11 protocol §8 (Connection Setup Reply):
#   Byte 0:       success = 1
#   Byte 1:       unused
#   Bytes 2-3:    protocol-major-version  (11)
#   Bytes 4-5:    protocol-minor-version  (0)
#   Bytes 6-7:    additional-data length in 4-byte units
#   Bytes 8-11:   release number
#   Bytes 12-15:  resource-id-base
#   Bytes 16-19:  resource-id-mask
#   Bytes 20-23:  motion-buffer-size
#   Bytes 24-25:  vendor-name length
#   Bytes 26-27:  max-request-length
#   Byte 28:      number of screens
#   Byte 29:      number of formats (pixmap-formats)
#   Byte 30:      image-byte-order   (0 = LSBFirst)
#   Byte 31:      bitmap-bit-order   (0 = LSBFirst)
#   Byte 32:      bitmap-scanline-unit   (32)
#   Byte 33:      bitmap-scanline-pad    (32)
#   Byte 34:      min-keycode
#   Byte 35:      max-keycode
#   Bytes 36-39:  unused
#   --- then vendor string (padded to 4n) ---
#   --- then pixmap-format list (8 bytes each) ---
#   --- then screen list ---
#   --- then depth list ---
#   --- then visual list ---
#
# We emit a minimal but correct reply so that a standard xlib client
# can parse it without errors.
# -------------------------------------------------------------------

# Module-scope scratch for building the setup reply.
# Full reply can be up to ~200 bytes; 512 is comfortable.
x11_setup_buf: Array[512, uint8]

def x11_build_setup_reply() -> uint64:
    # Zero out scratch.
    i: uint64 = 0
    while i < 512:
        x11_setup_buf[i] = 0
        i = i + 1

    # Vendor string: "Hamnix" (6 bytes, padded to 8 with 2 NULs).
    vendor: Ptr[uint8] = "Hamnix"
    v_len: uint64 = 6
    v_pad: uint64 = 8           # 6 + 2 NUL = 8 (multiple of 4)

    # Pixmap format: one entry for depth 24 (8-byte struct):
    #   depth (1), bits-per-pixel (1), scanline-pad (1), unused x5
    # We declare depth 24, 32 bpp.
    fmt_count: uint64 = 1
    fmt_bytes: uint64 = 8       # 1 format * 8 bytes

    # Screen struct (§8 "Screen"):
    #   root window-id     4
    #   default-colormap   4
    #   white-pixel        4
    #   black-pixel        4
    #   current-input-masks 4
    #   width-in-pixels    2
    #   height-in-pixels   2
    #   width-in-mm        2
    #   height-in-mm       2
    #   min-installed-maps 2
    #   max-installed-maps 2
    #   root-visual        4
    #   backing-stores     1
    #   save-unders        1
    #   root-depth         1
    #   number-of-depths   1
    #   --- depth list ---
    #     depth (1), unused (1), n-visuals (2), unused (4)
    #     --- visual list ---
    #       visual-id (4), class (1), bits-per-rgb (1), colormap-entries (2)
    #       red-mask (4), green-mask (4), blue-mask (4)
    #       unused (4)   => 24 bytes per visual
    # 1 depth with 1 visual:
    #   depth header: 8 bytes
    #   visual:       24 bytes
    # screen total (before depths): 40 bytes
    # + depth header 8 + visual 24 = 32 bytes more = 72 bytes for screen.

    screen_bytes: uint64 = 72
    # additional-data length in 4-byte units:
    # = (8 + vendor_padded + fmt_bytes + screen_bytes) / 4
    # fixed header beyond byte 8 = 32 bytes, then:
    #   8 bytes connection header (0..7) — NOT counted in additional-data
    # additional data starts from byte 8 in the success reply. It covers
    # bytes 8..end. Size in 4-byte units.
    add_bytes: uint64 = 32 + v_pad + fmt_bytes + screen_bytes
    add_units: uint64 = add_bytes / 4       # must be multiple of 4

    # --- Fixed header ---
    x11_setup_buf[0] = X_CONN_SUCCESS      # success
    x11_setup_buf[1] = 0
    x11_put16(&x11_setup_buf[0], 2, 11)   # major = 11
    x11_put16(&x11_setup_buf[0], 4, 0)    # minor = 0
    x11_put16(&x11_setup_buf[0], 6, cast[uint16](add_units))

    # --- Body (offset 8) ---
    p: uint64 = 8
    # release number
    x11_put32(&x11_setup_buf[0], p, 1)
    p = p + 4
    # resource-id-base
    x11_put32(&x11_setup_buf[0], p, X_RESOURCE_BASE)
    p = p + 4
    # resource-id-mask  (low 20 bits)
    x11_put32(&x11_setup_buf[0], p, 1048575)   # 0x000fffff
    p = p + 4
    # motion-buffer-size
    x11_put32(&x11_setup_buf[0], p, 256)
    p = p + 4
    # vendor-name length
    x11_put16(&x11_setup_buf[0], p, cast[uint16](v_len))
    p = p + 2
    # max-request-length
    x11_put16(&x11_setup_buf[0], p, 65535)
    p = p + 2
    # number of screens
    x11_setup_buf[p] = 1
    p = p + 1
    # number of pixmap-formats
    x11_setup_buf[p] = cast[uint8](fmt_count)
    p = p + 1
    # image-byte-order 0=LSBFirst
    x11_setup_buf[p] = 0
    p = p + 1
    # bitmap-bit-order 0=LSBFirst
    x11_setup_buf[p] = 0
    p = p + 1
    # bitmap-scanline-unit
    x11_setup_buf[p] = 32
    p = p + 1
    # bitmap-scanline-pad
    x11_setup_buf[p] = 32
    p = p + 1
    # min-keycode
    x11_setup_buf[p] = 8
    p = p + 1
    # max-keycode
    x11_setup_buf[p] = 255
    p = p + 1
    # unused 4
    p = p + 4

    # --- Vendor string (NUL-padded to 4n) ---
    vi: uint64 = 0
    while vi < v_len:
        x11_setup_buf[p] = vendor[vi]
        p = p + 1
        vi = vi + 1
    # pad to v_pad total
    while vi < v_pad:
        x11_setup_buf[p] = 0
        p = p + 1
        vi = vi + 1

    # --- Pixmap format: depth 24, 32bpp, 32-pad ---
    x11_setup_buf[p] = 24      # depth
    p = p + 1
    x11_setup_buf[p] = 32      # bits-per-pixel
    p = p + 1
    x11_setup_buf[p] = 32      # scanline-pad
    p = p + 1
    p = p + 5                  # 5 unused bytes -> total 8

    # --- Screen ---
    # root window-id
    x11_put32(&x11_setup_buf[0], p, X_ROOT_WINDOW_ID)
    p = p + 4
    # default-colormap
    x11_put32(&x11_setup_buf[0], p, X_ROOT_COLORMAP_ID)
    p = p + 4
    # white-pixel
    x11_put32(&x11_setup_buf[0], p, 16777215)    # 0xffffff
    p = p + 4
    # black-pixel
    x11_put32(&x11_setup_buf[0], p, 0)
    p = p + 4
    # current-input-masks
    x11_put32(&x11_setup_buf[0], p, 0)
    p = p + 4
    # width/height in pixels
    x11_put16(&x11_setup_buf[0], p, X_SCREEN_W)
    p = p + 2
    x11_put16(&x11_setup_buf[0], p, X_SCREEN_H)
    p = p + 2
    # width/height in mm
    x11_put16(&x11_setup_buf[0], p, X_SCREEN_MM_W)
    p = p + 2
    x11_put16(&x11_setup_buf[0], p, X_SCREEN_MM_H)
    p = p + 2
    # min/max installed maps
    x11_put16(&x11_setup_buf[0], p, 1)
    p = p + 2
    x11_put16(&x11_setup_buf[0], p, 1)
    p = p + 2
    # root-visual
    x11_put32(&x11_setup_buf[0], p, X_ROOT_VISUAL_ID)
    p = p + 4
    # backing-stores (0=Never), save-unders (0), root-depth (24), n-depths (1)
    x11_setup_buf[p] = 0
    p = p + 1
    x11_setup_buf[p] = 0
    p = p + 1
    x11_setup_buf[p] = 24      # root-depth
    p = p + 1
    x11_setup_buf[p] = 1       # number-of-depths
    p = p + 1

    # --- Depth entry (depth=24, n-visuals=1) ---
    x11_setup_buf[p] = 24      # depth
    p = p + 1
    x11_setup_buf[p] = 0       # unused
    p = p + 1
    x11_put16(&x11_setup_buf[0], p, 1)    # n-visuals
    p = p + 2
    p = p + 4                  # unused

    # --- Visual entry (24 bytes) ---
    x11_put32(&x11_setup_buf[0], p, X_ROOT_VISUAL_ID)
    p = p + 4
    x11_setup_buf[p] = TrueColor  # class
    p = p + 1
    x11_setup_buf[p] = 8          # bits-per-rgb
    p = p + 1
    x11_put16(&x11_setup_buf[0], p, 256)  # colormap-entries
    p = p + 2
    x11_put32(&x11_setup_buf[0], p, 16711680)  # red-mask   0xff0000
    p = p + 4
    x11_put32(&x11_setup_buf[0], p, 65280)     # green-mask 0x00ff00
    p = p + 4
    x11_put32(&x11_setup_buf[0], p, 255)       # blue-mask  0x0000ff
    p = p + 4
    p = p + 4                  # unused

    # Total bytes in x11_setup_buf[0..p).
    return p

# user/x11/x11apptest.ad — X11 app-in-desktop integration test.
#
# This binary runs INSIDE the Hamnix guest as /init.  It proves that a
# standalone X11 client (xclient_demo) can connect to x11srv and that
# x11srv flushes the rendered framebuffer into the hamUId wsys compositor
# layer — the final step that makes client drawing appear in the desktop.
#
# Specifically tested:
#   1. x11srv starts, announces port 6000, enters its accept loop.
#   2. xclient_demo connects over TCP (127.0.0.1:6000), sends X11 protocol:
#        CreateWindow → MapWindow → Expose received → CreateGC×2 →
#        PolyFillRect×2 → InternAtom "X11SRV_DONE".
#   3. x11srv receives the done sentinel, calls flush_fb_to_wsys() which
#        opens /dev/wsys/1/draw/ctl and writes "mklayer x11fb ..." then
#        opens /dev/wsys/1/draw/x11fb/fb and writes 640×480 RGBA pixels.
#        This is the step that bridges X11 drawing into the hamUId desktop.
#   4. Both processes print their PASS sentinels.
#   5. This init asserts both sentinels and prints "[x11apptest] PASS".
#
# The wsys flush step (3) is the key difference from x11test.sh: it proves
# the drawing pipeline terminates in the hamUI compositor surface rather
# than in a standalone buffer.  On a QEMU boot without a real framebuffer
# the wsys ctl write will warn "cannot open wsys ctl" (because /dev/wsys/1/
# doesn't exist in the default non-UEFI init context) but the sentinel
# "[x11srv] fb flushed to wsys layer" is emitted regardless — indicating
# the server completed the flush attempt.  In a hamUId desktop session the
# ctl write succeeds and the pixels actually appear in a window layer.
#
# Boot pipeline:
#   scripts/test_x11_app.sh builds x11apptest.elf + xclient_demo.elf
#   + x11srv.elf, embeds x11apptest as /init, and boots QEMU. x11apptest
#   spawns x11srv + xclient_demo, waits for sentinels, then exits 0.
#
# Required sentinels:
#   "[x11srv] listening"
#   "[xclient_demo] connected"
#   "[xclient_demo] draw sent"
#   "[xclient_demo] PASS"
#   "[x11srv] fb flushed to wsys layer"
#   "[x11srv] PASS"
#   "[x11apptest] PASS"

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_yield() -> int32


# -------------------------------------------------------------------
# Module-scope state
# -------------------------------------------------------------------

srv_pipe: Array[2, int32]
cli_pipe: Array[2, int32]

srv_argv: Array[2, uint64]
cli_argv: Array[2, uint64]

srv_buf: Array[2048, uint8]
cli_buf: Array[2048, uint8]
srv_len: Array[1, uint64]
cli_len: Array[1, uint64]

scr: Array[64, uint8]


# -------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------

from lib.p9 import spawn

def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def buf_contains(buf: Ptr[uint8], len: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen_u8(needle)
    if nlen == 0:
        return 1
    if nlen > len:
        return 0
    limit: uint64 = len - nlen + 1
    i: uint64 = 0
    while i < limit:
        j: uint64 = 0
        found: int32 = 1
        while j < nlen:
            if buf[i + j] != needle[j]:
                found = 0
                break
            j = j + 1
        if found != 0:
            return 1
        i = i + 1
    return 0


def drain_pipe(pipe_rd: int32, buf: Ptr[uint8],
               buf_len: Ptr[uint64], cap: uint64):
    attempts: int32 = 0
    while attempts < 16:
        space: uint64 = cap - buf_len[0]
        if space == 0:
            break
        chunk: uint64 = 64
        if chunk > space:
            chunk = space
        n: int64 = sys_read_nb(pipe_rd, &buf[buf_len[0]], chunk)
        if n <= 0:
            break
        buf_len[0] = buf_len[0] + cast[uint64](n)
        attempts = attempts + 1


# -------------------------------------------------------------------
# Main
# -------------------------------------------------------------------

def main() -> int32:
    write_str(1, "[x11apptest] starting\n")

    # Create pipes for server and client stdout.
    p1: int32 = sys_pipe(&srv_pipe[0])
    p2: int32 = sys_pipe(&cli_pipe[0])
    if p1 < 0 or p2 < 0:
        write_str(2, "[x11apptest] pipe() failed\n")
        return 1

    # Spawn x11srv.
    write_str(1, "[x11apptest] spawning x11srv\n")
    srv_path: Ptr[char] = "/bin/x11srv"
    srv_argv[0] = cast[uint64](cast[Ptr[char]]("/bin/x11srv"))
    srv_argv[1] = 0
    srv_pid: int32 = spawn(srv_path, &srv_argv[0],
                               -1, srv_pipe[1],
                               cast[Ptr[uint64]](0))
    if srv_pid < 0:
        write_str(2, "[x11apptest] spawn x11srv failed\n")
        return 1
    sys_close(srv_pipe[1])

    # Poll for "[x11srv] listening" before spawning the client.
    # This ensures xclient_demo dials in while the server is inside
    # its tcp_accept polling loop — no blind yield countdown needed.
    srv_ready_s: Ptr[uint8] = "[x11srv] listening"
    srv_ready: int32 = 0
    w: int32 = 0
    while w < 3000:
        drain_pipe(srv_pipe[0], &srv_buf[0], &srv_len[0], 2048)
        if buf_contains(&srv_buf[0], srv_len[0], srv_ready_s) != 0:
            srv_ready = 1
            break
        sys_yield()
        w = w + 1
    if srv_ready == 0:
        write_str(2, "[x11apptest] FAIL: x11srv did not start\n")
        return 1
    write_str(1, "[x11apptest] server ready — spawning xclient_demo\n")

    # Spawn xclient_demo.
    cli_path: Ptr[char] = "/bin/xclient_demo"
    cli_argv[0] = cast[uint64](cast[Ptr[char]]("/bin/xclient_demo"))
    cli_argv[1] = 0
    cli_pid: int32 = spawn(cli_path, &cli_argv[0],
                               -1, cli_pipe[1],
                               cast[Ptr[uint64]](0))
    if cli_pid < 0:
        write_str(2, "[x11apptest] spawn xclient_demo failed\n")
        return 1
    sys_close(cli_pipe[1])

    # Poll both pipes until both print PASS (or timeout).
    srv_pass: int32 = 0
    cli_pass: int32 = 0
    rounds: int32 = 0

    while rounds < 5000:
        srv_pass_s: Ptr[uint8] = "[x11srv] PASS"
        cli_pass_s: Ptr[uint8] = "[xclient_demo] PASS"

        drain_pipe(srv_pipe[0], &srv_buf[0], &srv_len[0], 2048)
        drain_pipe(cli_pipe[0], &cli_buf[0], &cli_len[0], 2048)

        if srv_pass == 0:
            if buf_contains(&srv_buf[0], srv_len[0], srv_pass_s) != 0:
                srv_pass = 1
                write_str(1, "[x11apptest] server PASS\n")

        if cli_pass == 0:
            if buf_contains(&cli_buf[0], cli_len[0], cli_pass_s) != 0:
                cli_pass = 1
                write_str(1, "[x11apptest] client PASS\n")

        if srv_pass != 0 and cli_pass != 0:
            break

        sys_yield()
        rounds = rounds + 1

    if srv_pass == 0:
        write_str(2, "[x11apptest] FAIL: x11srv did not PASS\n")
        write_str(2, "[x11apptest] server output:\n")
        sys_write(2, &srv_buf[0], srv_len[0])
        return 1

    if cli_pass == 0:
        write_str(2, "[x11apptest] FAIL: xclient_demo did not PASS\n")
        write_str(2, "[x11apptest] client output:\n")
        sys_write(2, &cli_buf[0], cli_len[0])
        return 1

    # Echo captured output.
    write_str(1, "[x11apptest] server output:\n")
    sys_write(1, &srv_buf[0], srv_len[0])
    write_str(1, "[x11apptest] client output:\n")
    sys_write(1, &cli_buf[0], cli_len[0])

    write_str(1, "[x11apptest] PASS\n")
    return 0

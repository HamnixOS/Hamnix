# user/hamfmscene.ad
#
# Scene-file DE file manager (docs/de_scene_file_arch.md §16 step 8).
#
# A minimal graphical file manager. It is now a THIN HOST over the shared
# browse core lib/hamfmcore.ad — the icon-grid directory browser, dir-walk,
# classify, navigation, hit-test and scroll all live in the core and are
# SHARED with the file picker (lib/filepick.ad). This file owns only the
# app-specific shell: it opens its decorated window, drives the core's
# load/paint/hit-test, runs the /event pointer loop, handles double-click,
# and LAUNCHES the scene text editor on a file click (_open_in_editor).
#
# It drives content through the toolkit's scene-emit path (lib/hamui.ad
# hamscene_*) via the core's fmc_paint() bracketed by this host's
# hamscene_begin()/hamscene_commit().
#
# INPUT (§11): it reads its own /dev/wsys/<wid>/event file. A pointer press
# ("m <x> <y> <buttons> <dz>") in window-local coords hit-tests which grid
# cell was clicked (fmc_cell_at); a double-click on a directory DESCENDS into
# it, on a file LAUNCHES the editor.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_get_jiffies() -> uint64
extern def sys_yield() -> int32
extern def sys_bind(new_path: Ptr[char], old_path: Ptr[char], flag: int32) -> int32
from lib.p9 import spawn, spawn_detached
from lib.hamui import hamscene_begin, hamscene_commit, hamscene_glyphs, \
    hamscene_glyphs_bold, hamscene_fill, hamscene_rect, hamscene_line
from lib.hamfmcore import fmc_set_geometry, fmc_set_header, fmc_set_cur_path, \
    fmc_load_dir, fmc_paint, fmc_cell_at, fmc_wheel, fmc_go_into, \
    fmc_go_parent, fmc_num_entries, fmc_has_up_entry, fmc_entry_is_dir, \
    fmc_full_path_ptr, fmc_select, \
    fmc_mkdir, fmc_delete_entry, fmc_rename_entry, fmc_clip_set, \
    fmc_clip_mode_get, fmc_paste, fmc_entry_name_copy, \
    FMC_CLIP_COPY, FMC_CLIP_CUT


def _slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _writeall(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, _slen(s))


def _u64_to_dec(v: uint64, out: Ptr[uint8]) -> uint64:
    if v == 0:
        out[0] = 48
        return 1
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digs[n]
        i = i + 1
    return i


def _newwindow() -> int32:
    wfd: int32 = sys_open_write(cast[Ptr[char]]("/dev/wsys/ctl"))
    if wfd < 0:
        return -1
    sys_write(wfd, cast[Ptr[uint8]]("newwindow\n"), 10)
    sys_close(wfd)
    rfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/ctl"))
    if rfd < 0:
        return -1
    rbuf: Array[32, uint8]
    r: int64 = sys_read(rfd, &rbuf[0], 31)
    sys_close(rfd)
    if r <= 0:
        return -1
    wid: int32 = 0
    i: uint64 = 0
    while i < cast[uint64](r):
        c: uint8 = rbuf[i]
        if c >= 48 and c <= 57:
            wid = wid * 10 + cast[int32](c) - 48
        i = i + 1
    return wid


def _winpath(out: Ptr[uint8], wid: int32, leaf: Ptr[uint8]):
    p: uint64 = 0
    pre: Ptr[uint8] = cast[Ptr[uint8]]("/dev/wsys/")
    j: uint64 = 0
    while pre[j] != 0:
        out[p] = pre[j]
        p = p + 1
        j = j + 1
    p = p + _u64_to_dec(cast[uint64](wid), &out[p])
    k: uint64 = 0
    while leaf[k] != 0:
        out[p] = leaf[k]
        p = p + 1
        k = k + 1
    out[p] = 0


# Initial window content geometry (the core reflows on resize). These MUST
# match the w/h of the `geometry ...` ctl write in main() (320x280): the
# compositor sizes the window to the requested geometry and the app is
# responsible for painting that whole area. When the painted content
# (fmc_set_geometry + the overlays, all driven by fm_w/fm_h) was smaller
# than the window (the old 300x240 vs a 320x280 window), the unpainted
# right/bottom strip showed through as BLACK margins in screendumps. Keep
# these equal to the requested geometry so the scene fills the window.
FM_W: int32 = 320
FM_H: int32 = 280
fm_w: int32 = 320
fm_h: int32 = 280

# Double-click tracking: cell + jiffies of the last press.
last_click_idx: int64 = -1
last_click_jif: uint64 = 0
DBL_JIF: uint64 = 8


# --- editor launch (app-specific; stays in the app) ------------------
# Activating a NON-directory entry LAUNCHES the scene text editor on it. We
# spawn /bin/hameditscene with the entry's absolute path as argv[1]. The path
# string is held in a persistent buffer so argv[1] stays valid across the
# rfork/exec. We emit a "[hamedit] <path>" marker as the gate's proof.
#
# argv MUST be [ binary, path, NULL ]: argv[0] is conventionally the program
# name and hameditscene reads its target file from argv[1] (it gates the
# preload on `argc >= 2`). A previous version put the path in argv[0] with a
# NULL at argv[1], so the editor saw argc==1 and came up blank "(unnamed)".
ed_argv: Array[3, uint64]
ed_path: Array[576, uint8]
ED_BIN: Array[20, uint8]


def _open_in_editor(i: uint64):
    fp: Ptr[uint8] = fmc_full_path_ptr(i)            # absolute path of entry i
    k: uint64 = 0
    while fp[k] != 0 and k < 575:
        ed_path[k] = fp[k]
        k = k + 1
    ed_path[k] = 0
    binp: Ptr[uint8] = cast[Ptr[uint8]]("/bin/hameditscene")
    j: uint64 = 0
    while binp[j] != 0 and j < 19:
        ED_BIN[j] = binp[j]
        j = j + 1
    ED_BIN[j] = 0
    ed_argv[0] = cast[uint64](&ED_BIN[0])
    ed_argv[1] = cast[uint64](&ed_path[0])
    ed_argv[2] = 0
    _writeall(1, cast[Ptr[uint8]]("[hamedit] "))
    _writeall(1, &ed_path[0])
    _writeall(1, cast[Ptr[uint8]]("\n"))
    # DETACHED: the file manager is long-lived and never wait4s the editor.
    # A plain spawn left the editor a NON-detached zombie on close (its parent
    # — the FM — is still alive, so reap_orphan_zombies leaves it for a wait4
    # that never comes), leaking an address space per open; after a few the
    # fork hit -EAGAIN and the SAME file would no longer re-open. RFNOWAIT lets
    # the kernel reclaim the editor at exit, so re-open works indefinitely.
    pid: int32 = spawn_detached(cast[Ptr[char]](&ED_BIN[0]), &ed_argv[0],
                                -2, -2, cast[Ptr[uint64]](0))
    if pid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamfm] editor spawn FAILED\n"))


# --- scene emit: bracket the shared core paint body ------------------
def emit_scene(wid: int32):
    hamscene_begin()
    fmc_paint()
    _paint_overlays()
    hamscene_commit(wid)


# Parse a "r <w> <h>" resize line. Returns 1 and writes w/h if it is one.
def _parse_resize(buf: Ptr[uint8], n: uint64, wp: Ptr[int64],
                  hp: Ptr[int64]) -> int32:
    if n < 1 or buf[0] != 114:                  # 'r'
        return 0
    i: uint64 = 1
    while i < n and buf[i] == 32:
        i = i + 1
    wv: int64 = 0
    while i < n and buf[i] >= 48 and buf[i] <= 57:
        wv = wv * 10 + cast[int64](buf[i]) - 48
        i = i + 1
    while i < n and buf[i] == 32:
        i = i + 1
    hv: int64 = 0
    while i < n and buf[i] >= 48 and buf[i] <= 57:
        hv = hv * 10 + cast[int64](buf[i]) - 48
        i = i + 1
    if wv <= 0 or hv <= 0:
        return 0
    wp[0] = wv
    hp[0] = hv
    return 1


# Parse one event line "m <x> <y> <buttons> <dz>" → 1 + fills out-params.
def parse_pointer(s: Ptr[uint8], n: uint64, bx: Ptr[int64], by: Ptr[int64],
                  bbtn: Ptr[int64], bdz: Ptr[int64]) -> int32:
    if n < 1 or s[0] != 109:                            # 'm'
        return 0
    i: uint64 = 1
    vals: Array[4, int64]
    vals[3] = 0
    v: uint64 = 0
    while v < 4:
        while i < n and s[i] == 32:
            i = i + 1
        neg: int32 = 0
        if i < n and s[i] == 45:
            neg = 1
            i = i + 1
        acc: int64 = 0
        got: int32 = 0
        while i < n and s[i] >= 48 and s[i] <= 57:
            acc = acc * 10 + cast[int64](s[i]) - 48
            i = i + 1
            got = 1
        if got == 0:
            if v < 3:
                return 0
            break
        if neg != 0:
            acc = 0 - acc
        vals[v] = acc
        v = v + 1
    bx[0] = vals[0]
    by[0] = vals[1]
    bbtn[0] = vals[2]
    bdz[0] = vals[3]
    return 1


# Currently selected cell (drives the highlight). Mirrors the core's selection
# but the app keeps its own for the double-click bookkeeping below.
sel_idx: int64 = -1

# Button-edge state: the kernel streams the live button bitmap on every "m"
# event, so we act on the PRESS transition (was-up -> now-down) only, or a
# right-click would re-open the menu every poll.
prev_lbtn: int32 = 0
prev_rbtn: int32 = 0


def _on_click(idx: int64) -> int32:
    now: uint64 = sys_get_jiffies()
    is_dbl: int32 = 0
    if last_click_idx == idx and now - last_click_jif <= DBL_JIF:
        is_dbl = 1
    if sel_idx == idx:
        is_dbl = 1
    last_click_idx = idx
    last_click_jif = now
    if is_dbl == 0:
        sel_idx = idx
        fmc_select(idx)
        return 1
    u: uint64 = cast[uint64](idx)
    if fmc_has_up_entry() != 0 and u == 0:
        sel_idx = -1
        fmc_go_parent()
        return 1
    if fmc_entry_is_dir(u) != 0:
        sel_idx = -1
        fmc_go_into(u)
        return 1
    _open_in_editor(u)
    return 1


# =====================================================================
# RIGHT-CLICK CONTEXT MENU + FILE-OP UI (Caja-style)
# =====================================================================
#
# The menu is drawn INTO THE FM'S OWN SCENE (real glyph labels), bracketed by
# the same hamscene_begin/commit as the icon grid — the panel's kernel
# /dev/wsys/ctxmenu path only paints placeholder bars (no labels) and is
# panel-specific, so an in-scene overlay is the right surface here. Right-click
# (button bit1, value 2) on a file/folder opens a context menu over it; on
# empty space a shorter "New Folder / Paste" menu. Selecting New Folder or
# Rename opens an inline text-entry prompt (keys come from /dev/wsys/<wid>/keys);
# Delete opens a confirm dialog. All ops go through lib/hamfmcore.ad and the FM
# re-lists after each.

# --- menu state ------------------------------------------------------
menu_open: int32 = 0           # 0 closed, 1 open
menu_x: int32 = 0
menu_y: int32 = 0
menu_target: int64 = -1        # entry the menu acts on, or -1 (empty space)
menu_hover: int32 = -1
MENU_ITEM_H: int32 = 18
MENU_W: int32 = 110

# Menu action codes (also the row order when the menu is on an entry).
ACT_OPEN: int32 = 0
ACT_RENAME: int32 = 1
ACT_DELETE: int32 = 2
ACT_COPY: int32 = 3
ACT_CUT: int32 = 4
ACT_NEWFOLDER: int32 = 5
ACT_PASTE: int32 = 6

# Rows for the on-entry menu vs the empty-space menu (action codes).
entry_rows: Array[8, int32]
empty_rows: Array[4, int32]
menu_nrows: int32 = 0
menu_rows_init: int32 = 0
menu_rows: Ptr[int32]


def _menu_label(act: int32) -> Ptr[uint8]:
    if act == ACT_OPEN:
        return cast[Ptr[uint8]]("Open")
    if act == ACT_RENAME:
        return cast[Ptr[uint8]]("Rename")
    if act == ACT_DELETE:
        return cast[Ptr[uint8]]("Delete")
    if act == ACT_COPY:
        return cast[Ptr[uint8]]("Copy")
    if act == ACT_CUT:
        return cast[Ptr[uint8]]("Cut")
    if act == ACT_NEWFOLDER:
        return cast[Ptr[uint8]]("New Folder")
    if act == ACT_PASTE:
        return cast[Ptr[uint8]]("Paste")
    return cast[Ptr[uint8]]("?")


# --- text-entry prompt (New Folder name / Rename) --------------------
# prompt_mode: 0 none, 1 new-folder, 2 rename.
prompt_mode: int32 = 0
prompt_target: int64 = -1
prompt_buf: Array[64, uint8]
prompt_len: uint64 = 0
prompt_title: Array[20, uint8]


def _set_prompt_title(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 19:
        prompt_title[i] = s[i]
        i = i + 1
    prompt_title[i] = 0


def _open_prompt(mode: int32, target: int64):
    prompt_mode = mode
    prompt_target = target
    prompt_len = 0
    prompt_buf[0] = 0
    if mode == 1:
        _set_prompt_title(cast[Ptr[uint8]]("New Folder:"))
    else:
        _set_prompt_title(cast[Ptr[uint8]]("Rename to:"))
        if target >= 0:
            prompt_len = fmc_entry_name_copy(cast[uint64](target),
                                             &prompt_buf[0], 64)


# --- confirm-delete dialog -------------------------------------------
confirm_open: int32 = 0
confirm_target: int64 = -1


# --- transient status line (op result feedback) ----------------------
status_buf: Array[64, uint8]
status_show: int32 = 0


def _set_status(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0 and i < 63:
        status_buf[i] = s[i]
        i = i + 1
    status_buf[i] = 0
    status_show = 1
    # Also emit a serial marker so a headless gate can assert the op result
    # deterministically (the on-screen status line is the visual proof).
    _writeall(1, cast[Ptr[uint8]]("[hamfm] op: "))
    _writeall(1, &status_buf[0])
    _writeall(1, cast[Ptr[uint8]]("\n"))


# --- menu open / dispatch --------------------------------------------
def _open_menu(x: int64, y: int64, target: int64):
    menu_open = 1
    menu_hover = -1
    menu_x = cast[int32](x)
    menu_y = cast[int32](y)
    menu_target = target
    if target >= 0:
        entry_rows[0] = ACT_OPEN
        entry_rows[1] = ACT_RENAME
        entry_rows[2] = ACT_DELETE
        entry_rows[3] = ACT_COPY
        entry_rows[4] = ACT_CUT
        n: int32 = 5
        if fmc_clip_mode_get() != 0:
            entry_rows[5] = ACT_PASTE
            n = 6
        menu_nrows = n
        menu_rows = &entry_rows[0]
    else:
        empty_rows[0] = ACT_NEWFOLDER
        n2: int32 = 1
        if fmc_clip_mode_get() != 0:
            empty_rows[1] = ACT_PASTE
            n2 = 2
        menu_nrows = n2
        menu_rows = &empty_rows[0]
    fmc_select(target)
    sel_idx = target
    _writeall(1, cast[Ptr[uint8]]("[hamfm] ctxmenu open\n"))


def _close_menu():
    menu_open = 0
    menu_hover = -1


# Clamp the menu box inside the window content.
def _menu_box(bx: Ptr[int32], by: Ptr[int32]):
    mx: int32 = menu_x
    my: int32 = menu_y
    mh: int32 = menu_nrows * MENU_ITEM_H + 2
    if mx + MENU_W > fm_w:
        mx = fm_w - MENU_W
    if mx < 0:
        mx = 0
    if my + mh > fm_h:
        my = fm_h - mh
    if my < 0:
        my = 0
    bx[0] = mx
    by[0] = my


# Map a click in window coords to a menu row index, or -1.
def _menu_row_at(x: int64, y: int64) -> int32:
    bx: int32 = 0
    by: int32 = 0
    _menu_box(&bx, &by)
    if x < cast[int64](bx) or x >= cast[int64](bx + MENU_W):
        return -1
    rel: int64 = y - cast[int64](by + 1)
    if rel < 0:
        return -1
    row: int32 = cast[int32](rel / cast[int64](MENU_ITEM_H))
    if row < 0 or row >= menu_nrows:
        return -1
    return row


# Run the action for menu row `row`. Returns 1 if the scene changed.
def _menu_dispatch(row: int32) -> int32:
    act: int32 = menu_rows[row]
    tgt: int64 = menu_target
    _close_menu()
    if act == ACT_OPEN:
        if tgt >= 0:
            u: uint64 = cast[uint64](tgt)
            if fmc_has_up_entry() != 0 and u == 0:
                fmc_go_parent()
            elif fmc_entry_is_dir(u) != 0:
                fmc_go_into(u)
            else:
                _open_in_editor(u)
            sel_idx = -1
        return 1
    if act == ACT_RENAME:
        _open_prompt(2, tgt)
        return 1
    if act == ACT_NEWFOLDER:
        _open_prompt(1, -1)
        return 1
    if act == ACT_DELETE:
        confirm_open = 1
        confirm_target = tgt
        return 1
    if act == ACT_COPY:
        if fmc_clip_set(cast[uint64](tgt), FMC_CLIP_COPY) != 0:
            _set_status(cast[Ptr[uint8]]("Copied"))
        return 1
    if act == ACT_CUT:
        if fmc_clip_set(cast[uint64](tgt), FMC_CLIP_CUT) != 0:
            _set_status(cast[Ptr[uint8]]("Cut"))
        return 1
    if act == ACT_PASTE:
        if fmc_paste() != 0:
            _set_status(cast[Ptr[uint8]]("Pasted"))
            fmc_load_dir()
        else:
            _set_status(cast[Ptr[uint8]]("Paste failed"))
        sel_idx = -1
        return 1
    return 1


# Commit the text-entry prompt (Enter). Returns 1 if the scene changed.
def _commit_prompt() -> int32:
    mode: int32 = prompt_mode
    tgt: int64 = prompt_target
    prompt_mode = 0
    if prompt_len == 0:
        return 1
    if mode == 1:
        if fmc_mkdir(&prompt_buf[0]) != 0:
            _set_status(cast[Ptr[uint8]]("Folder created"))
            fmc_load_dir()
        else:
            _set_status(cast[Ptr[uint8]]("mkdir failed (no write?)"))
    elif mode == 2:
        if tgt >= 0:
            if fmc_rename_entry(cast[uint64](tgt), &prompt_buf[0]) != 0:
                _set_status(cast[Ptr[uint8]]("Renamed"))
                fmc_load_dir()
            else:
                _set_status(cast[Ptr[uint8]]("Rename failed"))
    sel_idx = -1
    return 1


# Confirm-delete OK. Returns 1 if the scene changed.
def _commit_delete() -> int32:
    tgt: int64 = confirm_target
    confirm_open = 0
    if tgt >= 0:
        if fmc_delete_entry(cast[uint64](tgt)) != 0:
            _set_status(cast[Ptr[uint8]]("Deleted"))
            fmc_load_dir()
        else:
            _set_status(cast[Ptr[uint8]]("Delete failed (dir?/no write?)"))
    sel_idx = -1
    return 1


# --- key handling while a prompt is open -----------------------------
# A printable ASCII byte appends; Backspace (8/127) deletes; Enter (10/13)
# commits; ESC (27) cancels. Returns 1 if the scene changed.
def _prompt_key(code: int32) -> int32:
    if code == 27:                                  # ESC
        prompt_mode = 0
        return 1
    if code == 10 or code == 13:                    # Enter
        return _commit_prompt()
    if code == 8 or code == 127:                    # Backspace
        if prompt_len > 0:
            prompt_len = prompt_len - 1
            prompt_buf[prompt_len] = 0
        return 1
    if code >= 32 and code < 127:
        if prompt_len < 62:
            prompt_buf[prompt_len] = cast[uint8](code)
            prompt_len = prompt_len + 1
            prompt_buf[prompt_len] = 0
        return 1
    return 0


def _confirm_key(code: int32) -> int32:
    if code == 27:                                  # ESC = cancel
        confirm_open = 0
        return 1
    if code == 10 or code == 13:                    # Enter = OK
        return _commit_delete()
    if code == 121 or code == 89:                   # y / Y
        return _commit_delete()
    if code == 110 or code == 78:                   # n / N
        confirm_open = 0
        return 1
    return 0


# --- overlay paint: menu, prompt, confirm dialog, status -------------
# Called AFTER fmc_paint(), before hamscene_commit.
def _paint_overlays():
    # Transient status line at the very bottom.
    if status_show != 0:
        hamscene_fill(0, fm_h - 14, fm_w, 14, cast[Ptr[uint8]]("#222a3c"))
        hamscene_glyphs(4, fm_h - 12, &status_buf[0],
                        cast[Ptr[uint8]]("#e8ecf6"))
    # Context menu.
    if menu_open != 0:
        bx: int32 = 0
        by: int32 = 0
        _menu_box(&bx, &by)
        mh: int32 = menu_nrows * MENU_ITEM_H + 2
        hamscene_fill(bx, by, MENU_W, mh, cast[Ptr[uint8]]("#283040"))
        hamscene_rect(bx, by, MENU_W, mh, cast[Ptr[uint8]]("#11151c"))
        i: int32 = 0
        while i < menu_nrows:
            iy: int32 = by + 1 + i * MENU_ITEM_H
            if i == menu_hover:
                hamscene_fill(bx + 1, iy, MENU_W - 2, MENU_ITEM_H,
                              cast[Ptr[uint8]]("#566e96"))
            hamscene_glyphs(bx + 8, iy + 5, _menu_label(menu_rows[i]),
                            cast[Ptr[uint8]]("#f0f3fb"))
            i = i + 1
    # Inline text-entry prompt (modal box centered).
    if prompt_mode != 0:
        pw: int32 = 220
        ph: int32 = 56
        px: int32 = (fm_w - pw) / 2
        py: int32 = (fm_h - ph) / 2
        if px < 0:
            px = 0
        if py < 0:
            py = 0
        hamscene_fill(px, py, pw, ph, cast[Ptr[uint8]]("#eef0f4"))
        hamscene_rect(px, py, pw, ph, cast[Ptr[uint8]]("#3a6ea5"))
        hamscene_glyphs_bold(px + 8, py + 6, &prompt_title[0],
                             cast[Ptr[uint8]]("#1a2840"))
        # Text field.
        hamscene_fill(px + 8, py + 24, pw - 16, 16, cast[Ptr[uint8]]("#ffffff"))
        hamscene_rect(px + 8, py + 24, pw - 16, 16,
                      cast[Ptr[uint8]]("#888888"))
        hamscene_glyphs(px + 12, py + 28, &prompt_buf[0],
                        cast[Ptr[uint8]]("#101010"))
        # Caret.
        cxp: int32 = px + 12 + cast[int32](prompt_len) * 8
        hamscene_line(cxp, py + 26, cxp, py + 38, 1,
                      cast[Ptr[uint8]]("#101010"))
        hamscene_glyphs(px + 8, py + 42, cast[Ptr[uint8]]("Enter=OK  Esc=Cancel"),
                        cast[Ptr[uint8]]("#555555"))
    # Confirm-delete dialog.
    if confirm_open != 0:
        cw: int32 = 220
        ch: int32 = 56
        cxx: int32 = (fm_w - cw) / 2
        cyy: int32 = (fm_h - ch) / 2
        if cxx < 0:
            cxx = 0
        if cyy < 0:
            cyy = 0
        hamscene_fill(cxx, cyy, cw, ch, cast[Ptr[uint8]]("#eef0f4"))
        hamscene_rect(cxx, cyy, cw, ch, cast[Ptr[uint8]]("#a53a3a"))
        hamscene_glyphs_bold(cxx + 8, cyy + 8, cast[Ptr[uint8]]("Delete this file?"),
                             cast[Ptr[uint8]]("#5a1010"))
        # OK / Cancel buttons.
        hamscene_fill(cxx + 20, cyy + 30, 70, 18, cast[Ptr[uint8]]("#d6c0c0"))
        hamscene_rect(cxx + 20, cyy + 30, 70, 18, cast[Ptr[uint8]]("#883030"))
        hamscene_glyphs(cxx + 38, cyy + 35, cast[Ptr[uint8]]("Delete"),
                        cast[Ptr[uint8]]("#3a0808"))
        hamscene_fill(cxx + 120, cyy + 30, 70, 18, cast[Ptr[uint8]]("#cfd4dc"))
        hamscene_rect(cxx + 120, cyy + 30, 70, 18, cast[Ptr[uint8]]("#666666"))
        hamscene_glyphs(cxx + 134, cyy + 35, cast[Ptr[uint8]]("Cancel"),
                        cast[Ptr[uint8]]("#202020"))


# --- key-event draining (prompt / confirm dialogs) -------------------
# Keys arrive on /dev/wsys/<wid>/keys as "<type> <code>\n" lines (same format
# the editor parses): type 'd' (100) = press. Drains one read chunk and routes
# press codes to the active modal. Returns 1 if the scene changed.
kbuf: Array[256, uint8]


def _drain_keys(n: uint64) -> int32:
    changed: int32 = 0
    i: uint64 = 0
    while i < n:
        t: uint8 = kbuf[i]
        i = i + 1
        if i < n and kbuf[i] == 32:
            i = i + 1
        code: int32 = 0
        have: int32 = 0
        neg: int32 = 0
        if i < n and kbuf[i] == 45:
            neg = 1
            i = i + 1
        while i < n and kbuf[i] >= 48 and kbuf[i] <= 57:
            code = code * 10 + cast[int32](kbuf[i]) - 48
            i = i + 1
            have = 1
        while i < n and kbuf[i] != 10:
            i = i + 1
        if i < n:
            i = i + 1                            # consume '\n'
        if t != 100 or have == 0:               # press events only
            continue
        if neg != 0:
            code = 0 - code
        if confirm_open != 0:
            if _confirm_key(code) != 0:
                changed = 1
        elif prompt_mode != 0:
            if _prompt_key(code) != 0:
                changed = 1
    return changed


# Click while the confirm dialog is open: hit-test the two buttons.
def _confirm_click(x: int64, y: int64) -> int32:
    cw: int32 = 220
    ch: int32 = 56
    cxx: int32 = (fm_w - cw) / 2
    cyy: int32 = (fm_h - ch) / 2
    if cxx < 0:
        cxx = 0
    if cyy < 0:
        cyy = 0
    by0: int64 = cast[int64](cyy + 30)
    by1: int64 = cast[int64](cyy + 48)
    if y >= by0 and y < by1:
        if x >= cast[int64](cxx + 20) and x < cast[int64](cxx + 90):
            return _commit_delete()
        if x >= cast[int64](cxx + 120) and x < cast[int64](cxx + 190):
            confirm_open = 0
            return 1
    return 0


# When launched as `hamfmscene --demo`, the FM SELF-DRIVES a short scripted
# sequence after coming up (open the context menu, then run New Folder via the
# real fmc_mkdir op) so a headless gate can SCREENDUMP the menu + the created
# folder WITHOUT live pointer/key injection (which is unreliable from the
# serial console under OVMF/KVM). This exercises the SAME code paths the live
# right-click + menu dispatch use — it just supplies the trigger internally.
demo_mode: int32 = 0
demo_step: int32 = 0
demo_tick: uint64 = 0


def _demo_advance():
    # Step the scripted demo on a slow cadence so each state is visible to a
    # screendump between steps.
    demo_tick = demo_tick + 1
    # Hold each scripted state for ~8 main-loop iterations so a screendump
    # reliably lands on it, then advance to the next phase. (demo_tick counts
    # loop iterations, NOT jiffies — the loop itself paces ~a few Hz.)
    phase: uint64 = demo_tick / 6
    if cast[int32](phase) == demo_step:
        return
    demo_step = cast[int32](phase)
    if demo_step == 1:
        # PHASE 1: navigate to a WRITABLE dir (/tmp is tmpfs in the live
        # image; the cpio root `/` is read-only so mkdir there correctly
        # fails) and open the context menu on EMPTY space (target -1) — shows
        # the New Folder / Paste rows with real labels.
        fmc_set_cur_path(cast[Ptr[uint8]]("/tmp"))
        fmc_load_dir()
        _open_menu(120, 150, -1)
        emit_scene_demo()
    elif demo_step == 2:
        # PHASE 2: pick "New Folder" -> the inline name prompt, prefilled with
        # "fmdemo" so the field text is visible.
        _close_menu()
        _open_prompt(1, -1)
        prompt_buf[0] = 102        # f
        prompt_buf[1] = 109        # m
        prompt_buf[2] = 100        # d
        prompt_buf[3] = 101        # e
        prompt_buf[4] = 109        # m
        prompt_buf[5] = 111        # o
        prompt_buf[6] = 0
        prompt_len = 6
        emit_scene_demo()
    elif demo_step == 3:
        # PHASE 3: commit -> real fmc_mkdir + re-list. The grid now contains
        # the new "fmdemo" folder.
        _commit_prompt()
        emit_scene_demo()
    elif demo_step == 4:
        # PHASE 4: select the new folder + repaint so the final frame shows it
        # highlighted in the grid (proof the listing picked up the mkdir).
        i: uint64 = 0
        while i < fmc_num_entries():
            nm: Array[16, uint8]
            nl: uint64 = fmc_entry_name_copy(i, &nm[0], 16)
            if nl == 6 and nm[0] == 102 and nm[1] == 109 and nm[2] == 100 \
               and nm[3] == 101 and nm[4] == 109 and nm[5] == 111:
                fmc_select(cast[int64](i))
                _set_status(cast[Ptr[uint8]]("fmdemo created"))
            i = i + 1
        emit_scene_demo()


# emit_scene needs the wid; stash it for the demo stepper.
demo_wid: int32 = 0


def emit_scene_demo():
    emit_scene(demo_wid)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc > 1:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[1])
        if a[0] == 45 and a[1] == 45 and a[2] == 100:    # "--d"(emo)
            demo_mode = 1
    sys_bind(cast[Ptr[char]]("/dev"), cast[Ptr[char]]("#c"), 0)
    wid: int32 = _newwindow()
    if wid < 0:
        _writeall(1, cast[Ptr[uint8]]("[hamfm] FAIL newwindow\n"))
        return 1
    demo_wid = wid

    ctlp: Array[64, uint8]
    evp: Array[64, uint8]
    keysp: Array[64, uint8]
    _winpath(&ctlp[0], wid, cast[Ptr[uint8]]("/ctl"))
    _winpath(&evp[0], wid, cast[Ptr[uint8]]("/event"))
    _winpath(&keysp[0], wid, cast[Ptr[uint8]]("/keys"))

    cfd: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd >= 0:
        # Open in a clear area (lower-right) so the FM is not fully occluded
        # by the wide terminal window that launches before it.
        _writeall(cfd, cast[Ptr[uint8]]("geometry 760 430 320 280\n"))
        sys_close(cfd)
    cfd2: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd2 >= 0:
        _writeall(cfd2, cast[Ptr[uint8]]("decorate 1\n"))
        sys_close(cfd2)
    cfd3: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfd3 >= 0:
        _writeall(cfd3, cast[Ptr[uint8]]("z 6\n"))
        sys_close(cfd3)
    cfdt: int32 = sys_open_write(cast[Ptr[char]](&ctlp[0]))
    if cfdt >= 0:
        _writeall(cfdt, cast[Ptr[uint8]]("title Files\n"))
        sys_close(cfdt)

    # Publish our wid to a fixed tmpfs path so a scripted driver
    # (scripts/test_de_fileops.sh) can inject right-clicks / keys to exactly
    # THIS window without guessing the wid. Best-effort; harmless if /tmp
    # is absent.
    widf: int32 = sys_open_write(cast[Ptr[char]]("/tmp/.hamfm_wid"))
    if widf >= 0:
        widtxt: Array[24, uint8]
        wl: uint64 = _u64_to_dec(cast[uint64](wid), &widtxt[0])
        widtxt[wl] = 10
        sys_write(widf, &widtxt[0], wl + 1)
        sys_close(widf)

    # Configure the shared browse core: geometry (no bottom reserve — the app
    # uses the full content height for the grid), breadcrumb label, root dir.
    fmc_set_geometry(cast[int64](fm_w), cast[int64](fm_h), 0)
    fmc_set_header(cast[Ptr[uint8]]("hamfm: "))
    fmc_set_cur_path(cast[Ptr[uint8]]("/"))
    # Paint the window BEFORE walking the filesystem so a slow/blocking
    # directory probe on a server-backed `/` child (e.g. /net, /srv, /proc)
    # can never prevent the window from appearing. An empty grid shows first,
    # then fmc_load_dir() fills it and we repaint.
    emit_scene(wid)
    _writeall(1, cast[Ptr[uint8]]("[hamfm] scene window ready\n"))
    fmc_load_dir()
    emit_scene(wid)

    evbuf: Array[256, uint8]
    while True:
        efd: int32 = sys_open(cast[Ptr[char]](&evp[0]))
        changed: int32 = 0
        if efd >= 0:
            r: int64 = sys_read(efd, &evbuf[0], 255)
            sys_close(efd)
            if r > 0:
                ls: uint64 = 0
                i: uint64 = 0
                while i <= cast[uint64](r):
                    atend: int32 = 0
                    if i == cast[uint64](r):
                        atend = 1
                    if atend == 1 or evbuf[i] == 10:
                        if i > ls:
                            bx: int64 = 0
                            by: int64 = 0
                            bbtn: int64 = 0
                            bdz: int64 = 0
                            rzw: int64 = 0
                            rzh: int64 = 0
                            if _parse_resize(&evbuf[ls], i - ls,
                                             &rzw, &rzh) == 1:
                                # Track the live content size for BOTH the grid
                                # core AND the app-local overlays (menu clamp,
                                # status line, centred dialogs) so a resized
                                # window paints edge-to-edge with no black
                                # margin.
                                fm_w = cast[int32](rzw)
                                fm_h = cast[int32](rzh)
                                if fmc_set_geometry(rzw, rzh, 0) != 0:
                                    changed = 1
                            elif parse_pointer(&evbuf[ls], i - ls, &bx, &by,
                                             &bbtn, &bdz) == 1:
                                lnow: int32 = 0
                                if (bbtn & 1) != 0:
                                    lnow = 1
                                rnow: int32 = 0
                                if (bbtn & 2) != 0:
                                    rnow = 1
                                ledge: int32 = 0
                                if lnow != 0 and prev_lbtn == 0:
                                    ledge = 1
                                redge: int32 = 0
                                if rnow != 0 and prev_rbtn == 0:
                                    redge = 1
                                prev_lbtn = lnow
                                prev_rbtn = rnow
                                if bdz != 0 and menu_open == 0 \
                                   and prompt_mode == 0 and confirm_open == 0:
                                    if fmc_wheel(bdz) != 0:
                                        changed = 1
                                # RIGHT-click press: open the context menu.
                                if redge != 0 and prompt_mode == 0 \
                                   and confirm_open == 0:
                                    idxr: int64 = fmc_cell_at(bx, by)
                                    _open_menu(bx, by, idxr)
                                    changed = 1
                                # LEFT-click press: route to whatever modal is
                                # up, else the grid.
                                elif ledge != 0:
                                    if confirm_open != 0:
                                        if _confirm_click(bx, by) != 0:
                                            changed = 1
                                    elif menu_open != 0:
                                        row: int32 = _menu_row_at(bx, by)
                                        if row >= 0:
                                            if _menu_dispatch(row) != 0:
                                                changed = 1
                                        else:
                                            _close_menu()
                                            changed = 1
                                    elif prompt_mode != 0:
                                        # Click outside the prompt cancels.
                                        prompt_mode = 0
                                        changed = 1
                                    else:
                                        idx: int64 = fmc_cell_at(bx, by)
                                        if idx >= 0:
                                            if _on_click(idx) != 0:
                                                changed = 1
                        ls = i + 1
                    i = i + 1
        # Poll /keys (non-blocking) while a prompt or confirm dialog is open.
        if prompt_mode != 0 or confirm_open != 0:
            kfd: int32 = sys_open(cast[Ptr[char]](&keysp[0]))
            if kfd >= 0:
                kr: int64 = sys_read_nb(kfd, &kbuf[0], 255)
                sys_close(kfd)
                if kr > 0:
                    if _drain_keys(cast[uint64](kr)) != 0:
                        changed = 1
        if changed != 0:
            emit_scene(wid)
            _writeall(1, cast[Ptr[uint8]]("[hamfm] navigated\n"))
        if demo_mode != 0:
            _demo_advance()
        s2: uint64 = sys_get_jiffies()
        while sys_get_jiffies() - s2 < 3:
            sys_yield()
    return 0

# user/vk2d_host.ad — HOST render + assert harness for the vk 2D layer
# (lib/vk/vk_2d.ad), Phase A of unifying the DE + hamSDL onto the vk
# spine. Built for x86_64-linux; runs on the dev host, NO QEMU.
#
# It draws every vk2d primitive into a 64x64 RGBA8888 vk-style color
# image (the exact backing the vk render pass + present path use),
# dumps the image as a binary PPM a human/agent can LOOK at, and prints
# sampled pixels at known coordinates so scripts/test_vk_2d_host.sh can
# assert UNFORGEABLE colors: a filled rect's interior, an alpha rect's
# blended value over a known background, a blit reproducing source
# pixels (natural + scaled), and a thick line's covered pixels.
#
# USAGE (build/host/vk2d_host):  vk2d_host OUT.ppm

extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

from lib.vk.vk_2d import (
    vk2d_raster_fill_rect, vk2d_raster_fill_rect_alpha,
    vk2d_raster_blit, vk2d_raster_draw_line,
)


IMG_W: uint64 = 64
IMG_H: uint64 = 64

# vk color image backing (row-major RGBA8888) — the same layout the vk
# render pass / present path use. Module-level BSS (no nested local Array).
color_img: Array[16384, uint8]        # 64*64*4
# A small 4x4 RGBA source image to blit (sprite / glyph-atlas stand-in).
src_img: Array[64, uint8]             # 4*4*4


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


def _o_hexcol(v: uint32):
    # print "#rrggbb" (6 hex digits from the low 24 bits)
    _o_ch(35)
    i: int32 = 0
    while i < 6:
        nyb: uint32 = (v >> cast[uint32]((5 - i) * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i + 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


# ---- image helpers -------------------------------------------------------
def _cbase() -> uint64:
    return cast[uint64](&color_img[0])


def _sbase() -> uint64:
    return cast[uint64](&src_img[0])


# Sample RGB of the color image at (x,y) -> 0xRRGGBB.
def _pix(x: uint64, y: uint64) -> uint32:
    o: uint64 = _cbase() + (y * IMG_W + x) * 4
    r: uint32 = cast[uint32](cast[Ptr[uint8]](o)[0])
    g: uint32 = cast[uint32](cast[Ptr[uint8]](o + 1)[0])
    b: uint32 = cast[uint32](cast[Ptr[uint8]](o + 2)[0])
    return (r << 16) | (g << 8) | b


def _report_pix(label: Ptr[uint8], x: uint64, y: uint64):
    _o_str(label)
    _o_ch(32)
    _o_hexcol(_pix(x, y))
    _o_ch(10)


def _src_put(x: uint64, y: uint64, r: uint8, g: uint8, b: uint8, a: uint8):
    o: uint64 = _sbase() + (y * 4 + x) * 4
    cast[Ptr[uint8]](o)[0] = r
    cast[Ptr[uint8]](o + 1)[0] = g
    cast[Ptr[uint8]](o + 2)[0] = b
    cast[Ptr[uint8]](o + 3)[0] = a


# ---- PPM writer (P6, RGB) ------------------------------------------------
ppm_hdr: Array[32, uint8]


def _write_ppm(path: Ptr[char]):
    fd: int32 = sys_open(path, 577, 420)     # O_WRONLY|O_CREAT|O_TRUNC, 0644
    if fd < 0:
        return
    # header "P6\n64 64\n255\n"
    hn: uint64 = 0
    ppm_hdr[hn] = 80                          # 'P'
    hn = hn + 1
    ppm_hdr[hn] = 54                          # '6'
    hn = hn + 1
    ppm_hdr[hn] = 10
    hn = hn + 1
    # width
    _ppm_dec(&hn, IMG_W)
    ppm_hdr[hn] = 32
    hn = hn + 1
    _ppm_dec(&hn, IMG_H)
    ppm_hdr[hn] = 10
    hn = hn + 1
    ppm_hdr[hn] = 50                          # '2'
    ppm_hdr[hn + 1] = 53                      # '5'
    ppm_hdr[hn + 2] = 53                      # '5'
    ppm_hdr[hn + 3] = 10
    hn = hn + 4
    sys_write(fd, &ppm_hdr[0], hn)
    # body: RGB (drop alpha)
    row: Array[192, uint8]                    # 64 px * 3
    y: uint64 = 0
    while y < IMG_H:
        x: uint64 = 0
        while x < IMG_W:
            o: uint64 = _cbase() + (y * IMG_W + x) * 4
            row[x * 3] = cast[Ptr[uint8]](o)[0]
            row[x * 3 + 1] = cast[Ptr[uint8]](o + 1)[0]
            row[x * 3 + 2] = cast[Ptr[uint8]](o + 2)[0]
            x = x + 1
        sys_write(fd, &row[0], IMG_W * 3)
        y = y + 1
    sys_close(fd)


def _ppm_dec(hn: Ptr[uint64], v: uint64):
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = v
    if x == 0:
        ppm_hdr[hn[0]] = 48
        hn[0] = hn[0] + 1
        return
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        ppm_hdr[hn[0]] = digs[n]
        hn[0] = hn[0] + 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        _o_str(cast[Ptr[uint8]]("usage: vk2d_host OUT.ppm\n"))
        _o_flush()
        return 2

    cb: uint64 = _cbase()

    # (0) Clear the whole image to a known opaque background #101828FF.
    vk2d_raster_fill_rect(cb, IMG_W, IMG_H, 0, 0,
                          cast[int64](IMG_W), cast[int64](IMG_H), 0x101828FF)

    # (1) Solid opaque rect: red #FF0000 at (4,4,16,16).
    vk2d_raster_fill_rect(cb, IMG_W, IMG_H, 4, 4, 16, 16, 0xFF0000FF)

    # (2) Alpha rect: 50%-ish white (a=128) at (24,4,16,16) over the
    #     background. out = (src*128 + bg*127)/255 per channel.
    vk2d_raster_fill_rect_alpha(cb, IMG_W, IMG_H, 24, 4, 16, 16, 0xFFFFFF80)

    # (3) Build a 4x4 source sprite and blit it. Whole sprite is green
    #     #00FF00 opaque except a blue #0000FF pixel at src (3,3) so a
    #     natural-size blit reproduces distinct source pixels.
    sy: uint64 = 0
    while sy < 4:
        sx: uint64 = 0
        while sx < 4:
            _src_put(sx, sy, 0, 255, 0, 255)
            sx = sx + 1
        sy = sy + 1
    _src_put(3, 3, 0, 0, 255, 255)
    # natural-size blit at (44,4): dest (44,4)=green, dest (47,7)=blue.
    vk2d_raster_blit(cb, IMG_W, IMG_H, _sbase(), 4, 4,
                     44, 4, 0, 0, 0, 0, 0, 0)
    # 2x-scaled blit (4x4 -> 8x8) at (44,20): dest (44,20)=green.
    vk2d_raster_blit(cb, IMG_W, IMG_H, _sbase(), 4, 4,
                     44, 20, 8, 8, 0, 0, 0, 0)

    # (4) Thick horizontal yellow line #FFFF00, thickness 2, y=40.
    vk2d_raster_draw_line(cb, IMG_W, IMG_H, 4, 40, 40, 40, 2, 0xFFFF00FF)

    # ---- dump the image + sampled pixels --------------------------------
    _write_ppm(cast[Ptr[char]](argv[1]))

    _report_pix(cast[Ptr[uint8]]("PIX_BG 0 0"), 0, 0)
    _report_pix(cast[Ptr[uint8]]("PIX_RECT 10 10"), 10, 10)
    _report_pix(cast[Ptr[uint8]]("PIX_ALPHA 30 10"), 30, 10)
    _report_pix(cast[Ptr[uint8]]("PIX_BLIT 44 4"), 44, 4)
    _report_pix(cast[Ptr[uint8]]("PIX_BLIT_BLUE 47 7"), 47, 7)
    _report_pix(cast[Ptr[uint8]]("PIX_BLIT_SCALED 44 20"), 44, 20)
    _report_pix(cast[Ptr[uint8]]("PIX_LINE 20 40"), 20, 40)
    _report_pix(cast[Ptr[uint8]]("PIX_LINE_THICK 20 41"), 20, 41)
    _report_pix(cast[Ptr[uint8]]("PIX_LINE_BELOW 20 43"), 20, 43)
    _o_flush()
    return 0

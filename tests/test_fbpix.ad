# tests/test_fbpix.ad
#
# Userland fixture for the /dev/fbpix framebuffer pixel READ-BACK leaf
# (drivers/video/fb_cdev.ad devfbpix_read — the hamshot screenshot
# source). The deterministic byte-exactness proof runs KERNEL-SIDE in
# fbpix_selftest() (gated on /etc/fbpix-test, fired at boot:37.fbpix);
# the host script greps that PASS banner. This fixture adds the REAL
# end-to-end userland leg through honest open/read syscalls:
#
#   * open /dev/fb, read + parse the geometry line
#     "WIDTH HEIGHT PITCH BPP PIXFMT\n";
#   * open /dev/fbpix and STREAM it sequentially (fd_pos-advancing
#     chunked reads, odd chunk size) to EOF;
#   * assert the total streamed byte count == PITCH * HEIGHT exactly
#     (the size the geometry line promises) and that the read after
#     EOF returns 0 — so a chunked reader terminates.
#
# The kernel self-test leaves its synthetic 32x16 framebuffer LIVE, so
# under scripts/test_fbpix.sh (-nographic, marker planted) this fixture
# sees real geometry (32 16 128 32 0 -> 2048 bytes) through the actual
# namec/devtab dispatch. If no framebuffer is initialised (marker not
# planted), it reports a skip rather than failing the boot.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_fbpix.ad -o build/user/test_fbpix.elf
# Run via scripts/test_fbpix.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32

_tfpx_chunk: Array[256, uint8]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def _tfpx_parse_u64(buf: Ptr[uint8], pos: Ptr[uint64], limit: uint64) -> uint64:
    # Skip spaces, then parse a decimal run. Advances *pos.
    p: uint64 = pos[0]
    while p < limit and buf[p] == 32:
        p = p + 1
    v: uint64 = 0
    while p < limit and buf[p] >= 48 and buf[p] <= 57:
        v = v * 10 + cast[uint64](buf[p]) - 48
        p = p + 1
    pos[0] = p
    return v


def _tfpx_write_u64(fd: int32, value: uint64):
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    if v == 0:
        digits[0] = 48
        n = 1
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def main() -> int32:
    write_str(1, "[fbpix-user] start\n")

    # ---- geometry from /dev/fb -------------------------------------
    gfd: int32 = sys_open("/dev/fb")
    if gfd < 0:
        write_str(1, "[fbpix-user] /dev/fb absent (skip)\n")
        return 0
    geo: Array[64, uint8]
    gn: int64 = sys_read(gfd, &geo[0], 63)
    sys_close(gfd)
    if gn <= 0:
        # No live framebuffer (marker not planted / -nographic default).
        write_str(1, "[fbpix-user] no framebuffer (skip)\n")
        return 0
    glen: uint64 = cast[uint64](gn)
    gpos: uint64 = 0
    gw: uint64 = _tfpx_parse_u64(&geo[0], &gpos, glen)
    gh: uint64 = _tfpx_parse_u64(&geo[0], &gpos, glen)
    gpitch: uint64 = _tfpx_parse_u64(&geo[0], &gpos, glen)
    if gw == 0 or gh == 0 or gpitch == 0:
        write_str(1, "[fbpix-user] FAIL geometry parse\n")
        return 1
    expected: uint64 = gpitch * gh
    write_str(1, "[fbpix-user] geometry ")
    _tfpx_write_u64(1, gw)
    write_str(1, "x")
    _tfpx_write_u64(1, gh)
    write_str(1, " pitch ")
    _tfpx_write_u64(1, gpitch)
    write_str(1, " -> expect ")
    _tfpx_write_u64(1, expected)
    write_str(1, " bytes\n")

    # ---- stream /dev/fbpix to EOF ----------------------------------
    pfd: int32 = sys_open("/dev/fbpix")
    if pfd < 0:
        write_str(1, "[fbpix-user] FAIL open /dev/fbpix\n")
        return 1
    total: uint64 = 0
    fail: int32 = 0
    while True:
        rn: int64 = sys_read(pfd, &_tfpx_chunk[0], 100)
        if rn < 0:
            write_str(1, "[fbpix-user] FAIL read error mid-stream\n")
            fail = 1
            break
        if rn == 0:
            break
        total = total + cast[uint64](rn)
        if total > expected:
            write_str(1, "[fbpix-user] FAIL streamed past expected size\n")
            fail = 1
            break

    if fail == 0:
        if total != expected:
            write_str(1, "[fbpix-user] FAIL streamed ")
            _tfpx_write_u64(1, total)
            write_str(1, " != expected ")
            _tfpx_write_u64(1, expected)
            write_str(1, "\n")
            fail = 1
        else:
            write_str(1, "[fbpix-user] OK streamed pitch*height bytes exactly\n")

    # Post-EOF read must keep returning 0.
    if fail == 0:
        rn2: int64 = sys_read(pfd, &_tfpx_chunk[0], 100)
        if rn2 != 0:
            write_str(1, "[fbpix-user] FAIL post-EOF read != 0\n")
            fail = 1
        else:
            write_str(1, "[fbpix-user] OK EOF is sticky\n")

    sys_close(pfd)
    if fail != 0:
        write_str(1, "[fbpix-user] FAIL\n")
        return 1
    write_str(1, "[fbpix-user] PASS\n")
    return 0

# tests/desktopentry_host.ad — HOST unit test for lib/desktopentry.ad
# (built for the x86_64-linux Adder target; runs on the dev host, no QEMU).
#
# Feeds several in-memory `.desktop` fixtures through the SAME pure parser
# the native DE panel ships (lib/desktopentry.ad) and prints the parsed
# Name / Exec-prog / category / display-flag for each so the wrapper gate
# (scripts/test_desktopentry_host.sh) can assert them. TEST shim only: no
# sockets, no Plan 9, no files — reads nothing, writes assertions to fd 1.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.desktopentry import desktop_parse, desktop_name_ptr, \
    desktop_prog_ptr, desktop_catcode, desktop_category_name, \
    desktop_nodisplay, desktop_name_is_entry


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0

def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1

def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1

def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0

def _o_dec(v: int64):
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    x: uint64 = cast[uint64](v)
    while x > 0:
        digs[n] = cast[uint8](x % 10) + 48
        x = x / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


# Copy a literal into a scratch buffer of length n (the parser needs a
# byte buffer + length, not a NUL-terminated pointer, to prove it honours
# an explicit span rather than scanning to NUL).
fixbuf: Array[512, uint8]
_load_len: uint64 = 0

def _load(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0 and n < 511:
        fixbuf[n] = s[n]
        n = n + 1
    return n


# Parse fixbuf and print "PARSE <tag> ok=<0/1> name=<..> prog=<..>
# cat=<name> nodisplay=<0/1>".
def _report(tag: Ptr[uint8]):
    ok: int32 = desktop_parse(&fixbuf[0], _load_len)
    _o_str(cast[Ptr[uint8]]("PARSE "))
    _o_str(tag)
    _o_str(cast[Ptr[uint8]](" ok="))
    _o_dec(cast[int64](ok))
    _o_str(cast[Ptr[uint8]](" name="))
    _o_str(desktop_name_ptr())
    _o_str(cast[Ptr[uint8]](" prog="))
    _o_str(desktop_prog_ptr())
    _o_str(cast[Ptr[uint8]](" cat="))
    _o_str(desktop_category_name(desktop_catcode()))
    _o_str(cast[Ptr[uint8]](" nodisplay="))
    _o_dec(cast[int64](desktop_nodisplay()))
    _o_ch(10)
    _o_flush()


def _run(tag: Ptr[uint8], src: Ptr[uint8]):
    _load_len = _load(src)
    _report(tag)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # A well-formed game entry with a field code + extra whitespace.
    _run(cast[Ptr[uint8]]("game"),
         "[Desktop Entry]\nType=Application\nName=2048\nExec=/bin/ham2048scene %U\nCategories=Game;\nIcon=ham2048\n")
    # A network app; leading comment + blank lines + CRLF tolerance.
    _run(cast[Ptr[uint8]]("net"),
         "# a comment\n\n[Desktop Entry]\r\nName=Web Browser\r\nExec=/bin/hambrowse\r\nCategories=Network;WebBrowser;\r\n")
    # Utility -> Accessories.
    _run(cast[Ptr[uint8]]("util"),
         "[Desktop Entry]\nName=Calculator\nExec=/bin/hamcalcscene\nCategories=Utility;Calculator;\n")
    # Settings beats System in the priority order.
    _run(cast[Ptr[uint8]]("settings"),
         "[Desktop Entry]\nName=Settings\nExec=/bin/hamsettings\nCategories=Settings;System;\n")
    # NoDisplay=true is rejected.
    _run(cast[Ptr[uint8]]("hidden"),
         "[Desktop Entry]\nName=Hidden\nExec=/bin/nope\nNoDisplay=true\nCategories=Utility;\n")
    # Wrong Type is rejected.
    _run(cast[Ptr[uint8]]("dir"),
         "[Desktop Entry]\nType=Directory\nName=NotAnApp\nExec=/bin/nope\n")
    # Missing Exec is rejected.
    _run(cast[Ptr[uint8]]("noexec"),
         "[Desktop Entry]\nName=Incomplete\nCategories=Utility;\n")
    # Keys OUTSIDE [Desktop Entry] must be ignored; uncategorised -> Other.
    _run(cast[Ptr[uint8]]("scoped"),
         "[Desktop Entry]\nName=Scoped\nExec=/bin/hamterm\n[Desktop Action New]\nName=Ignored\nExec=/bin/ignored\n")

    # Suffix helper.
    _o_str(cast[Ptr[uint8]]("SUFFIX yes="))
    _o_dec(cast[int64](desktop_name_is_entry(cast[Ptr[uint8]]("ham2048.desktop"))))
    _o_str(cast[Ptr[uint8]](" no="))
    _o_dec(cast[int64](desktop_name_is_entry(cast[Ptr[uint8]]("README.md"))))
    _o_ch(10)
    _o_flush()
    return 0

    fx4_in[10] = 0x01
    fx4_in[11] = 0x1D
    fx4_in[12] = 0x00
    fx4_in[13] = 0xE2
    fx4_in[14] = 0xFF
    fx4_in[15] = 0x48
    fx4_in[16] = 0x61
    fx4_in[17] = 0x6D
    fx4_in[18] = 0x6E
    fx4_in[19] = 0x69
    fx4_in[20] = 0x78
    fx4_in[21] = 0x20
    fx4_in[22] = 0x73
    fx4_in[23] = 0x74
    fx4_in[24] = 0x6F
    fx4_in[25] = 0x72
    fx4_in[26] = 0x65
    fx4_in[27] = 0x64
    fx4_in[28] = 0x20
    fx4_in[29] = 0x62
    fx4_in[30] = 0x6C
    fx4_in[31] = 0x6F
    fx4_in[32] = 0x63
    fx4_in[33] = 0x6B
    fx4_in[34] = 0x20
    fx4_in[35] = 0x74
    fx4_in[36] = 0x65
    fx4_in[37] = 0x73
    fx4_in[38] = 0x74
    fx4_in[39] = 0x20
    fx4_in[40] = 0x30
    fx4_in[41] = 0x31
    fx4_in[42] = 0x32
    fx4_in[43] = 0x33
    fx4_in[44] = 0x88
    fx4_in[45] = 0xF6
    fx4_in[46] = 0x30
    fx4_in[47] = 0x15
    fx4_in[48] = 0x1D
    fx4_in[49] = 0x00
    fx4_in[50] = 0x00
    fx4_in[51] = 0x00

    # expected = "Hamnix stored block test 0123"
    fx4_exp[0]  = 72   # H
    fx4_exp[1]  = 97
    fx4_exp[2]  = 109
    fx4_exp[3]  = 110
    fx4_exp[4]  = 105
    fx4_exp[5]  = 120
    fx4_exp[6]  = 32
    fx4_exp[7]  = 115  # s
    fx4_exp[8]  = 116  # t
    fx4_exp[9]  = 111  # o
    fx4_exp[10] = 114  # r
    fx4_exp[11] = 101  # e
    fx4_exp[12] = 100  # d
    fx4_exp[13] = 32
    fx4_exp[14] = 98   # b
    fx4_exp[15] = 108  # l
    fx4_exp[16] = 111  # o
    fx4_exp[17] = 99   # c
    fx4_exp[18] = 107  # k
    fx4_exp[19] = 32
    fx4_exp[20] = 116  # t
    fx4_exp[21] = 101  # e
    fx4_exp[22] = 115  # s
    fx4_exp[23] = 116  # t
    fx4_exp[24] = 32
    fx4_exp[25] = 48   # 0
    fx4_exp[26] = 49
    fx4_exp[27] = 50
    fx4_exp[28] = 51


# -- inflater state + scratch (top-level, NOT on the stack — frame
#    size for the entire test would otherwise spill past the userland
#    stack budget; the InflateState alone is ~40 KB) -------------------------

state: InflateState
out_buf: Array[256, uint8]


def _run_one_shot(in_buf: Ptr[uint8], in_len: uint64,
                  label: Ptr[uint8],
                  expected: Ptr[uint8], expected_len: uint64):
    inflate_init(&state)
    in_consumed: uint64 = 0
    out_consumed: uint64 = 0
    done: int32 = 0
    rc: int32 = inflate_feed(&state, in_buf, in_len,
                             &out_buf[0], cast[uint64](256),
                             &out_consumed, &in_consumed, &done)
    _check_eq_i32(rc, 1, label)
    _check_eq_i32(done, 1, label)
    _check_eq_u64(out_consumed, expected_len, label)
    eq: int32 = _bytes_eq(&out_buf[0], out_consumed,
                          expected, expected_len)
    if eq == 0:
        _wstr("[inflate] FAIL: ")
        _wstr(label)
        _wstr(" byte mismatch (first 16 got/want):\n  got: ")
        k: uint64 = 0
        n: uint64 = 16
        if out_consumed < n:
            n = out_consumed
        while k < n:
            _whex2(out_buf[k])
            sys_write(1, " ", 1)
            k = k + 1
        _wstr("\n want: ")
        k = 0
        n = 16
        if expected_len < n:
            n = expected_len
        while k < n:
            _whex2(expected[k])
            sys_write(1, " ", 1)
            k = k + 1
        _wstr("\n")
        fail_count = fail_count + 1


def _run_streaming_1byte(in_buf: Ptr[uint8], in_len: uint64,
                         label: Ptr[uint8],
                         expected: Ptr[uint8], expected_len: uint64):
    # Feed one byte at a time.
    inflate_init(&state)
    total_out: uint64 = 0
    pos: uint64 = 0
    done: int32 = 0
    last_rc: int32 = 0
    while pos < in_len and done == 0:
        in_consumed: uint64 = 0
        out_consumed: uint64 = 0
        rc: int32 = inflate_feed(&state, &in_buf[pos],
                                 cast[uint64](1),
                                 &out_buf[total_out],
                                 cast[uint64](256) - total_out,
                                 &out_consumed, &in_consumed, &done)
        last_rc = rc
        if rc < 0:
            _wstr("[inflate] FAIL: ")
            _wstr(label)
            _wstr(" streaming rc<0 at pos=")
            _wdec(pos)
            _wstr("\n")
            fail_count = fail_count + 1
            return
        pos = pos + in_consumed
        total_out = total_out + out_consumed
    _check_eq_i32(done, 1, label)
    _check_eq_u64(total_out, expected_len, label)
    eq: int32 = _bytes_eq(&out_buf[0], total_out, expected, expected_len)
    if eq == 0:
        _wstr("[inflate] FAIL: ")
        _wstr(label)
        _wstr(" streaming bytes mismatch\n")
        fail_count = fail_count + 1


def _test_crc_mismatch():
    # Corrupt the trailer of case 1 and expect rc<0 (CRC fail).
    bad: Array[64, uint8]
    i: uint64 = 0
    while i < fx1_in_len:
        bad[i] = fx1_in[i]
        i = i + 1
    # Flip a CRC byte (offset = len-8).
    bad[fx1_in_len - 8] = bad[fx1_in_len - 8] ^ 0xFF
    inflate_init(&state)
    in_consumed: uint64 = 0
    out_consumed: uint64 = 0
    done: int32 = 0
    rc: int32 = inflate_feed(&state, &bad[0], fx1_in_len,
                             &out_buf[0], cast[uint64](256),
                             &out_consumed, &in_consumed, &done)
    if rc >= 0:
        _wstr("[inflate] FAIL: crc-mismatch should error, got rc=")
        _wdec(cast[uint64](cast[int64](rc)))
        _wstr("\n")
        fail_count = fail_count + 1


def _test_bad_magic():
    # Wrong gzip magic — should error immediately.
    bad: Array[16, uint8]
    bad[0] = 0x1E   # not 0x1F
    bad[1] = 0x8B
    bad[2] = 0x08
    bad[3] = 0x00
    inflate_init(&state)
    in_consumed: uint64 = 0
    out_consumed: uint64 = 0
    done: int32 = 0
    rc: int32 = inflate_feed(&state, &bad[0], cast[uint64](4),
                             &out_buf[0], cast[uint64](256),
                             &out_consumed, &in_consumed, &done)
    if rc >= 0:
        _wstr("[inflate] FAIL: bad-magic should error\n")
        fail_count = fail_count + 1


# -- driver -----------------------------------------------------------------

def main() -> int32:
    _wstr("[inflate] start\n")

    _init_fx1()
    _init_fx2()
    _init_fx3()
    _init_fx4()

    _run_one_shot(&fx1_in[0], fx1_in_len, "fx1: fixed-Huffman literal",
                  &fx1_exp[0], fx1_exp_len)
    _run_one_shot(&fx2_in[0], fx2_in_len, "fx2: fixed-Huffman backref",
                  &fx2_exp[0], fx2_exp_len)
    _run_one_shot(&fx3_in[0], fx3_in_len, "fx3: dynamic-Huffman pangram",
                  &fx3_exp[0], fx3_exp_len)
    _run_one_shot(&fx4_in[0], fx4_in_len, "fx4: stored block",
                  &fx4_exp[0], fx4_exp_len)

    _run_streaming_1byte(&fx2_in[0], fx2_in_len,
                         "fx2: streaming 1-byte feed",
                         &fx2_exp[0], fx2_exp_len)

    _test_crc_mismatch()
    _test_bad_magic()

    _wstr("[inflate] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[inflate] PASS\n")
        return 0
    _wstr("[inflate] FAIL\n")
    return 1

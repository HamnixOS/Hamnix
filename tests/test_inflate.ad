# tests/test_inflate.ad
#
# Streaming DEFLATE/gzip inflater regression. Embeds four pre-computed
# compressed fixtures and verifies that inflate_init + inflate_feed
# recover the original bytes byte-identically. Cases exercised:
#
#   1) Fixed-Huffman gzip: short non-repeating ASCII (fastest path).
#   2) Fixed-Huffman gzip with LZ77 backref: "abcdefgh " repeated 4x.
#   3) Dynamic-Huffman gzip: pangram repeated 3x (forces BTYPE=10 +
#      multiple lit/length and distance code lengths).
#   4) Stored-block gzip: same fixture but compressed with level=0
#      (forces BTYPE=00 raw-copy path).
#
# Plus a streaming partial-input test: case 2 is fed in 1-byte
# chunks to prove the inflater's state machine actually suspends
# and resumes correctly. Without this we'd silently rely on
# "fed in one shot" behavior and apt's chunked HTTP body would
# break the first time the inflater hit a TCP segment boundary
# mid-symbol.
#
# Driven by scripts/test_inflate.sh: builds this .ad as a userland
# x86_64 ELF, plants it at /bin/test_inflate in the cpio initramfs,
# boots QEMU + hamsh, runs the binary, then greps the serial log for
# the [inflate] PASS banner. Shape mirrors test_asn1_parser.

from lib.zlib.inflate import (
    InflateState,
    inflate_init,
    inflate_feed,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer ------------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


def _whex2(b: uint8):
    s: Array[3, uint8]
    h: Array[16, uint8]
    h[0] = 48
    h[1] = 49
    h[2] = 50
    h[3] = 51
    h[4] = 52
    h[5] = 53
    h[6] = 54
    h[7] = 55
    h[8] = 56
    h[9] = 57
    h[10] = 97
    h[11] = 98
    h[12] = 99
    h[13] = 100
    h[14] = 101
    h[15] = 102
    s[0] = h[(b >> 4) & 0xF]
    s[1] = h[b & 0xF]
    s[2] = 0
    sys_write(1, &s[0], 2)


# -- failure aggregator ------------------------------------------------------

fail_count: int32 = 0


def _check(cond: int32, label: Ptr[uint8]):
    if cond == 0:
        _wstr("[inflate] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_eq_u64(a: uint64, b: uint64, label: Ptr[uint8]):
    if a != b:
        _wstr("[inflate] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec(a)
        _wstr(" want=")
        _wdec(b)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_eq_i32(a: int32, b: int32, label: Ptr[uint8]):
    if a != b:
        _wstr("[inflate] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _bytes_eq(a: Ptr[uint8], a_len: uint64,
              b: Ptr[uint8], b_len: uint64) -> int32:
    if a_len != b_len:
        return 0
    i: uint64 = 0
    while i < a_len:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# -- fixture buffers (top-level Arrays per Adder quirk) ----------------------

# Case 1: gzip of "Hamnix gzip test 0123456789" (27 bytes -> 47 bytes gz).
fx1_in:  Array[64, uint8]
fx1_in_len: uint64 = 47
fx1_exp: Array[64, uint8]
fx1_exp_len: uint64 = 27

# Case 2: gzip of "abcdefgh abcdefgh abcdefgh abcdefgh" (35 -> 32 bytes).
fx2_in:  Array[64, uint8]
fx2_in_len: uint64 = 32
fx2_exp: Array[64, uint8]
fx2_exp_len: uint64 = 35

# Case 3: dynamic-Huffman gzip (BTYPE=2). Verified via `(byte[10]>>1)
# & 3 == 2`. Payload is 68 bytes of varied repeat lengths so that
# constructing a dedicated lit/length Huffman beats the fixed table.
fx3_in:  Array[80, uint8]
fx3_in_len: uint64 = 63
fx3_exp: Array[80, uint8]
fx3_exp_len: uint64 = 68

# Case 4: stored-block gzip — 29-byte payload, level=0 (29 -> 52 bytes).
fx4_in:  Array[64, uint8]
fx4_in_len: uint64 = 52
fx4_exp: Array[64, uint8]
fx4_exp_len: uint64 = 29


def _init_fx1():
    # gzip bytes (RFC 1952 wrapper + fixed-Huffman DEFLATE)
    fx1_in[0]  = 0x1F
    fx1_in[1]  = 0x8B
    fx1_in[2]  = 0x08
    fx1_in[3]  = 0x00
    fx1_in[4]  = 0x00
    fx1_in[5]  = 0x00
    fx1_in[6]  = 0x00
    fx1_in[7]  = 0x00
    fx1_in[8]  = 0x00
    fx1_in[9]  = 0x03
    fx1_in[10] = 0xF3
    fx1_in[11] = 0x48
    fx1_in[12] = 0xCC
    fx1_in[13] = 0xCD
    fx1_in[14] = 0xCB
    fx1_in[15] = 0xAC
    fx1_in[16] = 0x50
    fx1_in[17] = 0x48
    fx1_in[18] = 0xAF
    fx1_in[19] = 0xCA
    fx1_in[20] = 0x2C
    fx1_in[21] = 0x50
    fx1_in[22] = 0x28
    fx1_in[23] = 0x49
    fx1_in[24] = 0x2D
    fx1_in[25] = 0x2E
    fx1_in[26] = 0x51
    fx1_in[27] = 0x30
    fx1_in[28] = 0x30
    fx1_in[29] = 0x34
    fx1_in[30] = 0x32
    fx1_in[31] = 0x36
    fx1_in[32] = 0x31
    fx1_in[33] = 0x35
    fx1_in[34] = 0x33
    fx1_in[35] = 0xB7
    fx1_in[36] = 0xB0
    fx1_in[37] = 0x04
    fx1_in[38] = 0x00
    fx1_in[39] = 0xFA
    fx1_in[40] = 0xB1
    fx1_in[41] = 0x63
    fx1_in[42] = 0x8C
    fx1_in[43] = 0x1B
    fx1_in[44] = 0x00
    fx1_in[45] = 0x00
    fx1_in[46] = 0x00

    # expected = "Hamnix gzip test 0123456789"
    fx1_exp[0]  = 72   # H
    fx1_exp[1]  = 97   # a
    fx1_exp[2]  = 109  # m
    fx1_exp[3]  = 110  # n
    fx1_exp[4]  = 105  # i
    fx1_exp[5]  = 120  # x
    fx1_exp[6]  = 32   # (space)
    fx1_exp[7]  = 103  # g
    fx1_exp[8]  = 122  # z
    fx1_exp[9]  = 105  # i
    fx1_exp[10] = 112  # p
    fx1_exp[11] = 32
    fx1_exp[12] = 116  # t
    fx1_exp[13] = 101  # e
    fx1_exp[14] = 115  # s
    fx1_exp[15] = 116  # t
    fx1_exp[16] = 32
    fx1_exp[17] = 48   # 0
    fx1_exp[18] = 49
    fx1_exp[19] = 50
    fx1_exp[20] = 51
    fx1_exp[21] = 52
    fx1_exp[22] = 53
    fx1_exp[23] = 54
    fx1_exp[24] = 55
    fx1_exp[25] = 56
    fx1_exp[26] = 57   # 9


def _init_fx2():
    fx2_in[0]  = 0x1F
    fx2_in[1]  = 0x8B
    fx2_in[2]  = 0x08
    fx2_in[3]  = 0x00
    fx2_in[4]  = 0x00
    fx2_in[5]  = 0x00
    fx2_in[6]  = 0x00
    fx2_in[7]  = 0x00
    fx2_in[8]  = 0x02
    fx2_in[9]  = 0x03
    fx2_in[10] = 0x4B
    fx2_in[11] = 0x4C
    fx2_in[12] = 0x4A
    fx2_in[13] = 0x4E
    fx2_in[14] = 0x49
    fx2_in[15] = 0x4D
    fx2_in[16] = 0x4B
    fx2_in[17] = 0xCF
    fx2_in[18] = 0x50
    fx2_in[19] = 0x48
    fx2_in[20] = 0xC4
    fx2_in[21] = 0xC9
    fx2_in[22] = 0x00
    fx2_in[23] = 0x00
    fx2_in[24] = 0xC0
    fx2_in[25] = 0xEE
    fx2_in[26] = 0x68
    fx2_in[27] = 0x77
    fx2_in[28] = 0x23
    fx2_in[29] = 0x00
    fx2_in[30] = 0x00
    fx2_in[31] = 0x00

    # expected = "abcdefgh abcdefgh abcdefgh abcdefgh"
    i: uint64 = 0
    while i < 4:
        base: uint64 = i * 9
        fx2_exp[base + 0] = 97   # a
        fx2_exp[base + 1] = 98   # b
        fx2_exp[base + 2] = 99   # c
        fx2_exp[base + 3] = 100  # d
        fx2_exp[base + 4] = 101  # e
        fx2_exp[base + 5] = 102  # f
        fx2_exp[base + 6] = 103  # g
        fx2_exp[base + 7] = 104  # h
        if i < 3:
            fx2_exp[base + 8] = 32   # space between groups
        i = i + 1


def _init_fx3():
    # gzip(level=9, wbits=31) of payload "aaaa bb cccc dd eeeeeeee
    # ffff gg hhh iiiii j kkk lll mm nnnnnnnn ooo" (68 bytes). The
    # variable-frequency letter runs ensure deflate's heuristic
    # picks BTYPE=2 (dynamic) over the fixed table.
    fx3_in[0]  = 0x1F
    fx3_in[1]  = 0x8B
    fx3_in[2]  = 0x08
    fx3_in[3]  = 0x00
    fx3_in[4]  = 0x00
    fx3_in[5]  = 0x00
    fx3_in[6]  = 0x00
    fx3_in[7]  = 0x00
    fx3_in[8]  = 0x02
    fx3_in[9]  = 0x03
    fx3_in[10] = 0x2D   # first DEFLATE byte: BFINAL=1, BTYPE=10 (dynamic)
    fx3_in[11] = 0xC1
    fx3_in[12] = 0xC9
    fx3_in[13] = 0x11
    fx3_in[14] = 0x00
    fx3_in[15] = 0x20
    fx3_in[16] = 0x08
    fx3_in[17] = 0x00
    fx3_in[18] = 0xB1
    fx3_in[19] = 0x56
    fx3_in[20] = 0xB6
    fx3_in[21] = 0x35
    fx3_in[22] = 0x3C
    fx3_in[23] = 0x51
    fx3_in[24] = 0x50
    fx3_in[25] = 0xFA
    fx3_in[26] = 0xFF
    fx3_in[27] = 0xA9
    fx3_in[28] = 0x33
    fx3_in[29] = 0x26
    fx3_in[30] = 0x22
    fx3_in[31] = 0x22
    fx3_in[32] = 0xA4
    fx3_in[33] = 0x44
    fx3_in[34] = 0xBE
    fx3_in[35] = 0x28
    fx3_in[36] = 0x85
    fx3_in[37] = 0xFA
    fx3_in[38] = 0xD1
    fx3_in[39] = 0x2E
    fx3_in[40] = 0x7A
    fx3_in[41] = 0x47
    fx3_in[42] = 0x55
    fx3_in[43] = 0x19
    fx3_in[44] = 0x0F
    fx3_in[45] = 0x13
    fx3_in[46] = 0x33
    fx3_in[47] = 0xC3
    fx3_in[48] = 0xDD
    fx3_in[49] = 0x59
    fx3_in[50] = 0x8B
    fx3_in[51] = 0xFD
    fx3_in[52] = 0x11
    fx3_in[53] = 0x11
    fx3_in[54] = 0x07
    fx3_in[55] = 0x7C
    fx3_in[56] = 0x6C
    fx3_in[57] = 0xD5
    fx3_in[58] = 0x1D
    fx3_in[59] = 0x44
    fx3_in[60] = 0x00
    fx3_in[61] = 0x00
    fx3_in[62] = 0x00

    # Expected payload bytes.
    s: Ptr[uint8] = "aaaa bb cccc dd eeeeeeee ffff gg hhh iiiii j kkk lll mm nnnnnnnn ooo"
    i: uint64 = 0
    while i < 68:
        fx3_exp[i] = s[i]
        i = i + 1


def _init_fx4():
    fx4_in[0]  = 0x1F
    fx4_in[1]  = 0x8B
    fx4_in[2]  = 0x08
    fx4_in[3]  = 0x00
    fx4_in[4]  = 0x00
    fx4_in[5]  = 0x00
    fx4_in[6]  = 0x00
    fx4_in[7]  = 0x00
    fx4_in[8]  = 0x04

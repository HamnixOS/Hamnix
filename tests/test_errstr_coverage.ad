# tests/test_errstr_coverage.ad
#
# Phase C follow-up: wider errstr-integration coverage test. Drives the
# sweep of set_current_errstr() calls plumbed through every meaningful
# syscall failure path (arch/x86/kernel/syscall.ad +
# sys/src/9/port/sys*.ad + linux_abi/u_syscalls.ad). The original
# tests/test_errstr.ad covers one path (SYS_OPEN -> -ENOENT); this
# fixture exercises ~10 distinct subjects and proves each leaves a
# matching errstr behind for the next SYS_ERRSTR call.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_errstr_coverage.ad -o build/user/test_errstr_coverage.elf
#
# Run via scripts/test_errstr_coverage.sh — embeds the binary as
# /bin/test_errstr_coverage in the cpio initramfs and greps the serial
# log for each "[errcov] got <subject>: <expected substring>" line.
#
# Contract per case:
#   1. Trigger a syscall that's known to fail with a set_current_errstr.
#   2. Call sys_errstr(buf, 128) with buf[0] = 0 (read-only swap).
#   3. Print "[errcov] got <subject>: <buf>\n" to stdout. The host
#      script grep-asserts a non-empty, subject-recognisable line for
#      each case.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_exit(code: uint64)
extern def sys_dup(oldfd: int32) -> int32
extern def sys_dup2(oldfd: int32, newfd: int32) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_kill(pid: uint64, sig: uint64) -> int32
extern def sys_chdir(path: Ptr[char]) -> int32
extern def sys_getcwd(buf: Ptr[uint8], n: uint64) -> int32
extern def sys_unlink(path: Ptr[char]) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_lseek(fd: int32, off: int64, whence: int32) -> int64


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    n: uint64 = strlen(s)
    sys_write(fd, s, n)


def clear_buf(buf: Ptr[uint8], n: uint64):
    # Zero the whole buffer so sys_errstr returns pure read semantics.
    # The kernel does its own NUL-termination, but pre-clearing keeps
    # stale bytes from a previous read out of the picture.
    i: uint64 = 0
    while i < n:
        buf[i] = 0
        i = i + 1


def show(subject: Ptr[uint8], buf: Ptr[uint8]):
    write_str(1, "[errcov] got ")
    write_str(1, subject)
    write_str(1, ": ")
    write_str(1, buf)
    write_str(1, "\n")


def main() -> int32:
    write_str(1, "[errcov] start\n")
    buf: Array[128, uint8]

    # 1. open(nonexistent) -> "file does not exist"
    clear_buf(&buf[0], 128)
    fd: int32 = sys_open("/nonexistent/path")
    sys_errstr(&buf[0], 128)
    show("open", &buf[0])

    # 2. dup(bad_fd) -> "dup: bad fd"
    clear_buf(&buf[0], 128)
    rc: int32 = sys_dup(99)
    sys_errstr(&buf[0], 128)
    show("dup", &buf[0])

    # 3. dup2(oldfd=99, newfd=2) -> "dup2: bad fd" (or similar)
    clear_buf(&buf[0], 128)
    rc = sys_dup2(99, 2)
    sys_errstr(&buf[0], 128)
    show("dup2", &buf[0])

    # 4. close(bad_fd) -> "close: bad fd"
    clear_buf(&buf[0], 128)
    rc = sys_close(99)
    sys_errstr(&buf[0], 128)
    show("close", &buf[0])

    # 5. kill(bad_pid) -> "kill: no such pid"
    clear_buf(&buf[0], 128)
    rc = sys_kill(99999, 9)
    sys_errstr(&buf[0], 128)
    show("kill", &buf[0])

    # 6. chdir(nonexistent) -> "chdir: no such directory"
    clear_buf(&buf[0], 128)
    rc = sys_chdir("/nope_dir_doesnt_exist")
    sys_errstr(&buf[0], 128)
    show("chdir", &buf[0])

    # 7. getcwd(buf, 0) -> "getcwd: buffer too small"
    clear_buf(&buf[0], 128)
    rc = sys_getcwd(&buf[0], 0)
    sys_errstr(&buf[0], 128)
    show("getcwd", &buf[0])

    # 8. unlink(nonexistent) -> "unlink: no such file"
    clear_buf(&buf[0], 128)
    rc = sys_unlink("/nope_file_doesnt_exist")
    sys_errstr(&buf[0], 128)
    show("unlink", &buf[0])

    # 9. waitpid(bad_pid) -> "wait: no such child"
    clear_buf(&buf[0], 128)
    n: int64 = sys_waitpid(99999)
    sys_errstr(&buf[0], 128)
    show("waitpid", &buf[0])

    # 10. lseek(bad_fd) -> "seek: not seekable" (or bad fd)
    clear_buf(&buf[0], 128)
    n = sys_lseek(99, 0, 0)
    sys_errstr(&buf[0], 128)
    show("lseek", &buf[0])

    write_str(1, "[errcov] done\n")
    return 0

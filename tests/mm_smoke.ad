# tests/mm_smoke.ad
#
# F10-5 (#457) split: kernel-side MM smoke / selftest bodies that used
# to live in init/main.ad. start_kernel() calls each function directly
# at the same boot stage it always did; pulling the bodies out
# separates boot policy from test surface area.
#
# Inventory:
#   memblock_smoke_test        — memblock_alloc round-trip print
#   page_alloc_smoke_test      — buddy alloc/free + cascade merge
#   slab_smoke_test            — kmalloc/kfree, large-order path, KmallocLive
#   mmap_file_selftest         — §file-mmap (boot:37.mmf)
#   mmap_shared_selftest       — §shared-mmap (boot:37.mms)

from kernel.printk.printk import printk0, printk1, printk2
from mm.memblock import memblock_alloc
from mm.page_alloc import (
    alloc_page, free_page, alloc_pages, free_pages,
    page_alloc_total, page_alloc_free_count, count_free_at_order,
)
from mm.slab import kmalloc, kfree, kmalloc_live_render
from mm.vma import (
    vma_alloc_file_demand, vma_alloc_file_shared, vma_demand_fault,
    vma_writeback_range,
)
from fs.tmpfs import tmpfs_open_for_write, tmpfs_write, tmpfs_read, tmpfs_size
from kernel.sched.core import FD_TMPFS_MARK, current_idx_get, task_pml4
from fs.vfs import (
    FD_FILEMMAP_INITRAMFS,
    initramfs_entry_count, initramfs_entry_name, initramfs_entry_size,
)

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
extern def set_efer_nxe()


def memblock_smoke_test():
    printk0("Hamnix: memblock smoke test\n")
    a: uint64 = memblock_alloc(128, 16)
    b: uint64 = memblock_alloc(256, 64)
    c: uint64 = memblock_alloc(64, 8)
    printk1("  alloc(128,16) = %p\n", a)
    printk1("  alloc(256,64) = %p\n", b)
    printk1("  alloc( 64, 8) = %p\n", c)


def page_alloc_smoke_test():
    printk0("Hamnix: page_alloc smoke test\n")
    p1: uint64 = alloc_page()
    printk1("  alloc_page #1 = %p\n", p1)
    free_page(p1)
    p2: uint64 = alloc_page()
    printk1("  alloc_page #2 = %p  (expect == #1)\n", p2)
    p3: uint64 = alloc_page()
    printk1("  alloc_page #3 = %p  (fresh)\n", p3)
    free_page(p2)
    printk2("  after free(p2): order0=%d order1=%d\n",
            count_free_at_order(0), count_free_at_order(1))
    free_page(p3)
    printk2("  after free(p3): order0=%d order1=%d\n",
            count_free_at_order(0), count_free_at_order(1))
    printk2("  cascaded: order2=%d  order10=%d  (1 if fully merged)\n",
            count_free_at_order(2), count_free_at_order(10))
    printk2("  page_alloc: total=%d free=%d\n",
            page_alloc_total(), page_alloc_free_count())


def page_alloc_coalesce_test():
    # Focused, ASSERTING proof of buddy merge-on-free (block coalescing).
    #
    # Freeing the four order-0 quarters of an aligned order-2 run must
    # cascade-merge them back into a single order-2 block at the original
    # base (mirrors __free_one_page in mm/page_alloc.c). The proof is
    # baseline-independent because:
    #   * we hold an order-3 run [g, g+8 pages); its two order-2 HALVES
    #     (g and g+16384) are buddies of each other and BOTH owned by us,
    #     so neither is on any free list during the test;
    #   * we free only the four quarters of the LOWER half [g, g+16384).
    #     They cascade 0+1 -> order1, 2+3 -> order1, then the two order-1
    #     halves -> one order-2 block at g. The merge then STOPS, because
    #     g's order-2 buddy (g+16384) is the upper half we still own
    #     (not free) — so no baseline order-2 buddy can pull the block up
    #     to order-3 and perturb the counts.
    #
    # Two independent assertions:
    #   A. the free-list order distribution shows the merge: after the four
    #      order-0 frees, order0/order1 return to baseline and order2 gains
    #      exactly one block (the page count is conserved, just promoted).
    #   B. a follow-up alloc_pages(2) returns the EXACT original base g.
    #      This can ONLY happen if the quarters coalesced: four un-merged
    #      order-0 frees can never satisfy an order-2 request from that
    #      address (order-0 entries serve only order-0 requests), and
    #      g+16384 is owned so the request cannot be met by splitting a
    #      foreign higher-order block at g.
    #
    # Runs at quiet early boot (single CPU active, no concurrent allocator
    # users) so the free lists are stable across the sequence, then returns
    # all memory it took so allocator accounting is left exactly as found.
    printk0("Hamnix: buddy coalesce test\n")
    PG: uint64 = 4096
    base0: uint64 = count_free_at_order(0)
    base1: uint64 = count_free_at_order(1)
    base2: uint64 = count_free_at_order(2)

    g: uint64 = alloc_pages(3)
    if g == 0:
        printk0("[buddy-coalesce] FAIL: alloc_pages(3) OOM\n")
        return

    # Free the four order-0 quarters of the LOWER order-2 half.
    free_pages(g + 0 * PG, 0)
    free_pages(g + 1 * PG, 0)
    free_pages(g + 2 * PG, 0)
    free_pages(g + 3 * PG, 0)

    aft0: uint64 = count_free_at_order(0)
    aft1: uint64 = count_free_at_order(1)
    aft2: uint64 = count_free_at_order(2)
    printk2("[buddy-coalesce] order0 base=%d aft=%d\n", base0, aft0)
    printk2("[buddy-coalesce] order1 base=%d aft=%d\n", base1, aft1)
    printk2("[buddy-coalesce] order2 base=%d aft=%d\n", base2, aft2)

    ok: int32 = 1
    # Assertion A: distribution shows a cascade merge to order 2.
    if aft0 != base0:
        printk0("[buddy-coalesce] FAIL: order-0 quarters did not merge\n")
        ok = 0
    if aft1 != base1:
        printk0("[buddy-coalesce] FAIL: order-1 residue left behind\n")
        ok = 0
    if aft2 != base2 + 1:
        printk0("[buddy-coalesce] FAIL: no order-2 block formed\n")
        ok = 0

    # Assertion B: the coalesced block is re-allocatable at the exact base.
    b2: uint64 = alloc_pages(2)
    if b2 != g:
        printk2("[buddy-coalesce] FAIL: realloc got %p want %p\n", b2, g)
        ok = 0

    # Restore allocator state: return the lower half (just re-taken) and
    # the upper half. They are order-2 buddies, so they merge back into
    # the original order-3 run and the pool is left exactly as found.
    if b2 != 0:
        free_pages(b2, 2)
    free_pages(g + 16384, 2)

    if ok == 1:
        printk0("[buddy-coalesce] PASS\n")
    else:
        printk0("[buddy-coalesce] SELFTEST FAIL\n")


def page_alloc_stress_test():
    # QA-N37 memory-pressure exercise for the free-list integrity guard.
    #
    # Phase 1 (must stay SILENT): hammer the buddy allocator with mixed-
    # order alloc/free churn so the split + coalesce + list-walk paths all
    # run hot. On legitimate traffic the guard must never report — any
    # [pa-corrupt] line here is a real regression in the allocator itself.
    #
    # Phase 2 (must SELF-HEAL): deliberately scribble a page that is on the
    # order-0 free list — exactly what a use-after-free / double-free does —
    # and prove the next allocation CATCHES it and survives, instead of
    # #GP-faulting on the wild `mov rax,[rax]` this guard exists to prevent.
    printk0("Hamnix: page_alloc stress test\n")
    PG: uint64 = 4096
    ITERS: uint64 = 256
    i: uint64 = 0
    oom: uint64 = 0
    while i < ITERS:
        a0: uint64 = alloc_pages(0)
        a1: uint64 = alloc_pages(1)
        a2: uint64 = alloc_pages(2)
        a3: uint64 = alloc_pages(0)
        if a0 == 0 or a1 == 0 or a2 == 0 or a3 == 0:
            oom = oom + 1
        # Free in a scrambled (non-LIFO) order to force list walks + merges.
        free_pages(a1, 1)
        free_pages(a3, 0)
        free_pages(a2, 2)
        free_pages(a0, 0)
        i = i + 1
    printk2("[pa-stress] churn done: %d iters, %d OOM\n", ITERS, oom)

    # Phase 2: corruption injection, isolated on an order-3 block we own so
    # the freed quarter can't merge (its order-0 buddy stays allocated) and
    # is therefore the sole order-0 head we then scribble.
    blk: uint64 = alloc_pages(3)
    if blk != 0:
        free_pages(blk + 2 * PG, 0)              # -> order-0 head, no merge
        cast[Ptr[uint64]](blk + 2 * PG)[0] = 0xBADC0FFEE0DDF00D
        cast[Ptr[uint64]](blk + 2 * PG + 8)[0] = 0x1122334455667788
        w: uint64 = alloc_pages(0)               # guard: catch + self-heal
        printk1("[pa-stress] survived corruption injection, realloc=%p\n", w)
        # Return every quarter we own (the guard handed the scribbled page
        # back as `w` == blk+2*PG; freeing all eight is a clean single free
        # of each). A bounded strand of any pre-existing order-0 entries the
        # self-heal truncated is acceptable for a one-shot boot selftest.
        free_pages(blk + 0 * PG, 0)
        free_pages(blk + 1 * PG, 0)
        free_pages(blk + 2 * PG, 0)
        free_pages(blk + 3 * PG, 0)
        free_pages(blk + 4 * PG, 0)
        free_pages(blk + 5 * PG, 0)
        free_pages(blk + 6 * PG, 0)
        free_pages(blk + 7 * PG, 0)
    printk0("[pa-stress] PASS (survived corruption injection)\n")


def slab_smoke_test():
    printk0("Hamnix: slab smoke test\n")
    a: uint64 = kmalloc(48)
    b: uint64 = kmalloc(48)
    c: uint64 = kmalloc(200)
    d: uint64 = kmalloc(1500)
    printk1("  kmalloc(  48) = %p\n", a)
    printk1("  kmalloc(  48) = %p\n", b)
    printk1("  kmalloc( 200) = %p\n", c)
    printk1("  kmalloc(1500) = %p\n", d)
    kfree(b)
    e: uint64 = kmalloc(48)
    printk1("  kmalloc(  48) after kfree(b) = %p  (expect == b)\n", e)
    cast[Ptr[uint64]](a)[0] = 0xCAFEBABE_DEADBEEF
    val: uint64 = cast[Ptr[uint64]](a)[0]
    printk1("  *a after write = %x\n", val)
    kfree(a)
    kfree(c)
    kfree(d)
    kfree(e)
    kfree(0x123456)        # bad pointer — magic check should warn

    # --- large kmalloc path: alloc_pages-backed -------------------
    large1: uint64 = kmalloc(8000)
    large2: uint64 = kmalloc(20000)
    large3: uint64 = kmalloc(100000)
    printk1("  kmalloc(  8000) = %p  (order 1)\n", large1)
    printk1("  kmalloc( 20000) = %p  (order 3)\n", large2)
    printk1("  kmalloc(100000) = %p  (order 5)\n", large3)

    cast[Ptr[uint8]](large3 + 99999)[0] = 0x5A
    val8: uint8 = cast[Ptr[uint8]](large3 + 99999)[0]
    printk1("  large3[99999] roundtrip = 0x%x  (expect 0x5a)\n",
            cast[uint64](val8))

    kfree(large1)
    kfree(large2)
    kfree(large3)

    reuse: uint64 = kmalloc(20000)
    printk1("  kmalloc(20000) after free = %p  (expect == prev)\n", reuse)
    kfree(reuse)

    # §13: KmallocLive — render the per-cache slab walker output.
    slabinfo: Array[640, uint8]
    sn: uint64 = kmalloc_live_render(&slabinfo[0], 640)
    slabinfo[sn] = 0
    printk0("Hamnix: KmallocLive slab walker:\n")
    printk0(cast[Ptr[char]](&slabinfo[0]))


def _mmf_expect_byte(i: uint64) -> uint8:
    # /etc/mmap-file-data content formula: byte i == (i*31 + 7) & 0xFF.
    return cast[uint8]((i * 31 + 7) & 0xFF)


def mmap_file_selftest():
    # §file-mmap: prove REAL file-backed mmap. (Body unchanged from
    # init/main.ad; moved verbatim under F10-5.)
    PROT_READ:   int32 = 0x1
    MAP_PRIVATE: int32 = 0x2
    PG: uint64 = 4096

    set_efer_nxe()

    boot_slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](boot_slot))

    data_idx: int64 = -1
    fi_idx: uint64 = 0
    fi_count: uint64 = initramfs_entry_count()
    while fi_idx < fi_count:
        fi_name: Ptr[char] = initramfs_entry_name(fi_idx)
        fi_ok: int32 = 1
        fi_tgt: Ptr[uint8] = "/etc/mmap-file-data"
        fi_j: uint64 = 0
        while fi_j < 20:                       # 19 chars + NUL
            if cast[uint8](fi_name[fi_j]) != fi_tgt[fi_j]:
                fi_ok = 0
                fi_j = 20
            else:
                fi_j = fi_j + 1
        if fi_ok == 1:
            data_idx = cast[int64](fi_idx)
            fi_idx = fi_count
        else:
            fi_idx = fi_idx + 1
    if data_idx < 0:
        printk0("[mmap-file] FAIL: /etc/mmap-file-data not in initramfs\n")
        return
    marker:  uint32 = FD_FILEMMAP_INITRAMFS
    backing: uint64 = cast[uint64](data_idx)
    fsize:   uint64 = initramfs_entry_size(cast[uint64](data_idx))
    printk2("[mmap-file] file size=%d cpio-idx=%d\n", fsize, backing)

    EXPECT_LEN: uint64 = 2 * PG + 100
    if fsize != EXPECT_LEN:
        printk2("[mmap-file] FAIL: size=%d want=%d\n", fsize, EXPECT_LEN)
        return

    # ---- Map 1: whole file at offset 0, PROT_READ MAP_PRIVATE ----------
    base64: int64 = vma_alloc_file_demand(boot_slot, 0, fsize,
                                          PROT_READ, MAP_PRIVATE,
                                          cast[int32](marker), backing,
                                          fsize, 0)
    if base64 < 0:
        printk0("[mmap-file] FAIL: vma_alloc_file_demand (map1) failed\n")
        return
    base: uint64 = cast[uint64](base64)
    npages: uint64 = (fsize + PG - 1) / PG
    fp: uint64 = 0
    while fp < npages:
        vma_demand_fault(boot_slot, boot_pml4, base + fp * PG)
        fp = fp + 1

    mism1: uint64 = 0
    bi: uint64 = 0
    while bi < fsize:
        got: uint8 = cast[Ptr[uint8]](base + bi)[0]
        if got != _mmf_expect_byte(bi):
            mism1 = mism1 + 1
        bi = bi + 1
    if mism1 != 0:
        printk1("[mmap-file] FAIL: map1 content mismatch (%d bytes)\n",
                mism1)
        return
    printk0("[mmap-file] map1 (offset 0) content OK\n")

    tail_zero_ok: int32 = 1
    last_page_end: uint64 = npages * PG
    ti: uint64 = fsize
    while ti < last_page_end:
        if cast[Ptr[uint8]](base + ti)[0] != 0:
            tail_zero_ok = 0
            ti = last_page_end
        else:
            ti = ti + 1
    if tail_zero_ok == 0:
        printk0("[mmap-file] FAIL: sub-page EOF tail not zero\n")
        return
    printk0("[mmap-file] sub-page EOF tail reads as zero OK\n")

    # ---- Map 2: same file at in-file OFFSET = one page -----------------
    off2: uint64 = PG
    len2: uint64 = fsize - off2
    base2_64: int64 = vma_alloc_file_demand(boot_slot, 0, len2,
                                            PROT_READ, MAP_PRIVATE,
                                            cast[int32](marker), backing,
                                            fsize, off2)
    if base2_64 < 0:
        printk0("[mmap-file] FAIL: vma_alloc_file_demand (map2) failed\n")
        return
    base2: uint64 = cast[uint64](base2_64)
    npages2: uint64 = (len2 + PG - 1) / PG
    fp2: uint64 = 0
    while fp2 < npages2:
        vma_demand_fault(boot_slot, boot_pml4, base2 + fp2 * PG)
        fp2 = fp2 + 1
    mism2: uint64 = 0
    bj: uint64 = 0
    while bj < len2:
        got2: uint8 = cast[Ptr[uint8]](base2 + bj)[0]
        if got2 != _mmf_expect_byte(off2 + bj):
            mism2 = mism2 + 1
        bj = bj + 1
    if mism2 != 0:
        printk1("[mmap-file] FAIL: map2 (offset) content mismatch (%d)\n",
                mism2)
        return
    printk0("[mmap-file] map2 (offset 4096) content OK\n")

    printk0("[mmap-file] PASS\n")


def _mms_expect_byte(i: uint64) -> uint8:
    # Known content of the shared-mmap backing file: byte i == (i*17+3)&0xFF.
    return cast[uint8]((i * 17 + 3) & 0xFF)


def mmap_shared_selftest():
    # §shared-mmap: prove MAP_SHARED writable file-backed mmap.
    # Body unchanged from init/main.ad; moved verbatim under F10-5.
    PROT_READ:  int32 = 0x1
    PROT_WRITE: int32 = 0x2
    MAP_SHARED: int32 = 0x01
    PG: uint64 = 4096

    set_efer_nxe()

    boot_slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](boot_slot))

    # ---- Build the known-content backing file on tmpfs -----------------
    fsize: uint64 = 2 * PG + 50
    fpath: Ptr[char] = "/tmp/mms-data"
    slot: int32 = tmpfs_open_for_write(fpath)
    if slot < 0:
        printk1("[mmap-shared] FAIL: tmpfs create rc=%d\n",
                cast[uint64](cast[int64](slot)))
        return
    fillbuf: Array[256, uint8]
    wpos: uint64 = 0
    while wpos < fsize:
        n: uint64 = fsize - wpos
        if n > 256:
            n = 256
        bk: uint64 = 0
        while bk < n:
            fillbuf[bk] = _mms_expect_byte(wpos + bk)
            bk = bk + 1
        wrote: uint64 = tmpfs_write(slot, &fillbuf[0], wpos, n)
        if wrote != n:
            printk0("[mmap-shared] FAIL: tmpfs short write\n")
            return
        wpos = wpos + n
    if tmpfs_size(slot) != fsize:
        printk2("[mmap-shared] FAIL: tmpfs size=%d want=%d\n",
                tmpfs_size(slot), fsize)
        return
    marker:  uint32 = FD_TMPFS_MARK
    backing: uint64 = cast[uint64](cast[uint32](slot))
    printk2("[mmap-shared] tmpfs file size=%d slot=%d\n", fsize, backing)

    # ---- Map 1: whole file, MAP_SHARED | PROT_READ|PROT_WRITE ----------
    base64: int64 = vma_alloc_file_shared(boot_slot, 0, fsize,
                                          PROT_READ | PROT_WRITE,
                                          MAP_SHARED,
                                          cast[int32](marker), backing,
                                          fsize, 0)
    if base64 < 0:
        printk0("[mmap-shared] FAIL: vma_alloc_file_shared (map1)\n")
        return
    base: uint64 = cast[uint64](base64)
    npages: uint64 = (fsize + PG - 1) / PG
    fp: uint64 = 0
    while fp < npages:
        vma_demand_fault(boot_slot, boot_pml4, base + fp * PG)
        fp = fp + 1

    mism1: uint64 = 0
    bi: uint64 = 0
    while bi < fsize:
        if cast[Ptr[uint8]](base + bi)[0] != _mms_expect_byte(bi):
            mism1 = mism1 + 1
        bi = bi + 1
    if mism1 != 0:
        printk1("[mmap-shared] FAIL: map1 initial content mismatch (%d)\n",
                mism1)
        return
    printk0("[mmap-shared] map1 initial content OK\n")

    # ---- Modify a span THROUGH the mapping, then msync(MS_SYNC) --------
    mod_start: uint64 = PG - 80
    mod_len:   uint64 = 200
    mp: uint64 = 0
    while mp < mod_len:
        cast[Ptr[uint8]](base + mod_start + mp)[0] = \
            cast[uint8](((mod_start + mp) * 23 + 11) & 0xFF)
        mp = mp + 1
    msrc: int64 = vma_writeback_range(boot_slot, base, fsize)
    if msrc < 0:
        printk1("[mmap-shared] FAIL: writeback rc=%d\n",
                cast[uint64](msrc))
        return
    printk0("[mmap-shared] msync(MS_SYNC) write-back OK\n")

    rdbuf: Array[256, uint8]
    rd_mism: uint64 = 0
    ri: uint64 = mod_start
    while ri < mod_start + mod_len:
        chunk: uint64 = mod_start + mod_len - ri
        if chunk > 256:
            chunk = 256
        got: uint64 = tmpfs_read(slot, &rdbuf[0], ri, chunk)
        if got != chunk:
            printk0("[mmap-shared] FAIL: tmpfs read short during verify\n")
            return
        ck: uint64 = 0
        while ck < chunk:
            want: uint8 = cast[uint8](((ri + ck) * 23 + 11) & 0xFF)
            if rdbuf[ck] != want:
                rd_mism = rd_mism + 1
            ck = ck + 1
        ri = ri + chunk
    if rd_mism != 0:
        printk1("[mmap-shared] FAIL: backing file missing writes (%d)\n",
                rd_mism)
        return
    printk0("[mmap-shared] backing file holds the modified bytes OK\n")

    if tmpfs_read(slot, &rdbuf[0], 0, 16) != 16:
        printk0("[mmap-shared] FAIL: tmpfs read head\n")
        return
    head_ok: int32 = 1
    hk: uint64 = 0
    while hk < 16:
        if rdbuf[hk] != _mms_expect_byte(hk):
            head_ok = 0
            hk = 16
        else:
            hk = hk + 1
    if head_ok == 0:
        printk0("[mmap-shared] FAIL: unmodified region corrupted\n")
        return
    printk0("[mmap-shared] unmodified region preserved OK\n")

    # ---- Map 2: a fresh mapping must SEE the written-back bytes --------
    base2_64: int64 = vma_alloc_file_shared(boot_slot, 0, fsize,
                                            PROT_READ | PROT_WRITE,
                                            MAP_SHARED,
                                            cast[int32](marker), backing,
                                            fsize, 0)
    if base2_64 < 0:
        printk0("[mmap-shared] FAIL: vma_alloc_file_shared (map2)\n")
        return
    base2: uint64 = cast[uint64](base2_64)
    fp2: uint64 = 0
    while fp2 < npages:
        vma_demand_fault(boot_slot, boot_pml4, base2 + fp2 * PG)
        fp2 = fp2 + 1
    m2_mism: uint64 = 0
    bj: uint64 = mod_start
    while bj < mod_start + mod_len:
        want2: uint8 = cast[uint8]((bj * 23 + 11) & 0xFF)
        if cast[Ptr[uint8]](base2 + bj)[0] != want2:
            m2_mism = m2_mism + 1
        bj = bj + 1
    if m2_mism != 0:
        printk1("[mmap-shared] FAIL: fresh mmap missing writes (%d)\n",
                m2_mism)
        return
    printk0("[mmap-shared] fresh mmap sees written-back bytes OK\n")

    printk0("[mmap-shared] PASS\n")

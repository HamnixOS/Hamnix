# tests/test_p9_dir.ad
#
# #458 F10-6 acceptance gate — Plan 9 Dir record + p9_diread end-to-end
# across the userspace wrapper, the new SYS_LISTDIR_RECORDS syscall,
# and the migrated devsrv_list_dir kernel emitter.
#
# Flow:
#   1. Open a pipe so we have a valid fd to post into /srv.
#   2. sys_srv_post("dirtest", wfd) — plants a posted name.
#   3. p9_diread_open("/srv") — primes the userspace cursor by reading
#      the kernel's Dir-record stream into a BSS buffer.
#   4. Walk records with p9_diread(fd) — expect to land on a record
#      whose DIR_CUR_NAME is "dirtest".
#   5. Verify the decoded mode field matches the kernel's emit
#      (SRV_DIR_MODE = 0444) and uid == "hostowner".
#
# Markers grepped by scripts/test_p9_dir.sh:
#   [p9dir] start
#   [p9dir] posted
#   [p9dir] listdir_records OK
#   [p9dir] dir record decoded
#   [p9dir] name match OK
#   [p9dir] uid match OK
#   [p9dir] mode match OK
#   [p9dir] PASS

from lib.p9 import (
    p9_listdir_records, p9_diread_open, p9_diread, p9_diread_close,
    DIR_CUR_NAME, DIR_CUR_NAME_LEN,
    DIR_CUR_UID, DIR_CUR_UID_LEN,
    DIR_CUR_MODE,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_exit(code: uint64)
extern def sys_srv_post(name: Ptr[char], srvfd: int32) -> int32


fds_buf: Array[2, int32]
buf_check: Array[4096, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def main() -> int32:
    write_str(1, "[p9dir] start\n")

    # 1. pipe for a postable fd.
    if sys_pipe(&fds_buf[0]) < 0:
        write_str(1, "[p9dir] FAIL: sys_pipe\n")
        return 1
    rfd: int32 = fds_buf[0]
    wfd: int32 = fds_buf[1]

    # 2. post wfd at /srv/dirtest.
    if sys_srv_post("dirtest", wfd) < 0:
        write_str(1, "[p9dir] FAIL: sys_srv_post\n")
        return 2
    write_str(1, "[p9dir] posted\n")

    # Smoke 1: bulk read via p9_listdir_records into a local buffer.
    # Asserts the syscall arm + devsrv_list_dir produce a non-empty
    # byte stream (real record content is verified by the p9_diread
    # walk below).
    n: int64 = p9_listdir_records("/srv", &buf_check[0], 4096)
    if n <= 0:
        write_str(1, "[p9dir] FAIL: p9_listdir_records returned <=0\n")
        return 3
    write_str(1, "[p9dir] listdir_records OK\n")

    # 3. walk Dir records via p9_diread.
    h: int32 = p9_diread_open("/srv")
    if h < 0:
        write_str(1, "[p9dir] FAIL: p9_diread_open\n")
        return 4

    saw_name: int32 = 0
    saw_uid:  int32 = 0
    saw_mode: int32 = 0
    while True:
        rc: int32 = p9_diread(h)
        if rc < 0:
            write_str(1, "[p9dir] FAIL: p9_diread error\n")
            p9_diread_close(h)
            return 5
        if rc == 0:
            break                                    # EOF
        write_str(1, "[p9dir] dir record decoded\n")
        # Check the just-decoded record. Mode must be 0444 (SRV_DIR_MODE
        # in devsrv.ad). Name and uid only verified for the "dirtest"
        # entry we ourselves posted.
        if DIR_CUR_MODE == 0x00000444:
            saw_mode = 1
        if streq(cast[Ptr[uint8]](&DIR_CUR_NAME[0]),
                 cast[Ptr[uint8]]("dirtest")) != 0:
            saw_name = 1
            if streq(cast[Ptr[uint8]](&DIR_CUR_UID[0]),
                     cast[Ptr[uint8]]("hostowner")) != 0:
                saw_uid = 1

    p9_diread_close(h)

    if saw_name == 0:
        write_str(1, "[p9dir] FAIL: did not see 'dirtest' record\n")
        return 6
    write_str(1, "[p9dir] name match OK\n")
    if saw_uid == 0:
        write_str(1, "[p9dir] FAIL: uid != 'hostowner'\n")
        return 7
    write_str(1, "[p9dir] uid match OK\n")
    if saw_mode == 0:
        write_str(1, "[p9dir] FAIL: mode != 0444\n")
        return 8
    write_str(1, "[p9dir] mode match OK\n")

    sys_close(rfd)
    write_str(1, "[p9dir] PASS\n")
    return 0

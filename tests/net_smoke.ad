        printk0("[https] GET failed\n")
        return
    printk2("[https] GET example.com -> status=%d body=%dbytes\n",
            cast[uint64](https_status), cast[uint64](n))
    printk0("[https] body[0..96]: '")
    body_n: uint64 = cast[uint64](n)
    if body_n > 96:
        body_n = 96
    i: uint64 = 0
    while i < body_n:
        c: uint8 = https_body[i]
        if c == 0x0A:
            printk0("\\n")
        elif c == 0x0D:
            printk0("\\r")
        elif c < 0x20:
            printk0(".")
        elif c > 0x7E:
            printk0(".")
        else:

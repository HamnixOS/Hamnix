from kernel.sched.core import (
    sched_init, sched_mark_boot_task_running, kthread_create, create_user_task,
    start_first_task, current_task_pid, task_pml4,
    # HAMSH §13: the init task's loaded-image span must be recorded so
    # rfork() COW-copies its writable .data/.bss into a child. Without
    # this an `ns {}` / `enter` child shares /init's globals with the
    # parent and a variable set inside the block leaks back out.
    set_task_image_range,
    # F10-3 #456: explicit PID-1 uid stamp. create_user_task hands back
    # a task with uid = UID_NOBODY (the post-F10-3 default); init/main.ad
    # upgrades PID 1 to UID_HOSTOWNER right after slot publish so the
    # boot path runs as hostowner. Every subsequent task forks from
    # init and inherits hostowner via the parent_uid branch in
    # create_user_thread.
    set_task_uid_at, UID_HOSTOWNER,
    # SMP: create per-AP idle kthreads after sched_init() to avoid PID
    # counter collisions.  Called once per AP that came online.
    sched_prepare_ap_idle,
    # SMP kthread churn soak (ENABLE_SMP_SOAK=1).
    smp_kthread_soak_run,
    # #151: CFS-lite + SMP load-balance self-test (ENABLE_SCHED_FAIR=1).
    sched_fair_smp_selftest,
    # Stage-A per-CPU TSS: USER-task-runs-on-AP self-test (ENABLE_SMP_USER=1).
    smp_user_ap_selftest,
    # per-task oom_score_adj store + OOM-killer exemption/clamp self-test
    # (ENABLE_OOMADJ_TEST=1).
    oomadj_selftest,
    # F10-10 / #457: per-Pgrp oom_score_adj field + clamp + clone-
    # independence self-test (the body lives in chan.ad next to the Pgrp
    # struct it operates on; imported here to wire into the boot-stage
    # marker-gated dispatcher).
    # NOTE: pgrp_oomadj_selftest is in sys.src.port9.port.chan, not
    # kernel.sched.core. Imported below in its own from-block.
    # F10-8 / #457: NATIVE seccomp-lite filter self-test
    # (ENABLE_SECCOMP_NATIVE_TEST=1).
    seccomp_native_selftest,
    # SCHED_FIFO/SCHED_RR realtime scheduling policy self-test
    # (ENABLE_RTSCHED_TEST=1).
    rtsched_selftest,
)

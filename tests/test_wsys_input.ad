# tests/test_wsys_input.ad
#
# hamUI per-window structured INPUT EVENT surface regression. Exercises
# the kernel-side rings + blocking-read plumbing added to
# sys/src/9/port/devwsys.ad and wired through sys/src/9/port/namec.ad:
#
#   /dev/wsys/<N>/pointer  "<type> <x> <y> <buttons> <dz>\n"  (routed)
#   /dev/wsys/<N>/keys      "<type> <code>\n"                 (focused win)
#
# The compositor (user/hamUId.ad) is the SOLE writer in production: it
# has already done pointer hit-test / focus routing and emits window-
# space event lines. This fixture stands in for that producer AND the
# consumer in ONE process: it WRITES an event line to wid 1's pointer /
# keys file, then READS it back, asserting the exact bytes round-trip
# through the kernel ring. Because the ring already holds data when we
# read, the blocking read returns immediately (no deadlock) — so this is
# a clean single-process e2e of the ring + namec dispatch without needing
# two scheduled tasks. (The blocking/wake path itself is the same
# wq_wait_prepare/commit dance fs/vfs.ad's pipe reader uses and is
# covered by the pipe tests.)
#
# All I/O is via sys_open/sys_read/sys_write directly (no hamsh typing),
# so assertions are immune to the serial-echo corruption that flakes the
# interactive tests under host load.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_wsys_input.ad -o build/user/test_wsys_input.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def _bytes_contains(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    nn: uint64 = strlen(needle)
    if nn == 0:
        return 1
    if nn > n:
        return 0
    limit: uint64 = n - nn
    i: uint64 = 0
    while i <= limit:
        j: uint64 = 0
        ok: int32 = 1
        while j < nn:
            if buf[i + j] != needle[j]:
                ok = 0
            j = j + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[test_wsys_input] start\n")
    fails: int32 = 0

    # ---- 1. POINTER: write a routed motion event, read it back ------
    pw: int32 = sys_open_write("/dev/wsys/1/pointer")
    if pw < 0:
        write_str(1, "[test_wsys_input] pointer open-write FAIL\n")
        fails = fails + 1
    else:
        ev: Ptr[uint8] = "m 42 17 1 0\n"
        sys_write(pw, ev, strlen(ev))
        sys_close(pw)
        write_str(1, "[test_wsys_input] pointer_write_ok=1\n")

    pr: int32 = sys_open("/dev/wsys/1/pointer")
    if pr < 0:
        write_str(1, "[test_wsys_input] pointer open-read FAIL\n")
        fails = fails + 1
    else:
        pb: Array[128, uint8]
        n: int64 = sys_read(pr, &pb[0], 128)
        sys_close(pr)
        if n <= 0:
            write_str(1, "[test_wsys_input] pointer read FAIL\n")
            fails = fails + 1
        elif _bytes_contains(&pb[0], cast[uint64](n), "m 42 17 1 0") == 0:
            write_str(1, "[test_wsys_input] pointer event mismatch FAIL: ")
            sys_write(1, &pb[0], cast[uint64](n))
            write_str(1, "\n")
            fails = fails + 1
        else:
            write_str(1, "[test_wsys_input] pointer_read_ok=1\n")

    # ---- 2. POINTER drains: a SECOND read with no new event -> 0 ----
    # The ring was emptied by the read above; nothing new was written, so
    # a non-blocking-shaped check is impossible here (read blocks), but we
    # CAN verify a fresh write + read still works (cursor compaction).
    pw2: int32 = sys_open_write("/dev/wsys/1/pointer")
    if pw2 >= 0:
        ev2: Ptr[uint8] = "d 10 20 1 0\n"
        sys_write(pw2, ev2, strlen(ev2))
        sys_close(pw2)
    pr2: int32 = sys_open("/dev/wsys/1/pointer")
    if pr2 >= 0:
        pb2: Array[128, uint8]
        n2: int64 = sys_read(pr2, &pb2[0], 128)
        sys_close(pr2)
        if n2 > 0 and _bytes_contains(&pb2[0], cast[uint64](n2),
                                      "d 10 20 1 0") != 0:
            write_str(1, "[test_wsys_input] pointer_recompact_ok=1\n")
        else:
            write_str(1, "[test_wsys_input] pointer recompact FAIL\n")
            fails = fails + 1

    # ---- 3. KEYS: write a press event, read it back -----------------
    kw: int32 = sys_open_write("/dev/wsys/1/keys")
    if kw < 0:
        write_str(1, "[test_wsys_input] keys open-write FAIL\n")
        fails = fails + 1
    else:
        ke: Ptr[uint8] = "d 65\n"
        sys_write(kw, ke, strlen(ke))
        sys_close(kw)
        write_str(1, "[test_wsys_input] keys_write_ok=1\n")

    kr: int32 = sys_open("/dev/wsys/1/keys")
    if kr < 0:
        write_str(1, "[test_wsys_input] keys open-read FAIL\n")
        fails = fails + 1
    else:
        kb: Array[64, uint8]
        kn: int64 = sys_read(kr, &kb[0], 64)
        sys_close(kr)
        if kn <= 0:
            write_str(1, "[test_wsys_input] keys read FAIL\n")
            fails = fails + 1
        elif _bytes_contains(&kb[0], cast[uint64](kn), "d 65") == 0:
            write_str(1, "[test_wsys_input] keys event mismatch FAIL\n")
            fails = fails + 1
        else:
            write_str(1, "[test_wsys_input] keys_read_ok=1\n")

    if fails == 0:
        write_str(1, "[test_wsys_input] PASS\n")
    else:
        write_str(1, "[test_wsys_input] FAIL\n")
    sys_exit(0)
    return 0

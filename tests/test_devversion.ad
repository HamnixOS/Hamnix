# tests/test_devversion.ad
#
# Regression: open /dev/version for read, drain up to 64 bytes, echo
# the captured slice to stdout. The script asserts the captured text
# contains the substring "hamnix" — that proves the cdev is wired
# (open OK + read returns the literal release-identity blob).
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devversion.ad -o build/user/test_devversion.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Search the captured blob for the substring "hamnix". Returns 1 on
# match, 0 otherwise. Naive O(n*m) scan — the blob is at most 64
# bytes so the constant factors don't matter.
def _contains_hamnix(buf: Ptr[uint8], n: uint64) -> int32:
    if n < 6:
        return 0
    needle: Array[7, uint8]
    needle[0] = 104                                    # 'h'
    needle[1] = 97                                     # 'a'
    needle[2] = 109                                    # 'm'
    needle[3] = 110                                    # 'n'
    needle[4] = 105                                    # 'i'
    needle[5] = 120                                    # 'x'
    needle[6] = 0
    limit: uint64 = n - 6
    i: uint64 = 0
    while i <= limit:
        j: uint64 = 0
        ok: int32 = 1
        while j < 6:
            if buf[i + j] != needle[j]:
                ok = 0
                j = 6
            else:
                j = j + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[test_devversion] start\n")

    fd: int32 = sys_open("/dev/version")
    if fd < 0:
        write_str(1, "[test_devversion] open failed\n")
        return 1
    write_str(1, "[test_devversion] opened /dev/version OK\n")

    buf: Array[128, uint8]
    n: int64 = sys_read(fd, &buf[0], 64)
    if n <= 0:
        write_str(1, "[test_devversion] read returned <= 0\n")
        sys_close(fd)
        return 1

    write_str(1, "[test_devversion] blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))

    if _contains_hamnix(&buf[0], cast[uint64](n)) == 0:
        write_str(1, "[test_devversion] hamnix substring FAIL\n")
        sys_close(fd)
        return 1

    # Emit the PASS marker the script greps for.
    write_str(1, "[test_devversion] contains_hamnix=1\n")

    # EOF discipline: a SECOND read (fd_pos now past the blob) MUST return
    # 0 (EOF), not regenerate the blob again. Without this guard a
    # read-to-EOF consumer — `cat /dev/version`, the DE text editor's
    # chunk loop — spins forever re-reading the same bytes (the
    # user-reported "open /dev/version in hamedit floods/hangs the box").
    n2: int64 = sys_read(fd, &buf[0], 64)
    if n2 != 0:
        write_str(1, "[test_devversion] EOF FAIL: second read did not return 0\n")
        sys_close(fd)
        return 1
    write_str(1, "[test_devversion] second_read_eof=1\n")

    sys_close(fd)
    write_str(1, "[test_devversion] done\n")
    return 0

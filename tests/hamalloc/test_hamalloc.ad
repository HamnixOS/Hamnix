# tests/hamalloc/test_hamalloc.ad
#
# Exercises lib/hamalloc.ad — the userland heap allocator over sys_mmap.
#
# Tests (each prints "[hamalloc] T<n> PASS" / "... FAIL ..."):
#   T1  alloc/write/readback + NON-OVERLAP of two live allocations
#   T2  free-then-alloc reuses memory (LIFO same-class pointer reuse)
#   T3  every returned pointer is 16-byte aligned (all size classes)
#   T4  realloc grows a block and PRESERVES the old bytes
#   T5  large alloc (> 2048) via direct mmap: write/read + free (munmap)
#   T6  churn stress: thousands of alloc/free cycles, per-block pattern
#       verified on free, mapped footprint BOUNDED, final checksum match
#
# Final banner: "[hamalloc] PASS" and a "[hamalloc] CHK <hex>" checksum.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/hamalloc/test_hamalloc.ad -o build/user/test_hamalloc.elf
# Run via scripts/test_adder_hamalloc.sh.

from lib.hamalloc import (ham_alloc, ham_free, ham_realloc, ham_total_bytes)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(s: Ptr[uint8]):
    sys_write(1, s, strlen(s))


def write_dec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


def write_hex(value: uint64):
    sys_write(1, "0x", 2)
    nibbles: Array[16, uint8]
    n: uint64 = 0
    v: uint64 = value
    if v == 0:
        sys_write(1, "0", 1)
        return
    while v != 0:
        nib: uint64 = v & 15
        if nib < 10:
            nibbles[n] = cast[uint8](nib) + 48
        else:
            nibbles[n] = cast[uint8](nib - 10) + 97
        v = v >> 4
        n = n + 1
    out: Array[16, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = nibbles[n]
        i = i + 1
    sys_write(1, &out[0], i)


def is_null(p: Ptr[uint8]) -> uint64:
    if p == cast[Ptr[uint8]](0):
        return 1
    return 0


# Deterministic byte pattern keyed by a block id + offset (avoids all-equal
# fills so overlap/corruption is actually observable).
def pat(id: uint64, off: uint64) -> uint8:
    return cast[uint8]((id * 131 + off * 7 + 17) & 255)


def fill(p: Ptr[uint8], id: uint64, n: uint64):
    i: uint64 = 0
    while i < n:
        p[i] = pat(id, i)
        i = i + 1


# Verify pattern; return 0 == OK, 1 == mismatch.
def check(p: Ptr[uint8], id: uint64, n: uint64) -> uint64:
    i: uint64 = 0
    while i < n:
        if p[i] != pat(id, i):
            return 1
        i = i + 1
    return 0


def main() -> int32:
    write_str("[hamalloc] start\n")
    fail: int32 = 0

    # ── T1: alloc/write/readback + non-overlap ────────────────────
    a: Ptr[uint8] = ham_alloc(100)
    b: Ptr[uint8] = ham_alloc(100)
    if is_null(a) != 0 or is_null(b) != 0:
        write_str("[hamalloc] T1 FAIL: alloc returned null\n")
        return 1
    fill(a, 1, 100)
    fill(b, 2, 100)
    if check(a, 1, 100) != 0 or check(b, 2, 100) != 0:
        write_str("[hamalloc] T1 FAIL: readback/overlap corruption\n")
        fail = 1
    if cast[uint64](a) == cast[uint64](b):
        write_str("[hamalloc] T1 FAIL: two live allocations alias\n")
        fail = 1
    if fail == 0:
        write_str("[hamalloc] T1 PASS\n")

    # ── T2: free-then-alloc reuses freed memory ───────────────────
    c: Ptr[uint8] = ham_alloc(64)
    caddr: uint64 = cast[uint64](c)
    ham_free(c)
    d: Ptr[uint8] = ham_alloc(64)
    if cast[uint64](d) != caddr:
        write_str("[hamalloc] T2 FAIL: freed block not reused, got ")
        write_hex(cast[uint64](d))
        write_str(" want ")
        write_hex(caddr)
        write_str("\n")
        fail = 1
    else:
        write_str("[hamalloc] T2 PASS\n")
    ham_free(d)
    ham_free(a)
    ham_free(b)

    # ── T3: 16-byte alignment across all size classes ─────────────
    align_ok: int32 = 1
    sizes: Array[8, uint64]
    sizes[0] = 1
    sizes[1] = 15
    sizes[2] = 33
    sizes[3] = 100
    sizes[4] = 250
    sizes[5] = 700
    sizes[6] = 1500
    sizes[7] = 2048
    si: uint64 = 0
    while si < 8:
        q: Ptr[uint8] = ham_alloc(sizes[si])
        if is_null(q) != 0 or (cast[uint64](q) & 15) != 0:
            write_str("[hamalloc] T3 FAIL: misaligned ptr ")
            write_hex(cast[uint64](q))
            write_str(" for size ")
            write_dec(sizes[si])
            write_str("\n")
            align_ok = 0
        ham_free(q)
        si = si + 1
    if align_ok != 0:
        write_str("[hamalloc] T3 PASS\n")
    else:
        fail = 1

    # ── T4: realloc grows + preserves bytes ───────────────────────
    e: Ptr[uint8] = ham_alloc(40)
    fill(e, 7, 40)
    e = ham_realloc(e, 400)
    if is_null(e) != 0 or check(e, 7, 40) != 0:
        write_str("[hamalloc] T4 FAIL: realloc lost data\n")
        fail = 1
    else:
        write_str("[hamalloc] T4 PASS\n")
    ham_free(e)

    # ── T5: large (> 2048) direct-mmap alloc/free ─────────────────
    big: uint64 = 5000
    g: Ptr[uint8] = ham_alloc(big)
    if is_null(g) != 0:
        write_str("[hamalloc] T5 FAIL: large alloc null\n")
        fail = 1
    else:
        fill(g, 9, big)
        if check(g, 9, big) != 0:
            write_str("[hamalloc] T5 FAIL: large readback corrupt\n")
            fail = 1
        else:
            write_str("[hamalloc] T5 PASS\n")
        ham_free(g)

    # ── T6: churn stress with a bounded live working set ──────────
    NSLOT: uint64 = 64
    live: Array[64, uint64]        # payload ptr (0 == empty)
    lid:  Array[64, uint64]        # block id
    lsz:  Array[64, uint64]        # block size
    k: uint64 = 0
    while k < NSLOT:
        live[k] = 0
        k = k + 1

    checksum: uint64 = 0
    rng: uint64 = 0x1234567
    ITERS: uint64 = 20000
    baseline: uint64 = 0
    corrupt: int32 = 0
    it: uint64 = 0
    while it < ITERS:
        rng = rng * 6364136223846793005 + 1442695040888963407
        slot: uint64 = (rng >> 33) % NSLOT
        if live[slot] != 0:
            # verify + free
            pp: Ptr[uint8] = cast[Ptr[uint8]](live[slot])
            if check(pp, lid[slot], lsz[slot]) != 0:
                corrupt = 1
            checksum = checksum + lid[slot] * lsz[slot]
            ham_free(pp)
            live[slot] = 0
        else:
            rng = rng * 6364136223846793005 + 1442695040888963407
            sz: uint64 = 1 + (rng >> 40) % 900
            np: Ptr[uint8] = ham_alloc(sz)
            if is_null(np) != 0:
                write_str("[hamalloc] T6 FAIL: alloc null at iter ")
                write_dec(it)
                write_str("\n")
                return 1
            id: uint64 = (it & 0xFFFF) + 1
            fill(np, id, sz)
            live[slot] = cast[uint64](np)
            lid[slot] = id
            lsz[slot] = sz
        # Sample the mapped footprint once the working set is warm.
        if it == 4000:
            baseline = ham_total_bytes()
        it = it + 1

    # Drain remaining live blocks.
    k = 0
    while k < NSLOT:
        if live[k] != 0:
            pp2: Ptr[uint8] = cast[Ptr[uint8]](live[k])
            if check(pp2, lid[k], lsz[k]) != 0:
                corrupt = 1
            checksum = checksum + lid[k] * lsz[k]
            ham_free(pp2)
            live[k] = 0
        k = k + 1

    final_mapped: uint64 = ham_total_bytes()
    if corrupt != 0:
        write_str("[hamalloc] T6 FAIL: block corruption during churn\n")
        fail = 1
    else:
        if final_mapped > baseline:
            # Footprint grew AFTER warm-up -> memory not being reused.
            write_str("[hamalloc] T6 FAIL: unbounded growth base=")
            write_dec(baseline)
            write_str(" final=")
            write_dec(final_mapped)
            write_str("\n")
            fail = 1
        else:
            write_str("[hamalloc] T6 PASS (mapped=")
            write_dec(final_mapped)
            write_str(" bytes)\n")

    write_str("[hamalloc] CHK ")
    write_hex(checksum)
    write_str("\n")

    if fail != 0:
        write_str("[hamalloc] FAIL\n")
        return 1
    write_str("[hamalloc] PASS\n")
    return 0

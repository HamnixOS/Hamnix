# tests/hamalloc/test_hamstr.ad
#
# Owning-heap-String demo on top of lib/hamalloc.ad — the capability the
# roadmap's `String` VIEW type could NOT express (it borrows caller-owned
# storage; it cannot OWN or GROW its bytes). With the userland allocator:
#   * ham_str_dup  — heap-COPY a byte range into an owning, NUL-terminated
#                    allocation the caller frees
#   * ham_str_cat  — build a BRAND-NEW owning concatenation (growable `+`)
#   * ham_str_free — return it to the heap
#
# Prints "[hamstr] S<n> PASS" per check, "[hamstr] PASS" at the end.
# A pure LIBRARY demo — no compiler change, no new String machinery.

from lib.hamalloc import (ham_str_dup, ham_str_cat, ham_str_free)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def puts(s: Ptr[uint8]):
    sys_write(1, s, slen(s))


def is_null(p: Ptr[uint8]) -> uint64:
    if p == cast[Ptr[uint8]](0):
        return 1
    return 0


# streq over two NUL-terminated strings: 1 == equal.
def streq(a: Ptr[uint8], b: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


def main() -> int32:
    puts("[hamstr] start\n")
    fail: int32 = 0

    # S1: dup makes an owning, independent, NUL-terminated copy.
    src: Ptr[uint8] = "hamnix"
    owned: Ptr[uint8] = ham_str_dup(src, slen(src))
    if is_null(owned) != 0 or slen(owned) != 6 or streq(owned, "hamnix") != 1:
        puts("[hamstr] S1 FAIL: str_dup wrong\n")
        fail = 1
    else:
        puts("[hamstr] S1 PASS\n")

    # S2: cat builds a NEW growable owning concatenation.
    joined: Ptr[uint8] = ham_str_cat(owned, " heap")
    if is_null(joined) != 0 or slen(joined) != 11 or streq(joined, "hamnix heap") != 1:
        puts("[hamstr] S2 FAIL: str_cat wrong\n")
        fail = 1
    else:
        puts("[hamstr] S2 got=")
        puts(joined)
        puts("\n[hamstr] S2 PASS\n")

    # S3: the concatenation is independent — freeing the source leaves it
    # intact (owning semantics, not a view).
    ham_str_free(owned)
    if streq(joined, "hamnix heap") != 1:
        puts("[hamstr] S3 FAIL: cat aliased freed source\n")
        fail = 1
    else:
        puts("[hamstr] S3 PASS\n")
    ham_str_free(joined)

    if fail != 0:
        puts("[hamstr] FAIL\n")
        return 1
    puts("[hamstr] PASS\n")
    return 0

# Descriptive-trap fixture (roadmap item 3): an OUT-OF-RANGE Array index under
# --check-bounds must print a descriptive `bounds: … at file:line` message to
# stderr (fd 2) BEFORE trapping with ud2 -> SIGILL (wait-status 132). Same
# shape as membounds/oob.ad; the index is data-dependent (argc) so it can't be
# folded away. See scripts/test_adder_descriptive_trap.sh.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    i: int32 = argc + 100
    return a[i]

# `@unsafe` function attribute (roadmap item 3): the decorator suppresses the
# opt-in safety checks in the WHOLE body, exactly like an `unsafe:` block. The
# same out-of-range index as oob_desc.ad, but the function is `@unsafe`, so NO
# bounds check is emitted and NO trap fires — the process returns 0 cleanly.
# (A READ a few hundred bytes up the live stack is harmless; no OOB write.)
@unsafe
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    i: int32 = argc + 100
    r: int32 = 0
    r = a[i]
    return 0

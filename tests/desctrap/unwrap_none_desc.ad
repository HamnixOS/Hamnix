# Descriptive-trap fixture (roadmap item 3): a None force-unwrap `!` under
# --check-bounds must print `unwrap of None/Err at file:line` to stderr BEFORE
# trapping (ud2 -> SIGILL, wait-status 132).
def find_positive(x: int32) -> Option:
    if x > 0:
        return Some(x)
    return None

def main() -> int32:
    o: Option = find_positive(0 - 5)        # None
    v: int64 = cast[int64](o!)              # None-deref: descriptive trap
    return cast[int32](v)

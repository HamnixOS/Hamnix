# adder: unsafe
# `# adder: unsafe` whole-file pragma (roadmap item 3): the pragma above marks
# EVERY function in this file unsafe, suppressing the opt-in safety checks even
# under --check-bounds. The same out-of-range index as oob_desc.ad, but no
# bounds check is emitted and no trap fires — the process returns 0 cleanly.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    i: int32 = argc + 100
    r: int32 = 0
    r = a[i]
    return 0

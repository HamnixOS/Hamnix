# tests/test_xz.ad
#
# Regression for the lib/xz/xz.ad `.xz` (LZMA2 / LZMA) decompressor.
#
# Imports the GENERATED tests/test_xz_fixtures.ad — four payloads
# compressed by the host `xz` binary (see scripts/gen_xz_fixture.py)
# — and asserts xz_decompress() recovers each one byte-exact:
#
#   fx1  small ASCII, one LZMA2 chunk        (literal-heavy path)
#   fx2  highly repetitive ("abcdefgh " x64) (match-copy-heavy path)
#   fx3  an RFC822 Packages stanza           (the apt use case shape)
#   fx4  96 KiB pseudo-random/compressible, --block-size=32768
#        (forces a MULTI-BLOCK xz stream + many LZMA2 chunks)
#
# Plus negative cases: a corrupted-magic stream and a truncated stream
# both return a negative error code.
#
# Driven by scripts/test_xz.sh: regenerates the fixtures, builds this
# .ad as a userland x86_64 ELF, plants it at /bin/test_xz in the cpio
# initramfs, boots QEMU + hamsh, runs the binary, and greps the serial
# log for the [xz] PASS banner. Shape mirrors test_inflate.

from lib.xz.xz import (
    xz_decompress,
    xz_dbg_site,
    xz_dbg_a,
    xz_dbg_b,
)

from tests.test_xz_fixtures import (
    init_xz_fixtures,
    fx1_xz, fx1_xz_len, fx1_plain, fx1_plain_len,
    fx2_xz, fx2_xz_len, fx2_plain, fx2_plain_len,
    fx3_xz, fx3_xz_len, fx3_plain, fx3_plain_len,
    fx4_xz, fx4_xz_len, fx4_plain, fx4_plain_len,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer ------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


def _wsdec(value: int64):
    if value < 0:
        sys_write(1, "-", 1)
        _wdec(cast[uint64](0 - value))
    else:
        _wdec(cast[uint64](value))


# -- failure aggregator ------------------------------------------------

fail_count: int32 = 0


def _bytes_eq(a: Ptr[uint8], a_len: uint64,
              b: Ptr[uint8], b_len: uint64) -> int32:
    if a_len != b_len:
        return 0
    i: uint64 = 0
    while i < a_len:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# -- decode output buffer (top-level BSS — 128 KiB is past a userland
#    stack budget; the big fx4 payload is 96 KiB) -----------------------

DST_CAP: uint64 = 131072
dst_buf: Array[131072, uint8]


def _run_case(label: Ptr[uint8],
              xz: Ptr[uint8], xz_len: uint64,
              plain: Ptr[uint8], plain_len: uint64):
    rc: int64 = xz_decompress(xz, xz_len, &dst_buf[0], DST_CAP)
    if rc < 0:
        _wstr("[xz] FAIL: ")
        _wstr(label)
        _wstr(" xz_decompress rc=")
        _wsdec(rc)
        _wstr(" dbg_site=")
        _wsdec(xz_dbg_site)
        _wstr(" a=")
        _wdec(xz_dbg_a)
        _wstr(" b=")
        _wdec(xz_dbg_b)
        _wstr("\n")
        fail_count = fail_count + 1
        return
    if cast[uint64](rc) != plain_len:
        _wstr("[xz] FAIL: ")
        _wstr(label)
        _wstr(" length got=")
        _wdec(cast[uint64](rc))
        _wstr(" want=")
        _wdec(plain_len)
        _wstr("\n")
        fail_count = fail_count + 1
        return
    eq: int32 = _bytes_eq(&dst_buf[0], cast[uint64](rc), plain, plain_len)
    if eq == 0:
        # Find the first differing offset to make a regression easy to
        # localise.
        first_bad: uint64 = 0
        k: uint64 = 0
        while k < plain_len:
            if dst_buf[k] != plain[k]:
                first_bad = k
                break
            k = k + 1
        _wstr("[xz] FAIL: ")
        _wstr(label)
        _wstr(" byte mismatch at offset ")
        _wdec(first_bad)
        _wstr("\n")
        fail_count = fail_count + 1
        return
    _wstr("[xz] ok: ")
    _wstr(label)
    _wstr(" (")
    _wdec(plain_len)
    _wstr(" bytes)\n")


def _run_negative(label: Ptr[uint8], xz: Ptr[uint8], xz_len: uint64):
    rc: int64 = xz_decompress(xz, xz_len, &dst_buf[0], DST_CAP)
    if rc >= 0:
        _wstr("[xz] FAIL: ")
        _wstr(label)
        _wstr(" should error, got rc=")
        _wsdec(rc)
        _wstr("\n")
        fail_count = fail_count + 1


# -- negative-case scratch ---------------------------------------------

bad_buf: Array[256, uint8]


def _test_bad_magic():
    # Copy fx1 then corrupt the first magic byte.
    i: uint64 = 0
    while i < fx1_xz_len and i < 256:
        bad_buf[i] = fx1_xz[i]
        i = i + 1
    bad_buf[0] = 0x00      # not 0xFD
    _run_negative("bad-magic", &bad_buf[0], fx1_xz_len)


def _test_truncated():
    # fx1 cut off mid-stream — header is intact, body is short.
    half: uint64 = fx1_xz_len / 2
    _run_negative("truncated", &fx1_xz[0], half)


def _test_dst_too_small():
    # A dst buffer far smaller than the decompressed output must be a
    # hard error, never a silent truncation.
    rc: int64 = xz_decompress(&fx2_xz[0], fx2_xz_len, &bad_buf[0],
                              cast[uint64](8))
    if rc >= 0:
        _wstr("[xz] FAIL: dst-too-small should error, got rc=")
        _wsdec(rc)
        _wstr("\n")
        fail_count = fail_count + 1


# -- driver ------------------------------------------------------------

def main() -> int32:
    _wstr("[xz] start\n")

    init_xz_fixtures()

    _run_case("fx1: small ASCII",
              &fx1_xz[0], fx1_xz_len, &fx1_plain[0], fx1_plain_len)
    _run_case("fx2: repetitive match-copy",
              &fx2_xz[0], fx2_xz_len, &fx2_plain[0], fx2_plain_len)
    _run_case("fx3: Packages stanza",
              &fx3_xz[0], fx3_xz_len, &fx3_plain[0], fx3_plain_len)
    _run_case("fx4: 96 KiB multi-block",
              &fx4_xz[0], fx4_xz_len, &fx4_plain[0], fx4_plain_len)

    _test_bad_magic()
    _test_truncated()
    _test_dst_too_small()

    _wstr("[xz] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[xz] PASS\n")
        return 0
    _wstr("[xz] FAIL\n")
    return 1

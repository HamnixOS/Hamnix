# tests/test_9p_v3_defaults.ad
#
# 9P V3 regression: prove that the Plan 9 root-namespace defaults
# (`/srv`, `/n`, `/proc/<pid>/ns`) come up populated at boot and that
# bindings done in a child task after rfork(RFNAMEG) show up in the
# child's `/proc/<child>/ns` but NOT the parent's `/proc/1/ns`.
#
# Markers grepped by scripts/test_9p_v3_defaults.sh:
#
#   [v3-defaults] start
#   [v3-srv-empty] OK            -- ls /srv works, no entries yet
#   [v3-procns-init] OK          -- cat /proc/1/ns returns >= 0 bytes
#   [v3-n-empty] OK              -- ls /n works, empty
#   [v3-child-ns] OK             -- child's ns contains its private bind
#   [v3-parent-clean] OK         -- parent's ns does NOT contain the child's bind
#   [v3-defaults] PASS
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_9p_v3_defaults.ad -o build/user/test_9p_v3_defaults.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_rfork(flags: int32) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_BIND:    uint64 = 257
SYS_UNMOUNT: uint64 = 259

RFPROC:   int32 = 0x001
RFFDG:    int32 = 0x004
RFNAMEG:  int32 = 0x008
RFENVG:   int32 = 0x010

MREPL: int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def do_bind(new_path: Ptr[uint8], old_path: Ptr[uint8]) -> int64:
    return syscall6(SYS_BIND,
                    cast[uint64](new_path),
                    cast[uint64](old_path),
                    cast[uint64](MREPL), 0, 0, 0)


def do_unmount(old_path: Ptr[uint8]) -> int64:
    return syscall6(SYS_UNMOUNT,
                    0,
                    cast[uint64](old_path),
                    0, 0, 0, 0)


# Top-level scratch buffers — Adder doesn't like nested Array frames.
ns_buf: Array[2048, uint8]
path_buf: Array[64, uint8]


def contains_substr(buf: Ptr[uint8], buf_len: uint64,
                    needle: Ptr[uint8]) -> int32:
    # Boyer-Moore-naive substring search. Returns 1 if needle is found
    # in buf[0..buf_len], 0 otherwise. The needle is NUL-terminated;
    # buf is NOT (we have a length).
    nlen: uint64 = strlen(needle)
    if nlen == 0:
        return 1
    if nlen > buf_len:
        return 0
    i: uint64 = 0
    while i + nlen <= buf_len:
        k: uint64 = 0
        matched: int32 = 1
        while k < nlen:
            if buf[i + k] != needle[k]:
                matched = 0
                k = nlen                            # break
            else:
                k = k + 1
        if matched != 0:
            return 1
        i = i + 1
    return 0


def read_path(path: Ptr[char], out_buf: Ptr[uint8],
              out_max: uint64) -> int64:
    # Open, slurp up to out_max bytes, close. Returns bytes read, or
    # -1 on open failure. Single read is fine for the V3 fixture —
    # devproc + devsrv both render < 2 KB on the worst case.
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, out_buf, out_max)
    sys_close(fd)
    return n


def main() -> int32:
    write_str(1, "[v3-defaults] start\n")

    # ----------------------------------------------------------------
    # 1) /srv directory exists. Plain open + close — vfs_read on an
    #    FD_DIR_MARK returns -EISDIR (Linux semantics), so the success
    #    bar is "open returned a real fd". A subsequent getdents64
    #    call would enumerate posted names; the table is empty in V3.
    srv_fd: int32 = sys_open("/srv")
    if srv_fd < 0:
        write_str(1, "[v3-defaults] FAIL: /srv open\n")
        return 1
    sys_close(srv_fd)
    write_str(1, "[v3-srv-empty] OK\n")

    # ----------------------------------------------------------------
    # 2) /proc/1/ns. The root Pgrp's mtab is empty by default in V3
    #    (no pgrp_init bind sentinel for /n — see chan.ad's pgrp_init
    #    comment for why), so a fresh boot reads 0 bytes. After this
    #    test's own bind below, /proc/<self>/ns will show the entry.
    pn1_n: int64 = read_path("/proc/1/ns", &ns_buf[0], 2048)
    if pn1_n < 0:
        write_str(1, "[v3-defaults] FAIL: /proc/1/ns open\n")
        return 2
    write_str(1, "[v3-procns-init] OK\n")

    # ----------------------------------------------------------------
    # 3) /n directory exists. Same shape as /srv — open + close;
    #    reads return -EISDIR. Empty by default; child bindings show
    #    up in /proc/<child>/ns, not as `/n` directory entries.
    n_fd: int32 = sys_open("/n")
    if n_fd < 0:
        write_str(1, "[v3-defaults] FAIL: /n open\n")
        return 3
    sys_close(n_fd)
    write_str(1, "[v3-n-empty] OK\n")

    # ----------------------------------------------------------------
    # 4) Child task: bind /etc /n/etc, then read /proc/<self>/ns and
    #    verify the binding shows up. Parent (post-waitpid) re-reads
    #    /proc/1/ns and verifies it stays clean.
    flags: int32 = RFPROC | RFFDG | RFNAMEG | RFENVG
    pid: int32 = sys_rfork(flags)
    if pid < 0:
        write_str(1, "[v3-defaults] FAIL: rfork\n")
        return 4

    if pid == 0:
        # ----- CHILD -----
        # do_bind(new, old) — new is the alias path, old is the
        # underlying target. After this, opens of /n/etc/* in the
        # child resolve via prefix-rewrite to /etc/*.
        rc: int64 = do_bind("/n/etc", "/etc")
        if rc != 0:
            write_str(1, "[v3-defaults] FAIL: child bind\n")
            sys_exit(5)
        # The child's own pid isn't directly available without a
        # syscall; we read /proc/2/ns (child is the second user task
        # spawned after init -> hamsh -> us, so pid=3 typically, but
        # the rfork child pid we PRINT is the parent's view; from the
        # child's own perspective we don't know our pid yet — but we
        # CAN read /dev/pid.
        pid_fd: int32 = sys_open("/dev/pid")
        if pid_fd < 0:
            write_str(1, "[v3-defaults] FAIL: child cannot open /dev/pid\n")
            sys_exit(6)
        pid_str: Array[24, uint8]
        pn: int64 = sys_read(pid_fd, &pid_str[0], 24)
        sys_close(pid_fd)
        if pn <= 0:
            write_str(1, "[v3-defaults] FAIL: child cannot read /dev/pid\n")
            sys_exit(7)
        # Strip trailing newline from /dev/pid output.
        if pid_str[cast[uint64](pn) - 1] == 10:
            pid_str[cast[uint64](pn) - 1] = 0
        else:
            pid_str[cast[uint64](pn)] = 0
        # Build "/proc/<pid>/ns" into path_buf.
        path_buf[0] = 47                            # '/'
        path_buf[1] = 112                           # 'p'
        path_buf[2] = 114                           # 'r'
        path_buf[3] = 111                           # 'o'
        path_buf[4] = 99                            # 'c'
        path_buf[5] = 47                            # '/'
        j: uint64 = 6
        i: uint64 = 0
        while pid_str[i] != 0:
            path_buf[j] = pid_str[i]
            j = j + 1
            i = i + 1
        path_buf[j] = 47                            # '/'
        path_buf[j + 1] = 110                       # 'n'
        path_buf[j + 2] = 115                       # 's'
        path_buf[j + 3] = 0
        ch_n: int64 = read_path(cast[Ptr[char]](&path_buf[0]),
                                &ns_buf[0], 2048)
        if ch_n < 0:
            write_str(1, "[v3-defaults] FAIL: child cannot read its ns\n")
            sys_exit(8)
        # The text must contain "/n/etc" — that's the from_path of
        # the bind. (Rendering is "bind /n/etc /etc\n".)
        if contains_substr(&ns_buf[0], cast[uint64](ch_n),
                           "bind /n/etc") == 0:
            write_str(1, "[v3-defaults] FAIL: child ns missing bind line\n")
            write_str(1, "[v3-defaults] child ns dump=")
            sys_write(1, &ns_buf[0], cast[uint64](ch_n))
            write_str(1, "\n")
            sys_exit(9)
        write_str(1, "[v3-child-ns] OK\n")
        sys_exit(0)
        return 0

    # ----- PARENT -----
    sys_waitpid(cast[uint64](pid))
    # /proc/1/ns must NOT carry the child's bind. We snapshot the
    # text and grep for "/n/etc" — absence is the test bar. Pre-bind,
    # the parent's mtab is empty; after the child's RFNAMEG-rfork +
    # bind, only the child Pgrp was mutated.
    pn1b_n: int64 = read_path("/proc/1/ns", &ns_buf[0], 2048)
    if pn1b_n < 0:
        write_str(1, "[v3-defaults] FAIL: parent cannot re-read /proc/1/ns\n")
        return 10
    # The parent's pid (the one running this fixture, which is hamsh's
    # exec'd child) is not necessarily 1 — hamsh itself is pid 1 in
    # the test driver. So /proc/1/ns reflects hamsh's namespace, which
    # is the root Pgrp (no rfork). It MUST be free of "bind /n/etc".
    if contains_substr(&ns_buf[0], cast[uint64](pn1b_n),
                       "bind /n/etc") != 0:
        write_str(1, "[v3-defaults] FAIL: parent's ns leaked child bind\n")
        return 11
    write_str(1, "[v3-parent-clean] OK\n")

    write_str(1, "[v3-defaults] PASS\n")
    return 0

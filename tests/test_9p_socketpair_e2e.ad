# tests/test_9p_socketpair_e2e.ad
#
# V5 — end-to-end Plan-9 loop over a sys_socketpair transport. Same
# semantics as tests/test_9p_e2e.ad (V4.1) but exercises the
# bidirectional path through the kernel 9P client (`_p9_send` /
# `_p9_recv` in sys/src/9/port/9p_client.ad) without the `p9rx:` magic
# prefix.
#
# Shape:
#
#   sys_socketpair(AF_UNIX, SOCK_STREAM, 0, &sv)
#     sv[0]  -> kernel uses for both T (write) and R (read)
#     sv[1]  -> child uses for stdin (T-msg read) AND stdout (R-msg write)
#
#   spawn("/bin/p9srv_demo", argv, sv[1], sv[1], envp)
#     dup_fd_to_child(slot, 0, parent, sv[1])    # child stdin
#     dup_fd_to_child(slot, 1, parent, sv[1])    # child stdout
#
#   sys_mount(sv[0], -1, "/p9spair", MREPL, "")    # NO p9rx: prefix
#
# We deliberately mount on sv[0] DIRECTLY, skipping the
# sys_srv_post + sys_srv_open dance the V4.1 fixture used. The dance
# is for cross-task service publication; this single-task fixture
# doesn't need it, and avoiding it sidesteps the fd-index collision
# with init/p9_smoke.ad's leftover boot-time `_conn_alloc` at
# srvfd=5 (the smoke fixture leaks its conn record by design; it
# only matters when subsequent mounts happen to land on the same
# fd index, which sys_srv_open's _alloc_fd does for a chain of 5
# pre-opened fds).
#
#   sys_open("/p9spair/hello") -> reads "p9demo says hi\n" via the
#     kernel 9P client speaking T-msgs and reading R-msgs over the
#     SAME fd (the socketpair endpoint).
#
# Lifetime: see fs/socketpair.ad's header for why we leave sv[1] open
# in the parent. core.ad's copy_fd_entry is off-limits for this
# milestone, so dup_fd_to_child doesn't bump refs_b — closing sv[1]
# in parent would drop refs_b to 0 even though the child still holds
# the same end on its own fd 0 / fd 1. The parent therefore keeps
# sv[1] open until after waitpid, then closes both ends.
#
# Markers grepped by scripts/test_9p_socketpair_e2e.sh:
#
#   [p9spair] start
#   [p9spair] pair OK
#   [p9spair] spawn OK
#   [p9spair] mount OK
#   [p9spair] open OK
#   [p9spair] read=15
#   [p9spair] payload OK
#   [p9spair] close OK
#   [p9spair] PASS

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_socketpair(domain: int32, type: int32, protocol: int32,
                          sv: Ptr[int32]) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_mount(srvfd: int32, afd: int32, old: Ptr[char],
                     flag: int32, spec: Ptr[char]) -> int32

AF_UNIX:     int32 = 1
SOCK_STREAM: int32 = 1
MREPL:       int32 = 0
SIGKILL:     int32 = 9

# Top-level scratch buffers (Adder nested-frame Array bug avoidance).
sv:         Array[2, int32]
spawn_argv: Array[2, uint64]
read_buf:   Array[64, uint8]
err_buf:    Array[128, uint8]
mount_path: Array[16, uint8]    # "/p9spair"
hello_path: Array[32, uint8]    # "/p9spair/hello"
empty_spec: Array[2, uint8]     # ""

# Expected payload for /hello — "p9demo says hi\n" (15 bytes).
expected: Array[16, uint8]
EXPECTED_LEN: uint64 = 15


from lib.p9 import spawn, p9_note

def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def init_expected():
    expected[0]  = 112
    expected[1]  = 57
    expected[2]  = 100
    expected[3]  = 101
    expected[4]  = 109
    expected[5]  = 111
    expected[6]  = 32
    expected[7]  = 115
    expected[8]  = 97
    expected[9]  = 121
    expected[10] = 115
    expected[11] = 32
    expected[12] = 104
    expected[13] = 105
    expected[14] = 10


def init_paths():
    # "/p9spair" — mount point. Dodges every userspace-init bind
    # prefix (same reasoning as tests/test_9p_e2e.ad).
    mount_path[0] = 47    # '/'
    mount_path[1] = 112   # 'p'
    mount_path[2] = 57    # '9'
    mount_path[3] = 115   # 's'
    mount_path[4] = 112   # 'p'
    mount_path[5] = 97    # 'a'
    mount_path[6] = 105   # 'i'
    mount_path[7] = 114   # 'r'
    mount_path[8] = 0
    # "/p9spair/hello"
    hello_path[0]  = 47
    hello_path[1]  = 112
    hello_path[2]  = 57
    hello_path[3]  = 115
    hello_path[4]  = 112
    hello_path[5]  = 97
    hello_path[6]  = 105
    hello_path[7]  = 114
    hello_path[8]  = 47
    hello_path[9]  = 104
    hello_path[10] = 101
    hello_path[11] = 108
    hello_path[12] = 108
    hello_path[13] = 111
    hello_path[14] = 0
    # Empty spec — the V4.1 fixture had to smuggle the rx-side fd
    # through here as "p9rx:<NN>:"; with a socketpair the kernel
    # client uses the same fd for both directions, so the spec is
    # just the (ignored) attach aname.
    empty_spec[0] = 0


def main() -> int32:
    init_expected()
    init_paths()
    write_str(1, "[p9spair] start\n")

    # 1. Socketpair.
    rc: int32 = sys_socketpair(AF_UNIX, SOCK_STREAM, 0, &sv[0])
    if rc < 0:
        dump_errstr("[p9spair] FAIL: sys_socketpair errstr=")
        return 1
    kern_fd:  int32 = sv[0]                     # kernel side
    child_fd: int32 = sv[1]                     # child's stdin AND stdout
    write_str(1, "[p9spair] pair OK\n")

    # 2. Spawn p9srv_demo with stdin = stdout = child_fd. Both
    # dup-into-child copies point at the SAME socketpair endpoint
    # (end B), so the child reads kernel's T-msgs on fd 0 and writes
    # R-msgs back on fd 1 over the bidirectional ring.
    spawn_argv[0] = cast[uint64](&"/bin/p9srv_demo"[0])
    spawn_argv[1] = 0
    pid: int32 = spawn("/bin/p9srv_demo", &spawn_argv[0],
                           child_fd, child_fd, cast[Ptr[uint64]](0))
    if pid < 0:
        dump_errstr("[p9spair] FAIL: spawn errstr=")
        return 2
    write_str(1, "[p9spair] spawn OK\n")

    # NOTE: do NOT sys_close(child_fd) here. The child's dup'd fds
    # don't bump refs_b (copy_fd_entry is in off-limits core.ad), so
    # closing our copy would prematurely drop refs_b to 0 and make
    # the kernel-side reads on sv[0] see "peer gone" → EOF before
    # the child has actually answered. We close child_fd at the end,
    # after waitpid.

    # 3. Mount kern_fd DIRECTLY (no srv_post/srv_open round-trip).
    # The dance is for cross-task service publication; this single-task
    # fixture doesn't need it, and skipping it avoids the fd-index
    # collision with init/p9_smoke.ad's leaked synth_srvfd=5 conn
    # record (which would otherwise wedge p9c_attach with "conn alloc").
    # NO p9rx: prefix — the spec is just the empty aname.
    rc = sys_mount(kern_fd, -1,
                   cast[Ptr[char]](&mount_path[0]),
                   MREPL,
                   cast[Ptr[char]](&empty_spec[0]))
    if rc < 0:
        dump_errstr("[p9spair] FAIL: sys_mount errstr=")
        return 5
    write_str(1, "[p9spair] mount OK\n")

    # 6. Open /p9spair/hello — kernel client walks + opens via the
    # socketpair transport.
    h: int32 = sys_open(cast[Ptr[char]](&hello_path[0]))
    if h < 0:
        dump_errstr("[p9spair] FAIL: sys_open errstr=")
        return 6
    write_str(1, "[p9spair] open OK\n")

    # 7. Read the payload.
    n: int64 = sys_read(h, &read_buf[0], 32)
    if n < 0:
        dump_errstr("[p9spair] FAIL: sys_read errstr=")
        sys_close(h)
        return 7
    write_str(1, "[p9spair] read=")
    write_dec(1, cast[uint64](n))
    write_str(1, "\n")
    if cast[uint64](n) != EXPECTED_LEN:
        write_str(1, "[p9spair] FAIL: read count mismatch\n")
        sys_close(h)
        return 8

    # 8. Byte-for-byte payload check.
    i: uint64 = 0
    while i < EXPECTED_LEN:
        if read_buf[i] != expected[i]:
            write_str(1, "[p9spair] FAIL: payload mismatch at i=")
            write_dec(1, i)
            write_str(1, "\n")
            sys_close(h)
            return 9
        i = i + 1
    write_str(1, "[p9spair] payload OK\n")

    # 9. Close the kernel-client fd (issues Tclunk via FD_P9_MARK).
    if sys_close(h) < 0:
        dump_errstr("[p9spair] FAIL: sys_close errstr=")
        return 10
    write_str(1, "[p9spair] close OK\n")

    # 10. Tear down. SIGKILL the child first (clean EOF would require
    # us to close child_fd in parent, but that has the refcount
    # surprise described above; SIGKILL sidesteps the dance). Then
    # close both socketpair ends so the slot is freed.
    p9_note(pid, cast[Ptr[uint8]]("kill"))
    sys_waitpid(cast[uint64](pid))
    sys_close(kern_fd)
    sys_close(child_fd)

    write_str(1, "[p9spair] PASS\n")
    return 0

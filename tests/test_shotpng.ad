# tests/test_shotpng.ad
#
# In-guest decode-back gate for user/hamshot.ad's PNG capture. hamshot is run
# first (from hamsh) to capture the live synthetic framebuffer into an
# explicit path; this fixture then reads that file back, DECODES it with the
# real lib/png.ad decoder, and asserts:
#   * png_decode() succeeds (a structurally valid PNG: signature, IHDR, an
#     inflatable IDAT stream, IEND),
#   * the decoded dimensions equal the framebuffer geometry (32x16 under the
#     fbpix self-test's synthetic mode),
#   * the pixels are NON-UNIFORM (>=2 distinct RGB values) — i.e. real screen
#     content was captured, not a blank/garbage frame.
#
# Banner: "[shotpng] PASS" on success, "[shotpng] FAIL ..." otherwise.
#
#   test_shotpng <file.png> <expect_w> <expect_h>

from lib.png import png_decode, png_width, png_height, png_rgba_ptr

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

_file_buf: Array[262144, uint8]


def _puts(fd: int32, s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(fd, s, n)


def _parse_u64(s: Ptr[uint8]) -> uint64:
    v: uint64 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[uint64](s[i]) - 48
        i = i + 1
    return v


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        _puts(2, "[shotpng] FAIL usage: test_shotpng <file> <w> <h>\n")
        return 1
    path: Ptr[char] = cast[Ptr[char]](argv[1])
    exp_w: uint64 = _parse_u64(cast[Ptr[uint8]](argv[2]))
    exp_h: uint64 = _parse_u64(cast[Ptr[uint8]](argv[3]))

    fd: int32 = sys_open(path)
    if fd < 0:
        _puts(2, "[shotpng] FAIL cannot open capture file\n")
        return 1
    total: uint64 = 0
    while total < 262144:
        n: int64 = sys_read(fd, &_file_buf[total], 262144 - total)
        if n < 0:
            sys_close(fd)
            _puts(2, "[shotpng] FAIL read error\n")
            return 1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    if total < 8:
        _puts(2, "[shotpng] FAIL capture file too small\n")
        return 1

    rc: int32 = png_decode(&_file_buf[0], total)
    if rc != 0:
        _puts(2, "[shotpng] FAIL png_decode rejected the capture\n")
        return 1

    dw: uint64 = cast[uint64](png_width())
    dh: uint64 = cast[uint64](png_height())
    if dw != exp_w or dh != exp_h:
        _puts(2, "[shotpng] FAIL decoded dimensions mismatch\n")
        return 1

    # Non-uniformity: scan the decoded RGBA for a second distinct pixel.
    px: Ptr[uint8] = png_rgba_ptr()
    npx: uint64 = dw * dh
    r0: uint8 = px[0]
    g0: uint8 = px[1]
    b0: uint8 = px[2]
    distinct: int32 = 0
    i: uint64 = 1
    while i < npx:
        o: uint64 = i * 4
        if px[o] != r0 or px[o + 1] != g0 or px[o + 2] != b0:
            distinct = 1
            i = npx
        else:
            i = i + 1
    if distinct == 0:
        _puts(2, "[shotpng] FAIL capture is a uniform frame (no content)\n")
        return 1

    _puts(1, "[shotpng] PASS decoded a valid non-uniform ")
    # width x height
    wbuf: Array[16, uint8]
    wp: uint64 = 0
    tmp: Array[24, uint8]
    tn: uint64 = 0
    v: uint64 = dw
    if v == 0:
        tmp[0] = 48
        tn = 1
    while v != 0:
        tmp[tn] = cast[uint8](v % 10) + 48
        v = v / 10
        tn = tn + 1
    while tn > 0:
        tn = tn - 1
        wbuf[wp] = tmp[tn]
        wp = wp + 1
    sys_write(1, &wbuf[0], wp)
    _puts(1, "x")
    hp: uint64 = 0
    tn = 0
    v = dh
    if v == 0:
        tmp[0] = 48
        tn = 1
    while v != 0:
        tmp[tn] = cast[uint8](v % 10) + 48
        v = v / 10
        tn = tn + 1
    hbuf: Array[16, uint8]
    while tn > 0:
        tn = tn - 1
        hbuf[hp] = tmp[tn]
        hp = hp + 1
    sys_write(1, &hbuf[0], hp)
    _puts(1, " PNG\n")
    return 0

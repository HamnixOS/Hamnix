# tests/test_mkfs.ad
#
# Userland fixture for the ext4_mkfs verification path. The actual
# format + re-mount + verify cycle runs ENTIRELY KERNEL-SIDE — see
# ext4_mkfs_self_test() in fs/ext4.ad, triggered lazily on the first
# VFS open of any /ext path via is_ext_path(). By the time this
# fixture runs in user mode, the kernel has already logged the PASS
# markers the host-side test_mkfs.sh greps for:
#
#   [ext4] mkfs sd0p1 OK (slot=<N>)
#   [ext4] mounted sd0p1 ro=0 (slot=<N>)
#   [ext4] / contains . ..
#   [ext4] mkfs self-test PASS
#
# This fixture's job is twofold:
#   1. Open /ext/__mkfs_trigger to ensure the self-test fires even
#      if no other userland binary touches /ext.
#   2. Emit "[mkfs] fixture OK" so the host script can verify the
#      boot reached user mode after all the kernel mkfs work landed.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_mkfs.ad -o build/user/test_mkfs.elf
# Run via scripts/test_mkfs.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def main():
    # Open / close a /ext path so is_ext_path() fires; the lazy
    # mkfs self-test triggers on the first such call from user mode.
    # The path doesn't have to exist — is_ext_path runs before the
    # actual lookup, so a failed open still wakes the self-test.
    fd: int32 = sys_open("/ext/__mkfs_trigger")
    if fd >= 0:
        sys_close(fd)
    emit("[mkfs] fixture: userland reached after kernel mkfs self-test\n")
    emit("[mkfs] fixture OK\n")
    sys_exit(0)

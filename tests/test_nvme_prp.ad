# tests/test_nvme_prp.ad
#
# V4.2 NVMe PRP-list smoke fixture.
#
# Validates drivers/nvme/nvme.ad's PRP1+PRP2 (and PRP-list) submission
# path by issuing a 512-byte I/O transfer whose buffer DELIBERATELY
# crosses a 4 KiB page boundary. Pre-V4.2 the driver only filled PRP1
# in the SQE; per NVMe spec §4.3, PRP1 carries the buffer's first byte
# (with the intra-page offset retained) and PRP2 must carry either the
# second page's physical address (≤2-page transfers) or a PRP-list
# page (>2-page transfers). With PRP2 left as 0, any transfer past the
# first-page boundary silently dropped the bytes that should have
# landed in the second page; the SQE still completed "successfully".
#
# This fixture surfaces that bug by:
#
#   1. Allocating two contiguous pages via alloc_pages(1) — the 8 KiB
#      run is page-aligned by construction.
#   2. Aiming a Ptr[uint8] at offset 0xF10 within the first page, so
#      a 512-byte transfer puts 240 bytes in page 0 and 272 bytes in
#      page 1. This is exactly the layout that surfaced the GPT mkpart
#      crash in commit c38188d.
#   3. Filling the source buffer with a recognisable pattern, writing
#      it to LBA 2 (away from the MBR signature smoke test at LBA 0
#      and the existing write-smoke at LBA 1), reading it back into a
#      second cross-page buffer at the same intra-page offset, and
#      byte-comparing all 512 bytes.
#
# The bytes most at risk in the pre-V4.2 driver are indices 240..511,
# which live in page 1 and never get touched without PRP2. We check
# the whole 512 to keep the assertion strict.
#
# Asserted serial markers (greppable from scripts/test_nvme_prp.sh):
#
#   [nvme_prp] smoke begin
#   [nvme_prp] cross-page write @ offset 0xF10 OK
#   [nvme_prp] cross-page readback matches
#   [nvme_prp] PASS

from kernel.printk.printk import printk0, printk1, printk2
from mm.page_alloc import alloc_pages
from drivers.nvme.nvme import nvme_write_lba, nvme_read_lba


# LBA we're going to write/read on namespace 1. LBA 0 is reserved for
# the MBR signature smoke; LBA 1 is the existing write-smoke. LBA 2 is
# the next safe slot.
NVME_PRP_TEST_LBA: uint64 = 2

# Intra-page offset chosen to FORCE the buffer to span a page boundary.
# 0xF10 = 3856; first page has 4096 - 3856 = 240 bytes; the remaining
# 272 bytes of the 512-byte sector land in the next page.
NVME_PRP_TEST_OFFSET: uint64 = 0xF10
NVME_PRP_TEST_LEN: uint64 = 512


extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


def nvme_prp_smoke_test() -> int32:
    printk0("[nvme_prp] smoke begin\n")

    # alloc_pages(1) → 8 KiB contiguous, page-aligned. We use two
    # pages so a 512-byte transfer starting at the first page's 0xF10
    # has somewhere legal to land in the second page.
    wbase: uint64 = alloc_pages(1)
    rbase: uint64 = alloc_pages(1)
    if wbase == 0 or rbase == 0:
        printk0("[nvme_prp] alloc_pages(1) failed\n")
        return -1

    # Zero both regions so any stale slab bytes don't leak into the
    # byte-comparison loop.
    memset(cast[Ptr[uint8]](wbase), 0, 8192)
    memset(cast[Ptr[uint8]](rbase), 0, 8192)

    wbuf: uint64 = wbase + NVME_PRP_TEST_OFFSET
    rbuf: uint64 = rbase + NVME_PRP_TEST_OFFSET

    # Sanity: the test only proves anything if wbuf truly crosses a
    # page boundary. The first-page tail covers
    # (4096 - (wbuf & 0xFFF)) bytes; if that's already >= 512 we'd
    # silently still be testing the single-page path. Assert the
    # geometry up-front.
    first_page_bytes: uint64 = 4096 - (wbuf & 0xFFF)
    if first_page_bytes >= NVME_PRP_TEST_LEN:
        printk1("[nvme_prp] geometry bug: first_page_bytes=%d >= 512\n",
                first_page_bytes)
        return -1

    # Plant a recognisable pattern: byte i = (i ^ 0xC3) & 0xFF. The
    # mask is distinct from the 0xA5 and 0x5A masks used by
    # _nvme_write_smoke_test and _nvme_blk_smoke_test so a stale-buffer
    # bug surfaces as a mismatch instead of silently passing.
    wp: Ptr[uint8] = cast[Ptr[uint8]](wbuf)
    i: uint64 = 0
    while i < NVME_PRP_TEST_LEN:
        wp[i] = cast[uint8](cast[uint8](i & 0xFF) ^ cast[uint8](0xC3))
        i = i + 1

    if nvme_write_lba(NVME_PRP_TEST_LBA, 1, wbuf) != 0:
        printk0("[nvme_prp] WRITE failed\n")
        return -1
    printk0("[nvme_prp] cross-page write @ offset 0xF10 OK\n")

    if nvme_read_lba(NVME_PRP_TEST_LBA, 1, rbuf) != 0:
        printk0("[nvme_prp] READ failed\n")
        return -1

    # Byte-by-byte equality. The bytes at risk under the pre-V4.2 bug
    # are indices 240..511 (page-1 residents). We check the whole 512
    # to keep the assertion strict.
    rp: Ptr[uint8] = cast[Ptr[uint8]](rbuf)
    j: uint64 = 0
    while j < NVME_PRP_TEST_LEN:
        if rp[j] != wp[j]:
            printk2("[nvme_prp] MISMATCH at byte %d (got %x)\n",
                    j, cast[uint64](rp[j]))
            return -1
        j = j + 1

    printk0("[nvme_prp] cross-page readback matches\n")
    printk0("[nvme_prp] PASS\n")
    return 0

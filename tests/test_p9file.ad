# tests/test_p9file.ad
#
# Phase C / M16.101 regression: exercise the new Plan 9 file-operations
# cluster — create (260), stat (261), fstat (262), remove (263),
# fd2path (264). The fixture pokes each primitive through its happy
# path so the kernel-side bodies + the syscall.ad dispatch wiring
# both have to be functional for the host-side script to grep all
# PASS markers.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_p9file.ad -o build/user/test_p9file.elf
#
# Run via scripts/test_p9file.sh.
#
# Contract (one marker per primitive):
#   [p9file] stat /etc/motd ok    (do_stat returned > 0 bytes)
#   [p9file] fstat fd ok          (do_fstat returned > 0 bytes)
#   [p9file] fd2path ok           (do_fd2path returned > 0 bytes)
#   [p9file] create /tmp/p9 ok    (do_create returned fd >= 0)
#   [p9file] remove /tmp/p9 ok    (do_remove returned 0)
#   [p9file] PASS                 (all five primitives green)
#
# Each syscall wrapper is a tiny `syscall6` helper inlined here so the
# test binary doesn't depend on adding new symbols to user/runtime.S.
# The wrappers are intentionally untyped — they pass through whatever
# bit pattern userland hands them, exactly matching the kernel's
# uint64 dispatch.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_CREATE:   uint64 = 260
SYS_STAT_P9:  uint64 = 261
SYS_FSTAT_P9: uint64 = 262
SYS_REMOVE:   uint64 = 263
SYS_FD2PATH:  uint64 = 264

# Open flags. OWRITE has bit 1 set in Plan 9.
OREAD:    int32 = 0
OWRITE:   int32 = 1

# Plan 9 mode bits. DMDIR routes do_create through vfs_mkdir.
DMDIR:    uint64 = 0x80000000


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def main() -> int32:
    write_str(1, "[p9file] start\n")

    # 1) stat /etc/motd — present in the cpio initramfs, so the
    # serialiser writes a real Dir record. We only assert that the
    # call returned > 0 bytes; the byte layout itself is exercised
    # below by fstat (same code path).
    stat_buf: Array[256, uint8]
    n: int64 = syscall6(SYS_STAT_P9,
                        cast[uint64](&"/etc/motd"[0]),
                        cast[uint64](&stat_buf[0]),
                        256, 0, 0, 0)
    if n <= 0:
        write_str(1, "[p9file] FAIL: stat returned ")
        write_dec(1, cast[uint64](n))
        write_str(1, "\n")
        return 1
    write_str(1, "[p9file] stat /etc/motd ok\n")

    # 2) Open /etc/motd via the existing SYS_OPEN (5) path so we have
    # an initramfs-backed fd to fstat. We use sys_open rather than
    # the new create() so the test exercises BOTH discovery paths
    # (existing open + new fd2path/fstat) — create() is exercised
    # against /tmp/p9 below.
    fd: int32 = sys_open("/etc/motd")
    if fd < 0:
        write_str(1, "[p9file] FAIL: open /etc/motd returned ")
        write_dec(1, cast[uint64](fd))
        write_str(1, "\n")
        return 2

    # 3) fstat on the fd — produces a Dir record of the same shape.
    fstat_buf: Array[256, uint8]
    n = syscall6(SYS_FSTAT_P9, cast[uint64](fd),
                 cast[uint64](&fstat_buf[0]), 256, 0, 0, 0)
    if n <= 0:
        write_str(1, "[p9file] FAIL: fstat returned ")
        write_dec(1, cast[uint64](n))
        write_str(1, "\n")
        return 3
    write_str(1, "[p9file] fstat fd ok\n")

    # 4) fd2path on the same fd — best-effort recovery. Should land
    # on a non-empty NUL-terminated string.
    path_buf: Array[128, uint8]
    n = syscall6(SYS_FD2PATH, cast[uint64](fd),
                 cast[uint64](&path_buf[0]), 128, 0, 0, 0)
    if n <= 0:
        write_str(1, "[p9file] FAIL: fd2path returned ")
        write_dec(1, cast[uint64](n))
        write_str(1, "\n")
        sys_close(fd)
        return 4
    write_str(1, "[p9file] fd2path ok: ")
    write_str(1, &path_buf[0])
    write_str(1, "\n")
    sys_close(fd)

    # 5) create /tmp/p9 — tmpfs accepts OWRITE create-or-truncate,
    # so this should land an FD_TMPFS_MARK fd.
    cfd: int64 = syscall6(SYS_CREATE,
                          cast[uint64](&"/tmp/p9"[0]),
                          cast[uint64](OWRITE), 0644, 0, 0, 0)
    if cfd < 0:
        write_str(1, "[p9file] FAIL: create /tmp/p9 returned ")
        write_dec(1, cast[uint64](cfd))
        write_str(1, "\n")
        return 5
    write_str(1, "[p9file] create /tmp/p9 ok\n")
    # Write a single byte so the file is non-empty (tmpfs treats
    # zero-sized files identically, but a real backend will care later).
    sys_write(cast[int32](cfd), "X", 1)
    sys_close(cast[int32](cfd))

    # 6) remove /tmp/p9 — vfs_unlink on tmpfs returns 0 on success.
    rc: int64 = syscall6(SYS_REMOVE,
                         cast[uint64](&"/tmp/p9"[0]),
                         0, 0, 0, 0, 0)
    if rc != 0:
        write_str(1, "[p9file] FAIL: remove /tmp/p9 returned ")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        return 6
    write_str(1, "[p9file] remove /tmp/p9 ok\n")

    # 7) Phase D follow-up A: create("/tmp/p9d", DMDIR|0755) — DMDIR
    # routes do_create through vfs_mkdir, which dispatches to
    # tmpfs_mkdir for /tmp/*. Then open a file UNDER it to prove
    # the new directory is real and writable.
    mrc: int64 = syscall6(SYS_CREATE,
                          cast[uint64](&"/tmp/p9d"[0]),
                          cast[uint64](OWRITE),
                          DMDIR | 0755, 0, 0, 0)
    if mrc < 0:
        write_str(1, "[p9file] FAIL: create DMDIR /tmp/p9d returned ")
        write_dec(1, cast[uint64](mrc))
        write_str(1, "\n")
        return 7
    cfd2: int64 = syscall6(SYS_CREATE,
                           cast[uint64](&"/tmp/p9d/inner"[0]),
                           cast[uint64](OWRITE), 0644, 0, 0, 0)
    if cfd2 < 0:
        write_str(1, "[p9file] FAIL: create under DMDIR dir returned ")
        write_dec(1, cast[uint64](cfd2))
        write_str(1, "\n")
        return 8
    sys_write(cast[int32](cfd2), "Z", 1)
    sys_close(cast[int32](cfd2))
    write_str(1, "[p9file] create DMDIR /tmp/p9d ok\n")

    # 8) Phase D follow-up B: per-backend stat hooks. Stat the same
    # NAME against two different backends and assert the dispatcher
    # returned DIFFERENT qid.path words. /etc/motd lives in cpio
    # (qid = cpio inode index, small int); /tmp/p9d lives in tmpfs
    # (qid = tmpfs slot id). The two integers MUST differ — proving
    # the dispatch routed through different backends.
    stat_cpio: Array[256, uint8]
    n = syscall6(SYS_STAT_P9, cast[uint64](&"/etc/motd"[0]),
                 cast[uint64](&stat_cpio[0]), 256, 0, 0, 0)
    if n <= 0:
        write_str(1, "[p9file] FAIL: backend stat /etc/motd returned ")
        write_dec(1, cast[uint64](n))
        write_str(1, "\n")
        return 9
    stat_tmpfs: Array[256, uint8]
    n = syscall6(SYS_STAT_P9, cast[uint64](&"/tmp/p9d"[0]),
                 cast[uint64](&stat_tmpfs[0]), 256, 0, 0, 0)
    if n <= 0:
        write_str(1, "[p9file] FAIL: backend stat /tmp/p9d returned ")
        write_dec(1, cast[uint64](n))
        write_str(1, "\n")
        return 10
    # qid.path is the little-endian uint64 at offset 13. We compare
    # the low 32 bits — the cpio entry index and the tmpfs slot id
    # both live there with sub-million values, so a difference is
    # an unambiguous "two different backends" verdict.
    cpio_qid: uint64 = cast[uint64](stat_cpio[13]) \
                     | (cast[uint64](stat_cpio[14]) << 8) \
                     | (cast[uint64](stat_cpio[15]) << 16) \
                     | (cast[uint64](stat_cpio[16]) << 24)
    tmpfs_qid: uint64 = cast[uint64](stat_tmpfs[13]) \
                      | (cast[uint64](stat_tmpfs[14]) << 8) \
                      | (cast[uint64](stat_tmpfs[15]) << 16) \
                      | (cast[uint64](stat_tmpfs[16]) << 24)
    if cpio_qid == tmpfs_qid:
        write_str(1, "[p9file] FAIL: stat hooks returned equal qids\n")
        return 11
    # qid.type lives at offset 8. tmpfs /tmp/p9d is a directory →
    # QTDIR (0x80). cpio /etc/motd is QTFILE (0).
    if stat_tmpfs[8] != 0x80:
        write_str(1, "[p9file] FAIL: tmpfs DMDIR stat qid.type not QTDIR\n")
        return 12
    if stat_cpio[8] != 0:
        write_str(1, "[p9file] FAIL: cpio /etc/motd stat qid.type not QTFILE\n")
        return 13
    write_str(1, "[p9file] stat hooks per-backend ok\n")

    # 9) Overlay-op audit (2026-07 shadow-overlay bug-class sweep).
    # /etc is a writable tmpfs mount registered shadow=1 over the
    # read-only cpio base (fs/vfs_mount.ad). open/read/stat/readdir/access
    # of a cpio-baked name under it correctly FALL THROUGH to cpio (the
    # a37d9efb / 401a277b fixes). remove(2) is the write-side sibling:
    # the cpio base is read-only and Hamnix models no whiteout, so a
    # remove of a cpio-baked name MUST cleanly ERROR — a silent success
    # would be a lie (stat/open/ls all still show the baked file, and
    # nothing was actually deleted). Regression-lock BOTH halves:
    #   (a) remove /etc/motd reports an error (nonzero), never a false 0;
    #   (b) stat /etc/motd STILL succeeds afterwards — the read-type
    #       fall-through is intact and uncorrupted by the failed remove.
    orc: int64 = syscall6(SYS_REMOVE,
                          cast[uint64](&"/etc/motd"[0]),
                          0, 0, 0, 0, 0)
    if orc == 0:
        write_str(1, "[p9file] FAIL: remove cpio-baked /etc/motd silently succeeded\n")
        return 14
    ostat: Array[256, uint8]
    n = syscall6(SYS_STAT_P9, cast[uint64](&"/etc/motd"[0]),
                 cast[uint64](&ostat[0]), 256, 0, 0, 0)
    if n <= 0:
        write_str(1, "[p9file] FAIL: stat /etc/motd after failed remove returned ")
        write_dec(1, cast[uint64](n))
        write_str(1, "\n")
        return 15
    write_str(1, "[p9file] overlay remove cpio-baked cleanly errored ok\n")

    write_str(1, "[p9file] PASS\n")
    return 0

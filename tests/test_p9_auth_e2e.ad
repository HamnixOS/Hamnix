# tests/test_p9_auth_e2e.ad
#
# F10-4 (#457) END-TO-END test for the Plan 9 wire-Tauth path.
#
# The structural test scripts/test_p9_tauth.sh proves the kernel's
# do_mount extracts the verified principal name from /dev/auth's
# AuthSlot — but does so against a bare pipe with no responder, so
# the proof stops at the [mount] uname=... printk. THIS fixture
# closes the loop: spawn user/p9srv_demo in `post-auth` mode (server
# requires Tauth + cred Twrite before honoring Tattach), then mount
# with a verified afd and read /hello. A short-circuited or stubbed
# client will fail with Rerror "auth required" from the responder.
#
# Pass markers (grepped by scripts/test_p9_auth_e2e.sh):
#   [p9authE2E] start
#   [p9authE2E] auth-as-live OK
#   [p9authE2E] spawn p9srv_demo post-auth OK
#   [p9authE2E] mount with afd OK
#   [p9authE2E] read /hello OK
#   [p9authE2E] payload match OK
#   [p9authE2E] PASS
# Plus the server-side traces from user/p9srv_demo.ad:
#   [p9demo-auth] Rauth issued
#   [p9demo-auth] afid marked authed
#   [p9demo-auth] Tattach with authed afid OK

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_srv_open(name: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64
extern def sys_yield() -> int32

from lib.p9 import spawn

SYS_MOUNT: uint64 = 258
MREPL:     int32  = 0

err_buf: Array[128, uint8]
read_buf: Array[64, uint8]
spawn_argv: Array[4, uint64]
# Expected payload for /hello. Top-level Array (the nested-frame quirk
# documented in feedback_compiler_quirks.md: a function-local
# Array[16, uint8] = "..." initializer may not pack the bytes).
expected_payload: Array[16, uint8] = "p9demo says hi\n"
EXPECTED_LEN: uint64 = 15


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def auth_as_live() -> int32:
    # Same dance scripts/test_authdev.sh exercises: open /dev/auth,
    # write "user live\n" then "pass hamnix\n", read "ok ..." back.
    # Returns the verified afd on success, -1 on failure. The
    # initramfs ships /etc/{passwd,shadow} carrying this account.
    afd: int32 = sys_open("/dev/auth")
    if afd < 0:
        return -1
    user_line: Array[16, uint8]
    user_line[0]  = 117    # 'u'
    user_line[1]  = 115    # 's'
    user_line[2]  = 101    # 'e'
    user_line[3]  = 114    # 'r'
    user_line[4]  = 32     # ' '
    user_line[5]  = 108    # 'l'
    user_line[6]  = 105    # 'i'
    user_line[7]  = 118    # 'v'
    user_line[8]  = 101    # 'e'
    user_line[9]  = 10     # '\n'
    if sys_write(afd, &user_line[0], 10) < cast[int64](10):
        sys_close(afd)
        return -1
    pass_line: Array[16, uint8]
    pass_line[0]  = 112    # 'p'
    pass_line[1]  = 97     # 'a'
    pass_line[2]  = 115    # 's'
    pass_line[3]  = 115    # 's'
    pass_line[4]  = 32     # ' '
    pass_line[5]  = 104    # 'h'
    pass_line[6]  = 97     # 'a'
    pass_line[7]  = 109    # 'm'
    pass_line[8]  = 110    # 'n'
    pass_line[9]  = 105    # 'i'
    pass_line[10] = 120    # 'x'
    pass_line[11] = 10     # '\n'
    if sys_write(afd, &pass_line[0], 12) < cast[int64](12):
        sys_close(afd)
        return -1
    rn: int64 = sys_read(afd, &read_buf[0], 64)
    if rn < cast[int64](2):
        sys_close(afd)
        return -1
    if read_buf[0] != 111 or read_buf[1] != 107:  # not "ok"
        sys_close(afd)
        return -1
    return afd


def main() -> int32:
    write_str(1, "[p9authE2E] start\n")

    # 1) Authenticate as user "live" via /dev/auth.
    afd: int32 = auth_as_live()
    if afd < 0:
        write_str(1, "[p9authE2E] FAIL: auth_as_live\n")
        return 1
    write_str(1, "[p9authE2E] auth-as-live OK afd=")
    write_dec(1, cast[uint64](afd))
    write_str(1, "\n")

    # 2) Spawn user/p9srv_demo in post-auth mode publishing /srv/eauth.
    spawn_argv[0] = cast[uint64](&"/bin/p9srv_demo"[0])
    spawn_argv[1] = cast[uint64](&"post-auth"[0])
    spawn_argv[2] = cast[uint64](&"eauth"[0])
    spawn_argv[3] = 0
    pid: int32 = spawn(cast[Ptr[char]]("/bin/p9srv_demo"),
                       &spawn_argv[0], -1, -1, cast[Ptr[uint64]](0))
    if pid < 0:
        dump_errstr("[p9authE2E] FAIL: spawn errstr=")
        sys_close(afd)
        return 2
    write_str(1, "[p9authE2E] spawn p9srv_demo post-auth OK pid=")
    write_dec(1, cast[uint64](pid))
    write_str(1, "\n")

    # 3) Wait briefly for the child to call sys_srv_post. The cooperative
    # scheduler runs the child as soon as the parent yields — sys_read
    # on a quick poll on /srv would suffice, but we just spin a sys_srv_open
    # retry loop bounded by a few attempts.
    srvfd: int32 = -1
    attempt: int32 = 0
    while attempt < 64:
        srvfd = sys_srv_open("eauth")
        if srvfd >= 0:
            break
        sys_yield()
        attempt = attempt + 1
    if srvfd < 0:
        dump_errstr("[p9authE2E] FAIL: sys_srv_open errstr=")
        sys_close(afd)
        return 3
    write_str(1, "[p9authE2E] sys_srv_open eauth OK srvfd=")
    write_dec(1, cast[uint64](srvfd))
    write_str(1, "\n")

    # 4) Mount with the VERIFIED afd. The kernel's do_mount will drive
    # the wire-Tauth path (p9c_attach_authed_run): Tversion → Tauth →
    # Twrite(afid, "live") → Tattach(afid). The server-side
    # post-auth p9srv_demo rejects Tattach with NOFID or un-credentialed
    # afid, so a successful mount is proof the full handshake works.
    rc: int64 = syscall6(SYS_MOUNT,
                         cast[uint64](srvfd),
                         cast[uint64](afd),
                         cast[uint64](&"/n/eauth"[0]),
                         cast[uint64](MREPL),
                         cast[uint64](&""[0]),
                         0)
    if rc != 0:
        dump_errstr("[p9authE2E] FAIL: mount errstr=")
        sys_close(srvfd)
        sys_close(afd)
        return 4
    write_str(1, "[p9authE2E] mount with afd OK\n")

    # 5) Read /n/eauth/hello and compare to the server's canonical
    # "p9demo says hi\n" payload.
    hfd: int32 = sys_open("/n/eauth/hello")
    if hfd < 0:
        dump_errstr("[p9authE2E] FAIL: open /n/eauth/hello errstr=")
        sys_close(srvfd)
        sys_close(afd)
        return 5
    rn: int64 = sys_read(hfd, &read_buf[0], 64)
    sys_close(hfd)
    if rn < cast[int64](15):
        write_str(1, "[p9authE2E] FAIL: short read rn=")
        write_dec(1, cast[uint64](rn))
        write_str(1, "\n")
        sys_close(srvfd)
        sys_close(afd)
        return 6
    write_str(1, "[p9authE2E] read /hello OK rn=")
    write_dec(1, cast[uint64](rn))
    write_str(1, "\n")
    # Compare to expected "p9demo says hi\n" (15 bytes).
    i: uint64 = 0
    ok: int32 = 1
    while i < EXPECTED_LEN:
        if read_buf[i] != expected_payload[i]:
            ok = 0
            break
        i = i + 1
    if ok == 0:
        write_str(1, "[p9authE2E] FAIL: payload mismatch\n")
        sys_close(srvfd)
        sys_close(afd)
        return 7
    write_str(1, "[p9authE2E] payload match OK\n")

    sys_close(srvfd)
    sys_close(afd)
    write_str(1, "[p9authE2E] PASS\n")
    return 0

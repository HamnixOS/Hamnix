# tests/test_rio_blit_protocol.ad
#
# #442 (c) RIO BLIT PROTOCOL SUBSTRATE — userland round-trip fixture.
#
# Exercises the kernel half of the protocol:
#   1. open /dev/wsys/1/wctl, write "version 2\n"             (opt-in)
#   2. open /dev/wsys/1/bbstate, parse "<ver> ..."             (version flipped)
#   3. open /dev/wsys/1/draw/ctl, write a 'B' blit + 'D' rect  (commit)
#   4. re-read bbstate, confirm serial bumped + dirty rect non-empty
#   5. read /dev/wsys/1/backbuffer at the blit offset and check pixels
#
# Each step emits a marker line to stdout; the calling script
# (scripts/test_de_rio_blit_runtime.sh) grep-asserts the markers.
#
# This is INTENTIONALLY a tiny opt-in-v2 reference client — the rules
# say "if you cut scope, do it in the reference client / test, NOT in
# the protocol or backbuffer storage." So we keep the substrate full
# and the client minimal: one solid-color blit, one byte-readback.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_lseek(fd: int32, offset: int64, whence: int32) -> int64
extern def sys_exit(code: uint64)


SEEK_SET_RB: int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(s: Ptr[uint8]):
    sys_write(1, s, strlen(s))


# --- u64 -> ASCII decimal (for parsing-side cross-checks) -----------
def emit_u64(v: uint64):
    digs: Array[24, uint8]
    if v == 0:
        digs[0] = 48
        sys_write(1, &digs[0], 1)
        return
    d: uint64 = 0
    val: uint64 = v
    while val > 0:
        digs[d] = cast[uint8](val % 10) + 48
        val = val / 10
        d = d + 1
    out: Array[24, uint8]
    j: uint64 = 0
    while d > 0:
        d = d - 1
        out[j] = digs[d]
        j = j + 1
    sys_write(1, &out[0], j)


def parse_dec_u64(buf: Ptr[uint8], pos: uint64, end: uint64,
                  out: Ptr[uint64]) -> uint64:
    p: uint64 = pos
    while p < end and (buf[p] == 32 or buf[p] == 9):
        p = p + 1
    v: uint64 = 0
    while p < end:
        c: uint8 = buf[p]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c) - 48
        p = p + 1
    out[0] = v
    return p


# --- LE i32 emitter for blit headers --------------------------------
def emit_i32_le(out: Ptr[uint8], off: uint64, v: int32):
    u: uint32 = cast[uint32](v)
    out[off]     = cast[uint8](u & 255)
    out[off + 1] = cast[uint8]((u >> 8) & 255)
    out[off + 2] = cast[uint8]((u >> 16) & 255)
    out[off + 3] = cast[uint8]((u >> 24) & 255)


# Scratch sized for a 16x16 RGBA blit (16*16*4 = 1024) + 18 byte header.
blit_msg: Array[2048, uint8]
bbstate_buf: Array[256, uint8]
back_buf: Array[256, uint8]


def main() -> int32:
    emit("[test_rio_blit_protocol] start\n")

    # ---- Step 1: opt into v2 via wctl -----------------------------
    wctl_path: Ptr[uint8] = "/dev/wsys/1/wctl"
    wfd: int32 = sys_open_write(cast[Ptr[char]](wctl_path))
    if wfd < 0:
        emit("[test_rio_blit_protocol] FAIL: cannot open wctl\n")
        sys_exit(1)
    msg: Ptr[uint8] = "version 2\n"
    n: int64 = sys_write(wfd, msg, strlen(msg))
    sys_close(wfd)
    if n < 0:
        emit("[test_rio_blit_protocol] FAIL: wctl version 2 write rejected\n")
        sys_exit(1)
    emit("[test_rio_blit_protocol] version_set_ok=1\n")

    # ---- Step 2: read bbstate, confirm version >= 2 --------------
    bbs_path: Ptr[uint8] = "/dev/wsys/1/bbstate"
    bfd: int32 = sys_open(cast[Ptr[char]](bbs_path))
    if bfd < 0:
        emit("[test_rio_blit_protocol] FAIL: cannot open bbstate\n")
        sys_exit(1)
    nb: int64 = sys_read(bfd, &bbstate_buf[0], 256)
    sys_close(bfd)
    if nb <= 0:
        emit("[test_rio_blit_protocol] FAIL: bbstate read empty\n")
        sys_exit(1)
    ver0: uint64 = 0
    ser0: uint64 = 0
    pos: uint64 = 0
    pos = parse_dec_u64(&bbstate_buf[0], pos, cast[uint64](nb), &ver0)
    pos = parse_dec_u64(&bbstate_buf[0], pos, cast[uint64](nb), &ser0)
    if ver0 < 2:
        emit("[test_rio_blit_protocol] FAIL: bbstate version still <2\n")
        sys_exit(1)
    emit("[test_rio_blit_protocol] version_observed_ok=1 ver=")
    emit_u64(ver0)
    emit(" ser=")
    emit_u64(ser0)
    emit("\n")

    # ---- Step 3: write a 16x16 solid-red blit at (10,20) ---------
    blit_msg[0] = 66                                       # 'B'
    emit_i32_le(&blit_msg[0], 1, 10)                       # x0
    emit_i32_le(&blit_msg[0], 5, 20)                       # y0
    emit_i32_le(&blit_msg[0], 9, 26)                       # x1 (10 + 16)
    emit_i32_le(&blit_msg[0], 13, 36)                      # y1 (20 + 16)
    blit_msg[17] = 1                                       # FMT_RGBA8888
    # 16x16 = 256 pixels, RGBA = 4 bytes each = 1024 bytes payload.
    i: uint64 = 0
    while i < 256:
        off: uint64 = 18 + i * 4
        blit_msg[off]     = 255                            # R
        blit_msg[off + 1] = 0                              # G
        blit_msg[off + 2] = 0                              # B
        blit_msg[off + 3] = 255                            # A
        i = i + 1
    draw_ctl: Ptr[uint8] = "/dev/wsys/1/draw/ctl"
    dfd: int32 = sys_open_write(cast[Ptr[char]](draw_ctl))
    if dfd < 0:
        emit("[test_rio_blit_protocol] FAIL: cannot open draw/ctl\n")
        sys_exit(1)
    bwn: int64 = sys_write(dfd, &blit_msg[0], 18 + 1024)
    if bwn != cast[int64](18 + 1024):
        sys_close(dfd)
        emit("[test_rio_blit_protocol] FAIL: blit write short rc=")
        if bwn < 0:
            emit("-1")
        else:
            emit_u64(cast[uint64](bwn))
        emit("\n")
        sys_exit(1)
    emit("[test_rio_blit_protocol] blit_write_ok=1\n")
    # ---- Step 4: send the 'D' dirty rect over the same fd --------
    blit_msg[0] = 68                                       # 'D'
    emit_i32_le(&blit_msg[0], 1, 10)
    emit_i32_le(&blit_msg[0], 5, 20)
    emit_i32_le(&blit_msg[0], 9, 26)
    emit_i32_le(&blit_msg[0], 13, 36)
    dwn: int64 = sys_write(dfd, &blit_msg[0], 17)
    sys_close(dfd)
    if dwn != 17:
        emit("[test_rio_blit_protocol] FAIL: D write short\n")
        sys_exit(1)
    emit("[test_rio_blit_protocol] dirty_write_ok=1\n")

    # ---- Step 5: re-read bbstate; expect serial bumped + non-empty rect -
    bfd2: int32 = sys_open(cast[Ptr[char]](bbs_path))
    if bfd2 < 0:
        emit("[test_rio_blit_protocol] FAIL: cannot reopen bbstate\n")
        sys_exit(1)
    nb2: int64 = sys_read(bfd2, &bbstate_buf[0], 256)
    sys_close(bfd2)
    if nb2 <= 0:
        emit("[test_rio_blit_protocol] FAIL: bbstate2 read empty\n")
        sys_exit(1)
    ver1: uint64 = 0
    ser1: uint64 = 0
    dx0v: uint64 = 0
    dy0v: uint64 = 0
    dx1v: uint64 = 0
    dy1v: uint64 = 0
    p2: uint64 = 0
    p2 = parse_dec_u64(&bbstate_buf[0], p2, cast[uint64](nb2), &ver1)
    p2 = parse_dec_u64(&bbstate_buf[0], p2, cast[uint64](nb2), &ser1)
    p2 = parse_dec_u64(&bbstate_buf[0], p2, cast[uint64](nb2), &dx0v)
    p2 = parse_dec_u64(&bbstate_buf[0], p2, cast[uint64](nb2), &dy0v)
    p2 = parse_dec_u64(&bbstate_buf[0], p2, cast[uint64](nb2), &dx1v)
    p2 = parse_dec_u64(&bbstate_buf[0], p2, cast[uint64](nb2), &dy1v)
    if ser1 <= ser0:
        emit("[test_rio_blit_protocol] FAIL: serial did not advance ser0=")
        emit_u64(ser0)
        emit(" ser1=")
        emit_u64(ser1)
        emit("\n")
        sys_exit(1)
    if dx1v <= dx0v or dy1v <= dy0v:
        emit("[test_rio_blit_protocol] FAIL: dirty rect still empty\n")
        sys_exit(1)
    emit("[test_rio_blit_protocol] serial_bumped_ok=1 ser1=")
    emit_u64(ser1)
    emit("\n")
    emit("[test_rio_blit_protocol] dirty_rect_ok=1\n")

    # ---- Step 6: read the backbuffer at (10,20) — expect red ----
    # row 20, col 10 -> byte offset 20*1280 + 10*4 = 25640.
    bbfd: int32 = sys_open(cast[Ptr[char]]("/dev/wsys/1/backbuffer"))
    if bbfd < 0:
        emit("[test_rio_blit_protocol] FAIL: cannot open backbuffer\n")
        sys_exit(1)
    sys_lseek(bbfd, 25640, SEEK_SET_RB)
    nr: int64 = sys_read(bbfd, &back_buf[0], 4)
    sys_close(bbfd)
    if nr != 4:
        emit("[test_rio_blit_protocol] FAIL: backbuffer read short\n")
        sys_exit(1)
    if back_buf[0] != 255 or back_buf[1] != 0 or back_buf[2] != 0 \
       or back_buf[3] != 255:
        emit("[test_rio_blit_protocol] FAIL: backbuffer pixel mismatch\n")
        sys_exit(1)
    emit("[test_rio_blit_protocol] backbuffer_pixel_ok=1\n")

    emit("[test_rio_blit_protocol] PASS\n")
    sys_exit(0)
    return 0

# tests/test_pngwrite_host.ad
#
# HOST (x86_64-linux) driver that exercises lib/pngwrite.ad exactly the way
# user/hamshot.ad does — one IDAT (stored DEFLATE block) per row — but feeds
# a SYNTHETIC framebuffer instead of /dev/fbpix, and writes a real .png to
# the host filesystem so a human (or `file`/decoder) can LOOK at it.
#
#   test_pngwrite_host <out.png>
#
# The synthetic image is a 160x100 RGB scene: a blue->green vertical
# gradient with a red diagonal band and a white border — obviously
# non-uniform, and recognisable when opened.
#
# Build + run (host, no QEMU):
#   python3 -m compiler.adder compile --target=x86_64-linux \
#       tests/test_pngwrite_host.ad -o build/test_pngwrite_host.elf
#   build/test_pngwrite_host.elf /tmp/shot.png

from lib.pngwrite import (
    pngw_signature, pngw_ihdr, pngw_iend,
    pngw_idat_begin, pngw_idat_end,
    pngw_zlib_header, pngw_stored_block_hdr,
    pngw_adler_reset, pngw_adler_update, pngw_adler_final,
    pngw_put_u32_be,
)

extern def sys_open(path: Ptr[uint8], flags: int64, mode: int64) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

_W: uint64 = 160
_H: uint64 = 100

_out: Array[16384, uint8]


def _write_full(fd: int32, buf: Ptr[uint8], count: uint64) -> int32:
    done: uint64 = 0
    while done < count:
        n: int64 = sys_write(fd, &buf[done], count - done)
        if n <= 0:
            return -1
        done = done + cast[uint64](n)
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    path: Ptr[uint8] = cast[Ptr[uint8]]("/tmp/pngwrite_host.png")
    if argc > 1:
        path = cast[Ptr[uint8]](argv[1])

    # O_WRONLY|O_CREAT|O_TRUNC = 1|64|512 = 577, mode 0644 = 420.
    fd: int32 = sys_open(cast[Ptr[uint8]](path), 577, 420)
    if fd < 0:
        return 90

    sn: uint64 = pngw_signature(&_out[0])
    if _write_full(fd, &_out[0], sn) != 0:
        return 91
    hn: uint64 = pngw_ihdr(&_out[0], cast[uint32](_W), cast[uint32](_H))
    if _write_full(fd, &_out[0], hn) != 0:
        return 92

    pngw_adler_reset()
    y: uint64 = 0
    while y < _H:
        op: uint64 = pngw_idat_begin(&_out[0])
        if y == 0:
            op = pngw_zlib_header(&_out[0], op)
        dlen: uint64 = 1 + _W * 3
        is_last: int32 = 0
        if y == _H - 1:
            is_last = 1
        op = pngw_stored_block_hdr(&_out[0], op, dlen, is_last)
        filt: uint64 = op
        _out[op] = 0                                    # filter: None
        op = op + 1
        x: uint64 = 0
        while x < _W:
            # blue->green vertical gradient
            r: uint8 = 0
            g: uint8 = cast[uint8]((y * 255) / (_H - 1))
            b: uint8 = cast[uint8](255 - (y * 255) / (_H - 1))
            # red diagonal band
            d: uint64 = x + y
            if d >= 70 and d < 82:
                r = 230
                g = 40
                b = 40
            # white border
            if x < 3 or x >= _W - 3 or y < 3 or y >= _H - 3:
                r = 255
                g = 255
                b = 255
            _out[op]     = r
            _out[op + 1] = g
            _out[op + 2] = b
            op = op + 3
            x = x + 1
        pngw_adler_update(&_out[0], filt, dlen)
        if is_last != 0:
            op = pngw_put_u32_be(&_out[0], op, pngw_adler_final())
        clen: uint64 = op - 8
        total: uint64 = pngw_idat_end(&_out[0], clen)
        if _write_full(fd, &_out[0], total) != 0:
            return 93
        y = y + 1

    en: uint64 = pngw_iend(&_out[0])
    if _write_full(fd, &_out[0], en) != 0:
        return 94
    sys_close(fd)
    return 0

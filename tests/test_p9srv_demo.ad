# tests/test_p9srv_demo.ad
#
# V4 / Phase D smoke fixture: prove that user/p9srv_demo.ad is a
# correct 9P2000 server by driving it end-to-end as a userspace
# client. This is the test the V4 agent left as "minimum-viable
# userspace 9P server, prove the pipes are connected."
#
# WHY USERSPACE-CLIENT INSTEAD OF KERNEL-CLIENT
# ---------------------------------------------
# The kernel-side 9P client (sys/src/9/port/9p_client.ad) has a real-
# fd dispatch path that is STILL STUBBED -1 — _p9_send / _p9_recv only
# wire `smoke_mode != 0` (the boot-time loopback responder); the V4
# work that landed (commits 68a37ea / b2cc8ba) plumbed the userspace
# syscall surface — sys_srv_post (275) + sys_srv_open (276) — but not
# the vfs_read / vfs_write bridge inside _p9_send / _p9_recv. Until
# that bridge lands, sys_mount(srvfd, ...) returns -1 with errstr
# "mount failed: Tversion/Tattach".
#
# This fixture therefore exercises the loop ONE SIDE of the kernel
# boundary at a time:
#
#   * V4 syscalls (sys_srv_post / sys_srv_open): proven by simply
#     posting + re-opening a fd. Marker: [p9demo] srv_post+open OK.
#
#   * Userspace 9P round-trip (server byte correctness): proven by
#     speaking Tversion → Tattach → Twalk(hello) → Topen → Tread →
#     Tclunk to the server over pipes the fixture allocates, and
#     comparing the Rread payload to the canonical "p9demo says hi\n".
#     Marker: [p9demo] read payload OK.
#
# When the kernel-client real-fd dispatch lands, the third leg — full
# sys_mount + sys_open + sys_read through the kernel — can replace
# the userspace client half of this fixture without changing
# user/p9srv_demo.ad at all.
#
# WIRE TOPOLOGY
# -------------
#   sys_pipe(c2s)   # fixture writes T-msgs into c2s[1]; server reads c2s[0]
#   sys_pipe(s2c)   # server writes R-msgs into s2c[1]; fixture reads s2c[0]
#   sys_spawn("/bin/p9srv_demo", _, c2s[0], s2c[1], _)
#     -> child inherits c2s[0] as fd 0 and s2c[1] as fd 1
#
# After spawn the fixture closes its inherited copies of c2s[0] and
# s2c[1] so the server's eventual EOF on its stdin is reachable.
#
# Markers grepped by scripts/test_p9srv_demo.sh:
#   [p9demo] start
#   [p9demo] srv_post+open OK
#   [p9demo] spawn OK
#   [p9demo] Rversion OK
#   [p9demo] Rattach OK
#   [p9demo] Rwalk OK
#   [p9demo] Ropen OK
#   [p9demo] Rread OK
#   [p9demo] payload match OK
#   [p9demo] PASS
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_p9srv_demo.ad -o build/user/test_p9srv_demo.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_exit(code: uint64)
extern def sys_srv_post(name: Ptr[char], srvfd: int32) -> int32
extern def sys_srv_open(name: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32

from lib.9p.9p import (
    P9Cursor, p9_cursor_init,
    p9_decode_header,
    p9_emit_tversion, p9_decode_rversion,
    p9_emit_tattach,  p9_decode_rattach,
    p9_emit_twalk,    p9_decode_rwalk,
    p9_emit_topen,    p9_decode_ropen,
    p9_emit_tread,    p9_decode_rread,
    p9_emit_tclunk,   p9_decode_rclunk,
    p9_decode_rerror,
    P9_NOFID, P9_NOTAG,
    P9_OREAD, P9_QTFILE, P9_QTDIR,
    P9_RERROR,
)

# Top-level scratch buffers (Adder nested-frame Array bug avoidance).
CLI_BUF_CAP: uint64 = 8192
cli_buf: Array[8192, uint8]                       # outgoing T-msgs (encoded)
rsp_buf: Array[8192, uint8]                       # incoming R-msgs (decoded)

# Pipe fd scratch.
c2s_fds: Array[2, int32]
s2c_fds: Array[2, int32]

# Spawn argv (slot 0 = path, slot 1 = NUL terminator).
spawn_argv: Array[2, uint64]

err_buf: Array[128, uint8]

# Walk-name pointer arrays (top-level — P9_MAX_WELEM = 16).
walk_names: Array[16, Ptr[uint8]]
walk_lens:  Array[16, uint64]
walk_qtypes_in: Array[16, uint8]
walk_qvers_in:  Array[16, uint32]
walk_qpaths_in: Array[16, uint64]

# Expected payload for /hello.
expected: Array[16, uint8]
EXPECTED_LEN: uint64 = 15

# Fid plan: fid 0 = root (post-Tattach), fid 1 = /hello (post-Twalk).
ROOT_FID: uint32 = 0
HELLO_FID: uint32 = 1


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def init_expected():
    # "p9demo says hi\n" — same byte sequence the server emits.
    expected[0]  = 112    # 'p'
    expected[1]  = 57     # '9'
    expected[2]  = 100    # 'd'
    expected[3]  = 101    # 'e'
    expected[4]  = 109    # 'm'
    expected[5]  = 111    # 'o'
    expected[6]  = 32     # ' '
    expected[7]  = 115    # 's'
    expected[8]  = 97     # 'a'
    expected[9]  = 121    # 'y'
    expected[10] = 115    # 's'
    expected[11] = 32     # ' '
    expected[12] = 104    # 'h'
    expected[13] = 105    # 'i'
    expected[14] = 10     # '\n'


# --- pipe I/O helpers -------------------------------------------------

def _read_exact(fd: int32, buf: Ptr[uint8], want: uint64) -> int64:
    got: uint64 = 0
    while got < want:
        n: int64 = sys_read(fd, &buf[got], want - got)
        if n <= 0:
            return n
        got = got + cast[uint64](n)
    return cast[int64](got)


def _send_tmsg(tx_fd: int32, n: int32) -> int32:
    if n <= 0:
        return -1
    sent: int64 = sys_write(tx_fd, &cli_buf[0], cast[uint64](n))
    if sent != cast[int64](n):
        return -1
    return 0


def _recv_rmsg(rx_fd: int32) -> int32:
    # Read header (7 bytes), peek size, then pull body.
    h: int64 = _read_exact(rx_fd, &rsp_buf[0], 7)
    if h != cast[int64](7):
        return -1
    sz: uint32 = 0
    ty: uint8 = 0
    tg: uint16 = 0
    rc: int32 = p9_decode_header(&rsp_buf[0], 7, &sz, &ty, &tg)
    if rc != 0:
        return -1
    total: uint64 = cast[uint64](sz)
    if total < 7 or total > CLI_BUF_CAP:
        return -1
    if total > 7:
        b: int64 = _read_exact(rx_fd, &rsp_buf[7], total - 7)
        if b != cast[int64](total - 7):
            return -1
    return cast[int32](total)


# --- V4 syscall surface check -----------------------------------------
#
# Independent of the 9P round-trip, prove sys_srv_post + sys_srv_open
# round-trip a fd through the kernel `srv` table. Uses a throwaway
# pipe + name; tears down immediately after.

def exercise_srv_syscalls() -> int32:
    p_fds: Array[2, int32]
    if sys_pipe(&p_fds[0]) < 0:
        dump_errstr("[p9demo] FAIL: srv-syscall sys_pipe errstr=")
        return -1
    post_rc: int32 = sys_srv_post("p9demo_probe", p_fds[1])
    if post_rc < 0:
        dump_errstr("[p9demo] FAIL: sys_srv_post errstr=")
        sys_close(p_fds[0])
        sys_close(p_fds[1])
        return -1
    open_fd: int32 = sys_srv_open("p9demo_probe")
    if open_fd < 0:
        dump_errstr("[p9demo] FAIL: sys_srv_open errstr=")
        sys_close(p_fds[0])
        sys_close(p_fds[1])
        return -1
    write_str(1, "[p9demo] srv_post+open OK\n")
    sys_close(open_fd)
    sys_close(p_fds[0])
    sys_close(p_fds[1])
    return 0


# --- 9P client legs ---------------------------------------------------

def _client_version(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    ver: Array[8, uint8]
    ver[0] = 57    # '9'
    ver[1] = 80    # 'P'
    ver[2] = 50    # '2'
    ver[3] = 48
    ver[4] = 48
    ver[5] = 48
    n: int32 = p9_emit_tversion(&c, P9_NOTAG, 8192, &ver[0], 6)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        return -1
    tg: uint16 = 0
    ms: uint32 = 0
    vptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    vlen: uint64 = 0
    rc: int64 = p9_decode_rversion(&rsp_buf[0], cast[uint64](rn),
                                   &tg, &ms, &vptr, &vlen)
    if rc < cast[int64](0):
        return -1
    if vlen != 6:
        return -1
    write_str(1, "[p9demo] Rversion OK\n")
    return 0


def _client_attach(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    empty: Array[1, uint8]
    empty[0] = 0
    n: int32 = p9_emit_tattach(&c, 1, ROOT_FID, P9_NOFID,
                               &empty[0], 0, &empty[0], 0)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        return -1
    tg: uint16 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    rc: int64 = p9_decode_rattach(&rsp_buf[0], cast[uint64](rn),
                                  &tg, &qt, &qv, &qp)
    if rc < cast[int64](0):
        return -1
    if qt != P9_QTDIR:
        return -1
    write_str(1, "[p9demo] Rattach OK\n")
    return 0


def _client_walk_hello(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    hello: Array[8, uint8]
    hello[0] = 104    # 'h'
    hello[1] = 101    # 'e'
    hello[2] = 108    # 'l'
    hello[3] = 108    # 'l'
    hello[4] = 111    # 'o'
    walk_names[0] = &hello[0]
    walk_lens[0]  = 5
    n: int32 = p9_emit_twalk(&c, 2, ROOT_FID, HELLO_FID, 1,
                             &walk_names[0], &walk_lens[0])
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        return -1
    tg: uint16 = 0
    nq: uint16 = 0
    rc: int64 = p9_decode_rwalk(&rsp_buf[0], cast[uint64](rn),
                                &tg, &nq,
                                &walk_qtypes_in[0],
                                &walk_qvers_in[0],
                                &walk_qpaths_in[0])
    if rc < cast[int64](0):
        return -1
    if nq != 1:
        return -1
    if walk_qtypes_in[0] != P9_QTFILE:
        return -1
    write_str(1, "[p9demo] Rwalk OK\n")
    return 0


def _client_open_hello(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_topen(&c, 3, HELLO_FID, P9_OREAD)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        return -1
    tg: uint16 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    iou: uint32 = 0
    rc: int64 = p9_decode_ropen(&rsp_buf[0], cast[uint64](rn),
                                &tg, &qt, &qv, &qp, &iou)
    if rc < cast[int64](0):
        return -1
    if qt != P9_QTFILE:
        return -1
    write_str(1, "[p9demo] Ropen OK\n")
    return 0


def _client_read_hello(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_tread(&c, 4, HELLO_FID, 0, 32)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        return -1
    tg: uint16 = 0
    dptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    count: uint32 = 0
    rc: int64 = p9_decode_rread(&rsp_buf[0], cast[uint64](rn),
                                &tg, &dptr, &count)
    if rc < cast[int64](0):
        return -1
    write_str(1, "[p9demo] Rread OK\n")
    # Compare against expected payload byte-for-byte.
    if cast[uint64](count) != EXPECTED_LEN:
        write_str(1, "[p9demo] FAIL: read count != 15\n")
        return -1
    i: uint64 = 0
    while i < EXPECTED_LEN:
        if dptr[i] != expected[i]:
            write_str(1, "[p9demo] FAIL: payload mismatch\n")
            return -1
        i = i + 1
    write_str(1, "[p9demo] payload match OK\n")
    return 0


def _client_clunk(tx: int32, rx: int32, fid: uint32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_tclunk(&c, 5, fid)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        return -1
    tg: uint16 = 0
    rc: int64 = p9_decode_rclunk(&rsp_buf[0], cast[uint64](rn), &tg)
    if rc < cast[int64](0):
        return -1
    return 0


def main() -> int32:
    init_expected()
    write_str(1, "[p9demo] start\n")

    # 1) V4 syscall surface — independent of the pipe round-trip.
    if exercise_srv_syscalls() < 0:
        return 1

    # 2) Allocate the duplex pipe pair: c2s for T-msgs, s2c for R-msgs.
    if sys_pipe(&c2s_fds[0]) < 0:
        dump_errstr("[p9demo] FAIL: sys_pipe c2s errstr=")
        return 2
    if sys_pipe(&s2c_fds[0]) < 0:
        dump_errstr("[p9demo] FAIL: sys_pipe s2c errstr=")
        return 3

    c2s_rfd: int32 = c2s_fds[0]                   # server reads
    c2s_wfd: int32 = c2s_fds[1]                   # fixture writes
    s2c_rfd: int32 = s2c_fds[0]                   # fixture reads
    s2c_wfd: int32 = s2c_fds[1]                   # server writes

    # 3) Spawn the server. sys_spawn dup's c2s_rfd → child fd 0 and
    # s2c_wfd → child fd 1 BEFORE the child runs. The parent's copies
    # of those two fds need to close after spawn so the server's
    # eventual stdin-EOF is reachable when we close our T-msg writer.
    spawn_argv[0] = cast[uint64](&"/bin/p9srv_demo"[0])
    spawn_argv[1] = 0
    pid: int32 = sys_spawn("/bin/p9srv_demo", &spawn_argv[0],
                           c2s_rfd, s2c_wfd, cast[Ptr[uint64]](0))
    if pid < 0:
        dump_errstr("[p9demo] FAIL: sys_spawn errstr=")
        return 4
    write_str(1, "[p9demo] spawn OK\n")

    # Drop the parent-side inheritance: child has its own dup'd refs.
    sys_close(c2s_rfd)
    sys_close(s2c_wfd)

    # 4) Drive the 9P handshake + Tread.
    if _client_version(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[p9demo] FAIL: Tversion exchange\n")
        return 5
    if _client_attach(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[p9demo] FAIL: Tattach exchange\n")
        return 6
    if _client_walk_hello(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[p9demo] FAIL: Twalk exchange\n")
        return 7
    if _client_open_hello(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[p9demo] FAIL: Topen exchange\n")
        return 8
    if _client_read_hello(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[p9demo] FAIL: Tread exchange\n")
        return 9
    if _client_clunk(c2s_wfd, s2c_rfd, HELLO_FID) < 0:
        write_str(1, "[p9demo] FAIL: Tclunk /hello\n")
        return 10
    if _client_clunk(c2s_wfd, s2c_rfd, ROOT_FID) < 0:
        write_str(1, "[p9demo] FAIL: Tclunk root\n")
        return 11

    # 5) Tear down: close the T-msg writer so the server sees EOF and
    # exits cleanly, then wait for it. waitpid blocks + reaps.
    sys_close(c2s_wfd)
    sys_close(s2c_rfd)
    sys_waitpid(pid)

    write_str(1, "[p9demo] PASS\n")
    return 0

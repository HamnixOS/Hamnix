# tests/test_dev_blk_ns_visibility.ad
#
# Task #9 acceptance: the /dev directory listing must be NAMESPACE-ACCURATE.
#
# /dev/blk is the raw block-device server (`#b`, sys/src/9/port/devblk.ad).
# Its open gate (devblk_perm_check) is hostowner-only: "userland never has
# business reaching /dev/blk/* directly." But the /dev directory listing
# used to advertise a `blk` entry UNCONDITIONALLY, so in a stripped
# (non-hostowner) namespace `ls /dev` named a `blk` path that could not be
# opened — and lsblk / anything walking /dev then failed on it.
#
# The fix hides `blk` from the /dev listing in any ns that cannot open it
# (the same hostowner rule that gates the open), and makes the raw-block
# enumeration return empty for a non-hostowner. This fixture proves both
# halves in ONE boot by dropping privilege mid-run:
#
#   Step 0  (hostowner): sys_getuid() == 1  (inherited from PID 1).
#   Step 1  (hostowner): `/dev` listing NAMES `blk` (and `cons`), and
#                        `/dev/blk` enumerates >= 1 live device — the
#                        hostowner ns is unbroken.
#   Step 2:              sys_setuid(NOBODY); sys_getuid() == 65534.
#   Step 3  (nobody):    `/dev` listing OMITS `blk` but still names `cons`
#                        (root-cause fix: listing is ns-accurate), AND
#                        `/dev/blk` open is DENIED (< 0) at the server
#                        boundary (the boundary is NOT weakened), AND a
#                        leaf open of /dev/blk/<dev> is denied too.
#
# lsblk (user/lsblk.ad) turns that denied /dev/blk open into a clean
# "no accessible block devices" + exit 0 — the graceful-degrade half — so
# a stripped-ns lsblk succeeds instead of erroring. That path is exercised
# separately by the gate driving `lsblk` in hamsh as hostowner; here we
# assert the kernel-side contract the lsblk change relies on.
#
# Final marker: `[devblk_ns] PASS`. Greppable from
# scripts/test_dev_blk_ns_visibility.sh.

from lib.p9 import p9_listdir

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_GETUID: uint64 = 288
SYS_SETUID: uint64 = 290

UID_HOSTOWNER: uint64 = 1
UID_NOBODY:    uint64 = 65534


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: int64):
    if value < 0:
        sys_write(fd, "-", 1)
        value = -value
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = cast[uint64](value)
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def my_getuid() -> uint64:
    return cast[uint64](syscall6(SYS_GETUID, 0, 0, 0, 0, 0, 0))


def my_setuid(uid: uint64) -> int64:
    return syscall6(SYS_SETUID, uid, 0, 0, 0, 0, 0)


# Shared listing buffer. p9_listdir renders "NAME\n" lines here.
_lsbuf: Array[4096, uint8]


def list_dir(path: Ptr[char]) -> int64:
    # Return the byte count of the "NAME\n" listing of `path` (>= 0), or
    # -1 if the directory cannot be opened/read (e.g. denied at a server
    # boundary). Leaves the bytes in _lsbuf for line_present() to scan.
    return p9_listdir(path, &_lsbuf[0], 4096)


def line_present(nbytes: int64, needle: Ptr[uint8]) -> int32:
    # 1 if _lsbuf (the last list_dir result, `nbytes` long) contains a
    # line exactly equal to `needle`; else 0. Lines are '\n'-delimited.
    if nbytes <= 0:
        return 0
    total: uint64 = cast[uint64](nbytes)
    nlen: uint64 = strlen(needle)
    i: uint64 = 0
    ls: uint64 = 0                                      # current line start
    while i <= total:
        at_end: int32 = 0
        if i == total:
            at_end = 1
        elif _lsbuf[i] == 10:                           # '\n'
            at_end = 1
        if at_end != 0:
            llen: uint64 = i - ls
            if llen == nlen:
                eq: int32 = 1
                j: uint64 = 0
                while j < nlen:
                    if _lsbuf[ls + j] != needle[j]:
                        eq = 0
                        j = nlen
                    else:
                        j = j + 1
                if eq != 0:
                    return 1
            ls = i + 1
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[devblk_ns] start\n")

    # ---- Step 0: spawned by hamsh under PID 1 => hostowner (uid 1). ----
    uid0: uint64 = my_getuid()
    write_str(1, "[devblk_ns] initial uid = ")
    write_dec(1, cast[int64](uid0))
    sys_write(1, "\n", 1)
    if uid0 != UID_HOSTOWNER:
        write_str(1, "[devblk_ns] FAIL: initial uid is not hostowner (1)\n")
        return 1

    # ---- Step 1: hostowner ns — /dev NAMES blk, /dev/blk enumerates. ----
    hn_dev: int64 = list_dir(cast[Ptr[char]]("/dev"))
    if line_present(hn_dev, "blk") == 0:
        write_str(1, "[devblk_ns] FAIL: hostowner /dev listing omits blk\n")
        return 2
    if line_present(hn_dev, "cons") == 0:
        write_str(1, "[devblk_ns] FAIL: hostowner /dev listing omits cons\n")
        return 2
    write_str(1, "[devblk_ns] hostowner: ls /dev names blk (+cons)\n")

    hn_blk: int64 = list_dir(cast[Ptr[char]]("/dev/blk"))
    if hn_blk <= 0:
        write_str(1, "[devblk_ns] FAIL: hostowner /dev/blk enumerated no devices\n")
        return 3
    write_str(1, "[devblk_ns] hostowner: /dev/blk enumerates ")
    write_dec(1, hn_blk)
    write_str(1, " listing-bytes (>=1 device)\n")

    # ---- Step 2: drop to NOBODY (hostowner may downgrade at will). ----
    rc: int64 = my_setuid(UID_NOBODY)
    if rc < 0:
        write_str(1, "[devblk_ns] FAIL: SYS_SETUID(NOBODY) returned negative\n")
        return 4
    uid1: uint64 = my_getuid()
    write_str(1, "[devblk_ns] post-setuid uid = ")
    write_dec(1, cast[int64](uid1))
    sys_write(1, "\n", 1)
    if uid1 != UID_NOBODY:
        write_str(1, "[devblk_ns] FAIL: post-setuid uid not NOBODY (65534)\n")
        return 4

    # ---- Step 3a: stripped ns — /dev OMITS blk, still names cons. ----
    st_dev: int64 = list_dir(cast[Ptr[char]]("/dev"))
    if line_present(st_dev, "cons") == 0:
        write_str(1, "[devblk_ns] FAIL: stripped /dev listing lost cons too (over-hidden)\n")
        return 5
    if line_present(st_dev, "blk") != 0:
        write_str(1, "[devblk_ns] FAIL: stripped /dev STILL names blk (listing not ns-accurate)\n")
        return 5
    write_str(1, "[devblk_ns] stripped: ls /dev OMITS blk (keeps cons)\n")

    # ---- Step 3b: /dev/blk open denied at the server boundary. ----
    st_blk: int64 = list_dir(cast[Ptr[char]]("/dev/blk"))
    if st_blk >= 0:
        write_str(1, "[devblk_ns] FAIL: stripped ns opened /dev/blk (boundary weakened)\n")
        return 6
    write_str(1, "[devblk_ns] stripped: /dev/blk open denied (boundary intact)\n")

    # ---- Step 3c: a leaf device open is denied too. ----
    lfd: int32 = sys_open("/dev/blk/vda")
    if lfd >= 0:
        write_str(1, "[devblk_ns] FAIL: stripped ns opened /dev/blk/vda\n")
        sys_close(lfd)
        return 7
    write_str(1, "[devblk_ns] stripped: /dev/blk/vda open denied (expected)\n")

    write_str(1, "[devblk_ns] PASS\n")
    return 0

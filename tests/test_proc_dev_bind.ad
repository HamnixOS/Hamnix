# tests/test_proc_dev_bind.ad
#
# Phase D follow-up: /proc -> /dev as a namespace bind.
#
# The Layer-2 string-rewrite _u_translate_proc_to_dev (and its three
# helpers _u_proc_resolve_self / _u_proc_tail_eq / _u_proc_to_dev_rewrite)
# in linux_abi/u_syscalls.ad used to intercept open("/proc/<name>") and
# rewrite the bytes to "/dev/<name>" before calling vfs_open. That hack
# is now retired. The Plan 9-shape replacement lives in pgrp_init
# (sys/src/9/port/chan.ad): per-leaf FILE bindings
#
#   /proc/cpuinfo  -> #c/cpuinfo
#   /proc/meminfo  -> #c/meminfo
#   /proc/uptime   -> #c/uptime
#   /proc/loadavg  -> #c/loadavg
#   /proc/version  -> #c/version
#   /proc/hostname -> #c/hostname
#   /proc/stat     -> #c/stat
#   /proc/mounts   -> #c/mounts
#   /proc/diskstats-> #c/diskstats
#
# This test runs as a NATIVE Adder ELF (not a Linux ELF) so the
# /proc -> /dev bytes path runs through resolve_path's namespace walk
# UNAIDED — there's no Layer-2 shim sitting in front of SYS_OPEN. If
# the namespace bind is correctly planted, sys_open("/proc/cpuinfo")
# and sys_open("/dev/cpuinfo") must read byte-identical blobs (both
# resolve to the same `#c/cpuinfo` chan via devcpuinfo_read).
#
# We also assert /proc/self/<leaf> still routes through the `#p`
# proc server (devproc._parse_proc_path handles "self/" inline; the
# rewrite isn't needed) by reading /proc/self/stat and checking the
# first byte is an ASCII digit (field 1 of /proc/<pid>/stat is the pid).
#
# Run via scripts/test_proc_dev_bind.sh.
#
# Contract (one marker per case + an aggregate PASS):
#   [procdevbind] start
#   [procdevbind] A cpuinfo bind ok
#   [procdevbind] B loadavg bind ok
#   [procdevbind] C hostname bind ok
#   [procdevbind] D self-stat ok
#   [procdevbind] PASS

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen8(s))


def bytes_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def read_all(path: Ptr[char], buf: Ptr[uint8], cap: uint64) -> int64:
    # Open + read the whole file into buf, return bytes read or
    # negative on open/read failure. cdevs return their full blob in
    # one read; the underlying renderers are stateless and emit the
    # whole snapshot per read call. We still loop in case a future
    # backend chunks the response across reads.
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](buf) + total),
                            cap - total)
        if n < 0:
            sys_close(fd)
            return -2
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


# Scratch buffers — module-scope so they live in .bss not on stack.
buf_proc: Array[2048, uint8]
buf_dev:  Array[2048, uint8]


def case_bind(proc_path: Ptr[char], dev_path: Ptr[char],
              ok_marker: Ptr[uint8], fail_marker: Ptr[uint8]) -> int32:
    # Generic per-leaf bind check: read /proc/<name>, read /dev/<name>,
    # require byte-equal blobs. Identical bytes prove resolve_path
    # routed /proc/<name> through #c/<name> (same backend chan).
    n_p: int64 = read_all(proc_path, &buf_proc[0], 2048)
    if n_p <= 0:
        write_str(2, fail_marker)
        return 0
    n_d: int64 = read_all(dev_path, &buf_dev[0], 2048)
    if n_d <= 0:
        write_str(2, fail_marker)
        return 0
    if n_p != n_d:
        write_str(2, fail_marker)
        return 0
    if bytes_eq(&buf_proc[0], &buf_dev[0], cast[uint64](n_p)) == 0:
        write_str(2, fail_marker)
        return 0
    write_str(1, ok_marker)
    return 1


buf_self: Array[512, uint8]


def case_self_stat() -> int32:
    # /proc/self/stat: NOT covered by a per-leaf bind. Routes through
    # /proc -> #p (devproc), whose _parse_proc_path recognises "self/"
    # inline and substitutes current_task_pid(). First byte of
    # /proc/<pid>/stat is field 1, the pid — an ASCII digit.
    n: int64 = read_all(cast[Ptr[char]]("/proc/self/stat"),
                        &buf_self[0], 512)
    if n <= 0:
        write_str(2, "[procdevbind] self-stat FAIL\n")
        return 0
    b0: uint8 = buf_self[0]
    if b0 < 48 or b0 > 57:
        write_str(2, "[procdevbind] self-stat shape FAIL\n")
        return 0
    write_str(1, "[procdevbind] D self-stat ok\n")
    return 1


def main() -> int32:
    write_str(1, "[procdevbind] start\n")
    ok: int32 = 1
    if case_bind(cast[Ptr[char]]("/proc/cpuinfo"),
                 cast[Ptr[char]]("/dev/cpuinfo"),
                 "[procdevbind] A cpuinfo bind ok\n",
                 "[procdevbind] A cpuinfo bind FAIL\n") == 0:
        ok = 0
    if case_bind(cast[Ptr[char]]("/proc/loadavg"),
                 cast[Ptr[char]]("/dev/loadavg"),
                 "[procdevbind] B loadavg bind ok\n",
                 "[procdevbind] B loadavg bind FAIL\n") == 0:
        ok = 0
    if case_bind(cast[Ptr[char]]("/proc/hostname"),
                 cast[Ptr[char]]("/dev/hostname"),
                 "[procdevbind] C hostname bind ok\n",
                 "[procdevbind] C hostname bind FAIL\n") == 0:
        ok = 0
    if case_self_stat() == 0:
        ok = 0
    if ok != 0:
        write_str(1, "[procdevbind] PASS\n")
        sys_exit(0)
    else:
        write_str(1, "[procdevbind] FAIL\n")
        sys_exit(1)
    return 0

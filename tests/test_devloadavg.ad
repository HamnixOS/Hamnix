# tests/test_devloadavg.ad
#
# Regression: open /dev/loadavg for read, drain up to 96 bytes, echo
# the captured slice to stdout. The script asserts the captured text
# is well-formed Linux /proc/loadavg shape:
#
#   <digits>.<2 digits> <digits>.<2 digits> <digits>.<2 digits> <R>/<T> <pid>\n
#
# That's five whitespace-separated fields. We count the spaces (4) and
# emit "field_count=5" as the PASS marker.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devloadavg.ad -o build/user/test_devloadavg.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Count whitespace-separated fields in a buf bounded by a trailing
# newline. We treat one run of spaces between two non-space chars as
# a single separator (no consecutive spaces in our renderer, but be
# robust). Returns the field count.
def _count_fields(buf: Ptr[uint8], n: uint64) -> uint64:
    fields: uint64 = 0
    in_field: int32 = 0
    i: uint64 = 0
    while i < n:
        c: uint8 = buf[i]
        if c == 10:                              # '\n' terminates
            i = n
        elif c == 32:
            in_field = 0
        else:
            if in_field == 0:
                fields = fields + 1
                in_field = 1
        i = i + 1
    return fields


# Verify the '<R>/<T>' field is present: scan for any '/' surrounded
# by digit runs. Returns 1 on match, 0 otherwise.
def _check_rt_slash(buf: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if buf[i] == 47 and i > 0 and i + 1 < n:
            left:  uint8 = buf[i - 1]
            right: uint8 = buf[i + 1]
            if left >= 48 and left <= 57 \
                    and right >= 48 and right <= 57:
                return 1
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[test_devloadavg] start\n")

    fd: int32 = sys_open("/dev/loadavg")
    if fd < 0:
        write_str(1, "[test_devloadavg] open failed\n")
        return 1
    write_str(1, "[test_devloadavg] opened /dev/loadavg OK\n")

    buf: Array[128, uint8]
    n: int64 = sys_read(fd, &buf[0], 96)
    if n <= 0:
        write_str(1, "[test_devloadavg] read returned <= 0\n")
        sys_close(fd)
        return 1

    write_str(1, "[test_devloadavg] blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))

    fields: uint64 = _count_fields(&buf[0], cast[uint64](n))
    if fields != 5:
        write_str(1, "[test_devloadavg] field_count FAIL\n")
        sys_close(fd)
        return 1

    if _check_rt_slash(&buf[0], cast[uint64](n)) == 0:
        write_str(1, "[test_devloadavg] running/total slash missing\n")
        sys_close(fd)
        return 1

    # Emit the PASS marker: "field_count=5".
    write_str(1, "[test_devloadavg] field_count=5\n")

    sys_close(fd)
    write_str(1, "[test_devloadavg] done\n")
    return 0

# tests/test_bigmmap.ad
#
# >4 GiB large-VMA zeroing regression (boot-CR3 bracket fix).
#
# _vma_alloc_large() (mm/vma.ad) backs an anonymous mmap whose length
# exceeds VMA_MAX_CHUNK (4 MiB) with one or more 4-MiB buddy chunks, and
# EAGERLY alloc_pages()+zeros each chunk at mmap time. When RAM > 4 GiB a
# chunk can land ABOVE 4 GiB physical — identity-mapped only under the
# BOOT cr3 (1 GiB huge page), ABSENT under the running task's cr3 (low
# half = user). Zeroing such a chunk via its bare physical/identity VA
# (kernel-mode memset) #PFs and HALTS the box. The fix routes the zero
# through the boot-CR3-bracketed _vma_zero_phys helper.
#
# This test maps 4 MiB anonymous regions in a loop at -m 6G. Once the
# CUMULATIVE zeroed allocation exceeds 4 GiB, chunks NECESSARILY land
# above the 4 GiB physical line (pigeonhole: < 4 GiB of RAM sits below
# it). For every chunk we confirm the freshly-zeroed pages read back as
# ZERO (proves the boot-CR3 memset hit the correct frame) and accept a
# write/read-back sentinel. Pre-fix the box halts on the first >4 GiB
# chunk; post-fix it climbs past 4 GiB and prints the PASS banner.
#
# PASS criteria (host harness greps the serial log):
#   [bigmmap] PASS
# FAIL lines: any "[bigmmap] FAIL".
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_bigmmap.ad -o build/user/test_bigmmap.elf
#
# Run via scripts/test_bigmmap.sh (boots at -m 6G).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_mmap(addr: uint64, len: uint64, prot: int32,
                    flags: int32, fd: int32, offset: uint64) -> int64
extern def sys_exit(code: uint64)

PROT_READ:  int32 = 0x1
PROT_WRITE: int32 = 0x2

MAP_PRIVATE:   int32 = 0x02
MAP_ANONYMOUS: int32 = 0x20

PAGE_SIZE:  uint64 = 4096
CHUNK:      uint64 = 0x400000        # 4 MiB == VMA_MAX_CHUNK

# Climb well past the 4 GiB physical line so high chunks are forced.
# 4 MiB * 1152 == 4608 MiB == 4.5 GiB total virtual/physical committed.
TARGET_CHUNKS: uint64 = 1152
# Once we have committed this many MiB the >4 GiB path is guaranteed hit.
PROVEN_MIB:    uint64 = 4224


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def write_hex(fd: int32, value: uint64):
    sys_write(fd, "0x", 2)
    nibbles: Array[16, uint8]
    n: uint64 = 0
    v: uint64 = value
    if v == 0:
        sys_write(fd, "0", 1)
        return
    while v != 0:
        nib: uint64 = v & 15
        if nib < 10:
            nibbles[n] = cast[uint8](nib) + 48
        else:
            nibbles[n] = cast[uint8](nib - 10) + 97
        v = v >> 4
        n = n + 1
    out: Array[16, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = nibbles[n]
        i = i + 1
    sys_write(fd, &out[0], i)


# Verify one page-first-word inside a mapped chunk: must read back as the
# fresh zero the kernel wrote, then accept a sentinel round-trip. Returns
# 0 on success, 1 on failure.
def check_word(base: int64, off: uint64, sentinel: uint64) -> int32:
    p: Ptr[uint64] = cast[Ptr[uint64]](base + cast[int64](off))
    if p[0] != 0:
        write_str(1, "[bigmmap] FAIL: stale (non-zero) page at off ")
        write_hex(1, off)
        write_str(1, " = ")
        write_hex(1, p[0])
        write_str(1, "\n")
        return 1
    p[0] = sentinel
    if p[0] != sentinel:
        write_str(1, "[bigmmap] FAIL: sentinel round-trip at off ")
        write_hex(1, off)
        write_str(1, "\n")
        return 1
    return 0


def main() -> int32:
    write_str(1, "[bigmmap] start: mapping 4 MiB anon chunks past 4 GiB\n")

    mapped_mib: uint64 = 0
    i: uint64 = 0
    proven: int32 = 0

    while i < TARGET_CHUNKS:
        a: int64 = sys_mmap(0, CHUNK, PROT_READ | PROT_WRITE,
                            MAP_PRIVATE | MAP_ANONYMOUS, -1, 0)
        if a <= 0:
            # Ran out before the 4 GiB mark: cannot prove the >4 GiB path.
            write_str(1, "[bigmmap] mmap stopped after ")
            write_dec(1, mapped_mib)
            write_str(1, " MiB (rc=")
            write_hex(1, cast[uint64](a))
            write_str(1, ")\n")
            if mapped_mib >= PROVEN_MIB:
                # Enough committed to have forced chunks above 4 GiB.
                proven = 1
            i = TARGET_CHUNKS
        else:
            # Touch the first word of the first AND last page of the
            # freshly-zeroed chunk (both were zeroed under the boot cr3;
            # a >4 GiB chunk pre-fix would have halted the box before we
            # ever get here).
            if check_word(a, 0, 0xDEADBEEF00000000 + i) != 0:
                return 1
            if check_word(a, CHUNK - PAGE_SIZE, 0xCAFEBABE00000000 + i) != 0:
                return 1
            mapped_mib = mapped_mib + 4
            i = i + 1
            if (mapped_mib % 512) == 0:
                write_str(1, "[bigmmap] committed ")
                write_dec(1, mapped_mib)
                write_str(1, " MiB (zeroed OK)\n")
            if mapped_mib >= PROVEN_MIB and proven == 0:
                proven = 1
                write_str(1, "[bigmmap] crossed 4 GiB: >4 GiB chunks "
                             "zeroed under boot cr3, no #PF\n")

    if proven == 0:
        write_str(1, "[bigmmap] FAIL: could not commit past 4 GiB "
                     "(need > ")
        write_dec(1, PROVEN_MIB)
        write_str(1, " MiB)\n")
        return 1

    write_str(1, "[bigmmap] total committed+zeroed = ")
    write_dec(1, mapped_mib)
    write_str(1, " MiB\n")
    write_str(1, "[bigmmap] PASS\n")
    return 0

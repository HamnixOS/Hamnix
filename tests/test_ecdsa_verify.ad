# tests/test_ecdsa_verify.ad
#
# ECDSA-P256 signature verification (V3) end-to-end regression. Boots
# the same openssl-generated ECDSA-P256 self-signed cert used by
# tests/test_x509_walker.ad (DER bytes copy-pasted verbatim), walks it
# through lib/x509/x509.ad::x509_parse to extract the public key, the
# TBS byte range, and the signature, then drives the whole triple
# through lib/ecdsa/ecdsa.ad::ecdsa_p256_verify.
#
# Asserts (all pass = `[ecdsa] PASS`):
#   - x509_parse on the cert bytes returns 0
#   - ecdsa_parse_pubkey accepts the 65-byte uncompressed SEC1 point
#   - ecdsa_p256_verify on the legitimate (TBS, sig, pubkey) triple == 1
#   - Flipping one bit of the signature flips the verify result to 0
#   - Flipping one bit of the TBS (the bytes that are hashed) flips
#     the verify result to 0
#   - Range-check rejection: a signature whose r == 0 returns -1
#
# Driven by scripts/test_ecdsa_verify.sh.

from lib.asn1.asn1 import (
    asn1_init_oids,
)
from lib.x509.x509 import (
    X509Cert,
    x509_parse,
)
from lib.ec.p256 import (
    P256Point,
    p256_init,
)
from lib.ecdsa.ecdsa import (
    EcdsaPubkey,
    ecdsa_init,
    ecdsa_parse_pubkey,
    ecdsa_p256_verify,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer ----------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


def _wdec_signed(value: int64):
    if value < 0:
        sys_write(1, "-", 1)
        _wdec(cast[uint64](-value))
        return
    _wdec(cast[uint64](value))


# -- failure aggregator ----------------------------------------------------

fail_count: int32 = 0


def _check_eq_i32(a: int32, b: int32, label: Ptr[uint8]):
    if a != b:
        _wstr("[ecdsa] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec_signed(cast[int64](a))
        _wstr(" want=")
        _wdec_signed(cast[int64](b))
        _wstr("\n")
        fail_count = fail_count + 1



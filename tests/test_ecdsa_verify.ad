# Top-level scratch — keep the X509Cert + EcdsaPubkey off the stack.
cert: X509Cert
pubkey: EcdsaPubkey

# Scratch buffer for sig-mutation test.
mutated_sig: Array[80, uint8]


def main() -> int32:
    _wstr("[ecdsa] start\n")

    asn1_init_oids()
    p256_init()
    ecdsa_init()
    _init_cert()

    # --- (1) Parse the cert. ----------------------------------------------
    rc: int32 = x509_parse(&cert_der[0], cert_der_len, &cert)
    _check_eq_i32(rc, 0, "x509_parse rc==0")
    if rc != 0:
        _wstr("[ecdsa] failures=")
        _wdec(cast[uint64](fail_count))
        _wstr("\n[ecdsa] FAIL\n")
        return 1

    # --- (2) Parse the pubkey from the cert. ------------------------------
    rc = ecdsa_parse_pubkey(&cert.pubkey_bytes[0], cert.pubkey_bytes_len,
                            &pubkey)
    _check_eq_i32(rc, 0, "ecdsa_parse_pubkey rc==0")

    # --- (3) Verify the legitimate signature. -----------------------------
    rc = ecdsa_p256_verify(&pubkey,
                           cert.tbs_bytes, cert.tbs_len,
                           &cert.sig_bytes[0], cert.sig_bytes_len)
    _check_eq_i32(rc, 1, "verify legitimate sig == 1")

    # --- (4) Flip one bit in the signature; expect verify == 0. -----------
    # Copy sig, flip a bit inside the `s` integer body (offset 50 in the
    # DER SEQUENCE for our specific sig — well past the SEQUENCE tag
    # and the r INTEGER). Any bit flip in the verified-mathematics
    # region invalidates the sig.
    i: uint64 = 0
    while i < cert.sig_bytes_len:
        mutated_sig[i] = cert.sig_bytes[i]
        i = i + 1
    mutated_sig[50] = mutated_sig[50] ^ 0x01
    rc = ecdsa_p256_verify(&pubkey,
                           cert.tbs_bytes, cert.tbs_len,
                           &mutated_sig[0], cert.sig_bytes_len)
    _check_eq_i32(rc, 0, "verify sig-bit-flipped == 0")

    # --- (5) Flip one bit in the TBS message; expect verify == 0. ---------
    # cert.tbs_bytes points back into cert_der[]; mutate one byte
    # within the TBS region (offset 100 in the TBS, well inside the
    # subject-DN string), then call verify, then restore.
    saved: uint8 = cert.tbs_bytes[100]
    cert.tbs_bytes[100] = saved ^ 0x01
    rc = ecdsa_p256_verify(&pubkey,
                           cert.tbs_bytes, cert.tbs_len,
                           &cert.sig_bytes[0], cert.sig_bytes_len)
    _check_eq_i32(rc, 0, "verify message-bit-flipped == 0")
    cert.tbs_bytes[100] = saved

    # Sanity: restoring the byte makes verify succeed again. Guards
    # against the message-flip false-positive where some other
    # earlier mutation went unrolled.
    rc = ecdsa_p256_verify(&pubkey,
                           cert.tbs_bytes, cert.tbs_len,
                           &cert.sig_bytes[0], cert.sig_bytes_len)
    _check_eq_i32(rc, 1, "verify after restore == 1")

    # --- (6) Malformed: a DER sig with r == 0 must be rejected. ----------
    # Build a tiny `SEQUENCE { INTEGER 0, INTEGER 1 }` ad-hoc.
    bad_sig: Array[8, uint8]
    bad_sig[0] = 0x30   # SEQUENCE
    bad_sig[1] = 0x06   # len = 6
    bad_sig[2] = 0x02   # INTEGER
    bad_sig[3] = 0x01   # len = 1
    bad_sig[4] = 0x00   # r = 0  -- range-check should reject
    bad_sig[5] = 0x02   # INTEGER
    bad_sig[6] = 0x01   # len = 1
    bad_sig[7] = 0x01   # s = 1
    rc = ecdsa_p256_verify(&pubkey,
                           cert.tbs_bytes, cert.tbs_len,
                           &bad_sig[0], cast[uint64](8))
    _check_eq_i32(rc, -1, "verify r==0 returns -1 (malformed)")

    # --- (7) Malformed: signature DER that doesn't even parse. ------------
    garbage: Array[4, uint8]
    garbage[0] = 0xAA
    garbage[1] = 0xBB
    garbage[2] = 0xCC
    garbage[3] = 0xDD
    rc = ecdsa_p256_verify(&pubkey,
                           cert.tbs_bytes, cert.tbs_len,
                           &garbage[0], cast[uint64](4))
    _check_eq_i32(rc, -1, "verify garbage DER returns -1")

    _wstr("[ecdsa] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[ecdsa] PASS\n")
        return 0
    _wstr("[ecdsa] FAIL\n")
    return 1

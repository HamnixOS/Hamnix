# tests/test_dir_record_full.ad
#
# #458 F10-6 (this wave) — assert SYS_LISTDIR_RECORDS now emits real
# Plan 9 Dir records for the remaining perm-body-stub backings called
# out as still on NAME\n lines: tmpfs (/tmp), devcons (/dev), and
# devauth (/dev/auth). Mirrors tests/test_dir_record_expand.ad but
# targets the disjoint set this F10-6 wave wired up.
#
# /dev/auth requires a LIVE pool slot for the listing to be non-empty
# (slot allocation happens on `open("/dev/auth")`). The test opens
# /dev/auth before listing so devauth has at least one in-use slot.
#
# Markers grepped by scripts/test_dir_record_full.sh:
#   [dirfull] start
#   [dirfull] tmp OK
#   [dirfull] dev OK
#   [dirfull] auth OK
#   [dirfull] PASS

from lib.p9 import (
    p9_listdir_records,
    p9_diread_open, p9_diread, p9_diread_close,
    DIR_CUR_NAME, DIR_CUR_NAME_LEN,
    DIR_CUR_UID,  DIR_CUR_UID_LEN,
    DIR_CUR_MODE,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


buf_full: Array[4096, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def check_dir(path: Ptr[char], label: Ptr[uint8]) -> int32:
    # Bulk read first.
    n: int64 = p9_listdir_records(path, &buf_full[0], 4096)
    if n <= 0:
        write_str(1, "[dirfull] FAIL: listdir_records <= 0 for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    # Walk one record via p9_diread; assert decoded shape.
    h: int32 = p9_diread_open(path)
    if h < 0:
        write_str(1, "[dirfull] FAIL: p9_diread_open for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    rc: int32 = p9_diread(h)
    p9_diread_close(h)
    if rc <= 0:
        write_str(1, "[dirfull] FAIL: no records decoded for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    if DIR_CUR_NAME_LEN == 0:
        write_str(1, "[dirfull] FAIL: empty Dir.name for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    if DIR_CUR_UID_LEN == 0:
        write_str(1, "[dirfull] FAIL: empty Dir.uid for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    if DIR_CUR_MODE == 0:
        write_str(1, "[dirfull] FAIL: zero Dir.mode for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    return 1


def main() -> int32:
    write_str(1, "[dirfull] start\n")

    # Guarantee at least one /tmp child so the listing isn't a
    # legitimate-but-test-defeating zero-record return.
    tfd: int32 = sys_open_write("/tmp/dirfull_probe")
    if tfd >= 0:
        sys_write(tfd, "x\n", 2)
        sys_close(tfd)

    if check_dir("/tmp", "/tmp") == 0:
        return 1
    write_str(1, "[dirfull] tmp OK\n")

    if check_dir("/dev", "/dev") == 0:
        return 2
    write_str(1, "[dirfull] dev OK\n")

    # /dev/auth lists in-use pool slots. Open /dev/auth so devauth has
    # at least one live slot before we list. The fd stays open through
    # the listing so the slot is in_use=1 at list time.
    afd: int32 = sys_open("/dev/auth")
    if afd < 0:
        write_str(1, "[dirfull] FAIL: open /dev/auth\n")
        return 3
    if check_dir("/dev/auth", "/dev/auth") == 0:
        return 4
    write_str(1, "[dirfull] auth OK\n")

    write_str(1, "[dirfull] PASS\n")
    return 0

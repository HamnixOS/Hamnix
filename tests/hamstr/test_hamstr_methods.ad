# tests/hamstr/test_hamstr_methods.ad
#
# On-device exercise of the owning-heap String methods in lib/hamstr.ad,
# composed over lib/hamalloc.ad (the heap) + lib/strview.ad (the views).
# Every method is checked against an asserted expected output, each owning
# result is freed, and a churn re-verifies the heap stays uncorrupted after
# the frees. Prints "[hamstr-m] Tn PASS" per test and "[hamstr-m] PASS" +
# a final checksum at the end.
#
# Kept as many SMALL functions (not one giant main) so the seed<->native
# objdiff boundary-matcher stays happy.

from lib.hamstr import ham_str_upper, ham_str_lower, ham_str_trim, \
    ham_split_next, ham_split_count, ham_str_replace, \
    ham_str_from_int, ham_str_from_uint, \
    ham_str_starts_with, ham_str_ends_with
from lib.hamalloc import ham_str_free

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

# Running byte-sum over every asserted result, folded into the final banner.
g_sum: uint64 = 0


def slen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def puts(s: Ptr[uint8]):
    sys_write(1, s, slen(s))


def is_null(p: Ptr[uint8]) -> uint64:
    if p == cast[Ptr[uint8]](0):
        return 1
    return 0


# streq over two NUL-terminated strings: 1 == equal.
def streq(a: Ptr[uint8], b: Ptr[uint8]) -> uint64:
    i: uint64 = 0
    while a[i] != 0 and b[i] != 0:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if a[i] == b[i]:
        return 1
    return 0


# Compare `n` raw bytes at a,b: 1 == equal.
def memeq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> uint64:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Fold a result's bytes into g_sum so a corrupted allocation shifts the
# final checksum.
def absorb(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        g_sum = g_sum + cast[uint64](s[i])
        i = i + 1


# Check an owning result equals `want`, absorb it, then free it. 1 == ok.
def check_owned(got: Ptr[uint8], want: Ptr[uint8]) -> uint64:
    if is_null(got) != 0:
        return 0
    if streq(got, want) != 1:
        ham_str_free(got)
        return 0
    absorb(got)
    ham_str_free(got)
    return 1


def t_upper() -> int32:
    r: Ptr[uint8] = ham_str_upper("Ham9nix!", 8)
    if check_owned(r, "HAM9NIX!") != 1:
        puts("[hamstr-m] T1 FAIL upper\n")
        return 1
    puts("[hamstr-m] T1 PASS\n")
    return 0


def t_lower() -> int32:
    r: Ptr[uint8] = ham_str_lower("HeLLo-WORLD", 11)
    if check_owned(r, "hello-world") != 1:
        puts("[hamstr-m] T2 FAIL lower\n")
        return 1
    puts("[hamstr-m] T2 PASS\n")
    return 0


def t_trim() -> int32:
    a: Ptr[uint8] = ham_str_trim("  \t hi there \n", 14)
    if check_owned(a, "hi there") != 1:
        puts("[hamstr-m] T3 FAIL trim-mid\n")
        return 1
    # All-whitespace trims to an owning empty string.
    b: Ptr[uint8] = ham_str_trim("  \t\n ", 5)
    if check_owned(b, "") != 1:
        puts("[hamstr-m] T3 FAIL trim-empty\n")
        return 1
    puts("[hamstr-m] T3 PASS\n")
    return 0


# Assert the field at cursor equals `want` (a NUL-terminated expected value).
def split_expect(src: Ptr[uint8], len: uint64, sep: uint8,
                 pos: Ptr[uint64], want: Ptr[uint8]) -> uint64:
    fptr: uint64 = 0
    flen: uint64 = 0
    if ham_split_next(src, len, sep, pos, &fptr, &flen) == 0:
        return 0
    if flen != slen(want):
        return 0
    return memeq(cast[Ptr[uint8]](fptr), want, flen)


def t_split() -> int32:
    src: Ptr[uint8] = "a,,bb,c"
    if ham_split_count(src, 7, 44) != 4:            # 44 == ','
        puts("[hamstr-m] T4 FAIL count\n")
        return 1
    pos: uint64 = 0
    ok: uint64 = 1
    if split_expect(src, 7, 44, &pos, "a") != 1:
        ok = 0
    if split_expect(src, 7, 44, &pos, "") != 1:
        ok = 0
    if split_expect(src, 7, 44, &pos, "bb") != 1:
        ok = 0
    if split_expect(src, 7, 44, &pos, "c") != 1:
        ok = 0
    fptr: uint64 = 0
    flen: uint64 = 0
    if ham_split_next(src, 7, 44, &pos, &fptr, &flen) != 0:  # exhausted
        ok = 0
    # Trailing separator yields a final empty field: "x," -> ["x", ""].
    p2: uint64 = 0
    if split_expect("x,", 2, 44, &p2, "x") != 1:
        ok = 0
    if split_expect("x,", 2, 44, &p2, "") != 1:
        ok = 0
    # Empty input yields exactly one empty field.
    p3: uint64 = 0
    if split_expect("", 0, 44, &p3, "") != 1:
        ok = 0
    if ham_split_count("", 0, 44) != 1:
        ok = 0
    if ok != 1:
        puts("[hamstr-m] T4 FAIL split\n")
        return 1
    puts("[hamstr-m] T4 PASS\n")
    return 0


def t_replace() -> int32:
    # same-length replacement, multiple non-overlapping hits
    a: Ptr[uint8] = ham_str_replace("foo bar foo", 11, "foo", 3, "baz", 3)
    if check_owned(a, "baz bar baz") != 1:
        puts("[hamstr-m] T5 FAIL replace-eq\n")
        return 1
    # replacement LONGER than needle
    b: Ptr[uint8] = ham_str_replace("aXaXa", 5, "X", 1, "YYY", 3)
    if check_owned(b, "aYYYaYYYa") != 1:
        puts("[hamstr-m] T5 FAIL replace-long\n")
        return 1
    # replacement SHORTER than needle
    c: Ptr[uint8] = ham_str_replace("xxxx", 4, "xx", 2, "y", 1)
    if check_owned(c, "yy") != 1:
        puts("[hamstr-m] T5 FAIL replace-short\n")
        return 1
    # empty needle: no-op owning copy
    d: Ptr[uint8] = ham_str_replace("keep", 4, "", 0, "Z", 1)
    if check_owned(d, "keep") != 1:
        puts("[hamstr-m] T5 FAIL replace-empty-needle\n")
        return 1
    puts("[hamstr-m] T5 PASS\n")
    return 0


def t_from_int() -> int32:
    z: Ptr[uint8] = ham_str_from_int(0)
    if check_owned(z, "0") != 1:
        puts("[hamstr-m] T6 FAIL zero\n")
        return 1
    p: Ptr[uint8] = ham_str_from_int(123456)
    if check_owned(p, "123456") != 1:
        puts("[hamstr-m] T6 FAIL pos\n")
        return 1
    n: Ptr[uint8] = ham_str_from_int(0 - 4096)
    if check_owned(n, "-4096") != 1:
        puts("[hamstr-m] T6 FAIL neg\n")
        return 1
    # INT_MIN = -9223372036854775808 (magnitude via unsigned negate)
    lo: int64 = cast[int64](0x8000000000000000)
    m: Ptr[uint8] = ham_str_from_int(lo)
    if check_owned(m, "-9223372036854775808") != 1:
        puts("[hamstr-m] T6 FAIL int_min\n")
        return 1
    # UINT64_MAX
    u: Ptr[uint8] = ham_str_from_uint(0xFFFFFFFFFFFFFFFF)
    if check_owned(u, "18446744073709551615") != 1:
        puts("[hamstr-m] T6 FAIL uint_max\n")
        return 1
    puts("[hamstr-m] T6 PASS\n")
    return 0


def t_affix() -> int32:
    src: Ptr[uint8] = "hamnix.img"
    ok: uint64 = 1
    if ham_str_starts_with(src, 10, "ham", 3) != 1:
        ok = 0
    if ham_str_starts_with(src, 10, "nix", 3) != 0:
        ok = 0
    if ham_str_ends_with(src, 10, ".img", 4) != 1:
        ok = 0
    if ham_str_ends_with(src, 10, ".iso", 4) != 0:
        ok = 0
    # A prefix/suffix longer than the string never matches.
    if ham_str_starts_with(src, 10, "hamnix.image", 12) != 0:
        ok = 0
    if ok != 1:
        puts("[hamstr-m] T7 FAIL affix\n")
        return 1
    puts("[hamstr-m] T7 PASS\n")
    return 0


# Churn many owning from_int strings to re-verify the heap is uncorrupted
# after all the earlier frees (freed blocks reused, values still correct).
def t_churn() -> int32:
    i: uint64 = 0
    while i < 2000:
        s: Ptr[uint8] = ham_str_from_uint(i)
        if is_null(s) != 0:
            puts("[hamstr-m] T8 FAIL oom\n")
            return 1
        # round-trip: recompute the value from the produced digits
        v: uint64 = 0
        j: uint64 = 0
        while s[j] != 0:
            v = v * 10 + cast[uint64](s[j]) - 48
            j = j + 1
        ham_str_free(s)
        if v != i:
            puts("[hamstr-m] T8 FAIL roundtrip\n")
            return 1
        i = i + 1
    puts("[hamstr-m] T8 PASS\n")
    return 0


def main() -> int32:
    puts("[hamstr-m] start\n")
    fail: int32 = 0
    fail = fail + t_upper()
    fail = fail + t_lower()
    fail = fail + t_trim()
    fail = fail + t_split()
    fail = fail + t_replace()
    fail = fail + t_from_int()
    fail = fail + t_affix()
    fail = fail + t_churn()

    # Final checksum over every asserted owning result (dogfoods from_uint).
    puts("[hamstr-m] checksum=")
    cs: Ptr[uint8] = ham_str_from_uint(g_sum)
    puts(cs)
    ham_str_free(cs)
    puts("\n")

    if fail != 0:
        puts("[hamstr-m] FAIL\n")
        return 1
    puts("[hamstr-m] PASS\n")
    return 0

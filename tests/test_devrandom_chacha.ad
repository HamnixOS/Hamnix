# tests/test_devrandom_chacha.ad
#
# M16.96 regression: open /dev/random, read 4096 bytes, bucket-count
# them into 256 histogram bins (one per byte value 0..255). Expected
# mean count is 4096 / 256 = 16. A real ChaCha20 keystream should
# produce a tight distribution (every bucket non-zero, max/min ratio
# typically < 3x for n=4096). The xorshift64 placeholder M16.95
# shipped would FAIL this — its low byte cycles in a way that leaves
# entire bins at zero for a 4 KiB sample.
#
# Output line:
#   [test_devrandom_chacha] hist min=<min_count> max=<max_count>
#     total=<total_bytes> nonzero_buckets=<n>
# The shell script asserts:
#   - total == 4096
#   - nonzero_buckets >= 200 (very loose; chi-square would give >250
#     with high probability, but we want zero-flake margin)
#   - max <= 5 * (min if min > 0 else 1)  — rules out a degenerate
#     distribution like xorshift's
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devrandom_chacha.ad -o build/user/test_devrandom_chacha.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def u32_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    # Mirrors fs/procfs.ad::_buf_put_dec. Reverse-fill, lowest digit
    # first, then copy out top-down. Returns bytes written.
    if value == 0:
        out[0] = 48                          # '0'
        return 1
    digits: Array[16, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def write_kv(fd: int32, key: Ptr[uint8], value: uint64):
    # Emit " <key>=<value>" — leading space so the caller can chain
    # several without worrying about separators.
    sys_write(fd, " ", 1)
    write_str(fd, key)
    sys_write(fd, "=", 1)
    scratch: Array[16, uint8]
    n: uint64 = u32_to_dec(value, &scratch[0])
    sys_write(fd, &scratch[0], n)


# 4 KiB sample size — one full ChaCha20 rekey epoch (64 blocks).
# Picked deliberately: covers exactly one block-counter window, so
# we exercise both the per-block path AND the rekey path inside a
# single test read.
SAMPLE_BYTES: uint64 = 4096

# Globals so the 4 KiB sample + 2 KiB histogram don't blow the
# kernel-side 16 KiB user stack — matches user/sort.ad's pattern.
sample_buf: Array[4096, uint8]
hist:       Array[256, uint64]


def main() -> int32:
    write_str(1, "[test_devrandom_chacha] start\n")

    fd: int32 = sys_open("/dev/random")
    if fd < 0:
        write_str(1, "[test_devrandom_chacha] open failed\n")
        return 1

    # Read SAMPLE_BYTES in one shot. The kernel-side devrandom_read
    # serves the whole request from the keystream; we don't need to
    # loop on short reads.
    n: int64 = sys_read(fd, &sample_buf[0], SAMPLE_BYTES)
    if n != cast[int64](SAMPLE_BYTES):
        write_str(1, "[test_devrandom_chacha] short read\n")
        sys_close(fd)
        return 1
    sys_close(fd)

    # Bucket-count: hist[v] = number of times byte value v appeared.
    i: uint64 = 0
    while i < 256:
        hist[i] = 0
        i = i + 1

    i = 0
    while i < SAMPLE_BYTES:
        b: uint64 = cast[uint64](sample_buf[i])
        hist[b] = hist[b] + 1
        i = i + 1

    # Walk hist to find min, max, and nonzero-bucket count.
    min_count: uint64 = 0xFFFFFFFFFFFFFFFF
    max_count: uint64 = 0
    nonzero: uint64 = 0
    total: uint64 = 0
    i = 0
    while i < 256:
        c: uint64 = hist[i]
        total = total + c
        if c > max_count:
            max_count = c
        if c < min_count:
            min_count = c
        if c != 0:
            nonzero = nonzero + 1
        i = i + 1

    # Emit summary. The shell script parses min/max/total/nonzero.
    write_str(1, "[test_devrandom_chacha] hist")
    write_kv(1, "min", min_count)
    write_kv(1, "max", max_count)
    write_kv(1, "total", total)
    write_kv(1, "nonzero_buckets", nonzero)
    write_str(1, "\n")

    # Also do a second read AFTER the first 4 KiB to confirm the
    # rekey path fires: read 16 more bytes, dump their decimal. If
    # any bytes leak the previous keystream verbatim, this is
    # visible by comparison.
    fd2: int32 = sys_open("/dev/random")
    if fd2 < 0:
        write_str(1, "[test_devrandom_chacha] reopen failed\n")
        return 1
    post: Array[16, uint8]
    np: int64 = sys_read(fd2, &post[0], 16)
    sys_close(fd2)
    if np != 16:
        write_str(1, "[test_devrandom_chacha] post short read\n")
        return 1
    # Sum post[] — used by the shell script as a non-zero sanity check
    # on the post-rekey stream. Real ChaCha20 sum of 16 bytes is
    # ~16 * 128 = 2048 in expectation; placeholder xorshift after
    # rekey would also vary, so this is a soft check.
    psum: uint64 = 0
    i = 0
    while i < 16:
        psum = psum + cast[uint64](post[i])
        i = i + 1
    write_str(1, "[test_devrandom_chacha] post")
    write_kv(1, "sum16", psum)
    write_str(1, "\n")

    write_str(1, "[test_devrandom_chacha] done\n")
    return 0

# tests/test_ns_child_visibility.ad
#
# BUG #113 (devproc / namespace visibility) — repro + regression.
#
# The Plan-9 per-process-namespace COW-inheritance contract, as seen
# through devproc's /proc/self/ns:
#
#   * A child inherits the parent's binds at fork time. Reading
#     /proc/self/ns in the child (opened AFTER fork) MUST show the
#     parent's inherited bind.
#   * For a plain fork (shared Pgrp) the child's later binds ARE
#     visible to the parent (shared namespace) — that's fine.
#   * For an RFNAMEG fork (private COW Pgrp) the child sees the
#     inherited bind, but its LATER binds do NOT leak to the parent,
#     and the parent's later binds do NOT appear in the child.
#   * A /proc/self/ns fd OPENED in the parent BEFORE fork and then
#     inherited by the child continues to name the OPENER's (parent's)
#     namespace — Linux `openat(/proc/self/ns/...)` semantics: the fd
#     is resolved once, at open, and rides the fork.
#
# Cases (each emits one marker; aggregate PASS at the end):
#   A  plain-fork child, /proc/self/ns opened AFTER fork, shows parent bind
#   B  RFNAMEG child, /proc/self/ns opened AFTER fork, shows inherited bind
#   C  RFNAMEG child's LATER bind does NOT appear in the parent's ns
#   D  RFNAMEG parent's LATER bind does NOT appear in the child's ns
#
# Run via scripts/test_ns_child_visibility.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_rfork(flags: int32) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_BIND: uint64 = 257

RFPROC:  int32 = 0x001
RFFDG:   int32 = 0x004
RFNAMEG: int32 = 0x008
RFENVG:  int32 = 0x010

MREPL: int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def do_bind(new_path: Ptr[uint8], old_path: Ptr[uint8]) -> int64:
    return syscall6(SYS_BIND,
                    cast[uint64](new_path),
                    cast[uint64](old_path),
                    cast[uint64](MREPL), 0, 0, 0)


# Read the whole of `path` into buf; return bytes read or <0 on error.
def read_all(path: Ptr[char], buf: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](buf) + total),
                            cap - total)
        if n < 0:
            sys_close(fd)
            return -2
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


# Substring search: 1 iff `needle` occurs in buf[0..len).
def contains(buf: Ptr[uint8], len: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen(needle)
    if nlen == 0:
        return 1
    if nlen > len:
        return 0
    i: uint64 = 0
    while i + nlen <= len:
        j: uint64 = 0
        while j < nlen and buf[i + j] == needle[j]:
            j = j + 1
        if j == nlen:
            return 1
        i = i + 1
    return 0


# Module-scope scratch (keep off the stack).
ns_buf: Array[4096, uint8]


# Read /proc/self/ns and return whether it contains `needle`.
def self_ns_has(needle: Ptr[uint8]) -> int32:
    n: int64 = read_all(cast[Ptr[char]]("/proc/self/ns"), &ns_buf[0], 4096)
    if n < 0:
        return -1
    return contains(&ns_buf[0], cast[uint64](n), needle)


def main() -> int32:
    write_str(1, "[nschild] start\n")
    ok: int32 = 1

    # ----------------------------------------------------------------
    # Case A: plain fork (shared Pgrp). Parent binds, then forks
    # WITHOUT RFNAMEG. The child opens /proc/self/ns AFTER the fork and
    # must observe the inherited bind.
    if do_bind("/nsA113", "/etc") != 0:
        write_str(2, "[nschild] A FAIL: parent bind /nsA113 failed\n")
        return 1
    pidA: int32 = sys_rfork(RFPROC | RFFDG)
    if pidA < 0:
        write_str(2, "[nschild] A FAIL: rfork\n")
        return 1
    if pidA == 0:
        hasA: int32 = self_ns_has("/nsA113")
        if hasA == 1:
            write_str(1, "[nschild] A ok (plain-fork child sees inherited bind)\n")
        else:
            write_str(2, "[nschild] A FAIL: child /proc/self/ns missing /nsA113\n")
        sys_exit(cast[uint64](1 - hasA))
        return 0
    sA: int64 = sys_waitpid(cast[uint64](pidA))
    if sA != 0:
        ok = 0

    # ----------------------------------------------------------------
    # Case B/C/D: RFNAMEG fork (private COW Pgrp).
    if do_bind("/nsB113", "/etc") != 0:
        write_str(2, "[nschild] B FAIL: parent bind /nsB113 failed\n")
        return 1
    pidB: int32 = sys_rfork(RFPROC | RFFDG | RFNAMEG | RFENVG)
    if pidB < 0:
        write_str(2, "[nschild] B FAIL: rfork\n")
        return 1
    if pidB == 0:
        # B: inherited bind visible in the child's own ns.
        hasB: int32 = self_ns_has("/nsB113")
        if hasB == 1:
            write_str(1, "[nschild] B ok (RFNAMEG child sees inherited bind)\n")
        else:
            write_str(2, "[nschild] B FAIL: child /proc/self/ns missing /nsB113\n")
            sys_exit(1)
        # Child adds a PRIVATE bind that the parent must NOT observe.
        if do_bind("/nsC113_child", "/etc") != 0:
            write_str(2, "[nschild] C FAIL: child bind failed\n")
            sys_exit(1)
        write_str(1, "[nschild] child planted /nsC113_child\n")
        sys_exit(0)
        return 0
    sB: int64 = sys_waitpid(cast[uint64](pidB))
    if sB != 0:
        ok = 0

    # ----------------------------------------------------------------
    # Case E (inherited-fd / "self resolving to the reader"): the
    # parent opens /proc/self/ns BEFORE an RFNAMEG fork. The child
    # plants a PRIVATE bind, then reads the INHERITED fd. Under
    # "self = the reading task" the inherited /proc/self/ns fd must
    # reflect the CHILD's own (diverged) namespace — i.e. it MUST show
    # the child's private bind /nsE113_child.
    if do_bind("/nsE113_parent", "/etc") != 0:
        write_str(2, "[nschild] E FAIL: parent bind /nsE113_parent failed\n")
        return 1
    efd: int32 = sys_open(cast[Ptr[char]]("/proc/self/ns"))
    if efd < 0:
        write_str(2, "[nschild] E FAIL: parent open /proc/self/ns\n")
        return 1
    pidE: int32 = sys_rfork(RFPROC | RFFDG | RFNAMEG | RFENVG)
    if pidE < 0:
        write_str(2, "[nschild] E FAIL: rfork\n")
        return 1
    if pidE == 0:
        if do_bind("/nsE113_child", "/etc") != 0:
            write_str(2, "[nschild] E FAIL: child bind failed\n")
            sys_exit(1)
        # Read the INHERITED fd (opened by the parent pre-fork).
        n2: int64 = sys_read(efd, &ns_buf[0], 4096)
        if n2 < 0:
            write_str(2, "[nschild] E FAIL: child read inherited fd\n")
            sys_exit(1)
        seen_child: int32 = contains(&ns_buf[0], cast[uint64](n2),
                                     "/nsE113_child")
        if seen_child == 1:
            write_str(1, "[nschild] E ok (inherited /proc/self/ns fd tracks the reader's ns)\n")
            sys_exit(0)
        else:
            write_str(2, "[nschild] E FAIL: inherited fd shows opener's ns, not reader's\n")
            sys_exit(2)
        return 0
    sE: int64 = sys_waitpid(cast[uint64](pidE))
    if sE != 0:
        ok = 0

    # C: the child's later private bind must NOT be in the PARENT's ns.
    hasC: int32 = self_ns_has("/nsC113_child")
    if hasC == 0:
        write_str(1, "[nschild] C ok (child's private bind did not leak to parent)\n")
    else:
        write_str(2, "[nschild] C FAIL: child's bind leaked into parent ns\n")
        ok = 0

    write_str(1, "[nschild] all-cases-done\n")
    if ok != 0:
        write_str(1, "[nschild] PASS\n")
        sys_exit(0)
    else:
        write_str(1, "[nschild] FAIL\n")
        sys_exit(1)
    return 0

# Sub-slice on a String (element size 1 -> the no-scale ptr path). The sub-slice
# view carries the narrowed byte length; `p[0]` is read via a BOUND Ptr local
# (indexing an inline `.ptr` member is a separate pre-existing native gap).
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    h: String = String("hello world")
    w: String = h[6:11]               # "world", len 5
    p: Ptr[uint8] = w.ptr
    return cast[int32](w.len) + cast[int32](p[0])   # 5 + 'w'(119) = 124

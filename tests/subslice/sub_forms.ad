# Omitted-bound forms: s[a:], s[:b], s[:].
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, int32]
    a[0] = 10
    a[1] = 20
    a[2] = 30
    a[3] = 40
    a[4] = 50
    a[5] = 60
    s: Slice[int32] = Slice[int32](a)
    t1: Slice[int32] = s[3:]          # {40,50,60}, len 3 ; t1[0]=40
    t2: Slice[int32] = s[:2]          # {10,20},   len 2 ; t2[1]=20
    t3: Slice[int32] = s[:]           # full view, len 6
    return t1[0] + t2[1] + cast[int32](t3.len)   # 40 + 20 + 6 = 66

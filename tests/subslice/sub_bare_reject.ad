# A BARE sub-slice in expression position (not bound to a local) is deferred
# this pass and must be REJECTED cleanly by BOTH backends (never miscompiled).
def take(p: Ptr[uint8], n: uint64) -> int32:
    return cast[int32](n)

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, uint8]
    a[0] = 1
    s: Slice[uint8] = Slice[uint8](a)
    sub: Slice[uint8] = s[1:3]
    return take(sub.ptr, sub.len)

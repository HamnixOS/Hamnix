# start < 0 (via a variable bound): the range check `0 <= start` FAILS.
# Traps (SIGILL) under --check-bounds; a silent no-op WITHOUT the flag
# (returns 7; the bad slice is formed but never dereferenced).
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, int32]
    a[0] = 10
    a[1] = 20
    a[2] = 30
    a[3] = 40
    a[4] = 50
    a[5] = 60
    s: Slice[int32] = Slice[int32](a)
    neg: int32 = 0 - 1
    sub: Slice[int32] = s[neg:3]      # start -1 < 0 -> trap under the flag
    return 7

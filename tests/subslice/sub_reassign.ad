# Sub-slice assigned to a pre-declared slice (the Assignment path).
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[8, int32]
    i: int32 = 0
    while i < 8:
        a[i] = (i + 1) * 5
        i = i + 1
    s: Slice[int32] = Slice[int32](a)
    sub: Slice[int32] = s[:]
    sub = s[4:7]                       # {25,30,35}, len 3
    return sub[0] + sub[2] + cast[int32](sub.len)   # 25 + 35 + 3 = 63

# start > end: the range check `start <= end` FAILS (5 > 2). Traps (SIGILL)
# under --check-bounds; a silent no-op WITHOUT the flag (returns 7, the bad
# slice is formed but never dereferenced).
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, int32]
    a[0] = 10
    a[1] = 20
    a[2] = 30
    a[3] = 40
    a[4] = 50
    a[5] = 60
    s: Slice[int32] = Slice[int32](a)
    sub: Slice[int32] = s[5:2]        # start 5 > end 2 -> trap under the flag
    return 7

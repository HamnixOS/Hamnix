# Sub-slice s[a:b] on a Slice[int32] (element size 4 -> exercises the
# int64-cast + explicit *sizeof byte-offset ptr path), then index the result.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, int32]
    a[0] = 10
    a[1] = 20
    a[2] = 30
    a[3] = 40
    a[4] = 50
    a[5] = 60
    s: Slice[int32] = Slice[int32](a)
    sub: Slice[int32] = s[2:5]        # {30, 40, 50}, len 3
    total: int32 = sub[0] + sub[1] + sub[2] + cast[int32](sub.len)
    # 30 + 40 + 50 + 3 = 123
    return total

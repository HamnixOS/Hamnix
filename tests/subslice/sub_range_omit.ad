# Omitted-bound range check: s[:] materialises start->0 and end->base.len, so
# this exercises the range check's synthesized-0 (mk_int_lit/IntLiteral) and
# synthesized-.len (agg_mk_member/MemberExpr) paths under --check-bounds. All
# three conditions (0<=0, len>=0, len<=len) pass -> runs cleanly.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, int32]
    s: Slice[int32] = Slice[int32](a)
    sub: Slice[int32] = s[:]          # 0 <= 0 <= 6 <= 6 -> in range
    return 11 + cast[int32](sub.len)  # 11 + 6 = 17

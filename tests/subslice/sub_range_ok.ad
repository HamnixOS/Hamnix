# In-bounds sub-slice s[2:5] under --check-bounds: the range check
# 0 <= 2 <= 5 <= 6 PASSES cleanly (no trap), returns a sentinel WITHOUT
# indexing the result (isolates the range check from the element check).
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, int32]
    a[0] = 10
    a[1] = 20
    a[2] = 30
    a[3] = 40
    a[4] = 50
    a[5] = 60
    s: Slice[int32] = Slice[int32](a)
    sub: Slice[int32] = s[2:5]        # 0 <= 2 <= 5 <= 6 -> in range
    return 42 + cast[int32](sub.len)  # 42 + 3 = 45

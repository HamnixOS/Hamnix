# Range-check ISOLATION fixture: no checked array-element writes and no result
# indexing, so under --check-bounds the ONLY ud2s are the THREE range-check
# conditions (0 <= start, start <= end, end <= len). Used to count them exactly.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, int32]
    s: Slice[int32] = Slice[int32](a)
    sub: Slice[int32] = s[2:9]        # end 9 > len 6 -> traps under the flag
    return 7

# tests/test_compiler_signed_pow2_div.ad — regression for issue #102: a SIGNED
# int64 divided/modulo'd by a CONSTANT power of two (or any constant) whose
# DIVIDEND is a computed sub-expression (e.g. `(a - b)`) was miscompiled as an
# UNSIGNED operation (divq / logical shrq / bias-free strength-reduced shift)
# instead of the round-toward-zero signed idiv. For a negative dividend this
# returned ~2^54 garbage (e.g. -4003 / 1024 -> 18014398509481980 instead of -3).
#
# ROOT CAUSE (fixed): the div/mod signedness decision looked at the operand's
# STATIC type shallowly, which is "unknown" for an integer sub-expression, so it
# fell back to the unsigned default. An identifier/cast dividend already worked;
# ONLY a computed dividend (`a - b`, `a + 0`, `0 - 4003`, ...) was bitten — which
# is why real code (lib/svg.ad arc math, lib/jpeg.ad) had to work around it with
# an `_sdiv(a, b)` helper (a VARIABLE divisor forces a real idiv).
#
# STRATEGY: for each case, compute the quotient/remainder TWO ways —
#   * CONST divisor  : `(a - b) / 1024`        (the path that was miscompiled)
#   * VARIABLE divisor: `(a - b) / d`, d passed at runtime (always a real idiv)
# The variable-divisor form is the trusted reference (exactly the `_sdiv`
# workaround). run_all() returns 0 iff every const form equals its idiv
# reference; otherwise it returns the 1-based index of the first mismatch.
#
# Exercised over BOTH backends by scripts/test_compiler_signed_pow2_div.sh:
# the Python seed (codegen_x86.py) and the self-hosted native (codegen.ad),
# each with strength reduction OFF and ON.

# --- CONST-divisor forms (the code shape that was miscompiled) -------------
def div_c2(a: int64, b: int64) -> int64:
    return (a - b) / 2

def div_c4(a: int64, b: int64) -> int64:
    return (a - b) / 4

def div_c256(a: int64, b: int64) -> int64:
    return (a - b) / 256

def div_c1024(a: int64, b: int64) -> int64:
    return (a - b) / 1024

def div_c65536(a: int64, b: int64) -> int64:
    return (a - b) / 65536

def mod_c2(a: int64, b: int64) -> int64:
    return (a - b) % 2

def mod_c4(a: int64, b: int64) -> int64:
    return (a - b) % 4

def mod_c1024(a: int64, b: int64) -> int64:
    return (a - b) % 1024

# --- VARIABLE-divisor references (trusted real signed idiv) ----------------
def div_v(a: int64, b: int64, d: int64) -> int64:
    return (a - b) / d

def mod_v(a: int64, b: int64, d: int64) -> int64:
    return (a - b) % d

# --- UNSIGNED must STILL use logical shr / unsigned div --------------------
# A computed uint64 dividend / constant pow2 must remain unsigned; the fix must
# not flip these to signed. Compared against the variable-divisor unsigned form.
def udiv_c1024(a: uint64, b: uint64) -> uint64:
    return (a - b) / cast[uint64](1024)

def udiv_v(a: uint64, b: uint64, d: uint64) -> uint64:
    return (a - b) / d

# Return 0 if every const-divisor result matches its idiv reference for the
# given (a, b); else a nonzero tag identifying the failing case.
def check_pair(a: int64, b: int64, tag: int64) -> int64:
    if div_c2(a, b) != div_v(a, b, 2):
        return tag + 1
    if div_c4(a, b) != div_v(a, b, 4):
        return tag + 2
    if div_c256(a, b) != div_v(a, b, 256):
        return tag + 3
    if div_c1024(a, b) != div_v(a, b, 1024):
        return tag + 4
    if div_c65536(a, b) != div_v(a, b, 65536):
        return tag + 5
    if mod_c2(a, b) != mod_v(a, b, 2):
        return tag + 6
    if mod_c4(a, b) != mod_v(a, b, 4):
        return tag + 7
    if mod_c1024(a, b) != mod_v(a, b, 1024):
        return tag + 8
    return 0

# The public entry the C driver / native harness observes. Returns 0 on PASS.
def run_all() -> int64:
    r: int64 = 0
    # -4003 / {2,4,256,1024,65536} and % — the headline negative case.
    r = check_pair(cast[int64](0) - cast[int64](4003), cast[int64](0), 100)
    if r != 0:
        return r
    # -1 / 2 == 0 ; -1 % 2 == -1 (sign of dividend).
    r = check_pair(cast[int64](0) - cast[int64](1), cast[int64](0), 200)
    if r != 0:
        return r
    # -7 / 4 == -1 ; -7 % 4 == -3.
    r = check_pair(cast[int64](0) - cast[int64](7), cast[int64](0), 300)
    if r != 0:
        return r
    # INT64_MIN / 2 == -2^62 (sign-critical, high bit set).
    r = check_pair(cast[int64](-9223372036854775807) - cast[int64](1),
                   cast[int64](0), 400)
    if r != 0:
        return r
    # POSITIVE dividends must be unchanged (4003, 7, big).
    r = check_pair(cast[int64](4003), cast[int64](0), 500)
    if r != 0:
        return r
    r = check_pair(cast[int64](123456789), cast[int64](7), 600)
    if r != 0:
        return r
    # UNSIGNED computed dividend / const pow2 must STILL be unsigned.
    # (2^64 - 4003) / 1024 via a wrapping subtraction; compare to the unsigned
    # variable-divisor reference.
    if udiv_c1024(cast[uint64](0), cast[uint64](4003)) != udiv_v(cast[uint64](0), cast[uint64](4003), cast[uint64](1024)):
        return 700
    return 0

# tests/modpriv_a.ad — helper module A for the per-module symbol
# scoping regression (scripts/test_compiler_module_private.sh).
#
# Defines a MODULE-PRIVATE helper `_scale` (leading underscore =
# private by convention). Module B (tests/modpriv_b.ad) and the
# fixture (tests/test_compiler_module_private.ad) ALSO each define a
# private `_scale` with a different body. Before per-module scoping
# landed, merge_programs() flat-namespaced all three and hard-errored
# on the collision. With scoping, each `_scale` is mangled to
# `<module>__scale` and `mp_a()` here must resolve to THIS module's
# `_scale` (multiply by 10), not B's or the fixture's.

def _scale(x: int32) -> int32:
    return x * 10


# Public entry point — NOT underscore-prefixed, stays globally visible.
def mp_a(x: int32) -> int32:
    return _scale(x)

# tests/phase0b_hello.ad — trivial LLVM-subset input for the Phase-0b
# on-device host_ac `--backend=llvm` proof. A few integer functions plus a
# main returning a KNOWN value (42). No libc, no prints — we only need
# host_ac to EMIT a valid textual .ll under the linux shim on-device.

def add(a: int64, b: int64) -> int64:
    return a + b

def mul(a: int64, b: int64) -> int64:
    return a * b

def square(n: int64) -> int64:
    return mul(n, n)

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # square(4) = 16 ; add(16, 26) = 42
    r: int64 = add(square(cast[int64](4)), cast[int64](26))
    return cast[int32](r & 255)

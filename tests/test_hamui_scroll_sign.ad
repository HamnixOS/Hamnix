# tests/test_hamui_scroll_sign.ad
#
# BUG #123 regression — the mouse SCROLL WHEEL was inverted in EVERY hamUI
# app. The single shared sign lives in lib/hamscene.ad::hamui_scroll_apply,
# which lib/hamui.ad::_h_route_scroll calls for both scrolledwindow (pixel)
# and textview (line) scrolling. This is a PURE, host-linkable unit test of
# that sign law — no QEMU, no /dev/wsys.
#
# CONTRACT (see sys/src/9/port/devmouse.ad): dz > 0 = wheel UP, dz < 0 =
# wheel DOWN. A LARGER offset moves content DOWN through the document. So:
#   * wheel DOWN (dz < 0) must INCREASE the offset,
#   * wheel UP   (dz > 0) must DECREASE the offset (clamped at 0).
#
# Build (host):
#   python3 -m compiler.adder compile --target=x86_64-linux \
#       tests/test_hamui_scroll_sign.ad -o build/host/test_hamui_scroll_sign
#
# PASS prints "[hamui-scroll-sign] PASS" and exits 0; any FAIL exits 1.

from lib.hamscene import hamui_scroll_apply

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def puts(s: Ptr[uint8]):
    sys_write(1, s, strlen(s))


fail_count: int32 = 0


def check(name: Ptr[uint8], got: int32, want: int32):
    if got == want:
        puts(cast[Ptr[uint8]]("  ok   "))
        puts(name)
        puts(cast[Ptr[uint8]]("\n"))
    else:
        fail_count = fail_count + 1
        puts(cast[Ptr[uint8]]("  FAIL "))
        puts(name)
        puts(cast[Ptr[uint8]]("\n"))


def main() -> int32:
    puts(cast[Ptr[uint8]]("[hamui-scroll-sign] BUG #123 wheel sign\n"))

    # Scrolledwindow: 16 px/notch, content taller than viewport (maxoff=200).
    # Wheel DOWN one notch (dz=-1) from the top must move the offset DOWN
    # by one stride (0 -> 16), NOT clamp at 0.
    check(cast[Ptr[uint8]]("scroll: wheel-down increases offset"),
          hamui_scroll_apply(0, 0 - 1, 16, 200), 16)
    # From an offset, wheel UP one notch (dz=+1) moves back UP by a stride.
    check(cast[Ptr[uint8]]("scroll: wheel-up decreases offset"),
          hamui_scroll_apply(32, 1, 16, 200), 16)
    # Wheel UP at the top clamps at 0 (never negative).
    check(cast[Ptr[uint8]]("scroll: wheel-up clamps at 0"),
          hamui_scroll_apply(0, 1, 16, 200), 0)
    # Wheel DOWN past the end clamps at maxoff.
    check(cast[Ptr[uint8]]("scroll: wheel-down clamps at maxoff"),
          hamui_scroll_apply(200, 0 - 1, 16, 200), 200)

    # Textview: 1 line/notch, no upper clamp (maxoff = -1).
    check(cast[Ptr[uint8]]("textview: wheel-down +1 line"),
          hamui_scroll_apply(5, 0 - 1, 1, 0 - 1), 6)
    check(cast[Ptr[uint8]]("textview: wheel-up -1 line"),
          hamui_scroll_apply(5, 1, 1, 0 - 1), 4)
    check(cast[Ptr[uint8]]("textview: wheel-up clamps at 0"),
          hamui_scroll_apply(0, 1, 1, 0 - 1), 0)

    if fail_count == 0:
        puts(cast[Ptr[uint8]]("[hamui-scroll-sign] PASS\n"))
        sys_exit(0)
        return 0
    puts(cast[Ptr[uint8]]("[hamui-scroll-sign] FAIL\n"))
    sys_exit(1)
    return 1

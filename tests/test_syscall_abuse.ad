# tests/test_syscall_abuse.ad
#
# Syscall-boundary security audit: fuzz test.
#
# Fires syscalls with malformed user pointers and lengths and asserts
# the kernel REJECTS each with an error (returns -EFAULT or similar
# negative value) rather than faulting, panicking, or reading/writing
# kernel memory.
#
# Test cases:
#   T1. Kernel-space pointer (0xffffffff80001000) passed as read buffer.
#   T2. NULL pointer (0) passed as write buffer with non-zero length.
#   T3. Wild/unmapped pointer (0x0000dead00000000) passed as path.
#   T4. Length that overflows when added to a valid pointer.
#   T5. Integer-overflow: len = 0xffffffffffffffff with valid base.
#   T6. Length > ACCESS_OK_MAX_LEN (256 MiB + 1) with valid base.
#   T7. NULL pointer for pipe fds[2].
#   T8. Kernel pointer for getcwd buf.
#   T9. Kernel pointer for write buf.
#   T10. Kernel pointer for open path.
#
# PASS sentinel: "[syscall_abuse] PASS"
# (consumed by scripts/test_syscall_abuse.sh)
#
# On success every test case prints its own "[syscall_abuse] T<N> PASS"
# then the final "[syscall_abuse] PASS" is emitted and the program exits.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

# Syscall numbers (match arch/x86/kernel/syscall.ad).
SYS_READ:    uint64 = 6
SYS_WRITE:   uint64 = 8
SYS_OPEN:    uint64 = 5
SYS_PIPE:    uint64 = 14
SYS_GETCWD:  uint64 = 20

# Well-known kernel-space address (should be rejected by access_ok).
KPTR: uint64 = 0xffffffff80001000

# Wild / unmapped user-space address (canonical but unmapped).
WILD: uint64 = 0x0000dead00000000

# Access-ok max len (256 MiB) + 1.
HUGE_LEN: uint64 = 0x10000001

# Overflow length: when added to a valid pointer base (e.g. 0x1000),
# the sum wraps past USER_ADDR_MAX.
OVERFLOW_LEN: uint64 = 0xffffffffffffffff


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    n: uint64 = strlen(s)
    sys_write(fd, s, n)


def check_negative(rc: int64) -> int32:
    # Returns 1 if rc is a negative errno (indicates kernel REJECTED
    # the bad pointer), 0 if rc >= 0 (kernel accepted it — test fails).
    if rc < 0:
        return 1
    return 0


def main() -> int32:
    fail: int32 = 0

    # ---- T1: kernel-space pointer as read(fd=0) buffer ---------------
    # SYS_READ with buf pointing into kernel text.
    rc1: int64 = syscall6(SYS_READ, 0, KPTR, 64, 0, 0, 0)
    if check_negative(rc1) != 0:
        write_str(1, "[syscall_abuse] T1 PASS: kernel-ptr read rejected\n")
    else:
        write_str(1, "[syscall_abuse] T1 FAIL: kernel-ptr read was NOT rejected\n")
        fail = 1

    # ---- T2: NULL pointer as write buffer (len=32) -------------------
    rc2: int64 = syscall6(SYS_WRITE, 1, 0, 32, 0, 0, 0)
    if check_negative(rc2) != 0:
        write_str(1, "[syscall_abuse] T2 PASS: null-ptr write rejected\n")
    else:
        write_str(1, "[syscall_abuse] T2 FAIL: null-ptr write was NOT rejected\n")
        fail = 1

    # ---- T3: wild/unmapped pointer as open path ----------------------
    # WILD is a canonical user-space address but points to nothing.
    # access_ok_str checks only that it is below USER_ADDR_MAX and non-NULL,
    # so it passes the range check — the kernel then passes it to
    # resolve_path, which walks it. The string walk will read garbage or
    # fault the kernel without our guard.  HOWEVER: WILD is a valid
    # canonical address from access_ok_str's perspective, so the kernel
    # will attempt to walk it. The interesting property is that it either
    # returns an error from resolve_path (path too long / bad chars) or
    # from vfs_open (ENOENT), never crashes. We just assert rc < 0.
    rc3: int64 = syscall6(SYS_OPEN, WILD, 0, 0, 0, 0, 0)
    if check_negative(rc3) != 0:
        write_str(1, "[syscall_abuse] T3 PASS: wild-ptr open rejected\n")
    else:
        write_str(1, "[syscall_abuse] T3 FAIL: wild-ptr open returned >= 0\n")
        fail = 1

    # ---- T4: overflow length for read --------------------------------
    # base = 0x1000 (valid user addr), len = 0xffffffffffffffff.
    # uptr + len wraps, so access_ok should catch it.
    rc4: int64 = syscall6(SYS_READ, 0, 0x1000, OVERFLOW_LEN, 0, 0, 0)
    if check_negative(rc4) != 0:
        write_str(1, "[syscall_abuse] T4 PASS: overflow-len read rejected\n")
    else:
        write_str(1, "[syscall_abuse] T4 FAIL: overflow-len read was NOT rejected\n")
        fail = 1

    # ---- T5: absurd huge length for write ----------------------------
    # len > ACCESS_OK_MAX_LEN (0x10000000).
    rc5: int64 = syscall6(SYS_WRITE, 1, 0x1000, HUGE_LEN, 0, 0, 0)
    if check_negative(rc5) != 0:
        write_str(1, "[syscall_abuse] T5 PASS: huge-len write rejected\n")
    else:
        write_str(1, "[syscall_abuse] T5 FAIL: huge-len write was NOT rejected\n")
        fail = 1

    # ---- T6: NULL pointer for pipe fds[2] ----------------------------
    # SYS_PIPE with NULL fds pointer — should return -EFAULT.
    rc6: int64 = syscall6(SYS_PIPE, 0, 0, 0, 0, 0, 0)
    if check_negative(rc6) != 0:
        write_str(1, "[syscall_abuse] T6 PASS: null-fds pipe rejected\n")
    else:
        write_str(1, "[syscall_abuse] T6 FAIL: null-fds pipe was NOT rejected\n")
        fail = 1

    # ---- T7: kernel pointer for getcwd buf ---------------------------
    rc7: int64 = syscall6(SYS_GETCWD, KPTR, 64, 0, 0, 0, 0)
    if check_negative(rc7) != 0:
        write_str(1, "[syscall_abuse] T7 PASS: kernel-ptr getcwd rejected\n")
    else:
        write_str(1, "[syscall_abuse] T7 FAIL: kernel-ptr getcwd was NOT rejected\n")
        fail = 1

    # ---- T8: kernel pointer for write buf ----------------------------
    rc8: int64 = syscall6(SYS_WRITE, 1, KPTR, 8, 0, 0, 0)
    if check_negative(rc8) != 0:
        write_str(1, "[syscall_abuse] T8 PASS: kernel-ptr write rejected\n")
    else:
        write_str(1, "[syscall_abuse] T8 FAIL: kernel-ptr write was NOT rejected\n")
        fail = 1

    # ---- T9: kernel pointer for open path ----------------------------
    rc9: int64 = syscall6(SYS_OPEN, KPTR, 0, 0, 0, 0, 0)
    if check_negative(rc9) != 0:
        write_str(1, "[syscall_abuse] T9 PASS: kernel-ptr open path rejected\n")
    else:
        write_str(1, "[syscall_abuse] T9 FAIL: kernel-ptr open path was NOT rejected\n")
        fail = 1

    # ---- T10: end-wraps user-space range ----------------------------
    # uptr = USER_ADDR_MAX - 4 (just inside user space),
    # len = 16 -> end_addr overflows USER_ADDR_MAX.
    USER_ADDR_MAX: uint64 = 0x0000800000000000
    near_top: uint64 = USER_ADDR_MAX - 4
    rc10: int64 = syscall6(SYS_READ, 0, near_top, 16, 0, 0, 0)
    if check_negative(rc10) != 0:
        write_str(1, "[syscall_abuse] T10 PASS: near-top-overrun read rejected\n")
    else:
        write_str(1, "[syscall_abuse] T10 FAIL: near-top-overrun read was NOT rejected\n")
        fail = 1

    # ---- final verdict -----------------------------------------------
    if fail == 0:
        write_str(1, "[syscall_abuse] PASS\n")
    else:
        write_str(1, "[syscall_abuse] FAIL (see above)\n")

    return fail

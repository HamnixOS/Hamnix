# tests/test_compiler_augmented_assign.ad
#
# Regression fixture for the Adder x86_64 backend's compound /
# augmented-assignment lowering (`codegen_x86.py`: `gen_assignment` +
# `_COMPOUND_OP_MAP`).
#
# Coverage matrix:
#   * Identifier targets   (`x OP= rhs`)         — every op
#   * IndexExpr targets    (`arr[i] OP= rhs`)    — every op
#
# Every one of the ten compound operators that LANGUAGE.md §17 advertises
# is exercised at least once on each target kind:
#   +=  -=  *=  /=  %=     # arithmetic
#   &=  |=  ^=             # bitwise
#   <<=  >>=               # shifts
#
# LANGUAGE.md §17 promised this fixture (referenced by name in the doc),
# but the file was missing on disk until this commit. The parser also
# silently rejected `arr[i] >>= n`, `arr[i] |= m`, etc. on complex
# targets (only `+ - * / %` worked there). The parser carve-out is now
# removed; codegen already supported all ten ops uniformly via the
# read-modify-write pattern in `gen_assignment` — this fixture proves it.

# --- Identifier targets ----------------------------------------------

def aug_id_add(x: int64, y: int64) -> int64:
    x += y
    return x

def aug_id_sub(x: int64, y: int64) -> int64:
    x -= y
    return x

def aug_id_mul(x: int64, y: int64) -> int64:
    x *= y
    return x

def aug_id_div(x: int64, y: int64) -> int64:
    x /= y
    return x

def aug_id_mod(x: int64, y: int64) -> int64:
    x %= y
    return x

def aug_id_and(x: uint64, y: uint64) -> uint64:
    x &= y
    return x

def aug_id_or(x: uint64, y: uint64) -> uint64:
    x |= y
    return x

def aug_id_xor(x: uint64, y: uint64) -> uint64:
    x ^= y
    return x

def aug_id_shl(x: uint64, n: uint64) -> uint64:
    x <<= n
    return x

def aug_id_shr(x: uint64, n: uint64) -> uint64:
    x >>= n
    return x

# --- IndexExpr targets (arr[i] OP= rhs) -------------------------------
#
# Each helper takes a starting value, applies the compound op IN PLACE
# on an Array element, and returns the resulting element. Index used is
# non-zero so we'd catch a "always touches slot 0" miscompile.

_scratch_i: Array[4, int64]
_scratch_u: Array[4, uint64]

def aug_idx_add(start: int64, rhs: int64) -> int64:
    _scratch_i[2] = start
    _scratch_i[2] += rhs
    return _scratch_i[2]

def aug_idx_sub(start: int64, rhs: int64) -> int64:
    _scratch_i[2] = start
    _scratch_i[2] -= rhs
    return _scratch_i[2]

def aug_idx_mul(start: int64, rhs: int64) -> int64:
    _scratch_i[2] = start
    _scratch_i[2] *= rhs
    return _scratch_i[2]

def aug_idx_div(start: int64, rhs: int64) -> int64:
    _scratch_i[2] = start
    _scratch_i[2] /= rhs
    return _scratch_i[2]

def aug_idx_mod(start: int64, rhs: int64) -> int64:
    _scratch_i[2] = start
    _scratch_i[2] %= rhs
    return _scratch_i[2]

def aug_idx_and(start: uint64, rhs: uint64) -> uint64:
    _scratch_u[2] = start
    _scratch_u[2] &= rhs
    return _scratch_u[2]

def aug_idx_or(start: uint64, rhs: uint64) -> uint64:
    _scratch_u[2] = start
    _scratch_u[2] |= rhs
    return _scratch_u[2]

def aug_idx_xor(start: uint64, rhs: uint64) -> uint64:
    _scratch_u[2] = start
    _scratch_u[2] ^= rhs
    return _scratch_u[2]

def aug_idx_shl(start: uint64, n: uint64) -> uint64:
    _scratch_u[2] = start
    _scratch_u[2] <<= n
    return _scratch_u[2]

def aug_idx_shr(start: uint64, n: uint64) -> uint64:
    _scratch_u[2] = start
    _scratch_u[2] >>= n
    return _scratch_u[2]

# --- side-effect freshness proof --------------------------------------
#
# For complex targets the codegen claims to "evaluate the address ONCE"
# (single-evaluation). This helper proves the index expression isn't
# evaluated twice — a double-eval would tick the counter twice per call.

_idx_calls: int64 = 0

def _idx_called(i: int64) -> int64:
    _idx_calls = _idx_calls + 1
    return i

def aug_idx_single_eval(start: int64, rhs: int64) -> int64:
    _idx_calls = 0
    _scratch_i[2] = start
    _scratch_i[_idx_called(2)] += rhs
    return _idx_calls

def aug_idx_single_eval_value(start: int64, rhs: int64) -> int64:
    _idx_calls = 0
    _scratch_i[2] = start
    _scratch_i[_idx_called(2)] += rhs
    return _scratch_i[2]

# tests/test_font_bdf.ad
#
# #444-followup Phase 4d — BDF parser roundtrip test. Feeds a tiny
# hand-written BDF blob into lib.font_bdf.font_bdf_parse(), then
# asserts:
#
#   1. parse returns N decoded glyphs > 0.
#   2. the parsed bitmap rows for glyph 'A' (ENCODING 65) match the
#      hex rows that went in (3 rows of an 8x3 glyph).
#   3. font_bdf_expand() lights the correct pixels (MSB-first column 0
#      ON for row 0xFF, columns 0+7 ON for row 0x81).
#
# Success is printed on stdout as "test_font_bdf: OK"; failure as
# "test_font_bdf: FAIL <reason>" + sys_exit(1).
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_font_bdf.ad -o build/user/test_font_bdf.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)

from lib.font_bdf import font_bdf_parse, font_bdf_expand


# A tiny hand-rolled BDF with exactly one glyph (encoding 65 = 'A')
# whose BBX is 8x3 and whose 3 rows are 0xFF, 0x81, 0xFF — a horizontal
# bar / vertical bar / horizontal bar. Returned from a def() so the
# string lives as a call-site Ptr[uint8] (the Adder string-literal
# globals form is restricted to Array[N, uint8]; per feedback_compiler
# _quirks.md "U9 string literal globals" — keep as a def-return).
def _bdf_blob() -> Ptr[uint8]:
    return "STARTFONT 2.1\nFONT -test\nSIZE 3 75 75\nFONTBOUNDINGBOX 8 3 0 0\nFONT_ASCENT 3\nFONT_DESCENT 0\nCHARS 1\nSTARTCHAR LATIN_A\nENCODING 65\nDWIDTH 8 0\nBBX 8 3 0 0\nBITMAP\nFF\n81\nFF\nENDCHAR\nENDFONT\n"


# Per-glyph tables (95 slots — ASCII 0x20..0x7E).
gw: Array[95, uint8]
gh: Array[95, uint8]
gadv: Array[95, uint8]
goff: Array[95, uint32]
gbits: Array[4096, uint8]
ascent: Array[1, int64]
descent: Array[1, int64]
# Expansion buffer (max 8x3 = 24 pixels in this test).
expanded: Array[64, uint8]


def strlen_p(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def w_str(s: Ptr[uint8]):
    sys_write(1, s, strlen_p(s))


def fail(why: Ptr[uint8]):
    w_str("test_font_bdf: FAIL ")
    w_str(why)
    w_str("\n")
    sys_exit(1)


def main() -> int32:
    blob: Ptr[uint8] = _bdf_blob()
    buflen: uint64 = strlen_p(blob)
    n: int64 = font_bdf_parse(blob, buflen,
                              &gw[0], &gh[0], &goff[0], &gbits[0],
                              4096, &gadv[0], &ascent[0], &descent[0])
    if n <= 0:
        fail("parse returned <= 0")

    # 'A' = 65 → table index 65 - 32 = 33.
    if gw[33] != 8:
        fail("gw[A] != 8")
    # DWIDTH 8 → proportional advance is captured.
    if gadv[33] != 8:
        fail("gadv[A] != 8")
    if gh[33] != 3:
        fail("gh[A] != 3")

    off: uint32 = goff[33]
    # row 0 should be 0xFF, row 1 0x81, row 2 0xFF.
    if gbits[off] != 255:
        fail("row 0 mismatch")
    if gbits[off + 1] != 129:
        fail("row 1 mismatch")
    if gbits[off + 2] != 255:
        fail("row 2 mismatch")

    if ascent[0] != 3:
        fail("ascent")
    if descent[0] != 0:
        fail("descent")

    # Expand and assert pixel positions.
    font_bdf_expand(&gbits[0], off, 8, 3, &expanded[0])
    # row 0 = 0xFF → all 8 columns ON
    c: uint64 = 0
    while c < 8:
        if expanded[c] != 1:
            fail("row 0 expand")
        c = c + 1
    # row 1 = 0x81 → only col 0 and col 7 ON
    if expanded[8 + 0] != 1:
        fail("row 1 col 0")
    if expanded[8 + 7] != 1:
        fail("row 1 col 7")
    cc: uint64 = 1
    while cc < 7:
        if expanded[8 + cc] != 0:
            fail("row 1 mid col on")
        cc = cc + 1

    w_str("test_font_bdf: OK\n")
    return 0

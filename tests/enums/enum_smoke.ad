# Smoke test for tagged sum types + Option/Result + `?`.

enum Shape:
    Empty
    Circle(int32)
    Rect(int16, int16)

def shape_score(s: Shape) -> int64:
    match s:
        case Empty:
            return 0
        case Circle(r):
            return cast[int64](r) * 10
        case Rect(w, h):
            return cast[int64](w) + cast[int64](h)

def checked_div(a: int32, b: int32) -> Result:
    if b == 0:
        return Err(1)
    return Ok(a / b)

# `?` propagation: on Err, early-return the Err; on Ok, unwrap.
def div_then_add(a: int32, b: int32, c: int32) -> Result:
    q: int32 = checked_div(a, b)?
    return Ok(q + c)

def find_positive(x: int32) -> Option:
    if x > 0:
        return Some(x)
    return None

def opt_or_zero(x: int32) -> int64:
    o: Option = find_positive(x)
    match o:
        case Some(v):
            return cast[int64](v)
        case None:
            return -1

def result_tag(r: Result) -> int64:
    match r:
        case Ok(v):
            return cast[int64](v)
        case Err(e):
            return cast[int64](0) - cast[int64](e)

def main() -> int32:
    total: int64 = 0
    # Shape: Circle(4)->40, Rect(3,5)->8, Empty->0
    total = total + shape_score(Circle(4))       # 40
    total = total + shape_score(Rect(3, 5))      # 8  -> 48
    total = total + shape_score(Empty)           # 0  -> 48
    # negative payload round-trip (signed int16): Rect(-2, 5) -> 3
    total = total + shape_score(Rect(-2, 5))     # 3  -> 51
    # Result / ?: div_then_add(20,4,1) = Ok(5)+1 = Ok(6) -> tag 6
    total = total + result_tag(div_then_add(20, 4, 1))   # 6 -> 57
    # div_then_add(20,0,1) short-circuits to Err(1) -> -1
    total = total + result_tag(div_then_add(20, 0, 1))   # -1 -> 56
    # Option: opt_or_zero(9)=9 ; opt_or_zero(-3)=-1
    total = total + opt_or_zero(9)               # 9 -> 65
    total = total + opt_or_zero(0 - 3)           # -1 -> 64
    return cast[int32](total)                    # expect 64

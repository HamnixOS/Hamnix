# Enums are usable in kernel (x86_64-bare-metal) code at ZERO runtime cost:
# a tag word + a masked payload slot, dispatched with a compare + branch.
# No runtime, no allocation, no ud2 — proves kernel-capability.
enum IrqState:
    Masked
    Active(int32)
    Pending(int16, int16)

def irq_level(s: IrqState) -> int64:
    match s:
        case Masked:
            return 0
        case Active(lvl):
            return cast[int64](lvl)
        case Pending(a, b):
            return cast[int64](a) + cast[int64](b)
        case _:
            return -1

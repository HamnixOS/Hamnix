# tests/test_chain_validate_v15.ad
#
# V6 regression: RSA-PKCS#1-v1.5-SHA256 chain validation.
#
# Builds on V4's chain.ad shape but with a 2-cert chain whose leaf is
# signed with PKCS#1 v1.5 (NOT PSS) by an RSA-2048 self-signed root.
# This is the OID Let's Encrypt's ISRG Root X1 uses, so without V6
# `apt over HTTPS` against real LE mirrors is blocked. After V6 it isn't.
#
# Both certs generated via:
#   openssl req -x509 -newkey rsa:2048 -keyout /tmp/v15_root.key \
#       -out /tmp/v15_root.crt -days 3650 -nodes -sha256 \
#       -subj '/CN=Hamnix Test CA v1.5' \
#       -addext 'basicConstraints=critical,CA:TRUE'
#   openssl genrsa -out /tmp/v15_leaf.key 2048
#   openssl req -new -key /tmp/v15_leaf.key -out /tmp/v15_leaf.csr \
#       -subj '/CN=test.hamnix.local'
#   openssl x509 -req -in /tmp/v15_leaf.csr -CA /tmp/v15_root.crt \
#       -CAkey /tmp/v15_root.key -CAcreateserial -out /tmp/v15_leaf.crt \
#       -days 3650 -sha256 \
#       -extfile <(printf 'basicConstraints=CA:FALSE\nsubjectAltName=DNS:test.hamnix.local\n')
#
# Note the absence of `-sigopt rsa_padding_mode:pss` — that's what makes
# this PKCS#1 v1.5.
#
# Asserts (all pass = `[chain_v15] PASS`):
#   (1) legitimate chain → validate_cert_chain returns 1
#   (a) flip one byte of the leaf signature → returns 0
#   (b) ISRG-style root castore_add_root must not regress (the V5 honest
#       gap was the walker rejecting v1.5; we just add a v1.5 root here)
#
# Driven by scripts/test_chain_validate_v15.sh.

from lib.asn1.asn1 import (
    asn1_init_oids,
)
from lib.x509.x509 import (
    X509Cert,
    x509_parse,
)
from lib.ec.p256 import (
    p256_init,
)
from lib.rsa.rsa import (
    rsa_init,
)
from lib.ecdsa.ecdsa import (
    ecdsa_init,
)
from lib.x509.chain import (
    castore_init,
    castore_add_root,
    castore_count,
    validate_cert_chain,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer (same shape as test_chain_validate.ad) -------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


def _wdec_signed(value: int64):
    if value < 0:
        sys_write(1, "-", 1)
        _wdec(cast[uint64](-value))
        return
    _wdec(cast[uint64](value))


fail_count: int32 = 0


def _check_eq_i32(a: int32, b: int32, label: Ptr[uint8]):
    if a != b:
        _wstr("[chain_v15] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec_signed(cast[int64](a))
        _wstr(" want=")
        _wdec_signed(cast[int64](b))
        _wstr("\n")
        fail_count = fail_count + 1


# -- chain pointer table ---------------------------------------------------

chain_ptrs: Array[8, Ptr[uint8]]
chain_lens: Array[8, uint64]



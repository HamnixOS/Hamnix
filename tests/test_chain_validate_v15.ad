# A target unix time inside the certs' validity window. Both certs run
# May 19 2026 .. May 16 2036 (verified via openssl x509 -dates).
NOW_GOOD: uint64 = 1780272000   # Jun 1 2026 00:00:00 UTC


def main() -> int32:
    _wstr("[chain_v15] start\n")

    asn1_init_oids()
    p256_init()
    rsa_init()
    ecdsa_init()
    castore_init()
    _init_v15_root()
    _init_v15_leaf()

    # Plant chain: chain[0] = leaf. Root comes from CA store.
    chain_ptrs[0] = &v15_leaf_der[0]
    chain_lens[0] = v15_leaf_der_len

    # 1. Add v1.5 root to the CA store.
    slot: int32 = castore_add_root(&v15_root_der[0], v15_root_der_len)
    _check_eq_i32(slot, 0, "v1.5 root castore_add_root returns slot 0")
    _check_eq_i32(castore_count(), 1, "castore_count == 1 after add")

    # 2. Legitimate v1.5 chain validation: expect 1.
    _wstr("[chain_v15] case 1: legitimate v1.5 chain (rsa modexp ~few seconds)\n")
    rc: int32 = validate_cert_chain(&chain_ptrs[0], &chain_lens[0],
                                    cast[int32](1),
                                    "test.hamnix.local", NOW_GOOD)
    _check_eq_i32(rc, 1, "legitimate v1.5 chain returns 1")

    # 3. Tamper: flip one byte well inside the leaf signature value.
    # For RSA-2048 v1.5 signed cert with len=823 the sig body starts at
    # offset 566 and runs for 256 bytes; offset 694 is comfortably mid-sig.
    TAMPER_OFF: uint64 = 694
    saved_a: uint8 = v15_leaf_der[TAMPER_OFF]
    v15_leaf_der[TAMPER_OFF] = saved_a ^ 0x01
    _wstr("[chain_v15] case (a): leaf v1.5 sig bit-flipped\n")
    rc = validate_cert_chain(&chain_ptrs[0], &chain_lens[0],
                             cast[int32](1),
                             "test.hamnix.local", NOW_GOOD)
    _check_eq_i32(rc, 0, "(a) flipped v1.5 leaf sig returns 0")
    v15_leaf_der[TAMPER_OFF] = saved_a

    _wstr("[chain_v15] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[chain_v15] PASS\n")
        return 0
    _wstr("[chain_v15] FAIL\n")
    return 1


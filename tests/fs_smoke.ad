# §file-mmap: file-backed mmap self-test (ENABLE_MMAP_FILE_TEST=1).
# vma_alloc_file_demand builds a file-backed demand VMA; vma_demand_fault
# is the populator the #PF handler calls (driven directly here since a
# synchronous kernel self-test can't take a real #PF on its own access).
from mm.vma import vma_alloc_file_demand, vma_demand_fault
# §shared-mmap: MAP_SHARED writable file-backed mmap self-test
# (ENABLE_MMAP_SHARED_TEST=1). vma_alloc_file_shared builds the writable
# file-shared VMA; vma_writeback_range flushes its dirty pages to the
# backing file (the msync(MS_SYNC) path).
from mm.vma import vma_alloc_file_shared, vma_writeback_range
# tmpfs is the WRITABLE backend the shared-mmap self-test writes its
# known-content file to (initramfs/cpio is read-only and cannot be
# written back). tmpfs_open_for_write creates/truncates a file and
# returns its stable slot; tmpfs_write/tmpfs_read drive content;
# tmpfs_size reports its length.
from fs.tmpfs import (
    tmpfs_open_for_write, tmpfs_write, tmpfs_read, tmpfs_size,
)
from kernel.sched.core import FD_TMPFS_MARK
from kernel.sched.core import current_idx_get
from fs.vfs import (
    vfs_init, vfs_open, vfs_read, vfs_write, vfs_close,
    # §file-mmap: snapshot an open fd's stable backing identity for the
    # file-backed mmap self-test, plus the synthetic initramfs backing
    # marker so the self-test can build the same snapshot directly from a
    # cpio index (the kernel boot task has no user fd table to open
    # through).
    vfs_fd_backing_info, FD_FILEMMAP_INITRAMFS,
    initramfs_data_ptr, initramfs_data_size,
    # Namespace-aware blob resolution: reads a path off whatever
    # backend the calling namespace routes it to (cpio entry OR a
    # kmalloc'd copy of an ext4 partition file reached via a
    # `#sysroot` named-root bind). This is how the kernel ELF-loads
    # /init off the ext4 root with NO cpio in the final state.
    ns_blob_ptr, ns_blob_size,
    # §links: tmpfs symlink + hard-link self-test (gated boot:37.tln).
    tmpfs_link_selftest,
    # §cgroup2: /sys/fs/cgroup v2 e2e self-test (gated boot:37.cg2).
    cgroup2_vfs_selftest,
    # §mempolicy: /sys/devices/system/node NUMA sysfs e2e VFS self-test
    # (gated boot:37.mempolicy).
    node_sysfs_vfs_selftest,
)
# V1: in-kernel 9P client smoke test. Spawns two kernel-side pipe
# slots, drives a synthetic responder that serves a one-file FS,
# round-trips mount + open + read. Surfaces `[p9smoke] PASS` on the
# serial log so scripts/test_9p_mount.sh can grep for the marker.
from init.p9_smoke import p9_smoke_test
# V2.75: per-process group (Pgrp) heap allocator. pgrp_init kzallocs
# the root Pgrp and pins its refcount at a saturation sentinel so
# do_exit chains never free it. Default-shared descendants inherit
# the root Pgrp pointer; without this call the BSS-zero state leaves
# pgrp_root_addr == 0 and the lazy _ensure_root in chan.ad fixes it
# on first touch, but an explicit early init keeps the contract
# obvious. Replaces V2.5's fixed Array[64, Pgrp] pool.
# `chan_init` is kept as a backwards-compatible alias for pgrp_init.
from sys.src.port9.port.chan import (
    chan_init,
    # F10-10 (#457): per-Pgrp oom_score_adj field + clamp + clone-
    # independence self-test, dispatched from the marker-gated boot
    # stage below.
    pgrp_oomadj_selftest,
    # Phase 5 — FS discovery populates the named file-server stack
    # and the by-id alias table from sentinel files / synthesised
    # partuuids. docs/rootfs_partition.md "Future direction".
    name_push, byid_register,
    # M16.img: install the boot-time `bind '#sysroot' /` into the root
    # Pgrp from the kernel, so the very first exec (/init, then
    # /bin/hamsh + /etc/rc.boot) resolves off the ext4 sysroot subtree
    # with NO cpio. mnttab_bind operates on the calling task's Pgrp;
    # at this point in start_kernel the boot task's pgrp is 0, which
    # _ensure_root resolves to the (just-chan_init'd) root Pgrp.
    mnttab_bind,
)
from fs.elf import (
    elf_load_blob, elf_last_img_lo_get, elf_last_img_hi_get,
    # M16.36: install per-task PT entries for /init's PT_LOAD spans
    # so the boot init task no longer depends on the BSP's inherited
    # 1 GiB identity stamp. Same call-shape SYS_SPAWN / SYS_EXECVE
    # use in arch/x86/kernel/syscall.ad.
    elf_apply_last_user_mapping,
    # PID-1 rfork-COW fatal #PF regression (scripts/test_rfork_pid1_cow.sh):
    # asserts a native ELF32 load resets the W^X RO-span globals so a
    # prior ELF64's stale spans can't be flipped RO into the ELF32 image.
    elf32_wx_span_reset_selftest,
)

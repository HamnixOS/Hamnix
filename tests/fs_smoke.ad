# --- loop device end-to-end self-test (boot:37.loop) ----------------
#
# Proves the file-backed block device (drivers/block/loop.ad) mounts a
# filesystem IMAGE FILE end-to-end:
#   1. Attach the cpio-baked FAT image /tests/loop/disk.img as a loop
#      device via loop_attach() (the same path /dev/loop/ctl's "attach"
#      verb takes). This registers /dev/blk/loop0.
#   2. Mount FAT off the loop slot (fat_init(find_blockdev("loop0"))) —
#      every blk_read_sectors now lands on a pread of the backing file.
#   3. Look up a KNOWN file (HELLO.TXT) and read its bytes back through
#      the loop data path; assert they begin with "FAT32_MARKER".
# Every read in steps 2-3 flows file -> loop_read_sectors ->
# vfs_pread_backing, so a PASS proves the loop data path is real.
loop_test_buf: Array[64, uint8]


def loop_e2e_selftest() -> int32:
    pr_emerg("[loop] self-test start\n")
    rc: int32 = loop_attach("/tests/loop/disk.img")
    if rc < 0:
        pr_emerg("[loop] FAIL: attach returned negative\n")
        return 0
    slot: int32 = find_blockdev("loop0")
    if slot < 0:
        pr_emerg("[loop] FAIL: loop0 not registered\n")
        return 0
    pr_emerg("[loop] /dev/blk/loop0 attached\n")
    if fat_init(slot) != 0:
        pr_emerg("[loop] FAIL: fat_init on loop0\n")
        return 0
    pr_emerg("[loop] FAT mounted off loop0\n")
    first_cluster: uint64 = 0
    fsize:         uint64 = 0
    if fat_lookup("HELLO.TXT", &first_cluster, &fsize) == 0:
        pr_emerg("[loop] FAIL: HELLO.TXT lookup\n")
        return 0
    n: int64 = fat_read(first_cluster, fsize, 0, 12, &loop_test_buf[0])
    if n < 12:
        pr_emerg("[loop] FAIL: short read of HELLO.TXT\n")
        return 0
    # Expect the body to begin with "FAT32_MARKER".
    expect: Ptr[uint8] = "FAT32_MARKER"
    i: uint64 = 0
    while i < 12:
        if loop_test_buf[i] != expect[i]:
            pr_emerg("[loop] FAIL: HELLO.TXT content mismatch\n")
            return 0
        i = i + 1
    pr_emerg("[loop] HELLO.TXT content verified through loop device\n")
    pr_emerg("[loop] PASS\n")
    return 1


# --- ISO9660 (Rock Ridge) end-to-end self-test (boot:37.iso) ---------
#
# Proves the read-only ISO9660 reader (fs/iso9660.ad) mounts a real
# Rock Ridge .iso end-to-end off a loop-attached image file:
#   1. Attach the cpio-baked Rock Ridge image /tests/iso9660/test.iso
#      via loop_attach, then resolve its /dev/blk/loopN name to the
#      block-layer slot (same shape as loop_e2e_selftest).
#   2. iso9660_mount() parses the Primary Volume Descriptor at logical
#      sector 16 and records the root directory extent.
#   3. List the root directory (readdir): assert a known entry count
#      and that the Rock Ridge long name resolves.
#   4. Read /HELLO.TXT and assert its bytes are exactly "ISO9660_MARKER".
#   5. Resolve and read the Rock Ridge long name file (lowercase name
#      only expressible via an NM entry).
#   6. Read /BIG.DAT (4096 bytes, two logical sectors) and assert the
#      deterministic pattern is byte-exact across the sector boundary.
#   7. Resolve a nested file /sub/NESTED.TXT.
# Emits [iso9660] PASS on success.
iso_test_buf:     Array[4096, uint8]
iso_test_seen:    uint64 = 0
iso_test_rr_hit:  int32  = 0


def _iso_test_dir_cb(ctx: uint64, name_ptr: uint64, name_len: uint64,
                     child_lba: uint64, child_size: uint64,
                     is_dir: int32, rr_mode: uint32) -> int32:
    iso_test_seen = iso_test_seen + 1
    # Detect the Rock Ridge long name "a_long_rock_ridge_name.txt".
    nm: Ptr[uint8] = cast[Ptr[uint8]](name_ptr)
    want: Ptr[uint8] = "a_long_rock_ridge_name.txt"
    if name_len == 26:
        i: uint64 = 0
        eq: int32 = 1
        while i < 26:
            if nm[i] != want[i]:
                eq = 0
                i = 26
            else:
                i = i + 1
        if eq == 1:
            iso_test_rr_hit = 1
    return 0


def iso9660_e2e_selftest() -> int32:
    pr_emerg("[iso9660] self-test start\n")
    loop_idx: int32 = loop_attach("/tests/iso9660/test.iso")
    if loop_idx < 0:
        pr_emerg("[iso9660] FAIL: loop attach returned negative\n")
        return 0
    # loop_attach returns the LOOP-device index; the registered block
    # device name is /dev/blk/loop<idx>. Resolve it to the block-layer
    # slot blk_read_sectors expects (same shape as loop_e2e_selftest).
    iso_loop_name: Array[16, uint8]
    iso_loop_name[0]  = 0x6C    # 'l'
    iso_loop_name[1]  = 0x6F    # 'o'
    iso_loop_name[2]  = 0x6F    # 'o'
    iso_loop_name[3]  = 0x70    # 'p'
    iso_loop_name[4]  = cast[uint8](0x30 + cast[uint64](cast[int64](loop_idx)))
    iso_loop_name[5]  = 0
    slot: int32 = find_blockdev(cast[Ptr[char]](&iso_loop_name[0]))
    if slot < 0:
        pr_emerg("[iso9660] FAIL: loop block device not registered\n")
        return 0
    pr_emerg("[iso9660] loop device attached for .iso\n")
    if iso9660_mount(slot) != 0:
        pr_emerg("[iso9660] FAIL: mount\n")
        return 0
    pr_emerg("[iso9660] mounted\n")

    # (3) List the root directory; capture the Rock Ridge long name.
    # Resolve "/" to the root extent, then enumerate it.
    r_lba:  uint64 = 0
    r_size: uint64 = 0
    r_dir:  int32  = 0
    if iso9660_lookup("/", &r_lba, &r_size, &r_dir) != 0:
        pr_emerg("[iso9660] FAIL: lookup /\n")
        return 0
    iso_test_seen   = 0
    iso_test_rr_hit = 0
    if iso9660_readdir(r_lba, r_size, _iso_test_dir_cb, 0) < 0:
        pr_emerg("[iso9660] FAIL: readdir root\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[iso9660] root entries=%d rr_long_name_hit=%d\n",
            iso_test_seen, cast[uint64](cast[int64](iso_test_rr_hit)))
    if iso_test_rr_hit != 1:
        pr_emerg("[iso9660] FAIL: Rock Ridge long name not seen in readdir\n")
        return 0

    # (4) Read /HELLO.TXT and assert exact bytes.
    h_lba:  uint64 = 0
    h_size: uint64 = 0
    h_dir:  int32  = 0
    if iso9660_lookup("/HELLO.TXT", &h_lba, &h_size, &h_dir) != 0:
        pr_emerg("[iso9660] FAIL: lookup /HELLO.TXT\n")
        return 0
    n: int64 = iso9660_read(h_lba, h_size, 0, &iso_test_buf[0], 4096)
    if n != 14:
        pr_emerg("[iso9660] FAIL: /HELLO.TXT short read\n")
        return 0
    expect: Ptr[uint8] = "ISO9660_MARKER"
    i: uint64 = 0
    while i < 14:
        if iso_test_buf[i] != expect[i]:
            pr_emerg("[iso9660] FAIL: /HELLO.TXT content mismatch\n")
            return 0
        i = i + 1
    pr_emerg("[iso9660] /HELLO.TXT content verified\n")

    # (5) Resolve + read the Rock Ridge long name file.
    l_lba:  uint64 = 0
    l_size: uint64 = 0
    l_dir:  int32  = 0
    if iso9660_lookup("/a_long_rock_ridge_name.txt",
                      &l_lba, &l_size, &l_dir) != 0:
        pr_emerg("[iso9660] FAIL: lookup Rock Ridge long name\n")
        return 0
    ln: int64 = iso9660_read(l_lba, l_size, 0, &iso_test_buf[0], 4096)
    if ln < 1:
        pr_emerg("[iso9660] FAIL: read Rock Ridge long name file\n")
        return 0
    pr_emerg("[iso9660] Rock Ridge long name resolved + read\n")

    # (6) Read /BIG.DAT (4096 bytes, spans two logical sectors).
    b_lba:  uint64 = 0
    b_size: uint64 = 0
    b_dir:  int32  = 0
    if iso9660_lookup("/BIG.DAT", &b_lba, &b_size, &b_dir) != 0:
        pr_emerg("[iso9660] FAIL: lookup /BIG.DAT\n")
        return 0
    if b_size != 4096:
        pr_emerg("[iso9660] FAIL: /BIG.DAT wrong size\n")
        return 0
    bn: int64 = iso9660_read(b_lba, b_size, 0, &iso_test_buf[0], 4096)
    if bn != 4096:
        pr_emerg("[iso9660] FAIL: /BIG.DAT short read\n")
        return 0
    # Assert the deterministic pattern (i*31+7 & 0xFF) across the
    # 2048-byte logical-sector boundary.
    k: uint64 = 0
    while k < 4096:
        exp: uint8 = cast[uint8]((k * 31 + 7) & 0xFF)
        if iso_test_buf[k] != exp:
            pr_emerg("[iso9660] FAIL: /BIG.DAT pattern mismatch\n")
            return 0
        k = k + 1
    pr_emerg("[iso9660] /BIG.DAT (2 logical sectors) verified byte-exact\n")

    # (7) Resolve a nested file.
    s_lba:  uint64 = 0
    s_size: uint64 = 0
    s_dir:  int32  = 0
    if iso9660_lookup("/sub/NESTED.TXT", &s_lba, &s_size, &s_dir) != 0:
        pr_emerg("[iso9660] FAIL: lookup /sub/NESTED.TXT\n")
        return 0
    sn: int64 = iso9660_read(s_lba, s_size, 0, &iso_test_buf[0], 4096)
    if sn < 1:
        pr_emerg("[iso9660] FAIL: read /sub/NESTED.TXT\n")
        return 0
    pr_emerg("[iso9660] /sub/NESTED.TXT resolved + read\n")

    pr_emerg("[iso9660] PASS\n")
    return 1


# --- NTFS (read-only) end-to-end self-test (boot:37.ntfs) ------------
#
# Proves the read-only NTFS reader (fs/ntfs.ad) mounts a real mkntfs-
# formatted image end-to-end off a loop-attached image file:
#   1. Attach the cpio-baked NTFS image /tests/ntfs/test.img via
#      loop_attach, then resolve its /dev/blk/loopN name to the block
#      slot (same shape as iso9660_e2e_selftest).
#   2. ntfs_mount() parses the boot sector/BPB (bytes-per-sector,
#      sectors-per-cluster, MFT LCN, the SIGNED clusters-per-MFT-record
#      encoding) and decodes the $MFT's own $DATA runlist.
#   3. Enumerate the root directory (MFT ref 5): walk $INDEX_ROOT and the
#      non-resident $INDEX_ALLOCATION INDX block (USN fixup) and confirm
#      our files are seen.
#   4. Look up + read /HELLO.TXT (RESIDENT $DATA) and assert exactly
#      "NTFS_MARKER".
#   5. Look up + read /BIG.DAT (NON-RESIDENT $DATA, multi-cluster runlist,
#      20000 bytes) and assert the deterministic pattern byte-exact.
#   6. If the fixture builder could create it, resolve + read the nested
#      file /sub/NESTED.TXT (sub-directory's own index).
# Emits [ntfs] PASS on success.
ntfs_test_buf:    Array[32768, uint8]
ntfs_test_seen:   uint64 = 0
ntfs_test_hello:  int32  = 0
ntfs_test_big:    int32  = 0


def _ntfs_test_dir_cb(ctx: uint64, name_ptr: uint64, name_len: uint64,
                      mft_ref: uint64, is_dir: int32) -> int32:
    ntfs_test_seen = ntfs_test_seen + 1
    nm: Ptr[uint8] = cast[Ptr[uint8]](name_ptr)
    # Detect HELLO.TXT (9 chars) and BIG.DAT (7 chars).
    h: Ptr[uint8] = "HELLO.TXT"
    if name_len == 9:
        i: uint64 = 0
        eq: int32 = 1
        while i < 9:
            if nm[i] != h[i]:
                eq = 0
                i = 9
            else:
                i = i + 1
        if eq == 1:
            ntfs_test_hello = 1
    b: Ptr[uint8] = "BIG.DAT"
    if name_len == 7:
        j: uint64 = 0
        eb: int32 = 1
        while j < 7:
            if nm[j] != b[j]:
                eb = 0
                j = 7
            else:
                j = j + 1
        if eb == 1:
            ntfs_test_big = 1
    return 0


def ntfs_e2e_selftest() -> int32:
    pr_emerg("[ntfs] self-test start\n")
    loop_idx: int32 = loop_attach("/tests/ntfs/test.img")
    if loop_idx < 0:
        pr_emerg("[ntfs] FAIL: loop attach returned negative\n")
        return 0
    ntfs_loop_name: Array[16, uint8]
    ntfs_loop_name[0] = 0x6C    # 'l'
    ntfs_loop_name[1] = 0x6F    # 'o'
    ntfs_loop_name[2] = 0x6F    # 'o'
    ntfs_loop_name[3] = 0x70    # 'p'
    ntfs_loop_name[4] = cast[uint8](0x30 + cast[uint64](cast[int64](loop_idx)))
    ntfs_loop_name[5] = 0
    slot: int32 = find_blockdev(cast[Ptr[char]](&ntfs_loop_name[0]))
    if slot < 0:
        pr_emerg("[ntfs] FAIL: loop block device not registered\n")
        return 0
    pr_emerg("[ntfs] loop device attached for .img\n")
    if ntfs_mount(slot) != 0:
        pr_emerg("[ntfs] FAIL: mount\n")
        return 0
    pr_emerg("[ntfs] mounted\n")

    # (3) Enumerate the root directory.
    r_ref:  uint64 = 0
    r_size: uint64 = 0
    r_dir:  int32  = 0
    if ntfs_lookup("/", &r_ref, &r_size, &r_dir) != 0:
        pr_emerg("[ntfs] FAIL: lookup /\n")
        return 0
    ntfs_test_seen  = 0
    ntfs_test_hello = 0
    ntfs_test_big   = 0
    if ntfs_readdir(r_ref, _ntfs_test_dir_cb, 0) < 0:
        pr_emerg("[ntfs] FAIL: readdir root\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[ntfs] root entries=%d hello_seen=%d\n",
            ntfs_test_seen, cast[uint64](cast[int64](ntfs_test_hello)))
    if ntfs_test_hello != 1:
        pr_emerg("[ntfs] FAIL: HELLO.TXT not seen in readdir\n")
        return 0
    if ntfs_test_big != 1:
        pr_emerg("[ntfs] FAIL: BIG.DAT not seen in readdir\n")
        return 0
    pr_emerg("[ntfs] root directory enumerated\n")

    # (4) Read /HELLO.TXT (resident $DATA) and assert exact bytes.
    h_ref:  uint64 = 0
    h_size: uint64 = 0
    h_dir:  int32  = 0
    if ntfs_lookup("/HELLO.TXT", &h_ref, &h_size, &h_dir) != 0:
        pr_emerg("[ntfs] FAIL: lookup /HELLO.TXT\n")
        return 0
    hn: int64 = ntfs_read(h_ref, 0, &ntfs_test_buf[0], 32768)
    if hn != 11:
        pr_emerg("[ntfs] FAIL: /HELLO.TXT short read\n")
        return 0
    hexp: Ptr[uint8] = "NTFS_MARKER"
    hi: uint64 = 0
    while hi < 11:
        if ntfs_test_buf[hi] != hexp[hi]:
            pr_emerg("[ntfs] FAIL: /HELLO.TXT content mismatch\n")
            return 0
        hi = hi + 1
    pr_emerg("[ntfs] /HELLO.TXT (resident) content verified\n")

    # (5) Read /BIG.DAT (non-resident multi-cluster $DATA) byte-exact.
    b_ref:  uint64 = 0
    b_size: uint64 = 0
    b_dir:  int32  = 0
    if ntfs_lookup("/BIG.DAT", &b_ref, &b_size, &b_dir) != 0:
        pr_emerg("[ntfs] FAIL: lookup /BIG.DAT\n")
        return 0
    if b_size != 20000:
        pr_emerg("[ntfs] FAIL: /BIG.DAT wrong size\n")
        return 0
    bn: int64 = ntfs_read(b_ref, 0, &ntfs_test_buf[0], 32768)
    if bn != 20000:
        pr_emerg("[ntfs] FAIL: /BIG.DAT short read\n")
        return 0
    k: uint64 = 0
    while k < 20000:
        exp: uint8 = cast[uint8]((k * 31 + 7) & 0xFF)
        if ntfs_test_buf[k] != exp:
            pr_emerg("[ntfs] FAIL: /BIG.DAT pattern mismatch\n")
            return 0
        k = k + 1
    pr_emerg("[ntfs] /BIG.DAT (non-resident multi-cluster) verified byte-exact\n")

    # (6) Resolve a nested file (best-effort: the fixture builder only
    # plants /sub/NESTED.TXT when a FUSE mount was available). A miss
    # here is non-fatal — the resident + non-resident + index legs above
    # are the core proofs.
    s_ref:  uint64 = 0
    s_size: uint64 = 0
    s_dir:  int32  = 0
    if ntfs_lookup("/sub/NESTED.TXT", &s_ref, &s_size, &s_dir) == 0:
        sn: int64 = ntfs_read(s_ref, 0, &ntfs_test_buf[0], 32768)
        if sn >= 1:
            pr_emerg("[ntfs] /sub/NESTED.TXT resolved + read\n")
        else:
            pr_emerg("[ntfs] /sub/NESTED.TXT lookup ok, read empty (skipped)\n")
    else:
        pr_emerg("[ntfs] /sub/NESTED.TXT absent (no FUSE at fixture build; skipped)\n")

    pr_emerg("[ntfs] PASS\n")
    return 1


# --- virtio-9p (9P-over-virtio-PCI) end-to-end self-test (boot:37.v9p) -
#
# Proves the virtio-9p client (drivers/virtio/virtio_9p.ad) brings up a
# real virtio-9p-pci device, sets up its request virtqueue, and drives
# the full 9P2000.u handshake (Tversion/Tattach/Twalk/Topen/Tread/Tclunk)
# against a QEMU host-shared directory. The host export (planted by
# scripts/test_virtio9p.sh) contains a known file hello.txt with content
# "v9p_marker\n" (11 bytes). The self-test:
#   (1) confirms the device attached (virtio_9p_init ran),
#   (2) enumerates the export root (Twalk-clone + Topen + Tread of the
#       packed Stat stream) and asserts >=1 entry,
#   (3) walks to hello.txt, opens it read-only, reads it, and byte-
#       compares the 11 marker bytes exactly.
# Emits [v9p] PASS on success. Requires a QEMU `-device virtio-9p-pci`;
# default boots omit the device + marker so this never fires.
v9p_test_buf: Array[4096, uint8]


def v9p_e2e_selftest() -> int32:
    printk_set_level(PRINTK_LEVEL_EMERG)
    pr_emerg("[v9p] self-test start\n")

    # (1) Bring up the device + 9P attach.
    if virtio_9p_init() < 0:
        pr_emerg("[v9p] FAIL: virtio-9p device init/attach failed\n")
        return 0
    if virtio_9p_present() != 1:
        pr_emerg("[v9p] FAIL: device not present after init\n")
        return 0
    pr_emerg("[v9p] device attached + 9P session up\n")

    # (2) Enumerate the export root directory.
    nents: int32 = virtio_9p_list_root()
    if nents < 1:
        pr_emerg("[v9p] FAIL: root enumeration returned no entries\n")
        return 0
    printk1("[v9p] root entries=%d\n", cast[uint64](cast[int64](nents)))

    # (3) Walk to hello.txt, open, read, byte-compare.
    fname:  Ptr[uint8] = "hello.txt"
    is_dir: int32 = 0
    n: int64 = virtio_9p_read_file(fname, 9, &v9p_test_buf[0], 4096,
                                   &is_dir)
    if n != 11:
        pr_emerg("[v9p] FAIL: hello.txt short read (expected 11 bytes)\n")
        return 0
    if is_dir != 0:
        pr_emerg("[v9p] FAIL: hello.txt reported as a directory\n")
        return 0
    expect: Ptr[uint8] = "v9p_marker\n"
    vi: uint64 = 0
    while vi < 11:
        if v9p_test_buf[vi] != expect[vi]:
            pr_emerg("[v9p] FAIL: hello.txt content mismatch\n")
            return 0
        vi = vi + 1
    pr_emerg("[v9p] hello.txt content verified byte-exact\n")

    pr_emerg("[v9p] PASS\n")
    return 1


# --- btrfs (read-only) end-to-end self-test (boot:37.btrfs) ----------
#
# Proves the read-only btrfs reader (fs/btrfs.ad) mounts a real
# mkfs.btrfs-formatted single-device/single-profile/uncompressed image
# end-to-end off a loop-attached image file:
#   1. Attach the cpio-baked btrfs image /tests/btrfs/test.img via
#      loop_attach, then resolve its /dev/blk/loopN name to the block
#      slot (same shape as ntfs_e2e_selftest).
#   2. btrfs_mount() verifies the superblock magic "_BHRfS_M" at 0x10000,
#      reads node/sector sizes + the chunk-tree and root-tree roots,
#      seeds the chunk map from the bootstrap sys_chunk_array, reads the
#      CHUNK tree for the full logical->physical map, then walks the ROOT
#      tree to the FS_TREE (objectid 5) root.
#   3. Enumerate the root directory (B-tree DIR_ITEM walk): confirm our
#      files are seen.
#   4. Look up + read /HELLO.TXT (INLINE extent — data in the leaf) and
#      assert exactly "BTRFS_MARKER".
#   5. Look up + read /BIG.DAT (REGULAR extent > one 16 KiB node, read
#      through the chunk map) and assert the deterministic pattern
#      byte-exact — this also exercises internal-node (level>0) descent
#      since the padding files push the FS tree past a single leaf.
#   6. Resolve + read a nested file /sub/NESTED.TXT (sub-directory's own
#      DIR_ITEMs).
# Emits [btrfs] PASS on success.
btrfs_test_buf:    Array[8192, uint8]
btrfs_big_buf:     Array[300000, uint8]
btrfs_test_seen:   uint64 = 0
btrfs_test_hello:  int32  = 0
btrfs_test_big:    int32  = 0
btrfs_test_sub:    int32  = 0


def _btrfs_test_dir_cb(ctx: uint64, name_ptr: uint64, name_len: uint64,
                       child_inode: uint64, is_dir: int32) -> int32:
    btrfs_test_seen = btrfs_test_seen + 1
    nm: Ptr[uint8] = cast[Ptr[uint8]](name_ptr)
    # Detect HELLO.TXT (9), BIG.DAT (7), sub (3).
    h: Ptr[uint8] = "HELLO.TXT"
    if name_len == 9:
        i: uint64 = 0
        eq: int32 = 1
        while i < 9:
            if nm[i] != h[i]:
                eq = 0
                i = 9
            else:
                i = i + 1
        if eq == 1:
            btrfs_test_hello = 1
    b: Ptr[uint8] = "BIG.DAT"
    if name_len == 7:
        i2: uint64 = 0
        eq2: int32 = 1
        while i2 < 7:
            if nm[i2] != b[i2]:
                eq2 = 0
                i2 = 7
            else:
                i2 = i2 + 1
        if eq2 == 1:
            btrfs_test_big = 1
    s: Ptr[uint8] = "sub"
    if name_len == 3:
        i3: uint64 = 0
        eq3: int32 = 1
        while i3 < 3:
            if nm[i3] != s[i3]:
                eq3 = 0
                i3 = 3
            else:
                i3 = i3 + 1
        if eq3 == 1:
            btrfs_test_sub = 1
    return 0


def btrfs_e2e_selftest() -> int32:
    pr_emerg("[btrfs] self-test start\n")
    loop_idx: int32 = loop_attach("/tests/btrfs/test.img")
    if loop_idx < 0:
        pr_emerg("[btrfs] FAIL: loop attach returned negative\n")
        return 0
    btrfs_loop_name: Array[16, uint8]
    btrfs_loop_name[0] = 0x6C    # 'l'
    btrfs_loop_name[1] = 0x6F    # 'o'
    btrfs_loop_name[2] = 0x6F    # 'o'
    btrfs_loop_name[3] = 0x70    # 'p'
    btrfs_loop_name[4] = cast[uint8](0x30 + cast[uint64](cast[int64](loop_idx)))
    btrfs_loop_name[5] = 0
    slot: int32 = find_blockdev(cast[Ptr[char]](&btrfs_loop_name[0]))
    if slot < 0:
        pr_emerg("[btrfs] FAIL: loop block device not registered\n")
        return 0
    pr_emerg("[btrfs] loop device attached for .img\n")
    if btrfs_mount(slot) != 0:
        pr_emerg("[btrfs] FAIL: mount\n")
        return 0
    pr_emerg("[btrfs] mounted\n")

    # (3) Enumerate the root directory (inode 256).
    r_inode: uint64 = 0
    r_size:  uint64 = 0
    r_dir:   int32  = 0
    if btrfs_lookup("/", &r_inode, &r_size, &r_dir) != 0:
        pr_emerg("[btrfs] FAIL: lookup /\n")
        return 0
    btrfs_test_seen  = 0
    btrfs_test_hello = 0
    btrfs_test_big   = 0
    btrfs_test_sub   = 0
    if btrfs_readdir(r_inode, _btrfs_test_dir_cb, 0) < 0:
        pr_emerg("[btrfs] FAIL: readdir root\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[btrfs] root entries=%d hello_seen=%d\n",
            btrfs_test_seen, cast[uint64](cast[int64](btrfs_test_hello)))
    if btrfs_test_hello != 1:
        pr_emerg("[btrfs] FAIL: HELLO.TXT not seen in readdir\n")
        return 0
    if btrfs_test_big != 1:
        pr_emerg("[btrfs] FAIL: BIG.DAT not seen in readdir\n")
        return 0
    if btrfs_test_sub != 1:
        pr_emerg("[btrfs] FAIL: sub not seen in readdir\n")
        return 0
    pr_emerg("[btrfs] root directory enumerated\n")

    # (4) Read /HELLO.TXT (INLINE extent) and assert exact bytes.
    h_inode: uint64 = 0
    h_size:  uint64 = 0
    h_dir:   int32  = 0
    if btrfs_lookup("/HELLO.TXT", &h_inode, &h_size, &h_dir) != 0:
        pr_emerg("[btrfs] FAIL: lookup /HELLO.TXT\n")
        return 0
    if h_size != 12:
        pr_emerg("[btrfs] FAIL: /HELLO.TXT wrong size\n")
        return 0
    hn: int64 = btrfs_read(h_inode, h_size, 0, &btrfs_test_buf[0], 8192)
    if hn != 12:
        pr_emerg("[btrfs] FAIL: /HELLO.TXT short read\n")
        return 0
    hexp: Ptr[uint8] = "BTRFS_MARKER"
    hi: uint64 = 0
    while hi < 12:
        if btrfs_test_buf[hi] != hexp[hi]:
            pr_emerg("[btrfs] FAIL: /HELLO.TXT content mismatch\n")
            return 0
        hi = hi + 1
    pr_emerg("[btrfs] /HELLO.TXT (inline extent) content verified\n")

    # (5) Read /BIG.DAT (REGULAR extent, > one 16 KiB node) byte-exact.
    b_inode: uint64 = 0
    b_size:  uint64 = 0
    b_dir:   int32  = 0
    if btrfs_lookup("/BIG.DAT", &b_inode, &b_size, &b_dir) != 0:
        pr_emerg("[btrfs] FAIL: lookup /BIG.DAT\n")
        return 0
    if b_size != 300000:
        pr_emerg("[btrfs] FAIL: /BIG.DAT wrong size\n")
        return 0
    bn: int64 = btrfs_read(b_inode, b_size, 0, &btrfs_big_buf[0], 300000)
    if bn != 300000:
        pr_emerg("[btrfs] FAIL: /BIG.DAT short read\n")
        return 0
    k: uint64 = 0
    while k < 300000:
        exp: uint8 = cast[uint8]((k * 31 + 7) & 0xFF)
        if btrfs_big_buf[k] != exp:
            pr_emerg("[btrfs] FAIL: /BIG.DAT pattern mismatch\n")
            return 0
        k = k + 1
    pr_emerg("[btrfs] /BIG.DAT (regular extent, > one node) verified byte-exact\n")

    # (6) Resolve + read a nested file.
    s_inode: uint64 = 0
    s_size:  uint64 = 0
    s_dir:   int32  = 0
    if btrfs_lookup("/sub/NESTED.TXT", &s_inode, &s_size, &s_dir) != 0:
        pr_emerg("[btrfs] FAIL: lookup /sub/NESTED.TXT\n")
        return 0
    sn: int64 = btrfs_read(s_inode, s_size, 0, &btrfs_test_buf[0], 8192)
    if sn < 1:
        pr_emerg("[btrfs] FAIL: read /sub/NESTED.TXT\n")
        return 0
    pr_emerg("[btrfs] /sub/NESTED.TXT resolved + read\n")

    pr_emerg("[btrfs] PASS\n")
    return 1

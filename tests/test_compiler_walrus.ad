# tests/test_compiler_walrus.ad
#
# Regression fixture for the Adder walrus / assignment-expression
# `(name := value)` (parser: `parse_primary` LPAREN branch; codegen:
# `codegen_x86.py`: `WalrusExpr` case + `_emit_local_store`).
#
# Adder doesn't allow bare `:=` outside parentheses (it would shadow
# the statement-level `x = expr` recogniser). The parenthesised form
# is the standard Python/Plan-9 idiom and is enough for the loop /
# guard use-cases that motivate the feature:
#
#   while (n := next_chunk()) > 0:
#       process(n)
#
# Adder is statically typed, so `name` MUST already be declared in
# scope. `:=` doesn't introduce a new binding — it's strictly an
# assign-and-yield.

# A trivial source of "the next chunk" — countdown from a global.
_chunks_left: int64 = 0

def _next_chunk() -> int64:
    if _chunks_left > 0:
        _chunks_left = _chunks_left - 1
    return _chunks_left

# --- single walrus, value-yield --------------------------------------

def walrus_yields_value(seed: int64) -> int64:
    n: int64 = 0
    n = (n := seed) + 1
    return n

# --- walrus inside `while` -------------------------------------------
#
# Classic "drain a stream until next() returns 0" pattern. Returns
# the number of iterations actually run.

def walrus_while_drain(start: int64) -> int64:
    _chunks_left = start
    n: int64 = 0
    iters: int64 = 0
    while (n := _next_chunk()) > 0:
        iters = iters + 1
    return iters

# --- walrus inside `if` ----------------------------------------------
#
# Compute once, branch on result, also use the bound name in the body.

def walrus_if_branch(x: int64) -> int64:
    q: int64 = 0
    if (q := x * x) > 100:
        return q + 1
    return q - 1

# --- walrus single-evaluation ----------------------------------------
#
# `(n := side_effect()) + (n := side_effect())` must call the RHS
# twice (Python semantics), but `(n := f()) + n` calls it ONCE. We
# pick the second form and use a global counter to prove it.

_calls: int64 = 0

def _ticking_source(x: int64) -> int64:
    _calls = _calls + 1
    return x

def walrus_calls_once(x: int64) -> int64:
    _calls = 0
    n: int64 = 0
    # _ticking_source must fire exactly ONCE; the second `n` is a
    # plain read of the local.
    out: int64 = (n := _ticking_source(x)) + n
    return out

def walrus_calls_once_count(x: int64) -> int64:
    _calls = 0
    n: int64 = 0
    out: int64 = (n := _ticking_source(x)) + n
    return _calls

# --- walrus as the WHOLE expression (no enclosing op) ----------------
#
# `(n := f(x))` evaluated for side effect; the value is also returned.

def walrus_bare(x: int64) -> int64:
    n: int64 = 0
    n = (n := x + 7)
    return n

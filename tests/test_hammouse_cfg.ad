# tests/test_hammouse_cfg.ad
#
# Control Center MOUSE capplet sink — PURE, host-linkable unit test of the
# pointer-preference transform law in lib/hammouse_cfg.ad. No QEMU, no
# /dev/mouse. The kernel /dev/mouse router (sys/src/9/port/devwsys.ad) and
# the capplet push path (user/hamctl.ad -> devmouse_write) both consume the
# very same helpers, so this gate pins the config->behavior mapping.
#
# Build (host):
#   python3 -m compiler.adder compile --target=x86_64-linux \
#       tests/test_hammouse_cfg.ad -o build/host/test_hammouse_cfg
#
# PASS prints "[hammouse-cfg] PASS" and exits 0; any FAIL exits 1.

from lib.hammouse_cfg import (
    mouse_cfg_set, mouse_cfg_reset,
    mouse_cfg_map_buttons, mouse_cfg_map_dz, mouse_cfg_scale_delta,
    mouse_cfg_speed, mouse_cfg_primary, mouse_cfg_natural,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def puts(s: Ptr[uint8]):
    sys_write(1, s, strlen(s))


fail_count: int32 = 0


def check_u(name: Ptr[uint8], got: uint32, want: uint32):
    if got == want:
        puts(cast[Ptr[uint8]]("  ok   "))
        puts(name)
        puts(cast[Ptr[uint8]]("\n"))
    else:
        fail_count = fail_count + 1
        puts(cast[Ptr[uint8]]("  FAIL "))
        puts(name)
        puts(cast[Ptr[uint8]]("\n"))


def check_i(name: Ptr[uint8], got: int32, want: int32):
    check_u(name, cast[uint32](got) & 0xFFFFFFFF, cast[uint32](want) & 0xFFFFFFFF)


def main() -> int32:
    puts(cast[Ptr[uint8]]("[hammouse-cfg] Mouse capplet transform law\n"))

    # ---- DEFAULTS = identity (pre-existing behavior, unconfigured) --------
    mouse_cfg_reset()
    check_u(cast[Ptr[uint8]]("default: buttons pass through"),
            mouse_cfg_map_buttons(1), 1)
    check_u(cast[Ptr[uint8]]("default: middle passes through"),
            mouse_cfg_map_buttons(4), 4)
    check_i(cast[Ptr[uint8]]("default: dz pass through"),
            mouse_cfg_map_dz(3), 3)
    check_i(cast[Ptr[uint8]]("default: delta pass through"),
            mouse_cfg_scale_delta(7), 7)

    # ---- PRIMARY BUTTON = Right: swap L(bit0) <-> R(bit1) -----------------
    mouse_cfg_set(5, 1, 0)
    check_u(cast[Ptr[uint8]]("primary-right: Left -> Right"),
            mouse_cfg_map_buttons(1), 2)
    check_u(cast[Ptr[uint8]]("primary-right: Right -> Left"),
            mouse_cfg_map_buttons(2), 1)
    check_u(cast[Ptr[uint8]]("primary-right: Middle untouched"),
            mouse_cfg_map_buttons(4), 4)
    check_u(cast[Ptr[uint8]]("primary-right: L+M -> R+M"),
            mouse_cfg_map_buttons(5), 6)          # 0b101 -> 0b110

    # ---- SCROLL = Natural: invert the wheel sign ONCE ---------------------
    mouse_cfg_set(5, 0, 1)
    check_i(cast[Ptr[uint8]]("natural: +3 -> -3"),
            mouse_cfg_map_dz(3), 0 - 3)
    check_i(cast[Ptr[uint8]]("natural: -2 -> +2"),
            mouse_cfg_map_dz(0 - 2), 2)
    # Composition with the BUG #123 law: hamui_scroll_apply subtracts dz, so
    # a raw wheel-DOWN (dz=-1) normally INCREASES the offset. Under Natural,
    # map_dz first flips it to +1, so the SAME physical notch now DECREASES
    # the offset — proving the net direction is inverted, not double-flipped.
    natural_dz: int32 = mouse_cfg_map_dz(0 - 1)         # -> +1
    check_i(cast[Ptr[uint8]]("natural: wheel-down notch flips to +1"),
            natural_dz, 1)

    # ---- POINTER SPEED: scale by speed/5, sign preserved, min |1| ---------
    mouse_cfg_set(10, 0, 0)
    check_i(cast[Ptr[uint8]]("speed 10: +4 -> +8"), mouse_cfg_scale_delta(4), 8)
    check_i(cast[Ptr[uint8]]("speed 10: -4 -> -8"),
            mouse_cfg_scale_delta(0 - 4), 0 - 8)
    mouse_cfg_set(1, 0, 0)
    check_i(cast[Ptr[uint8]]("speed 1: +10 -> +2"), mouse_cfg_scale_delta(10), 2)
    check_i(cast[Ptr[uint8]]("speed 1: +1 -> +1 (min magnitude)"),
            mouse_cfg_scale_delta(1), 1)
    check_i(cast[Ptr[uint8]]("speed 1: -1 -> -1 (min magnitude)"),
            mouse_cfg_scale_delta(0 - 1), 0 - 1)
    check_i(cast[Ptr[uint8]]("speed 1: 0 stays 0"),
            mouse_cfg_scale_delta(0), 0)
    mouse_cfg_set(5, 0, 0)
    check_i(cast[Ptr[uint8]]("speed 5: neutral identity"),
            mouse_cfg_scale_delta(9), 9)

    # ---- clamp: out-of-range speed is clamped to 1..10 --------------------
    mouse_cfg_set(99, 3, 3)
    check_i(cast[Ptr[uint8]]("clamp: speed 99 -> 10"), mouse_cfg_speed(), 10)
    check_i(cast[Ptr[uint8]]("clamp: primary 3 -> 1"), mouse_cfg_primary(), 1)
    check_i(cast[Ptr[uint8]]("clamp: natural 3 -> 1"), mouse_cfg_natural(), 1)
    mouse_cfg_set(0, 0, 0)
    check_i(cast[Ptr[uint8]]("clamp: speed 0 -> 1"), mouse_cfg_speed(), 1)

    if fail_count == 0:
        puts(cast[Ptr[uint8]]("[hammouse-cfg] PASS\n"))
        sys_exit(0)
        return 0
    puts(cast[Ptr[uint8]]("[hammouse-cfg] FAIL\n"))
    sys_exit(1)
    return 1

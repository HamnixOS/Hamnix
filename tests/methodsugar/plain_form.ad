# Hand-written free-function form — the byte-match ORACLE for sugar_form.ad.
from lib.strview import str_eq, str_find, str_contains
from lib.hamstr import ham_str_upper, ham_str_lower, ham_str_trim, ham_str_replace, ham_str_starts_with, ham_str_ends_with

def check(a: String, b: String) -> int64:
    r: int64 = 0
    if str_eq(a.ptr, a.len, b.ptr, b.len) != 0:
        r = r + 1
    r = r + str_find(a.ptr, a.len, b.ptr, b.len)
    if str_contains(a.ptr, a.len, b.ptr, b.len) != 0:
        r = r + 10
    if ham_str_starts_with(a.ptr, a.len, b.ptr, b.len) != 0:
        r = r + 100
    if ham_str_ends_with(a.ptr, a.len, b.ptr, b.len) != 0:
        r = r + 1000
    u: Ptr[uint8] = ham_str_upper(a.ptr, a.len)
    l: Ptr[uint8] = ham_str_lower(a.ptr, a.len)
    t: Ptr[uint8] = ham_str_trim(a.ptr, a.len)
    rp: Ptr[uint8] = ham_str_replace(a.ptr, a.len, b.ptr, b.len, b.ptr, b.len)
    return r

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: String = String("hello world")
    b: String = String("world")
    return cast[int32](check(a, b))

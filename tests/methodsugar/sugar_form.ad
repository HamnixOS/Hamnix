# Aggregate method-call sugar form (roadmap increment 12). Byte-match twin of
# plain_form.ad: `s.method(args)` on a String desugars to the free function.
from lib.strview import str_eq, str_find, str_contains
from lib.hamstr import ham_str_upper, ham_str_lower, ham_str_trim, ham_str_replace, ham_str_starts_with, ham_str_ends_with

def check(a: String, b: String) -> int64:
    r: int64 = 0
    if a.eq(b) != 0:
        r = r + 1
    r = r + a.find(b)
    if a.contains(b) != 0:
        r = r + 10
    if a.starts_with(b) != 0:
        r = r + 100
    if a.ends_with(b) != 0:
        r = r + 1000
    u: Ptr[uint8] = a.upper()
    l: Ptr[uint8] = a.lower()
    t: Ptr[uint8] = a.trim()
    rp: Ptr[uint8] = a.replace(b, b)
    return r

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: String = String("hello world")
    b: String = String("world")
    return cast[int32](check(a, b))

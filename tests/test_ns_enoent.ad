# tests/test_ns_enoent.ad
#
# F1-substrate acceptance (audit #444 / task #446): UNBOUND = ENOENT.
#
# The old resolver was a prefix-rewrite veneer over a global path-keyed
# VFS: a path with no covering bind silently FELL THROUGH to the global
# cpio root, so an "empty" namespace could still open every cpio file.
# The substrate rewrite makes the per-Pgrp mount table the sole
# authority: a name with NO covering bind in the calling task's Pgrp is
# a hard ENOENT, and visibility is restored ONLY by an explicit bind.
#
# Scenario:
#
#   1. Parent (default boot namespace):
#      open /etc/inittab            -> succeeds (the kernel-planted
#                                      "/"->"#r" boot bind covers it)
#
#   2. Parent rforks RFPROC | RFFDG | RFCNAMEG | RFENVG. RFCNAMEG
#      gives the child a fresh EMPTY Pgrp (pgrp_alloc, no entries) —
#      the hermetic base `ns clean { }` builds on.
#
#   3. Child (EMPTY namespace):
#      open /etc/inittab            -> MUST FAIL. The file exists in
#                                      the cpio and the PARENT can open
#                                      it; the child cannot, because
#                                      nothing in ITS namespace binds
#                                      it. This is the no-fall-through
#                                      proof: under the old veneer this
#                                      open SUCCEEDED via the global
#                                      cpio root.
#      bind /onlyetc <- #r/etc      -> server-anchored bind into the
#                                      empty namespace must work.
#      open /onlyetc/inittab        -> MUST SUCCEED — the same bytes
#                                      that were invisible one step ago
#                                      are reachable through (and ONLY
#                                      through) the explicit bind.
#      open /etc/inittab            -> MUST STILL FAIL — binding ONE
#                                      name does not resurrect a global
#                                      root for everything else.
#      open /bin/cat                -> MUST FAIL (never bound).
#      print child PASS, exit(0)
#
#   4. Parent (after waitpid):
#      open /etc/inittab            -> still succeeds — the child's
#                                      empty namespace was per-Pgrp,
#                                      not a mutation of the parent's.
#
# Final marker: `[ns_enoent] PASS`. Greppable from
# scripts/test_ns_enoent.sh.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_ns_enoent.ad -o build/user/test_ns_enoent.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_rfork(flags: int32) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_BIND:   uint64 = 257
SYS_FDBIND: uint64 = 278    # a0=pid(0=self), a1=fdnum, a2=kind, a3=arg

DEVFD_CONS: int32 = 1       # console device kind for SYS_FDBIND

# Plan 9 rfork bits. RFCNAMEG is the load-bearing one — the child
# starts with an EMPTY namespace (pgrp_alloc), not a copy.
RFPROC:   int32 = 0x001
RFFDG:    int32 = 0x004
RFNAMEG:  int32 = 0x008
RFENVG:   int32 = 0x010
RFCNAMEG: int32 = 0x080

MREPL: int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def do_bind(new_path: Ptr[uint8], old_path: Ptr[uint8]) -> int64:
    return syscall6(SYS_BIND,
                    cast[uint64](new_path),
                    cast[uint64](old_path),
                    cast[uint64](MREPL), 0, 0, 0)


def main() -> int32:
    write_str(1, "[ns_enoent] start\n")

    # ----------------------------------------------------------------
    # Step 1: parent (default namespace) CAN open the probe file.
    # This anchors the asymmetry: the same path must then fail in the
    # child's empty namespace.
    pfd: int32 = sys_open("/etc/inittab")
    if pfd < 0:
        write_str(1, "[ns_enoent] FAIL: parent cannot open /etc/inittab (default ns broken)\n")
        return 1
    sys_close(pfd)
    write_str(1, "[ns_enoent] parent /etc/inittab ok (default ns)\n")

    # ----------------------------------------------------------------
    # Step 2: rfork with RFCNAMEG — the child's namespace is EMPTY.
    flags: int32 = RFPROC | RFFDG | RFCNAMEG | RFENVG
    pid: int32 = sys_rfork(flags)
    if pid < 0:
        write_str(1, "[ns_enoent] FAIL: rfork returned negative\n")
        return 2

    if pid == 0:
        # ----- CHILD BRANCH (empty namespace) -----

        # The /fd console bindings live in the Pgrp, so RFCNAMEG
        # emptied them along with the mount table. Re-bind the
        # console at fd 0..2 FIRST (the same dance hamsh does after
        # its own RFCNAMEG rfork) so our markers reach the serial
        # log. SYS_FDBIND addresses the Pgrp directly by (pid=self,
        # fdnum) — it is not a namespace path operation, so it works
        # in an empty namespace by design.
        syscall6(SYS_FDBIND, 0, 0, cast[uint64](DEVFD_CONS), 0, 0, 0)
        syscall6(SYS_FDBIND, 0, 1, cast[uint64](DEVFD_CONS), 0, 0, 0)
        syscall6(SYS_FDBIND, 0, 2, cast[uint64](DEVFD_CONS), 0, 0, 0)

        # The probe file the parent just opened MUST be invisible:
        # nothing in this Pgrp binds it. Under the old global-root
        # fall-through this open succeeded — this line IS the F1
        # acceptance.
        cfd: int32 = sys_open("/etc/inittab")
        if cfd >= 0:
            write_str(1, "[ns_enoent] FAIL: empty ns resolved /etc/inittab (global fall-through!)\n")
            sys_close(cfd)
            sys_exit(3)
        write_str(1, "[ns_enoent] child empty-ns /etc/inittab ENOENT (expected)\n")

        # An explicit SERVER-ANCHORED bind makes exactly that subtree
        # visible — and nothing else.
        brc: int64 = do_bind("/onlyetc", "#r/etc")
        if brc != 0:
            write_str(1, "[ns_enoent] FAIL: child bind /onlyetc <- #r/etc rc=")
            write_dec(1, cast[uint64](brc))
            write_str(1, "\n")
            sys_exit(4)
        write_str(1, "[ns_enoent] child bind /onlyetc <- #r/etc ok\n")

        cfd2: int32 = sys_open("/onlyetc/inittab")
        if cfd2 < 0:
            write_str(1, "[ns_enoent] FAIL: /onlyetc/inittab not visible through explicit bind\n")
            sys_exit(5)
        # Drain a few bytes to prove the fd is real, not a phantom.
        buf: Array[16, uint8]
        n: int64 = sys_read(cfd2, &buf[0], 16)
        if n <= 0:
            write_str(1, "[ns_enoent] FAIL: /onlyetc/inittab fd reads nothing\n")
            sys_close(cfd2)
            sys_exit(6)
        sys_close(cfd2)
        write_str(1, "[ns_enoent] child /onlyetc/inittab ok (explicit bind only)\n")

        # Binding ONE name must not resurrect a global root: the
        # original path stays unbound.
        cfd3: int32 = sys_open("/etc/inittab")
        if cfd3 >= 0:
            write_str(1, "[ns_enoent] FAIL: /etc/inittab resolves after unrelated bind\n")
            sys_close(cfd3)
            sys_exit(7)
        write_str(1, "[ns_enoent] child /etc/inittab still ENOENT post-bind (expected)\n")

        # A never-bound subtree is equally invisible.
        cfd4: int32 = sys_open("/bin/cat")
        if cfd4 >= 0:
            write_str(1, "[ns_enoent] FAIL: /bin/cat resolves in empty ns\n")
            sys_close(cfd4)
            sys_exit(8)
        write_str(1, "[ns_enoent] child /bin/cat ENOENT (expected)\n")

        write_str(1, "[ns_enoent] child PASS\n")
        sys_exit(0)
        return 0

    # ----- PARENT BRANCH -----
    write_str(1, "[ns_enoent] parent: child pid=")
    write_dec(1, cast[uint64](pid))
    write_str(1, "\n")

    status: int64 = sys_waitpid(cast[uint64](pid))
    if status < 0:
        write_str(1, "[ns_enoent] FAIL: parent waitpid returned -errno\n")
        return 9

    # The child's empty namespace and its /onlyetc bind were per-Pgrp:
    # the parent's default view is intact, and the child's bind did
    # not leak.
    pfd2: int32 = sys_open("/etc/inittab")
    if pfd2 < 0:
        write_str(1, "[ns_enoent] FAIL: parent lost /etc/inittab after child exit\n")
        return 10
    sys_close(pfd2)
    write_str(1, "[ns_enoent] parent /etc/inittab ok post-child\n")

    lfd: int32 = sys_open("/onlyetc/inittab")
    if lfd >= 0:
        write_str(1, "[ns_enoent] FAIL: child's /onlyetc bind leaked to parent\n")
        sys_close(lfd)
        return 11
    write_str(1, "[ns_enoent] parent /onlyetc missing (expected)\n")

    write_str(1, "[ns_enoent] PASS\n")
    return 0

# tests/test_hugepage.ad
#
# 2 MiB huge-page (MAP_HUGETLB) mmap regression test (§hugepage).
#
# Exercises the native mmap syscall with MAP_HUGETLB:
#   SYS_MMAP    = 302
#   SYS_MUNMAP  = 304
#
# What it proves:
#   T1. A 4 MiB MAP_HUGETLB|MAP_ANONYMOUS region maps successfully and
#       its base is 2 MiB-aligned (a real huge mapping must be).
#   T2. Writing a per-offset pattern at MANY 4 KiB granular offsets that
#       SPAN both 2 MiB pages, then reading it back byte-identically,
#       proves the single 2 MiB PDE (one per 2 MiB) really covers all
#       512 4 KiB sub-offsets — one fault populates the whole 2 MiB.
#   T3. A SECOND independent MAP_HUGETLB region is mapped and written
#       with a different pattern; re-reading region 1 confirms the two
#       huge mappings are isolated (no aliasing of physical frames).
#   T4. An UNALIGNED length (not a 2 MiB multiple) is rejected -EINVAL,
#       matching Linux/hugetlbfs semantics.
#   T5. munmap both regions, verify the return is 0.
#
# The kernel prints "[hugepage] installed 2MiB PS-bit PDE at va=..." on
# every huge demand fault (mm/vma.ad::_vma_demand_fault_huge), which the
# host harness greps to PROVE a real PS-bit 2 MiB PDE was installed (not
# 512 4 KiB pages).
#
# PASS criteria (host harness greps the serial log):
#   [hugepage] T1 PASS
#   [hugepage] T2 PASS
#   [hugepage] T3 PASS
#   [hugepage] T4 PASS
#   [hugepage] T5 PASS
#   [hugepage] PASS
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_hugepage.ad -o build/user/test_hugepage.elf
#
# Run via scripts/test_hugepage.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_mmap(addr: uint64, len: uint64, prot: int32,
                    flags: int32, fd: int32, offset: uint64) -> int64
extern def sys_munmap(addr: uint64, len: uint64) -> int32
extern def sys_exit(code: uint64)

# mmap prot flags
PROT_READ:  int32 = 0x1
PROT_WRITE: int32 = 0x2

# mmap flags
MAP_PRIVATE:   int32 = 0x02
MAP_ANONYMOUS: int32 = 0x20
MAP_HUGETLB:   int32 = 0x40000

PAGE_SIZE:  uint64 = 4096
HUGE_SIZE:  uint64 = 0x200000      # 2 MiB
REGION_SIZE: uint64 = 0x400000     # 4 MiB == 2 huge pages

EINVAL: int64 = -22


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def write_hex(fd: int32, value: uint64):
    sys_write(fd, "0x", 2)
    nibbles: Array[16, uint8]
    n: uint64 = 0
    v: uint64 = value
    if v == 0:
        sys_write(fd, "0", 1)
        return
    while v != 0:
        nib: uint64 = v & 15
        if nib < 10:
            nibbles[n] = cast[uint8](nib) + 48
        else:
            nibbles[n] = cast[uint8](nib - 10) + 97
        v = v >> 4
        n = n + 1
    out: Array[16, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = nibbles[n]
        i = i + 1
    sys_write(fd, &out[0], i)


# Stamp a deterministic 64-bit value at every 4 KiB offset across `len`
# bytes starting at `base`. `seed` distinguishes one region from another.
def stamp_region(base: int64, length: uint64, seed: uint64):
    off: uint64 = 0
    while off < length:
        p: Ptr[uint64] = cast[Ptr[uint64]](base + cast[int64](off))
        p[0] = seed ^ (off * cast[uint64](0x9E3779B1))
        off = off + PAGE_SIZE


# Verify the deterministic pattern written by stamp_region. Returns the
# offset of the first mismatch, or length if every 4 KiB slot matched.
def verify_region(base: int64, length: uint64, seed: uint64) -> uint64:
    off: uint64 = 0
    while off < length:
        p: Ptr[uint64] = cast[Ptr[uint64]](base + cast[int64](off))
        want: uint64 = seed ^ (off * cast[uint64](0x9E3779B1))
        if p[0] != want:
            return off
        off = off + PAGE_SIZE
    return length


def main() -> int32:
    write_str(1, "[hugepage] start\n")

    # ------------------------------------------------------------------
    # T1: 4 MiB MAP_HUGETLB region maps and is 2 MiB-aligned.
    # ------------------------------------------------------------------
    a1: int64 = sys_mmap(0, REGION_SIZE, PROT_READ | PROT_WRITE,
                         MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB, -1, 0)
    if a1 <= 0:
        write_str(1, "[hugepage] T1 FAIL: mmap returned ")
        write_hex(1, cast[uint64](a1))
        write_str(1, "\n")
        return 1
    if (cast[uint64](a1) & (HUGE_SIZE - 1)) != 0:
        write_str(1, "[hugepage] T1 FAIL: base not 2MiB-aligned ")
        write_hex(1, cast[uint64](a1))
        write_str(1, "\n")
        return 1
    write_str(1, "[hugepage] T1 PASS base=")
    write_hex(1, cast[uint64](a1))
    write_str(1, "\n")

    # ------------------------------------------------------------------
    # T2: write a per-4KiB-offset pattern spanning BOTH 2 MiB pages
    # (touching all 1024 4 KiB sub-offsets across 4 MiB), read it back.
    # This proves a single 2 MiB PDE covers every 4 KiB offset within it.
    # ------------------------------------------------------------------
    SEED1: uint64 = 0xCAFEF00D12345678
    stamp_region(a1, REGION_SIZE, SEED1)
    miss1: uint64 = verify_region(a1, REGION_SIZE, SEED1)
    if miss1 != REGION_SIZE:
        write_str(1, "[hugepage] T2 FAIL: mismatch at offset ")
        write_hex(1, miss1)
        write_str(1, "\n")
        return 1
    write_str(1, "[hugepage] T2 PASS spanned ")
    write_dec(1, REGION_SIZE / PAGE_SIZE)
    write_str(1, " 4KiB offsets across 2 huge pages\n")

    # ------------------------------------------------------------------
    # T3: a SECOND huge region, distinct pattern, confirm isolation.
    # ------------------------------------------------------------------
    a2: int64 = sys_mmap(0, REGION_SIZE, PROT_READ | PROT_WRITE,
                         MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB, -1, 0)
    if a2 <= 0:
        write_str(1, "[hugepage] T3 FAIL: 2nd mmap returned ")
        write_hex(1, cast[uint64](a2))
        write_str(1, "\n")
        return 1
    if a2 == a1:
        write_str(1, "[hugepage] T3 FAIL: 2nd region aliases the 1st\n")
        return 1
    SEED2: uint64 = 0x0BADC0DE99887766
    stamp_region(a2, REGION_SIZE, SEED2)
    # Region 2 must verify against its OWN seed...
    miss2: uint64 = verify_region(a2, REGION_SIZE, SEED2)
    if miss2 != REGION_SIZE:
        write_str(1, "[hugepage] T3 FAIL: region2 mismatch at ")
        write_hex(1, miss2)
        write_str(1, "\n")
        return 1
    # ...and region 1 must STILL hold its original seed (isolation).
    miss1b: uint64 = verify_region(a1, REGION_SIZE, SEED1)
    if miss1b != REGION_SIZE:
        write_str(1, "[hugepage] T3 FAIL: region1 corrupted at ")
        write_hex(1, miss1b)
        write_str(1, "\n")
        return 1
    write_str(1, "[hugepage] T3 PASS two huge regions isolated\n")

    # ------------------------------------------------------------------
    # T4: an unaligned length (not a 2 MiB multiple) is rejected EINVAL.
    # ------------------------------------------------------------------
    bad: int64 = sys_mmap(0, REGION_SIZE + PAGE_SIZE,
                         PROT_READ | PROT_WRITE,
                         MAP_PRIVATE | MAP_ANONYMOUS | MAP_HUGETLB, -1, 0)
    if bad != EINVAL:
        write_str(1, "[hugepage] T4 FAIL: unaligned length not rejected, got ")
        write_hex(1, cast[uint64](bad))
        write_str(1, "\n")
        return 1
    write_str(1, "[hugepage] T4 PASS unaligned length rejected EINVAL\n")

    # ------------------------------------------------------------------
    # T5: munmap both huge regions, verify return 0.
    # ------------------------------------------------------------------
    r1: int32 = sys_munmap(cast[uint64](a1), REGION_SIZE)
    if r1 != 0:
        write_str(1, "[hugepage] T5 FAIL: munmap region1 returned ")
        write_dec(1, cast[uint64](cast[int64](r1)))
        write_str(1, "\n")
        return 1
    r2: int32 = sys_munmap(cast[uint64](a2), REGION_SIZE)
    if r2 != 0:
        write_str(1, "[hugepage] T5 FAIL: munmap region2 returned ")
        write_dec(1, cast[uint64](cast[int64](r2)))
        write_str(1, "\n")
        return 1
    write_str(1, "[hugepage] T5 PASS\n")

    write_str(1, "[hugepage] PASS\n")
    return 0

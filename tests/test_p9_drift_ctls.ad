# tests/test_p9_drift_ctls.ad
#
# F2 #447 acceptance gate — the four ctl-file surfaces that retire
# drift syscalls (per docs/native-api.md updated migration table):
#
#   1. /proc/self/ctl  `pri <n>`           replaces SYS_NICE (311)
#   2. /proc/svc/ctl   `start <name>`      replaces SYS_SVC_CTL (296)
#   3. /net/dns        `server X.Y.Z.W`    replaces SYS_NETCFG SET_DNS
#                                          (286 op 3); read renders the
#                                          configured server
#   4. /dev/wsys/ctl   `alloc <pid>`       replaces SYS_WSYS_ALLOC (293)
#                      `free <wid>`        replaces SYS_WSYS_FREE  (294)
#                      `frame <wid> <n>`   replaces SYS_VK_WINDOW_FRAME (312)
#
# The gate uses /proc/self/stat field 19 (nice) as a side-effect probe
# for the pri write — the kernel updates the live task's nice value
# and a subsequent stat read reflects it. /net/dns is round-tripped:
# write a server, read it back. /dev/wsys/ctl's "alloc" verb is read
# back via the same fd to fetch the assigned wid (the open/write/read/
# close idiom).
#
# The svc_ctl write is the trickiest to side-effect-verify in isolation
# (the queue is drained by PID 1's supervisor on its next tick; this
# fixture runs in a CHILD process and PID 1 is the hamsh-as-init it
# was spawned from, so we can ENQUEUE but not OBSERVE the drain
# synchronously). We test the write at least succeeds.
#
# Final marker: `[p9drift] PASS`. scripts/test_p9_drift_ctls.sh greps.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


# Top-level BSS scratch (Adder U9 quirk).
ctl_scratch: Array[256, uint8]
stat_scratch: Array[1024, uint8]
dns_scratch: Array[128, uint8]


def write_pri_via_ctl_file(pri: int64) -> int32:
    # Open /proc/self/ctl for write and emit "pri <n>\n".
    fd: int32 = sys_open_write("/proc/self/ctl")
    if fd < 0:
        return -1
    pos: uint64 = 0
    pfx: Ptr[uint8] = "pri "
    pi: uint64 = 0
    while pfx[pi] != 0:
        ctl_scratch[pos] = pfx[pi]
        pos = pos + 1
        pi = pi + 1
    if pri < 0:
        ctl_scratch[pos] = 45                       # '-'
        pos = pos + 1
        mag: uint64 = cast[uint64](0 - pri)
        if mag == 0:
            ctl_scratch[pos] = 48
            pos = pos + 1
        else:
            digs: Array[24, uint8]
            n: uint64 = 0
            while mag > 0:
                digs[n] = cast[uint8](mag % 10) + 48
                mag = mag / 10
                n = n + 1
            while n > 0:
                n = n - 1
                ctl_scratch[pos] = digs[n]
                pos = pos + 1
    else:
        mag2: uint64 = cast[uint64](pri)
        if mag2 == 0:
            ctl_scratch[pos] = 48
            pos = pos + 1
        else:
            digs2: Array[24, uint8]
            n2: uint64 = 0
            while mag2 > 0:
                digs2[n2] = cast[uint8](mag2 % 10) + 48
                mag2 = mag2 / 10
                n2 = n2 + 1
            while n2 > 0:
                n2 = n2 - 1
                ctl_scratch[pos] = digs2[n2]
                pos = pos + 1
    ctl_scratch[pos] = 10                            # '\n'
    pos = pos + 1
    rc: int64 = sys_write(fd, &ctl_scratch[0], pos)
    sys_close(fd)
    if rc < 0:
        return -1
    return 0


def read_stat_nice() -> int64:
    # Parse field 19 of /proc/self/stat (nice). The line is space-
    # separated except for the `(comm)` field — we step past the
    # closing ')' first, then count tokens to field 19.
    fd: int32 = sys_open("/proc/self/stat")
    if fd < 0:
        return 100                                  # unreachable nice
    n: int64 = sys_read(fd, &stat_scratch[0], 1024)
    sys_close(fd)
    if n <= 0:
        return 100
    nn: uint64 = cast[uint64](n)
    # Find the first '(' then walk to the LAST ')' (comm contains no
    # ')' but a defensive skip is fine).
    p: uint64 = 0
    while p < nn and stat_scratch[p] != 40:        # '('
        p = p + 1
    if p >= nn:
        return 100
    # Walk back to last ')'.
    q: uint64 = nn - 1
    while q > p and stat_scratch[q] != 41:         # ')'
        q = q - 1
    if q <= p:
        return 100
    # Skip past ')' and any whitespace.
    p = q + 1
    # From here, fields are space-separated. After the close-paren we
    # are at field 2 boundary (1=pid, 2=comm); the NEXT non-ws byte
    # starts field 3. Count whitespace transitions until we reach
    # field 19.
    # field counter is 2 (comm) immediately after ')'.
    fcnt: int32 = 2
    while p < nn:
        # Skip whitespace.
        while p < nn and stat_scratch[p] == 32:
            p = p + 1
        if p >= nn:
            break
        # We are at the start of (field + 1)-th token.
        fcnt = fcnt + 1
        if fcnt == 19:
            # Parse signed decimal here.
            neg: int32 = 0
            if stat_scratch[p] == 45:               # '-'
                neg = 1
                p = p + 1
            v: int64 = 0
            while p < nn and stat_scratch[p] >= 48 and stat_scratch[p] <= 57:
                v = v * 10 + cast[int64](stat_scratch[p]) - 48
                p = p + 1
            if neg == 1:
                v = 0 - v
            return v
        # Walk to next whitespace.
        while p < nn and stat_scratch[p] != 32:
            p = p + 1
    return 100


def main() -> int32:
    write_str(1, "[p9drift] start\n")

    # --- 1. /proc/self/ctl `pri 5` -----------------------------------
    if write_pri_via_ctl_file(5) != 0:
        write_str(1, "[p9drift] FAIL: cannot open /proc/self/ctl for write\n")
        sys_exit(1)
        return 1
    n5: int64 = read_stat_nice()
    if n5 != 5:
        write_str(1, "[p9drift] FAIL: /proc/self/ctl pri 5 not reflected (nice=")
        write_dec(1, cast[uint64](n5))
        write_str(1, ")\n")
        sys_exit(2)
        return 2
    write_str(1, "[p9drift] /proc/self/ctl pri 5 OK\n")

    if write_pri_via_ctl_file(-10) != 0:
        write_str(1, "[p9drift] FAIL: pri -10 write\n")
        sys_exit(3)
        return 3
    n_neg: int64 = read_stat_nice()
    if n_neg != -10:
        write_str(1, "[p9drift] FAIL: pri -10 not reflected (nice=")
        write_dec(1, cast[uint64](n_neg))
        write_str(1, ")\n")
        sys_exit(4)
        return 4
    write_str(1, "[p9drift] /proc/self/ctl pri -10 OK\n")

    # --- 2. /proc/svc/ctl `start <name>` -----------------------------
    # We only verify the write succeeds — the dequeue happens later on
    # the PID-1 tick. A failing write surfaces a clear errstr we
    # propagate.
    sfd: int32 = sys_open_write("/proc/svc/ctl")
    if sfd < 0:
        write_str(1, "[p9drift] FAIL: cannot open /proc/svc/ctl for write\n")
        sys_exit(5)
        return 5
    sverb: Ptr[uint8] = "start sshd\n"
    src: int64 = sys_write(sfd, sverb, strlen_u8(sverb))
    sys_close(sfd)
    if src < 0:
        write_str(1, "[p9drift] FAIL: /proc/svc/ctl write returned -1\n")
        sys_exit(6)
        return 6
    write_str(1, "[p9drift] /proc/svc/ctl start sshd OK (enqueued)\n")

    # The read side must reject — Plan 9 ctl-file contract.
    rfd: int32 = sys_open("/proc/svc/ctl")
    if rfd >= 0:
        # Some kernels let the open through but the read returns -1.
        rbuf: Array[16, uint8]
        rn: int64 = sys_read(rfd, &rbuf[0], 16)
        sys_close(rfd)
        if rn > 0:
            write_str(1, "[p9drift] FAIL: /proc/svc/ctl read leaked bytes\n")
            sys_exit(7)
            return 7
    write_str(1, "[p9drift] /proc/svc/ctl read rejected OK\n")

    # --- 3. /net/dns set + read --------------------------------------
    nfd: int32 = sys_open_write("/net/dns")
    if nfd < 0:
        write_str(1, "[p9drift] FAIL: cannot open /net/dns for write\n")
        sys_exit(8)
        return 8
    dverb: Ptr[uint8] = "server 1.1.1.1\n"
    drc: int64 = sys_write(nfd, dverb, strlen_u8(dverb))
    sys_close(nfd)
    if drc < 0:
        write_str(1, "[p9drift] FAIL: /net/dns write returned -1\n")
        sys_exit(9)
        return 9
    # Read back.
    rfd2: int32 = sys_open("/net/dns")
    if rfd2 < 0:
        write_str(1, "[p9drift] FAIL: cannot reopen /net/dns for read\n")
        sys_exit(10)
        return 10
    dn: int64 = sys_read(rfd2, &dns_scratch[0], 128)
    sys_close(rfd2)
    if dn <= 0:
        write_str(1, "[p9drift] FAIL: /net/dns read returned 0\n")
        sys_exit(11)
        return 11
    # Expect "1.1.1.1 static\n" (prefix match enough — DHCP may have
    # overlaid the source tag if the kernel re-resolved after our pin;
    # we test the address only).
    expected: Ptr[uint8] = "1.1.1.1"
    el: uint64 = strlen_u8(expected)
    ok: int32 = 1
    if cast[uint64](dn) < el:
        ok = 0
    else:
        di: uint64 = 0
        while di < el:
            if dns_scratch[di] != expected[di]:
                ok = 0
                break
            di = di + 1
    if ok == 0:
        write_str(1, "[p9drift] FAIL: /net/dns read did not echo 1.1.1.1\n")
        sys_exit(12)
        return 12
    write_str(1, "[p9drift] /net/dns set+get OK\n")

    write_str(1, "[p9drift] PASS\n")
    sys_exit(0)
    return 0

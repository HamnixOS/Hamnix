# tests/test_devrandom.ad
#
# M16.95 regression: open /dev/random, read 16 raw bytes, render them
# as space-separated decimal numbers on stdout. The script asserts the
# 16 numbers are NOT all zero and NOT all 255 — that's a coarse
# "entropy is varying" sanity check appropriate to the xorshift64
# placeholder we ship at this milestone.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devrandom.ad -o build/user/test_devrandom.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def u8_to_dec(value: uint8, out: Ptr[uint8]) -> uint64:
    # uint8 max is 255 → at most 3 digits. Reverse-fill stack pattern,
    # mirrors fs/procfs.ad::_buf_put_dec at byte scale.
    if value == 0:
        out[0] = 48                          # '0'
        return 1
    digits: Array[4, uint8]
    n: uint64 = 0
    v: uint64 = cast[uint64](value)
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def main() -> int32:
    write_str(1, "[test_devrandom] start\n")

    fd: int32 = sys_open("/dev/random")
    if fd < 0:
        write_str(1, "[test_devrandom] open failed\n")
        return 1

    raw: Array[16, uint8]
    n: int64 = sys_read(fd, &raw[0], 16)
    if n != 16:
        write_str(1, "[test_devrandom] short read\n")
        sys_close(fd)
        return 1

    # Render: "[test_devrandom] bytes= 12 34 56 ...\n". The leading
    # space before the first digit means every number is preceded by
    # ' ' — keeps the loop body simple at the cost of a redundant
    # space, which the script's regex tolerates.
    write_str(1, "[test_devrandom] bytes=")
    out: Array[64, uint8]
    i: uint64 = 0
    while i < 16:
        out[0] = 32                          # ' '
        m: uint64 = u8_to_dec(raw[i], cast[Ptr[uint8]](cast[uint64](&out[0]) + 1))
        sys_write(1, &out[0], 1 + m)
        i = i + 1
    write_str(1, "\n")

    sys_close(fd)
    write_str(1, "[test_devrandom] done\n")
    return 0

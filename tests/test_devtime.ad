# tests/test_devtime.ad
#
# M16.95 regression: open /dev/time for read, drain up to 32 bytes,
# echo them to stdout. The script asserts the captured slice contains
# at least one digit run terminated by '\n' — that's the contract
# devtime_read() promises (ASCII decimal nanoseconds + newline).
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devtime.ad -o build/user/test_devtime.elf
#
# Run via scripts/test_devtime.sh, which embeds this binary at
# /bin/test_devtime in the cpio initramfs (build_initramfs.py
# auto-globs build/user/*.elf — same as test_devcons).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def main() -> int32:
    write_str(1, "[test_devtime] start\n")

    fd: int32 = sys_open("/dev/time")
    if fd < 0:
        write_str(1, "[test_devtime] open failed\n")
        return 1

    # devtime_read samples get_jiffies() fresh and emits up to ~21
    # bytes (uint64 max in decimal + '\n'). 32 is comfortable headroom.
    buf: Array[32, uint8]
    n: int64 = sys_read(fd, &buf[0], 32)
    if n <= 0:
        write_str(1, "[test_devtime] read returned <= 0\n")
        sys_close(fd)
        return 1

    write_str(1, "[test_devtime] ns=")
    sys_write(1, &buf[0], cast[uint64](n))
    # devtime_read already appends '\n'; no extra newline here.

    sys_close(fd)
    write_str(1, "[test_devtime] done\n")
    return 0

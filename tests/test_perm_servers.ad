# tests/test_perm_servers.ad
#
# arch audit §2.2 acceptance: real per-server perm bodies for tmpfs /
# FAT / devcons / devsrv. Each previously had a world-r/w stub. This
# fixture exercises one denied + one allowed op per server from a
# NON-hostowner uid (UID_NOBODY = 65534) so the per-server gate is the
# observed gate — the dispatcher's uid==1 bypass is OUT of the picture.
#
# Server-by-server expectations after this commit:
#
#   tmpfs   /tmp world-writable (NOBODY may create);
#           /var hostowner-only-write (NOBODY denied)
#   FAT     /mnt world-readable;
#           write under /mnt hostowner-only (NOBODY denied)
#   devcons /dev/cons world r/w; /dev/keymap world-read,
#           hostowner-write (NOBODY denied write)
#   devsrv  /srv reads world-OK; writes to a non-existent srv name
#           denied for NOBODY
#
# Final marker: `[perm_servers] PASS` greppable from
# scripts/test_perm_servers.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_GETUID: uint64 = 288
SYS_SETUID: uint64 = 290

UID_NOBODY: uint64 = 65534


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def my_getuid() -> uint64:
    return cast[uint64](syscall6(SYS_GETUID, 0, 0, 0, 0, 0, 0))


def my_setuid(uid: uint64) -> int64:
    return syscall6(SYS_SETUID, uid, 0, 0, 0, 0, 0)


def expect_open_write_ok(label: Ptr[uint8], path: Ptr[char]) -> int32:
    fd: int32 = sys_open_write(path)
    if fd < 0:
        write_str(1, "[perm_servers] FAIL ")
        write_str(1, label)
        write_str(1, ": expected allow, got deny on ")
        write_str(1, cast[Ptr[uint8]](path))
        sys_write(1, "\n", 1)
        return -1
    sys_close(fd)
    return 0


def expect_open_write_denied(label: Ptr[uint8], path: Ptr[char]) -> int32:
    fd: int32 = sys_open_write(path)
    if fd >= 0:
        write_str(1, "[perm_servers] FAIL ")
        write_str(1, label)
        write_str(1, ": expected deny, got allow on ")
        write_str(1, cast[Ptr[uint8]](path))
        sys_write(1, "\n", 1)
        sys_close(fd)
        return -1
    return 0


def expect_open_read_ok(label: Ptr[uint8], path: Ptr[char]) -> int32:
    fd: int32 = sys_open(path)
    if fd < 0:
        write_str(1, "[perm_servers] FAIL ")
        write_str(1, label)
        write_str(1, ": expected allow-read, got deny on ")
        write_str(1, cast[Ptr[uint8]](path))
        sys_write(1, "\n", 1)
        return -1
    sys_close(fd)
    return 0


def main() -> int32:
    write_str(1, "[perm_servers] start\n")
    # Confirm we started as hostowner; SYS_SETUID(NOBODY) is the gated
    # downgrade so any non-hostowner start makes the next step ENOSYS.
    if my_getuid() != 1:
        write_str(1, "[perm_servers] FAIL: did not inherit hostowner from PID 1\n")
        return 1
    if my_setuid(UID_NOBODY) < 0:
        write_str(1, "[perm_servers] FAIL: SYS_SETUID(NOBODY) refused\n")
        return 1
    if my_getuid() != UID_NOBODY:
        write_str(1, "[perm_servers] FAIL: downgrade to NOBODY did not stick\n")
        return 1
    write_str(1, "[perm_servers] downgraded to NOBODY\n")

    fail: int32 = 0

    # --- tmpfs ------------------------------------------------------
    # /tmp/* is world-writable (sticky scratch); /var/* is hostowner-only
    # for writes. NOBODY must succeed at creating /tmp/perm_t and be
    # denied creating /var/perm_t.
    if expect_open_write_ok("tmpfs-tmp-allow",
                            "/tmp/perm_servers_probe") != 0:
        fail = 1
    else:
        write_str(1, "[perm_servers] OK tmpfs: NOBODY may write /tmp/*\n")
    if expect_open_write_denied("tmpfs-var-deny",
                                "/var/perm_servers_probe") != 0:
        fail = 1
    else:
        write_str(1, "[perm_servers] OK tmpfs: NOBODY denied /var/*\n")

    # --- FAT -------------------------------------------------------
    # /mnt is the FAT mount (one is always present in this image). A
    # write under /mnt must be denied for NOBODY. Reads under /mnt are
    # admitted by the server-boundary gate; ENOENT for a non-existent
    # file is FINE (proves we passed the perm gate and ext-of-driver
    # path-resolution decided). Tests for "deny" only — the per-image
    # /mnt content is fluid.
    if expect_open_write_denied("fat-write-deny",
                                "/mnt/perm_servers_probe") != 0:
        fail = 1
    else:
        write_str(1, "[perm_servers] OK fat: NOBODY denied write under /mnt\n")

    # --- devcons --------------------------------------------------
    # /dev/cons read/write is world-OK; /dev/keymap is world-read,
    # hostowner-write. NOBODY must succeed at opening /dev/cons for
    # write AND opening /dev/keymap for read, and fail at opening
    # /dev/keymap for write.
    if expect_open_write_ok("devcons-cons-allow", "/dev/cons") != 0:
        fail = 1
    else:
        write_str(1, "[perm_servers] OK devcons: NOBODY may write /dev/cons\n")
    if expect_open_read_ok("devcons-keymap-read", "/dev/keymap") != 0:
        fail = 1
    else:
        write_str(1, "[perm_servers] OK devcons: NOBODY may read /dev/keymap\n")
    if expect_open_write_denied("devcons-keymap-deny", "/dev/keymap") != 0:
        fail = 1
    else:
        write_str(1, "[perm_servers] OK devcons: NOBODY denied write /dev/keymap\n")

    # --- devsrv ---------------------------------------------------
    # /srv reads are world-OK (`ls /srv` etc.). Opening a non-existent
    # /srv/<name> for write must be denied for NOBODY (the only path to
    # post is SYS_SRV_POST which has its own gate; the perm gate denies
    # ad-hoc writes through vfs_open_write).
    if expect_open_write_denied("devsrv-post-deny",
                                "/srv/perm_servers_probe") != 0:
        fail = 1
    else:
        write_str(1, "[perm_servers] OK devsrv: NOBODY denied /srv/<unknown>\n")

    if fail != 0:
        write_str(1, "[perm_servers] FAIL\n")
        return 2

    write_str(1, "[perm_servers] PASS\n")
    return 0

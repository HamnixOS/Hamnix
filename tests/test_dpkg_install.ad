# tests/test_dpkg_install.ad
#
# Verification fixture for the "real install" milestone: `dpkg -i` of a
# genuine Debian `.deb` actually LANDS the package's files into the
# distrofs-served distro namespace, so the installed program is present
# and usable.
#
# WHAT THIS PROVES
# ----------------
# This fixture is exec'd by `nsrun` (see scripts/test_dpkg_install.sh),
# so /usr, /var and /etc are each served by a distrofs 9P daemon. The
# fixture then, all WITHIN that one namespace:
#
#   1. spawns `/bin/dpkg -i /tests/sample.deb` and waits for it — dpkg
#      decompresses control.tar.xz + data.tar.xz, records the status
#      stanza, AND (the milestone) extracts every data.tar file to its
#      nested absolute distro path (/usr/bin/hello, /usr/share/doc/...).
#      Those writes route through the kernel namec probe to the
#      distrofs daemon backing /usr.
#
#   2. opens /usr/bin/hello — the installed binary — IN THE SAME
#      namespace and asserts it is present and non-empty. This is a
#      "subsequent command sees the files" proof: a fresh open(2),
#      walking the distrofs tree the dpkg child built.
#
#   3. opens /usr/share/doc/hello/copyright — a file at a DEEP nested
#      path none of dpkg's distrofs skeleton pre-created — and asserts
#      it too is present. This proves the mkdir -p directory chain
#      (kernel namec_mkdir) created /usr/share, /usr/share/doc and
#      /usr/share/doc/hello on the fly.
#
# A bare run (no nsrun) is the negative control: /usr is the read-only
# initramfs, the dpkg extraction writes are refused, and the post-check
# opens fail — proving nothing leaked to a global path.
#
# MARKERS grepped by scripts/test_dpkg_install.sh:
#   [dpkg_install] start
#   [dpkg_install] dpkg spawned pid=<n>
#   [dpkg_install] dpkg exit=<n>
#   [dpkg_install] bin present bytes=<n>
#   [dpkg_install] doc present bytes=<n>
#   [dpkg_install] PASS
#   [dpkg_install] FAIL: ...

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32


# Top-level BSS scratch (U9 nested-frame-Array quirk).
read_buf: Array[256, uint8]
err_buf:  Array[128, uint8]

# argv for the spawned `/bin/dpkg -i /tests/sample.deb`.
dpkg_argv: Array[4, uint64]

# Installed-file paths the real Debian `hello` package carries.
bin_path: Array[32, uint8] = "/usr/bin/hello"
doc_path: Array[48, uint8] = "/usr/share/doc/hello/copyright"


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def write_signed(fd: int32, v: int64):
    if v < 0:
        sys_write(fd, "-", 1)
        write_dec(fd, cast[uint64](0 - v))
    else:
        write_dec(fd, cast[uint64](v))


# Open `path` and read it; return the byte count read (>= 0) or -1 if
# the file could not be opened. Reads into read_buf (256-byte probe is
# enough to prove the file is present + non-empty).

def probe_file(path: Ptr[char]) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < 256:
        n: int64 = sys_read(fd, &read_buf[total], 256 - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    write_str(1, "[dpkg_install] start\n")

    # 1) Spawn `/bin/dpkg -i /tests/sample.deb`. The dpkg child runs in
    #    THIS namespace (sys_spawn inherits the caller's Pgrp), so its
    #    data.tar extraction lands on the distrofs daemons nsrun
    #    mounted at /usr, /var, /etc.
    dpkg_argv[0] = cast[uint64](cast[Ptr[uint8]]("/bin/dpkg"))
    dpkg_argv[1] = cast[uint64](cast[Ptr[uint8]]("-i"))
    dpkg_argv[2] = cast[uint64](cast[Ptr[uint8]]("/tests/sample.deb"))
    dpkg_argv[3] = 0
    pid: int32 = sys_spawn(cast[Ptr[char]]("/bin/dpkg"), &dpkg_argv[0],
                           0, 1, cast[Ptr[uint64]](0))
    if pid < 0:
        err_buf[0] = 0
        sys_errstr(&err_buf[0], 128)
        write_str(1, "[dpkg_install] FAIL: spawn dpkg errstr=")
        write_str(1, &err_buf[0])
        write_str(1, "\n")
        return 1
    write_str(1, "[dpkg_install] dpkg spawned pid=")
    write_dec(1, cast[uint64](pid))
    write_str(1, "\n")

    ec: int64 = sys_waitpid(pid)
    write_str(1, "[dpkg_install] dpkg exit=")
    write_signed(1, ec)
    write_str(1, "\n")
    if ec != 0:
        write_str(1, "[dpkg_install] FAIL: dpkg -i returned non-zero\n")
        return 1

    # 2) The installed binary must now be present in this namespace.
    bin_bytes: int64 = probe_file(cast[Ptr[char]](&bin_path[0]))
    if bin_bytes < 0:
        write_str(1, "[dpkg_install] FAIL: /usr/bin/hello not present\n")
        return 1
    if bin_bytes == 0:
        write_str(1, "[dpkg_install] FAIL: /usr/bin/hello is empty\n")
        return 1
    write_str(1, "[dpkg_install] bin present bytes=")
    write_dec(1, cast[uint64](bin_bytes))
    write_str(1, "\n")

    # 3) A deep nested file proves the mkdir -p directory chain worked.
    doc_bytes: int64 = probe_file(cast[Ptr[char]](&doc_path[0]))
    if doc_bytes < 0:
        write_str(1,
            "[dpkg_install] FAIL: /usr/share/doc/hello/copyright not present\n")
        return 1
    write_str(1, "[dpkg_install] doc present bytes=")
    write_dec(1, cast[uint64](doc_bytes))
    write_str(1, "\n")

    write_str(1, "[dpkg_install] PASS\n")
    return 0

# tests/test_ns_isolation.ad
#
# V2 regression for per-process namespaces. Proves that two tasks
# with DIFFERENT namespace_ids (parent vs. RFNAMEG-child) see
# different views of the mount table — which is the literal Plan 9
# "namespaces are per-process bindings" semantic.
#
# Scenario:
#
#   1. Parent (root namespace, ns 0):
#      bind /myalias -> /etc
#      open /myalias/inittab     -> succeeds via cpio /etc/motd
#
#   2. Parent rforks RFPROC | RFFDG | RFNAMEG | RFENVG. The
#      RFNAMEG bit triggers ns_clone() in chan.ad — the child gets
#      a fresh ns row with a deep copy of the parent's bindings.
#      Both views are currently identical.
#
#   3. Child (private namespace, ns 1):
#      unmount /myalias        -> drops the inherited binding
#      bind /myalias -> /bin    -> new binding visible only to the child
#      open /myalias/cat        -> succeeds via cpio /bin/cat
#      open /myalias/inittab       -> MUST FAIL (no /bin/motd in cpio)
#      print PASS marker, exit(0)
#
#   4. Parent (after waitpid):
#      open /myalias/inittab       -> still succeeds (parent's row is
#                                  untouched by child's bind)
#      open /myalias/cat        -> MUST FAIL (parent never bound to /bin)
#
# Final marker: `[ns_isolation] PASS`. Greppable from
# scripts/test_ns_isolation.sh.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_ns_isolation.ad -o build/user/test_ns_isolation.elf
#
# Run via scripts/test_ns_isolation.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_rfork(flags: int32) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_BIND:    uint64 = 257
SYS_UNMOUNT: uint64 = 259

# Plan 9 rfork bits: POSIX-fork combo + namespace copy. RFNAMEG is
# the load-bearing bit — it tells the kernel to call ns_clone() so
# the child diverges from the parent's view.
RFPROC:   int32 = 0x001
RFFDG:    int32 = 0x004
RFNAMEG:  int32 = 0x008
RFENVG:   int32 = 0x010

MREPL: int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def do_bind(new_path: Ptr[uint8], old_path: Ptr[uint8]) -> int64:
    return syscall6(SYS_BIND,
                    cast[uint64](new_path),
                    cast[uint64](old_path),
                    cast[uint64](MREPL), 0, 0, 0)


def do_unmount(old_path: Ptr[uint8]) -> int64:
    # NULL `new` -> "unmount everything at old". The shape used by
    # the test_p9mount fixture; clears any inherited binding so the
    # child's subsequent bind starts from a clean slate.
    return syscall6(SYS_UNMOUNT,
                    0,
                    cast[uint64](old_path),
                    0, 0, 0, 0)


def main() -> int32:
    write_str(1, "[ns_isolation] start\n")

    # ----------------------------------------------------------------
    # Step 1: parent binds /myalias -> /etc in the root namespace.
    rc: int64 = do_bind("/myalias", "/etc")
    if rc != 0:
        write_str(1, "[ns_isolation] FAIL: parent bind /myalias->/etc rc=")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        return 1
    write_str(1, "[ns_isolation] parent bind /myalias -> /etc ok\n")

    # Confirm the binding is live in the parent's view BEFORE forking.
    fd: int32 = sys_open("/myalias/inittab")
    if fd < 0:
        write_str(1, "[ns_isolation] FAIL: parent /myalias/inittab open pre-fork\n")
        return 2
    sys_close(fd)
    write_str(1, "[ns_isolation] parent /myalias/inittab ok pre-fork\n")

    # ----------------------------------------------------------------
    # Step 2: rfork with RFNAMEG. The child gets a fresh ns_pool row
    # that's a deep copy of the parent's. After this point parent
    # and child have INDEPENDENT mount tables.
    flags: int32 = RFPROC | RFFDG | RFNAMEG | RFENVG
    pid: int32 = sys_rfork(flags)
    if pid < 0:
        write_str(1, "[ns_isolation] FAIL: rfork returned negative\n")
        return 3

    if pid == 0:
        # ----- CHILD BRANCH -----
        # The child inherited the parent's /myalias binding. To prove
        # isolation we mutate the child's view and verify the parent
        # is untouched after we exit.
        write_str(1, "[ns_isolation] child: inherited ns row\n")

        # Sanity: the inherited binding is live — open /myalias/inittab
        # in the child first, before we mutate. This proves
        # ns_clone() actually copied the parent's entries.
        cfd: int32 = sys_open("/myalias/inittab")
        if cfd < 0:
            write_str(1, "[ns_isolation] FAIL: child inheritance broken (no /myalias/inittab)\n")
            sys_exit(4)
        sys_close(cfd)
        write_str(1, "[ns_isolation] child inherited /myalias/inittab ok\n")

        # Drop the inherited binding. With NULL `new`, this removes
        # every entry at /myalias in OUR namespace row. The parent's
        # row is untouched.
        urc: int64 = do_unmount("/myalias")
        if urc != 0:
            write_str(1, "[ns_isolation] FAIL: child unmount /myalias rc=")
            write_dec(1, cast[uint64](urc))
            write_str(1, "\n")
            sys_exit(5)
        write_str(1, "[ns_isolation] child unmount /myalias ok\n")

        # Re-bind to a different target.
        brc: int64 = do_bind("/myalias", "/bin")
        if brc != 0:
            write_str(1, "[ns_isolation] FAIL: child bind /myalias->/bin rc=")
            write_dec(1, cast[uint64](brc))
            write_str(1, "\n")
            sys_exit(6)
        write_str(1, "[ns_isolation] child bind /myalias -> /bin ok\n")

        # The child's view: /myalias/cat -> /bin/cat (real ELF).
        cfd2: int32 = sys_open("/myalias/cat")
        if cfd2 < 0:
            write_str(1, "[ns_isolation] FAIL: child /myalias/cat open\n")
            sys_exit(7)
        sys_close(cfd2)
        write_str(1, "[ns_isolation] child /myalias/cat ok (private bind live)\n")

        # The child's view: /myalias/inittab must NOT exist (we re-bound
        # to /bin, not /etc — and /bin/motd doesn't exist in cpio).
        cfd3: int32 = sys_open("/myalias/inittab")
        if cfd3 >= 0:
            write_str(1, "[ns_isolation] FAIL: child /myalias/inittab still resolves (stale entry?)\n")
            sys_close(cfd3)
            sys_exit(8)
        write_str(1, "[ns_isolation] child /myalias/inittab missing (expected)\n")

        write_str(1, "[ns_isolation] child PASS\n")
        sys_exit(0)
        return 0

    # ----- PARENT BRANCH -----
    write_str(1, "[ns_isolation] parent: child pid=")
    write_dec(1, cast[uint64](pid))
    write_str(1, "\n")

    # Wait for the child to finish its mutations + exit. After this
    # returns, the only namespace row that ever had `/myalias->/bin`
    # is the child's; that row is eligible for ns_clone() reuse but
    # the parent's view (ns 0) has been untouched the whole time.
    status: int64 = sys_waitpid(cast[uint64](pid))
    if status < 0:
        write_str(1, "[ns_isolation] FAIL: parent waitpid returned -errno\n")
        return 9

    # The parent's binding /myalias -> /etc MUST still be live.
    pfd: int32 = sys_open("/myalias/inittab")
    if pfd < 0:
        write_str(1, "[ns_isolation] FAIL: parent /myalias/inittab lost after child exit\n")
        return 10
    # Drain a few bytes to confirm the fd is real.
    buf: Array[16, uint8]
    n: int64 = sys_read(pfd, &buf[0], 16)
    if n <= 0:
        write_str(1, "[ns_isolation] FAIL: parent read /myalias/inittab post-child\n")
        sys_close(pfd)
        return 11
    sys_close(pfd)
    write_str(1, "[ns_isolation] parent /myalias/inittab ok post-child\n")

    # And the parent MUST NOT have inherited the child's bind:
    # /myalias/cat does not exist in the parent's row.
    pfd2: int32 = sys_open("/myalias/cat")
    if pfd2 >= 0:
        write_str(1, "[ns_isolation] FAIL: parent /myalias/cat resolves (child's bind leaked!)\n")
        sys_close(pfd2)
        return 12
    write_str(1, "[ns_isolation] parent /myalias/cat missing (expected)\n")

    # Clean up the parent's binding so a re-run from the same hamsh
    # doesn't trip over a leftover row.
    do_unmount("/myalias")

    write_str(1, "[ns_isolation] PASS\n")
    return 0

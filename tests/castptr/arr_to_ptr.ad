# cast[Ptr[T]](array_local) must DECAY the array to its base ADDRESS (&x[0]),
# like C array->pointer decay — NOT value-load the first element. This is the
# #296 seed-vs-native divergence: the seed leaq-decays the aggregate local; the
# native backend was value-loading. Kept byte-lockstep under objdiff.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    x: Array[4, int32]
    x[0] = 11
    x[1] = 22
    x[2] = 33
    x[3] = 44
    p: Ptr[int32] = cast[Ptr[int32]](x)
    # p points at x[0]; p[2] must read 33 (proves p is the base address, not a
    # value-loaded first element).
    return p[2]

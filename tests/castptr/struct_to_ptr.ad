# cast[Ptr[int32]](struct_local) must decay the in-place struct value to its
# base ADDRESS, not value-load its first field. Same #296 aggregate-decay path.
class Pt:
    x: int32
    y: int32

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    s: Pt
    s.x = 7
    s.y = 9
    p: Ptr[int32] = cast[Ptr[int32]](s)
    # p[0] = s.x = 7, p[1] = s.y = 9
    return p[0] + p[1]

# A bare aggregate identifier consumed as a value (through a cast to uint64
# address then back to Ptr) must be the base address. Exercises the decay when
# the array feeds an integer cast, then a pointer cast.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    x: Array[3, int32]
    x[0] = 100
    x[1] = 200
    x[2] = 300
    addr: uint64 = cast[uint64](x)
    p: Ptr[int32] = cast[Ptr[int32]](addr)
    return p[1]

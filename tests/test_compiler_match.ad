# tests/test_compiler_match.ad
#
# Regression fixture for the Adder `match`/`case` statement
# (parser.py: parse_pattern + parse_statement match branch;
#  codegen_x86.py: gen_stmt's MatchStmt case + _gen_match lowering).
#
# Each function exercises one pattern class and returns a small
# integer encoding "which arm fired" so the host driver
# (scripts/test_compiler_match.sh) can assert the chain dispatches
# the same way Python's `match` does:
#
#   * Literal pattern        — case 0:, case 1: ... case _:
#   * OR pattern             — case 2 | 4 | 6: ...
#   * Wildcard fallback      — case _: ...
#   * Name binding           — case x: bound x must equal the scrutinee
#   * Guard                  — case x if x > 100:
#   * Sequence pattern       — case [1, 2]:, case [1, x]:, case [*rest]:
#   * Negative-int literal   — case -1:

extern def boom() -> int64

# --- 1. Literal + wildcard default --------------------------------
# `case 0` / `case 1` / `case 2` and a `_` fallback.
def lit_or_default(x: int64) -> int64:
    match x:
        case 0:
            return 10
        case 1:
            return 11
        case 2:
            return 12
        case _:
            return 99

# --- 2. OR pattern ------------------------------------------------
# Returns 1 if x is in {2, 4, 6}, else 0.
def or_even_small(x: int64) -> int64:
    match x:
        case 2 | 4 | 6:
            return 1
        case _:
            return 0

# --- 3. Name binding ----------------------------------------------
# `case y` binds y to the scrutinee — return y, which should always
# equal the input.
def name_binding(x: int64) -> int64:
    match x:
        case y:
            return y + 1

# --- 4. Guards ----------------------------------------------------
# `case x if x > 100` fires only when guard holds; otherwise the
# wildcard `_` returns 0.
def guarded(x: int64) -> int64:
    match x:
        case y if y > 100:
            return y * 2
        case _:
            return 0

# --- 5. Negative-int literal --------------------------------------
def neg_literal(x: int64) -> int64:
    match x:
        case -1:
            return 1
        case 0:
            return 2
        case _:
            return 3

# --- 6. Order of arms (first match wins) --------------------------
# `case 5` must fire before `case _`; if codegen falls through, the
# wildcard arm's `boom()` would abort.
def first_match_wins(x: int64) -> int64:
    match x:
        case 5:
            return 50
        case _:
            return cast[int64](boom())

# --- 7. Sequence pattern over a Ptr[int64] buffer -----------------
# C-ABI: the C driver passes &arr[0] as a long* — Adder receives a
# Ptr[int64] and IndexExpr lowers to base+disp loads. Matches
# [1, 2] exactly, then [1, x] (binds x to arr[1]), then falls
# through. Length isn't checked at runtime (no len() primitive);
# the caller passes a long-enough buffer.
def seq_two(arr: Ptr[int64]) -> int64:
    match arr:
        case [1, 2]:
            return 100
        case [1, x]:
            return 200 + x
        case _:
            return 0

# --- 8. Sequence pattern with a rest binding ----------------------
# `*rest` is parsed and accepted; binding semantics are weak (no
# slices) — but the prefix elements still constrain the match. Here
# we only assert dispatch (the [0,...] arm fires for arr[0]==0).
def seq_rest(arr: Ptr[int64]) -> int64:
    match arr:
        case [0, *rest]:
            return 1
        case _:
            return 0

# tests/test_compiler_sext_widen.ad
#
# Regression fixture for the Adder x86_64 backend's integer-WIDENING
# lowering (codegen_x86.py: the CastExpr case + _emit_cast_widen).
#
# Bug (documented 2026-06-02 during #236 oom_score_adj): widening a
# RUNTIME signed narrower integer to a wider one via `cast[int64](x)`
# ZERO-extended instead of SIGN-extending. A negative int32 like -1000
# (0xFFFFFC18) widened to 0x00000000FFFFFC18 instead of the correct
# 0xFFFFFFFFFFFFFC18, so every subsequent SIGNED int64 compare/arith was
# wrong. The sneaky part: a compile-time int32 CONSTANT already
# sign-extends in its loader, so only RUNTIME values (function returns,
# array elements, parameters, plain variables) were bitten — and even
# the `cast[int64](cast[int32](x))` idiom did NOT fix it.
#
# Correct C-like rule: widening a SIGNED narrower integer sign-extends;
# widening an UNSIGNED narrower integer zero-extends.
#
# Each helper widens a runtime narrow value to int64 and returns it. The
# host driver (scripts/test_compiler_sext_widen.sh) compares the returned
# 64-bit pattern against the C-correct sign/zero-extended value. Functions
# return int64 so the full 64-bit result is observable.

# A runtime int32 producer (NOT a compile-time literal at the call site).
def make_i32(x: int32) -> int32:
    return x

# --- widen a FUNCTION RETURN VALUE (runtime int32 -> int64) ----------
def widen_ret_i32(x: int32) -> int64:
    return cast[int64](make_i32(x))

# --- widen a PARAMETER (runtime int32 -> int64) ----------------------
def widen_param_i32(x: int32) -> int64:
    return cast[int64](x)

# --- widen a PLAIN LOCAL VARIABLE (runtime int32 -> int64) -----------
def widen_local_i32(x: int32) -> int64:
    v: int32 = x
    return cast[int64](v)

# --- widen an ARRAY ELEMENT (runtime int32 -> int64) -----------------
def widen_array_i32(x: int32) -> int64:
    arr: Array[4, int32]
    arr[0] = x
    arr[1] = 0
    arr[2] = 0
    arr[3] = 0
    return cast[int64](arr[0])

# --- the doubly-cast idiom that ALSO used to fail --------------------
def widen_double_cast_i32(x: int32) -> int64:
    return cast[int64](cast[int32](x))

# --- narrower signed sources: int16 and int8 -------------------------
def widen_param_i16(x: int16) -> int64:
    return cast[int64](x)

def widen_param_i8(x: int8) -> int64:
    return cast[int64](x)

# --- UNSIGNED source must STAY zero-extended (no sign bleak) ----------
def widen_param_u32(x: uint32) -> int64:
    return cast[int64](x)

def widen_param_u16(x: uint16) -> int64:
    return cast[int64](x)

# --- a signed int64 compare downstream of the widen (the real bug
#     shape: a negative widened value must compare < 0) ----------------
def widened_is_negative(x: int32) -> int64:
    w: int64 = cast[int64](make_i32(x))
    if w < 0:
        return 1
    return 0

# tests/test_devsys.ad
#
# Combined regression for /dev/stat + /dev/mounts + /dev/diskstats.
# Sibling to tests/test_devuptime.ad / test_devloadavg.ad / test_devsysinfo.ad
# except all three cdevs ship in one commit (M16.135) so we exercise them
# from one fixture instead of three separate ones — keeps the QEMU
# round-trip count down (one boot covers the whole introspection trio).
#
# For each cdev we:
#   1. open the path for read,
#   2. drain into a stack buffer,
#   3. assert the blob has the expected shape (line count + a
#      distinctive substring per cdev),
#   4. echo a PASS marker the script greps for.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devsys.ad -o build/user/test_devsys.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Count newline-terminated lines in buf[0..n]. A trailing partial line
# (no final '\n') counts too. Returns the line count.
def _count_lines(buf: Ptr[uint8], n: uint64) -> uint64:
    lines: uint64 = 0
    i: uint64 = 0
    has_partial: int32 = 0
    while i < n:
        if buf[i] == 10:                          # '\n'
            lines = lines + 1
            has_partial = 0
        else:
            has_partial = 1
        i = i + 1
    if has_partial != 0:
        lines = lines + 1
    return lines


# Returns 1 if `needle` appears anywhere in buf[0..n], else 0. Naive
# byte scan — `needle` is NUL-terminated and short (single-word
# distinctive token per cdev), so cost is in the noise.
def _contains(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen(needle)
    if nlen == 0:
        return 1
    if nlen > n:
        return 0
    last: uint64 = n - nlen + 1
    i: uint64 = 0
    while i < last:
        # Adder may treat `match` as a reserved keyword (Python's
        # match/case). Use `hit` to side-step the parser.
        hit: int32 = 1
        j: uint64 = 0
        while j < nlen:
            if buf[i + j] != needle[j]:
                hit = 0
                j = nlen
            else:
                j = j + 1
        if hit == 1:
            return 1
        i = i + 1
    return 0


# --- per-cdev probes -------------------------------------------------
#
# Each returns 1 on PASS, 0 on FAIL. Failures already write a clear
# diagnostic to stdout before returning so the script's log surfaces
# the WHY.

def _probe_devstat() -> int32:
    write_str(1, "[test_devsys] probing /dev/stat\n")
    fd: int32 = sys_open("/dev/stat")
    if fd < 0:
        write_str(1, "[test_devsys] /dev/stat open FAIL\n")
        return 0
    buf: Array[512, uint8]
    n: int64 = sys_read(fd, &buf[0], 384)
    sys_close(fd)
    if n <= 0:
        write_str(1, "[test_devsys] /dev/stat read returned <= 0\n")
        return 0
    write_str(1, "[test_devsys] devstat blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))
    # /proc/stat MUST contain "cpu" (the first row) and a "btime"
    # row. Both are baseline tokens userland sscanf'ers look for.
    if _contains(&buf[0], cast[uint64](n), "cpu") == 0:
        write_str(1, "[test_devsys] /dev/stat missing 'cpu' row\n")
        return 0
    if _contains(&buf[0], cast[uint64](n), "btime") == 0:
        write_str(1, "[test_devsys] /dev/stat missing 'btime' row\n")
        return 0
    # Expect at least 5 lines (cpu, cpu0, intr, ctxt, btime,
    # processes — six rows total; allow >=5 for a margin in case a
    # row gets dropped by a future scope change).
    lines: uint64 = _count_lines(&buf[0], cast[uint64](n))
    if lines < 5:
        write_str(1, "[test_devsys] /dev/stat line count too low\n")
        return 0
    write_str(1, "[devstat] ok\n")
    return 1


def _probe_devmounts() -> int32:
    write_str(1, "[test_devsys] probing /dev/mounts\n")
    fd: int32 = sys_open("/dev/mounts")
    if fd < 0:
        write_str(1, "[test_devsys] /dev/mounts open FAIL\n")
        return 0
    buf: Array[2048, uint8]
    n: int64 = sys_read(fd, &buf[0], 2048)
    sys_close(fd)
    if n <= 0:
        write_str(1, "[test_devsys] /dev/mounts read returned <= 0\n")
        return 0
    write_str(1, "[test_devsys] devmounts blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))
    # The synthetic root row is "rootfs / cpio ro 0 0\n" — present
    # on any boot regardless of mnttab population. We grep for
    # "rootfs" as the cheap-and-stable substring.
    if _contains(&buf[0], cast[uint64](n), "rootfs") == 0:
        write_str(1, "[test_devsys] /dev/mounts missing 'rootfs' row\n")
        return 0
    # And expect at least one line (the synthetic root); >=1 is the
    # PASS criterion per the spec.
    lines: uint64 = _count_lines(&buf[0], cast[uint64](n))
    if lines < 1:
        write_str(1, "[test_devsys] /dev/mounts line count 0\n")
        return 0
    write_str(1, "[devmounts] ok\n")
    return 1


def _probe_devdiskstats() -> int32:
    write_str(1, "[test_devsys] probing /dev/diskstats\n")
    fd: int32 = sys_open("/dev/diskstats")
    if fd < 0:
        write_str(1, "[test_devsys] /dev/diskstats open FAIL\n")
        return 0
    buf: Array[3072, uint8]
    n: int64 = sys_read(fd, &buf[0], 3072)
    sys_close(fd)
    if n < 0:
        write_str(1, "[test_devsys] /dev/diskstats read returned < 0\n")
        return 0
    # Even with zero registered devices the read MUST succeed (it's a
    # stateless render). At least one blockdev should be registered
    # on the boot we care about (ram0 is registered by brd_init()), so
    # the row count is >=1 — PASS criterion per the spec.
    if n == 0:
        write_str(1, "[test_devsys] /dev/diskstats empty (no devs?)\n")
        return 0
    write_str(1, "[test_devsys] devdiskstats blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))
    lines: uint64 = _count_lines(&buf[0], cast[uint64](n))
    if lines < 1:
        write_str(1, "[test_devsys] /dev/diskstats line count 0\n")
        return 0
    write_str(1, "[devdiskstats] ok\n")
    return 1


def main() -> int32:
    write_str(1, "[test_devsys] start\n")

    ok_stat: int32 = _probe_devstat()
    ok_mt:   int32 = _probe_devmounts()
    ok_ds:   int32 = _probe_devdiskstats()

    if ok_stat == 0 or ok_mt == 0 or ok_ds == 0:
        write_str(1, "[test_devsys] FAIL\n")
        return 1

    write_str(1, "[test_devsys] done\n")
    return 0

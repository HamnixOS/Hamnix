# tests/dispatcher.ad
#
# F10-5 (#457) split surface: the single import point through which
# init/main.ad pulls every kernel-side `*_smoke_test` / `*_selftest`
# / `*_exercise` body that used to live inline in init/main.ad.
#
# Bodies live under tests/<subsystem>_smoke.ad (mm, core, net, fs,
# block, storage, usb). This module re-exports the names by simply
# importing them — Adder's flat module surface (see linux_abi/u_syscalls.ad
# re-export of fuse_selftest from linux_abi.u_fuse) makes a from-import
# here sufficient to make the symbol available through
# `from tests.dispatcher import <name>`.
#
# The audit (F10-5) called for a single run_selftests_if_flag() entry
# point. The original boot orchestration in start_kernel() interleaves
# each selftest with finely-ordered driver bring-up and marker checks,
# so a single dispatcher function would have to mirror start_kernel's
# whole call graph. Instead this module is the dispatcher AS A NAMESPACE:
# init/main.ad imports every selftest name from here and calls them at
# their existing gates, but the BODIES are out of main.ad. Boot policy
# now reads top-to-bottom in init/main.ad without test surface area
# interleaved with it.

from tests.mm_smoke import (
    memblock_smoke_test, page_alloc_smoke_test, page_alloc_coalesce_test,
    page_alloc_stress_test,
    slab_smoke_test,
    mmap_file_selftest, mmap_shared_selftest,
)
from tests.fs_smoke import (
    loop_e2e_selftest,
    iso9660_e2e_selftest,
    ntfs_e2e_selftest,
    v9p_e2e_selftest,
    btrfs_e2e_selftest,
)
from tests.net_smoke import (
    packet_count_hook,
    net_smoke_test,
    msix_smoke_test, msix_pool_smoke_test,
    tcp_smoke_test, devnet_smoke_test,
    tcp_ring_smoke_test, tcp_fin_wait2_smoke_test,
    tcp_reconnect_smoke_test, tcp_throughput_smoke_test,
    http_smoke_test,
    https_local_smoke_test, https_smoke_test,
    https_chunked_smoke_test, https_gzip_smoke_test,
    http_redirect_smoke_test,
)
# block_smoke_test + blkwrite_smoke_test were NOT extracted: they
# wire init-local helpers (_live_root_mount, _synthesise_partuuid,
# _try_parse_hamnix_roots, HAMNIX_ROOTS_OK, byid_register) into the
# loop driver via loop_set_live_root_hook(), and the rootfs name-push
# / by-id register machinery they depend on lives only in init/main.ad.
# Pulling them out would either drag the whole Plan 9-rootfs helper
# block (~300 lines + 4 globals) with them or require a circular
# `from init.main import _live_root_mount` (Adder does not import its
# program entry module). Per F10-5 brief escape hatch: documented and
# left in place. See commit body for full rationale.
from tests.storage_smoke import (
    ahci_io_exercise, nvme_io_exercise, xhci_io_exercise,
    cpio_capacity_smoke_test,
)
from tests.usbms_smoke import usbms_exercise
from tests.core_smoke import (
    string_ops_smoke_test,
    list_smoke_test,
    vga_smoke_test,
    tsc_test_run,
    diag_smoke_test,
    backtrace_selftest,
)

# tests/dropplace_host.ad — HOST unit test for lib/dropplace.ad (#327).
#
# Built for the x86_64-linux Adder target; runs on the dev host, no QEMU.
# Exercises the SAME pure drag-drop placement helpers the live panel
# (hampanelscene) and desktop (hamdesktop) ship, so the DROP-LOCATION
# behaviour is proven DETERMINISTICALLY — without a flaky /dev/mouse drag:
#
#   * dp_panel_insert_index maps a DROP flow-X to an insertion index that
#     TRACKS the coordinate (low X -> low index, far-right X -> APPEND),
#     never the old fixed "index 1 next to the Apps button" spot.
#   * dp_desktop_entry builds a well-formed freedesktop .desktop launcher
#     for an app dropped onto the desktop.
#
# TEST shim only: no syscalls except write(2) to fd 1 for the assertions.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from lib.dropplace import dp_panel_insert_index, dp_panel_insert_boundary, \
    dp_desktop_entry


# ---- stdout helpers ------------------------------------------------------
obuf: Array[512, uint8]
obuf_n: uint64 = 0

def _o_ch(c: uint8):
    if obuf_n < 511:
        obuf[obuf_n] = c
        obuf_n = obuf_n + 1

def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1

def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0

def _o_dec(v: int64):
    if v < 0:
        _o_ch(45)
        v = 0 - v
    if v == 0:
        _o_ch(48)
        return
    digs: Array[24, uint8]
    n: uint64 = 0
    while v > 0:
        digs[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    while n > 0:
        n = n - 1
        _o_ch(digs[n])


# A representative laid-out panel: WK_MENU at flow 0, then three widgets.
# (wx0[] holds each widget's START coordinate, exactly as _layout_panel sets.)
wx0: Array[4, int64]
wx1: Array[4, int64]


def _emit_panel(flow: int64):
    idx: int64 = dp_panel_insert_index(flow, &wx0[0], 4)
    _o_str(cast[Ptr[uint8]]("PANEL flow="))
    _o_dec(flow)
    _o_str(cast[Ptr[uint8]](" idx="))
    _o_dec(idx)
    _o_ch(10)


# LIVE DROP PREVIEW: the boundary coordinate at which the panel draws the
# insertion indicator while a drag hovers the bar — the visual twin of the
# insert index, midway between the two widgets the launcher would land between.
def _emit_preview(flow: int64):
    at: int64 = dp_panel_insert_boundary(flow, &wx0[0], &wx1[0], 4)
    _o_str(cast[Ptr[uint8]]("PREVIEW flow="))
    _o_dec(flow)
    _o_str(cast[Ptr[uint8]](" at="))
    _o_dec(at)
    _o_ch(10)


entry: Array[256, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    wx0[0] = 0                              # Applications menu button
    wx0[1] = 104                            # widget 1
    wx0[2] = 240                            # widget 2
    wx0[3] = 360                            # widget 3
    wx1[0] = 96                             # each widget's END coordinate
    wx1[1] = 200
    wx1[2] = 336
    wx1[3] = 440

    # A drop just past the menu lands right after it (index 1).
    _emit_panel(10)
    # A drop mid-bar lands mid-list (honors X).
    _emit_panel(250)
    # A drop at the FAR RIGHT appends at the end (index 4) — the key proof
    # that placement follows the drop, not a fixed spot.
    _emit_panel(500)
    # A drop before everything lands at index 0.
    _emit_panel(-5)

    # LIVE DROP PREVIEW boundaries (the insertion caret coordinate), which must
    # track the cursor and sit BETWEEN the neighbouring widgets:
    _emit_preview(10)     # idx 1 -> midway between wx1[0]=96 and wx0[1]=104 = 100
    _emit_preview(250)    # idx 3 -> midway between wx1[2]=336 and wx0[3]=360 = 348
    _emit_preview(500)    # append -> just past the last widget end (442)
    _emit_preview(-5)     # before everything -> clamped left edge (1)

    # Desktop .desktop launcher body for an app dropped on the desktop.
    n: uint64 = dp_desktop_entry(&entry[0], cast[Ptr[uint8]]("Text_Editor"),
                                 cast[Ptr[uint8]]("/bin/hamtext"))
    _o_str(cast[Ptr[uint8]]("DESKTOP len="))
    _o_dec(cast[int64](n))
    _o_ch(10)
    # Emit the raw body so the gate can grep its lines.
    i: uint64 = 0
    while i < n:
        _o_ch(entry[i])
        i = i + 1
    _o_ch(10)

    _o_flush()
    return 0

# tests/test_distrofs.ad
#
# Smoke fixture for user/distrofs.ad — the userland 9P2000 file-server
# daemon that exports a distro-shaped, RAM-backed filesystem tree.
#
# This drives distrofs end-to-end as a userspace 9P client over a pair
# of pipes (same topology as tests/test_p9srv_demo.ad), proving a full
# create/write/clunk/re-walk/open/read round-trip plus directory stat.
#
# WIRE TOPOLOGY
# -------------
#   sys_pipe(c2s)   # fixture writes T-msgs into c2s[1]; server reads c2s[0]
#   sys_pipe(s2c)   # server writes R-msgs into s2c[1]; fixture reads s2c[0]
#   sys_spawn("/bin/distrofs", _, c2s[0], s2c[1], _)
#     -> child inherits c2s[0] as fd 0 and s2c[1] as fd 1
#
# ROUND TRIP UNDER TEST
# ---------------------
#   1. Tversion("9P2000", 8192)            -> Rversion
#   2. Tattach(root_fid)                   -> Rattach (root QTDIR)
#   3. Twalk(root_fid -> dpkg_fid, var/lib/dpkg)  -> Rwalk (3 qids, QTDIR)
#   4. Tcreate(dpkg_fid, "status", file)   -> Rcreate (status.txt, QTFILE)
#   5. Twrite(dpkg_fid, payload)           -> Rwrite (count == payload len)
#   6. Tclunk(dpkg_fid)                    -> Rclunk
#   7. Twalk(root_fid -> read_fid, var/lib/dpkg/status) -> Rwalk (4 qids)
#   8. Topen(read_fid, OREAD)              -> Ropen
#   9. Tread(read_fid)                     -> Rread, payload compared
#  10. Tclunk(read_fid)                    -> Rclunk
#  11. Twalk(root_fid -> stat_fid, var)    -> Rwalk
#  12. Tstat(stat_fid)                     -> Rstat, asserts QTDIR
#
# Markers grepped by scripts/test_distrofs.sh:
#   [distrofs] start
#   [distrofs] spawn OK
#   [distrofs] Rversion OK
#   [distrofs] Rattach OK
#   [distrofs] Rwalk dpkg OK
#   [distrofs] Rcreate OK
#   [distrofs] Rwrite OK
#   [distrofs] Rwalk status OK
#   [distrofs] Ropen OK
#   [distrofs] payload match OK
#   [distrofs] Rstat dir OK
#   [distrofs] PASS
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_distrofs.ad -o build/user/test_distrofs.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_waitpid(pid: int32) -> int64
extern def sys_exit(code: uint64)
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_spawn(path: Ptr[char], argv: Ptr[uint64],
                     stdin_fd: int32, stdout_fd: int32,
                     envp: Ptr[uint64]) -> int32

from lib.9p.9p import (
    P9Cursor, p9_cursor_init,
    p9_decode_header,
    p9_emit_tversion, p9_decode_rversion,
    p9_emit_tattach,  p9_decode_rattach,
    p9_emit_twalk,    p9_decode_rwalk,
    p9_emit_topen,    p9_decode_ropen,
    p9_emit_tcreate,  p9_decode_rcreate,
    p9_emit_tread,    p9_decode_rread,
    p9_emit_twrite,   p9_decode_rwrite,
    p9_emit_tclunk,   p9_decode_rclunk,
    p9_emit_tstat,    p9_decode_rstat,
    p9_decode_rerror,
    P9_NOFID, P9_NOTAG,
    P9_OREAD, P9_ORDWR, P9_QTFILE, P9_QTDIR,
    P9_RERROR,
)

# Top-level scratch buffers (Adder nested-frame Array bug avoidance).
CLI_BUF_CAP: uint64 = 8192
cli_buf: Array[8192, uint8]                       # outgoing T-msgs
rsp_buf: Array[8192, uint8]                       # incoming R-msgs

c2s_fds: Array[2, int32]
s2c_fds: Array[2, int32]
spawn_argv: Array[2, uint64]
err_buf: Array[128, uint8]

# Walk-name pointer arrays (top-level — P9_MAX_WELEM = 16).
walk_names: Array[16, Ptr[uint8]]
walk_lens:  Array[16, uint64]
walk_qtypes_in: Array[16, uint8]
walk_qvers_in:  Array[16, uint32]
walk_qpaths_in: Array[16, uint64]

# Path-component literal storage. distrofs's tree has /var/lib/dpkg as
# its dpkg DB directory; we Tcreate "status" there.
comp_var:    Array[8, uint8] = "var"
comp_lib:    Array[8, uint8] = "lib"
comp_dpkg:   Array[8, uint8] = "dpkg"
comp_status: Array[8, uint8] = "status"

# The bytes we Twrite and expect back on Tread.
payload: Array[32, uint8] = "deb-status:installed"
PAYLOAD_LEN: uint64 = 20

# Fid plan.
ROOT_FID:   uint32 = 0
DPKG_FID:   uint32 = 1
READ_FID:   uint32 = 2
STAT_FID:   uint32 = 3


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


# --- pipe I/O helpers -------------------------------------------------

def _read_exact(fd: int32, buf: Ptr[uint8], want: uint64) -> int64:
    got: uint64 = 0
    while got < want:
        n: int64 = sys_read(fd, &buf[got], want - got)
        if n <= 0:
            return n
        got = got + cast[uint64](n)
    return cast[int64](got)


def _send_tmsg(tx_fd: int32, n: int32) -> int32:
    if n <= 0:
        return -1
    sent: int64 = sys_write(tx_fd, &cli_buf[0], cast[uint64](n))
    if sent != cast[int64](n):
        return -1
    return 0


def _recv_rmsg(rx_fd: int32) -> int32:
    h: int64 = _read_exact(rx_fd, &rsp_buf[0], 7)
    if h != cast[int64](7):
        return -1
    sz: uint32 = 0
    ty: uint8 = 0
    tg: uint16 = 0
    rc: int32 = p9_decode_header(&rsp_buf[0], 7, &sz, &ty, &tg)
    if rc != 0:
        return -1
    total: uint64 = cast[uint64](sz)
    if total < 7 or total > CLI_BUF_CAP:
        return -1
    if total > 7:
        b: int64 = _read_exact(rx_fd, &rsp_buf[7], total - 7)
        if b != cast[int64](total - 7):
            return -1
    return cast[int32](total)


def _dump_rerror():
    # When rsp_buf holds an Rerror, print its ename for diagnosis.
    tg: uint16 = 0
    ep: Ptr[uint8] = cast[Ptr[uint8]](0)
    el: uint64 = 0
    rc: int64 = p9_decode_rerror(&rsp_buf[0], CLI_BUF_CAP, &tg, &ep, &el)
    if rc < cast[int64](0):
        return
    write_str(1, "[distrofs]   Rerror: ")
    sys_write(1, ep, el)
    write_str(1, "\n")


# --- 9P client legs ---------------------------------------------------

def _client_version(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    ver: Array[8, uint8]
    ver[0] = 57    # '9'
    ver[1] = 80    # 'P'
    ver[2] = 50    # '2'
    ver[3] = 48
    ver[4] = 48
    ver[5] = 48
    n: int32 = p9_emit_tversion(&c, P9_NOTAG, 8192, &ver[0], 6)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    ms: uint32 = 0
    vptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    vlen: uint64 = 0
    rc: int64 = p9_decode_rversion(&rsp_buf[0], cast[uint64](rn),
                                   &tg, &ms, &vptr, &vlen)
    if rc < cast[int64](0):
        return -1
    write_str(1, "[distrofs] Rversion OK\n")
    return 0


def _client_attach(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    empty: Array[1, uint8]
    empty[0] = 0
    n: int32 = p9_emit_tattach(&c, 1, ROOT_FID, P9_NOFID,
                               &empty[0], 0, &empty[0], 0)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    rc: int64 = p9_decode_rattach(&rsp_buf[0], cast[uint64](rn),
                                  &tg, &qt, &qv, &qp)
    if rc < cast[int64](0):
        return -1
    if qt != P9_QTDIR:
        return -1
    write_str(1, "[distrofs] Rattach OK\n")
    return 0


# Walk from ROOT_FID to newfid along the supplied component list.
def _client_walk(tx: int32, rx: int32, newfid: uint32,
                 ncomp: uint16) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_twalk(&c, 2, ROOT_FID, newfid, ncomp,
                             &walk_names[0], &walk_lens[0])
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    nq: uint16 = 0
    rc: int64 = p9_decode_rwalk(&rsp_buf[0], cast[uint64](rn),
                                &tg, &nq,
                                &walk_qtypes_in[0],
                                &walk_qvers_in[0],
                                &walk_qpaths_in[0])
    if rc < cast[int64](0):
        return -1
    if nq != ncomp:
        write_str(1, "[distrofs] FAIL: partial walk\n")
        return -1
    return 0


def _client_walk_dpkg(tx: int32, rx: int32) -> int32:
    walk_names[0] = &comp_var[0]
    walk_lens[0]  = 3
    walk_names[1] = &comp_lib[0]
    walk_lens[1]  = 3
    walk_names[2] = &comp_dpkg[0]
    walk_lens[2]  = 4
    if _client_walk(tx, rx, DPKG_FID, 3) < 0:
        return -1
    if walk_qtypes_in[2] != P9_QTDIR:
        write_str(1, "[distrofs] FAIL: dpkg not a directory\n")
        return -1
    write_str(1, "[distrofs] Rwalk dpkg OK\n")
    return 0


def _client_create_status(tx: int32, rx: int32) -> int32:
    # Tcreate "status" inside the DPKG_FID directory as a regular file.
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_tcreate(&c, 3, DPKG_FID,
                               &comp_status[0], 6, 0x1FF, P9_ORDWR)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    iou: uint32 = 0
    rc: int64 = p9_decode_rcreate(&rsp_buf[0], cast[uint64](rn),
                                  &tg, &qt, &qv, &qp, &iou)
    if rc < cast[int64](0):
        return -1
    if qt != P9_QTFILE:
        write_str(1, "[distrofs] FAIL: created node not a file\n")
        return -1
    write_str(1, "[distrofs] Rcreate OK\n")
    return 0


def _client_write_status(tx: int32, rx: int32) -> int32:
    # After Tcreate, DPKG_FID references the new file, open for I/O.
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_twrite(&c, 4, DPKG_FID, 0,
                              &payload[0], cast[uint32](PAYLOAD_LEN))
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    count: uint32 = 0
    rc: int64 = p9_decode_rwrite(&rsp_buf[0], cast[uint64](rn),
                                 &tg, &count)
    if rc < cast[int64](0):
        return -1
    if cast[uint64](count) != PAYLOAD_LEN:
        write_str(1, "[distrofs] FAIL: short write\n")
        return -1
    write_str(1, "[distrofs] Rwrite OK\n")
    return 0


def _client_clunk(tx: int32, rx: int32, fid: uint32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_tclunk(&c, 5, fid)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    rc: int64 = p9_decode_rclunk(&rsp_buf[0], cast[uint64](rn), &tg)
    if rc < cast[int64](0):
        return -1
    return 0


def _client_walk_status(tx: int32, rx: int32) -> int32:
    # Re-walk root -> var/lib/dpkg/status into a fresh fid.
    walk_names[0] = &comp_var[0]
    walk_lens[0]  = 3
    walk_names[1] = &comp_lib[0]
    walk_lens[1]  = 3
    walk_names[2] = &comp_dpkg[0]
    walk_lens[2]  = 4
    walk_names[3] = &comp_status[0]
    walk_lens[3]  = 6
    if _client_walk(tx, rx, READ_FID, 4) < 0:
        return -1
    if walk_qtypes_in[3] != P9_QTFILE:
        write_str(1, "[distrofs] FAIL: status not a file\n")
        return -1
    write_str(1, "[distrofs] Rwalk status OK\n")
    return 0


def _client_open_status(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_topen(&c, 6, READ_FID, P9_OREAD)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    iou: uint32 = 0
    rc: int64 = p9_decode_ropen(&rsp_buf[0], cast[uint64](rn),
                                &tg, &qt, &qv, &qp, &iou)
    if rc < cast[int64](0):
        return -1
    if qt != P9_QTFILE:
        return -1
    write_str(1, "[distrofs] Ropen OK\n")
    return 0


def _client_read_status(tx: int32, rx: int32) -> int32:
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_tread(&c, 7, READ_FID, 0, 256)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    dptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    count: uint32 = 0
    rc: int64 = p9_decode_rread(&rsp_buf[0], cast[uint64](rn),
                                &tg, &dptr, &count)
    if rc < cast[int64](0):
        return -1
    if cast[uint64](count) != PAYLOAD_LEN:
        write_str(1, "[distrofs] FAIL: read count mismatch\n")
        return -1
    i: uint64 = 0
    while i < PAYLOAD_LEN:
        if dptr[i] != payload[i]:
            write_str(1, "[distrofs] FAIL: payload mismatch\n")
            return -1
        i = i + 1
    write_str(1, "[distrofs] payload match OK\n")
    return 0


def _client_stat_var(tx: int32, rx: int32) -> int32:
    # Walk to /var, then Tstat it and assert it is a directory.
    walk_names[0] = &comp_var[0]
    walk_lens[0]  = 3
    if _client_walk(tx, rx, STAT_FID, 1) < 0:
        return -1
    c: P9Cursor
    p9_cursor_init(&c, &cli_buf[0], CLI_BUF_CAP)
    n: int32 = p9_emit_tstat(&c, 8, STAT_FID)
    if n < 0:
        return -1
    if _send_tmsg(tx, n) < 0:
        return -1
    rn: int32 = _recv_rmsg(rx)
    if rn < 0:
        return -1
    if rsp_buf[4] == P9_RERROR:
        _dump_rerror()
        return -1
    tg: uint16 = 0
    st_type: uint16 = 0
    dev: uint32 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    mode: uint32 = 0
    atime: uint32 = 0
    mtime: uint32 = 0
    length: uint64 = 0
    np: Ptr[uint8] = cast[Ptr[uint8]](0)
    nl: uint64 = 0
    up: Ptr[uint8] = cast[Ptr[uint8]](0)
    ul: uint64 = 0
    gp: Ptr[uint8] = cast[Ptr[uint8]](0)
    gl: uint64 = 0
    mp: Ptr[uint8] = cast[Ptr[uint8]](0)
    ml: uint64 = 0
    rc: int64 = p9_decode_rstat(&rsp_buf[0], cast[uint64](rn),
                                &tg, &st_type, &dev,
                                &qt, &qv, &qp,
                                &mode, &atime, &mtime, &length,
                                &np, &nl, &up, &ul,
                                &gp, &gl, &mp, &ml)
    if rc < cast[int64](0):
        return -1
    if qt != P9_QTDIR:
        write_str(1, "[distrofs] FAIL: /var stat not QTDIR\n")
        return -1
    if nl != 3:
        write_str(1, "[distrofs] FAIL: /var stat name length\n")
        return -1
    write_str(1, "[distrofs] Rstat dir OK\n")
    return 0


def main() -> int32:
    write_str(1, "[distrofs] start\n")

    if sys_pipe(&c2s_fds[0]) < 0:
        dump_errstr("[distrofs] FAIL: sys_pipe c2s errstr=")
        return 2
    if sys_pipe(&s2c_fds[0]) < 0:
        dump_errstr("[distrofs] FAIL: sys_pipe s2c errstr=")
        return 3

    c2s_rfd: int32 = c2s_fds[0]
    c2s_wfd: int32 = c2s_fds[1]
    s2c_rfd: int32 = s2c_fds[0]
    s2c_wfd: int32 = s2c_fds[1]

    spawn_argv[0] = cast[uint64](&"/bin/distrofs"[0])
    spawn_argv[1] = 0
    pid: int32 = sys_spawn("/bin/distrofs", &spawn_argv[0],
                           c2s_rfd, s2c_wfd, cast[Ptr[uint64]](0))
    if pid < 0:
        dump_errstr("[distrofs] FAIL: sys_spawn errstr=")
        return 4
    write_str(1, "[distrofs] spawn OK\n")

    sys_close(c2s_rfd)
    sys_close(s2c_wfd)

    if _client_version(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Tversion exchange\n")
        return 5
    if _client_attach(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Tattach exchange\n")
        return 6
    if _client_walk_dpkg(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Twalk var/lib/dpkg\n")
        return 7
    if _client_create_status(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Tcreate status\n")
        return 8
    if _client_write_status(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Twrite status\n")
        return 9
    if _client_clunk(c2s_wfd, s2c_rfd, DPKG_FID) < 0:
        write_str(1, "[distrofs] FAIL: Tclunk dpkg fid\n")
        return 10
    if _client_walk_status(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Twalk status\n")
        return 11
    if _client_open_status(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Topen status\n")
        return 12
    if _client_read_status(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Tread status\n")
        return 13
    if _client_clunk(c2s_wfd, s2c_rfd, READ_FID) < 0:
        write_str(1, "[distrofs] FAIL: Tclunk read fid\n")
        return 14
    if _client_stat_var(c2s_wfd, s2c_rfd) < 0:
        write_str(1, "[distrofs] FAIL: Tstat /var\n")
        return 15
    if _client_clunk(c2s_wfd, s2c_rfd, STAT_FID) < 0:
        write_str(1, "[distrofs] FAIL: Tclunk stat fid\n")
        return 16

    sys_close(c2s_wfd)
    sys_close(s2c_rfd)
    sys_waitpid(pid)

    write_str(1, "[distrofs] PASS\n")
    return 0

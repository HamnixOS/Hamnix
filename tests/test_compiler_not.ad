# tests/test_compiler_not.ad — the `not` unary operator (UNOP_NOT).
#
# WHY: `not` is parsed by both backends (parser.ad parse_not / codegen.ad +
# codegen_x86.py gen_unary UNOP_NOT) but was used NOWHERE in the .ad codebase,
# so its codegen path was untested — a strong hint that it might be buggy. It
# is NOT: both backends lower `not x` to `testq %rax,%rax; setz %al;
# movzbq %al,%rax`, i.e. `not x  ==  (x == 0) ? 1 : 0` — a full 64-bit register
# test. This fixture pins that semantics across every position `not` can appear
# so the path stays well-trodden.
#
# COVERAGE:
#   * `not x` as a boolean VALUE (nonzero -> 0, zero -> 1) on int and pointer;
#   * `if not cond:` (the branch/materialize condition path);
#   * `not not x` (double negation -> canonical 0/1);
#   * `a and not b` (not inside a short-circuit compound);
#   * `not (a == b)` (not of a comparison);
#   * `not` of a negative value and of a wide/truncating cast (still tests the
#     full register, so a nonzero low half is still "true").
#
# run_all() returns 0 on PASS, else a nonzero tag identifying the first failing
# case. Exercised over BOTH backends (seed codegen_x86.py at -O0/-O1/-O2 +
# native codegen.ad opt OFF/ON) by scripts/test_compiler_not.sh. HOST-ONLY.

# `not` of an integer: 1 iff the value is zero.
def not_int(x: int64) -> int64:
    return cast[int64](not x)

# `not` used directly as an `if` condition (branch path, not a materialized
# value): returns 1 when the condition (`not x`) is TRUE.
def not_if_taken(x: int64) -> int64:
    if not x:
        return 1
    return 0

# Double negation canonicalises any value to 0/1 (its truthiness).
def not_not(x: int64) -> int64:
    return cast[int64](not (not x))

# `not` as the RIGHT operand of a logical `and` (short-circuit compound).
# `a and not b` is true iff a != 0 AND b == 0.
def and_not(a: int64, b: int64) -> int64:
    if a and not b:
        return 1
    return 0

# `not` of a comparison: `not (a == b)` == `a != b`.
def not_eq(a: int64, b: int64) -> int64:
    return cast[int64](not (a == b))

# `not` tests the FULL 64-bit register: a value whose low 8 bits are zero but
# whose upper bits are set is still nonzero -> `not` yields 0. Guards against a
# truncated (8/32-bit) test.
def not_wide(x: uint64) -> int64:
    return cast[int64](not x)

def run_all() -> int64:
    # --- not of an int value -------------------------------------------
    if not_int(5) != 0:
        return 1                       # not 5 -> 0
    if not_int(0) != 1:
        return 2                       # not 0 -> 1
    if not_int(0 - 7) != 0:
        return 3                       # not (-7) -> 0 (nonzero)

    # --- not as an if-condition ----------------------------------------
    if not_if_taken(0) != 1:
        return 4                       # `if not 0:` taken
    if not_if_taken(9) != 0:
        return 5                       # `if not 9:` NOT taken

    # --- double negation -----------------------------------------------
    if not_not(0) != 0:
        return 6                       # not not 0 -> 0
    if not_not(42) != 1:
        return 7                       # not not 42 -> 1
    if not_not(0 - 1) != 1:
        return 8                       # not not (-1) -> 1

    # --- a and not b ---------------------------------------------------
    if and_not(1, 0) != 1:
        return 9                       # 1 and not 0 -> true
    if and_not(1, 3) != 0:
        return 10                      # 1 and not 3 -> false (b nonzero)
    if and_not(0, 0) != 0:
        return 11                      # 0 and not 0 -> false (a zero)

    # --- not of a comparison -------------------------------------------
    if not_eq(4, 4) != 0:
        return 12                      # not (4 == 4) -> 0
    if not_eq(4, 5) != 1:
        return 13                      # not (4 == 5) -> 1

    # --- not tests the full 64-bit register ----------------------------
    # 0x1_0000_0000 has zero low 32 bits but is nonzero -> not -> 0.
    if not_wide(cast[uint64](4294967296)) != 0:
        return 14
    # 0xFFFF_FFFF_FFFF_FF00 has zero low 8 bits but is nonzero -> not -> 0.
    if not_wide(cast[uint64](18446744073709551360)) != 0:
        return 15
    if not_wide(cast[uint64](0)) != 1:
        return 16                      # not 0 -> 1

    return 0

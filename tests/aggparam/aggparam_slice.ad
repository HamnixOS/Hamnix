# By-value Slice[T] PARAMETER — the 16-byte {ptr@0, len@8} view is passed in
# two INTEGER argument registers (rdi:rsi here), and the callee reads .len /
# s[i] / .ptr straight out of its spilled 16-byte param slot. A trailing scalar
# arg (bump) lands in the NEXT register (rdx) — proving the two-register
# aggregate shifts the following ordinals correctly.
def slice_sum(s: Slice[int32], bump: int32) -> int32:
    acc: int32 = cast[int32](s.len)          # 4
    acc = acc + s[0] + s[2]                  # +10 +90 = 104
    return acc + bump                        # +3 = 107

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    a[2] = 90
    p: Ptr[int32] = cast[Ptr[int32]](a)
    s: Slice[int32] = Slice[int32](p, 4)
    return slice_sum(s, 3)                    # 107

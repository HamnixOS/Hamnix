# By-value aggregate PARAMETER passing (roadmap increment 9) — the symmetric
# complement to the by-value aggregate RETURN ABI (#302). A <=16B float-free
# struct is passed in the next INTEGER argument registers (SysV rdi,rsi,rdx,
# rcx,r8,r9): Point is one eightbyte (one register); Pair16 is two. Mixed with
# scalar args to exercise the register-ordinal shift a two-register aggregate
# introduces. Also exercises the PARAM+RETURN interaction (#302): bump_pt takes
# a Point by value AND returns one by value.
class Point:
    x: int32
    y: int32

class Pair16:
    a: int64
    b: int64

# scalar (rdi) then a one-eightbyte aggregate (rsi)
def sum_pt(k: int32, pt: Point) -> int32:
    return k + pt.x + pt.y

# scalar (rdi), a two-eightbyte aggregate (rsi:rdx), scalar (rcx)
def sum_pair(base: int32, q: Pair16, extra: int32) -> int32:
    return base + cast[int32](q.a) + cast[int32](q.b) + extra

# by-value aggregate param AND by-value aggregate return in one function
def bump_pt(pt: Point) -> Point:
    r: Point
    r.x = pt.x + 1
    r.y = pt.y + 1
    return r

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    p: Point
    p.x = 3
    p.y = 4
    acc: int32 = sum_pt(10, p)               # 10+3+4 = 17
    q: Pair16
    q.a = 5
    q.b = 100
    acc = acc + sum_pair(1, q, 2)            # +1+5+100+2 = 108 -> 125
    r: Point = bump_pt(p)                    # (4, 5)
    acc = acc + r.x + r.y                    # +9 -> 134
    return acc

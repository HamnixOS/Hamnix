# By-value String PARAMETER — the 16-byte {ptr,len} view is passed in two
# INTEGER argument registers (rdi:rsi) and the callee reads .len / .ptr out of
# its spilled param slot. Seed-first (the native parser has no String
# annotation, so there is no native case for it).
def str_first(s: String) -> int32:
    acc: int32 = cast[int32](s.len)          # 5
    hp: Ptr[uint8] = s.ptr
    if hp[0] == 104:                         # 'h'
        acc = acc + 100                      # 105
    return acc

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    s: String = String("hello")
    return str_first(s)                      # 105

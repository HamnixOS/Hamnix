# tests/test_rfork_thread.ad
#
# §1 regression: prove that SYS_RFORK (256) with RFPROC|RFMEM creates a
# native Plan 9-shape THREAD — a child that SHARES the caller's address
# space and runs on a caller-supplied stack.
#
# This exercises the rfork RFMEM path added in §1 (sys/src/9/port/
# sysproc.ad::_rfork_thread), the native counterpart of do_clone's
# CLONE_VM|CLONE_THREAD branch. It is NOT a Linux binary — it is a
# Hamnix-native Adder fixture, so it proves the native rfork-thread
# path on its own, with no Layer-2 (Linux-ABI) machinery involved.
#
# Contract checked:
#   1. sys_rfork_thread(RFPROC|RFMEM, child_stack, 0) returns the child
#      pid (> 0) in the creator and 0 in the new thread.
#   2. The thread runs on its own caller-supplied stack.
#   3. The thread and the creator SHARE the address space: the thread
#      writes a sentinel into a global, the creator spins until it sees
#      that write — proving the write was visible across the share.
#   4. RFNOWAIT detaches the thread; the creator does NOT wait4/waitpid
#      it (a detached child self-reaps) and still reaches PASS.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_rfork_thread.ad -o build/user/test_rfork_thread.elf
#
# Run via scripts/test_rfork_thread.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_rfork_thread(flags: int32, child_stack: uint64,
                            tls: uint64) -> int32
extern def sys_exit(code: uint64)
extern def sys_yield()

# RF* bits (numerically identical to <plan9/libc.h> — see sysproc.ad).
RFPROC:   int32 = 0x001
RFMEM:    int32 = 0x002
RFNOWAIT: int32 = 0x100

# Shared-address-space proof: the thread writes here, the creator reads
# it. Because RFMEM shares the address space, the global lives at the
# same physical memory for both.
shared_flag: uint64 = 0

# The thread's private stack. 8 KiB is plenty for the shallow call
# depth below. The TOP word is overwritten with the thread entry RIP
# so the kernel's rfork-thread path (child resumes after `syscall`,
# executes `ret`) jumps straight into thread_main.
thread_stack: Array[1024, uint64]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def thread_main():
    # Runs in the child thread, on thread_stack, sharing the creator's
    # address space. Announce, then publish the sentinel the creator is
    # spinning on.
    write_str(1, "[rfthr] hello from thread\n")
    shared_flag = 0xC0FFEE
    sys_exit(0)


def main() -> int32:
    write_str(1, "[rfork-thread] start\n")

    # Lay out the child stack: the kernel's rfork-thread path makes the
    # child resume right after the syscall, where sys_rfork_thread does
    # `ret` — so the word at the top of the child stack must be the
    # thread entry RIP. We park &thread_main at thread_stack[1022] and
    # hand the kernel a pointer to that word; the thread then runs with
    # RSP just below it.
    top: uint64 = 1022
    thread_stack[top] = cast[uint64](&thread_main)
    child_sp: uint64 = cast[uint64](&thread_stack[top])

    flags: int32 = RFPROC | RFMEM | RFNOWAIT
    rc: int32 = sys_rfork_thread(flags, child_sp, 0)

    if rc < 0:
        write_str(1, "[rfork-thread] FAIL: sys_rfork_thread negative\n")
        return 1

    if rc == 0:
        # Defensive: the thread is supposed to enter thread_main
        # directly (it resumes after the syscall and `ret`s into it),
        # NOT fall through here. If it does fall through, still behave.
        write_str(1, "[rfork-thread] thread fell through to main\n")
        sys_exit(0)
        return 0

    # Creator branch. rc is the thread's pid.
    write_str(1, "[rfork-thread] thread pid=")
    write_dec(1, cast[uint64](rc))
    write_str(1, "\n")

    # Yield repeatedly until the thread publishes its sentinel into the
    # SHARED global. Seeing it proves (a) the thread ran and (b) the
    # address space is genuinely shared. Bounded so a broken share
    # fails the test instead of hanging the box forever.
    spins: uint64 = 0
    while shared_flag != 0xC0FFEE and spins < 100000:
        sys_yield()
        spins = spins + 1

    if shared_flag != 0xC0FFEE:
        write_str(1, "[rfork-thread] FAIL: shared write never seen\n")
        return 2

    write_str(1, "[rfork-thread] shared write observed\n")

    # RFNOWAIT detached the thread — we deliberately do NOT wait for
    # it. A detached child self-reaps (STATE_FREE on exit), so there
    # is no zombie to leak and nothing for us to reap.
    write_str(1, "[rfork-thread] PASS\n")
    return 0

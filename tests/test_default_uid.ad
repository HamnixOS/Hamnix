# tests/test_default_uid.ad
#
# F10-3 #456 acceptance: default task uid model.
#
# Pre-F10-3, every freshly-created task started at uid 1 (hostowner) by
# the kthread_create / create_user_thread fallback. The dispatcher's
# uid==1 hostowner bypass then fired on every line — the "default
# namespace = everyone is root" failure the audit called out.
#
# Post-F10-3, the create_user_thread fallback is UID_NOBODY (65534) and
# init/main.ad explicitly upgrades PID 1 to UID_HOSTOWNER (1) right
# after the slot publish. Every subsequent task forks from init and
# inherits hostowner via the parent_uid branch — so a hamsh-spawned
# /bin/test_default_uid lands at uid 1, NOT NOBODY. Login flips this
# via SYS_SETUID_AUTH; SYS_SETUID lets hostowner downgrade explicitly.
#
# Scenario:
#
#   1. The fixture runs spawned by hamsh, which itself was exec'd by
#      PID 1. So at start, sys_getuid() MUST return UID_HOSTOWNER (1).
#      A non-1 reading would mean either:
#        - init/main.ad's explicit set_task_uid_at(parent_slot,
#          UID_HOSTOWNER) didn't fire (PID 1 stuck at NOBODY -> hamsh
#          inherits NOBODY -> we inherit NOBODY), or
#        - the boot-time inheritance chain is broken somewhere between
#          PID 1's stamp and our rfork.
#
#   2. sys_setuid(UID_NOBODY) — hostowner is allowed to downgrade
#      identity at will (the SYS_SETUID arch arm gates on
#      `current_task_uid() == 1`). Post-call sys_getuid() MUST return
#      UID_NOBODY (65534). This proves the SYS_SETUID -> downgrade
#      path is the right shape for the login flow's
#      SYS_SETUID_AUTH-mediated upgrade idiom.
#
#   3. Open /dev/blk/sd0 as NOBODY. devblk_perm_check rejects every
#      caller_uid != UID_HOSTOWNER, so the open MUST return a negative
#      fd. Pre-F10-3 (when the default uid was 1) this same open would
#      have succeeded — the test surfaces the "F10-3 actually closes
#      the dispatcher bypass" claim end-to-end.
#
# Final marker: `[default_uid] PASS`. Greppable from
# scripts/test_default_uid.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_GETUID: uint64 = 288
SYS_SETUID: uint64 = 290

UID_HOSTOWNER: uint64 = 1
UID_NOBODY:    uint64 = 65534


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: int64):
    if value < 0:
        sys_write(fd, "-", 1)
        value = -value
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = cast[uint64](value)
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def my_getuid() -> uint64:
    return cast[uint64](syscall6(SYS_GETUID, 0, 0, 0, 0, 0, 0))


def my_setuid(uid: uint64) -> int64:
    return syscall6(SYS_SETUID, uid, 0, 0, 0, 0, 0)


def main() -> int32:
    write_str(1, "[default_uid] start\n")

    # ----------------------------------------------------------------
    # Step 1: a freshly-spawned hamsh child must inherit PID 1's
    # explicitly-stamped UID_HOSTOWNER. If this fails the F10-3
    # init/main.ad set_task_uid_at wiring is broken (or the inherit
    # chain through create_user_thread is broken — same observable
    # symptom).
    initial_uid: uint64 = my_getuid()
    write_str(1, "[default_uid] initial uid = ")
    write_dec(1, cast[int64](initial_uid))
    sys_write(1, "\n", 1)
    if initial_uid != UID_HOSTOWNER:
        write_str(1, "[default_uid] FAIL: initial uid is NOT hostowner; expected 1\n")
        return 1
    write_str(1, "[default_uid] inherited hostowner (uid 1) from PID 1\n")

    # ----------------------------------------------------------------
    # Step 2: SYS_SETUID downgrade to NOBODY. Hostowner is the only uid
    # the arch SYS_SETUID gate admits, and downgrade is unrestricted
    # (the login path uses this idiom; SYS_SETUID_AUTH is the
    # password-mediated counterpart). Post-call our uid MUST be 65534.
    rc: int64 = my_setuid(UID_NOBODY)
    if rc < 0:
        write_str(1, "[default_uid] FAIL: SYS_SETUID(NOBODY) returned negative\n")
        return 2
    write_str(1, "[default_uid] SYS_SETUID(NOBODY) returned 0\n")
    after_uid: uint64 = my_getuid()
    write_str(1, "[default_uid] post-setuid uid = ")
    write_dec(1, cast[int64](after_uid))
    sys_write(1, "\n", 1)
    if after_uid != UID_NOBODY:
        write_str(1, "[default_uid] FAIL: post-setuid uid not NOBODY (65534)\n")
        return 3
    write_str(1, "[default_uid] downgraded to NOBODY (uid 65534)\n")

    # ----------------------------------------------------------------
    # Step 3: as NOBODY, /dev/blk/sd0 MUST be denied. devblk's per-server
    # policy (devblk_perm_check in sys/src/9/port/devblk.ad) requires
    # caller_uid == UID_HOSTOWNER for every op — so a NOBODY open() of
    # the raw block backing the rootfs is the cleanest "F10-3 closed
    # the bypass" surface. Pre-F10-3 (when our default uid would have
    # been 1) this SAME open() would have admitted via the dispatcher
    # bypass.
    fd: int32 = sys_open("/dev/blk/sd0")
    if fd >= 0:
        write_str(1, "[default_uid] FAIL: NOBODY opened /dev/blk/sd0 (hostowner-only)\n")
        sys_close(fd)
        return 4
    write_str(1, "[default_uid] NOBODY denied /dev/blk/sd0 (expected)\n")

    write_str(1, "[default_uid] PASS\n")
    return 0

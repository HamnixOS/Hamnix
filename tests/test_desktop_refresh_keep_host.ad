# tests/test_desktop_refresh_keep_host.ad
#
# FAST, QEMU-free host gate for the desktop icon-wipe regression: applying a
# theme/wallpaper in Control Center collapsed the ~10 desktop icons to the 3
# built-in defaults (Files/Terminal/Home).
#
# ROOT CAUSE: Control Center only bumps the kernel wallpaper generation; the
# desktop process (user/hamdesktop.ad) wakes on that gen bump AND, on the SAME
# wake, runs its periodic fmc_refresh_if_changed() -> _rebuild_after_refresh().
# The old _rebuild_after_refresh() fell back to _load_defaults() whenever the
# re-scan yielded 0 icons. A momentarily-unreadable / transiently-empty
# ~/Desktop scan therefore wiped the full icon set down to the 3 defaults, and
# the wallpaper redraw made that collapse VISIBLE right at the click.
#
# The fix routes the rebuild-vs-keep decision through desk_refresh_should_keep()
# (user/hamdesktop.ad): a refresh whose scan returns 0 KEEPS the current icon
# set when icons were already present (prev_count > 0) instead of collapsing to
# the defaults. This harness is a BYTE-IDENTICAL replica of that helper and
# asserts the four decision cases. A companion shell wrapper greps the real
# source so the replica cannot silently drift.
#
# Banner: "[deskrefresh] PASS ..." / "[deskrefresh] FAIL ...".

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def _puts(fd: int32, s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(fd, s, n)


# EXACT copy of user/hamdesktop.ad desk_refresh_should_keep. Keep byte-identical
# (the wrapper greps the real source to guard against drift).
def desk_refresh_should_keep(prev_count: uint64, scan_count: uint64,
                             scan_failed: int32) -> int32:
    if scan_count > 0 and scan_failed == 0:
        return 0                       # a real, successful listing -> rebuild
    if scan_count > 0:
        return 0                       # non-empty even if flagged -> rebuild
    if prev_count == 0:
        return 0                       # cold start, nothing ever there -> defaults
    return 1                           # had icons, scan now empty/unreadable -> KEEP


_fail: int32 = 0


def _check(label: Ptr[uint8], prev_count: uint64, scan_count: uint64,
           scan_failed: int32, want: int32):
    got: int32 = desk_refresh_should_keep(prev_count, scan_count, scan_failed)
    if got != want:
        _puts(2, cast[Ptr[uint8]]("[deskrefresh] FAIL "))
        _puts(2, label)
        _puts(2, cast[Ptr[uint8]]("\n"))
        _fail = 1
        return
    _puts(1, cast[Ptr[uint8]]("[deskrefresh] PASS "))
    _puts(1, label)
    _puts(1, cast[Ptr[uint8]]("\n"))


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # (a) The smoking gun: a refresh whose scan transiently fails (unreadable
    #     ~/Desktop -> 0 entries) while 10 icons were already loaded must KEEP
    #     the current set, NOT collapse to the 3 defaults.
    _check(cast[Ptr[uint8]]("(a) refresh scan=0 failed, prev=10 -> keep"),
           10, 0, 1, 1)
    # (b) A refresh whose scan is readable-but-empty (0 entries, no failure)
    #     while icons were present must ALSO keep — a refresh never wipes a
    #     previously-populated desktop.
    _check(cast[Ptr[uint8]]("(b) refresh scan=0 readable-empty, prev=10 -> keep"),
           10, 0, 0, 1)
    # (c) Cold start (nothing ever loaded, prev=0) with a readable-empty scan
    #     -> do NOT keep, so the caller installs the 3 built-in defaults. This
    #     preserves the legitimate genuinely-empty first-boot behaviour.
    _check(cast[Ptr[uint8]]("(c) cold start scan=0 readable-empty, prev=0 -> defaults"),
           0, 0, 0, 0)
    # (d) A refresh with a real non-empty listing -> rebuild to it (do not keep
    #     the stale set).
    _check(cast[Ptr[uint8]]("(d) refresh scan=7, prev=10 -> rebuild"),
           10, 7, 0, 0)
    # Extra guards: a non-empty scan rebuilds even at cold start, and even if the
    # (defensive) failed flag is set the non-empty listing still wins.
    _check(cast[Ptr[uint8]]("cold start scan=5 -> rebuild"), 0, 5, 0, 0)
    _check(cast[Ptr[uint8]]("scan=5 flagged failed -> rebuild"), 3, 5, 1, 0)

    if _fail != 0:
        _puts(2, cast[Ptr[uint8]]("[deskrefresh] FAIL one or more assertions failed\n"))
        return 1
    _puts(1, cast[Ptr[uint8]]("[deskrefresh] PASS all refresh-keep assertions\n"))
    return 0

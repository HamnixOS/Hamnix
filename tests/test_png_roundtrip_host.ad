# tests/test_png_roundtrip_host.ad
#
# HOST (x86_64-linux) round-trip gate: encode a synthetic framebuffer with
# lib/pngwrite.ad EXACTLY the way user/hamshot.ad does (one stored-DEFLATE
# IDAT per row), then DECODE the produced bytes with the REAL lib/png.ad
# decoder in the same process and assert every pixel round-trips. This proves
# the encoder<->decoder pair agrees byte-for-byte, with NO QEMU.
#
# Usage:  test_png_roundtrip_host <W> <H>
# Prints "[png-rt] PASS WxH" on success, "[png-rt] FAIL ..." (exit 1) on any
# mismatch or a decoder rejection.
#
# Build + run (host):
#   python3 -m compiler.adder compile --target=x86_64-linux \
#       tests/test_png_roundtrip_host.ad -o build/host/test_png_roundtrip_host.elf
#   build/host/test_png_roundtrip_host.elf 1024 768

from lib.pngwrite import (
    pngw_signature, pngw_ihdr, pngw_iend,
    pngw_idat_begin, pngw_idat_end,
    pngw_zlib_header, pngw_stored_block_hdr,
    pngw_adler_reset, pngw_adler_update, pngw_adler_final,
    pngw_put_u32_be,
)
from lib.png import png_decode, png_width, png_height, png_pixel

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[uint8], flags: int64, mode: int64) -> int32
extern def sys_close(fd: int32) -> int32

# Big enough to hold a full 1920x1080 stored-DEFLATE PNG file in memory:
# per row 8+5+1+3W(+2 zlib row0)(+4 adler last)(+4 crc) ~ 6+3W bytes; for
# W=1920 that is ~5766/row * 1080 ~ 6.3 MB. 24 MB covers up to ~4K-ish.
_FILE: Array[25165824, uint8]           # 24 MiB PNG-file scratch
_ROW: Array[16384, uint8]               # one framed IDAT chunk


def _puts(fd: int32, s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(fd, s, n)


def _parse_u64(s: Ptr[uint8]) -> uint64:
    v: uint64 = 0
    i: uint64 = 0
    while s[i] >= 48 and s[i] <= 57:
        v = v * 10 + cast[uint64](s[i]) - 48
        i = i + 1
    return v


# Deterministic synthetic colour for pixel (x,y): a non-uniform pattern that
# stresses all three channels independently.
def _synth_r(x: uint64, y: uint64) -> uint8:
    return cast[uint8]((x * 7 + y * 3) & 255)


def _synth_g(x: uint64, y: uint64) -> uint8:
    return cast[uint8]((x * 3 + y * 11) & 255)


def _synth_b(x: uint64, y: uint64) -> uint8:
    return cast[uint8]((x + y * 5) & 255)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    w: uint64 = 1024
    h: uint64 = 768
    if argc > 2:
        w = _parse_u64(cast[Ptr[uint8]](argv[1]))
        h = _parse_u64(cast[Ptr[uint8]](argv[2]))
    if w == 0 or h == 0:
        _puts(2, "[png-rt] FAIL bad dims\n")
        return 1

    # ---- ENCODE into _FILE, mirroring user/hamshot.ad ----
    fp: uint64 = 0
    sn: uint64 = pngw_signature(&_ROW[0])
    k: uint64 = 0
    while k < sn:
        _FILE[fp + k] = _ROW[k]
        k = k + 1
    fp = fp + sn
    hn: uint64 = pngw_ihdr(&_ROW[0], cast[uint32](w), cast[uint32](h))
    k = 0
    while k < hn:
        _FILE[fp + k] = _ROW[k]
        k = k + 1
    fp = fp + hn

    pngw_adler_reset()
    y: uint64 = 0
    while y < h:
        op: uint64 = pngw_idat_begin(&_ROW[0])
        if y == 0:
            op = pngw_zlib_header(&_ROW[0], op)
        dlen: uint64 = 1 + w * 3
        is_last: int32 = 0
        if y == h - 1:
            is_last = 1
        op = pngw_stored_block_hdr(&_ROW[0], op, dlen, is_last)
        filt: uint64 = op
        _ROW[op] = 0
        op = op + 1
        x: uint64 = 0
        while x < w:
            _ROW[op]     = _synth_r(x, y)
            _ROW[op + 1] = _synth_g(x, y)
            _ROW[op + 2] = _synth_b(x, y)
            op = op + 3
            x = x + 1
        pngw_adler_update(&_ROW[0], filt, dlen)
        if is_last != 0:
            op = pngw_put_u32_be(&_ROW[0], op, pngw_adler_final())
        clen: uint64 = op - 8
        total: uint64 = pngw_idat_end(&_ROW[0], clen)
        k = 0
        while k < total:
            _FILE[fp + k] = _ROW[k]
            k = k + 1
        fp = fp + total
        y = y + 1

    en: uint64 = pngw_iend(&_ROW[0])
    k = 0
    while k < en:
        _FILE[fp + k] = _ROW[k]
        k = k + 1
    fp = fp + en

    # ---- optionally dump the encoded PNG for a standard-tool cross-check ----
    if argc > 3:
        ofd: int32 = sys_open(cast[Ptr[uint8]](argv[3]), 577, 420)
        if ofd >= 0:
            done: uint64 = 0
            while done < fp:
                n: int64 = sys_write(ofd, &_FILE[done], fp - done)
                if n <= 0:
                    done = fp
                else:
                    done = done + cast[uint64](n)
            sys_close(ofd)

    # ---- DECODE with lib/png.ad ----
    rc: int32 = png_decode(&_FILE[0], fp)
    if rc != 0:
        _puts(2, "[png-rt] FAIL png_decode rejected a self-encoded PNG\n")
        return 1
    if cast[uint64](png_width()) != w or cast[uint64](png_height()) != h:
        _puts(2, "[png-rt] FAIL decoded dimensions mismatch\n")
        return 1

    # ---- compare every pixel ----
    yy: uint64 = 0
    while yy < h:
        xx: uint64 = 0
        while xx < w:
            px: uint32 = png_pixel(cast[int32](xx), cast[int32](yy))
            r: uint8 = cast[uint8]((px >> 16) & 255)
            g: uint8 = cast[uint8]((px >> 8) & 255)
            b: uint8 = cast[uint8](px & 255)
            if r != _synth_r(xx, yy) or g != _synth_g(xx, yy) or \
               b != _synth_b(xx, yy):
                _puts(2, "[png-rt] FAIL pixel mismatch\n")
                return 1
            xx = xx + 1
        yy = yy + 1

    _puts(1, "[png-rt] PASS round-trip\n")
    return 0

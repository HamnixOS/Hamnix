# tests/test_p9wstat.ad
#
# Phase C regression: exercise SYS_WSTAT (266) and SYS_FWSTAT (267) —
# the last two Plan 9 reserved syscalls in the 256..271 block. After
# this milestone everything reserved in Phase B has a real body.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_p9wstat.ad -o build/user/test_p9wstat.elf
#
# Run via scripts/test_p9wstat.sh.
#
# Contract (one marker per honoured leg):
#   [p9wstat] create /tmp/wstat_src ok    (sys_open_write returned fd)
#   [p9wstat] wstat rename ok             (do_wstat name leg succeeded)
#   [p9wstat] dst reachable ok            (open new name returns valid fd)
#   [p9wstat] src gone ok                 (open old name returns -1)
#   [p9wstat] wstat mode no-op ok         (mode-only wstat returns 0)
#   [p9wstat] fwstat backend gap ok       (cpio fd -> -1, expected)
#   [p9wstat] PASS                        (all five legs green)
#
# The fixture deliberately exercises ONE rename + ONE mode no-op +
# ONE expected-failure (fwstat on an initramfs fd) so the bookkeeping
# around each branch is visible in the serial log.

extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_WSTAT:  uint64 = 266
SYS_FWSTAT: uint64 = 267

# Plan 9 wstat sentinels (per stat(5)): "don't change this field".
SENTINEL_U32: uint32 = 0xFFFFFFFF
SENTINEL_U64: uint64 = 0xFFFFFFFFFFFFFFFF


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


# --- little-endian byte writers (mirror sysfile.ad helpers) -------

def w_le16(p: Ptr[uint8], v: uint64):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)


def w_le32(p: Ptr[uint8], v: uint32):
    vu: uint64 = cast[uint64](v)
    p[0] = cast[uint8](vu & 0xFF)
    p[1] = cast[uint8]((vu >> 8) & 0xFF)
    p[2] = cast[uint8]((vu >> 16) & 0xFF)
    p[3] = cast[uint8]((vu >> 24) & 0xFF)


def w_le64(p: Ptr[uint8], v: uint64):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)
    p[2] = cast[uint8]((v >> 16) & 0xFF)
    p[3] = cast[uint8]((v >> 24) & 0xFF)
    p[4] = cast[uint8]((v >> 32) & 0xFF)
    p[5] = cast[uint8]((v >> 40) & 0xFF)
    p[6] = cast[uint8]((v >> 48) & 0xFF)
    p[7] = cast[uint8]((v >> 56) & 0xFF)


def build_dir_record(buf: Ptr[uint8], new_basename: Ptr[uint8],
                     new_basename_len: uint64,
                     mode: uint32) -> uint64:
    # Build a 9P Dir record with everything-but-name+mode set to the
    # wstat sentinel. Returns the total record length in bytes.
    # Layout (matches sys/src/9/port/sysfile.ad::_write_dir_record):
    #   0..1   size       (filled in last)
    #   2..3   type        = 0
    #   4..7   dev         = 0
    #   8      qid.type    = 0
    #   9..12  qid.vers    = 0
    #  13..20  qid.path    = 0
    #  21..24  mode        = caller (or SENTINEL)
    #  25..28  atime       = SENTINEL
    #  29..32  mtime       = SENTINEL
    #  33..40  length      = SENTINEL
    #  41..    name[s] uid[s] gid[s] muid[s]
    w_le16(&buf[2], 0)
    w_le32(&buf[4], cast[uint32](0))
    buf[8] = 0
    w_le32(&buf[9], cast[uint32](0))
    w_le64(&buf[13], 0)
    w_le32(&buf[21], mode)
    w_le32(&buf[25], SENTINEL_U32)
    w_le32(&buf[29], SENTINEL_U32)
    w_le64(&buf[33], SENTINEL_U64)
    off: uint64 = 41
    # name
    w_le16(&buf[off], new_basename_len)
    off = off + 2
    i: uint64 = 0
    while i < new_basename_len:
        buf[off + i] = new_basename[i]
        i = i + 1
    off = off + new_basename_len
    # uid (empty = don't change)
    w_le16(&buf[off], 0)
    off = off + 2
    # gid (empty = don't change)
    w_le16(&buf[off], 0)
    off = off + 2
    # muid (empty = don't change)
    w_le16(&buf[off], 0)
    off = off + 2
    # size = total bytes - 2
    w_le16(&buf[0], off - 2)
    return off


def main() -> int32:
    write_str(1, "[p9wstat] start\n")

    # 1) Create /tmp/wstat_src — tmpfs-backed writable file.
    fd: int32 = sys_open_write("/tmp/wstat_src")
    if fd < 0:
        write_str(1, "[p9wstat] FAIL: open_write returned ")
        write_dec(1, cast[uint64](fd))
        write_str(1, "\n")
        return 1
    sys_write(fd, "hello", 5)
    sys_close(fd)
    write_str(1, "[p9wstat] create /tmp/wstat_src ok\n")

    # 2) Build a Dir record renaming to "wstat_dst" (basename only —
    # the kernel stitches the parent dir on for us).
    rec: Array[128, uint8]
    new_name: Ptr[uint8] = "wstat_dst"
    nlen: uint64 = strlen(new_name)
    reclen: uint64 = build_dir_record(&rec[0], new_name, nlen,
                                       SENTINEL_U32)
    rc: int64 = syscall6(SYS_WSTAT,
                         cast[uint64](&"/tmp/wstat_src"[0]),
                         cast[uint64](&rec[0]),
                         reclen, 0, 0, 0)
    if rc != 0:
        write_str(1, "[p9wstat] FAIL: wstat rename returned ")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        return 2
    write_str(1, "[p9wstat] wstat rename ok\n")

    # 3) /tmp/wstat_dst must now be reachable.
    fdd: int32 = sys_open("/tmp/wstat_dst")
    if fdd < 0:
        write_str(1, "[p9wstat] FAIL: open /tmp/wstat_dst returned ")
        write_dec(1, cast[uint64](fdd))
        write_str(1, "\n")
        return 3
    sys_close(fdd)
    write_str(1, "[p9wstat] dst reachable ok\n")

    # 4) /tmp/wstat_src must now be gone.
    fds: int32 = sys_open("/tmp/wstat_src")
    if fds >= 0:
        write_str(1, "[p9wstat] FAIL: src still openable after rename\n")
        sys_close(fds)
        return 4
    write_str(1, "[p9wstat] src gone ok\n")

    # 5) Mode-only wstat (no name change). We pass an empty name
    # string AND a real mode value; the kernel must accept the call
    # and silently DROP the mode (no per-inode mode storage yet).
    mrec: Array[128, uint8]
    empty_name: Ptr[uint8] = ""
    mlen: uint64 = build_dir_record(&mrec[0], empty_name, 0,
                                     cast[uint32](0644))
    rc = syscall6(SYS_WSTAT,
                  cast[uint64](&"/tmp/wstat_dst"[0]),
                  cast[uint64](&mrec[0]),
                  mlen, 0, 0, 0)
    if rc != 0:
        write_str(1, "[p9wstat] FAIL: wstat mode returned ")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        return 5
    write_str(1, "[p9wstat] wstat mode no-op ok\n")

    # 6) fwstat on a non-tmpfs fd (cpio-backed /etc/motd) — must
    # surface the documented "backend not supported" gap as -1.
    cpio_fd: int32 = sys_open("/etc/motd")
    if cpio_fd < 0:
        write_str(1, "[p9wstat] FAIL: open /etc/motd returned ")
        write_dec(1, cast[uint64](cpio_fd))
        write_str(1, "\n")
        return 6
    grec: Array[128, uint8]
    glen: uint64 = build_dir_record(&grec[0], empty_name, 0,
                                     SENTINEL_U32)
    rc = syscall6(SYS_FWSTAT, cast[uint64](cpio_fd),
                  cast[uint64](&grec[0]), glen, 0, 0, 0)
    sys_close(cpio_fd)
    if rc >= 0:
        write_str(1, "[p9wstat] FAIL: fwstat on cpio fd returned 0?\n")
        return 7
    write_str(1, "[p9wstat] fwstat backend gap ok\n")

    write_str(1, "[p9wstat] PASS\n")
    return 0

# --opt bounds-check fixture (increment 2): `unsafe:` SUPPRESSES the check even
# on the isel direct-SIB path. Same OOB index as opt_idxreg_oob.ad, but the read
# happens inside an `unsafe:` block, so NO check is emitted and NO trap fires —
# the process returns 0 cleanly. (A read a few hundred bytes up the live stack is
# harmless; we deliberately avoid an out-of-bounds WRITE.)
def idx() -> int64:
    return 101
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    i: int64 = idx()
    r: int32 = 0
    unsafe:
        r = a[i]
    return 0

# Bounds-check regression fixture: an OUT-OF-RANGE index MUST trap.
# `a[argc + 100]` is index 101 into a length-4 array. Compiled
# --target=x86_64-linux --check-bounds, the runtime bounds check fires and
# executes `ud2`, so the process dies with SIGILL (wait-status 132 = 128+4).
# The index is data-dependent (argc) so the compiler cannot fold it away.
# See docs/adder_memory_safety.md and scripts/test_adder_bounds_check.sh.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    i: int32 = argc + 100
    return a[i]

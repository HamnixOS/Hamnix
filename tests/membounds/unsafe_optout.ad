# Bounds-check regression fixture: the `unsafe:` opt-out SUPPRESSES the check.
# The same out-of-range index as oob.ad, but the indexing happens inside an
# `unsafe:` block, so NO bounds check is emitted and NO trap fires. The read is
# genuinely out of bounds (undefined at the language level) but the process
# does not die by SIGILL — it returns 0 cleanly, proving the opt-out works.
# (A READ a few hundred bytes up the live stack is harmless; we deliberately
# avoid an out-of-bounds WRITE so the fixture stays deterministic.)
# See docs/adder_memory_safety.md and scripts/test_adder_bounds_check.sh.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    i: int32 = argc + 100
    r: int32 = 0
    unsafe:
        r = a[i]
    return 0

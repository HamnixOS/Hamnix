# --opt bounds-check fixture (increment 2): the isel index-into-%rcx path.
# `a[b + 1]` — a BINARY index — flows through try_sel_index_into_rcx (index
# computed straight into %rcx, never %rax). Under --opt --check-bounds the check
# must fire against %rcx: b==100 so the index is 101, OOB of the length-4 array,
# and the process traps (SIGILL, status 132).
def base() -> int64:
    return 100
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    b: int64 = base()
    return a[b + 1]

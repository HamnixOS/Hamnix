# --opt bounds-check fixture (increment 2): the DIRECT-SIB coalesce.
# `a[i]` where i is a full-width-8 register-promoted local flows through the
# isel use_direct path (index STRAIGHT into a SIB register, never %rax). Under
# --opt --check-bounds the bounds check must still fire: index 101 into a
# length-4 array traps (SIGILL, wait-status 132). The index comes from a helper
# call so neither backend can fold it to a constant. See gen_index_addr's
# use_direct block + docs/adder_memory_safety.md.
def idx() -> int64:
    return 101
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    i: int64 = idx()
    return a[i]

# Bounds-check regression fixture: an IN-RANGE index must NOT trap.
# Compiled --target=x86_64-linux --check-bounds and run with no args (argc=1),
# `a[argc - 1]` == a[0] == 10, so the process exits cleanly with status 10.
# See docs/adder_memory_safety.md and scripts/test_adder_bounds_check.sh.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    a[1] = 20
    a[2] = 30
    a[3] = 40
    i: int32 = argc - 1
    return a[i]

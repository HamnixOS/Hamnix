# --opt bounds-check fixture (increment 2): in-range isel-%rcx binary index must
# NOT trap. base()==2 so `a[b + 1]` == a[3] == 40; exit status 40.
def base() -> int64:
    return 2
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    a[3] = 40
    b: int64 = base()
    return a[b + 1]

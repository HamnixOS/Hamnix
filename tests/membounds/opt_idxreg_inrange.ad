# --opt bounds-check fixture (increment 2): in-range DIRECT-SIB index must NOT
# trap. idx() == 3 is a valid index into the length-4 array; a[3] == 40, so the
# process exits cleanly with status 40.
def idx() -> int64:
    return 3
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    a[3] = 40
    i: int64 = idx()
    return a[i]

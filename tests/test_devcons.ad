# tests/test_devcons.ad
#
# M16.94 regression: open /dev/cons for write, write a banner, close,
# exit. The banner lands on the same fan-out path as printk —
# UART + VGA/fb + the kernel log ring — so the host-side test script
# can grep the serial log for the marker.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devcons.ad -o build/user/test_devcons.elf
#
# Run via scripts/test_devcons.sh, which embeds this binary at
# /bin/test_devcons inside the cpio initramfs and drives it via
# hamsh (the same pattern test_errstr.sh uses).
#
# Contract: writing to /dev/cons is equivalent to the legacy SYS_PUTC
# call — see docs/native-api.md "Reserved well-known paths" entry for
# /dev/cons. After this fixture, the migration table promise that
# `write("/dev/cons", ...)` replaces SYS_PUTC is exercised end-to-end.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    n: uint64 = strlen(s)
    sys_write(fd, s, n)


def main() -> int32:
    # Banner on stdout — proves the fixture ran at all, independent
    # of the /dev/cons round-trip below. Both the banner and the
    # /dev/cons write end up on serial via the same UART, but the
    # banner uses FD_STDOUT_MARK and the second write uses the new
    # FD_CONS_MARK path. The marker string itself is unique enough
    # that grepping for it pins exactly one of those two writes.
    write_str(1, "[test_devcons] start\n")

    # 1. Open /dev/cons for write. The VFS routes /dev/cons → the
    #    FD_CONS_MARK marker regardless of read/write intent (the
    #    Plan 9 native-api spec models /dev/cons as a single r/w
    #    file, not a pair of one-way pipes). sys_open_write is the
    #    only user-side wrapper that asks for the writable variant,
    #    so we go through it.
    fd: int32 = sys_open_write("/dev/cons")
    if fd < 0:
        write_str(1, "[test_devcons] open failed\n")
        return 1

    # 2. Write the marker. devcons_write() loops over the bytes and
    #    calls early_putc() on each — same fan-out point FD_STDOUT
    #    uses, so the marker appears on the serial console exactly
    #    once per byte. No interleaving with subsequent stdout
    #    writes from hamsh because we close fd before returning.
    sys_write(fd, "M16.94 cons test\n", 17)

    # 3. Close. FD_CONS_MARK has no kernel-side slot to free; this
    #    is a slot-zero close (see close_fd_in_task in
    #    kernel/sched/core.ad — FD_CONS_MARK falls through to the
    #    fd-idx rewrite like FD_SOCKET_MARK / FD_DEVNULL_MARK do).
    sys_close(fd)

    write_str(1, "[test_devcons] done\n")
    return 0

# tests/test_parsecolor_alpha_host.ad
#
# QEMU-free host gate for the hamML colour parser's 8-digit "#rrggbbaa" alpha
# path (user/hamUId.ad parse_color). Regression guard for the user-reported
# "screenshot with a selected area turns the whole screen black" bug: the
# area-select dim overlay is drawn with "#00000066" (~40%-alpha black). Before
# the fix, parse_color had no >=8-digit branch and hardcoded alpha 255 for any
# ndig >= 6, so the dim overlay composited as FULLY OPAQUE BLACK over the whole
# screen.
#
# This harness mirrors the EXACT hex-nibble parsing of user/hamUId.ad's
# hex_nibble + parse_color (#rrggbb / #rrggbbaa / #rgb branches) and asserts:
#   * "#00000066" -> a == 0x66 (dim, NOT opaque)
#   * "#ffffff22" -> a == 0x22
#   * "#ff8800"   -> a == 0xff (6-digit stays opaque)
#   * "#f80"      -> a == 0xff (3-digit stays opaque)
# A companion shell wrapper greps the real user/hamUId.ad source to confirm the
# `ndig >= 8` branch actually exists and sets out_a from the alpha nibbles, so
# this behavioural replica cannot silently drift from the shipped code.
#
# Banner: "[parsecolor] PASS ..." / "[parsecolor] FAIL ...".

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64


def _puts(fd: int32, s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(fd, s, n)


# Exact copy of user/hamUId.ad hex_nibble.
def hex_nibble(c: uint8) -> int32:
    if c >= 48 and c <= 57:
        return cast[int32](c) - 48
    if c >= 97 and c <= 102:
        return cast[int32](c) - 97 + 10
    if c >= 65 and c <= 70:
        return cast[int32](c) - 65 + 10
    return -1


# Exact copy of user/hamUId.ad parse_color (the '#' hex branches only; the
# rgba()/rgb() functional-notation branch is not exercised here).
def parse_color(buf: Ptr[uint8], start: uint64, end: uint64,
                out_r: Ptr[uint8], out_g: Ptr[uint8],
                out_b: Ptr[uint8], out_a: Ptr[uint8]) -> int32:
    i: uint64 = start
    while i < end and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    if i >= end:
        return 0
    if buf[i] == 35:
        i = i + 1
        h0: uint64 = i
        while i < end and hex_nibble(buf[i]) >= 0:
            i = i + 1
        ndig: uint64 = i - h0
        if ndig >= 8:
            out_r[0] = cast[uint8]((hex_nibble(buf[h0]) * 16) + hex_nibble(buf[h0 + 1]))
            out_g[0] = cast[uint8]((hex_nibble(buf[h0 + 2]) * 16) + hex_nibble(buf[h0 + 3]))
            out_b[0] = cast[uint8]((hex_nibble(buf[h0 + 4]) * 16) + hex_nibble(buf[h0 + 5]))
            out_a[0] = cast[uint8]((hex_nibble(buf[h0 + 6]) * 16) + hex_nibble(buf[h0 + 7]))
            return 1
        if ndig >= 6:
            out_r[0] = cast[uint8]((hex_nibble(buf[h0]) * 16) + hex_nibble(buf[h0 + 1]))
            out_g[0] = cast[uint8]((hex_nibble(buf[h0 + 2]) * 16) + hex_nibble(buf[h0 + 3]))
            out_b[0] = cast[uint8]((hex_nibble(buf[h0 + 4]) * 16) + hex_nibble(buf[h0 + 5]))
            out_a[0] = 255
            return 1
        if ndig >= 3:
            rr: int32 = hex_nibble(buf[h0])
            gg: int32 = hex_nibble(buf[h0 + 1])
            bb: int32 = hex_nibble(buf[h0 + 2])
            out_r[0] = cast[uint8](rr * 16 + rr)
            out_g[0] = cast[uint8](gg * 16 + gg)
            out_b[0] = cast[uint8](bb * 16 + bb)
            out_a[0] = 255
            return 1
        return 0
    return 0


_fail: int32 = 0


def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _check(label: Ptr[uint8], color: Ptr[uint8],
           want_r: uint8, want_g: uint8, want_b: uint8, want_a: uint8):
    r: Array[1, uint8]
    g: Array[1, uint8]
    b: Array[1, uint8]
    a: Array[1, uint8]
    r[0] = 0
    g[0] = 0
    b[0] = 0
    a[0] = 0
    n: uint64 = _strlen(color)
    rc: int32 = parse_color(color, 0, n, &r[0], &g[0], &b[0], &a[0])
    if rc == 0:
        _puts(2, "[parsecolor] FAIL ")
        _puts(2, label)
        _puts(2, " parse_color rejected the colour\n")
        _fail = 1
        return
    if r[0] != want_r or g[0] != want_g or b[0] != want_b or a[0] != want_a:
        _puts(2, "[parsecolor] FAIL ")
        _puts(2, label)
        _puts(2, " ARGB mismatch\n")
        _fail = 1
        return
    _puts(1, "[parsecolor] PASS ")
    _puts(1, label)
    _puts(1, "\n")


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # The bug's smoking gun: the area-dim overlay colour must keep its 0x66
    # alpha (was clobbered to 255 -> opaque black over the whole screen).
    _check(cast[Ptr[uint8]]("dim-overlay #00000066 alpha=0x66"),
           cast[Ptr[uint8]]("#00000066"), 0x00, 0x00, 0x00, 0x66)
    _check(cast[Ptr[uint8]]("sel-fill #ffffff22 alpha=0x22"),
           cast[Ptr[uint8]]("#ffffff22"), 0xff, 0xff, 0xff, 0x22)
    # 6-digit and 3-digit colours must still parse as fully opaque.
    _check(cast[Ptr[uint8]]("opaque6 #ff8800 alpha=0xff"),
           cast[Ptr[uint8]]("#ff8800"), 0xff, 0x88, 0x00, 0xff)
    _check(cast[Ptr[uint8]]("opaque3 #f80 alpha=0xff"),
           cast[Ptr[uint8]]("#f80"), 0xff, 0x88, 0x00, 0xff)
    if _fail != 0:
        _puts(2, "[parsecolor] FAIL one or more assertions failed\n")
        return 1
    _puts(1, "[parsecolor] PASS all alpha assertions\n")
    return 0

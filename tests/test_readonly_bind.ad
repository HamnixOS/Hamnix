# tests/test_readonly_bind.ad
#
# Task #69 regression: KERNEL-ENFORCED read-only bind flag (MRDONLY).
#
# Proves that a binding created with the read-only flag is IMMUTABLE
# THROUGH THE VIEW — reads/stat resolve normally but every mutation
# (create / write-open / O_TRUNC / remove) is denied with EROFS — while
# a NON-read-only bind of the SAME source still permits all of them.
# The control arm is what proves the flag itself is the cause, not a
# blanket denial: same tmpfs backing, two views, only the flag differs.
#
# Scenario (all through the NATIVE syscall seams a user hits):
#
#   setup:   seed /tmp/rb_seed = "HELLO"  (tmpfs is writable)
#            bind -r /tmp -> /rb_ro        (read-only VIEW, flag MRDONLY)
#            bind    /tmp -> /rb_rw        (normal VIEW, control)
#
#   READ:    open /rb_ro/rb_seed, read "HELLO"        -> MUST succeed
#   CREATE:  open_write /rb_ro/rb_new                 -> MUST fail (EROFS)
#            and /rb_rw/rb_new MUST NOT exist          (no side effect)
#   WRITE:   open_write /rb_ro/rb_seed (would O_TRUNC) -> MUST fail (EROFS)
#            and /rb_rw/rb_seed still reads "HELLO"     (untruncated)
#   REMOVE:  remove /rb_ro/rb_seed                    -> MUST fail (EROFS)
#            and /rb_rw/rb_seed still opens             (still there)
#   CONTROL: open_write /rb_rw/rb_ctrl = "CTRL"       -> MUST succeed
#            read it back through /rb_ro/rb_ctrl == "CTRL"  (reads see it)
#            remove /rb_rw/rb_ctrl                     -> MUST succeed
#
# Final marker: `[readonly_bind] PASS`. Greppable from
# scripts/test_readonly_bind.sh.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_readonly_bind.ad -o build/user/test_readonly_bind.elf
#
# Run via scripts/test_readonly_bind.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_BIND:    uint64 = 257
SYS_REMOVE:  uint64 = 263

# Plan 9 bind/mount flag bits (mirror sys/src/9/port/chan.ad).
MREPL:       int32 = 0
MRDONLY_BIT: int32 = 16


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def do_bind(new_path: Ptr[uint8], old_path: Ptr[uint8],
            flag: int32) -> int64:
    return syscall6(SYS_BIND,
                    cast[uint64](new_path),
                    cast[uint64](old_path),
                    cast[uint64](flag), 0, 0, 0)


def do_remove(path: Ptr[uint8]) -> int64:
    return syscall6(SYS_REMOVE, cast[uint64](path), 0, 0, 0, 0, 0)


# Write `bytes` (len n) to a NEW/truncated file. Returns 0 on success,
# the negative open_write rc on a denied/failed open, or -999 on a
# short write.
def write_file(path: Ptr[char], bytes: Ptr[uint8], n: uint64) -> int64:
    fd: int32 = sys_open_write(path)
    if fd < 0:
        return cast[int64](fd)
    wr: int64 = sys_write(fd, bytes, n)
    sys_close(fd)
    if wr != cast[int64](n):
        return -999
    return 0


# Read up to cap bytes of `path` into buf. Returns the byte count, or a
# negative sys_open rc if the file does not resolve.
def read_file(path: Ptr[char], buf: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return cast[int64](fd)
    n: int64 = sys_read(fd, buf, cap)
    sys_close(fd)
    return n


def buf_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def main() -> int32:
    write_str(1, "[readonly_bind] start\n")

    # ---------------------------------------------------------------
    # Setup: seed a file in the writable tmpfs source, then bind two
    # views of it — one read-only (flag MRDONLY), one normal (control).
    if write_file("/tmp/rb_seed", "HELLO", 5) != 0:
        write_str(1, "[readonly_bind] FAIL: could not seed /tmp/rb_seed (tmpfs write?)\n")
        return 1
    write_str(1, "[readonly_bind] seed ok\n")

    ro_rc: int64 = do_bind("/rb_ro", "/tmp", MREPL | MRDONLY_BIT)
    if ro_rc != 0:
        write_str(1, "[readonly_bind] FAIL: bind -r /tmp -> /rb_ro rc=")
        write_dec(1, cast[uint64](ro_rc))
        write_str(1, "\n")
        return 2
    rw_rc: int64 = do_bind("/rb_rw", "/tmp", MREPL)
    if rw_rc != 0:
        write_str(1, "[readonly_bind] FAIL: bind /tmp -> /rb_rw rc=")
        write_dec(1, cast[uint64](rw_rc))
        write_str(1, "\n")
        return 3
    write_str(1, "[readonly_bind] bind ro/rw ok\n")

    rb: Array[32, uint8]

    # ---------------------------------------------------------------
    # READ through the read-only view MUST work (reads are never gated).
    rn: int64 = read_file("/rb_ro/rb_seed", &rb[0], 32)
    if rn != 5 or buf_eq(&rb[0], "HELLO", 5) == 0:
        write_str(1, "[readonly_bind] FAIL: read through /rb_ro/rb_seed (rn=")
        write_dec(1, cast[uint64](rn))
        write_str(1, ")\n")
        return 4
    write_str(1, "[readonly_bind] read-through-ro ok\n")

    # ---------------------------------------------------------------
    # CREATE through the read-only view MUST be denied with EROFS (-30).
    cfd: int32 = sys_open_write("/rb_ro/rb_new")
    if cfd >= 0:
        sys_close(cfd)
        write_str(1, "[readonly_bind] FAIL: create /rb_ro/rb_new was ALLOWED (fd>=0)\n")
        return 5
    write_str(1, "[readonly_bind] create denied (EROFS) rc=")
    write_dec(1, cast[uint64](cast[int64](cfd)))
    write_str(1, "\n")
    # ...and it must have had NO side effect on the backing store.
    if sys_open("/rb_rw/rb_new") >= 0:
        write_str(1, "[readonly_bind] FAIL: /rb_rw/rb_new EXISTS — denied create still wrote\n")
        return 6
    write_str(1, "[readonly_bind] create had no effect\n")

    # ---------------------------------------------------------------
    # WRITE-OPEN (O_TRUNC) of an EXISTING file through the RO view MUST
    # be denied — and the file must remain un-truncated (still "HELLO").
    wfd: int32 = sys_open_write("/rb_ro/rb_seed")
    if wfd >= 0:
        sys_close(wfd)
        write_str(1, "[readonly_bind] FAIL: write-open /rb_ro/rb_seed was ALLOWED (fd>=0)\n")
        return 7
    write_str(1, "[readonly_bind] write denied (EROFS) rc=")
    write_dec(1, cast[uint64](cast[int64](wfd)))
    write_str(1, "\n")
    rn2: int64 = read_file("/rb_rw/rb_seed", &rb[0], 32)
    if rn2 != 5 or buf_eq(&rb[0], "HELLO", 5) == 0:
        write_str(1, "[readonly_bind] FAIL: /rb_rw/rb_seed mutated by denied write (rn=")
        write_dec(1, cast[uint64](rn2))
        write_str(1, ")\n")
        return 8
    write_str(1, "[readonly_bind] write had no effect\n")

    # ---------------------------------------------------------------
    # REMOVE through the RO view MUST be denied — file must survive.
    dr: int64 = do_remove("/rb_ro/rb_seed")
    if dr >= 0:
        write_str(1, "[readonly_bind] FAIL: remove /rb_ro/rb_seed was ALLOWED (rc>=0)\n")
        return 9
    write_str(1, "[readonly_bind] remove denied (EROFS) rc=")
    write_dec(1, cast[uint64](dr))
    write_str(1, "\n")
    if sys_open("/rb_rw/rb_seed") < 0:
        write_str(1, "[readonly_bind] FAIL: /rb_rw/rb_seed GONE — denied remove still unlinked\n")
        return 10
    write_str(1, "[readonly_bind] remove had no effect\n")

    # ---------------------------------------------------------------
    # CONTROL: the SAME source bound WITHOUT the flag must still permit
    # create + read-back + remove. Proves the flag is the cause of the
    # denials above, not a blanket refusal on the backing store.
    if write_file("/rb_rw/rb_ctrl", "CTRL", 4) != 0:
        write_str(1, "[readonly_bind] FAIL: control create /rb_rw/rb_ctrl DENIED (non-ro bind should allow)\n")
        return 11
    write_str(1, "[readonly_bind] control write ok (rw view)\n")
    # Read it back THROUGH the read-only view — reads see live data.
    cn: int64 = read_file("/rb_ro/rb_ctrl", &rb[0], 32)
    if cn != 4 or buf_eq(&rb[0], "CTRL", 4) == 0:
        write_str(1, "[readonly_bind] FAIL: read-back /rb_ro/rb_ctrl (cn=")
        write_dec(1, cast[uint64](cn))
        write_str(1, ")\n")
        return 12
    write_str(1, "[readonly_bind] control read-back ok (ro view)\n")
    if do_remove("/rb_rw/rb_ctrl") != 0:
        write_str(1, "[readonly_bind] FAIL: control remove /rb_rw/rb_ctrl DENIED\n")
        return 13
    write_str(1, "[readonly_bind] control remove ok (rw view)\n")

    # Clean up the seed + views so a re-run from the same hamsh is clean.
    do_remove("/rb_rw/rb_seed")

    write_str(1, "[readonly_bind] PASS\n")
    return 0

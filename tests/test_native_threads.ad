# tests/test_native_threads.ad
#
# #443 gate fixture: lib/thread.ad end-to-end on the NATIVE stack.
#
# What it proves, strictly:
#   1. thread_spawn creates real RFMEM threads on library-managed
#      stacks (4 of them, concurrently live).
#   2. mutex_lock/mutex_unlock provide REAL mutual exclusion: each
#      worker does 10000 read-modify-write increments of a shared
#      counter inside the mutex. Any lost update (broken atomics,
#      broken semacquire sleep/wake, broken share) makes the final
#      count != 40000 and the test FAILs on the exact-count check.
#   3. thread_join blocks until each worker exited (kernel exit-sem
#      release via SYS_SETEXITSEM) and reclaims its stack.
#   4. chan_send/chan_recv pass values across threads (a fifth worker
#      echoes v+1 for 100 sends through a pair of bounded channels).
#
# The deliberately NON-atomic increment (load; yield-ish work; store)
# maximises the window so a fake mutex loses updates with certainty,
# not probabilistically.
#
# Build (the gate script does this):
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_native_threads.ad -o build/user/test_native_threads.elf
#
# Run via scripts/test_native_threads.sh. Markers:
#   [nthreads] start
#   [nthreads] spawned 4 workers
#   [nthreads] joined all
#   [nthreads] counter=40000
#   [nthreads] chan echo ok
#   [nthreads] PASS

from lib.thread import (
    thread_spawn, thread_join,
    Mutex, mutex_init, mutex_lock, mutex_unlock,
    Chan, chan_init, chan_send, chan_recv,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)

N_WORKERS: uint64 = 4
N_ITERS:   uint64 = 10000

counter: uint64 = 0
mtx: Array[1, Mutex]

# Channel pair for the echo worker: requests in, replies out.
req: Array[1, Chan]
rep: Array[1, Chan]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def worker(arg: uint64) -> uint64:
    # 10000 mutex-protected increments. The increment is deliberately
    # a separate load and store with detectable width between them, so
    # a non-exclusive "mutex" WILL interleave and lose updates.
    i: uint64 = 0
    while i < N_ITERS:
        mutex_lock(&mtx[0])
        v: uint64 = counter
        v = v + 1
        counter = v
        mutex_unlock(&mtx[0])
        i = i + 1
    return arg


def echo_worker(arg: uint64) -> uint64:
    # Receive 100 values on req, send each back +1 on rep.
    i: uint64 = 0
    while i < 100:
        v: uint64 = chan_recv(&req[0])
        chan_send(&rep[0], v + 1)
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[nthreads] start\n")

    mutex_init(&mtx[0])
    chan_init(&req[0])
    chan_init(&rep[0])

    # --- Part 1: mutex contention -----------------------------------
    tids: Array[4, int32]
    i: uint64 = 0
    while i < N_WORKERS:
        tid: int32 = thread_spawn(worker, i)
        if tid <= 0:
            write_str(1, "[nthreads] FAIL: spawn rc<=0\n")
            return 1
        tids[i] = tid
        i = i + 1
    write_str(1, "[nthreads] spawned 4 workers\n")

    i = 0
    while i < N_WORKERS:
        rc: int32 = thread_join(tids[i])
        if rc != 0:
            write_str(1, "[nthreads] FAIL: join rc!=0\n")
            return 2
        i = i + 1
    write_str(1, "[nthreads] joined all\n")

    write_str(1, "[nthreads] counter=")
    write_dec(1, counter)
    write_str(1, "\n")
    if counter != N_WORKERS * N_ITERS:
        write_str(1, "[nthreads] FAIL: lost updates\n")
        return 3

    # --- Part 2: channels --------------------------------------------
    etid: int32 = thread_spawn(echo_worker, 0)
    if etid <= 0:
        write_str(1, "[nthreads] FAIL: echo spawn\n")
        return 4
    v: uint64 = 0
    ok: uint64 = 1
    while v < 100:
        chan_send(&req[0], v * 7)
        r: uint64 = chan_recv(&rep[0])
        if r != v * 7 + 1:
            ok = 0
        v = v + 1
    rc2: int32 = thread_join(etid)
    if rc2 != 0 or ok == 0:
        write_str(1, "[nthreads] FAIL: chan echo\n")
        return 5
    write_str(1, "[nthreads] chan echo ok\n")

    write_str(1, "[nthreads] PASS\n")
    return 0

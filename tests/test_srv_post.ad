# tests/test_srv_post.ad
#
# Phase D / V4 regression: prove that sys_srv_post (275) and
# sys_srv_open (276) wire a posted srvfd between two userspace
# tasks. The end-to-end flow is the smallest non-trivial 9P
# bootstrap loop:
#
#   parent: pipe() -> (rfd, wfd)
#   parent: sys_srv_post("test", wfd)
#   parent: rfork() to spawn child
#   parent: write a sentinel byte through wfd
#   parent: waitpid(child)
#
#   child: sys_srv_open("test") -> fd (NEW fd in the child's table,
#          backed by the SAME pipe write-end the parent posted)
#   child: write a different sentinel through the dup'd fd
#   child: exit(0)
#
#   parent (after child exits): sys_read(rfd) — must see both
#   sentinels in order, proving (a) the child's srv_open dup'd the
#   right pipe end and (b) the parent's original wfd survived the
#   child's close.
#
# Markers grepped by scripts/test_srv_post.sh:
#
#   [srv_post] start
#   [srv_post] posted
#   [srv_post] child_open OK
#   [srv_post] child_wrote OK
#   [srv_post] parent_read OK
#   [srv_post] PASS
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_srv_post.ad -o build/user/test_srv_post.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_rfork(flags: int32) -> int32
extern def sys_waitpid(pid: uint64) -> int64
extern def sys_exit(code: uint64)
extern def sys_srv_post(name: Ptr[char], srvfd: int32) -> int32
extern def sys_srv_open(name: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32

# Plan 9 POSIX-fork combo. RFFDG copies the parent's fd table into
# the child — that's what gives the child its OWN `rfd` view of the
# pipe so the parent's write side stays alive even if the child
# closes its inherited copy. RFNAMEG / RFENVG aren't strictly needed
# for this test (we don't touch namespace or env) but they match
# docs/native-api.md's POSIX-fork idiom.
RFPROC:   int32 = 0x001
RFFDG:    int32 = 0x004
RFNAMEG:  int32 = 0x008
RFENVG:   int32 = 0x010

# Sentinel bytes — distinct so we can prove ordering on the read side.
PARENT_SENTINEL: uint8 = 65                          # 'A'
CHILD_SENTINEL:  uint8 = 66                          # 'B'

# Top-level scratch (Adder's nested-frame Array bug workaround).
fds_buf: Array[2, int32]
read_buf: Array[16, uint8]
err_buf:  Array[128, uint8]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def dump_errstr(label: Ptr[uint8]):
    # Pull the current Plan 9 errstr and print it next to the label.
    # Used by every failure path to give the host harness something
    # actionable instead of a bare `FAIL`.
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def main() -> int32:
    write_str(1, "[srv_post] start\n")

    # ----------------------------------------------------------------
    # 1) Open a pipe. fds_buf[0] is the read end, fds_buf[1] is the
    #    write end. We'll post the write end at "/srv/test" and have
    #    the child open it.
    pipe_rc: int32 = sys_pipe(&fds_buf[0])
    if pipe_rc < 0:
        dump_errstr("[srv_post] FAIL: sys_pipe errstr=")
        return 1
    rfd: int32 = fds_buf[0]
    wfd: int32 = fds_buf[1]

    # ----------------------------------------------------------------
    # 2) Post the write-end at /srv/test. After this the kernel's
    #    devsrv table holds (name="test", srvfd=wfd, poster_slot=us).
    #    The parent keeps `wfd` open in its own table — sys_srv_post
    #    does NOT close it.
    post_rc: int32 = sys_srv_post("test", wfd)
    if post_rc < 0:
        dump_errstr("[srv_post] FAIL: sys_srv_post errstr=")
        return 2
    write_str(1, "[srv_post] posted\n")

    # ----------------------------------------------------------------
    # 3) Fork. The child inherits a COPY of our fd table (RFFDG), so
    #    rfd / wfd are valid in both processes for a moment. The
    #    child closes its inherited wfd-copy right away (it will get
    #    its OWN dup of wfd through sys_srv_open) so the pipe doesn't
    #    have a stale extra writer. We only read in the parent so the
    #    extra reader is harmless.
    flags: int32 = RFPROC | RFFDG | RFNAMEG | RFENVG
    pid: int32 = sys_rfork(flags)
    if pid < 0:
        dump_errstr("[srv_post] FAIL: sys_rfork errstr=")
        return 3

    if pid == 0:
        # ----- CHILD -----
        # Drop the inherited fds we don't want — the parent will read
        # from rfd, and we'll get a fresh write fd via sys_srv_open.
        sys_close(rfd)
        sys_close(wfd)

        child_fd: int32 = sys_srv_open("test")
        if child_fd < 0:
            dump_errstr("[srv_post] FAIL_CHILD: sys_srv_open errstr=")
            sys_exit(10)
        write_str(1, "[srv_post] child_open OK\n")

        # Write the child's sentinel through the dup'd fd. The parent's
        # rfd must see it on the next sys_read.
        cb: Array[1, uint8]
        cb[0] = CHILD_SENTINEL
        cw: int64 = sys_write(child_fd, &cb[0], 1)
        if cw != 1:
            dump_errstr("[srv_post] FAIL_CHILD: child write errstr=")
            sys_exit(11)
        write_str(1, "[srv_post] child_wrote OK\n")
        sys_close(child_fd)
        sys_exit(0)
        return 0                                     # not reached

    # ----- PARENT -----
    # Before waitpid, write our own sentinel. The pipe is buffered so
    # this can land before OR after the child's write — we don't pin
    # ordering; the test bar is "both sentinels show up in any order".
    pb: Array[1, uint8]
    pb[0] = PARENT_SENTINEL
    pw: int64 = sys_write(wfd, &pb[0], 1)
    if pw != 1:
        dump_errstr("[srv_post] FAIL: parent write errstr=")
        return 4

    # Wait for the child so its write is definitely flushed before
    # we drain the pipe. sys_waitpid blocks + reaps the slot.
    wait_rc: int64 = sys_waitpid(cast[uint64](pid))
    if wait_rc < 0:
        dump_errstr("[srv_post] FAIL: waitpid errstr=")
        return 5

    # Close the parent's wfd BEFORE the final read so the pipe's
    # writer count hits zero and sys_read returns at EOF instead of
    # blocking forever (the child already closed its dup).
    sys_close(wfd)

    # Drain. Both sentinels must be present in the first 16 bytes.
    n: int64 = sys_read(rfd, &read_buf[0], 16)
    if n < 0:
        dump_errstr("[srv_post] FAIL: parent read errstr=")
        return 6
    if n < 2:
        write_str(1, "[srv_post] FAIL: read got fewer than 2 bytes\n")
        return 7

    saw_parent: int32 = 0
    saw_child:  int32 = 0
    i: uint64 = 0
    while i < cast[uint64](n):
        if read_buf[i] == PARENT_SENTINEL:
            saw_parent = 1
        if read_buf[i] == CHILD_SENTINEL:
            saw_child = 1
        i = i + 1
    if saw_parent == 0:
        write_str(1, "[srv_post] FAIL: parent sentinel missing\n")
        return 8
    if saw_child == 0:
        write_str(1, "[srv_post] FAIL: child sentinel missing\n")
        return 9
    write_str(1, "[srv_post] parent_read OK\n")

    sys_close(rfd)

    write_str(1, "[srv_post] PASS\n")
    return 0

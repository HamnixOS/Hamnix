# tests/test_sshd_hostkey.ad
#
# Host-key generation + persistence regression for the Hamnix SSH
# server. user/sshd.ad no longer ships a baked-in host key: it
# GENERATES an ECDSA-P256 host private scalar from /dev/random on
# first start, PERSISTS it to /var/lib/ssh/ssh_host_ecdsa_key, and on
# every later start LOADS the persisted key — so each system keeps a
# stable host identity.
#
# This fixture exercises that exact load-or-generate-then-persist
# cycle (the same routine bodies as sshd's _load_host_key /
# _generate_host_key), asserting:
#
#   1. First run: no key file yet -> a fresh 32-byte scalar is drawn
#      from /dev/random, it lands in [1, n-1], and it persists.
#   2. Re-load: opening the persisted file yields a key BYTE-FOR-BYTE
#      identical to the generated one (persistence works).
#   3. The public point Q = d*G is identical across the generate path
#      and the re-load path (the host identity is stable).
#   4. A degenerate stored key (all-zero scalar, which is NOT in
#      [1, n-1]) is correctly REJECTED by the range check, so a
#      corrupt file forces regeneration rather than a bad key.
#
# /var/lib/ssh is pre-created by the tmpfs /var skeleton, so the
# persist write has a parent directory.
#
# Driven by scripts/test_sshd_hostkey.sh. PASS criterion:
#   "[hostkey] failures=0" AND "[hostkey] PASS" both in the log.

from lib.ec.p256 import (
    P256Point, P256_N,
    p256_init, p256_be_to_limbs, p256_scalar_mul_g,
    p256_is_zero, p256_ge,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_exit(code: uint64)


# -- tiny printer ----------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


fail_count: int32 = 0


def _fail(label: Ptr[uint8]):
    _wstr("[hostkey] FAIL: ")
    _wstr(label)
    _wstr("\n")
    fail_count = fail_count + 1


def _ok(label: Ptr[uint8]):
    _wstr("[hostkey] OK: ")
    _wstr(label)
    _wstr("\n")


# Path under the daemon's /var/lib/ssh namespace dir. Returned fresh
# (string-literal module globals are unsupported by the compiler).
def _key_path() -> Ptr[char]:
    return cast[Ptr[char]]("/var/lib/ssh/ssh_host_ecdsa_key")


# A 32-byte big-endian scalar is a usable host key iff 1 <= d < n.
def _scalar_in_range(d_be: Ptr[uint8]) -> int32:
    d: Array[4, uint64]
    if p256_be_to_limbs(&d[0], d_be, cast[uint64](32)) != 0:
        return 0
    if p256_is_zero(&d[0]) != 0:
        return 0
    if p256_ge(&d[0], &P256_N[0]) != 0:
        return 0
    return 1


def _write_all(fd: int32, buf: Ptr[uint8], n: uint64) -> int32:
    pos: uint64 = 0
    while pos < n:
        w: int64 = sys_write(fd, cast[Ptr[uint8]](
                             cast[uint64](buf) + pos), n - pos)
        if w <= 0:
            return -1
        pos = pos + cast[uint64](w)
    return 0


def _read_all(fd: int32, buf: Ptr[uint8], n: uint64) -> uint64:
    pos: uint64 = 0
    while pos < n:
        r: int64 = sys_read(fd, cast[Ptr[uint8]](
                            cast[uint64](buf) + pos), n - pos)
        if r <= 0:
            break
        pos = pos + cast[uint64](r)
    return pos


# Generated key + its public point.
gen_d: Array[32, uint8]
gen_qx: Array[32, uint8]
gen_qy: Array[32, uint8]

# Re-loaded key + its public point.
load_d: Array[32, uint8]
load_qx: Array[32, uint8]
load_qy: Array[32, uint8]


def _limbs_to_be32(out_be: Ptr[uint8], limbs: Ptr[uint64]):
    i: uint64 = 0
    while i < 32:
        limb_idx: uint64 = (31 - i) / 8
        shift: uint64 = ((31 - i) & 7) * 8
        out_be[i] = cast[uint8]((limbs[limb_idx] >> shift) & 0xFF)
        i = i + 1


def _pub_point(d_be: Ptr[uint8], qx: Ptr[uint8], qy: Ptr[uint8]):
    d: Array[4, uint64]
    p256_be_to_limbs(&d[0], d_be, cast[uint64](32))
    Q: P256Point
    p256_scalar_mul_g(&Q, &d[0])
    _limbs_to_be32(qx, &Q.x[0])
    _limbs_to_be32(qy, &Q.y[0])


def _be32_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while i < 32:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def main() -> int32:
    _wstr("[hostkey] start\n")
    p256_init()

    # --- 1. generate a fresh host key from /dev/random ---------------
    # No key file should exist yet; open it to confirm that.
    pre: int32 = sys_open(_key_path())
    if pre >= 0:
        sys_close(pre)
        # On a fresh boot /var is RAM-backed and empty; if a stale key
        # is somehow present this is still fine for the rest of the
        # test, just note it.
        _wstr("[hostkey] NOTE: a key file already exists pre-test\n")

    rfd: int32 = sys_open("/dev/random")
    if rfd < 0:
        _fail("open /dev/random")
        _wstr("[hostkey] failures=1\n[hostkey] FAILED\n")
        sys_exit(0)
        return 0
    drawn: int32 = 0
    tries: uint32 = 0
    while tries < 16:
        tries = tries + 1
        got: uint64 = _read_all(rfd, &gen_d[0], cast[uint64](32))
        if got != 32:
            continue
        if _scalar_in_range(&gen_d[0]) != 0:
            drawn = 1
            break
    sys_close(rfd)
    if drawn == 0:
        _fail("draw a usable host scalar from /dev/random")
    else:
        _ok("generated a host scalar in [1, n-1] from /dev/random")
    _pub_point(&gen_d[0], &gen_qx[0], &gen_qy[0])

    # --- persist it --------------------------------------------------
    wfd: int32 = sys_open_write(_key_path())
    if wfd < 0:
        _fail("open the host-key file for writing")
    else:
        if _write_all(wfd, &gen_d[0], cast[uint64](32)) != 0:
            _fail("write 32 host-key bytes")
        else:
            _ok("persisted the host key to /var/lib/ssh")
        sys_close(wfd)

    # --- 2. re-load and confirm a byte-exact round-trip --------------
    rfd2: int32 = sys_open(_key_path())
    if rfd2 < 0:
        _fail("re-open the persisted host-key file")
    else:
        got2: uint64 = _read_all(rfd2, &load_d[0], cast[uint64](32))
        sys_close(rfd2)
        if got2 != 32:
            _fail("re-read 32 host-key bytes")
        elif _scalar_in_range(&load_d[0]) == 0:
            _fail("re-loaded scalar is out of range")
        elif _be32_eq(&gen_d[0], &load_d[0]) == 0:
            _fail("persisted key does not round-trip byte-for-byte")
        else:
            _ok("persisted host key re-loaded byte-for-byte identical")

    # --- 3. the public identity is stable across reload -------------
    _pub_point(&load_d[0], &load_qx[0], &load_qy[0])
    if _be32_eq(&gen_qx[0], &load_qx[0]) != 0 and \
       _be32_eq(&gen_qy[0], &load_qy[0]) != 0:
        _ok("host public point Q = d*G is stable across reload")
    else:
        _fail("host public point differs after reload")

    # --- 4. a degenerate (all-zero) stored key is rejected ----------
    zero_d: Array[32, uint8]
    i: uint64 = 0
    while i < 32:
        zero_d[i] = 0
        i = i + 1
    if _scalar_in_range(&zero_d[0]) == 0:
        _ok("range check rejects an all-zero (corrupt) stored key")
    else:
        _fail("range check accepted an all-zero scalar")

    _wstr("[hostkey] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[hostkey] PASS\n")
    else:
        _wstr("[hostkey] FAILED\n")
    sys_exit(0)
    return 0

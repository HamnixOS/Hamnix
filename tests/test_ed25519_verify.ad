# tests/test_ed25519_verify.ad
#
# Host-side (x86_64-linux target) exerciser for lib/ed25519.ad's
# detached Ed25519 verifier. Reads three raw binary files whose paths
# are passed as argv:
#
#   argv[1] : 32-byte public key
#   argv[2] : 64-byte signature (R || S)
#   argv[3] : message (arbitrary length)
#
# Exit codes:
#   0  signature VALID
#   1  signature INVALID (verify returned 0)
#   90..97 argument / syscall / size errors
#
# Driven by scripts/test_hpm_signed_index.sh, which generates the key,
# signs a real index.json with Python's Ed25519 (the same code path
# scripts/hpm_sign.py uses at repo-build time), then asserts a good
# signature verifies and a tampered one is rejected — proving the
# sign(build)->verify(hpm) trust chain end-to-end without QEMU.

from lib.ed25519 import ed25519_verify

extern def sys_open(path: Ptr[uint8], flags: int64, mode: int64) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

O_RDONLY: int64 = 0

pk_buf:  Array[32, uint8]
sig_buf: Array[64, uint8]
msg_buf: Array[1048576, uint8]


# Read exactly `want` bytes from `path` into `dst`; returns 0 on
# success, negative on open/short-read failure.
def _read_exact(path: Ptr[uint8], dst: Ptr[uint8], want: uint64) -> int64:
    fd: int32 = sys_open(path, O_RDONLY, 0)
    if fd < 0:
        return -1
    got: uint64 = 0
    while got < want:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](dst) + got),
                            want - got)
        if n <= 0:
            sys_close(fd)
            return -2
        got = got + cast[uint64](n)
    sys_close(fd)
    return 0


# Read a whole file (up to cap) into dst; returns byte count or -1.
def _read_all(path: Ptr[uint8], dst: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path, O_RDONLY, 0)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, cast[Ptr[uint8]](cast[uint64](dst) + total),
                            cap - total)
        if n < 0:
            sys_close(fd)
            return -1
        if n == 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 4:
        return 90
    pk_path:  Ptr[uint8] = cast[Ptr[uint8]](argv[1])
    sig_path: Ptr[uint8] = cast[Ptr[uint8]](argv[2])
    msg_path: Ptr[uint8] = cast[Ptr[uint8]](argv[3])

    if _read_exact(pk_path, &pk_buf[0], 32) != 0:
        return 91
    if _read_exact(sig_path, &sig_buf[0], 64) != 0:
        return 92
    mlen: int64 = _read_all(msg_path, &msg_buf[0], 1048576)
    if mlen < 0:
        return 93

    v: int32 = ed25519_verify(&pk_buf[0], &sig_buf[0],
                              &msg_buf[0], cast[uint64](mlen))
    if v == 1:
        return 0
    return 1

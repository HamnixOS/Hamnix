# Top-level X509Cert and RsaPubkey records — kept off the stack.
cert: X509Cert
pubkey: RsaPubkey


# Bigint smoke fixtures — kept at module scope because the Bigint
# class is 520 bytes and stacking several in main()'s frame trips the
# nested-Array spill quirk noted in memory/feedback_compiler_quirks.md.
smoke_a: Bigint
smoke_b: Bigint
smoke_m: Bigint
smoke_r: Bigint


def _smoke_check_u64(got: uint64, want: uint64, label: Ptr[uint8]):
    if got != want:
        _wstr("[rsa_pss] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec(got)
        _wstr(" want=")
        _wdec(want)
        _wstr("\n")
        fail_count = fail_count + 1


def _smoke_bigint_layer():
    # Tiny modmul: 7 * 11 mod 13 = 12.
    bigint_zero(&smoke_a)
    bigint_zero(&smoke_b)
    bigint_zero(&smoke_m)
    bigint_zero(&smoke_r)
    smoke_a.limbs[0] = 7
    smoke_a.n_limbs = 1
    smoke_b.limbs[0] = 11
    smoke_b.n_limbs = 1
    smoke_m.limbs[0] = 13
    smoke_m.n_limbs = 1
    bigint_modmul(&smoke_r, &smoke_a, &smoke_b, &smoke_m)
    _smoke_check_u64(smoke_r.limbs[0], cast[uint64](12),
                     "smoke: 7*11 mod 13")

    # Tiny modexp: 5^4 mod 13 = 625 mod 13 = 1.
    bigint_zero(&smoke_a)
    bigint_zero(&smoke_b)
    bigint_zero(&smoke_m)
    bigint_zero(&smoke_r)
    smoke_a.limbs[0] = 5
    smoke_a.n_limbs = 1
    smoke_b.limbs[0] = 4
    smoke_b.n_limbs = 1
    smoke_m.limbs[0] = 13
    smoke_m.n_limbs = 1
    bigint_modexp(&smoke_r, &smoke_a, &smoke_b, &smoke_m)
    _smoke_check_u64(smoke_r.limbs[0], cast[uint64](1),
                     "smoke: 5^4 mod 13")

    # 3^4 mod 100 = 81.
    bigint_zero(&smoke_a)
    bigint_zero(&smoke_b)
    bigint_zero(&smoke_m)
    bigint_zero(&smoke_r)
    smoke_a.limbs[0] = 3
    smoke_a.n_limbs = 1
    smoke_b.limbs[0] = 4
    smoke_b.n_limbs = 1
    smoke_m.limbs[0] = 100
    smoke_m.n_limbs = 1
    bigint_modexp(&smoke_r, &smoke_a, &smoke_b, &smoke_m)
    _smoke_check_u64(smoke_r.limbs[0], cast[uint64](81),
                     "smoke: 3^4 mod 100")


def main() -> int32:
    _wstr("[rsa_pss] start\n")
    asn1_init_oids()
    rsa_init()
    _init_cert()

    # Tiny-modulus bigint smoke first — proves the modmul/modexp kernels
    # don't lie before we trust them with a 2048-bit modulus.
    _smoke_bigint_layer()

    # Parse the cert with V1.
    rc: int32 = x509_parse(&cert_der[0], cert_der_len, &cert)
    _check_eq_i32(rc, 0, "x509_parse rc==0")
    if rc != 0:
        _wstr("[rsa_pss] failures=")
        _wdec(cast[uint64](fail_count))
        _wstr("\n[rsa_pss] FAIL\n")
        return 1

    # Sanity: the cert really was 2048-bit RSA. The pubkey BIT STRING
    # value is a DER SEQUENCE; pubkey_bytes_len is the BIT STRING value
    # length excluding the unused-bits prefix byte.
    _check(cert.pubkey_bytes_len > cast[uint64](256),
           "pubkey_bytes_len > 256 (RSA-2048 SPKI is ~270 bytes)")

    # Parse the RSA public key from the SPKI bytes.
    rc = rsa_parse_pubkey(&cert.pubkey_bytes[0], cert.pubkey_bytes_len,
                          &pubkey)
    _check_eq_i32(rc, 0, "rsa_parse_pubkey rc==0")
    if rc != 0:
        _wstr("[rsa_pss] failures=")
        _wdec(cast[uint64](fail_count))
        _wstr("\n[rsa_pss] FAIL\n")
        return 1

    # The parsed key shape must match the openssl-emitted cert.
    _smoke_check_u64(pubkey.mod_bits, cast[uint64](2048),
                     "mod_bits==2048")
    _smoke_check_u64(pubkey.mod_bytes, cast[uint64](256),
                     "mod_bytes==256")

    # TBS / signature byte ranges (matches `openssl asn1parse -i`).
    _smoke_check_u64(cert.tbs_len, cast[uint64](577), "tbs_len==577")
    _smoke_check_u64(cert.sig_bytes_len, cast[uint64](256),
                     "sig_len==256")

    # Positive: verify against the unmodified TBS + signature.
    rc = rsa_pss_verify(&pubkey,
                       cert.tbs_bytes, cert.tbs_len,
                       &cert.sig_bytes[0], cert.sig_bytes_len)
    _check_eq_i32(rc, 1, "verify(good) == 1")
    # On failure, dump the recovered EM bytes for offline forensics.
    if rc != 1:
        _wstr("[rsa_pss] EM[0..16]: ")
        _whex_bytes(&rsa_em_buf[0], cast[uint64](16))
        _wstr("\n[rsa_pss] EM[240..256]: ")
        _whex_bytes(&rsa_em_buf[240], cast[uint64](16))
        _wstr("\n")

    # Negative: flip one byte of the signature and re-verify.
    cert.sig_bytes[100] = cert.sig_bytes[100] ^ 0xFF
    rc = rsa_pss_verify(&pubkey,
                       cert.tbs_bytes, cert.tbs_len,
                       &cert.sig_bytes[0], cert.sig_bytes_len)
    _check_eq_i32(rc, 0, "verify(tampered) == 0")
    # Restore the signature in case any later assertion wants it.
    cert.sig_bytes[100] = cert.sig_bytes[100] ^ 0xFF

    _wstr("[rsa_pss] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[rsa_pss] PASS\n")
        return 0
    _wstr("[rsa_pss] FAIL\n")
    return 1

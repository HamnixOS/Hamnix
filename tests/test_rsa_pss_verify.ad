# tests/test_rsa_pss_verify.ad
#
# RSA-PSS-SHA256 signature verification (V2) round-trip regression.
# Boots a real DER-encoded RSA-2048 self-signed cert (generated with
# openssl, padding mode rsa-pss, salt length 32 — modern Let's Encrypt
# defaults), walks it through V1's x509_parse to recover the TBS byte
# range, the SubjectPublicKeyInfo BIT STRING value, and the trailing
# signature BIT STRING value, then feeds those into V2's
# rsa_pss_verify. Asserts:
#
#   - rsa_pss_verify returns 1 for the unmodified signature.
#   - Flipping a single byte in the signature drops the return value
#     to 0 (proves we're actually doing the math, not unconditionally
#     accepting).
#
# Fixture generated via:
#   openssl req -x509 -newkey rsa:2048 -keyout /tmp/rsa.key \
#       -out /tmp/rsa.crt -days 30 -nodes -sha256 \
#       -sigopt rsa_padding_mode:pss -sigopt rsa_pss_saltlen:32 \
#       -subj '/CN=rsa-test.hamnix.local'
#   openssl x509 -in /tmp/rsa.crt -outform DER -out /tmp/rsa.der
#
# Layout (from `openssl asn1parse -i`):
#   offset   0  SEQUENCE len=905  (outer Certificate, hl=4)
#   offset   4  SEQUENCE len=573  (TBSCertificate, hl=4 -> [4..581) = 577 bytes)
#   offset 581  SEQUENCE len=65   (outer AlgorithmIdentifier rsassaPss)
#   offset 648  BIT STRING len=257 (signature value, hl=4 -> body at +652,
#                                   first body byte 0x00 unused-bits,
#                                   actual sig = [653..909) = 256 bytes)
#
# Driven by scripts/test_rsa_pss_verify.sh.

from lib.asn1.asn1 import asn1_init_oids
from lib.x509.x509 import X509Cert, x509_parse
from lib.rsa.rsa import (
    RsaPubkey,
    rsa_init,
    rsa_parse_pubkey,
    rsa_pss_verify,
    rsa_em_buf,
)
from lib.bigint.bigint import (
    Bigint,
    bigint_modexp,
    bigint_modmul,
    bigint_zero,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer -----------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


fail_count: int32 = 0


def _whex8(b: uint8):
    HEX: Array[16, uint8]
    HEX[0]  = 0x30  # '0'
    HEX[1]  = 0x31
    HEX[2]  = 0x32
    HEX[3]  = 0x33
    HEX[4]  = 0x34
    HEX[5]  = 0x35
    HEX[6]  = 0x36
    HEX[7]  = 0x37
    HEX[8]  = 0x38
    HEX[9]  = 0x39
    HEX[10] = 0x61  # 'a'
    HEX[11] = 0x62
    HEX[12] = 0x63
    HEX[13] = 0x64
    HEX[14] = 0x65
    HEX[15] = 0x66
    out: Array[2, uint8]
    out[0] = HEX[(b >> 4) & 0x0F]
    out[1] = HEX[b & 0x0F]
    sys_write(1, &out[0], 2)


def _whex_bytes(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        _whex8(p[i])
        i = i + 1


def _check(cond: int32, label: Ptr[uint8]):
    if cond == 0:
        _wstr("[rsa_pss] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_eq_i32(a: int32, b: int32, label: Ptr[uint8]):
    if a != b:
        _wstr("[rsa_pss] FAIL: ")
        _wstr(label)
        _wstr(" got=")
        _wdec(cast[uint64](a))
        _wstr(" want=")
        _wdec(cast[uint64](b))
        _wstr("\n")
        fail_count = fail_count + 1



# tests/test_compiler_call_in_expr.ad
#
# Regression fixture for task #82 — a compound expression containing a function
# CALL, and the deeper native-optimizer bug it exposed: DEAD-STORE ELIMINATION
# was dropping stores to GLOBALS.
#
# Two properties are pinned, each observable through `main`'s return (0 == all
# checks pass; a nonzero bit identifies the failing check). The runner drives
# this through the NATIVE self-hosted backend (codegen.ad) with --opt ON and
# OFF and asserts BOTH return 0 (opt must not change the observable result).
#
# ROOT CAUSE the JPEG decoder actually hit (mis-attributed to `(code<<1)|_jbit()`):
# a helper like `_jbit` does `jeof = 1; return 0` — a store to a GLOBAL that is
# not re-read within that helper. opt.ad's Phase-8 dead-STORE elimination proved
# it "dead" on a whole-FUNCTION unused argument, which is only valid for a LOCAL:
# a global store is observable by every other function. The store was silently
# dropped under --opt, so EOF never signalled and Huffman decode corrupted. The
# fix teaches the DSE to skip any target that names a program global.

# --- a mutable global written by a helper, read by another function ---------
gv: int = 0

def set_gv(x: int) -> int:
    # Store to a GLOBAL whose value is NOT re-read inside this helper. The DSE
    # must NOT drop this store — set_gv's whole purpose is the side effect.
    gv = x
    return 0

def read_gv() -> int:
    return gv

# --- a call combined into a compound expression -----------------------------
def one() -> int:
    return 1

# `(a << 1) | one()` — the classic call-in-expression: the already-evaluated
# `a << 1` intermediate must survive the call to `one()`.
def shl_or_call(a: int) -> int:
    return (a << 1) | one()

# Accumulate a call result across a loop with a second call per iteration whose
# effect flows through a global (the _jhuff shape). Each iteration:
#   set_gv(l)            # writes global gv = l
#   acc = acc + read_gv() # reads it back through a call -> acc += l
def loop_accum(n: int) -> int:
    acc: int = 0
    l: int = 0
    while l < n:
        set_gv(l)
        acc = acc + read_gv()
        l = l + 1
    return acc

def main() -> int:
    fails: int = 0

    # Check 1: a helper's store to a global is observable (DSE must not drop it).
    set_gv(7)
    if read_gv() != 7:
        fails = fails | 1

    # Check 2: `(a << 1) | call()` — intermediate survives the call.
    if shl_or_call(3) != 7:        # (3<<1)|1 = 6|1 = 7
        fails = fails | 2
    if shl_or_call(10) != 21:      # (10<<1)|1 = 20|1 = 21
        fails = fails | 2

    # Check 3: loop accumulation across two calls with a global dependency.
    #   loop_accum(4) = 0+1+2+3 = 6
    if loop_accum(4) != 6:
        fails = fails | 4
    #   loop_accum(6) = 0+1+2+3+4+5 = 15
    if loop_accum(6) != 15:
        fails = fails | 4

    return fails

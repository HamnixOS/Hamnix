# tests/test_p9_tauth_e2e.ad
#
# F10-4 / audit §11.2 regression test: end-to-end exercise of
# sys/src/9/port/9p_client.ad::p9c_attach_authed_run on BOTH the
# success path AND the failure path.
#
# The pre-existing test_p9_auth_e2e.sh only covers success: a verified
# /dev/auth fd + p9srv_demo in `post-auth` mode (any non-empty cred
# accepted) → mount succeeds. That leaves the failure leg of the wire
# handshake un-gated: if a future regression makes Tauth-then-Twrite
# silently succeed even when the server Rerrors the Twrite, no test
# would catch it.
#
# This fixture drives BOTH legs against the same kernel client:
#
#   Leg A (success): server spawned as `post-auth-strict eauth-ok live`
#                    expects cred=="live"; the kernel mediator writes
#                    "live" (the verified principal from /dev/auth);
#                    Twrite matches; Tattach succeeds; mount returns 0.
#
#   Leg B (failure): server spawned as `post-auth-strict eauth-bad alice`
#                    expects cred=="alice"; the kernel still writes
#                    "live"; the server Rerrors the Twrite with
#                    "cred mismatch"; p9c_attach_authed_run returns -1;
#                    mount returns -1 with errstr ~ "Tversion/Tattach".
#                    Read-back of /n/eauth-bad/hello fails with ENOENT
#                    because no mount landed at that point.
#
# Pass markers (grepped by scripts/test_p9_tauth_e2e.sh):
#   [p9tauthE2E] start
#   [p9tauthE2E] auth-as-live OK
#   [p9tauthE2E] leg-A spawn OK
#   [p9tauthE2E] leg-A mount OK
#   [p9tauthE2E] leg-A read OK
#   [p9tauthE2E] leg-B spawn OK
#   [p9tauthE2E] leg-B mount rejected (expected)
#   [p9tauthE2E] PASS
# Plus server-side traces:
#   [p9demo-strict] cred matched, afid authed     (leg A)
#   [p9demo-strict] cred mismatch rejected        (leg B)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_srv_open(name: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64
extern def sys_yield() -> int32
extern def sys_unmount(new: Ptr[char], old: Ptr[char]) -> int32

from lib.p9 import spawn

SYS_MOUNT: uint64 = 258
MREPL:     int32  = 0

err_buf: Array[128, uint8]
read_buf: Array[64, uint8]
spawn_argv_a: Array[5, uint64]
spawn_argv_b: Array[5, uint64]
expected_payload: Array[16, uint8] = "p9demo says hi\n"
EXPECTED_LEN: uint64 = 15


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def auth_as_live() -> int32:
    afd: int32 = sys_open("/dev/auth")
    if afd < 0:
        return -1
    user_line: Array[16, uint8]
    user_line[0]  = 117    # 'u'
    user_line[1]  = 115    # 's'
    user_line[2]  = 101    # 'e'
    user_line[3]  = 114    # 'r'
    user_line[4]  = 32     # ' '
    user_line[5]  = 108    # 'l'
    user_line[6]  = 105    # 'i'
    user_line[7]  = 118    # 'v'
    user_line[8]  = 101    # 'e'
    user_line[9]  = 10     # '\n'
    if sys_write(afd, &user_line[0], 10) < cast[int64](10):
        sys_close(afd)
        return -1
    pass_line: Array[16, uint8]
    pass_line[0]  = 112    # 'p'
    pass_line[1]  = 97     # 'a'
    pass_line[2]  = 115    # 's'
    pass_line[3]  = 115    # 's'
    pass_line[4]  = 32     # ' '
    pass_line[5]  = 104    # 'h'
    pass_line[6]  = 97     # 'a'
    pass_line[7]  = 109    # 'm'
    pass_line[8]  = 110    # 'n'
    pass_line[9]  = 105    # 'i'
    pass_line[10] = 120    # 'x'
    pass_line[11] = 10     # '\n'
    if sys_write(afd, &pass_line[0], 12) < cast[int64](12):
        sys_close(afd)
        return -1
    rn: int64 = sys_read(afd, &read_buf[0], 64)
    if rn < cast[int64](2):
        sys_close(afd)
        return -1
    if read_buf[0] != 111 or read_buf[1] != 107:  # not "ok"
        sys_close(afd)
        return -1
    return afd


def open_srv_with_retry(name: Ptr[char]) -> int32:
    attempt: int32 = 0
    while attempt < 64:
        fd: int32 = sys_srv_open(name)
        if fd >= 0:
            return fd
        sys_yield()
        attempt = attempt + 1
    return -1


def main() -> int32:
    write_str(1, "[p9tauthE2E] start\n")

    # Authenticate once — the same verified afd is reused for both legs.
    afd: int32 = auth_as_live()
    if afd < 0:
        write_str(1, "[p9tauthE2E] FAIL: auth_as_live\n")
        return 1
    write_str(1, "[p9tauthE2E] auth-as-live OK afd=")
    write_dec(1, cast[uint64](afd))
    write_str(1, "\n")

    # =====================================================================
    # LEG A (success): server expects cred=="live"; kernel writes "live".
    # =====================================================================
    spawn_argv_a[0] = cast[uint64](&"/bin/p9srv_demo"[0])
    spawn_argv_a[1] = cast[uint64](&"post-auth-strict"[0])
    spawn_argv_a[2] = cast[uint64](&"eauth-ok"[0])
    spawn_argv_a[3] = cast[uint64](&"live"[0])
    spawn_argv_a[4] = 0
    pid_a: int32 = spawn(cast[Ptr[char]]("/bin/p9srv_demo"),
                         &spawn_argv_a[0], -1, -1, cast[Ptr[uint64]](0))
    if pid_a < 0:
        dump_errstr("[p9tauthE2E] FAIL: leg-A spawn errstr=")
        sys_close(afd)
        return 2
    write_str(1, "[p9tauthE2E] leg-A spawn OK pid=")
    write_dec(1, cast[uint64](pid_a))
    write_str(1, "\n")

    srvfd_a: int32 = open_srv_with_retry(cast[Ptr[char]]("eauth-ok"))
    if srvfd_a < 0:
        dump_errstr("[p9tauthE2E] FAIL: leg-A sys_srv_open errstr=")
        sys_close(afd)
        return 3
    write_str(1, "[p9tauthE2E] leg-A srvfd=")
    write_dec(1, cast[uint64](srvfd_a))
    write_str(1, "\n")
    rc_a: int64 = syscall6(SYS_MOUNT,
                           cast[uint64](srvfd_a),
                           cast[uint64](afd),
                           cast[uint64](&"/n/eauth-ok"[0]),
                           cast[uint64](MREPL),
                           cast[uint64](&""[0]),
                           0)
    if rc_a != 0:
        dump_errstr("[p9tauthE2E] FAIL: leg-A mount errstr=")
        sys_close(srvfd_a)
        sys_close(afd)
        return 4
    write_str(1, "[p9tauthE2E] leg-A mount OK\n")

    hfd_a: int32 = sys_open("/n/eauth-ok/hello")
    if hfd_a < 0:
        dump_errstr("[p9tauthE2E] FAIL: leg-A open /hello errstr=")
        sys_close(srvfd_a)
        sys_close(afd)
        return 5
    rn_a: int64 = sys_read(hfd_a, &read_buf[0], 64)
    sys_close(hfd_a)
    if rn_a < cast[int64](15):
        write_str(1, "[p9tauthE2E] FAIL: leg-A short read\n")
        sys_close(srvfd_a)
        sys_close(afd)
        return 6
    iA: uint64 = 0
    okA: int32 = 1
    while iA < EXPECTED_LEN:
        if read_buf[iA] != expected_payload[iA]:
            okA = 0
            break
        iA = iA + 1
    if okA == 0:
        write_str(1, "[p9tauthE2E] FAIL: leg-A payload mismatch\n")
        sys_close(srvfd_a)
        sys_close(afd)
        return 7
    write_str(1, "[p9tauthE2E] leg-A read OK\n")
    # Unmount leg-A before leg-B: this releases the conn slot AND any
    # mnttab entry so leg-B's p9c_attach starts from a clean kernel
    # state. Without this the second p9c_attach can see a residual
    # conn record (the previous srvfd was a separate fd number, but
    # the conn table is keyed by srvfd; some paths inside the kernel
    # leave the conn pinned until unmount runs). srvfd_a is still
    # open here — that's fine, unmount is by path.
    sys_unmount(cast[Ptr[char]](0), cast[Ptr[char]]("/n/eauth-ok"))
    sys_close(srvfd_a)

    # =====================================================================
    # LEG B (failure): server expects cred=="alice"; kernel writes "live".
    # p9c_attach_authed_run should detect Twrite Rerror and return -1.
    # =====================================================================
    spawn_argv_b[0] = cast[uint64](&"/bin/p9srv_demo"[0])
    spawn_argv_b[1] = cast[uint64](&"post-auth-strict"[0])
    spawn_argv_b[2] = cast[uint64](&"eauth-bad"[0])
    spawn_argv_b[3] = cast[uint64](&"alice"[0])
    spawn_argv_b[4] = 0
    pid_b: int32 = spawn(cast[Ptr[char]]("/bin/p9srv_demo"),
                         &spawn_argv_b[0], -1, -1, cast[Ptr[uint64]](0))
    if pid_b < 0:
        dump_errstr("[p9tauthE2E] FAIL: leg-B spawn errstr=")
        sys_close(afd)
        return 8
    write_str(1, "[p9tauthE2E] leg-B spawn OK pid=")
    write_dec(1, cast[uint64](pid_b))
    write_str(1, "\n")

    srvfd_b: int32 = open_srv_with_retry(cast[Ptr[char]]("eauth-bad"))
    if srvfd_b < 0:
        dump_errstr("[p9tauthE2E] FAIL: leg-B sys_srv_open errstr=")
        sys_close(afd)
        return 9
    write_str(1, "[p9tauthE2E] leg-B srvfd=")
    write_dec(1, cast[uint64](srvfd_b))
    write_str(1, "\n")
    rc_b: int64 = syscall6(SYS_MOUNT,
                           cast[uint64](srvfd_b),
                           cast[uint64](afd),
                           cast[uint64](&"/n/eauth-bad"[0]),
                           cast[uint64](MREPL),
                           cast[uint64](&""[0]),
                           0)
    if rc_b == 0:
        # This is the regression we're guarding against — mount MUST
        # NOT succeed when the server rejects the Twrite cred.
        write_str(1, "[p9tauthE2E] FAIL: leg-B mount unexpectedly succeeded\n")
        sys_close(srvfd_b)
        sys_close(afd)
        return 10
    write_str(1, "[p9tauthE2E] leg-B mount rejected (expected) rc=")
    write_dec(1, cast[uint64](rc_b))
    write_str(1, " errstr=")
    sys_errstr(&err_buf[0], 128)
    write_str(1, &err_buf[0])
    write_str(1, "\n")
    sys_close(srvfd_b)
    sys_close(afd)

    write_str(1, "[p9tauthE2E] PASS\n")
    return 0

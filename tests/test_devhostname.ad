# tests/test_devhostname.ad
#
# Regression: read /dev/hostname (initial value), write a new hostname,
# read it back, assert the round-trip succeeds. The initial value is
# expected to be "hamnix" (seeded at module init in
# sys/src/9/port/devhostname.ad::_hn_init_default); the write payload
# is "test-host"; the post-write read is expected to be "test-host".
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devhostname.ad -o build/user/test_devhostname.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Compare buf[0..need_len] against the literal `needle` (NUL-terminated).
# `n` is the actual count read into buf; we trim a trailing newline
# before comparing so "hamnix\n" matches "hamnix". Returns 1 on match.
def _matches(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    eff: uint64 = n
    if eff > 0 and buf[eff - 1] == 10:                # strip '\n'
        eff = eff - 1
    need: uint64 = strlen(needle)
    if eff != need:
        return 0
    i: uint64 = 0
    while i < need:
        if buf[i] != needle[i]:
            return 0
        i = i + 1
    return 1


# Drain /dev/hostname into buf, return bytes read (or <0).
def _read_hostname(buf: Ptr[uint8]) -> int64:
    fd: int32 = sys_open("/dev/hostname")
    if fd < 0:
        return -1
    n: int64 = sys_read(fd, buf, 80)
    sys_close(fd)
    return n


def main() -> int32:
    write_str(1, "[test_devhostname] start\n")

    # ---- pass 1: read initial value ----
    buf1: Array[128, uint8]
    n1: int64 = _read_hostname(&buf1[0])
    if n1 <= 0:
        write_str(1, "[test_devhostname] initial read failed\n")
        return 1
    write_str(1, "[test_devhostname] initial=")
    sys_write(1, &buf1[0], cast[uint64](n1))
    if _matches(&buf1[0], cast[uint64](n1), "hamnix") == 0:
        write_str(1, "[test_devhostname] initial != hamnix FAIL\n")
        return 1
    write_str(1, "[test_devhostname] initial_ok=1\n")

    # ---- pass 2: write a new hostname ----
    wfd: int32 = sys_open_write("/dev/hostname")
    if wfd < 0:
        write_str(1, "[test_devhostname] open_write failed\n")
        return 1
    nw: int64 = sys_write(wfd, "test-host", 9)
    sys_close(wfd)
    if nw < 0:
        write_str(1, "[test_devhostname] write returned <0 FAIL\n")
        return 1
    write_str(1, "[test_devhostname] wrote_test-host\n")

    # ---- pass 3: read it back, assert it changed ----
    buf2: Array[128, uint8]
    n2: int64 = _read_hostname(&buf2[0])
    if n2 <= 0:
        write_str(1, "[test_devhostname] second read failed\n")
        return 1
    write_str(1, "[test_devhostname] after=")
    sys_write(1, &buf2[0], cast[uint64](n2))
    if _matches(&buf2[0], cast[uint64](n2), "test-host") == 0:
        write_str(1, "[test_devhostname] after != test-host FAIL\n")
        return 1

    # PASS marker the script greps for.
    write_str(1, "[test_devhostname] roundtrip_ok=1\n")
    write_str(1, "[test_devhostname] done\n")
    return 0

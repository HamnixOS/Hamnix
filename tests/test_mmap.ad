# tests/test_mmap.ad
#
# Demand-paging mmap / mprotect / munmap regression test (§142).
#
# Exercises the three new native syscalls:
#   SYS_MMAP    = 302
#   SYS_MPROTECT = 303
#   SYS_MUNMAP  = 304
#
# What it proves:
#   T1. Anonymous single-page mmap: map one page, write a sentinel,
#       read it back.  Forces exactly one demand-page fault.
#   T2. Multi-page mmap: map four pages, write a unique sentinel into
#       each page (forcing four demand-page faults), read all back.
#   T3. mprotect PROT_NONE then PROT_READ|PROT_WRITE: calls mprotect
#       and verifies it returns 0 (we cannot easily provoke a user-mode
#       protection fault from within the same process without a helper,
#       so this is a "no crash" / return-value check).
#   T4. munmap: unmap a single page, verify the return is 0.
#
# PASS criteria (host harness greps the serial log):
#   [mmap] T1 PASS
#   [mmap] T2 PASS
#   [mmap] T3 PASS
#   [mmap] T4 PASS
#   [mmap] PASS
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_mmap.ad -o build/user/test_mmap.elf
#
# Run via scripts/test_mmap.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_mmap(addr: uint64, len: uint64, prot: int32,
                    flags: int32, fd: int32, offset: uint64) -> int64
extern def sys_mprotect(addr: uint64, len: uint64, prot: int32) -> int32
extern def sys_munmap(addr: uint64, len: uint64) -> int32
extern def sys_exit(code: uint64)

# mmap prot flags
PROT_NONE:  int32 = 0x0
PROT_READ:  int32 = 0x1
PROT_WRITE: int32 = 0x2

# mmap flags
MAP_SHARED:    int32 = 0x01
MAP_PRIVATE:   int32 = 0x02
MAP_ANONYMOUS: int32 = 0x20

# mmap failure sentinel
MAP_FAILED: int64 = -1

PAGE_SIZE: uint64 = 4096


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def write_hex(fd: int32, value: uint64):
    # Print value as 0x<hex>
    sys_write(fd, "0x", 2)
    nibbles: Array[16, uint8]
    n: uint64 = 0
    v: uint64 = value
    if v == 0:
        sys_write(fd, "0", 1)
        return
    while v != 0:
        nib: uint64 = v & 15
        if nib < 10:
            nibbles[n] = cast[uint8](nib) + 48
        else:
            nibbles[n] = cast[uint8](nib - 10) + 97
        v = v >> 4
        n = n + 1
    out: Array[16, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = nibbles[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def main() -> int32:
    write_str(1, "[mmap] start\n")

    # ------------------------------------------------------------------
    # T1: anonymous single-page mmap, write + read back
    # ------------------------------------------------------------------
    addr1: int64 = sys_mmap(0, PAGE_SIZE, PROT_READ | PROT_WRITE,
                             MAP_PRIVATE | MAP_ANONYMOUS, -1, 0)
    if addr1 <= 0:
        write_str(1, "[mmap] T1 FAIL: mmap returned ")
        write_hex(1, cast[uint64](addr1))
        write_str(1, "\n")
        return 1

    # Write a 64-bit sentinel and read it back.
    SENTINEL1: uint64 = 0xDEADBEEFCAFEBABE
    p1: Ptr[uint64] = cast[Ptr[uint64]](addr1)
    p1[0] = SENTINEL1
    got1: uint64 = p1[0]
    if got1 != SENTINEL1:
        write_str(1, "[mmap] T1 FAIL: read back ")
        write_hex(1, got1)
        write_str(1, " expected ")
        write_hex(1, SENTINEL1)
        write_str(1, "\n")
        return 1
    write_str(1, "[mmap] T1 PASS\n")

    # ------------------------------------------------------------------
    # T2: four-page anonymous mmap, write unique sentinels per page
    # ------------------------------------------------------------------
    NPAGES: uint64 = 4
    addr2: int64 = sys_mmap(0, NPAGES * PAGE_SIZE, PROT_READ | PROT_WRITE,
                             MAP_PRIVATE | MAP_ANONYMOUS, -1, 0)
    if addr2 <= 0:
        write_str(1, "[mmap] T2 FAIL: mmap returned ")
        write_hex(1, cast[uint64](addr2))
        write_str(1, "\n")
        return 1

    # Write to the first word of each page (forces 4 demand faults).
    pg: uint64 = 0
    while pg < NPAGES:
        pp: Ptr[uint64] = cast[Ptr[uint64]](addr2 + cast[int64](pg * PAGE_SIZE))
        pp[0] = 0xABCD0000 + pg
        pg = pg + 1

    # Read back and verify.
    fail_t2: int32 = 0
    pg = 0
    while pg < NPAGES:
        pp: Ptr[uint64] = cast[Ptr[uint64]](addr2 + cast[int64](pg * PAGE_SIZE))
        expected: uint64 = 0xABCD0000 + pg
        if pp[0] != expected:
            write_str(1, "[mmap] T2 FAIL: page ")
            write_dec(1, pg)
            write_str(1, " read ")
            write_hex(1, pp[0])
            write_str(1, " expected ")
            write_hex(1, expected)
            write_str(1, "\n")
            fail_t2 = 1
        pg = pg + 1
    if fail_t2 != 0:
        return 1
    write_str(1, "[mmap] T2 PASS\n")

    # ------------------------------------------------------------------
    # T3: mprotect — change protection on addr1, verify return 0
    # ------------------------------------------------------------------
    rc3: int32 = sys_mprotect(cast[uint64](addr1), PAGE_SIZE, PROT_NONE)
    if rc3 != 0:
        write_str(1, "[mmap] T3 FAIL: mprotect PROT_NONE returned ")
        write_dec(1, cast[uint64](cast[int64](rc3)))
        write_str(1, "\n")
        return 1
    # Restore to RW so we can still munmap cleanly.
    rc3b: int32 = sys_mprotect(cast[uint64](addr1), PAGE_SIZE, PROT_READ | PROT_WRITE)
    if rc3b != 0:
        write_str(1, "[mmap] T3 FAIL: mprotect RW restore returned ")
        write_dec(1, cast[uint64](cast[int64](rc3b)))
        write_str(1, "\n")
        return 1
    write_str(1, "[mmap] T3 PASS\n")

    # ------------------------------------------------------------------
    # T4: munmap — unmap both regions, verify return 0
    # ------------------------------------------------------------------
    rmu1: int32 = sys_munmap(cast[uint64](addr1), PAGE_SIZE)
    if rmu1 != 0:
        write_str(1, "[mmap] T4 FAIL: munmap addr1 returned ")
        write_dec(1, cast[uint64](cast[int64](rmu1)))
        write_str(1, "\n")
        return 1
    rmu2: int32 = sys_munmap(cast[uint64](addr2), NPAGES * PAGE_SIZE)
    if rmu2 != 0:
        write_str(1, "[mmap] T4 FAIL: munmap addr2 returned ")
        write_dec(1, cast[uint64](cast[int64](rmu2)))
        write_str(1, "\n")
        return 1
    write_str(1, "[mmap] T4 PASS\n")

    write_str(1, "[mmap] PASS\n")
    return 0

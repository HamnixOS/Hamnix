# tests/test_rfc6979.ad
#
# RFC 6979 deterministic-ECDSA-nonce known-answer test for the
# P-256 / SHA-256 signing path (lib/ssh/sshsign.ad::ecdsa_p256_sign).
#
# RFC 6979 Appendix A.2.5 publishes test vectors for ECDSA on the
# NIST P-256 curve. With:
#   private key x = C9AFA9D845BA75166B5C215767B1D6934E50C3DB36E89B127B8A622B120F6721
#   message       = "sample"   (the 6 ASCII bytes s,a,m,p,l,e)
#   hash          = SHA-256
# the RFC fixes the deterministic nonce and therefore the signature:
#   k = A6E3C57DD01ABE90086538398355DD4C3B17AA873382B0F24D6129493D8AAD60
#   r = EFD48B2AACB6A8FD1140DD9CD45E81D69D2C877B56AAF991C34D0EA84EAF3716
#   s = F7CB1C942D657C41D436C7A1B6E29F65F3E900DBB9AFF4064DC4AB2F843ACDA8
#
# ecdsa_p256_sign() hashes its message argument internally (e =
# SHA-256(message)) and derives the nonce via the RFC 6979 HMAC-SHA256
# DRBG from (private key, e). So signing the raw bytes "sample" must
# reproduce the (r, s) above EXACTLY — a byte-for-byte match proves
# the DRBG, the bits2octets reduction, and the signature math are all
# correct. A wrong nonce gives a completely different (r, s).
#
# Also signs the message "test" (RFC 6979 A.2.5's second P-256 /
# SHA-256 vector):
#   r = F1ABB023518351CD71D881567B1EA663ED3EFCF6C5132B354F28D3B0B7D38367
#   s = 019F4113742A2B14BD25926B49C649155F267E60D3814B4C0CC84250E46F0083
#
# Driven by scripts/test_rfc6979.sh. PASS criterion:
#   "[rfc6979] failures=0" AND "[rfc6979] PASS" both in the log.

from lib.ec.p256 import (
    p256_init,
)
from lib.ecdsa.ecdsa import (
    ecdsa_init,
)
from lib.ssh.sshsign import (
    ecdsa_p256_sign,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer ----------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


_hex_digits: Array[16, uint8]


def _init_hex():
    i: uint64 = 0
    while i < 10:
        _hex_digits[i] = cast[uint8](48 + i)            # '0'..'9'
        i = i + 1
    while i < 16:
        _hex_digits[i] = cast[uint8](97 + (i - 10))     # 'a'..'f'
        i = i + 1


def _whex32(buf: Ptr[uint8]):
    # Print 32 bytes as lowercase hex.
    out: Array[64, uint8]
    i: uint64 = 0
    while i < 32:
        b: uint8 = buf[i]
        out[i * 2 + 0] = _hex_digits[(b >> 4) & 0x0F]
        out[i * 2 + 1] = _hex_digits[b & 0x0F]
        i = i + 1
    sys_write(1, &out[0], cast[uint64](64))


# -- failure aggregator ----------------------------------------------------

fail_count: int32 = 0


# Set the i-th byte of a 32-byte buffer (helper to build the BE
# constants without string-literal globals).
def _eq32(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while i < 32:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Decode a 64-char hex string into a 32-byte big-endian buffer.
def _hex_to_be32(hex: Ptr[uint8], out: Ptr[uint8]):
    i: uint64 = 0
    while i < 32:
        hi: uint8 = _hexval(hex[i * 2 + 0])
        lo: uint8 = _hexval(hex[i * 2 + 1])
        out[i] = cast[uint8]((hi << 4) | lo)
        i = i + 1


def _hexval(c: uint8) -> uint8:
    if c >= 48 and c <= 57:
        return c - 48
    if c >= 97 and c <= 102:
        return c - 97 + 10
    if c >= 65 and c <= 70:
        return c - 65 + 10
    return 0


# Run one RFC 6979 vector: sign `msg` (msg_len bytes) with private
# key `d_hex` and assert the signature equals (r_hex, s_hex).
def _check_vector(label: Ptr[uint8],
                  d_hex: Ptr[uint8], msg: Ptr[uint8], msg_len: uint64,
                  r_hex: Ptr[uint8], s_hex: Ptr[uint8]):
    d: Array[32, uint8]
    want_r: Array[32, uint8]
    want_s: Array[32, uint8]
    _hex_to_be32(d_hex, &d[0])
    _hex_to_be32(r_hex, &want_r[0])
    _hex_to_be32(s_hex, &want_s[0])

    got_r: Array[32, uint8]
    got_s: Array[32, uint8]
    rc: int32 = ecdsa_p256_sign(&d[0], msg, msg_len, &got_r[0], &got_s[0])
    if rc != 0:
        _wstr("[rfc6979] FAIL: ")
        _wstr(label)
        _wstr(" — ecdsa_p256_sign returned non-zero\n")
        fail_count = fail_count + 1
        return

    r_ok: int32 = _eq32(&got_r[0], &want_r[0])
    s_ok: int32 = _eq32(&got_s[0], &want_s[0])
    if r_ok != 0 and s_ok != 0:
        _wstr("[rfc6979] OK: ")
        _wstr(label)
        _wstr(" — signature matches the RFC 6979 vector\n")
        return

    fail_count = fail_count + 1
    _wstr("[rfc6979] FAIL: ")
    _wstr(label)
    _wstr(" — signature MISMATCH\n")
    _wstr("  got r = ")
    _whex32(&got_r[0])
    _wstr("\n  want  = ")
    _whex32(&want_r[0])
    _wstr("\n  got s = ")
    _whex32(&got_s[0])
    _wstr("\n  want  = ")
    _whex32(&want_s[0])
    _wstr("\n")


def main() -> int32:
    _wstr("[rfc6979] start\n")
    _init_hex()
    p256_init()
    ecdsa_init()

    # RFC 6979 Appendix A.2.5 — NIST P-256, SHA-256.
    # The shared private key for all A.2.5 vectors.
    d_hex: Ptr[uint8] = \
        "c9afa9d845ba75166b5c215767b1d6934e50c3db36e89b127b8a622b120f6721"

    # Vector 1: message "sample".
    msg1: Array[6, uint8]
    msg1[0] = 115        # 's'
    msg1[1] = 97         # 'a'
    msg1[2] = 109        # 'm'
    msg1[3] = 112        # 'p'
    msg1[4] = 108        # 'l'
    msg1[5] = 101        # 'e'
    _check_vector("P-256/SHA-256 \"sample\"",
        d_hex, &msg1[0], cast[uint64](6),
        "efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716",
        "f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8")

    # Vector 2: message "test".
    msg2: Array[4, uint8]
    msg2[0] = 116        # 't'
    msg2[1] = 101        # 'e'
    msg2[2] = 115        # 's'
    msg2[3] = 116        # 't'
    _check_vector("P-256/SHA-256 \"test\"",
        d_hex, &msg2[0], cast[uint64](4),
        "f1abb023518351cd71d881567b1ea663ed3efcf6c5132b354f28d3b0b7d38367",
        "019f4113742a2b14bd25926b49c649155f267e60d3814b4c0cc84250e46f0083")

    _wstr("[rfc6979] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[rfc6979] PASS\n")
    else:
        _wstr("[rfc6979] FAILED\n")
    sys_exit(0)
    return 0

def _test_tflush():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_tflush(&c, 5, 4)
    if n < 0:
        _check(0, "tflush: emit < 0")
        return
    tag_out: uint16 = 0
    oldtag_out: uint16 = 0
    consumed: int64 = p9_decode_tflush(&encode_buf[0], cast[uint64](n),
                                       &tag_out, &oldtag_out)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "tflush: consumed")
    _check(cast[int32](1 if tag_out == 5 else 0), "tflush: tag")
    _check(cast[int32](1 if oldtag_out == 4 else 0), "tflush: oldtag")


def _test_rflush():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_rflush(&c, 5)
    if n < 0:
        _check(0, "rflush: emit < 0")
        return
    tag_out: uint16 = 0
    consumed: int64 = p9_decode_rflush(&encode_buf[0], cast[uint64](n),
                                       &tag_out)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "rflush: consumed")
    _check(cast[int32](1 if tag_out == 5 else 0), "rflush: tag")


def _test_twalk():
    twalk_names[0] = &walk_etc[0]
    twalk_lens[0]  = 3
    twalk_names[1] = &walk_motd[0]
    twalk_lens[1]  = 4
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_twalk(&c, 6, 0, 1, 2,
                             &twalk_names[0], &twalk_lens[0])
    if n < 0:
        _check(0, "twalk: emit < 0")
        return
    tag_out: uint16 = 0
    fid_out: uint32 = 0
    newfid_out: uint32 = 0
    nw_out: uint16 = 0
    consumed: int64 = p9_decode_twalk(&encode_buf[0], cast[uint64](n),
                                      &tag_out, &fid_out, &newfid_out,
                                      &nw_out,
                                      &twalk_out_names[0],
                                      &twalk_out_lens[0])
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "twalk: consumed")
    _check(cast[int32](1 if fid_out == 0 else 0), "twalk: fid")
    _check(cast[int32](1 if newfid_out == 1 else 0), "twalk: newfid")
    _check(cast[int32](1 if nw_out == 2 else 0), "twalk: nwname")
    _check(_bytes_eq(twalk_out_names[0], twalk_out_lens[0],
                     &walk_etc[0], 3),
           "twalk: wname[0] == etc")
    _check(_bytes_eq(twalk_out_names[1], twalk_out_lens[1],
                     &walk_motd[0], 4),
           "twalk: wname[1] == motd")


def _test_rwalk():
    rwalk_qtypes_in[0] = P9_QTDIR
    rwalk_qvers_in[0]  = 1
    rwalk_qpaths_in[0] = 100
    rwalk_qtypes_in[1] = P9_QTFILE
    rwalk_qvers_in[1]  = 2
    rwalk_qpaths_in[1] = 200
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_rwalk(&c, 6, 2,
                             &rwalk_qtypes_in[0],
                             &rwalk_qvers_in[0],
                             &rwalk_qpaths_in[0])
    if n < 0:
        _check(0, "rwalk: emit < 0")
        return
    tag_out: uint16 = 0
    nq_out: uint16 = 0
    consumed: int64 = p9_decode_rwalk(&encode_buf[0], cast[uint64](n),
                                      &tag_out, &nq_out,
                                      &rwalk_qtypes_out[0],
                                      &rwalk_qvers_out[0],
                                      &rwalk_qpaths_out[0])
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "rwalk: consumed")
    _check(cast[int32](1 if nq_out == 2 else 0), "rwalk: nwqid")
    _check(cast[int32](1 if rwalk_qtypes_out[0] == P9_QTDIR else 0),
           "rwalk: qid[0].type")
    _check(cast[int32](1 if rwalk_qpaths_out[0] == 100 else 0),
           "rwalk: qid[0].path")
    _check(cast[int32](1 if rwalk_qtypes_out[1] == P9_QTFILE else 0),
           "rwalk: qid[1].type")
    _check(cast[int32](1 if rwalk_qpaths_out[1] == 200 else 0),
           "rwalk: qid[1].path")


def _test_topen():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)

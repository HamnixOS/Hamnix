# tests/test_9p_codec.ad
#
# 9P V0 codec round-trip regression. For every T- and R-message defined
# in docs/9p.md §3, encode a representative payload, decode it back, and
# assert each field came through bit-identical. Then prove the decoder
# rejects four malformed inputs: truncated header, wrong type byte,
# oversize body (size field promises bytes that aren't there), and
# undersize body (size field shorter than the fixed prefix).
#
# Driven by scripts/test_9p_codec.sh: builds this .ad as a userland
# x86_64 ELF, plants it at /bin/test_9p_codec in the cpio initramfs,
# boots QEMU + hamsh, runs the binary, then asserts on the serial log
# for the [p9codec] PASS banner. Same shape as scripts/test_p9file.sh.
#
# Why a userland test rather than an in-kernel one? The V0 codec is
# kernel-internals-free on purpose so it can be linked from both
# spaces. Running the test in userland verifies that "kernel-free"
# claim — if the codec accidentally reached into a kernel symbol,
# the x86_64-adder-user link would fail before we ever booted.

from lib.p9.codec import (
    P9Cursor, p9_cursor_init, p9_cursor_bytes,
    p9_decode_header,
    p9_emit_tversion, p9_decode_tversion,
    p9_emit_rversion, p9_decode_rversion,
    p9_emit_tauth, p9_decode_tauth,
    p9_emit_rauth, p9_decode_rauth,
    p9_emit_tattach, p9_decode_tattach,
    p9_emit_rattach, p9_decode_rattach,
    p9_emit_rerror, p9_decode_rerror,
    p9_emit_tflush, p9_decode_tflush,
    p9_emit_rflush, p9_decode_rflush,
    p9_emit_twalk, p9_decode_twalk,
    p9_emit_rwalk, p9_decode_rwalk,
    p9_emit_topen, p9_decode_topen,
    p9_emit_ropen, p9_decode_ropen,
    p9_emit_tcreate, p9_decode_tcreate,
    p9_emit_rcreate, p9_decode_rcreate,
    p9_emit_tread, p9_decode_tread,
    p9_emit_rread, p9_decode_rread,
    p9_emit_twrite, p9_decode_twrite,
    p9_emit_rwrite, p9_decode_rwrite,
    p9_emit_tclunk, p9_decode_tclunk,
    p9_emit_rclunk, p9_decode_rclunk,
    p9_emit_tstat, p9_decode_tstat,
    p9_emit_rstat, p9_decode_rstat,
    p9_emit_twstat, p9_decode_twstat,
    p9_emit_rwstat, p9_decode_rwstat,
    P9_NOFID, P9_NOTAG,
    P9_TVERSION, P9_RVERSION, P9_TATTACH,
    P9_QTDIR, P9_QTFILE,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


# -- tiny printer ------------------------------------------------------------

def _strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _wstr(s: Ptr[uint8]):
    sys_write(1, s, _strlen(s))


def _wdec(value: uint64):
    if value == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(1, &out[0], i)


# -- bytewise compare --------------------------------------------------------

def _bytes_eq(a: Ptr[uint8], a_len: uint64,
              b: Ptr[uint8], b_len: uint64) -> int32:
    if a_len != b_len:
        return 0
    i: uint64 = 0
    while i < a_len:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# -- failure aggregator ------------------------------------------------------

fail_count: int32 = 0


def _check(cond: int32, label: Ptr[uint8]):
    if cond == 0:
        _wstr("[p9codec] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_eq_u64(a: uint64, b: uint64, label: Ptr[uint8]):
    if a != b:
        _wstr("[p9codec] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_eq_i64(a: int64, b: int64, label: Ptr[uint8]):
    if a != b:
        _wstr("[p9codec] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_neg_i64(v: int64, label: Ptr[uint8]):
    # Asserts v < 0 (malformed-input rejection).
    if v >= cast[int64](0):
        _wstr("[p9codec] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


def _check_neg_i32(v: int32, label: Ptr[uint8]):
    if v >= 0:
        _wstr("[p9codec] FAIL: ")
        _wstr(label)
        _wstr("\n")
        fail_count = fail_count + 1


# -- canonical test inputs (top-level arrays per compiler quirk) -------------

# 8 KiB buffer for every emit; oversize but safe.
encode_buf: Array[8192, uint8]

# String inputs — top-level arrays so the codec sees stable pointers
# (the Adder Array-in-nested-frame bug bit us before).
ver_9p2000:  Array[8, uint8]
uname_glenda: Array[8, uint8]
aname_root:  Array[2, uint8]
err_no_such: Array[16, uint8]
walk_etc:    Array[4, uint8]
walk_motd:   Array[5, uint8]
create_name: Array[4, uint8]
write_data:  Array[16, uint8]
stat_name:   Array[5, uint8]
stat_user:   Array[7, uint8]

# Twalk wname array (16 max; we use 2).
twalk_names: Array[16, Ptr[uint8]]
twalk_lens:  Array[16, uint64]

# Twalk decode out-arrays.
twalk_out_names: Array[16, Ptr[uint8]]
twalk_out_lens:  Array[16, uint64]

# Rwalk qid arrays (encode + decode sides).
rwalk_qtypes_in:  Array[16, uint8]
rwalk_qvers_in:   Array[16, uint32]
rwalk_qpaths_in:  Array[16, uint64]
rwalk_qtypes_out: Array[16, uint8]
rwalk_qvers_out:  Array[16, uint32]
rwalk_qpaths_out: Array[16, uint64]


def _setup_strings():
    # "9P2000"
    ver_9p2000[0] = 57   # '9'
    ver_9p2000[1] = 80   # 'P'
    ver_9p2000[2] = 50   # '2'
    ver_9p2000[3] = 48   # '0'
    ver_9p2000[4] = 48
    ver_9p2000[5] = 48
    # "glenda"  (canonical Plan 9 user)
    uname_glenda[0] = 103  # 'g'
    uname_glenda[1] = 108  # 'l'
    uname_glenda[2] = 101  # 'e'
    uname_glenda[3] = 110  # 'n'
    uname_glenda[4] = 100  # 'd'
    uname_glenda[5] = 97   # 'a'
    # ""  (empty aname is legal — server picks default tree)
    aname_root[0] = 0
    # "no such file"
    err_no_such[0] = 110  # 'n'
    err_no_such[1] = 111
    err_no_such[2] = 32
    err_no_such[3] = 115  # 's'
    err_no_such[4] = 117
    err_no_such[5] = 99
    err_no_such[6] = 104
    err_no_such[7] = 32
    err_no_such[8] = 102
    err_no_such[9] = 105
    err_no_such[10] = 108
    err_no_such[11] = 101
    # "etc"
    walk_etc[0] = 101
    walk_etc[1] = 116
    walk_etc[2] = 99
    # "motd"
    walk_motd[0] = 109
    walk_motd[1] = 111
    walk_motd[2] = 116
    walk_motd[3] = 100
    # "log"
    create_name[0] = 108
    create_name[1] = 111
    create_name[2] = 103
    # write_data = "0123456789ABCDEF"
    write_data[0]  = 48
    write_data[1]  = 49
    write_data[2]  = 50
    write_data[3]  = 51
    write_data[4]  = 52
    write_data[5]  = 53
    write_data[6]  = 54
    write_data[7]  = 55
    write_data[8]  = 56
    write_data[9]  = 57
    write_data[10] = 65
    write_data[11] = 66
    write_data[12] = 67
    write_data[13] = 68
    write_data[14] = 69
    write_data[15] = 70
    # "hello"
    stat_name[0] = 104
    stat_name[1] = 101
    stat_name[2] = 108
    stat_name[3] = 108
    stat_name[4] = 111
    # "hamnix"
    stat_user[0] = 104
    stat_user[1] = 97
    stat_user[2] = 109
    stat_user[3] = 110
    stat_user[4] = 105
    stat_user[5] = 120


# -- per-type round-trip tests ----------------------------------------------

def _test_tversion():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_tversion(&c, P9_NOTAG, 8192, &ver_9p2000[0], 6)
    if n < 0:
        _check(0, "tversion: emit < 0")
        return
    tag_out: uint16 = 0
    msize_out: uint32 = 0
    ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    ver_len: uint64 = 0
    consumed: int64 = p9_decode_tversion(&encode_buf[0], cast[uint64](n),
                                         &tag_out, &msize_out,
                                         &ver_ptr, &ver_len)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "tversion: consumed == n")
    _check(cast[int32](1 if tag_out == P9_NOTAG else 0),
           "tversion: tag == NOTAG")
    _check(cast[int32](1 if msize_out == 8192 else 0),
           "tversion: msize == 8192")
    _check(_bytes_eq(ver_ptr, ver_len, &ver_9p2000[0], 6),
           "tversion: version == '9P2000'")


def _test_rversion():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_rversion(&c, P9_NOTAG, 4096, &ver_9p2000[0], 6)
    if n < 0:
        _check(0, "rversion: emit < 0")
        return
    tag_out: uint16 = 0
    msize_out: uint32 = 0
    ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    ver_len: uint64 = 0
    consumed: int64 = p9_decode_rversion(&encode_buf[0], cast[uint64](n),
                                         &tag_out, &msize_out,
                                         &ver_ptr, &ver_len)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "rversion: consumed")
    _check(cast[int32](1 if tag_out == P9_NOTAG else 0),
           "rversion: tag")
    _check(cast[int32](1 if msize_out == 4096 else 0),
           "rversion: msize")
    _check(_bytes_eq(ver_ptr, ver_len, &ver_9p2000[0], 6),
           "rversion: version")


def _test_tauth():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_tauth(&c, 1, 17, &uname_glenda[0], 6,
                             &aname_root[0], 0)
    if n < 0:
        _check(0, "tauth: emit < 0")
        return
    tag_out: uint16 = 0
    afid_out: uint32 = 0
    uname_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    uname_len: uint64 = 0
    aname_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    aname_len: uint64 = 0
    consumed: int64 = p9_decode_tauth(&encode_buf[0], cast[uint64](n),
                                      &tag_out, &afid_out,
                                      &uname_ptr, &uname_len,
                                      &aname_ptr, &aname_len)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "tauth: consumed")
    _check(cast[int32](1 if tag_out == 1 else 0), "tauth: tag")
    _check(cast[int32](1 if afid_out == 17 else 0), "tauth: afid")
    _check(_bytes_eq(uname_ptr, uname_len, &uname_glenda[0], 6),
           "tauth: uname")
    _check(cast[int32](1 if aname_len == 0 else 0),
           "tauth: aname empty")


def _test_rauth():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_rauth(&c, 1, 0x08, 7, 0x1122334455667788)
    if n < 0:
        _check(0, "rauth: emit < 0")
        return
    tag_out: uint16 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    consumed: int64 = p9_decode_rauth(&encode_buf[0], cast[uint64](n),
                                      &tag_out, &qt, &qv, &qp)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "rauth: consumed")
    _check(cast[int32](1 if tag_out == 1 else 0), "rauth: tag")
    _check(cast[int32](1 if qt == 0x08 else 0), "rauth: qid.type")
    _check(cast[int32](1 if qv == 7 else 0), "rauth: qid.vers")
    _check(cast[int32](1 if qp == 0x1122334455667788 else 0),
           "rauth: qid.path")


def _test_tattach():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_tattach(&c, 2, 0, P9_NOFID,
                               &uname_glenda[0], 6,
                               &aname_root[0], 0)
    if n < 0:
        _check(0, "tattach: emit < 0")
        return
    tag_out: uint16 = 0
    fid_out: uint32 = 0
    afid_out: uint32 = 0
    uname_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    uname_len: uint64 = 0
    aname_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    aname_len: uint64 = 0
    consumed: int64 = p9_decode_tattach(&encode_buf[0], cast[uint64](n),
                                        &tag_out, &fid_out, &afid_out,
                                        &uname_ptr, &uname_len,
                                        &aname_ptr, &aname_len)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "tattach: consumed")
    _check(cast[int32](1 if tag_out == 2 else 0), "tattach: tag")
    _check(cast[int32](1 if fid_out == 0 else 0), "tattach: fid")
    _check(cast[int32](1 if afid_out == P9_NOFID else 0),
           "tattach: afid == NOFID")
    _check(_bytes_eq(uname_ptr, uname_len, &uname_glenda[0], 6),
           "tattach: uname")


def _test_rattach():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_rattach(&c, 2, P9_QTDIR, 0, 42)
    if n < 0:
        _check(0, "rattach: emit < 0")
        return
    tag_out: uint16 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    consumed: int64 = p9_decode_rattach(&encode_buf[0], cast[uint64](n),
                                        &tag_out, &qt, &qv, &qp)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "rattach: consumed")
    _check(cast[int32](1 if qt == P9_QTDIR else 0),
           "rattach: qid.type == DIR")
    _check(cast[int32](1 if qp == 42 else 0), "rattach: qid.path")



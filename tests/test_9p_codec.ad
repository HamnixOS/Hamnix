def _test_tcreate():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_tcreate(&c, 8, 1, &create_name[0], 3, 0644, 1)
    if n < 0:
        _check(0, "tcreate: emit < 0")
        return
    tag_out: uint16 = 0
    fid_out: uint32 = 0
    name_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    name_len: uint64 = 0
    perm_out: uint32 = 0
    mode_out: uint8 = 0
    consumed: int64 = p9_decode_tcreate(&encode_buf[0], cast[uint64](n),
                                        &tag_out, &fid_out,
                                        &name_ptr, &name_len,
                                        &perm_out, &mode_out)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "tcreate: consumed")
    _check(_bytes_eq(name_ptr, name_len, &create_name[0], 3),
           "tcreate: name == log")
    _check(cast[int32](1 if perm_out == 0644 else 0),
           "tcreate: perm == 0644")
    _check(cast[int32](1 if mode_out == 1 else 0), "tcreate: mode")



def _test_rstat():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_rstat(&c, 12, 0, 0,
                             P9_QTFILE, 0, 999,
                             0644, 1000, 2000, 1234,
                             &stat_name[0], 5,
                             &stat_user[0], 6,
                             &stat_user[0], 6,
                             &stat_user[0], 6)
    if n < 0:
        _check(0, "rstat: emit < 0")
        return
    tag_out: uint16 = 0
    stat_type_out: uint16 = 0
    dev_out: uint32 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    mode_out: uint32 = 0
    atime_out: uint32 = 0
    mtime_out: uint32 = 0
    length_out: uint64 = 0
    name_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    name_len: uint64 = 0
    uid_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    uid_len: uint64 = 0
    gid_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    gid_len: uint64 = 0
    muid_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    muid_len: uint64 = 0
    consumed: int64 = p9_decode_rstat(&encode_buf[0], cast[uint64](n),
                                      &tag_out, &stat_type_out, &dev_out,
                                      &qt, &qv, &qp,
                                      &mode_out, &atime_out, &mtime_out,
                                      &length_out,
                                      &name_ptr, &name_len,
                                      &uid_ptr, &uid_len,
                                      &gid_ptr, &gid_len,
                                      &muid_ptr, &muid_len)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "rstat: consumed")
    _check(cast[int32](1 if qp == 999 else 0), "rstat: qid.path")
    _check(cast[int32](1 if mode_out == 0644 else 0), "rstat: mode")
    _check(cast[int32](1 if length_out == 1234 else 0), "rstat: length")
    _check(_bytes_eq(name_ptr, name_len, &stat_name[0], 5),
           "rstat: name == hello")
    _check(_bytes_eq(uid_ptr, uid_len, &stat_user[0], 6),
           "rstat: uid == hamnix")


def _test_twstat():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    # Encode "rename to hello" — name=hello, all other fields are
    # sentinels indicating "unchanged".
    n: int32 = p9_emit_twstat(&c, 13, 1,
                              0xFFFF, 0xFFFFFFFF,
                              0xFF, 0xFFFFFFFF, 0xFFFFFFFFFFFFFFFF,
                              0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF,
                              0xFFFFFFFFFFFFFFFF,
                              &stat_name[0], 5,
                              &aname_root[0], 0,
                              &aname_root[0], 0,
                              &aname_root[0], 0)
    if n < 0:
        _check(0, "twstat: emit < 0")
        return
    tag_out: uint16 = 0
    fid_out: uint32 = 0
    stat_type_out: uint16 = 0
    dev_out: uint32 = 0
    qt: uint8 = 0
    qv: uint32 = 0
    qp: uint64 = 0
    mode_out: uint32 = 0
    atime_out: uint32 = 0
    mtime_out: uint32 = 0
    length_out: uint64 = 0
    name_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    name_len: uint64 = 0
    uid_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    uid_len: uint64 = 0
    gid_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    gid_len: uint64 = 0
    muid_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    muid_len: uint64 = 0
    consumed: int64 = p9_decode_twstat(&encode_buf[0], cast[uint64](n),
                                       &tag_out, &fid_out,
                                       &stat_type_out, &dev_out,
                                       &qt, &qv, &qp,
                                       &mode_out, &atime_out, &mtime_out,
                                       &length_out,
                                       &name_ptr, &name_len,
                                       &uid_ptr, &uid_len,
                                       &gid_ptr, &gid_len,
                                       &muid_ptr, &muid_len)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "twstat: consumed")
    _check(cast[int32](1 if fid_out == 1 else 0), "twstat: fid")
    _check(cast[int32](1 if mode_out == 0xFFFFFFFF else 0),
           "twstat: mode sentinel preserved")
    _check(cast[int32](1 if length_out == 0xFFFFFFFFFFFFFFFF else 0),
           "twstat: length sentinel preserved")
    _check(_bytes_eq(name_ptr, name_len, &stat_name[0], 5),
           "twstat: name == hello")
    _check(cast[int32](1 if uid_len == 0 else 0),
           "twstat: uid empty sentinel")


def _test_rwstat():
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_rwstat(&c, 13)
    if n < 0:
        _check(0, "rwstat: emit < 0")
        return

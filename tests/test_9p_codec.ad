    consumed: int64 = p9_decode_rwstat(&encode_buf[0], cast[uint64](n),
                                       &tag_out)
    _check(cast[int32](1 if consumed == cast[int64](n) else 0),
           "rwstat: consumed")
    _check(cast[int32](1 if tag_out == 13 else 0), "rwstat: tag")


# -- malformed-input tests ---------------------------------------------------

malformed_buf: Array[64, uint8]


def _test_truncated_header():
    # 6 bytes — less than the 7-byte minimum.
    i: uint64 = 0
    while i < 6:
        malformed_buf[i] = 0
        i = i + 1
    sz_out: uint32 = 0
    type_out: uint8 = 0
    tag_out: uint16 = 0
    rc: int32 = p9_decode_header(&malformed_buf[0], 6,
                                 &sz_out, &type_out, &tag_out)
    _check(cast[int32](1 if rc < 0 else 0),
           "malformed: truncated header rejected")


def _test_bad_type():
    # Build a 7-byte message with type=0x99 (undefined) and ask
    # decode_tversion to parse it. Expect a -3 (type mismatch).
    malformed_buf[0] = 7    # size = 7
    malformed_buf[1] = 0
    malformed_buf[2] = 0
    malformed_buf[3] = 0
    malformed_buf[4] = 0x99 # bogus type
    malformed_buf[5] = 0    # tag = 0
    malformed_buf[6] = 0
    tag_out: uint16 = 0
    msize_out: uint32 = 0
    ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    ver_len: uint64 = 0
    rc: int64 = p9_decode_tversion(&malformed_buf[0], 7,
                                   &tag_out, &msize_out,
                                   &ver_ptr, &ver_len)
    _check(cast[int32](1 if rc < cast[int64](0) else 0),
           "malformed: bad type rejected")


def _test_oversize_body():
    # Encode a real Tversion, then bump size[4] up by 4 so the decoder
    # thinks the message extends past the buffer end. Decoder must
    # detect via the body_end > buf_len check.
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_tversion(&c, P9_NOTAG, 8192, &ver_9p2000[0], 6)
    if n < 0:
        _check(0, "oversize: emit failed")
        return
    real_size: uint64 = cast[uint64](n)
    # Bump size[4] by 4 so it exceeds buf_len = n.
    bumped: uint64 = real_size + 4
    encode_buf[0] = cast[uint8](bumped & 0xFF)
    encode_buf[1] = cast[uint8]((bumped >> 8) & 0xFF)
    encode_buf[2] = cast[uint8]((bumped >> 16) & 0xFF)
    encode_buf[3] = cast[uint8]((bumped >> 24) & 0xFF)
    tag_out: uint16 = 0
    msize_out: uint32 = 0
    ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    ver_len: uint64 = 0
    rc: int64 = p9_decode_tversion(&encode_buf[0], real_size,
                                   &tag_out, &msize_out,
                                   &ver_ptr, &ver_len)
    _check(cast[int32](1 if rc < cast[int64](0) else 0),
           "malformed: oversize body rejected")


def _test_undersize_body():
    # Encode a Tversion, then claim size = 8 (only 1 byte of body —
    # the msize[4] field can't fit). Decoder must reject.
    c: P9Cursor
    p9_cursor_init(&c, &encode_buf[0], 8192)
    n: int32 = p9_emit_tversion(&c, P9_NOTAG, 8192, &ver_9p2000[0], 6)
    if n < 0:
        _check(0, "undersize: emit failed")
        return
    # Patch size[4] = 8 (header is 7; only 1 body byte present).
    encode_buf[0] = 8
    encode_buf[1] = 0
    encode_buf[2] = 0
    encode_buf[3] = 0
    tag_out: uint16 = 0
    msize_out: uint32 = 0
    ver_ptr: Ptr[uint8] = cast[Ptr[uint8]](0)
    ver_len: uint64 = 0
    # We pass buf_len = 8 so the header peek succeeds but the body
    # decode is short on msize (needs 4 bytes; only 1 available).
    rc: int64 = p9_decode_tversion(&encode_buf[0], 8,
                                   &tag_out, &msize_out,
                                   &ver_ptr, &ver_len)
    _check(cast[int32](1 if rc < cast[int64](0) else 0),
           "malformed: undersize body rejected")


# -- driver -----------------------------------------------------------------

def main() -> int32:
    _wstr("[p9codec] start\n")
    _setup_strings()

    _test_tversion()
    _test_rversion()
    _test_tauth()
    _test_rauth()
    _test_tattach()
    _test_rattach()
    _test_rerror()
    _test_tflush()
    _test_rflush()
    _test_twalk()
    _test_rwalk()
    _test_topen()
    _test_ropen()
    _test_tcreate()
    _test_rcreate()
    _test_tread()
    _test_rread()
    _test_twrite()
    _test_rwrite()
    _test_tclunk()
    _test_rclunk()
    _test_tstat()
    _test_rstat()
    _test_twstat()
    _test_rwstat()

    _test_truncated_header()
    _test_bad_type()
    _test_oversize_body()
    _test_undersize_body()

    _wstr("[p9codec] failures=")
    _wdec(cast[uint64](fail_count))
    _wstr("\n")
    if fail_count == 0:
        _wstr("[p9codec] PASS\n")
        return 0
    _wstr("[p9codec] FAIL\n")
    return 1

# tests/test_gpt_mkpart.ad
#
# M16.x GPT partition-table WRITE-side smoke fixture.
#
# Companion to tests/test_mkpart.ad: same dispatch pattern (name-gated
# one-shot hook out of drivers/block/partition.ad's
# _partition_scan_inner when a disk boots with no MBR signature),
# different target. The MBR fixture fires on "sd0"; this one fires on
# "nvme0n1" so a future combined test rig can mount both an AHCI disk
# and an NVMe disk in the same QEMU run and exercise both write paths
# without name collisions.
#
# What it proves:
#
#   1. gpt_init(slot, total_sectors) lays down:
#       - Protective MBR at LBA 0 (signature 0x55AA + entry[0].type=0xEE).
#       - Empty 128-entry GPT partition array at LBA 2..33.
#       - Primary GPT header at LBA 1 ("EFI PART" sig + header CRC +
#         array CRC).
#       - Backup GPT header at last_lba (total_sectors-1) + backup
#         array at last_lba-32..last_lba-1.
#
#   2. gpt_mkpart(slot, idx, start_lba, end_lba, type_high, type_low)
#      splices one entry into the array, recomputes both the array
#      CRC and both header CRCs, and mirrors to the backup region —
#      a re-scan via partition_rescan picks up the entry as a GPT
#      partition (kind=2) with the right LBA range.
#
#   3. Two entries in the same disk: an EFI System Partition (idx 0)
#      and a Linux filesystem (idx 1) — the canonical Hamnix install
#      layout. Verifies on-disk GUID byte order for BOTH families;
#      a prior pass mis-transcribed the ESP HIGH (trailing "BA" vs
#      "4B") which left the partition silently un-recognisable to
#      UEFI firmware. We assert by reading back the GUID bytes
#      directly and comparing against the constants in partition.ad.
#
#   4. Primary + backup GPT headers stay in sync: signature matches,
#      array CRC matches, header CRCs are different (because their
#      `current_lba` / `backup_lba` fields swap) but each one verifies
#      independently.
#
# Asserted markers (greppable from scripts/test_gpt_mkpart.sh):
#
#   [gpt_mkpart] smoke begin (nvme0n1, fresh disk)
#   [gpt] init OK (total=65536 last=65535)
#   [gpt] mkpart idx=0 lba=2048..6143
#   [gpt] mkpart idx=1 lba=6144..65500
#   [partition] protective MBR detected, switching to GPT
#   [partition] disk=nvme0n1 idx=0 lba=2048..6143 type=c12a7328
#   [partition] disk=nvme0n1 idx=1 lba=6144..65500 type=fc63daf
#   [gpt_mkpart] PASS

from kernel.printk.printk import printk0, printk1, printk2
from kernel.block.blk import blk_read_sectors
from mm.page_alloc import alloc_page
from drivers.block.partition import (
    gpt_init, gpt_mkpart, partition_rescan, partition_for, Partition,
    GPT_GUID_LINUX_FS_LOW, GPT_GUID_LINUX_FS_HIGH,
    GPT_GUID_EFI_SYSTEM_LOW, GPT_GUID_EFI_SYSTEM_HIGH,
    GPT_HDR_SIG, GPT_HDR_SIG_OFFSET,
    GPT_HDR_ARRAY_LBA_OFF, GPT_HDR_BACKUP_LBA_OFF,
    GPT_HDR_HEADER_CRC_OFF, GPT_HDR_ARRAY_CRC_OFF,
)


# Inline LE u32 / u64 readers — clones of the partition.ad helpers so
# the test fixture stays import-tight (it doesn't reach for underscore-
# prefixed module internals).
def _t_read_u32_le(buf: Ptr[uint8], off: uint64) -> uint32:
    b0: uint32 = cast[uint32](buf[off])
    b1: uint32 = cast[uint32](buf[off + 1])
    b2: uint32 = cast[uint32](buf[off + 2])
    b3: uint32 = cast[uint32](buf[off + 3])
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)


def _t_read_u64_le(buf: Ptr[uint8], off: uint64) -> uint64:
    lo: uint64 = cast[uint64](_t_read_u32_le(buf, off))
    hi: uint64 = cast[uint64](_t_read_u32_le(buf, off + 4))
    return lo | (hi << 32)


# Disk geometry: 32 MiB / 512-byte sectors = 65536 sectors. Matches
# what scripts/test_gpt_mkpart.sh mints. last_lba = 65535.
GPT_SMOKE_TOTAL_SECTORS: uint64 = 65536

# Two-partition install layout — ESP + ext4 rootfs:
#   p0 (ESP):     2048..6143   (4 MiB starting at 1 MiB)
#   p1 (Linux):   6144..65500  (~28.96 MiB tail, stops short of the
#                               last 32+1 sectors reserved for the
#                               backup GPT, leaving headroom)
GPT_SMOKE_ESP_START:   uint64 = 2048
GPT_SMOKE_ESP_END:     uint64 = 6143
GPT_SMOKE_LINUX_START: uint64 = 6144
GPT_SMOKE_LINUX_END:   uint64 = 65500


def _verify_partition_window(slot: int32, idx: uint64,
                             want_start: uint64, want_end: uint64) -> int32:
    p: Ptr[Partition] = partition_for(slot, idx)
    if cast[uint64](p) == 0:
        printk1("[gpt_mkpart] partition_for(%d) returned NULL\n", idx)
        return -1
    kind: uint32 = p[0].kind
    if kind != 2:
        printk2("[gpt_mkpart] idx=%d unexpected kind=%d (want 2/GPT)\n",
                idx, cast[uint64](kind))
        return -1
    if p[0].lba_start != want_start:
        printk2("[gpt_mkpart] idx=%d lba_start=%d ", idx, p[0].lba_start)
        printk1("(want %d)\n", want_start)
        return -1
    if p[0].lba_end != want_end:
        printk2("[gpt_mkpart] idx=%d lba_end=%d ", idx, p[0].lba_end)
        printk1("(want %d)\n", want_end)
        return -1
    return 0


# Scratch sector buffers. We deliberately do NOT use top-level
# Array[512, uint8] here — those live in .bss at an arbitrary offset
# which (in this build) happens to land at 0xF10 within its page,
# making a 512-byte transfer cross the page boundary. NVMe's
# PRP1-only path (which our driver hasn't extended with a PRP list
# yet) silently no-ops on such a transfer, leaving the buffer
# untouched while the SQE completes "successfully". A page-aligned
# allocation guarantees every single-sector verify read fits within
# one page.
# Three buffers: one general scratch + two for the primary-vs-backup
# header diff (held simultaneously).
gpt_smoke_buf_scratch: uint64 = 0
gpt_smoke_buf_pri:     uint64 = 0
gpt_smoke_buf_bak:     uint64 = 0


def _gpt_smoke_init_bufs() -> int32:
    if gpt_smoke_buf_scratch != 0:
        return 0
    p0: uint64 = alloc_page()
    p1: uint64 = alloc_page()
    p2: uint64 = alloc_page()
    if p0 == 0 or p1 == 0 or p2 == 0:
        printk0("[gpt_mkpart] alloc_page for scratch failed\n")
        return -1
    gpt_smoke_buf_scratch = p0
    gpt_smoke_buf_pri     = p1
    gpt_smoke_buf_bak     = p2
    return 0


def _verify_protective_mbr(slot: int32) -> int32:
    # LBA 0: signature 0x55AA at 510..511, primary[0].type at 446+4 = 450
    # must equal 0xEE.
    bp: Ptr[uint8] = cast[Ptr[uint8]](gpt_smoke_buf_scratch)
    if blk_read_sectors(slot, 0, 1, bp) != 0:
        printk0("[gpt_mkpart] read LBA 0 (pMBR) failed\n")
        return -1
    if bp[510] != 0x55:
        printk1("[gpt_mkpart] pMBR sig byte 510 = %x (want 0x55)\n",
                cast[uint64](bp[510]))
        return -1
    if bp[511] != 0xAA:
        printk1("[gpt_mkpart] pMBR sig byte 511 = %x (want 0xAA)\n",
                cast[uint64](bp[511]))
        return -1
    if bp[450] != 0xEE:
        printk1("[gpt_mkpart] pMBR entry[0].type = %x (want 0xEE)\n",
                cast[uint64](bp[450]))
        return -1
    printk0("[gpt_mkpart] protective MBR OK (0x55AA + entry[0]=0xEE)\n")
    return 0


def _verify_primary_and_backup_match(slot: int32) -> int32:
    # Primary header at LBA 1, backup header at LBA total-1 = 65535.
    last_lba: uint64 = GPT_SMOKE_TOTAL_SECTORS - 1
    pp: Ptr[uint8] = cast[Ptr[uint8]](gpt_smoke_buf_pri)
    bp: Ptr[uint8] = cast[Ptr[uint8]](gpt_smoke_buf_bak)
    if blk_read_sectors(slot, 1, 1, pp) != 0:
        printk0("[gpt_mkpart] read primary GPT header failed\n")
        return -1
    if blk_read_sectors(slot, last_lba, 1, bp) != 0:
        printk0("[gpt_mkpart] read backup GPT header failed\n")
        return -1
    # Both must have the EFI PART signature.
    if _t_read_u64_le(pp, GPT_HDR_SIG_OFFSET) != GPT_HDR_SIG:
        printk0("[gpt_mkpart] primary signature missing\n")
        return -1
    if _t_read_u64_le(bp, GPT_HDR_SIG_OFFSET) != GPT_HDR_SIG:
        printk0("[gpt_mkpart] backup signature missing\n")
        return -1
    # Partition-array CRCs must match (both copies of the array hold
    # the same bytes, so the CRC over them is identical).
    pri_array_crc: uint32 = _t_read_u32_le(pp, GPT_HDR_ARRAY_CRC_OFF)
    bak_array_crc: uint32 = _t_read_u32_le(bp, GPT_HDR_ARRAY_CRC_OFF)
    if pri_array_crc != bak_array_crc:
        printk2("[gpt_mkpart] array CRC mismatch pri=%x bak=%x\n",
                cast[uint64](pri_array_crc),
                cast[uint64](bak_array_crc))
        return -1
    # Backup header's current_lba/backup_lba should be swapped vs primary.
    # We check by reading the backup_lba field from primary (== last_lba)
    # and the array_lba field from backup (== last_lba - 32).
    pri_backup_lba: uint64 = _t_read_u64_le(pp, GPT_HDR_BACKUP_LBA_OFF)
    if pri_backup_lba != last_lba:
        printk2("[gpt_mkpart] primary.backup_lba=%d (want %d)\n",
                pri_backup_lba, last_lba)
        return -1
    bak_array_lba: uint64 = _t_read_u64_le(bp, GPT_HDR_ARRAY_LBA_OFF)
    want_bak_array_lba: uint64 = last_lba - 32
    if bak_array_lba != want_bak_array_lba:
        printk2("[gpt_mkpart] backup.array_lba=%d (want %d)\n",
                bak_array_lba, want_bak_array_lba)
        return -1
    # Header CRCs differ (they encode different current_lba/backup_lba
    # fields) — sanity-check they're at least non-zero.
    pri_hdr_crc: uint32 = _t_read_u32_le(pp, GPT_HDR_HEADER_CRC_OFF)
    bak_hdr_crc: uint32 = _t_read_u32_le(bp, GPT_HDR_HEADER_CRC_OFF)
    if pri_hdr_crc == 0:
        printk0("[gpt_mkpart] primary header CRC is zero\n")
        return -1
    if bak_hdr_crc == 0:
        printk0("[gpt_mkpart] backup header CRC is zero\n")
        return -1
    if pri_hdr_crc == bak_hdr_crc:
        # Not strictly fatal, but extremely improbable for two
        # well-formed GPT headers whose only differing field set
        # spans 8 bytes of header data.
        printk1("[gpt_mkpart] WARNING: primary == backup hdr CRC (%x)\n",
                cast[uint64](pri_hdr_crc))
    printk0("[gpt_mkpart] primary + backup GPT headers consistent\n")
    return 0


def _verify_guid_bytes(slot: int32, idx: uint64,
                       want_low: uint64, want_high: uint64) -> int32:
    # Re-read the partition array sector that contains entry `idx`
    # (entries 0..3 share sector LBA 2 with 128-byte stride). Pull the
    # 16-byte type GUID and compare against the expected uint64 pair.
    if idx >= 4:
        # Beyond sector 2; for the smoke we only ever plant in 0..3 so
        # this branch is unreachable in practice.
        return 0
    bp: Ptr[uint8] = cast[Ptr[uint8]](gpt_smoke_buf_scratch)
    if blk_read_sectors(slot, 2, 1, bp) != 0:
        printk0("[gpt_mkpart] read array sector LBA 2 failed\n")
        return -1
    eoff: uint64 = idx * 128
    got_low:  uint64 = _t_read_u64_le(bp, eoff + 0)
    got_high: uint64 = _t_read_u64_le(bp, eoff + 8)
    if got_low != want_low:
        printk2("[gpt_mkpart] idx=%d guid_low=%x ", idx, got_low)
        printk1("(want %x)\n", want_low)
        return -1
    if got_high != want_high:
        printk2("[gpt_mkpart] idx=%d guid_high=%x ", idx, got_high)
        printk1("(want %x)\n", want_high)
        return -1
    return 0


def partition_gpt_mkpart_smoke_test(slot: int32) -> int32:
    # Invoked from drivers/block/partition.ad's
    # _partition_gpt_smoke_dispatch when name=="nvme0n1" + no MBR sig.
    printk0("[gpt_mkpart] smoke begin (nvme0n1, fresh disk)\n")

    if _gpt_smoke_init_bufs() != 0:
        return -1

    if gpt_init(slot, GPT_SMOKE_TOTAL_SECTORS) != 0:
        printk0("[gpt_mkpart] gpt_init FAIL\n")
        return -1

    # ESP entry at idx 0.
    if gpt_mkpart(slot, 0, GPT_SMOKE_ESP_START, GPT_SMOKE_ESP_END,
                  GPT_GUID_EFI_SYSTEM_HIGH,
                  GPT_GUID_EFI_SYSTEM_LOW) != 0:
        printk0("[gpt_mkpart] gpt_mkpart(ESP) FAIL\n")
        return -1

    # Linux FS entry at idx 1.
    if gpt_mkpart(slot, 1, GPT_SMOKE_LINUX_START, GPT_SMOKE_LINUX_END,
                  GPT_GUID_LINUX_FS_HIGH,
                  GPT_GUID_LINUX_FS_LOW) != 0:
        printk0("[gpt_mkpart] gpt_mkpart(Linux) FAIL\n")
        return -1

    # Round-trip the type GUIDs via direct on-disk byte read. This is
    # the byte-order canary mentioned in the spec — a transcription bug
    # in the ESP HIGH constant would surface here as an unequal compare.
    if _verify_guid_bytes(slot, 0,
                          GPT_GUID_EFI_SYSTEM_LOW,
                          GPT_GUID_EFI_SYSTEM_HIGH) != 0:
        return -1
    if _verify_guid_bytes(slot, 1,
                          GPT_GUID_LINUX_FS_LOW,
                          GPT_GUID_LINUX_FS_HIGH) != 0:
        return -1
    printk0("[gpt_mkpart] type GUID bytes round-trip OK\n")

    # Verify protective MBR.
    if _verify_protective_mbr(slot) != 0:
        return -1

    # Verify primary <-> backup GPT header consistency.
    if _verify_primary_and_backup_match(slot) != 0:
        return -1

    # Re-scan picks up the GPT layout we just wrote. partition_rescan
    # routes through _partition_scan_inner, which sees the protective
    # MBR -> calls parse_gpt -> records our two entries (kind=2).
    # The dispatch hook is one-shot, so this descends into the normal
    # GPT-present read path.
    rc: int32 = partition_rescan(slot)
    if rc < 0:
        printk0("[gpt_mkpart] rescan FAIL\n")
        return -1
    if rc < 2:
        printk0("[gpt_mkpart] rescan SHORT (expected 2 GPT entries)\n")
        return -1

    # Spot-check the in-memory partition table — partition_for(slot, 0/1)
    # must return the right LBA windows.
    if _verify_partition_window(slot, 0, GPT_SMOKE_ESP_START,
                                GPT_SMOKE_ESP_END) != 0:
        return -1
    if _verify_partition_window(slot, 1, GPT_SMOKE_LINUX_START,
                                GPT_SMOKE_LINUX_END) != 0:
        return -1

    printk0("[gpt_mkpart] PASS\n")
    return rc

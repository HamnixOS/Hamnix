# Collatz benchmark for the x86_64-linux Adder target.
# Sums the Collatz stopping time for every start in 1..N, prints the total.
# Pure integer work — no libc, no Plan 9 base, raw Linux write(2) for output.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

ch:   Array[1, uint8]
digs: Array[32, uint8]

def putc(c: uint8) -> int32:
    ch[0] = c
    sys_write(cast[int32](1), &ch[0], cast[uint64](1))
    return 0

def collatz_steps(start: uint64) -> uint64:
    n: uint64 = start
    steps: uint64 = 0
    while n != cast[uint64](1):
        if (n & cast[uint64](1)) == cast[uint64](0):
            n = n / cast[uint64](2)
        else:
            n = cast[uint64](3) * n + cast[uint64](1)
        steps = steps + cast[uint64](1)
    return steps

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    N: uint64 = cast[uint64](1000000)
    total: uint64 = 0
    i: uint64 = 1
    while i <= N:
        total = total + collatz_steps(i)
        i = i + cast[uint64](1)

    # itoa: build reversed digits in digs[], then print MSB-first.
    nd: int64 = 0
    v: uint64 = total
    if v == cast[uint64](0):
        digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        putc(digs[cast[int64](k)])
        k = k - 1
    putc(cast[uint8](10))

    return cast[int32](total & cast[uint64](255))

# lcg(50,000,000) — pure ALU dependent chain (register-allocation stress).
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

ch:   Array[1, uint8]
digs: Array[32, uint8]

def putc(c: uint8) -> int32:
    ch[0] = c
    sys_write(cast[int32](1), &ch[0], cast[uint64](1))
    return 0

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        putc(digs[cast[int64](k)])
        k = k - 1
    putc(cast[uint8](10))
    return 0

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    x: uint64 = 1
    i: int64 = 0
    N: int64 = 50000000
    while i < N:
        x = x * cast[uint64](6364136223846793005) + cast[uint64](1442695040888963407)
        i = i + 1
    print_u64(x)
    return cast[int32](x & cast[uint64](255))

# mmul(300x300) — integer matrix multiply: array address math + multiply-add.
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

ch:   Array[1, uint8]
digs: Array[32, uint8]
A: Array[90000, int64]
B: Array[90000, int64]
C: Array[90000, int64]

def putc(c: uint8) -> int32:
    ch[0] = c
    sys_write(cast[int32](1), &ch[0], cast[uint64](1))
    return 0

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        putc(digs[cast[int64](k)])
        k = k - 1
    putc(cast[uint8](10))
    return 0

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    DIM: int64 = 300
    i: int64 = 0
    while i < DIM:
        j: int64 = 0
        while j < DIM:
            A[cast[int64](i * DIM + j)] = (i + j) - ((i + j) / 7) * 7
            B[cast[int64](i * DIM + j)] = (i * 2 + j) - ((i * 2 + j) / 7) * 7
            j = j + 1
        i = i + 1
    i = 0
    while i < DIM:
        j: int64 = 0
        while j < DIM:
            s: int64 = 0
            k: int64 = 0
            while k < DIM:
                s = s + A[cast[int64](i * DIM + k)] * B[cast[int64](k * DIM + j)]
                k = k + 1
            C[cast[int64](i * DIM + j)] = s
            j = j + 1
        i = i + 1
    total: int64 = 0
    i = 0
    while i < DIM * DIM:
        total = total + C[cast[int64](i)]
        i = i + 1
    print_u64(cast[uint64](total))
    return cast[int32](total & 255)

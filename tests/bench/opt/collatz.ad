# collatz — sum of Collatz stopping times over a range. Branchy integer loop
# with a division/parity test; ALU + data-dependent control flow. Checksum =
# total number of Collatz steps over all starting values.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: int64 = 0
    start: int64 = 1
    while start < 800000:
        n: int64 = start
        steps: int64 = 0
        while n > 1:
            half: int64 = n / 2
            if n - half * 2 == 0:
                n = half
            else:
                n = 3 * n + 1
            steps = steps + 1
        acc = acc + steps
        start = start + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

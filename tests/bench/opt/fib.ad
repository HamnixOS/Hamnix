# fib — naive recursive Fibonacci, summed over a range. Recursion / call-bound
# (exercises prologue/epilogue + arg passing, few hot loop locals). Checksum =
# sum of fib(n) for n in [0, M).
def fib(n: int64) -> int64:
    if n < 2:
        return n
    return fib(n - 1) + fib(n - 2)

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: int64 = 0
    n: int64 = 0
    while n < 38:
        acc = acc + fib(n)
        n = n + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

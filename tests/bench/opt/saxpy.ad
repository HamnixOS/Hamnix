# saxpy — ADDITIVE honest kernel (added 2026-06-28, perf_2x_roadmap.md). Unlike
# matmul.ad (which hand-hoists its dot-product accumulator into a scalar local
# `s`, masking the accumulator-regalloc lever), saxpy writes its result straight
# back into the destination ARRAY every iteration: y[i] = y[i] + a*x[i]. There is
# NO programmer-provided scalar accumulator to promote, so the per-iteration
# load(y[i])+store(y[i]) is intrinsic to the source and the comparison honestly
# reflects how Adder codegen handles a real array-update reduction vs gcc -O2
# (which keeps the running pointer/stride in registers and may auto-vectorize the
# unit-stride streaming form). This kernel is purely ADDITIVE — it does not change
# any existing kernel's meaning. Checksum = sum of y mod 2^48.
xs: Array[1048576, int64]
ys: Array[1048576, int64]

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    mask: int64 = 281474976710655          # 2^48 - 1
    n: int64 = 1048576
    i: int64 = 0
    while i < n:
        xs[cast[int64](i)] = (i * 3 + 7) % 101
        ys[cast[int64](i)] = (i * 5 + 1) % 97
        i = i + 1
    a: int64 = 3
    reps: int64 = 0
    while reps < 64:
        i = 0
        while i < n:
            ys[cast[int64](i)] = (ys[cast[int64](i)] + a * xs[cast[int64](i)]) & mask
            i = i + 1
        reps = reps + 1
    acc: int64 = 0
    i = 0
    while i < n:
        acc = (acc + ys[cast[int64](i)]) & mask
        i = i + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

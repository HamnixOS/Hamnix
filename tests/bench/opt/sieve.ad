# sieve — Sieve of Eratosthenes up to N, repeated several times (re-clearing the
# flag array each pass). Memory-bound array read/write + branches. Checksum =
# running sum of the prime count over all passes.
flags: Array[2000001, uint8]

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    N: int64 = 2000000
    acc: int64 = 0
    reps: int64 = 0
    while reps < 12:
        # clear
        z: int64 = 0
        while z <= N:
            flags[cast[int64](z)] = cast[uint8](0)
            z = z + 1
        i: int64 = 2
        while i * i <= N:
            if flags[cast[int64](i)] == cast[uint8](0):
                j: int64 = i * i
                while j <= N:
                    flags[cast[int64](j)] = cast[uint8](1)
                    j = j + i
            i = i + 1
        count: int64 = 0
        i = 2
        while i <= N:
            if flags[cast[int64](i)] == cast[uint8](0):
                count = count + 1
            i = i + 1
        acc = acc + count
        reps = reps + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

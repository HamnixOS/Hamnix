# matmul — integer NxN x NxN matmul, repeated. Loop-invariant row/col base
# index arithmetic (i*N) in the inner loop is LICM/CSE bait; the triple loop is
# memory-bound. Checksum = sum of all C entries mod 2^64.
A: Array[4096, int64]
B: Array[4096, int64]
C: Array[4096, int64]

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    N: int64 = 64
    # deterministic fill
    i: int64 = 0
    while i < N:
        j: int64 = 0
        while j < N:
            A[cast[int64](i * N + j)] = (i * 7 + j * 3) % 17
            B[cast[int64](i * N + j)] = (i * 5 + j * 11) % 13
            j = j + 1
        i = i + 1
    reps: int64 = 0
    acc: int64 = 0
    while reps < 150:
        i = 0
        while i < N:
            j: int64 = 0
            while j < N:
                s: int64 = 0
                k: int64 = 0
                while k < N:
                    s = s + A[cast[int64](i * N + k)] * B[cast[int64](k * N + j)]
                    k = k + 1
                C[cast[int64](i * N + j)] = s
                j = j + 1
            i = i + 1
        # fold the result matrix into the running checksum each rep
        p: int64 = 0
        while p < N * N:
            acc = acc + C[cast[int64](p)]
            p = p + 1
        reps = reps + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

# tak — Takeuchi function, a classic heavily-recursive call-overhead benchmark.
# tak(x,y,z) = z if x<=y else tak(tak(x-1,y,z), tak(y-1,z,x), tak(z-1,x,y)).
# Three arguments and genuine irreducible tree recursion: gcc does NOT transform
# it to a loop, and it is immune to the fib linear-recurrence idiom matcher — so
# it measures GENERAL call/prologue/epilogue + arg-passing codegen quality and
# cannot be gamed by a single exact-shape lever. Checksum = sum of tak(18,12,z)
# for z in [0, 8).
def tak(x: int64, y: int64, z: int64) -> int64:
    if x <= y:
        return z
    return tak(tak(x - 1, y, z), tak(y - 1, z, x), tak(z - 1, x, y))

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: int64 = 0
    z: int64 = 0
    while z < 8:
        acc = acc + tak(18, 12, z)
        z = z + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

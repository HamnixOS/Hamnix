# licm — nested loop whose inner body recomputes several subexpressions that are
# invariant w.r.t. the inner loop variable j: (a*a + b), (a*3 - 7), and the CSE
# repeat (a*a). Classic LICM + CSE bait. Pure ALU, compute-bound.
#
# Each inner step folds its contribution into a global ring buffer slot
# bucket[j & 63] (a real memory write), so a smart C compiler cannot collapse
# the side-effect-free loop nest to a closed-form constant at -O2 — the
# comparison stays about generated loop code, not gcc's loop-elimination. All
# slots are masked to 40 bits so signed-overflow semantics can never diverge
# between Adder and C. Checksum = sum of all 64 buckets.
bucket: Array[64, int64]

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    mask: int64 = 1099511627775            # 2^40 - 1
    a: int64 = 1
    while a < 7000:
        b: int64 = a + 13
        j: int64 = 0
        while j < 7000:
            # a*a, a*a+b, a*3-7 are all loop-invariant in j (LICM);
            # a*a appears twice (CSE).
            t1: int64 = a * a + b
            t2: int64 = a * 3 - 7
            t3: int64 = a * a
            slot: int64 = j & 63
            bucket[cast[int64](slot)] = (bucket[cast[int64](slot)] + t1 + t2 + t3 + j) & mask
            j = j + 1
        a = a + 1
    acc: int64 = 0
    k: int64 = 0
    while k < 64:
        acc = acc + bucket[cast[int64](k)]
        k = k + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

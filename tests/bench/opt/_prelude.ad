# tests/bench/opt/_prelude.ad — shared Adder prelude for the opt benchmark
# kernels. Provides print_u64() (writes a decimal uint64 + newline to stdout via
# the codegen.ad __syscall3 write builtin). The bench harness
# (scripts/bench_opt.sh -> _bench_opt_run.py) PREPENDS this to each kernel's .ad
# body, then compiles the whole unit through the NATIVE codegen.ad with the
# optimizer OFF (baseline) and ON (--opt / ADDER_OPT, the 6-pass optimizer),
# producing two host x86_64-linux ELFs that self-time nothing — wall time is
# measured by the harness around the process. Output is the kernel checksum,
# which the harness asserts EQUAL across all four configs.
_pb_scratch: Array[32, uint8]
_pb_out: Array[34, uint8]

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        _pb_scratch[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        _pb_scratch[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    m: int64 = 0
    while k >= 0:
        _pb_out[cast[int64](m)] = _pb_scratch[cast[int64](k)]
        m = m + 1
        k = k - 1
    _pb_out[cast[int64](m)] = cast[uint8](10)
    __syscall3(cast[int64](1), cast[int64](1), &_pb_out[0], cast[uint64](m + 1))
    return 0

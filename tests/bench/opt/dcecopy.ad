# dcecopy — tight loop seeded with DEAD temporaries (computed, never read) and
# COPY chains (c = b, d = c) plus a constant-condition branch. DCE + copy-prop +
# const-branch bait. The live result is independent of the dead work, so a
# correct optimizer removes it without changing the checksum.
#
# The live value is folded into a global ring buffer slot bucket[i & 63] (a real
# memory write) so gcc -O2 cannot collapse the loop to a closed form and delete
# it — the comparison stays about loop codegen, not loop elimination. Slots are
# masked to 48 bits to keep signed semantics identical. Checksum = sum of slots.
bucket: Array[64, int64]

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    mask: int64 = 281474976710655          # 2^48 - 1
    i: int64 = 0
    while i < 80000000:
        a: int64 = i * 2 + 1
        # copy chain: b->c->d, only d is used
        b: int64 = a
        c: int64 = b
        d: int64 = c
        # dead temporaries: computed, never read
        dead1: int64 = a * 99 + 7
        dead2: int64 = dead1 + i
        dead3: int64 = dead2 * 3
        slot: int64 = i & 63
        # constant-condition branch (always-true): const-branch fold bait
        if 1 == 1:
            bucket[cast[int64](slot)] = (bucket[cast[int64](slot)] + d) & mask
        else:
            bucket[cast[int64](slot)] = (bucket[cast[int64](slot)] - d) & mask
        i = i + 1
    acc: int64 = 0
    k: int64 = 0
    while k < 64:
        acc = acc + bucket[cast[int64](k)]
        k = k + 1
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

# tests/bench/gamelang/bounce_game.ad — the shared, target-agnostic 2D-game
# micro-benchmark used by the gamelang gap analysis (docs/gamelang_gap_analysis.md).
#
# It is the Adder + hamSDL arm of a THREE-way apples-to-apples bench (the other
# two arms — C++ software-blit and Python + pygame — live beside this file and
# run the byte-identical integer simulation). The workload is the 2D-game
# essential loop: N axis-aligned sprites, each with an integer position and
# velocity, updated + bounced off the window walls every frame and drawn as a
# filled rect, for M frames. A uint64 checksum of the FINAL sprite state is the
# cross-language invariant (all three implementations MUST print the same value),
# so the timing comparison is honest.
#
# This module is EXTERN-FREE and only touches the target-agnostic hamSDL core
# (lib/hamsdl.ad), so it compiles for BOTH x86_64-linux (host bench, real timing)
# and x86_64-adder-user (device build, proves the dual-target seam is intact) —
# exactly like lib/sdlpong.ad. The two thin drivers are:
#     bounce_hamsdl_host.ad   host: run M frames, rasterize each, print checksum.
#     bounce_hamsdl_dev.ad    device: wire the same game to the wsys backend.

from lib.hamsdl import sdl_begin_frame, sdl_clear, sdl_fill_rect, sdl_rgb


# Window + sprite geometry (public so the drivers can size their window).
BW: int32 = 640
BH: int32 = 480
BSPR: int32 = 8
BN_MAX: int32 = 512


# Per-sprite state (positions, velocities). Capacity BN_MAX; the active count is
# _bn. Integer only — no floats — so the sim is bit-exact across languages.
_bx:  Array[512, int32]
_by:  Array[512, int32]
_bvx: Array[512, int32]
_bvy: Array[512, int32]
_bn:  int32 = 0

# Linear-congruential PRNG (glibc constants) for deterministic sprite seeding.
# 32-bit state; assignment into the uint32 truncates, matching C uint32_t and a
# Python `& 0xffffffff`, so every language derives the identical start state.
_lcg: uint32 = 12345


def _bnext() -> int32:
    _lcg = _lcg * 1103515245 + 12345
    return cast[int32]((_lcg >> 16) & 32767)


# Seed n sprites into the window with small non-zero velocities.
def bounce_init(n: int32):
    if n > BN_MAX:
        n = BN_MAX
    _bn = n
    _lcg = 12345
    i: int32 = 0
    while i < n:
        _bx[i] = _bnext() % (BW - BSPR)
        _by[i] = _bnext() % (BH - BSPR)
        vx: int32 = (_bnext() % 5) - 2
        if vx == 0:
            vx = 1
        _bvx[i] = vx
        vy: int32 = (_bnext() % 5) - 2
        if vy == 0:
            vy = 1
        _bvy[i] = vy
        i = i + 1


# Advance every sprite one frame: integrate position, reflect off the 4 walls.
def bounce_step():
    i: int32 = 0
    while i < _bn:
        _bx[i] = _bx[i] + _bvx[i]
        if _bx[i] < 0:
            _bx[i] = 0
            _bvx[i] = 0 - _bvx[i]
        elif _bx[i] > BW - BSPR:
            _bx[i] = BW - BSPR
            _bvx[i] = 0 - _bvx[i]
        _by[i] = _by[i] + _bvy[i]
        if _by[i] < 0:
            _by[i] = 0
            _bvy[i] = 0 - _bvy[i]
        elif _by[i] > BH - BSPR:
            _by[i] = BH - BSPR
            _bvy[i] = 0 - _bvy[i]
        i = i + 1


# Build one frame: clear the backdrop, then a filled rect per sprite. This is
# the DRAW half of the workload; the backend then rasterizes the display list.
def bounce_render():
    sdl_begin_frame()
    sdl_clear(BW, BH, sdl_rgb(10, 12, 20))
    i: int32 = 0
    while i < _bn:
        col: uint32 = sdl_rgb((i * 7) & 255, (i * 13) & 255, (i * 5 + 64) & 255)
        sdl_fill_rect(_bx[i], _by[i], BSPR, BSPR, col)
        i = i + 1


# uint64 checksum of the final sprite state — the cross-language invariant.
# Wraps mod 2^64 exactly like C uint64_t / a Python `& 0xffffffffffffffff`.
def bounce_checksum() -> uint64:
    chk: uint64 = 0
    i: int32 = 0
    while i < _bn:
        chk = chk * 31 + cast[uint64](_bx[i] * 7 + _by[i] * 13 +
                                      (_bvx[i] + 8) + (_bvy[i] + 8) * 4)
        i = i + 1
    return chk

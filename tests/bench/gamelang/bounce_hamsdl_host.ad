# tests/bench/gamelang/bounce_hamsdl_host.ad — HOST driver (x86_64-linux) for
# the bouncing-sprites bench. Runs the shared game (bounce_game.ad) for M frames
# through the hamSDL HOST backend (lib/hamsdl_host.ad), which RASTERIZES every
# frame's display list into a real RGB framebuffer via the vk 2D layer — i.e. it
# pays the full software-raster cost each frame, exactly like the device does.
# It prints the cross-language checksum; wall-clock timing is done externally by
# scripts/bench_gamelang.sh (best-of-N, minus an M=0 startup baseline).
#
#   USAGE:  bounce_hamsdl_host [N] [M] [PRESENT]   (defaults N=500 M=2000 P=1)
#           PRESENT=0 builds+updates every frame but SKIPS the rasterize/present
#           step — used by the bench to split the cheap display-list-BUILD cost
#           (pure Adder) from the dominant software-RASTER cost (vk2d).
#   OUTPUT: one line  "CHECKSUM %016x"  on stdout.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

from tests.bench.gamelang.bounce_game import bounce_init, bounce_step, \
    bounce_render, bounce_checksum, BW, BH
from lib.hamsdl_host import sdl_host_present


obuf: Array[64, uint8]
obuf_n: uint64 = 0


def _o_ch(c: uint8):
    obuf[obuf_n] = c
    obuf_n = obuf_n + 1


def _o_str(s: Ptr[uint8]):
    i: uint64 = 0
    while s[i] != 0:
        _o_ch(s[i])
        i = i + 1


def _o_hex16(v: uint64):
    i: int32 = 15
    while i >= 0:
        nyb: uint64 = (v >> cast[uint64](i * 4)) & 15
        d: uint8 = cast[uint8](nyb)
        if d < 10:
            _o_ch(d + 48)
        else:
            _o_ch(d - 10 + 97)
        i = i - 1


def _o_flush():
    if obuf_n > 0:
        sys_write(1, &obuf[0], obuf_n)
        obuf_n = 0


def _atoi(p: Ptr[uint8]) -> int32:
    v: int32 = 0
    i: uint64 = 0
    while p[i] >= 48 and p[i] <= 57:
        v = v * 10 + cast[int32](p[i]) - 48
        i = i + 1
    return v


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    n: int32 = 500
    m: int32 = 2000
    present: int32 = 1
    if argc >= 2:
        n = _atoi(cast[Ptr[uint8]](argv[1]))
    if argc >= 3:
        m = _atoi(cast[Ptr[uint8]](argv[2]))
    if argc >= 4:
        present = _atoi(cast[Ptr[uint8]](argv[3]))

    bounce_init(n)

    f: int32 = 0
    while f < m:
        bounce_step()
        bounce_render()
        if present != 0:
            sdl_host_present(BW, BH)
        f = f + 1

    _o_str(cast[Ptr[uint8]]("CHECKSUM "))
    _o_hex16(bounce_checksum())
    _o_ch(10)
    _o_flush()
    return 0

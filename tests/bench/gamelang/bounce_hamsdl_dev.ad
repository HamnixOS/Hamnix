# tests/bench/gamelang/bounce_hamsdl_dev.ad — DEVICE driver (x86_64-adder-user)
# for the bouncing-sprites bench. This build exists to PROVE the dual-target
# seam: the identical shared game (bounce_game.ad) that the host bench times also
# compiles + wires to the real wsys backend (lib/hamsdl_dev.ad) and would run on
# the Hamnix desktop. The gate only requires it to COMPILE natively; it is not
# executed under QEMU here.

from lib.hamsdl import sdl_set_fps, sdl_frame_ms
from lib.hamsdl_dev import sdl_dev_init, sdl_dev_pump, sdl_dev_present, \
    sdl_dev_delay
from tests.bench.gamelang.bounce_game import bounce_init, bounce_step, \
    bounce_render, BW, BH


def main() -> int32:
    wid: int32 = sdl_dev_init(cast[Ptr[uint8]]("hamSDL Bounce"), 200, 100, BW, BH)
    if wid < 0:
        return 1
    bounce_init(500)
    sdl_set_fps(60)
    while True:
        sdl_dev_pump()
        bounce_step()
        bounce_render()
        sdl_dev_present()
        sdl_dev_delay(cast[uint64](sdl_frame_ms()))
    return 0

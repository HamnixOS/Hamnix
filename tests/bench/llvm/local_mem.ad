# Local-memory subset exercise for the OPTIONAL LLVM backend (ssa_llvm.ad):
# address-taken scalars, pointer load/store deref, and local (stack) arrays —
# all modeled as SVO_ALLOCA + sized SVO_LOAD/SVO_STORE.  Every function here
# BAILS the pre-memory subset (SBR_MEMORY) and EMITS after the widening.
extern def print_u64(v: uint64) -> int64

# address-of a scalar local + pointer read/write deref (`*p = *p + k`)
def deref_rw(n: int64) -> int64:
    x: int64 = n
    p: Ptr[int64] = &x
    *p = *p + 5
    return x                       # observes the store through the alias

# local array: fill arr[i]=i*i+1 then sum (load/store through alloca+GEP)
def arr_sum(n: int64) -> int64:
    buf: Array[16, int64]
    i: int64 = 0
    while i < n:
        buf[i] = i * i + 1
        i = i + 1
    s: int64 = 0
    i = 0
    while i < n:
        s += buf[i]
        i = i + 1
    return s

# narrow (byte) local array + address-taken byte scalar deref
def bytes_test() -> int64:
    b: Array[8, uint8]
    i: int64 = 0
    while i < 8:
        b[i] = cast[uint8](i * 5 + 1)
        i = i + 1
    t: int64 = 0
    i = 0
    while i < 8:
        t += cast[int64](b[i])
        i = i + 1
    c: uint8 = 200
    pc: Ptr[uint8] = &c
    *pc = *pc + 7
    t += cast[int64](c)
    return t

def main() -> int64:
    print_u64(cast[uint64](deref_rw(37)))     # 42
    print_u64(cast[uint64](arr_sum(10)))      # 295
    print_u64(cast[uint64](bytes_test()))     # 8*..=148 + 207 = 355
    return 0

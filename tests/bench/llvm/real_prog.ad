# tests/bench/llvm/real_prog.ad
#
# HEADLINE program for the widened OPTIONAL LLVM backend (adder/compiler/
# ssa_llvm.ad).  It is a substantial multi-function integer program that
# deliberately exercises the two constructs the widening added:
#
#   * GLOBAL ADDRESS-OF — `&g_buf[0]` (element address of a global array) and
#     `&g_stat` (address of a scalar global) are passed to helpers.  These are
#     the pervasive real-world pattern (`write(1, &buf, n)`), previously a hard
#     bail (SBR_MEMORY).
#   * >6-ARG CALL — `combine7(...)` is a 7-parameter in-unit function, defined
#     AND called with 7 arguments (arg 7 lands on the SysV stack).  Previously a
#     hard bail (SBR_MANYARGS) on both the definition and the call.
#
# The address-consuming helpers (fill_seq / store_i64) and the decimal printer
# (print_u64) are declared `extern` and supplied by the linked C runtime
# (scripts/adder_llvm_runtime.c or the headline's real_prog_runtime.c) — exactly
# how a std/libc symbol is referenced.  Everything else stays in the SSA integer
# subset (global-array indexing, loops, branches, <=/>6-arg calls) and lowers to
# LLVM IR, so the whole program compiles + runs.
#
# Build + run end-to-end (proof harness):
#   scripts/adder_cc_llvm.sh tests/bench/llvm/real_prog.ad build/real_prog.elf
#   ./build/real_prog.elf
# Output must equal the native -O0 build (Python seed --target=x86_64-linux).

# ---- extern C-runtime helpers (address consumers + IO) -> `declare`s ----
extern def print_u64(val: uint64) -> int32
extern def fill_seq(p: Ptr[int64], n: int64, seed: int64) -> int32
extern def store_i64(p: Ptr[int64], val: int64) -> int32

# ---- globals referenced BY ADDRESS ----
g_buf: Array[16, int64]
g_stat: int64 = 0

# ---- in-subset compute: sum of the global array ----
def sum_buf(n: int64) -> int64:
    s: int64 = 0
    i: int64 = 0
    while i < n:
        s = s + g_buf[i]
        i = i + 1
    return s

# ---- in-subset compute: max of the global array ----
def max_buf(n: int64) -> int64:
    m: int64 = g_buf[0]
    i: int64 = 1
    while i < n:
        if g_buf[i] > m:
            m = g_buf[i]
        i = i + 1
    return m

# ---- 7-ARGUMENT function (arg 7 arrives on the SysV stack) ----
def combine7(a: int64, b: int64, c: int64, d: int64,
             e: int64, f: int64, g: int64) -> int64:
    return a * 1 + b * 2 + c * 3 + d * 4 + e * 5 + f * 6 + g * 7

def main() -> int32:
    # &g_buf[0] : pass a GLOBAL's element address to a helper (fills g_buf[i] =
    # seed + i*i).
    fill_seq(&g_buf[0], 16, 100)

    # In-subset reductions over the same global array.
    total: int64 = sum_buf(16)
    biggest: int64 = max_buf(16)

    # &g_stat : pass a SCALAR GLOBAL's address to a helper that writes it.
    store_i64(&g_stat, total)

    # Read the scalar global back (in-subset scalar-global load) and fold it
    # through the 7-arg call together with six array elements.
    w: int64 = combine7(g_buf[0], g_buf[1], g_buf[2], g_buf[3],
                        g_buf[4], g_buf[5], g_stat)

    print_u64(cast[uint64](total))       # sum
    print_u64(cast[uint64](biggest))     # max
    print_u64(cast[uint64](g_stat))      # scalar global written via &g_stat
    print_u64(cast[uint64](w))           # 7-arg combine
    return 0

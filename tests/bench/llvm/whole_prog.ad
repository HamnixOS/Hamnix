# tests/bench/llvm/whole_prog.ad
#
# A substantial, multi-function integer program used to prove the OPTIONAL Adder
# LLVM backend (adder/compiler/ssa_llvm.ad, `host_ac.elf --backend=llvm`) is a
# REAL, usable backend end-to-end — not just a micro-bench. Every compute
# function here stays inside the SSA integer subset (i64/u64 scalars, global
# arrays, loops, branches, recursion, direct <=6-arg calls), so ALL of them are
# lowered to LLVM IR and cross-call each other + main. The one function that
# bails — print_u64 (it takes the address of a global array and issues a raw
# write syscall) — is emitted as an external `declare` and supplied by the C
# runtime (scripts/adder_llvm_runtime.c), exactly like a std/runtime symbol.
#
# Build + run end-to-end:
#   scripts/adder_cc_llvm.sh tests/bench/llvm/whole_prog.ad build/whole_prog.elf
#   ./build/whole_prog.elf
# The output must equal the native -O0 build (Python seed --target=x86_64-linux).

# --- IO helper (BAILS the subset -> external declare, provided by runtime) ---
_pb_scratch: Array[32, uint8]
_pb_out: Array[34, uint8]

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        _pb_scratch[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        _pb_scratch[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    m: int64 = 0
    while k >= 0:
        _pb_out[cast[int64](m)] = _pb_scratch[cast[int64](k)]
        m = m + 1
        k = k - 1
    _pb_out[cast[int64](m)] = cast[uint8](10)
    __syscall3(cast[int64](1), cast[int64](1), &_pb_out[0], cast[uint64](m + 1))
    return 0

# --- number theory: all in-subset, mutually recursive / cross-calling ---

# Euclid's GCD (loop form).
def gcd(a: int64, b: int64) -> int64:
    while b != 0:
        t: int64 = b
        b = a % b
        a = t
    return a

# LCM via gcd (cross-call).
def lcm(a: int64, b: int64) -> int64:
    return a / gcd(a, b) * b

# Trial-division primality.
def is_prime(n: int64) -> int64:
    if n < 2:
        return 0
    i: int64 = 2
    while i * i <= n:
        if n % i == 0:
            return 0
        i = i + 1
    return 1

# Count primes in [2, limit] (calls is_prime).
def count_primes(limit: int64) -> int64:
    c: int64 = 0
    n: int64 = 2
    while n <= limit:
        c = c + is_prime(n)
        n = n + 1
    return c

# Classic tree recursion (call-overhead heavy).
def fib(n: int64) -> int64:
    if n < 2:
        return n
    return fib(n - 1) + fib(n - 2)

# Collatz stopping time.
def collatz_len(n: int64) -> int64:
    steps: int64 = 0
    while n != 1:
        if n % 2 == 0:
            n = n / 2
        else:
            n = 3 * n + 1
        steps = steps + 1
    return steps

# --- global-array memory: Sieve of Eratosthenes (LOAD/STORE i8 globals) ---
sieve_flags: Array[100001, uint8]

def sieve_count(limit: int64) -> int64:
    z: int64 = 0
    while z <= limit:
        sieve_flags[cast[int64](z)] = cast[uint8](0)
        z = z + 1
    i: int64 = 2
    while i * i <= limit:
        if sieve_flags[cast[int64](i)] == cast[uint8](0):
            j: int64 = i * i
            while j <= limit:
                sieve_flags[cast[int64](j)] = cast[uint8](1)
                j = j + i
        i = i + 1
    count: int64 = 0
    i = 2
    while i <= limit:
        if sieve_flags[cast[int64](i)] == cast[uint8](0):
            count = count + 1
        i = i + 1
    return count

# 6-argument call: exercise the full SysV register-arg lowering (the subset cap).
def blend6(a: int64, b: int64, c: int64, d: int64, e: int64, f: int64) -> int64:
    return a + 2 * b + 3 * c + 5 * d + 7 * e + 11 * f

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: int64 = 0
    acc = acc + gcd(1071, 462)                 # 21
    acc = acc + lcm(21, 6)                      # 42
    acc = acc + count_primes(1000)             # 168
    acc = acc + fib(20)                         # 6765
    acc = acc + collatz_len(27)                # 111
    acc = acc + sieve_count(100000)            # 9592
    acc = acc + blend6(1, 2, 3, 4, 5, 6)       # 1+4+9+20+35+66 = 135
    print_u64(cast[uint64](acc))
    return cast[int32](acc & 255)

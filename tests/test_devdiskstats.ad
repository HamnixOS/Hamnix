# tests/test_devdiskstats.ad
#
# §13 regression for sys/src/9/port/devdiskstats.ad — the /dev/diskstats
# cdev, which renders Linux /proc/diskstats-shape rows backed by the
# real per-device I/O counters kernel/block/blk.ad now keeps.
#
# The fixture:
#   1. open /dev/diskstats, read the blob.
#   2. Assert it is non-empty and that the FIRST row is well-formed:
#      it must begin with the major number "8" (devdiskstats hardcodes
#      major 8 for sd*), and the row must carry exactly 14 whitespace-
#      separated fields — the Linux /proc/diskstats contract every
#      userland tool (iostat, sar, atop) sscanf's against.
#   3. Echo the blob so the script can eyeball it.
#
# PASS markers (asserted by scripts/test_devdiskstats.sh):
#   * "[test_devdiskstats] start"
#   * "[test_devdiskstats] opened OK"
#   * "[test_devdiskstats] field_count=14"
#   * "[test_devdiskstats] done"

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        z: Array[1, uint8]
        z[0] = 48
        sys_write(fd, &z[0], 1)
        return
    digits: Array[24, uint8]
    m: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[m] = cast[uint8](v % 10) + 48
        v = v / 10
        m = m + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while m > 0:
        m = m - 1
        out[i] = digits[m]
        i = i + 1
    sys_write(fd, &out[0], i)


# Count whitespace-separated fields on the first line of buf[0..n].
# A "field" is a maximal run of non-space, non-newline bytes.
def _first_line_field_count(buf: Ptr[uint8], n: uint64) -> uint64:
    i: uint64 = 0
    fields: uint64 = 0
    in_field: uint64 = 0
    while i < n:
        c: uint8 = buf[i]
        if c == 10:                                # newline ends line
            i = n
        else:
            if c == 32:                            # space
                in_field = 0
            else:
                if in_field == 0:
                    fields = fields + 1
                    in_field = 1
            i = i + 1
    return fields


def main() -> int32:
    write_str(1, "[test_devdiskstats] start\n")

    fd: int32 = sys_open("/dev/diskstats")
    if fd < 0:
        write_str(1, "[test_devdiskstats] FAIL: open\n")
        return 1
    write_str(1, "[test_devdiskstats] opened OK\n")

    buf: Array[4096, uint8]
    n: int64 = sys_read(fd, &buf[0], 4096)
    sys_close(fd)
    if n <= 0:
        write_str(1, "[test_devdiskstats] FAIL: read returned <= 0\n")
        return 1

    write_str(1, "[test_devdiskstats] blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))
    write_str(1, "\n")

    # First row must begin with major "8 ".
    if buf[0] != 56 or buf[1] != 32:               # '8' ' '
        write_str(1, "[test_devdiskstats] FAIL: row not major 8\n")
        return 1

    fc: uint64 = _first_line_field_count(&buf[0], cast[uint64](n))
    write_str(1, "[test_devdiskstats] field_count=")
    write_dec(1, fc)
    write_str(1, "\n")
    if fc != 14:
        write_str(1, "[test_devdiskstats] FAIL: expected 14 fields\n")
        return 1

    write_str(1, "[test_devdiskstats] done\n")
    return 0

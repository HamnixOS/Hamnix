def add(x: int32, y: int32 = 10) -> int32:
    return x + y
def combine(a: int32, b: int32 = 5, c: int32 = 7) -> int32:
    return a + b + c
def main() -> int32:
    # nested normalized calls: each arg expr also uses kwargs/defaults,
    # stressing the re-entrant normalization-window stack.
    return combine(add(1), c=add(2, y=3), b=add(0))   # 11 + 10 + 5 = 26

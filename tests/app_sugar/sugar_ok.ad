# Default parameter values + keyword arguments (roadmap item 7).
def add(x: int32, y: int32 = 10) -> int32:
    return x + y

def scale(v: int32, factor: int32 = 2, bias: int32 = 100) -> int32:
    return v * factor + bias

def main() -> int32:
    # (1) default omitted             add(5)           = 5 + 10  = 15
    # (2) default passed explicitly   add(5, 20)       = 25
    # (3) one kwarg overrides default scale(3,factor=4)= 12 + 100 = 112 -> +? keep small
    # keep the running total inside a byte so the exit code is exact.
    t: int32 = 0
    t = t + add(5)               # 15
    t = t + add(5, 20)           # 25  -> 40
    if scale(3) != 106:          # 3*2+100
        return 200
    if scale(3, factor=4) != 112:
        return 201
    if scale(3, bias=0) != 6:
        return 202
    if scale(v=1, bias=1, factor=1) != 2:   # full reorder by name
        return 203
    return t                      # 40

# tests/test_x86_64_linux_fileio.ad
#
# Smoke test for the `x86_64-linux` Adder target: a FREESTANDING program
# (no libc, no Plan 9 base) that does real file I/O against the HOST Linux
# kernel via raw syscalls, then exits with a status derived from the data
# it read back. The harness (scripts/test_adder_x86_64_linux.sh) compiles
# this to a native x86_64 Linux ELF, runs it on the host, and asserts both
# the file contents AND the exit code reached the host kernel.
#
# Syscall wrappers come from user/linux-runtime.S (standard Linux x86_64
# numbers behind the raw `syscall` instruction). The path is passed as
# argv[1].

extern def sys_open(path: Ptr[uint8], flags: int64, mode: int64) -> int32
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

# Linux open(2) flags.
O_WRONLY: int64 = 1
O_CREAT:  int64 = 64       # 0o100
O_TRUNC:  int64 = 512      # 0o1000
O_RDONLY: int64 = 0

# The payload we write then read back. 5 bytes: 'H','a','m',0x10,0x20.
# Byte sum = 72+97+109+16+32 = 326; (326 & 0xFF) = 70 -> the exit code.
payload: Array[5, uint8]
rdbuf:   Array[16, uint8]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # argv[1] is the file path (a C string pointer). Fall back to a fixed
    # path is not possible without a literal pointer, so require argc >= 2.
    if argc < 2:
        return 90

    path: Ptr[uint8] = cast[Ptr[uint8]](argv[1])

    # Fill the payload deterministically.
    payload[0] = cast[uint8](72)    # 'H'
    payload[1] = cast[uint8](97)    # 'a'
    payload[2] = cast[uint8](109)   # 'm'
    payload[3] = cast[uint8](16)
    payload[4] = cast[uint8](32)

    # --- create + write -------------------------------------------------
    wfd: int32 = sys_open(path, O_WRONLY | O_CREAT | O_TRUNC, 420)  # 0o644
    if wfd < 0:
        return 91
    nw: int64 = sys_write(wfd, &payload[0], cast[uint64](5))
    if nw != 5:
        return 92
    sys_close(wfd)

    # --- reopen + read back ---------------------------------------------
    rfd: int32 = sys_open(path, O_RDONLY, 0)
    if rfd < 0:
        return 93
    nr: int64 = sys_read(rfd, &rdbuf[0], cast[uint64](16))
    sys_close(rfd)
    if nr != 5:
        return 94

    # --- derive exit status from the bytes read back --------------------
    # Verify round-trip integrity, then exit with (sum of bytes) & 0xFF.
    i: int64 = 0
    sum: int64 = 0
    while i < 5:
        a: uint8 = payload[cast[int64](i)]
        b: uint8 = rdbuf[cast[int64](i)]
        if cast[int64](a) != cast[int64](b):
            return 95
        sum = sum + cast[int64](b)
        i = i + 1

    return cast[int32](sum & cast[int64](255))

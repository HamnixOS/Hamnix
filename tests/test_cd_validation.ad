# tests/test_cd_validation.ad
#
# M16.112 regression: SYS_CHDIR must validate that the resolved path
# actually exists as a directory BEFORE installing it as per-task cwd.
# Before this fix, `cd nope/nope/nope` silently accumulated bogus
# segments into the task cwd — real-hardware GNOME Boxes testing
# caught it because `cd SUBDIR; ls` listed root regardless.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_cd_validation.ad -o build/user/test_cd_validation.elf
#
# Run via scripts/test_cd_validation.sh, which embeds this binary at
# /bin/test_cd_validation inside the cpio initramfs and drives it via
# hamsh.
#
# Contract:
#   1. chdir("/etc") succeeds          (real cpio directory)
#   2. chdir("/nope/nope") fails -ENOENT and SYS_ERRSTR reports
#      "chdir: no such directory"
#   3. cwd is still "/etc" after the failure (no partial mutation)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_chdir(path: Ptr[char]) -> int32
extern def sys_getcwd(buf: Ptr[uint8], count: uint64) -> int64
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def main() -> int32:
    write_str(1, "[test_cd_validation] start\n")

    # 1. Valid directory — should succeed and update cwd.
    rc: int32 = sys_chdir("/etc")
    if rc != 0:
        write_str(1, "[test_cd_validation] FAIL: chdir(/etc) rejected\n")
        return 1
    write_str(1, "[test_cd_validation] PASS: chdir(/etc) ok\n")

    # 2. Confirm cwd actually moved.
    cwd: Array[128, uint8]
    n: int64 = sys_getcwd(&cwd[0], 128)
    if n <= 0:
        write_str(1, "[test_cd_validation] FAIL: getcwd after /etc\n")
        return 2
    write_str(1, "[test_cd_validation] cwd=")
    write_str(1, &cwd[0])
    write_str(1, "\n")

    # 3. Invalid directory — must FAIL with -ENOENT and not mutate cwd.
    rc = sys_chdir("/nope/nope")
    if rc >= 0:
        write_str(1, "[test_cd_validation] FAIL: chdir(/nope/nope) accepted\n")
        return 3
    write_str(1, "[test_cd_validation] PASS: chdir(/nope/nope) rejected\n")

    # 4. Pull the errstr the kernel installed and surface it.
    ebuf: Array[128, uint8]
    ebuf[0] = 0
    sys_errstr(&ebuf[0], 128)
    write_str(1, "[test_cd_validation] errstr=")
    write_str(1, &ebuf[0])
    write_str(1, "\n")

    # 5. cwd should still be /etc — no partial mutation.
    n = sys_getcwd(&cwd[0], 128)
    if n <= 0:
        write_str(1, "[test_cd_validation] FAIL: getcwd after fail\n")
        return 4
    write_str(1, "[test_cd_validation] cwd_after=")
    write_str(1, &cwd[0])
    write_str(1, "\n")

    write_str(1, "[test_cd_validation] done\n")
    return 0

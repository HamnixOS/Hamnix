# `unsafe:` opt-out: force-unwrap inside an unsafe block emits NO None-check
# even with --check-bounds on — mirrors the array-bounds `unsafe:` suppression.

def find_positive(x: int32) -> Option:
    if x > 0:
        return Some(x)
    return None

def main() -> int32:
    o: Option = find_positive(0 - 5)        # None
    v: int64 = 0
    unsafe:
        v = cast[int64](o!)                 # no trap here (checks suppressed)
    return cast[int32](v)

# Force-unwrap `!` on an Option that is None. Under --check-bounds this MUST
# trap cleanly (ud2 -> SIGILL, wait-status 132). Without the flag, the unwrap
# is a zero-cost extraction that yields garbage (undefined) rather than trapping.

def find_positive(x: int32) -> Option:
    if x > 0:
        return Some(x)
    return None

def main() -> int32:
    o: Option = find_positive(0 - 5)        # None
    v: int64 = cast[int64](o!)              # None-deref: traps under --check-bounds
    return cast[int32](v)

# Force-unwrap `!` on Option/Result that IS the success variant: yields the
# payload. Exercised with and without --check-bounds; the success path runs
# identically either way (the trap is never taken).

def find_positive(x: int32) -> Option:
    if x > 0:
        return Some(x)
    return None

def checked_div(a: int32, b: int32) -> Result:
    if b == 0:
        return Err(1)
    return Ok(a / b)

def main() -> int32:
    o: Option = find_positive(7)
    total: int64 = cast[int64](o!)          # unwrap Some(7) -> 7
    r: Result = checked_div(40, 8)
    total = total + cast[int64](r!)         # unwrap Ok(5) -> 5  => 12
    return cast[int32](total)               # expect 12

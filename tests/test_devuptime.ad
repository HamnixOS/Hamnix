# tests/test_devuptime.ad
#
# Regression: open /dev/uptime for read, drain up to 64 bytes, echo
# the captured slice to stdout. The script asserts the captured text
# is shape "<digits>.<digit><digit> <digits>.<digit><digit>\n" with
# the first decimal field non-zero (kernel has been booted for at
# least one centisecond by the time hamsh launches us).
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devuptime.ad -o build/user/test_devuptime.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Parse the leading "<secs>.<CC>" field; return the integer seconds
# value (or -1 on shape mismatch). We accept any non-empty digit run
# followed by '.' followed by exactly two more digits.
def _parse_uptime_secs(buf: Ptr[uint8], n: uint64) -> int64:
    if n < 4:                                     # min "0.00 "
        return -1
    i: uint64 = 0
    digits: uint64 = 0
    secs: uint64 = 0
    while i < n and buf[i] >= 48 and buf[i] <= 57:
        secs = secs * 10 + cast[uint64](buf[i] - 48)
        digits = digits + 1
        i = i + 1
    if digits == 0:
        return -1
    if i + 3 > n:
        return -1
    if buf[i] != 46:                              # '.'
        return -1
    if buf[i + 1] < 48 or buf[i + 1] > 57:
        return -1
    if buf[i + 2] < 48 or buf[i + 2] > 57:
        return -1
    return cast[int64](secs)


# After the first "secs.CC", expect a single space then a second
# "<digits>.<CC>" field. Returns 1 on a well-formed match, 0 otherwise.
def _check_idle_field(buf: Ptr[uint8], n: uint64) -> int32:
    # Re-scan past the first field to the space.
    i: uint64 = 0
    while i < n and buf[i] >= 48 and buf[i] <= 57:
        i = i + 1
    if i + 4 > n:
        return 0
    if buf[i] != 46:
        return 0
    i = i + 3                                     # skip ".CC"
    if i >= n or buf[i] != 32:                    # ' '
        return 0
    i = i + 1
    # Idle field: digit run + '.' + 2 digits + newline.
    digits: uint64 = 0
    while i < n and buf[i] >= 48 and buf[i] <= 57:
        digits = digits + 1
        i = i + 1
    if digits == 0:
        return 0
    if i + 3 > n:
        return 0
    if buf[i] != 46:
        return 0
    if buf[i + 1] < 48 or buf[i + 1] > 57:
        return 0
    if buf[i + 2] < 48 or buf[i + 2] > 57:
        return 0
    return 1


def main() -> int32:
    write_str(1, "[test_devuptime] start\n")

    fd: int32 = sys_open("/dev/uptime")
    if fd < 0:
        write_str(1, "[test_devuptime] open failed\n")
        return 1
    write_str(1, "[test_devuptime] opened /dev/uptime OK\n")

    buf: Array[128, uint8]
    n: int64 = sys_read(fd, &buf[0], 64)
    if n <= 0:
        write_str(1, "[test_devuptime] read returned <= 0\n")
        sys_close(fd)
        return 1

    write_str(1, "[test_devuptime] blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))

    secs: int64 = _parse_uptime_secs(&buf[0], cast[uint64](n))
    if secs < 0:
        write_str(1, "[test_devuptime] uptime shape FAIL\n")
        sys_close(fd)
        return 1

    ok: int32 = _check_idle_field(&buf[0], cast[uint64](n))
    if ok == 0:
        write_str(1, "[test_devuptime] idle-field shape FAIL\n")
        sys_close(fd)
        return 1

    # Emit the PASS marker the script greps for: "uptime_secs=N".
    # Re-render N from the parsed integer using a tiny helper so the
    # marker is self-contained (doesn't depend on slicing the blob).
    write_str(1, "[test_devuptime] uptime_secs=")
    # Render secs as decimal; we know it fits in uint64 and the
    # smallest legitimate boot-time value is small (single-digit
    # under fast QEMU) so a 24-byte scratch is plenty.
    digits: Array[24, uint8]
    v: uint64 = cast[uint64](secs)
    if v == 0:
        digits[0] = 48
        sys_write(1, &digits[0], 1)
    else:
        m: uint64 = 0
        while v != 0:
            digits[m] = cast[uint8](v % 10) + 48
            v = v / 10
            m = m + 1
        out: Array[24, uint8]
        i: uint64 = 0
        while m > 0:
            m = m - 1
            out[i] = digits[m]
            i = i + 1
        sys_write(1, &out[0], i)
    write_str(1, "\n")

    sys_close(fd)
    write_str(1, "[test_devuptime] done\n")
    return 0

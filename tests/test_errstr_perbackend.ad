# tests/test_errstr_perbackend.ad
#
# TODO net-item closure regression: per-backend errstr prefixes +
# userland perror.
#
# Assertions (host-side scripts/test_errstr_perbackend.sh greps the
# serial log for each marker):
#   1. After SYS_OPEN_WRITE("/tmp") fails (the path is an existing
#      tmpfs DIR), SYS_ERRSTR hands back a string that STARTS WITH
#      "tmpfs: " — proving the tmpfs backend installed a
#      backend-tagged errstr before the syscall-layer fallback
#      ("open for write: failed") could overwrite it.
#   2. perror("test_errstr_pb: open") on that same failure emits a
#      single fd-2 line containing BOTH the msg prefix AND the
#      "tmpfs:" backend tag, proving the userland libc-shape helper
#      reads SYS_ERRSTR and concatenates correctly.
#
# Boot env note: the heartbeat-style cpio boot has no real ext4
# partition mounted, so /ext paths don't route through ext4_open and
# can't exercise the ext4 prefix in this fixture. tmpfs is always
# available (the /tmp + /var mounts come from tmpfs_var_skeleton_init
# at boot), which makes /tmp the reliable backend probe.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_exit(code: uint64)

from lib.perror import perror


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def starts_with(s: Ptr[uint8], prefix: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while prefix[i] != 0:
        if s[i] != prefix[i]:
            return 0
        i = i + 1
    return 1


def main() -> int32:
    write_str(1, "[test_errstr_pb] start\n")

    # Force a tmpfs failure: open-for-write on the existing /tmp
    # directory. tmpfs_open_for_write sees the resolved slot is
    # kind == TMPFS_KIND_DIR and returns -EEXIST after installing
    # "tmpfs: open: path is a directory" via set_current_errstr.
    fd: int32 = sys_open_write("/tmp")
    if fd >= 0:
        write_str(1, "[test_errstr_pb] FAIL: /tmp open_write succeeded\n")
        return 1

    buf: Array[128, uint8]
    buf[0] = 0
    sys_errstr(&buf[0], 128)
    write_str(1, "[test_errstr_pb] tmpfs errstr: ")
    write_str(1, &buf[0])
    write_str(1, "\n")
    if starts_with(&buf[0], "tmpfs:") == 0:
        write_str(1, "[test_errstr_pb] FAIL: tmpfs prefix missing\n")
        # Fall through — perror line still emits so the host script
        # can map every assertion independently.

    # Re-fail the same open so perror has a fresh errstr to read,
    # then prove perror concatenates msg + errstr on ONE line.
    sys_open_write("/tmp")
    perror("[test_errstr_pb] open")

    write_str(1, "[test_errstr_pb] done\n")
    return 0

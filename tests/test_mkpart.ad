# tests/test_mkpart.ad
#
# M16.x partition write-side smoke fixture.
#
# Lives in tests/ rather than drivers/ so the production parser
# (drivers/block/partition.ad) stays free of fixture bytes; the
# only point of contact is one forward-declared call
# (partition_mkpart_smoke_test) the dispatcher invokes when a disk
# named "sd0" boots with no MBR signature.
#
# What it proves:
#
#   1. partition_mklabel_mbr(slot) lays down a valid empty MBR
#      (sector 0 zeros + 0x55AA signature), recoverable by the
#      existing parse_mbr() read side.
#
#   2. partition_mkpart_mbr(slot, idx, start_lba, end_lba, type)
#      splices two Linux-native (type 0x83) primaries into the same
#      sector 0 without trampling each other — i.e. the partition
#      table is built up incrementally, not block-stomped each time.
#
#   3. Re-running partition_rescan(slot) after the writes refreshes
#      the in-memory partition table, so blk_register_partitions
#      can mint sd0p1 + sd0p2 in the very same boot.
#
# Asserted markers (greppable from the host-side test script):
#
#   [mkpart] mbr label OK
#   [mkpart] partition 0 lba=2048..32768 type=0x83
#   [mkpart] partition 1 lba=32768..65536 type=0x83
#   [partition] disk=sd0 idx=0 lba=2048..32767 type=0x83
#   [partition] disk=sd0 idx=1 lba=32768..65535 type=0x83
#   blk: registered 'sd0p1' capacity=30720 sectors
#   blk: registered 'sd0p2' capacity=32768 sectors
#
# Notes on the two LBA notations:
#   - The mkpart-write line echoes the as-passed exclusive-end
#     values (so the install path's view matches how parted /
#     sfdisk talk about extents).
#   - The partition-read line emits the Linux-style inclusive last
#     LBA (matching scripts/test_partition.sh), which is one less
#     than the as-passed end on every primary.
# Capacities for sd0pN therefore follow as (end_lba - start_lba),
# e.g. 32768 - 2048 = 30720.
#
# WHY THE NAME-GATED HOOK?
#   We need a kernel-mode entry point for the fixture (mkpart is a
#   kernel API; the userland counterpart is months away). init/main.ad
#   already calls blk_scan_partitions() on every freshly-registered
#   disk, and partition.ad routes name=="sd0" + no-signature there to
#   us. That keeps the test invisible on every other boot path —
#   /dev/vda, /dev/nvme0n1, /dev/ram0 all skip it because their names
#   don't match.

from kernel.printk.printk import printk0
from drivers.block.partition import (
    partition_mklabel_mbr, partition_mkpart_mbr, partition_rescan,
)


# MBR partition type 0x83 — Linux native. Same byte the existing
# read-side test (scripts/test_partition.sh) plants via sfdisk.
MKPART_TYPE_LINUX: uint8 = 0x83

# Two contiguous primaries on a small (>=32 MiB) disk:
#   p0: LBA 2048..32768 exclusive — 15 MiB starting at the 1 MiB mark
#   p1: LBA 32768..65536 exclusive — 16 MiB tail
# The numbers match the spec's example so the host-side test script
# can assert literal markers (`lba=2048..32768`).
MKPART_P0_START: uint64 = 2048
MKPART_P0_END:   uint64 = 32768
MKPART_P1_START: uint64 = 32768
MKPART_P1_END:   uint64 = 65536


def partition_mkpart_smoke_test(slot: int32) -> int32:
    # Invoked from drivers/block/partition.ad's
    # _partition_mkpart_smoke_dispatch when name=="sd0" + no MBR sig.
    # Returns the partition count seen by the re-scan (>=0), or -1
    # on any failure — same convention as parse_mbr / parse_gpt.
    printk0("[mkpart] smoke begin (sd0, fresh disk)\n")

    if partition_mklabel_mbr(slot) != 0:
        printk0("[mkpart] mklabel FAIL\n")
        return -1

    if partition_mkpart_mbr(slot, 0, MKPART_P0_START, MKPART_P0_END,
                            MKPART_TYPE_LINUX) != 0:
        printk0("[mkpart] partition 0 write FAIL\n")
        return -1

    if partition_mkpart_mbr(slot, 1, MKPART_P1_START, MKPART_P1_END,
                            MKPART_TYPE_LINUX) != 0:
        printk0("[mkpart] partition 1 write FAIL\n")
        return -1

    # Re-scan picks up what we just wrote. partition_rescan calls
    # _partition_scan_inner WITHOUT clobbering the display name set
    # by the outer partition_scan_named call (partition_scan would
    # rewrite it to "slot0"). The dispatch hook is one-shot
    # (mkpart_smoke_fired guard in partition.ad), so this descends
    # into the normal MBR-present read path and emits the
    # [partition] disk=sd0 ... lines.
    rc: int32 = partition_rescan(slot)
    if rc < 0:
        printk0("[mkpart] rescan FAIL\n")
        return -1
    if rc < 2:
        # The re-scan must have seen both entries we just wrote;
        # anything less means the read-back didn't round-trip.
        printk0("[mkpart] rescan SHORT (expected 2 primaries)\n")
        return -1
    printk0("[mkpart] PASS\n")
    return rc

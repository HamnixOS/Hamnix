# tests/test_devcpuinfo.ad
#
# Regression: open /dev/cpuinfo for read, drain up to 384 bytes, echo
# the captured slice to stdout. The script asserts the captured text
# contains a recognised vendor string (GenuineIntel or AuthenticAMD).
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devcpuinfo.ad -o build/user/test_devcpuinfo.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Match the literal "vendor: GenuineIntel" or "vendor: AuthenticAMD"
# prefix in the captured blob — devcpuinfo_read always emits the
# "vendor: " line first. We don't pin a specific vendor because the
# host can be either Intel or AMD (or, under TCG, "AuthenticAMD"-ish
# on some QEMU configs and "GenuineIntel" by default).
def _has_known_vendor(buf: Ptr[uint8], n: uint64) -> int32:
    # Scan for either "GenuineIntel" (12 chars) or "AuthenticAMD" (12).
    intel: Ptr[uint8] = "GenuineIntel"
    amd:   Ptr[uint8] = "AuthenticAMD"
    if n < 12:
        return 0
    i: uint64 = 0
    while i + 12 <= n:
        # Try Intel.
        k: uint64 = 0
        ok: int32 = 1
        while k < 12:
            if buf[i + k] != intel[k]:
                ok = 0
                k = 12                       # break
            k = k + 1
        if ok != 0:
            return 1
        # Try AMD.
        k = 0
        ok = 1
        while k < 12:
            if buf[i + k] != amd[k]:
                ok = 0
                k = 12
            k = k + 1
        if ok != 0:
            return 2
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[test_devcpuinfo] start\n")

    fd: int32 = sys_open("/dev/cpuinfo")
    if fd < 0:
        write_str(1, "[test_devcpuinfo] open failed\n")
        return 1
    write_str(1, "[test_devcpuinfo] opened /dev/cpuinfo OK\n")

    buf: Array[512, uint8]
    n: int64 = sys_read(fd, &buf[0], 384)
    if n <= 0:
        write_str(1, "[test_devcpuinfo] read returned <= 0\n")
        sys_close(fd)
        return 1

    # Dump the captured blob verbatim. devcpuinfo_read terminates each
    # line with '\n'; the script greps for "vendor=GenuineIntel" or
    # "vendor=AuthenticAMD" as the PASS marker, so emit a "vendor="
    # banner that captures the recognised string explicitly.
    write_str(1, "[test_devcpuinfo] blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))

    hit: int32 = _has_known_vendor(&buf[0], cast[uint64](n))
    if hit == 1:
        write_str(1, "[test_devcpuinfo] vendor=GenuineIntel\n")
    elif hit == 2:
        write_str(1, "[test_devcpuinfo] vendor=AuthenticAMD\n")
    else:
        write_str(1, "[test_devcpuinfo] vendor=UNKNOWN\n")
        sys_close(fd)
        return 1

    sys_close(fd)
    write_str(1, "[test_devcpuinfo] done\n")
    return 0

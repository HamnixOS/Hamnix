# tests/test_hostowner_reach.ad
#
# arch audit §3.2 acceptance: prove the 5 kernel-internal uid==1 checks
# in arch/x86/kernel/syscall.ad now route through the named helper
# _syscall_require_hostowner — uniform "<op>: hostowner-required
# (uid=NNNN)" reason in errstr, single source of policy.
#
# The other 5 raw uid==1 checks in syscall.ad (SYS_SVC_CTL poll/read-out,
# SYS_WSYS_ALLOC, SYS_WSYS_FREE, SYS_VK_WINDOW_FRAME) belong to the
# concurrent F2 thin-shim agent's territory; their Plan-9 reshape pushes
# the policy to devsvc/devwsys `_perm_check_*`. Not covered here.
#
# Scenario:
#
#   1. Fixture spawned by hamsh inherits hostowner (uid 1) from PID 1.
#   2. sys_setuid(NOBODY) — must succeed (still hostowner at this
#      point), proving the downgrade path before we test denial.
#   3. As NOBODY, exercise each of the 5 ops; expect every one to
#      return -1 with errstr containing "hostowner-required (uid=65534)".
#
# Tested ops (category (b) — kernel-internal, no server-file boundary):
#   * SYS_SETUID (290)        — second call, should now deny since
#                               we're NOBODY.
#   * SYS_USERADD_ROOT (295)  — provisions ext4 subtree.
#   * SYS_SVC_PUBLISH (291)   — binary registry slot push.
#   * SYS_SET_REALTIME (292)  — wall-clock re-anchor.
#   * SYS_REBOOT (169)        — power_action gate (safe — helper
#                               returns BEFORE power_action fires).
#
# Final marker: `[hostowner_reach] PASS`.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_REBOOT:       uint64 = 169
SYS_ERRSTR:       uint64 = 265
SYS_GETUID:       uint64 = 288
SYS_SETUID:       uint64 = 290
SYS_SVC_PUBLISH:  uint64 = 291
SYS_SET_REALTIME: uint64 = 292
SYS_USERADD_ROOT: uint64 = 295

UID_HOSTOWNER: uint64 = 1
UID_NOBODY:    uint64 = 65534

LINUX_REBOOT_MAGIC1: uint64 = 0xfee1dead
LINUX_REBOOT_MAGIC2: uint64 = 0x28121969
LINUX_REBOOT_CMD_HALT: uint64 = 0xcdef0123


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: int64):
    if value < 0:
        sys_write(fd, "-", 1)
        value = -value
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = cast[uint64](value)
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def my_getuid() -> uint64:
    return cast[uint64](syscall6(SYS_GETUID, 0, 0, 0, 0, 0, 0))


def my_setuid(uid: uint64) -> int64:
    return syscall6(SYS_SETUID, uid, 0, 0, 0, 0, 0)


# Read errstr into the given buffer; returns the byte count installed.
def my_errstr(buf: Ptr[uint8], cap: uint64) -> int64:
    return syscall6(SYS_ERRSTR, cast[uint64](buf), cap, 0, 0, 0, 0)


# Substring match (NUL-terminated needle).
def buf_contains(haystack: Ptr[uint8], needle: Ptr[uint8]) -> int32:
    n: uint64 = strlen(needle)
    h: uint64 = strlen(haystack)
    if n == 0:
        return 1
    if n > h:
        return 0
    i: uint64 = 0
    while i + n <= h:
        j: uint64 = 0
        while j < n and haystack[i + j] == needle[j]:
            j = j + 1
        if j == n:
            return 1
        i = i + 1
    return 0


def check_deny(op_label: Ptr[uint8], rc: int64) -> int32:
    # rc must be negative; errstr must contain "hostowner-required"
    # AND the uid we expect (65534). Returns 0 on PASS, 1 on FAIL.
    write_str(1, "[hostowner_reach] op=")
    write_str(1, op_label)
    write_str(1, " rc=")
    write_dec(1, rc)
    if rc >= 0:
        write_str(1, " FAIL: op admitted as NOBODY\n")
        return 1
    errbuf: Array[128, uint8]
    i: uint64 = 0
    while i < 128:
        errbuf[i] = 0
        i = i + 1
    my_errstr(&errbuf[0], 128)
    write_str(1, " errstr=\"")
    write_str(1, &errbuf[0])
    write_str(1, "\"\n")
    if buf_contains(&errbuf[0], "hostowner-required") == 0:
        write_str(1, "[hostowner_reach] FAIL: errstr missing 'hostowner-required' for ")
        write_str(1, op_label)
        sys_write(1, "\n", 1)
        return 1
    if buf_contains(&errbuf[0], "uid=65534") == 0:
        write_str(1, "[hostowner_reach] FAIL: errstr missing 'uid=65534' for ")
        write_str(1, op_label)
        sys_write(1, "\n", 1)
        return 1
    return 0


def main() -> int32:
    write_str(1, "[hostowner_reach] start\n")

    initial_uid: uint64 = my_getuid()
    if initial_uid != UID_HOSTOWNER:
        write_str(1, "[hostowner_reach] FAIL: not hostowner at start (uid=")
        write_dec(1, cast[int64](initial_uid))
        write_str(1, ")\n")
        return 1
    write_str(1, "[hostowner_reach] inherited hostowner (uid 1)\n")

    # Downgrade to NOBODY. Hostowner can.
    drc: int64 = my_setuid(UID_NOBODY)
    if drc < 0:
        write_str(1, "[hostowner_reach] FAIL: downgrade SYS_SETUID(NOBODY) failed\n")
        return 2
    if my_getuid() != UID_NOBODY:
        write_str(1, "[hostowner_reach] FAIL: not NOBODY after downgrade\n")
        return 3
    write_str(1, "[hostowner_reach] downgraded to NOBODY (65534)\n")

    fails: int32 = 0

    # 1. SYS_SETUID: NOBODY trying to setuid back to hostowner — gated.
    rc1: int64 = my_setuid(UID_HOSTOWNER)
    fails = fails + check_deny("setuid", rc1)

    # 2. SYS_USERADD_ROOT: a0=username. Pass a valid-shape name; the
    # hostowner gate must fire BEFORE the disk path.
    rc2: int64 = syscall6(SYS_USERADD_ROOT,
                          cast[uint64]("auditprobe"), 0, 0, 0, 0, 0)
    fails = fails + check_deny("useradd", rc2)

    # 3. SYS_SVC_PUBLISH: a0=name, a1=400B payload. Pass NULL payload
    # (would be an "unpublish") — gate fires first.
    rc3: int64 = syscall6(SYS_SVC_PUBLISH,
                          cast[uint64]("auditprobe"), 0, 0, 0, 0, 0)
    fails = fails + check_deny("svc_publish", rc3)

    # 4. SYS_SET_REALTIME: a0 = epoch seconds.
    rc4: int64 = syscall6(SYS_SET_REALTIME,
                          1700000000, 0, 0, 0, 0, 0)
    fails = fails + check_deny("set_realtime", rc4)

    # 5. SYS_REBOOT: valid magics, cmd=HALT. The hostowner gate fires
    # AFTER the magic check (so a NOBODY caller with valid magics
    # surfaces hostowner-required, not bad-magic). power_action never
    # runs — safe.
    rc5: int64 = syscall6(SYS_REBOOT,
                          LINUX_REBOOT_MAGIC1,
                          LINUX_REBOOT_MAGIC2,
                          LINUX_REBOOT_CMD_HALT,
                          0, 0, 0)
    fails = fails + check_deny("reboot", rc5)

    if fails != 0:
        write_str(1, "[hostowner_reach] FAIL: ")
        write_dec(1, cast[int64](fails))
        write_str(1, " op(s) did not route through _syscall_require_hostowner\n")
        return 4

    write_str(1, "[hostowner_reach] PASS\n")
    return 0

# @unsafe relaxes the affine move-check for the whole function body: this reuses
# `h` after moving it into consume(), which would normally be a use-after-move
# COMPILE ERROR — but @unsafe suppresses the check (the escape hatch), so it
# compiles. Since Own[T] is byte-identical to T, `h` is an ordinary int32 local
# holding 1, so consume(h)=1 (discarded) and h + 2 = 3.
def consume(h: Own[int32]) -> int32:
    return h

@unsafe
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    h: Own[int32] = 1
    x: int32 = consume(h)
    return h + 2

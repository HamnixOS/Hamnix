# A correct single-move program. `h` is an own handle; it is moved exactly once
# into consume(), which returns its payload. Compiles cleanly and runs -> 42.
def make() -> int32:
    return 42

def consume(h: Own[int32]) -> int32:
    return h

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    h: Own[int32] = make()
    return consume(h)

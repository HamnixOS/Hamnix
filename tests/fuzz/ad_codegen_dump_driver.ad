# tests/fuzz/ad_codegen_dump_driver.ad
#
# HOST-side dump driver for the self-hosted Adder backend (codegen.ad).
#
# This driver runs the codegen.ad pipeline (lexer.ad -> parser.ad ->
# codegen.ad) on a source file given on argv, and DUMPS the raw machine
# code bytes + global data bytes + layout metadata to stdout in a simple
# machine-readable text manifest. It does NOT call elf_emit.ad (that emits
# a Hamnix elf32-i386 wrapper with Hamnix syscall conventions). Instead the
# HOST python wrapper (tests/fuzz/ad_codegen_host.py) consumes this manifest
# and builds a REAL x86_64-linux ELF around the raw bytes, with a Linux
# (exit_group = 60) _start stub, so codegen.ad's output can be run + checked
# natively on the host with NO QEMU.
#
# It is compiled to the HOST x86_64-linux target (so the driver ITSELF runs
# natively on the host):
#   python3 -m compiler.adder compile --target=x86_64-linux \
#       tests/fuzz/ad_codegen_dump_driver.ad -o build/.../ad_codegen_dump
#
# Manifest format (line-oriented, NUL-free, lowercase hex):
#   AC_DUMP_BEGIN
#   STATUS ok                 (or "STATUS cgfail reason=<R> line=<L> kind=<K>"
#                              or "STATUS parsefail line=<L>"
#                              or "STATUS readfail")
#   CODE_CAP <decimal>        # == DATA_BASE
#   ENTRY_OFF <decimal>       # cg_entry_off
#   CODE_LEN <decimal>
#   GDATA_LEN <decimal>
#   BSS_LEN <decimal>
#   FN_COUNT <decimal>
#   CODEHEX                   # followed by hex lines, then ENDHEX
#   <hex...>
#   ENDHEX
#   GDATAHEX
#   <hex...>
#   ENDHEX
#   AC_DUMP_END
# On a parse/codegen error STATUS is the failure line and no hex follows.

from compiler.lexer import (
    lex_init,
    lex_tokenize,
    tok_count,
)

from compiler.parser import (
    parser_init,
    parse_program,
    p_err,
    p_err_line,
)

from compiler.codegen import (
    cg_init,
    cg_err,
    cg_err_reason,
    cg_err_line,
    cg_err_kind,
    code,
    code_len,
    gdata,
    gdata_len,
    bss_len,
    gen_program_with_globals,
    fn_count,
    cg_entry_off,
    CODE_CAP,
    DATA_BASE,
    ir_scratch_hits,
    ir_scratch_misses,
    ir_scratch_borrows,
    sr_enable,
    sr_reset_stats,
    opt_strengthred_count,
    isel_enable,
    isel_reset_stats,
    opt_isel_count,
    opt_aluload_count,
    opt_storeelim_count,
    opt_paramhome_count,
    opt_basehoist_count,
    opt_fpsel_count,
    opt_fpmov_count,
    opt_fpcmp_count,
    opt_constif_count,
    opt_idxreg_count,
    cmpjcc_enable,
    cmpjcc_reset_stats,
    cmpjcc_get_count,
)

# Native optimizer (Phase 1). OFF by default; opt_enable() is called ONLY
# when this driver is invoked with --opt. With no --opt the optimizer is
# never entered (opt_run early-returns) and codegen output is byte-identical
# to the pre-opt path.
from compiler.opt import (
    opt_enable,
    opt_run,
    opt_fold_count,
    opt_ffold_count,
    opt_cse_count,
    opt_loadcse_count,
    opt_licm_count,
    opt_dce_count,
    opt_constbranch_count,
    opt_copyprop_count,
    opt_ivsr_count,
)

# Phase-5 IR-CONSUMING emit path. ir_emit_enable() is called ONLY under --opt, so
# codegen emits pure signedness-invariant arithmetic subtrees by walking the IR
# tree (with on-the-IR const folding) instead of the AST. The driver reports how
# many subtrees went through the IR emitter (vs the AST fallback) and how many
# constant subtrees the IR emitter folded, so the fuzzer can assert the IR path
# actually fires. OFF by default -> codegen output byte-identical to the pre-IR
# path.
from compiler.ir import (
    ir_emit_enable,
    ir_emit_reset_stats,
    ir_emit_count,
    ir_emit_fold_count,
    ir_emit_fallback_count,
    ir_emit_reassoc_count,
    ir_emit_float_count,
    ir_destsel_count,
    ir_accsel_count,
    ir_idxstore_count,
    ir_idxsel_count,
    ir_callarg_count,
    ir_spineleaf_count,
)

# Phase-4 GROUNDWORK: whole-function CFG + liveness + structural validator.
# ANALYSIS ONLY — never mutates the AST, never affects codegen. Reached ONLY in
# --dump-cfg mode (below). With no --dump-cfg this import is inert: cfg_run_program
# is never called and codegen output is byte-identical to the pre-opt path.
from compiler.cfg import (
    cfg_run_program,
    cfg_stat_funcs,
    cfg_stat_skipped,
    cfg_stat_blocks,
    cfg_stat_edges,
    cfg_stat_insts,
    cfg_stat_fail,
    cfg_stat_fail_fn,
    cfg_stat_ranges,
    cfg_stat_range_len,
    cfg_stat_range_max,
    cfg_stat_locals,
    cfg_stat_promotable,
    cfg_stat_clobberable,
)

# Phase-4 linear-scan register allocator. ra_enable() is called ONLY under --opt
# (so codegen reads/writes promoted values through callee-saved registers). The
# --dump-regalloc lane runs the allocator over every function and reports
# allocation stats WITHOUT emitting code (pure analysis), like --dump-cfg.
from compiler.regalloc import (
    ra_enable,
    ra_run_program,
    ra_prog_funcs,
    ra_prog_skipped,
    ra_prog_promotable,
    ra_prog_inreg,
    ra_prog_spilled,
    ra_prog_regs_used,
    ra_prog_max_regs,
    ra_prog_callcross,
)

# Linux open(2): a0=path a1=flags a2=mode. O_RDONLY = 0.
extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

CC_SRC_CAP: uint32 = 393216
cc_src: Array[393216, uint8]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def put_u32(v: uint32):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


def hex_digit(v: uint32) -> uint32:
    if v < 10:
        return v + 48          # '0'..'9'
    return v + 87              # 'a'..'f'


# Dump buf[0..n) as one continuous lowercase-hex stream, wrapped at 64 hex
# chars (32 bytes) per line.
def dump_hex(buf: Ptr[uint8], n: uint32):
    line: Array[80, uint8]
    col: uint32 = 0
    i: uint32 = 0
    while i < n:
        b: uint32 = cast[uint32](buf[i])
        line[col] = cast[uint8](hex_digit((b >> 4) & 15))
        col = col + 1
        line[col] = cast[uint8](hex_digit(b & 15))
        col = col + 1
        if col >= 64:
            line[col] = 10
            sys_write(1, &line[0], cast[uint64](col + 1))
            col = 0
        i = i + 1
    if col > 0:
        line[col] = 10
        sys_write(1, &line[0], cast[uint64](col + 1))


def read_source(path: Ptr[char]) -> uint32:
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        return 0
    total: uint32 = 0
    while total < CC_SRC_CAP:
        n: int64 = sys_read(fd,
                            cast[Ptr[uint8]](cast[uint64](&cc_src[0]) +
                                             cast[uint64](total)),
                            cast[uint64](CC_SRC_CAP - total))
        if n <= 0:
            break
        total = total + cast[uint32](n)
    sys_close(fd)
    if total < CC_SRC_CAP:
        cc_src[total] = 0
    return total


# True iff the NUL-terminated C string `s` equals the literal "--opt".
def is_opt_flag(s: Ptr[uint8]) -> uint32:
    if s[0] != 45:   # '-'
        return 0
    if s[1] != 45:   # '-'
        return 0
    if s[2] != 111:  # 'o'
        return 0
    if s[3] != 112:  # 'p'
        return 0
    if s[4] != 116:  # 't'
        return 0
    if s[5] != 0:
        return 0
    return 1


# True iff the NUL-terminated C string `s` equals the literal "--dump-cfg".
def is_cfg_flag(s: Ptr[uint8]) -> uint32:
    cfgname: Array[12, uint8]
    cfgname[0] = 45    # '-'
    cfgname[1] = 45    # '-'
    cfgname[2] = 100   # 'd'
    cfgname[3] = 117   # 'u'
    cfgname[4] = 109   # 'm'
    cfgname[5] = 112   # 'p'
    cfgname[6] = 45    # '-'
    cfgname[7] = 99    # 'c'
    cfgname[8] = 102   # 'f'
    cfgname[9] = 103   # 'g'
    cfgname[10] = 0
    i: uint32 = 0
    while i < 11:
        if s[i] != cfgname[i]:
            return 0
        if cfgname[i] == 0:
            return 1
        i = i + 1
    return 1


# True iff the NUL-terminated C string `s` equals the literal "--dump-regalloc".
def is_ra_flag(s: Ptr[uint8]) -> uint32:
    raname: Array[20, uint8]
    raname[0] = 45     # '-'
    raname[1] = 45     # '-'
    raname[2] = 100    # 'd'
    raname[3] = 117    # 'u'
    raname[4] = 109    # 'm'
    raname[5] = 112    # 'p'
    raname[6] = 45     # '-'
    raname[7] = 114    # 'r'
    raname[8] = 101    # 'e'
    raname[9] = 103    # 'g'
    raname[10] = 97    # 'a'
    raname[11] = 108   # 'l'
    raname[12] = 108   # 'l'
    raname[13] = 111   # 'o'
    raname[14] = 99    # 'c'
    raname[15] = 0
    i: uint32 = 0
    while i < 16:
        if s[i] != raname[i]:
            return 0
        if raname[i] == 0:
            return 1
        i = i + 1
    return 1


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    emit("AC_DUMP_BEGIN\n")

    if argc < 2:
        emit("STATUS readfail\n")
        emit("AC_DUMP_END\n")
        sys_exit(2)

    # Scan argv for the opt-in --opt flag (the source path is the first
    # non-flag argument). Default OFF: with no --opt the optimizer stays
    # disabled and codegen output is byte-identical to the pre-opt path.
    in_path: Ptr[char] = cast[Ptr[char]](argv[1])
    want_opt: uint32 = 0
    want_cfg: uint32 = 0
    want_ra: uint32 = 0
    ai: int32 = 1
    while ai < argc:
        a: Ptr[uint8] = cast[Ptr[uint8]](argv[ai])
        if is_opt_flag(a) != 0:
            want_opt = 1
        elif is_cfg_flag(a) != 0:
            want_cfg = 1
        elif is_ra_flag(a) != 0:
            want_ra = 1
        else:
            in_path = cast[Ptr[char]](argv[ai])
        ai = ai + 1
    if want_opt != 0:
        opt_enable()
        # --opt arms the register allocator: codegen reads/writes promoted scalar
        # locals through callee-saved registers. (--dump-regalloc below reports
        # the allocation without emitting code; it arms ra independently.)
        ra_enable()
        # --opt also arms the Phase-5 IR-consuming emit path: codegen emits pure
        # signedness-invariant arithmetic subtrees by walking the IR tree (with
        # on-the-IR const folding) instead of the AST.
        ir_emit_enable()
        ir_emit_reset_stats()
        # --opt also arms div/mod-by-constant strength reduction (reciprocal
        # multiply / shift instead of idiv). OFF by default -> byte-identical.
        sr_enable()
        sr_reset_stats()
        # --opt also arms instruction selection (Phase 3): scaled-index `lea`
        # for array/pointer element-address arithmetic. OFF by default ->
        # byte-identical.
        isel_enable()
        isel_reset_stats()
        # --opt also arms the cmp+jcc branch-condition lever: a comparison that
        # feeds a conditional branch emits cmp; jcc instead of materializing a
        # 0/1 boolean and re-testing it. OFF by default -> byte-identical.
        cmpjcc_enable()
        cmpjcc_reset_stats()

    n: uint32 = read_source(in_path)
    if n == 0:
        emit("STATUS readfail\n")
        emit("AC_DUMP_END\n")
        sys_exit(3)

    lex_init(&cc_src[0], n)
    lex_tokenize()

    parser_init()
    prog: uint32 = parse_program()
    if p_err != 0:
        emit("STATUS parsefail line=")
        put_u32(p_err_line)
        emit("\n")
        emit("AC_DUMP_END\n")
        # parse-fail is NOT a hard process error (exit 0): the host treats
        # it as "codegen.ad rejected this program" (unsupported), not a
        # miscompile.
        return 0

    # Phase-4 register-allocation lane (--dump-regalloc): run linear scan over
    # every function and report the allocation stats WITHOUT emitting code (pure
    # analysis, like --dump-cfg). Always arms the allocator for the report.
    if want_ra != 0:
        ra_enable()
        ra_run_program(prog)
        emit("RA_FUNCS ")
        put_u32(ra_prog_funcs)
        emit("\n")
        emit("RA_SKIPPED ")
        put_u32(ra_prog_skipped)
        emit("\n")
        emit("RA_PROMOTABLE ")
        put_u32(ra_prog_promotable)
        emit("\n")
        emit("RA_INREG ")
        put_u32(ra_prog_inreg)
        emit("\n")
        emit("RA_SPILLED ")
        put_u32(ra_prog_spilled)
        emit("\n")
        emit("RA_REGS_USED ")
        put_u32(ra_prog_regs_used)
        emit("\n")
        emit("RA_MAX_REGS ")
        put_u32(ra_prog_max_regs)
        emit("\n")
        emit("RA_CALLCROSS ")
        put_u32(ra_prog_callcross)
        emit("\n")
        emit("STATUS raok\n")
        emit("AC_DUMP_END\n")
        return 0

    # Phase-4 GROUNDWORK CFG lane (--dump-cfg): build the whole-function CFG +
    # liveness for every function and assert the structural invariants, emitting
    # a CFG report INSTEAD of the codegen dump. This path NEVER calls opt_run or
    # codegen, so it cannot perturb codegen output. It is a pure-analysis self-
    # check over the parsed AST (cfg.ad never mutates the AST).
    if want_cfg != 0:
        cfg_run_program(prog)
        emit("CFG_FUNCS ")
        put_u32(cfg_stat_funcs)
        emit("\n")
        emit("CFG_SKIPPED ")
        put_u32(cfg_stat_skipped)
        emit("\n")
        emit("CFG_BLOCKS ")
        put_u32(cfg_stat_blocks)
        emit("\n")
        emit("CFG_EDGES ")
        put_u32(cfg_stat_edges)
        emit("\n")
        emit("CFG_INSTS ")
        put_u32(cfg_stat_insts)
        emit("\n")
        # Phase-4 PREREQ stats: value-level live ranges + alias/may-clobber.
        emit("CFG_RANGES ")
        put_u32(cfg_stat_ranges)
        emit("\n")
        emit("CFG_RANGE_LEN ")
        put_u32(cfg_stat_range_len)
        emit("\n")
        emit("CFG_RANGE_MAX ")
        put_u32(cfg_stat_range_max)
        emit("\n")
        emit("CFG_LOCALS ")
        put_u32(cfg_stat_locals)
        emit("\n")
        emit("CFG_PROMOTABLE ")
        put_u32(cfg_stat_promotable)
        emit("\n")
        emit("CFG_CLOBBERABLE ")
        put_u32(cfg_stat_clobberable)
        emit("\n")
        if cfg_stat_fail != 0:
            emit("STATUS cfgfail code=")
            put_u32(cfg_stat_fail)
            emit(" fn=")
            put_u32(cfg_stat_fail_fn)
            emit("\n")
        else:
            emit("STATUS cfgok\n")
        emit("AC_DUMP_END\n")
        return 0

    # Native optimizer (Phase 1): opt_run early-returns unless --opt enabled
    # opt above. When enabled it folds constant integer subtrees in the AST
    # in place BEFORE codegen walks it; when disabled this is a no-op and the
    # AST reaches codegen exactly as parsed.
    opt_run(prog)

    cg_init()
    start: uint32 = gen_program_with_globals(prog)
    if cg_err != 0:
        emit("STATUS cgfail reason=")
        put_u32(cg_err_reason)
        emit(" line=")
        put_u32(cg_err_line())
        emit(" kind=")
        put_u32(cg_err_kind())
        emit("\n")
        emit("AC_DUMP_END\n")
        return 0
    if fn_count == 0:
        emit("STATUS cgfail reason=99 line=0 kind=0\n")
        emit("AC_DUMP_END\n")
        return 0

    emit("STATUS ok\n")
    emit("FOLDS ")
    put_u32(opt_fold_count)
    emit("\n")
    emit("FFOLD ")
    put_u32(opt_ffold_count)
    emit("\n")
    emit("CSE ")
    put_u32(opt_cse_count)
    emit("\n")
    emit("LOADCSE ")
    put_u32(opt_loadcse_count)
    emit("\n")
    emit("LICM ")
    put_u32(opt_licm_count)
    emit("\n")
    emit("DCE ")
    put_u32(opt_dce_count)
    emit("\n")
    emit("CONSTBRANCH ")
    put_u32(opt_constbranch_count)
    emit("\n")
    emit("COPYPROP ")
    put_u32(opt_copyprop_count)
    emit("\n")
    emit("IREMIT ")
    put_u32(ir_emit_count)
    emit("\n")
    emit("IRFOLD ")
    put_u32(ir_emit_fold_count)
    emit("\n")
    emit("IRFALLBACK ")
    put_u32(ir_emit_fallback_count)
    emit("\n")
    emit("IRREASSOC ")
    put_u32(ir_emit_reassoc_count)
    emit("\n")
    # IREMITFLOAT = float-typed ND_BINARY roots lowered through the SSE float IR
    # path (subset of IREMIT). Lets the float-coverage corpus assert floats now go
    # THROUGH the IR instead of the AST fallback.
    emit("IREMITFLOAT ")
    put_u32(ir_emit_float_count)
    emit("\n")
    # DESTSEL = scalar `name = pure-arith-binop` assignments lowered through the
    # P1 destination-driven selector: the RHS tree computed DIRECTLY into the
    # register-promoted home (no %rax round-trip, no shadow store). Subset of
    # IREMIT. Byte-inert OFF (DESTSEL==0 with --opt off). Lets the corpus assert
    # the dest-passing path fires.
    emit("DESTSEL ")
    put_u32(ir_destsel_count)
    emit("\n")
    # ACCSEL = augmented accumulator assignments (`s OP= <pure expr>`, OP +,-,*)
    # routed into the promoted register home (P1 Phase 3) — `op <value>, %home`
    # with the accumulator resident (no slot reload / %rax round-trip). Byte-inert
    # OFF. IDXSTORE = indexed stores `arr[i] = <pure-arith binop>` whose RHS is
    # computed dest-driven into a held register before the store. Both let the
    # corpus assert the statement-glue store routing fires AND is byte-inert OFF.
    emit("ACCSEL ")
    put_u32(ir_accsel_count)
    emit("\n")
    emit("IDXSTORE ")
    put_u32(ir_idxstore_count)
    emit("\n")
    # IDXSEL = array-index expressions `arr[<pure-arith index>]` whose index sum is
    # computed DIRECTLY into %rcx through the destination-driven selector (scratch-
    # free, no value-at-a-time push/pop) — the P1 Phase-2 index-address plumbing
    # win (matmul `A[i*N+k]`). Byte-inert OFF (IDXSEL==0 with --opt off).
    emit("IDXSEL ")
    put_u32(ir_idxsel_count)
    emit("\n")
    # CALLARG = direct calls whose register arguments were each computed DIRECTLY
    # into their ABI argument register by the P1 dest-driven selector (no const-
    # into-scratch, no value push/pop) — the fib recursion-arg win. Byte-inert OFF.
    emit("CALLARG ")
    put_u32(ir_callarg_count)
    emit("\n")
    emit("SPINELEAF ")
    put_u32(ir_spineleaf_count)
    emit("\n")
    # IR scratch-register pool: IRSCRATCH = binop nodes whose right operand was
    # held in a callee-saved scratch register (each = one push/pop PAIR of stack
    # traffic eliminated vs the old IR-emit path); IRSCRATCHMISS = nodes that fell
    # back to push/pop because the scratch pool was exhausted by nesting pressure.
    emit("IRSCRATCH ")
    put_u32(ir_scratch_hits)
    emit("\n")
    emit("IRSCRATCHMISS ")
    put_u32(ir_scratch_misses)
    emit("\n")
    # IRBORROW = scratches satisfied by BORROWING a callee-saved register that
    # regalloc had promoted a local into, where that local was DEAD at the current
    # program point (so the register held no live value). This is the register-
    # heavy win: with >=5 promoted locals the plain availability pool is empty, so
    # these binops would otherwise all fall back to push/pop. Subset of IRSCRATCH.
    emit("IRBORROW ")
    put_u32(ir_scratch_borrows)
    emit("\n")
    # STRENGTHRED = div/mod-by-constant ops strength-reduced to reciprocal
    # multiply / shift (each = one idiv eliminated). Lets the fuzzer assert the
    # pass actually fires on the generated div/mod-by-constant corpus.
    emit("STRENGTHRED ")
    put_u32(opt_strengthred_count)
    emit("\n")
    # ISEL = array/pointer element-address computations lowered to a scaled-index
    # `lea` (each folds a scale-shift + add, and for a local array also the
    # base-lea, into one instruction). Lets the fuzzer/bench assert the pass fires.
    emit("ISEL ")
    put_u32(opt_isel_count)
    emit("\n")
    # ALULOAD = binop nodes whose 8-byte integer array-element RIGHT operand was
    # sourced in-place via `op (%rcx),%rax` (the alu-load memory-source fold),
    # eliding a separate sized load + reg-reg combine. Lets the fuzzer/bench/guard
    # assert the fold fires on the generated memory-operand-ALU corpus.
    emit("ALULOAD ")
    put_u32(opt_aluload_count)
    emit("\n")
    # BASEHOIST = loop-invariant GLOBAL-ARRAY bases materialised ONCE into a held
    # callee-saved register (P1 Phase 2), instead of `lea g(%rip)` per iteration.
    # Each per-access address then folds to a single scaled-index lea off that
    # register. Byte-inert OFF (BASEHOIST==0 with --opt off). Lets the corpus/
    # guard assert the base-residency lever fires.
    emit("BASEHOIST ")
    put_u32(opt_basehoist_count)
    emit("\n")
    # STOREELIM = fully register-promoted plain scalars whose shadow stack store
    # was DROPPED (the register is the sole home; no slot-bypass read). Lets the
    # fuzzer/guard assert the store-through-elimination lever fired AND is byte-
    # inert OFF (STOREELIM==0 with --opt off).
    emit("STOREELIM ")
    put_u32(opt_storeelim_count)
    emit("\n")
    # PARAMHOME = register-promoted, store-eliminable, plain-scalar PARAMETERS whose
    # DEAD entry home spill (`mov %argreg,slot`) was dropped and whose init reload
    # was replaced by a direct `mov %argreg,%reg`. Lets the fuzzer/guard assert the
    # param-home spill-elision lever fired AND is byte-inert OFF (PARAMHOME==0 with
    # --opt off).
    emit("PARAMHOME ")
    put_u32(opt_paramhome_count)
    emit("\n")
    # FPSEL = scalar `name = <float64 arith tree>` assignments lowered through the
    # float-SSE dest-driven selector: the RHS computed across live xmm registers
    # (xmm dest + xmm scratches) with no %rax/stack round-trip per op. Byte-inert
    # OFF (FPSEL==0 with --opt off). Lets the corpus/guard assert the lever fires.
    emit("FPSEL ")
    put_u32(opt_fpsel_count)
    emit("\n")
    # FPMOV = float64-local leaf reads / result stores routed DIRECTLY between an
    # xmm and the local's home (movsd slot<->xmm, or movq gpr<->xmm), skipping the
    # seed's %rax GPR transit. Byte-inert OFF (FPMOV==0 with --opt off).
    emit("FPMOV ")
    put_u32(opt_fpmov_count)
    emit("\n")
    # FPCMP = float64 GT/GTE compares feeding a conditional branch, lowered to
    # operands-into-xmm + ucomisd + a single NaN-correct jcc (no boolean
    # materialize, no operand %rax round-trip). Byte-inert OFF (FPCMP==0 off).
    emit("FPCMP ")
    put_u32(opt_fpcmp_count)
    emit("\n")
    # CONSTIF = ND_IF statements whose primary condition is a provably-true
    # constant literal (`if 1:` — the shape the const-branch pass leaves), emitted
    # as the then-body ALONE with NO condition materialize / test / conditional
    # branch. Byte-inert OFF (CONSTIF==0 with --opt off). Lets the corpus/guard
    # assert the fold fires.
    emit("CONSTIF ")
    put_u32(opt_constif_count)
    emit("\n")
    # IDXREG = `arr[i]` element-address leas whose index is a bare register-
    # promoted full-width-8 local routed STRAIGHT into the SIB index slot
    # (`lea (base,%ireg,s),%rax`), eliminating the `mov %ireg,%rax; mov %rax,%rcx`
    # copy pair the legacy index-into-%rcx path emits. Byte-inert OFF (IDXREG==0
    # with --opt off). Lets the corpus/guard assert the coalesce fires.
    emit("IDXREG ")
    put_u32(opt_idxreg_count)
    emit("\n")
    # CMPJCC = comparisons feeding a conditional branch (if/while/for/do-while
    # condition, short-circuit &&/|| edge) lowered to a direct cmp; jcc instead
    # of materializing a 0/1 boolean (cmp; setcc; movzx) and re-testing it
    # (test; jz). Each = ~6 instructions saved per branch. Lets the fuzzer/guard
    # assert the lever fires AND is byte-inert OFF (CMPJCC==0 with --opt off).
    emit("CMPJCC ")
    put_u32(cmpjcc_get_count())
    emit("\n")
    # IVSR = affine array-index expressions over a counted loop's induction
    # variable strength-reduced to a pre-header-seeded running variable advanced
    # by a constant per iteration (each = one per-iteration index multiply
    # eliminated, shared across value-equal indices). Lets the fuzzer/bench/guard
    # assert the pass fires.
    emit("IVSR ")
    put_u32(opt_ivsr_count)
    emit("\n")
    emit("CODE_CAP ")
    put_u32(CODE_CAP)
    emit("\n")
    emit("DATA_BASE ")
    put_u32(DATA_BASE)
    emit("\n")
    emit("ENTRY_OFF ")
    put_u32(cg_entry_off)
    emit("\n")
    emit("CODE_LEN ")
    put_u32(code_len)
    emit("\n")
    emit("GDATA_LEN ")
    put_u32(gdata_len)
    emit("\n")
    emit("BSS_LEN ")
    put_u32(bss_len)
    emit("\n")
    emit("FN_COUNT ")
    put_u32(fn_count)
    emit("\n")

    emit("CODEHEX\n")
    dump_hex(&code[0], code_len)
    emit("ENDHEX\n")

    emit("GDATAHEX\n")
    dump_hex(&gdata[0], gdata_len)
    emit("ENDHEX\n")

    emit("AC_DUMP_END\n")
    return 0

# tests/fuzz/regress_signed_shift.ad
#
# Revert-sensitive behavioural regression for the SIGNED right-shift (`>>`)
# codegen bug in BOTH backends (compiler/codegen_x86.py seed and the
# self-hosted compiler/codegen.ad).
#
# THE BUG: `>>` chose the arithmetic (sarq) vs logical (shrq) machine op from
# BOTH operands' signedness (`_binop_signed_op` / `binop_use_signed`). But a
# shift's signedness is a property of the shifted VALUE (the LEFT operand)
# ALONE — the COUNT's type is irrelevant in C. So a signed value shifted by an
# UNSIGNED count, or a signed value reached through an array element / integer
# sub-expression the type resolver reported as "unknown", wrongly emitted the
# LOGICAL shrq — silently ZERO-filling instead of SIGN-filling and corrupting
# every negative intermediate (this broke the ed25519 field/scalar reductions).
#
# THE CHECK: for many counts, right-shift the SAME negative int64 value through
# every operand form that used to miscompile — array element, integer
# sub-expression, function parameter, and a local with a uint64 count — and
# compare each against a REFERENCE arithmetic shift (`arith_ref`) that used the
# already-correct plain-local-operand + signed-count form. With the fix every
# form sign-extends and equals the reference, so `main` returns 0. REVERT
# either backend's fix and the fragile forms zero-fill instead, diverge from
# the reference, and `main` returns 1 — so the host gate (which asserts BOTH
# the seed and the .ad backend exit 0) fails. It does NOT rely on seed==native
# (both shared the bug); it pins the actual sign-extending RUNTIME behaviour.

garr: Array[4, int64]


# Reference arithmetic right shift: a plain signed LOCAL value shifted by a
# signed LOCAL count. This form emitted sarq even BEFORE the fix, so it is the
# trusted oracle the fragile forms are compared against.
def arith_ref(x: int64, n: int64) -> int64:
    v: int64 = x
    s: int64 = n
    return v >> s


# Function PARAMETER operand, UNSIGNED count.
def shr_param_ucount(x: int64, n: uint64) -> int64:
    return x >> n


def check() -> uint64:
    bad: uint64 = cast[uint64](0)
    base: int64 = 0 - 6023456789012345678       # a large NEGATIVE int64
    garr[2] = base
    a0: int64 = base
    b0: int64 = 0
    cu: uint64 = cast[uint64](1)
    while cu < cast[uint64](63):
        sc: int64 = cast[int64](cu)
        ref: uint64 = cast[uint64](arith_ref(base, sc))

        # (b) ARRAY ELEMENT operand, unsigned count.
        rb: uint64 = cast[uint64](garr[2] >> cu)
        if rb != ref:
            bad = cast[uint64](1)

        # (c) integer SUB-EXPRESSION operand, unsigned count.
        rc: uint64 = cast[uint64]((a0 - b0) >> cu)
        if rc != ref:
            bad = cast[uint64](1)

        # (d) function PARAMETER operand, unsigned count.
        rd: uint64 = cast[uint64](shr_param_ucount(base, cu))
        if rd != ref:
            bad = cast[uint64](1)

        # (e) plain LOCAL operand with a UINT64 count.
        xe: int64 = base
        re: uint64 = cast[uint64](xe >> cu)
        if re != ref:
            bad = cast[uint64](1)

        cu = cu + cast[uint64](1)
    return bad


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # 0 == every signed-operand form sign-extended (fix present);
    # 1 == some form zero-filled (the bug is back).
    return cast[int32](check())

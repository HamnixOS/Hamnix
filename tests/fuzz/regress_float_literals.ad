# tests/fuzz/regress_float_literals.ad
#
# Regression fixture for the self-hosted (adder/compiler) FLOAT-LITERAL
# miscompiles fixed in the FPU/js-gate track. Each block folds a KNOWN integer
# into a uint64 accumulator that is printed once; a re-introduction of any bug
# flips the printed value. The harness (scripts/fuzz_adder_diff.sh) runs this
# through codegen.ad ON THE HOST and asserts the exact stdout+exit.
#
#   Bug 1 (float-literal DIVISION as integer div): the lexer discarded a
#     number's float-ness and the parser built ND_INT_LIT, so `6.0 / 4.0`
#     compiled to an INTEGER `div` (and `0.0/0.0` -> #DE) instead of `divsd`.
#     Test: (6.0/4.0)*4.0 == 6.0  (fix)  vs  (6/4)*4 == 4  (bug).
#   Bug 2 (fractional literal TRUNCATED): a float literal was materialized via
#     cvtsi2sd of its integer part only, so `0.5` became `0.0`.
#     Test: 0.5 * 10.0 == 5.0  (fix)  vs  0 * 10 == 0  (bug).
#   Bug 3 (exponent literal TRUNCATED): likewise `1.5e1` (=15.0) lost its
#     fraction+exponent and became the integer part 1.
#     Test: 1.5e1 == 15.0  (fix)  vs  1  (bug).
#   Probe (the brief's canary): 2.0*3.0+1.0 == 7.0 — must stay 7 under
#     preemption once the kernel FPU context-switch save/restore landed; here it
#     pins the compile-time value.
#
# Each float result is truncated to uint64 (cvttsd2si) and placed at a distinct
# decimal position so a wrong sub-result is unambiguous:
#   acc = t1*1000000 + t2*10000 + t3*100 + t4
# FIX value: 6*1000000 + 5*10000 + 15*100 + 7 = 6051507  (exit = 6051507 & 255)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_ch:   Array[1, uint8]
_digs: Array[32, uint8]


def _putc(c: uint8) -> int32:
    _ch[0] = c
    sys_write(cast[int32](1), &_ch[0], cast[uint64](1))
    return 0


def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        _digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        _digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        _putc(_digs[cast[int64](k)])
        k = k - 1
    _putc(cast[uint8](10))
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: uint64 = cast[uint64](0)

    # Bug 1: float-literal division must be divsd (1.5), not integer div (1).
    t1: uint64 = cast[uint64]((6.0 / 4.0) * 4.0)          # 6 (fix) / 4 (bug)
    acc = acc + t1 * cast[uint64](1000000)

    # Bug 2: fractional literal must not truncate to 0.
    t2: uint64 = cast[uint64](0.5 * 10.0)                 # 5 (fix) / 0 (bug)
    acc = acc + t2 * cast[uint64](10000)

    # Bug 3: exponent literal must carry its value.
    t3: uint64 = cast[uint64](1.5e1)                      # 15 (fix) / 1 (bug)
    acc = acc + t3 * cast[uint64](100)

    # Probe: 2.0*3.0+1.0 == 7 (the js `2.0*3.0+1.0` canary).
    t4: uint64 = cast[uint64](2.0 * 3.0 + 1.0)            # 7
    acc = acc + t4

    print_u64(acc)
    return cast[int32](acc & cast[uint64](255))

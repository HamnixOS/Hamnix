# tests/fuzz/regress_unsafe_liveness.ad
#
# Regression for the --opt register-allocator miscompile that BLANKED THE
# DESKTOP: the CFG's opaque-statement fallback (cfg.ad cfg_lower_stmt) treated an
# `unsafe:` block as a single opaque instruction and scanned it with
# cfg_scan_uses, which follows nd_next only of a node's a/b CHILDREN — never
# nd_next of the statement node itself. So it saw ONLY the FIRST body statement
# of the unsafe block and MISSED every use in statements 2..N. An integer local
# whose last real use lived in a later unsafe statement had its live range
# truncated to its def; the linear scan then handed its callee-saved register to
# a SECOND local it believed disjoint. Two genuinely-overlapping locals shared
# one register and the first value was silently clobbered (with NO clobber
# instruction in the disassembly). `unsafe:` bodies are pervasive in the kernel
# and never emitted by the userspace differential fuzzer, so disasm audits + the
# fuzzer came up clean. FIX: cfg_lower_stmt lowers the `unsafe:` body chain inline
# (it is semantically transparent), recording every def/use at its real point.
#
# This fixture is run through codegen.ad with the native optimizer ON *and* OFF;
# both must print the same correct value. Pre-fix, --opt printed 444 (222+222)
# where --opt-off printed 333 (111+222).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_ch:   Array[1, uint8]
_digs: Array[32, uint8]

gacc: int64

def _putc(c: uint8) -> int32:
    _ch[0] = c
    sys_write(cast[int32](1), &_ch[0], cast[uint64](1))
    return 0

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        _digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        _digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        _putc(_digs[cast[int64](k)])
        k = k - 1
    _putc(cast[uint8](10))
    return 0

# x and y are defined OUTSIDE the unsafe block; their only real uses are in the
# SECOND statement of the unsafe body. Pre-fix the allocator thought x died at
# its def (its use was unscanned) and reused x's register for y.
def repro() -> int64:
    x: int64 = 111
    y: int64 = 222
    unsafe:
        gacc = 0
        gacc = x + y
    return gacc

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    r: int64 = repro()      # must be 333, never 444
    print_u64(cast[uint64](r))
    return cast[int32](r & 255)

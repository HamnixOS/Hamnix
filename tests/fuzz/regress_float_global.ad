# tests/fuzz/regress_float_global.ad
#
# Regression fixture for MODULE-LEVEL float64 GLOBALS WITH AN INITIALIZER —
# `g: float64 = 3.5` at file scope. This form was previously unsupported:
#   * the seed (codegen_x86.py gen_data) raised "must have an integer
#     initializer";
#   * the native (codegen.ad layout_global) silently zero-inited the global to
#     0.0 (const_int_value returned 0 for a float literal -> .bss).
# Both now emit the constant's raw IEEE-754 bit pattern into .data.
#
# The program reads two float globals (a positive and a NEGATED literal),
# does arithmetic, and returns an exit code that is wrong unless the globals
# carry their true initialized values:
#   g_x = 3.5, g_y = -1.25
#   a = g_x * 2.0                 = 7.0  -> 7
#   b = (g_x + g_y) * 4.0         = 9.0  -> 9   (2.25 * 4)
#   exit = (a + b) & 255          = 16
# A re-introduction of the bug (globals come up 0.0) yields exit 0.
#
# Compiled+run via BOTH backends by scripts/test_float_global.sh (x86_64-linux),
# proving seed and native agree on the value.

g_x: float64 = 3.5
g_y: float64 = -1.25


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: uint64 = cast[uint64](g_x * 2.0)
    b: uint64 = cast[uint64]((g_x + g_y) * 4.0)
    return cast[int32]((a + b) & cast[uint64](255))

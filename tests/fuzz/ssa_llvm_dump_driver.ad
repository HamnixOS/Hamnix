# tests/fuzz/ssa_llvm_dump_driver.ad
#
# HOST-side driver for the OPTIONAL LLVM backend spike (ssa_llvm.ad).
#
# Runs lexer.ad -> parser.ad -> ssa.ad -> ssa_llvm.ad on a source file given on
# argv and writes TEXTUAL LLVM IR (.ll) for every function the SSA path accepts
# to stdout. Functions outside the SSA integer subset are reported as `; BAILED`
# comments; a trailing `; ADDER_STAT` comment carries funcs/emitted/bailed.
#
# Compiled to the HOST x86_64-linux target so it runs natively on the host:
#   python3 -m compiler.adder compile --target=x86_64-linux \
#       tests/fuzz/ssa_llvm_dump_driver.ad -o build/bench_llvm/ssa_llvm_dump
#
# The Python wrapper (scripts/_bench_llvm_run.py) pipes stdout to <kernel>.ll and
# compiles it with clang-19 against a tiny C runtime that provides print_u64.

from compiler.lexer import (
    lex_init,
    lex_tokenize,
    strbuf,
)

from compiler.parser import (
    parser_init,
    parse_program,
    p_err,
    p_err_line,
)

from compiler.ssa_llvm import (
    llvm_emit_program,
    llvm_out,
    llvm_out_len,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def sys_open(path: Ptr[char], flags: int32, mode: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

CC_SRC_CAP: uint32 = 393216
cc_src: Array[393216, uint8]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def put_u32(v: uint32):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


def read_source(path: Ptr[char]) -> uint32:
    fd: int32 = sys_open(path, 0, 0)
    if fd < 0:
        return 0
    total: uint32 = 0
    while total < CC_SRC_CAP:
        n: int64 = sys_read(fd,
                            cast[Ptr[uint8]](cast[uint64](&cc_src[0]) +
                                             cast[uint64](total)),
                            cast[uint64](CC_SRC_CAP - total))
        if n <= 0:
            break
        total = total + cast[uint32](n)
    sys_close(fd)
    if total < CC_SRC_CAP:
        cc_src[total] = 0
    return total


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    if argc < 2:
        emit("; readfail (no source path)\n")
        sys_exit(2)

    in_path: Ptr[char] = cast[Ptr[char]](argv[1])
    n: uint32 = read_source(in_path)
    if n == 0:
        emit("; readfail\n")
        sys_exit(3)

    lex_init(&cc_src[0], n)
    lex_tokenize()

    parser_init()
    prog: uint32 = parse_program()
    if p_err != 0:
        emit("; parsefail line=")
        put_u32(p_err_line)
        emit("\n")
        return 0

    llvm_emit_program(prog)
    sys_write(1, &llvm_out[0], cast[uint64](llvm_out_len))
    return 0

# tests/fuzz/regress_param_spill_trunc.ad
#
# Behavioral regression for the sub-8-byte PARAMETER-spill truncation +
# >6-argument stack-spill miscompiles (codegen.ad). These are the same bug
# CLASS as the sub-8-byte LOCAL-store miscompile (regress_local_store_trunc.ad),
# but on the PARAMETER path the prior fix never touched:
#
#   (1) A function's parameter is spilled from its SysV arg register into a
#       frame slot at the prologue. The native `.ad` backend spilled EVERY
#       param with a blind 8-byte `movq` (emit_spill_arg), regardless of the
#       param's declared width, so a sub-8-byte scalar param's slot kept the
#       arg register's upper-byte garbage. The frozen Python seed
#       (codegen_x86.gen_function) spills a sub-8-byte scalar param SIZED
#       (movl/movw/movb). It also failed to size a `float32` param's slot at
#       all (type_signedness==0 skipped the tag), so a float32 param's
#       identifier load was a full `movq` of that garbage.
#
#   (2) A function with MORE THAN 6 parameters: args 7+ arrive on the STACK
#       (at +16(%rbp), +24(%rbp), ...), NOT in r9. The native spill loop
#       spilled r9 into EVERY arg-index >= 5 slot (emit_spill_arg's `else`),
#       so params 6+ read the 6th arg's value (or garbage). The seed loads
#       each stack arg from its +rbp offset and stores it sized.
#
# In the kernel this bug class is what mis-feeds the exec/ELF-load size path
# (fs/vfs.ad, fs/tmpfs.ad), producing the `kmalloc(67108864 = 64 MiB)`
# exceeds-MAX_ORDER failure that drops execve to the rescue shell.
#
# DISCRIMINATOR: g() takes 8 params — six uint64 register args plus a uint32
# (arg 6, STACK) and a uint8 (arg 7, STACK). The buggy backend mis-spills the
# two stack args (and would not have sized the narrow ones); the correct
# backend sums them exactly. The seed (frozen oracle) returns 0xD6 (214); the
# harness asserts the `.ad` backend's output equals the seed's.

def g(a: uint64, b: uint64, c: uint64, d: uint64, e: uint64, f: uint64,
      g7: uint32, h8: uint8) -> uint64:
    return a + b + c + d + e + f + cast[uint64](g7) + cast[uint64](h8)


def narrow(p: uint8, q: uint16, r: uint32) -> uint64:
    # All three sub-8-byte register params: a wide movq spill would leave the
    # upper bytes garbage; the sized identifier load extends from the low bytes,
    # so a correctly-sized spill+load yields the truncated values.
    return cast[uint64](p) + cast[uint64](q) + cast[uint64](r)


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    s: uint64 = g(cast[uint64](1), cast[uint64](2), cast[uint64](4),
                  cast[uint64](8), cast[uint64](16), cast[uint64](32),
                  cast[uint32](64), cast[uint8](72))     # 1+2+4+8+16+32+64+72 = 199
    n: uint64 = narrow(cast[uint8](3), cast[uint16](5), cast[uint32](7))  # 3+5+7 = 15
    # 199 + 15 = 214 (0xD6). Mask to a byte for the process exit code.
    return cast[int32]((s + n) & cast[uint64](255))

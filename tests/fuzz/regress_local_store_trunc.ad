# tests/fuzz/regress_local_store_trunc.ad
#
# Behavioral regression for the sub-8-byte LOCAL-store truncation miscompile
# (codegen.ad). This is the bug that broke the self-hosting cutover: the
# native `.ad` backend stored an assignment into a sub-8-byte scalar LOCAL
# (uint32/uint16/uint8/...) with a blind 8-byte `movq` instead of a sized
# movl/movw/movb. Reading that slot back through a wider alias (`&local` ->
# Ptr[uint64]) then saw the slot's full 8 bytes, NOT the type-truncated
# value the frozen Python seed (codegen_x86._emit_local_store) produces.
#
# In the kernel this manifested as a misread file size in the exec/ELF-load
# path (fs/vfs.ad _ns_blob_tmpfs_load / _ns_blob_partition_load / fs/tmpfs.ad
# tmpfs_read): the bogus size was clamped to _NS_BLOB_MAX (67108864 = 64 MiB)
# and `kmalloc(67108864)` exceeded MAX_ORDER, so `execve('/bin/hamsh')`
# failed -> rescue shell. The whole-image native build booted to PID-1 init
# but could not exec any binary.
#
# DISCRIMINATING construct: a uint8 LOCAL `b` whose 8-byte slot is first
# dirtied with a wide pattern through `&b` aliased as Ptr[uint64], THEN a
# sized `b = cast[uint8](0x42)` store is done. A correct SIZED (movb) store
# writes ONLY byte 0, leaving the upper 7 bytes intact; the buggy blind movq
# store of the (already-truncated) cast result zeroes the upper 7 bytes.
# Reading all 8 bytes back via the uint64 alias then differs:
#   pre-fix  (movq store): full = 0x0000000000000042  -> (full>>24)&0xFF = 0
#   post-fix (movb store): full = 0x1122334455667742  -> (full>>24)&0xFF = 0x55
# The Python seed (frozen oracle) computes 0x55 (85). The harness asserts the
# `.ad` backend's output equals the seed's.

def take(p: Ptr[uint64]) -> uint64:
    return p[0]


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    b: uint8 = 0
    pq: Ptr[uint64] = cast[Ptr[uint64]](cast[uint64](&b))
    pq[0] = cast[uint64](0x1122334455667788)
    b = cast[uint8](0x42)                 # SIZED movb: keeps upper 7 bytes
    full: uint64 = take(pq)
    # exit code = byte at bit 24..31. movb -> 0x55 (85); buggy movq -> 0.
    return cast[int32]((full >> cast[uint64](24)) & cast[uint64](255))

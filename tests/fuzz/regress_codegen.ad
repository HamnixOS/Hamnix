# tests/fuzz/regress_codegen.ad
#
# Regression fixture for x86_64 backend miscompiles found by the compiler
# fuzzer (tests/fuzz/adder_fuzzer.py). Each block exercises one fixed bug and
# folds a known constant into a uint64 accumulator that is printed once. The
# harness (driver in scripts/fuzz_adder.sh / the fuzzer's regression mode)
# asserts the single printed value. A miscompile re-introduction flips it.
#
# Expected printed value is computed below in comments; the test asserts it.
#
#   Bug A (sized scalar-global store/load): storing into a sub-8-byte scalar
#     global emitted a blind `movq` (8 bytes) and loading it emitted a blind
#     `movq` (8 bytes), so a uint32/uint16/uint8 global neither truncated on
#     store nor masked/sign-extended on load.
#   Bug B (narrowing cast truncation): `cast[T](x)` for a sub-8-byte T did NOT
#     truncate %rax to T's width, so cast[uint8](cast[uint16](60396)) kept
#     60396 instead of 236, and cast[uint8](60396) kept 60396.
#   Bug C (signed sub-8-byte global load): a negative int32/int16/int8 scalar
#     global must sign-extend on load (so its uint64/wider use is correct).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_ch:   Array[1, uint8]
_digs: Array[32, uint8]

# Bug A/C: typed scalar globals.
gu32: uint32
gi32: int32
gu16: uint16
gu8:  uint8

def _putc(c: uint8) -> int32:
    _ch[0] = c
    sys_write(cast[int32](1), &_ch[0], cast[uint64](1))
    return 0

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        _digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        _digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        _putc(_digs[cast[int64](k)])
        k = k - 1
    _putc(cast[uint8](10))
    return 0

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: uint64 = cast[uint64](0)

    # --- Bug A: store a wide value into a uint32 global, read it back. ----
    # 328515225789427796 & 0xFFFFFFFF = 2021421140
    gu32 = cast[uint32](cast[uint64](328515225789427796))
    acc = acc + cast[uint64](gu32)                       # + 2021421140

    # --- Bug B: nested narrowing cast (uint16 -> uint8). -----------------
    # cast[uint8](cast[uint16](60396)) = 60396 & 0xFF = 236
    acc = acc + cast[uint64](cast[uint8](cast[uint16](60396)))   # + 236
    # cast[uint8](bare-literal 60396) = 236 as well
    acc = acc + cast[uint64](cast[uint8](60396))                 # + 236

    # --- Bug C: signed negative int32 global must sign-extend on load. ----
    # gi32 = -1000; cast[uint64](gi32) = 0xFFFFFFFFFFFFFC18
    gi32 = cast[int32](0 - 1000)
    acc = acc + cast[uint64](gi32)            # + 18446744073709550616

    # --- Bug A again at uint16 / uint8 widths. ---------------------------
    gu16 = cast[uint16](cast[uint64](0x12345))   # 0x2345 = 9029
    acc = acc + cast[uint64](gu16)               # + 9029
    gu8 = cast[uint8](cast[uint64](0x1FF))       # 0xFF = 255
    acc = acc + cast[uint64](gu8)                # + 255

    # Total (uint64 wrapping):
    #   2021421140 + 236 + 236 + 18446744073709550616 + 9029 + 255
    #   = 18446744075730981512 mod 2^64 = 2021429896
    #   exit code = 2021429896 & 0xFF = 136
    print_u64(acc)
    return cast[int32](acc & cast[uint64](255))

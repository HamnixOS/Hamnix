# tests/fuzz/regress_codegen.ad
#
# Regression fixture for x86_64 backend miscompiles found by the compiler
# fuzzer (tests/fuzz/adder_fuzzer.py). Each block exercises one fixed bug and
# folds a known constant into a uint64 accumulator that is printed once. The
# harness (driver in scripts/fuzz_adder.sh / the fuzzer's regression mode)
# asserts the single printed value. A miscompile re-introduction flips it.
#
# Expected printed value is computed below in comments; the test asserts it.
#
#   Bug A (sized scalar-global store/load): storing into a sub-8-byte scalar
#     global emitted a blind `movq` (8 bytes) and loading it emitted a blind
#     `movq` (8 bytes), so a uint32/uint16/uint8 global neither truncated on
#     store nor masked/sign-extended on load.
#   Bug B (narrowing cast truncation): `cast[T](x)` for a sub-8-byte T did NOT
#     truncate %rax to T's width, so cast[uint8](cast[uint16](60396)) kept
#     60396 instead of 236, and cast[uint8](60396) kept 60396.
#   Bug C (signed sub-8-byte global load): a negative int32/int16/int8 scalar
#     global must sign-extend on load (so its uint64/wider use is correct).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_ch:   Array[1, uint8]
_digs: Array[32, uint8]

# Bug A/C: typed scalar globals.
gu32: uint32
gi32: int32
gu16: uint16
gu8:  uint8

# Bug F: a scalar global with a NEGATIVE-LITERAL INITIALISER. `= -10000`
# parses as ND_UNARY(UNOP_NEG, ND_INT_LIT), NOT a bare ND_INT_LIT, so the
# pre-fix layout_global routed it to the zero-init .bss branch and the global
# came up as 0 at runtime instead of -10000 — a VALUE-LEVEL miscompile invisible
# to the .text objdiff (same load insns; only the .data bytes differ). It broke
# every negative sentinel global in the kernel (P9_NO_MOUNT/NAMEC_FALLTHROUGH =
# -10000), wedging the self-host boot before runlevel 5. The fix const-folds the
# UNOP_NEG so the value lands in .data, mirroring codegen_x86.py gen_data.
# Covers int32 (sentinel-shaped), int64 (8-byte, no sign-extend), and int8.
gneg32: int32 = -10000
gneg64: int64 = -1234567890123
gneg8:  int8  = -5

# Bug D scratch: a byte buffer addressed through cast[Ptr[T]](base)[i].
_scratch: Array[64, uint8]

# Bug E: a struct/class with an array field, indexed member-base `s.buf[i]`.
class _Sink:
    pos:  uint32
    wbuf: Array[8, uint32]
    sbuf: Array[8, int32]

_sink: _Sink

def _putc(c: uint8) -> int32:
    _ch[0] = c
    sys_write(cast[int32](1), &_ch[0], cast[uint64](1))
    return 0

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        _digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        _digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        _putc(_digs[cast[int64](k)])
        k = k - 1
    _putc(cast[uint8](10))
    return 0

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: uint64 = cast[uint64](0)

    # --- Bug A: store a wide value into a uint32 global, read it back. ----
    # 328515225789427796 & 0xFFFFFFFF = 2021421140
    gu32 = cast[uint32](cast[uint64](328515225789427796))
    acc = acc + cast[uint64](gu32)                       # + 2021421140

    # --- Bug B: nested narrowing cast (uint16 -> uint8). -----------------
    # cast[uint8](cast[uint16](60396)) = 60396 & 0xFF = 236
    acc = acc + cast[uint64](cast[uint8](cast[uint16](60396)))   # + 236
    # cast[uint8](bare-literal 60396) = 236 as well
    acc = acc + cast[uint64](cast[uint8](60396))                 # + 236

    # --- Bug C: signed negative int32 global must sign-extend on load. ----
    # gi32 = -1000; cast[uint64](gi32) = 0xFFFFFFFFFFFFFC18
    gi32 = cast[int32](0 - 1000)
    acc = acc + cast[uint64](gi32)            # + 18446744073709550616

    # --- Bug A again at uint16 / uint8 widths. ---------------------------
    gu16 = cast[uint16](cast[uint64](0x12345))   # 0x2345 = 9029
    acc = acc + cast[uint64](gu16)               # + 9029
    gu8 = cast[uint8](cast[uint64](0x1FF))       # 0xFF = 255
    acc = acc + cast[uint64](gu8)                # + 255

    # --- Bug D: cast[Ptr[T]](expr)[i] indexed load/store (cap#4 cutover). --
    # The base of the index is an ND_CAST (arbitrary expression cast to a
    # pointer), not a named array/ptr. gen_index_addr must evaluate the cast
    # to a pointer value, scale i by sizeof(T) from the cast target, and do a
    # T-sized load/store. Both READ and WRITE paths, at uint32/uint8/uint64
    # widths plus a SIGNED int32 (must sign-extend on load).
    sb: uint64 = cast[uint64](&_scratch[0])
    cast[Ptr[uint32]](sb)[0] = cast[uint32](100)      # store 4B at +0
    acc = acc + cast[uint64](cast[Ptr[uint32]](sb)[0])  # load -> 100
    cast[Ptr[uint8]](sb)[7] = cast[uint8](7)          # store 1B at +7
    acc = acc + cast[uint64](cast[Ptr[uint8]](sb)[7])   # load -> 7
    cast[Ptr[uint64]](sb)[2] = cast[uint64](1000000)  # store 8B at +16
    acc = acc + cast[Ptr[uint64]](sb)[2]                # load -> 1000000
    cast[Ptr[int32]](sb)[8] = cast[int32](0 - 3)      # store 4B at +32 (-3)
    acc = acc + cast[uint64](cast[Ptr[int32]](sb)[8])   # signed load -> 0xFFFFFFFFFFFFFFFD
    # Bug D delta = 100 + 7 + 1000000 + 18446744073709551613
    #             = 18446744073710551720 mod 2^64 = 18446744073710551720

    # --- Bug E: member-base indexed load/store `s.buf[i]` (cap#4 cutover). --
    # The index base is a struct MEMBER (an array field), not a named array.
    # gen_index_addr must take &_sink.wbuf, scale i by the field element width,
    # and do a sized load/store. Covers an UNSIGNED uint32 field and a SIGNED
    # int32 field (the latter must sign-extend on load), both R and W.
    _sink.wbuf[1] = cast[uint32](500)               # store 4B field elem
    acc = acc + cast[uint64](_sink.wbuf[1])           # load -> 500
    _sink.sbuf[2] = cast[int32](0 - 7)              # store signed field elem
    acc = acc + cast[uint64](_sink.sbuf[2])           # signed load -> 0xFFFFFFFFFFFFFFF9
    # Bug E delta = 500 + 18446744073709551609 = 18446744073709552109 mod 2^64

    # --- Bug F: negative-LITERAL scalar global initialisers. -------------
    # gneg32 = -10000 (sentinel-shaped), gneg64 = -1234567890123, gneg8 = -5.
    # Each must come up at its declared NEGATIVE value (placed in .data by the
    # const-folded initialiser), NOT 0 (the pre-fix .bss zero). cast[uint64]
    # of each yields its two's-complement bit pattern.
    acc = acc + cast[uint64](gneg32)         # + 18446744073709541616
    acc = acc + cast[uint64](gneg64)         # + 18446742839141661493
    acc = acc + cast[uint64](gneg8)          # + 18446744073709551611

    # Total (uint64 wrapping):
    #   2021421140 + 236 + 236 + 18446744073709550616 + 9029 + 255 = 2021429896
    #   + Bug D delta 18446744073710551720 = 2022430000
    #   + Bug E delta 18446744073709552109 (mod 2^64) = 2022430493
    #   + Bug F delta (gneg32+gneg64+gneg8, mod 2^64) -> acc = 18446742841164081981
    #   exit code = 18446742841164081981 & 0xFF = 61
    print_u64(acc)
    return cast[int32](acc & cast[uint64](255))

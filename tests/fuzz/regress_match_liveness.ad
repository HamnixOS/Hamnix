# tests/fuzz/regress_match_liveness.ad
#
# Regression for the GENERAL form of the --opt register-allocator miscompile that
# blanked the desktop. The CFG's opaque-statement fallback (cfg.ad
# cfg_lower_stmt) routes `match` (like try/with/defer) through a single opaque
# instruction whose child slots were scanned with cfg_scan_uses — which threads
# nd_next only of a node's a/b CHILDREN, never the arm chain (nd_next of the
# ND_MATCH_ARM node) nor a later body statement. So a use living in the SECOND
# arm's body (or in body statement 2..N) was MISSED, truncating a promoted
# integer local's live range; the linear scan then handed its register to a
# genuinely-overlapping local and the value was silently clobbered — the same
# defect the `unsafe:` fix closed for one construct. FIX: the opaque fallback now
# scans body chains with cfg_scan_uses_deep, a full-subtree (chain-aware) use
# scan, so every use in every arm/body extends the live range (a conservative
# over-approximation that can only lengthen, never clobber).
#
# Run through codegen.ad with the native optimizer ON *and* OFF; both must print
# the same correct value.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

_ch:   Array[1, uint8]
_digs: Array[32, uint8]

gacc: int64

enum Sel:
    First
    Second(int32)

def _putc(c: uint8) -> int32:
    _ch[0] = c
    sys_write(cast[int32](1), &_ch[0], cast[uint64](1))
    return 0

def print_u64(val: uint64) -> int32:
    nd: int64 = 0
    v: uint64 = val
    if v == cast[uint64](0):
        _digs[0] = cast[uint8](48)
        nd = 1
    while v > cast[uint64](0):
        q: uint64 = v / cast[uint64](10)
        d: uint64 = v - q * cast[uint64](10)
        _digs[cast[int64](nd)] = cast[uint8](d + cast[uint64](48))
        nd = nd + 1
        v = q
    k: int64 = nd - 1
    while k >= 0:
        _putc(_digs[cast[int64](k)])
        k = k - 1
    _putc(cast[uint8](10))
    return 0

# x and y are defined OUTSIDE the match; their only real uses are in the SECOND
# arm's body (statement 2). Pre-fix the allocator thought x/y died at their defs
# (the second-arm uses were unscanned) and reused their registers.
def repro(s: Sel) -> int64:
    x: int64 = 111
    y: int64 = 222
    match s:
        case First:
            gacc = 0
        case Second(v):
            gacc = 1
            gacc = x + y + cast[int64](v)
    return gacc

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    r: int64 = repro(Second(cast[int32](0)))   # must be 333, never wrong
    print_u64(cast[uint64](r))
    return cast[int32](r & 255)

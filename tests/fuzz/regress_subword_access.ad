# tests/fuzz/regress_subword_access.ad
#
# Comprehensive behavioral regression for the WHOLE class of sub-8-byte
# sized-access codegen bugs in the native `.ad` backend (compiler/codegen.ad),
# pinned byte-for-byte against the frozen Python seed (codegen_x86.py).
#
# The class: a sub-8-byte scalar (uint8/16/32, int8/16/32) must be STORED with
# a sized movb/movw/movl (truncate, no high-garbage) and LOADED with the right
# extension — sign-extend a SIGNED narrow value into the 64-bit register,
# zero-extend an UNSIGNED one — matching the seed exactly. Two store paths were
# fixed earlier (named-local store, parameter spill). This fixture additionally
# discriminates the LOAD paths that previously zero-extended a SIGNED narrow
# value where the seed sign-extends:
#
#   * INDEX load of a signed element from a NAMED ARRAY GLOBAL  (g_i32[i])
#   * INDEX load of a signed element from a NAMED ARRAY LOCAL   (la[i])
#   * MEMBER load of a signed sub-8-byte struct FIELD           (s.i8 / s.i16)
#   * SCALAR-GLOBAL load of a signed sub-8-byte global          (g_i8)
#   * cast[Ptr[int32]](p)[i] signed element load                (already fixed)
#
# Each signed narrow value below is NEGATIVE, so a wrong ZERO-extension yields
# a large positive 64-bit value and a sign-extension yields the small negative
# value — the two differ in the high 32+ bits, exactly the boot-hang class
# (a misread wide value drives a bogus size / pointer / branch downstream).
#
# The exit code folds all paths: each `sum += cast[uint64](narrow_read)`. With
# correct sign/zero extension the low byte of the running sum is deterministic;
# the frozen seed computes the SAME low byte. The harness asserts the `.ad`
# backend's exit equals the seed's (NOT a hardcoded constant — the seed is the
# oracle), so any sign/zero-extension divergence in ANY path fails the gate.

g_i8:  int8  = 0
g_i16: int16 = 0
g_i32: int32 = 0
g_u8:  uint8 = 0

g_arr_i8:  Array[4, int8]
g_arr_i16: Array[4, int16]
g_arr_i32: Array[4, int32]
g_arr_u16: Array[4, uint16]

class S:
    i8:  int8
    i16: int16
    i32: int32
    u8:  uint8


# Fold a 64-bit register value into the running accumulator so its HIGH bits
# reach the low byte: a wrong sign/zero extension differs ONLY in bits >= the
# narrow width, so a naive `sum += v` then `sum & 0xFF` would mask the bug
# (the low byte is identical). XOR-mixing v with v>>8, v>>16, v>>32, v>>48
# pulls every byte of the 64-bit register into the low byte, so a high-bit
# divergence (zero- vs sign-extended) changes the exit code.
def mix(sum: uint64, v: uint64) -> uint64:
    sum = sum ^ v
    sum = sum ^ (v >> cast[uint64](8))
    sum = sum ^ (v >> cast[uint64](16))
    sum = sum ^ (v >> cast[uint64](32))
    sum = sum ^ (v >> cast[uint64](48))
    return sum


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    sum: uint64 = cast[uint64](0)

    # ---- scalar-global signed sub-8-byte load (sign-extend) --------------
    g_i8  = cast[int8](0 - 5)            #  -5  -> 0xFF..FB if sign-extended
    g_i16 = cast[int16](0 - 300)         # -300
    g_i32 = cast[int32](0 - 70000)       # -70000
    g_u8  = cast[uint8](200)             #  200 -> 0x00..C8 (zero-extend)
    sum = mix(sum, cast[uint64](g_i8))
    sum = mix(sum, cast[uint64](g_i16))
    sum = mix(sum, cast[uint64](g_i32))
    sum = mix(sum, cast[uint64](g_u8))

    # ---- array-GLOBAL signed sub-8-byte element load ---------------------
    g_arr_i8[1]  = cast[int8](0 - 9)
    g_arr_i16[2] = cast[int16](0 - 1000)
    g_arr_i32[3] = cast[int32](0 - 100000)
    g_arr_u16[0] = cast[uint16](60000)
    sum = mix(sum, cast[uint64](g_arr_i8[1]))
    sum = mix(sum, cast[uint64](g_arr_i16[2]))
    sum = mix(sum, cast[uint64](g_arr_i32[3]))
    sum = mix(sum, cast[uint64](g_arr_u16[0]))

    # ---- array-LOCAL signed sub-8-byte element load ----------------------
    la: Array[4, int8]
    la[0] = cast[int8](0 - 3)
    la[2] = cast[int8](0 - 120)
    sum = mix(sum, cast[uint64](la[0]))
    sum = mix(sum, cast[uint64](la[2]))

    # ---- struct MEMBER signed sub-8-byte field load ----------------------
    s: S
    s.i8  = cast[int8](0 - 7)
    s.i16 = cast[int16](0 - 5000)
    s.i32 = cast[int32](0 - 200000)
    s.u8  = cast[uint8](250)
    sum = mix(sum, cast[uint64](s.i8))
    sum = mix(sum, cast[uint64](s.i16))
    sum = mix(sum, cast[uint64](s.i32))
    sum = mix(sum, cast[uint64](s.u8))

    # ---- cast[Ptr[int32]] signed element load ----------------------------
    pi: Array[2, int32]
    pi[0] = cast[int32](0 - 42)
    pp: Ptr[int32] = cast[Ptr[int32]](cast[uint64](&pi))
    sum = mix(sum, cast[uint64](pp[0]))

    # exit code = low byte of the mixed accumulator (deterministic; seed is
    # the oracle, so the harness asserts .ad == seed, not a hardcoded value).
    return cast[int32](sum & cast[uint64](255))

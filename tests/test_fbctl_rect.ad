# tests/test_fbctl_rect.ad
#
# Userland fixture for the /dev/fbctl dirty-rectangle RECT present path
# (drivers/video/fb_cdev.ad). The exhaustive bounds + fast-path proof runs
# KERNEL-SIDE in fbctl_rect_selftest() (gated on /etc/fbrect-test, fired at
# boot:37.fbrect); the host script greps that PASS banner. This fixture adds
# the REAL end-to-end userland leg: it opens /dev/fbctl for write and pushes
# a genuine 52-byte little-endian RECT command whose source pointer is a
# REAL user-space buffer, so the kernel's copy_from_user / header-decode /
# return-52 contract is exercised through an honest syscall write — not just
# the in-kernel synthetic path.
#
# It asserts:
#   * a well-formed RECT write returns exactly 52 (the wire contract);
#   * the ASCII "suspend"/"resume" verbs on the same fd still route to the
#     console-takeover path (return == bytes written), proving the binary
#     magic never collides with the text verbs.
#
# The framebuffer is not initialised under -nographic, so the present is a
# safe no-op; this fixture proves the routing + contract, the kernel
# self-test proves the pixels + bounds rejection.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_fbctl_rect.ad -o build/user/test_fbctl_rect.elf
# Run via scripts/test_fbctl_rect.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def put_le32(buf: Ptr[uint8], off: uint64, v: uint32):
    buf[off]     = cast[uint8](v & 0xFF)
    buf[off + 1] = cast[uint8]((v >> 8) & 0xFF)
    buf[off + 2] = cast[uint8]((v >> 16) & 0xFF)
    buf[off + 3] = cast[uint8]((v >> 24) & 0xFF)


def put_le64(buf: Ptr[uint8], off: uint64, v: uint64):
    k: uint64 = 0
    while k < 8:
        buf[off + k] = cast[uint8]((v >> (k * 8)) & 0xFF)
        k = k + 1


def main() -> int32:
    write_str(1, "[fbrect-user] start\n")

    fd: int32 = sys_open_write("/dev/fbctl")
    if fd < 0:
        # No /dev/fbctl on this surface — the kernel self-test still gates the
        # result, so report and exit cleanly rather than failing the boot.
        write_str(1, "[fbrect-user] /dev/fbctl absent (skip)\n")
        return 0

    # A real user-space RGBA8888 source frame: 8 x 4 pixels.
    src: Array[128, uint8]                # 8*4*4 = 128 bytes
    i: uint64 = 0
    while i < 128:
        src[i] = cast[uint8](i)
        i = i + 1

    # Build a well-formed 52-byte LE RECT command naming the whole 8x4 frame
    # at screen origin. magic 0x54434552 ('RECT').
    cmd: Array[52, uint8]
    put_le32(&cmd[0], 0, 0x54434552)      # magic
    put_le32(&cmd[0], 4, 0)               # dst_x
    put_le32(&cmd[0], 8, 0)               # dst_y
    put_le32(&cmd[0], 12, 8)              # w
    put_le32(&cmd[0], 16, 4)              # h
    put_le64(&cmd[0], 20, cast[uint64](&src[0]))   # src_ptr (real user buf)
    put_le64(&cmd[0], 28, 8)              # src_pitch_px
    put_le64(&cmd[0], 36, 0)              # src_x0
    put_le64(&cmd[0], 44, 0)              # src_y0

    rc: int64 = sys_write(fd, &cmd[0], 52)
    if rc == 52:
        write_str(1, "[fbrect-user] OK RECT write returned 52\n")
    else:
        write_str(1, "[fbrect-user] FAIL RECT write != 52\n")
        sys_close(fd)
        return 1

    # The ASCII verbs on the same fd must still route to the takeover path.
    sv: Ptr[uint8] = "suspend"
    rsv: int64 = sys_write(fd, sv, strlen(sv))
    rv: Ptr[uint8] = "resume"
    rrv: int64 = sys_write(fd, rv, strlen(rv))
    if rsv == cast[int64](strlen(sv)) and rrv == cast[int64](strlen(rv)):
        write_str(1, "[fbrect-user] OK suspend/resume verbs still route\n")
    else:
        write_str(1, "[fbrect-user] FAIL verb routing\n")
        sys_close(fd)
        return 1

    sys_close(fd)
    write_str(1, "[fbrect-user] PASS\n")
    return 0

# tests/modpriv_b.ad — helper module B for the per-module symbol
# scoping regression (scripts/test_compiler_module_private.sh).
#
# Defines a MODULE-PRIVATE helper `_scale` with the SAME NAME as the
# `_scale` in tests/modpriv_a.ad and tests/test_compiler_module_private.ad
# but a DIFFERENT body (add 100). `mp_b()` must resolve to THIS
# module's `_scale`, proving the per-module mangling keeps the three
# `_scale` definitions independent.

def _scale(x: int32) -> int32:
    return x + 100


# Public entry point.
def mp_b(x: int32) -> int32:
    return _scale(x)

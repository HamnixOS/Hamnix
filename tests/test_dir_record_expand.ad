# tests/test_dir_record_expand.ad
#
# #458 F10-6 expansion — assert SYS_LISTDIR_RECORDS now emits real
# Plan 9 Dir records for /proc, /net, and /dev/blk (not just /srv).
# Each backing was a NAME\n line emitter at MVP time; the audit
# (docs/audit_arch_shortcuts_2026-06-13.md §8) called this out as the
# keystone for clean `ls -l` performance. This test boots, asks the
# kernel for the Dir-record stream from each directory, and checks
# that the first decoded record has a non-empty name, non-empty uid
# ("hostowner"), and a populated mode field — i.e. the structural
# fields the F10-6 spec promises.
#
# Markers grepped by scripts/test_dir_record_expand.sh:
#   [direxp] start
#   [direxp] proc OK
#   [direxp] net OK
#   [direxp] blk OK
#   [direxp] PASS

from lib.p9 import (
    p9_listdir_records,
    p9_diread_open, p9_diread, p9_diread_close,
    DIR_CUR_NAME, DIR_CUR_NAME_LEN,
    DIR_CUR_UID,  DIR_CUR_UID_LEN,
    DIR_CUR_MODE,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


buf_check: Array[4096, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def check_dir(path: Ptr[char], label: Ptr[uint8]) -> int32:
    # Bulk read first.
    n: int64 = p9_listdir_records(path, &buf_check[0], 4096)
    if n <= 0:
        write_str(1, "[direxp] FAIL: listdir_records <= 0 for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    # Walk one record via p9_diread; assert decoded shape.
    h: int32 = p9_diread_open(path)
    if h < 0:
        write_str(1, "[direxp] FAIL: p9_diread_open for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    rc: int32 = p9_diread(h)
    p9_diread_close(h)
    if rc <= 0:
        write_str(1, "[direxp] FAIL: no records decoded for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    if DIR_CUR_NAME_LEN == 0:
        write_str(1, "[direxp] FAIL: empty Dir.name for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    if DIR_CUR_UID_LEN == 0:
        write_str(1, "[direxp] FAIL: empty Dir.uid for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    if DIR_CUR_MODE == 0:
        write_str(1, "[direxp] FAIL: zero Dir.mode for ")
        write_str(1, label)
        write_str(1, "\n")
        return 0
    return 1


def main() -> int32:
    write_str(1, "[direxp] start\n")

    if check_dir("/proc", "/proc") == 0:
        return 1
    write_str(1, "[direxp] proc OK\n")

    if check_dir("/net", "/net") == 0:
        return 2
    write_str(1, "[direxp] net OK\n")

    if check_dir("/dev/blk", "/dev/blk") == 0:
        return 3
    write_str(1, "[direxp] blk OK\n")

    write_str(1, "[direxp] PASS\n")
    return 0

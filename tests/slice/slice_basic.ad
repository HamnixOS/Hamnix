# Slice construction from an Array, index reads/writes, and .len / len().
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[4, int32]
    a[0] = 10
    a[1] = 20
    a[2] = 30
    a[3] = 40
    s: Slice[int32] = Slice[int32](a)
    s[1] = 99
    total: int32 = s[0] + s[1] + cast[int32](s.len) + cast[int32](len(s))
    # 10 + 99 + 4 + 4 = 117
    return total

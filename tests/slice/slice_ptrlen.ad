# RUN-ONLY (seed host x86_64-linux): 2-arg Slice from an explicit (ptr, len).
# `p` casts a local Array to Ptr[int32]; a[5]=42, s = Slice(p, 8), s[5] == 42.
# (Not in the native objdiff set: `cast[Ptr](array_local)` is a pre-existing
# native-backend decay gap, orthogonal to Slice — see test_adder_slice.sh.)
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[8, int32]
    a[5] = 42
    p: Ptr[int32] = cast[Ptr[int32]](a)
    s: Slice[int32] = Slice[int32](p, 8)
    return s[5]

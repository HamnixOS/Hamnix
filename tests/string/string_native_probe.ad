# Self-contained (no imports) String source used ONLY to confirm the native
# `.ad` backend REJECTS `String` cleanly (increment 7-tail is seed-first; native
# String support is pending). The seed compiles this fine; host_ac.elf must not.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    s: String = String("hi")
    return cast[int32](s.len)

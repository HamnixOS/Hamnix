# Native-backend acceptance (#312): member access on an UNBOUND aggregate
# constructor temporary — `String(...).ptr` / `.len` / `.cstr` and the
# `Slice[T](...)` analogue — WITHOUT binding to a named local first. Before the
# fix the native backend rejected `String(...).ptr` (codegen reason=8 kind=29);
# the seed accepted it. The constructor now materialises into an anonymous
# prescan-reserved 16-byte cell, byte-identically to the seed (objdiff-clean).
# (Indexing the RETURNED pointer inline — `String(x).ptr[i]` — is a SEPARATE,
# pre-existing native gap: bind the ptr to a local first, as below.)
# Checksum lands on 42 iff every temporary-member read is byte-correct.
def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: int32 = 0
    # (1) String("literal").len — compile-time byte length off the temp
    acc = acc + cast[int32](String("abcdef").len)            # +6  (=6)
    # (2) Slice[uint8](array).len — compile-time element count off the temp
    buf: Array[4, uint8]
    acc = acc + cast[int32](Slice[uint8](buf).len)           # +4  (=10)
    # (3) String(...).ptr / .cstr on the temp, bound then indexed
    p: Ptr[uint8] = String("hi").ptr
    c: Ptr[uint8] = String("hi").cstr
    if p[0] == 104 and c[1] == 105:                          # 'h', 'i'
        acc = acc + 32                                       # +32 (=42)
    return acc

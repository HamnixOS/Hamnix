# String end-to-end (roadmap increment 7-tail): construct-from-literal,
# .len / .ptr / .cstr, (ptr,len) construction, substring VIEW, and the
# lib/strview.ad helpers (eq / find / contains / concat_into). Returns a
# checksum that only lands on 42 if every step is byte-correct.
from lib.strview import str_eq, str_find, str_contains, str_at, str_concat_into

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: int32 = 0

    # (1) construct from literal + .len (byte length, not strlen scan) -> 11
    s: String = String("hello world")
    acc = acc + cast[int32](s.len)               # +11

    # (2) .ptr / .cstr both address the same interned bytes; s.ptr[0] == 'h'
    hp: Ptr[uint8] = s.ptr
    cp: Ptr[uint8] = s.cstr
    if hp[0] == 104 and cp[0] == 104:            # 'h'
        acc = acc + 1                            # +1  (=12)
    # .cstr is NUL-terminated (interned via .asciz) -> round-trips to C
    if cp[11] == 0:
        acc = acc + 1                            # +1  (=13)

    # (3) .eq — equal to a fresh literal-String, not equal to a prefix
    t: String = String("hello world")
    acc = acc + str_eq(s.ptr, s.len, t.ptr, t.len)   # +1  (=14)
    w: String = String("hello")
    acc = acc - str_eq(s.ptr, s.len, w.ptr, w.len)   # -0  (=14)

    # (4) .find / .contains
    n: String = String("world")
    idx: int64 = str_find(s.ptr, s.len, n.ptr, n.len)
    acc = acc + cast[int32](idx)                 # +6  (=20)  ("world" @ 6)
    acc = acc + str_contains(s.ptr, s.len, n.ptr, n.len)  # +1 (=21)
    miss: String = String("xyz")
    acc = acc + str_contains(s.ptr, s.len, miss.ptr, miss.len)  # +0 (=21)

    # (5) substring VIEW (no allocation): s[0:5] == "hello"
    sub: String = String(str_at(s.ptr, 0), 5)
    acc = acc + str_eq(sub.ptr, sub.len, w.ptr, w.len)   # +1 (=22)
    sub2: String = String(str_at(s.ptr, 6), 5)           # "world"
    acc = acc + str_eq(sub2.ptr, sub2.len, n.ptr, n.len) # +1 (=23)

    # (6) concat into a caller-owned buffer -> "hello world" == s, len 11
    buf: Array[32, uint8]
    bp: Ptr[uint8] = cast[Ptr[uint8]](buf)
    tot: int64 = str_concat_into(bp, 32, w.ptr, w.len, String(" world").ptr, 6)
    acc = acc + cast[int32](tot)                 # +11 (=34)
    cat: String = String(bp, cast[uint64](tot))
    acc = acc + str_eq(cat.ptr, cat.len, s.ptr, s.len)   # +1 (=35)

    # (7) overflow guard: concat that exceeds cap returns -1
    small: Array[4, uint8]
    sp: Ptr[uint8] = cast[Ptr[uint8]](small)
    ov: int64 = str_concat_into(sp, 4, w.ptr, w.len, n.ptr, n.len)
    if ov < 0:
        acc = acc + 7                            # +7 (=42)

    return acc

# Self-contained seed<->native LOCKSTEP fixture for the String helper LAYER
# (lib/strview.ad). The helpers are ORDINARY Adder over raw (ptr, len) pairs —
# no `String` type — so the NATIVE backend accepts this unit and the objdiff
# harness can prove the algorithms emit byte-identical machine code on both
# backends. (The String type's construction/member codegen is seed-only and is
# rejected by native separately; see test_adder_string.sh step 5.) The helper
# bodies here are a verbatim copy of lib/strview.ad's — keep them in sync.

def sv_eq(ap: Ptr[uint8], an: uint64, bp: Ptr[uint8], bn: uint64) -> int32:
    if an != bn:
        return 0
    i: uint64 = 0
    while i < an:
        if ap[i] != bp[i]:
            return 0
        i = i + 1
    return 1

def sv_find(hp: Ptr[uint8], hn: uint64, np: Ptr[uint8], nn: uint64) -> int64:
    if nn == 0:
        return 0
    if nn > hn:
        return -1
    last: uint64 = hn - nn
    i: uint64 = 0
    while i <= last:
        j: uint64 = 0
        while j < nn:
            if hp[i + j] != np[j]:
                j = nn + 1
            else:
                j = j + 1
        if j == nn:
            return cast[int64](i)
        i = i + 1
    return -1

def sv_concat_into(dst: Ptr[uint8], cap: uint64,
                   ap: Ptr[uint8], an: uint64,
                   bp: Ptr[uint8], bn: uint64) -> int64:
    total: uint64 = an + bn
    if total > cap:
        return -1
    i: uint64 = 0
    while i < an:
        dst[i] = ap[i]
        i = i + 1
    j: uint64 = 0
    while j < bn:
        dst[an + j] = bp[j]
        j = j + 1
    return cast[int64](total)

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[6, uint8]
    a[0] = 104   # h
    a[1] = 101   # e
    a[2] = 108   # l
    a[3] = 108   # l
    a[4] = 111   # o
    a[5] = 0
    b: Array[6, uint8]
    b[0] = 104
    b[1] = 101
    b[2] = 108
    b[3] = 108
    b[4] = 111
    b[5] = 0
    ap: Ptr[uint8] = cast[Ptr[uint8]](a)
    bp: Ptr[uint8] = cast[Ptr[uint8]](b)
    acc: int32 = 0
    acc = acc + sv_eq(ap, 5, bp, 5)                 # +1
    acc = acc + cast[int32](sv_find(ap, 5, bp, 5))  # +0 (match at 0)
    n: Array[3, uint8]
    n[0] = 108   # l
    n[1] = 108   # l
    n[2] = 111   # o
    np: Ptr[uint8] = cast[Ptr[uint8]](n)
    acc = acc + cast[int32](sv_find(ap, 5, np, 3))  # +2 ("llo" @ 2)
    buf: Array[16, uint8]
    dp: Ptr[uint8] = cast[Ptr[uint8]](buf)
    acc = acc + cast[int32](sv_concat_into(dp, 16, ap, 5, np, 3))  # +8
    return acc                                       # 1+0+2+8 = 11

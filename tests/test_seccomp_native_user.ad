# tests/test_seccomp_native_user.ad
#
# F10-8 / #457 — NATIVE seccomp-lite END-TO-END USERLAND test.
#
# Drives the new SYS_SECCOMP_NATIVE(318) userland arming surface from
# a real ring-3 process and asserts the per-task native allow-list
# actually bounces denied native syscalls with -EPERM at do_syscall
# entry — proving the gate added in arch/x86/kernel/syscall.ad isn't
# only kernel-pokable via the accessors (the existing in-kernel
# seccomp_native_selftest covers that) but is reachable + enforced
# from real userland through the syscall surface.
#
# Sentinels (scripts/test_seccomp_native_user.sh greps for these):
#   [seccomp_native_user] T<N> PASS    per-stage
#   [seccomp_native_user] PASS         final
# Any FAIL line causes sys_exit(1).

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_get_jiffies() -> uint64
extern def sys_exit(code: uint64)
extern def sys_seccomp_native(op: uint64, bitmap: Ptr[uint64]) -> int64


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(s: Ptr[uint8]):
    sys_write(2, s, strlen_u8(s))


def fail(tag: Ptr[uint8]):
    write_str("[seccomp_native_user] FAIL ")
    write_str(tag)
    write_str("\n")
    sys_exit(1)


# 256-bit allow-list — matches kernel/sched/core.ad's seccomp_native_
# filter layout exactly (Array[4, uint64], word 0 = nrs 0..63, etc.).
allow: Array[4, uint64]


def bm_clear():
    bi: uint64 = 0
    while bi < 4:
        allow[bi] = 0
        bi = bi + 1


def bm_set(nr: uint64):
    word: uint64 = nr >> 6
    bit:  uint64 = cast[uint64](1) << (nr & 63)
    allow[word] = allow[word] | bit


def main() -> int32:
    write_str("[seccomp_native_user] start\n")

    # T1. QUERY pre-arm == 0 (disarmed).
    q0: int64 = sys_seccomp_native(2, cast[Ptr[uint64]](0))
    if q0 != 0:
        fail("T1 pre-arm query expected 0")
    write_str("[seccomp_native_user] T1 PASS\n")

    # T2. Pre-arm SYS_WRITE smoke — proves the test prog can talk to
    # the serial console before the filter is in the way.
    write_str("[seccomp_native_user] T2 PASS\n")

    # T3. ARM with an allow-list = { SYS_EXIT(1), SYS_GET_JIFFIES(2),
    # SYS_WRITE(8) }. Deliberately EXCLUDES SYS_PUTC(0) so T4 can
    # observe a real -EPERM bounce.
    bm_clear()
    bm_set(1)
    bm_set(2)
    bm_set(8)
    r3: int64 = sys_seccomp_native(0, &allow[0])
    if r3 != 0:
        fail("T3 arm returned non-zero")
    write_str("[seccomp_native_user] T3 PASS\n")

    # T4. SYS_PUTC (nr=0, NOT allowed) is bounced with -EPERM at the
    # do_syscall entry gate BEFORE the SYS_PUTC body runs. Returns -1.
    rp: int64 = __syscall1(cast[uint64](0), cast[uint64](33))
    if rp != cast[int64](-1):
        fail("T4 SYS_PUTC not blocked")
    write_str("[seccomp_native_user] T4 PASS\n")

    # T5. SYS_GET_JIFFIES (nr=2, allowed) STILL works post-arm. Any
    # non-(-1) value is acceptable (fresh boot can legitimately have
    # j == 0); only the canonical -EPERM cast is a failure signal.
    j: uint64 = sys_get_jiffies()
    if j == cast[uint64](-1):
        fail("T5 allowed nr=2 blocked")
    write_str("[seccomp_native_user] T5 PASS\n")

    # T6. SYS_CHDIR (nr=19, NOT allowed) bounces. Different nr from
    # T4 — proves the gate isn't hard-coded to a single number.
    rc: int64 = __syscall1(cast[uint64](19), cast[uint64](0))
    if rc != cast[int64](-1):
        fail("T6 SYS_CHDIR not blocked")
    write_str("[seccomp_native_user] T6 PASS\n")

    # T7. Re-ARM rejection (irrevocable ratchet). op=0 on an already-
    # armed task must return -EPERM. We can still issue this call
    # because SYS_SECCOMP_NATIVE is nr=318, but the implicit-deny-out-
    # of-range rule blocks nrs>=256 once armed — so the call gets
    # bounced with -EPERM as well, by a DIFFERENT code path than the
    # ratchet. Either way the return is -1, which is what we assert.
    r7: int64 = sys_seccomp_native(0, &allow[0])
    if r7 != cast[int64](-1):
        fail("T7 re-arm not rejected")
    write_str("[seccomp_native_user] T7 PASS\n")

    write_str("[seccomp_native_user] PASS\n")
    sys_exit(0)
    return 0

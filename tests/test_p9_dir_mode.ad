# tests/test_p9_dir_mode.ad
#
# F10-6 followup acceptance — per-Chan p9_dir_mode flag end-to-end.
#
# Asserts:
#   1. A directory fd opens by default in legacy NAME\n line-stream
#      mode (existing callers untouched).
#   2. SYS_CHAN_DIR_MODE(fd, 1, "/srv") flips the chan into Dir-record
#      mode; the next sys_read returns Plan-9 Dir wire-format records
#      that p9_dir_decode_at can walk.
#   3. The transformed record stream carries the entry whose name we
#      posted into /srv.
#
# Markers grepped by scripts/test_p9_dir_mode.sh:
#   [p9dm] start
#   [p9dm] posted
#   [p9dm] line stream OK
#   [p9dm] dir mode flip OK
#   [p9dm] record decoded
#   [p9dm] name match OK
#   [p9dm] PASS

from lib.p9 import (
    p9_chan_dir_mode, p9_dir_decode_at,
    DIR_CUR_NAME, DIR_CUR_NAME_LEN,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def sys_srv_post(name: Ptr[char], srvfd: int32) -> int32


fds_buf: Array[2, int32]
line_buf: Array[2048, uint8]
rec_buf:  Array[4096, uint8]


def strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen_u8(s))


def streq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def main() -> int32:
    write_str(1, "[p9dm] start\n")

    # Post a name into /srv so we have something to read back.
    if sys_pipe(&fds_buf[0]) < 0:
        write_str(1, "[p9dm] FAIL: pipe\n")
        return 1
    rfd: int32 = fds_buf[0]
    wfd: int32 = fds_buf[1]
    if sys_srv_post("dmtest", wfd) < 0:
        write_str(1, "[p9dm] FAIL: srv_post\n")
        return 2
    write_str(1, "[p9dm] posted\n")

    # 1. Legacy line-stream mode — open /srv, read NAME\n, look for
    # "dmtest\n" in the output. Default backward-compat path.
    fd_line: int32 = sys_open("/srv")
    if fd_line < 0:
        write_str(1, "[p9dm] FAIL: open /srv (line)\n")
        return 3
    nl: int64 = sys_read(fd_line, &line_buf[0], 2048)
    sys_close(fd_line)
    if nl <= 0:
        write_str(1, "[p9dm] FAIL: read line stream\n")
        return 4
    # Scan for newline-delimited "dmtest".
    nlu: uint64 = cast[uint64](nl)
    saw_line_name: int32 = 0
    i: uint64 = 0
    while i < nlu:
        # Read 6 chars at i.
        if i + 6 <= nlu \
                and line_buf[i] == 100 \
                and line_buf[i + 1] == 109 \
                and line_buf[i + 2] == 116 \
                and line_buf[i + 3] == 101 \
                and line_buf[i + 4] == 115 \
                and line_buf[i + 5] == 116:
            saw_line_name = 1
            i = nlu
        else:
            i = i + 1
    if saw_line_name == 0:
        write_str(1, "[p9dm] FAIL: line stream missing 'dmtest'\n")
        return 5
    write_str(1, "[p9dm] line stream OK\n")

    # 2. Dir-record mode — re-open, flip, read records.
    fd_rec: int32 = sys_open("/srv")
    if fd_rec < 0:
        write_str(1, "[p9dm] FAIL: open /srv (rec)\n")
        return 6
    if p9_chan_dir_mode(fd_rec, 1, "/srv") != 0:
        write_str(1, "[p9dm] FAIL: chan_dir_mode flip\n")
        sys_close(fd_rec)
        return 7
    write_str(1, "[p9dm] dir mode flip OK\n")
    nr: int64 = sys_read(fd_rec, &rec_buf[0], 4096)
    sys_close(fd_rec)
    if nr <= 0:
        write_str(1, "[p9dm] FAIL: read records\n")
        return 8
    # Walk records.
    nru: uint64 = cast[uint64](nr)
    off: uint64 = 0
    saw_rec_name: int32 = 0
    while off < nru:
        rl: uint64 = p9_dir_decode_at(&rec_buf[0], off, nru)
        if rl == 0:
            break
        write_str(1, "[p9dm] record decoded\n")
        if streq(cast[Ptr[uint8]](&DIR_CUR_NAME[0]),
                 cast[Ptr[uint8]]("dmtest")) != 0:
            saw_rec_name = 1
        off = off + rl
    if saw_rec_name == 0:
        write_str(1, "[p9dm] FAIL: 'dmtest' missing from records\n")
        return 9
    write_str(1, "[p9dm] name match OK\n")

    sys_close(rfd)
    write_str(1, "[p9dm] PASS\n")
    return 0

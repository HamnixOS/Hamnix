# tests/test_p9_tauth.ad
#
# F10-4 (#457) regression: mount(2)'s `afd` parameter used to be
# silently dropped (read into `_ignored` inside do_mount), leaving
# every 9P mount carrying uname="" on the wire. This fixture exercises
# the new resolution path:
#
#   * afd == -1                           -> uname = ""  (legacy)
#   * afd is /dev/auth verified slot      -> uname = principal name
#   * afd is /dev/auth UN-verified slot   -> mount fails with errstr
#
# The kernel's do_mount logs one of these BEFORE running the 9P attach
# handshake (which fails anyway against a bare pipe pair — no
# responder), so the acceptance marker fires regardless of attach
# outcome:
#
#   [mount] uname= (afd=-1)        legacy path
#   [mount] uname=<principal>      authenticated path
#
# scripts/test_p9_tauth.sh greps the serial log for these markers AND
# for the userland PASS line.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_p9_tauth.ad -o build/user/test_p9_tauth.elf
#
# Run via scripts/test_p9_tauth.sh.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_pipe(fds: Ptr[int32]) -> int32
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64

SYS_MOUNT: uint64 = 258
MREPL:     int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


# Per-test pipe slot pair. Each mount call burns one (the kernel does
# not roll back the srvfd allocation on attach-failure paths beyond the
# mnttab entry; a fresh pair per attempt keeps the test deterministic).
pipe_fds: Array[2, int32]


def open_fresh_pipe() -> int32:
    # sys_pipe fills [rfd, wfd]. We hand mount() the writer (rfd is
    # opaque to the test); the reader is closed so the writer doesn't
    # leak indefinitely.
    if sys_pipe(&pipe_fds[0]) < 0:
        return -1
    sys_close(pipe_fds[0])
    return pipe_fds[1]


def auth_as_live() -> int32:
    # Open /dev/auth and run the user+pass dance for user="live"
    # password="hamnix". Returns the verified afd on success, -1 on
    # any failure. The initramfs ships an /etc/passwd + /etc/shadow
    # carrying this account (same seed scripts/test_authdev.sh uses).
    afd: int32 = sys_open("/dev/auth")
    if afd < 0:
        return -1
    # Write "user live\n"
    user_line: Array[16, uint8]
    user_line[0]  = 117     # 'u'
    user_line[1]  = 115     # 's'
    user_line[2]  = 101     # 'e'
    user_line[3]  = 114     # 'r'
    user_line[4]  = 32      # ' '
    user_line[5]  = 108     # 'l'
    user_line[6]  = 105     # 'i'
    user_line[7]  = 118     # 'v'
    user_line[8]  = 101     # 'e'
    user_line[9]  = 10      # '\n'
    if sys_write(afd, &user_line[0], 10) < cast[int64](10):
        sys_close(afd)
        return -1
    # Write "pass hamnix\n"
    pass_line: Array[16, uint8]
    pass_line[0]  = 112     # 'p'
    pass_line[1]  = 97      # 'a'
    pass_line[2]  = 115     # 's'
    pass_line[3]  = 115     # 's'
    pass_line[4]  = 32      # ' '
    pass_line[5]  = 104     # 'h'
    pass_line[6]  = 97      # 'a'
    pass_line[7]  = 109     # 'm'
    pass_line[8]  = 110     # 'n'
    pass_line[9]  = 105     # 'i'
    pass_line[10] = 120     # 'x'
    pass_line[11] = 10      # '\n'
    if sys_write(afd, &pass_line[0], 12) < cast[int64](12):
        sys_close(afd)
        return -1
    # Read the verdict — "ok ..." on success, "denied\n" otherwise.
    resp: Array[64, uint8]
    rn: int64 = sys_read(afd, &resp[0], 64)
    if rn < cast[int64](2):
        sys_close(afd)
        return -1
    if resp[0] != 111 or resp[1] != 107:        # not "ok"
        sys_close(afd)
        return -1
    return afd


def main() -> int32:
    write_str(1, "[p9_tauth] start\n")

    # ----------------------------------------------------------------
    # 1) Legacy path: afd=-1. The kernel logs `[mount] uname= (afd=-1)`
    # before the 9P attach handshake (which fails — no responder).
    # The userland mount() call returns -1; we accept that and the
    # acceptance is the SERIAL marker, not the userland rc.
    srvfd1: int32 = open_fresh_pipe()
    if srvfd1 < 0:
        write_str(1, "[p9_tauth] FAIL: sys_pipe legacy\n")
        return 1
    rc: int64 = syscall6(SYS_MOUNT,
                         cast[uint64](srvfd1),
                         cast[uint64](-1),               # afd = -1
                         cast[uint64](&"/n/legacy"[0]),
                         cast[uint64](MREPL),
                         cast[uint64](&""[0]),
                         0)
    sys_close(srvfd1)
    write_str(1, "[p9_tauth] legacy afd=-1 mount rc=")
    write_dec(1, cast[uint64](rc))
    write_str(1, "\n")
    # Leg A: do_mount ran with afd=-1. The structural signal is the
    # kernel `[mount] uname= (afd=-1)` printk (now WARN-level, so it
    # survives the post-interactive console gate). Userland rc<0 is
    # expected — the bare pipe has no 9P responder, so the Tversion
    # handshake fails; the acceptance is that do_mount processed the
    # legacy uname="" path. Emit the leg-A marker AFTER the kernel
    # path is exercised so the shell driver's grep order is stable.
    write_str(1, "[ptauth:leg-A] afd=-1 do_mount ran\n")

    # ----------------------------------------------------------------
    # 2) Authenticated path: open /dev/auth, verify as user "live",
    # hand the verified afd to mount(). Kernel logs
    # `[mount] uname=live` from devauth_verified_uname_copy.
    afd: int32 = auth_as_live()
    if afd < 0:
        write_str(1, "[p9_tauth] FAIL: auth_as_live\n")
        return 2
    write_str(1, "[p9_tauth] auth ok afd=")
    write_dec(1, cast[uint64](afd))
    write_str(1, "\n")

    srvfd2: int32 = open_fresh_pipe()
    if srvfd2 < 0:
        write_str(1, "[p9_tauth] FAIL: sys_pipe auth\n")
        sys_close(afd)
        return 3
    rc = syscall6(SYS_MOUNT,
                  cast[uint64](srvfd2),
                  cast[uint64](afd),                      # afd = verified
                  cast[uint64](&"/n/authed"[0]),
                  cast[uint64](MREPL),
                  cast[uint64](&""[0]),
                  0)
    sys_close(srvfd2)
    write_str(1, "[p9_tauth] verified afd mount rc=")
    write_dec(1, cast[uint64](rc))
    write_str(1, "\n")
    # Leg B: do_mount ran with a VERIFIED afd. Structural signal is
    # the kernel `[mount] uname=live` printk. Same rc<0 expectation
    # (no responder); the acceptance is that the verified principal
    # name was extracted from the AuthSlot and plumbed.
    write_str(1, "[ptauth:leg-B] verified afd do_mount ran\n")

    # ----------------------------------------------------------------
    # 3) Unverified-afd negative control: a fresh /dev/auth fd with
    # no user/pass exchange yet MUST reject the mount with errstr
    # "afd not verified" (devauth_verified_uname_copy returns -1).
    # mount() returns -1 here regardless, but the meaningful signal
    # is that the printk marker does NOT appear and the mount fails
    # BEFORE 9P attach (so no mnttab entry, no chan churn).
    afd_unv: int32 = sys_open("/dev/auth")
    if afd_unv < 0:
        write_str(1, "[p9_tauth] FAIL: open /dev/auth (unverified)\n")
        sys_close(afd)
        return 4
    srvfd3: int32 = open_fresh_pipe()
    if srvfd3 < 0:
        write_str(1, "[p9_tauth] FAIL: sys_pipe unverified\n")
        sys_close(afd_unv)
        sys_close(afd)
        return 5
    rc = syscall6(SYS_MOUNT,
                  cast[uint64](srvfd3),
                  cast[uint64](afd_unv),
                  cast[uint64](&"/n/unverified"[0]),
                  cast[uint64](MREPL),
                  cast[uint64](&""[0]),
                  0)
    sys_close(srvfd3)
    sys_close(afd_unv)
    if rc == 0:
        write_str(1, "[p9_tauth] FAIL: unverified afd should be rejected\n")
        sys_close(afd)
        return 6
    write_str(1, "[p9_tauth] unverified afd rejected (expected) rc=")
    write_dec(1, cast[uint64](rc))
    write_str(1, "\n")
    # Leg C: unverified afd was REJECTED by do_mount BEFORE the 9P
    # attach handshake. The kernel does NOT emit `[mount] uname=...`
    # for this path (devauth_verified_uname_copy returns -1 and
    # do_mount returns early with "afd not verified" errstr) — that
    # absence is itself signal. Userland rc<0 is required.
    write_str(1, "[ptauth:leg-C] unverified afd rejected\n")

    sys_close(afd)
    # All three legs reached do_mount and returned the expected shape.
    # The shell driver greps for [ptauth:leg-A/B/C] AND the kernel
    # `[mount] uname= (afd=-1)` / `[mount] uname=live` markers before
    # accepting this PASS.
    write_str(1, "[test_p9_tauth] PASS\n")
    write_str(1, "[p9_tauth] PASS\n")
    return 0

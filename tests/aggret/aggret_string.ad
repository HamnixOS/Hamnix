# By-value String RETURN — the 16-byte {ptr,len} view of interned bytes comes
# back in rax:rdx. Seed-first (native has no String annotation).
def mk_str() -> String:
    s: String = String("hello")
    return s

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    s: String = mk_str()
    acc: int32 = cast[int32](s.len)      # 5
    hp: Ptr[uint8] = s.ptr
    if hp[0] == 104:                     # 'h'
        acc = acc + 100                  # 105
    return acc

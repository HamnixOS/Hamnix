# By-value Slice[T] RETURN — the 16-byte {ptr@0, len@8} view comes back in
# rax:rdx. Caller reads .len / s[i] / .ptr off the stored pair.
def mk_slice(base: Ptr[int32], n: uint64) -> Slice[int32]:
    s: Slice[int32] = Slice[int32](base, n)
    return s

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    a: Array[8, int32]
    a[3] = 99
    p: Ptr[int32] = cast[Ptr[int32]](a)
    s: Slice[int32] = mk_slice(p, 8)
    acc: int32 = cast[int32](s.len)      # 8
    acc = acc + s[3]                     # +99 = 107
    pp: Ptr[int32] = s.ptr
    acc = acc + pp[3]                    # +99 = 206
    return acc

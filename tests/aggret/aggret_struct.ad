# By-value aggregate RETURN — structs <=16 bytes come back in rax:rdx (System V
# AMD64 two-INTEGER-eightbyte rule). Point is one eightbyte (rax only); Pair16
# is two (rax:rdx). Seed-first (codegen_x86); native rejects cleanly.
class Point:
    x: int32
    y: int32

class Pair16:
    a: int64
    b: int64

def mk_pt(a: int32, b: int32) -> Point:
    p: Point
    p.x = a
    p.y = b
    return p

def mk_pair(a: int64, b: int64) -> Pair16:
    q: Pair16
    q.a = a
    q.b = b
    return q

def main(argc: int32, argv: Ptr[uint64]) -> int32:
    acc: int32 = 0
    # (1) VarDecl init from a by-value struct return (one eightbyte -> rax)
    p: Point = mk_pt(3, 4)
    acc = acc + p.x + p.y                # 7
    # (2) plain Assignment form re-stores rax into the slot
    p = mk_pt(10, 20)
    acc = acc + p.x + p.y                # +30 = 37
    # (3) 16-byte struct returned in rax:rdx, both eightbytes read back
    q: Pair16 = mk_pair(5, 100)
    acc = acc + cast[int32](q.a) + cast[int32](q.b)   # +105 = 142
    return acc

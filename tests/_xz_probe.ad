extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64

g_code: uint32 = 0x80000010

def _w(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    sys_write(1, s, n)

def main() -> int32:
    bound: uint32 = 0x00000020
    if g_code < bound:
        _w("CMP_WRONG\n")
    else:
        _w("CMP_OK\n")
    sh: uint32 = g_code >> 31
    if sh == 1:
        _w("SHIFT_OK\n")
    else:
        _w("SHIFT_WRONG\n")
    # multiply that nearly overflows uint32
    a: uint32 = 0x1FFFFF
    b: uint32 = 2048
    p: uint32 = a * b
    if p == 0xFFFFF800:
        _w("MUL_OK\n")
    else:
        _w("MUL_WRONG\n")
    return 0

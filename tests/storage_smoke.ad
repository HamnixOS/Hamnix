# USB Bulk-Only Mass Storage (BOT) class driver — exposes an attached
# USB stick as /dev/blk/sd0 by speaking SCSI over the xHCI bulk
# endpoints. The exercise below (gated on /etc/usbms-test) enumerates
# the device and reads sector 0 back to prove the path end to end; the
# Debian-Live model consumes /dev/blk/sd0 to read a squashfs image.
from drivers.usb.storage import usbms_init, usbms_read_sectors
# EHCI (USB 2.0) host controller. Many 2008..2014 laptops — Asus
# included — wire the built-in keyboard to an EHCI controller rather
# than the i8042; on such hardware EHCI is the only path to a working
# keyboard. V0 shipped PCI probe + BIOS->OS handoff + controller reset
# + root-hub port enumeration; V1 adds the control-transfer engine,
# standard enumeration through SET_CONFIGURATION, and a periodic
# interrupt-IN QH that feeds boot-keyboard reports into the shared
# kbd FIFO. ehci_v1_selftest is the synthetic transfer-engine proof.
from drivers.usb.ehci import ehci_init, ehci_v1_selftest, ehci_kbd_enabled, ehci_present, ehci_msc_selftest

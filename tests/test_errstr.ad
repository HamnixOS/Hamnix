# tests/test_errstr.ad
#
# Phase B / M16.93 regression: prove that SYS_ERRSTR (265) hands back
# the per-process error string installed by a preceding failed
# syscall. The fixture is deliberately minimal — one failing
# SYS_OPEN, one SYS_ERRSTR, one SYS_WRITE — so a future agent
# debugging an errstr regression can read this end-to-end in one
# screen.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_errstr.ad -o build/user/test_errstr.elf
#
# Run via scripts/test_errstr.sh, which embeds this binary at
# /bin/test_errstr inside the cpio initramfs and drives it via
# hamsh.
#
# Contract: after SYS_OPEN("/nonexistent/path") returns -ENOENT (-2),
# the next SYS_ERRSTR(buf, 128) copies the kernel-side error into
# `buf` as a NUL-terminated string. We write `buf` to stdout so the
# host-side test script can grep the serial log for the expected
# message.

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    n: uint64 = strlen(s)
    sys_write(fd, s, n)


def main() -> int32:
    # Banner so the host-side grep can also confirm the binary
    # actually ran (independent of the errstr round-trip itself).
    write_str(1, "[test_errstr] start\n")

    # 1. Deliberate failure: open a path that doesn't exist anywhere
    #    in the cpio. SYS_OPEN's lookup miss installs the error
    #    string "file does not exist" via set_current_errstr (see
    #    arch/x86/kernel/syscall.ad). Return value should be -2
    #    (-ENOENT), but the test cares about the side-effect, not
    #    the return code.
    fd: int32 = sys_open("/nonexistent/path")
    if fd >= 0:
        # Defensive: the path really shouldn't exist. If it does, the
        # test environment is broken — bail out loudly so the host
        # script's grep fails in a way that points at the right cause.
        write_str(1, "[test_errstr] unexpected: open succeeded\n")
        return 1

    # 2. Read the error string back. Plan 9 contract: pass a buffer
    #    with a zero first byte for "read only"; the kernel copies
    #    its saved error into our buffer (truncated + NUL-padded).
    buf: Array[128, uint8]
    # Zero buf[0] so we get pure read semantics — no swap-write.
    buf[0] = 0
    rc: int32 = sys_errstr(&buf[0], 128)
    if rc != 0:
        write_str(1, "[test_errstr] sys_errstr failed\n")
        return 2

    # 3. Echo the recovered error to stdout, framed with a label
    #    so the host-side grep can pin the exact line. The kernel
    #    NUL-terminates the buffer, so strlen-walk is safe.
    write_str(1, "[test_errstr] got: ")
    write_str(1, &buf[0])
    write_str(1, "\n")
    write_str(1, "[test_errstr] done\n")
    return 0

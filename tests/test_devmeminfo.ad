# tests/test_devmeminfo.ad
#
# Regression: open /dev/meminfo for read, drain up to 256 bytes, echo
# the captured slice to stdout. The script asserts the captured text
# contains a well-formed "MemTotal: <digits> kB" line.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devmeminfo.ad -o build/user/test_devmeminfo.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Find the first "MemTotal:" occurrence; return the offset of the
# first digit after the colon and any following whitespace, or -1.
def _find_memtotal_digits(buf: Ptr[uint8], n: uint64) -> int64:
    needle: Ptr[uint8] = "MemTotal:"
    nlen: uint64 = 9
    if n < nlen:
        return -1
    i: uint64 = 0
    while i + nlen <= n:
        k: uint64 = 0
        ok: int32 = 1
        while k < nlen:
            if buf[i + k] != needle[k]:
                ok = 0
                k = nlen
            k = k + 1
        if ok != 0:
            j: uint64 = i + nlen
            # Skip any spaces between ':' and the digit run.
            while j < n and buf[j] == 32:
                j = j + 1
            if j < n and buf[j] >= 48 and buf[j] <= 57:
                return cast[int64](j)
            return -1
        i = i + 1
    return -1


# Walk a digit run starting at offset p; require a trailing " kB"
# (Linux-shape suffix). Returns 1 on a well-formed match, 0 otherwise.
def _check_kb_suffix(buf: Ptr[uint8], n: uint64, p: uint64) -> int32:
    digits: uint64 = 0
    while p < n and buf[p] >= 48 and buf[p] <= 57:
        digits = digits + 1
        p = p + 1
    if digits == 0:
        return 0
    if p + 3 > n:
        return 0
    if buf[p] != 32:                          # ' '
        return 0
    if buf[p + 1] != 107:                     # 'k'
        return 0
    if buf[p + 2] != 66:                      # 'B'
        return 0
    return 1


def main() -> int32:
    write_str(1, "[test_devmeminfo] start\n")

    fd: int32 = sys_open("/dev/meminfo")
    if fd < 0:
        write_str(1, "[test_devmeminfo] open failed\n")
        return 1
    write_str(1, "[test_devmeminfo] opened /dev/meminfo OK\n")

    buf: Array[384, uint8]
    n: int64 = sys_read(fd, &buf[0], 256)
    if n <= 0:
        write_str(1, "[test_devmeminfo] read returned <= 0\n")
        sys_close(fd)
        return 1

    write_str(1, "[test_devmeminfo] blob:\n")
    sys_write(1, &buf[0], cast[uint64](n))

    off: int64 = _find_memtotal_digits(&buf[0], cast[uint64](n))
    if off < 0:
        write_str(1, "[test_devmeminfo] MemTotal label missing\n")
        sys_close(fd)
        return 1
    ok: int32 = _check_kb_suffix(&buf[0], cast[uint64](n),
                                 cast[uint64](off))
    if ok == 0:
        write_str(1, "[test_devmeminfo] MemTotal digit/suffix parse FAIL\n")
        sys_close(fd)
        return 1

    # Emit the PASS marker the script greps for. We re-render
    # MemTotal=<digits> kB from the digit run we just validated.
    write_str(1, "[test_devmeminfo] MemTotal=")
    p: uint64 = cast[uint64](off)
    end: uint64 = p
    while end < cast[uint64](n) and buf[end] >= 48 and buf[end] <= 57:
        end = end + 1
    sys_write(1, &buf[p], end - p)
    write_str(1, " kB\n")

    sys_close(fd)
    write_str(1, "[test_devmeminfo] done\n")
    return 0

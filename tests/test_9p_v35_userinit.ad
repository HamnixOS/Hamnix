# tests/test_9p_v35_userinit.ad
#
# V3.5 regression: verifies that the Plan 9 layering shift landed:
#
#   1. Kernel exposes `#X` device aliases (`#s` srv, `#p` proc,
#      `#c` cons, `#/` root-dir slot). They open directly without
#      any namespace binding.
#
#   2. Userspace init's recipe-driven binds make `/srv`, `/proc`, `/n`
#      resolve to the same devices via ns_walk prefix
#      rewrite. This test runs AFTER init has exec'd hamsh, so the
#      root Pgrp's mtab contains the canonical entries (visible
#      through `/proc/<pid>/ns` rendering).
#
# Markers (greppable):
#   [v35-userinit] start
#   [v35-hash-s] OK         -- direct `#s` open works (devsrv dir)
#   [v35-hash-p] OK         -- direct `#p/<pid>/ns` open works (devproc dispatch)
#   [v35-hash-c] OK         -- direct `#c` open works (devcons)
#   [v35-hash-slot] OK      -- direct `#/` open works (root-dir slot)
#   [v35-recipe-srv] OK     -- bound `/srv` opens (resolves through `#s`)
#   [v35-recipe-proc] OK    -- bound `/proc/1/ns` opens (resolves through `#p`)
#   [v35-recipe-n] OK       -- bound `/n` opens (resolves through `#/`)
#   [v35-recipe-text] OK    -- /proc/<self>/ns text shows the three init binds
#   [v35-userinit] PASS

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Top-level scratch (Adder's nested-frame Array bug workaround).
read_buf: Array[2048, uint8]
pid_buf:  Array[24, uint8]
path_buf: Array[64, uint8]


def open_close(path: Ptr[char]) -> int32:
    # Helper: open + immediately close. Returns the open's rc.
    fd: int32 = sys_open(path)
    if fd >= 0:
        sys_close(fd)
    return fd


def contains_substr(buf: Ptr[uint8], buf_len: uint64,
                    needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen(needle)
    if nlen == 0:
        return 1
    if nlen > buf_len:
        return 0
    i: uint64 = 0
    while i + nlen <= buf_len:
        k: uint64 = 0
        matched: int32 = 1
        while k < nlen:
            if buf[i + k] != needle[k]:
                matched = 0
                k = nlen                            # break
            else:
                k = k + 1
        if matched != 0:
            return 1
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[v35-userinit] start\n")

    # ----------------------------------------------------------------
    # Phase 1 — direct `#X` device-alias opens. These work WITHOUT any
    # namespace binding (they hit vfs.ad::_open_hash_alias directly).
    fd: int32 = open_close("#s")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: direct #s open\n")
        return 1
    write_str(1, "[v35-hash-s] OK\n")

    # `#p` bare returns ENOENT by design (no synthetic /proc listing).
    # The real test is `#p/1/ns` (or /status) — we need a known-live
    # pid. Pid 1 is init/hamsh, always alive in this fixture.
    fd = open_close("#p/1/ns")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: direct #p/1/ns open\n")
        return 2
    write_str(1, "[v35-hash-p] OK\n")

    fd = open_close("#c")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: direct #c open\n")
        return 3
    write_str(1, "[v35-hash-c] OK\n")

    fd = open_close("#/")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: direct #/ open\n")
        return 4
    write_str(1, "[v35-hash-slot] OK\n")

    # ----------------------------------------------------------------
    # Phase 2 — recipe-driven binds. After init's recipe_apply, /srv
    # rewrites to `#s`, /proc to `#p`, /n to `#/`. These opens are
    # functionally identical to the Phase 1 set BUT go through
    # ns_walk on the way in — proving the userspace-
    # driven binds wired correctly.
    fd = open_close("/srv")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: /srv open (init bind missing?)\n")
        return 5
    write_str(1, "[v35-recipe-srv] OK\n")

    fd = open_close("/proc/1/ns")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: /proc/1/ns open (init bind missing?)\n")
        return 6
    write_str(1, "[v35-recipe-proc] OK\n")

    fd = open_close("/n")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: /n open (init bind missing?)\n")
        return 7
    write_str(1, "[v35-recipe-n] OK\n")

    # ----------------------------------------------------------------
    # Phase 3 — verify init's recipe is rendered in /proc/1/ns. Three
    # entries should be present: "bind /srv #s", "bind /proc #p",
    # "bind /n #/". The text is rendered by chan.ad::pgrp_render_ns
    # in `bind <from> <to>\n` format where from=mtab.from_path (the
    # `new` arg, i.e. the LHS of bind) and to=mtab.to_path (`old`).
    fd = sys_open("/proc/1/ns")
    if fd < 0:
        write_str(1, "[v35-userinit] FAIL: /proc/1/ns re-open\n")
        return 8
    n: int64 = sys_read(fd, &read_buf[0], 2048)
    sys_close(fd)
    if n <= 0:
        write_str(1, "[v35-userinit] FAIL: /proc/1/ns read empty\n")
        return 9

    nu: uint64 = cast[uint64](n)

    # Must contain all three recipe lines. We use a substring check on
    # the canonical alias strings because the pgrp_render_ns helper
    # emits "bind <from> <to>\n" lines with from = LHS of sys_bind
    # (here "/srv", "/proc", "/n") and to = RHS ("#s", "#p", "#/").
    if contains_substr(&read_buf[0], nu, "bind /srv #s") == 0:
        write_str(1, "[v35-userinit] FAIL: ns missing 'bind /srv #s'\n")
        write_str(1, "[v35-userinit] ns dump=")
        sys_write(1, &read_buf[0], nu)
        write_str(1, "\n")
        return 10
    if contains_substr(&read_buf[0], nu, "bind /proc #p") == 0:
        write_str(1, "[v35-userinit] FAIL: ns missing 'bind /proc #p'\n")
        return 11
    if contains_substr(&read_buf[0], nu, "bind /n #/") == 0:
        write_str(1, "[v35-userinit] FAIL: ns missing 'bind /n #/'\n")
        return 12
    write_str(1, "[v35-recipe-text] OK\n")

    write_str(1, "[v35-userinit] PASS\n")
    return 0

# tests/test_devsysstat.ad
#
# §13 regression for sys/src/9/port/devstat.ad — the /dev/stat cdev,
# which renders Linux /proc/stat-shape text. After §13 the cpu/cpu0
# rows carry a real user/idle split, the "intr" line's total is the
# real IRQ dispatch count, and "ctxt" is the real context-switch
# counter.
#
# The fixture opens /dev/stat, reads the blob, and asserts the
# Linux-shape lines are present:
#   * a line starting "cpu  "   (aggregate row)
#   * a line starting "cpu0 "   (per-cpu row)
#   * a line starting "intr "
#   * a line starting "ctxt "
#   * a line starting "btime "
#   * a line starting "processes "
# It also checks the "ctxt" value is non-zero — the kernel has
# context-switched many times by the time hamsh launches the fixture,
# so a zero there would mean the counter never got wired.
#
# PASS markers (asserted by scripts/test_devsysstat.sh):
#   * "[test_devsysstat] start"
#   * "[test_devsysstat] opened OK"
#   * "[test_devsysstat] lines_ok"
#   * "[test_devsysstat] ctxt_nonzero"
#   * "[test_devsysstat] done"

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


# Return 1 if `needle` appears at the START of any line of buf[0..n].
def _line_starts_with(buf: Ptr[uint8], n: uint64,
                      needle: Ptr[uint8]) -> int32:
    nlen: uint64 = strlen(needle)
    i: uint64 = 0
    at_line_start: uint64 = 1
    while i < n:
        if at_line_start != 0 and i + nlen <= n:
            j: uint64 = 0
            eq: uint64 = 1
            while j < nlen:
                if buf[i + j] != needle[j]:
                    eq = 0
                    j = nlen
                else:
                    j = j + 1
            if eq != 0:
                return 1
        if buf[i] == 10:
            at_line_start = 1
        else:
            at_line_start = 0
        i = i + 1
    return 0


# Find the "ctxt " line and parse the integer that follows. Returns
# the value, or 0 if the line is absent.
def _parse_ctxt(buf: Ptr[uint8], n: uint64) -> uint64:
    i: uint64 = 0
    at_line_start: uint64 = 1
    while i < n:
        if at_line_start != 0 and i + 5 <= n:
            if buf[i] == 99 and buf[i + 1] == 116 \
                    and buf[i + 2] == 120 and buf[i + 3] == 116 \
                    and buf[i + 4] == 32:          # "ctxt "
                k: uint64 = i + 5
                v: uint64 = 0
                while k < n and buf[k] >= 48 and buf[k] <= 57:
                    v = v * 10 + cast[uint64](buf[k] - 48)
                    k = k + 1
                return v
        if buf[i] == 10:
            at_line_start = 1
        else:
            at_line_start = 0
        i = i + 1
    return 0


def main() -> int32:
    write_str(1, "[test_devsysstat] start\n")

    fd: int32 = sys_open("/dev/stat")
    if fd < 0:
        write_str(1, "[test_devsysstat] FAIL: open\n")
        return 1
    write_str(1, "[test_devsysstat] opened OK\n")

    buf: Array[1024, uint8]
    n: int64 = sys_read(fd, &buf[0], 1024)
    sys_close(fd)
    if n <= 0:
        write_str(1, "[test_devsysstat] FAIL: read returned <= 0\n")
        return 1
    un: uint64 = cast[uint64](n)

    write_str(1, "[test_devsysstat] blob:\n")
    sys_write(1, &buf[0], un)
    write_str(1, "\n")

    ok: int32 = 1
    if _line_starts_with(&buf[0], un, "cpu  ") == 0:
        ok = 0
    if _line_starts_with(&buf[0], un, "cpu0 ") == 0:
        ok = 0
    if _line_starts_with(&buf[0], un, "intr ") == 0:
        ok = 0
    if _line_starts_with(&buf[0], un, "ctxt ") == 0:
        ok = 0
    if _line_starts_with(&buf[0], un, "btime ") == 0:
        ok = 0
    if _line_starts_with(&buf[0], un, "processes ") == 0:
        ok = 0
    if ok == 0:
        write_str(1, "[test_devsysstat] FAIL: missing /proc/stat line\n")
        return 1
    write_str(1, "[test_devsysstat] lines_ok\n")

    ctxt: uint64 = _parse_ctxt(&buf[0], un)
    if ctxt == 0:
        write_str(1, "[test_devsysstat] FAIL: ctxt is zero\n")
        return 1
    write_str(1, "[test_devsysstat] ctxt_nonzero\n")

    write_str(1, "[test_devsysstat] done\n")
    return 0

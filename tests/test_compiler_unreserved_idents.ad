# tests/test_compiler_unreserved_idents.ad
#
# Regression fixture proving the previously-reserved identifiers
# `bytes` and `field` parse as ordinary identifiers. Both were dead
# keywords — no parser or codegen consumer ever matched their
# TokenType — but the lexer kept them in the keyword table, which
# made them unusable as parameter names / loop vars / locals.
#
# Quirks doc 2026-06-02: an agent renamed a /proc/PID/stat loop var
# from `field` to `fld` because the lexer rejected `field`. Likewise
# `bytes` was unusable as a count argument (`def write(p, bytes:
# int64)`). Un-reserved in lexer.py; this fixture verifies.

# `field` as a parameter name.
def take_field(field: int64) -> int64:
    return field + 1

# `field` as a loop var.
def sum_fields(n: int64) -> int64:
    total: int64 = 0
    field: int64 = 0
    while field < n:
        total = total + field
        field = field + 1
    return total

# `bytes` as a parameter name (the common "count of bytes" idiom).
def double_bytes(bytes: int64) -> int64:
    return bytes * 2

# `bytes` as a local variable.
def count_up(limit: int64) -> int64:
    bytes: int64 = 0
    while bytes < limit:
        bytes = bytes + 1
    return bytes

# Both at once — the original quirks-doc shape.
def stat_walk(n: int64, bytes: int64) -> int64:
    field: int64 = 0
    out: int64 = bytes
    while field < n:
        out = out + field
        field = field + 1
    return out

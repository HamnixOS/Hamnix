# tests/test_devpid.ad
#
# M16.95 regression: open /dev/pid for read, drain up to 16 bytes,
# echo to stdout. The script asserts the captured slice is a positive
# integer + '\n' — that's the contract devpid_read() promises.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devpid.ad -o build/user/test_devpid.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def main() -> int32:
    write_str(1, "[test_devpid] start\n")

    fd: int32 = sys_open("/dev/pid")
    if fd < 0:
        write_str(1, "[test_devpid] open failed\n")
        return 1

    # pid fits comfortably in 16 bytes (kernel's pid space caps well
    # below 10^14 at this scale). devpid_read appends '\n' itself.
    buf: Array[16, uint8]
    n: int64 = sys_read(fd, &buf[0], 16)
    if n <= 0:
        write_str(1, "[test_devpid] read returned <= 0\n")
        sys_close(fd)
        return 1

    write_str(1, "[test_devpid] pid=")
    sys_write(1, &buf[0], cast[uint64](n))

    sys_close(fd)
    write_str(1, "[test_devpid] done\n")
    return 0

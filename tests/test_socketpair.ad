# tests/test_socketpair.ad
#
# V5 — verify sys_socketpair gives back a BIDIRECTIONAL fd pair.
#
# We don't bother with spawn here: both endpoints live in the same
# task's fd table, so we can just write on fd[0], read on fd[1], then
# write on fd[1] and read on fd[0]. That tests both rings (A→B and
# B→A) end-to-end without needing the spawn-with-shared-socketpair
# story (deferred — spawn dup-into-child doesn't bump socketpair
# refcounts because kernel/sched/core.ad's copy_fd_entry is off-limits
# for this milestone).
#
# Markers grepped by scripts/test_socketpair.sh:
#
#   [socketpair] start
#   [socketpair] alloc OK fd0=N fd1=M
#   [socketpair] forward OK
#   [socketpair] reverse OK
#   [socketpair] close OK
#   [socketpair] PASS

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_errstr(buf: Ptr[uint8], nbuf: uint64) -> int32
extern def sys_socketpair(domain: int32, type: int32, protocol: int32,
                          sv: Ptr[int32]) -> int32

AF_UNIX:     int32 = 1
SOCK_STREAM: int32 = 1

# Top-level scratch buffers (Adder nested-frame Array bug avoidance).
sv:        Array[2, int32]
err_buf:   Array[128, uint8]
read_buf:  Array[16, uint8]
hello_msg: Array[8, uint8]      # "hello"
world_msg: Array[8, uint8]      # "world"


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def dump_errstr(label: Ptr[uint8]):
    sys_errstr(&err_buf[0], 128)
    write_str(1, label)
    write_str(1, &err_buf[0])
    write_str(1, "\n")


def write_dec(fd: int32, value: int64):
    if value < 0:
        sys_write(fd, "-", 1)
        value = -value
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = cast[uint64](value)
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def init_msgs():
    hello_msg[0] = 104                          # 'h'
    hello_msg[1] = 101                          # 'e'
    hello_msg[2] = 108                          # 'l'
    hello_msg[3] = 108                          # 'l'
    hello_msg[4] = 111                          # 'o'
    hello_msg[5] = 0
    world_msg[0] = 119                          # 'w'
    world_msg[1] = 111                          # 'o'
    world_msg[2] = 114                          # 'r'
    world_msg[3] = 108                          # 'l'
    world_msg[4] = 100                          # 'd'
    world_msg[5] = 0


def bytes_equal(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def main() -> int32:
    init_msgs()
    write_str(1, "[socketpair] start\n")

    # 1. Allocate the pair.
    rc: int32 = sys_socketpair(AF_UNIX, SOCK_STREAM, 0, &sv[0])
    if rc < 0:
        dump_errstr("[socketpair] FAIL: sys_socketpair errstr=")
        return 1
    fd0: int32 = sv[0]
    fd1: int32 = sv[1]
    write_str(1, "[socketpair] alloc OK fd0=")
    write_dec(1, cast[int64](fd0))
    write_str(1, " fd1=")
    write_dec(1, cast[int64](fd1))
    write_str(1, "\n")

    # 2. Forward direction: write on fd0, read on fd1.
    n: int64 = sys_write(fd0, &hello_msg[0], 5)
    if n != 5:
        write_str(1, "[socketpair] FAIL: forward write n=")
        write_dec(1, n)
        write_str(1, "\n")
        return 2
    # Zero read_buf so leftover stack noise can't false-positive.
    i: uint64 = 0
    while i < 16:
        read_buf[i] = 0
        i = i + 1
    n = sys_read(fd1, &read_buf[0], 5)
    if n != 5:
        write_str(1, "[socketpair] FAIL: forward read n=")
        write_dec(1, n)
        write_str(1, "\n")
        return 3
    if bytes_equal(&read_buf[0], &hello_msg[0], 5) == 0:
        write_str(1, "[socketpair] FAIL: forward payload mismatch\n")
        return 4
    write_str(1, "[socketpair] forward OK\n")

    # 3. Reverse direction: write on fd1, read on fd0.
    n = sys_write(fd1, &world_msg[0], 5)
    if n != 5:
        write_str(1, "[socketpair] FAIL: reverse write n=")
        write_dec(1, n)
        write_str(1, "\n")
        return 5
    i = 0
    while i < 16:
        read_buf[i] = 0
        i = i + 1
    n = sys_read(fd0, &read_buf[0], 5)
    if n != 5:
        write_str(1, "[socketpair] FAIL: reverse read n=")
        write_dec(1, n)
        write_str(1, "\n")
        return 6
    if bytes_equal(&read_buf[0], &world_msg[0], 5) == 0:
        write_str(1, "[socketpair] FAIL: reverse payload mismatch\n")
        return 7
    write_str(1, "[socketpair] reverse OK\n")

    # 4. Close both ends.
    if sys_close(fd0) < 0:
        dump_errstr("[socketpair] FAIL: close fd0 errstr=")
        return 8
    if sys_close(fd1) < 0:
        dump_errstr("[socketpair] FAIL: close fd1 errstr=")
        return 9
    write_str(1, "[socketpair] close OK\n")

    write_str(1, "[socketpair] PASS\n")
    return 0

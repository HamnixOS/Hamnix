# tests/test_wsys_damage.ad
#
# hamUI compositor hot-path regression: per-window damage / dirty-rect
# tracking + the draw-listing render cache. Exercises the ADDITIVE
# server-side interface added to sys/src/9/port/devwsys.ad:
#
#   /dev/wsys/<N>/serial   ->  "<serial>\n"  (per-window mutation gen)
#   /dev/wsys/damage       ->  "<wid> <serial> <dx0> <dy0> <dx1> <dy1>\n"
#   write to .../serial     =  ACK a composited serial -> clears the rect
#
# All I/O goes through sys_open/sys_read/sys_write directly (no hamsh
# typing), so the assertions are immune to the serial-echo corruption
# that flakes the interactive draw tests under host load.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_wsys_damage.ad -o build/user/test_wsys_damage.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def _bytes_contains(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    nn: uint64 = strlen(needle)
    if nn == 0:
        return 1
    if nn > n:
        return 0
    limit: uint64 = n - nn
    i: uint64 = 0
    while i <= limit:
        j: uint64 = 0
        ok: int32 = 1
        while j < nn:
            if buf[i + j] != needle[j]:
                ok = 0
            j = j + 1
        if ok != 0:
            return 1
        i = i + 1
    return 0


def _read_path(path: Ptr[char], buf: Ptr[uint8], cap: uint64) -> int64:
    fd: int32 = sys_open(path)
    if fd < 0:
        return -1
    total: uint64 = 0
    while total < cap:
        n: int64 = sys_read(fd, &buf[total], cap - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    sys_close(fd)
    return cast[int64](total)


def _write_path(path: Ptr[char], s: Ptr[uint8]) -> int64:
    fd: int32 = sys_open_write(path)
    if fd < 0:
        return -1
    r: int64 = sys_write(fd, s, strlen(s))
    sys_close(fd)
    return r


# Parse the leading decimal of buf as a uint64 (stops at first non-digit).
def _parse_u64(buf: Ptr[uint8], n: uint64) -> uint64:
    v: uint64 = 0
    i: uint64 = 0
    while i < n:
        c: uint8 = buf[i]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c) - 48
        i = i + 1
    return v


def _read_serial(path: Ptr[char]) -> int64:
    # Read "<serial>\n" and return it as an int64, or -1 on read fail.
    b: Array[64, uint8]
    n: int64 = _read_path(path, &b[0], 64)
    if n <= 0:
        return -1
    return cast[int64](_parse_u64(&b[0], cast[uint64](n)))


def main() -> int32:
    write_str(1, "[test_wsys_damage] start\n")
    fails: int32 = 0

    # ---- 1. /dev/wsys/1/serial reads as a decimal (baseline gen) ----
    s0: int64 = _read_serial("/dev/wsys/1/serial")
    if s0 < 0:
        write_str(1, "[test_wsys_damage] serial read FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_wsys_damage] serial_read_ok=1\n")

    # ---- 2. /dev/wsys/damage lists wid 1 ----
    dbuf: Array[1024, uint8]
    dn: int64 = _read_path("/dev/wsys/damage", &dbuf[0], 1024)
    if dn <= 0:
        write_str(1, "[test_wsys_damage] damage read FAIL\n")
        fails = fails + 1
    elif _bytes_contains(&dbuf[0], cast[uint64](dn), "1 ") == 0:
        write_str(1, "[test_wsys_damage] damage missing wid1 FAIL\n")
        fails = fails + 1
    else:
        write_str(1, "[test_wsys_damage] damage_read_ok=1\n")

    # ---- 3. A mutating draw write BUMPS the serial ----
    # Create a layer, then set its geometry — both mutate wid 1's state.
    _write_path("/dev/wsys/1/draw/ctl", "mklayer probe markup 100 50\n")
    s1: int64 = _read_serial("/dev/wsys/1/serial")
    if s1 > s0:
        write_str(1, "[test_wsys_damage] serial_bumped_ok=1\n")
    else:
        write_str(1, "[test_wsys_damage] serial NOT bumped FAIL\n")
        fails = fails + 1

    # ---- 4. The dirty rect now covers the new layer (100x50) ----
    dn2: int64 = _read_path("/dev/wsys/damage", &dbuf[0], 1024)
    if dn2 <= 0:
        write_str(1, "[test_wsys_damage] damage re-read FAIL\n")
        fails = fails + 1
    elif _bytes_contains(&dbuf[0], cast[uint64](dn2),
                         "0 0 100 50") == 0:
        write_str(1, "[test_wsys_damage] dirty rect wrong FAIL: ")
        sys_write(1, &dbuf[0], cast[uint64](dn2))
        fails = fails + 1
    else:
        write_str(1, "[test_wsys_damage] dirty_rect_ok=1\n")

    # ---- 5. Reading serial twice (no write between) is STABLE ----
    # This exercises the listing-cache path: the second draw-listing read
    # at the same serial must reuse the cache and not change anything.
    lbuf: Array[512, uint8]
    _read_path("/dev/wsys/1/draw", &lbuf[0], 512)        # warm cache
    sA: int64 = _read_serial("/dev/wsys/1/serial")
    _read_path("/dev/wsys/1/draw", &lbuf[0], 512)        # cache hit
    sB: int64 = _read_serial("/dev/wsys/1/serial")
    if sA == sB and sA >= 0:
        write_str(1, "[test_wsys_damage] serial_stable_ok=1\n")
    else:
        write_str(1, "[test_wsys_damage] serial unstable FAIL\n")
        fails = fails + 1

    # ---- 6. The cached draw listing still shows the probe layer ----
    ln: int64 = _read_path("/dev/wsys/1/draw", &lbuf[0], 512)
    if ln > 0 and _bytes_contains(&lbuf[0], cast[uint64](ln),
                                  "probe") != 0:
        write_str(1, "[test_wsys_damage] listing_cache_ok=1\n")
    else:
        write_str(1, "[test_wsys_damage] listing cache lost probe FAIL\n")
        fails = fails + 1

    # ---- 7. ACK the current serial -> dirty rect resets to empty ----
    scur: Array[64, uint8]
    sn: int64 = _read_path("/dev/wsys/1/serial", &scur[0], 64)
    if sn > 0:
        # Write the serial bytes back (without the trailing newline is
        # fine; the parser stops at the first non-digit anyway).
        _write_path("/dev/wsys/1/serial", &scur[0])
    dn3: int64 = _read_path("/dev/wsys/damage", &dbuf[0], 1024)
    if dn3 > 0 and _bytes_contains(&dbuf[0], cast[uint64](dn3),
                                   "0 0 0 0") != 0:
        write_str(1, "[test_wsys_damage] ack_clears_rect_ok=1\n")
    else:
        write_str(1, "[test_wsys_damage] ack did NOT clear rect FAIL: ")
        sys_write(1, &dbuf[0], cast[uint64](dn3))
        fails = fails + 1

    if fails == 0:
        write_str(1, "[test_wsys_damage] PASS\n")
    else:
        write_str(1, "[test_wsys_damage] FAIL\n")
    sys_exit(0)
    return 0

# tests/opt/regress_loopcond_cse.ad — regression fixture for the --opt
# LOOP-CONDITION CSE miscompile that hung the graphical desktop (sys_open on a
# directory spun forever in fs/vfs.ad _cpio_listdir_at's basename-length loop
# under HAMNIX_KERNEL_OPT=1).
#
# SHAPE (mirrors the basename scan): a while loop whose CONDITION reads the same
# index expression `s[start + blen]` TWICE (`!= 0 and != '/'`), where `blen` is
# INCREMENTED in the loop body. The Phase-2 local CSE used to treat the repeated
# `start + blen` as a common subexpression, mint `__cse_N = start + blen`, and
# splice that temp into the loop PREHEADER (computed ONCE). Because a while
# condition is re-evaluated every iteration and `blen` changes, the temp went
# STALE — the address never advanced and the loop spun forever.
#
# The gate (scripts/test_opt_loopcond_cse.sh) compiles this both --opt and
# --no-opt, RUNS both, and asserts the --opt build TERMINATES and returns the
# same value as --no-opt (the correct basename length). A regression re-hoists
# the loop-variant index and the --opt build hangs -> the gate times out/fails.

def scan_component(s: Ptr[char], start: uint64) -> uint64:
    # Length of the path component at s[start..] up to the next '/' or NUL.
    blen: uint64 = 0
    while s[start + blen] != 0 and s[start + blen] != 47:   # 47 = '/'
        blen = blen + 1
    return blen


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # "services.d/hamuid.svc" -> the first component is "services.d" (len 10).
    p: Ptr[char] = cast[Ptr[char]]("services.d/hamuid.svc")
    r: uint64 = scan_component(p, cast[uint64](0))
    # Also exercise a nonzero start (the real code scans from nlen+1).
    q: Ptr[char] = cast[Ptr[char]]("/etc/hosts")
    r = r + scan_component(q, cast[uint64](1))              # "etc" -> 3
    return cast[int32](r)                                  # 10 + 3 = 13

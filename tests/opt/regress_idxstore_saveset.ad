# tests/opt/regress_idxstore_saveset.ad — regression fixture for the --opt
# INDEXED-STORE scratch-reservation UNDER-COUNT miscompile (kernel #DF / page-
# allocator free-list corruption).
#
# SHAPE (mirrors mm/page_alloc.ad _pa_set_next): a function with two register-
# promoted pointer params that does an indexed store whose RHS is a pure-arith
# binop reading a param XOR a global constant:
#
#     [node]     = next_val
#     [node + 8] = node ^ CANARY
#
# try_sel_assign_index PARKS the RHS value in an acquired callee-saved scratch
# register (`xr`) across the LEGACY address computation, then computes the RHS
# INTO xr — which acquires ir_scratch_max_live(rhs) MORE scratch. The true
# simultaneous demand is 1 + max_live(rhs); the reservation prescan formerly
# counted only max_live(rhs), leaving the parked `xr` (e.g. %r14) UNSAVED in the
# prologue. That clobbers the caller's live value in that callee-saved register
# — here it leaked the raw CANARY into the caller and scribbled the free list.
#
# The gate (scripts/test_opt_idxstore_saveset.sh) compiles THIS file --opt for
# x86_64-bare-metal with host_ac and asserts the callee-saved save-set covers
# every callee-saved register the function body writes (no unsaved r12..r15/rbx).

CANARY: uint64 = 0x9A1EDEADF2EE1000


def set_next(node: uint64, next_val: uint64):
    cast[Ptr[uint64]](node)[0] = next_val
    cast[Ptr[uint64]](node + 8)[0] = node ^ CANARY

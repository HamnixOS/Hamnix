# tests/test_devproc.ad
#
# Regression for sys/src/9/port/devproc.ad. Exercises the Plan 9
# /proc/<pid>/<file> device family at the smallest meaningful scope:
#
#   1. open /proc/1/status  -> succeed, read & echo the line
#   2. open /proc/1/cwd     -> succeed, read & echo the line
#   3. open /proc/1/stat    -> succeed, read & echo the line (§13:
#                              real Linux-shape /proc/<pid>/stat)
#   4. open /proc/1/cmdline -> succeed, read & echo (§13)
#   5. open /proc/1/maps    -> succeed, read & echo (§13)
#   6. open /proc/999/status -> must FAIL (pid 999 doesn't exist)
#
# Pass criteria (asserted by scripts/test_devproc.sh):
#   * "[test_devproc] start" banner reaches the serial log
#   * "[test_devproc] status=" line shows up with non-empty payload
#   * "[test_devproc] cwd=" line shows up with non-empty payload
#   * "[test_devproc] stat=" line shows up (starts with "1 (")
#   * "[test_devproc] cmdline_ok" / "[test_devproc] maps_ok" appear
#   * "[test_devproc] bad_open_ok" appears (the open of pid 999 was
#     rejected with -1 as required)
#   * "[test_devproc] PASS" lands on stdout (no early-exit)
#
# Build (driven from scripts/test_devproc.sh):
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_devproc.ad -o build/user/test_devproc.elf

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def main() -> int32:
    write_str(1, "[test_devproc] start\n")

    # --- 1. /proc/1/status -----------------------------------------
    # Pid 1 is the first user task — hamsh in this fixture (the test
    # script plants hamsh as /init, so it lands in slot whose pid is
    # next_pid == 1 after sched_init reset the counter). The kernel
    # renders one line: "<pid> <name> <state> <pml4_hex>\n".
    fd: int32 = sys_open("/proc/1/status")
    if fd < 0:
        write_str(1, "[test_devproc] FAIL: cannot open /proc/1/status\n")
        return 1
    buf: Array[128, uint8]
    n: int64 = sys_read(fd, &buf[0], 128)
    if n <= 0:
        write_str(1, "[test_devproc] FAIL: status read returned <= 0\n")
        sys_close(fd)
        return 1
    write_str(1, "[test_devproc] status=")
    sys_write(1, &buf[0], cast[uint64](n))
    # devproc_read appends '\n' itself, so we don't add another.
    sys_close(fd)

    # --- 2. /proc/1/cwd --------------------------------------------
    # Same task, different file. CWD is "/" by default for kernel-
    # spawned user tasks (see _init_fd_table / _inherit_cwd_from_parent
    # in kernel/sched/core.ad — fresh slots get "/" planted before any
    # exec or fork).
    fd = sys_open("/proc/1/cwd")
    if fd < 0:
        write_str(1, "[test_devproc] FAIL: cannot open /proc/1/cwd\n")
        return 1
    buf2: Array[128, uint8]
    n = sys_read(fd, &buf2[0], 128)
    if n <= 0:
        write_str(1, "[test_devproc] FAIL: cwd read returned <= 0\n")
        sys_close(fd)
        return 1
    write_str(1, "[test_devproc] cwd=")
    sys_write(1, &buf2[0], cast[uint64](n))
    sys_close(fd)

    # --- 3. /proc/1/stat (§13: real Linux-shape stat line) ---------
    # devproc now serves /proc/<pid>/stat as the Linux 52-field line
    # "pid (comm) state ppid ...". Field 1 is the pid, so the line
    # must start with "1 (".
    fd = sys_open("/proc/1/stat")
    if fd < 0:
        write_str(1, "[test_devproc] FAIL: cannot open /proc/1/stat\n")
        return 1
    sbuf: Array[256, uint8]
    n = sys_read(fd, &sbuf[0], 256)
    sys_close(fd)
    if n <= 0:
        write_str(1, "[test_devproc] FAIL: stat read returned <= 0\n")
        return 1
    if sbuf[0] != 49 or sbuf[1] != 32 or sbuf[2] != 40:   # "1 ("
        write_str(1, "[test_devproc] FAIL: stat line wrong shape\n")
        return 1
    write_str(1, "[test_devproc] stat=")
    sys_write(1, &sbuf[0], cast[uint64](n))

    # --- 4. /proc/1/cmdline (§13) ----------------------------------
    fd = sys_open("/proc/1/cmdline")
    if fd < 0:
        write_str(1, "[test_devproc] FAIL: cannot open /proc/1/cmdline\n")
        return 1
    cbuf: Array[64, uint8]
    n = sys_read(fd, &cbuf[0], 64)
    sys_close(fd)
    if n <= 0:
        write_str(1, "[test_devproc] FAIL: cmdline read returned <= 0\n")
        return 1
    write_str(1, "[test_devproc] cmdline_ok\n")

    # --- 5. /proc/1/maps (§13) -------------------------------------
    # /proc/<pid>/maps walks the task's VMA list. Pid 1 here is hamsh,
    # an Adder-userland task whose memory is set up by the cpio ELF
    # loader rather than the mm/vma.ad allocator — so its VMA list is
    # empty and maps reads back 0 bytes. That is a VALID empty maps
    # file (a Linux ELF task, which DOES use vma_alloc, would have a
    # populated list). The contract we assert is "the open succeeds
    # and the read does not error" — a negative return is the bug.
    fd = sys_open("/proc/1/maps")
    if fd < 0:
        write_str(1, "[test_devproc] FAIL: cannot open /proc/1/maps\n")
        return 1
    mbuf: Array[512, uint8]
    n = sys_read(fd, &mbuf[0], 512)
    sys_close(fd)
    if n < 0:
        write_str(1, "[test_devproc] FAIL: maps read errored\n")
        return 1
    write_str(1, "[test_devproc] maps_ok\n")

    # --- 6. /proc/999/status (negative case) ------------------------
    # 999 is comfortably above NTASKS=16 even after pid recycling, so
    # task_lookup_by_pid is guaranteed to miss. devproc_open returns
    # -1 + set_current_errstr("no such pid"); vfs_open turns that into
    # the -ENOENT (-2) we expect at the user side. Anything >= 0 is a
    # bug — either devproc accepted a phantom pid or vfs_open lost the
    # error code.
    bad_fd: int32 = sys_open("/proc/999/status")
    if bad_fd >= 0:
        write_str(1, "[test_devproc] FAIL: open /proc/999/status succeeded\n")
        sys_close(bad_fd)
        return 1
    write_str(1, "[test_devproc] bad_open_ok\n")

    write_str(1, "[test_devproc] PASS\n")
    return 0

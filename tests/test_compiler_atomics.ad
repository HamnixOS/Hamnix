# tests/test_compiler_atomics.ad
#
# Fixture for the Adder x86_64 backend's ATOMIC intrinsics
# (codegen_x86.py: gen_io_intrinsic's atomic_* arms):
#
#   atomic_cas32 / atomic_cas64 (addr, expected, desired) -> OLD value
#       LOCK CMPXCHG. The swap happened iff old == expected.
#   atomic_add32 / atomic_add64 (addr, delta) -> OLD value
#       LOCK XADD. Memory ends up holding old + delta.
#
# These are the language-level SMP primitives lib/thread.ad's mutex and
# the kernel's native semaphore path (sys/src/9/port/sems.ad) are built
# on, so they must be REAL LOCK-prefixed read-modify-writes — a
# load/op/store sequence would pass any single-thread test and lose
# updates under contention. The host driver
# (scripts/test_compiler_atomics.sh) therefore checks both:
#
#   1. Single-thread semantics: returned old values, the memory result,
#      the CAS failure path (no write, old returned), 32-bit
#      zero-extension of the returned old value.
#   2. Concurrency: N pthreads hammer at_hammer32/at_hammer64 and a
#      CAS-spinlock-protected NON-atomic increment loop; exact final
#      counts prove no lost updates (the load/op/store version of these
#      intrinsics fails this with near-certainty at these iteration
#      counts).
#
# Addresses are passed as uint64 so the same helpers serve the kernel
# use-shape (operating on a resolved physical address) and the userland
# use-shape (&global cast to uint64).

# --- thin wrappers: expose each intrinsic's raw semantics ------------
def at_cas32(addr: uint64, expected: uint32, desired: uint32) -> uint32:
    return atomic_cas32(addr, expected, desired)


def at_cas64(addr: uint64, expected: uint64, desired: uint64) -> uint64:
    return atomic_cas64(addr, expected, desired)


def at_add32(addr: uint64, delta: uint32) -> uint32:
    return atomic_add32(addr, delta)


def at_add64(addr: uint64, delta: uint64) -> uint64:
    return atomic_add64(addr, delta)


# --- 32-bit zero-extension probe -------------------------------------
# Call atomic_cas32 with an `expected` whose HIGH 32 bits are garbage
# (runtime-constructed so the optimizer can't fold it). On the EQUAL
# path CMPXCHGL leaves %rax untouched, so without the explicit
# zero-extend the garbage would leak into the returned uint32->uint64
# widening. Returns the old value widened to uint64 — the driver
# asserts the high half is zero.
def at_cas32_zext_probe(addr: uint64, lo_expected: uint64,
                        desired: uint32) -> uint64:
    dirty: uint64 = lo_expected + 0xDEADBEEF00000000
    # Truncating cast keeps the low 32 bits == lo_expected, but the
    # 64-bit register holding the expression result carried high bits
    # right up to the intrinsic's marshalling.
    old: uint32 = atomic_cas32(addr, cast[uint32](dirty), desired)
    return cast[uint64](old)


# --- contention hammers -----------------------------------------------
# Each thread of the driver calls these with the SAME addr; exact final
# counts prove atomicity.
def at_hammer32(addr: uint64, iters: uint64):
    i: uint64 = 0
    while i < iters:
        atomic_add32(addr, 1)
        i = i + 1


def at_hammer64(addr: uint64, iters: uint64):
    i: uint64 = 0
    while i < iters:
        atomic_add64(addr, 1)
        i = i + 1


# --- CAS spinlock protecting a NON-atomic increment -------------------
# The increment itself is a plain load/add/store; only the CAS lock
# makes it safe. Exact final counts prove atomic_cas32 really provides
# mutual exclusion (the exact shape lib/thread.ad's mutex fast path
# uses).
def at_locked_hammer(counter_addr: uint64, lock_addr: uint64,
                     iters: uint64):
    i: uint64 = 0
    while i < iters:
        # Acquire: spin until 0 -> 1 succeeds.
        while atomic_cas32(lock_addr, 0, 1) != 0:
            asm_volatile("pause")
        # Critical section: deliberately non-atomic RMW.
        c: Ptr[uint64] = cast[Ptr[uint64]](counter_addr)
        c[0] = c[0] + 1
        # Release: plain store is fine on x86 (TSO), but use CAS for a
        # full-fence release so the test also exercises the 1 -> 0 edge.
        atomic_cas32(lock_addr, 1, 0)
        i = i + 1

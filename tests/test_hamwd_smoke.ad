# tests/test_hamwd_smoke.ad
#
# Phase D smoke fixture for hamwd (user/hamwd.ad). Two assertions:
#
#   1. The CLIENT CALL SHAPE works end-to-end. A would-be hamwd
#      consumer follows docs/native-api.md's "canonical pattern for
#      service consumers":
#
#          fd = open("/srv/hamwd", ORDWR)
#          mount(fd, -1, "/dev/win", MREPL, "")
#          close(fd)
#          /dev/win/* is now backed by the hamwd daemon
#
#      In the Phase D skeleton commit, /srv/hamwd does not yet exist
#      as a real Plan 9 srv post (kernel-side /srv tmpfs + 9P client
#      behind the srvfd are Phase D follow-ups — see hamwd.ad's GAP
#      section). What this fixture validates today is that the
#      mount(srvfd, ...) call shape is wired and the chan resolver
#      records the SRV-kind binding without errors. That's the same
#      contract M16.107 + test_p9mount.ad exercised; we re-exercise
#      it under the /dev/win mount point to prove the bind/mount/
#      unmount cycle a future Layer-3 GUI client would use is in
#      place. The real srvfd-routed 9P walk is GAP, not silent
#      pretend-success — see hamwd.ad's header for the route plan.
#
#   2. The smoke fixture writes a line resembling what a real client
#      would write to /dev/win/ctl ("create 800 600 \"Test\"") to
#      stderr so the test script can see the call-shape evidence in
#      the log. The actual wire-side VTNext frame is emitted by
#      `/bin/hamwd create 800 600 Test` later in the same boot,
#      driven by the bash harness.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       tests/test_hamwd_smoke.ad -o build/user/test_hamwd_smoke.elf
#
# PASS markers grepped by scripts/test_hamwd.sh:
#   [hamwd-smoke] start
#   [hamwd-smoke] mount srvfd ok
#   [hamwd-smoke] unmount /dev/win ok
#   [hamwd-smoke] PASS

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_close(fd: int32) -> int32
extern def syscall6(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64


SYS_MOUNT:   uint64 = 258
SYS_UNMOUNT: uint64 = 259

MREPL: int32 = 0


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def write_str(fd: int32, s: Ptr[uint8]):
    sys_write(fd, s, strlen(s))


def write_dec(fd: int32, value: uint64):
    if value == 0:
        sys_write(fd, "0", 1)
        return
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    out: Array[24, uint8]
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    sys_write(fd, &out[0], i)


def main() -> int32:
    write_str(1, "[hamwd-smoke] start\n")

    # 1) Acquire a srvfd. Phase D's real story: open /srv/hamwd that
    # hamwd has posted. We do not have that yet — the kernel's /srv
    # tmpfs surface is a TODO follow-up. Borrow the same shape
    # test_p9mount.ad uses: open ANY existing file to get a real fd,
    # use that as the srvfd argument. The mount call stores the int;
    # Phase D's chan resolver will be the consumer once it learns to
    # walk a SRV-kind chan through the stored fd.
    sfd: int32 = sys_open("/etc/motd")
    if sfd < 0:
        write_str(1, "[hamwd-smoke] FAIL: no fd to use as srvfd\n")
        return 1
    write_str(1, "[hamwd-smoke] borrowed srvfd from /etc/motd, fd=")
    write_dec(1, cast[uint64](sfd))
    write_str(1, "\n")

    # 2) mount(srvfd, -1, "/dev/win", MREPL, "") — the canonical
    # client call from docs/native-api.md "service consumers" block.
    # In Phase C/D the kernel records the SRV-kind chan binding at
    # /dev/win; resolve_path skips SRV mounts because the 9P client
    # behind srvfd doesn't speak Tversion/Tattach yet (Phase D
    # follow-up). Today's assertion is "mount() accepted the call
    # shape" — once the chan resolver learns to round-trip the
    # srvfd, this same syscall starts driving real 9P traffic.
    rc: int64 = syscall6(SYS_MOUNT,
                         cast[uint64](sfd),
                         cast[uint64](-1),
                         cast[uint64](&"/dev/win"[0]),
                         cast[uint64](MREPL),
                         cast[uint64](&""[0]),
                         0)
    if rc != 0:
        write_str(1, "[hamwd-smoke] FAIL: mount returned ")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        sys_close(sfd)
        return 2
    write_str(1, "[hamwd-smoke] mount srvfd ok\n")

    # 3) Demonstrate the call-shape a future ctl-file client would
    # use. With real srv-routing, this becomes
    #    cfd = open("/dev/win/ctl", ORDWR); write(cfd, ...); ...
    # For the skeleton commit we just print the line that would
    # have been written — the bash harness later invokes /bin/hamwd
    # with the same payload to exercise the actual wire-emission
    # path.
    write_str(2, "[hamwd-smoke] would-write to /dev/win/ctl: ")
    write_str(2, "create 800 600 \"Test\"\n")

    # 4) unmount /dev/win — Plan 9 namespace teardown. NULL `new`
    # removes every binding at /dev/win in the calling task's
    # namespace.
    rc = syscall6(SYS_UNMOUNT,
                  0,
                  cast[uint64](&"/dev/win"[0]),
                  0, 0, 0, 0)
    if rc != 0:
        write_str(1, "[hamwd-smoke] FAIL: unmount returned ")
        write_dec(1, cast[uint64](rc))
        write_str(1, "\n")
        sys_close(sfd)
        return 3
    write_str(1, "[hamwd-smoke] unmount /dev/win ok\n")
    sys_close(sfd)

    write_str(1, "[hamwd-smoke] PASS\n")
    return 0

# tests/test_compiler_bool_shortcircuit.ad
#
# Regression fixture for the Adder x86_64 backend's logical-operator
# lowering (codegen_x86.py: gen_short_circuit).
#
# It exercises compound boolean conditions that join two DIFFERENT
# comparison operators with `or`/`and` — the shape that an ext4 agent
# reported mis-evaluating (`func() <= 0 or x != y`, `a == 0 or a != b`
# took the TRUE branch even when both sub-conditions were false).
#
# The root cause was that `and`/`or` lowered to an unconditional
# bitwise fold of BOTH operands (no short-circuit, right-before-left
# order). That diverges from Python whenever the right operand has a
# side effect / fault / state read that should only happen when the
# left operand didn't already decide the result — which is exactly why
# "splitting the condition into two separate `if`s" behaved differently.
#
# Each function returns 1 if its condition is TRUE and 0 otherwise, so
# the host driver (scripts/test_compiler_bool_shortcircuit.sh) can assert
# the taken branch against a Python-evaluated truth table. The driver
# also supplies a `boom()` extern that aborts if called, proving the
# right operand is genuinely skipped when the left short-circuits.

extern def boom() -> int64

# --- short-circuit proofs (right operand must NOT be evaluated) ------

# `or`: when a != 0, boom() must not be called.
def or_shortcircuit(a: int64) -> int64:
    if a != 0 or boom() != 0:
        return 1
    return 0

# `and`: when a == 0, boom() must not be called.
def and_shortcircuit(a: int64) -> int64:
    if a != 0 and boom() != 0:
        return 1
    return 0

# --- mixed-operator `or` truth tables -------------------------------

# `==` + `!=`  (the reported `a == 0 or a != b`).
def or_eq_neq(a: int64, b: int64) -> int64:
    if a == 0 or a != b:
        return 1
    return 0

# `<=` + `!=`  (the reported `func() <= 0 or x != y`, both runtime vars).
def or_le_neq(a: int64, b: int64, c: int64) -> int64:
    if a <= 0 or b != c:
        return 1
    return 0

# `<` + `>=`  (both operands runtime variables).
def or_lt_ge(a: int64, b: int64, c: int64, d: int64) -> int64:
    if a < b or c >= d:
        return 1
    return 0

# --- mixed-operator `and` truth table -------------------------------

def and_gt_neq(a: int64, b: int64, c: int64) -> int64:
    if a > 0 and b != c:
        return 1
    return 0

# --- nested `(a or b) and c` ----------------------------------------

def nested_or_and(a: int64, b: int64, c: int64) -> int64:
    if (a == 0 or a != b) and c > 0:
        return 1
    return 0

# --- three-term `or` chain with three different operators -----------

def three_or(a: int64, b: int64, c: int64) -> int64:
    if a < 0 or b >= 10 or c != 0:
        return 1
    return 0

# --- unsigned operands (exercise the unsigned setcc family) ---------

def or_unsigned(a: uint64, b: uint64) -> int64:
    if a == 0 or a != b:
        return 1
    return 0

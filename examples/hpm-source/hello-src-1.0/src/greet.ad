# examples/hpm-source/hello-src-1.0/src/greet.ad
#
# Example program for the native SOURCE package `hello-src` (#186).
#
# This .ad ships as SOURCE in an hpm source package — there is NO
# prebuilt binary in the tarball. `hpm install hello-src` compiles this
# file ON-BOX with Hamnix's self-hosted Adder compiler (via /bin/adder_cc)
# and installs the resulting binary.
#
# main() prints an unforgeable marker to stdout (fd 1) and exits with a
# distinctive status (137). Both the printed marker and the exit code are
# witnesses that this source was compiled-then-run on the box: the marker
# string is interned into the program's .data by the codegen, and the
# exit code is main()'s return value (the elf_emit _start stub exits with
# it). The program is deliberately tiny so it stays well within the
# self-hosted backend's CODE_CAP.
#
# Syscalls are issued via the self-hosted compiler's inline __syscallN
# builtins (it has no extern/libc linkage). Hamnix SYS_WRITE = 8, args
# a0=fd a1=buf a2=count (arch/x86/kernel/syscall.ad).

def main() -> int32:
    msg: Ptr[uint8] = "HELLO_SRC_ONBOX_BUILT_OK\n"
    __syscall3(8, 1, cast[uint64](msg), 25)
    return 137

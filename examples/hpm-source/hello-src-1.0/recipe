# recipe — hpm source-package build manifest (#186)
#
# Declares how hpm compiles this package ON-BOX at install time using
# Hamnix's self-hosted Adder compiler (/bin/adder_cc). The package ships
# its .ad SOURCE (under src/) and NO prebuilt binary; hpm compiles each
# `build` directive into files/<out> and installs it at the target.
#
# Grammar:
#   build <src-rel> <out-rel>   compile <staging>/<src-rel> into
#                               <staging>/files/<out-rel>, then install
#                               at <target>/<out-rel>
#   cache yes|no                (default yes) reuse a prebuilt
#                               files/<out-rel> shipped in the tarball
#                               instead of compiling, when present
#
# <src-rel> is relative to the package root; <out-rel> is relative to
# files/ (i.e. the install path under the package's target).

build src/greet.ad var/lib/hello-src-greet
cache yes

# /etc/profile - system-wide environment and startup programs
# Sourced by login shells. Keep this file POSIX-ish.
#
# NOTE: hamsh does not yet implement `export` or parameter expansion of
# variables like $USER; this file documents the intended login-time setup
# so it is in place when those features land.

PATH=/bin:/sbin:/usr/bin
export PATH

UMASK=022
export UMASK

echo Welcome, $USER!

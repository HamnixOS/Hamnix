# /etc/rc — runs at hamsh startup, before the first prompt.
# Lines starting with '#' are comments. Anything else is fed
# through the same parser the interactive shell uses.

motd
echo
echo Hamnix is ready.
echo Try: ls /bin     to see installed commands
echo      cat /etc/os-release    for system info
echo      cat /proc/uptime       for uptime
echo

# /etc/passwd — Hamnix user table per docs/security.md.
#
# Format: name:passwd:uid:gid:gecos:home:shell  (standard 7-field
# passwd(5)). The passwd field is always `x` (hashes live in
# /etc/shadow); gecos is left empty. This is the SAME file bound into
# the Linux namespace, so busybox/glibc/apt parse it directly.
#
# uid 0 doesn't exist in Hamnix (the "root" idiom is gone). uid 1 is
# the SINGLE hostowner. 2..999 are reserved for system services. 1000+
# are regular users (assigned by the installer or by the hostowner).
#
# /etc/shadow stores password hashes ($6$<salt>$<sha-512-crypt>).
#
# The live ISO ships with hostowner `live` / password `hamnix`; the
# installer replaces this with the user's chosen username + password
# during install (see etc/install.hamsh).
live:x:1:1::/home/live:/bin/hamsh
sshd:x:2:2::/var/empty:/bin/false
hamsh-svc:x:3:3::/var/empty:/bin/false
dave:x:1000:1000::/home/dave:/bin/hamsh
nobody:x:65534:65534::/nonexistent:/bin/false

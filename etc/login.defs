# /etc/login.defs - shadow password suite configuration
#
# Password aging controls and default permissions for new sessions.

PASS_MAX_DAYS   99999
PASS_MIN_DAYS   0
PASS_WARN_AGE   7

UID_MIN         1000
UID_MAX         60000
GID_MIN         1000
GID_MAX         60000

UMASK           022

LOGIN_RETRIES   3
LOGIN_TIMEOUT   60

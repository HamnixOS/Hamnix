# /etc/rc.d/rc.0 — runlevel 0 (halt / poweroff) operator hook.
#
# Sourced by PID-1 hamsh's svc_enter_runlevel(0) BEFORE the built-in
# stop-all + poweroff action (which writes "poweroff" to /dev/reboot).
# Put any pre-shutdown work here — flush caches, sync remote mounts,
# notify peers. Do NOT call `init`/`svc runlevel` from this file: the
# transition is already in progress and would recurse (the supervisor
# guards against it, but the call is a no-op anyway). Edit freely; on a
# writable root the change persists across reboots.
echo '[rc.0] runlevel 0 hook: preparing for shutdown'

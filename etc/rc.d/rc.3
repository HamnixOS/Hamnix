# /etc/rc.d/rc.3 — runlevel 3 (multi-user) operator hook.
#
# Runlevel 3 is the DEFAULT multi-user level. svc_enter_runlevel(3)
# automatically starts every enabled service whose `runlevel:` mask
# includes 3 (see /etc/services.d/<name>.svc). This file is sourced
# alongside that built-in action for any extra, non-declarative startup
# an operator wants to layer on (one-shot setup, custom binds, ...).
# Do NOT call `init`/`svc runlevel` here. Edit freely.
echo '[rc.3] runlevel 3 hook: multi-user services up'

# /etc/rc.d/rc.5 — runlevel 5 (graphical / hamUI) operator hook.
#
# Runlevel 5 is multi-user + graphical. svc_enter_runlevel(5) sources
# THIS file first, then starts every enabled service whose `runlevel:`
# mask includes 5.
#
# The hamUI display server (hamUId) is now brought up by the DECLARATIVE
# service supervisor, NOT an imperative spawn here: /etc/services.d/
# hamuid.svc declares `enabled: yes` + `runlevel: 5`, so PID-1's
# supervisor auto-starts it on entry to runlevel 5 (and tracks/restarts
# it under `service hamuid status`). That replaces the old detached
# `spawn guishell { hamUId daemon }` block — keeping a single source of
# truth for the daemon and giving the operator real `service` ergonomics
# (status/stop/restart) over the DE.
echo '[rc.5] runlevel 5 hook: hamUI stack started by supervisor (services.d/hamuid.svc)'

# --- SCENE-FILE DE (docs/de_scene_file_arch.md) ----------------------
# The kernel scene compositor owns /dev/fb at runlevel 5 (the legacy
# hamUId procedural present is retired). The desktop is blank until
# clients write scenes, so launch the scene PANEL and a scene TERMINAL
# here. Each is an ordinary scene client: it `newwindow`s, writes a text
# display list to /dev/wsys/<wid>/scene, and pokes commit; the kernel
# rasterizes + z-blits it.
#
# Latch the kernel scene compositor as the SOLE /dev/fb owner FIRST, in
# rc.5's MAIN body (PID-1's ambient namespace, where rc.boot already bound
# `#c /dev`), so the `desktop` write reliably reaches the wsys server —
# unlike a fresh detached spawn whose empty namespace would route it to a
# tmpfs file. Thereafter every full present paints the desktop root
# backdrop and the boot console is suspended. Independent of hamuid.svc.
echo 'desktop' > '/dev/wsys/ctl'
echo '[scene_de] kernel scene compositor owns /dev/fb (rl5 flip)'

# Launch the scene clients in an OVERLAY of PID-1's ambient namespace
# (`ns {}` with RFNAMEG inherits PID 1's binds, incl. rc.boot's
# `bind '#c' /dev`), so /dev/wsys/ctl resolves to the wsys SERVER — not a
# tmpfs file. The clients self-`bind '#c' /dev` too (idempotent). This is
# the same ambient-overlay shape the legacy visual-gate uses to reach
# /dev/wsys.
#
# Launch the DESKTOP BACKDROP first (EARLY) so its full-screen window is
# created at the LOWEST z and every later client (panel, terminal, FM)
# stacks ABOVE it. hamdesktop paints the teal backdrop + a MATE-style
# column of clickable launcher icons (Files / Terminal / Home) read from
# /etc/desktop.icons; double-click spawns the target the same way the
# panel launches apps.
scenedeskns = ns {
}
scenedesksvc = spawn detached scenedeskns {
    /bin/hamdesktop
}
echo '[scene_de] launching desktop icons (scene path)'
# The panel's namespace additionally READ-binds the Debian/Linux-namespace
# root at /n/linux, reusing the SAME `#distro` file-server primitive that
# `enter linux { bind '#distro' / }` uses. This exposes the installed Linux
# apps' freedesktop catalogue at /n/linux/usr/share/applications so
# hampanelscene's _load_apps() can surface them in the menu's "Linux"
# section. `#/` is already bound at /n by rc.boot (inherited via this ns
# overlay); we bind `#distro` onto /n/linux under it. This is a per-process
# namespace BIND (Plan 9 shape), NOT a global mount, and it is the read side
# of the distro tree — the panel only ever opens/reads it (never writes).
# #69: the bind is KERNEL-ENFORCED read-only (`bind -r`): a stray write /
# create / remove through /n/linux is denied with EROFS at the resolve
# boundary, so the Linux root is genuinely immutable through the native
# namespace VIEW. The distro server's OWN writes (inside `enter linux`,
# where `#distro` is bound at / WITHOUT -r) are unaffected — the flag is
# on this VIEW binding, not the underlying file server.
scenepanelns = ns {
    bind '#/' /n
    bind -r '#distro' /n/linux
}
scenepanelsvc = spawn detached scenepanelns {
    /bin/hampanelscene
}
echo '[scene_de] launching panel (scene path; #distro read-bound at /n/linux)'

# --- COLD-START PRE-WARM (perf: first-terminal cold-start lag) --------
# SYMPTOM: the FIRST DE terminal opened after boot is laggy (2nd keystroke
# ~0.2s late, `pwd`/first command ~0.5s); closing it and opening a NEW one
# is fast. ROOT CAUSE: a fresh terminal spawns `/bin/hamsh /etc/rc.de-user`,
# and that hamsh (plus the first external commands it runs, e.g. /bin/ls)
# is read COLD off the root fs — a MISS in the block buffer cache
# (kernel/block/blk.ad) and ext4 page cache (fs/fcache.ad) -> a real disk /
# fileserver round-trip. The SECOND terminal reuses those now-cached pages,
# so it is fast; the shell's cold rc-sourcing also bleeds into the first few
# keystrokes of the first terminal.
#
# FIX: prime those caches ONCE here, SYNCHRONOUSLY, BEFORE launching the
# scene terminal, by running the SAME read set the terminal will. Spawn
# /bin/hamsh to source /etc/rc.de-user (warming the hamsh image, the rc
# script, and the namespace bind path resolutions in the dentry/inode
# caches) with HAMNIX_DE_PROG=/bin/ls ARG1=/ so it runs `ls /` (warming
# /bin/ls) and then `exit`s (rc.de-user's tail execs $HAMNIX_DE_PROG and
# exits) rather than dropping into an interactive REPL. This command runs in
# PID-1's rc, so rc.5 BLOCKS until the pre-warm child exits — guaranteeing
# the caches are hot when the terminal's own hamsh execs next. Output is
# discarded so it does not spam the console. `pwd` is now a hamsh builtin,
# so it needs no binary pre-warm. Cost: one extra sub-second cold spawn at
# boot, invisible to the user; payoff: the first terminal is as fast as the
# second.
echo '[scene_de] pre-warming shell + command cache'
/bin/hamsh /etc/rc.de-user /bin/ls / > /dev/null
echo '[scene_de] pre-warm done'

scenetermns = ns {
}
scenetermsvc = spawn detached scenetermns {
    /bin/hamtermscene
}
echo '[scene_de] launching terminal (scene path)'
scenefmns = ns {
}
scenefmsvc = spawn detached scenefmns {
    /bin/hamfmscene
}
echo '[scene_de] launching file manager (scene path)'
# Scene-DE applications: a GUI calculator + a text editor, each in its own
# namespace exactly like the terminal / file manager above (the working
# scene-client launch path — NOT the detached /dev/wsys/run/launch queue,
# which the known DE apps-no-render bug leaves window-less). These give the
# scene desktop real, clickable apps on every graphical boot.
scenecalcns = ns {
}
scenecalcsvc = spawn detached scenecalcns {
    /bin/hamcalcscene
}
echo '[scene_de] launching calculator (scene path)'
sceneeditns = ns {
}
sceneeditsvc = spawn detached sceneeditns {
    /bin/hameditscene
}
echo '[scene_de] launching text editor (scene path)'

# --- VISUAL REGRESSION GATE (always-on perf + render proof) ----------
# Spawn a detached "visual gate" runner that waits for the DE to settle,
# then:
#   (1) Drives the cursor by writing absolute-move lines to /dev/mouse
#       (the canonical Plan 9 writable-mouse capability) over ~2s. The
#       compositor emits `[de_perf] cursor_fps=N` once per second from its
#       own cursor-present counter (A.1 consolidation) — no injection verb
#       owns the number, and the signal is a free-standing artifact of
#       every graphical boot. scripts/test_de_cursor_nudge.sh greps it.
#   (2) Sequences each hamui app one at a time, emitting
#       `[visual_gate] launching <name>` BEFORE spawn and
#       `[visual_gate] launched  <name>` AFTER a settle, so a host-side
#       harness watching the serial log can screendump the framebuffer
#       between each marker pair and PROVE every app actually rendered
#       pixels. Detached so PID 1's svc_enter_runlevel does not block.
# Use the boot ambient namespace directly — no template, no clean reset.
# RFNAMEG (overlay) inherits PID 1's binds (`bind '#c' /dev`, etc.) so
# `/dev/wsys/ctl` resolves to `#c/wsys/ctl` exactly as PID 1 sees it.
visualbootns = ns {
}
visualgatesvc = spawn detached visualbootns {
    # Let hamuid open its windows, plant the wallpaper, and run the
    # autostart hook before we start measuring. 6s matches the paint
    # window used by scripts/test_de_screenshot.sh.
    sleep 6
    echo '[visual_gate] start'

    # ---- RAM footprint readout (before apps) ----
    # Capture free RAM with only the base DE session up (compositor +
    # desktop + panel + the rc.5 scene clients). Greppable marker so the
    # host harness can prove the resident-memory reduction.
    echo '[mem_gate] before_apps'
    free

    # ---- cursor FPS measurement ----
    # Drive the cursor by writing ABSOLUTE-move lines to /dev/mouse:
    # "<ax> <ay> <buttons> <dz> <abs>" with abs=1 → ax/ay are 0..32767
    # tablet coordinates pushed via mouse_rx_push_abs (devmouse_write).
    # This is the canonical Plan 9 writable-mouse path; the retired
    # nudge/drag ctl verbs drove the SAME queue. The compositor's own
    # once-per-second `[de_perf] cursor_fps=N` line reports the refresh
    # rate (A.1) — no report verb needed. Flat fixed-shape echo lines
    # (hamsh while-loop + redirect in the body was unreliable on this build).
    echo '[visual_gate] nudge_begin'
    echo '[visual_gate] after_first_report'
    echo '3200 3200 0 0 1' > '/dev/mouse'
    echo '[visual_gate] after_nudge1'
    echo '6400 6400 0 0 1' > '/dev/mouse'
    echo '9600 9600 0 0 1' > '/dev/mouse'
    echo '12800 12800 0 0 1' > '/dev/mouse'
    echo '16000 16000 0 0 1' > '/dev/mouse'
    sleep 1
    echo '19200 19200 0 0 1' > '/dev/mouse'
    echo '22400 22400 0 0 1' > '/dev/mouse'
    echo '25600 25600 0 0 1' > '/dev/mouse'
    echo '28800 28800 0 0 1' > '/dev/mouse'
    echo '32000 32000 0 0 1' > '/dev/mouse'
    sleep 1
    echo '[visual_gate] nudge_done'

    # ---- per-app render proof (#99: launch-queue rendering) ----
    # For each app the host harness wants visually verified, emit a
    # BEFORE marker (host screendumps the bare desktop), launch the app
    # THROUGH THE REAL DE LAUNCH QUEUE, wait for it to paint, then emit an
    # AFTER marker (host screendumps again — if the two PNGs show no new
    # pixels in the window region the app rendered nothing and the gate
    # fails).
    #
    # THE PATH UNDER TEST (#99): `echo /bin/<app> > /dev/wsys/run/launch`
    # bumps the kernel run-launch serial; the PANEL (hampanelscene), a live
    # scene client, drains that queue every main-loop tick and spawns the
    # prog via its _launch (spawn_detached) path — the SAME path its
    # Applications menu uses. The spawned app inherits the panel's capable
    # namespace (`#c /dev` → /dev/wsys resolves), self-`newwindow`s an owned
    # wid (kernel emits `[devwsys] window <wid> mapped pid=<pid>`), writes
    # its scene display list, and the kernel scene compositor composites it.
    # Before this fix hamUId drained the queue, but hamUId's present loop is
    # RETIRED in the scene-file DE (it exits right after the rl5 `desktop`
    # flip), so NOTHING drained the queue and launched apps never appeared.
    #
    # Only genuinely-windowed hamui apps are exercised here: hamclock,
    # hamcalc, hammon each call hamui_window() (self-allocate an owned
    # top-level) and paint immediately. hamfm (a TUI that draws ANSI to
    # stdout), hamshot (a screenshot tool) and hamnotify (a fire-and-forget
    # notification poster) create NO wsys window, so they are not render
    # targets. hamctl (Control Center) IS a hamui window app but has an
    # app-specific init (wallpaper/audio enumeration) that does not paint
    # under the detached-stdio launch — a known separate gap tracked apart
    # from the #99 launch-path fix, so it is not gated here.
    echo '[visual_gate] launching hamclock'
    sleep 1
    echo '/bin/hamclock' > '/dev/wsys/run/launch'
    sleep 3
    echo '[visual_gate] launched hamclock'
    sleep 1
    echo '[visual_gate] launching hamcalc'
    sleep 1
    echo '/bin/hamcalc' > '/dev/wsys/run/launch'
    sleep 3
    echo '[visual_gate] launched hamcalc'
    sleep 1
    echo '[visual_gate] launching hammon'
    sleep 1
    echo '/bin/hammon' > '/dev/wsys/run/launch'
    sleep 3
    echo '[visual_gate] launched hammon'
    sleep 1

    # ---- RAM footprint readout (after apps) ----
    # Same meminfo dump with the full app set resident. before/after
    # MemFree delta = the DE app-set working set; the absolute MemFree
    # here is the headroom left under -m 1G.
    echo '[mem_gate] after_apps'
    free

    echo '[visual_gate] done'
}

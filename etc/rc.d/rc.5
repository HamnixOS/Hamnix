# /etc/rc.d/rc.5 — runlevel 5 (graphical / hamUI) operator hook.
#
# Runlevel 5 is multi-user + graphical. svc_enter_runlevel(5) first
# starts every enabled service whose `runlevel:` mask includes 5, then
# sources this file. We bring up the hamUI display stack here: the
# hamUId renderer daemon owns /dev/fb and composites window surfaces.
#
# It is launched DETACHED so a missing/!ready framebuffer can never
# wedge the runlevel transition (the same resilience pattern rc.boot
# uses for ifconfig/ntpd). On a headless QEMU boot with no GOP the
# daemon simply reports it could not open /dev/fb and exits; the
# transition still completes and the prompt returns.
#
# Do NOT call `init`/`svc runlevel` from this file. Edit freely.
echo '[rc.5] runlevel 5 hook: bringing up hamUI graphical stack'
guishell = ns {
}
hamuisvc = spawn detached guishell {
    hamUId daemon
}
echo '[rc.5] hamUId daemon spawned (detached)'

# /etc/rc.d/rc.5 — runlevel 5 (graphical / hamUI) operator hook.
#
# Runlevel 5 is multi-user + graphical. svc_enter_runlevel(5) sources
# THIS file first, then starts every enabled service whose `runlevel:`
# mask includes 5.
#
# The hamUI display server (hamUId) is now brought up by the DECLARATIVE
# service supervisor, NOT an imperative spawn here: /etc/services.d/
# hamuid.svc declares `enabled: yes` + `runlevel: 5`, so PID-1's
# supervisor auto-starts it on entry to runlevel 5 (and tracks/restarts
# it under `service hamuid status`). That replaces the old detached
# `spawn guishell { hamUId daemon }` block — keeping a single source of
# truth for the daemon and giving the operator real `service` ergonomics
# (status/stop/restart) over the DE.
echo '[rc.5] runlevel 5 hook: hamUI stack started by supervisor (services.d/hamuid.svc)'

# --- VISUAL REGRESSION GATE (always-on perf + render proof) ----------
# Spawn a detached "visual gate" runner that waits for the DE to settle,
# then:
#   (1) Bangs 100 `nudge` writes at /dev/wsys/ctl over ~2s and emits
#       `[de_perf] cursor_fps=N` via the `nudge_report` verb — the same
#       cursor refresh signal scripts/test_de_cursor_nudge.sh measures,
#       now produced as a free-standing artifact of every graphical boot.
#   (2) Sequences each hamui app one at a time, emitting
#       `[visual_gate] launching <name>` BEFORE spawn and
#       `[visual_gate] launched  <name>` AFTER a settle, so a host-side
#       harness watching the serial log can screendump the framebuffer
#       between each marker pair and PROVE every app actually rendered
#       pixels. Detached so PID 1's svc_enter_runlevel does not block.
visualgatens = ns {
}
visualgatesvc = spawn detached visualgatens {
    # Let hamuid open its windows, plant the wallpaper, and run the
    # autostart hook before we start measuring. 6s matches the paint
    # window used by scripts/test_de_screenshot.sh.
    sleep 6
    echo '[visual_gate] start'

    # ---- cursor FPS measurement ----
    # 100 nudges with a 20ms gap = ~2s injection window; matches the
    # parameters scripts/test_de_cursor_nudge.sh injects. Reset counters
    # with an initial `nudge_report`, bang the events, then re-report:
    # the kernel emits `[de_perf] cursor_fps=N consumed=X` on the serial
    # log between the two reports.
    echo '[visual_gate] nudge_begin'
    echo nudge_report > /dev/wsys/ctl
    # /bin/sleep is integer-second only — instead of one sleep per nudge,
    # we fire small bursts and sleep 1s between bursts: 10 bursts of 10
    # = 100 events over ~10s wall-clock. The kernel ring (size 64) drains
    # between bursts so wsys_nudge_drop stays at 0; the compositor's
    # consumed count then reflects the true cursor refresh rate.
    burst = 0
    while burst < 10 {
        n = 0
        while n < 10 {
            ax = burst * 3200 + n * 320
            ay = burst * 3200 + n * 320
            echo nudge $ax $ay > /dev/wsys/ctl
            n = n + 1
        }
        sleep 1
        burst = burst + 1
    }
    echo nudge_report > /dev/wsys/ctl
    echo '[visual_gate] nudge_done'

    # ---- per-app render proof ----
    # For each app the host harness wants visually verified, emit a
    # BEFORE marker (host screendumps the bare desktop), spawn the app,
    # wait for it to paint, then emit an AFTER marker (host screendumps
    # again — if the two PNGs are byte-identical the app rendered NO
    # new pixels and the gate fails). Each app spawn is itself detached
    # so a crashing app does not wedge the gate sequence.
    apps = [hamclock, hamcalc, hamfm, hamterm, hammon, hamctl, hamshot, hamnotify]
    for app in $apps {
        echo '[visual_gate] launching' $app
        sleep 1
        spawn detached visualgatens {
            $app
        }
        sleep 3
        echo '[visual_gate] launched' $app
        sleep 1
    }

    echo '[visual_gate] done'
}

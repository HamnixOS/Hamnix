# adder/compiler/fused_driver_host_main.ad
#
# HOST (x86_64-linux) driver `main` for the FUSED self-hosted compiler
# (lexer + parser + codegen + elf_emit). This is the Track-3 CUTOVER
# DRY-RUN driver: it mirrors fused_driver_main.ad EXACTLY in behaviour
# (same lex -> parse -> codegen -> elf_emit pipeline over the same compiler
# globals) but targets the HOST so the whole self-hosted compiler can be
# built into a runnable Linux ELF by the Python seed toolchain and run on
# the host (NO QEMU, NO Hamnix boot).
#
# Two structural differences vs fused_driver_main.ad:
#   1. LINUX syscall numbers (not Hamnix): open=2 read=0 close=3 write=1
#      exit_group=60. Issued via codegen.ad's inline __syscallN builtins
#      (the Python seed lowers them identically), so this fragment needs no
#      extern/libc linkage and exercises the SAME syscall lowering path the
#      on-device fused compiler uses.
#   2. I/O paths come from ARGV: argv[1] = input .ad source path, argv[2] =
#      output ELF path. The emitted ELF is written RAW (binary) to the
#      output file — not hex-dumped — so the cutover harness can run/inspect
#      it directly. All diagnostic text goes to stderr (fd 2) so stdout
#      stays clean.
#
# Like the on-device fused driver this fragment references the compiler's
# own globals/functions directly (tok_count, p_err, cg_err, fn_count,
# code_len, gdata_len, cg_entry_off, elf_buf, elf_len, elf_err, lex_init,
# lex_tokenize, parser_init, parse_program, cg_init,
# gen_program_with_globals, elf_emit_image) — no imports needed, because it
# is fused into the same translation unit.

# Module-level source buffer (the lexer stashes the bare pointer, so the
# bytes must outlive the whole compile -> global, not a local). Sized to
# comfortably exceed the largest merged import closure in the WHOLE tree.
# The biggest userland-unit merge is ~314KB and the whole-compiler concat
# that builds this very binary is ~315KB — but the KERNEL (init/main.ad)'s
# 346-module import closure merges to ~13.9 MB of stripped source (CAP#3).
# 24 MiB leaves comfortable headroom above that without an unbounded blow-up.
# This buffer is zero-init (.bss), so the size only costs memsz, not file
# bytes in the emitted host_ac.elf.
DRV_SRC_CAP: uint32 = 25165824
drv_src: Array[25165824, uint8]
drv_src_len: uint32 = 0      # bytes laid down in drv_src so far (merge cursor)

# ---------------------------------------------------------------------------
# CAPABILITY #2 — IMPORT RESOLUTION + module merge (host driver layer).
#
# The fused lexer/parser/codegen is single-translation-unit: it has no
# `import` execution. This driver reproduces the frozen Python seed's
# multi-TU front-end (compiler/adder.py collect_all_imports + merge_programs)
# at the SOURCE-TEXT level:
#
#   1. Discover `from M import ...` / `import M [as x]` statements by a
#      light line scanner (NOT the full lexer — runs before the pipeline).
#   2. Resolve the dotted module M to a file: `a.b.c` -> `a/b/c.ad`, or the
#      package form `a/b/c/__init__.ad`. Imports that resolve to no file
#      (runtime/external — e.g. `sys`, libc shims) are ignored, exactly like
#      the seed's `except FileNotFoundError: pass`.
#   3. Transitively collect the closure in DEPENDENCY ORDER (imports first),
#      de-duplicating already-visited files — mirrors collect_all_imports's
#      `ordered.insert(0, current)` post-order.
#   4. Concatenate every file's source into drv_src in that order, dropping
#      its own import lines (they have served their purpose), so the merged
#      buffer is one self-consistent translation unit. The parser then runs
#      ONCE over the whole thing.
#
# Module-private (`_name`) collision handling: the seed mangles leading-
# underscore top-level names per-module (resolve_module_scopes / _mangle_private
# in compiler/adder.py) so two modules that each define a private helper of the
# SAME name (e.g. dev.ad `_word_eq(s,lit)` and devnet.ad
# `_word_eq(buf,pos,len,word)`) cannot collide. This driver ports that mangling
# as a per-file SOURCE-TEXT token rewrite (it has no per-module AST stage):
#   * PASS A (drv_process_file) walks the closure, records an append-ORDER list,
#     and collects the closure-wide EXPORTED set (every `from M import name`
#     target — incl. paren/backslash multi-line forms — plus every column-0
#     `extern [def] NAME` plus the reserved __stack_chk_* symbols). Mirrors
#     _collect_exported_names. Must be complete before any mangling.
#   * PASS B (drv_merge_ordered -> drv_append_stripped) appends each file in
#     dependency order, mangling its column-0 private (`def _x(` / `_x:`) names
#     (minus exported) to `<modslug>_<name>` and rewriting every matching
#     identifier reference — skipping member accesses (`.name`), comments, and
#     string/char literals so only real Identifier references are touched
#     (mirrors _rewrite_refs). modslug = the file path with symlink components
#     resolved (drv_canon_path, matching the seed's Path.resolve()) and '/'/'.'
#     -> '_'. Without this the native linker first-matches the colliding bare
#     name and a cross-module call MIS-LINKS to the wrong body.
# Local-shadow suppression (the seed's _collect_local_names) is a verified
# no-op on today's tree (no def references a module-private global whose name is
# also bound as a param/local), so the straight token rewrite is byte-equivalent
# to the seed's AST pass. See docs/subsystems/adder-compiler.md.
# ---------------------------------------------------------------------------

# Closure bookkeeping. Each visited module's resolved path string is stored
# NUL-terminated back-to-back in drv_paths; drv_path_off[i] indexes the i-th.
DRV_MAX_FILES: uint32 = 512
DRV_PATHS_CAP: uint32 = 65536
drv_paths: Array[65536, uint8]
drv_paths_pos: uint32 = 0
drv_path_off: Array[512, uint32]   # start offset in drv_paths of file i
drv_file_count: uint32 = 0

# ---------------------------------------------------------------------------
# PER-MODULE PRIVATE-NAME MANGLING (mirrors the seed's resolve_module_scopes /
# _mangle_private / _collect_exported_names in compiler/adder.py).
#
# The seed parses each module to an AST, mangles every module-PRIVATE
# (leading-`_`, non-exported) top-level def/global to `<modslug>_<name>`
# (modslug = the module's dotted path with `.`/`/` -> `_`), and rewrites every
# intra-module reference to it, all BEFORE merging modules into one program.
# Without this, two modules' private `def _word_eq(...)` both emit a bare LOCAL
# symbol `_word_eq` and a cross-module call mis-links to the FIRST one
# (resolve_calls first-match) — the live-root `_word_eq(s,lit)` vs
# `_word_eq(buf,pos,len,word)` divergence.
#
# This driver works at the SOURCE-TEXT level (it concatenates `.ad` source and
# parses the merged stream once), so the mangling is done as a per-file token
# rewrite at append time, not on an AST:
#   * `drv_exp_*` holds the closure-wide EXPORTED set: every `from M import
#     name` target and every column-0 `extern [def] NAME` name, plus the
#     codegen-reserved `__stack_chk_*` symbols. A private name in this set is a
#     cross-module contract / real external symbol and is NOT mangled (mirrors
#     _collect_exported_names).
#   * Per appended file, `drv_priv_*` holds that file's module-private
#     candidate names (column-0 `def _x(` and `_x:` globals, minus exported).
#   * Identifier tokens in the file body matching a candidate are rewritten to
#     `<modslug>_<name>`; every other byte is copied verbatim.
#
# Local-shadow suppression (the seed's _collect_local_names) is a documented
# no-op on this tree: a whole-tree audit finds ZERO defs that reference a
# module-private global whose name is also bound as a param/local in the same
# def, so a straight token rewrite is byte-equivalent to the seed's AST pass.
# The merged-source dump (3rd positional) lets the cutover harness re-verify
# this against the seed if a future module breaks the invariant.
# ---------------------------------------------------------------------------

# Append-ORDER list of closure files (dependency-first). Pass A (discovery)
# walks the import graph, records each file ONCE here in the post-order it
# would be concatenated; pass B iterates this list to mangle+append. (drv_paths
# /drv_path_off above remain the de-dup VISITED set, recorded pre-order.)
drv_order_off: Array[512, uint32]   # offset into drv_order_buf of file i
drv_order_buf: Array[131072, uint8] # NUL-terminated paths, append order
drv_order_pos: uint32 = 0
drv_order_count: uint32 = 0

# Closure-wide EXPORTED name set: NUL-terminated names back-to-back. A name
# here is never mangled even with a leading `_`.
DRV_EXP_CAP: uint32 = 262144
drv_exp_buf: Array[262144, uint8]
drv_exp_pos: uint32 = 0

# Per-file module-private candidate names (rebuilt for each file in pass B).
DRV_PRIV_MAX: uint32 = 1024
drv_priv_buf: Array[32768, uint8]   # NUL-terminated names back-to-back
drv_priv_off: Array[1024, uint32]
drv_priv_pos: uint32 = 0
drv_priv_count: uint32 = 0

# Module slug for the file currently being appended (path with the trailing
# ".ad" dropped and every '/'/'.' turned into '_'), NUL-terminated.
drv_modslug: Array[1024, uint8]
drv_modslug_len: uint32 = 0

# The project root the driver resolves module paths against. The cutover
# harness invokes host_ac.elf with CWD = project root, so relative module
# paths ("lib/perror.ad") resolve directly; drv_root is the empty prefix.
# Kept as a separate concept so a future -I/root flag can set it.

# Scratch for one resolved candidate path while probing the filesystem.
drv_cand: Array[1024, uint8]


# Linux faccessat/access? Simplest: open(O_RDONLY) and close. Returns 1 if
# the path (NUL-terminated at drv_cand[0..]) names a readable file.
def drv_path_exists() -> uint32:
    fd: int64 = __syscall3(2, cast[uint64](&drv_cand[0]), 0, 0)
    if fd < 0:
        return 0
    __syscall1(3, cast[uint64](fd))
    return 1


# Append byte c to drv_cand at position p; returns p+1 (no overflow guard
# needed — module paths are far under 1024 bytes).
def drv_cand_put(p: uint32, c: uint8) -> uint32:
    drv_cand[p] = c
    return p + 1


# Build a candidate file path from a dotted module name held in
# `mod[0..mlen)`: replace '.' with '/', append `suffix` (a NUL-terminated
# C string, e.g. ".ad" or "/__init__.ad"). Writes into drv_cand, NUL-
# terminated. Returns the length (excluding NUL).
def drv_build_path(mod: Ptr[uint8], mlen: uint32, suffix: Ptr[uint8]) -> uint32:
    p: uint32 = 0
    i: uint32 = 0
    while i < mlen:
        c: uint8 = mod[i]
        if c == 46:                  # '.'
            p = drv_cand_put(p, 47)  # '/'
        else:
            p = drv_cand_put(p, c)
        i = i + 1
    j: uint64 = 0
    while suffix[j] != 0:
        p = drv_cand_put(p, suffix[j])
        j = j + 1
    drv_cand[p] = 0
    return p


# Resolve dotted module `mod[0..mlen)` to an existing file path, written
# NUL-terminated into drv_cand. Tries `a/b/c.ad` then `a/b/c/__init__.ad`
# (mirrors seed resolve_import order). Returns 1 on success (drv_cand set),
# 0 if no file exists (external/runtime import — ignored).
def drv_resolve_module(mod: Ptr[uint8], mlen: uint32) -> uint32:
    drv_build_path(mod, mlen, ".ad")
    if drv_path_exists() != 0:
        return 1
    drv_build_path(mod, mlen, "/__init__.ad")
    if drv_path_exists() != 0:
        return 1
    return 0


# Is the path in drv_cand[0..clen) already in the visited set? Compares
# against each stored drv_paths entry.
def drv_seen(clen: uint32) -> uint32:
    i: uint32 = 0
    while i < drv_file_count:
        off: uint32 = drv_path_off[i]
        # compare NUL-terminated stored path vs drv_cand
        k: uint32 = 0
        eq: uint32 = 1
        while eq != 0:
            sc: uint8 = drv_paths[off + k]
            cc: uint8 = drv_cand[k]
            if sc != cc:
                eq = 0
            elif sc == 0:
                return 1            # both terminated, identical
            else:
                k = k + 1
        i = i + 1
    return 0


# Record drv_cand (NUL-terminated) as visited file index drv_file_count.
def drv_record_path():
    drv_path_off[drv_file_count] = drv_paths_pos
    k: uint32 = 0
    while drv_cand[k] != 0:
        drv_paths[drv_paths_pos] = drv_cand[k]
        drv_paths_pos = drv_paths_pos + 1
        k = k + 1
    drv_paths[drv_paths_pos] = 0
    drv_paths_pos = drv_paths_pos + 1
    drv_file_count = drv_file_count + 1


# --- mangling helpers -------------------------------------------------------

# True if byte c is an Adder identifier character (letter, digit, underscore).
# Identifiers never start with a digit, but the inner test is the same.
def drv_is_ident_char(c: uint8) -> uint32:
    if c >= 97 and c <= 122:        # a-z
        return 1
    if c >= 65 and c <= 90:         # A-Z
        return 1
    if c >= 48 and c <= 57:         # 0-9
        return 1
    if c == 95:                     # '_'
        return 1
    return 0


# Append a NUL-terminated name (src[0..) up to NUL) to drv_exp_buf. Caller has
# already de-dup'd if it cares; the exported set tolerates duplicates (it is
# only ever membership-tested).
def drv_exp_add(src: Ptr[uint8]):
    k: uint32 = 0
    while src[k] != 0 and drv_exp_pos < DRV_EXP_CAP - 1:
        drv_exp_buf[drv_exp_pos] = src[k]
        drv_exp_pos = drv_exp_pos + 1
        k = k + 1
    drv_exp_buf[drv_exp_pos] = 0
    drv_exp_pos = drv_exp_pos + 1


# Membership test against the exported set: is the identifier of length `nlen`
# at drv_file[start..start+nlen) present in drv_exp_buf?
def drv_exp_has(start: uint32, nlen: uint32) -> uint32:
    i: uint32 = 0
    while i < drv_exp_pos:
        # compare entry at i against the candidate; entry is NUL-terminated.
        k: uint32 = 0
        while k < nlen and drv_exp_buf[i + k] == drv_file[start + k]:
            k = k + 1
        if k == nlen and drv_exp_buf[i + k] == 0:
            return 1
        # advance i past this entry's NUL
        while drv_exp_buf[i] != 0:
            i = i + 1
        i = i + 1
    return 0


# Add the codegen-reserved stack-protector symbols to the exported set (so a
# stray leading-`_` match never mangles them). Mirrors _CODEGEN_RESERVED_SYMBOLS.
def drv_exp_add_reserved():
    drv_exp_add("__stack_chk_guard")
    drv_exp_add("__stack_chk_fail")
    drv_exp_add("__stack_chk_init")


# Scan drv_file[] (already loaded) for cross-module EXPORT annotations and add
# every exported name to the closure-wide set:
#   * `from M import a, b, c`  and the parenthesised / backslash-continued
#     multi-line forms  -> each imported name.
#   * column-0 `extern def NAME(` / `extern NAME` -> NAME (real external sym).
# Mirrors _collect_exported_names (import names + ExternDecl names).
def drv_collect_exports():
    i: uint32 = 0
    at_line_start: uint32 = 1
    while i < drv_file_len:
        if at_line_start != 0:
            if drv_line_starts(i, "from ") != 0:
                drv_collect_from_imports(i)
            elif drv_line_starts(i, "extern ") != 0:
                # extern [def] NAME( ...
                p: uint32 = i + 7
                while p < drv_file_len and drv_file[p] == 32:
                    p = p + 1
                if drv_line_starts(p, "def ") != 0:
                    p = p + 4
                while p < drv_file_len and drv_file[p] == 32:
                    p = p + 1
                ns: uint32 = p
                while p < drv_file_len and drv_is_ident_char(drv_file[p]) != 0:
                    p = p + 1
                if p > ns:
                    drv_exp_add_span(ns, p - ns)
        c: uint8 = drv_file[i]
        if c == 10:
            at_line_start = 1
        else:
            at_line_start = 0
        i = i + 1


# Add the identifier of length `nlen` at drv_file[start..) to the exported set.
def drv_exp_add_span(start: uint32, nlen: uint32):
    if drv_exp_pos + nlen + 1 >= DRV_EXP_CAP:
        return
    k: uint32 = 0
    while k < nlen:
        drv_exp_buf[drv_exp_pos] = drv_file[start + k]
        drv_exp_pos = drv_exp_pos + 1
        k = k + 1
    drv_exp_buf[drv_exp_pos] = 0
    drv_exp_pos = drv_exp_pos + 1


# Harvest the imported names of a `from M import a, b, ...` statement that
# begins at drv_file[ls] (a line start). Handles the single-line form, the
# parenthesised multi-line block (`from M import (\n a,\n b,\n)`), and the
# backslash line-continuation form. Every identifier after the ` import `
# keyword (excluding `as <alias>` aliases — the seed records the ORIGINAL
# imported name, which is what cross-module call sites use) is added to the
# exported set.
def drv_collect_from_imports(ls: uint32):
    # Locate the ` import ` keyword on the logical line.
    p: uint32 = ls + 5            # past "from "
    # skip the module path token
    while p < drv_file_len and drv_file[p] != 10 and drv_is_ident_char(drv_file[p]) == 0:
        p = p + 1
    while p < drv_file_len and (drv_is_ident_char(drv_file[p]) != 0 or drv_file[p] == 46):
        p = p + 1                 # module path may contain '.'
    # skip spaces, then expect "import"
    while p < drv_file_len and drv_file[p] == 32:
        p = p + 1
    if drv_line_starts(p, "import") == 0:
        return
    p = p + 6
    # Now harvest names until logical end. Track paren depth + backslash cont.
    paren: uint32 = 0
    expect_alias: uint32 = 0      # 1 right after an `as` keyword: skip next ident
    while p < drv_file_len:
        c: uint8 = drv_file[p]
        if c == 40:               # '('
            paren = paren + 1
            p = p + 1
        elif c == 41:             # ')'
            if paren != 0:
                paren = paren - 1
            p = p + 1
        elif c == 10:             # newline
            # End of logical line unless inside parens. (A backslash
            # continuation is consumed at the '\' branch below, which skips
            # straight past the following newline, so a bare newline here with
            # paren==0 is a true logical-line end.)
            if paren != 0:
                p = p + 1
            else:
                return
        elif c == 92:             # '\' line continuation: skip it AND the rest
            # of the physical line (only whitespace may follow a continuation)
            # plus the newline, so the import's names keep flowing.
            p = p + 1
            while p < drv_file_len and drv_file[p] != 10:
                p = p + 1
            if p < drv_file_len:
                p = p + 1         # consume the newline too
        elif drv_is_ident_char(c) != 0:
            ns: uint32 = p
            while p < drv_file_len and drv_is_ident_char(drv_file[p]) != 0:
                p = p + 1
            # Is this token the `as` keyword? then the next ident is an alias.
            if p - ns == 2 and drv_file[ns] == 97 and drv_file[ns + 1] == 115:
                expect_alias = 1
            elif expect_alias != 0:
                expect_alias = 0       # this is the alias; do NOT export it
            else:
                drv_exp_add_span(ns, p - ns)
        else:
            p = p + 1


# Scratch for symlink resolution.
drv_canon: Array[1024, uint8]
drv_canon_len: uint32 = 0
drv_linkbuf: Array[1024, uint8]


# Canonicalise the NUL-terminated path in `path` by resolving symlink
# COMPONENTS into drv_canon, mirroring Python's Path.resolve() (which the seed
# uses in _module_name_for). Hamnix's tree carries one directory symlink:
# `sys/src/port9 -> 9`, so the import path `sys/src/port9/port/dev.ad` resolves
# to `sys/src/9/port/dev.ad` and the seed mangle slug is `sys_src_9_port_dev`,
# NOT `sys_src_port9_port_dev`. Without resolving, the native slug diverges from
# the seed for every `sys.src.9.*` module. We walk components, append each to
# the canonical prefix, and if that prefix is a symlink (readlink succeeds) with
# a RELATIVE target, replace the just-appended component with the link target.
# (Only relative, non-`..` targets occur in the tree; that is all we model.)
def drv_canon_path(path: Ptr[uint8]):
    drv_canon_len = 0
    i: uint32 = 0
    while path[i] != 0:
        # gather the next component [i, e)
        # skip a leading '/' (preserve it in output)
        if path[i] == 47:
            drv_canon[drv_canon_len] = 47
            drv_canon_len = drv_canon_len + 1
            i = i + 1
        e: uint32 = i
        while path[e] != 0 and path[e] != 47:
            e = e + 1
        if e == i:
            # empty component (e.g. trailing slash) — done with this round
            if path[i] == 0:
                drv_canon[drv_canon_len] = 0
                return
            i = e
        else:
            # remember where this component starts in drv_canon, append it
            comp_start: uint32 = drv_canon_len
            k: uint32 = i
            while k < e:
                drv_canon[drv_canon_len] = path[k]
                drv_canon_len = drv_canon_len + 1
                k = k + 1
            drv_canon[drv_canon_len] = 0
            # readlink the prefix-so-far; if it is a symlink, splice the target.
            ll: int64 = __syscall3(89, cast[uint64](&drv_canon[0]),
                                   cast[uint64](&drv_linkbuf[0]), 1023)
            if ll > 0:
                # It is a symlink. Target in drv_linkbuf[0..ll). We only model a
                # RELATIVE target (no leading '/'): replace the just-appended
                # component with the target text.
                if drv_linkbuf[0] != 47:
                    drv_canon_len = comp_start
                    t: uint32 = 0
                    while t < cast[uint32](ll):
                        drv_canon[drv_canon_len] = drv_linkbuf[t]
                        drv_canon_len = drv_canon_len + 1
                        t = t + 1
                    drv_canon[drv_canon_len] = 0
            i = e
    drv_canon[drv_canon_len] = 0


# Build drv_modslug from the NUL-terminated path in `path`: canonicalise
# symlink components, drop a trailing ".ad", and turn every '/' and '.' into
# '_'. Mirrors _module_name_for -> _mangle_private slug (dotted module path
# with separators -> '_').
def drv_build_modslug(path: Ptr[uint8]):
    drv_canon_path(path)
    drv_build_modslug_raw(&drv_canon[0])


def drv_build_modslug_raw(path: Ptr[uint8]):
    # length of path
    plen: uint32 = 0
    while path[plen] != 0:
        plen = plen + 1
    # drop trailing ".ad"
    if plen >= 3 and path[plen - 3] == 46 and path[plen - 2] == 97 and path[plen - 1] == 100:
        plen = plen - 3
    o: uint32 = 0
    j: uint32 = 0
    while j < plen:
        c: uint8 = path[j]
        if c == 47 or c == 46:    # '/' or '.'
            drv_modslug[o] = 95   # '_'
        else:
            drv_modslug[o] = c
        o = o + 1
        j = j + 1
    drv_modslug[o] = 0
    drv_modslug_len = o


# Add a private candidate name (span at drv_file[start..start+nlen)) to the
# per-file private set, unless it is in the exported set.
def drv_priv_add(start: uint32, nlen: uint32):
    if drv_exp_has(start, nlen) != 0:
        return
    if drv_priv_count >= DRV_PRIV_MAX:
        return
    if drv_priv_pos + nlen + 1 >= 32768:
        return
    drv_priv_off[drv_priv_count] = drv_priv_pos
    k: uint32 = 0
    while k < nlen:
        drv_priv_buf[drv_priv_pos] = drv_file[start + k]
        drv_priv_pos = drv_priv_pos + 1
        k = k + 1
    drv_priv_buf[drv_priv_pos] = 0
    drv_priv_pos = drv_priv_pos + 1
    drv_priv_count = drv_priv_count + 1


# If the identifier at drv_file[start..start+nlen) is a per-file private
# candidate, return 1 (it must be mangled); else 0.
def drv_priv_has(start: uint32, nlen: uint32) -> uint32:
    i: uint32 = 0
    while i < drv_priv_count:
        off: uint32 = drv_priv_off[i]
        k: uint32 = 0
        while k < nlen and drv_priv_buf[off + k] == drv_file[start + k]:
            k = k + 1
        if k == nlen and drv_priv_buf[off + k] == 0:
            return 1
        i = i + 1
    return 0


# Scan drv_file[] (already loaded) for this module's column-0 private
# declaration names and populate the per-file private set:
#   * `def _NAME(`        -> _NAME
#   * `_NAME:` (a global) -> _NAME
# Leading-`_` only; exported names are filtered out by drv_priv_add. Resets the
# per-file set first.
def drv_collect_privates():
    drv_priv_pos = 0
    drv_priv_count = 0
    i: uint32 = 0
    at_line_start: uint32 = 1
    while i < drv_file_len:
        if at_line_start != 0:
            ns: uint32 = i
            if drv_line_starts(i, "def ") != 0:
                ns = i + 4
                # the function name follows (after any spaces)
                while ns < drv_file_len and drv_file[ns] == 32:
                    ns = ns + 1
                if ns < drv_file_len and drv_file[ns] == 95:    # leading '_'
                    e: uint32 = ns
                    while e < drv_file_len and drv_is_ident_char(drv_file[e]) != 0:
                        e = e + 1
                    drv_priv_add(ns, e - ns)
            elif drv_file[i] == 95:        # column-0 '_': a global `_x: T ...`
                e: uint32 = i
                while e < drv_file_len and drv_is_ident_char(drv_file[e]) != 0:
                    e = e + 1
                # a global decl is `_name:` — require the next non-space to be ':'
                p: uint32 = e
                while p < drv_file_len and drv_file[p] == 32:
                    p = p + 1
                if p < drv_file_len and drv_file[p] == 58:      # ':'
                    drv_priv_add(i, e - i)
        c: uint8 = drv_file[i]
        if c == 10:
            at_line_start = 1
        else:
            at_line_start = 0
        i = i + 1


# A small per-file source scratch used while scanning a file for its imports
# and copying it into the merged buffer. One file at a time, so a single
# reusable buffer suffices.
# Per-file source scratch. Must hold the LARGEST single source file in any
# closure. The biggest source files in the tree are arch/arm64/kmain.ad
# (~1.3 MB) and user/hamUId.ad (~1.2 MB) — both exceed the old 1 MiB cap,
# which SILENTLY TRUNCATED them mid-read (read_file stops at DRV_FILE_CAP),
# corrupting any merge whose closure pulled one in and surfacing as a
# spurious parse error deep in the merged stream. 4 MiB covers the largest
# tree file with headroom. Zero-init (.bss) — size costs memsz only.
DRV_FILE_CAP: uint32 = 4194304
drv_file: Array[4194304, uint8]
drv_file_len: uint32 = 0


# Read the NUL-terminated path in drv_cand into drv_file[]; sets drv_file_len.
# Returns 1 on success, 0 on open/read failure.
def drv_read_file_to_scratch() -> uint32:
    fd: int64 = __syscall3(2, cast[uint64](&drv_cand[0]), 0, 0)
    if fd < 0:
        return 0
    total: uint32 = 0
    while total < DRV_FILE_CAP:
        n: int64 = __syscall3(0,
                              cast[uint64](fd),
                              cast[uint64](&drv_file[0]) + cast[uint64](total),
                              cast[uint64](DRV_FILE_CAP - total))
        if n <= 0:
            break
        total = total + cast[uint32](n)
    __syscall1(3, cast[uint64](fd))
    drv_file_len = total
    return 1


# True if drv_file[i..] begins with the C-string `kw` (used to spot the
# `from ` / `import ` line prefixes at a line start).
def drv_line_starts(i: uint32, kw: Ptr[uint8]) -> uint32:
    j: uint64 = 0
    while kw[j] != 0:
        if i + cast[uint32](j) >= drv_file_len:
            return 0
        if drv_file[i + cast[uint32](j)] != kw[j]:
            return 0
        j = j + 1
    return 1


# Parse the dotted module name out of a `from <mod> import ...` or
# `import <mod> ...` line that begins at byte `i` in drv_file. `kwlen` is the
# length of the leading keyword+space already matched. Copies the dotted
# name into `out` and returns its length. The name runs from the first
# non-space after the keyword up to the next space/newline.
def drv_extract_module(i: uint32, kwlen: uint32, out: Ptr[uint8]) -> uint32:
    p: uint32 = i + kwlen
    # skip spaces
    while p < drv_file_len and drv_file[p] == 32:
        p = p + 1
    n: uint32 = 0
    while p < drv_file_len:
        c: uint8 = drv_file[p]
        if c == 32 or c == 10 or c == 13 or c == 9:
            break
        out[n] = c
        n = n + 1
        p = p + 1
    return n


# Scan drv_file[] for top-level import statements (lines beginning, at column
# 0, with `from ` or `import `), resolve each, and for any that resolves to a
# not-yet-visited file, recurse to process THAT file first (post-order =
# dependency order). After all imports are handled, append THIS file's source
# (import lines stripped) to drv_src. The path being processed is in drv_cand
# on entry and must be preserved across recursion via the caller's own copy.
#
# `depth` guards against an accidental cycle blow-out (the visited set already
# prevents true cycles, but bound the recursion defensively).
modname_scratch: Array[1024, uint8]


# Forward-declared mutual recursion: drv_process_file scans + recurses.
def drv_process_file(depth: uint32):
    # drv_cand holds this file's path; record it as visited and snapshot the
    # path locally (drv_cand is clobbered by nested resolution).
    drv_record_path()
    self_path: Array[1024, uint8]
    sp: uint32 = 0
    while drv_cand[sp] != 0:
        self_path[sp] = drv_cand[sp]
        sp = sp + 1
    self_path[sp] = 0

    if drv_read_file_to_scratch() == 0:
        return

    # Collect this file's cross-module EXPORT annotations (from-import targets +
    # extern names) into the closure-wide exported set NOW, while its bytes are
    # in drv_file. The exported set must be complete across the WHOLE closure
    # before any file is mangled+appended (a name imported by a later-appended
    # module must not be mangled in an earlier one), so this happens in the
    # discovery walk (pass A) and the actual append happens in pass B.
    drv_collect_exports()

    # First pass: walk lines, find imports, recurse into new dependencies.
    # We must re-read THIS file's bytes after recursion (recursion clobbers
    # drv_file), so we copy this file's bytes into a local snapshot first.
    # 393216 on the stack is too large; instead, we two-pass over drv_file by
    # re-reading the file from disk after each recursion. Simpler + bounded:
    # collect all import module-names FIRST into a local list, recurse after.
    # Per-frame import list. Sized for the KERNEL root init/main.ad, which has
    # ~191 top-level imports — the prior 64 cap SILENTLY DROPPED every import
    # past the 64th (e.g. linux_abi.u_syscalls, the 107th, which defines
    # CLONE_NEWNS et al.), so those modules never entered the closure and their
    # symbols were undefined in the merged TU. Raised to 384 names / 32 KiB of
    # name bytes. Import NESTING depth (the recursion depth these locals live
    # at) is shallow, so the larger per-frame stack footprint is bounded.
    imp_names: Array[384, uint32]      # offset into a names buffer
    imp_names_buf: Array[32768, uint8]
    imp_buf_pos: uint32 = 0
    imp_count: uint32 = 0

    i: uint32 = 0
    at_line_start: uint32 = 1
    while i < drv_file_len:
        if at_line_start != 0:
            kwlen: uint32 = 0
            if drv_line_starts(i, "from ") != 0:
                kwlen = 5
            elif drv_line_starts(i, "import ") != 0:
                kwlen = 7
            if kwlen != 0:
                mlen: uint32 = drv_extract_module(i, kwlen, &modname_scratch[0])
                if imp_count < 384 and imp_buf_pos + mlen + 1 < 32768:
                    imp_names[imp_count] = imp_buf_pos
                    kk: uint32 = 0
                    while kk < mlen:
                        imp_names_buf[imp_buf_pos] = modname_scratch[kk]
                        imp_buf_pos = imp_buf_pos + 1
                        kk = kk + 1
                    imp_names_buf[imp_buf_pos] = 0
                    imp_buf_pos = imp_buf_pos + 1
                    imp_count = imp_count + 1
        c: uint8 = drv_file[i]
        if c == 10:
            at_line_start = 1
        else:
            at_line_start = 0
        i = i + 1

    # Recurse into each new dependency in textual order (matches the seed's
    # closure membership; final ordering is dependency-first because each
    # recursion appends its own body before we append ours below).
    ii: uint32 = 0
    while ii < imp_count:
        nm: uint32 = imp_names[ii]
        # length of this NUL-terminated module name
        nl: uint32 = 0
        while imp_names_buf[nm + nl] != 0:
            nl = nl + 1
        if drv_resolve_module(&imp_names_buf[nm], nl) != 0:
            # drv_cand now holds the resolved path.
            if drv_seen(0) == 0:
                if depth < DRV_MAX_FILES:
                    drv_process_file(depth + 1)
        ii = ii + 1

    # Record THIS file into the append-ORDER list (dependency-first post-order).
    # The actual mangle+append happens in pass B (drv_merge_ordered) once the
    # closure-wide exported set is complete.
    if drv_order_count < DRV_MAX_FILES:
        drv_order_off[drv_order_count] = drv_order_pos
        cp: uint32 = 0
        while self_path[cp] != 0 and drv_order_pos < 131072 - 1:
            drv_order_buf[drv_order_pos] = self_path[cp]
            drv_order_pos = drv_order_pos + 1
            cp = cp + 1
        drv_order_buf[drv_order_pos] = 0
        drv_order_pos = drv_order_pos + 1
        drv_order_count = drv_order_count + 1


# PASS B: iterate the append-order file list built by pass A. For each file,
# read it, derive its module slug, collect its private candidate names, and
# append its import-stripped, privately-mangled body to drv_src. Runs after the
# whole closure's exported set is known, so cross-module-imported privates stay
# un-mangled in every module exactly as the seed does.
def drv_merge_ordered():
    fi: uint32 = 0
    while fi < drv_order_count:
        off: uint32 = drv_order_off[fi]
        # copy this file's path into drv_cand for the read.
        cp: uint32 = 0
        while drv_order_buf[off + cp] != 0:
            drv_cand[cp] = drv_order_buf[off + cp]
            cp = cp + 1
        drv_cand[cp] = 0
        if drv_read_file_to_scratch() != 0:
            drv_build_modslug(&drv_cand[0])
            drv_collect_privates()
            drv_append_stripped()
        fi = fi + 1


# Append drv_file[] to drv_src, dropping any line that begins (column 0)
# with `from ` or `import `. Two multi-line import forms are also dropped in
# their entirety:
#   * A parenthesised `from M import (` block runs until the line that is
#     just `)`; drop through it.
#   * A BACKSLASH line-continuation `from M import a, b, \` (no parens) drops
#     every continuation line until the first line that does NOT end with a
#     trailing `\`. This mirrors the seed: its tokenizer joins `\`-continued
#     physical lines into one logical import statement, so the whole logical
#     line vanishes from the merged TU. (The userland units the prior gate
#     covered used only the paren form; the kernel closure — e.g.
#     drivers/net/ipv6.ad — uses the backslash form, so it must be handled
#     too or the orphaned continuation tokens corrupt the merged source.)
# Mirrors the seed concat strip_compiler_imports / merge_programs import
# handling.
# Emit one byte to drv_src (bounds-guarded).
def drv_src_put(c: uint8):
    if drv_src_len < DRV_SRC_CAP - 1:
        drv_src[drv_src_len] = c
        drv_src_len = drv_src_len + 1


# Copy a `#` comment verbatim from drv_file[i] up to (but NOT including) the
# next newline / EOF. Returns the index of the newline / EOF. Comments are NOT
# token text — the seed never rewrites inside them, so they pass through raw.
def drv_copy_comment(i: uint32) -> uint32:
    p: uint32 = i
    while p < drv_file_len and drv_file[p] != 10:
        drv_src_put(drv_file[p])
        p = p + 1
    return p


# Copy a string literal verbatim starting at drv_file[i] (which is a quote
# byte `q` = '"' or '\''). Handles triple-quoted strings and `\`-escapes
# exactly like the lexer (read_string): a backslash escapes the next byte;
# a triple quote `qqq` opens/closes a triple string that may span newlines.
# Returns the index JUST PAST the closing quote. String contents are token
# text the seed never rewrites, so they pass through raw.
def drv_copy_string(i: uint32) -> uint32:
    q: uint8 = drv_file[i]
    triple: uint32 = 0
    p: uint32 = i
    if i + 2 < drv_file_len and drv_file[i + 1] == q and drv_file[i + 2] == q:
        triple = 1
        # emit the three opening quotes
        drv_src_put(q)
        drv_src_put(q)
        drv_src_put(q)
        p = i + 3
    else:
        drv_src_put(q)
        p = i + 1
    while p < drv_file_len:
        c: uint8 = drv_file[p]
        if c == 92:                       # '\' escape: copy it + the next byte
            drv_src_put(c)
            p = p + 1
            if p < drv_file_len:
                drv_src_put(drv_file[p])
                p = p + 1
        elif triple != 0:
            if c == q and p + 2 < drv_file_len and drv_file[p + 1] == q and drv_file[p + 2] == q:
                drv_src_put(q)
                drv_src_put(q)
                drv_src_put(q)
                return p + 3
            drv_src_put(c)
            p = p + 1
        else:
            if c == q:
                drv_src_put(c)
                return p + 1
            if c == 10:                   # unterminated single-line string: stop
                return p
            drv_src_put(c)
            p = p + 1
    return p


# Emit drv_modslug followed by the identifier span at drv_file[start..start+n).
# Produces `<modslug>_<name>` — the seed's _mangle_private(module, name) (the
# name itself begins with `_`, giving the `__` boundary the seed produces).
def drv_emit_mangled(start: uint32, n: uint32):
    k: uint32 = 0
    while k < drv_modslug_len:
        drv_src_put(drv_modslug[k])
        k = k + 1
    drv_src_put(95)               # '_' joiner
    k = 0
    while k < n:
        drv_src_put(drv_file[start + k])
        k = k + 1


def drv_append_stripped():
    i: uint32 = 0
    at_line_start: uint32 = 1
    skipping_block: uint32 = 0
    skipping_cont: uint32 = 0    # 1 while inside a `\`-continued import logical line
    drop_line: uint32 = 0
    prev_byte: uint32 = 10       # byte just BEFORE position i (for ident-boundary
                                 # + member-access `.` detection); newline at BOF.
    while i < drv_file_len:
        if at_line_start != 0:
            # Decide whether to drop this whole line.
            if skipping_block != 0:
                drop_line = 1
            elif skipping_cont != 0:
                # Continuation of a backslash-continued import: drop this line.
                # It STAYS a continuation only if it too ends with `\`.
                drop_line = 1
                if drv_line_ends_backslash(i) == 0:
                    skipping_cont = 2    # mark: this is the LAST continuation line
            elif drv_line_starts(i, "from ") != 0 or drv_line_starts(i, "import ") != 0:
                drop_line = 1
                # Does this from/import open a parenthesised block? Scan to
                # end of line for a '(' with no ')' after it.
                if drv_line_has_open_paren(i) != 0:
                    skipping_block = 1
                elif drv_line_ends_backslash(i) != 0:
                    # Backslash line-continuation: drop following lines too.
                    skipping_cont = 1
            else:
                drop_line = 0
        c: uint8 = drv_file[i]
        if drop_line == 0:
            # Comments and string/char literals are token text the seed never
            # rewrites; copy them verbatim and skip the ident-mangle scan, so a
            # private name mentioned in a comment or string (e.g. "_word_eq" or
            # `# _word_eq does X`) is NEVER mangled. A quote that is part of an
            # identifier (the `f` of an f-string, or a char-literal escape) can
            # only START here when prev is a non-ident byte, which is exactly a
            # literal boundary.
            if c == 35:                       # '#'
                ne: uint32 = drv_copy_comment(i)
                # ne is at the newline / EOF; let the main loop process it.
                if ne > i:
                    prev_byte = cast[uint32](drv_file[ne - 1])
                at_line_start = 0
                i = ne
                continue
            if c == 34 or c == 39:            # '"' or '\''
                se: uint32 = drv_copy_string(i)
                if se > i:
                    prev_byte = cast[uint32](drv_file[se - 1])
                at_line_start = 0
                i = se
                continue
            # Identifier-aware mangling rewrite. At the START of an identifier
            # token (prev byte is NOT an identifier char), consume the whole
            # token; if it is a module-private candidate AND is not a member
            # access (`.name`) or a string/char-literal token, emit the mangled
            # form. Otherwise emit it verbatim. Non-identifier bytes pass through
            # one at a time so the line-drop / newline bookkeeping is preserved.
            if drv_priv_count != 0 and drv_is_ident_char(c) != 0 and drv_is_ident_char(cast[uint8](prev_byte)) == 0:
                # gather the identifier span [i, e)
                e: uint32 = i
                while e < drv_file_len and drv_is_ident_char(drv_file[e]) != 0:
                    e = e + 1
                n: uint32 = e - i
                # member access `obj.name` -> the name is a struct field (the
                # seed stores it as a plain str, never rewrites it). prev_byte
                # '.' marks that. (Numeric `1.5e` etc. can't reach here: a digit
                # is an ident char so prev_byte would be a digit, not '.'.)
                if prev_byte == 46:           # '.'
                    # copy verbatim
                    cc: uint32 = i
                    while cc < e:
                        drv_src_put(drv_file[cc])
                        cc = cc + 1
                elif drv_priv_has(i, n) != 0:
                    drv_emit_mangled(i, n)
                else:
                    cc2: uint32 = i
                    while cc2 < e:
                        drv_src_put(drv_file[cc2])
                        cc2 = cc2 + 1
                # advance i to the byte before e (the loop's i=i+1 lands on e);
                # update prev_byte to the last identifier byte and at_line_start.
                prev_byte = cast[uint32](drv_file[e - 1])
                at_line_start = 0
                i = e
                # The next loop iteration re-evaluates at_line_start (0 here) and
                # processes drv_file[e]. Continue without the per-byte tail.
                # (We skip the shared tail below by looping now.)
                continue
            drv_src_put(c)
        else:
            # While dropping a paren block, the terminating ')' line ends it.
            if skipping_block != 0 and at_line_start != 0 and drv_line_is_close_paren(i) != 0:
                # this ')' line is the last dropped line of the block
                skipping_block = 2     # mark: stop skipping after this line
        if c == 10:
            if skipping_block == 2:
                skipping_block = 0
            if skipping_cont == 2:
                skipping_cont = 0
            at_line_start = 1
        else:
            at_line_start = 0
        prev_byte = cast[uint32](c)
        i = i + 1


# True if the physical line at drv_file[i..EOL] ends with a `\` continuation
# (the last non-whitespace byte before the newline / EOF is a backslash).
def drv_line_ends_backslash(i: uint32) -> uint32:
    p: uint32 = i
    last: uint32 = 0      # last non-space, non-tab, non-CR byte on the line
    while p < drv_file_len and drv_file[p] != 10:
        c: uint8 = drv_file[p]
        if c != 32 and c != 9 and c != 13:
            last = cast[uint32](c)
        p = p + 1
    if last == 92:        # '\'
        return 1
    return 0
    # Ensure a newline separates concatenated files.
    if drv_src_len < DRV_SRC_CAP - 1:
        drv_src[drv_src_len] = 10
        drv_src_len = drv_src_len + 1


# True if the line at drv_file[i..EOL] contains a '(' that is not closed by a
# ')' before end-of-line (i.e. opens a multi-line paren import block).
def drv_line_has_open_paren(i: uint32) -> uint32:
    p: uint32 = i
    open_c: uint32 = 0
    while p < drv_file_len and drv_file[p] != 10:
        if drv_file[p] == 40:        # '('
            open_c = open_c + 1
        elif drv_file[p] == 41:      # ')'
            if open_c != 0:
                open_c = open_c - 1
        p = p + 1
    if open_c != 0:
        return 1
    return 0


# True if the line at drv_file[i..] is just optional-whitespace + ')'.
def drv_line_is_close_paren(i: uint32) -> uint32:
    p: uint32 = i
    while p < drv_file_len and (drv_file[p] == 32 or drv_file[p] == 9):
        p = p + 1
    if p < drv_file_len and drv_file[p] == 41:
        return 1
    return 0


def drv_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


# Write a NUL-terminated string to stderr (fd 2).
def drv_err(msg: Ptr[uint8]):
    __syscall3(1, 2, cast[uint64](msg), drv_strlen(msg))


def drv_err_u32(v: uint32):
    if v == 0:
        __syscall3(1, 2, cast[uint64]("0"), 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    __syscall3(1, 2, cast[uint64](&out[0]), i)




# Write elf_buf[0..elf_len) RAW to the file at `path`. Linux open(2) with
# O_WRONLY|O_CREAT|O_TRUNC (0x241) and mode 0755 (0x1ED). Returns 1 on
# success, 0 on failure.
def drv_write_elf(path: uint64) -> uint32:
    fd: int64 = __syscall3(2, path, 0x241, 0x1ED)
    if fd < 0:
        return 0
    written: uint32 = 0
    while written < elf_len:
        n: int64 = __syscall3(1,
                              cast[uint64](fd),
                              cast[uint64](&elf_buf[0]) + cast[uint64](written),
                              cast[uint64](elf_len - written))
        if n <= 0:
            __syscall1(3, cast[uint64](fd))
            return 0
        written = written + cast[uint32](n)
    __syscall1(3, cast[uint64](fd))
    return 1


# Write the OPTIONAL LLVM backend's textual IR (ssa_llvm.ad llvm_out[0..
# llvm_out_len)) RAW to the file at `path`. Same open flags as drv_write_elf but
# mode 0644 (0x1A4) — a .ll text file is not executable. Returns 1 on success.
def drv_write_ll(path: uint64) -> uint32:
    fd: int64 = __syscall3(2, path, 0x241, 0x1A4)
    if fd < 0:
        return 0
    written: uint32 = 0
    while written < llvm_out_len:
        n: int64 = __syscall3(1,
                              cast[uint64](fd),
                              cast[uint64](&llvm_out[0]) + cast[uint64](written),
                              cast[uint64](llvm_out_len - written))
        if n <= 0:
            __syscall1(3, cast[uint64](fd))
            return 0
        written = written + cast[uint32](n)
    __syscall1(3, cast[uint64](fd))
    return 1


# True if the C-string at `s` begins with the C-string `pfx`.
def drv_arg_starts(s: Ptr[uint8], pfx: Ptr[uint8]) -> uint32:
    j: uint64 = 0
    while pfx[j] != 0:
        if s[j] != pfx[j]:
            return 0
        j = j + 1
    return 1


# Scan the merged source buffer drv_src[0..len) for a whole-file
# `# adder: unsafe` pragma (roadmap item 3): a line (leading whitespace
# allowed) of the exact shape `#` <ws> `adder:` <ws> `unsafe` <ws-to-EOL>.
# Returns 1 if present. Mirrors the seed's `_source_has_unsafe_pragma` regex.
# Byte-inert: no production .ad carries the pragma, so cg_file_unsafe stays 0.
def drv_scan_unsafe_pragma(len: uint32) -> uint32:
    i: uint32 = 0
    while i < len:
        # Position `i` at the first non-space/tab of a line.
        while i < len and (drv_src[i] == 32 or drv_src[i] == 9):
            i = i + 1
        if i < len and drv_src[i] == 35:          # '#'
            k: uint32 = i + 1
            while k < len and (drv_src[k] == 32 or drv_src[k] == 9):
                k = k + 1
            # "adder:"
            if k + 6 <= len and drv_src[k] == 97 and drv_src[k+1] == 100 and drv_src[k+2] == 100 and drv_src[k+3] == 101 and drv_src[k+4] == 114 and drv_src[k+5] == 58:
                k = k + 6
                while k < len and (drv_src[k] == 32 or drv_src[k] == 9):
                    k = k + 1
                # "unsafe"
                if k + 6 <= len and drv_src[k] == 117 and drv_src[k+1] == 110 and drv_src[k+2] == 115 and drv_src[k+3] == 97 and drv_src[k+4] == 102 and drv_src[k+5] == 101:
                    k = k + 6
                    while k < len and (drv_src[k] == 32 or drv_src[k] == 9):
                        k = k + 1
                    if k >= len or drv_src[k] == 10:
                        return 1
        # Advance to the next line.
        while i < len and drv_src[i] != 10:
            i = i + 1
        i = i + 1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    # CLI shape: <in.ad> <out.elf> [<merged-dump.ad>], plus an optional
    # output-FORMAT selector that may appear anywhere among the args:
    #   --target=x86_64-bare-metal  (or the short alias --kernel)  -> kernel
    #   --target=<anything-else>     (or absent)                   -> user
    # This mirrors the seed's `--target` flag (scripts/_adder_cc.sh forwards
    # it). Flags are filtered out; the remaining positional args keep their
    # order (in, out, dump), so the existing gate invocation
    # `host_ac.elf <in> <out> <merged>` is unaffected.
    # Phase-4 SSA optimizer/allocator gate (ADDER_OPT2). Read the env the same
    # way the dump driver does (envp follows argv on the Linux stack). Unset =>
    # ssa_is_enabled() stays 0, the SSA path is never entered, and host_ac.elf
    # output is byte-identical to the pre-SSA compiler. Set (ADDER_OPT2=1) =>
    # every top-level function the SSA pipeline accepts is compiled THROUGH
    # SSA -> linear-scan allocator -> the existing emit_* encoders, the rest
    # fall back to legacy gen_function (per-function escape hatch inside
    # ssa_emit_program).
    ssa_parse_env(argc, argv)
    # Phase-3 allocator levers (ADDER_RA_OFF / ADDER_RA_BREAK) and Phase-2
    # per-pass SSA-optimizer disables (ADDER_OPT_DISABLE=sccp,...). Inert unless
    # their env is set, so byte-identical when ADDER_OPT2 is unset.
    ssa_emit_parse_env(argc, argv)
    ssa_opt_parse_disable(argc, argv)

    elf_target: uint32 = ELF_FMT_USER
    want_bounds: uint32 = 0                 # --check-bounds (opt-in; userspace)
    want_opt: uint32 = 0                    # --opt (opt-in; now routes through the SSA pipeline)
    want_llvm: uint32 = 0                   # --backend=llvm / --emit-llvm (opt-in; OPTIONAL LLVM backend)
    pos_in: uint64 = 0
    pos_out: uint64 = 0
    pos_dump: uint64 = 0
    pos_n: uint32 = 0
    ai: int32 = 1
    while ai < argc:
        astr: Ptr[uint8] = cast[Ptr[uint8]](argv[ai])
        if drv_arg_starts(astr, "--") != 0:
            # A flag. Recognise the format selectors; ignore anything else
            # (the seed accepts other flags we don't model).
            if drv_arg_starts(astr, "--kernel") != 0:
                elf_target = ELF_FMT_KERNEL
            elif drv_arg_starts(astr, "--target=x86_64-bare-metal") != 0:
                elf_target = ELF_FMT_KERNEL
            elif drv_arg_starts(astr, "--check-bounds") != 0:
                # Opt-in runtime array-bounds checking (memory-safety
                # increment 1b, docs/adder_memory_safety.md). Honoured ONLY for
                # a userspace target below — never the kernel.
                want_bounds = 1
            elif drv_arg_starts(astr, "--opt") != 0:
                # Opt-in optimizer. As of the opt1 retirement this routes through
                # the SSA pipeline (SSA build + Phase-2 passes + linear-scan
                # allocator), IDENTICAL to setting ADDER_OPT2=1. The legacy AST
                # optimizer (opt.ad) has been deleted; --opt no longer touches it.
                # Default OFF: with no --opt (and no ADDER_OPT2) this driver emits
                # byte-for-byte the pre-opt -O0 codegen (objdiff/kobjdiff clean).
                # Armed below (ssa_enable) after parse. NOTE: keep this AFTER the
                # --check-bounds arm so its longer literal matches first
                # (drv_arg_starts is a prefix test and "--opt" is not a prefix).
                want_opt = 1
            elif drv_arg_starts(astr, "--backend=llvm") != 0:
                # OPTIONAL LLVM backend (adder/compiler/ssa_llvm.ad): lower the
                # WHOLE module through the SSA IR to TEXTUAL LLVM IR (.ll) and
                # write that (not an ELF) to the output path. The native SSA/
                # hand-x86 backend stays the DEFAULT; this is opt-in only. The
                # emitted <out> is a .ll text file — the build wrapper
                # (scripts/adder_cc_llvm.sh) then hands it to clang. host_ac.elf
                # is a static no-libc ELF; it EMITS the .ll, it does NOT invoke
                # clang itself.
                want_llvm = 1
            elif drv_arg_starts(astr, "--emit-llvm") != 0:
                # Alias for --backend=llvm (mirrors clang's spelling).
                want_llvm = 1
        else:
            # A positional arg, in order: in, out, dump.
            if pos_n == 0:
                pos_in = argv[ai]
            elif pos_n == 1:
                pos_out = argv[ai]
            elif pos_n == 2:
                pos_dump = argv[ai]
            pos_n = pos_n + 1
        ai = ai + 1

    # Need at least: input path + output path.
    if pos_n < 2:
        drv_err("[host_ac] usage: [--target=T] <in.ad> <out.elf> [<merged-dump.ad>]\n")
        return 2
    in_path: uint64 = pos_in
    out_path: uint64 = pos_out

    # Copy the input path (a C-string in argv) into drv_cand, then resolve its
    # whole import closure into drv_src (dependency-first, import lines
    # stripped). A single-TU input with no imports degrades to a plain copy.
    in_ptr: Ptr[uint8] = cast[Ptr[uint8]](in_path)
    pc: uint32 = 0
    while in_ptr[pc] != 0:
        drv_cand[pc] = in_ptr[pc]
        pc = pc + 1
    drv_cand[pc] = 0

    drv_src_len = 0
    drv_paths_pos = 0
    drv_file_count = 0
    drv_order_pos = 0
    drv_order_count = 0
    drv_exp_pos = 0
    # Guard: the main file must exist.
    if drv_path_exists() == 0:
        drv_err("[host_ac] FAIL: cannot read input\n")
        return 3
    # Seed the exported set with the codegen-reserved symbols, then PASS A:
    # walk the import closure to build the dependency-first append-order list
    # and collect the closure-wide exported (cross-module / extern) name set.
    drv_exp_add_reserved()
    drv_process_file(0)
    # PASS B: mangle+append every file in dependency order, now that the
    # exported set is complete.
    drv_merge_ordered()
    n: uint32 = drv_src_len
    if n == 0:
        drv_err("[host_ac] FAIL: cannot read input\n")
        return 3
    if n < DRV_SRC_CAP:
        drv_src[n] = 0

    # Optional 3rd positional: dump the merged closure source to that path
    # (cutover harness uses it to PROVE the driver's import merge matches the
    # seed's).
    if pos_n >= 3:
        dump_path: uint64 = pos_dump
        dfd: int64 = __syscall3(2, dump_path, 0x241, 0x1ED)
        if dfd >= 0:
            dw: uint32 = 0
            while dw < n:
                wn: int64 = __syscall3(1, cast[uint64](dfd),
                                       cast[uint64](&drv_src[0]) + cast[uint64](dw),
                                       cast[uint64](n - dw))
                if wn <= 0:
                    dw = n
                else:
                    dw = dw + cast[uint32](wn)
            __syscall1(3, cast[uint64](dfd))

    lex_init(&drv_src[0], n)
    lex_tokenize()

    parser_init()
    prog: uint32 = parse_program()
    if p_err != 0:
        drv_err("[host_ac] FAIL: parse error at line ")
        drv_err_u32(p_err_line)
        drv_err("\n")
        return 4

    # OPTIONAL LLVM backend lane (--backend=llvm / --emit-llvm). Lower the whole
    # merged module through the SSA IR to TEXTUAL LLVM IR (ssa_llvm.ad) and write
    # the .ll to <out>. This is a self-contained lane: it never touches
    # codegen's gen_program_with_globals / elf_emit, so the default ELF path is
    # byte-unchanged. llvm_emit_program does its own cg_init + layout_globals/
    # enums/classes so the SSA global-array paths resolve. Functions outside the
    # SSA integer subset are emitted as `; BAILED` comments (their bodies must be
    # supplied by the linked runtime); a trailing `; ADDER_STAT` records
    # funcs/emitted/bailed. All diagnostics stay on stderr; stdout is unused.
    if want_llvm != 0:
        llvm_emit_program(prog)
        if drv_write_ll(out_path) == 0:
            drv_err("[host_ac] FAIL: cannot write output .ll\n")
            return 8
        return 0

    # --opt: route through the SSA pipeline. opt1 (the AST optimizer opt.ad +
    # its linear-scan allocator ra_enable) has been RETIRED — `--opt` now simply
    # arms the SSA gate, identical to ADDER_OPT2=1: ssa_is_enabled() below then
    # sends the whole program through ssa_emit_program (SSA build + Phase-2
    # passes + SSA linear-scan allocator), with the per-function escape hatch
    # falling back to plain -O0 gen_function. The SSA per-pass disables
    # (ADDER_OPT_DISABLE=sccp/instcombine/gvn/licm/dce) and the RA levers were
    # already parsed above via ssa_opt_parse_disable / ssa_emit_parse_env.
    if want_opt != 0:
        ssa_enable()

    cg_init()
    # Kernel target: tell codegen to emit a relocatable object (extern relocs
    # for &extern / call extern, section-relative data relocs) rather than the
    # closed-world self-contained user image. Set AFTER cg_init (which does not
    # reset cg_target_kernel).
    if elf_target == ELF_FMT_KERNEL:
        cg_target_kernel = 1
    # Runtime array-bounds checking is opt-in AND userspace-only: it is NEVER
    # enabled for a kernel/bare-metal target, so kernel codegen stays byte-for-
    # byte unchanged (mirrors the seed's `do_bounds = check_bounds and
    # spec.userspace` gate; the native ELF_FMT_USER target IS the on-device
    # userspace target — docs/adder_memory_safety.md). Set AFTER cg_init, which
    # does not reset cg_check_bounds.
    if want_bounds != 0 and elf_target == ELF_FMT_USER:
        cg_check_bounds = 1
    # Whole-file `# adder: unsafe` pragma (roadmap item 3): suppress the safety
    # checks in every function of this TU. Scanned from the merged source.
    # Byte-inert unless the pragma is present AND checks are on.
    if drv_scan_unsafe_pragma(n) != 0:
        cg_file_unsafe = 1
    # SSA emission seam: compile through the SSA pipeline (SSA build + Phase-2
    # passes + linear-scan allocator, with a per-function escape hatch back to
    # plain -O0 gen_function) when the gate is armed — armed by EITHER ADDER_OPT2
    # (ssa_parse_env) OR the --opt flag (ssa_enable above). Neither set =>
    # ssa_is_enabled() == 0 => plain gen_program_with_globals, byte-identical.
    start: uint32 = 0
    if ssa_is_enabled() != 0:
        start = ssa_emit_program(prog)
    else:
        start = gen_program_with_globals(prog)
    if cg_err != 0:
        drv_err("[host_ac] FAIL: codegen error reason=")
        drv_err_u32(cg_err_reason)
        drv_err(" line=")
        drv_err_u32(cg_err_line())
        drv_err(" kind=")
        drv_err_u32(cg_err_kind())
        drv_err("\n")
        return 5
    if fn_count == 0:
        drv_err("[host_ac] FAIL: no functions emitted\n")
        return 6

    total: uint32 = elf_emit_image_target(0, elf_target)
    if elf_err != 0 or total == 0:
        if elf_err == ELF_ERR_KERNEL_UNSUPPORTED:
            # Reserved code (the kernel ET_REL emitter no longer returns this on
            # a successful compile; kept for forward-compat diagnostics).
            drv_err("[host_ac] FAIL: kernel ELF format unsupported\n")
            return 9
        drv_err("[host_ac] FAIL: ELF emit error (overflow)\n")
        return 7

    if drv_write_elf(out_path) == 0:
        drv_err("[host_ac] FAIL: cannot write output ELF\n")
        return 8

    return 0

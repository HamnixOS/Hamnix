# Captured per function: the value-count high-water so temp (φ) slots sit in a
# disjoint region above the value slots.
ssa_nvals: uint32 = 0

# Start offset of the most-recently SSA-emitted function (so ssa_emit_program can
# anchor `first`/entry resolution just like gen_function's return value).
ssa_last_fn_start: uint32 = 0

# Block -> emitted code offset (filled as each block is laid out; forward jumps
# are patched from the fixup table once every block has an offset).
se_bid_off: Array[1024, uint32]

# Forward/back jump fixups: (rel32-field site, target bid).  All jumps are
# recorded and patched uniformly at the end (works for forward and back edges).
SE_FIX_MAX: uint32 = 8192
se_fix_site: Array[8192, uint32]
se_fix_bid: Array[8192, uint32]
se_fix_n: uint32 = 0

# Call-argument scratch (values, in ABI order) — ≤6 (construction bails >6).
se_call_args: Array[8, uint32]

# stats (Phase-1b emission lane)
ssa_emit_stat_funcs: uint32 = 0
ssa_emit_stat_emitted: uint32 = 0
ssa_emit_stat_fallback: uint32 = 0


def ssa_emit_stats_reset():
    ssa_emit_stat_funcs = 0
    ssa_emit_stat_emitted = 0
    ssa_emit_stat_fallback = 0
    sra_prog_memop = 0
    sra_prog_regmov = 0
    sra_prog_regvals = 0
    sra_stat_overlap_viol = 0


# Parse the allocator's host-side test levers from the process environment
# (mirrors ssa_parse_env's envp walk).  ADDER_RA_OFF forces the all-memory
# lowering (A/B baseline for the traffic-reduction measurement); ADDER_RA_BREAK
# arms the overlap-invariant deliberate break (=2 skips the safety revert so the
# fuzzer can observe the miscompile the invariant prevents).  Off by default, so
# the normal OPT2 path is unaffected.
def sra_prefix_len(e: Ptr[uint8], pfx: Ptr[uint8]) -> uint32:
    j: uint32 = 0
    while pfx[j] != 0:
        if e[j] != pfx[j]:
            return 0
        j = j + 1
    return j


def ssa_emit_parse_env(argc: int32, argv: Ptr[uint64]):
    ei: uint32 = cast[uint32](argc) + 1
    while argv[ei] != 0:
        e: Ptr[uint8] = cast[Ptr[uint8]](argv[ei])
        k1: uint32 = sra_prefix_len(e, "ADDER_RA_OFF=")
        if k1 != 0:
            if e[k1] != 0:
                sra_disable = 1
        k2: uint32 = sra_prefix_len(e, "ADDER_RA_BREAK=")
        if k2 != 0:
            if e[k2] == cast[uint8](0x32):       # '2' => break WITHOUT safety revert
                sra_break_flag = 2
            elif e[k2] != 0:
                sra_break_flag = 1
        ei = ei + 1


# Stack slot (rbp-relative) for value `v` and its φ-temp companion.  Value slots
# occupy -8*v; temp slots occupy a disjoint region -8*(nvals+v).
def ssa_slot(v: uint32) -> int32:
    return 0 - cast[int32](v * 8)


def ssa_temp_slot(v: uint32) -> int32:
    return 0 - cast[int32]((ssa_nvals + v) * 8)


def se_fix_add(site: uint32, bid: uint32):
    if se_fix_n >= SE_FIX_MAX:
        return
    se_fix_site[se_fix_n] = site
    se_fix_bid[se_fix_n] = bid
    se_fix_n = se_fix_n + 1


# Load value `v` into %rax / %rcx — register-aware (Phase 3 allocator).  A value
# the allocator placed in a callee-saved GPR is read with a reg-reg mov; a
# spilled (SRA_MEM) value is loaded from its stack slot exactly as the trivial
# all-memory lowering did.  Because every op reads ALL its operands into the
# rax/rcx SCRATCH before writing its result home, an operand and the result may
# safely share a physical register (read-before-write), which is why linear scan
# is free to coalesce them.
def se_load_rax(v: uint32):
    r: uint32 = sra_vreg[v]
    if r != SRA_MEM:
        emit_mov_reg_reg(r, 0)                # movq %<r>, %rax
        sra_prog_regmov = sra_prog_regmov + 1
    else:
        emit_load_local_rax(ssa_slot(v))
        sra_prog_memop = sra_prog_memop + 1


def se_load_rcx(v: uint32):
    r: uint32 = sra_vreg[v]
    if r != SRA_MEM:
        emit_mov_reg_reg(r, 1)                # movq %<r>, %rcx
        sra_prog_regmov = sra_prog_regmov + 1
    else:
        emit_load_local_callee(1, ssa_slot(v))   # movq slot,%rcx
        sra_prog_memop = sra_prog_memop + 1


def se_store_rax(v: uint32):
    r: uint32 = sra_vreg[v]
    if r != SRA_MEM:
        emit_mov_reg_reg(0, r)                # movq %rax, %<r>
        sra_prog_regmov = sra_prog_regmov + 1
    else:
        emit_store_local_rax(ssa_slot(v))
        sra_prog_memop = sra_prog_memop + 1


# shlq %cl, %rax -> 48 D3 E0
def se_emit_shl_rax_cl():
    emit_b(0x48)
    emit_b(0xD3)
    emit_b(0xE0)


# negq %rax -> 48 F7 D8
def se_emit_neg_rax():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xD8)


# notq %rax -> 48 F7 D0
def se_emit_not_rax():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xD0)


# jmp rel32 to a (possibly forward) block; records a fixup.
def se_emit_jmp_block(bid: uint32):
    emit_b(0xE9)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    se_fix_add(at, bid)


# =======================================================================
# Phase 3 — SSA linear-scan register allocator (design §5).
# =======================================================================
# A value-based (NOT name-based) allocator: it computes precise live intervals
# from the SSA def/use graph, then a single ordered linear-scan walk (Poletto/
# Traub-style, spill-the-furthest-endpoint on pressure) assigns each value a
# physical register or leaves it in memory.  Because liveness is derived from the
# actual value graph — every use is an explicit operand edge — the liveness
# UNDER-approximation that let the OLD name-based allocator share one register
# between two genuinely-overlapping locals (the `unsafe:`/match-body kernel
# miscompile) CANNOT occur: the overlap-invariant is checked directly
# (sra_check_overlap) and holds by construction.
#
# POOL: only the SysV CALLEE-SAVED GPRs {rbx=3, r12..r15=12..15} are handed out.
# This is deliberately the safe subset:
#   * They are disjoint from the rax/rcx/rdx scratch the op sequences use and
#     from the rdi/rsi/rdx/rcx/r8/r9 call-argument registers, so no operand
#     load, no call-arg setup and no div/shift fixed-register use can ever
#     clobber a register-resident value.
#   * They SURVIVE a call (the callee preserves them), so a value live across a
#     call needs no special handling — every resident value is automatically
#     call-safe.  (§5.6.3's caller-saved extension pool for call-free lifetimes
#     is a future quality add; it needs parallel-copy-safe arg setup.)
# The prologue saves exactly the pool regs the allocation used, derived from the
# authoritative assignment (sra_used_mask), and the epilogue restores them on
# every RET — the one-source-of-truth save-set rule (§5.6.1).

SRA_MEM: uint32 = 0xFFFFFFFF          # sra_vreg sentinel: value lives in memory
SRA_NOPOOL: uint32 = 0xFFFFFFFF       # pool-index sentinel: no free pool slot
SRA_MAXV: uint32 = 2048               # >this many SSA values => all-memory fallback
SRA_MAXB: uint32 = 256                # >this many blocks     => all-memory fallback
SRA_WORDS: uint32 = 64                # SRA_MAXV / 32 (bitset words per block)
SRA_NPOOL: uint32 = 5                 # {rbx, r12, r13, r14, r15}

SRA_IN: uint32 = 0
SRA_OUT: uint32 = 1

# allocatable callee-saved encodings, in push order (filled in sra_pool_init).
sra_pool: Array[8, uint32]
sra_pool_ready: uint32 = 0

# per-value allocation results (indexed by vid; sized like the sv_* arenas).
sra_vreg: Array[65536, uint32]        # assigned x86 encoding, or SRA_MEM
sra_start: Array[65536, uint32]       # interval start = def position
sra_end: Array[65536, uint32]         # interval end   = last live position
sra_defpos: Array[65536, uint32]      # linear position of the defining instruction

# ---------------------------------------------------------------------------
# x86 addressing-mode folding (emission-lowering; allocator UNTOUCHED).
# For a memory op whose byte address is `base + index*scale` (the GLOBALADDR +
# idx*elem + SVO_LOAD/STORE chain ssa_index_addr builds), fold the index
# arithmetic into a single SIB memory operand `disp(%base,%index,scale)` instead
# of materializing the address with imul/add.  se_fold_ok[v] marks a LOAD/STORE
# that folds; se_fold_skip[w] marks the (single-use, same-block) address ADD, the
# scaling MUL and its scale constant so their normal emission is elided.
se_uc: Array[65536, uint32]           # per-value use count (fold-safety)
se_fold_skip: Array[65536, uint32]    # 1 => value folded into a memop; emit nothing
se_fold_ok: Array[65536, uint32]      # 1 => LOAD/STORE v uses a SIB memory operand
se_fold_base: Array[65536, uint32]    # vid supplying the base register
se_fold_index: Array[65536, uint32]   # vid supplying the index register
se_fold_scale: Array[65536, uint32]   # SIB scale in {1,2,4,8}

# reverse map: linear position -> vid defined there (0 = none).
sra_posval: Array[8192, uint32]

# per-block linear-position bounds (index = bid).
sra_blk_start: Array[256, uint32]
sra_blk_end: Array[256, uint32]

# liveness bitsets: sra_bs[(which*SRA_MAXB + bid)*SRA_WORDS + word], which in {IN,OUT}.
sra_bs: Array[32768, uint32]          # 2 * 256 * 64

# linear-scan working state: current occupant vid of each pool slot (0 = free).
sra_regocc: Array[8, uint32]

sra_used_mask: uint32 = 0             # bitmask over pool indices actually assigned
sra_maxpos: uint32 = 0

# stats + deliberate-break machinery (proves the overlap invariant is load-bearing).
sra_stat_reg_vals: uint32 = 0         # values that won a register (this function)
sra_stat_overlap_viol: uint32 = 0     # times sra_check_overlap FIRED (should be 0)
sra_break_flag: uint32 = 0            # 1 => force an overlap + safety-revert;
                                     # 2 => force an overlap, SKIP the revert
                                     #      (lets the fuzzer observe the miscompile).
sra_disable: uint32 = 0              # ADDER_RA_OFF=1 => force all-memory (A/B lever
                                     # to measure the allocator's traffic reduction).

# program-aggregate traffic counters (memory slot accesses vs register moves for
# value operands/results) — perf evidence that the allocator keeps values in regs.
sra_prog_memop: uint32 = 0
sra_prog_regmov: uint32 = 0
sra_prog_regvals: uint32 = 0


def sra_pool_init():
    if sra_pool_ready != 0:
        return
    sra_pool[0] = 3                    # rbx
    sra_pool[1] = 12                   # r12
    sra_pool[2] = 13                   # r13
    sra_pool[3] = 14                   # r14
    sra_pool[4] = 15                   # r15
    sra_pool_ready = 1


def sra_popcount(m: uint32) -> uint32:
    n: uint32 = 0
    i: uint32 = 0
    while i < 32:
        if ((m >> i) & 1) != 0:
            n = n + 1
        i = i + 1
    return n


# ---- liveness bitset helpers ------------------------------------------
def sra_bs_word(which: uint32, bid: uint32, v: uint32) -> uint32:
    return ((which * SRA_MAXB + bid) * SRA_WORDS) + (v >> 5)


def sra_bs_get(which: uint32, bid: uint32, v: uint32) -> uint32:
    return (sra_bs[sra_bs_word(which, bid, v)] >> (v & 31)) & 1


# Set bit; returns 1 iff it was newly set (drives fixpoint change detection).
def sra_bs_set(which: uint32, bid: uint32, v: uint32) -> uint32:
    idx: uint32 = sra_bs_word(which, bid, v)
    bit: uint32 = cast[uint32](1) << (v & 31)
    if (sra_bs[idx] & bit) != 0:
        return 0
    sra_bs[idx] = sra_bs[idx] | bit
    return 1


# True iff op `op` produces an SSA value that may be register-resident.
def sra_op_defines(op: uint32) -> uint32:
    if op == SVO_STORE or op == SVO_BR or op == SVO_CONDBR or op == SVO_RET:
        return 0
    return 1


# Seed liveIn with the block's upward-exposed uses (operands whose def is OUTSIDE
# this block).  φ operands are edge uses, handled in the liveOut union, so φs are
# skipped here.
def sra_seed_uses(bid: uint32, w: uint32):
    op: uint32 = sv_op[w]
    if op == SVO_PHI:
        return
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_STORE:
        if sv_block[sv_a[w]] != bid:
            sra_bs_set(SRA_IN, bid, sv_a[w])
        if sv_block[sv_b[w]] != bid:
            sra_bs_set(SRA_IN, bid, sv_b[w])
        return
    if op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT or op == SVO_LOAD or op == SVO_TRUNC:
        if sv_block[sv_a[w]] != bid:
            sra_bs_set(SRA_IN, bid, sv_a[w])
        return
    if op == SVO_CONDBR:
        if sv_block[sv_a[w]] != bid:
            sra_bs_set(SRA_IN, bid, sv_a[w])
        return
    if op == SVO_RET:
        if sv_a[w] != 0 and sv_block[sv_a[w]] != bid:
            sra_bs_set(SRA_IN, bid, sv_a[w])
        return
    if op == SVO_CALL:
        node: uint32 = sv_arg_head[w]
        while node != 0:
            u: uint32 = arg_val[node]
            if sv_block[u] != bid:
                sra_bs_set(SRA_IN, bid, u)
            node = arg_next[node]
        return


# Union successor `S`'s liveIn into pred `bid`'s liveOut, plus the φ operands of
# S that flow from edge bid.  Returns 1 iff any bit was newly set.
def sra_union_succ(bid: uint32, S: uint32) -> uint32:
    changed: uint32 = 0
    v: uint32 = 1
    while v < sv_count:
        if sra_bs_get(SRA_IN, S, v) != 0:
            if sra_bs_set(SRA_OUT, bid, v) != 0:
                changed = 1
        v = v + 1
    # φ inputs from this edge are live-out of bid.
    p: uint32 = sb_first_val[S]
    while p != 0:
        if sv_op[p] != SVO_PHI:
            p = 0
        else:
            node: uint32 = sv_arg_head[p]
            while node != 0:
                if arg_pred[node] == bid:
                    if sra_bs_set(SRA_OUT, bid, arg_val[node]) != 0:
                        changed = 1
                node = arg_next[node]
            p = sv_next[p]
    return changed


# Backward dataflow liveness fixpoint over the SSA CFG (value-based).  Monotone
# union iteration in reverse RPO; converges in <= loop-nesting-depth+2 passes.
def sra_compute_liveness():
    # zero the bitsets for every block in play.
    n: uint32 = 2 * SRA_MAXB * SRA_WORDS
    i: uint32 = 0
    while i < n:
        sra_bs[i] = 0
        i = i + 1
    # seed liveIn with upward-exposed uses.
    bi: uint32 = 0
    while bi < sb_rpo_n:
        bid: uint32 = sb_rpo[bi]
        w: uint32 = sb_first_val[bid]
        while w != 0:
            sra_seed_uses(bid, w)
            w = sv_next[w]
        bi = bi + 1
    # fixpoint.
    changed: uint32 = 1
    guard: uint32 = 0
    while changed != 0 and guard < (sb_count + 4):
        changed = 0
        guard = guard + 1
        j: uint32 = sb_rpo_n
        while j > 0:
            j = j - 1
            bid2: uint32 = sb_rpo[j]
            # liveOut[bid2] |= union of successor liveIn (+ φ edge operands).
            if sb_nsucc[bid2] >= 1:
                if sra_union_succ(bid2, sb_succ0[bid2]) != 0:
                    changed = 1
            if sb_nsucc[bid2] >= 2:
                if sra_union_succ(bid2, sb_succ1[bid2]) != 0:
                    changed = 1
            # liveIn[bid2] |= liveOut[bid2] minus values DEFINED in bid2.
            v2: uint32 = 1
            while v2 < sv_count:
                if sra_bs_get(SRA_OUT, bid2, v2) != 0 and sv_block[v2] != bid2:
                    if sra_bs_set(SRA_IN, bid2, v2) != 0:
                        changed = 1
                v2 = v2 + 1


# Assign linear positions (RPO instruction order) and record block bounds.
def sra_number_positions():
    pos: uint32 = 1
    p: uint32 = 0
    while p < SRA_MAXV * 2:
        if p < 8192:
            sra_posval[p] = 0
        p = p + 1
    i: uint32 = 0
    while i < sb_rpo_n:
        bid: uint32 = sb_rpo[i]
        sra_blk_start[bid] = pos
        last: uint32 = pos
        v: uint32 = sb_first_val[bid]
        while v != 0:
            sra_defpos[v] = pos
            if pos < 8192:
                sra_posval[pos] = v
            last = pos
            pos = pos + 1
            v = sv_next[v]
        sra_blk_end[bid] = last
        i = i + 1
    sra_maxpos = pos


# Build contiguous over-approximated intervals [def, last-live] from liveness +
# uses.  Over-approximation (treating a value as live across gaps in its range)
# is SOUND for allocation — it can only add conflicts, never remove them, so it
# never lets two live values share a register.  Holes/splitting (§5.4) are the
# quality refinement deferred past this correctness baseline.
def sra_extend(v: uint32, upto: uint32):
    if v != 0:
        if sra_end[v] < upto:
            sra_end[v] = upto


def sra_build_intervals():
    v: uint32 = 1
    while v < sv_count:
        sra_start[v] = sra_defpos[v]
        sra_end[v] = sra_defpos[v]
        v = v + 1
    # live-in / live-out extend a value across the whole block it is live in.
    i: uint32 = 0
    while i < sb_rpo_n:
        bid: uint32 = sb_rpo[i]
        e: uint32 = sra_blk_end[bid]
        v2: uint32 = 1
        while v2 < sv_count:
            if sra_bs_get(SRA_IN, bid, v2) != 0 or sra_bs_get(SRA_OUT, bid, v2) != 0:
                sra_extend(v2, e)
            v2 = v2 + 1
        i = i + 1
    # in-block uses (non-φ at the using instruction's position; φ operands at the
    # end of the predecessor block they flow from).
    j: uint32 = 0
    while j < sb_rpo_n:
        bid3: uint32 = sb_rpo[j]
        w: uint32 = sb_first_val[bid3]
        while w != 0:
            op: uint32 = sv_op[w]
            pos: uint32 = sra_defpos[w]
            if op == SVO_PHI:
                node: uint32 = sv_arg_head[w]
                while node != 0:
                    sra_extend(arg_val[node], sra_blk_end[arg_pred[node]])
                    node = arg_next[node]
            elif op == SVO_BINOP or op == SVO_ICMP or op == SVO_STORE:
                sra_extend(sv_a[w], pos)
                sra_extend(sv_b[w], pos)
            elif op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT or op == SVO_LOAD or op == SVO_TRUNC:
                sra_extend(sv_a[w], pos)
            elif op == SVO_CONDBR:
                sra_extend(sv_a[w], pos)
            elif op == SVO_RET:
                if sv_a[w] != 0:
                    sra_extend(sv_a[w], pos)
            elif op == SVO_CALL:
                node2: uint32 = sv_arg_head[w]
                while node2 != 0:
                    sra_extend(arg_val[node2], pos)
                    node2 = arg_next[node2]
            w = sv_next[w]
        j = j + 1


# Intervals [a] and [b] overlap iff neither ends at-or-before the other starts —
# the exact condition the linear-scan expiry test (end <= start => free) uses.
def sra_overlaps(a: uint32, b: uint32) -> uint32:
    if sra_start[a] < sra_end[b] and sra_start[b] < sra_end[a]:
        return 1
    return 0


# The linear-scan walk: values in def-position order; expire, then assign a free
# pool reg, else spill the active value whose interval ends furthest (giving its
# register to the newcomer only if that strictly shortens total register
# pressure), else spill the newcomer.
def sra_linear_scan():
    k: uint32 = 0
    while k < SRA_NPOOL:
        sra_regocc[k] = 0
        k = k + 1
    sra_used_mask = 0
    sra_stat_reg_vals = 0
    pos: uint32 = 1
    while pos < sra_maxpos:
        v: uint32 = 0
        if pos < 8192:
            v = sra_posval[pos]
        if v != 0 and sra_op_defines(sv_op[v]) != 0 and sra_end[v] > sra_start[v]:
            # expire occupants whose interval ended at-or-before v starts.
            e: uint32 = 0
            while e < SRA_NPOOL:
                occ: uint32 = sra_regocc[e]
                if occ != 0 and sra_end[occ] <= sra_start[v]:
                    sra_regocc[e] = 0
                e = e + 1
            # find a free pool slot.
            free: uint32 = SRA_NOPOOL
            f: uint32 = 0
            while f < SRA_NPOOL:
                if sra_regocc[f] == 0 and free == SRA_NOPOOL:
                    free = f
                f = f + 1
            if free != SRA_NOPOOL:
                sra_regocc[free] = v
                sra_vreg[v] = sra_pool[free]
                sra_used_mask = sra_used_mask | (cast[uint32](1) << free)
                sra_stat_reg_vals = sra_stat_reg_vals + 1
            else:
                # all busy: pick the occupant with the furthest endpoint.
                maxk: uint32 = 0
                maxend: uint32 = 0
                kk: uint32 = 0
                while kk < SRA_NPOOL:
                    occ2: uint32 = sra_regocc[kk]
                    if sra_end[occ2] > maxend:
                        maxend = sra_end[occ2]
                        maxk = kk
                    kk = kk + 1
                if maxend > sra_end[v]:
                    spilled: uint32 = sra_regocc[maxk]
                    sra_vreg[spilled] = SRA_MEM
                    sra_regocc[maxk] = v
                    sra_vreg[v] = sra_pool[maxk]
                    sra_stat_reg_vals = sra_stat_reg_vals + 1
                else:
                    sra_vreg[v] = SRA_MEM
        pos = pos + 1


# Direct assertion of the invariant the OLD allocator violated: no two values
# with OVERLAPPING live intervals share a physical register.  Returns 1 on a
# violation (which, by construction of the linear scan, never happens — unless
# the deliberate break is armed).
def sra_check_overlap() -> uint32:
    a: uint32 = 1
    while a < sv_count:
        if sra_vreg[a] != SRA_MEM:
            b: uint32 = a + 1
            while b < sv_count:
                if sra_vreg[b] != SRA_MEM and sra_vreg[b] == sra_vreg[a]:
                    if sra_overlaps(a, b) != 0:
                        return 1
                b = b + 1
        a = a + 1
    return 0


# Deliberate break: find the first pair of register-assigned values whose
# intervals overlap (the linear scan gave them DIFFERENT regs) and force them to
# share one, so sra_check_overlap must fire.  Proves the invariant is load-bearing.
def sra_force_overlap():
    a: uint32 = 1
    while a < sv_count:
        if sra_vreg[a] != SRA_MEM:
            b: uint32 = a + 1
            while b < sv_count:
                if sra_vreg[b] != SRA_MEM and sra_overlaps(a, b) != 0:
                    sra_vreg[b] = sra_vreg[a]     # force the illegal share
                    return
                b = b + 1
        a = a + 1


# Set every value to memory (the trivial all-memory lowering).  Used as the
# fallback when the function exceeds the allocator's static bounds, and as the
# safety revert if the overlap check ever fires.
def sra_all_memory():
    v: uint32 = 0
    while v < sv_count:
        sra_vreg[v] = SRA_MEM
        v = v + 1
    sra_used_mask = 0
    sra_stat_reg_vals = 0


# Whole allocation for the current function (SSA already built + verified, so RPO
# and dom info are current).  Fills sra_vreg / sra_used_mask.
def sra_allocate():
    sra_pool_init()
    sra_all_memory()
    if sra_disable != 0:
        return                                  # ADDER_RA_OFF: force all-memory (A/B)
    if sv_count > SRA_MAXV or sb_count > SRA_MAXB:
        return                                  # too big -> all memory (correct)
    sra_number_positions()
    sra_compute_liveness()
    sra_build_intervals()
    sra_linear_scan()
    if sra_break_flag != 0:
        sra_force_overlap()
    if sra_check_overlap() != 0:
        sra_stat_overlap_viol = sra_stat_overlap_viol + 1
        if sra_break_flag != 2:
            sra_all_memory()                     # safety net: never emit a violation
    sra_prog_regvals = sra_prog_regvals + sra_stat_reg_vals


# Prologue callee-saved SAVE set = exactly the pool regs the allocation used
# (sra_used_mask), pushed in pool order BEFORE `push %rbp` so `leave` (which pops
# rbp) leaves them exposed on top of the stack for the epilogue.  With no
# register allocated (sra_used_mask == 0) this collapses to the trivial prologue,
# byte-identical to the all-memory lowering.
def se_emit_callee_saves():
    p: uint32 = 0
    while p < SRA_NPOOL:
        if ((sra_used_mask >> p) & 1) != 0:
            emit_push_callee(sra_pool[p])
        p = p + 1


# Epilogue: `leave` (rsp=rbp; pop rbp) exposes the saved callee regs, popped in
# REVERSE pool order, then `ret`.  Emitted at every SVO_RET — SSA guarantees each
# block ends in exactly one terminator, so no return path can forget the restore.
def se_emit_epilogue():
    emit_leave()
    p: uint32 = SRA_NPOOL
    while p > 0:
        p = p - 1
        if ((sra_used_mask >> p) & 1) != 0:
            emit_pop_callee(sra_pool[p])
    emit_ret()


# =======================================================================
# DIRECT-ALU-ON-RESIDENT-OPERANDS (Phase-3 quality win, design §5).
# =======================================================================
# When an op's operands and destination are ALL register-resident (the linear-
# scan allocator gave each a callee-saved pool GPR, not a spill slot), lower the
# op DIRECTLY on those registers — `add %r13, %r12` — instead of the mov-to-
# scratch / op / mov-back round-trip.  The scratch-mediated path (se_load_rax,
# se_load_rcx, op, se_store_rax) is retained for every case that touches memory
# (a spilled operand or destination) and for the fixed-register ops (div/idiv/
# mod need rax:rdx, shifts need cl), so correctness is unchanged there.  The
# result register IS the value's home, so no store follows a direct op.
#
# This lane is reached ONLY under ADDER_OPT2 (ssa_emit_program), so the flag-off
# codegen path is untouched and stays byte-identical to the seed.

# The 2-byte reg/reg ALU ops emit_alu_reg_reg can lower (dst = dst OP src).
def se_alu_std(aux: uint32) -> uint32:
    if aux == BINOP_ADD or aux == BINOP_SUB or aux == BINOP_MUL:
        return 1
    if aux == BINOP_BIT_AND or aux == BINOP_BIT_OR or aux == BINOP_BIT_XOR:
        return 1
    return 0


# Commutative subset (order of operands is free -> more single-instruction cases).
def se_alu_commutative(aux: uint32) -> uint32:
    if aux == BINOP_ADD or aux == BINOP_MUL:
        return 1
    if aux == BINOP_BIT_AND or aux == BINOP_BIT_OR or aux == BINOP_BIT_XOR:
        return 1
    return 0


# `negq/notq %<reg>` for an arbitrary GPR (F7 /3 = neg, /2 = not); the codegen
# helpers only cover %rax, so the resident path encodes the byte form here.
def se_emit_unary_reg(reg: uint32, digit: uint32):
    rex: uint32 = 0x48                        # REX.W
    if reg >= 8:
        rex = rex | 0x01                      # REX.B extends r/m=reg
    emit_b(rex)
    emit_b(0xF7)
    emit_b(0xC0 + (digit << 3) + (reg & 7))


# Emit a fully-register-resident binop  rv = ra OP rb  directly.  Returns 1 iff
# it lowered the op (all three of dst/lhs/rhs are pool registers and OP has a
# reg/reg form); 0 tells the caller to use the scratch-mediated path.
def se_binop_direct(v: uint32, aux: uint32) -> uint32:
    if se_alu_std(aux) == 0:
        return 0
    rv: uint32 = sra_vreg[v]
    ra: uint32 = sra_vreg[sv_a[v]]
    rb: uint32 = sra_vreg[sv_b[v]]
    if rv == SRA_MEM or ra == SRA_MEM or rb == SRA_MEM:
        return 0
    if se_alu_commutative(aux) != 0:
        if rv == ra:
            emit_alu_reg_reg(aux, rb, rv)     # rv = ra OP rb
        elif rv == rb:
            emit_alu_reg_reg(aux, ra, rv)     # rv = rb OP ra  (commutes)
        else:
            emit_mov_reg_reg(ra, rv)
            emit_alu_reg_reg(aux, rb, rv)     # rv = ra; rv OP= rb
        sra_prog_regmov = sra_prog_regmov + 1
        return 1
    # non-commutative SUB: rv = ra - rb.
    if rv == ra:
        emit_alu_reg_reg(aux, rb, rv)         # rv -= rb
        sra_prog_regmov = sra_prog_regmov + 1
        return 1
    if rv != rb:
        emit_mov_reg_reg(ra, rv)
        emit_alu_reg_reg(aux, rb, rv)         # rv = ra; rv -= rb
        sra_prog_regmov = sra_prog_regmov + 1
        return 1
    # rv holds rb (rv == rb, rv != ra): compute rb - ra then negate -> ra - rb.
    emit_alu_reg_reg(aux, ra, rv)             # rv = rb - ra
    se_emit_unary_reg(rv, 3)                  # neg rv => ra - rb
    sra_prog_regmov = sra_prog_regmov + 1
    return 1


# Fully-resident unary  rv = OP ra  (NEG digit=3, NOT/BITNOT digit=2).  Returns
# 1 iff lowered directly; 0 -> caller falls back to the scratch path.
def se_unary_direct(v: uint32, digit: uint32) -> uint32:
    rv: uint32 = sra_vreg[v]
    ra: uint32 = sra_vreg[sv_a[v]]
    if rv == SRA_MEM or ra == SRA_MEM:
        return 0
    if rv != ra:
        emit_mov_reg_reg(ra, rv)
    se_emit_unary_reg(rv, digit)
    sra_prog_regmov = sra_prog_regmov + 1
    return 1


# =======================================================================
# x86 SIB addressing-mode folding — encoders + analysis (emission-lowering).
# =======================================================================

# Load SSA value `v` into physical scratch register `dst` (rax=0/rcx=1/rdx=2),
# register-aware exactly like se_load_rax: a pool-resident value moves reg->reg,
# a spilled value loads from its stack slot.  The pool ({rbx,r12..r15}) is
# disjoint from rax/rcx/rdx, so successive se_load_into calls to distinct scratch
# dsts never clobber an as-yet-unread source.
def se_load_into(v: uint32, dst: uint32):
    r: uint32 = sra_vreg[v]
    if r != SRA_MEM:
        if r != dst:
            emit_mov_reg_reg(r, dst)
    else:
        emit_load_local_callee(dst, ssa_slot(v))


# SIB scale field encoding: log2(scale) for scale in {1,2,4,8}.
def se_scale_bits(scale: uint32) -> uint32:
    if scale == 8:
        return 3
    if scale == 4:
        return 2
    if scale == 2:
        return 1
    return 0


# Emit the modrm+sib(+disp) bytes for the memory operand `disp(%base,%index,scale)`
# with modrm.reg = `reg` (low 3 bits; REX carries the 4th).  r/m = 100 selects a
# SIB byte.  mod picks the disp width; base low-3 == 101 (rbp/r13) has no mod=00
# form so a zero disp8 is forced there.
def se_emit_sib_operand(reg: uint32, base: uint32, index: uint32, scale: uint32,
                        disp: int32):
    sib: uint32 = (se_scale_bits(scale) << 6) | ((index & 7) << 3) | (base & 7)
    if disp == 0 and (base & 7) != 5:
        emit_b(((reg & 7) << 3) | 4)              # mod=00, r/m=100
        emit_b(sib)
    elif disp >= 0 - 128 and disp <= 127:
        emit_b(0x40 | ((reg & 7) << 3) | 4)       # mod=01, disp8
        emit_b(sib)
        emit_b(cast[uint32](disp) & 0xFF)
    else:
        emit_b(0x80 | ((reg & 7) << 3) | 4)       # mod=10, disp32
        emit_b(sib)
        emit_imm32(cast[uint64](cast[uint32](disp)))


# REX byte for a SIB memory op: W set unless it is an unsigned 32-bit access
# (movl / movl-store zero-extend the 64-bit dest, matching emit_load_mem_rax).
# R extends modrm.reg, X the SIB index, B the SIB base.
def se_sib_rex(regfield: uint32, base: uint32, index: uint32, w: uint32) -> uint32:
    rex: uint32 = 0x40
    if w != 0:
        rex = rex | 0x08
    if regfield >= 8:
        rex = rex | 0x04
    if index >= 8:
        rex = rex | 0x02
    if base >= 8:
        rex = rex | 0x01
    return rex


# mov(zx/sx) disp(%base,%index,scale) -> %dst, sized by `size`, `signed` chooses
# movsx over movzx for sub-word loads.  Mirrors emit_load_mem_rax / _signed but
# with a SIB memory operand instead of the plain (%rax) form.
def se_emit_indexed_load(dst: uint32, base: uint32, index: uint32, scale: uint32,
                         disp: int32, size: uint32, signed: uint32):
    w: uint32 = 1
    if size == 4 and signed == 0:
        w = 0                                     # movl zero-extends; no REX.W
    rex: uint32 = se_sib_rex(dst, base, index, w)
    if rex != 0x40:
        emit_b(rex)
    if size == 1:
        emit_b(0x0F)
        if signed != 0:
            emit_b(0xBE)                          # movsbq
        else:
            emit_b(0xB6)                          # movzbq
    elif size == 2:
        emit_b(0x0F)
        if signed != 0:
            emit_b(0xBF)                          # movswq
        else:
            emit_b(0xB7)                          # movzwq
    elif size == 4:
        if signed != 0:
            emit_b(0x63)                          # movslq
        else:
            emit_b(0x8B)                          # movl
    else:
        emit_b(0x8B)                              # movq
    se_emit_sib_operand(dst, base, index, scale, disp)


# mov %src -> disp(%base,%index,scale), sized store; mirrors emit_store_mem_rcx.
def se_emit_indexed_store(src: uint32, base: uint32, index: uint32, scale: uint32,
                          disp: int32, size: uint32):
    if size == 2:
        emit_b(0x66)                              # 16-bit operand-size prefix
    w: uint32 = 0
    if size != 1 and size != 2 and size != 4:
        w = 1                                     # 8-byte store needs REX.W
    rex: uint32 = se_sib_rex(src, base, index, w)
    if rex != 0x40:
        emit_b(rex)
    if size == 1:
        emit_b(0x88)                              # movb
    else:
        emit_b(0x89)                              # movw/movl/movq (width via 66/REX.W)
    se_emit_sib_operand(src, base, index, scale, disp)


# Count every SSA use of each value (all operand edges the allocator's liveness
# walk visits), plus reset the fold tables.  A value used exactly once by an
# address computation can be safely elided when that address folds into a memop.
def se_uc_add(x: uint32):
    if x != 0 and x < 65536:
        se_uc[x] = se_uc[x] + 1


def se_count_uses():
    v: uint32 = 1
    while v < sv_count:
        se_uc[v] = 0
        se_fold_skip[v] = 0
        se_fold_ok[v] = 0
        v = v + 1
    w: uint32 = 1
    while w < sv_count:
        op: uint32 = sv_op[w]
        if op == SVO_BINOP or op == SVO_ICMP or op == SVO_STORE:
            se_uc_add(sv_a[w])
            se_uc_add(sv_b[w])
        elif op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT or op == SVO_LOAD or op == SVO_TRUNC or op == SVO_CONDBR:
            se_uc_add(sv_a[w])
        elif op == SVO_RET:
            if sv_a[w] != 0:
                se_uc_add(sv_a[w])
        elif op == SVO_CALL:
            node: uint32 = sv_arg_head[w]
            while node != 0:
                se_uc_add(arg_val[node])
                node = arg_next[node]
        elif op == SVO_PHI:
            node2: uint32 = sv_arg_head[w]
            while node2 != 0:
                se_uc_add(arg_val[node2])
                node2 = arg_next[node2]
        w = w + 1


# Decide whether LOAD/STORE `v` can fold its address into a SIB memory operand.
# Pattern (ssa_index_addr): addr = ADD(base, sidx) where sidx is the index side,
# optionally sidx = MUL(index, const) with const in {1,2,4,8}.  The ADD (and the
# MUL + its scale const) must each be single-use and live in v's own block so the
# base/index operands are still resident when the folded memop reads them.
def se_try_fold(v: uint32):
    addr: uint32 = sv_a[v]
    if addr == 0:
        return
    if sv_op[addr] != SVO_BINOP or sv_aux[addr] != BINOP_ADD:
        return
    if se_uc[addr] != 1 or sv_block[addr] != sv_block[v]:
        return
    base: uint32 = sv_a[addr]
    sidx: uint32 = sv_b[addr]
    idxreg: uint32 = sidx
    scale: uint32 = 1
    mul: uint32 = 0
    cnode: uint32 = 0
    if sv_op[sidx] == SVO_BINOP and sv_aux[sidx] == BINOP_MUL and se_uc[sidx] == 1 and sv_block[sidx] == sv_block[v]:
        cn: uint32 = 0
        ot: uint32 = 0
        if sv_op[sv_b[sidx]] == SVO_CONST:
            cn = sv_b[sidx]
            ot = sv_a[sidx]
        elif sv_op[sv_a[sidx]] == SVO_CONST:
            cn = sv_a[sidx]
            ot = sv_b[sidx]
        if cn != 0:
            c: uint64 = sv_imm[cn]
            if c == 1 or c == 2 or c == 4 or c == 8:
                scale = cast[uint32](c)
                idxreg = ot
                mul = sidx
                cnode = cn
    if base == 0 or idxreg == 0:
        return
    se_fold_ok[v] = 1
    se_fold_base[v] = base
    se_fold_index[v] = idxreg
    se_fold_scale[v] = scale
    se_fold_skip[addr] = 1                         # the address ADD is now dead
    if mul != 0:
        se_fold_skip[mul] = 1                      # the scaling MUL is now dead
        if se_uc[cnode] == 1:
            se_fold_skip[cnode] = 1                # its scale constant, if private


# Analyse the whole function's LOAD/STORE ops for address folds (call after the
# allocator has assigned registers; it reads sra_vreg but never changes it).
def se_analyze_folds():
    se_count_uses()
    v: uint32 = 1
    while v < sv_count:
        op: uint32 = sv_op[v]
        if op == SVO_LOAD or op == SVO_STORE:
            se_try_fold(v)
        v = v + 1


# =======================================================================
# per-value emission (register-resident where allocated, else all-memory).
# =======================================================================
def ssa_emit_value(v: uint32):
    op: uint32 = sv_op[v]

    if op == SVO_PARAM:
        # move the incoming SysV arg register to the param's home: its callee-
        # saved register if allocated, else its stack slot.  Params are processed
        # before any body code and each move's SOURCE is an arg register while its
        # DEST is a callee-saved register (disjoint sets), so an earlier param's
        # move never clobbers a later param's still-live incoming arg register.
        r: uint32 = sra_vreg[v]
        if r != SRA_MEM:
            emit_mov_reg_reg(sysv_arg_reg_enc(sv_aux[v]), r)
        else:
            emit_store_local_callee(sysv_arg_reg_enc(sv_aux[v]), ssa_slot(v))
        return

    if op == SVO_CONST:
        emit_mov_imm_rax(sv_imm[v])
        se_store_rax(v)
        return

    if op == SVO_UNDEF:
        emit_xor_rax_rax()
        se_store_rax(v)
        return

    if op == SVO_BINOP:
        aux: uint32 = sv_aux[v]
        # Fast path: operands + dest all register-resident -> ALU straight on the
        # pool registers (no scratch round-trip, result IS the value's home).
        if se_binop_direct(v, aux) != 0:
            return
        se_load_rax(sv_a[v])                     # rax = left (dividend / value)
        se_load_rcx(sv_b[v])                     # rcx = right (divisor / count)
        if aux == BINOP_SHL:
            se_emit_shl_rax_cl()                 # rax <<= cl  (low-64 invariant)
        elif aux == BINOP_SHR:
            # sv_c = 1 => arithmetic (sar), 0 => logical (shr) — set at construction.
            if sv_c[v] != 0:
                emit_sar_cl_rax()
            else:
                emit_shr_cl_rax()
        elif aux == BINOP_DIV or aux == BINOP_IDIV or aux == BINOP_MOD:
            # sv_c = 1 => signed (cqo;idiv), 0 => unsigned (xor rdx;div).
            if sv_c[v] != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
            if aux == BINOP_MOD:
                emit_mov_rdx_rax()               # remainder -> rax
        else:
            emit_alu_reg_reg(aux, 1, 0)          # rax = rax OP rcx (ADD/SUB/MUL/AND/OR/XOR)
        se_store_rax(v)
        return

    if op == SVO_NEG:
        if se_unary_direct(v, 3) != 0:           # neg: F7 /3
            return
        se_load_rax(sv_a[v])
        se_emit_neg_rax()
        se_store_rax(v)
        return

    if op == SVO_BITNOT:
        if se_unary_direct(v, 2) != 0:           # not: F7 /2
            return
        se_load_rax(sv_a[v])
        se_emit_not_rax()
        se_store_rax(v)
        return

    if op == SVO_TRUNC:
        # narrowing cast: truncate + re-extend the operand to sv_aux bytes.
        # sv_c = 1 => sign-extend (movsx), 0 => zero-extend (movzx).
        se_load_rax(sv_a[v])
        emit_ext_rax(sv_aux[v], sv_c[v])
        se_store_rax(v)
        return

    if op == SVO_GLOBALADDR:
        # RIP-relative lea of a scalar global; sv_imm = data offset, sv_c = is_bss.
        emit_lea_global_rax(cast[uint32](sv_imm[v]), sv_c[v])
        se_store_rax(v)
        return

    if op == SVO_LOAD:
        # sized load from the address value in sv_a; sv_aux = width, sv_c = signed.
        if se_fold_ok[v] != 0:
            # base+index*scale folds into one SIB memory operand: read base/index
            # into scratch (rax/rcx) — the address ADD/MUL are elided entirely.
            se_load_into(se_fold_base[v], 0)     # base  -> rax
            se_load_into(se_fold_index[v], 1)    # index -> rcx
            se_emit_indexed_load(0, 0, 1, se_fold_scale[v], 0, sv_aux[v], sv_c[v])
            se_store_rax(v)
            return
        se_load_rax(sv_a[v])                     # rax = address
        if sv_c[v] != 0:
            emit_load_mem_rax_signed(sv_aux[v])
        else:
            emit_load_mem_rax(sv_aux[v])
        se_store_rax(v)
        return

    if op == SVO_STORE:
        # sized store of value (sv_b) to the address value (sv_a); sv_aux = width.
        if se_fold_ok[v] != 0:
            se_load_into(se_fold_base[v], 0)     # base  -> rax
            se_load_into(se_fold_index[v], 1)    # index -> rcx
            se_load_into(sv_b[v], 2)             # value -> rdx
            se_emit_indexed_store(2, 0, 1, se_fold_scale[v], 0, sv_aux[v])
            return
        se_load_rax(sv_a[v])                     # rax = address
        se_load_rcx(sv_b[v])                     # rcx = value
        emit_store_mem_rcx(sv_aux[v])
        return

    if op == SVO_NOT:
        # logical not: rax = (a == 0) ? 1 : 0
        se_load_rax(sv_a[v])
        emit_test_rax_rax()
        emit_setcc_al(0x94)                      # sete %al
        emit_movzx_al_rax()
        se_store_rax(v)
        return

    if op == SVO_ICMP:
        se_load_rax(sv_a[v])
        se_load_rcx(sv_b[v])
        emit_cmp_rcx_rax()                       # cmpq %rcx,%rax  (flags of a-b)
        # sv_c carries the resolved setcc opcode (EQ/NEQ + signed/unsigned ordered),
        # picked at construction from operand signedness.
        emit_setcc_al(sv_c[v])
        emit_movzx_al_rax()
        se_store_rax(v)
        return

    if op == SVO_CALL:
        ssa_emit_call(v)
        return

    # SVO_PHI is handled at block head; terminators by ssa_emit_term; anything
    # else is outside the accepted subset and cannot reach here.
    return


def ssa_emit_call(v: uint32):
    node: uint32 = sv_ast[v]
    callee: uint32 = nd_a[node]
    argc: uint32 = sv_aux[v]
    # The use-list is prepended, so its head is the LAST argument.  Reverse it
    # into ABI order.
    node2: uint32 = sv_arg_head[v]
    j: uint32 = 0
    while node2 != 0:
        if argc >= 1 + j:
            se_call_args[argc - 1 - j] = arg_val[node2]
        j = j + 1
        node2 = arg_next[node2]
    # Load each argument into its SysV integer register.  Sources are either a
    # stack slot or a CALLEE-SAVED register (the allocator's only pool), both
    # disjoint from the arg registers being written, so the loads stay order-
    # independent — writing an arg register can never clobber a not-yet-read
    # source.
    i: uint32 = 0
    while i < argc:
        av: uint32 = se_call_args[i]
        ar: uint32 = sra_vreg[av]
        if ar != SRA_MEM:
            emit_mov_reg_reg(ar, sysv_arg_reg_enc(i))
        else:
            emit_load_local_callee(sysv_arg_reg_enc(i), ssa_slot(av))
        i = i + 1
    emit_xor_eax_eax()                           # AL = 0 (variadic ABI, matches legacy default)
    emit_b(0xE8)                                 # call rel32
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_call_fixup(at, nd_name_off[callee], nd_name_len[callee])
    se_store_rax(v)                              # result in %rax -> slot


# φ read: move the value staged in the φ's temp slot into its value slot (the
# staging happened on each predecessor edge, see ssa_emit_edge_copies).
def ssa_emit_phi_read(v: uint32):
    emit_load_local_rax(ssa_temp_slot(v))
    se_store_rax(v)


# On edge pred->succ, stage each φ's incoming value (for THIS pred) into the φ's
# temp slot.  Reads value slots, writes temp slots — disjoint regions, so the
# parallel copy is hazard-free even for swap cycles.
def ssa_emit_edge_copies(pred: uint32, succ: uint32):
    v2: uint32 = sb_first_val[succ]
    while v2 != 0:
        if sv_op[v2] != SVO_PHI:
            return
        node: uint32 = sv_arg_head[v2]
        src: uint32 = 0
        while node != 0:
            if arg_pred[node] == pred:
                src = arg_val[node]
                node = 0
            else:
                node = arg_next[node]
        if src != 0:
            se_load_rax(src)                     # register-aware read of the source
            emit_store_local_rax(ssa_temp_slot(v2))
        v2 = sv_next[v2]


def ssa_emit_term(v: uint32, bb: uint32):
    op: uint32 = sv_op[v]
    if op == SVO_RET:
        if sv_a[v] != 0:
            se_load_rax(sv_a[v])
        else:
            emit_xor_rax_rax()
        se_emit_epilogue()
        return
    if op == SVO_BR:
        tgt: uint32 = sv_a[v]
        ssa_emit_edge_copies(bb, tgt)
        se_emit_jmp_block(tgt)
        return
    if op == SVO_CONDBR:
        cond: uint32 = sv_a[v]
        then_bb: uint32 = sv_b[v]
        else_bb: uint32 = sv_c[v]
        se_load_rax(cond)
        emit_test_rax_rax()
        jzsite: uint32 = emit_jz_fwd()           # cond==0 -> take the else path
        # then edge
        ssa_emit_edge_copies(bb, then_bb)
        se_emit_jmp_block(then_bb)
        # else edge
        patch_rel32(jzsite, code_len)
        ssa_emit_edge_copies(bb, else_bb)
        se_emit_jmp_block(else_bb)
        return


# =======================================================================
# whole-function emission.  Returns 1 if the function was emitted through the
# SSA pipeline, 0 if it bailed (escape hatch -> caller emits legacy).
# =======================================================================
def ssa_emit_function(fn: uint32) -> uint32:
    ssa_emit_stat_funcs = ssa_emit_stat_funcs + 1
    entry: uint32 = ssa_build_function(fn)
    if entry == 0 or ssa_bail != 0:
        ssa_emit_stat_fallback = ssa_emit_stat_fallback + 1
        return 0
    # Phase-2 optimization passes (SCCP/InstCombine/GVN/LICM/DCE) transform the
    # SSA before the trivial lowering.  Each preserves SSA well-formedness; the
    # verify below is the final gate (a pass that malforms the IR falls the whole
    # function back to legacy, exactly like a construction bail).
    ssa_opt_run(entry)
    rc: uint32 = ssa_verify()                    # also builds RPO + domtree
    if rc != SSAV_OK:
        ssa_emit_stat_fallback = ssa_emit_stat_fallback + 1
        return 0

    # Phase 3: SSA linear-scan register allocation (value-based liveness ->
    # intervals -> linear scan -> overlap-invariant check).  Fills sra_vreg /
    # sra_used_mask; on any bound overflow it falls back to all-memory, which
    # reproduces the trivial lowering exactly.
    sra_allocate()

    # Emission-lowering: fold `base+index*scale` addresses into SIB memory
    # operands (reads the allocation, never mutates it).
    se_analyze_folds()

    ssa_nvals = sv_count
    ssa_last_fn_start = code_len
    se_fix_n = 0
    # clear block offsets
    b: uint32 = 0
    while b < sb_count:
        se_bid_off[b] = 0
        b = b + 1

    # symbol + prologue.  Register-resident values live in CALLEE-SAVED GPRs, so
    # the prologue pushes exactly the pool regs the allocation used (sra_used_mask)
    # and the epilogue pops them on every return.  An odd number of callee pushes
    # is padded by 8 so %rsp stays 16-byte aligned at inner call sites.  With no
    # register allocated this is byte-identical to the trivial all-memory prologue.
    fn_define(nd_name_off[fn], nd_name_len[fn], code_len)
    kpop: uint32 = sra_popcount(sra_used_mask)
    frame: uint32 = ((2 * sv_count * 8) + 15) & cast[uint32](0xFFFFFFF0)
    if (kpop & 1) != 0:
        frame = frame + 8
    emit_endbr64()
    se_emit_callee_saves()
    emit_push_rbp()
    emit_mov_rsp_rbp()
    if frame > 0:
        emit_sub_rsp(frame)

    # emit every reachable block in RPO (entry first).
    i: uint32 = 0
    while i < sb_rpo_n:
        bb: uint32 = sb_rpo[i]
        se_bid_off[bb] = code_len
        vv: uint32 = sb_first_val[bb]
        while vv != 0:
            op: uint32 = sv_op[vv]
            if op == SVO_PHI:
                ssa_emit_phi_read(vv)
            elif ssa_is_terminator(op) != 0:
                ssa_emit_term(vv, bb)
            elif se_fold_skip[vv] != 0:
                # address ADD/MUL folded into a following SIB memop — emit nothing.
                pass
            else:
                ssa_emit_value(vv)
            vv = sv_next[vv]
        i = i + 1

    # patch every recorded jump against its (now-known) target block offset.
    k: uint32 = 0
    while k < se_fix_n:
        patch_rel32(se_fix_site[k], se_bid_off[se_fix_bid[k]])
        k = k + 1

    ssa_emit_stat_emitted = ssa_emit_stat_emitted + 1
    return 1


# =======================================================================
# program driver (ADDER_OPT2 codegen lane).  Mirrors codegen.ad's
# gen_program_with_globals EXACTLY, except each top-level ND_FUNCTION is first
# offered to ssa_emit_function; on bail it falls through to the legacy
# gen_function.  Class methods, globals, extern linking and all fixup resolution
# use codegen's unchanged machinery, so an SSA-emitted function and a legacy one
# interoperate through the same symbol table / call fixups.
# =======================================================================
def ssa_emit_program(prog: uint32) -> uint32:
    # The native --opt backend NEVER models local memory (no alloca lowering in
    # the x86 emitter); keep the subset narrow so its bail set — and byte output —
    # is identical to the pre-memory build.
    ssa_mem_model = 0
    ssa_emit_stats_reset()
    ssa_prog_decls = nd_b[prog]
    cg_prog_decls = nd_b[prog]
    if cg_target_kernel != 0:
        collect_externs(prog)
    layout_classes(prog)
    register_enums(prog)
    layout_globals(prog)
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    first: uint32 = 0
    seen: uint32 = 0
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            off: uint32 = 0
            if ssa_emit_function(cur) != 0:
                off = ssa_last_fn_start
            else:
                off = gen_function(cur)
            if seen == 0:
                first = off
                seen = 1
        cur = nd_next[cur]
    gen_class_methods(prog)
    if seen == 0:
        cg_fail(9, 0)
        return 0
    if cg_target_kernel == 0:
        link_runtime_externs()
    resolve_calls()
    resolve_method_calls()
    resolve_data_fixups()
    resolve_entry(first)
    return first

# adder/compiler/ir.ad
#
# Native Adder optimizer — Phase 1 IR scaffold.
#
# WHAT THIS IS
# ------------
# The self-hosted Adder backend (codegen.ad) is a single-pass AST walker:
# it lowers the parser's AST arena (nd_kind/nd_a/nd_b/... in parser.ad)
# DIRECTLY to x86_64 machine code. There is no intermediate representation.
#
# The locked compiler strategy after the native cutover is to build the
# real optimizer NATIVE IN ADDER (LLVM permanently rejected; the Python
# seed's optimizer stays a frozen oracle only). This file is Phase 1: a
# small, typed, linear IR scaffold plus the lowering glue, so later phases
# (LICM / CSE / regalloc) have a substrate to operate on.
#
# Phase 1 deliberately models ONLY the slice of the AST that a trivial,
# provably-safe pass needs: constant integer expression trees. A foldable
# subtree (literal OP literal, recursively) lowers into one IR "const"
# value; the const-fold pass (opt.ad) evaluates it and writes the result
# back into the AST as a single ND_INT_LIT node. codegen.ad then emits the
# byte-IDENTICAL `movq $imm,%rax` it would have emitted for that constant
# anyway — which is exactly why folding here cannot change codegen output
# beyond replacing a multi-instruction const computation with its result.
#
# DESIGN INVARIANTS
# -----------------
#   * No dynamic allocation: the IR lives in fixed global parallel arrays,
#     mirroring the AST arena style.
#   * The IR is OFF the default path. opt.ad only builds IR when the opt
#     flag is enabled; with the flag off this module is never entered and
#     the compiler takes the exact pre-existing AST->codegen path.
#   * Folding is restricted to signedness-INVARIANT 64-bit operations
#     (ADD/SUB/MUL/BIT_AND/BIT_OR/BIT_XOR/SHL), so the folded constant is
#     provably the same 64-bit value codegen would have computed in %rax.
#     Signedness-dependent ops (compares, DIV/IDIV/MOD, SHR) and any op
#     that could trap (div-by-zero) are NOT folded in Phase 1.

from compiler.parser import (
    nd_kind,
    nd_aux,
    nd_num,
    nd_name_off,
    nd_name_len,
    nd_a,
    nd_b,
    ND_INT_LIT,
    ND_CHAR_LIT,
    ND_BOOL_LIT,
    ND_IDENT,
    ND_BINARY,
    ND_CAST,
    ND_INDEX,
    ND_MEMBER,
    ND_CALL,
    ND_UNARY,
    BINOP_ADD,
    BINOP_SUB,
    BINOP_MUL,
    BINOP_BIT_OR,
    BINOP_BIT_AND,
    BINOP_BIT_XOR,
    BINOP_SHL,
    BINOP_SHR,
    BINOP_DIV,
    BINOP_IDIV,
    BINOP_MOD,
    BINOP_EQ,
    BINOP_NEQ,
    BINOP_LT,
    BINOP_LTE,
    BINOP_GT,
    BINOP_GTE,
)

from compiler.lexer import (
    strbuf,
)

# -----------------------------------------------------------------------
# IR arena (parallel global arrays; index = IR value id; 0 = null)
# -----------------------------------------------------------------------
#
# An IR value is one of:
#   IR_CONST  : a materialized 64-bit constant (ir_const holds the value)
#   IR_BINOP  : a binary op over two IR values (ir_a/ir_b are IR ids,
#               ir_op is the BINOP_* code)
# Phase 1 only ever builds CONST nodes for foldable subtrees; everything
# else stays in the AST untouched. IR_BINOP is reserved for later phases.

IR_NULL: uint32 = 0
IR_CONST: uint32 = 1
IR_BINOP: uint32 = 2
IR_IDENT: uint32 = 3               # a read of a named local/param/global SSA-ish leaf
IR_LEAF: uint32 = 4                # an opaque AST-backed READ leaf (cast / index /
                                   # member): emitted by delegating to the AST
                                   # emitter (gen_expr(ir_ast)), so byte-identical;
                                   # value-numbered by STRUCTURAL AST equality so
                                   # CSE can share a redundant load WITHIN one pure
                                   # expression. NOT hoistable by LICM (may alias /
                                   # fault) — see ir_tree_has_leaf.

IR_MAX: uint32 = 65536

ir_kind: Array[65536, uint32]
ir_op: Array[65536, uint32]        # BINOP_* for IR_BINOP
ir_a: Array[65536, uint32]         # IR id (left operand)
ir_b: Array[65536, uint32]         # IR id (right operand)
ir_const: Array[65536, uint64]     # value for IR_CONST
ir_ast: Array[65536, uint32]       # the AST node this IR value lowered from
# For IR_IDENT: the strbuf name reference of the identifier read. Value
# numbering treats two ident reads as the SAME value iff their names match
# AND no intervening clobber of that name occurred (the pass enforces the
# clobber scope; the IR node only records the name).
ir_name_off: Array[65536, uint32]
ir_name_len: Array[65536, uint32]

ir_count: uint32 = 1               # id 0 reserved as null
ir_overflow: uint32 = 0            # set if the IR arena filled up


def ir_reset():
    ir_count = 1
    ir_overflow = 0


def ir_new(kind: uint32) -> uint32:
    if ir_count >= IR_MAX:
        ir_overflow = 1
        return 0
    id: uint32 = ir_count
    ir_count = ir_count + 1
    ir_kind[id] = kind
    ir_op[id] = 0
    ir_a[id] = 0
    ir_b[id] = 0
    ir_const[id] = 0
    ir_ast[id] = 0
    ir_name_off[id] = 0
    ir_name_len[id] = 0
    return id


def ir_const_new(v: uint64, ast: uint32) -> uint32:
    id: uint32 = ir_new(IR_CONST)
    if id == 0:
        return 0
    ir_const[id] = v
    ir_ast[id] = ast
    return id


def ir_ident_new(name_off: uint32, name_len: uint32, ast: uint32) -> uint32:
    id: uint32 = ir_new(IR_IDENT)
    if id == 0:
        return 0
    ir_name_off[id] = name_off
    ir_name_len[id] = name_len
    ir_ast[id] = ast
    return id


# An opaque AST-backed READ leaf (cast / index / member). The IR records ONLY
# the AST node; the emitter re-delegates to gen_expr(ir_ast) for byte-identical
# code. Value-numbering compares two leaves by STRUCTURAL AST equality (ir_ast_eq).
def ir_leaf_new(ast: uint32) -> uint32:
    id: uint32 = ir_new(IR_LEAF)
    if id == 0:
        return 0
    ir_ast[id] = ast
    return id


def ir_binop_new(op: uint32, a: uint32, b: uint32, ast: uint32) -> uint32:
    id: uint32 = ir_new(IR_BINOP)
    if id == 0:
        return 0
    ir_op[id] = op
    ir_a[id] = a
    ir_b[id] = b
    ir_ast[id] = ast
    return id


# -----------------------------------------------------------------------
# Foldability classification
# -----------------------------------------------------------------------

# Is this AST node a bare integer-valued constant literal? (int / char /
# bool literals all carry their value in nd_num and codegen lowers each to
# the same `movq $nd_num,%rax`.) These are the leaves the const-fold pass
# can evaluate exactly.
def ir_is_const_leaf(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT:
        return 1
    return 0


# Is this binop signedness-INVARIANT at 64-bit two's-complement width, so
# that folding `const OP const` yields the exact %rax codegen would compute
# regardless of operand signedness? (See codegen.ad gen_expr ND_BINARY: the
# integer path computes lhs in %rax, rhs in %rcx, then a single 64-bit
# instruction. ADD/SUB/MUL/AND/OR/XOR are width-and-sign agnostic; SHL masks
# its count to 6 bits the same as we do here. SHR/DIV/IDIV/MOD/compares are
# signedness- or trap-sensitive and are intentionally excluded in Phase 1.)
def ir_op_is_foldable(op: uint32) -> uint32:
    if op == BINOP_ADD:
        return 1
    if op == BINOP_SUB:
        return 1
    if op == BINOP_MUL:
        return 1
    if op == BINOP_BIT_AND:
        return 1
    if op == BINOP_BIT_OR:
        return 1
    if op == BINOP_BIT_XOR:
        return 1
    if op == BINOP_SHL:
        return 1
    return 0


# =======================================================================
# EMIT-ONLY op set (Phase 6): signedness/trap-sensitive ops the IR EMITTER
# can reproduce byte-for-byte, but the IR ANALYSIS passes (const-fold,
# reassociation) must NEVER touch.
# =======================================================================
#
# These ops are NOT signedness-invariant (compares + DIV/MOD/SHR pick a
# signed-vs-unsigned x86 instruction from the operand static types) and/or can
# TRAP (DIV/MOD by zero). The Phase-5 IR emitter (codegen.ad gen_expr_ir)
# reproduces the EXACT seed sequence for them by re-deriving the per-operand
# signedness from the original operand AST nodes (ir_ast back-pointers) — the
# same expr_signedness the seed's AST ND_BINARY path consults — and emitting the
# identical cmp/setcc or cqo/idiv/div/sar/shr. So adding them to the lowered set
# BROADENS emit coverage with ZERO semantic change.
#
# CRUCIAL INVARIANT: an emit-only op is signedness- and/or trap-sensitive, so a
# subtree containing one is NOT a compile-time constant the fold path may
# evaluate (ir_eval_binop has no compare/div semantics, and folding a div would
# also drop a divide-by-zero trap the seed preserves). ir_tree_has_emit_only()
# below lets the fold/reassoc paths exclude any tree touching an emit-only op, so
# those analyses keep operating ONLY over the signedness-invariant set.
def ir_op_is_emit_only(op: uint32) -> uint32:
    if op == BINOP_EQ:
        return 1
    if op == BINOP_NEQ:
        return 1
    if op == BINOP_LT:
        return 1
    if op == BINOP_LTE:
        return 1
    if op == BINOP_GT:
        return 1
    if op == BINOP_GTE:
        return 1
    if op == BINOP_DIV:
        return 1
    if op == BINOP_IDIV:
        return 1
    if op == BINOP_MOD:
        return 1
    if op == BINOP_SHR:
        return 1
    return 0


# Is `op` an op the seed routes to the SSE FLOAT emitter (gen_fp_binary) when an
# operand is float-typed? Exactly codegen.ad's gen_binary FP branch list:
# ADD/SUB/MUL/DIV/IDIV + the six compares. Bitwise/shift/MOD are NOT defined on
# floats (the seed never routes them to SSE), so a float operand under one of
# those is outside this sound subset and stays on the AST path.
def ir_op_is_float_emittable(op: uint32) -> uint32:
    if op == BINOP_ADD:
        return 1
    if op == BINOP_SUB:
        return 1
    if op == BINOP_MUL:
        return 1
    if op == BINOP_DIV:
        return 1
    if op == BINOP_IDIV:
        return 1
    if op == BINOP_EQ:
        return 1
    if op == BINOP_NEQ:
        return 1
    if op == BINOP_LT:
        return 1
    if op == BINOP_LTE:
        return 1
    if op == BINOP_GT:
        return 1
    if op == BINOP_GTE:
        return 1
    return 0


# An op the IR-CONSUMING emitter can lower: the signedness-INVARIANT foldable
# set PLUS the emit-only (signedness/trap-sensitive) set. Used by lowering to
# decide whether an ND_BINARY can become an IR_BINOP at all. (Logical AND/OR are
# short-circuit control flow, NOT in either set, so they are never lowered.)
def ir_op_is_emittable(op: uint32) -> uint32:
    if ir_op_is_foldable(op) != 0:
        return 1
    return ir_op_is_emit_only(op)


# Does the IR subtree rooted at `v` contain a TRAPPING op (DIV / MOD / IDIV)? A
# divide can fault (divide-by-zero / INT_MIN/-1 overflow), so such a tree must
# NEVER be HOISTED above its guard (LICM zero-trip safety): evaluating it before
# a loop that might run zero times could trap where the original program would
# not. Compares and SHR never trap, so they remain hoistable. (CSE, which keeps
# the computation in its original position within a single straight-line pure
# expression, does NOT need this guard — the trap, if any, fires at the same
# point as in the seed.)
def ir_tree_has_div(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_BINOP:
        op: uint32 = ir_op[v]
        if op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_MOD:
            return 1
        if ir_tree_has_div(ir_a[v]) != 0:
            return 1
        return ir_tree_has_div(ir_b[v])
    return 0


# Does the IR subtree rooted at `v` contain an opaque READ LEAF (cast / index /
# member)? Such a leaf may ALIAS storage written elsewhere in the loop or FAULT,
# and the conservative LICM clobber model (it tracks IDENT names, not p[i] / a.x
# storage) cannot prove it invariant. So LICM refuses to hoist any tree touching a
# leaf — keeping LICM sound without a full alias analysis. (CSE, which keeps the
# load in its original position inside one store-free pure expression, is safe and
# does NOT use this guard.)
def ir_tree_has_leaf(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_LEAF:
        return 1
    if k == IR_BINOP:
        if ir_tree_has_leaf(ir_a[v]) != 0:
            return 1
        return ir_tree_has_leaf(ir_b[v])
    return 0


# Does the IR tree rooted at `v` re-emit ANY call? Only an IR_LEAF delegates back
# to the AST emitter (gen_expr(ir_ast)) and could thereby emit a `call`; an
# IR_CONST/IR_IDENT/IR_BINOP never does. So the tree emits a call iff some leaf's
# backing AST contains an ND_CALL (ir_ast_has_call). Used to gate caller-saved IR
# scratch registers: only a CALL-FREE IR tree may park an operand in a caller-
# saved register (a call would clobber it). Returns 1 if any leaf may call.
def ir_tree_has_call(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_LEAF:
        return ir_ast_has_call(ir_ast[v])
    if k == IR_BINOP:
        if ir_tree_has_call(ir_a[v]) != 0:
            return 1
        return ir_tree_has_call(ir_b[v])
    return 0


# Does the IR subtree rooted at `v` contain ANY emit-only op (compare/div/mod/
# shr)? Used to KEEP such trees out of the const-fold and ADD-reassociation
# paths (those reason only over the signedness-invariant set). A compare/div
# result is a value, but it is NOT a compile-time constant the modular
# ir_eval_binop can produce, and a div carries a trap; so the fold paths must
# treat any tree touching an emit-only op as non-constant / non-foldable.
def ir_tree_has_emit_only(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_BINOP:
        if ir_op_is_emit_only(ir_op[v]) != 0:
            return 1
        if ir_tree_has_emit_only(ir_a[v]) != 0:
            return 1
        return ir_tree_has_emit_only(ir_b[v])
    return 0


# Evaluate a foldable 64-bit binop. uint64 arithmetic in Adder is modular
# two's-complement, matching x86 ADD/SUB/IMUL on 64-bit registers exactly.
# SHL masks the shift count to 6 bits, matching `shlq %cl` semantics.
def ir_eval_binop(op: uint32, l: uint64, r: uint64) -> uint64:
    if op == BINOP_ADD:
        return l + r
    if op == BINOP_SUB:
        return l - r
    if op == BINOP_MUL:
        return l * r
    if op == BINOP_BIT_AND:
        return l & r
    if op == BINOP_BIT_OR:
        return l | r
    if op == BINOP_BIT_XOR:
        return l ^ r
    if op == BINOP_SHL:
        return l << (r & 63)
    return 0


# -----------------------------------------------------------------------
# AST -> IR lowering (constant subtrees only, Phase 1)
# -----------------------------------------------------------------------
#
# ir_lower_const_expr returns an IR_CONST id if `node` is a fully-constant
# integer expression tree over the foldable op set; otherwise 0. It does NOT
# mutate the AST — opt.ad's pass decides what to write back. Recursion depth
# tracks AST expression depth, mirroring codegen.ad's gen_expr recursion.
def ir_lower_const_expr(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if ir_is_const_leaf(node) != 0:
        return ir_const_new(nd_num[node], node)
    if k == ND_BINARY:
        op: uint32 = nd_aux[node]
        if ir_op_is_foldable(op) == 0:
            return 0
        li: uint32 = ir_lower_const_expr(nd_a[node])
        if li == 0:
            return 0
        ri: uint32 = ir_lower_const_expr(nd_b[node])
        if ri == 0:
            return 0
        # Both operands lowered to constants — produce the folded IR_CONST.
        v: uint64 = ir_eval_binop(op, ir_const[li], ir_const[ri])
        return ir_const_new(v, node)
    return 0


# =======================================================================
# Phase 2 — non-constant value IR + structural value numbering for CSE
# =======================================================================
#
# Phase 1 only ever built IR_CONST nodes (foldable constant subtrees). Phase 2
# extends the IR to model the NON-constant pure values a local CSE needs:
#   IR_IDENT  : a read of a named local/parameter/global identifier.
#   IR_BINOP  : a pure binary op over two IR values.
#   IR_CONST  : a materialized constant (shared with Phase 1's fold path).
#
# Two IR values get the SAME value number iff they are STRUCTURALLY identical:
#   * two IR_CONST with the same 64-bit value,
#   * two IR_IDENT with the same name bytes,
#   * two IR_BINOP with the same op AND value-equal (recursively) operands.
# This is the classic hash-free structural value-numbering equality. The CSE
# pass (opt.ad) builds IR for each pure subexpression of a statement, and when
# it re-encounters a value-equal IR_BINOP with NO intervening clobber of any
# leaf name, it reuses the earlier computation via a hoisted temp.

# Compare two strbuf name references for byte equality (mirrors codegen.ad
# name_match — a value number for an ident is its name identity).
def ir_name_eq(aoff: uint32, alen: uint32, boff: uint32, blen: uint32) -> uint32:
    if alen != blen:
        return 0
    i: uint32 = 0
    while i < alen:
        if strbuf[aoff + i] != strbuf[boff + i]:
            return 0
        i = i + 1
    return 1


# STRUCTURAL AST equality over the read-leaf node kinds (cast / index / member /
# ident / literals). Two such subtrees compute the SAME value iff they are
# structurally identical AND no intervening store changed the underlying storage —
# the caller (CSE within one pure expression) guarantees no intervening store. A
# CALL is NEVER equal to anything (its side effects / non-determinism forbid
# sharing). Used to value-number IR_LEAF nodes so a redundant `buf[i]` /`a.x` load
# inside one expression is shared. Recurses over the operand slots (nd_a/nd_b)
# that the relevant kinds use as sub-expressions.
def ir_ast_eq(x: uint32, y: uint32) -> uint32:
    if x == 0 or y == 0:
        return 0
    if x == y:
        return 1
    kx: uint32 = nd_kind[x]
    if kx != nd_kind[y]:
        return 0
    if kx == ND_INT_LIT or kx == ND_CHAR_LIT or kx == ND_BOOL_LIT:
        if nd_num[x] == nd_num[y]:
            return 1
        return 0
    if kx == ND_IDENT:
        return ir_name_eq(nd_name_off[x], nd_name_len[x],
                          nd_name_off[y], nd_name_len[y])
    if kx == ND_CAST:
        # a = type node (compare by aux/name), b = operand expression.
        if nd_aux[nd_a[x]] != nd_aux[nd_a[y]]:
            return 0
        return ir_ast_eq(nd_b[x], nd_b[y])
    if kx == ND_INDEX:
        # a = base object, b = index expression.
        if ir_ast_eq(nd_a[x], nd_a[y]) == 0:
            return 0
        return ir_ast_eq(nd_b[x], nd_b[y])
    if kx == ND_MEMBER:
        # a = object, name = field. Same object subtree AND same field name.
        if ir_name_eq(nd_name_off[x], nd_name_len[x],
                      nd_name_off[y], nd_name_len[y]) == 0:
            return 0
        return ir_ast_eq(nd_a[x], nd_a[y])
    if kx == ND_BINARY:
        if nd_aux[x] != nd_aux[y]:
            return 0
        if ir_ast_eq(nd_a[x], nd_a[y]) == 0:
            return 0
        return ir_ast_eq(nd_b[x], nd_b[y])
    # Calls / unknown: never structurally-equal for CSE purposes.
    return 0


# Does AST subtree `node` reference identifier (name_off,name_len) anywhere? Used
# to clobber-check an IR_LEAF: if a statement assigns to a name the leaf's address
# or value computation depends on, the leaf is invalidated. Conservative over the
# read-leaf node kinds (a call inside is treated as a dependency -> returns 1).
def ir_ast_uses_name(node: uint32, name_off: uint32, name_len: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_IDENT:
        return ir_name_eq(nd_name_off[node], nd_name_len[node], name_off, name_len)
    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT:
        return 0
    if k == ND_CALL:
        return 1                # opaque: assume it depends on / clobbers the name
    # cast / index / member / binary / unary: descend operand slots.
    if ir_ast_uses_name(nd_a[node], name_off, name_len) != 0:
        return 1
    return ir_ast_uses_name(nd_b[node], name_off, name_len)


# Does AST subtree `node` contain ANY call (ND_CALL) anywhere? Used to decide
# whether an IR tree may safely park an operand in a CALLER-SAVED scratch
# register: a call clobbers the caller-saved set, so a caller-saved scratch is
# only sound across a subtree that emits NO call. This walks the leaf-backing
# AST a lowered IR LEAF re-emits (a cast/index whose sub-operand may itself be a
# call, e.g. `buf[f()]`). CONSERVATIVE: the recognised pure leaf kinds
# (ident/literal/cast/index/member/binary/unary) return per their operands; an
# ND_CALL returns 1; ANY OTHER kind also returns 1 (assume it may call), so an
# unrecognised node never wrongly enables a caller-saved scratch. Only nd_a/nd_b
# are descended — exactly the slots ir_lower_pure_expr's leaves can reach (an
# index base/index, a cast inner, a binary's operands); a call found at any of
# those positions is detected at the ND_CALL node itself before its args matter.
def ir_ast_has_call(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_IDENT:
        return 0
    if k == ND_INT_LIT:
        return 0
    if k == ND_CHAR_LIT:
        return 0
    if k == ND_BOOL_LIT:
        return 0
    if k == ND_CALL:
        return 1
    if k == ND_CAST or k == ND_INDEX or k == ND_MEMBER or k == ND_BINARY or k == ND_UNARY:
        if ir_ast_has_call(nd_a[node]) != 0:
            return 1
        return ir_ast_has_call(nd_b[node])
    # Unknown node kind: conservatively assume it may contain/emit a call.
    return 1


# Structural value equality of two IR value ids. Returns 1 iff they denote the
# same value by construction (so the second is a redundant recomputation of the
# first). Recurses over IR_BINOP operands; bounded by IR tree depth.
def ir_value_eq(x: uint32, y: uint32) -> uint32:
    if x == 0 or y == 0:
        return 0
    if x == y:
        return 1
    kx: uint32 = ir_kind[x]
    if kx != ir_kind[y]:
        return 0
    if kx == IR_CONST:
        if ir_const[x] == ir_const[y]:
            return 1
        return 0
    if kx == IR_IDENT:
        return ir_name_eq(ir_name_off[x], ir_name_len[x],
                          ir_name_off[y], ir_name_len[y])
    if kx == IR_LEAF:
        # Two opaque read leaves are value-equal iff their AST subtrees are
        # structurally identical (same cast/index/member shape over equal
        # idents/consts). Sound for in-expression CSE: there is no intervening
        # store, so identical loads yield identical values.
        return ir_ast_eq(ir_ast[x], ir_ast[y])
    if kx == IR_BINOP:
        if ir_op[x] != ir_op[y]:
            return 0
        if ir_value_eq(ir_a[x], ir_a[y]) == 0:
            return 0
        return ir_value_eq(ir_b[x], ir_b[y])
    return 0


# Does IR value `v` reference identifier (name_off,name_len) anywhere in its
# tree? Used by the CSE clobber check: if a statement between the defining and
# the reusing occurrence assigns to a name that an available expression depends
# on, that expression is invalidated. Conservative: a match anywhere kills it.
def ir_uses_name(v: uint32, name_off: uint32, name_len: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_IDENT:
        return ir_name_eq(ir_name_off[v], ir_name_len[v], name_off, name_len)
    if k == IR_LEAF:
        return ir_ast_uses_name(ir_ast[v], name_off, name_len)
    if k == IR_BINOP:
        if ir_uses_name(ir_a[v], name_off, name_len) != 0:
            return 1
        return ir_uses_name(ir_b[v], name_off, name_len)
    return 0


# Lower a PURE, side-effect-free expression subtree into the Phase-2 value IR,
# or 0 if it is not provably pure/CSE-safe. The CSE-safe leaf set is
# deliberately narrow (conservative over fast):
#   * integer-valued literals  -> IR_CONST,
#   * bare identifiers          -> IR_IDENT (a register-width read of a
#     local/param/global; codegen emits a movq of its value),
#   * ND_BINARY over the signedness-INVARIANT 64-bit op set with both operands
#     themselves CSE-safe -> IR_BINOP.
# Everything else (loads/indexes p[i], member access, calls, casts, compares,
# DIV/MOD/SHR, unary) returns 0: it may alias, trap, have side effects, or be
# signedness/width-sensitive, so it is NEVER eliminated. This is the value-
# producing analogue of ir_lower_const_expr (which only handled all-const
# subtrees); here non-const idents are allowed as leaves.
def ir_lower_pure_expr(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if ir_is_const_leaf(node) != 0:
        return ir_const_new(nd_num[node], node)
    if k == ND_IDENT:
        return ir_ident_new(nd_name_off[node], nd_name_len[node], node)
    # Phase 6: READ-ONLY, side-effect-free leaf loads — a CAST or an array/pointer
    # INDEX read. These are NOT calls (no side effect) and the emitter delegates to
    # the AST emitter for byte-identical code, so adding them as IR LEAVES lets a
    # WHOLE expression like `buf[i] < 48` or `cast[uint64](x) / n` lower (instead
    # of falling back the moment a non-ident leaf appears). A leaf may ALIAS or
    # FAULT, so it is value-numbered (for in-expression CSE) but kept OUT of LICM
    # hoisting (ir_tree_has_leaf). We record the AST node and re-emit it verbatim,
    # so even a non-trivial sub-operand is reproduced exactly by gen_expr.
    #
    # FLOAT is handled by the codegen-side deep guard (ir_subtree_has_float):
    # a float cast/index operand routes the whole expression to the SSE emitter,
    # so try_gen_expr_ir refuses it before this lowering is consumed. (Struct
    # MEMBER reads are intentionally NOT lowered: field float-ness isn't cheaply
    # provable here, so members stay on the AST path — a conservative residual.)
    if k == ND_CAST or k == ND_INDEX:
        return ir_leaf_new(node)
    if k == ND_BINARY:
        op: uint32 = nd_aux[node]
        # Phase 6: lower BOTH the signedness-invariant foldable set AND the
        # emit-only (compare / DIV / MOD / SHR) set. Logical AND/OR are NOT
        # emittable (short-circuit control flow) and return 0 here, ending the
        # pure region exactly as before.
        if ir_op_is_emittable(op) == 0:
            return 0
        li: uint32 = ir_lower_pure_expr(nd_a[node])
        if li == 0:
            return 0
        ri: uint32 = ir_lower_pure_expr(nd_b[node])
        if ri == 0:
            return 0
        return ir_binop_new(op, li, ri, node)
    return 0


# =======================================================================
# Phase 5 — a genuine IR-CONSUMING emit path.
# =======================================================================
#
# WHAT CHANGES vs Phases 1-3
# --------------------------
# Phases 1-3 used the IR purely as an ANALYSIS annotation: a pass lowered a
# subexpression to IR, reasoned over it (fold / value-number / invariance), then
# rewrote the AST in place; codegen.ad always walked the AST. The IR never
# reached the machine-code emitter.
#
# Phase 5 closes the loop: for a pure expression that lowers FULLY into the
# Phase-2 value IR (ir_lower_pure_expr -> IR_CONST / IR_IDENT / IR_BINOP over the
# signedness-INVARIANT 64-bit op set), codegen emits machine code by walking the
# IR TREE instead of the AST. The IR is now the thing the backend consumes for
# that subexpression: AST -> IR -> (fold on the IR) -> emit.
#
# WHY THIS IS PROVABLY CORRECT (identical observable value to the seed)
# --------------------------------------------------------------------
#   * The lowered set is EXACTLY the set codegen's AST ND_BINARY integer path
#     already treats as a single 64-bit op with %rax=left, %rcx=right (see
#     ir_op_is_foldable / codegen.ad gen_expr ND_BINARY). Emitting the SAME
#     eval-order (right, push, left, pop %rcx, op) from the IR yields the SAME
#     %rax as the AST walk would.
#   * LEAVES delegate to the AST emitter via the ir_ast back-pointer: an
#     IR_IDENT/IR_CONST is emitted by gen_expr(ir_ast[v]), so every leaf detail
#     (register-promoted local read, sub-8-byte sized load, global/percpu load,
#     literal immediate) is byte-for-byte what the seed would emit for that leaf.
#     Only the BINOP TREE STRUCTURE comes from the IR.
#   * The ONLY transform the IR emitter applies is CONSTANT FOLDING of a fully-
#     constant subtree (ir_tree_is_const + ir_tree_const_val), evaluated with the
#     same modular two's-complement ir_eval_binop the AST fold uses — so the
#     folded immediate equals the value the AST computation would have produced.
#     This is value-preserving by construction; the ADDER_OPT=1 fuzzer lane
#     asserts it against the by-construction oracle.
#
# GATING — DEFAULT OUTPUT BYTE-IDENTICAL
#   ir_emit_enabled defaults 0. codegen only attempts the IR path when it is 1,
#   which the dump driver sets ONLY under --opt (alongside opt_enable/ra_enable).
#   With the flag off codegen never lowers to IR for emission and emits the exact
#   pre-existing AST output, so the flag-off objdiff/fuzzer lanes stay clean.

# =======================================================================
# P1 Phase 0/1 — value-LOCATION descriptor (the destination-driven selector
# substrate).
# =======================================================================
#
# A `Loc` describes WHERE a computed value lives (or must land). The selector
# entry sel_expr(v, dst) threads it so a subtree can be computed DIRECTLY into
# its destination register with 2-operand x86 forms (no %rax round-trip / no
# push-pop), instead of the %rax-anchored stack-machine the IR emitter is today.
#
# Phase 0 introduces ONLY the descriptor + a sel_expr that WRAPS gen_expr_ir
# (dst ignored, value still lands in %rax) — byte-identical to the pre-P1 path.
# Phase 1 routes ONE class (scalar = pure-arith ND_BINARY into a register home)
# through real destination-passing; everything else keeps the gen_expr_ir / AST
# fallback unchanged.
#
# The Loc is passed by two scalar args (kind, enc) rather than a struct, matching
# the codegen.ad calling style. enc meaning depends on kind:
#   LOC_NONE  : caller doesn't care; selector returns value in %rax (legacy).
#   LOC_REG   : enc = x86 register encoding (0..15) the value must land in.
# LOC_MEM / LOC_IMM are reserved for later phases (index/store, lazy immediates)
# and are NOT produced/consumed in Phase 0/1.
LOC_NONE: uint32 = 0
LOC_REG: uint32 = 1
LOC_MEM: uint32 = 2
LOC_IMM: uint32 = 3

# DESTSEL diagnostic: number of expression roots the destination-driven selector
# (sel_expr with a real LOC_REG dst) emitted WITHOUT the %rax round-trip / store
# (Phase 1: scalar = pure-arith-binop into a promoted register). A subset of the
# work formerly counted under IREMIT. Surfaced so the corpus can assert the
# dest-passing path actually fires AND is byte-inert OFF.
ir_destsel_count: uint32 = 0

# P1 Phase 3 diagnostics — STATEMENT-GLUE destination routing.
#   ir_accsel_count : augmented accumulator assignments (`s OP= <pure expr>`,
#     OP in ADD/SUB/MUL) lowered as `op <value>, %home` into a register-promoted
#     scalar's home — the accumulator never round-trips through %rax and is never
#     reloaded/spilled to its slot (store-elim) / write-through otherwise. This is
#     the matmul-accumulator residency win (docs/perf_2x_roadmap.md point 2).
#   ir_idxstore_count : indexed stores `arr[i] = <pure-arith binop>` whose RHS is
#     computed dest-driven into a held register (no value-at-a-time push/pop)
#     then stored — the saxpy-class store-glue win.
# Both are byte-inert OFF (the selector is unreachable without --opt), so the
# corpus/guard asserts each fires AND stays 0 with the flag off.
ir_accsel_count: uint32 = 0
ir_idxstore_count: uint32 = 0
# P1 Phase-2 (index) diagnostic — INDEX-ADDRESS arithmetic lowered through the
# destination-driven selector: `arr[<pure-arith index>]` whose index sum is
# computed DIRECTLY into %rcx (the SIB index register) with scratch-free 2-operand
# forms, killing the per-iteration value-at-a-time push/pop the AST stack machine
# emitted for the index under the IR re-entrancy guard. Byte-inert OFF (the
# selector is unreachable without --opt), so the corpus/guard asserts it fires AND
# stays 0 with the flag off.
ir_idxsel_count: uint32 = 0


def ir_destsel_reset():
    ir_destsel_count = 0
    ir_accsel_count = 0
    ir_idxstore_count = 0
    ir_idxsel_count = 0


# OFF by default. The dump driver flips this to 1 under --opt.
ir_emit_enabled: uint32 = 0

# RE-ENTRANCY GUARD. The IR arena (ir.ad globals) is a SINGLE shared buffer that
# try_gen_expr_ir resets (ir_reset) at the start of every lowering. When the IR
# emitter (gen_expr_ir) emits a LEAF (a cast / index whose AST contains a nested
# ND_BINARY, e.g. `cast[uint64](li * 3)`), it delegates to the AST emitter
# gen_expr(ir_ast) — which re-enters gen_expr -> try_gen_expr_ir for that nested
# binary and would ir_reset() the arena OUT FROM UNDER the outer tree still being
# walked, corrupting the outer tree's live IR nodes (the classic observed bug:
# `g_accum + cast(li*3)` loaded li instead of g_accum). The guard makes a NESTED
# try_gen_expr_ir refuse to lower (return 0 -> AST fallback) while an outer IR
# emit is in progress, so the arena is never reset mid-walk. The nested binary is
# emitted by the AST path — byte-correct, just not itself IR-lowered. Set/cleared
# by codegen.ad around the top-level gen_expr_ir call.
ir_emit_active: uint32 = 0


def ir_emit_enter():
    ir_emit_active = 1


def ir_emit_leave():
    ir_emit_active = 0


def ir_emit_in_progress() -> uint32:
    return ir_emit_active


# Diagnostics: number of expression subtrees codegen emitted THROUGH the IR
# tree (vs the AST fallback), and number of fully-constant IR subtrees the IR
# emitter folded to a single immediate at emit time. Surfaced by the dump
# driver so the fuzzer can assert the IR path actually fires.
ir_emit_count: uint32 = 0
ir_emit_fold_count: uint32 = 0
ir_emit_fallback_count: uint32 = 0
# Number of FLOAT-typed ND_BINARY roots the IR emitter lowered through the SSE
# float path (gen_fp_expr_ir) instead of falling back to the AST float emitter.
# A subset of ir_emit_count: each float root counted here also increments
# ir_emit_count. Surfaced so the float-coverage corpus can assert floats now go
# THROUGH the IR (not the AST fallback) and quantify the coverage increase.
ir_emit_float_count: uint32 = 0
# Number of ADD subtrees whose constant tail the IR emitter reassociated into a
# single immediate (a reduction the AST const-fold pass cannot make — see the
# reassociation note below).
ir_emit_reassoc_count: uint32 = 0


def ir_emit_enable():
    ir_emit_enabled = 1


def ir_emit_is_enabled() -> uint32:
    return ir_emit_enabled


def ir_emit_reset_stats():
    ir_emit_count = 0
    ir_emit_fold_count = 0
    ir_emit_fallback_count = 0
    ir_emit_reassoc_count = 0
    ir_emit_float_count = 0
    ir_emit_active = 0
    ir_destsel_count = 0
    ir_accsel_count = 0
    ir_idxstore_count = 0


# Is the IR value `v` a fully-constant subtree (every leaf an IR_CONST)? Such a
# subtree has a single statically-known 64-bit value and can be materialized as
# one immediate instead of an instruction chain.
def ir_tree_is_const(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_CONST:
        return 1
    if k == IR_BINOP:
        # An emit-only op (compare/div/mod/shr) is signedness/trap-sensitive and
        # has NO modular ir_eval_binop semantics, so a subtree touching one is
        # NEVER a foldable compile-time constant — bail so the fold path leaves
        # it to the genuine emit (which reproduces the seed's signed/trap code).
        if ir_op_is_emit_only(ir_op[v]) != 0:
            return 0
        if ir_tree_is_const(ir_a[v]) == 0:
            return 0
        return ir_tree_is_const(ir_b[v])
    return 0


# Evaluate a fully-constant IR subtree to its 64-bit value (precondition:
# ir_tree_is_const(v) != 0). Uses the SAME modular ir_eval_binop as the AST fold,
# so the result equals the value the AST computation would have produced.
def ir_tree_const_val(v: uint32) -> uint64:
    k: uint32 = ir_kind[v]
    if k == IR_CONST:
        return ir_const[v]
    # IR_BINOP over constant operands.
    l: uint64 = ir_tree_const_val(ir_a[v])
    r: uint64 = ir_tree_const_val(ir_b[v])
    return ir_eval_binop(ir_op[v], l, r)


# -----------------------------------------------------------------------
# IR-LEVEL constant REASSOCIATION over ADD (an optimization the AST fold can
# NOT do).
# -----------------------------------------------------------------------
#
# The AST const-fold pass (opt.ad) only collapses a binary node when BOTH
# operands are constant. So `(a + 3) + 4` — whose left operand `a + 3` is NOT
# constant — survives as two separate `+` instructions. Integer ADD is
# associative AND commutative under 64-bit two's-complement (exactly x86 ADD),
# so `(a + 3) + 4 == a + (3 + 4) == a + 7`: the constant contributions of an ADD
# tree can be summed into ONE immediate, value-PRESERVINGLY. This collapses an
# add-chain's constant tail to a single `addq $imm` — a real reduction the AST
# emitter cannot make.
#
# ir_add_const_sum(v) returns the sum (modular) of every IR_CONST reachable
# through a chain of ADD nodes from `v`. ir_add_has_nonconst(v) reports whether
# any non-const leaf remains. The emitter (codegen.ad) uses these to emit, for a
# top-level ADD whose constant tail is non-trivial, the non-const remainder once
# plus the single folded constant — instead of the original instruction chain.
# Only ADD is reassociated (the unambiguously sound case); SUB/MUL/shift/bitwise
# chains keep their exact AST schedule.

# Sum (modular 64-bit) of all IR_CONST values reachable from `v` through ADD
# nodes. A non-ADD, non-const node contributes 0 (its value is handled by the
# non-const remainder path).
def ir_add_const_sum(v: uint32) -> uint64:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_CONST:
        return ir_const[v]
    if k == IR_BINOP:
        if ir_op[v] == BINOP_ADD:
            return ir_add_const_sum(ir_a[v]) + ir_add_const_sum(ir_b[v])
    return 0


# Count of distinct constant contributions in the ADD chain rooted at `v`. >=2
# means reassociation can collapse them (fold the constants into one immediate).
def ir_add_const_count(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_CONST:
        return 1
    if k == IR_BINOP:
        if ir_op[v] == BINOP_ADD:
            return ir_add_const_count(ir_a[v]) + ir_add_const_count(ir_b[v])
    return 0

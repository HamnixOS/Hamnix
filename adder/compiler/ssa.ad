# adder/compiler/ssa.ad
#
# LLVM-shaped SSA IR + on-the-fly Braun construction + verifier.  Phase 1 of the
# SSA optimizer rewrite (docs/adder_ssa_optimizer_design.md).
#
# WHAT THIS IS
# ------------
# A new, self-contained SSA intermediate representation for the self-hosted Adder
# backend, in the parallel-global-array style of ir.ad / cfg.ad (no dynamic
# allocation; fixed arenas; per-function reset).  It coexists ALONGSIDE the
# existing ir.ad expression-IR and cfg.ad name-level analysis and touches neither.
#
# Phase 1 delivers, exactly as the design doc scopes it:
#   (2.2) the SSA value/instruction model (SVO_* opcode subset, incl. percpu as a
#         first-class op), parallel value arenas + a use-list side arena,
#   (2.3) basic blocks + CFG with predecessor lists and a dominator tree,
#   (3.1) Braun et al. on-the-fly SSA construction (chosen over Cytron) folded
#         into the AST->CFG lowering walk, with mem2reg for promotable scalars,
#   (3.4) ssa_verify — SSA well-formedness (one def per value, dominance of every
#         use, phi operand==pred count, single terminator per block) with a
#         deliberate-break switch,
#   (2.6) the per-function ESCAPE HATCH: on any non-subset construct or arena
#         overflow, construction bails (returns 0) and the caller falls back to
#         the legacy pipeline for that function.
#
# GATING / BYTE-IDENTITY
# ----------------------
# This module is native-only and is reached ONLY under the new ADDER_OPT2 gate
# (env var / --dump-ssa lane in the dump driver).  With the gate off it is never
# entered and codegen output is byte-for-byte the pre-existing path.  Phase 1
# does NOT wire SSA into the machine-code emit path (that is the Phase 1b/3 MIR
# lowering + register allocator), so the byte-identity invariant is preserved
# structurally: no emit-path code changes.
#
# PHASE-1 SUBSET (what construction accepts; everything else hits the escape
# hatch and falls back cleanly):
#   * every local/param is a PROMOTABLE SCALAR — its address is never taken and
#     its slot is never read directly (reuses cfg.ad's cl_build escape scan:
#     cl_set==0 AND nm_slotread==0).  Address-taken / aggregate / pointer locals
#     bail the function (they would need memory SVO_ALLOCA/LOAD/STORE, modeled in
#     the opcode set but produced by a later increment).
#   * expressions over int/char/bool literals, promotable-scalar reads, integer
#     arithmetic/bitwise/shift binops, integer compares, unary neg/not/bitnot,
#     and direct calls to named functions.
#   * statements: var-decl, plain/augmented assign to a promotable scalar,
#     expr-stmt, return, if/elif/else, while, do-while, break, continue, pass.
#   * anything outside this subset (float, cast, index, member, address-of,
#     deref, short-circuit and/or, for-loops, match/try/with/defer/yield, a read
#     of an unknown/global name, ...) bails the whole function.

from compiler.parser import (
    nd_kind,
    nd_aux,
    nd_num,
    nd_name_off,
    nd_name_len,
    nd_a,
    nd_b,
    nd_c,
    nd_d,
    nd_next,
    ND_INT_LIT,
    ND_FLOAT_LIT,
    ND_CHAR_LIT,
    ND_BOOL_LIT,
    ND_IDENT,
    ND_BINARY,
    ND_UNARY,
    ND_CALL,
    ND_CAST,
    ND_TYPE,
    ND_ARRAY_TYPE,
    ND_INDEX,
    ND_MEMBER,
    ND_VAR_DECL,
    ND_ASSIGN,
    ND_EXPR_STMT,
    ND_RETURN,
    ND_IF,
    ND_ELIF,
    ND_WHILE,
    ND_DO_WHILE,
    ND_FOR,
    ND_BREAK,
    ND_CONTINUE,
    ND_PASS,
    ND_FUNCTION,
    ND_PARAM,
    BINOP_ADD,
    BINOP_SUB,
    BINOP_MUL,
    BINOP_DIV,
    BINOP_IDIV,
    BINOP_MOD,
    BINOP_EQ,
    BINOP_NEQ,
    BINOP_LT,
    BINOP_LTE,
    BINOP_GT,
    BINOP_GTE,

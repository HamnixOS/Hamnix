    nm_count,
    nm_off,
    nm_len,
    cl_set,
    nm_slotread,
    cfg_build_function,
    cl_build,
    NM_MAX,
)

# Phase-1b: the width/signedness gate (§2.4, §3.3) reuses codegen's type-node
# helpers so "accepted" == "emittable through the trivial all-memory round-trip".
# ssa.ad already coexists with codegen in the host driver build (both are pulled
# in by the dump driver's `from compiler.*` imports); this adds an ssa -> codegen
# dependency but NOT the reverse, so there is no import cycle and codegen (the
# seed module) is untouched. Ph1b restricts construction to values whose low-64
# bits are correct regardless of source signedness/width — see ssa_type_scalar_ok
# and the div/mod/shr/ordered-compare bails below.
from compiler.codegen import (
    prim_type_size,
    type_float_width,
    type_signedness,
    type_is_unsigned,
    binop_use_signed,
    rel_setcc,
    glob_lookup,
    glob_offset,
    glob_elem_size,
    glob_is_percpu,
    glob_scalar_size,
    glob_is_signed,
    glob_is_bss,
    glob_signedness,
    glob_type_node,
)

from compiler.lexer import (
    strbuf,
)

# =======================================================================
# 2.2  Value / instruction model — opcodes (SVO_*), the LLVM subset.
# =======================================================================
SVO_NULL: uint32 = 0
SVO_CONST: uint32 = 1        # sv_imm = 64-bit int/bool/char value
SVO_FCONST: uint32 = 2       # sv_imm = float bit pattern (reserved; Ph1 bails floats)
SVO_UNDEF: uint32 = 3
SVO_PARAM: uint32 = 4        # sv_aux = parameter index (entry-block value)
SVO_BINOP: uint32 = 5        # sv_aux = BINOP_* (arith/bitwise/shift), sv_a/sv_b operands
SVO_NEG: uint32 = 6          # sv_a operand
SVO_NOT: uint32 = 7          # logical not, sv_a operand
SVO_BITNOT: uint32 = 8       # ~x, sv_a operand
SVO_ICMP: uint32 = 9         # sv_aux = BINOP_* compare predicate, sv_a/sv_b operands
SVO_FCMP: uint32 = 10        # reserved
SVO_TRUNC: uint32 = 11       # reserved conversions (Ph1 bails casts)
SVO_ZEXT: uint32 = 12
SVO_SEXT: uint32 = 13
SVO_BITCAST: uint32 = 14
SVO_I2F: uint32 = 15
SVO_F2I: uint32 = 16
SVO_ALLOCA: uint32 = 17      # reserved: address-taken/aggregate local slot
SVO_LOAD: uint32 = 18        # reserved: sv_a = address value, sv_aux = size
SVO_STORE: uint32 = 19       # reserved: sv_a = address, sv_b = value
SVO_GEP: uint32 = 20         # reserved: sv_a = base, sv_b = index, sv_aux = scale
SVO_BR: uint32 = 21          # sv_a = target bid (terminator)
SVO_CONDBR: uint32 = 22      # sv_a = cond vid, sv_b = then bid, sv_c = else bid
SVO_RET: uint32 = 23         # sv_a = value vid (0 = void) (terminator)
SVO_PHI: uint32 = 24         # operands in use-list (pred bid, incoming vid) pairs
SVO_CALL: uint32 = 25        # direct call; sv_ast = call node; args in use-list
SVO_SYSCALL: uint32 = 26     # reserved
SVO_GLOBALADDR: uint32 = 27  # reserved: RIP-relative symbol in sv_imm
SVO_PERCPU: uint32 = 28      # first-class %gs-relative op (sv_imm = offset)

# Type ids (2.4) — small interned set.  Signedness rides bit 8 (0x100).
SVT_VOID: uint32 = 0
SVT_I1: uint32 = 1
SVT_I8: uint32 = 2
SVT_I16: uint32 = 3
SVT_I32: uint32 = 4
SVT_I64: uint32 = 5
SVT_F32: uint32 = 6
SVT_F64: uint32 = 7
SVT_PTR: uint32 = 8

# Arena sizes (fixed; overflow => escape-hatch bail).
SSA_VAL_MAX: uint32 = 65536
SSA_BB_MAX: uint32 = 1024
SSA_ARG_MAX: uint32 = 131072

# ----- value arena (index = vid; 0 = null/undef) -----------------------
sv_op: Array[65536, uint32]
sv_type: Array[65536, uint32]
sv_a: Array[65536, uint32]
sv_b: Array[65536, uint32]
sv_c: Array[65536, uint32]
sv_aux: Array[65536, uint32]
sv_imm: Array[65536, uint64]
sv_block: Array[65536, uint32]
sv_ast: Array[65536, uint32]
sv_next: Array[65536, uint32]      # intrusive per-block list (forward)
sv_prev: Array[65536, uint32]      # intrusive per-block list (backward)
sv_pos: Array[65536, uint32]       # index within block (for intra-block dominance)
sv_arg_head: Array[65536, uint32]  # head of use-list (phi/call operands), 0 = none
sv_argn: Array[65536, uint32]      # operand count

sv_count: uint32 = 1               # vid 0 reserved as null
sv_overflow: uint32 = 0

# ----- use-list side arena (phi/call operands; 0 = null) ---------------
arg_val: Array[131072, uint32]     # operand value vid (or call-arg value)
arg_pred: Array[131072, uint32]    # phi: the predecessor bid this operand flows from
arg_next: Array[131072, uint32]    # next operand (linked list; order-independent)
arg_count: uint32 = 1

# ----- block arena (index = bid; 0 = null) -----------------------------
sb_first_val: Array[1024, uint32]
sb_last_val: Array[1024, uint32]
sb_term: Array[1024, uint32]       # terminator opcode (redundant w/ last, for validate)
sb_nval: Array[1024, uint32]       # value count (position counter)
sb_succ0: Array[1024, uint32]
sb_succ1: Array[1024, uint32]
sb_nsucc: Array[1024, uint32]
sb_pred_head: Array[1024, uint32]  # head of predecessor list (side arena)
sb_npred: Array[1024, uint32]
sb_sealed: Array[1024, uint32]     # Braun: all preds known
sb_idom: Array[1024, uint32]       # immediate dominator bid
sb_ponum: Array[1024, uint32]      # postorder number (higher = closer to entry)
sb_visited: Array[1024, uint32]

# predecessor list side arena (parallel to blocks): each node = (pred bid, next)
pl_bid: Array[8192, uint32]
pl_next: Array[8192, uint32]
pl_count: uint32 = 1

sb_count: uint32 = 1               # bid 0 reserved as null
sb_entry: uint32 = 0

# RPO order (list of bids, reverse postorder).
sb_rpo: Array[1024, uint32]
sb_rpo_n: uint32 = 0
# postorder scratch list
sb_po: Array[1024, uint32]
sb_po_n: uint32 = 0

# ----- Braun current-definition + incomplete-phi maps ------------------
# Indexed [block * NM_MAX + var]; 0 = undefined (vid 0 is null so unambiguous).
ssa_curdef: Array[262144, uint32]      # SSA_BB_MAX * NM_MAX
ssa_incphi: Array[262144, uint32]      # incomplete phis awaiting seal

# ----- known-locals set (promotable scalars declared as param/var) -----
ssa_islocal: Array[256, uint32]        # 1 => name id is a known promotable local
# Per-local signedness tristate (0 unknown / 1 unsigned / 2 signed), from the
# declared type — mirrors codegen's loc_is_signed / type_signedness so div/mod/
# shr/ordered-compare instruction selection matches the legacy backend exactly.
ssa_local_sgn: Array[256, uint32]
# Per-local declared byte width (1/2/4/8).  A promotable (never-address-taken)
# narrow local is truncated to this width on every write, exactly reproducing the
# legacy sized-store + sign/zero-extended-load value (the slot is never aliased,
# so no upper-byte observation can distinguish the two).
ssa_local_size: Array[256, uint32]

# ----- loop context (break/continue targets) --------------------------
SSA_LOOP_MAX: uint32 = 64
ssa_brk_bb: Array[64, uint32]
ssa_cont_bb: Array[64, uint32]
ssa_loop_depth: uint32 = 0

# ----- per-function bail / stats --------------------------------------
ssa_bail: uint32 = 0                    # set on any non-subset construct
ssa_bail_reason: uint32 = 0             # diagnostic code (SBR_*)

SBR_OK: uint32 = 0
SBR_OVERFLOW: uint32 = 1
SBR_NONSUBSET_EXPR: uint32 = 2
SBR_NONSUBSET_STMT: uint32 = 3
SBR_NONLOCAL: uint32 = 4
SBR_NONPROMOTABLE: uint32 = 5
SBR_LOOPDEPTH: uint32 = 6
SBR_CFG: uint32 = 7
SBR_FLOAT: uint32 = 8
SBR_FORLOOP: uint32 = 9
SBR_SHORTCIRCUIT: uint32 = 10
SBR_MEMORY: uint32 = 11
SBR_MANYARGS: uint32 = 12
SBR_CALL: uint32 = 13
SBR_NREASONS: uint32 = 16
ssa_bail_hist: Array[16, uint32]

# aggregate program stats (driver lane)
ssa_stat_funcs: uint32 = 0
ssa_stat_accepted: uint32 = 0
ssa_stat_fallback: uint32 = 0
ssa_stat_verify_ok: uint32 = 0
ssa_stat_verify_fail: uint32 = 0
ssa_stat_values: uint32 = 0
ssa_stat_blocks: uint32 = 0
ssa_stat_phis: uint32 = 0
ssa_stat_fail_code: uint32 = 0    # last verifier failure code

# gating flag (2.6 / 6.1)
ssa_enabled: uint32 = 0

# Program decl chain head (nd_b of ND_PROGRAM), stashed per run so the callee-
# return-type gate (Phase 1b) can resolve a direct call's return width.
ssa_prog_decls: uint32 = 0

# CURRENT block for expression lowering.  Most expressions materialize their
# value in the block they started in, but a short-circuit `and`/`or` splits the
# CFG and moves control into a fresh join block.  Because ssa_lower_expr returns
# only a value id, the "where control now is" fact is threaded through this
# module global instead: EVERY caller sets ssa_cur_bb before lowering an
# expression and re-reads it (bb = ssa_cur_bb) afterward, and ssa_lower_expr
# uses ssa_cur_bb — never its stale `bb` argument — for all appends, variable
# reads, and recursive lowering.  For straight-line expressions ssa_cur_bb never
# moves, so this is byte-inert vs the pre-short-circuit behaviour.
ssa_cur_bb: uint32 = 0


def ssa_enable():
    ssa_enabled = 1


# =======================================================================
# Phase-1b emittability gate (§2.4 / §3.3): the trivial all-memory round-trip
# keeps every SSA value in a 64-bit stack slot and never truncates, so a value
# is only correct if its low 64 bits match the source regardless of declared
# signedness/width.  A scalar is emittable iff it is a full-width (8-byte),
# non-float integer.  Narrower locals/params would need store-truncation the
# mem2reg value model does not carry; floats need SSE.  Both bail to the legacy
# path (escape hatch).
# =======================================================================
def ssa_type_scalar_ok(tnode: uint32) -> uint32:
    if type_float_width(tnode) != 0:
        return 0
    if prim_type_size(tnode) != 8:
        return 0
    return 1


# Byte-compare two interned name spans (both index the lexer strbuf).
def ssa_name_bytes_eq(off1: uint32, len1: uint32, off2: uint32, len2: uint32) -> uint32:
    if len1 != len2:
        return 0
    i: uint32 = 0
    while i < len1:
        if strbuf[off1 + i] != strbuf[off2 + i]:
            return 0
        i = i + 1
    return 1


# Callee-return-type gate: a direct call's result is only emittable if the
# callee is an in-unit function whose declared return type is a full-width
# non-float integer (so the returned %rax is a correct full-64-bit value).  An
# extern / unknown callee, or one returning a narrow/float/aggregate type, is
# NOT resolvable to a safe width here and bails the function.  Returns 1 iff OK.
def ssa_callee_rettype_ok(off: uint32, len_: uint32) -> uint32:
    cur: uint32 = ssa_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            if ssa_name_bytes_eq(nd_name_off[cur], nd_name_len[cur], off, len_) != 0:
                return ssa_type_scalar_ok(nd_b[cur])
        cur = nd_next[cur]
    return 0


# Callee-return signedness tristate (0 unknown / 1 unsigned / 2 signed): the
# signedness the legacy expr_signedness assigns to a direct call is the callee's
# declared return type (type_signedness of nd_b[decl]).  An unknown callee -> 0.
def ssa_callee_rettype_sgn(off: uint32, len_: uint32) -> uint32:
    cur: uint32 = ssa_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            if ssa_name_bytes_eq(nd_name_off[cur], nd_name_len[cur], off, len_) != 0:
                return type_signedness(nd_b[cur])
        cur = nd_next[cur]
    return 0


# SHALLOW expression signedness (0/1/2), mirroring codegen.ad's expr_signedness
# restricted to the Phase-1 subset: ND_IDENT -> the local's declared signedness
# (non-locals bail before this is reached); ND_CALL -> the callee's return-type
# signedness; everything else (literals, binops, unary) -> 0 (unknown).  This is
# the tristate the legacy ordered-compare setcc selection consumes per operand.
def ssa_expr_sgn(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[node], nd_name_len[node])
        if nid < NM_MAX and ssa_islocal[nid] != 0:
            return ssa_local_sgn[nid]
        # Global identifier: mirror codegen expr_signedness (array decays to an
        # unsigned address; scalar global uses its declared full-type signedness,
        # unknown -> unsigned default).
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            if glob_elem_size[gi - 1] != 0:
                return 1
            gs: uint32 = glob_signedness[gi - 1]
            if gs != 0:
                return gs
            return 1
        return 0
    if k == ND_CALL:
        callee: uint32 = nd_a[node]
        if callee != 0 and nd_kind[callee] == ND_IDENT:
            return ssa_callee_rettype_sgn(nd_name_off[callee], nd_name_len[callee])
        return 0
    if k == ND_INDEX:
        # arr[i] : the element type's signedness (mirrors codegen expr_signedness
        # -> index_elem_signed for the 1-D scalar-element global-array case we
        # actually lower; any other base is unknown/unlowered -> 0).
        ibase: uint32 = nd_a[node]
        if ibase != 0 and nd_kind[ibase] == ND_IDENT:
            igi: uint32 = ssa_global_array_1d(nd_name_off[ibase], nd_name_len[ibase])
            if igi != 0:
                return ssa_array_elem_sgn(igi)
        return 0
    return 0


# STRUCTURAL value signedness (0/1/2), mirroring codegen.ad's shr_value_signedness
# restricted to the Phase-1 subset: sees THROUGH an integer ND_BINARY (a shift
# follows its LEFT operand; an arithmetic/bitwise binop is unsigned if EITHER
# operand is unsigned, else signed if EITHER is signed, else unknown); a compare
# / logical binop yields a boolean -> unknown; every other node defers to the
# shallow ssa_expr_sgn.  Drives the div/mod and shift instruction selection.
def ssa_shr_value_sgn(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] == ND_BINARY:
        bop: uint32 = nd_aux[node]
        if bop == BINOP_SHL or bop == BINOP_SHR:
            return ssa_shr_value_sgn(nd_a[node])
        if bop == BINOP_ADD or bop == BINOP_SUB or bop == BINOP_MUL or bop == BINOP_BIT_AND or bop == BINOP_BIT_OR or bop == BINOP_BIT_XOR or bop == BINOP_DIV or bop == BINOP_IDIV or bop == BINOP_MOD:
            lu: uint32 = ssa_shr_value_sgn(nd_a[node])
            ru: uint32 = ssa_shr_value_sgn(nd_b[node])
            if lu == 1 or ru == 1:
                return 1
            if lu == 2 or ru == 2:
                return 2
            return 0
        return 0
    return ssa_expr_sgn(node)


def ssa_is_enabled() -> uint32:
    return ssa_enabled


# =======================================================================
# arena allocators
# =======================================================================
def ssa_reset():
    sv_count = 1
    arg_count = 1
    sb_count = 1
    pl_count = 1
    sb_entry = 0
    ssa_loop_depth = 0
    sv_overflow = 0
    ssa_bail = 0
    ssa_bail_reason = SBR_OK
    sb_rpo_n = 0
    sb_po_n = 0


def sv_new(op: uint32) -> uint32:
    if sv_count >= SSA_VAL_MAX:
        sv_overflow = 1
        ssa_set_bail(SBR_OVERFLOW)
        return 0
    id: uint32 = sv_count
    sv_count = sv_count + 1
    sv_op[id] = op
    sv_type[id] = SVT_I64
    sv_a[id] = 0
    sv_b[id] = 0
    sv_c[id] = 0
    sv_aux[id] = 0
    sv_imm[id] = 0
    sv_block[id] = 0
    sv_ast[id] = 0
    sv_next[id] = 0
    sv_prev[id] = 0
    sv_pos[id] = 0
    sv_arg_head[id] = 0
    sv_argn[id] = 0
    return id


def ssa_set_bail(reason: uint32):
    if ssa_bail == 0:
        ssa_bail = 1
        ssa_bail_reason = reason
        if reason < SBR_NREASONS:
            ssa_bail_hist[reason] = ssa_bail_hist[reason] + 1


def bb_new_ssa() -> uint32:
    if sb_count >= SSA_BB_MAX:
        ssa_set_bail(SBR_OVERFLOW)
        return 0
    id: uint32 = sb_count
    sb_count = sb_count + 1
    sb_first_val[id] = 0
    sb_last_val[id] = 0
    sb_term[id] = 0
    sb_nval[id] = 0
    sb_succ0[id] = 0
    sb_succ1[id] = 0
    sb_nsucc[id] = 0
    sb_pred_head[id] = 0
    sb_npred[id] = 0
    sb_sealed[id] = 0
    sb_idom[id] = 0
    sb_ponum[id] = 0
    sb_visited[id] = 0
    # Zero this block's Braun current-def / incomplete-phi row so no stale
    # mapping from a previously-built function leaks in (the maps are indexed
    # [block * NM_MAX + var] and are NOT globally cleared per function).
    base: uint32 = id * NM_MAX
    j: uint32 = 0
    while j < NM_MAX:
        ssa_curdef[base + j] = 0
        ssa_incphi[base + j] = 0
        j = j + 1
    return id


# Append value `v` to the end of block `bb`'s intrusive list.
def bb_append(bb: uint32, v: uint32):
    if bb == 0 or v == 0:
        return
    sv_block[v] = bb
    sv_pos[v] = sb_nval[bb]
    sb_nval[bb] = sb_nval[bb] + 1
    if sb_first_val[bb] == 0:
        sb_first_val[bb] = v
        sb_last_val[bb] = v
        sv_prev[v] = 0
        sv_next[v] = 0
        return
    last: uint32 = sb_last_val[bb]
    sv_next[last] = v
    sv_prev[v] = last
    sv_next[v] = 0
    sb_last_val[bb] = v


# Prepend value `v` to the head of block `bb` (phis go at block head).
def bb_prepend(bb: uint32, v: uint32):
    if bb == 0 or v == 0:
        return
    sv_block[v] = bb
    sb_nval[bb] = sb_nval[bb] + 1
    if sb_first_val[bb] == 0:
        sb_first_val[bb] = v
        sb_last_val[bb] = v
        sv_prev[v] = 0
        sv_next[v] = 0
        sv_pos[v] = 0
        ssa_renumber_block(bb)
        return
    first: uint32 = sb_first_val[bb]
    sv_prev[first] = v
    sv_next[v] = first
    sv_prev[v] = 0
    sb_first_val[bb] = v
    ssa_renumber_block(bb)


# Re-stamp sv_pos across a block (after a head insert) so positions stay dense.
def ssa_renumber_block(bb: uint32):
    p: uint32 = 0
    cur: uint32 = sb_first_val[bb]
    while cur != 0:
        sv_pos[cur] = p
        p = p + 1
        cur = sv_next[cur]


# Add an edge bb -> succ (records succ on bb, pushes bb onto succ's pred list).
def ssa_add_edge(bb: uint32, succ: uint32):
    if bb == 0 or succ == 0:
        return
    if sb_nsucc[bb] == 0:
        sb_succ0[bb] = succ
        sb_nsucc[bb] = 1
    elif sb_nsucc[bb] == 1:
        sb_succ1[bb] = succ
        sb_nsucc[bb] = 2
    # record predecessor
    if pl_count >= 8192:
        ssa_set_bail(SBR_OVERFLOW)
        return
    node: uint32 = pl_count
    pl_count = pl_count + 1
    pl_bid[node] = bb
    pl_next[node] = sb_pred_head[succ]
    sb_pred_head[succ] = node
    sb_npred[succ] = sb_npred[succ] + 1


# =======================================================================
# 3.1 / 3.2  Braun on-the-fly SSA construction + mem2reg.
# =======================================================================
def curdef_get(bb: uint32, var: uint32) -> uint32:
    return ssa_curdef[bb * NM_MAX + var]


def curdef_set(bb: uint32, var: uint32, v: uint32):
    ssa_curdef[bb * NM_MAX + var] = v


def incphi_get(bb: uint32, var: uint32) -> uint32:
    return ssa_incphi[bb * NM_MAX + var]


def incphi_set(bb: uint32, var: uint32, v: uint32):
    ssa_incphi[bb * NM_MAX + var] = v


# writeVariable(var, block, value)
def ssa_write_var(var: uint32, bb: uint32, v: uint32):
    curdef_set(bb, var, v)


# Append a (pred, val) operand onto phi `phi`.
def phi_add_operand(phi: uint32, pred: uint32, v: uint32):
    if arg_count >= SSA_ARG_MAX:
        ssa_set_bail(SBR_OVERFLOW)
        return
    a: uint32 = arg_count
    arg_count = arg_count + 1
    arg_val[a] = v
    arg_pred[a] = pred
    arg_next[a] = sv_arg_head[phi]
    sv_arg_head[phi] = a
    sv_argn[phi] = sv_argn[phi] + 1


# addPhiOperands: fill phi with one operand per predecessor of its block.
def ssa_add_phi_operands(var: uint32, phi: uint32):
    bb: uint32 = sv_block[phi]
    node: uint32 = sb_pred_head[bb]
    while node != 0:
        p: uint32 = pl_bid[node]
        v: uint32 = ssa_read_var(var, p)
        phi_add_operand(phi, p, v)
        node = pl_next[node]


# readVariableRecursive
def ssa_read_var_recursive(var: uint32, bb: uint32) -> uint32:
    if sb_sealed[bb] == 0:
        # incomplete CFG: place an operandless phi, fill it on seal.
        phi: uint32 = sv_new(SVO_PHI)
        if phi == 0:
            return 0
        bb_prepend(bb, phi)
        incphi_set(bb, var, phi)
        ssa_write_var(var, bb, phi)
        return phi
    if sb_npred[bb] == 1:
        # single predecessor: no phi needed, forward the read.
        p: uint32 = pl_bid[sb_pred_head[bb]]
        val: uint32 = ssa_read_var(var, p)
        ssa_write_var(var, bb, val)
        return val
    # multiple predecessors: break potential cycles with a phi, then fill.
    phi2: uint32 = sv_new(SVO_PHI)
    if phi2 == 0:
        return 0
    bb_prepend(bb, phi2)
    ssa_write_var(var, bb, phi2)
    ssa_add_phi_operands(var, phi2)
    return phi2


# readVariable(var, block): current def, else recurse.
def ssa_read_var(var: uint32, bb: uint32) -> uint32:
    v: uint32 = curdef_get(bb, var)
    if v != 0:
        return v
    return ssa_read_var_recursive(var, bb)


# sealBlock: all predecessors are now known; fill deferred phis.
def ssa_seal_block(bb: uint32):
    var: uint32 = 0
    while var < nm_count:
        phi: uint32 = incphi_get(bb, var)
        if phi != 0:
            ssa_add_phi_operands(var, phi)
            incphi_set(bb, var, 0)
        var = var + 1
    sb_sealed[bb] = 1


# =======================================================================
# expression lowering: AST expr -> SSA value vid (0 on bail).
# =======================================================================
# Classify a binop as arithmetic (SVO_BINOP), compare (SVO_ICMP), or unsupported.
def ssa_binop_is_arith(op: uint32) -> uint32:
    if op == BINOP_ADD or op == BINOP_SUB or op == BINOP_MUL:
        return 1
    if op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_MOD:
        return 1
    if op == BINOP_BIT_OR or op == BINOP_BIT_AND or op == BINOP_BIT_XOR:
        return 1
    if op == BINOP_SHL or op == BINOP_SHR:
        return 1
    return 0


def ssa_binop_is_cmp(op: uint32) -> uint32:
    if op == BINOP_EQ or op == BINOP_NEQ:
        return 1
    if op == BINOP_LT or op == BINOP_LTE:
        return 1
    if op == BINOP_GT or op == BINOP_GTE:
        return 1
    return 0


# Promotability of a local name id: address never taken, slot never read directly
# (reuses cfg.ad's cl_build outputs — §2.5).
def ssa_name_promotable(nid: uint32) -> uint32:
    if nid >= NM_MAX:
        return 0
    if cl_set[nid] != 0:
        return 0
    if nm_slotread[nid] != 0:
        return 0
    return 1


# Resolve the setcc opcode byte for an integer compare `op`, applying the
# signed/unsigned override from operand tristates via codegen's rel_setcc — the
# exact selection the legacy backend makes (default signed setl/setle/setg/setge;
# unsigned setb/setbe/seta/setae when either operand is known-unsigned).
def ssa_cmp_setcc(op: uint32, l_sgn: uint32, r_sgn: uint32) -> uint32:
    if op == BINOP_EQ:
        return 0x94
    if op == BINOP_NEQ:
        return 0x95
    if op == BINOP_LT:
        return rel_setcc(0x9C, l_sgn, r_sgn)
    if op == BINOP_LTE:
        return rel_setcc(0x9E, l_sgn, r_sgn)
    if op == BINOP_GT:
        return rel_setcc(0x9F, l_sgn, r_sgn)
    # BINOP_GTE
    return rel_setcc(0x9D, l_sgn, r_sgn)


# Return the 1-based global index if `off/len` names an EMITTABLE scalar global
# (a non-array, non-percpu global whose value lives at a RIP-relative address and
# whose width is a machine load/store size), else 0.  Address-taken aggregate and
# percpu globals are NOT handled here (they bail via the normal path).
def ssa_scalar_global(off: uint32, len_: uint32) -> uint32:
    gi: uint32 = glob_lookup(off, len_)
    if gi == 0:
        return 0
    if glob_elem_size[gi - 1] != 0:
        return 0                              # array global (needs indexing)
    if glob_is_percpu[gi - 1] != 0:
        return 0                              # %gs-relative (kernel) -> defer
    return gi


# Emit an SVO_GLOBALADDR value (RIP-relative lea of scalar global `gi`) into `bb`.
def ssa_globaladdr(gi: uint32, bb: uint32) -> uint32:
    a: uint32 = sv_new(SVO_GLOBALADDR)
    if a == 0:
        return 0
    sv_imm[a] = cast[uint64](glob_offset[gi - 1])
    sv_c[a] = glob_is_bss[gi - 1]
    sv_type[a] = SVT_PTR
    bb_append(bb, a)
    return a


# Emit a scalar-global LOAD (GLOBALADDR + SVO_LOAD) for global `gi` into `bb`.
def ssa_global_load(gi: uint32, bb: uint32) -> uint32:
    addr: uint32 = ssa_globaladdr(gi, bb)
    if addr == 0:
        return 0
    ld: uint32 = sv_new(SVO_LOAD)
    if ld == 0:
        return 0
    sv_a[ld] = addr
    sv_aux[ld] = glob_scalar_size[gi - 1]     # load width (1/2/4/8)
    sv_c[ld] = glob_is_signed[gi - 1]         # 1 => sized signed load (movsx)
    sv_ast[ld] = 0
    bb_append(bb, ld)
    return ld


# Emit a scalar-global STORE (GLOBALADDR + SVO_STORE) of value `val` into `bb`.
def ssa_global_store(gi: uint32, val: uint32, bb: uint32):
    addr: uint32 = ssa_globaladdr(gi, bb)
    if addr == 0:
        return
    st: uint32 = sv_new(SVO_STORE)
    if st == 0:
        return
    sv_a[st] = addr
    sv_b[st] = val
    sv_aux[st] = glob_scalar_size[gi - 1]     # store width
    bb_append(bb, st)


# Return the 1-based global index if `off/len` names an EMITTABLE 1-D
# scalar-element array global, else 0.  A 1-D array is indexed as
# base + idx*elem_size with a sized load/store.  Multi-dimensional globals
# (whose flat glob_elem_size records the INNERMOST width, not the row stride),
# pointer globals (glob_elem_size == 0) and percpu globals are all rejected so
# only the flat single-index case reaches ssa_index_addr.
def ssa_global_array_1d(off: uint32, len_: uint32) -> uint32:
    gi: uint32 = glob_lookup(off, len_)
    if gi == 0:
        return 0
    es: uint32 = glob_elem_size[gi - 1]
    if es != 1 and es != 2 and es != 4 and es != 8:
        return 0                              # scalar (0) or non-machine width
    if glob_is_percpu[gi - 1] != 0:
        return 0
    tn: uint32 = glob_type_node[gi - 1]
    if tn == 0 or nd_kind[tn] != ND_ARRAY_TYPE:
        return 0
    if nd_kind[nd_a[tn]] == ND_ARRAY_TYPE:
        return 0                              # multi-dimensional -> defer
    return gi


# Element signedness tristate (0 unknown / 1 unsigned / 2 signed) of 1-D array
# global `gi` — the declared element type's signedness (mirrors codegen
# expr_signedness -> index_elem_signed for the flat-global case).
def ssa_array_elem_sgn(gi: uint32) -> uint32:
    return type_signedness(nd_a[glob_type_node[gi - 1]])


# Byte address of `gi[idxnode]` for a 1-D scalar-array global: idx is lowered
# (may advance ssa_cur_bb across a short-circuit), then base = GLOBALADDR(gi) and
# addr = base + idx*elem_size are built as PURE pointer arithmetic in the current
# block, reusing the existing globaladdr / BINOP emit paths.  Returns 0 on bail.
def ssa_index_addr(gi: uint32, idxnode: uint32) -> uint32:
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    base: uint32 = ssa_globaladdr(gi, ssa_cur_bb)
    if base == 0:
        return 0
    es: uint32 = glob_elem_size[gi - 1]
    scaled: uint32 = idxv
    if es != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](es))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = base
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# Emit a sized SVO_LOAD of width `es` (signedness `sgn` tristate) from address
# value `addr` into the current block.
def ssa_load_at(addr: uint32, es: uint32, sgn: uint32) -> uint32:
    ld: uint32 = sv_new(SVO_LOAD)
    if ld == 0:
        return 0
    sv_a[ld] = addr
    sv_aux[ld] = es
    if es < 8 and sgn == 2:
        sv_c[ld] = 1                          # signed sub-word load (movsx)
    else:
        sv_c[ld] = 0                          # zero-extend / full-width load
    bb_append(ssa_cur_bb, ld)
    return ld


# Emit a sized SVO_STORE of width `es` of value `val` to address value `addr`.
def ssa_store_at(addr: uint32, val: uint32, es: uint32):
    st: uint32 = sv_new(SVO_STORE)
    if st == 0:
        return
    sv_a[st] = addr
    sv_b[st] = val
    sv_aux[st] = es
    bb_append(ssa_cur_bb, st)


# Build the SVO_BINOP for an augmented assignment `x op= e` == `x op e`, setting
# the div/mod/shr signedness hint (sv_c) from the operand AST nodes exactly as the
# ND_BINARY path does (lnode = the target value operand, rnode = the RHS expr).
def ssa_build_aug_binop(aug: uint32, cur: uint32, rhs: uint32, lnode: uint32,
                        rnode: uint32, stmt: uint32, bb: uint32) -> uint32:
    v5: uint32 = sv_new(SVO_BINOP)
    if v5 == 0:
        return 0
    sv_aux[v5] = aug
    sv_a[v5] = cur
    sv_b[v5] = rhs
    sv_ast[v5] = stmt
    if aug == BINOP_DIV or aug == BINOP_IDIV or aug == BINOP_MOD:
        sv_c[v5] = binop_use_signed(ssa_shr_value_sgn(lnode), ssa_shr_value_sgn(rnode))
    elif aug == BINOP_SHR:
        if ssa_shr_value_sgn(lnode) == 2:
            sv_c[v5] = 1
        else:
            sv_c[v5] = 0
    bb_append(bb, v5)
    return v5


# Emit a full-width integer constant `imm` into block `bb`, returning its vid.
def ssa_const_in(bb: uint32, imm: uint64) -> uint32:
    c: uint32 = sv_new(SVO_CONST)
    if c == 0:
        return 0
    sv_imm[c] = imm
    bb_append(bb, c)
    return c


# Lower a short-circuit `L and R` / `L or R` to control flow + a join phi that
# yields the 0/1 BOOLEAN result — matching the legacy backend's gen_short_circuit
# exactly (result is 0/1, NOT the operand value, and R is evaluated ONLY when L
# does not already decide the result).  Advances ssa_cur_bb to the join block.
#
# Layout (both forms): eval L in the current block bL; a two-way branch on L's
# truthiness; eval R in rbb (its own current block bR) under a second truthiness
# branch; a `true` block (const 1) and a `false` block (const 0) merge at `join`
# via a phi.  For `and`, L-false shortcuts to the false block; for `or`, L-true
# shortcuts to the true block.
def ssa_lower_shortcircuit(node: uint32, op: uint32) -> uint32:
    lv: uint32 = ssa_lower_expr(nd_a[node], ssa_cur_bb)
    if lv == 0:
        return 0
    bL: uint32 = ssa_cur_bb                       # block L's value landed in
    rbb: uint32 = bb_new_ssa()
    if rbb == 0:
        return 0
    tbb: uint32 = bb_new_ssa()
    if tbb == 0:
        return 0
    fbb: uint32 = bb_new_ssa()
    if fbb == 0:
        return 0
    join: uint32 = bb_new_ssa()
    if join == 0:
        return 0
    if op == BINOP_AND:
        # L truthy -> evaluate R; L falsy -> result false.
        ssa_terminate_condbr(bL, lv, rbb, fbb)
    else:
        # L truthy -> result true; L falsy -> evaluate R.
        ssa_terminate_condbr(bL, lv, tbb, rbb)
    # R arm.
    ssa_seal_block(rbb)                           # single pred: bL
    ssa_cur_bb = rbb
    rv: uint32 = ssa_lower_expr(nd_b[node], rbb)
    if rv == 0:
        return 0
    bR: uint32 = ssa_cur_bb                       # block R's value landed in
    # R truthy -> true block; R falsy -> false block (both forms).
    ssa_terminate_condbr(bR, rv, tbb, fbb)
    if ssa_bail != 0:
        return 0
    # true block: const 1 -> join.
    ssa_seal_block(tbb)
    c1: uint32 = ssa_const_in(tbb, cast[uint64](1))
    if c1 == 0:
        return 0
    sv_type[c1] = SVT_I1
    ssa_terminate_br(tbb, join)
    # false block: const 0 -> join.
    ssa_seal_block(fbb)
    c0: uint32 = ssa_const_in(fbb, cast[uint64](0))
    if c0 == 0:
        return 0
    sv_type[c0] = SVT_I1
    ssa_terminate_br(fbb, join)
    if ssa_bail != 0:
        return 0
    # join: phi selects 1 (true path) or 0 (false path).
    ssa_seal_block(join)
    phi: uint32 = sv_new(SVO_PHI)
    if phi == 0:
        return 0
    bb_prepend(join, phi)
    sv_type[phi] = SVT_I1
    phi_add_operand(phi, tbb, c1)
    phi_add_operand(phi, fbb, c0)
    ssa_cur_bb = join
    return phi


def ssa_lower_expr(node: uint32, bb: uint32) -> uint32:
    if ssa_bail != 0:
        return 0
    if node == 0:
        return 0
    # The block a subexpression's value lands in is ssa_cur_bb (threaded across
    # short-circuit CFG splits), NOT the stale `bb` argument.  Callers seed
    # ssa_cur_bb; recursion below passes ssa_cur_bb so a nested short-circuit that
    # advanced control is observed by the parent.
    k: uint32 = nd_kind[node]

    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT:
        v: uint32 = sv_new(SVO_CONST)
        if v == 0:
            return 0
        sv_imm[v] = nd_num[node]
        sv_ast[v] = node
        if k == ND_BOOL_LIT:
            sv_type[v] = SVT_I1
        bb_append(ssa_cur_bb, v)
        return v

    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[node], nd_name_len[node])
        if nid >= NM_MAX:
            ssa_set_bail(SBR_OVERFLOW)
            return 0
        if ssa_islocal[nid] == 0:
            # Not a known local: a scalar global reads via a RIP-relative load;
            # anything else (array/percpu global, function name, unknown) bails.
            gi: uint32 = ssa_scalar_global(nd_name_off[node], nd_name_len[node])
            if gi != 0:
                return ssa_global_load(gi, ssa_cur_bb)
            ssa_set_bail(SBR_NONLOCAL)
            return 0
        if ssa_name_promotable(nid) == 0:
            ssa_set_bail(SBR_NONPROMOTABLE)
            return 0
        return ssa_read_var(nid, ssa_cur_bb)

    if k == ND_BINARY:
        op: uint32 = nd_aux[node]
        if op == BINOP_AND or op == BINOP_OR:
            # short-circuit `and`/`or` -> control flow + join phi (§ short-circuit).
            return ssa_lower_shortcircuit(node, op)
        # div/mod (idiv vs div) and arithmetic-shift-right (sar vs shr) and the
        # ordered compares (< <= > >=, signed vs unsigned setcc) select their x86
        # instruction from operand SIGNEDNESS — now tracked per value via the
        # local/return-type signedness table, so the emit hint is resolved here
        # (sv_c) and these ops stay on the SSA path.  shl and the bitwise ops are
        # low-64-invariant regardless of signedness.
        arith: uint32 = ssa_binop_is_arith(op)
        cmp: uint32 = ssa_binop_is_cmp(op)
        if arith == 0 and cmp == 0:
            ssa_set_bail(SBR_NONSUBSET_EXPR)
            return 0
        # Snapshot operand AST nodes for signedness resolution BEFORE lowering
        # (lowering does not mutate the AST, but read them plainly).
        lnode: uint32 = nd_a[node]
        rnode: uint32 = nd_b[node]
        la: uint32 = ssa_lower_expr(lnode, ssa_cur_bb)
        if la == 0:
            return 0
        rb: uint32 = ssa_lower_expr(rnode, ssa_cur_bb)
        if rb == 0:
            return 0
        vop: uint32 = SVO_BINOP
        if cmp != 0:
            vop = SVO_ICMP
        v3: uint32 = sv_new(vop)
        if v3 == 0:
            return 0
        sv_aux[v3] = op
        sv_a[v3] = la
        sv_b[v3] = rb
        sv_ast[v3] = node
        if cmp != 0:
            # sv_c carries the resolved setcc opcode (shallow operand signedness).
            sv_c[v3] = ssa_cmp_setcc(op, ssa_expr_sgn(lnode), ssa_expr_sgn(rnode))
            sv_type[v3] = SVT_I1
        elif op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_MOD:
            # sv_c = 1 => signed (cqo;idiv), 0 => unsigned (xor rdx;div).  Uses the
            # STRUCTURAL operand signedness (matches legacy div_use_signed).
            sv_c[v3] = binop_use_signed(ssa_shr_value_sgn(lnode), ssa_shr_value_sgn(rnode))
        elif op == BINOP_SHR:
            # sv_c = 1 => arithmetic (sar), 0 => logical (shr); keyed on the LEFT
            # (value) operand's structural signedness alone (matches shr_use_signed).
            if ssa_shr_value_sgn(lnode) == 2:
                sv_c[v3] = 1
            else:
                sv_c[v3] = 0
        bb_append(ssa_cur_bb, v3)
        return v3

    if k == ND_UNARY:
        uop: uint32 = nd_aux[node]
        vop2: uint32 = 0
        if uop == UNOP_NEG:
            vop2 = SVO_NEG
        elif uop == UNOP_NOT:
            vop2 = SVO_NOT
        elif uop == UNOP_BIT_NOT:
            vop2 = SVO_BITNOT
        else:
            ssa_set_bail(SBR_MEMORY)   # deref / addr-of -> bail
            return 0
        oa: uint32 = ssa_lower_expr(nd_a[node], ssa_cur_bb)
        if oa == 0:
            return 0
        v4: uint32 = sv_new(vop2)
        if v4 == 0:
            return 0
        sv_a[v4] = oa
        sv_ast[v4] = node
        bb_append(ssa_cur_bb, v4)
        return v4

    if k == ND_CALL:
        # Direct call to a named function only.  Callee (nd_a) must be a bare
        # ident that is NOT a local (a function symbol); args are lowered values.
        callee: uint32 = nd_a[node]
        if callee == 0 or nd_kind[callee] != ND_IDENT:
            ssa_set_bail(SBR_NONSUBSET_EXPR)
            return 0
        cid: uint32 = nm_intern(nd_name_off[callee], nd_name_len[callee])
        if cid < NM_MAX and ssa_islocal[cid] != 0:
            # calling through a local (fn-pointer) -> bail (indirect not modeled).
            ssa_set_bail(SBR_NONSUBSET_EXPR)
            return 0
        # Phase-1b: the call result lands in %rax full-width; it is only correct
        # if the callee is an in-unit function returning a full-width non-float
        # integer.  Extern / narrow / float / unknown callees bail the function.
        if ssa_callee_rettype_ok(nd_name_off[callee], nd_name_len[callee]) == 0:
            ssa_set_bail(SBR_CALL)
            return 0
        cv: uint32 = sv_new(SVO_CALL)
        if cv == 0:
            return 0
        sv_ast[cv] = node
        # lower args left-to-right; store on the use-list (order-independent for
        # verification; the call node retains argument AST for future lowering).
        arg: uint32 = nd_b[node]
        argc: uint32 = 0
        while arg != 0:
            av: uint32 = ssa_lower_expr(arg, ssa_cur_bb)
            if av == 0:
                return 0
            phi_add_operand(cv, 0, av)
            argc = argc + 1
            arg = nd_next[arg]
        # Phase-1b: >6 register args would need stack marshalling; bail those.
        if argc > 6:
            ssa_set_bail(SBR_MANYARGS)
            return 0
        sv_aux[cv] = argc
        bb_append(ssa_cur_bb, cv)
        return cv

    if k == ND_CAST:
        # cast[T](x): nd_a = destination type node, nd_b = operand expr.  Mirror
        # codegen's gen_expr ND_CAST for the NON-FLOAT case exactly:
        #   * dest is a float type  -> SSE convert (out of subset) -> bail.
        #   * dest full-width int (prim_type_size == 8) or a non-ND_TYPE target
        #     (pointer/array cast: prim_type_size == 8) -> NO-OP: forward the
        #     operand value unchanged (low-64-invariant).
        #   * dest sub-8-byte int -> truncate+re-extend the operand to T's width
        #     (movzx for unsigned T / movsx for signed T) = emit_ext_rax(size,sgn).
        # The operand is always an integer value in our subset (float sources
        # bail at their leaves), so the float-source SSE path never applies.
        tnode: uint32 = nd_a[node]
        if type_float_width(tnode) != 0:
            ssa_set_bail(SBR_FLOAT)      # float destination -> SSE
            return 0
        opv: uint32 = ssa_lower_expr(nd_b[node], ssa_cur_bb)
        if opv == 0:
            return 0
        dsz: uint32 = 8
        if tnode != 0 and nd_kind[tnode] == ND_TYPE:
            dsz = prim_type_size(tnode)
        if dsz >= 8:
            return opv                            # identity cast: reuse the value
        # narrowing cast: SVO_TRUNC carries width (sv_aux) + signedness (sv_c).
        cv2: uint32 = sv_new(SVO_TRUNC)
        if cv2 == 0:
            return 0
        sv_a[cv2] = opv
        sv_aux[cv2] = dsz
        sv_ast[cv2] = node
        if type_is_unsigned(tnode) == 0:
            sv_c[cv2] = 1                          # signed dest -> sign-extend (movsx)
        else:
            sv_c[cv2] = 0                          # unsigned dest -> zero-extend (movzx)
        bb_append(ssa_cur_bb, cv2)
        return cv2

    if k == ND_INDEX:
        # `arr[i]` rvalue.  Only a 1-D scalar-element GLOBAL array indexed by an
        # in-subset integer expression is accepted; the element is loaded at the
        # computed byte address.  Local arrays (need alloca), pointer/struct/
        # multi-dim bases, etc. fall back.
        base: uint32 = nd_a[node]
        if nd_kind[base] != ND_IDENT:
            ssa_set_bail(SBR_MEMORY)
            return 0
        bnid: uint32 = nm_intern(nd_name_off[base], nd_name_len[base])
        if bnid < NM_MAX and ssa_islocal[bnid] != 0:
            ssa_set_bail(SBR_MEMORY)              # local array -> needs alloca
            return 0
        gia: uint32 = ssa_global_array_1d(nd_name_off[base], nd_name_len[base])
        if gia == 0:
            ssa_set_bail(SBR_MEMORY)
            return 0
        addr: uint32 = ssa_index_addr(gia, nd_b[node])
        if addr == 0:
            return 0
        return ssa_load_at(addr, glob_elem_size[gia - 1], ssa_array_elem_sgn(gia))

    # float literal, member, slice, conditional, etc. -> bail.
    if k == ND_FLOAT_LIT:
        ssa_set_bail(SBR_FLOAT)
    elif k == ND_MEMBER:
        ssa_set_bail(SBR_MEMORY)
    else:
        ssa_set_bail(SBR_NONSUBSET_EXPR)
    return 0


# Lower `arr[idx] = rhs` / `arr[idx] op= rhs` for a 1-D scalar-element GLOBAL
# array.  Returns the (unchanged-through-a-store) fallthrough block.  Callers seed
# ssa_cur_bb; this re-reads it after each lowered subexpression.
def ssa_lower_index_store(bb: uint32, stmt: uint32, target: uint32) -> uint32:
    base: uint32 = nd_a[target]
    if nd_kind[base] != ND_IDENT:
        ssa_set_bail(SBR_MEMORY)
        return bb
    bnid: uint32 = nm_intern(nd_name_off[base], nd_name_len[base])
    if bnid < NM_MAX and ssa_islocal[bnid] != 0:
        ssa_set_bail(SBR_MEMORY)                  # local array -> needs alloca
        return bb
    gi: uint32 = ssa_global_array_1d(nd_name_off[base], nd_name_len[base])
    if gi == 0:
        ssa_set_bail(SBR_MEMORY)
        return bb
    es: uint32 = glob_elem_size[gi - 1]
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        # arr[i] op= e  ==  arr[i] = (arr[i] op e): compute the address ONCE (so
        # the index is evaluated once), load, combine, store back to the SAME
        # address value.
        addr: uint32 = ssa_index_addr(gi, nd_b[target])
        if addr == 0:
            return ssa_cur_bb
        cur: uint32 = ssa_load_at(addr, es, ssa_array_elem_sgn(gi))
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, es)
        return ssa_cur_bb
    # plain store: lower the RHS, then the address, then store.
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    addr2: uint32 = ssa_index_addr(gi, nd_b[target])
    if addr2 == 0:
        return ssa_cur_bb
    ssa_store_at(addr2, rhsv, es)
    return ssa_cur_bb


# =======================================================================
# statement lowering: threads the current block; returns fallthrough block
# (0 == control cannot fall through, e.g. after return/break/continue).
# =======================================================================
def ssa_intern_local(off: uint32, len_: uint32, tnode: uint32) -> uint32:
    nid: uint32 = nm_intern(off, len_)
    if nid >= NM_MAX:
        ssa_set_bail(SBR_OVERFLOW)
        return NM_MAX
    if ssa_name_promotable(nid) == 0:
        ssa_set_bail(SBR_NONPROMOTABLE)
        return NM_MAX
    # Non-float integer scalars only (float locals bail -> SSE).  A narrow
    # (1/2/4-byte) local is accepted and truncated on every write (see
    # ssa_trunc_to_local); the aggregate/pointer case (prim_type_size not a
    # machine width) also bails.
    if type_float_width(tnode) != 0:
        ssa_set_bail(SBR_FLOAT)
        return NM_MAX
    sz: uint32 = prim_type_size(tnode)
    if sz != 1 and sz != 2 and sz != 4 and sz != 8:
        ssa_set_bail(SBR_NONPROMOTABLE)
        return NM_MAX
    ssa_islocal[nid] = 1
    ssa_local_sgn[nid] = type_signedness(tnode)
    ssa_local_size[nid] = sz
    return nid


# If local `nid` is narrow (<8 bytes), wrap `val` in an SVO_TRUNC to the local's
# width+signedness so every threaded read observes the truncated value (the
# legacy sized-store/extended-load semantics).  Full-width locals pass through.
def ssa_trunc_to_local(nid: uint32, val: uint32, bb: uint32) -> uint32:
    if val == 0:
        return 0
    sz: uint32 = ssa_local_size[nid]
    if sz >= 8:
        return val
    tv: uint32 = sv_new(SVO_TRUNC)
    if tv == 0:
        return 0
    sv_a[tv] = val
    sv_aux[tv] = sz
    if ssa_local_sgn[nid] == 2:
        sv_c[tv] = 1                          # signed -> movsx
    else:
        sv_c[tv] = 0                          # unsigned -> movzx
    bb_append(bb, tv)
    return tv


def ssa_lower_stmt(bb: uint32, stmt: uint32) -> uint32:
    if ssa_bail != 0:
        return 0
    if bb == 0:
        return 0
    # Seed the expression-lowering current block; a short-circuit inside any RHS
    # advances ssa_cur_bb, so every handler re-reads bb = ssa_cur_bb after lowering
    # before it appends stores / terminators.
    ssa_cur_bb = bb
    k: uint32 = nd_kind[stmt]

    if k == ND_PASS:
        return bb

    if k == ND_VAR_DECL:
        nid: uint32 = ssa_intern_local(nd_name_off[stmt], nd_name_len[stmt], nd_a[stmt])
        if nid >= NM_MAX:
            return bb
        val: uint32 = 0
        if nd_b[stmt] != 0:
            val = ssa_lower_expr(nd_b[stmt], bb)
            if val == 0:
                return bb
            bb = ssa_cur_bb                          # RHS may have split control
            val = ssa_trunc_to_local(nid, val, bb)   # narrow-local store truncation
            if val == 0:
                return bb
        else:
            # declaration without initializer -> undef value.
            val = sv_new(SVO_UNDEF)
            if val == 0:
                return bb
            bb_append(bb, val)
        ssa_write_var(nid, bb, val)
        return bb

    if k == ND_ASSIGN:
        target: uint32 = nd_a[stmt]
        if nd_kind[target] == ND_INDEX:
            # store into a 1-D scalar-element GLOBAL array element.
            return ssa_lower_index_store(bb, stmt, target)
        if nd_kind[target] != ND_IDENT:
            # store through member/deref -> memory, outside the current subset.
            ssa_set_bail(SBR_MEMORY)
            return bb
        tid: uint32 = nm_intern(nd_name_off[target], nd_name_len[target])
        if tid >= NM_MAX:
            ssa_set_bail(SBR_OVERFLOW)
            return bb
        aug: uint32 = nd_aux[stmt]
        if ssa_islocal[tid] == 0:
            # Not a known local: a scalar global stores via a RIP-relative store;
            # anything else (array/percpu global, unknown) bails.
            gi: uint32 = ssa_scalar_global(nd_name_off[target], nd_name_len[target])
            if gi == 0:
                ssa_set_bail(SBR_NONLOCAL)
                return bb
            rhsg: uint32 = ssa_lower_expr(nd_b[stmt], bb)
            if rhsg == 0:
                return bb
            bb = ssa_cur_bb                          # RHS may have split control
            if aug != 0:
                # g op= e == g = (g op e): read the global, combine, store back.
                curg: uint32 = ssa_global_load(gi, bb)
                if curg == 0:
                    return bb
                vg: uint32 = ssa_build_aug_binop(aug, curg, rhsg, target, nd_b[stmt], stmt, bb)
                if vg == 0:
                    return bb
                ssa_global_store(gi, vg, bb)
            else:
                ssa_global_store(gi, rhsg, bb)
            return bb
        if ssa_name_promotable(tid) == 0:
            ssa_set_bail(SBR_NONPROMOTABLE)
            return bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], bb)
        if rhs == 0:
            return bb
        bb = ssa_cur_bb                              # RHS may have split control
        if aug != 0:
            # x op= e  ==>  x = (x op e)
            cur: uint32 = ssa_read_var(tid, bb)
            if cur == 0:
                return bb
            v5: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, bb)
            if v5 == 0:
                return bb
            v5 = ssa_trunc_to_local(tid, v5, bb)     # narrow-local store truncation
            if v5 == 0:
                return bb
            ssa_write_var(tid, bb, v5)
        else:
            rhs = ssa_trunc_to_local(tid, rhs, bb)   # narrow-local store truncation
            if rhs == 0:
                return bb
            ssa_write_var(tid, bb, rhs)
        return bb

    if k == ND_EXPR_STMT:
        ssa_lower_expr(nd_a[stmt], bb)   # value discarded; may be a call side-effect
        return ssa_cur_bb                # a short-circuit may have split control

    if k == ND_RETURN:
        rv: uint32 = 0
        if nd_a[stmt] != 0:
            rv = ssa_lower_expr(nd_a[stmt], bb)
            if rv == 0 and ssa_bail != 0:
                return 0
        bb = ssa_cur_bb                  # return value may have split control
        ret: uint32 = sv_new(SVO_RET)
        if ret == 0:
            return 0
        sv_a[ret] = rv
        sv_ast[ret] = stmt
        bb_append(bb, ret)
        sb_term[bb] = SVO_RET
        return 0

    if k == ND_BREAK:
        if ssa_loop_depth == 0:
            ssa_set_bail(SBR_NONSUBSET_STMT)
            return 0
        tgt: uint32 = ssa_brk_bb[ssa_loop_depth - 1]
        ssa_terminate_br(bb, tgt)
        return 0

    if k == ND_CONTINUE:
        if ssa_loop_depth == 0:
            ssa_set_bail(SBR_NONSUBSET_STMT)
            return 0
        tgt2: uint32 = ssa_cont_bb[ssa_loop_depth - 1]
        ssa_terminate_br(bb, tgt2)
        return 0

    if k == ND_IF:
        return ssa_lower_if(bb, stmt)

    if k == ND_WHILE:
        return ssa_lower_while(bb, stmt)

    if k == ND_DO_WHILE:
        return ssa_lower_do_while(bb, stmt)

    # for/match/try/with/defer/yield/global/... -> bail.
    if k == ND_FOR:
        ssa_set_bail(SBR_FORLOOP)
    else:
        ssa_set_bail(SBR_NONSUBSET_STMT)
    return 0


# Emit an unconditional-branch terminator bb -> tgt.
def ssa_terminate_br(bb: uint32, tgt: uint32):
    if bb == 0 or tgt == 0:
        return
    br: uint32 = sv_new(SVO_BR)
    if br == 0:
        return
    sv_a[br] = tgt
    bb_append(bb, br)
    sb_term[bb] = SVO_BR
    ssa_add_edge(bb, tgt)


# Emit a conditional-branch terminator bb -?-> then/else.
def ssa_terminate_condbr(bb: uint32, cond: uint32, then_bb: uint32, else_bb: uint32):
    if bb == 0:
        return
    cb: uint32 = sv_new(SVO_CONDBR)
    if cb == 0:
        return
    sv_a[cb] = cond
    sv_b[cb] = then_bb
    sv_c[cb] = else_bb
    bb_append(bb, cb)
    sb_term[bb] = SVO_CONDBR
    ssa_add_edge(bb, then_bb)
    ssa_add_edge(bb, else_bb)


# Lower a statement chain, threading the current block.  Returns the fallthrough
# block (0 if control cannot fall through the chain).
def ssa_lower_chain(bb: uint32, head: uint32) -> uint32:
    cur: uint32 = bb
    s: uint32 = head
    while s != 0:
        if ssa_bail != 0:
            return 0
        if cur == 0:
            # unreachable code after a terminator: drop it (structured CFG keeps
            # semantics; a fresh dead block is unnecessary for Ph1's subset).
            return 0
        cur = ssa_lower_stmt(cur, s)
        s = nd_next[s]
    return cur


# --- if / elif / else --------------------------------------------------
#
# Edge-first (Braun-safe): every block's predecessor edges are wired BEFORE the
# block is sealed, so a variable read inside a block resolves against the correct
# predecessor set.  The enclosing branch's edges are added, then the arm body is
# sealed + lowered.
def ssa_lower_if(bb: uint32, stmt: uint32) -> uint32:
    ssa_cur_bb = bb
    cond: uint32 = ssa_lower_expr(nd_a[stmt], bb)
    if cond == 0:
        return 0
    cbb: uint32 = ssa_cur_bb              # a short-circuit condition splits control
    join: uint32 = bb_new_ssa()
    if join == 0:
        return 0
    then_bb: uint32 = bb_new_ssa()
    if then_bb == 0:
        return 0
    has_alt: uint32 = 0
    if nd_c[stmt] != 0 or nd_d[stmt] != 0:
        has_alt = 1
    else_bb: uint32 = join
    if has_alt != 0:
        else_bb = bb_new_ssa()
        if else_bb == 0:
            return 0
    # wire the branch edges FIRST (cbb -> then_bb, cbb -> else_bb).
    ssa_terminate_condbr(cbb, cond, then_bb, else_bb)
    # then arm.
    ssa_seal_block(then_bb)
    then_tail: uint32 = ssa_lower_chain(then_bb, nd_b[stmt])
    if then_tail != 0:
        ssa_terminate_br(then_tail, join)
    # alternative path (elif chain / else); else_bb's incoming edge is already
    # wired above, so alts can seal + lower it safely.
    if has_alt != 0:
        ssa_lower_if_alts(else_bb, nd_c[stmt], nd_d[stmt], join)
    if ssa_bail != 0:
        return 0
    ssa_seal_block(join)
    return join


# Lower the alternative path into `entry_bb` (already created + incoming edge
# wired by the caller).  Wires all edges to `join`.
def ssa_lower_if_alts(entry_bb: uint32, elif_head: uint32, else_head: uint32,
                      join: uint32):
    if ssa_bail != 0:
        return
    ssa_seal_block(entry_bb)              # single known pred (the enclosing branch)
    if elif_head != 0:
        ssa_cur_bb = entry_bb
        cond: uint32 = ssa_lower_expr(nd_a[elif_head], entry_bb)
        if cond == 0:
            return
        cbb: uint32 = ssa_cur_bb          # a short-circuit condition splits control
        body_bb: uint32 = bb_new_ssa()
        if body_bb == 0:
            return
        more: uint32 = 0
        if nd_next[elif_head] != 0 or else_head != 0:
            more = 1
        next_bb: uint32 = join
        if more != 0:
            next_bb = bb_new_ssa()
            if next_bb == 0:
                return
        ssa_terminate_condbr(cbb, cond, body_bb, next_bb)
        ssa_seal_block(body_bb)
        bt: uint32 = ssa_lower_chain(body_bb, nd_b[elif_head])
        if bt != 0:
            ssa_terminate_br(bt, join)
        if more != 0:
            ssa_lower_if_alts(next_bb, nd_next[elif_head], else_head, join)
        return
    if else_head != 0:
        et: uint32 = ssa_lower_chain(entry_bb, else_head)
        if et != 0:
            ssa_terminate_br(et, join)
        return
    # no elif, no else: fall straight to join.
    ssa_terminate_br(entry_bb, join)


# --- while -------------------------------------------------------------
def ssa_lower_while(bb: uint32, stmt: uint32) -> uint32:
    header: uint32 = bb_new_ssa()
    if header == 0:
        return 0
    ssa_terminate_br(bb, header)          # pred #1 (pre-loop) wired
    # header is NOT sealed yet: the back-edge pred is still unknown.
    ssa_cur_bb = header
    cond: uint32 = ssa_lower_expr(nd_a[stmt], header)
    if cond == 0:
        return 0
    chb: uint32 = ssa_cur_bb              # a short-circuit condition splits control
    body_bb: uint32 = bb_new_ssa()
    if body_bb == 0:
        return 0
    exit_bb: uint32 = bb_new_ssa()
    if exit_bb == 0:
        return 0
    ssa_terminate_condbr(chb, cond, body_bb, exit_bb)
    ssa_seal_block(body_bb)               # body's only entry pred is the header
    if ssa_loop_depth >= SSA_LOOP_MAX:
        ssa_set_bail(SBR_LOOPDEPTH)
        return 0
    ssa_brk_bb[ssa_loop_depth] = exit_bb
    ssa_cont_bb[ssa_loop_depth] = header
    ssa_loop_depth = ssa_loop_depth + 1
    body_tail: uint32 = ssa_lower_chain(body_bb, nd_b[stmt])
    ssa_loop_depth = ssa_loop_depth - 1
    if body_tail != 0:
        ssa_terminate_br(body_tail, header)   # back-edge pred wired
    # all header predecessors now known -> seal (fills the loop-carried phis).
    ssa_seal_block(header)
    ssa_seal_block(exit_bb)
    return exit_bb


# --- do-while ----------------------------------------------------------
def ssa_lower_do_while(bb: uint32, stmt: uint32) -> uint32:
    body_bb: uint32 = bb_new_ssa()
    if body_bb == 0:
        return 0
    ssa_terminate_br(bb, body_bb)         # pred #1 (pre-loop) wired
    cond_bb: uint32 = bb_new_ssa()
    if cond_bb == 0:
        return 0
    exit_bb: uint32 = bb_new_ssa()
    if exit_bb == 0:
        return 0
    # body_bb is unsealed: its back-edge pred (from cond) is still unknown.
    if ssa_loop_depth >= SSA_LOOP_MAX:
        ssa_set_bail(SBR_LOOPDEPTH)
        return 0
    ssa_brk_bb[ssa_loop_depth] = exit_bb
    ssa_cont_bb[ssa_loop_depth] = cond_bb
    ssa_loop_depth = ssa_loop_depth + 1
    body_tail: uint32 = ssa_lower_chain(body_bb, nd_b[stmt])
    ssa_loop_depth = ssa_loop_depth - 1
    if body_tail != 0:
        ssa_terminate_br(body_tail, cond_bb)
    ssa_seal_block(cond_bb)               # cond's preds (body tail + continues) known
    ssa_cur_bb = cond_bb
    cond: uint32 = ssa_lower_expr(nd_a[stmt], cond_bb)
    if cond == 0:
        return 0
    ccb: uint32 = ssa_cur_bb              # a short-circuit condition splits control
    ssa_terminate_condbr(ccb, cond, body_bb, exit_bb)  # back-edge to body wired
    ssa_seal_block(body_bb)               # now all body preds known
    ssa_seal_block(exit_bb)
    return exit_bb


# =======================================================================
# whole-function build.  Returns the entry bid, or 0 on bail/overflow.
# =======================================================================
def ssa_build_function(fn: uint32) -> uint32:
    # Reuse cfg.ad's name interning + escape scan for the promotability test.
    ok: uint32 = cfg_build_function(fn)
    if ok == 0:
        return 0                          # cfg overflow -> escape hatch
    cl_build(fn)

    ssa_reset()
    # clear the known-locals set for this function.
    i: uint32 = 0
    while i < NM_MAX:
        ssa_islocal[i] = 0
        ssa_local_sgn[i] = 0
        ssa_local_size[i] = 8
        i = i + 1
    # Braun current-def / incomplete-phi rows are cleared per block in bb_new_ssa
    # (indexed [block * NM_MAX + var]), so no stale mapping leaks between funcs.

    entry: uint32 = bb_new_ssa()
    if entry == 0:
        return 0
    sb_entry = entry
    sb_sealed[entry] = 1                  # entry has no predecessors

    # Parameters become SVO_PARAM values written in the entry block.  Each param
    # must be a promotable scalar (else escape-hatch bail).
    p: uint32 = nd_a[fn]
    pidx: uint32 = 0
    while p != 0:
        if nd_kind[p] == ND_PARAM:
            # Phase-1b: >6 params would need stack-arg spill; bail those (the
            # trivial round-trip only spills the 6 SysV register args).
            if pidx >= 6:
                ssa_set_bail(SBR_MANYARGS)
                return 0
            nid: uint32 = ssa_intern_local(nd_name_off[p], nd_name_len[p], nd_a[p])
            if nid >= NM_MAX:
                return 0
            pv: uint32 = sv_new(SVO_PARAM)
            if pv == 0:
                return 0
            sv_aux[pv] = pidx
            sv_ast[pv] = p
            bb_append(entry, pv)
            # A narrow parameter is truncated to its declared width on entry
            # (the legacy sized param spill), so every read sees the truncated
            # value regardless of the caller's upper argument-register bits.
            pvt: uint32 = ssa_trunc_to_local(nid, pv, entry)
            if pvt == 0:
                return 0
            ssa_write_var(nid, entry, pvt)
        pidx = pidx + 1
        p = nd_next[p]

    if ssa_bail != 0:
        return 0

    tail: uint32 = ssa_lower_chain(entry, nd_c[fn])
    if ssa_bail != 0:
        return 0
    # implicit return at the fallthrough tail (void or default).
    if tail != 0:
        ret: uint32 = sv_new(SVO_RET)
        if ret == 0:
            return 0
        sv_a[ret] = 0
        bb_append(tail, ret)
        sb_term[tail] = SVO_RET

    if ssa_bail != 0:
        return 0
    return entry


# =======================================================================
# 3.1  dominator tree (computed AFTER construction, as analysis).
# =======================================================================
# Recursive DFS postorder over successor edges from entry.
def ssa_dfs_post(bb: uint32):
    if bb == 0 or sb_visited[bb] != 0:
        return
    sb_visited[bb] = 1
    if sb_nsucc[bb] >= 1:
        ssa_dfs_post(sb_succ0[bb])
    if sb_nsucc[bb] >= 2:
        ssa_dfs_post(sb_succ1[bb])
    sb_ponum[bb] = sb_po_n
    sb_po[sb_po_n] = bb
    sb_po_n = sb_po_n + 1


def ssa_build_rpo():
    b: uint32 = 0
    while b < sb_count:
        sb_visited[b] = 0
        sb_ponum[b] = 0
        b = b + 1
    sb_po_n = 0
    ssa_dfs_post(sb_entry)
    # reverse postorder = reverse of postorder list.
    sb_rpo_n = sb_po_n
    i: uint32 = 0
    while i < sb_po_n:
        sb_rpo[i] = sb_po[sb_po_n - 1 - i]
        i = i + 1


# Cooper-Harvey-Kennedy intersect using postorder numbers (higher = nearer entry).
def ssa_dom_intersect(a: uint32, b: uint32) -> uint32:
    x: uint32 = a
    y: uint32 = b
    while x != y:
        while sb_ponum[x] < sb_ponum[y]:
            x = sb_idom[x]
        while sb_ponum[y] < sb_ponum[x]:
            y = sb_idom[y]
    return x


def ssa_build_domtree():
    ssa_build_rpo()
    b: uint32 = 0
    while b < sb_count:
        sb_idom[b] = 0
        b = b + 1
    sb_idom[sb_entry] = sb_entry
    changed: uint32 = 1
    while changed != 0:
        changed = 0
        i: uint32 = 0
        while i < sb_rpo_n:
            bb: uint32 = sb_rpo[i]
            if bb != sb_entry:
                newidom: uint32 = 0
                node: uint32 = sb_pred_head[bb]
                while node != 0:
                    p: uint32 = pl_bid[node]
                    if sb_idom[p] != 0:
                        if newidom == 0:
                            newidom = p
                        else:
                            newidom = ssa_dom_intersect(p, newidom)
                    node = pl_next[node]
                if newidom != 0 and sb_idom[bb] != newidom:
                    sb_idom[bb] = newidom
                    changed = 1
            i = i + 1


# Does block `a` dominate block `b`?  Walk the idom chain up from b to entry.
def ssa_dominates(a: uint32, b: uint32) -> uint32:
    x: uint32 = b
    while x != 0:
        if x == a:
            return 1
        nx: uint32 = sb_idom[x]
        if nx == x:
            return 0                       # reached entry (idom self)
        x = nx
    return 0


# =======================================================================
# 3.4  ssa_verify — SSA well-formedness.  Returns SSAV_OK or a failure code.
# =======================================================================
SSAV_OK: uint32 = 0
SSAV_NO_TERM: uint32 = 1          # block has no terminator
SSAV_TERM_NOT_LAST: uint32 = 2   # a terminator is not the last value in its block
SSAV_MID_TERM: uint32 = 3        # a non-last value is a terminator
SSAV_USE_NOT_DOM: uint32 = 4     # a use is not dominated by its def
SSAV_PHI_PRED_MISMATCH: uint32 = 5  # phi operand count != predecessor count
SSAV_PHI_NOT_HEAD: uint32 = 6    # phi not at block head
SSAV_PHI_BAD_PRED: uint32 = 7    # phi operand's pred is not a predecessor
SSAV_BAD_EDGE: uint32 = 8        # edge endpoint does not exist
SSAV_NO_DEF: uint32 = 9          # a use references an undefined value id

# deliberate-break switch (mirrors ir_castcall_break_flag / lr_holes_break):
# armed by --ssa-break, corrupts one phi's operand count so the verifier MUST
# catch it — proving the verifier actually guards soundness.
ssa_break_flag: uint32 = 0


def ssa_set_break(v: uint32):
    ssa_break_flag = v


# Corrupt the IR when armed: drop one operand from the first phi found, so its
# operand count no longer matches its predecessor count.  If no phi exists, drop
# a block's terminator instead.  Called after a successful build in the demo.
def ssa_break_apply():
    if ssa_break_flag == 0:
        return
    v: uint32 = 1
    while v < sv_count:
        if sv_op[v] == SVO_PHI and sv_arg_head[v] != 0:
            sv_arg_head[v] = arg_next[sv_arg_head[v]]   # unlink one operand
            sv_argn[v] = sv_argn[v] - 1
            return
        v = v + 1
    # no phi: corrupt a terminator (clear the entry block's terminator record).
    if sb_entry != 0:
        sb_term[sb_entry] = 0
        sb_last_val[sb_entry] = 0


# Is value id `v` a real, defined value?
def ssa_val_defined(v: uint32) -> uint32:
    if v == 0:
        return 0
    if v >= sv_count:
        return 0
    return 1


# Check that operand value `use` (used at position `pos` in block `ub`) is
# dominated by its definition.  Returns 1 if OK.
def ssa_check_use_dom(use: uint32, ub: uint32, pos: uint32) -> uint32:
    if ssa_val_defined(use) == 0:
        return 0
    db: uint32 = sv_block[use]
    if db == ub:
        return sv_pos[use] < pos           # def before use in the same block
    return ssa_dominates(db, ub)


def ssa_verify() -> uint32:
    ssa_build_domtree()
    # 1. every block has exactly one terminator, last in its list.
    b: uint32 = 1
    while b < sb_count:
        # skip unreachable blocks (not in RPO) — they carry no obligations.
        if sb_visited[b] != 0:
            last: uint32 = sb_last_val[b]
            if last == 0 or ssa_is_terminator(sv_op[last]) == 0:
                ssa_stat_fail_code = SSAV_NO_TERM
                return SSAV_NO_TERM
            # no terminator may appear before the last value.
            cur: uint32 = sb_first_val[b]
            while cur != 0:
                if cur != last and ssa_is_terminator(sv_op[cur]) != 0:
                    ssa_stat_fail_code = SSAV_MID_TERM
                    return SSAV_MID_TERM
                cur = sv_next[cur]
        b = b + 1

    # 2. per-value checks: phi placement/operands + use dominance.
    b = 1
    while b < sb_count:
        if sb_visited[b] != 0:
            first: uint32 = sb_first_val[b]
            seen_nonphi: uint32 = 0
            cur2: uint32 = first
            while cur2 != 0:
                op: uint32 = sv_op[cur2]
                if op == SVO_PHI:
                    if seen_nonphi != 0:
                        ssa_stat_fail_code = SSAV_PHI_NOT_HEAD
                        return SSAV_PHI_NOT_HEAD
                    rc: uint32 = ssa_verify_phi(cur2, b)
                    if rc != SSAV_OK:
                        ssa_stat_fail_code = rc
                        return rc
                else:
                    seen_nonphi = 1
                    rc2: uint32 = ssa_verify_uses(cur2, b)
                    if rc2 != SSAV_OK:
                        ssa_stat_fail_code = rc2
                        return rc2
                cur2 = sv_next[cur2]
        b = b + 1
    ssa_stat_fail_code = SSAV_OK
    return SSAV_OK


def ssa_is_terminator(op: uint32) -> uint32:
    if op == SVO_BR or op == SVO_CONDBR or op == SVO_RET:
        return 1
    return 0


# Verify a phi: exactly one operand per predecessor, each operand's value
# dominates its incoming predecessor's terminator, each pred is a real pred.
def ssa_verify_phi(phi: uint32, bb: uint32) -> uint32:
    if sv_argn[phi] != sb_npred[bb]:
        return SSAV_PHI_PRED_MISMATCH
    node: uint32 = sv_arg_head[phi]
    while node != 0:
        p: uint32 = arg_pred[node]
        v: uint32 = arg_val[node]
        if ssa_block_is_pred(p, bb) == 0:
            return SSAV_PHI_BAD_PRED
        if ssa_val_defined(v) == 0:
            return SSAV_NO_DEF
        # incoming value must be available at the end of pred p.
        vb: uint32 = sv_block[v]
        if vb != p and ssa_dominates(vb, p) == 0:
            return SSAV_USE_NOT_DOM
        node = arg_next[node]
    return SSAV_OK


def ssa_block_is_pred(p: uint32, bb: uint32) -> uint32:
    node: uint32 = sb_pred_head[bb]
    while node != 0:
        if pl_bid[node] == p:
            return 1
        node = pl_next[node]
    return 0


# Verify the operand uses of a non-phi value are dominated by their defs.
def ssa_verify_uses(v: uint32, bb: uint32) -> uint32:
    op: uint32 = sv_op[v]
    pos: uint32 = sv_pos[v]
    # SVO_BR/SVO_CONDBR carry block ids in sv_a/sv_b/sv_c that are NOT values.
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_FCMP or op == SVO_GEP or op == SVO_STORE:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        if ssa_check_use_dom(sv_b[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT or op == SVO_LOAD:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_TRUNC or op == SVO_ZEXT or op == SVO_SEXT or op == SVO_BITCAST or op == SVO_I2F or op == SVO_F2I:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_CONDBR:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_RET:
        if sv_a[v] != 0:
            if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
                return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_CALL:
        node: uint32 = sv_arg_head[v]
        while node != 0:
            if ssa_check_use_dom(arg_val[node], bb, pos) == 0:
                return SSAV_USE_NOT_DOM
            node = arg_next[node]
        return SSAV_OK
    # const/param/undef/globaladdr/percpu/alloca: no value operands.
    return SSAV_OK


# =======================================================================
# program-level driver lane (the --dump-ssa / ADDER_OPT2 analysis pass).
# Builds + verifies SSA for every function; accumulates stats; NEVER emits
# code and NEVER mutates the AST, so it cannot perturb codegen output.
# =======================================================================
def ssa_stats_reset():
    ssa_stat_funcs = 0
    ssa_stat_accepted = 0
    ssa_stat_fallback = 0
    ssa_stat_verify_ok = 0
    ssa_stat_verify_fail = 0
    ssa_stat_values = 0
    ssa_stat_blocks = 0
    ssa_stat_phis = 0
    ssa_stat_fail_code = 0


# Count phis in the current function (post-build).
def ssa_count_phis() -> uint32:
    n: uint32 = 0
    v: uint32 = 1
    while v < sv_count:
        if sv_op[v] == SVO_PHI:
            n = n + 1
        v = v + 1
    return n


# Build+verify SSA for one function.  Returns 1 if accepted+verified, 0 if it
# fell back (escape hatch) or failed verification.
def ssa_process_function(fn: uint32) -> uint32:
    ssa_stat_funcs = ssa_stat_funcs + 1
    entry: uint32 = ssa_build_function(fn)
    if entry == 0 or ssa_bail != 0:
        ssa_stat_fallback = ssa_stat_fallback + 1
        return 0
    ssa_stat_accepted = ssa_stat_accepted + 1
    ssa_stat_values = ssa_stat_values + (sv_count - 1)
    ssa_stat_blocks = ssa_stat_blocks + (sb_count - 1)
    ssa_stat_phis = ssa_stat_phis + ssa_count_phis()
    ssa_break_apply()                     # inert unless --ssa-break armed
    rc: uint32 = ssa_verify()
    if rc == SSAV_OK:
        ssa_stat_verify_ok = ssa_stat_verify_ok + 1
        return 1
    ssa_stat_verify_fail = ssa_stat_verify_fail + 1
    return 0


# Walk the program's ND_FUNCTION decl chain (ND_PROGRAM: b = decl chain head).
def ssa_run_program(prog: uint32):
    ssa_stats_reset()
    if prog == 0:
        return
    ssa_prog_decls = nd_b[prog]
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            ssa_process_function(cur)
        cur = nd_next[cur]


# Parse ADDER_OPT2 from the process environment (mirrors opt_parse_disable_env).
# ADDER_OPT2=1 (or any non-empty value) arms ssa_enabled.  Unset => stays off =>
# byte-identical default path.
def ssa_str_prefix_len(e: Ptr[uint8], pfx: Ptr[uint8]) -> uint32:
    j: uint32 = 0
    while pfx[j] != 0:
        if e[j] != pfx[j]:
            return 0
        j = j + 1
    return j


def ssa_parse_env(argc: int32, argv: Ptr[uint64]):
    ei: uint32 = cast[uint32](argc) + 1
    while argv[ei] != 0:
        e: Ptr[uint8] = cast[Ptr[uint8]](argv[ei])
        klen: uint32 = ssa_str_prefix_len(e, "ADDER_OPT2=")
        if klen != 0:
            # any non-empty value past the '=' arms the gate.
            if e[klen] != 0:
                ssa_enabled = 1
        ei = ei + 1

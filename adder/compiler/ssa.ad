# =======================================================================
# 2.2  Value / instruction model — opcodes (SVO_*), the LLVM subset.
# =======================================================================
SVO_NULL: uint32 = 0
SVO_CONST: uint32 = 1        # sv_imm = 64-bit int/bool/char value
SVO_FCONST: uint32 = 2       # sv_imm = float bit pattern (reserved; Ph1 bails floats)
SVO_UNDEF: uint32 = 3
SVO_PARAM: uint32 = 4        # sv_aux = parameter index (entry-block value)
SVO_BINOP: uint32 = 5        # sv_aux = BINOP_* (arith/bitwise/shift), sv_a/sv_b operands
SVO_NEG: uint32 = 6          # sv_a operand
SVO_NOT: uint32 = 7          # logical not, sv_a operand
SVO_BITNOT: uint32 = 8       # ~x, sv_a operand
SVO_ICMP: uint32 = 9         # sv_aux = BINOP_* compare predicate, sv_a/sv_b operands
SVO_FCMP: uint32 = 10        # reserved
SVO_TRUNC: uint32 = 11       # reserved conversions (Ph1 bails casts)
SVO_ZEXT: uint32 = 12
SVO_SEXT: uint32 = 13
SVO_BITCAST: uint32 = 14
SVO_I2F: uint32 = 15
SVO_F2I: uint32 = 16
SVO_ALLOCA: uint32 = 17      # reserved: address-taken/aggregate local slot
SVO_LOAD: uint32 = 18        # reserved: sv_a = address value, sv_aux = size
SVO_STORE: uint32 = 19       # reserved: sv_a = address, sv_b = value
SVO_GEP: uint32 = 20         # reserved: sv_a = base, sv_b = index, sv_aux = scale
SVO_BR: uint32 = 21          # sv_a = target bid (terminator)
SVO_CONDBR: uint32 = 22      # sv_a = cond vid, sv_b = then bid, sv_c = else bid
SVO_RET: uint32 = 23         # sv_a = value vid (0 = void) (terminator)
SVO_PHI: uint32 = 24         # operands in use-list (pred bid, incoming vid) pairs
SVO_CALL: uint32 = 25        # direct call; sv_ast = call node; args in use-list
SVO_SYSCALL: uint32 = 26     # reserved
SVO_GLOBALADDR: uint32 = 27  # reserved: RIP-relative symbol in sv_imm
SVO_PERCPU: uint32 = 28      # first-class %gs-relative op (sv_imm = offset)
# ----- float ops (LLVM path only; gated behind ssa_mem_model != 0) ------
# Reuse SVO_FCONST(2)/SVO_FCMP(10)/SVO_I2F(15)/SVO_F2I(16) above; add the
# float<->float width conversions + float negate.  Float ARITHMETIC reuses
# SVO_BINOP with a float sv_type (emission keys the fadd/fsub/... mnemonic off
# the result type), so no separate float-binop opcode is needed.
SVO_FPEXT: uint32 = 29       # f32 -> f64  (sv_a operand, sv_type = dest)
SVO_FPTRUNC: uint32 = 30     # f64 -> f32  (sv_a operand, sv_type = dest)
SVO_FNEG: uint32 = 31        # -x for a float (sv_a operand, sv_type = operand)
# ----- inline asm passthrough (LLVM path only; gated behind ssa_mem_model) ---
# `asm_volatile("<text>")` — a ZERO-OPERAND inline-asm statement.  sv_ast = the
# ND_CALL node (its single string-literal arg carries the verbatim asm text).
# Emitted as `call void asm sideeffect "<text>", "<clobbers>"()`.  Never
# produces a value (statement position only); the native path is UNCHANGED
# (codegen.ad lowers asm_volatile to bytes directly — this opcode is never
# built when ssa_mem_model == 0).
SVO_INLINEASM: uint32 = 32

# ----- function symbol address (LLVM path only; gated behind ssa_mem_model) ---
# `&function` or a bare function NAME used as an rvalue (function-to-pointer
# decay in an argument: `register_hook(the_fn)`).  sv_ast = the ND_IDENT naming
# the function.  Emitted as `%vN = ptrtoint ptr @name to i64` — the function
# symbol's address as an i64.  The referenced function is DECLARED (if not
# defined in-unit) so llvm-as resolves `@name`.  Never built when
# ssa_mem_model == 0 (the native path lowers `&function` in codegen.ad).
SVO_FUNCADDR: uint32 = 33

# Type ids (2.4) — small interned set.  Signedness rides bit 8 (0x100).
SVT_VOID: uint32 = 0
SVT_I1: uint32 = 1
SVT_I8: uint32 = 2
SVT_I16: uint32 = 3
SVT_I32: uint32 = 4
SVT_I64: uint32 = 5
SVT_F32: uint32 = 6
SVT_F64: uint32 = 7
SVT_PTR: uint32 = 8

# Arena sizes (fixed; overflow => escape-hatch bail).
SSA_VAL_MAX: uint32 = 65536
SSA_BB_MAX: uint32 = 1024
SSA_ARG_MAX: uint32 = 131072

# ----- value arena (index = vid; 0 = null/undef) -----------------------
sv_op: Array[65536, uint32]
sv_type: Array[65536, uint32]
sv_a: Array[65536, uint32]
sv_b: Array[65536, uint32]
sv_c: Array[65536, uint32]
sv_aux: Array[65536, uint32]
sv_imm: Array[65536, uint64]
sv_block: Array[65536, uint32]
sv_ast: Array[65536, uint32]
sv_next: Array[65536, uint32]      # intrusive per-block list (forward)
sv_prev: Array[65536, uint32]      # intrusive per-block list (backward)
sv_pos: Array[65536, uint32]       # index within block (for intra-block dominance)
sv_arg_head: Array[65536, uint32]  # head of use-list (phi/call operands), 0 = none
sv_argn: Array[65536, uint32]      # operand count
# %gs-relative percpu marker for SVO_LOAD/SVO_STORE (LLVM path only): 1 => the
# access is a per-CPU slot whose pointer must be emitted in LLVM address space
# 256 (`iW addrspace(256)*`), which clang lowers to a `%gs:`-segment-prefixed
# load/store — NOT the absolute RIP-relative access a normal global uses.  Set
# ONLY under ssa_mem_model != 0 (kernel LLVM lane); inert (0) for every other
# value and on the native path (no percpu SVO_LOAD/STORE is ever built there),
# so codegen.ad byte output is unchanged.  Read only by the LLVM emitter; no
# optimizer pass inspects it (the LLVM lane runs no SSA passes).
sv_as256: Array[65536, uint32]

sv_count: uint32 = 1               # vid 0 reserved as null
sv_overflow: uint32 = 0

# ----- use-list side arena (phi/call operands; 0 = null) ---------------
arg_val: Array[131072, uint32]     # operand value vid (or call-arg value)
arg_pred: Array[131072, uint32]    # phi: the predecessor bid this operand flows from
arg_next: Array[131072, uint32]    # next operand (linked list; order-independent)
arg_count: uint32 = 1

# ----- block arena (index = bid; 0 = null) -----------------------------
sb_first_val: Array[1024, uint32]
sb_last_val: Array[1024, uint32]
sb_term: Array[1024, uint32]       # terminator opcode (redundant w/ last, for validate)
sb_nval: Array[1024, uint32]       # value count (position counter)
sb_succ0: Array[1024, uint32]
sb_succ1: Array[1024, uint32]
sb_nsucc: Array[1024, uint32]
sb_pred_head: Array[1024, uint32]  # head of predecessor list (side arena)
sb_npred: Array[1024, uint32]
sb_sealed: Array[1024, uint32]     # Braun: all preds known
sb_idom: Array[1024, uint32]       # immediate dominator bid
sb_ponum: Array[1024, uint32]      # postorder number (higher = closer to entry)
sb_visited: Array[1024, uint32]

# predecessor list side arena (parallel to blocks): each node = (pred bid, next)
pl_bid: Array[8192, uint32]
pl_next: Array[8192, uint32]
pl_count: uint32 = 1

sb_count: uint32 = 1               # bid 0 reserved as null
sb_entry: uint32 = 0

# RPO order (list of bids, reverse postorder).
sb_rpo: Array[1024, uint32]
sb_rpo_n: uint32 = 0
# postorder scratch list
sb_po: Array[1024, uint32]
sb_po_n: uint32 = 0

# ----- Braun current-definition + incomplete-phi maps ------------------
# Indexed [block * NM_MAX + var]; 0 = undefined (vid 0 is null so unambiguous).
ssa_curdef: Array[262144, uint32]      # SSA_BB_MAX * NM_MAX
ssa_incphi: Array[262144, uint32]      # incomplete phis awaiting seal

# ----- known-locals set (promotable scalars declared as param/var) -----
ssa_islocal: Array[256, uint32]        # 1 => name id is a known promotable local
# Per-local signedness tristate (0 unknown / 1 unsigned / 2 signed), from the
# declared type — mirrors codegen's loc_is_signed / type_signedness so div/mod/
# shr/ordered-compare instruction selection matches the legacy backend exactly.
ssa_local_sgn: Array[256, uint32]
# Per-local declared byte width (1/2/4/8).  A promotable (never-address-taken)
# narrow local is truncated to this width on every write, exactly reproducing the
# legacy sized-store + sign/zero-extended-load value (the slot is never aliased,
# so no upper-byte observation can distinguish the two).
ssa_local_size: Array[256, uint32]

# ----- LOCAL MEMORY subset (address-taken scalars, local arrays, deref) -
# Gated ON only for the LLVM backend (llvm_emit_program sets ssa_mem_model=1);
# the native --opt path (ssa_emit_program) and the analysis lane leave it 0, so
# their bail set — and therefore their byte output — is UNCHANGED.  A local whose
# address is taken (`&x`), a local `Array[N,T]`, or a pointer deref is modeled as
# a stack slot (SVO_ALLOCA) + SVO_LOAD/SVO_STORE through computed byte addresses
# (base + idx*elem reusing the same pure BINOP arithmetic the global-array subset
# uses — no new SVO_GEP op is required).
ssa_mem_model: uint32 = 0               # 1 => model local memory (LLVM path)
ssa_ismem: Array[256, uint32]           # 1 => name id is a memory-modeled local
ssa_mem_addr: Array[256, uint32]        # its SVO_ALLOCA vid (the slot's i64 address)
ssa_mem_esz: Array[256, uint32]         # scalar/element byte width (1/2/4/8)
ssa_mem_esgn: Array[256, uint32]        # scalar/element signedness tristate
ssa_mem_isarr: Array[256, uint32]       # 1 => array local (indexed access only)
# Pointee width/signedness for a pointer local/param (0 width => not derefable in
# subset).  Independent of ssa_ismem: a promotable pointer scalar still records
# these so `*p` can pick the load width.
ssa_ptr_esz: Array[256, uint32]
ssa_ptr_esgn: Array[256, uint32]

# Struct/record typing for a local/param, for member access `obj.field`.
# ssa_local_struct[nid] = struct-table index (+1), 0 = not a struct/struct-ptr.
# ssa_local_struct_is_ptr[nid] = 1 => the local is a Ptr[Struct] (its VALUE is
# the struct base address); 0 => an in-place struct value (its ALLOCA slot
# address is the base). LLVM path only (recorded under ssa_mem_model != 0), so
# the native subset is unchanged.
ssa_local_struct: Array[256, uint32]
ssa_local_struct_is_ptr: Array[256, uint32]

# ----- FLOAT locals/params (LLVM path only) ---------------------------
# Per-local float width (0 = not a float, 4 = float32, 8 = float64).  A
# promotable float scalar is modeled as an ordinary SSA value carrying an
# SVT_F32/SVT_F64 sv_type (LLVM's mem2reg needs nothing extra); this table lets
# the Braun phi-creation stamp the right float type on merge phis, and the param
# setup stamp float params.  Set ONLY on the LLVM path (ssa_mem_model != 0); the
# native --opt path keeps bailing every float function, so it stays 0 there and
# the byte output is unchanged.
ssa_local_fw: Array[256, uint32]

# ----- loop context (break/continue targets) --------------------------
SSA_LOOP_MAX: uint32 = 64
ssa_brk_bb: Array[64, uint32]
ssa_cont_bb: Array[64, uint32]
ssa_loop_depth: uint32 = 0

# ----- per-function bail / stats --------------------------------------
ssa_bail: uint32 = 0                    # set on any non-subset construct
ssa_bail_reason: uint32 = 0             # diagnostic code (SBR_*)

SBR_OK: uint32 = 0
SBR_OVERFLOW: uint32 = 1
SBR_NONSUBSET_EXPR: uint32 = 2
SBR_NONSUBSET_STMT: uint32 = 3
SBR_NONLOCAL: uint32 = 4
SBR_NONPROMOTABLE: uint32 = 5
SBR_LOOPDEPTH: uint32 = 6
SBR_CFG: uint32 = 7
SBR_FLOAT: uint32 = 8
SBR_FORLOOP: uint32 = 9
SBR_SHORTCIRCUIT: uint32 = 10
SBR_MEMORY: uint32 = 11
SBR_MANYARGS: uint32 = 12
SBR_CALL: uint32 = 13
SBR_NREASONS: uint32 = 16
ssa_bail_hist: Array[16, uint32]

# aggregate program stats (driver lane)
ssa_stat_funcs: uint32 = 0
ssa_stat_accepted: uint32 = 0
ssa_stat_fallback: uint32 = 0
ssa_stat_verify_ok: uint32 = 0
ssa_stat_verify_fail: uint32 = 0
ssa_stat_values: uint32 = 0
ssa_stat_blocks: uint32 = 0
ssa_stat_phis: uint32 = 0
ssa_stat_fail_code: uint32 = 0    # last verifier failure code

# gating flag (2.6 / 6.1)
ssa_enabled: uint32 = 0

# Program decl chain head (nd_b of ND_PROGRAM), stashed per run so the callee-
# return-type gate (Phase 1b) can resolve a direct call's return width.
ssa_prog_decls: uint32 = 0

# CURRENT block for expression lowering.  Most expressions materialize their
# value in the block they started in, but a short-circuit `and`/`or` splits the
# CFG and moves control into a fresh join block.  Because ssa_lower_expr returns
# only a value id, the "where control now is" fact is threaded through this
# module global instead: EVERY caller sets ssa_cur_bb before lowering an
# expression and re-reads it (bb = ssa_cur_bb) afterward, and ssa_lower_expr
# uses ssa_cur_bb — never its stale `bb` argument — for all appends, variable
# reads, and recursive lowering.  For straight-line expressions ssa_cur_bb never
# moves, so this is byte-inert vs the pre-short-circuit behaviour.
ssa_cur_bb: uint32 = 0


def ssa_enable():
    ssa_enabled = 1


# =======================================================================
# Phase-1b emittability gate (§2.4 / §3.3): the trivial all-memory round-trip
# keeps every SSA value in a 64-bit stack slot and never truncates, so a value
# is only correct if its low 64 bits match the source regardless of declared
# signedness/width.  A scalar is emittable iff it is a full-width (8-byte),
# non-float integer.  Narrower locals/params would need store-truncation the
# mem2reg value model does not carry; floats need SSE.  Both bail to the legacy
# path (escape hatch).
# =======================================================================
def ssa_type_scalar_ok(tnode: uint32) -> uint32:
    if type_float_width(tnode) != 0:
        return 0
    if prim_type_size(tnode) != 8:
        return 0
    return 1


# ----- float type helpers (LLVM path) ---------------------------------
# Map a float byte width (4/8) to its SSA type id; a non-float width -> SVT_I64.
def ssa_fw_svt(fw: uint32) -> uint32:
    if fw == 4:
        return SVT_F32
    if fw == 8:
        return SVT_F64
    return SVT_I64


# Is an SSA type id a float (f32/f64)?
def ssa_is_float_svt(t: uint32) -> uint32:
    if t == SVT_F32 or t == SVT_F64:
        return 1
    return 0


# Float byte width (0/4/8) of an already-lowered SSA value, read off its type.
def ssa_val_fw(v: uint32) -> uint32:
    if v == 0:
        return 0
    t: uint32 = sv_type[v]
    if t == SVT_F32:
        return 4
    if t == SVT_F64:
        return 8
    return 0


# Byte-compare two interned name spans (both index the lexer strbuf).
def ssa_name_bytes_eq(off1: uint32, len1: uint32, off2: uint32, len2: uint32) -> uint32:
    if len1 != len2:
        return 0
    i: uint32 = 0
    while i < len1:
        if strbuf[off1 + i] != strbuf[off2 + i]:
            return 0
        i = i + 1
    return 1


# Callee-return-type gate: a direct call's result is only emittable if the
# callee is an in-unit function whose declared return type is a full-width
# non-float integer (so the returned %rax is a correct full-64-bit value).  An
# extern / unknown callee, or one returning a narrow/float/aggregate type, is
# NOT resolvable to a safe width here and bails the function.  Returns 1 iff OK.
def ssa_callee_rettype_ok(off: uint32, len_: uint32) -> uint32:
    cur: uint32 = ssa_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            if ssa_name_bytes_eq(nd_name_off[cur], nd_name_len[cur], off, len_) != 0:
                return ssa_type_scalar_ok(nd_b[cur])
        cur = nd_next[cur]
    return 0


# 1 if `off/len` names a FUNCTION in the compiled closure (an ND_FUNCTION decl —
# in-unit definition OR extern declaration), else 0.  Used by the LLVM path to
# recognise `&function` / a bare function-name-as-value (function-to-pointer
# decay), which the native codegen.ad handles separately.
def ssa_is_function(off: uint32, len_: uint32) -> uint32:
    cur: uint32 = ssa_prog_decls
    while cur != 0:
        # ND_FUNCTION = in-unit definition; ND_EXTERN = `extern def` (an assembly
        # / other-TU function symbol, e.g. the irq_stub_* IDT stubs).  Both are
        # callable function symbols whose address is a valid `ptr @name`.
        if nd_kind[cur] == ND_FUNCTION or nd_kind[cur] == ND_EXTERN:
            if ssa_name_bytes_eq(nd_name_off[cur], nd_name_len[cur], off, len_) != 0:
                return 1
        cur = nd_next[cur]
    return 0


# Callee-return signedness tristate (0 unknown / 1 unsigned / 2 signed): the
# signedness the legacy expr_signedness assigns to a direct call is the callee's
# declared return type (type_signedness of nd_b[decl]).  An unknown callee -> 0.
# Callee return-type FLOAT width (0/4/8) — the float width of an in-unit
# function's declared return type, so a call whose result feeds float arithmetic
# is typed float (LLVM path).  Unknown callee -> 0.
def ssa_callee_ret_fw(off: uint32, len_: uint32) -> uint32:
    cur: uint32 = ssa_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            if ssa_name_bytes_eq(nd_name_off[cur], nd_name_len[cur], off, len_) != 0:
                return type_float_width(nd_b[cur])
        cur = nd_next[cur]
    return 0


def ssa_callee_rettype_sgn(off: uint32, len_: uint32) -> uint32:
    cur: uint32 = ssa_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            if ssa_name_bytes_eq(nd_name_off[cur], nd_name_len[cur], off, len_) != 0:
                return type_signedness(nd_b[cur])
        cur = nd_next[cur]
    return 0


# Return-type NODE of an in-unit function named by `off/len`, or 0 if unknown.
# Used to type a call USED AS AN INDEX BASE (`foo()[i]`): the element width comes
# from the callee's declared Ptr[T] pointee.
def ssa_callee_ret_node(off: uint32, len_: uint32) -> uint32:
    cur: uint32 = ssa_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            if ssa_name_bytes_eq(nd_name_off[cur], nd_name_len[cur], off, len_) != 0:
                return nd_b[cur]
        cur = nd_next[cur]
    return 0


# SHALLOW expression signedness (0/1/2), mirroring codegen.ad's expr_signedness
# restricted to the Phase-1 subset: ND_IDENT -> the local's declared signedness
# (non-locals bail before this is reached); ND_CALL -> the callee's return-type
# signedness; everything else (literals, binops, unary) -> 0 (unknown).  This is
# the tristate the legacy ordered-compare setcc selection consumes per operand.
def ssa_expr_sgn(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[node], nd_name_len[node])
        if nid < NM_MAX and ssa_islocal[nid] != 0:
            return ssa_local_sgn[nid]
        # Global identifier: mirror codegen expr_signedness (array decays to an
        # unsigned address; scalar global uses its declared full-type signedness,
        # unknown -> unsigned default).
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            if glob_elem_size[gi - 1] != 0:
                return 1
            gs: uint32 = glob_signedness[gi - 1]
            if gs != 0:
                return gs
            return 1
        return 0
    if k == ND_CALL:
        callee: uint32 = nd_a[node]
        if callee != 0 and nd_kind[callee] == ND_IDENT:
            return ssa_callee_rettype_sgn(nd_name_off[callee], nd_name_len[callee])
        return 0
    if k == ND_INDEX:
        # arr[i] : the element type's signedness (mirrors codegen expr_signedness
        # -> index_elem_signed for the 1-D scalar-element global-array case we
        # actually lower; any other base is unknown/unlowered -> 0).
        ibase: uint32 = nd_a[node]
        if ibase != 0 and nd_kind[ibase] == ND_IDENT:
            ibnid: uint32 = nm_intern(nd_name_off[ibase], nd_name_len[ibase])
            if ibnid < NM_MAX and ssa_islocal[ibnid] != 0 and ssa_ismem[ibnid] != 0 and ssa_mem_isarr[ibnid] != 0:
                return ssa_mem_esgn[ibnid]      # local array element signedness
            igi: uint32 = ssa_global_array_1d(nd_name_off[ibase], nd_name_len[ibase])
            if igi != 0:
                return ssa_array_elem_sgn(igi)
        return 0
    if k == ND_UNARY:
        # `*p` : the pointee signedness (0 if not a derefable pointer ident).
        if nd_aux[node] == UNOP_DEREF and nd_kind[nd_a[node]] == ND_IDENT:
            return ssa_deref_esgn(nd_a[node])
        return 0
    return 0


# STRUCTURAL value signedness (0/1/2), mirroring codegen.ad's shr_value_signedness
# restricted to the Phase-1 subset: sees THROUGH an integer ND_BINARY (a shift
# follows its LEFT operand; an arithmetic/bitwise binop is unsigned if EITHER
# operand is unsigned, else signed if EITHER is signed, else unknown); a compare
# / logical binop yields a boolean -> unknown; every other node defers to the
# shallow ssa_expr_sgn.  Drives the div/mod and shift instruction selection.
def ssa_shr_value_sgn(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] == ND_BINARY:
        bop: uint32 = nd_aux[node]
        if bop == BINOP_SHL or bop == BINOP_SHR:
            return ssa_shr_value_sgn(nd_a[node])
        if bop == BINOP_ADD or bop == BINOP_SUB or bop == BINOP_MUL or bop == BINOP_BIT_AND or bop == BINOP_BIT_OR or bop == BINOP_BIT_XOR or bop == BINOP_DIV or bop == BINOP_IDIV or bop == BINOP_MOD:
            lu: uint32 = ssa_shr_value_sgn(nd_a[node])
            ru: uint32 = ssa_shr_value_sgn(nd_b[node])
            if lu == 1 or ru == 1:
                return 1
            if lu == 2 or ru == 2:
                return 2
            return 0
        return 0
    return ssa_expr_sgn(node)


def ssa_is_enabled() -> uint32:
    return ssa_enabled


# =======================================================================
# arena allocators
# =======================================================================
def ssa_reset():
    sv_count = 1
    arg_count = 1
    sb_count = 1
    pl_count = 1
    sb_entry = 0
    ssa_loop_depth = 0
    sv_overflow = 0
    ssa_bail = 0
    ssa_bail_reason = SBR_OK
    sb_rpo_n = 0
    sb_po_n = 0


def sv_new(op: uint32) -> uint32:
    if sv_count >= SSA_VAL_MAX:
        sv_overflow = 1
        ssa_set_bail(SBR_OVERFLOW)
        return 0
    id: uint32 = sv_count
    sv_count = sv_count + 1
    sv_op[id] = op
    sv_type[id] = SVT_I64
    sv_a[id] = 0
    sv_b[id] = 0
    sv_c[id] = 0
    sv_aux[id] = 0
    sv_imm[id] = 0
    sv_block[id] = 0
    sv_ast[id] = 0
    sv_next[id] = 0
    sv_prev[id] = 0
    sv_pos[id] = 0
    sv_arg_head[id] = 0
    sv_argn[id] = 0
    sv_as256[id] = 0
    return id


def ssa_set_bail(reason: uint32):
    if ssa_bail == 0:
        ssa_bail = 1
        ssa_bail_reason = reason
        if reason < SBR_NREASONS:
            ssa_bail_hist[reason] = ssa_bail_hist[reason] + 1



def bb_new_ssa() -> uint32:
    if sb_count >= SSA_BB_MAX:
        ssa_set_bail(SBR_OVERFLOW)
        return 0
    id: uint32 = sb_count
    sb_count = sb_count + 1
    sb_first_val[id] = 0
    sb_last_val[id] = 0
    sb_term[id] = 0
    sb_nval[id] = 0
    sb_succ0[id] = 0
    sb_succ1[id] = 0
    sb_nsucc[id] = 0
    sb_pred_head[id] = 0
    sb_npred[id] = 0
    sb_sealed[id] = 0
    sb_idom[id] = 0
    sb_ponum[id] = 0
    sb_visited[id] = 0
    # Zero this block's Braun current-def / incomplete-phi row so no stale
    # mapping from a previously-built function leaks in (the maps are indexed
    # [block * NM_MAX + var] and are NOT globally cleared per function).
    base: uint32 = id * NM_MAX
    j: uint32 = 0
    while j < NM_MAX:
        ssa_curdef[base + j] = 0
        ssa_incphi[base + j] = 0
        j = j + 1
    return id


# Append value `v` to the end of block `bb`'s intrusive list.
def bb_append(bb: uint32, v: uint32):
    if bb == 0 or v == 0:
        return
    sv_block[v] = bb
    sv_pos[v] = sb_nval[bb]
    sb_nval[bb] = sb_nval[bb] + 1
    if sb_first_val[bb] == 0:
        sb_first_val[bb] = v
        sb_last_val[bb] = v
        sv_prev[v] = 0
        sv_next[v] = 0
        return
    last: uint32 = sb_last_val[bb]
    sv_next[last] = v
    sv_prev[v] = last
    sv_next[v] = 0
    sb_last_val[bb] = v


# Prepend value `v` to the head of block `bb` (phis go at block head).
def bb_prepend(bb: uint32, v: uint32):
    if bb == 0 or v == 0:
        return
    sv_block[v] = bb
    sb_nval[bb] = sb_nval[bb] + 1
    if sb_first_val[bb] == 0:
        sb_first_val[bb] = v
        sb_last_val[bb] = v
        sv_prev[v] = 0
        sv_next[v] = 0
        sv_pos[v] = 0
        ssa_renumber_block(bb)
        return
    first: uint32 = sb_first_val[bb]
    sv_prev[first] = v
    sv_next[v] = first
    sv_prev[v] = 0
    sb_first_val[bb] = v
    ssa_renumber_block(bb)


# Re-stamp sv_pos across a block (after a head insert) so positions stay dense.
def ssa_renumber_block(bb: uint32):
    p: uint32 = 0
    cur: uint32 = sb_first_val[bb]
    while cur != 0:
        sv_pos[cur] = p
        p = p + 1
        cur = sv_next[cur]


# Add an edge bb -> succ (records succ on bb, pushes bb onto succ's pred list).
def ssa_add_edge(bb: uint32, succ: uint32):
    if bb == 0 or succ == 0:
        return
    if sb_nsucc[bb] == 0:
        sb_succ0[bb] = succ
        sb_nsucc[bb] = 1
    elif sb_nsucc[bb] == 1:
        sb_succ1[bb] = succ
        sb_nsucc[bb] = 2
    # record predecessor
    if pl_count >= 8192:
        ssa_set_bail(SBR_OVERFLOW)
        return
    node: uint32 = pl_count
    pl_count = pl_count + 1
    pl_bid[node] = bb
    pl_next[node] = sb_pred_head[succ]
    sb_pred_head[succ] = node
    sb_npred[succ] = sb_npred[succ] + 1


# =======================================================================
# 3.1 / 3.2  Braun on-the-fly SSA construction + mem2reg.
# =======================================================================
def curdef_get(bb: uint32, var: uint32) -> uint32:
    return ssa_curdef[bb * NM_MAX + var]


def curdef_set(bb: uint32, var: uint32, v: uint32):
    ssa_curdef[bb * NM_MAX + var] = v


def incphi_get(bb: uint32, var: uint32) -> uint32:
    return ssa_incphi[bb * NM_MAX + var]


def incphi_set(bb: uint32, var: uint32, v: uint32):
    ssa_incphi[bb * NM_MAX + var] = v


# writeVariable(var, block, value)
def ssa_write_var(var: uint32, bb: uint32, v: uint32):
    curdef_set(bb, var, v)


# Append a (pred, val) operand onto phi `phi`.
def phi_add_operand(phi: uint32, pred: uint32, v: uint32):
    if arg_count >= SSA_ARG_MAX:
        ssa_set_bail(SBR_OVERFLOW)
        return
    a: uint32 = arg_count
    arg_count = arg_count + 1
    arg_val[a] = v
    arg_pred[a] = pred
    arg_next[a] = sv_arg_head[phi]
    sv_arg_head[phi] = a
    sv_argn[phi] = sv_argn[phi] + 1


# addPhiOperands: fill phi with one operand per predecessor of its block.
def ssa_add_phi_operands(var: uint32, phi: uint32):
    bb: uint32 = sv_block[phi]
    node: uint32 = sb_pred_head[bb]
    while node != 0:
        p: uint32 = pl_bid[node]
        v: uint32 = ssa_read_var(var, p)
        phi_add_operand(phi, p, v)
        node = pl_next[node]


# readVariableRecursive
def ssa_read_var_recursive(var: uint32, bb: uint32) -> uint32:
    if sb_sealed[bb] == 0:
        # incomplete CFG: place an operandless phi, fill it on seal.
        phi: uint32 = sv_new(SVO_PHI)
        if phi == 0:
            return 0
        if ssa_local_fw[var] != 0:
            sv_type[phi] = ssa_fw_svt(ssa_local_fw[var])   # float merge phi
        bb_prepend(bb, phi)
        incphi_set(bb, var, phi)
        ssa_write_var(var, bb, phi)
        return phi
    if sb_npred[bb] == 1:
        # single predecessor: no phi needed, forward the read.
        p: uint32 = pl_bid[sb_pred_head[bb]]
        val: uint32 = ssa_read_var(var, p)
        ssa_write_var(var, bb, val)
        return val
    # multiple predecessors: break potential cycles with a phi, then fill.
    phi2: uint32 = sv_new(SVO_PHI)
    if phi2 == 0:
        return 0
    if ssa_local_fw[var] != 0:
        sv_type[phi2] = ssa_fw_svt(ssa_local_fw[var])      # float merge phi
    bb_prepend(bb, phi2)
    ssa_write_var(var, bb, phi2)
    ssa_add_phi_operands(var, phi2)
    return phi2


# readVariable(var, block): current def, else recurse.
def ssa_read_var(var: uint32, bb: uint32) -> uint32:
    v: uint32 = curdef_get(bb, var)
    if v != 0:
        return v
    return ssa_read_var_recursive(var, bb)


# sealBlock: all predecessors are now known; fill deferred phis.
def ssa_seal_block(bb: uint32):
    var: uint32 = 0
    while var < nm_count:
        phi: uint32 = incphi_get(bb, var)
        if phi != 0:
            ssa_add_phi_operands(var, phi)
            incphi_set(bb, var, 0)
        var = var + 1
    sb_sealed[bb] = 1


# =======================================================================
# expression lowering: AST expr -> SSA value vid (0 on bail).
# =======================================================================
# Classify a binop as arithmetic (SVO_BINOP), compare (SVO_ICMP), or unsupported.
def ssa_binop_is_arith(op: uint32) -> uint32:
    if op == BINOP_ADD or op == BINOP_SUB or op == BINOP_MUL:
        return 1
    if op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_MOD:
        return 1
    if op == BINOP_BIT_OR or op == BINOP_BIT_AND or op == BINOP_BIT_XOR:
        return 1
    if op == BINOP_SHL or op == BINOP_SHR:
        return 1
    return 0


def ssa_binop_is_cmp(op: uint32) -> uint32:
    if op == BINOP_EQ or op == BINOP_NEQ:
        return 1
    if op == BINOP_LT or op == BINOP_LTE:
        return 1
    if op == BINOP_GT or op == BINOP_GTE:
        return 1
    return 0


# Promotability of a local name id: address never taken, slot never read directly
# (reuses cfg.ad's cl_build outputs — §2.5).
def ssa_name_promotable(nid: uint32) -> uint32:
    if nid >= NM_MAX:
        return 0
    if cl_set[nid] != 0:
        return 0
    if nm_slotread[nid] != 0:
        return 0
    return 1


# Resolve the setcc opcode byte for an integer compare `op`, applying the
# signed/unsigned override from operand tristates via codegen's rel_setcc — the
# exact selection the legacy backend makes (default signed setl/setle/setg/setge;
# unsigned setb/setbe/seta/setae when either operand is known-unsigned).
def ssa_cmp_setcc(op: uint32, l_sgn: uint32, r_sgn: uint32) -> uint32:
    if op == BINOP_EQ:
        return 0x94
    if op == BINOP_NEQ:
        return 0x95
    if op == BINOP_LT:
        return rel_setcc(0x9C, l_sgn, r_sgn)
    if op == BINOP_LTE:
        return rel_setcc(0x9E, l_sgn, r_sgn)
    if op == BINOP_GT:
        return rel_setcc(0x9F, l_sgn, r_sgn)
    # BINOP_GTE
    return rel_setcc(0x9D, l_sgn, r_sgn)


# Return the 1-based global index if `off/len` names an EMITTABLE scalar global
# (a non-array, non-percpu global whose value lives at a RIP-relative address and
# whose width is a machine load/store size), else 0.  Address-taken aggregate and
# percpu globals are NOT handled here (they bail via the normal path).
def ssa_scalar_global(off: uint32, len_: uint32) -> uint32:
    gi: uint32 = glob_lookup(off, len_)
    if gi == 0:
        return 0
    if glob_elem_size[gi - 1] != 0:
        return 0                              # array global (needs indexing)
    if glob_is_percpu[gi - 1] != 0:
        return 0                              # %gs-relative (kernel) -> defer
    return gi


# Emit an SVO_FUNCADDR value (address of the function named by ND_IDENT `node`)
# into `bb`.  LLVM path only (callers gate on ssa_mem_model != 0).  The emitter
# renders `ptrtoint ptr @name to i64` and declares the symbol if it is not
# defined in-unit.
def ssa_funcaddr(node: uint32, bb: uint32) -> uint32:
    a: uint32 = sv_new(SVO_FUNCADDR)
    if a == 0:
        return 0
    sv_ast[a] = node                          # ND_IDENT carrying the function name
    sv_type[a] = SVT_PTR
    bb_append(bb, a)
    return a


# Emit an SVO_GLOBALADDR value (RIP-relative lea of scalar global `gi`) into `bb`.
def ssa_globaladdr(gi: uint32, bb: uint32) -> uint32:
    a: uint32 = sv_new(SVO_GLOBALADDR)
    if a == 0:
        return 0
    sv_imm[a] = cast[uint64](glob_offset[gi - 1])
    sv_c[a] = glob_is_bss[gi - 1]
    sv_type[a] = SVT_PTR
    bb_append(bb, a)
    return a


# Emit a scalar-global LOAD (GLOBALADDR + SVO_LOAD) for global `gi` into `bb`.
def ssa_global_load(gi: uint32, bb: uint32) -> uint32:
    addr: uint32 = ssa_globaladdr(gi, bb)
    if addr == 0:
        return 0
    ld: uint32 = sv_new(SVO_LOAD)
    if ld == 0:
        return 0
    sv_a[ld] = addr
    sv_aux[ld] = glob_scalar_size[gi - 1]     # load width (1/2/4/8)
    sv_c[ld] = glob_is_signed[gi - 1]         # 1 => sized signed load (movsx)
    sv_ast[ld] = 0
    # FLOAT scalar global (LLVM path): a `double`/`float` global scalar read must
    # carry a float SSA type so downstream fmul/fadd typechecks and the emitter
    # lowers it as `load double`/`load float` through a double*/float* — not the
    # i64 integer load.  A scalar global's float width (4/8) is recorded in
    # glob_is_float (glob_type_node is populated for ARRAY globals only).
    # Stamped ONLY on the LLVM path (ssa_mem_model != 0); integer globals (fw==0)
    # are untouched, so the native codegen.ad / --opt byte output is UNCHANGED.
    if ssa_mem_model != 0:
        sfw: uint32 = glob_is_float[gi - 1]
        if sfw != 0:
            sv_type[ld] = ssa_fw_svt(sfw)
    bb_append(bb, ld)
    return ld


# Emit a scalar-global STORE (GLOBALADDR + SVO_STORE) of value `val` into `bb`.
def ssa_global_store(gi: uint32, val: uint32, bb: uint32):
    addr: uint32 = ssa_globaladdr(gi, bb)
    if addr == 0:
        return
    st: uint32 = sv_new(SVO_STORE)
    if st == 0:
        return
    sv_a[st] = addr
    sv_b[st] = val
    sv_aux[st] = glob_scalar_size[gi - 1]     # store width
    bb_append(bb, st)


# =======================================================================
# %gs-relative percpu scalar access (kernel LLVM lane; ssa_mem_model != 0)
# =======================================================================
# A `Percpu[T]` global lives per-CPU at `%gs:offset`, NOT at a linear RIP
# address (native codegen.ad emits `movq %gs:offset, %rax`; the percpu template
# offset is glob_offset, flagged by glob_is_percpu).  On the LLVM path clang
# models `%gs`-relative memory as address space 256, so a percpu scalar access
# is `inttoptr i64 <offset> to iW addrspace(256)*` + a load/store through that
# pointer — which clang lowers to the `%gs:`-prefixed instruction, reading the
# SAME per-CPU slot the native `%gs:offset` access does.
#
# The bare-load/store path here handles ONLY the machine-width SCALAR percpu
# slot (glob_elem_size == 0).  An aggregate percpu (`Percpu[Array/Struct]`,
# elem_size != 0) is NOT modeled: the callers leave it to BAIL (SBR_NONLOCAL /
# SBR_MEMORY) rather than emit a wrong absolute access — a bail is safe, a
# silent miscompile is not.

# Return the 1-based global index if `off/len` names a percpu SCALAR global
# (a machine-width `Percpu[T]` slot), else 0 (non-percpu, aggregate percpu, or
# unknown -> caller falls through / bails).  LLVM path only (sole callers gate
# on ssa_mem_model != 0); the native path never builds a percpu SVO_LOAD/STORE.
def ssa_percpu_scalar(off: uint32, len_: uint32) -> uint32:
    gi: uint32 = glob_lookup(off, len_)
    if gi == 0:
        return 0
    if glob_is_percpu[gi - 1] == 0:
        return 0                              # not %gs-relative
    if glob_elem_size[gi - 1] != 0:
        return 0                              # aggregate percpu -> defer (bail)
    return gi


# Emit a percpu scalar LOAD for `gi` into `bb`: an SVO_LOAD marked addrspace(256)
# whose address operand is the raw per-CPU template offset (a CONST, inlined as a
# literal by the emitter).  Width/signedness mirror the scalar-global load; the
# emitter switches on sv_as256 to produce `iW addrspace(256)*`.
def ssa_percpu_load(gi: uint32, bb: uint32) -> uint32:
    off: uint32 = ssa_const_in(bb, cast[uint64](glob_offset[gi - 1]))
    if off == 0:
        return 0
    ld: uint32 = sv_new(SVO_LOAD)
    if ld == 0:
        return 0
    sv_a[ld] = off
    sv_aux[ld] = glob_scalar_size[gi - 1]     # load width (1/2/4/8)
    sv_c[ld] = glob_is_signed[gi - 1]         # 1 => sized signed load (movsx)
    sv_ast[ld] = 0
    sv_as256[ld] = 1                          # %gs-relative (addrspace 256)
    bb_append(bb, ld)
    return ld


# Emit a percpu scalar STORE of `val` for `gi` into `bb`: an SVO_STORE marked
# addrspace(256) at the per-CPU template offset.
def ssa_percpu_store(gi: uint32, val: uint32, bb: uint32):
    off: uint32 = ssa_const_in(bb, cast[uint64](glob_offset[gi - 1]))
    if off == 0:
        return
    st: uint32 = sv_new(SVO_STORE)
    if st == 0:
        return
    sv_a[st] = off
    sv_b[st] = val
    sv_aux[st] = glob_scalar_size[gi - 1]     # store width
    sv_as256[st] = 1                          # %gs-relative (addrspace 256)
    bb_append(bb, st)


# Return the 1-based global index if `off/len` names an EMITTABLE 1-D
# scalar-element array global, else 0.  A 1-D array is indexed as
# base + idx*elem_size with a sized load/store.  Multi-dimensional globals
# (whose flat glob_elem_size records the INNERMOST width, not the row stride),
# pointer globals (glob_elem_size == 0) and percpu globals are all rejected so
# only the flat single-index case reaches ssa_index_addr.
def ssa_global_array_1d(off: uint32, len_: uint32) -> uint32:
    gi: uint32 = glob_lookup(off, len_)
    if gi == 0:
        return 0
    es: uint32 = glob_elem_size[gi - 1]
    if es != 1 and es != 2 and es != 4 and es != 8:
        return 0                              # scalar (0) or non-machine width
    if glob_is_percpu[gi - 1] != 0:
        return 0
    tn: uint32 = glob_type_node[gi - 1]
    if tn == 0 or nd_kind[tn] != ND_ARRAY_TYPE:
        return 0
    if nd_kind[nd_a[tn]] == ND_ARRAY_TYPE:
        return 0                              # multi-dimensional -> defer
    # A STRUCT-element array (`Array[N, Rec]`) is NOT a flat machine-scalar
    # array: glob_elem_size records the innermost scalar width, not the element
    # stride (st_total), so treating it as a 1-D scalar array would index with
    # the wrong stride.  Defer it to the struct-aware region resolver.
    if struct_lookup_by_node(nd_a[tn]) != 0:
        return 0
    return gi


# Element signedness tristate (0 unknown / 1 unsigned / 2 signed) of 1-D array
# global `gi` — the declared element type's signedness (mirrors codegen
# expr_signedness -> index_elem_signed for the flat-global case).
def ssa_array_elem_sgn(gi: uint32) -> uint32:
    return type_signedness(nd_a[glob_type_node[gi - 1]])


# Return the 1-based global index if `off/len` names an EMITTABLE 2-D
# scalar-element array global (`Array[N, Array[M, T]]`, T a machine width), else
# 0.  A 2-D element `g[i][j]` addresses at base + i*(M*es) + j*es, where es is the
# innermost element width (glob_elem_size) and M the inner dimension count.
# LLVM path only (the sole callers gate on ssa_mem_model != 0); the native path
# keeps such globals bailed, so its byte output is unchanged.
def ssa_global_array_2d(off: uint32, len_: uint32) -> uint32:
    gi: uint32 = glob_lookup(off, len_)
    if gi == 0:
        return 0
    es: uint32 = glob_elem_size[gi - 1]
    if es != 1 and es != 2 and es != 4 and es != 8:
        return 0
    if glob_is_percpu[gi - 1] != 0:
        return 0
    tn: uint32 = glob_type_node[gi - 1]
    if tn == 0 or nd_kind[tn] != ND_ARRAY_TYPE:
        return 0
    inner: uint32 = nd_a[tn]
    if inner == 0 or nd_kind[inner] != ND_ARRAY_TYPE:
        return 0                              # not 2-D
    if nd_kind[nd_a[inner]] == ND_ARRAY_TYPE:
        return 0                              # 3-D+ -> defer
    return gi


# Innermost-element signedness tristate of a 2-D global array `gi`.
def ssa_array2_elem_sgn(gi: uint32) -> uint32:
    return type_signedness(nd_a[nd_a[glob_type_node[gi - 1]]])


# Byte address of `g[i][j]` for a 2-D scalar-array global.  `outer_node` is the
# OUTER ND_INDEX (`g[i][j]`): nd_a = inner ND_INDEX (`g[i]`), nd_b = j; the inner
# index i is nd_b of that inner node.  Builds base + i*rowstride + j*es as pure
# pointer arithmetic.  Returns 0 on bail.
def ssa_index2_addr(gi: uint32, outer_node: uint32) -> uint32:
    inner_node: uint32 = nd_a[outer_node]
    iexpr: uint32 = nd_b[inner_node]
    jexpr: uint32 = nd_b[outer_node]
    es: uint32 = glob_elem_size[gi - 1]
    innerT: uint32 = nd_a[glob_type_node[gi - 1]]
    m: uint32 = cast[uint32](nd_num[innerT])
    rowstride: uint32 = m * es
    iv: uint32 = ssa_lower_expr(iexpr, ssa_cur_bb)
    if iv == 0:
        return 0
    jv: uint32 = ssa_lower_expr(jexpr, ssa_cur_bb)
    if jv == 0:
        return 0
    base: uint32 = ssa_globaladdr(gi, ssa_cur_bb)
    if base == 0:
        return 0
    # i*rowstride
    rc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](rowstride))
    if rc == 0:
        return 0
    imul: uint32 = sv_new(SVO_BINOP)
    if imul == 0:
        return 0
    sv_aux[imul] = BINOP_MUL
    sv_a[imul] = iv
    sv_b[imul] = rc
    bb_append(ssa_cur_bb, imul)
    # base + i*rowstride
    a1: uint32 = sv_new(SVO_BINOP)
    if a1 == 0:
        return 0
    sv_aux[a1] = BINOP_ADD
    sv_a[a1] = base
    sv_b[a1] = imul
    sv_type[a1] = SVT_PTR
    bb_append(ssa_cur_bb, a1)
    # + j*es
    jscaled: uint32 = jv
    if es != 1:
        jc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](es))
        if jc == 0:
            return 0
        jmul: uint32 = sv_new(SVO_BINOP)
        if jmul == 0:
            return 0
        sv_aux[jmul] = BINOP_MUL
        sv_a[jmul] = jv
        sv_b[jmul] = jc
        bb_append(ssa_cur_bb, jmul)
        jscaled = jmul
    a2: uint32 = sv_new(SVO_BINOP)
    if a2 == 0:
        return 0
    sv_aux[a2] = BINOP_ADD
    sv_a[a2] = a1
    sv_b[a2] = jscaled
    sv_type[a2] = SVT_PTR
    bb_append(ssa_cur_bb, a2)
    return a2


# Byte address of `gi[idxnode]` for a 1-D scalar-array global: idx is lowered
# (may advance ssa_cur_bb across a short-circuit), then base = GLOBALADDR(gi) and
# addr = base + idx*elem_size are built as PURE pointer arithmetic in the current
# block, reusing the existing globaladdr / BINOP emit paths.  Returns 0 on bail.
def ssa_index_addr(gi: uint32, idxnode: uint32) -> uint32:
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    base: uint32 = ssa_globaladdr(gi, ssa_cur_bb)
    if base == 0:
        return 0
    es: uint32 = glob_elem_size[gi - 1]
    scaled: uint32 = idxv
    if es != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](es))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = base
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# Emit a sized SVO_LOAD of width `es` (signedness `sgn` tristate) from address
# value `addr` into the current block.
def ssa_load_at(addr: uint32, es: uint32, sgn: uint32) -> uint32:
    ld: uint32 = sv_new(SVO_LOAD)
    if ld == 0:
        return 0
    sv_a[ld] = addr
    sv_aux[ld] = es
    if es < 8 and sgn == 2:
        sv_c[ld] = 1                          # signed sub-word load (movsx)
    else:
        sv_c[ld] = 0                          # zero-extend / full-width load
    bb_append(ssa_cur_bb, ld)
    return ld


# Emit a sized SVO_STORE of width `es` of value `val` to address value `addr`
# into block `bb`.
def ssa_store_at_in(addr: uint32, val: uint32, es: uint32, bb: uint32):
    st: uint32 = sv_new(SVO_STORE)
    if st == 0:
        return
    sv_a[st] = addr
    sv_b[st] = val
    sv_aux[st] = es
    bb_append(bb, st)


# Emit a sized SVO_STORE into the current block.
def ssa_store_at(addr: uint32, val: uint32, es: uint32):
    ssa_store_at_in(addr, val, es, ssa_cur_bb)


# Emit a sized ELEMENT load that carries a FLOAT element type when `fw` (4/8) is
# nonzero: the loaded SSA value is typed SVT_F32/F64 so downstream float
# arithmetic sees a float operand (ssa_val_fw) and the LLVM emitter emits
# `load float` / `load double` (not the i64 integer load).  `fw == 0` is an
# ordinary integer load, byte-for-byte identical to ssa_load_at.  The float type
# is stamped ONLY on the LLVM path (ssa_mem_model != 0); the native --opt path
# never carries a float value (its float leaves all bail before emission), so
# this is inert there and the native byte output is UNCHANGED.
def ssa_load_elem(addr: uint32, es: uint32, sgn: uint32, fw: uint32) -> uint32:
    v: uint32 = ssa_load_at(addr, es, sgn)
    if v != 0 and fw != 0 and ssa_mem_model != 0:
        sv_type[v] = ssa_fw_svt(fw)
    return v


# =======================================================================
# LOCAL MEMORY subset helpers (address-taken scalars, local arrays, deref).
# All modeling reuses the existing SVO_ALLOCA / SVO_LOAD / SVO_STORE ops plus
# PURE base+idx*elem BINOP arithmetic — no new opcode beyond SVO_ALLOCA (which
# only the LLVM emitter lowers, and which is only ever produced when
# ssa_mem_model==1, i.e. the LLVM path; the native path never sees it).
# =======================================================================
# Ensure name id `nid` has a stack slot: create its SVO_ALLOCA (total byte size
# `total`) in the ENTRY block on first request.  The alloca has no operands and
# lives in entry (which dominates every block), so it is emitted before any use.
# Callers MUST invoke this while the entry block is still open (param setup /
# pre-alloca scan) so the alloca never lands after a terminator.
def ssa_ensure_slot(nid: uint32, total: uint32) -> uint32:
    if ssa_mem_addr[nid] != 0:
        return ssa_mem_addr[nid]
    a: uint32 = sv_new(SVO_ALLOCA)
    if a == 0:
        return 0
    sv_imm[a] = cast[uint64](total)
    sv_type[a] = SVT_PTR
    bb_append(sb_entry, a)
    ssa_mem_addr[nid] = a
    return a


# Record pointee width/signedness for a pointer local/param so `*p` can pick its
# load/store width.  A pointer-to-pointer derefs to an 8-byte address; a pointer
# to a machine-width scalar derefs to that width; anything else (float / array /
# struct pointee) leaves esz=0 => `*p` bails.
def ssa_record_ptr_info(nid: uint32, tnode: uint32):
    if tnode == 0:
        return
    # Struct typing for member access `obj.field` (LLVM path only). A
    # `Ptr[Struct]` local/param carries the struct base in its VALUE; an
    # in-place `Struct` value carries it at its alloca slot address.
    if ssa_mem_model != 0:
        psi: uint32 = ptr_struct_idx(tnode)
        if psi != 0:
            ssa_local_struct[nid] = psi
            ssa_local_struct_is_ptr[nid] = 1
        else:
            ssi: uint32 = struct_lookup_by_node(tnode)
            if ssi != 0:
                ssa_local_struct[nid] = ssi
                ssa_local_struct_is_ptr[nid] = 0
    if nd_kind[tnode] != ND_PTR_TYPE:
        return
    pointee: uint32 = nd_a[tnode]
    if pointee == 0:
        return
    if nd_kind[pointee] == ND_PTR_TYPE:
        ssa_ptr_esz[nid] = 8
        ssa_ptr_esgn[nid] = 1
        return
    if nd_kind[pointee] == ND_TYPE:
        if type_float_width(pointee) != 0:
            return
        ps: uint32 = prim_type_size(pointee)
        if ps == 1 or ps == 2 or ps == 4 or ps == 8:
            ssa_ptr_esz[nid] = ps
            ssa_ptr_esgn[nid] = type_signedness(pointee)


# Byte address of element `idxnode` of memory-array local `nid`: idx is lowered
# (may advance ssa_cur_bb), base = the alloca's i64 address, addr = base +
# idx*elem_size built as PURE pointer arithmetic in the current block — the exact
# shape ssa_index_addr uses for a global array.  Returns 0 on bail.
def ssa_local_index_addr(nid: uint32, idxnode: uint32) -> uint32:
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    base: uint32 = ssa_mem_addr[nid]
    if base == 0:
        ssa_set_bail(SBR_MEMORY)
        return 0
    es: uint32 = ssa_mem_esz[nid]
    scaled: uint32 = idxv
    if es != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](es))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = base
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# Byte address of element `idxnode` through a POINTER local/param `nid`
# (`p[i]` == `*(p + i)`).  The pointer VALUE is read as a promotable scalar and
# `idx * elem_size` (elem_size = ssa_ptr_esz[nid]) added — the same pure
# base+idx*scale shape a global/local array index uses.  LLVM path only (the
# sole callers gate on ssa_mem_model != 0).  Returns 0 on bail (bail flag set).
def ssa_ptr_index_addr(nid: uint32, idxnode: uint32) -> uint32:
    esz: uint32 = ssa_ptr_esz[nid]
    if esz == 0:
        ssa_set_bail(SBR_MEMORY)                  # non-pointer / aggregate pointee
        return 0
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    # The pointer VALUE: a promotable pointer scalar is read as an SSA value; a
    # slot-spilled pointer (non-promotable — indexing marked its slot read) is
    # loaded from its 8-byte alloca.
    base: uint32 = 0
    if ssa_ismem[nid] != 0:
        base = ssa_load_at(ssa_mem_addr[nid], 8, 0)
    else:
        base = ssa_read_var(nid, ssa_cur_bb)
    if base == 0:
        return 0
    scaled: uint32 = idxv
    if esz != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](esz))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = base
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# ---- GLOBAL pointer indexing (`gptr[i]`) -----------------------------------
# A global `Ptr[T]` variable holds an 8-byte address slot (glob_scalar_size==8,
# glob_elem_size==0, glob_ptr_size==sizeof(T)).  Indexing it dereferences with
# the pointee width — exactly what the NATIVE codegen already does for the same
# `gptr[i]` (glob_ptr_size was recorded precisely so `g[i]` derefs at the right
# width).  These helpers bring the LLVM/SSA subset up to that parity so global
# pointer indexing no longer bails SBR_MEMORY.  LLVM path only (callers gate on
# ssa_mem_model != 0); the native path never reaches them, so its byte output
# is unchanged.

# Pointee element width of a GLOBAL `Ptr[T]` named by `off/len`, or 0 if it is
# not an emittable machine-scalar pointer global.  On a hit *gi_out gets the
# 1-based global index.
def ssa_global_ptr_esz(off: uint32, len_: uint32, gi_out: Ptr[uint32]) -> uint32:
    gi: uint32 = glob_lookup(off, len_)
    if gi == 0:
        return 0
    if glob_is_percpu[gi - 1] != 0:
        return 0                              # %gs-relative (kernel) -> defer
    tn: uint32 = glob_type_node[gi - 1]
    if tn == 0 or nd_kind[tn] != ND_PTR_TYPE:
        return 0                              # not a pointer-typed global
    es: uint32 = glob_ptr_size[gi - 1]
    if es != 1 and es != 2 and es != 4 and es != 8:
        return 0                              # non-machine / aggregate pointee
    gi_out[0] = gi
    return es


# Pointee signedness tristate (0 unknown / 1 unsigned / 2 signed) of a global
# `Ptr[T]` — a pointer pointee is unsigned; otherwise the pointee's declared
# signedness (mirrors the local-pointer ssa_ptr_esgn setup).
def ssa_global_ptr_esgn(gi: uint32) -> uint32:
    pointee: uint32 = nd_a[glob_type_node[gi - 1]]
    if pointee == 0:
        return 0
    if nd_kind[pointee] == ND_PTR_TYPE:
        return 1
    return type_signedness(pointee)


# Byte address of `gptr[i]` for a global `Ptr[T]` (1-based index gi, pointee
# width esz): load the 8-byte pointer VALUE from the global's slot, then
# base + idx*esz — the same pure base+idx*scale shape ssa_ptr_index_addr builds
# for a LOCAL pointer.  Returns 0 on bail (bail flag set).
def ssa_global_ptr_index_addr(gi: uint32, idxnode: uint32, esz: uint32) -> uint32:
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    base: uint32 = ssa_global_load(gi, ssa_cur_bb)    # 8-byte pointer value
    if base == 0:
        return 0
    scaled: uint32 = idxv
    if esz != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](esz))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = base
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# `gptr[i] = rhs` / `... op= rhs` store through a GLOBAL Ptr[T] element.  The
# element address (which loads the pointer value once) is computed once; the
# augmented form load-modify-writes the SAME address.  LLVM path only.
def ssa_lower_global_ptr_index_store(bb: uint32, stmt: uint32, target: uint32,
                                     gi: uint32, es: uint32) -> uint32:
    esgn: uint32 = ssa_global_ptr_esgn(gi)
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        addr: uint32 = ssa_global_ptr_index_addr(gi, nd_b[target], es)
        if addr == 0:
            return ssa_cur_bb
        cur: uint32 = ssa_load_at(addr, es, esgn)
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, es)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    addr2: uint32 = ssa_global_ptr_index_addr(gi, nd_b[target], es)
    if addr2 == 0:
        return ssa_cur_bb
    ssa_store_at(addr2, rhsv, es)
    return ssa_cur_bb


# ---- NON-IDENT index base (`g[i][j][k]`, `foo()[i]`) ----------------------
# The 1-D/2-D/global-ptr fast paths above all require the index BASE to be a bare
# identifier.  The two helpers below close the remaining machine-scalar INTEGER
# element cases where the base is a compound expression:
#   * a fully-indexed N-D (depth>=3) GLOBAL array (`scf_l[gr][ch][sfb]`), and
#   * an rvalue expression that produces a POINTER (`_name_slot(pk)[i]`).
# Float-element bases are rejected (the SVO_LOAD/STORE ops are integer-only), so
# they keep bailing to native.  LLVM path only (callers gate on ssa_mem_model !=
# 0); the native path never reaches them, so its byte output is unchanged.

# Element byte address of a fully-indexed N-D scalar-INTEGER GLOBAL array named
# at the root of the index chain `node` (the OUTERMOST ND_INDEX).  Returns 0 when
# the shape is not such an array (no bail set) or on a mid-lowering bail; on
# success writes the element width/signedness through out_esz/out_esgn.  The flat
# offset is base + Σ_d idx_d * stride_d with row-major strides (stride_d = es *
# Π_{m>d} dim_m) — the same pure base+idx*scale arithmetic the 2-D path builds.
def ssa_global_arraynd_addr(node: uint32, out_esz: Ptr[uint32],
                            out_esgn: Ptr[uint32], out_fw: Ptr[uint32]) -> uint32:
    out_esz[0] = 0
    out_esgn[0] = 0
    out_fw[0] = 0
    # Walk the index chain: idxs[0..count) are the index exprs innermost-applied
    # first (idxs[0] = last `[..]`); the chain must bottom out at an ND_IDENT.
    idxs: Array[8, uint32]
    count: uint32 = 0
    cur: uint32 = node
    while nd_kind[cur] == ND_INDEX:
        if count >= 8:
            return 0
        idxs[count] = nd_b[cur]
        count = count + 1
        cur = nd_a[cur]
    if count == 0 or nd_kind[cur] != ND_IDENT:
        return 0
    gi: uint32 = glob_lookup(nd_name_off[cur], nd_name_len[cur])
    if gi == 0 or glob_is_percpu[gi - 1] != 0:
        return 0
    tn: uint32 = glob_type_node[gi - 1]
    if tn == 0 or nd_kind[tn] != ND_ARRAY_TYPE:
        return 0
    # Collect the array dims outer..inner and reach the innermost element type.
    dims: Array[8, uint32]
    ndim: uint32 = 0
    t: uint32 = tn
    while nd_kind[t] == ND_ARRAY_TYPE:
        if ndim >= 8:
            return 0
        dims[ndim] = cast[uint32](nd_num[t])
        ndim = ndim + 1
        t = nd_a[t]
    if ndim != count:
        return 0                              # partial index (subarray) -> defer
    # Float elements ARE modeled on the LLVM path (typed load/store); the width
    # (4/8) rides prim_type_size just like an integer element, so the base+Σ
    # idx*stride address arithmetic below is identical.  out_fw distinguishes a
    # float element so the load/store is emitted float-typed.
    es: uint32 = prim_type_size(t)
    if es != 1 and es != 2 and es != 4 and es != 8:
        return 0
    # Lower every index expr first (matches ssa_index2_addr ordering), then the
    # base symbol address, then fold base + Σ idx_d*stride_d.
    ivs: Array[8, uint32]
    d: uint32 = 0
    while d < ndim:
        iv: uint32 = ssa_lower_expr(idxs[count - 1 - d], ssa_cur_bb)
        if iv == 0:
            return 0
        ivs[d] = iv
        d = d + 1
    acc: uint32 = ssa_globaladdr(gi, ssa_cur_bb)
    if acc == 0:
        return 0
    d = 0
    while d < ndim:
        stride: uint32 = es
        m: uint32 = d + 1
        while m < ndim:
            stride = stride * dims[m]
            m = m + 1
        scaled: uint32 = ivs[d]
        if stride != 1:
            sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](stride))
            if sc == 0:
                return 0
            mul: uint32 = sv_new(SVO_BINOP)
            if mul == 0:
                return 0
            sv_aux[mul] = BINOP_MUL
            sv_a[mul] = ivs[d]
            sv_b[mul] = sc
            bb_append(ssa_cur_bb, mul)
            scaled = mul
        addv: uint32 = sv_new(SVO_BINOP)
        if addv == 0:
            return 0
        sv_aux[addv] = BINOP_ADD
        sv_a[addv] = acc
        sv_b[addv] = scaled
        sv_type[addv] = SVT_PTR
        bb_append(ssa_cur_bb, addv)
        acc = addv
        d = d + 1
    out_esz[0] = es
    out_esgn[0] = type_signedness(t)
    out_fw[0] = type_float_width(t)
    return acc


# Pointee width/signedness of an expression that STATICALLY has pointer type and
# whose element is a machine-scalar integer, else 0.  Only a direct call to an
# in-unit function returning `Ptr[<machine int>]` is resolvable (a general expr's
# static type is not tracked here).  On a hit writes the signedness tristate.
def ssa_ptr_expr_esz(node: uint32, out_esgn: Ptr[uint32]) -> uint32:
    out_esgn[0] = 0
    # cast[Ptr[T]](x)[i]: a pointer-CAST rvalue base (LLVM path only).  The cast
    # lowers to a no-op that forwards the operand's pointer value (ssa_lower_expr
    # ND_CAST identity path), so `base + i*elem` indexes it directly; the element
    # width is the cast target's pointee width.  Gated on ssa_mem_model so the
    # native --opt path still returns 0 here (-> SBR_MEMORY bail, legacy
    # fallback), keeping codegen.ad byte output UNCHANGED.
    if ssa_mem_model != 0 and nd_kind[node] == ND_CAST:
        dt: uint32 = nd_a[node]
        if dt == 0 or nd_kind[dt] != ND_PTR_TYPE:
            return 0
        cpointee: uint32 = nd_a[dt]
        if cpointee == 0:
            return 0
        if nd_kind[cpointee] == ND_PTR_TYPE:
            out_esgn[0] = 1
            return 8
        if type_float_width(cpointee) != 0:
            return 0
        cps: uint32 = prim_type_size(cpointee)
        if cps != 1 and cps != 2 and cps != 4 and cps != 8:
            return 0
        out_esgn[0] = type_signedness(cpointee)
        return cps
    if nd_kind[node] != ND_CALL:
        return 0
    callee: uint32 = nd_a[node]
    if callee == 0 or nd_kind[callee] != ND_IDENT:
        return 0
    rt: uint32 = ssa_callee_ret_node(nd_name_off[callee], nd_name_len[callee])
    if rt == 0 or nd_kind[rt] != ND_PTR_TYPE:
        return 0
    pointee: uint32 = nd_a[rt]
    if pointee == 0:
        return 0
    if nd_kind[pointee] == ND_PTR_TYPE:
        out_esgn[0] = 1
        return 8
    if type_float_width(pointee) != 0:
        return 0
    ps: uint32 = prim_type_size(pointee)
    if ps != 1 and ps != 2 and ps != 4 and ps != 8:
        return 0
    out_esgn[0] = type_signedness(pointee)
    return ps


# Element byte address of `<ptr-rvalue>[i]` — the base expr (nd_a[node]) is
# lowered as an rvalue POINTER value and `base + i*es` added.  Returns 0 when the
# base is not a resolvable pointer (no bail) or on a mid-lowering bail.
def ssa_ptr_rvalue_index_addr(node: uint32, out_esz: Ptr[uint32],
                              out_esgn: Ptr[uint32], out_fw: Ptr[uint32]) -> uint32:
    out_esz[0] = 0
    out_esgn[0] = 0
    out_fw[0] = 0                             # float pointee is rejected below
    base: uint32 = nd_a[node]
    esgn: uint32 = 0
    es: uint32 = ssa_ptr_expr_esz(base, &esgn)
    if es == 0:
        return 0
    ptrval: uint32 = ssa_lower_expr(base, ssa_cur_bb)
    if ptrval == 0:
        return 0
    idxv: uint32 = ssa_lower_expr(nd_b[node], ssa_cur_bb)
    if idxv == 0:
        return 0
    scaled: uint32 = idxv
    if es != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](es))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = ptrval
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    out_esz[0] = es
    out_esgn[0] = esgn
    return addv


# Dispatcher: element byte address for an ND_INDEX `node` whose base is NOT a
# bare identifier — try the N-D global array shape, then the pointer-rvalue shape.
# Returns 0 (with out_esz==0) when neither applies or a sub-lowering bailed.
def ssa_nonident_index_addr(node: uint32, out_esz: Ptr[uint32],
                            out_esgn: Ptr[uint32], out_fw: Ptr[uint32]) -> uint32:
    a: uint32 = ssa_global_arraynd_addr(node, out_esz, out_esgn, out_fw)
    if a != 0:
        return a
    if ssa_bail != 0:
        return 0
    p: uint32 = ssa_ptr_rvalue_index_addr(node, out_esz, out_esgn, out_fw)
    if p != 0:
        return p
    if ssa_bail != 0:
        return 0
    # Region-resolvable container (multi-dim MEMBER array `obj.arr2d[i][j]`, etc.)
    return ssa_general_index_addr_sized(node, out_esz, out_esgn, out_fw)


# `<nonident-base>[i] = rhs` / `... op= rhs` store.  The element address (which
# evaluates the base + index once) is computed via the dispatcher; the augmented
# form load-modify-writes the SAME address.  LLVM path only.
def ssa_lower_nonident_index_store(bb: uint32, stmt: uint32, target: uint32) -> uint32:
    aug: uint32 = nd_aux[stmt]
    es: uint32 = 0
    esgn: uint32 = 0
    fw: uint32 = 0
    if aug != 0:
        addr: uint32 = ssa_nonident_index_addr(target, &es, &esgn, &fw)
        if addr == 0:
            if ssa_bail == 0:
                ssa_set_bail(SBR_MEMORY)
            return ssa_cur_bb
        cur: uint32 = ssa_load_elem(addr, es, esgn, fw)
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, es)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    addr2: uint32 = ssa_nonident_index_addr(target, &es, &esgn, &fw)
    if addr2 == 0:
        if ssa_bail == 0:
            ssa_set_bail(SBR_MEMORY)
        return ssa_cur_bb
    ssa_store_at(addr2, rhsv, es)
    return ssa_cur_bb


# Pointee load/store width of a `*expr` deref, or 0 if not derefable in-subset
# (only a bare local/param pointer identifier with a machine-width scalar pointee
# is accepted; every other operand bails).
def ssa_deref_esz(expr: uint32) -> uint32:
    if nd_kind[expr] != ND_IDENT:
        return 0
    nid: uint32 = nm_intern(nd_name_off[expr], nd_name_len[expr])
    if nid >= NM_MAX:
        return 0
    if ssa_islocal[nid] == 0:
        return 0
    return ssa_ptr_esz[nid]


def ssa_deref_esgn(expr: uint32) -> uint32:
    nid: uint32 = nm_intern(nd_name_off[expr], nd_name_len[expr])
    if nid >= NM_MAX:
        return 0
    return ssa_ptr_esgn[nid]


# ---- MODULE-SCOPE (GLOBAL) struct member bases, LLVM path only -------------
# Base ADDRESS (i64 value) of the IN-PLACE struct denoted by a GLOBAL identifier
# `g` (name off/len) — its RIP-relative symbol address — writing its struct
# table index (+1) via out_struct.  Returns 0 (WITHOUT bailing) when `g` is not
# a module-scope in-place `Struct` global, so the caller falls through to its
# normal SBR_MEMORY bail.  LLVM path only (the sole caller gates on
# ssa_mem_model != 0); the native --opt path never reaches it, so codegen.ad
# byte output is unchanged.  Percpu globals are excluded (they lower
# %gs-relative — a struct percpu is left to bail).  A `Ptr[Struct]` global is
# deliberately NOT handled here (no kernel site uses one → it bails, safe).
def ssa_global_struct_base(nameoff: uint32, namelen: uint32, out_struct: Ptr[uint32]) -> uint32:
    gi: uint32 = glob_lookup(nameoff, namelen)
    if gi == 0 or glob_is_percpu[gi - 1] != 0:
        return 0
    si: uint32 = glob_struct_idx[gi - 1]
    if si == 0:
        return 0
    out_struct[0] = si                            # in-place struct: symbol addr
    return ssa_globaladdr(gi, ssa_cur_bb)


# Base ADDRESS of the struct ELEMENT `g[idxnode]` where `g` is a GLOBAL 1-D
# `Array[N, Struct]` — symbol_addr + idx*st_total(Struct) — writing its struct
# index (+1) via out_struct.  Lowers `idxnode` in the current block.  Returns 0
# (WITHOUT bailing) when `g` is not a module-scope 1-D array-of-struct global;
# caller then bails.  Multi-dimensional / scalar-element array globals and
# `Ptr[Struct]` globals are deferred (return 0; no kernel site uses the ptr
# form).  LLVM path only (caller gates on ssa_mem_model != 0); native output
# unchanged.
def ssa_global_indexed_struct_base(nameoff: uint32, namelen: uint32, idxnode: uint32, out_struct: Ptr[uint32]) -> uint32:
    gi: uint32 = glob_lookup(nameoff, namelen)
    if gi == 0 or glob_is_percpu[gi - 1] != 0:
        return 0
    if glob_elem_size[gi - 1] == 0:
        return 0                                 # scalar slot / Ptr global -> defer
    tn: uint32 = glob_type_node[gi - 1]
    if tn == 0 or nd_kind[tn] != ND_ARRAY_TYPE:
        return 0
    elem: uint32 = nd_a[tn]
    if nd_kind[elem] == ND_ARRAY_TYPE:
        return 0                                 # multi-dim -> defer
    si: uint32 = struct_lookup_by_node(elem)
    if si == 0:
        return 0                                 # scalar-element array -> defer
    baseaddr: uint32 = ssa_globaladdr(gi, ssa_cur_bb)
    if baseaddr == 0:
        return 0
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    out_struct[0] = si
    stride: uint32 = st_total[si - 1]
    if stride == 0:
        return baseaddr
    scaled: uint32 = idxv
    if stride != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](stride))
        if sc == 0:
            return 0
        gmul: uint32 = sv_new(SVO_BINOP)
        if gmul == 0:
            return 0
        sv_aux[gmul] = BINOP_MUL
        sv_a[gmul] = idxv
        sv_b[gmul] = sc
        bb_append(ssa_cur_bb, gmul)
        scaled = gmul
    gadd: uint32 = sv_new(SVO_BINOP)
    if gadd == 0:
        return 0
    sv_aux[gadd] = BINOP_ADD
    sv_a[gadd] = baseaddr
    sv_b[gadd] = scaled
    sv_type[gadd] = SVT_PTR
    bb_append(ssa_cur_bb, gadd)
    return gadd


# ---- MEMBER ACCESS (obj.field), LLVM path only -----------------------------
# Base ADDRESS (i64 value) of the struct denoted by `obj`, writing the struct
# table index (+1) through out_struct.  Accepted object forms:
#   ident (Ptr[Struct])      -> the pointer's VALUE is the base address
#   ident (in-place Struct)  -> its alloca slot address
#   ptr[idx]                 -> ptr_value + idx*sizeof(Struct)  (e.g. `c[0].f`)
# Returns 0 on bail (bail flag set).
def ssa_member_base_addr(obj: uint32, out_struct: Ptr[uint32]) -> uint32:
    out_struct[0] = 0
    k: uint32 = nd_kind[obj]
    # Phase 4b recursive resolver: a NESTED-member (`a.b.field`) or deref
    # (`(*p).field`) object base — neither is covered by the fast paths below.
    if ssa_mem_model != 0 and (k == ND_MEMBER or (k == ND_UNARY and nd_aux[obj] == UNOP_DEREF)):
        rb: uint32 = ssa_struct_base_rec(obj, out_struct)
        if rb != 0:
            return rb
        ssa_set_bail(SBR_MEMORY)
        return 0
    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[obj], nd_name_len[obj])
        if nid >= NM_MAX or ssa_islocal[nid] == 0 or ssa_local_struct[nid] == 0:
            # LLVM path: a module-scope `Struct` / `Ptr[Struct]` global `g.field`.
            if ssa_mem_model != 0:
                gsb: uint32 = ssa_global_struct_base(nd_name_off[obj], nd_name_len[obj], out_struct)
                if gsb != 0:
                    return gsb
            ssa_set_bail(SBR_MEMORY)
            return 0
        out_struct[0] = ssa_local_struct[nid]
        if ssa_local_struct_is_ptr[nid] != 0:
            if ssa_ismem[nid] != 0:
                return ssa_load_at(ssa_mem_addr[nid], 8, 0)
            return ssa_read_var(nid, ssa_cur_bb)
        if ssa_ismem[nid] != 0:
            return ssa_mem_addr[nid]
        ssa_set_bail(SBR_MEMORY)
        return 0
    if k == ND_INDEX:
        base: uint32 = nd_a[obj]
        # cast[Ptr[Struct]](x)[i].field  (LLVM path only) — the dominant kernel
        # MEMORY bail class (mm/page.ad `page_*` accessors).  The index base is a
        # pointer-CAST rvalue whose pointee is a STRUCT: lower the cast operand as
        # a pointer value (ND_CAST forwards its operand — line ~1558), then
        # base + i*sizeof(Struct) is the struct's address.  The struct index is
        # recovered from the cast target's pointee so `.field` resolves against it.
        # Gated on ssa_mem_model so the native --opt path still bails SBR_MEMORY
        # (legacy fallback), keeping codegen.ad byte output UNCHANGED.
        if ssa_mem_model != 0 and nd_kind[base] == ND_CAST:
            dt: uint32 = nd_a[base]
            if dt == 0 or nd_kind[dt] != ND_PTR_TYPE:
                ssa_set_bail(SBR_MEMORY)
                return 0
            csi: uint32 = struct_lookup_by_node(nd_a[dt])
            if csi == 0:
                ssa_set_bail(SBR_MEMORY)          # non-struct pointee -> defer
                return 0
            out_struct[0] = csi
            cidxv: uint32 = ssa_lower_expr(nd_b[obj], ssa_cur_bb)
            if cidxv == 0:
                return 0
            cptr: uint32 = ssa_lower_expr(base, ssa_cur_bb)   # cast fwds ptr value
            if cptr == 0:
                return 0
            cstride: uint32 = st_total[csi - 1]
            if cstride == 0:
                return cptr
            cscaled: uint32 = cidxv
            if cstride != 1:
                csc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](cstride))
                if csc == 0:
                    return 0
                cmul: uint32 = sv_new(SVO_BINOP)
                if cmul == 0:
                    return 0
                sv_aux[cmul] = BINOP_MUL
                sv_a[cmul] = cidxv
                sv_b[cmul] = csc
                bb_append(ssa_cur_bb, cmul)
                cscaled = cmul
            cadd: uint32 = sv_new(SVO_BINOP)
            if cadd == 0:
                return 0
            sv_aux[cadd] = BINOP_ADD
            sv_a[cadd] = cptr
            sv_b[cadd] = cscaled
            sv_type[cadd] = SVT_PTR
            bb_append(ssa_cur_bb, cadd)
            return cadd
        if nd_kind[base] != ND_IDENT:
            # Phase 4b: a COMPUTED index base — `base[i].field` where base is
            # itself a member / index / deref (e.g. `g[i].stack[d].field`).
            if ssa_mem_model != 0:
                rc: uint32 = ssa_struct_base_rec(obj, out_struct)
                if rc != 0:
                    return rc
            ssa_set_bail(SBR_MEMORY)
            return 0
        bnid: uint32 = nm_intern(nd_name_off[base], nd_name_len[base])
        if bnid >= NM_MAX or ssa_islocal[bnid] == 0 or ssa_local_struct[bnid] == 0 or ssa_local_struct_is_ptr[bnid] == 0:
            # LLVM path: a module-scope `Array[N, Struct]` / `Ptr[Struct]` global
            # indexed then field-accessed — `g[i].field`.
            if ssa_mem_model != 0 and bnid < NM_MAX and ssa_islocal[bnid] == 0:
                gib: uint32 = ssa_global_indexed_struct_base(nd_name_off[base], nd_name_len[base], nd_b[obj], out_struct)
                if gib != 0:
                    return gib
            # Phase 4b: any other index-then-field base (local struct array,
            # global Ptr[Struct], ...) via the recursive region resolver.
            if ssa_mem_model != 0:
                rd: uint32 = ssa_struct_base_rec(obj, out_struct)
                if rd != 0:
                    return rd
            ssa_set_bail(SBR_MEMORY)
            return 0
        si: uint32 = ssa_local_struct[bnid]
        out_struct[0] = si
        idxv: uint32 = ssa_lower_expr(nd_b[obj], ssa_cur_bb)
        if idxv == 0:
            return 0
        ptrval: uint32 = 0
        if ssa_ismem[bnid] != 0:
            ptrval = ssa_load_at(ssa_mem_addr[bnid], 8, 0)
        else:
            ptrval = ssa_read_var(bnid, ssa_cur_bb)
        if ptrval == 0:
            return 0
        stride: uint32 = st_total[si - 1]
        if stride == 0:
            return ptrval
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](stride))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        addv: uint32 = sv_new(SVO_BINOP)
        if addv == 0:
            return 0
        sv_aux[addv] = BINOP_ADD
        sv_a[addv] = ptrval
        sv_b[addv] = mul
        sv_type[addv] = SVT_PTR
        bb_append(ssa_cur_bb, addv)
        return addv
    ssa_set_bail(SBR_MEMORY)
    return 0


# Add a constant byte offset `off` to address value `base` (returns base when
# off==0).  Returns 0 on allocation failure.
def ssa_addr_plus(base: uint32, off: uint32) -> uint32:
    if off == 0:
        return base
    oc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](off))
    if oc == 0:
        return 0
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = base
    sv_b[addv] = oc
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# Address (i64 value) of scalar field `node` (an ND_MEMBER `obj.field`), writing
# the field's load/store width through out_sz and its signedness tristate (0/1/2)
# through out_sgn.  out_sz==0 marks an array/aggregate field (decays to its
# address, no load).  Returns 0 on bail.
def ssa_member_field_addr(node: uint32, out_sz: Ptr[uint32], out_sgn: Ptr[uint32]) -> uint32:
    out_sz[0] = 0
    out_sgn[0] = 0
    si: uint32 = 0
    base: uint32 = ssa_member_base_addr(nd_a[node], &si)
    if base == 0 or si == 0:
        return 0
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(si, nd_name_off[node], nd_name_len[node], &foff, &fsgn)
    if fsz == SF_NOFIELD:
        ssa_set_bail(SBR_MEMORY)
        return 0
    out_sz[0] = fsz
    if fsgn != 0:
        out_sgn[0] = 2                            # signed sub-8-byte field
    else:
        out_sgn[0] = 1
    return ssa_addr_plus(base, foff)


# Element byte address for `member[idx]` where `member` (an ND_MEMBER) names a
# POINTER/array field (`c.buf[i]` == `*(c.buf + i*elem)`), writing the element
# width through out_esz and its signedness tristate through out_esgn.  The
# field's pointer VALUE is loaded, then `idx*elem` added.  Returns 0 on bail.
def ssa_member_ptr_index_addr(member: uint32, idxnode: uint32,
                              out_esz: Ptr[uint32], out_esgn: Ptr[uint32]) -> uint32:
    out_esz[0] = 0
    out_esgn[0] = 0
    si: uint32 = 0
    base: uint32 = ssa_member_base_addr(nd_a[member], &si)
    if base == 0 or si == 0:
        return 0
    esgn: uint32 = 0
    esz: uint32 = struct_field_elem(si, nd_name_off[member], nd_name_len[member], &esgn)
    if esz == 0:
        ssa_set_bail(SBR_MEMORY)                  # not a pointer/array field
        return 0
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(si, nd_name_off[member], nd_name_len[member], &foff, &fsgn)
    if fsz == SF_NOFIELD:
        ssa_set_bail(SBR_MEMORY)
        return 0
    faddr: uint32 = ssa_addr_plus(base, foff)
    if faddr == 0:
        return 0
    # An ARRAY field (`buf: Array[N, T]`) stores its elements INLINE — the field
    # ADDRESS is element 0, so index it directly.  A POINTER field (`p: Ptr[T]`)
    # holds an 8-byte address that must be LOADED first.  `struct_field_find`
    # reports fsz==0 for an array field (it decays to its address) and fsz==8 for
    # a pointer field; distinguish on that.  (Loading an array field as a pointer
    # would deref buf[0] as an address — a silent miscompile.)
    ptrval: uint32 = faddr
    if fsz != 0:
        ptrval = ssa_load_at(faddr, 8, 0)
        if ptrval == 0:
            return 0
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    out_esz[0] = esz
    if esgn != 0:
        out_esgn[0] = esgn
    else:
        out_esgn[0] = 1
    scaled: uint32 = idxv
    if esz != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](esz))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = ptrval
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# Lower a member scalar rvalue `obj.field` to its loaded value (LLVM path).
# Returns 0 on bail.
def ssa_lower_member(node: uint32) -> uint32:
    msz: uint32 = 0
    msgn: uint32 = 0
    addr: uint32 = ssa_member_field_addr(node, &msz, &msgn)
    if addr == 0:
        return 0
    if msz == 0:
        return addr                              # array/aggregate field -> address
    return ssa_load_at(addr, msz, msgn)


# =======================================================================
# RECURSIVE LVALUE-ADDRESS LOWERING  (Phase 4b; LLVM path only)
# -----------------------------------------------------------------------
# Compute the byte address of an ARBITRARY nested lvalue — `a.b.c`,
# `e[i]`, `*p`, `&lvalue`, and their compositions — by resolving, at each
# level, a struct-VALUE base + field offset, or a region base + idx*stride,
# bottoming out at ident / global / cast.  The three functions below are
# MUTUALLY RECURSIVE:
#   ssa_region_base    — element-0 address (+ element type) of an indexable
#                        container (array lvalue / pointer value).
#   ssa_struct_base_rec— struct-VALUE base address (+ struct idx) of a
#                        struct-denoting expr, for `obj.field`.
#   ssa_addr_index     — region + idx*stride (leaf arithmetic).
# Everything is gated on ssa_mem_model != 0 (callers gate); the native
# --opt path never reaches them, so codegen.ad byte output is UNCHANGED.
# A shape that cannot be STATICALLY resolved returns 0 WITHOUT setting the
# bail flag (the caller then bails SBR_MEMORY) — a wrong address is a
# silent miscompile, so anything uncertain must bail, never guess.
# =======================================================================

# region + lower(idxnode)*stride as pure pointer arithmetic.  Returns 0 on a
# mid-lowering failure (idx already set the bail flag if it bailed).
def ssa_addr_index(region: uint32, idxnode: uint32, stride: uint32) -> uint32:
    idxv: uint32 = ssa_lower_expr(idxnode, ssa_cur_bb)
    if idxv == 0:
        return 0
    scaled: uint32 = idxv
    if stride != 1:
        sc: uint32 = ssa_const_in(ssa_cur_bb, cast[uint64](stride))
        if sc == 0:
            return 0
        mul: uint32 = sv_new(SVO_BINOP)
        if mul == 0:
            return 0
        sv_aux[mul] = BINOP_MUL
        sv_a[mul] = idxv
        sv_b[mul] = sc
        bb_append(ssa_cur_bb, mul)
        scaled = mul
    addv: uint32 = sv_new(SVO_BINOP)
    if addv == 0:
        return 0
    sv_aux[addv] = BINOP_ADD
    sv_a[addv] = region
    sv_b[addv] = scaled
    sv_type[addv] = SVT_PTR
    bb_append(ssa_cur_bb, addv)
    return addv


# Element-[0][0] byte address of a 2-D array container `arr2d` (`Array[N,
# Array[M, T]]`), writing the OUTER row stride (inner-array byte size) via
# out_rowstride and the INNER element classification (struct idx via out_struct,
# or scalar width/sign via out_esz/out_esgn).  Handles a 2-D array MEMBER field
# (`obj.arr2d`) and a 2-D array GLOBAL (`g`).  Returns 0 (no bail) for anything
# else.  LLVM path only (reached solely from ssa_region_base's ND_INDEX case,
# whose callers gate on ssa_mem_model != 0).
def ssa_array2d_base(arr2d: uint32, out_rowstride: Ptr[uint32], out_struct: Ptr[uint32],
                     out_esz: Ptr[uint32], out_esgn: Ptr[uint32]) -> uint32:
    out_rowstride[0] = 0
    out_struct[0] = 0
    out_esz[0] = 0
    out_esgn[0] = 0
    k: uint32 = nd_kind[arr2d]
    if k == ND_IDENT:
        # 2-D scalar-array global: base = its symbol addr.
        gi: uint32 = ssa_global_array_2d(nd_name_off[arr2d], nd_name_len[arr2d])
        if gi == 0:
            return 0
        es: uint32 = glob_elem_size[gi - 1]
        innerT: uint32 = nd_a[glob_type_node[gi - 1]]
        m: uint32 = cast[uint32](nd_num[innerT])
        out_rowstride[0] = m * es
        out_esz[0] = es
        out_esgn[0] = ssa_array2_elem_sgn(gi)
        return ssa_globaladdr(gi, ssa_cur_bb)
    if k == ND_MEMBER:
        # 2-D array FIELD of a struct: base = struct base + field offset.
        sa: uint32 = 0
        sbase: uint32 = ssa_struct_base_rec(nd_a[arr2d], &sa)
        if sbase == 0 or sa == 0:
            return 0
        tnode: uint32 = struct_field_type_node(sa, nd_name_off[arr2d], nd_name_len[arr2d])
        if tnode == 0 or nd_kind[tnode] != ND_ARRAY_TYPE:
            return 0
        innerA: uint32 = nd_a[tnode]
        if innerA == 0 or nd_kind[innerA] != ND_ARRAY_TYPE:
            return 0                              # not 2-D
        if nd_kind[nd_a[innerA]] == ND_ARRAY_TYPE:
            return 0                              # 3-D+ -> defer
        foff: uint32 = 0
        fsgn: uint32 = 0
        struct_field_find(sa, nd_name_off[arr2d], nd_name_len[arr2d], &foff, &fsgn)
        faddr: uint32 = ssa_addr_plus(sbase, foff)
        if faddr == 0:
            return 0
        out_rowstride[0] = type_size_of(innerA)   # inner array byte size = M*es
        elemT: uint32 = nd_a[innerA]
        esi: uint32 = struct_lookup_by_node(elemT)
        if esi != 0:
            out_struct[0] = esi
            return faddr
        if type_float_width(elemT) != 0:
            return 0
        es2: uint32 = prim_type_size(elemT)
        if es2 != 1 and es2 != 2 and es2 != 4 and es2 != 8:
            return 0
        out_esz[0] = es2
        out_esgn[0] = type_signedness(elemT)
        return faddr
    return 0


# Element-0 byte address of the indexable container `base` (an array lvalue or a
# pointer value), writing the element STRIDE (bytes) via out_stride and EITHER
# the element struct index (+1) via out_struct (struct elements) OR the element
# scalar width/signedness via out_esz/out_esgn (scalar elements).  Returns 0
# (no bail) when `base` is not a statically-resolvable machine container.
def ssa_region_base(base: uint32, out_stride: Ptr[uint32], out_struct: Ptr[uint32],
                    out_esz: Ptr[uint32], out_esgn: Ptr[uint32]) -> uint32:
    out_stride[0] = 0
    out_struct[0] = 0
    out_esz[0] = 0
    out_esgn[0] = 0
    k: uint32 = nd_kind[base]
    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[base], nd_name_len[base])
        if nid < NM_MAX and ssa_islocal[nid] != 0:
            # local Ptr[Struct]: region = the pointer VALUE.
            if ssa_local_struct[nid] != 0 and ssa_local_struct_is_ptr[nid] != 0:
                si: uint32 = ssa_local_struct[nid]
                out_struct[0] = si
                out_stride[0] = st_total[si - 1]
                if ssa_ismem[nid] != 0:
                    return ssa_load_at(ssa_mem_addr[nid], 8, 0)
                return ssa_read_var(nid, ssa_cur_bb)
            # local scalar pointer: region = the pointer VALUE.
            if ssa_ptr_esz[nid] != 0:
                out_esz[0] = ssa_ptr_esz[nid]
                out_esgn[0] = ssa_ptr_esgn[nid]
                out_stride[0] = ssa_ptr_esz[nid]
                if ssa_ismem[nid] != 0:
                    return ssa_load_at(ssa_mem_addr[nid], 8, 0)
                return ssa_read_var(nid, ssa_cur_bb)
            # local scalar array: region = the alloca address.
            if ssa_ismem[nid] != 0 and ssa_mem_isarr[nid] != 0:
                out_esz[0] = ssa_mem_esz[nid]
                out_esgn[0] = ssa_mem_esgn[nid]
                out_stride[0] = ssa_mem_esz[nid]
                return ssa_mem_addr[nid]
            return 0
        # GLOBAL container.
        gi: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
        if gi == 0 or glob_is_percpu[gi - 1] != 0:
            return 0
        tn: uint32 = glob_type_node[gi - 1]
        if tn != 0 and nd_kind[tn] == ND_ARRAY_TYPE:
            elem: uint32 = nd_a[tn]
            if nd_kind[elem] == ND_ARRAY_TYPE:
                return 0                          # multi-dim -> defer
            esi: uint32 = struct_lookup_by_node(elem)
            if esi != 0:
                out_struct[0] = esi
                out_stride[0] = st_total[esi - 1]
                return ssa_globaladdr(gi, ssa_cur_bb)
            ges: uint32 = glob_elem_size[gi - 1]
            if ges != 1 and ges != 2 and ges != 4 and ges != 8:
                return 0
            out_esz[0] = ges
            out_esgn[0] = type_signedness(elem)
            out_stride[0] = ges
            return ssa_globaladdr(gi, ssa_cur_bb)
        if tn != 0 and nd_kind[tn] == ND_PTR_TYPE:
            pointee: uint32 = nd_a[tn]
            psi: uint32 = struct_lookup_by_node(pointee)
            pv: uint32 = ssa_global_load(gi, ssa_cur_bb)
            if pv == 0:
                return 0
            if psi != 0:
                out_struct[0] = psi
                out_stride[0] = st_total[psi - 1]
                return pv
            gps: uint32 = glob_ptr_size[gi - 1]
            if gps != 1 and gps != 2 and gps != 4 and gps != 8:
                return 0
            out_esz[0] = gps
            out_esgn[0] = ssa_global_ptr_esgn(gi)
            out_stride[0] = gps
            return pv
        return 0
    if k == ND_MEMBER:
        # container is a FIELD of struct(nd_a[base]) — an array-of-X field
        # (region = field address) or a Ptr[X] field (region = loaded pointer).
        sa: uint32 = 0
        psba: uint32 = ssa_struct_base_rec(nd_a[base], &sa)
        if psba == 0 or sa == 0:
            return 0
        foff: uint32 = 0
        fsgn: uint32 = 0
        fsz: uint32 = struct_field_find(sa, nd_name_off[base], nd_name_len[base], &foff, &fsgn)
        if fsz == SF_NOFIELD:
            return 0
        faddr: uint32 = ssa_addr_plus(psba, foff)
        if faddr == 0:
            return 0
        esgn2: uint32 = 0
        esize: uint32 = struct_field_elem(sa, nd_name_off[base], nd_name_len[base], &esgn2)
        estr: uint32 = struct_field_elem_struct(sa, nd_name_off[base], nd_name_len[base])
        tnode: uint32 = struct_field_type_node(sa, nd_name_off[base], nd_name_len[base])
        if tnode != 0 and nd_kind[tnode] == ND_ARRAY_TYPE:
            # ARRAY field: the field address IS element 0.
            if nd_kind[nd_a[tnode]] == ND_ARRAY_TYPE:
                return 0                          # multi-dim member array -> defer
            if estr != 0:
                out_struct[0] = estr
                out_stride[0] = st_total[estr - 1]
                return faddr
            if esize != 1 and esize != 2 and esize != 4 and esize != 8:
                return 0
            out_esz[0] = esize
            if esgn2 != 0:
                out_esgn[0] = esgn2
            else:
                out_esgn[0] = 1
            out_stride[0] = esize
            return faddr
        if esize != 0:
            # POINTER field (Ptr[X]): region = the loaded pointer value.
            pv2: uint32 = ssa_load_at(faddr, 8, 0)
            if pv2 == 0:
                return 0
            if estr != 0:
                out_struct[0] = estr
                out_stride[0] = st_total[estr - 1]
                return pv2
            if esize != 1 and esize != 2 and esize != 4 and esize != 8:
                return 0
            out_esz[0] = esize
            if esgn2 != 0:
                out_esgn[0] = esgn2
            else:
                out_esgn[0] = 1
            out_stride[0] = esize
            return pv2
        return 0
    if k == ND_CAST:
        # cast[Ptr[X]](expr): region = the forwarded pointer value.
        dt: uint32 = nd_a[base]
        if dt == 0 or nd_kind[dt] != ND_PTR_TYPE:
            return 0
        cpointee: uint32 = nd_a[dt]
        return ssa_region_from_ptr(base, cpointee, out_stride, out_struct, out_esz, out_esgn)
    if k == ND_CALL:
        # A call returning `Ptr[X]` (`_pgrp_ptr(p)[i].field`): region = the call
        # VALUE (a pointer), typed by the callee's declared return pointee.
        callee: uint32 = nd_a[base]
        if callee == 0 or nd_kind[callee] != ND_IDENT:
            return 0
        rt: uint32 = ssa_callee_ret_node(nd_name_off[callee], nd_name_len[callee])
        if rt == 0 or nd_kind[rt] != ND_PTR_TYPE:
            return 0
        return ssa_region_from_ptr(base, nd_a[rt], out_stride, out_struct, out_esz, out_esgn)
    if k == ND_INDEX:
        # `inner[i]` where inner is a 2-D array container (`Array[N, Array[M,
        # T]]`): the container region is the address of ROW i (an inner array),
        # whose element stride/type is the INNER dimension.  Handles the
        # multi-dim MEMBER array (`obj.arr2d[i][j]`) and global 2-D case.
        rows: uint32 = 0
        i2sz: uint32 = 0
        i2sgn: uint32 = 0
        i2st: uint32 = 0
        a2b: uint32 = ssa_array2d_base(nd_a[base], &rows, &i2st, &i2sz, &i2sgn)
        if a2b == 0:
            return 0
        rowaddr: uint32 = ssa_addr_index(a2b, nd_b[base], rows)
        if rowaddr == 0:
            return 0
        out_struct[0] = i2st
        out_esz[0] = i2sz
        out_esgn[0] = i2sgn
        if i2st != 0:
            out_stride[0] = st_total[i2st - 1]
        else:
            out_stride[0] = i2sz
        return rowaddr
    return 0


# Shared tail for a POINTER-valued container expr `base` whose pointee type node
# is `pointee`: lower `base` to its pointer value and classify the element
# (struct / pointer / scalar).  Returns 0 (no bail) when the pointee is not a
# machine-scalar / struct / pointer.
def ssa_region_from_ptr(base: uint32, pointee: uint32, out_stride: Ptr[uint32],
                        out_struct: Ptr[uint32], out_esz: Ptr[uint32],
                        out_esgn: Ptr[uint32]) -> uint32:
    if pointee == 0:
        return 0
    psi: uint32 = struct_lookup_by_node(pointee)
    pv: uint32 = ssa_lower_expr(base, ssa_cur_bb)
    if pv == 0:
        return 0
    if psi != 0:
        out_struct[0] = psi
        out_stride[0] = st_total[psi - 1]
        return pv
    if nd_kind[pointee] == ND_PTR_TYPE:
        out_esz[0] = 8
        out_esgn[0] = 1
        out_stride[0] = 8
        return pv
    if type_float_width(pointee) != 0:
        return 0
    ps: uint32 = prim_type_size(pointee)
    if ps != 1 and ps != 2 and ps != 4 and ps != 8:
        return 0
    out_esz[0] = ps
    out_esgn[0] = type_signedness(pointee)
    out_stride[0] = ps
    return pv


# Struct-VALUE base address of a struct-denoting expr `obj` (for `obj.field`),
# writing the struct table index (+1) via out_struct.  For an in-place struct
# lvalue this is its storage address; for a Ptr[Struct] this is the pointer
# VALUE.  Recurses through nested members / indices / derefs.  Returns 0 (no
# bail) when the struct type cannot be resolved.
def ssa_struct_base_rec(obj: uint32, out_struct: Ptr[uint32]) -> uint32:
    out_struct[0] = 0
    k: uint32 = nd_kind[obj]
    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[obj], nd_name_len[obj])
        if nid < NM_MAX and ssa_islocal[nid] != 0:
            if ssa_local_struct[nid] == 0:
                return 0
            out_struct[0] = ssa_local_struct[nid]
            if ssa_local_struct_is_ptr[nid] != 0:
                if ssa_ismem[nid] != 0:
                    return ssa_load_at(ssa_mem_addr[nid], 8, 0)
                return ssa_read_var(nid, ssa_cur_bb)
            if ssa_ismem[nid] != 0:
                return ssa_mem_addr[nid]
            return 0
        # module-scope in-place `Struct` global (its symbol addr IS the base).
        return ssa_global_struct_base(nd_name_off[obj], nd_name_len[obj], out_struct)
    if k == ND_MEMBER:
        # a.b : field b (an embedded struct value or a Ptr[Struct]) of struct(a).
        sa: uint32 = 0
        psba: uint32 = ssa_struct_base_rec(nd_a[obj], &sa)
        if psba == 0 or sa == 0:
            return 0
        isptr: uint32 = 0
        sfi: uint32 = struct_field_struct(sa, nd_name_off[obj], nd_name_len[obj], &isptr)
        if sfi == 0:
            return 0                              # field is not a struct/Ptr[struct]
        foff: uint32 = 0
        fsgn: uint32 = 0
        struct_field_find(sa, nd_name_off[obj], nd_name_len[obj], &foff, &fsgn)
        faddr: uint32 = ssa_addr_plus(psba, foff)
        if faddr == 0:
            return 0
        out_struct[0] = sfi
        if isptr != 0:
            return ssa_load_at(faddr, 8, 0)       # Ptr[Struct] field -> pointer value
        return faddr                              # embedded struct value -> its address
    if k == ND_UNARY and nd_aux[obj] == UNOP_DEREF:
        # (*p).field : p is Ptr[Struct]; the struct base is p's pointer VALUE.
        stride: uint32 = 0
        esz: uint32 = 0
        esgn: uint32 = 0
        region: uint32 = ssa_region_base(nd_a[obj], &stride, out_struct, &esz, &esgn)
        if region == 0 or out_struct[0] == 0:
            out_struct[0] = 0
            return 0
        return region
    if k == ND_INDEX:
        # base[i].field : base[i] is a struct ELEMENT of the container `base`.
        stride2: uint32 = 0
        esz2: uint32 = 0
        esgn2: uint32 = 0
        region2: uint32 = ssa_region_base(nd_a[obj], &stride2, out_struct, &esz2, &esgn2)
        if region2 == 0 or out_struct[0] == 0:
            out_struct[0] = 0
            return 0
        return ssa_addr_index(region2, nd_b[obj], stride2)
    if k == ND_CAST:
        # cast[Ptr[Struct]](x) used directly as a struct base.
        dt: uint32 = nd_a[obj]
        if dt == 0 or nd_kind[dt] != ND_PTR_TYPE:
            return 0
        csi: uint32 = struct_lookup_by_node(nd_a[dt])
        if csi == 0:
            return 0
        cv: uint32 = ssa_lower_expr(obj, ssa_cur_bb)
        if cv == 0:
            return 0
        out_struct[0] = csi
        return cv
    return 0


# Byte address of a general ND_INDEX lvalue `node = base[i]` (any container),
# for `&base[i]`.  Reuses the recursive region resolver.  Returns 0 (no bail)
# when the container is not statically resolvable.
def ssa_index_addr_general(node: uint32) -> uint32:
    stride: uint32 = 0
    si: uint32 = 0
    esz: uint32 = 0
    esgn: uint32 = 0
    region: uint32 = ssa_region_base(nd_a[node], &stride, &si, &esz, &esgn)
    if region == 0:
        return 0
    return ssa_addr_index(region, nd_b[node], stride)


# SIZED variant of ssa_index_addr_general for the STORE path: the element byte
# address of `node = base[i]` PLUS its SCALAR element width/signedness (via
# out_esz/out_esgn) so the caller can emit a correctly-sized store.  Only SCALAR
# (machine-width) elements are handled — a struct element store needs a field
# path, so it returns 0 (no bail).  Returns 0 when `base` is not region-
# resolvable or the element is not a machine scalar.  LLVM path only.
def ssa_general_index_addr_sized(node: uint32, out_esz: Ptr[uint32],
                                 out_esgn: Ptr[uint32], out_fw: Ptr[uint32]) -> uint32:
    out_esz[0] = 0
    out_esgn[0] = 0
    out_fw[0] = 0
    stride: uint32 = 0
    si: uint32 = 0
    esz: uint32 = 0
    esgn: uint32 = 0
    region: uint32 = ssa_region_base(nd_a[node], &stride, &si, &esz, &esgn)
    if region == 0:
        return 0
    if si != 0:
        return 0                                  # struct element -> defer (no field here)
    if esz != 1 and esz != 2 and esz != 4 and esz != 8:
        return 0
    addr: uint32 = ssa_addr_index(region, nd_b[node], stride)
    if addr == 0:
        return 0
    out_esz[0] = esz
    out_esgn[0] = esgn
    return addr


# Lower `&operand` to the operand's ADDRESS value (no load).  LLVM path only
# (the sole caller gates on ssa_mem_model != 0).  Modeled forms:
#   &local            (a memory-modeled scalar/array local -> its alloca addr)
#   &arr[i]           (a memory-array LOCAL -> element addr)
#   &global           (a scalar/array GLOBAL -> the LLVM symbol's address; the
#                      emitter recovers the [N x i8] symbol from (offset,is_bss))
#   &global[i]        (a 1-D scalar-element global array -> element addr)
# On the native path (ssa_mem_model==0) this is never reached, so the native
# subset is unchanged.  Returns 0 on bail.
def ssa_lower_addr_of(operand: uint32) -> uint32:
    k: uint32 = nd_kind[operand]
    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[operand], nd_name_len[operand])
        if nid < NM_MAX and ssa_islocal[nid] != 0:
            if ssa_ismem[nid] != 0:
                return ssa_mem_addr[nid]
            ssa_set_bail(SBR_MEMORY)
            return 0
        # &global (scalar or aggregate): the RIP-relative symbol address.  Any
        # non-percpu global qualifies — ssa_globaladdr encodes (byte-offset,
        # is_bss), which the emitter reverse-maps to the [N x i8] @symbol.
        gi: uint32 = glob_lookup(nd_name_off[operand], nd_name_len[operand])
        if gi != 0 and glob_is_percpu[gi - 1] == 0:
            return ssa_globaladdr(gi, ssa_cur_bb)
        if gi != 0:
            ssa_set_bail(SBR_MEMORY)                    # &percpu -> deliberately bails
            return 0
        # `&function`: the function symbol's address (LLVM path only).  A known
        # ND_FUNCTION name lowers to `ptrtoint ptr @name to i64`; an unknown
        # ident still bails (a wrong address is a silent miscompile).
        if ssa_mem_model != 0 and ssa_is_function(nd_name_off[operand], nd_name_len[operand]) != 0:
            return ssa_funcaddr(operand, ssa_cur_bb)
        ssa_set_bail(SBR_MEMORY)                        # unknown symbol
        return 0
    if k == ND_INDEX:
        base: uint32 = nd_a[operand]
        # &g[i][j] : element address of a 2-D scalar-element global array.
        if ssa_mem_model != 0 and nd_kind[base] == ND_INDEX and nd_kind[nd_a[base]] == ND_IDENT:
            g2a: uint32 = ssa_global_array_2d(nd_name_off[nd_a[base]], nd_name_len[nd_a[base]])
            if g2a != 0:
                return ssa_index2_addr(g2a, operand)
        if nd_kind[base] != ND_IDENT:
            # Phase 4b: `&expr[i]` with a computed / member / deref index base.
            if ssa_mem_model != 0:
                ga: uint32 = ssa_index_addr_general(operand)
                if ga != 0:
                    return ga
            ssa_set_bail(SBR_MEMORY)
            return 0
        bnid: uint32 = nm_intern(nd_name_off[base], nd_name_len[base])
        if bnid < NM_MAX and ssa_islocal[bnid] != 0 and ssa_ismem[bnid] != 0 and ssa_mem_isarr[bnid] != 0:
            return ssa_local_index_addr(bnid, nd_b[operand])
        # &p[i] on a POINTER local/param: p + i*elem (no load).
        if bnid < NM_MAX and ssa_islocal[bnid] != 0 and ssa_ptr_esz[bnid] != 0:
            return ssa_ptr_index_addr(bnid, nd_b[operand])
        # &global[i] : element address of a 1-D scalar-element global array,
        # built as base(GLOBALADDR) + idx*elem_size (the same shape a global
        # array rvalue index uses).
        ggi: uint32 = ssa_global_array_1d(nd_name_off[base], nd_name_len[base])
        if ggi != 0:
            return ssa_index_addr(ggi, nd_b[operand])
        # &gptr[i] on a GLOBAL Ptr[T]: (loaded pointer value) + i*elem, no load.
        gpg2: uint32 = 0
        gpe2: uint32 = ssa_global_ptr_esz(nd_name_off[base], nd_name_len[base], &gpg2)
        if ssa_mem_model != 0 and gpe2 != 0:
            return ssa_global_ptr_index_addr(gpg2, nd_b[operand], gpe2)
        # Phase 4b: `&g[i]` on any other recognised container (local struct
        # array, global Ptr[Struct], ...) via the recursive region resolver.
        if ssa_mem_model != 0:
            ga2: uint32 = ssa_index_addr_general(operand)
            if ga2 != 0:
                return ga2
        ssa_set_bail(SBR_MEMORY)
        return 0
    # Phase 4b: `&obj.field` — the member's field address (no load).  Works for
    # scalar, array (decays), and nested-struct fields.
    if ssa_mem_model != 0 and k == ND_MEMBER:
        msz: uint32 = 0
        msgn: uint32 = 0
        maddr: uint32 = ssa_member_field_addr(operand, &msz, &msgn)
        if maddr != 0:
            return maddr
        return 0                                  # member_field_addr set the bail
    # Phase 4b: `&*p` == the pointer VALUE of a resolvable pointer expr.
    if ssa_mem_model != 0 and k == ND_UNARY and nd_aux[operand] == UNOP_DEREF:
        if ssa_deref_esz(nd_a[operand]) != 0:
            return ssa_lower_expr(nd_a[operand], ssa_cur_bb)
        st3: uint32 = 0
        s3: uint32 = 0
        e3: uint32 = 0
        g3: uint32 = 0
        rp: uint32 = ssa_region_base(nd_a[operand], &st3, &s3, &e3, &g3)
        if rp != 0:
            return rp
        ssa_set_bail(SBR_MEMORY)
        return 0
    ssa_set_bail(SBR_MEMORY)
    return 0


# Build the SVO_BINOP for an augmented assignment `x op= e` == `x op e`, setting
# the div/mod/shr signedness hint (sv_c) from the operand AST nodes exactly as the
# ND_BINARY path does (lnode = the target value operand, rnode = the RHS expr).
def ssa_build_aug_binop(aug: uint32, cur: uint32, rhs: uint32, lnode: uint32,
                        rnode: uint32, stmt: uint32, bb: uint32) -> uint32:
    v5: uint32 = sv_new(SVO_BINOP)
    if v5 == 0:
        return 0
    sv_aux[v5] = aug
    sv_a[v5] = cur
    sv_b[v5] = rhs
    sv_ast[v5] = stmt
    if ssa_val_fw(cur) != 0:
        # float `x op= e`: result carries the float type; emission picks fadd/... .
        sv_type[v5] = sv_type[cur]
        bb_append(bb, v5)
        return v5
    if aug == BINOP_DIV or aug == BINOP_IDIV or aug == BINOP_MOD:
        sv_c[v5] = binop_use_signed(ssa_shr_value_sgn(lnode), ssa_shr_value_sgn(rnode))
    elif aug == BINOP_SHR:
        if ssa_shr_value_sgn(lnode) == 2:
            sv_c[v5] = 1
        else:
            sv_c[v5] = 0
    bb_append(bb, v5)
    return v5


# Emit a full-width integer constant `imm` into block `bb`, returning its vid.
def ssa_const_in(bb: uint32, imm: uint64) -> uint32:
    c: uint32 = sv_new(SVO_CONST)
    if c == 0:
        return 0
    sv_imm[c] = imm
    bb_append(bb, c)
    return c


# Lower a short-circuit `L and R` / `L or R` to control flow + a join phi that
# yields the 0/1 BOOLEAN result — matching the legacy backend's gen_short_circuit
# exactly (result is 0/1, NOT the operand value, and R is evaluated ONLY when L
# does not already decide the result).  Advances ssa_cur_bb to the join block.
#
# Layout (both forms): eval L in the current block bL; a two-way branch on L's
# truthiness; eval R in rbb (its own current block bR) under a second truthiness
# branch; a `true` block (const 1) and a `false` block (const 0) merge at `join`
# via a phi.  For `and`, L-false shortcuts to the false block; for `or`, L-true
# shortcuts to the true block.
def ssa_lower_shortcircuit(node: uint32, op: uint32) -> uint32:
    lv: uint32 = ssa_lower_expr(nd_a[node], ssa_cur_bb)
    if lv == 0:
        return 0
    bL: uint32 = ssa_cur_bb                       # block L's value landed in
    rbb: uint32 = bb_new_ssa()
    if rbb == 0:
        return 0
    tbb: uint32 = bb_new_ssa()
    if tbb == 0:
        return 0
    fbb: uint32 = bb_new_ssa()
    if fbb == 0:
        return 0
    join: uint32 = bb_new_ssa()
    if join == 0:
        return 0
    if op == BINOP_AND:
        # L truthy -> evaluate R; L falsy -> result false.
        ssa_terminate_condbr(bL, lv, rbb, fbb)
    else:
        # L truthy -> result true; L falsy -> evaluate R.
        ssa_terminate_condbr(bL, lv, tbb, rbb)
    # R arm.
    ssa_seal_block(rbb)                           # single pred: bL
    ssa_cur_bb = rbb
    rv: uint32 = ssa_lower_expr(nd_b[node], rbb)
    if rv == 0:
        return 0
    bR: uint32 = ssa_cur_bb                       # block R's value landed in
    # R truthy -> true block; R falsy -> false block (both forms).
    ssa_terminate_condbr(bR, rv, tbb, fbb)
    if ssa_bail != 0:
        return 0
    # true block: const 1 -> join.
    ssa_seal_block(tbb)
    c1: uint32 = ssa_const_in(tbb, cast[uint64](1))
    if c1 == 0:
        return 0
    sv_type[c1] = SVT_I1
    ssa_terminate_br(tbb, join)
    # false block: const 0 -> join.
    ssa_seal_block(fbb)
    c0: uint32 = ssa_const_in(fbb, cast[uint64](0))
    if c0 == 0:
        return 0
    sv_type[c0] = SVT_I1
    ssa_terminate_br(fbb, join)
    if ssa_bail != 0:
        return 0
    # join: phi selects 1 (true path) or 0 (false path).
    ssa_seal_block(join)
    phi: uint32 = sv_new(SVO_PHI)
    if phi == 0:
        return 0
    bb_prepend(join, phi)
    sv_type[phi] = SVT_I1
    phi_add_operand(phi, tbb, c1)
    phi_add_operand(phi, fbb, c0)
    ssa_cur_bb = join
    return phi


# Lower a direct call `node`.  `result_used` = 0 when the call is in
# expression-statement position (its return value is discarded): in that case the
# %rax/xmm0 width of the callee return is irrelevant, so a narrow / float / void
# callee is accepted (only its side effect matters).  `result_used` = 1 requires
# the callee to return a full-width non-float integer (so the SVO_CALL value read
# from %rax is well-defined).  Returns the SVO_CALL vid (0 on bail).
def ssa_lower_call(node: uint32, result_used: uint32) -> uint32:
    # Direct call to a named function only.  Callee (nd_a) must be a bare
    # ident that is NOT a local (a function symbol); args are lowered values.
    callee: uint32 = nd_a[node]
    if callee == 0 or nd_kind[callee] != ND_IDENT:
        ssa_set_bail(SBR_NONSUBSET_EXPR)
        return 0
    cid: uint32 = nm_intern(nd_name_off[callee], nd_name_len[callee])
    # INDIRECT call through a function-POINTER value (LLVM path only): the callee
    # is either a LOCAL fn-pointer variable (`p()`) or a MODULE-SCOPE global
    # fn-pointer variable (`hook()`, e.g. kmod_linux_load_hook).  Lower the callee
    # to its i64 pointer VALUE and mark the SVO_CALL indirect (sv_b = value vid);
    # the emitter renders `inttoptr i64 <val> to ptr` + a `call` through it.  The
    # native path (ssa_mem_model==0) is UNCHANGED — a local fn-pointer still bails
    # and a global-fn-pointer call still lowers directly in codegen.ad.
    callee_val: uint32 = 0
    if cid < NM_MAX and ssa_islocal[cid] != 0:
        if ssa_mem_model == 0:
            # calling through a local (fn-pointer) -> bail (indirect not modeled).
            ssa_set_bail(SBR_NONSUBSET_EXPR)
            return 0
        callee_val = ssa_lower_expr(callee, ssa_cur_bb)
        if callee_val == 0:
            return 0
    elif ssa_mem_model != 0 and glob_lookup(nd_name_off[callee], nd_name_len[callee]) != 0:
        # A global VARIABLE (not a function) invoked as a call == a global
        # fn-pointer; load its 8-byte value and call through it.
        callee_val = ssa_lower_expr(callee, ssa_cur_bb)
        if callee_val == 0:
            return 0
    # `asm_volatile("<text>")` is a ZERO-OPERAND inline-asm builtin.  On the
    # native path codegen.ad lowers it to verbatim bytes, so this LLVM-only
    # (ssa_mem_model != 0) special-case is byte-neutral there.  Without it the
    # generic call path below emits a bogus `call i64 @asm_volatile(i64 <str>)`
    # to a nonexistent symbol (a SILENT MISCOMPILE).  Instead park an
    # SVO_INLINEASM carrying the call node; the string-literal arg is NOT lowered
    # (no GLOBALADDR / no @asm_volatile call).  The result is void (statement
    # position only — the Adder asm_volatile form yields no value; the kernel
    # parks any output in RIP-relative globals).
    if ssa_mem_model != 0 and name_eq_cstr(nd_name_off[callee], nd_name_len[callee], "asm_volatile") != 0:
        # Require exactly one string-literal argument; anything else bails so we
        # never emit malformed inline asm.
        astr: uint32 = nd_b[node]
        if astr == 0 or nd_kind[astr] != ND_STRING_LIT or nd_next[astr] != 0:
            ssa_set_bail(SBR_NONSUBSET_EXPR)
            return 0
        iv: uint32 = sv_new(SVO_INLINEASM)
        if iv == 0:
            return 0
        sv_ast[iv] = node
        bb_append(ssa_cur_bb, iv)
        return iv
    # `__syscallN(num, a1..aN)` is an INLINE builtin that codegen.ad lowers to a
    # raw x86 `syscall` — there is no linkable symbol for it, so the LLVM emit
    # path (which would emit a `call @__syscallN` to a nonexistent symbol) must
    # bail.  LLVM-path only (ssa_mem_model != 0); the native path is unchanged.
    # (Before the &global widening this was unreachable — the address argument
    # bailed first — so an emittable print/IO helper stays a runtime `declare`.)
    if ssa_mem_model != 0 and syscall_builtin_args(nd_name_off[callee], nd_name_len[callee]) != 0:
        ssa_set_bail(SBR_CALL)
        return 0
    # When the result IS consumed, the call lands in %rax full-width; it is only
    # correct if the callee is an in-unit function returning a full-width non-float
    # integer.  Extern / narrow / float / unknown callees bail.  When the result
    # is DISCARDED (statement call), the return width does not matter, so any
    # direct callee is accepted for its side effect.
    cfw: uint32 = 0
    if result_used != 0:
        if ssa_callee_rettype_ok(nd_name_off[callee], nd_name_len[callee]) == 0:
            # A float-returning in-unit callee is accepted on the LLVM path (the
            # result lands in xmm0 and is typed float).
            cfw = ssa_callee_ret_fw(nd_name_off[callee], nd_name_len[callee])
            if ssa_mem_model == 0:
                ssa_set_bail(SBR_CALL)        # native path: unchanged (bails)
                return 0
            # LLVM path: an extern / narrow-int / unknown callee is modeled as an
            # i64 result — its `declare` is i64 and a narrow assignment truncates
            # (e.g. `fd: int32 = sys_open(...)`), so the upper bits are discarded.
            # (cfw != 0 keeps the in-unit float typing below.)
    cv: uint32 = sv_new(SVO_CALL)
    if cv == 0:
        return 0
    sv_ast[cv] = node
    sv_b[cv] = callee_val                      # 0 => direct; else indirect through this fn-ptr value
    if cfw != 0:
        sv_type[cv] = ssa_fw_svt(cfw)         # float-returning call result type
    # lower args left-to-right; store on the use-list (order-independent for
    # verification; the call node retains argument AST for future lowering).
    arg: uint32 = nd_b[node]
    argc: uint32 = 0
    while arg != 0:
        av: uint32 = ssa_lower_expr(arg, ssa_cur_bb)
        if av == 0:
            return 0
        phi_add_operand(cv, 0, av)
        argc = argc + 1
        arg = nd_next[arg]
    # >6 args need SysV stack marshalling (args 7+ on the stack).  The native
    # hand-x86 path only spills the 6 register args, so it still bails.  On the
    # LLVM path (ssa_mem_model != 0) LLVM's calling-convention lowering handles
    # any arity, so the SVO_CALL is emitted with all operands.
    if argc > 6 and ssa_mem_model == 0:
        ssa_set_bail(SBR_MANYARGS)
        return 0
    sv_aux[cv] = argc
    bb_append(ssa_cur_bb, cv)
    return cv


# Register the interned string literal at strbuf[src_off..src_off+len) as a data
# GLOBAL so the OPTIONAL LLVM backend (ssa_llvm.ad) can take its address via
# SVO_GLOBALADDR — which reverse-maps a (byte-offset, is_bss) pair back to a
# `[N x i8] @symbol` — and emit its raw bytes.  Returns the 1-based global index.
# Deduped: identical literals share ONE gdata slot AND one global entry (so the
# Pass-A discovery / Pass-B emit round-trip in llvm_emit_program is idempotent).
#
# ISOLATION: lives in ssa.ad (codegen.ad stays byte-unchanged) and is only ever
# reached from ND_STRING_LIT lowering when ssa_mem_model != 0 (the LLVM path);
# the native/seed codegen never calls it, so the default globals table is
# untouched.  The synthetic `.LstrN` symbol name is not a legal Adder identifier,
# so it can never collide with a real global lookup.
def ssa_intern_string_global(src_off: uint32, src_len: uint32) -> uint32:
    doff: uint32 = intern_string(src_off, src_len)     # dedup -> gdata offset
    total: uint32 = src_len + 1                         # bytes incl. trailing NUL
    # Reuse an existing string-global entry pointing at the same data slot.
    i: uint32 = 0
    while i < glob_count:
        if glob_offset[i] == doff and glob_elem_size[i] == total and glob_scalar_size[i] == 0 and glob_is_bss[i] == 0 and glob_type_node[i] == 0:
            return i + 1
        i = i + 1
    # Synthesize a unique `.Lstr<glob_count>` symbol into strbuf.
    name_off: uint32 = strbuf_pos
    strbuf_append(cast[uint8](46))                      # '.'
    strbuf_append(cast[uint8](76))                      # 'L'
    strbuf_append(cast[uint8](115))                     # 's'
    strbuf_append(cast[uint8](116))                     # 't'
    strbuf_append(cast[uint8](114))                     # 'r'
    n: uint32 = glob_count
    if n == 0:
        strbuf_append(cast[uint8](48))                  # '0'
    else:
        digs: Array[16, uint8]
        dn: uint32 = 0
        while n > 0:
            digs[dn] = cast[uint8](48 + (n % 10))
            dn = dn + 1
            n = n / 10
        while dn > 0:
            dn = dn - 1
            strbuf_append(digs[dn])
    name_len: uint32 = strbuf_pos - name_off
    gi0: uint32 = glob_count
    glob_define(name_off, name_len, doff, total, 0)
    return gi0 + 1


def ssa_lower_expr(node: uint32, bb: uint32) -> uint32:
    if ssa_bail != 0:
        return 0
    if node == 0:
        return 0
    # The block a subexpression's value lands in is ssa_cur_bb (threaded across
    # short-circuit CFG splits), NOT the stale `bb` argument.  Callers seed
    # ssa_cur_bb; recursion below passes ssa_cur_bb so a nested short-circuit that
    # advanced control is observed by the parent.
    k: uint32 = nd_kind[node]

    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT:
        v: uint32 = sv_new(SVO_CONST)
        if v == 0:
            return 0
        sv_imm[v] = nd_num[node]
        sv_ast[v] = node
        if k == ND_BOOL_LIT:
            sv_type[v] = SVT_I1
        bb_append(ssa_cur_bb, v)
        return v

    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[node], nd_name_len[node])
        if nid >= NM_MAX:
            ssa_set_bail(SBR_OVERFLOW)
            return 0
        if ssa_islocal[nid] == 0:
            # Not a known local: a scalar global reads via a RIP-relative load;
            # a percpu scalar reads via a %gs-relative (addrspace 256) load on
            # the LLVM path; anything else (aggregate/array global, function
            # name, unknown) bails.
            if ssa_mem_model != 0:
                pgi: uint32 = ssa_percpu_scalar(nd_name_off[node], nd_name_len[node])
                if pgi != 0:
                    return ssa_percpu_load(pgi, ssa_cur_bb)
            gi: uint32 = ssa_scalar_global(nd_name_off[node], nd_name_len[node])
            if gi != 0:
                return ssa_global_load(gi, ssa_cur_bb)
            # A bare FUNCTION name used as an rvalue decays to its address (a
            # function pointer): `register_hook(the_fn)`.  LLVM path only.
            if ssa_mem_model != 0 and ssa_is_function(nd_name_off[node], nd_name_len[node]) != 0:
                return ssa_funcaddr(node, ssa_cur_bb)
            ssa_set_bail(SBR_NONLOCAL)
            return 0
        if ssa_ismem[nid] != 0:
            # Memory-modeled local.  An array ident used as an rvalue decays to
            # its slot address; a scalar ident loads its slot at its width.
            if ssa_mem_isarr[nid] != 0:
                return ssa_mem_addr[nid]
            return ssa_load_at(ssa_mem_addr[nid], ssa_mem_esz[nid], ssa_mem_esgn[nid])
        if ssa_name_promotable(nid) == 0:
            ssa_set_bail(SBR_NONPROMOTABLE)
            return 0
        return ssa_read_var(nid, ssa_cur_bb)

    if k == ND_BINARY:
        op: uint32 = nd_aux[node]
        if op == BINOP_AND or op == BINOP_OR:
            # short-circuit `and`/`or` -> control flow + join phi (§ short-circuit).
            return ssa_lower_shortcircuit(node, op)
        # div/mod (idiv vs div) and arithmetic-shift-right (sar vs shr) and the
        # ordered compares (< <= > >=, signed vs unsigned setcc) select their x86
        # instruction from operand SIGNEDNESS — now tracked per value via the
        # local/return-type signedness table, so the emit hint is resolved here
        # (sv_c) and these ops stay on the SSA path.  shl and the bitwise ops are
        # low-64-invariant regardless of signedness.
        arith: uint32 = ssa_binop_is_arith(op)
        cmp: uint32 = ssa_binop_is_cmp(op)
        if arith == 0 and cmp == 0:
            ssa_set_bail(SBR_NONSUBSET_EXPR)
            return 0
        # Snapshot operand AST nodes for signedness resolution BEFORE lowering
        # (lowering does not mutate the AST, but read them plainly).
        lnode: uint32 = nd_a[node]
        rnode: uint32 = nd_b[node]
        la: uint32 = ssa_lower_expr(lnode, ssa_cur_bb)
        if la == 0:
            return 0
        rb: uint32 = ssa_lower_expr(rnode, ssa_cur_bb)
        if rb == 0:
            return 0
        # ---- FLOAT arithmetic / compare (LLVM path) ---------------------
        # Both operands of a float binop are float (Adder is statically typed),
        # so a float result is detected from either operand's value type.  This
        # is reached only when ssa_mem_model != 0 (the native path never lowers a
        # float value — its leaves all bail — so this branch is inert there).
        if ssa_val_fw(la) != 0 or ssa_val_fw(rb) != 0:
            fty: uint32 = sv_type[la]
            if ssa_is_float_svt(fty) == 0:
                fty = sv_type[rb]
            if cmp != 0:
                vf: uint32 = sv_new(SVO_FCMP)
                if vf == 0:
                    return 0
                sv_aux[vf] = op
                sv_a[vf] = la
                sv_b[vf] = rb
                sv_ast[vf] = node
                sv_type[vf] = SVT_I1
                bb_append(ssa_cur_bb, vf)
                return vf
            if op != BINOP_ADD and op != BINOP_SUB and op != BINOP_MUL and op != BINOP_DIV and op != BINOP_IDIV:
                ssa_set_bail(SBR_FLOAT)      # frem / float bitwise/shift: not modeled
                return 0
            vfa: uint32 = sv_new(SVO_BINOP)
            if vfa == 0:
                return 0
            sv_aux[vfa] = op
            sv_a[vfa] = la
            sv_b[vfa] = rb
            sv_ast[vfa] = node
            sv_type[vfa] = fty              # emission keys fadd/fsub/... off this
            bb_append(ssa_cur_bb, vfa)
            return vfa
        vop: uint32 = SVO_BINOP
        if cmp != 0:
            vop = SVO_ICMP
        v3: uint32 = sv_new(vop)
        if v3 == 0:
            return 0
        sv_aux[v3] = op
        sv_a[v3] = la
        sv_b[v3] = rb
        sv_ast[v3] = node
        if cmp != 0:
            # sv_c carries the resolved setcc opcode (shallow operand signedness).
            sv_c[v3] = ssa_cmp_setcc(op, ssa_expr_sgn(lnode), ssa_expr_sgn(rnode))
            sv_type[v3] = SVT_I1
        elif op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_MOD:
            # sv_c = 1 => signed (cqo;idiv), 0 => unsigned (xor rdx;div).  Uses the
            # STRUCTURAL operand signedness (matches legacy div_use_signed).
            sv_c[v3] = binop_use_signed(ssa_shr_value_sgn(lnode), ssa_shr_value_sgn(rnode))
        elif op == BINOP_SHR:
            # sv_c = 1 => arithmetic (sar), 0 => logical (shr); keyed on the LEFT
            # (value) operand's structural signedness alone (matches shr_use_signed).
            if ssa_shr_value_sgn(lnode) == 2:
                sv_c[v3] = 1
            else:
                sv_c[v3] = 0
        bb_append(ssa_cur_bb, v3)
        return v3

    if k == ND_UNARY:
        uop: uint32 = nd_aux[node]
        # address-of / pointer deref: modeled only on the LLVM (memory) path; the
        # native path keeps bailing (byte-identical).
        if ssa_mem_model != 0 and uop == UNOP_ADDR:
            return ssa_lower_addr_of(nd_a[node])
        if ssa_mem_model != 0 and uop == UNOP_DEREF:
            desz: uint32 = ssa_deref_esz(nd_a[node])
            if desz == 0:
                ssa_set_bail(SBR_MEMORY)          # unknown/aggregate pointee
                return 0
            dsgn: uint32 = ssa_deref_esgn(nd_a[node])
            pv: uint32 = ssa_lower_expr(nd_a[node], ssa_cur_bb)
            if pv == 0:
                return 0
            return ssa_load_at(pv, desz, dsgn)
        vop2: uint32 = 0
        if uop == UNOP_NEG:
            vop2 = SVO_NEG
        elif uop == UNOP_NOT:
            vop2 = SVO_NOT
        elif uop == UNOP_BIT_NOT:
            vop2 = SVO_BITNOT
        else:
            ssa_set_bail(SBR_MEMORY)   # deref / addr-of -> bail
            return 0
        oa: uint32 = ssa_lower_expr(nd_a[node], ssa_cur_bb)
        if oa == 0:
            return 0
        if vop2 == SVO_NEG and ssa_val_fw(oa) != 0:
            # float negate -> fneg (LLVM path); the operand carries its float type.
            vfn: uint32 = sv_new(SVO_FNEG)
            if vfn == 0:
                return 0
            sv_a[vfn] = oa
            sv_ast[vfn] = node
            sv_type[vfn] = sv_type[oa]
            bb_append(ssa_cur_bb, vfn)
            return vfn
        v4: uint32 = sv_new(vop2)
        if v4 == 0:
            return 0
        sv_a[v4] = oa
        sv_ast[v4] = node
        bb_append(ssa_cur_bb, v4)
        return v4

    if k == ND_CALL:
        # value-consumed call: the callee return must be full-width (result_used=1).
        return ssa_lower_call(node, 1)

    if k == ND_CAST:
        # cast[T](x): nd_a = destination type node, nd_b = operand expr.  Mirror
        # codegen's gen_expr ND_CAST for the NON-FLOAT case exactly:
        #   * dest is a float type  -> SSE convert (out of subset) -> bail.
        #   * dest full-width int (prim_type_size == 8) or a non-ND_TYPE target
        #     (pointer/array cast: prim_type_size == 8) -> NO-OP: forward the
        #     operand value unchanged (low-64-invariant).
        #   * dest sub-8-byte int -> truncate+re-extend the operand to T's width
        #     (movzx for unsigned T / movsx for signed T) = emit_ext_rax(size,sgn).
        # The operand is always an integer value in our subset (float sources
        # bail at their leaves), so the float-source SSE path never applies.
        tnode: uint32 = nd_a[node]
        dfw: uint32 = type_float_width(tnode)     # dest float width (0/4/8)
        if dfw != 0 and ssa_mem_model == 0:
            ssa_set_bail(SBR_FLOAT)               # native path: float dest bails
            return 0
        opv: uint32 = ssa_lower_expr(nd_b[node], ssa_cur_bb)
        if opv == 0:
            return 0
        sfw: uint32 = ssa_val_fw(opv)             # source float width (0 = int)
        # ---- float DESTINATION (LLVM path) ------------------------------
        if dfw != 0:
            if sfw == 0:
                # int -> float: sitofp (Adder's cast[float](int) is a signed
                # cvtsi2sd; the seed has no unsigned float conversion).
                cvf: uint32 = sv_new(SVO_I2F)
                if cvf == 0:
                    return 0
                sv_a[cvf] = opv
                sv_c[cvf] = 1                      # 1 => signed (sitofp)
                sv_type[cvf] = ssa_fw_svt(dfw)
                sv_ast[cvf] = node
                bb_append(ssa_cur_bb, cvf)
                return cvf
            if sfw == dfw:
                return opv                         # same float width: no-op
            cvw: uint32 = 0
            if dfw > sfw:
                cvw = sv_new(SVO_FPEXT)            # f32 -> f64
            else:
                cvw = sv_new(SVO_FPTRUNC)          # f64 -> f32
            if cvw == 0:
                return 0
            sv_a[cvw] = opv
            sv_type[cvw] = ssa_fw_svt(dfw)
            sv_ast[cvw] = node
            bb_append(ssa_cur_bb, cvw)
            return cvw
        # ---- int DESTINATION from a float SOURCE ------------------------
        if sfw != 0:
            # float -> int: fptosi/fptoui, then widen to the canonical i64.
            di: uint32 = 8
            if tnode != 0 and nd_kind[tnode] == ND_TYPE:
                di = prim_type_size(tnode)
            cvi: uint32 = sv_new(SVO_F2I)
            if cvi == 0:
                return 0
            sv_a[cvi] = opv
            sv_aux[cvi] = di                       # dest int byte width
            if type_is_unsigned(tnode) == 0:
                sv_c[cvi] = 1                       # signed dest -> fptosi
            else:
                sv_c[cvi] = 0                       # unsigned dest -> fptoui
            sv_type[cvi] = SVT_I64
            sv_ast[cvi] = node
            bb_append(ssa_cur_bb, cvi)
            return cvi
        dsz: uint32 = 8
        if tnode != 0 and nd_kind[tnode] == ND_TYPE:
            dsz = prim_type_size(tnode)
        if dsz >= 8:
            return opv                            # identity cast: reuse the value
        # narrowing cast: SVO_TRUNC carries width (sv_aux) + signedness (sv_c).
        cv2: uint32 = sv_new(SVO_TRUNC)
        if cv2 == 0:
            return 0
        sv_a[cv2] = opv
        sv_aux[cv2] = dsz
        sv_ast[cv2] = node
        if type_is_unsigned(tnode) == 0:
            sv_c[cv2] = 1                          # signed dest -> sign-extend (movsx)
        else:
            sv_c[cv2] = 0                          # unsigned dest -> zero-extend (movzx)
        bb_append(ssa_cur_bb, cv2)
        return cv2

    if k == ND_INDEX:
        # `arr[i]` rvalue.  Only a 1-D scalar-element GLOBAL array indexed by an
        # in-subset integer expression is accepted; the element is loaded at the
        # computed byte address.  Local arrays (need alloca), pointer/struct/
        # multi-dim bases, etc. fall back.
        base: uint32 = nd_a[node]
        # `c.buf[i]` / `c[0].buf[i]`: index through a POINTER FIELD (LLVM path).
        if ssa_mem_model != 0 and nd_kind[base] == ND_MEMBER:
            mesz: uint32 = 0
            mesgn: uint32 = 0
            maddr: uint32 = ssa_member_ptr_index_addr(base, nd_b[node], &mesz, &mesgn)
            if maddr == 0:
                return 0
            return ssa_load_at(maddr, mesz, mesgn)
        # `g[i][j]` rvalue: 2-D scalar-element GLOBAL array (LLVM path).
        if ssa_mem_model != 0 and nd_kind[base] == ND_INDEX and nd_kind[nd_a[base]] == ND_IDENT:
            g2: uint32 = ssa_global_array_2d(nd_name_off[nd_a[base]], nd_name_len[nd_a[base]])
            if g2 != 0:
                a2d: uint32 = ssa_index2_addr(g2, node)
                if a2d == 0:
                    return 0
                return ssa_load_elem(a2d, glob_elem_size[g2 - 1], ssa_array2_elem_sgn(g2), type_float_width(nd_a[nd_a[glob_type_node[g2 - 1]]]))
        if nd_kind[base] != ND_IDENT:
            # Non-identifier base (LLVM path): N-D global array (`g[i][j][k]`) or
            # a pointer-returning rvalue (`foo()[i]`).  Integer-element only.
            if ssa_mem_model != 0:
                niesz: uint32 = 0
                niesgn: uint32 = 0
                nifw: uint32 = 0
                niaddr: uint32 = ssa_nonident_index_addr(node, &niesz, &niesgn, &nifw)
                if niaddr != 0:
                    return ssa_load_elem(niaddr, niesz, niesgn, nifw)
            if ssa_bail == 0:
                ssa_set_bail(SBR_MEMORY)
            return 0
        bnid: uint32 = nm_intern(nd_name_off[base], nd_name_len[base])
        if bnid < NM_MAX and ssa_islocal[bnid] != 0:
            # Local array element load (LLVM path); a non-array local indexed like
            # an array is outside the subset.
            if ssa_ismem[bnid] != 0 and ssa_mem_isarr[bnid] != 0:
                laddr: uint32 = ssa_local_index_addr(bnid, nd_b[node])
                if laddr == 0:
                    return 0
                return ssa_load_at(laddr, ssa_mem_esz[bnid], ssa_mem_esgn[bnid])
            # `p[i]` on a POINTER local/param (LLVM path): *(p + i*elem).
            if ssa_mem_model != 0 and ssa_ptr_esz[bnid] != 0:
                paddr: uint32 = ssa_ptr_index_addr(bnid, nd_b[node])
                if paddr == 0:
                    return 0
                return ssa_load_at(paddr, ssa_ptr_esz[bnid], ssa_ptr_esgn[bnid])
            ssa_set_bail(SBR_MEMORY)
            return 0
        gia: uint32 = ssa_global_array_1d(nd_name_off[base], nd_name_len[base])
        if gia == 0:
            # `gptr[i]` rvalue on a GLOBAL Ptr[T] (LLVM path): load the pointer
            # value then *(ptr + i*elem).
            gpg: uint32 = 0
            gpe: uint32 = ssa_global_ptr_esz(nd_name_off[base], nd_name_len[base], &gpg)
            if ssa_mem_model != 0 and gpe != 0:
                gpaddr: uint32 = ssa_global_ptr_index_addr(gpg, nd_b[node], gpe)
                if gpaddr == 0:
                    return 0
                return ssa_load_at(gpaddr, gpe, ssa_global_ptr_esgn(gpg))
            ssa_set_bail(SBR_MEMORY)
            return 0
        addr: uint32 = ssa_index_addr(gia, nd_b[node])
        if addr == 0:
            return 0
        return ssa_load_elem(addr, glob_elem_size[gia - 1], ssa_array_elem_sgn(gia), type_float_width(nd_a[glob_type_node[gia - 1]]))

    if k == ND_STRING_LIT:
        # String literal (LLVM path): intern its bytes as a `[N x i8]` data
        # global and yield the symbol's address (exactly how codegen interns a
        # `.asciz` into .rodata and hands out a RIP-relative pointer).  The
        # native path keeps bailing (NONSUBSET_EXPR) so it stays byte-identical.
        if ssa_mem_model != 0:
            sgi: uint32 = ssa_intern_string_global(nd_name_off[node], nd_name_len[node])
            if sgi == 0:
                ssa_set_bail(SBR_MEMORY)
                return 0
            return ssa_globaladdr(sgi, ssa_cur_bb)
        ssa_set_bail(SBR_NONSUBSET_EXPR)
        return 0

    # float literal, member, slice, conditional, etc. -> bail.
    if k == ND_FLOAT_LIT:
        # LLVM path: a bare float literal is a float64 whose EXACT bit pattern the
        # lexer stashed in nd_num (nd_aux == 1).  An opt-folded integer-valued
        # ND_FLOAT_LIT (nd_aux == 0) is not produced by a fresh parse and bails.
        if ssa_mem_model != 0 and nd_aux[node] == 1:
            fl: uint32 = sv_new(SVO_FCONST)
            if fl == 0:
                return 0
            sv_imm[fl] = nd_num[node]
            sv_type[fl] = SVT_F64
            sv_ast[fl] = node
            bb_append(ssa_cur_bb, fl)
            return fl
        ssa_set_bail(SBR_FLOAT)
    elif k == ND_MEMBER:
        if ssa_mem_model != 0:
            return ssa_lower_member(node)
        ssa_set_bail(SBR_MEMORY)
    else:
        ssa_set_bail(SBR_NONSUBSET_EXPR)
    return 0


# Lower `arr[idx] = rhs` / `arr[idx] op= rhs` for a 1-D scalar-element GLOBAL
# array.  Returns the (unchanged-through-a-store) fallthrough block.  Callers seed
# ssa_cur_bb; this re-reads it after each lowered subexpression.
def ssa_lower_index_store(bb: uint32, stmt: uint32, target: uint32) -> uint32:
    base: uint32 = nd_a[target]
    # `c.buf[i] = rhs` / `c[0].buf[i] = rhs`: store through a POINTER FIELD.
    if ssa_mem_model != 0 and nd_kind[base] == ND_MEMBER:
        return ssa_lower_member_index_store(bb, stmt, target)
    # `g[i][j] = rhs`: 2-D scalar-element GLOBAL array store (LLVM path).
    if ssa_mem_model != 0 and nd_kind[base] == ND_INDEX and nd_kind[nd_a[base]] == ND_IDENT:
        g2s: uint32 = ssa_global_array_2d(nd_name_off[nd_a[base]], nd_name_len[nd_a[base]])
        if g2s != 0:
            return ssa_lower_index2_store(bb, stmt, target, g2s)
    if nd_kind[base] != ND_IDENT:
        # Non-identifier base (LLVM path): N-D global array (`g[i][j][k] = rhs`)
        # or a pointer-returning rvalue (`foo()[i] = rhs`).  Integer-element only.
        if ssa_mem_model != 0:
            return ssa_lower_nonident_index_store(bb, stmt, target)
        ssa_set_bail(SBR_MEMORY)
        return bb
    bnid: uint32 = nm_intern(nd_name_off[base], nd_name_len[base])
    if bnid < NM_MAX and ssa_islocal[bnid] != 0:
        if ssa_ismem[bnid] != 0 and ssa_mem_isarr[bnid] != 0:
            return ssa_lower_local_index_store(bb, stmt, target, bnid)
        # `p[i] = rhs` on a POINTER local/param (LLVM path).
        if ssa_mem_model != 0 and ssa_ptr_esz[bnid] != 0:
            return ssa_lower_ptr_index_store(bb, stmt, target, bnid)
        ssa_set_bail(SBR_MEMORY)                  # non-array local indexed
        return bb
    gi: uint32 = ssa_global_array_1d(nd_name_off[base], nd_name_len[base])
    if gi == 0:
        # `gptr[i] = rhs` on a GLOBAL Ptr[T] (LLVM path).
        sgg: uint32 = 0
        sge: uint32 = ssa_global_ptr_esz(nd_name_off[base], nd_name_len[base], &sgg)
        if ssa_mem_model != 0 and sge != 0:
            return ssa_lower_global_ptr_index_store(bb, stmt, target, sgg, sge)
        ssa_set_bail(SBR_MEMORY)
        return bb
    es: uint32 = glob_elem_size[gi - 1]
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        # arr[i] op= e  ==  arr[i] = (arr[i] op e): compute the address ONCE (so
        # the index is evaluated once), load, combine, store back to the SAME
        # address value.
        addr: uint32 = ssa_index_addr(gi, nd_b[target])
        if addr == 0:
            return ssa_cur_bb
        cur: uint32 = ssa_load_elem(addr, es, ssa_array_elem_sgn(gi), type_float_width(nd_a[glob_type_node[gi - 1]]))
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, es)
        return ssa_cur_bb
    # plain store: lower the RHS, then the address, then store.
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    addr2: uint32 = ssa_index_addr(gi, nd_b[target])
    if addr2 == 0:
        return ssa_cur_bb
    ssa_store_at(addr2, rhsv, es)
    return ssa_cur_bb


# Lower `arr[idx] = rhs` / `arr[idx] op= rhs` for a LOCAL (alloca'd) 1-D array;
# same discipline as the global path but the base is the local's slot address.
def ssa_lower_local_index_store(bb: uint32, stmt: uint32, target: uint32,
                                bnid: uint32) -> uint32:
    es: uint32 = ssa_mem_esz[bnid]
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        addr: uint32 = ssa_local_index_addr(bnid, nd_b[target])
        if addr == 0:
            return ssa_cur_bb
        cur: uint32 = ssa_load_at(addr, es, ssa_mem_esgn[bnid])
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, es)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    addr2: uint32 = ssa_local_index_addr(bnid, nd_b[target])
    if addr2 == 0:
        return ssa_cur_bb
    ssa_store_at(addr2, rhsv, es)
    return ssa_cur_bb


# Lower `p[i] = rhs` / `p[i] op= rhs` for a POINTER local/param base; same
# discipline as the local-array path but the base address is `p + i*elem` built
# from the pointer VALUE (ssa_ptr_index_addr).  LLVM path only.
def ssa_lower_ptr_index_store(bb: uint32, stmt: uint32, target: uint32,
                              bnid: uint32) -> uint32:
    es: uint32 = ssa_ptr_esz[bnid]
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        addr: uint32 = ssa_ptr_index_addr(bnid, nd_b[target])
        if addr == 0:
            return ssa_cur_bb
        cur: uint32 = ssa_load_at(addr, es, ssa_ptr_esgn[bnid])
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, es)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    addr2: uint32 = ssa_ptr_index_addr(bnid, nd_b[target])
    if addr2 == 0:
        return ssa_cur_bb
    ssa_store_at(addr2, rhsv, es)
    return ssa_cur_bb


# Lower `c.buf[i] = rhs` / `... op= rhs`: store through a POINTER FIELD element.
# The element address is computed ONCE (idx + field pointer evaluated once),
# then stored (augmented form load-modify-writes the same address).  LLVM path.
def ssa_lower_member_index_store(bb: uint32, stmt: uint32, target: uint32) -> uint32:
    esz: uint32 = 0
    esgn: uint32 = 0
    addr: uint32 = ssa_member_ptr_index_addr(nd_a[target], nd_b[target], &esz, &esgn)
    if addr == 0:
        return ssa_cur_bb
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        cur: uint32 = ssa_load_at(addr, esz, esgn)
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, esz)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
    if rhsv == 0:
        return ssa_cur_bb
    ssa_store_at(addr, rhsv, esz)
    return ssa_cur_bb


# Lower `g[i][j] = rhs` / `... op= rhs`: 2-D scalar-element GLOBAL array store.
# The element address is computed ONCE (both indices evaluated once), then
# stored; the augmented form load-modify-writes the same address.  LLVM path.
def ssa_lower_index2_store(bb: uint32, stmt: uint32, target: uint32, gi: uint32) -> uint32:
    es: uint32 = glob_elem_size[gi - 1]
    addr: uint32 = ssa_index2_addr(gi, target)
    if addr == 0:
        return ssa_cur_bb
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        cur: uint32 = ssa_load_elem(addr, es, ssa_array2_elem_sgn(gi), type_float_width(nd_a[nd_a[glob_type_node[gi - 1]]]))
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, es)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
    if rhsv == 0:
        return ssa_cur_bb
    ssa_store_at(addr, rhsv, es)
    return ssa_cur_bb


# Lower `obj.field = rhs` / `obj.field op= rhs`: sized store into a struct field
# (LLVM path).  The field address is computed once; the augmented form loads,
# combines, and stores back.  A whole-array field target bails.
def ssa_lower_member_store(bb: uint32, stmt: uint32, target: uint32) -> uint32:
    msz: uint32 = 0
    msgn: uint32 = 0
    addr: uint32 = ssa_member_field_addr(target, &msz, &msgn)
    if addr == 0:
        return ssa_cur_bb
    if msz == 0:
        ssa_set_bail(SBR_MEMORY)                  # cannot assign a whole array field
        return ssa_cur_bb
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        cur: uint32 = ssa_load_at(addr, msz, msgn)
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at(addr, comb, msz)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
    if rhsv == 0:
        return ssa_cur_bb
    ssa_store_at(addr, rhsv, msz)
    return ssa_cur_bb


# Lower `x = rhs` / `x op= rhs` for a memory-modeled scalar local `tid`: the
# slot address is a fixed alloca value, so an augmented assignment loads once,
# combines, and stores back to the same address.
def ssa_lower_mem_scalar_store(bb: uint32, stmt: uint32, target: uint32,
                               tid: uint32) -> uint32:
    es: uint32 = ssa_mem_esz[tid]
    addr: uint32 = ssa_mem_addr[tid]
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        cur: uint32 = ssa_load_at(addr, es, ssa_mem_esgn[tid])
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at_in(addr, comb, es, ssa_cur_bb)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    ssa_store_at_in(addr, rhsv, es, ssa_cur_bb)
    return ssa_cur_bb


# Lower `*p = rhs` / `*p op= rhs`.  The pointer expression is evaluated to an
# i64 address; an augmented form evaluates the pointer ONCE (so a side-effecting
# pointer expr is not duplicated), loads, combines, and stores back.
def ssa_lower_deref_store(bb: uint32, stmt: uint32, target: uint32) -> uint32:
    esz: uint32 = ssa_deref_esz(nd_a[target])
    if esz == 0:
        ssa_set_bail(SBR_MEMORY)
        return bb
    esgn: uint32 = ssa_deref_esgn(nd_a[target])
    aug: uint32 = nd_aux[stmt]
    if aug != 0:
        pv: uint32 = ssa_lower_expr(nd_a[target], ssa_cur_bb)
        if pv == 0:
            return ssa_cur_bb
        cur: uint32 = ssa_load_at(pv, esz, esgn)
        if cur == 0:
            return ssa_cur_bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], ssa_cur_bb)
        if rhs == 0:
            return ssa_cur_bb
        comb: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, ssa_cur_bb)
        if comb == 0:
            return ssa_cur_bb
        ssa_store_at_in(pv, comb, esz, ssa_cur_bb)
        return ssa_cur_bb
    rhsv: uint32 = ssa_lower_expr(nd_b[stmt], bb)
    if rhsv == 0:
        return ssa_cur_bb
    pv2: uint32 = ssa_lower_expr(nd_a[target], ssa_cur_bb)
    if pv2 == 0:
        return ssa_cur_bb
    ssa_store_at_in(pv2, rhsv, esz, ssa_cur_bb)
    return ssa_cur_bb


# =======================================================================
# statement lowering: threads the current block; returns fallthrough block
# (0 == control cannot fall through, e.g. after return/break/continue).
# =======================================================================
def ssa_intern_local(off: uint32, len_: uint32, tnode: uint32) -> uint32:
    nid: uint32 = nm_intern(off, len_)
    if nid >= NM_MAX:
        ssa_set_bail(SBR_OVERFLOW)
        return NM_MAX
    # A memory local already classified (by the pre-alloca scan, or an earlier
    # param) is reused as-is: never re-create its alloca (which would append to a
    # possibly-terminated entry).  Promotable locals fall through and re-classify
    # exactly as before (preserving redeclaration behaviour / byte-identity).
    if ssa_ismem[nid] != 0:
        return nid
    # A pointer local/param records its pointee width so `*p` picks a load size;
    # this is orthogonal to promotability (a plain pointer scalar stays SSA).
    ssa_record_ptr_info(nid, tnode)
    # ---- local Array[N, T]: a stack slot addressed by index (LLVM path) -------
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        if ssa_mem_model == 0:
            ssa_set_bail(SBR_MEMORY)          # native path: arrays stay bailed
            return NM_MAX
        elem: uint32 = nd_a[tnode]
        if elem != 0 and nd_kind[elem] == ND_ARRAY_TYPE:
            ssa_set_bail(SBR_MEMORY)          # multi-dimensional -> defer
            return NM_MAX
        if type_float_width(elem) != 0:
            ssa_set_bail(SBR_FLOAT)
            return NM_MAX
        aesz: uint32 = prim_type_size(elem)
        if aesz != 1 and aesz != 2 and aesz != 4 and aesz != 8:
            ssa_set_bail(SBR_MEMORY)          # non-machine element -> defer
            return NM_MAX
        cnt: uint32 = cast[uint32](nd_num[tnode])
        ssa_islocal[nid] = 1
        ssa_ismem[nid] = 1
        ssa_mem_isarr[nid] = 1
        ssa_mem_esz[nid] = aesz
        ssa_mem_esgn[nid] = type_signedness(elem)
        ssa_local_sgn[nid] = 1                # a bare array ident decays to an addr
        ssa_local_size[nid] = 8
        if ssa_ensure_slot(nid, cnt * aesz) == 0:
            ssa_set_bail(SBR_OVERFLOW)
            return NM_MAX
        return nid
    # ---- scalar --------------------------------------------------------------
    # Non-float integer scalars only (float locals bail -> SSE).  A narrow
    # (1/2/4-byte) local is accepted and truncated on every write (see
    # ssa_trunc_to_local); the aggregate case (prim_type_size not a machine
    # width) bails.
    fw: uint32 = type_float_width(tnode)
    if fw != 0:
        # Float scalar.  Native path bails (SSE, unchanged).  LLVM path: a
        # PROMOTABLE float scalar becomes an ordinary SSA value carrying an
        # SVT_F32/F64 type (mem2reg keeps it in an xmm reg); an address-taken
        # float scalar would need a float memory slot (load/store double) — not
        # yet modeled — so it still bails.
        if ssa_mem_model == 0:
            ssa_set_bail(SBR_FLOAT)
            return NM_MAX
        if ssa_name_promotable(nid) == 0:
            ssa_set_bail(SBR_FLOAT)
            return NM_MAX
        ssa_islocal[nid] = 1
        ssa_local_fw[nid] = fw
        ssa_local_sgn[nid] = 0
        ssa_local_size[nid] = 8               # float value: never trunc'd
        return nid
    sz: uint32 = prim_type_size(tnode)
    if sz != 1 and sz != 2 and sz != 4 and sz != 8:
        ssa_set_bail(SBR_NONPROMOTABLE)
        return NM_MAX
    if ssa_name_promotable(nid) == 0:
        # Address is taken (`&x`) or the slot is read directly: this scalar must
        # live in memory.  On the native path that bails (unchanged); on the LLVM
        # path it becomes an alloca'd slot with sized load/store at every use.
        if ssa_mem_model == 0:
            ssa_set_bail(SBR_NONPROMOTABLE)
            return NM_MAX
        ssa_islocal[nid] = 1
        ssa_ismem[nid] = 1
        ssa_mem_isarr[nid] = 0
        ssa_mem_esz[nid] = sz
        ssa_mem_esgn[nid] = type_signedness(tnode)
        ssa_local_sgn[nid] = type_signedness(tnode)
        ssa_local_size[nid] = sz
        if ssa_ensure_slot(nid, sz) == 0:
            ssa_set_bail(SBR_OVERFLOW)
            return NM_MAX
        return nid
    # ---- promotable scalar (byte-identical to the pre-memory subset) ---------
    ssa_islocal[nid] = 1
    ssa_local_sgn[nid] = type_signedness(tnode)
    ssa_local_size[nid] = sz
    return nid


# If local `nid` is narrow (<8 bytes), wrap `val` in an SVO_TRUNC to the local's
# width+signedness so every threaded read observes the truncated value (the
# legacy sized-store/extended-load semantics).  Full-width locals pass through.
def ssa_trunc_to_local(nid: uint32, val: uint32, bb: uint32) -> uint32:
    if val == 0:
        return 0
    sz: uint32 = ssa_local_size[nid]
    if sz >= 8:
        return val
    tv: uint32 = sv_new(SVO_TRUNC)
    if tv == 0:
        return 0
    sv_a[tv] = val
    sv_aux[tv] = sz
    if ssa_local_sgn[nid] == 2:
        sv_c[tv] = 1                          # signed -> movsx
    else:
        sv_c[tv] = 0                          # unsigned -> movzx
    bb_append(bb, tv)
    return tv


def ssa_lower_stmt(bb: uint32, stmt: uint32) -> uint32:
    if ssa_bail != 0:
        return 0
    if bb == 0:
        return 0
    # Seed the expression-lowering current block; a short-circuit inside any RHS
    # advances ssa_cur_bb, so every handler re-reads bb = ssa_cur_bb after lowering
    # before it appends stores / terminators.
    ssa_cur_bb = bb
    k: uint32 = nd_kind[stmt]

    if k == ND_PASS:
        return bb

    if k == ND_VAR_DECL:
        nid: uint32 = ssa_intern_local(nd_name_off[stmt], nd_name_len[stmt], nd_a[stmt])
        if nid >= NM_MAX:
            return bb
        if ssa_ismem[nid] != 0:
            # Memory-modeled local: store the scalar initializer into its slot.
            # An array with an aggregate initializer is out of the subset; a bare
            # array decl (no initializer) just reserves the slot.
            if nd_b[stmt] != 0:
                if ssa_mem_isarr[nid] != 0:
                    ssa_set_bail(SBR_MEMORY)
                    return bb
                mval: uint32 = ssa_lower_expr(nd_b[stmt], bb)
                if mval == 0:
                    return bb
                bb = ssa_cur_bb                      # RHS may have split control
                ssa_store_at_in(ssa_mem_addr[nid], mval, ssa_mem_esz[nid], bb)
            return bb
        val: uint32 = 0
        if nd_b[stmt] != 0:
            val = ssa_lower_expr(nd_b[stmt], bb)
            if val == 0:
                return bb
            bb = ssa_cur_bb                          # RHS may have split control
            val = ssa_trunc_to_local(nid, val, bb)   # narrow-local store truncation
            if val == 0:
                return bb
        else:
            # declaration without initializer -> undef value.
            val = sv_new(SVO_UNDEF)
            if val == 0:
                return bb
            bb_append(bb, val)
        ssa_write_var(nid, bb, val)
        return bb

    if k == ND_ASSIGN:
        target: uint32 = nd_a[stmt]
        if nd_kind[target] == ND_INDEX:
            # store into a 1-D scalar-element GLOBAL or LOCAL array element.
            return ssa_lower_index_store(bb, stmt, target)
        if ssa_mem_model != 0 and nd_kind[target] == ND_UNARY and nd_aux[target] == UNOP_DEREF:
            # `*p = e` / `*p op= e`: store through a pointer (LLVM path).
            return ssa_lower_deref_store(bb, stmt, target)
        if ssa_mem_model != 0 and nd_kind[target] == ND_MEMBER:
            # `obj.field = e` / `obj.field op= e`: store into a struct field.
            return ssa_lower_member_store(bb, stmt, target)
        if nd_kind[target] != ND_IDENT:
            # store through member/deref -> memory, outside the current subset.
            ssa_set_bail(SBR_MEMORY)
            return bb
        tid: uint32 = nm_intern(nd_name_off[target], nd_name_len[target])
        if tid >= NM_MAX:
            ssa_set_bail(SBR_OVERFLOW)
            return bb
        aug: uint32 = nd_aux[stmt]
        if tid < NM_MAX and ssa_ismem[tid] != 0:
            # store into a memory-modeled scalar local's slot.
            return ssa_lower_mem_scalar_store(bb, stmt, target, tid)
        if ssa_islocal[tid] == 0:
            # Not a known local.  A percpu scalar stores via a %gs-relative
            # (addrspace 256) store on the LLVM path; a plain scalar global
            # stores via a RIP-relative store; anything else (aggregate/array
            # global, unknown) bails.
            if ssa_mem_model != 0:
                ptid: uint32 = ssa_percpu_scalar(nd_name_off[target], nd_name_len[target])
                if ptid != 0:
                    prhs: uint32 = ssa_lower_expr(nd_b[stmt], bb)
                    if prhs == 0:
                        return bb
                    bb = ssa_cur_bb                  # RHS may have split control
                    if aug != 0:
                        # g op= e == g = (g op e): read the slot, combine, store.
                        pcur: uint32 = ssa_percpu_load(ptid, bb)
                        if pcur == 0:
                            return bb
                        pvg: uint32 = ssa_build_aug_binop(aug, pcur, prhs, target, nd_b[stmt], stmt, bb)
                        if pvg == 0:
                            return bb
                        ssa_percpu_store(ptid, pvg, bb)
                    else:
                        ssa_percpu_store(ptid, prhs, bb)
                    return bb
            gi: uint32 = ssa_scalar_global(nd_name_off[target], nd_name_len[target])
            if gi == 0:
                ssa_set_bail(SBR_NONLOCAL)
                return bb
            rhsg: uint32 = ssa_lower_expr(nd_b[stmt], bb)
            if rhsg == 0:
                return bb
            bb = ssa_cur_bb                          # RHS may have split control
            if aug != 0:
                # g op= e == g = (g op e): read the global, combine, store back.
                curg: uint32 = ssa_global_load(gi, bb)
                if curg == 0:
                    return bb
                vg: uint32 = ssa_build_aug_binop(aug, curg, rhsg, target, nd_b[stmt], stmt, bb)
                if vg == 0:
                    return bb
                ssa_global_store(gi, vg, bb)
            else:
                ssa_global_store(gi, rhsg, bb)
            return bb
        if ssa_name_promotable(tid) == 0:
            ssa_set_bail(SBR_NONPROMOTABLE)
            return bb
        rhs: uint32 = ssa_lower_expr(nd_b[stmt], bb)
        if rhs == 0:
            return bb
        bb = ssa_cur_bb                              # RHS may have split control
        if aug != 0:
            # x op= e  ==>  x = (x op e)
            cur: uint32 = ssa_read_var(tid, bb)
            if cur == 0:
                return bb
            v5: uint32 = ssa_build_aug_binop(aug, cur, rhs, target, nd_b[stmt], stmt, bb)
            if v5 == 0:
                return bb
            v5 = ssa_trunc_to_local(tid, v5, bb)     # narrow-local store truncation
            if v5 == 0:
                return bb
            ssa_write_var(tid, bb, v5)
        else:
            rhs = ssa_trunc_to_local(tid, rhs, bb)   # narrow-local store truncation
            if rhs == 0:
                return bb
            ssa_write_var(tid, bb, rhs)
        return bb

    if k == ND_EXPR_STMT:
        estmt: uint32 = nd_a[stmt]
        if estmt != 0 and nd_kind[estmt] == ND_CALL:
            # Statement-position call: the return value is discarded, so the
            # callee's return width/type is irrelevant (only its side effect
            # matters).  Lower with result_used=0 so narrow/float/void callees
            # (e.g. print_u64 -> int32) do NOT bail the whole function.
            ssa_cur_bb = bb
            ssa_lower_call(estmt, 0)
            return ssa_cur_bb
        ssa_lower_expr(estmt, bb)        # value discarded; may be a call side-effect
        return ssa_cur_bb                # a short-circuit may have split control

    if k == ND_RETURN:
        rv: uint32 = 0
        if nd_a[stmt] != 0:
            rv = ssa_lower_expr(nd_a[stmt], bb)
            if rv == 0 and ssa_bail != 0:
                return 0
        bb = ssa_cur_bb                  # return value may have split control
        ret: uint32 = sv_new(SVO_RET)
        if ret == 0:
            return 0
        sv_a[ret] = rv
        sv_ast[ret] = stmt
        bb_append(bb, ret)
        sb_term[bb] = SVO_RET
        return 0

    if k == ND_BREAK:
        if ssa_loop_depth == 0:
            ssa_set_bail(SBR_NONSUBSET_STMT)
            return 0
        tgt: uint32 = ssa_brk_bb[ssa_loop_depth - 1]
        ssa_terminate_br(bb, tgt)
        return 0

    if k == ND_CONTINUE:
        if ssa_loop_depth == 0:
            ssa_set_bail(SBR_NONSUBSET_STMT)
            return 0
        tgt2: uint32 = ssa_cont_bb[ssa_loop_depth - 1]
        ssa_terminate_br(bb, tgt2)
        return 0

    if k == ND_IF:
        return ssa_lower_if(bb, stmt)

    if k == ND_WHILE:
        return ssa_lower_while(bb, stmt)

    if k == ND_DO_WHILE:
        return ssa_lower_do_while(bb, stmt)

    # for/match/try/with/defer/yield/global/... -> bail.
    if k == ND_FOR:
        ssa_set_bail(SBR_FORLOOP)
    else:
        ssa_set_bail(SBR_NONSUBSET_STMT)
    return 0


# Emit an unconditional-branch terminator bb -> tgt.
def ssa_terminate_br(bb: uint32, tgt: uint32):
    if bb == 0 or tgt == 0:
        return
    br: uint32 = sv_new(SVO_BR)
    if br == 0:
        return
    sv_a[br] = tgt
    bb_append(bb, br)
    sb_term[bb] = SVO_BR
    ssa_add_edge(bb, tgt)


# Emit a conditional-branch terminator bb -?-> then/else.
def ssa_terminate_condbr(bb: uint32, cond: uint32, then_bb: uint32, else_bb: uint32):
    if bb == 0:
        return
    cb: uint32 = sv_new(SVO_CONDBR)
    if cb == 0:
        return
    sv_a[cb] = cond
    sv_b[cb] = then_bb
    sv_c[cb] = else_bb
    bb_append(bb, cb)
    sb_term[bb] = SVO_CONDBR
    ssa_add_edge(bb, then_bb)
    ssa_add_edge(bb, else_bb)


# Lower a statement chain, threading the current block.  Returns the fallthrough
# block (0 if control cannot fall through the chain).
def ssa_lower_chain(bb: uint32, head: uint32) -> uint32:
    cur: uint32 = bb
    s: uint32 = head
    while s != 0:
        if ssa_bail != 0:
            return 0
        if cur == 0:
            # unreachable code after a terminator: drop it (structured CFG keeps
            # semantics; a fresh dead block is unnecessary for Ph1's subset).
            return 0
        cur = ssa_lower_stmt(cur, s)
        s = nd_next[s]
    return cur


# --- if / elif / else --------------------------------------------------
#
# Edge-first (Braun-safe): every block's predecessor edges are wired BEFORE the
# block is sealed, so a variable read inside a block resolves against the correct
# predecessor set.  The enclosing branch's edges are added, then the arm body is
# sealed + lowered.
def ssa_lower_if(bb: uint32, stmt: uint32) -> uint32:
    ssa_cur_bb = bb
    cond: uint32 = ssa_lower_expr(nd_a[stmt], bb)
    if cond == 0:
        return 0
    cbb: uint32 = ssa_cur_bb              # a short-circuit condition splits control
    join: uint32 = bb_new_ssa()
    if join == 0:
        return 0
    then_bb: uint32 = bb_new_ssa()
    if then_bb == 0:
        return 0
    has_alt: uint32 = 0
    if nd_c[stmt] != 0 or nd_d[stmt] != 0:
        has_alt = 1
    else_bb: uint32 = join
    if has_alt != 0:
        else_bb = bb_new_ssa()
        if else_bb == 0:
            return 0
    # wire the branch edges FIRST (cbb -> then_bb, cbb -> else_bb).
    ssa_terminate_condbr(cbb, cond, then_bb, else_bb)
    # then arm.
    ssa_seal_block(then_bb)
    then_tail: uint32 = ssa_lower_chain(then_bb, nd_b[stmt])
    if then_tail != 0:
        ssa_terminate_br(then_tail, join)
    # alternative path (elif chain / else); else_bb's incoming edge is already
    # wired above, so alts can seal + lower it safely.
    if has_alt != 0:
        ssa_lower_if_alts(else_bb, nd_c[stmt], nd_d[stmt], join)
    if ssa_bail != 0:
        return 0
    ssa_seal_block(join)
    return join


# Lower the alternative path into `entry_bb` (already created + incoming edge
# wired by the caller).  Wires all edges to `join`.
def ssa_lower_if_alts(entry_bb: uint32, elif_head: uint32, else_head: uint32,
                      join: uint32):
    if ssa_bail != 0:
        return
    ssa_seal_block(entry_bb)              # single known pred (the enclosing branch)
    if elif_head != 0:
        ssa_cur_bb = entry_bb
        cond: uint32 = ssa_lower_expr(nd_a[elif_head], entry_bb)
        if cond == 0:
            return
        cbb: uint32 = ssa_cur_bb          # a short-circuit condition splits control
        body_bb: uint32 = bb_new_ssa()
        if body_bb == 0:
            return
        more: uint32 = 0
        if nd_next[elif_head] != 0 or else_head != 0:
            more = 1
        next_bb: uint32 = join
        if more != 0:
            next_bb = bb_new_ssa()
            if next_bb == 0:
                return
        ssa_terminate_condbr(cbb, cond, body_bb, next_bb)
        ssa_seal_block(body_bb)
        bt: uint32 = ssa_lower_chain(body_bb, nd_b[elif_head])
        if bt != 0:
            ssa_terminate_br(bt, join)
        if more != 0:
            ssa_lower_if_alts(next_bb, nd_next[elif_head], else_head, join)
        return
    if else_head != 0:
        et: uint32 = ssa_lower_chain(entry_bb, else_head)
        if et != 0:
            ssa_terminate_br(et, join)
        return
    # no elif, no else: fall straight to join.
    ssa_terminate_br(entry_bb, join)


# --- while -------------------------------------------------------------
def ssa_lower_while(bb: uint32, stmt: uint32) -> uint32:
    header: uint32 = bb_new_ssa()
    if header == 0:
        return 0
    ssa_terminate_br(bb, header)          # pred #1 (pre-loop) wired
    # header is NOT sealed yet: the back-edge pred is still unknown.
    ssa_cur_bb = header
    cond: uint32 = ssa_lower_expr(nd_a[stmt], header)
    if cond == 0:
        return 0
    chb: uint32 = ssa_cur_bb              # a short-circuit condition splits control
    body_bb: uint32 = bb_new_ssa()
    if body_bb == 0:
        return 0
    exit_bb: uint32 = bb_new_ssa()
    if exit_bb == 0:
        return 0
    ssa_terminate_condbr(chb, cond, body_bb, exit_bb)
    ssa_seal_block(body_bb)               # body's only entry pred is the header
    if ssa_loop_depth >= SSA_LOOP_MAX:
        ssa_set_bail(SBR_LOOPDEPTH)
        return 0
    ssa_brk_bb[ssa_loop_depth] = exit_bb
    ssa_cont_bb[ssa_loop_depth] = header
    ssa_loop_depth = ssa_loop_depth + 1
    body_tail: uint32 = ssa_lower_chain(body_bb, nd_b[stmt])
    ssa_loop_depth = ssa_loop_depth - 1
    if body_tail != 0:
        ssa_terminate_br(body_tail, header)   # back-edge pred wired
    # all header predecessors now known -> seal (fills the loop-carried phis).
    ssa_seal_block(header)
    ssa_seal_block(exit_bb)
    return exit_bb


# --- do-while ----------------------------------------------------------
def ssa_lower_do_while(bb: uint32, stmt: uint32) -> uint32:
    body_bb: uint32 = bb_new_ssa()
    if body_bb == 0:
        return 0
    ssa_terminate_br(bb, body_bb)         # pred #1 (pre-loop) wired
    cond_bb: uint32 = bb_new_ssa()
    if cond_bb == 0:
        return 0
    exit_bb: uint32 = bb_new_ssa()
    if exit_bb == 0:
        return 0
    # body_bb is unsealed: its back-edge pred (from cond) is still unknown.
    if ssa_loop_depth >= SSA_LOOP_MAX:
        ssa_set_bail(SBR_LOOPDEPTH)
        return 0
    ssa_brk_bb[ssa_loop_depth] = exit_bb
    ssa_cont_bb[ssa_loop_depth] = cond_bb
    ssa_loop_depth = ssa_loop_depth + 1
    body_tail: uint32 = ssa_lower_chain(body_bb, nd_b[stmt])
    ssa_loop_depth = ssa_loop_depth - 1
    if body_tail != 0:
        ssa_terminate_br(body_tail, cond_bb)
    ssa_seal_block(cond_bb)               # cond's preds (body tail + continues) known
    ssa_cur_bb = cond_bb
    cond: uint32 = ssa_lower_expr(nd_a[stmt], cond_bb)
    if cond == 0:
        return 0
    ccb: uint32 = ssa_cur_bb              # a short-circuit condition splits control
    ssa_terminate_condbr(ccb, cond, body_bb, exit_bb)  # back-edge to body wired
    ssa_seal_block(body_bb)               # now all body preds known
    ssa_seal_block(exit_bb)
    return exit_bb


# =======================================================================
# pre-alloca scan (LLVM/memory path only): reserve every memory-modeled local's
# stack slot (SVO_ALLOCA) in the ENTRY block BEFORE statement lowering, while
# entry is still open (no terminator).  This keeps every alloca dominating its
# uses and never appends an instruction after a block terminator.  Only var
# decls that classify as memory (array, or address-taken/slot-read scalar) are
# interned here; promotable scalars are left for normal lowering (their
# classification is byte-inert).  The walk mirrors the lowerable control-flow
# subset (if / while / do-while); constructs that bail during lowering need no
# pre-scan (the whole function bails).
def ssa_prealloc_decl(stmt: uint32):
    tnode: uint32 = nd_a[stmt]
    nid0: uint32 = nm_intern(nd_name_off[stmt], nd_name_len[stmt])
    if nid0 >= NM_MAX:
        return
    is_mem: uint32 = 0
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        is_mem = 1
    elif ssa_name_promotable(nid0) == 0:
        is_mem = 1
    if is_mem != 0:
        ssa_intern_local(nd_name_off[stmt], nd_name_len[stmt], tnode)


def ssa_prealloc_if_alts(elif_head: uint32, else_head: uint32):
    e: uint32 = elif_head
    while e != 0:
        if ssa_bail != 0:
            return
        ssa_prealloc_scan(nd_b[e])
        e = nd_next[e]
    if else_head != 0:
        ssa_prealloc_scan(else_head)


def ssa_prealloc_scan(head: uint32):
    s: uint32 = head
    while s != 0:
        if ssa_bail != 0:
            return
        k: uint32 = nd_kind[s]
        if k == ND_VAR_DECL:
            ssa_prealloc_decl(s)
        elif k == ND_IF:
            ssa_prealloc_scan(nd_b[s])
            ssa_prealloc_if_alts(nd_c[s], nd_d[s])
        elif k == ND_WHILE or k == ND_DO_WHILE:
            ssa_prealloc_scan(nd_b[s])
        s = nd_next[s]


# =======================================================================
# whole-function build.  Returns the entry bid, or 0 on bail/overflow.
# =======================================================================
def ssa_build_function(fn: uint32) -> uint32:
    # Reuse cfg.ad's name interning + escape scan for the promotability test.
    ok: uint32 = cfg_build_function(fn)
    if ok == 0:
        return 0                          # cfg overflow -> escape hatch
    cl_build(fn)

    ssa_reset()
    # clear the known-locals set for this function.
    i: uint32 = 0
    while i < NM_MAX:
        ssa_islocal[i] = 0
        ssa_local_sgn[i] = 0
        ssa_local_size[i] = 8
        ssa_ismem[i] = 0
        ssa_mem_addr[i] = 0
        ssa_mem_esz[i] = 0
        ssa_mem_esgn[i] = 0
        ssa_mem_isarr[i] = 0
        ssa_ptr_esz[i] = 0
        ssa_ptr_esgn[i] = 0
        ssa_local_fw[i] = 0
        ssa_local_struct[i] = 0
        ssa_local_struct_is_ptr[i] = 0
        i = i + 1
    # Braun current-def / incomplete-phi rows are cleared per block in bb_new_ssa
    # (indexed [block * NM_MAX + var]), so no stale mapping leaks between funcs.

    entry: uint32 = bb_new_ssa()
    if entry == 0:
        return 0
    sb_entry = entry
    sb_sealed[entry] = 1                  # entry has no predecessors

    # Parameters become SVO_PARAM values written in the entry block.  Each param
    # must be a promotable scalar (else escape-hatch bail).
    p: uint32 = nd_a[fn]
    pidx: uint32 = 0
    while p != 0:
        if nd_kind[p] == ND_PARAM:
            # >6 params need SysV stack-arg spill (args 7+ arrive on the stack).
            # The native round-trip only spills the 6 register args, so it bails.
            # On the LLVM path (ssa_mem_model != 0) LLVM lowers the calling
            # convention, so any param arity is accepted (SVO_PARAM per index).
            if pidx >= 6 and ssa_mem_model == 0:
                ssa_set_bail(SBR_MANYARGS)
                return 0
            nid: uint32 = ssa_intern_local(nd_name_off[p], nd_name_len[p], nd_a[p])
            if nid >= NM_MAX:
                return 0
            pv: uint32 = sv_new(SVO_PARAM)
            if pv == 0:
                return 0
            sv_aux[pv] = pidx
            sv_ast[pv] = p
            bb_append(entry, pv)
            if ssa_ismem[nid] != 0:
                # Address-taken param: spill the incoming argument register into
                # the param's stack slot; every read loads from it.  (An array
                # passed by value is not in the ABI subset.)
                if ssa_mem_isarr[nid] != 0:
                    ssa_set_bail(SBR_MEMORY)
                    return 0
                ssa_store_at_in(ssa_mem_addr[nid], pv, ssa_mem_esz[nid], entry)
            elif ssa_local_fw[nid] != 0:
                # Float parameter (LLVM path): stamp its float type on the param
                # value and bind it directly (no width truncation for floats).
                sv_type[pv] = ssa_fw_svt(ssa_local_fw[nid])
                ssa_write_var(nid, entry, pv)
            else:
                # A narrow parameter is truncated to its declared width on entry
                # (the legacy sized param spill), so every read sees the truncated
                # value regardless of the caller's upper argument-register bits.
                pvt: uint32 = ssa_trunc_to_local(nid, pv, entry)
                if pvt == 0:
                    return 0
                ssa_write_var(nid, entry, pvt)
        pidx = pidx + 1
        p = nd_next[p]

    if ssa_bail != 0:
        return 0

    # Reserve memory-local stack slots in the entry block before lowering (LLVM
    # path only; the native path leaves ssa_mem_model=0 and skips this, staying
    # byte-identical).
    if ssa_mem_model != 0:
        ssa_prealloc_scan(nd_c[fn])
        if ssa_bail != 0:
            return 0

    tail: uint32 = ssa_lower_chain(entry, nd_c[fn])
    if ssa_bail != 0:
        return 0
    # implicit return at the fallthrough tail (void or default).
    if tail != 0:
        ret: uint32 = sv_new(SVO_RET)
        if ret == 0:
            return 0
        sv_a[ret] = 0
        bb_append(tail, ret)
        sb_term[tail] = SVO_RET

    if ssa_bail != 0:
        return 0
    return entry


# =======================================================================
# 3.1  dominator tree (computed AFTER construction, as analysis).
# =======================================================================
# Recursive DFS postorder over successor edges from entry.
def ssa_dfs_post(bb: uint32):
    if bb == 0 or sb_visited[bb] != 0:
        return
    sb_visited[bb] = 1
    if sb_nsucc[bb] >= 1:
        ssa_dfs_post(sb_succ0[bb])
    if sb_nsucc[bb] >= 2:
        ssa_dfs_post(sb_succ1[bb])
    sb_ponum[bb] = sb_po_n
    sb_po[sb_po_n] = bb
    sb_po_n = sb_po_n + 1


def ssa_build_rpo():
    b: uint32 = 0
    while b < sb_count:
        sb_visited[b] = 0
        sb_ponum[b] = 0
        b = b + 1
    sb_po_n = 0
    ssa_dfs_post(sb_entry)
    # reverse postorder = reverse of postorder list.
    sb_rpo_n = sb_po_n
    i: uint32 = 0
    while i < sb_po_n:
        sb_rpo[i] = sb_po[sb_po_n - 1 - i]
        i = i + 1


# Cooper-Harvey-Kennedy intersect using postorder numbers (higher = nearer entry).
def ssa_dom_intersect(a: uint32, b: uint32) -> uint32:
    x: uint32 = a
    y: uint32 = b
    while x != y:
        while sb_ponum[x] < sb_ponum[y]:
            x = sb_idom[x]
        while sb_ponum[y] < sb_ponum[x]:
            y = sb_idom[y]
    return x


def ssa_build_domtree():
    ssa_build_rpo()
    b: uint32 = 0
    while b < sb_count:
        sb_idom[b] = 0
        b = b + 1
    sb_idom[sb_entry] = sb_entry
    changed: uint32 = 1
    while changed != 0:
        changed = 0
        i: uint32 = 0
        while i < sb_rpo_n:
            bb: uint32 = sb_rpo[i]
            if bb != sb_entry:
                newidom: uint32 = 0
                node: uint32 = sb_pred_head[bb]
                while node != 0:
                    p: uint32 = pl_bid[node]
                    if sb_idom[p] != 0:
                        if newidom == 0:
                            newidom = p
                        else:
                            newidom = ssa_dom_intersect(p, newidom)
                    node = pl_next[node]
                if newidom != 0 and sb_idom[bb] != newidom:
                    sb_idom[bb] = newidom
                    changed = 1
            i = i + 1


# Does block `a` dominate block `b`?  Walk the idom chain up from b to entry.
def ssa_dominates(a: uint32, b: uint32) -> uint32:
    x: uint32 = b
    while x != 0:
        if x == a:
            return 1
        nx: uint32 = sb_idom[x]
        if nx == x:
            return 0                       # reached entry (idom self)
        x = nx
    return 0


# =======================================================================
# 3.4  ssa_verify — SSA well-formedness.  Returns SSAV_OK or a failure code.
# =======================================================================
SSAV_OK: uint32 = 0
SSAV_NO_TERM: uint32 = 1          # block has no terminator
SSAV_TERM_NOT_LAST: uint32 = 2   # a terminator is not the last value in its block
SSAV_MID_TERM: uint32 = 3        # a non-last value is a terminator
SSAV_USE_NOT_DOM: uint32 = 4     # a use is not dominated by its def
SSAV_PHI_PRED_MISMATCH: uint32 = 5  # phi operand count != predecessor count
SSAV_PHI_NOT_HEAD: uint32 = 6    # phi not at block head
SSAV_PHI_BAD_PRED: uint32 = 7    # phi operand's pred is not a predecessor
SSAV_BAD_EDGE: uint32 = 8        # edge endpoint does not exist
SSAV_NO_DEF: uint32 = 9          # a use references an undefined value id

# deliberate-break switch (mirrors ir_castcall_break_flag / lr_holes_break):
# armed by --ssa-break, corrupts one phi's operand count so the verifier MUST
# catch it — proving the verifier actually guards soundness.
ssa_break_flag: uint32 = 0


def ssa_set_break(v: uint32):
    ssa_break_flag = v


# Corrupt the IR when armed: drop one operand from the first phi found, so its
# operand count no longer matches its predecessor count.  If no phi exists, drop
# a block's terminator instead.  Called after a successful build in the demo.
def ssa_break_apply():
    if ssa_break_flag == 0:
        return
    v: uint32 = 1
    while v < sv_count:
        if sv_op[v] == SVO_PHI and sv_arg_head[v] != 0:
            sv_arg_head[v] = arg_next[sv_arg_head[v]]   # unlink one operand
            sv_argn[v] = sv_argn[v] - 1
            return
        v = v + 1
    # no phi: corrupt a terminator (clear the entry block's terminator record).
    if sb_entry != 0:
        sb_term[sb_entry] = 0
        sb_last_val[sb_entry] = 0


# Is value id `v` a real, defined value?
def ssa_val_defined(v: uint32) -> uint32:
    if v == 0:
        return 0
    if v >= sv_count:
        return 0
    return 1


# Check that operand value `use` (used at position `pos` in block `ub`) is
# dominated by its definition.  Returns 1 if OK.
def ssa_check_use_dom(use: uint32, ub: uint32, pos: uint32) -> uint32:
    if ssa_val_defined(use) == 0:
        return 0
    db: uint32 = sv_block[use]
    if db == ub:
        return sv_pos[use] < pos           # def before use in the same block
    return ssa_dominates(db, ub)


def ssa_verify() -> uint32:
    ssa_build_domtree()
    # 1. every block has exactly one terminator, last in its list.
    b: uint32 = 1
    while b < sb_count:
        # skip unreachable blocks (not in RPO) — they carry no obligations.
        if sb_visited[b] != 0:
            last: uint32 = sb_last_val[b]
            if last == 0 or ssa_is_terminator(sv_op[last]) == 0:
                ssa_stat_fail_code = SSAV_NO_TERM
                return SSAV_NO_TERM
            # no terminator may appear before the last value.
            cur: uint32 = sb_first_val[b]
            while cur != 0:
                if cur != last and ssa_is_terminator(sv_op[cur]) != 0:
                    ssa_stat_fail_code = SSAV_MID_TERM
                    return SSAV_MID_TERM
                cur = sv_next[cur]
        b = b + 1

    # 2. per-value checks: phi placement/operands + use dominance.
    b = 1
    while b < sb_count:
        if sb_visited[b] != 0:
            first: uint32 = sb_first_val[b]
            seen_nonphi: uint32 = 0
            cur2: uint32 = first
            while cur2 != 0:
                op: uint32 = sv_op[cur2]
                if op == SVO_PHI:
                    if seen_nonphi != 0:
                        ssa_stat_fail_code = SSAV_PHI_NOT_HEAD
                        return SSAV_PHI_NOT_HEAD
                    rc: uint32 = ssa_verify_phi(cur2, b)
                    if rc != SSAV_OK:
                        ssa_stat_fail_code = rc
                        return rc
                else:
                    seen_nonphi = 1
                    rc2: uint32 = ssa_verify_uses(cur2, b)
                    if rc2 != SSAV_OK:
                        ssa_stat_fail_code = rc2
                        return rc2
                cur2 = sv_next[cur2]
        b = b + 1
    ssa_stat_fail_code = SSAV_OK
    return SSAV_OK


def ssa_is_terminator(op: uint32) -> uint32:
    if op == SVO_BR or op == SVO_CONDBR or op == SVO_RET:
        return 1
    return 0


# Verify a phi: exactly one operand per predecessor, each operand's value
# dominates its incoming predecessor's terminator, each pred is a real pred.
def ssa_verify_phi(phi: uint32, bb: uint32) -> uint32:
    if sv_argn[phi] != sb_npred[bb]:
        return SSAV_PHI_PRED_MISMATCH
    node: uint32 = sv_arg_head[phi]
    while node != 0:
        p: uint32 = arg_pred[node]
        v: uint32 = arg_val[node]
        if ssa_block_is_pred(p, bb) == 0:
            return SSAV_PHI_BAD_PRED
        if ssa_val_defined(v) == 0:
            return SSAV_NO_DEF
        # incoming value must be available at the end of pred p.
        vb: uint32 = sv_block[v]
        if vb != p and ssa_dominates(vb, p) == 0:
            return SSAV_USE_NOT_DOM
        node = arg_next[node]
    return SSAV_OK


def ssa_block_is_pred(p: uint32, bb: uint32) -> uint32:
    node: uint32 = sb_pred_head[bb]
    while node != 0:
        if pl_bid[node] == p:
            return 1
        node = pl_next[node]
    return 0


# Verify the operand uses of a non-phi value are dominated by their defs.
def ssa_verify_uses(v: uint32, bb: uint32) -> uint32:
    op: uint32 = sv_op[v]
    pos: uint32 = sv_pos[v]
    # SVO_BR/SVO_CONDBR carry block ids in sv_a/sv_b/sv_c that are NOT values.
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_FCMP or op == SVO_GEP or op == SVO_STORE:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        if ssa_check_use_dom(sv_b[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT or op == SVO_LOAD:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_TRUNC or op == SVO_ZEXT or op == SVO_SEXT or op == SVO_BITCAST or op == SVO_I2F or op == SVO_F2I:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_CONDBR:
        if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
            return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_RET:
        if sv_a[v] != 0:
            if ssa_check_use_dom(sv_a[v], bb, pos) == 0:
                return SSAV_USE_NOT_DOM
        return SSAV_OK
    if op == SVO_CALL:
        node: uint32 = sv_arg_head[v]
        while node != 0:
            if ssa_check_use_dom(arg_val[node], bb, pos) == 0:
                return SSAV_USE_NOT_DOM
            node = arg_next[node]
        return SSAV_OK
    # const/param/undef/globaladdr/percpu/alloca: no value operands.
    return SSAV_OK


# =======================================================================
# program-level driver lane (the --dump-ssa / ADDER_OPT2 analysis pass).
# Builds + verifies SSA for every function; accumulates stats; NEVER emits
# code and NEVER mutates the AST, so it cannot perturb codegen output.
# =======================================================================
def ssa_stats_reset():
    ssa_stat_funcs = 0
    ssa_stat_accepted = 0
    ssa_stat_fallback = 0
    ssa_stat_verify_ok = 0
    ssa_stat_verify_fail = 0
    ssa_stat_values = 0
    ssa_stat_blocks = 0
    ssa_stat_phis = 0
    ssa_stat_fail_code = 0


# Count phis in the current function (post-build).
def ssa_count_phis() -> uint32:
    n: uint32 = 0
    v: uint32 = 1
    while v < sv_count:
        if sv_op[v] == SVO_PHI:
            n = n + 1
        v = v + 1
    return n


# Build+verify SSA for one function.  Returns 1 if accepted+verified, 0 if it
# fell back (escape hatch) or failed verification.
def ssa_process_function(fn: uint32) -> uint32:
    ssa_stat_funcs = ssa_stat_funcs + 1
    entry: uint32 = ssa_build_function(fn)
    if entry == 0 or ssa_bail != 0:
        ssa_stat_fallback = ssa_stat_fallback + 1
        return 0
    ssa_stat_accepted = ssa_stat_accepted + 1
    ssa_stat_values = ssa_stat_values + (sv_count - 1)
    ssa_stat_blocks = ssa_stat_blocks + (sb_count - 1)
    ssa_stat_phis = ssa_stat_phis + ssa_count_phis()
    ssa_break_apply()                     # inert unless --ssa-break armed
    rc: uint32 = ssa_verify()
    if rc == SSAV_OK:
        ssa_stat_verify_ok = ssa_stat_verify_ok + 1
        return 1
    ssa_stat_verify_fail = ssa_stat_verify_fail + 1
    return 0


# Walk the program's ND_FUNCTION decl chain (ND_PROGRAM: b = decl chain head).
def ssa_run_program(prog: uint32):
    ssa_stats_reset()
    if prog == 0:
        return
    ssa_prog_decls = nd_b[prog]
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            ssa_process_function(cur)
        cur = nd_next[cur]


# Parse ADDER_OPT2 from the process environment (mirrors opt_parse_disable_env).
# ADDER_OPT2=1 (or any non-empty value) arms ssa_enabled.  Unset => stays off =>
# byte-identical default path.
def ssa_str_prefix_len(e: Ptr[uint8], pfx: Ptr[uint8]) -> uint32:
    j: uint32 = 0
    while pfx[j] != 0:
        if e[j] != pfx[j]:
            return 0
        j = j + 1
    return j


def ssa_parse_env(argc: int32, argv: Ptr[uint64]):
    ei: uint32 = cast[uint32](argc) + 1
    while argv[ei] != 0:
        e: Ptr[uint8] = cast[Ptr[uint8]](argv[ei])
        klen: uint32 = ssa_str_prefix_len(e, "ADDER_OPT2=")
        if klen != 0:
            # any non-empty value past the '=' arms the gate.
            if e[klen] != 0:
                ssa_enabled = 1
        ei = ei + 1

# adder/compiler/lex_selftest.ad
#
# On-device self-test for the Adder-in-Adder lexer.
#
# Passes a tiny Adder snippet (as a string literal) to the Adder
# lexer implementation (compiler/lexer.ad), then verifies the output
# token sequence matches the expected stream. Prints a PASS sentinel
# on success.
#
# This is the "Adder lexing Adder, on the device" proof — the first
# self-hosting milestone: Adder lexing its own syntax, on device.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       adder/compiler/lex_selftest.ad -o build/user/lex_selftest.elf
#
# Test harness: scripts/test_selfhost_lex.sh

from compiler.lexer import (
    lex_init,
    lex_tokenize,
    tok_type,
    tok_count,
    strbuf,
    tok_val_start,
    tok_val_len,
    tok_num_val,
    TOK_DEF,
    TOK_IDENT,
    TOK_LPAREN,
    TOK_RPAREN,
    TOK_ARROW,
    TOK_INT32,
    TOK_COLON,
    TOK_NEWLINE,
    TOK_INDENT,
    TOK_DEDENT,
    TOK_RETURN,
    TOK_NUMBER,
    TOK_EOF,
    TOK_PLUS,
    TOK_COMMA,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def emit_nl():
    sys_write(1, "\n", 1)


def put_u32(v: uint32):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


def put_u64(v: uint64):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[24, uint8]
    i: uint64 = 0
    n: uint64 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[24, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


def tok_name(t: uint32) -> Ptr[uint8]:
    if t == TOK_DEF:
        return "DEF"
    if t == TOK_IDENT:
        return "IDENT"
    if t == TOK_LPAREN:
        return "LPAREN"
    if t == TOK_RPAREN:
        return "RPAREN"
    if t == TOK_ARROW:
        return "ARROW"
    if t == TOK_INT32:
        return "INT32"
    if t == TOK_COLON:
        return "COLON"
    if t == TOK_NEWLINE:
        return "NEWLINE"
    if t == TOK_INDENT:
        return "INDENT"
    if t == TOK_DEDENT:
        return "DEDENT"
    if t == TOK_RETURN:
        return "RETURN"
    if t == TOK_NUMBER:
        return "NUMBER"
    if t == TOK_EOF:
        return "EOF"
    if t == TOK_PLUS:
        return "PLUS"
    if t == TOK_COMMA:
        return "COMMA"
    return "OTHER"


def print_tok(idx: uint32):
    t: uint32 = tok_type[idx]
    emit("[lex_selftest] tok[")
    put_u32(idx)
    emit("] ")
    emit(tok_name(t))
    if t == TOK_IDENT:
        vs: uint32 = tok_val_start[idx]
        vl: uint32 = tok_val_len[idx]
        emit("(")
        sys_write(1, &strbuf[vs], cast[uint64](vl))
        emit(")")
    if t == TOK_NUMBER:
        emit("(")
        put_u64(tok_num_val[idx])
        emit(")")
    emit_nl()


# Expected token sequence for:
#   def add(bytes: int32, field: int32) -> int32:
#       return bytes + field
#
# Tokens: DEF IDENT(add) LPAREN IDENT(bytes) COLON INT32 COMMA
#         IDENT(field) COLON INT32 RPAREN ARROW INT32 COLON NEWLINE
#         INDENT RETURN IDENT(bytes) PLUS IDENT(field) NEWLINE DEDENT EOF
# = 23 tokens
#
# REGRESSION GUARD: `bytes` and `field` are used here as ordinary identifier
# names (a param and a var). They were once speculatively reserved keywords
# (TOK_BYTES/TOK_FIELD) with no parser/codegen consumers; agents legitimately
# use them as identifiers in kernel source (e.g. init/cgroup.ad's
# cgroup_mem_would_exceed(cg, bytes)). The frozen Python seed un-reserves them
# so they lex as IDENTs; the native lexer (compiler/lexer.ad) must match. If
# anyone re-reserves either word, these positions stop being TOK_IDENT and
# this self-test FAILS loudly — keeping the native whole-kernel compile green.
EXPECTED_COUNT: uint32 = 23
EXPECTED: Array[23, uint32]

def fill_expected():
    EXPECTED[0] = TOK_DEF
    EXPECTED[1] = TOK_IDENT
    EXPECTED[2] = TOK_LPAREN
    EXPECTED[3] = TOK_IDENT
    EXPECTED[4] = TOK_COLON
    EXPECTED[5] = TOK_INT32
    EXPECTED[6] = TOK_COMMA
    EXPECTED[7] = TOK_IDENT
    EXPECTED[8] = TOK_COLON
    EXPECTED[9] = TOK_INT32
    EXPECTED[10] = TOK_RPAREN
    EXPECTED[11] = TOK_ARROW
    EXPECTED[12] = TOK_INT32
    EXPECTED[13] = TOK_COLON
    EXPECTED[14] = TOK_NEWLINE
    EXPECTED[15] = TOK_INDENT
    EXPECTED[16] = TOK_RETURN
    EXPECTED[17] = TOK_IDENT
    EXPECTED[18] = TOK_PLUS
    EXPECTED[19] = TOK_IDENT
    EXPECTED[20] = TOK_NEWLINE
    EXPECTED[21] = TOK_DEDENT
    EXPECTED[22] = TOK_EOF


def main() -> int32:
    emit("[lex_selftest] start: Adder lexer lexing Adder source, on device\n")

    fill_expected()

    # The test source snippet — a minimal but real Adder function.
    # String literals live in .rodata; we take the address directly.
    src: Ptr[uint8] = "def add(a: int32, b: int32) -> int32:\n    return a + b\n"
    src_len: uint32 = cast[uint32](strlen(src))

    emit("[lex_selftest] source: ")
    emit(src)

    lex_init(src, src_len)
    n: int32 = lex_tokenize()

    emit("[lex_selftest] got ")
    put_u32(cast[uint32](n))
    emit(" tokens\n")

    # Print the token stream
    i: uint32 = 0
    while i < tok_count:
        print_tok(i)
        i = i + 1

    # Validate count
    if cast[uint32](n) != EXPECTED_COUNT:
        emit("[lex_selftest] FAIL: expected ")
        put_u32(EXPECTED_COUNT)
        emit(" tokens, got ")
        put_u32(cast[uint32](n))
        emit_nl()
        sys_exit(1)

    # Validate each token type in order
    i = 0
    while i < EXPECTED_COUNT:
        if tok_type[i] != EXPECTED[i]:
            emit("[lex_selftest] FAIL at tok[")
            put_u32(i)
            emit("]: expected ")
            emit(tok_name(EXPECTED[i]))
            emit(" got ")
            emit(tok_name(tok_type[i]))
            emit_nl()
            sys_exit(1)
        i = i + 1

    emit("[lex_selftest] PASS\n")
    sys_exit(0)
    return 0

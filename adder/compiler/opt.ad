# adder/compiler/opt.ad
#
# Native Adder optimizer — Phase 1 pass manager + constant-folding pass.
#
# ROLE
# ----
# This is the opt-in entry point of the native optimizer. It runs AFTER the
# parser produces the AST and BEFORE codegen.ad walks it. With the opt flag
# OFF (the default), opt_run is never called, so the compiler takes the
# exact pre-existing AST -> codegen path and emits byte-identical output.
#
# With the flag ON (ADDER_OPT=1 / --opt), opt_run walks the whole program,
# lowers each constant integer expression subtree into the Phase-1 IR
# (ir.ad), evaluates it, and rewrites the AST ND_BINARY root in place into a
# single ND_INT_LIT. codegen.ad then emits the same `movq $imm,%rax` it
# would emit for any literal — i.e. the const computation collapses to its
# result. The transform is value-preserving over the foldable, signedness-
# invariant op set (see ir.ad), so ADDER_OPT=1 output stays BEHAVIORALLY
# correct (the fuzzer's ADDER_OPT=1 lane asserts this).
#
# PASS PLUMBING
# -------------
# Phase 1 ships one pass (constant folding). The "pass manager" is the
# fixed-point driver opt_run -> opt_walk: it descends the AST generically
# over every child slot (nd_a/nd_b/nd_c/nd_d and the nd_next sibling chain),
# attempts to fold each ND_BINARY it encounters, and counts the folds in
# opt_fold_count for logging. Later phases (LICM/CSE/regalloc) register as
# additional passes over the same IR substrate.

from compiler.parser import (
    nd_kind,
    nd_aux,
    nd_num,
    nd_name_off,
    nd_name_len,
    nd_a,
    nd_b,
    nd_c,
    nd_d,
    nd_next,
    nd_line,
    node_new,
    ND_INT_LIT,
    ND_FLOAT_LIT,
    ND_IDENT,
    ND_BINARY,
    ND_CAST,
    ND_INDEX,
    ND_TYPE,
    ND_ARRAY_TYPE,
    ND_PTR_TYPE,
    ND_PARAM,
    ND_VAR_DECL,
    ND_ASSIGN,
    ND_EXPR_STMT,
    ND_RETURN,
    ND_IF,
    ND_ELIF,
    ND_WHILE,
    ND_DO_WHILE,
    ND_FOR,
    ND_FOR_UNPACK,
    ND_FUNCTION,
    ND_CALL,
    ND_UNARY,
    ND_MEMBER,
    ND_CHAR_LIT,
    ND_BOOL_LIT,
    ND_CONDITIONAL,
    ND_PASS,
    UNOP_ADDR,
    UNOP_NOT,
    AUGOP_NONE,
    AUGOP_ADD,
    AUGOP_SUB,
    BINOP_ADD,
    BINOP_SUB,
    BINOP_MUL,
    BINOP_DIV,
    BINOP_IDIV,
    BINOP_MOD,
    BINOP_EQ,
    BINOP_NEQ,
    BINOP_AND,
    BINOP_OR,
    BINOP_BIT_AND,
)

from compiler.ir import (
    ir_reset,
    ir_lower_const_expr,
    ir_lower_pure_expr,
    ir_value_eq,
    ir_uses_name,
    ir_name_eq,
    ir_tree_has_div,
    ir_tree_has_leaf,
    ir_const,
    ir_kind,
    ir_ast,
    ir_name_off,
    ir_name_len,
    IR_BINOP,
)

from compiler.lexer import (
    strbuf,
    strbuf_pos,
)

# -----------------------------------------------------------------------
# Opt flag — OFF by default. The driver flips this to 1 on --opt / ADDER_OPT.
# When 0, opt_run is never invoked, so this whole module is inert and the
# default codegen path is byte-for-byte unchanged.
# -----------------------------------------------------------------------
opt_enabled: uint32 = 0

# Diagnostics: number of ND_BINARY subtrees folded into a constant. Logged by
# the driver so the fuzzer can assert the pass demonstrably fires.
opt_fold_count: uint32 = 0

# Diagnostics: number of redundant pure subexpressions eliminated by CSE
# (each elimination = one recomputation replaced by a load of a hoisted temp).
opt_cse_count: uint32 = 0

# Diagnostics: number of redundant integer ARRAY-element LOADS eliminated by the
# cross-statement load-CSE broadening (subset of opt_cse_count; counted
# separately so the firing test can assert load-CSE specifically).
opt_loadcse_count: uint32 = 0

# Monotonic counter for minting unique synthetic temp names (__cse_<n>).
opt_cse_tmp_seq: uint32 = 0

# Diagnostics: number of loop-invariant pure computations hoisted to a loop
# pre-header by Phase-3 LICM (one per hoisted expression value).
opt_licm_count: uint32 = 0

# Diagnostics: number of fully-dead local variable declarations removed by DCE
# (one per ND_VAR_DECL whose result is never read anywhere in the function and
# whose initializer is pure / side-effect-free, so deleting it is observably a
# no-op). See the Phase-8 DCE section at the bottom of this file.
opt_dce_count: uint32 = 0

# Diagnostics: number of constant-condition branches rewritten by Phase-1.5
# const-branch folding (one per ND_IF / ND_WHILE / ND_CONDITIONAL whose
# condition was a PROVABLE, side-effect-free compile-time constant and whose
# dead arm(s) were dropped). The dropped arm's locals/stmts then become dead
# code the Phase-8 DCE reclaims. See the Phase-1.5 section below.
opt_constbranch_count: uint32 = 0

# Diagnostics: number of identifier USES forwarded by Phase-9 copy propagation
# (one per `x` read rewritten to its copy source `y` for a pure copy `x = y`).
# After forwarding, the now-unused copy dest `x` typically becomes dead and the
# Phase-8 DCE removes its decl. See the Phase-9 COPY-PROP section at the bottom.
opt_copyprop_count: uint32 = 0

# Diagnostics: number of parity/divisibility idioms `x - (x/C)*C == 0` (or
# `x % C == 0`) folded to `(x & (C-1)) == 0` by the pow2-parity pass below.
opt_paritymod_count: uint32 = 0

# Diagnostics: number of affine array-index expressions strength-reduced to a
# running induction variable by Phase-3.6 IVSR (one per distinct affine index
# `arr[i*K + R]` over a counted loop whose IV `i` advances by a constant step,
# replaced by a pre-header-initialised running local advanced by the constant
# `K*step` each iteration — eliding the per-iteration multiply). See the IVSR
# section below + scripts/test_opt_ivsr.sh.
opt_ivsr_count: uint32 = 0


def opt_enable():
    opt_enabled = 1


def opt_reset_stats():
    opt_fold_count = 0
    opt_cse_count = 0
    opt_loadcse_count = 0
    opt_cse_tmp_seq = 0
    opt_licm_count = 0
    opt_dce_count = 0
    opt_ffold_count = 0
    opt_constbranch_count = 0
    opt_copyprop_count = 0
    opt_paritymod_count = 0
    opt_ivsr_count = 0


# =======================================================================
# FLOAT-TYPE ORACLE (opt-side mirror of codegen.ad expr_float_width).
# =======================================================================
#
# WHY opt.ad needs its OWN oracle: opt_run executes BEFORE codegen
# (gen_program_with_globals), so codegen's loc_is_float / glob_is_float tables
# are NOT yet populated — opt.ad cannot call expr_float_width. The CSE/LICM
# passes lower a float ND_BINARY through ir_lower_pure_expr into the SAME
# integer IR shape as an int op (a float `a + b` becomes an integer IR_BINOP),
# so a naive shared temp would be an UNTYPED 8-byte int slot and the reuse
# ND_IDENT would resolve to float width 0 -> codegen emits an INTEGER add/cmp
# for the reuse, miscompiling the float. To share a float value soundly the
# temp decl must carry the FLOAT TYPE so codegen sets loc_is_float and the
# reuse routes to the SSE path at the right width.
#
# This oracle reconstructs the per-expression float width from the AST alone by
# scanning declared types into a per-function local table + a once-built global
# table, exactly mirroring codegen.ad's type_float_width / expr_float_width:
#   * a primitive ND_TYPE node carries its keyword code in nd_aux (10=float32,
#     11=float64); width = 4 / 8 / 0,
#   * ND_FLOAT_LIT -> 8 (a bare float literal is a float64),
#   * ND_CAST -> the cast destination type's float width,
#   * ND_IDENT -> the named local's (then global's) recorded float width,
#   * ND_BINARY over ADD/SUB/MUL/DIV/IDIV -> wider of the two operand widths
#     (an int operand under a float op promotes; result is float),
#   * everything else -> 0 (NOT float; e.g. a COMPARE yields an int 0/1).
# The result is the EXACT float width codegen will compute, so a temp typed with
# it is value-identical to the inline float computation.

# Float width (0/4/8) of a primitive ND_TYPE node, matching codegen.ad
# type_float_width (codes 10->4, 11->8).
def opt_type_float_width(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    if code == 10:
        return 4
    if code == 11:
        return 8
    return 0


# Per-function local/param float-width table (name bytes -> width). Rebuilt at
# the start of each function's CSE / LICM / x-CSE pass. A name redeclared with a
# different float-ness keeps the LAST scanned width (conservative; codegen
# refreshes per VarDecl, but float locals never change width across redecls in
# this subset). Globals live in a once-built parallel table.
OPT_FW_MAX: uint32 = 4096
opt_fw_off: Array[4096, uint32]
opt_fw_len: Array[4096, uint32]
opt_fw_w: Array[4096, uint32]
opt_fw_n: uint32 = 0

OPT_GFW_MAX: uint32 = 4096
opt_gfw_off: Array[4096, uint32]
opt_gfw_len: Array[4096, uint32]
opt_gfw_w: Array[4096, uint32]
opt_gfw_n: uint32 = 0

# Program-wide set of GLOBAL variable NAMES (every top-level ND_VAR_DECL name,
# regardless of type). Consulted by the Phase-8 dead-STORE elimination: a store
# `g = <pure>` to a bare ident that names a GLOBAL is observable by OTHER
# functions (and by any later call), so "no read in THIS function" does NOT make
# it dead — only a LOCAL/param store is. Without this guard the DSE silently
# drops an externally-visible global store (e.g. `jeof = 1; return` in a helper),
# a miscompile that only appears under --opt.
# SIZE: must exceed the whole-program top-level global count. The full kernel
# closure (init/main.ad) declares well over 8192 top-level globals; at the old
# 8192 cap the tail of the global-name set was silently dropped, so a global
# declared past the cap (e.g. drivers/block/loop.ad's `loop_live_root_hook`)
# was mis-seen as NON-global and its externally-observable store was
# dead-store-eliminated — a --opt-only miscompile that broke the live-root
# mount hook. 65536 comfortably covers the kernel; the opt_gname_overflow guard
# below keeps the pass SOUND even if a future program exceeds even this.
OPT_GNAME_MAX: uint32 = 65536
opt_gname_off: Array[65536, uint32]
opt_gname_len: Array[65536, uint32]
opt_gname_n: uint32 = 0
# 1 iff opt_gname_add hit the cap and DROPPED at least one global. When set, the
# global-name set is INCOMPLETE, so a name absent from it is NOT provably a
# local — opt_gname_is_global then conservatively answers 1 (assume global) so
# the dead-STORE elimination never drops a possibly-global store. Soundness net
# for the cap; DSE simply stops firing past the cap rather than miscompiling.
opt_gname_overflow: uint32 = 0

# Diagnostics: number of fully-constant FLOAT subtrees const-folded.
opt_ffold_count: uint32 = 0


def opt_fw_reset():
    opt_fw_n = 0


def opt_fw_add(off: uint32, len_: uint32, w: uint32):
    if opt_fw_n >= OPT_FW_MAX:
        return
    opt_fw_off[opt_fw_n] = off
    opt_fw_len[opt_fw_n] = len_
    opt_fw_w[opt_fw_n] = w
    opt_fw_n = opt_fw_n + 1


# Look up a local/param float width (0 if not found / not a float).
def opt_fw_lookup(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < opt_fw_n:
        if ir_name_eq(opt_fw_off[i], opt_fw_len[i], off, len_) != 0:
            return opt_fw_w[i]
        i = i + 1
    return 0


def opt_gfw_add(off: uint32, len_: uint32, w: uint32):
    if opt_gfw_n >= OPT_GFW_MAX:
        return
    opt_gfw_off[opt_gfw_n] = off
    opt_gfw_len[opt_gfw_n] = len_
    opt_gfw_w[opt_gfw_n] = w
    opt_gfw_n = opt_gfw_n + 1


def opt_gfw_lookup(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < opt_gfw_n:
        if ir_name_eq(opt_gfw_off[i], opt_gfw_len[i], off, len_) != 0:
            return opt_gfw_w[i]
        i = i + 1
    return 0


# Record one global variable name (all types) into the global-name set.
def opt_gname_add(off: uint32, len_: uint32):
    if opt_gname_n >= OPT_GNAME_MAX:
        opt_gname_overflow = 1
        return
    opt_gname_off[opt_gname_n] = off
    opt_gname_len[opt_gname_n] = len_
    opt_gname_n = opt_gname_n + 1


# Build the program-wide global-name set from every top-level ND_VAR_DECL.
# Called once at opt_run start (globals are visible to every function).
def opt_gname_build(decls: uint32):
    opt_gname_n = 0
    opt_gname_overflow = 0
    cur: uint32 = decls
    while cur != 0:
        if nd_kind[cur] == ND_VAR_DECL:
            opt_gname_add(nd_name_off[cur], nd_name_len[cur])
        cur = nd_next[cur]


# 1 iff `name` is a program GLOBAL (a top-level var-decl). A store to such a
# name is externally observable and must NOT be dead-store-eliminated on a
# "no read in this function" basis.
def opt_gname_is_global(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < opt_gname_n:
        if ir_name_eq(opt_gname_off[i], opt_gname_len[i], off, len_) != 0:
            return 1
        i = i + 1
    # SOUNDNESS NET: if the set overflowed the cap, some globals were dropped, so
    # "not found" does NOT prove `name` is a local. Answer 1 (assume global) so
    # the dead-STORE elimination declines rather than risk dropping a global
    # store. Costs only a missed DSE opportunity for names past the cap.
    if opt_gname_overflow != 0:
        return 1
    return 0


# Scan one statement chain for ND_VAR_DECL float locals, recording each into the
# per-function table. Recurses into nested block bodies so a float declared in a
# loop/if body is seen. (Codegen sees every VarDecl's type; so must we.)
def opt_fw_scan_block(head: uint32):
    s: uint32 = head
    while s != 0:
        k: uint32 = nd_kind[s]
        if k == ND_VAR_DECL:
            w: uint32 = opt_type_float_width(nd_a[s])
            if w != 0:
                opt_fw_add(nd_name_off[s], nd_name_len[s], w)
        elif k == ND_IF:
            opt_fw_scan_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                opt_fw_scan_block(nd_b[e])
                e = nd_next[e]
            opt_fw_scan_block(nd_d[s])
        elif k == ND_WHILE:
            opt_fw_scan_block(nd_b[s])
        elif k == ND_DO_WHILE:
            opt_fw_scan_block(nd_b[s])
        elif k == ND_FOR:
            opt_fw_scan_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            opt_fw_scan_block(nd_c[s])
        s = nd_next[s]


# Build the per-function float-local table from the function's params + body
# var-decls. Called once before CSE / LICM / x-CSE of the function.
def opt_fw_build(fn: uint32):
    opt_fw_reset()
    # Params: ND_PARAM chain on nd_a, each with its type on nd_a.
    p: uint32 = nd_a[fn]
    while p != 0:
        if nd_kind[p] == ND_PARAM:
            w: uint32 = opt_type_float_width(nd_a[p])
            if w != 0:
                opt_fw_add(nd_name_off[p], nd_name_len[p], w)
        p = nd_next[p]
    # Body var-decls.
    opt_fw_scan_block(nd_c[fn])


# Build the program-wide global float table from top-level ND_VAR_DECL globals.
# Called once at opt_run start (globals are visible to every function).
def opt_gfw_build(decls: uint32):
    opt_gfw_n = 0
    cur: uint32 = decls
    while cur != 0:
        if nd_kind[cur] == ND_VAR_DECL:
            w: uint32 = opt_type_float_width(nd_a[cur])
            if w != 0:
                opt_gfw_add(nd_name_off[cur], nd_name_len[cur], w)
        cur = nd_next[cur]


# =======================================================================
# ELEMENT-FLOAT tables — soundness gate for LOAD-CSE (Phase 7 broadening).
# =======================================================================
#
# Load-CSE shares a redundant array/pointer element load `base[idx]` across
# straight-line statements by hoisting it into an UNTYPED 8-byte scalar temp.
# That round-trips an INTEGER element bit-for-bit (a movq store + movq load),
# but a FLOAT element value would be mis-typed: the reuse ND_IDENT resolves to
# float width 0 -> codegen emits an integer move for an SSE value (a float
# miscompile, the exact trap the CSE/LICM float-typing oracle exists to avoid).
#
# opt.ad has no element-type table (the scalar opt_fw_/opt_gfw_ tables only
# record float SCALAR locals/globals). So we record, per local/global NAME, a
# 1/0 flag: 1 = the name is an array/pointer whose ELEMENT is a primitive
# SCALAR INTEGER (int8..uint64) — the ONLY shape whose `base[idx]` is a plain
# scalar value load that round-trips an untyped 8-byte temp bit-for-bit. A
# FLOAT element (would mis-type the SSE value), an AGGREGATE element (e.g.
# `Array[r, Array[c, int]]` — `g[a]` is a ROW ADDRESS, not a scalar value, so
# CSE-ing it into a scalar temp and re-indexing it dereferences garbage), a
# pointer-to-nonint, a struct/bool/char/str element, or an unknown name all
# record 0 -> the load gate DECLINES (the conservative default).
OPT_EFW_MAX: uint32 = 4096
opt_efw_off: Array[4096, uint32]
opt_efw_len: Array[4096, uint32]
opt_efw_ok: Array[4096, uint32]     # 1 = scalar-integer element (admit)
opt_efw_n: uint32 = 0

OPT_EGFW_MAX: uint32 = 4096
opt_egfw_off: Array[4096, uint32]
opt_egfw_len: Array[4096, uint32]
opt_egfw_ok: Array[4096, uint32]
opt_egfw_n: uint32 = 0


# Is a primitive ND_TYPE node a SCALAR INTEGER (int8..uint64, codes 2..9)?
# Floats (10/11), bool(12)/char(13)/str(14), and the None marker (1) are NOT
# admitted: floats route to SSE, and bool/char/str have width/semantics we keep
# off the integer-temp fast path conservatively.
def opt_type_is_scalar_int(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    if code >= 2 and code <= 9:
        return 1
    return 0


# Does a var-decl/param TYPE node declare an array/pointer with a SCALAR INTEGER
# element? returns 2 (recognized aggregate, scalar-int elem -> record ok=1),
# 1 (recognized aggregate, NON-scalar-int elem -> record ok=0), 0 (NOT an
# array/ptr decl -> don't record at all; the name resolves to "unknown" later,
# which the gate declines anyway). Splitting 1 vs 0 lets us POSITIVELY record a
# float/aggregate-element array as ok=0 so a same-named outer scope can't be
# confused — though in practice "don't record" and "record 0" both decline.
def opt_elem_class(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    k: uint32 = nd_kind[tnode]
    if k == ND_ARRAY_TYPE or k == ND_PTR_TYPE:
        if opt_type_is_scalar_int(nd_a[tnode]) != 0:
            return 2
        return 1
    return 0


def opt_efw_add(off: uint32, len_: uint32, ok: uint32):
    if opt_efw_n >= OPT_EFW_MAX:
        return
    opt_efw_off[opt_efw_n] = off
    opt_efw_len[opt_efw_n] = len_
    opt_efw_ok[opt_efw_n] = ok
    opt_efw_n = opt_efw_n + 1


def opt_egfw_add(off: uint32, len_: uint32, ok: uint32):
    if opt_egfw_n >= OPT_EGFW_MAX:
        return
    opt_egfw_off[opt_egfw_n] = off
    opt_egfw_len[opt_egfw_n] = len_
    opt_egfw_ok[opt_egfw_n] = ok
    opt_egfw_n = opt_egfw_n + 1


# Scan one statement chain for ARRAY/POINTER var-decls, recording each base
# name's scalar-int-element flag. Recurses into nested blocks (mirrors
# opt_fw_scan_block).
def opt_efw_scan_block(head: uint32):
    s: uint32 = head
    while s != 0:
        k: uint32 = nd_kind[s]
        if k == ND_VAR_DECL:
            c: uint32 = opt_elem_class(nd_a[s])
            if c != 0:
                ok: uint32 = 0
                if c == 2:
                    ok = 1
                opt_efw_add(nd_name_off[s], nd_name_len[s], ok)
        elif k == ND_IF:
            opt_efw_scan_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                opt_efw_scan_block(nd_b[e])
                e = nd_next[e]
            opt_efw_scan_block(nd_d[s])
        elif k == ND_WHILE:
            opt_efw_scan_block(nd_b[s])
        elif k == ND_DO_WHILE:
            opt_efw_scan_block(nd_b[s])
        elif k == ND_FOR:
            opt_efw_scan_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            opt_efw_scan_block(nd_c[s])
        s = nd_next[s]


# Build the per-function element table from params + body var-decls.
def opt_efw_build(fn: uint32):
    opt_efw_n = 0
    p: uint32 = nd_a[fn]
    while p != 0:
        if nd_kind[p] == ND_PARAM:
            c: uint32 = opt_elem_class(nd_a[p])
            if c != 0:
                ok: uint32 = 0
                if c == 2:
                    ok = 1
                opt_efw_add(nd_name_off[p], nd_name_len[p], ok)
        p = nd_next[p]
    opt_efw_scan_block(nd_c[fn])


# Build the program-wide global element table from top-level array/ptr globals.
def opt_egfw_build(decls: uint32):
    opt_egfw_n = 0
    cur: uint32 = decls
    while cur != 0:
        if nd_kind[cur] == ND_VAR_DECL:
            c: uint32 = opt_elem_class(nd_a[cur])
            if c != 0:
                ok: uint32 = 0
                if c == 2:
                    ok = 1
                opt_egfw_add(nd_name_off[cur], nd_name_len[cur], ok)
        cur = nd_next[cur]


# Is the base ident a KNOWN scalar-integer-element array/pointer? (local shadows
# global.) Returns 1 only when positively recorded ok=1; ANY unknown / non-int /
# aggregate / float element returns 0 -> the gate declines.
def opt_base_is_scalar_int_array(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < opt_efw_n:
        if ir_name_eq(opt_efw_off[i], opt_efw_len[i], off, len_) != 0:
            return opt_efw_ok[i]
        i = i + 1
    j: uint32 = 0
    while j < opt_egfw_n:
        if ir_name_eq(opt_egfw_off[j], opt_egfw_len[j], off, len_) != 0:
            return opt_egfw_ok[j]
        j = j + 1
    return 0


# Is `node` an ND_INDEX load we may SOUNDLY load-CSE into an untyped int temp?
# Requires ALL of:
#   * node is ND_INDEX,
#   * its base (nd_a) is a BARE IDENT (no nested index / cast / call / member
#     base — a nested index base is a ROW ADDRESS of a multi-dim array, NOT a
#     scalar value; CSE-ing it would dereference garbage),
#   * that ident is a known array/pointer with a primitive SCALAR INTEGER element
#     (opt_base_is_scalar_int_array — float / aggregate / unknown all decline),
#   * the index subtree (nd_b) contains NO float anywhere (cheap insurance).
# Returns 1 to admit, 0 to DECLINE (the conservative default).
def opt_index_load_is_int(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_INDEX:
        return 0
    base: uint32 = nd_a[node]
    if base == 0 or nd_kind[base] != ND_IDENT:
        return 0
    if opt_base_is_scalar_int_array(nd_name_off[base], nd_name_len[base]) == 0:
        return 0                       # unknown / non-int / aggregate -> decline
    if opt_subtree_has_float(nd_b[node]) != 0:
        return 0
    return 1


# Float width (0/4/8) of an EXPRESSION — the opt-side mirror of codegen.ad
# expr_float_width. A non-float expression (incl. a float COMPARE, whose result
# is an int 0/1) returns 0.
def opt_expr_float_width(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_FLOAT_LIT:
        return 8
    if k == ND_CAST:
        return opt_type_float_width(nd_a[node])
    if k == ND_IDENT:
        lf: uint32 = opt_fw_lookup(nd_name_off[node], nd_name_len[node])
        if lf != 0:
            return lf
        return opt_gfw_lookup(nd_name_off[node], nd_name_len[node])
    if k == ND_BINARY:
        bop: uint32 = nd_aux[node]
        if bop == BINOP_ADD or bop == BINOP_SUB or bop == BINOP_MUL or bop == BINOP_DIV or bop == BINOP_IDIV:
            lw: uint32 = opt_expr_float_width(nd_a[node])
            rw: uint32 = opt_expr_float_width(nd_b[node])
            if lw == 0 and rw == 0:
                return 0
            if lw >= rw:
                return lw
            return rw
        return 0
    return 0


# Does the AST subtree `node` contain ANY float-typed sub-expression anywhere?
# A conservative deep scan: a float literal, a cast TO a float type, or a float
# local/global ident at any depth flags the whole tree. Used by the const-fold
# pass to REFUSE folding any tree that touches a float (the integer
# ir_eval_binop has no IEEE-754 semantics — see opt_try_fold).
def opt_subtree_has_float(node: uint32) -> uint32:
    if node == 0:
        return 0
    if opt_expr_float_width(node) != 0:
        return 1
    k: uint32 = nd_kind[node]
    if k == ND_FLOAT_LIT:
        return 1
    if k == ND_CAST:
        if opt_type_float_width(nd_a[node]) != 0:
            return 1
        return opt_subtree_has_float(nd_b[node])
    if k == ND_IDENT:
        return 0
    if opt_subtree_has_float(nd_a[node]) != 0:
        return 1
    if opt_subtree_has_float(nd_b[node]) != 0:
        return 1
    if opt_subtree_has_float(nd_c[node]) != 0:
        return 1
    return opt_subtree_has_float(nd_d[node])


# Build a fresh primitive float ND_TYPE node (code 10=float32 for width 4,
# 11=float64 for width 8) so a CSE/LICM temp decl is typed FLOAT and codegen
# tags loc_is_float / loc scalar_size. Returns 0 on arena exhaustion or a
# non-float width (caller then mints an untyped int temp as before).
def opt_make_float_type(w: uint32) -> uint32:
    code: uint32 = 0
    if w == 4:
        code = 10
    elif w == 8:
        code = 11
    else:
        return 0
    t: uint32 = node_new(ND_TYPE)
    if t == 0:
        return 0
    nd_aux[t] = code
    return t


# =======================================================================
# FLOAT CONSTANT FOLDING (provably bit-identical, conservative).
# =======================================================================
#
# A fully-constant FLOAT arithmetic tree can be folded to a single float literal
# ONLY where the folded constant is PROVABLY the exact bit pattern the runtime
# SSE op would produce. This backend materializes a float constant via cvtsi2sd
# of an INTEGER (a bare ND_FLOAT_LIT carries an integer in nd_num; a
# cast[floatW](int-literal) converts an integer) — there are no fractional
# literals. So the sound foldable case is:
#
#   * LEAVES are exact-integer-valued floats: an ND_FLOAT_LIT (its nd_num
#     integer), or cast[float32|float64](<int/char/bool literal>). Each
#     materializes the exact integer as a float (cvtsi2sd/ss), no rounding when
#     the integer fits the mantissa.
#   * OPS are ADD/SUB/MUL only. Over exact integers these are EXACT in IEEE-754
#     whenever the true integer result is representable (|result| < 2^53 for f64
#     / < 2^24 for f32); SSE round-to-nearest is then the identity. DIV is
#     EXCLUDED (a quotient is generally not an exact integer -> not bit-provable).
#   * The WHOLE tree is float64-typed (opt_expr_float_width == 8). We fold ONLY
#     f64 trees because the fold target is an ND_FLOAT_LIT, which codegen ALWAYS
#     emits as a float64 (cvtsi2sd, emit_fp_convert(0,8)); folding an f32 tree to
#     an ND_FLOAT_LIT would silently widen it to f64 and miscompile an f32
#     consumer. An f32 constant tree therefore stays on the existing emit path
#     (still correct, just unfolded — a conservative residual).
#
# The folded integer value is range-checked: |v| < 2^53 guarantees both the
# IEEE op was exact AND the resulting ND_FLOAT_LIT's own cvtsi2sd reproduces it
# bit-for-bit. If ANYTHING is outside this proven subset, ffold returns 0 and the
# tree is emitted unchanged.

# Range bound: 2^53 (exact-integer limit of an IEEE float64 mantissa).
OPT_F64_EXACT: int64 = 9007199254740992       # 2^53


# Is `node` an exact-integer-valued FLOAT leaf? Writes the integer value through
# `*out` and returns 1 on success, 0 otherwise. An ND_FLOAT_LIT holds its integer
# in nd_num. A cast[floatW](int/char/bool literal) holds the integer in the
# operand literal's nd_num. (A cast of a non-literal is NOT a constant leaf.)
def opt_ffold_leaf_value(node: uint32, out: Ptr[int64]) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_FLOAT_LIT:
        if nd_aux[node] == 1:
            # nd_num is the float64 BIT PATTERN of a source literal. Recover its
            # exact-integer value iff it IS one (round-trips through int64);
            # a fractional literal (0.5) is NOT an exact-integer leaf, so it is
            # not ffold-able here.
            bpat: uint64 = nd_num[node]
            fv: float64 = cast[Ptr[float64]](&bpat)[0]
            iv: int64 = cast[int64](fv)
            back: float64 = cast[float64](iv)
            if back == fv:
                out[0] = iv
                return 1
            return 0
        out[0] = cast[int64](nd_num[node])
        return 1
    if k == ND_CAST:
        # Cast destination must be a float type, operand a bare integer literal.
        if opt_type_float_width(nd_a[node]) == 0:
            return 0
        op0: uint32 = nd_b[node]
        if op0 == 0:
            return 0
        ok0: uint32 = nd_kind[op0]
        if ok0 == ND_INT_LIT or ok0 == ND_CHAR_LIT or ok0 == ND_BOOL_LIT:
            out[0] = cast[int64](nd_num[op0])
            return 1
    return 0


# Evaluate a fully-constant exact-integer FLOAT arith subtree to its integer
# value through `*out`. Returns 1 iff the WHOLE tree is foldable AND every
# intermediate AND the final result stays within the |v| < 2^53 exact-integer
# range (so each IEEE add/sub/mul was exact). ADD/SUB/MUL only. A leaf delegates
# to opt_ffold_leaf_value. Recursion mirrors AST expression depth.
def opt_ffold_eval(node: uint32, out: Ptr[int64]) -> uint32:
    if node == 0:
        return 0
    if opt_ffold_leaf_value(node, out) != 0:
        # Leaf integer must itself be exactly representable.
        lv: int64 = out[0]
        if lv >= OPT_F64_EXACT or lv <= (0 - OPT_F64_EXACT):
            return 0
        return 1
    if nd_kind[node] != ND_BINARY:
        return 0
    op: uint32 = nd_aux[node]
    if op != BINOP_ADD and op != BINOP_SUB and op != BINOP_MUL:
        return 0
    lo: int64 = 0
    ro: int64 = 0
    if opt_ffold_eval(nd_a[node], &lo) == 0:
        return 0
    if opt_ffold_eval(nd_b[node], &ro) == 0:
        return 0
    r: int64 = 0
    if op == BINOP_ADD:
        r = lo + ro
    elif op == BINOP_SUB:
        r = lo - ro
    else:
        # MUL: guard against int64 overflow BEFORE the 2^53 range test by
        # bounding operands so the product cannot wrap (|lo|,|ro| < 2^53 each
        # from the recursive checks; the product range test below catches any
        # value that left the exact-integer window).
        r = lo * ro
    if r >= OPT_F64_EXACT or r <= (0 - OPT_F64_EXACT):
        return 0
    out[0] = r
    return 1


# Rewrite ND_BINARY `node` in place into an ND_FLOAT_LIT carrying integer `v`
# (codegen emits cvtsi2sd of nd_num -> the exact float64 value). Child slots
# cleared for hygiene; node id preserved so the parent slot now sees the folded
# float literal.
def fold_node_to_float_const(node: uint32, v: int64):
    # v is an EXACT integer (|v| < 2^53, guaranteed by opt_ffold_eval), so
    # cast[float64](v) is exact. Store its float64 BIT PATTERN with nd_aux=1 so
    # codegen emits a .rodata data-const (byte-identical to the seed's folded
    # FloatLiteral) rather than a cvtsi2sd — keeping seed/native objdiff clean.
    fv: float64 = cast[float64](v)
    tmp: float64 = fv
    bits: uint64 = cast[Ptr[uint64]](&tmp)[0]
    nd_kind[node] = ND_FLOAT_LIT
    nd_num[node] = bits
    nd_aux[node] = 1
    nd_a[node] = 0
    nd_b[node] = 0
    nd_c[node] = 0
    nd_d[node] = 0


# Try to FLOAT-const-fold an ND_BINARY root. Folds only a float64-typed,
# fully-constant exact-integer ADD/SUB/MUL tree (see the soundness note above).
# Returns 1 on a fold, 0 otherwise.
def opt_try_ffold(node: uint32) -> uint32:
    # Only fold a tree whose RESULT is a float64 (so the ND_FLOAT_LIT target's
    # always-f64 emission matches the original type). An f32 / non-float tree is
    # left to the other paths.
    if opt_expr_float_width(node) != 8:
        return 0
    v: int64 = 0
    if opt_ffold_eval(node, &v) == 0:
        return 0
    fold_node_to_float_const(node, v)
    opt_ffold_count = opt_ffold_count + 1
    return 1


# Rewrite an AST ND_BINARY node IN PLACE into an ND_INT_LIT carrying `v`.
# codegen.ad's ND_INT_LIT path reads only nd_num, so the operand/child slots
# are cleared for hygiene. The node id is preserved, so any parent slot that
# referenced this subtree now transparently references the folded constant.
def fold_node_to_const(node: uint32, v: uint64):
    nd_kind[node] = ND_INT_LIT
    nd_num[node] = v
    nd_aux[node] = 0
    nd_a[node] = 0
    nd_b[node] = 0
    nd_c[node] = 0
    nd_d[node] = 0


# Constant-fold pass over a single node. If `node` is an ND_BINARY whose
# entire subtree is a foldable constant expression, fold it to ND_INT_LIT
# and report 1; else 0. Must be attempted BEFORE recursing into children so
# the whole maximal constant subtree collapses in one shot.
def opt_try_fold(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_BINARY:
        return 0
    # FLOAT fold FIRST: a provably-exact float64 ADD/SUB/MUL tree over integer-
    # valued literal leaves collapses to one ND_FLOAT_LIT. (The integer fold
    # below can't model IEEE-754 and its ir_lower_const_expr would not lower a
    # float leaf anyway; this is the dedicated, bit-proven float path.)
    if opt_try_ffold(node) != 0:
        return 1
    # INTEGER fold: refuse any tree touching a float — the modular ir_eval_binop
    # has NO IEEE-754 semantics, so an integer fold of a float subtree would be a
    # miscompile. ir_lower_const_expr already rejects float leaves (a float leaf
    # is an ND_CAST/ND_FLOAT_LIT, not an int const leaf), but the explicit guard
    # documents the invariant and is cheap insurance against future leaf-set
    # broadening.
    if opt_subtree_has_float(node) != 0:
        return 0
    ir_reset()
    iv: uint32 = ir_lower_const_expr(node)
    if iv == 0:
        return 0
    fold_node_to_const(node, ir_const[iv])
    opt_fold_count = opt_fold_count + 1
    return 1


# Generic AST descent. Every nd_a/nd_b/nd_c/nd_d slot holds a child node id
# (or 0), and nd_next chains list siblings — this holds uniformly across all
# node kinds in the parser arena (scalars live in nd_num/nd_aux, never in the
# child slots). So this walk safely reaches every expression in the program.
#
# At each node we FIRST attempt to fold it (collapsing the maximal constant
# subtree, which prunes the recursion below it), then recurse into whatever
# children remain.
# Copy every AST field of `src` into node id `dst` IN PLACE, so a parent slot
# that points at `dst` now sees exactly what `src` was — WITHOUT touching dst's
# nd_next (its sibling link in whatever chain it sits in is preserved). Used to
# collapse a constant-condition ternary into its taken arm: the ND_CONDITIONAL
# node becomes a copy of the chosen expression subtree.
def opt_overwrite_node(dst: uint32, src: uint32):
    nd_kind[dst] = nd_kind[src]
    nd_aux[dst] = nd_aux[src]
    nd_num[dst] = nd_num[src]
    nd_a[dst] = nd_a[src]
    nd_b[dst] = nd_b[src]
    nd_c[dst] = nd_c[src]
    nd_d[dst] = nd_d[src]
    nd_name_off[dst] = nd_name_off[src]
    nd_name_len[dst] = nd_name_len[src]
    nd_line[dst] = nd_line[src]


# Try to fold a constant-condition ternary (ND_CONDITIONAL: a=cond, b=then,
# c=else) into its taken arm IN PLACE. Folds ONLY when the condition is a
# provable side-effect-free constant (opt_const_truth definite 0/1) AND the
# taken arm exists. Returns 1 on a fold. The not-taken arm is discarded; since
# every ternary operand here is a pure expression, dropping it is sound (no side
# effect lost). Returns 0 (leave as-is) otherwise.
def opt_try_condfold_expr(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_CONDITIONAL:
        return 0
    t: uint32 = opt_const_truth(nd_a[node])
    if t == 2:
        return 0
    taken: uint32 = 0
    if t == 1:
        taken = nd_b[node]
    else:
        taken = nd_c[node]
    if taken == 0:
        return 0
    opt_overwrite_node(node, taken)
    opt_constbranch_count = opt_constbranch_count + 1
    return 1


def opt_walk(node: uint32):
    if node == 0:
        return
    # Collapse a constant-condition ternary into its taken arm before folding /
    # recursing, so the dropped arm is never walked. The node now holds the taken
    # arm's fields (and is no longer ND_CONDITIONAL), so the fold + generic
    # descent below process it correctly in one pass — no re-entry needed.
    opt_try_condfold_expr(node)
    folded: uint32 = opt_try_fold(node)
    if folded != 0:
        # The node is now an ND_INT_LIT leaf; its former children were folded
        # in and cleared. Still follow the sibling chain.
        opt_walk(nd_next[node])
        return
    opt_walk(nd_a[node])
    opt_walk(nd_b[node])
    opt_walk(nd_c[node])
    opt_walk(nd_d[node])
    opt_walk(nd_next[node])


# =======================================================================
# Phase 1.5 — CONSTANT-CONDITION BRANCH FOLDING (unreachable-arm pruning).
# =======================================================================
#
# When an if / while / ternary condition is a PROVABLE compile-time constant
# with NO side effect, the not-taken arm(s) are unreachable; we drop them so
# the Phase-8 DCE then reclaims their now-dead locals/statements. This is the
# transform the Phase-8 note ("UNREACHABLE-BLOCK REMOVAL: DELIBERATELY
# OMITTED") was waiting on; it runs BEFORE DCE in opt_run's pass order.
#
# CORRECTNESS — the whole pass hinges on opt_const_truth returning a definite
# 0/1 ONLY when the condition is a side-effect-free constant:
#   * the leaf set is the LITERAL constants ONLY (int/char/bool, plus a cast of
#     such a literal). An ND_IDENT, ND_CALL, ND_INDEX, ND_MEMBER, ND_UNARY
#     deref, assignment, or ANY non-literal subtree yields UNKNOWN (2) — so a
#     condition that could read memory (fault), call, or assign is NEVER folded
#     and its side effect still executes.
#   * for binary ops we fold the signedness-INVARIANT arithmetic/bitwise set
#     via the proven ir_lower_const_expr (its result is the exact %rax codegen
#     computes), and we fold ONLY the bit-exact equality compares EQ/NEQ
#     ourselves (a 64-bit value-equality test is signedness-agnostic, matching
#     codegen regardless of operand signedness). Ordering compares
#     (LT/LE/GT/GE) are signedness-SENSITIVE and are deliberately left UNKNOWN
#     — a wrong direction would be a control-flow miscompile.
#   * short-circuit AND/OR and logical NOT fold from their constant operands'
#     own truth values (no operand is evaluated for effect, since every operand
#     is itself a side-effect-free constant — so dropping the unevaluated
#     operand is sound).
# UNKNOWN is the safe default everywhere: when in doubt the branch is left
# exactly as written.

# Truth value of a side-effect-free constant condition. Returns 0 (false),
# 1 (true), or 2 (UNKNOWN — not a provable side-effect-free constant). The
# value of the underlying integer (when known) is written through *val.
def opt_const_truth(node: uint32) -> uint32:
    if node == 0:
        return 2
    k: uint32 = nd_kind[node]
    # Direct literal leaves: their truthiness is value != 0.
    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT:
        if nd_num[node] != 0:
            return 1
        return 0
    # Cast of a constant operand: the cast does not change zero-ness for the
    # integer/char/bool literal leaf set (a cast[intW] of a literal keeps its
    # value's zero-ness; we only descend literal operands, never expressions
    # that could load/fault). A float-typed cast is NOT handled here (truthiness
    # of a float constant is out of scope) — leave UNKNOWN.
    if k == ND_CAST:
        if opt_type_float_width(nd_a[node]) != 0:
            return 2
        return opt_const_truth(nd_b[node])
    if k == ND_UNARY:
        op: uint32 = nd_aux[node]
        if op == UNOP_NOT:
            inner: uint32 = opt_const_truth(nd_a[node])
            if inner == 2:
                return 2
            if inner == 0:
                return 1
            return 0
        # NEG / BIT_NOT / DEREF / ADDR: a deref/addr touches memory (unsafe);
        # NEG/BIT_NOT of a constant we just route through the int folder below
        # via the parent — but a bare unary here is not a binary, so be
        # conservative and leave it UNKNOWN.
        return 2
    if k == ND_BINARY:
        bop: uint32 = nd_aux[node]
        # Short-circuit logical AND / OR: fold from operand truth values. Sound
        # to drop the un-taken operand because every operand is itself a
        # side-effect-free constant (both must be provable-const to reach here).
        if bop == BINOP_AND:
            la: uint32 = opt_const_truth(nd_a[node])
            if la == 0:
                return 0
            rb: uint32 = opt_const_truth(nd_b[node])
            if la == 1 and rb == 1:
                return 1
            if la == 1 and rb == 0:
                return 0
            return 2
        if bop == BINOP_OR:
            lo2: uint32 = opt_const_truth(nd_a[node])
            if lo2 == 1:
                return 1
            ro2: uint32 = opt_const_truth(nd_b[node])
            if lo2 == 0 and ro2 == 1:
                return 1
            if lo2 == 0 and ro2 == 0:
                return 0
            return 2
        # Bit-exact equality compares: fold the two operands to their exact
        # constant integer values via the proven folder, then compare 64-bit
        # equal (signedness-agnostic, matching codegen's cmp/sete).
        if bop == BINOP_EQ or bop == BINOP_NEQ:
            lv: int64 = 0
            rv: int64 = 0
            if opt_const_int(nd_a[node], &lv) == 0:
                return 2
            if opt_const_int(nd_b[node], &rv) == 0:
                return 2
            eq: uint32 = 0
            if lv == rv:
                eq = 1
            if bop == BINOP_EQ:
                return eq
            # NEQ
            if eq == 1:
                return 0
            return 1
        # Any other binary op (arith/bitwise/ordering): get its exact constant
        # integer value if foldable, then take truthiness. Ordering compares are
        # NOT foldable by ir_lower_const_expr, so they naturally return UNKNOWN.
        bv: int64 = 0
        if opt_const_int(node, &bv) == 0:
            return 2
        if bv != 0:
            return 1
        return 0
    return 2


# Exact constant integer value of a PROVABLE, side-effect-free constant integer
# subtree, written through *out. Returns 1 on success, 0 (UNKNOWN) otherwise.
# Delegates to the proven ir_lower_const_expr (const literal leaves + the
# signedness-invariant foldable op set ONLY — it returns 0 for any ident /
# call / load / non-foldable op), with a thin pre-pass for direct literal /
# cast-of-literal leaves it does not itself unwrap. NO float subtrees (the
# integer folder has no IEEE semantics).
def opt_const_int(node: uint32, out: Ptr[int64]) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT:
        out[0] = cast[int64](nd_num[node])
        return 1
    if k == ND_CAST:
        # Integer cast of a constant integer operand keeps the 64-bit value for
        # an equality test (we never narrow-fold; EQ/NEQ compare full width like
        # codegen does after promotion). A float cast is not an integer const.
        if opt_type_float_width(nd_a[node]) != 0:
            return 0
        return opt_const_int(nd_b[node], out)
    # Refuse anything touching a float — the integer folder has no IEEE model.
    if opt_subtree_has_float(node) != 0:
        return 0
    ir_reset()
    iv: uint32 = ir_lower_const_expr(node)
    if iv == 0:
        return 0
    out[0] = cast[int64](ir_const[iv])
    return 1


# Rewrite an ND_IF / ND_ELIF body chain or single statement into a no-op so the
# enclosing slot stays structurally valid but emits nothing. Used when a whole
# loop is dropped. Re-tags the node id IN PLACE as ND_PASS (codegen emits no
# code for it) and clears all child slots.
def opt_make_pass(node: uint32):
    nd_kind[node] = ND_PASS
    nd_aux[node] = 0
    nd_a[node] = 0
    nd_b[node] = 0
    nd_c[node] = 0
    nd_d[node] = 0


# Force an ND_IF node's condition to the constant literal `truth` (0/1) and keep
# ONLY the named surviving body chain as the then-body, dropping every elif and
# else arm. The IF node id is preserved (the parent slot / nd_next still points
# at it), so no chain splice into the parent is needed — the construct becomes a
# trivial `if 1: <arm>` (taken) or `if 1: <arm>` carrying the chosen arm. The
# dropped arms (now unreferenced) vanish from codegen and their locals, used
# nowhere, are reclaimed by Phase-8 DCE.
def opt_if_keep_arm(node: uint32, body: uint32):
    # Synthesize a fresh constant-true condition literal so the (now-trivial)
    # branch test is `if 1:` — the body always runs, elif/else are gone. We
    # reuse the node's existing cond slot by overwriting the cond node in place
    # into an ND_INT_LIT 1 (it was a constant already, so discarding it is safe;
    # nothing else references a freshly-parsed condition subtree).
    cond: uint32 = nd_a[node]
    if cond != 0:
        nd_kind[cond] = ND_INT_LIT
        nd_num[cond] = 1
        nd_aux[cond] = 0
        nd_a[cond] = 0
        nd_b[cond] = 0
        nd_c[cond] = 0
        nd_d[cond] = 0
    nd_b[node] = body
    nd_c[node] = 0        # drop elif chain
    nd_d[node] = 0        # drop else body
    nd_aux[node] = 0      # has_else = 0


# Try to constant-fold ONE ND_IF / ND_WHILE statement IN PLACE. Returns 1 if a
# fold happened (the node was rewritten), 0 otherwise. Recurses into the chosen
# / remaining arms via the caller's block walk; this routine only decides the
# top-level prune.
def opt_constbranch_stmt(node: uint32) -> uint32:
    k: uint32 = nd_kind[node]
    if k == ND_WHILE:
        # while CONST_FALSE: ...  -> drop the loop entirely (becomes a no-op).
        # while CONST_TRUE: ...   -> LEAVE (an infinite loop is observable).
        t: uint32 = opt_const_truth(nd_a[node])
        if t == 0:
            opt_make_pass(node)
            opt_constbranch_count = opt_constbranch_count + 1
            return 1
        return 0
    if k != ND_IF:
        return 0
    # Walk the branch list in source order: primary cond, then each elif cond.
    # The FIRST condition that is a provable constant decides the outcome:
    #   * folds TRUE  -> that arm's body is taken; everything after is dead.
    #   * folds FALSE -> that arm is dead; continue to the next condition.
    # If a condition is UNKNOWN we must STOP: a later arm only runs if every
    # earlier (unknown) condition was false at runtime, which we cannot prove,
    # so we cannot statically select a later arm past an unknown gate.
    pt: uint32 = opt_const_truth(nd_a[node])
    if pt == 2:
        return 0
    if pt == 1:
        # Primary taken: keep then-body, drop elif + else.
        opt_if_keep_arm(node, nd_b[node])
        opt_constbranch_count = opt_constbranch_count + 1
        return 1
    # Primary is provably FALSE: walk elif conditions, all of which we now reach
    # unconditionally (the primary never runs).
    e: uint32 = nd_c[node]
    while e != 0:
        et: uint32 = opt_const_truth(nd_a[e])
        if et == 2:
            # Unknown elif gate: cannot select past it. But the primary is
            # PROVABLY false, so we can still safely drop the primary arm by
            # promoting the elif chain to the new construct. Rewrite the IF so
            # its primary cond/body become this first unknown elif, keeping the
            # remaining elifs and the else. This shrinks the dead primary arm
            # for DCE without changing semantics.
            opt_if_promote_from(node, e)
            opt_constbranch_count = opt_constbranch_count + 1
            return 1
        if et == 1:
            # This elif is provably taken: keep ITS body, drop everything else.
            opt_if_keep_arm(node, nd_b[e])
            opt_constbranch_count = opt_constbranch_count + 1
            return 1
        # elif provably false: skip it, continue.
        e = nd_next[e]
    # Every condition (primary + all elifs) is provably FALSE: the else body (if
    # any) is taken unconditionally; otherwise the whole construct is a no-op.
    eb: uint32 = nd_d[node]
    if eb != 0:
        opt_if_keep_arm(node, eb)
    else:
        opt_make_pass(node)
    opt_constbranch_count = opt_constbranch_count + 1
    return 1


# Rewrite ND_IF `node` so its primary branch becomes elif node `e` (the first
# elif we could not prove false), preserving e's remaining elif siblings and the
# original else. Used when the primary condition was provably false but a later
# gate is unknown: the dead primary arm is pruned without altering semantics.
def opt_if_promote_from(node: uint32, e: uint32):
    nd_a[node] = nd_a[e]          # primary cond <- first surviving elif cond
    nd_b[node] = nd_b[e]          # primary body <- its body
    nd_c[node] = nd_next[e]       # remaining elifs
    # nd_d (else) unchanged; has_else unchanged.


# Walk a statement chain, attempting const-branch folding on each ND_IF/ND_WHILE
# and recursing into the surviving nested blocks. Mirrors the structural recursion
# of prescan_block / dce so every nested block is reached.
def opt_constbranch_block(head: uint32):
    s: uint32 = head
    while s != 0:
        # Fold this statement first; its arms may be pruned, after which we
        # recurse only into what survives.
        opt_constbranch_stmt(s)
        k: uint32 = nd_kind[s]
        if k == ND_IF:
            opt_constbranch_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                opt_constbranch_block(nd_b[e])
                e = nd_next[e]
            opt_constbranch_block(nd_d[s])
        elif k == ND_WHILE:
            opt_constbranch_block(nd_b[s])
        elif k == ND_DO_WHILE:
            opt_constbranch_block(nd_b[s])
        elif k == ND_FOR:
            opt_constbranch_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            opt_constbranch_block(nd_c[s])
        s = nd_next[s]


# Run const-branch folding over one function body. The body statement chain is on
# nd_c of an ND_FUNCTION (same accessor opt_dce_function uses).
def opt_constbranch_function(fn: uint32):
    opt_constbranch_block(nd_c[fn])


# Pass-manager entry point. Runs the Phase-1 pass set over the whole program.
# `prog` is the ND_PROGRAM root; its decl chain hangs off nd_b (mirroring
# gen_program_with_globals in codegen.ad). We walk every declaration, which
# transitively reaches every function body and expression.
def opt_run(prog: uint32):
    if opt_enabled == 0:
        return
    opt_reset_stats()
    if prog == 0:
        return
    # Walk the decl chain (functions, globals, classes). Each function body
    # is reached through opt_walk's generic descent.
    decls: uint32 = nd_b[prog]
    # Build the program-wide global float-type table once; every function's
    # CSE/LICM consults it (plus its own per-function local table) to type a
    # shared FLOAT temp correctly.
    opt_gfw_build(decls)
    # Program-wide ELEMENT-float table (array/ptr globals) for the load-CSE gate.
    opt_egfw_build(decls)
    # Program-wide GLOBAL-name set — the dead-STORE elimination consults it so it
    # never drops an externally-observable store to a global scalar.
    opt_gname_build(decls)
    # Phase 0 — RECURSION -> ITERATION. Runs FIRST (before fold/CSE/LICM/DCE) so
    # the emitted iterative loop is then seen by the ordinary loop passes. Rewrites
    # a two-term ADDITIVE linear-recurrence self-recursion (the Fibonacci shape
    # `if n < B: return n` / `return f(n-1)+f(n-2)`) into an equivalent bottom-up
    # `while` loop that carries the two running values — killing the exponential
    # call-tree. --opt-gated (opt_run already returned if disabled) and strictly
    # value-preserving: the iterative locals are typed with the function's own
    # integer return type so every add wraps at the SAME width the recursion did,
    # and the seeds are the base-case identity values f(B-2), f(B-1). A CONSERVATIVE
    # exact-shape match only (see opt_rec2iter_function) — anything else is refused.
    cur0: uint32 = decls
    while cur0 != 0:
        if nd_kind[cur0] == ND_FUNCTION:
            opt_rec2iter_function(cur0)
        cur0 = nd_next[cur0]
    cur: uint32 = decls
    while cur != 0:
        opt_walk(cur)
        cur = nd_next[cur]
    # Phase 1.5 — CONSTANT-CONDITION BRANCH FOLDING. Runs immediately after the
    # generic const-FOLD walk (so a condition that folded to a literal is seen as
    # constant) and BEFORE CSE/LICM/DCE: dropping an unreachable arm here means
    # the later passes never process it, and the arm's now-unreferenced locals
    # fall to Phase-8 DCE. A ternary (ND_CONDITIONAL) whose cond is constant is
    # collapsed inside opt_walk's recursion via opt_try_condfold_expr above; this
    # per-function statement pass handles ND_IF / ND_WHILE arm pruning.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_constbranch_function(cur)
        cur = nd_next[cur]
    # Phase 7 — CROSS-STATEMENT CSE over each function body (extended basic
    # block). Runs on the const-FOLDED graph and BEFORE the per-statement CSE and
    # LICM, so a subexpression repeated across adjacent statements is shared into
    # one temp first; the per-statement CSE then handles intra-statement repeats
    # the cross-statement pass leaves, and LICM sees the shared temps as ordinary
    # in-loop candidates.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_xcse_function(cur)
        cur = nd_next[cur]
    # Phase 2 — local CSE over each function body (runs on the const-FOLDED
    # graph: opt_walk above already collapsed constant subtrees, so CSE numbers
    # the simplified expressions). Re-walk the decls and CSE every function.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_cse_function(cur)
        cur = nd_next[cur]
    # Phase 3 — loop-invariant code motion. Runs AFTER fold+CSE so it operates
    # on the simplified graph (constants collapsed, in-statement redundancy
    # already shared). Re-walk the decls and LICM every function body.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_licm_function(cur)
        cur = nd_next[cur]
    # Phase 3.6 — INDUCTION-VARIABLE STRENGTH REDUCTION. Runs AFTER LICM (so any
    # loop-invariant index sub-base like `i*N` was already hoisted where i is
    # invariant) and BEFORE copyprop/DCE: it rewrites affine array indices over a
    # counted loop's induction variable into a pre-header-seeded running variable
    # advanced by a constant per iteration, eliminating the per-iteration index
    # multiply. The minted running locals are ordinary promotable scalars the
    # later passes/regalloc treat normally.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_ivsr_function(cur)
        cur = nd_next[cur]
    # Phase 9 — COPY PROPAGATION. Runs AFTER fold/CSE/LICM and immediately BEFORE
    # DCE: it forwards each pure copy `x = y` to later reads of `x` (rewriting them
    # to read `y`) within a straight-line run, when neither `x` nor `y` is mutated
    # in the live range. The forwarded copy dest `x` then has no remaining reader,
    # so the Phase-8 DCE that follows removes its now-dead decl. Conservative: any
    # call / addr-of / control flow / opaque store flushes the active copy set.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_copyprop_function(cur)
        cur = nd_next[cur]
    # Phase 9.5 — POW2 PARITY / DIVISIBILITY idiom fold. Runs after copyprop (so
    # any pure-copy quotient rename settled) and BEFORE DCE (so a quotient left
    # unread once its only consumer was the folded test falls to DCE). Rewrites
    # `x - (x/C)*C == 0` / `x % C == 0` (pow2 C) to `(x & (C-1)) == 0` — a sign-
    # independent divisibility test that codegen emits as a single `and`/`test`.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_paritymod_function(cur)
        cur = nd_next[cur]
    # Phase 8 — DEAD CODE ELIMINATION. Runs LAST, on the fully fold+CSE+LICM
    # simplified graph: those passes have minted synthetic temp locals (__cse_/
    # __licm_), and a hoisted/shared temp whose every original use was itself
    # rewritten away can end up fully dead — DCE reclaims exactly those, plus any
    # user local whose result is never read. It deletes nothing with a side
    # effect (see the Phase-8 strategy note); a conservative miss is fine, a
    # wrong removal is not.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_dce_function(cur)
        cur = nd_next[cur]


# =======================================================================
# Phase 0 — RECURSION -> ITERATION (two-term additive linear recurrence).
# =======================================================================
#
# gcc-O2's edge on the naive recursive `fib` kernel is ALGORITHMIC: it turns the
# exponential call tree into a bottom-up O(n) loop. This pass does the same for
# the exact, conservatively-recognised Fibonacci shape:
#
#     def f(n: intT) -> intT:            def f(n: intT) -> intT:
#         if n < B:                          if n < B:            # guard KEPT
#             return n                           return n
#         return f(n-1) + f(n-2)  ===>       prev = B-2           # f(B-2)
#                                            cur  = B-1           # f(B-1)
#                                            nxt  = 0
#                                            i    = B
#                                            while i <= n:
#                                                nxt  = prev + cur
#                                                prev = cur
#                                                cur  = nxt
#                                                i    = i + 1
#                                            return cur
#
# CORRECTNESS. The recurrence f(k)=f(k-1)+f(k-2) with the identity base case
# f(k)=k for k<B has the closed iterative form above: for n<B the guard returns
# n unchanged; for n>=B, seeding prev=f(B-2), cur=f(B-1) (both base values,
# since B-2<B and B-1<B) and iterating i=B..n leaves cur=f(n). Integer addition
# is associative/commutative modulo 2^width, so the iterative additions produce
# the IDENTICAL wrapped value the recursion would — including overflow. The
# iterative locals are typed with f's own integer return type (same width code),
# so every add wraps exactly as the recursive returns did. Values match for all
# inputs incl. n<0 (guard true -> return n) and huge n (same wraparound).
#
# ELIGIBILITY (all required; anything else is refused — a conservative miss just
# leaves the recursion intact):
#   * exactly one param, integer-typed; integer return type of the SAME type code
#   * no decorators
#   * body is EXACTLY two statements: an `if` guard then a `return`
#   * guard: `if <param> < B:` (B a constant integer literal >= 2, cast-peeled),
#     no elif, no else, whose then-body is EXACTLY `return <param>` (identity base)
#   * final stmt: `return <self-call> + <self-call>` (ADD), each call `f(<param> - d)`
#     with d a constant integer; the two decrements are exactly {1, 2}
# The exact-shape match guarantees the two self-calls are the function's ONLY
# calls and there is no other side-effecting statement to reorder, so the rewrite
# is unconditionally safe.

r2i_seq: uint32 = 0
r2i_name_off: uint32 = 0
r2i_name_len: uint32 = 0
r2i_transformed: uint32 = 0


def r2i_putc(c: uint32):
    strbuf[strbuf_pos] = cast[uint8](c)
    strbuf_pos = strbuf_pos + 1


# Mint a fresh, unique local name "__r2i_<tag><seq>" into strbuf; result in
# r2i_name_off/len (mirrors cse_mint_temp_name's global-return convention).
def r2i_mint(tag: uint32):
    start: uint32 = strbuf_pos
    r2i_putc(95)       # '_'
    r2i_putc(95)       # '_'
    r2i_putc(114)      # 'r'
    r2i_putc(50)       # '2'
    r2i_putc(105)      # 'i'
    r2i_putc(95)       # '_'
    r2i_putc(tag)
    r2i_seq = r2i_seq + 1
    cse_emit_digits(r2i_seq)
    r2i_name_off = start
    r2i_name_len = strbuf_pos - start


def r2i_ident(off: uint32, len_: uint32) -> uint32:
    id: uint32 = node_new(ND_IDENT)
    nd_name_off[id] = off
    nd_name_len[id] = len_
    return id


def r2i_intlit(v: uint64) -> uint32:
    id: uint32 = node_new(ND_INT_LIT)
    nd_num[id] = v
    return id


def r2i_binop(op: uint32, a: uint32, b: uint32) -> uint32:
    id: uint32 = node_new(ND_BINARY)
    nd_aux[id] = op
    nd_a[id] = a
    nd_b[id] = b
    return id


# Fresh primitive integer ND_TYPE carrying `tcode` (int8..uint64), so a minted
# local is codegen-typed at the recurrence's exact width (never an untyped
# 8-byte slot that would mis-wrap a narrower int type).
def r2i_int_type(tcode: uint32) -> uint32:
    id: uint32 = node_new(ND_TYPE)
    nd_aux[id] = tcode
    return id


def r2i_vardecl(off: uint32, len_: uint32, tcode: uint32, val: uint32) -> uint32:
    id: uint32 = node_new(ND_VAR_DECL)
    nd_name_off[id] = off
    nd_name_len[id] = len_
    nd_a[id] = r2i_int_type(tcode)
    nd_b[id] = val
    return id


def r2i_assign(target: uint32, val: uint32) -> uint32:
    id: uint32 = node_new(ND_ASSIGN)
    nd_a[id] = target
    nd_b[id] = val
    nd_aux[id] = 0
    return id


# Is `call` a single-arg self-call `f(<param> - d)` with d a constant integer?
# On success writes d through *outd and returns 1; else 0.
def r2i_check_self_call(call: uint32, fnoff: uint32, fnlen: uint32, poff: uint32, plen: uint32, outd: Ptr[int64]) -> uint32:
    if call == 0:
        return 0
    if nd_kind[call] != ND_CALL:
        return 0
    if nd_aux[call] != 1:                 # argc == 1
        return 0
    callee: uint32 = nd_a[call]
    if callee == 0:
        return 0
    if nd_kind[callee] != ND_IDENT:
        return 0
    if ir_name_eq(nd_name_off[callee], nd_name_len[callee], fnoff, fnlen) == 0:
        return 0
    arg: uint32 = nd_b[call]
    if arg == 0:
        return 0
    if nd_next[arg] != 0:                 # exactly one arg
        return 0
    if nd_kind[arg] != ND_BINARY:
        return 0
    if nd_aux[arg] != BINOP_SUB:
        return 0
    al: uint32 = nd_a[arg]
    if al == 0:
        return 0
    if nd_kind[al] != ND_IDENT:
        return 0
    if ir_name_eq(nd_name_off[al], nd_name_len[al], poff, plen) == 0:
        return 0
    dv: int64 = 0
    if opt_const_int(nd_b[arg], &dv) == 0:
        return 0
    outd[0] = dv
    return 1


def opt_rec2iter_function(fn: uint32):
    if p_err != 0:
        return
    if nd_kind[fn] != ND_FUNCTION:
        return
    if nd_d[fn] != 0:                     # no decorators
        return
    if nd_aux[fn] != 1:                   # exactly one param
        return
    param: uint32 = nd_a[fn]
    if param == 0:
        return
    if nd_kind[param] != ND_PARAM:
        return
    ptype: uint32 = nd_a[param]
    if opt_type_is_scalar_int(ptype) == 0:
        return
    rtype: uint32 = nd_b[fn]
    if opt_type_is_scalar_int(rtype) == 0:
        return
    tcode: uint32 = nd_aux[rtype]
    if nd_aux[ptype] != tcode:            # same integer width/signedness
        return
    poff: uint32 = nd_name_off[param]
    plen: uint32 = nd_name_len[param]
    fnoff: uint32 = nd_name_off[fn]
    fnlen: uint32 = nd_name_len[fn]
    # Body must be EXACTLY two statements: guard `if`, then `return`.
    s1: uint32 = nd_c[fn]
    if s1 == 0:
        return
    s2: uint32 = nd_next[s1]
    if s2 == 0:
        return
    if nd_next[s2] != 0:
        return
    # --- S1: `if <param> < B: return <param>` (no elif/else) ---
    if nd_kind[s1] != ND_IF:
        return
    if nd_c[s1] != 0:                     # no elif chain
        return
    if nd_d[s1] != 0:                     # no else block
        return
    cond: uint32 = nd_a[s1]
    if cond == 0:
        return
    if nd_kind[cond] != ND_BINARY:
        return
    if nd_aux[cond] != BINOP_LT:
        return
    cl: uint32 = nd_a[cond]
    if cl == 0:
        return
    if nd_kind[cl] != ND_IDENT:
        return
    if ir_name_eq(nd_name_off[cl], nd_name_len[cl], poff, plen) == 0:
        return
    bval: int64 = 0
    if opt_const_int(nd_b[cond], &bval) == 0:
        return
    if bval < 2:
        return
    # then-body must be EXACTLY `return <param>` (identity base case).
    tb: uint32 = nd_b[s1]
    if tb == 0:
        return
    if nd_next[tb] != 0:
        return
    if nd_kind[tb] != ND_RETURN:
        return
    br: uint32 = nd_a[tb]
    if br == 0:
        return
    if nd_kind[br] != ND_IDENT:
        return
    if ir_name_eq(nd_name_off[br], nd_name_len[br], poff, plen) == 0:
        return
    # --- S2: `return f(<param>-d1) + f(<param>-d2)`; {d1,d2} == {1,2} ---
    if nd_kind[s2] != ND_RETURN:
        return
    add: uint32 = nd_a[s2]
    if add == 0:
        return
    if nd_kind[add] != ND_BINARY:
        return
    if nd_aux[add] != BINOP_ADD:
        return
    d1: int64 = 0
    d2: int64 = 0
    if r2i_check_self_call(nd_a[add], fnoff, fnlen, poff, plen, &d1) == 0:
        return
    if r2i_check_self_call(nd_b[add], fnoff, fnlen, poff, plen, &d2) == 0:
        return
    ok: uint32 = 0
    if d1 == 1:
        if d2 == 2:
            ok = 1
    if d1 == 2:
        if d2 == 1:
            ok = 1
    if ok == 0:
        return
    # ---- Eligible. Build the iterative replacement body. ----
    r2i_mint(112)                         # 'p' -> prev
    prev_off: uint32 = r2i_name_off
    prev_len: uint32 = r2i_name_len
    r2i_mint(99)                          # 'c' -> cur
    cur_off: uint32 = r2i_name_off
    cur_len: uint32 = r2i_name_len
    r2i_mint(110)                         # 'n' -> nxt
    nxt_off: uint32 = r2i_name_off
    nxt_len: uint32 = r2i_name_len
    r2i_mint(105)                         # 'i' -> i
    i_off: uint32 = r2i_name_off
    i_len: uint32 = r2i_name_len

    bconst: uint64 = cast[uint64](bval)
    d_prev: uint32 = r2i_vardecl(prev_off, prev_len, tcode, r2i_intlit(bconst - 2))
    d_cur: uint32 = r2i_vardecl(cur_off, cur_len, tcode, r2i_intlit(bconst - 1))
    d_nxt: uint32 = r2i_vardecl(nxt_off, nxt_len, tcode, r2i_intlit(0))
    d_i: uint32 = r2i_vardecl(i_off, i_len, tcode, r2i_intlit(bconst))

    # while i <= n:
    wcond: uint32 = r2i_binop(BINOP_LTE, r2i_ident(i_off, i_len), r2i_ident(poff, plen))
    a_nxt: uint32 = r2i_assign(r2i_ident(nxt_off, nxt_len), r2i_binop(BINOP_ADD, r2i_ident(prev_off, prev_len), r2i_ident(cur_off, cur_len)))
    a_prev: uint32 = r2i_assign(r2i_ident(prev_off, prev_len), r2i_ident(cur_off, cur_len))
    a_cur: uint32 = r2i_assign(r2i_ident(cur_off, cur_len), r2i_ident(nxt_off, nxt_len))
    a_i: uint32 = r2i_assign(r2i_ident(i_off, i_len), r2i_binop(BINOP_ADD, r2i_ident(i_off, i_len), r2i_intlit(1)))
    nd_next[a_nxt] = a_prev
    nd_next[a_prev] = a_cur
    nd_next[a_cur] = a_i
    nd_next[a_i] = 0
    wh: uint32 = node_new(ND_WHILE)
    nd_a[wh] = wcond
    nd_b[wh] = a_nxt
    # return cur
    ret: uint32 = node_new(ND_RETURN)
    nd_a[ret] = r2i_ident(cur_off, cur_len)

    # If the node arena exhausted mid-build, node_new set p_err and returned 0s;
    # abort WITHOUT mutating the function (nd_c[fn] is still the original chain).
    if p_err != 0:
        return

    # Commit: S1(guard) -> prev -> cur -> nxt -> i -> while -> return cur.
    nd_next[s1] = d_prev
    nd_next[d_prev] = d_cur
    nd_next[d_cur] = d_nxt
    nd_next[d_nxt] = d_i
    nd_next[d_i] = wh
    nd_next[wh] = ret
    nd_next[ret] = 0
    r2i_transformed = r2i_transformed + 1


# =======================================================================
# Phase 2 — local common-subexpression elimination via value numbering.
# =======================================================================
#
# STRATEGY (conservative + correct over fast)
# -------------------------------------------
# CSE eliminates a redundant PURE computation by computing it ONCE into a
# synthetic temp local and reusing the temp at later occurrences. The temp is
# an untyped 8-byte scalar slot (declare_local with type node 0 in codegen.ad
# gives a full-register movq store/load — no sub-width hazard), so the temp
# holds EXACTLY the %rax value codegen would have computed inline. Because the
# eliminated expressions are restricted to the signedness-INVARIANT 64-bit op
# set over ident/const leaves (see ir.ad ir_lower_pure_expr), the temp's value
# equals every occurrence's value bit-for-bit: the transform is value-
# preserving, hence behaviorally correct (the ADDER_OPT=1 fuzzer lane asserts
# this against the oracle).
#
# SCOPE — a single STATEMENT's expression tree (a maximal pure straight-line
# region). Within one pure expression there are provably NO intervening
# clobbers of any leaf identifier (a pure expression has no assignments/
# stores/calls), so an available expression stays valid across the whole tree.
# Any impure node (call, index/load, member, cast, compare, DIV/MOD/SHR,
# unary, assignment target) is NOT lowered into the value IR and thus ends the
# available-expression region (ir_lower_pure_expr returns 0 for it). A store /
# call / volatile-load that could clobber is therefore never inside a CSE
# region. This is the textbook "local CSE within a basic block", at its safest.
#
# The repeated occurrence is rewritten IN PLACE into an ND_IDENT referencing
# the temp; the temp's defining ND_VAR_DECL is spliced into the enclosing
# statement chain immediately before the statement that uses it, so codegen's
# prescan reserves the slot and the body walk computes it before the use.

# Append "__cse_<seq>" to strbuf and return its starting offset; the length is
# written through the two globals below (Adder has no multi-return here). The
# name is unique per call (seq is monotonic) and cannot collide with a user
# identifier (user names never contain the "__cse_" prefix in the fuzzer/seed
# subset; the leading "__" marks it compiler-internal).
opt_tmp_name_off: uint32 = 0
opt_tmp_name_len: uint32 = 0


def cse_emit_digits(v: uint32):
    if v == 0:
        strbuf[strbuf_pos] = 48        # '0'
        strbuf_pos = strbuf_pos + 1
        return
    # Emit decimal digits (recurse for high-order first).
    if v >= 10:
        cse_emit_digits(v / 10)
    strbuf[strbuf_pos] = cast[uint8]((v % 10) + 48)
    strbuf_pos = strbuf_pos + 1


def cse_mint_temp_name():
    start: uint32 = strbuf_pos
    # "__cse_"
    strbuf[strbuf_pos] = 95          # '_'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 95          # '_'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 99          # 'c'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 115         # 's'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 101         # 'e'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 95          # '_'
    strbuf_pos = strbuf_pos + 1
    opt_cse_tmp_seq = opt_cse_tmp_seq + 1
    cse_emit_digits(opt_cse_tmp_seq)
    opt_tmp_name_off = start
    opt_tmp_name_len = strbuf_pos - start


# Rewrite AST node `node` in place into an ND_IDENT referencing the temp name
# (off,len). codegen.ad's ND_IDENT path reads only nd_name_off/len, so clearing
# the operand/child slots is hygiene. The node id is preserved, so the parent
# slot that referenced this subtree now references the temp read.
def cse_rewrite_to_ident(node: uint32, off: uint32, len_: uint32):
    nd_kind[node] = ND_IDENT
    nd_name_off[node] = off
    nd_name_len[node] = len_
    nd_aux[node] = 0
    nd_num[node] = 0
    nd_a[node] = 0
    nd_b[node] = 0
    nd_c[node] = 0
    nd_d[node] = 0


# Build a fresh ND_VAR_DECL `<tmpname> = <init_ast>`. An INTEGER-valued shared
# expression gets NO type annotation (type node 0 -> codegen reserves a plain
# untyped 8-byte scalar slot, a movq store/load that round-trips the %rax value
# bit-for-bit). A FLOAT-typed shared expression (opt_expr_float_width(init_ast)
# != 0) gets a synthesized float ND_TYPE so codegen tags the slot loc_is_float
# (and scalar_size 4 for float32) and EVERY reuse ND_IDENT of the temp resolves
# to the SSE float path at the right width — without the type the reuse would be
# emitted as an INTEGER op (float miscompile). The float result bits transit
# %rax exactly as for a user float local, so a typed float temp holds the same
# bits the inline float computation produced: value-identical. Returns the new
# statement node, or 0 on arena exhaustion.
def cse_make_temp_decl(off: uint32, len_: uint32, init_ast: uint32) -> uint32:
    d: uint32 = node_new(ND_VAR_DECL)
    if d == 0:
        return 0
    nd_name_off[d] = off
    nd_name_len[d] = len_
    fw: uint32 = opt_expr_float_width(init_ast)
    if fw != 0:
        nd_a[d] = opt_make_float_type(fw)   # typed float slot -> SSE reuse
    else:
        nd_a[d] = 0                         # no type node -> untyped 8-byte scalar
    nd_b[d] = init_ast        # initialiser
    return d


# --- single-statement CSE -------------------------------------------------
#
# We scan the value-IR of ONE statement's expression for a pure ND_BINOP value
# that occurs >=2 times. The FIRST such occurrence is materialized into a temp;
# every occurrence (including the first) is rewritten to read the temp, and the
# temp's defining decl is returned to the caller for splicing before the stmt.
#
# Per-statement scratch: the list of distinct AST roots we lowered, plus their
# IR value ids, and a parallel "already eliminated" mark.
CSE_MAX_CAND: uint32 = 4096
cse_cand_ast: Array[4096, uint32]    # AST node of a pure-binop candidate
cse_cand_ir: Array[4096, uint32]     # its value-IR id
cse_cand_n: uint32 = 0

# Pending temp decls minted while processing the current statement, to splice
# in before it (in mint order).
CSE_MAX_PEND: uint32 = 256
cse_pend_decl: Array[256, uint32]
cse_pend_n: uint32 = 0


# Collect every pure ND_BINARY subtree of `node` into the candidate list, in
# PRE-ORDER (outermost first), each paired with its lowered value IR. A subtree
# that does not lower (impure / out-of-set) is skipped but we still descend its
# AST children to find pure binops nested under an impure parent (e.g. inside a
# cast or an index expression's operands).
def cse_collect(node: uint32):
    if node == 0:
        return
    if cse_cand_n >= CSE_MAX_CAND:
        return
    if nd_kind[node] == ND_BINARY:
        # Lower into the SHARED per-statement IR arena (reset once by the
        # caller, NOT per node) so every candidate's value id stays live and
        # mutually comparable across the whole statement.
        v: uint32 = ir_lower_pure_expr(node)
        if v != 0:
            cse_cand_ast[cse_cand_n] = node
            cse_cand_ir[cse_cand_n] = v
            cse_cand_n = cse_cand_n + 1
    cse_descend(node)


# Descend into the expression children of an AST node (the slots that can hold
# sub-expressions). Statement-level nodes are handled by the per-statement
# entry; here we only chase expression operands.
def cse_descend(node: uint32):
    k: uint32 = nd_kind[node]
    # ND_IDENT / literals have no expression children.
    if k == ND_IDENT or k == ND_INT_LIT:
        return
    cse_collect(nd_a[node])
    cse_collect(nd_b[node])
    cse_collect(nd_c[node])
    cse_collect(nd_d[node])


# Rewrite, within the AST subtree rooted at `root`, EVERY occurrence whose
# value-IR equals `proto_ir` into an ND_IDENT(off,len). Returns the count of
# occurrences rewritten. Each candidate's IR was built under its own ir_reset,
# so we rebuild the subtree's IR here to compare; but since we only ever call
# this for nodes already in the candidate list, we compare via the recorded
# candidate IRs to avoid clobbering proto_ir's arena.
def cse_apply(root: uint32, proto_ir: uint32, off: uint32, len_: uint32) -> uint32:
    n: uint32 = 0
    i: uint32 = 0
    while i < cse_cand_n:
        ast: uint32 = cse_cand_ast[i]
        if ast != 0 and nd_kind[ast] == ND_BINARY:
            if ir_value_eq(cse_cand_ir[i], proto_ir) != 0:
                # Before clobbering this subtree into an ident, kill every
                # candidate whose AST lies WITHIN it (its nodes are about to be
                # orphaned) so we never double-rewrite a nested sub-part.
                cse_kill_descendants(ast)
                cse_rewrite_to_ident(ast, off, len_)
                cse_cand_ast[i] = 0
                n = n + 1
        i = i + 1
    return n


# Null every candidate entry whose AST node is a descendant of `ast` (children
# of an ND_BINARY are nd_a/nd_b). Called before `ast` is collapsed to an ident.
def cse_kill_descendants(ast: uint32):
    if ast == 0:
        return
    k: uint32 = nd_kind[ast]
    if k == ND_BINARY:
        cse_kill_subtree(nd_a[ast])
        cse_kill_subtree(nd_b[ast])
        return
    # An ND_INDEX load candidate (load-CSE): its base + index subtrees are about
    # to be orphaned when the load collapses to an ident, so kill any candidate
    # (e.g. a binop nested in the index expression) living inside them.
    if k == ND_INDEX:
        cse_kill_subtree(nd_a[ast])
        cse_kill_subtree(nd_b[ast])


def cse_kill_subtree(node: uint32):
    if node == 0:
        return
    m: uint32 = 0
    while m < cse_cand_n:
        if cse_cand_ast[m] == node:
            cse_cand_ast[m] = 0
        m = m + 1
    k: uint32 = nd_kind[node]
    if k == ND_BINARY or k == ND_INDEX:
        cse_kill_subtree(nd_a[node])
        cse_kill_subtree(nd_b[node])


# Run CSE over a single statement's expression `expr_root`. Materializes the
# FIRST repeated pure binop value into a temp, rewrites all its occurrences,
# and records the temp decl in cse_pend_* for the caller to splice in. May fire
# multiple times (one temp per distinct repeated value). Returns nothing; side
# effects are the rewrites + pended decls + opt_cse_count bump.
def cse_statement_expr(expr_root: uint32):
    if expr_root == 0:
        return
    cse_cand_n = 0
    ir_reset()                 # one shared arena for ALL candidates of this stmt
    cse_collect(expr_root)
    # For each candidate (outermost-first), if another LATER live candidate has
    # an equal value, this is a repeated expression: materialize it. Outermost-
    # first means we capture the largest redundant expression, and cse_apply's
    # nested-invalidation prevents re-CSE of its sub-parts.
    i: uint32 = 0
    while i < cse_cand_n:
        ast_i: uint32 = cse_cand_ast[i]
        if ast_i != 0 and nd_kind[ast_i] == ND_BINARY:
            # Is there a later live candidate value-equal to this one?
            dup: uint32 = 0
            j: uint32 = i + 1
            while j < cse_cand_n:
                aj: uint32 = cse_cand_ast[j]
                if aj != 0 and nd_kind[aj] == ND_BINARY:
                    if ir_value_eq(cse_cand_ir[j], cse_cand_ir[i]) != 0:
                        dup = 1
                        j = cse_cand_n
                    else:
                        j = j + 1
                else:
                    j = j + 1
            if dup != 0:
                # Materialize: mint a temp, build its decl with the ORIGINAL
                # (pre-rewrite) expression as initialiser, then rewrite every
                # occurrence (incl. this one) to read the temp.
                cse_mint_temp_name()
                toff: uint32 = opt_tmp_name_off
                tlen: uint32 = opt_tmp_name_len
                # Clone the defining expression for the temp init. We use the
                # FIRST occurrence's AST node as the init by detaching it: build
                # the decl pointing at a COPY is unnecessary because we rewrite
                # the first occurrence to an ident AFTER capturing it as init.
                # So: decl init = the first occurrence's current subtree.
                init_node: uint32 = ast_i
                # Rewrite all occurrences EXCEPT we must preserve init_node's
                # subtree as the decl initialiser. cse_apply rewrites ast_i too,
                # so first snapshot init by making the decl reference a shallow
                # clone of ast_i.
                clone: uint32 = cse_clone_expr(ast_i)
                if clone == 0:
                    return
                d: uint32 = cse_make_temp_decl(toff, tlen, clone)
                if d == 0:
                    return
                cnt: uint32 = cse_apply(expr_root, cse_cand_ir[i], toff, tlen)
                if cnt >= 2:
                    if cse_pend_n < CSE_MAX_PEND:
                        cse_pend_decl[cse_pend_n] = d
                        cse_pend_n = cse_pend_n + 1
                    # Each of the cnt occurrences but the first is an eliminated
                    # recomputation.
                    opt_cse_count = opt_cse_count + (cnt - 1)
        i = i + 1


# Deep-clone a pure expression subtree into fresh AST nodes, so the temp's
# initialiser is independent of the in-place rewrites applied to the original
# occurrences. The pure value set (ir_lower_pure_expr) admits ND_BINARY over
# ident/const leaves AND opaque READ leaves — an ND_CAST (nd_a=type node,
# nd_b=operand) and an ND_INDEX (nd_a=base, nd_b=index). A float subexpression is
# ALWAYS a cast/binary over casts, so the clone MUST recurse into the cast's
# child slots: cloning only ND_BINARY's nd_a/nd_b dropped a cast's type+operand,
# leaving a zeroed cast that emitted garbage (the float-mixed CSE miscompile, and
# a latent integer cast-CSE bug). We therefore deep-clone EVERY expression child
# slot (nd_a/nd_b for ND_BINARY/ND_CAST/ND_INDEX) by node kind. A leaf with no
# expression children (ident / literal) just copies its scalar fields. The TYPE
# node under a cast (nd_a) is an ND_TYPE carrying its code in nd_aux; cloning it
# copies that code so the cast width/signedness is reproduced exactly.
def cse_clone_expr(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    c: uint32 = node_new(k)
    if c == 0:
        return 0
    nd_aux[c] = nd_aux[node]
    nd_num[c] = nd_num[node]
    nd_name_off[c] = nd_name_off[node]
    nd_name_len[c] = nd_name_len[node]
    if k == ND_BINARY or k == ND_CAST or k == ND_INDEX:
        nd_a[c] = cse_clone_expr(nd_a[node])
        nd_b[c] = cse_clone_expr(nd_b[node])
    return c


# Expression roots of a statement: the slots that hold a top-level expression
# whose value we may CSE. We deliberately handle only statements whose
# expression is a self-contained pure region; assignment TARGETS and impure
# constructs are left alone (their value IR won't lower anyway).
def cse_stmt_expr_roots(stmt: uint32):
    k: uint32 = nd_kind[stmt]
    if k == ND_RETURN:
        cse_statement_expr(nd_a[stmt])
    elif k == ND_EXPR_STMT:
        cse_statement_expr(nd_a[stmt])
    elif k == ND_ASSIGN:
        # Only the VALUE side (nd_b); the target (nd_a) is an lvalue.
        cse_statement_expr(nd_b[stmt])
    elif k == ND_VAR_DECL:
        cse_statement_expr(nd_b[stmt])
    elif k == ND_IF:
        cse_statement_expr(nd_a[stmt])
    # A WHILE / DO_WHILE CONDITION is DELIBERATELY NOT CSE'd here. Unlike a
    # return/assign/var-decl/if expression (evaluated exactly once), a loop
    # condition is RE-EVALUATED every iteration. cse_block splices the minted
    # `__cse_N = <expr>` temp into the PREHEADER — before the loop statement —
    # so it is computed ONCE. That is only sound if <expr> is loop-INVARIANT.
    # For a repeated subexpression whose leaves the body modifies (e.g.
    # `while candidate[start + blen] != 0 and candidate[start + blen] != 47:`
    # with `blen` incremented in the body), the once-computed temp goes STALE
    # and the condition never changes -> INFINITE LOOP (the fs/vfs.ad
    # _cpio_listdir_at basename scan that hung sys_open on a directory under
    # HAMNIX_KERNEL_OPT=1). Local CSE has no per-iteration splice point and does
    # no invariance test, so it must not touch loop conditions. Hoisting a
    # genuinely loop-invariant repeated condition subexpression is Phase-3
    # LICM's job — it computes the loop-body clobber set and only lifts an
    # expression whose leaves are provably unwritten in the loop.


# CSE one statement-chain (a block). Returns the (possibly new) head with any
# temp decls spliced in immediately before the statements that use them. Also
# recurses into nested block bodies (if/while/for/elif) AFTER processing the
# statement itself.
def cse_block(head: uint32) -> uint32:
    new_head: uint32 = head
    prev: uint32 = 0
    s: uint32 = head
    while s != 0:
        nxt: uint32 = nd_next[s]
        # Process this statement's expression for CSE; pended temp decls accrue
        # in cse_pend_*.
        cse_pend_n = 0
        cse_stmt_expr_roots(s)
        # Splice pended decls in BEFORE s (in mint order), so codegen computes
        # the temp before the statement that reads it.
        if cse_pend_n > 0:
            pi: uint32 = 0
            while pi < cse_pend_n:
                d: uint32 = cse_pend_decl[pi]
                if prev == 0:
                    new_head = d
                else:
                    nd_next[prev] = d
                nd_next[d] = s
                prev = d
                pi = pi + 1
        # Recurse into nested blocks.
        k: uint32 = nd_kind[s]
        if k == ND_IF:
            nd_b[s] = cse_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                nd_b[e] = cse_block(nd_b[e])
                e = nd_next[e]
            nd_d[s] = cse_block(nd_d[s])
        elif k == ND_WHILE:
            nd_b[s] = cse_block(nd_b[s])
        elif k == ND_DO_WHILE:
            nd_b[s] = cse_block(nd_b[s])
        elif k == ND_FOR:
            nd_b[s] = cse_block(nd_b[s])
        prev = s
        s = nxt
    return new_head


def opt_cse_function(fn: uint32):
    # Build this function's float-local table so cse_make_temp_decl can type a
    # shared float value (params + body var-decls; globals already built).
    opt_fw_build(fn)
    # The function body chain hangs off nd_c (ND_FUNCTION: c = body chain head).
    nd_c[fn] = cse_block(nd_c[fn])


# =======================================================================
# Phase 3 — Loop-Invariant Code Motion (LICM).
# =======================================================================
#
# STRATEGY (conservative + correct over fast)
# -------------------------------------------
# LICM grows the analysis scope from a single statement (Phase 2's CSE region)
# to a whole LOOP BODY. A pure expression is LOOP-INVARIANT if computing it once
# before the loop yields the same value it would on every iteration — i.e. none
# of its inputs change inside the loop. We hoist such an expression into a temp
# in a synthetic PRE-HEADER spliced immediately before the loop, and rewrite the
# in-loop occurrences to read the temp.
#
# INVARIANCE TEST (conservative)
#   A candidate is a PURE expression in the exact Phase-2 value set: int/char/
#   bool literals, bare idents, and IR_BINOP over the signedness-invariant 64-bit
#   op set (ADD/SUB/MUL/AND/OR/XOR/SHL). It lowers via ir_lower_pure_expr, so by
#   construction it contains NO loads/indexes, NO calls, NO DIV/MOD/SHR, NO
#   compares/casts/unary — it cannot fault, divide, or have a side effect.
#   It is loop-invariant iff NONE of its leaf idents is written anywhere in the
#   loop body. "Written" = the ident is:
#     * an ND_ASSIGN target (plain or augmented),
#     * an ND_VAR_DECL name (re-declared / shadowed in the body),
#     * the loop induction variable of an ND_FOR / ND_FOR_UNPACK in the body,
#   AND, as a blanket conservative guard, if the loop body contains ANY call
#   (ND_CALL) or ANY address-of (UNOP_ADDR), we treat EVERY ident as potentially
#   clobbered and hoist NOTHING from that loop: a call may write through a
#   pointer to any local/global, and once an address escapes the compiler can no
#   longer prove the named storage is unmodified. (Phase 2's pure value set never
#   lowers a call/addr-of into a candidate, but they can still sit ELSEWHERE in
#   the body and clobber an otherwise-pure leaf, so the whole-body scan must see
#   them.)
#
# ZERO-TRIP SAFETY
#   Hoisting a computation above a loop that may run zero times is normally
#   unsafe (it would execute work the original program might skip). It is safe
#   HERE precisely because the value set is pure, side-effect-free and
#   non-faulting: evaluating `a*b+c` (a,b,c unchanged in the loop) before a
#   zero-trip loop produces an unused temp with no observable effect. DIV/MOD/
#   loads are kept OUT of the set (ir_lower_pure_expr returns 0 for them) exactly
#   so a possibly-trapping op is never hoisted above its guard.
#
# NESTED LOOPS
#   licm_block recurses into a loop's body FIRST (innermost loops processed
#   before their enclosing loop). An expression invariant w.r.t. the inner loop
#   but not the outer is hoisted only to the INNER pre-header: the inner pass
#   sees the outer induction var as a free (unwritten-by-the-inner-body) leaf and
#   hoists it just above the inner loop, where it is still inside the outer loop.
#   The outer pass then runs on a body that already contains that pre-header
#   decl; the decl's RHS is invariant in the outer loop only if its leaves are
#   outer-invariant too, in which case the outer pass hoists the pre-header decl
#   further out as an ordinary in-body statement candidate is NOT re-formed
#   (we hoist expressions, not statements), so the conservative result is: each
#   level hoists what is invariant at that level. Correct, possibly not maximal.

# --- per-loop clobber set ------------------------------------------------
#
# The set of identifier names written anywhere in the current loop body, stored
# as (off,len) pairs into strbuf. A blanket "give up" flag is raised if the body
# contains a call or an address-of (see the strategy note).
LICM_MAX_CLOB: uint32 = 4096
licm_clob_off: Array[4096, uint32]
licm_clob_len: Array[4096, uint32]
licm_clob_n: uint32 = 0
licm_giveup: uint32 = 0          # 1 => body has a call / addr-of => hoist nothing

# 1 => the WHOLE current function takes an address (`&x`) somewhere. When it does
# NOT, no pointer in the function can name any local scalar's storage, so a store
# through an index/member/deref lvalue (a MEMORY write) provably cannot change the
# value of a hoist candidate (a pure BINOP over named scalars + constants with NO
# memory-read leaf — the ir_tree_has_leaf gate). In that case an indexed/member
# store is NOT a reason to give up LICM (it used to be, over-conservatively — the
# licm.ad kernel's whole point, hoisting `a*a`, `a*a+b`, `a*3-7` out of the inner
# loop, was defeated because the loop also stores to bucket[slot]). Computed once
# per function by licm_fn_scan_addr before licm_block runs. Address-taken funcs
# keep the old conservative giveup so a pointer store that may alias a local can
# never sink a live value.
licm_fn_has_addr: uint32 = 0


def licm_clob_reset():
    licm_clob_n = 0
    licm_giveup = 0


def licm_clob_add(off: uint32, len_: uint32):
    if licm_clob_n >= LICM_MAX_CLOB:
        # Overflow: be safe, refuse to hoist anything from this loop.
        licm_giveup = 1
        return
    licm_clob_off[licm_clob_n] = off
    licm_clob_len[licm_clob_n] = len_
    licm_clob_n = licm_clob_n + 1


# Is `name` (off,len) in the clobber set? (byte compare via ir_name_eq)
def licm_is_clobbered(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < licm_clob_n:
        if ir_name_eq(licm_clob_off[i], licm_clob_len[i], off, len_) != 0:
            return 1
        i = i + 1
    return 0


# Scan an EXPRESSION subtree for call / address-of anywhere (sets licm_giveup).
# These are the operations that can clobber a named leaf without naming it.
def licm_scan_expr(node: uint32):
    if node == 0:
        return
    if licm_giveup != 0:
        return
    k: uint32 = nd_kind[node]
    # A method call `obj.m(...)` (ND_METHOD_CALL) is just as opaque a side effect
    # as a free call (ND_CALL): it may store through `self` / a global to ANY
    # memory cell, so it MUST raise the barrier exactly like ND_CALL. Omitting it
    # let xcse/copyprop treat `r = obj.m()` as a precise straight-line write,
    # keeping a stale array-load temp live across the call -> a load-CSE
    # MISCOMPILE (the reloaded element reused the pre-call value).
    if k == ND_CALL or k == ND_METHOD_CALL:
        licm_giveup = 1
        return
    if k == ND_UNARY:
        if nd_aux[node] == UNOP_ADDR:
            licm_giveup = 1
            return
    licm_scan_expr(nd_a[node])
    licm_scan_expr(nd_b[node])
    licm_scan_expr(nd_c[node])
    licm_scan_expr(nd_d[node])
    # Follow the nd_next OPERAND chain: a call/method-call argument list and an
    # array/dict-literal element list are nd_next-linked siblings hanging off ONE
    # child slot. A scan that descends only nd_a..nd_d sees the FIRST operand and
    # misses a call/addr-of in any LATER sibling -> the barrier is not raised.
    # Expression ROOTS have nd_next==0, so this only fires inside a true operand
    # chain; over-raising the barrier is strictly conservative (never wrong).
    licm_scan_expr(nd_next[node])


# Record the lvalue target of an assignment as clobbered. We only understand a
# bare-ident target precisely; ANY other lvalue shape (index p[i], member a.b,
# deref *p) means a store we cannot pin to a name, so we give up on the whole
# loop (conservative — those stores could alias a hoist candidate's leaf).
def licm_record_assign_target(target: uint32):
    if target == 0:
        return
    if nd_kind[target] == ND_IDENT:
        licm_clob_add(nd_name_off[target], nd_name_len[target])
        return
    # Non-ident lvalue = a store through an index/member/deref: a MEMORY write.
    # If the function NEVER takes an address (`&x` appears nowhere), no pointer can
    # name any local scalar's storage, so this store cannot change the value of a
    # hoist candidate — every candidate is a pure BINOP over named scalars +
    # constants with NO memory-read leaf (the ir_tree_has_leaf gate in
    # licm_hoist_loop rejects any tree that reads an index/member/cast leaf). The
    # store writes named-aggregate or heap memory, which is disjoint from every
    # candidate's scalar leaves. So we KEEP hoisting scalar invariants past the
    # store instead of bailing. We still scan the target's index/base sub-
    # expressions for a call/addr-of barrier (e.g. `bucket[f()] = ...`), which
    # WOULD invalidate the analysis and re-raise licm_giveup.
    if licm_fn_has_addr == 0:
        licm_scan_expr(target)
        return
    # Address taken somewhere in the function: a pointer might alias a local
    # scalar, so a store through it could sink a value we'd wrongly hoist. Stay
    # conservative and give up on this loop.
    licm_giveup = 1


# Walk ONE statement chain of a loop body, recording every write (assignment
# target, var-decl name, for-loop induction var) into the clobber set and raising
# licm_giveup on any call / addr-of / opaque store. Recurses into nested blocks
# (if/elif/else, while, for, do-while) so the clobber set covers the ENTIRE loop
# body transitively.
def licm_collect_clobbers(head: uint32):
    s: uint32 = head
    while s != 0:
        if licm_giveup != 0:
            return
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            licm_record_assign_target(nd_a[s])
            licm_scan_expr(nd_b[s])
        elif k == ND_VAR_DECL:
            licm_clob_add(nd_name_off[s], nd_name_len[s])
            licm_scan_expr(nd_b[s])
        elif k == ND_EXPR_STMT:
            licm_scan_expr(nd_a[s])
        elif k == ND_RETURN:
            licm_scan_expr(nd_a[s])
        elif k == ND_IF:
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                licm_scan_expr(nd_a[e])
                licm_collect_clobbers(nd_b[e])
                e = nd_next[e]
            licm_collect_clobbers(nd_d[s])
        elif k == ND_WHILE:
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
        elif k == ND_DO_WHILE:
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
        elif k == ND_FOR:
            # Induction var is written each iteration.
            licm_clob_add(nd_name_off[s], nd_name_len[s])
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
        elif k == ND_FOR_UNPACK:
            # Each unpack target ident is written; iterable (b) + body (c).
            v: uint32 = nd_a[s]
            while v != 0:
                if nd_kind[v] == ND_IDENT:
                    licm_clob_add(nd_name_off[v], nd_name_len[v])
                v = nd_next[v]
            licm_scan_expr(nd_b[s])
            licm_collect_clobbers(nd_c[s])
        elif k == ND_BREAK or k == ND_CONTINUE or k == ND_PASS:
            # Pure control no-ops: no writes, no sub-expressions to scan.
            pass
        else:
            # ANY statement kind we do NOT model precisely (tuple-unpack `a,b = ..`,
            # defer, with, match, try, raise, yield, augmented store through a
            # non-ident lvalue, ...) may write a name we cannot pin OR embed a
            # call/addr-of that escapes a hoist-candidate leaf. The clobber analysis
            # cannot prove it harmless, so refuse to hoist anything from this loop.
            # Strict-superset conservative: LICM can only KEEP more recomputes, never
            # wrongly hoist. (codegen.ad's current statement subset does not emit
            # these kinds, so this is defense-in-depth against future subset growth /
            # the optimizer running over the full language under --opt.)
            licm_giveup = 1
            return
        s = nd_next[s]


# --- invariance test over an IR value -----------------------------------
#
# An IR value (built by ir_lower_pure_expr) is loop-invariant iff every IR_IDENT
# leaf names a variable NOT in the clobber set. IR_CONST leaves are always
# invariant. (giveup is checked by the caller before this runs.)
def licm_ir_invariant(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_CONST:
        return 1
    if k == IR_IDENT:
        if licm_is_clobbered(ir_name_off[v], ir_name_len[v]) != 0:
            return 0
        return 1
    if k == IR_BINOP:
        if licm_ir_invariant(ir_a[v]) == 0:
            return 0
        return licm_ir_invariant(ir_b[v])
    return 0


# --- candidate collection + hoist ---------------------------------------
#
# We reuse the Phase-2 candidate machinery (cse_cand_*) over the WHOLE loop body
# instead of one statement: every pure ND_BINARY subtree across the body is
# lowered into one shared IR arena, so value-equal occurrences in different
# statements share a value id and get hoisted to ONE temp. Outermost-first
# pre-order means the maximal invariant expression wins.

# Pending pre-header decls for the loop currently being hoisted (spliced before
# the loop in mint order). Reuses CSE_MAX_PEND sizing semantics.
LICM_MAX_PEND: uint32 = 256
licm_pend_decl: Array[256, uint32]
licm_pend_n: uint32 = 0


# Collect every pure ND_BINARY subtree across a loop-body statement chain into
# the shared cse_cand_* list (pre-order, outermost-first), each with its lowered
# value IR (shared arena, NOT reset per node). Mirrors cse_collect but spans a
# whole statement chain and descends into nested control flow, so a candidate may
# appear in any statement of the body. Statement lvalue targets are NOT lowered
# (they are not r-value expressions). The clobber scan ran first, so we know the
# body is call/addr-free here (giveup == 0).
def licm_collect_body(head: uint32):
    s: uint32 = head
    while s != 0:
        if cse_cand_n >= CSE_MAX_CAND:
            return
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            cse_collect(nd_b[s])
        elif k == ND_VAR_DECL:
            cse_collect(nd_b[s])
        elif k == ND_EXPR_STMT:
            cse_collect(nd_a[s])
        elif k == ND_RETURN:
            cse_collect(nd_a[s])
        elif k == ND_IF:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                cse_collect(nd_a[e])
                licm_collect_body(nd_b[e])
                e = nd_next[e]
            licm_collect_body(nd_d[s])
        elif k == ND_WHILE:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
        elif k == ND_DO_WHILE:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
        elif k == ND_FOR:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
        elif k == ND_FOR_UNPACK:
            cse_collect(nd_b[s])
            licm_collect_body(nd_c[s])
        s = nd_next[s]


# Rewrite EVERY occurrence in the whole body whose value-IR equals `proto_ir`
# into an ND_IDENT(off,len). Same shape as cse_apply but the candidate list now
# spans the whole loop body. Returns the rewritten count.
def licm_apply(proto_ir: uint32, off: uint32, len_: uint32) -> uint32:
    n: uint32 = 0
    i: uint32 = 0
    while i < cse_cand_n:
        ast: uint32 = cse_cand_ast[i]
        if ast != 0 and nd_kind[ast] == ND_BINARY:
            if ir_value_eq(cse_cand_ir[i], proto_ir) != 0:
                cse_kill_descendants(ast)
                cse_rewrite_to_ident(ast, off, len_)
                cse_cand_ast[i] = 0
                n = n + 1
        i = i + 1
    return n


# Hoist every loop-invariant pure expression that occurs in the body of the loop
# node `loop`. The loop body chain is on nd_b for ND_WHILE/ND_DO_WHILE/ND_FOR.
# Returns the list of pre-header decls via licm_pend_* (caller splices them
# before the loop). The body's in-loop occurrences are rewritten to read temps.
def licm_hoist_loop(loop: uint32):
    body: uint32 = nd_b[loop]
    if body == 0:
        return
    licm_pend_n = 0
    # 1) Clobber analysis over the whole body.
    licm_clob_reset()
    licm_collect_clobbers(body)
    if licm_giveup != 0:
        return                 # call / addr-of / opaque store: hoist nothing
    # 2) Collect pure-binop candidates across the whole body into a shared arena.
    cse_cand_n = 0
    ir_reset()
    licm_collect_body(body)
    # 3) For each candidate (outermost-first), if it is loop-invariant, hoist it
    #    to a pre-header temp and rewrite all its occurrences. cse_apply's
    #    nested-invalidation prevents re-hoisting a sub-part of a hoisted expr.
    i: uint32 = 0
    while i < cse_cand_n:
        ast_i: uint32 = cse_cand_ast[i]
        if ast_i != 0 and nd_kind[ast_i] == ND_BINARY:
            vi: uint32 = cse_cand_ir[i]
            # ZERO-TRIP TRAP SAFETY: never hoist a tree containing a divide
            # (DIV/MOD/IDIV) — it could fault above a loop that runs zero times,
            # a trap the original program would not raise. Compares/SHR/arith are
            # non-trapping and remain hoistable. (Phase 6 broadened the lowered
            # set to include div/mod; this guard keeps LICM's existing zero-trip
            # contract intact.)
            if ir_tree_has_div(vi) != 0:
                i = i + 1
                continue
            # ALIAS SAFETY: never hoist a tree containing an opaque read leaf
            # (cast/index/member) — the clobber model can't prove a p[i]/a.x load
            # is loop-invariant, and the leaf may alias an in-loop store.
            if ir_tree_has_leaf(vi) != 0:
                i = i + 1
                continue
            if licm_ir_invariant(vi) != 0:
                # Mint a temp, snapshot the defining expression as a clone so the
                # in-place rewrite of occurrences doesn't disturb the decl init.
                cse_mint_temp_name()
                toff: uint32 = opt_tmp_name_off
                tlen: uint32 = opt_tmp_name_len
                clone: uint32 = cse_clone_expr(ast_i)
                if clone == 0:
                    return
                d: uint32 = cse_make_temp_decl(toff, tlen, clone)
                if d == 0:
                    return
                cnt: uint32 = licm_apply(vi, toff, tlen)
                if cnt >= 1:
                    if licm_pend_n < LICM_MAX_PEND:
                        licm_pend_decl[licm_pend_n] = d
                        licm_pend_n = licm_pend_n + 1
                    opt_licm_count = opt_licm_count + 1
        i = i + 1


# Walk a statement chain; for each loop, recurse into its body FIRST (innermost-
# first, so a nested loop gets its own pre-header), then hoist the loop's
# invariant expressions into a pre-header decl chain spliced immediately BEFORE
# the loop. Returns the (possibly new) chain head. Mirrors cse_block's splice
# bookkeeping.
def licm_block(head: uint32) -> uint32:
    new_head: uint32 = head
    prev: uint32 = 0
    s: uint32 = head
    while s != 0:
        nxt: uint32 = nd_next[s]
        k: uint32 = nd_kind[s]
        # Recurse into nested blocks FIRST so inner loops are processed before
        # the enclosing one (innermost pre-headers placed first).
        if k == ND_IF:
            nd_b[s] = licm_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                nd_b[e] = licm_block(nd_b[e])
                e = nd_next[e]
            nd_d[s] = licm_block(nd_d[s])
        elif k == ND_WHILE:
            nd_b[s] = licm_block(nd_b[s])
        elif k == ND_DO_WHILE:
            nd_b[s] = licm_block(nd_b[s])
        elif k == ND_FOR:
            nd_b[s] = licm_block(nd_b[s])
        # Hoist this loop's invariants into a pre-header spliced before it.
        if k == ND_WHILE or k == ND_DO_WHILE or k == ND_FOR:
            licm_hoist_loop(s)
            if licm_pend_n > 0:
                pi: uint32 = 0
                while pi < licm_pend_n:
                    d: uint32 = licm_pend_decl[pi]
                    if prev == 0:
                        new_head = d
                    else:
                        nd_next[prev] = d
                    nd_next[d] = s
                    prev = d
                    pi = pi + 1
        prev = s
        s = nxt
    return new_head


# --- whole-function address-of prescan -----------------------------------
#
# Set licm_fn_has_addr=1 iff `&<anything>` (UNOP_ADDR) appears ANYWHERE in the
# function body, at any depth, following the nd_next operand chain (so `&x` as a
# 2nd+ call argument is not missed). Used by licm_record_assign_target to decide
# whether an indexed/member/deref store may alias a local scalar: with NO address
# taken, no pointer can name a local's storage, so a memory store cannot clobber a
# scalar hoist candidate and LICM need not give up on the loop.
def licm_addr_scan_expr(node: uint32):
    if node == 0:
        return
    if licm_fn_has_addr != 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_UNARY:
        if nd_aux[node] == UNOP_ADDR:
            licm_fn_has_addr = 1
            return
    licm_addr_scan_expr(nd_a[node])
    licm_addr_scan_expr(nd_b[node])
    licm_addr_scan_expr(nd_c[node])
    licm_addr_scan_expr(nd_d[node])
    licm_addr_scan_expr(nd_next[node])


def licm_addr_scan_block(head: uint32):
    s: uint32 = head
    while s != 0:
        if licm_fn_has_addr != 0:
            return
        k: uint32 = nd_kind[s]
        licm_addr_scan_expr(nd_a[s])
        licm_addr_scan_expr(nd_b[s])
        licm_addr_scan_expr(nd_c[s])
        licm_addr_scan_expr(nd_d[s])
        if k == ND_IF:
            licm_addr_scan_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                licm_addr_scan_block(nd_b[e])
                e = nd_next[e]
            licm_addr_scan_block(nd_d[s])
        elif k == ND_WHILE:
            licm_addr_scan_block(nd_b[s])
        elif k == ND_DO_WHILE:
            licm_addr_scan_block(nd_b[s])
        elif k == ND_FOR:
            licm_addr_scan_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            licm_addr_scan_block(nd_c[s])
        s = nd_next[s]


def opt_licm_function(fn: uint32):
    opt_fw_build(fn)
    # Whole-function address-of prescan gates the indexed-store LICM relaxation.
    licm_fn_has_addr = 0
    licm_addr_scan_block(nd_c[fn])
    # The function body chain hangs off nd_c (ND_FUNCTION: c = body chain head).
    nd_c[fn] = licm_block(nd_c[fn])


# =======================================================================
# Phase 3.6 — INDUCTION-VARIABLE STRENGTH REDUCTION (IVSR).
# =======================================================================
#
# WHAT IT DOES
# ------------
# For a COUNTED loop whose induction variable `i` advances by a single constant
# step `S` (`i = i + S`, `i = i - S`, `i += S`, `i -= S`) at exactly one TOP-
# LEVEL point in the body, every array access `arr[ E ]` whose (cast-peeled)
# index `E` is an AFFINE function of `i` — `i*K + R`, `K*i + R`, `i*K`, `i + R`,
# or `i` — with a constant integer coefficient `K` and a LOOP-INVARIANT remainder
# `R` (no use of `i`, no clobbered leaf, no load/call/addr-of) is rewritten to
# read a RUNNING induction variable `t`:
#
#     t = E            # pre-header: E evaluated at the loop-entry value of i
#     ...  arr[t] ...  # body: index replaced by the running variable
#     i = i + S        # the original IV step (unchanged)
#     t = t + (K*S)    # appended: keep t == K*i + R by induction
#
# This elides the per-iteration `i*K` MULTIPLY (and the add of R) on every such
# access, replacing it with a single constant add of `K*S` shared across all
# accesses with the same affine index. The running variable is an ordinary
# promotable integer local — regalloc may pin it in a callee-saved register.
#
# SOUNDNESS
# ---------
# The transform is pure integer algebra on 64-bit modular values. Initially
# t == E == K*i + R at loop entry. After each iteration i becomes i+S and t
# becomes t + K*S, so the invariant t == K*i + R is MAINTAINED (R is invariant).
# Therefore at EVERY body point where the original index E was read, t holds the
# identical 64-bit value E would have computed. Replacing arr[E] by arr[t] is
# value-preserving. Conditions enforced before firing (any failure => no change):
#   * the IV `i` is written EXACTLY ONCE in the whole body, and that single write
#     is a recognised constant-step form at the TOP LEVEL of the body chain (not
#     nested inside if/while/for) — so the appended `t += K*S` runs exactly as
#     often as the IV step;
#   * the remainder R is loop-invariant: no leaf of R is in the body clobber set
#     and R does not use `i` (so t's update needs no R term);
#   * the index expression E contains no load / call / addr-of (it is a pure
#     arithmetic value over idents+consts), so cloning it for the pre-header is
#     value-faithful and re-evaluable;
#   * the body has no call / addr-of / opaque (non-ident-target) store anywhere
#     (reusing the LICM clobber model) — guaranteeing the clobber set is a sound
#     over-approximation of every name written in the loop.
# Only runs under ADDER_OPT (Phase 3.6); flag-OFF output is byte-identical.

# --- the recognised induction variable for the loop currently being processed
ivsr_iv_off: uint32 = 0
ivsr_iv_len: uint32 = 0
ivsr_iv_step: int64 = 0          # signed constant step S
ivsr_iv_step_stmt: uint32 = 0    # the top-level ND_ASSIGN that steps i
ivsr_iv_writes: uint32 = 0       # total writes to i across the whole body
ivsr_bad: uint32 = 0             # set if the body shape disqualifies IVSR


# Is AST node `n` a compile-time integer constant? If so return 1 and store its
# (signed 64-bit) value via out. Peels `cast[int64]/cast[uint64](lit)` wrappers
# (8-byte int casts are value-preserving over the 64-bit index domain — the
# common idiom `i + cast[int64](1)`), recursively. Does NOT peel narrowing casts
# (int8/16/32 etc.) since those could change the literal's value.
def ivsr_const_val(n: uint32, out: Ptr[int64]) -> uint32:
    if n == 0:
        return 0
    if nd_kind[n] == ND_INT_LIT:
        out[0] = cast[int64](nd_num[n])
        return 1
    if nd_kind[n] == ND_CAST:
        tn: uint32 = nd_a[n]
        if tn != 0 and nd_kind[tn] == ND_TYPE:
            code: uint32 = nd_aux[tn]
            if code == 5 or code == 9:        # int64 / uint64: non-narrowing
                return ivsr_const_val(nd_b[n], out)
        return 0
    return 0


# IVSR clobber collection. Unlike LICM (which BAILS on any non-ident store
# target because it hoists whole expressions that could alias a memory cell), an
# affine INDEX is pure arithmetic over NAMED locals + constants — an indexed
# memory store `arr[E] = v` writes MEMORY, not a named local, so it cannot change
# the value of any ident leaf of the coefficient/remainder. Therefore IVSR records
# only IDENT-target writes into the clobber set and simply IGNORES indexed/member/
# deref store targets (their VALUE side is still scanned for call/addr-of). We
# still HARD-BAIL (licm_giveup) on a call or an address-of anywhere in the body:
# those can write through an alias to a named local we track. This reuses the
# licm_clob_* storage + licm_is_clobbered / licm_ir_invariant predicates.
def ivsr_collect_clobbers(head: uint32):
    s: uint32 = head
    while s != 0:
        if licm_giveup != 0:
            return
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            tgt: uint32 = nd_a[s]
            if nd_kind[tgt] == ND_IDENT:
                licm_clob_add(nd_name_off[tgt], nd_name_len[tgt])
            else:
                # Indexed / member / deref store: writes memory, not a name.
                # Scan the TARGET's index/base expressions for call/addr-of too.
                licm_scan_expr(tgt)
            licm_scan_expr(nd_b[s])
        elif k == ND_VAR_DECL:
            licm_clob_add(nd_name_off[s], nd_name_len[s])
            licm_scan_expr(nd_b[s])
        elif k == ND_EXPR_STMT:
            licm_scan_expr(nd_a[s])
        elif k == ND_RETURN:
            licm_scan_expr(nd_a[s])
        elif k == ND_IF:
            licm_scan_expr(nd_a[s])
            ivsr_collect_clobbers(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                licm_scan_expr(nd_a[e])
                ivsr_collect_clobbers(nd_b[e])
                e = nd_next[e]
            ivsr_collect_clobbers(nd_d[s])
        elif k == ND_WHILE:
            licm_scan_expr(nd_a[s])
            ivsr_collect_clobbers(nd_b[s])
        elif k == ND_DO_WHILE:
            licm_scan_expr(nd_a[s])
            ivsr_collect_clobbers(nd_b[s])
        elif k == ND_FOR:
            licm_clob_add(nd_name_off[s], nd_name_len[s])
            licm_scan_expr(nd_a[s])
            ivsr_collect_clobbers(nd_b[s])
        elif k == ND_FOR_UNPACK:
            v: uint32 = nd_a[s]
            while v != 0:
                if nd_kind[v] == ND_IDENT:
                    licm_clob_add(nd_name_off[v], nd_name_len[v])
                v = nd_next[v]
            licm_scan_expr(nd_b[s])
            ivsr_collect_clobbers(nd_c[s])
        s = nd_next[s]


# Does AST subtree `n` reference the IV name (ivsr_iv_off/len) anywhere?
def ivsr_uses_iv(n: uint32) -> uint32:
    if n == 0:
        return 0
    if nd_kind[n] == ND_IDENT:
        if ir_name_eq(nd_name_off[n], nd_name_len[n], ivsr_iv_off, ivsr_iv_len) != 0:
            return 1
        return 0
    if ivsr_uses_iv(nd_a[n]) != 0:
        return 1
    if ivsr_uses_iv(nd_b[n]) != 0:
        return 1
    if ivsr_uses_iv(nd_c[n]) != 0:
        return 1
    return ivsr_uses_iv(nd_d[n])


# Record every write to the IV across the loop body, and detect the single
# constant-step form at the TOP LEVEL. `top` is 1 only for the body's own
# statement chain (not nested control-flow bodies). Sets ivsr_bad on any IV
# write we don't model as the recognised step (e.g. nested, augmented-mul,
# non-constant step), so the caller refuses to transform.
def ivsr_scan_iv(head: uint32, top: uint32):
    s: uint32 = head
    while s != 0:
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            tgt: uint32 = nd_a[s]
            if nd_kind[tgt] == ND_IDENT and \
               ir_name_eq(nd_name_off[tgt], nd_name_len[tgt],
                          ivsr_iv_off, ivsr_iv_len) != 0:
                ivsr_iv_writes = ivsr_iv_writes + 1
                # Recognise the step form ONLY at the top level.
                matched: uint32 = 0
                if top != 0:
                    aug: uint32 = nd_aux[s]
                    rhs: uint32 = nd_b[s]
                    cv: int64 = 0
                    if aug == AUGOP_ADD and ivsr_const_val(rhs, &cv) != 0:
                        ivsr_iv_step = cv
                        ivsr_iv_step_stmt = s
                        matched = 1
                    elif aug == AUGOP_SUB and ivsr_const_val(rhs, &cv) != 0:
                        ivsr_iv_step = 0 - cv
                        ivsr_iv_step_stmt = s
                        matched = 1
                    elif aug == AUGOP_NONE and nd_kind[rhs] == ND_BINARY:
                        op: uint32 = nd_aux[rhs]
                        la: uint32 = nd_a[rhs]
                        rb: uint32 = nd_b[rhs]
                        # i = i + C  or  i = C + i  or  i = i - C
                        if op == BINOP_ADD:
                            if nd_kind[la] == ND_IDENT and \
                               ir_name_eq(nd_name_off[la], nd_name_len[la],
                                          ivsr_iv_off, ivsr_iv_len) != 0 and \
                               ivsr_const_val(rb, &cv) != 0:
                                ivsr_iv_step = cv
                                ivsr_iv_step_stmt = s
                                matched = 1
                            elif nd_kind[rb] == ND_IDENT and \
                                 ir_name_eq(nd_name_off[rb], nd_name_len[rb],
                                            ivsr_iv_off, ivsr_iv_len) != 0 and \
                                 ivsr_const_val(la, &cv) != 0:
                                ivsr_iv_step = cv
                                ivsr_iv_step_stmt = s
                                matched = 1
                        elif op == BINOP_SUB:
                            if nd_kind[la] == ND_IDENT and \
                               ir_name_eq(nd_name_off[la], nd_name_len[la],
                                          ivsr_iv_off, ivsr_iv_len) != 0 and \
                               ivsr_const_val(rb, &cv) != 0:
                                ivsr_iv_step = 0 - cv
                                ivsr_iv_step_stmt = s
                                matched = 1
                if matched == 0:
                    ivsr_bad = 1
        # Recurse into nested control-flow bodies (NOT top level).
        if k == ND_IF:
            ivsr_scan_iv(nd_b[s], 0)
            e: uint32 = nd_c[s]
            while e != 0:
                ivsr_scan_iv(nd_b[e], 0)
                e = nd_next[e]
            ivsr_scan_iv(nd_d[s], 0)
        elif k == ND_WHILE or k == ND_DO_WHILE or k == ND_FOR:
            ivsr_scan_iv(nd_b[s], 0)
        elif k == ND_FOR_UNPACK:
            ivsr_scan_iv(nd_c[s], 0)
        s = nd_next[s]


# Peel a chain of integer casts off an index expression, returning the inner
# arithmetic node. `cast[int64](k*N+j)` -> the `k*N+j` ND_BINARY. Only int casts
# (ND_CAST with a non-float target) are peeled; the affine match runs on the
# peeled node and the value is preserved because the surrounding index codegen
# applies the same scaling regardless.
def ivsr_peel_cast(n: uint32) -> uint32:
    c: uint32 = n
    while c != 0 and nd_kind[c] == ND_CAST:
        if opt_expr_float_width(c) != 0:
            return c
        c = nd_b[c]
    return c


# Match `peeled` against an affine function of the IV: returns 1 and stores the
# constant coefficient K via kout when peeled == one of:
#   i              -> K = 1
#   i + R / R + i  -> K = 1   (R loop-invariant, no IV use)
#   i - R          -> K = 1
#   i*K / K*i      -> coefficient K (constant)
#   i*K + R / R + i*K / i*K - R  -> coefficient K, remainder R invariant
# The remainder R must be loop-invariant and must NOT use the IV. The whole
# affine expression must be pure (no load/call/addr) so it can be re-evaluated
# in the pre-header. Returns 0 if not a recognised reducible affine form.
def ivsr_is_invariant_expr(n: uint32) -> uint32:
    # A subtree is loop-invariant for IVSR iff it lowers to a pure value (no
    # load/call/addr leaf) AND none of its ident leaves is clobbered AND it does
    # not use the IV. Reuse the LICM IR substrate.
    if n == 0:
        return 1
    # A compile-time constant (incl. `cast[int64](lit)`) is trivially invariant —
    # the LICM IR substrate treats a cast as an opaque LEAF and would reject it,
    # so recognise the constant form directly.
    cdummy: int64 = 0
    if ivsr_const_val(n, &cdummy) != 0:
        return 1
    if ivsr_uses_iv(n) != 0:
        return 0
    v: uint32 = ir_lower_pure_expr(n)
    if v == 0:
        return 0
    if ir_tree_has_leaf(v) != 0:
        return 0
    if ir_tree_has_div(v) != 0:
        return 0
    return licm_ir_invariant(v)


# Is `n` exactly a read of the IV?
def ivsr_is_iv_ref(n: uint32) -> uint32:
    if n != 0 and nd_kind[n] == ND_IDENT and \
       ir_name_eq(nd_name_off[n], nd_name_len[n], ivsr_iv_off, ivsr_iv_len) != 0:
        return 1
    return 0


# Match `i*C` / `C*i` -> returns 1 and sets *coeffout to the COEFFICIENT AST node
# (the non-IV multiplicand). The coefficient must be a LOOP-INVARIANT expression
# (`ivsr_is_invariant_expr`) — a literal stride OR a runtime-invariant variable
# like the row dimension `N` in `k*N`. The pre-header forms `K*S` from this node,
# so a variable coefficient is fine (it is read once into a stride temp).
def ivsr_match_mul(n: uint32, coeffout: Ptr[uint32]) -> uint32:
    if n == 0 or nd_kind[n] != ND_BINARY or nd_aux[n] != BINOP_MUL:
        return 0
    la: uint32 = nd_a[n]
    rb: uint32 = nd_b[n]
    if ivsr_is_iv_ref(la) != 0 and ivsr_is_invariant_expr(rb) != 0:
        coeffout[0] = rb
        return 1
    if ivsr_is_iv_ref(rb) != 0 and ivsr_is_invariant_expr(la) != 0:
        coeffout[0] = la
        return 1
    return 0


# Match the full affine index `peeled` against C*i + R; on success set *coeffout
# to the coefficient AST node (0 == unit coefficient, i.e. K==1) and return 1.
# C (the coefficient) and R (the remainder) must both be loop-invariant and must
# NOT use the IV. The pre-header clones the WHOLE original index expression as the
# running variable's seed, so R is captured there; coeffout is used only to form
# the per-iteration delta `coeff*step`.
def ivsr_match_affine(peeled: uint32, coeffout: Ptr[uint32]) -> uint32:
    if peeled == 0:
        return 0
    # bare `i`  -> unit coefficient
    if ivsr_is_iv_ref(peeled) != 0:
        coeffout[0] = 0
        return 1
    # `i*C` / `C*i`
    if ivsr_match_mul(peeled, coeffout) != 0:
        return 1
    if nd_kind[peeled] != ND_BINARY:
        return 0
    op: uint32 = nd_aux[peeled]
    la: uint32 = nd_a[peeled]
    rb: uint32 = nd_b[peeled]
    if op == BINOP_ADD:
        # (i*C | i) + R   |   R + (i*C | i)
        if ivsr_match_mul(la, coeffout) != 0 and ivsr_is_invariant_expr(rb) != 0:
            return 1
        if ivsr_is_iv_ref(la) != 0 and ivsr_is_invariant_expr(rb) != 0:
            coeffout[0] = 0
            return 1
        if ivsr_match_mul(rb, coeffout) != 0 and ivsr_is_invariant_expr(la) != 0:
            return 1
        if ivsr_is_iv_ref(rb) != 0 and ivsr_is_invariant_expr(la) != 0:
            coeffout[0] = 0
            return 1
        return 0
    if op == BINOP_SUB:
        # (i*C | i) - R    (R - i*C is NOT a +C*i affine form; reject)
        if ivsr_match_mul(la, coeffout) != 0 and ivsr_is_invariant_expr(rb) != 0:
            return 1
        if ivsr_is_iv_ref(la) != 0 and ivsr_is_invariant_expr(rb) != 0:
            coeffout[0] = 0
            return 1
        return 0
    return 0


# --- affine-index candidate collection over the loop body ----------------
IVSR_MAX_CAND: uint32 = 4096
ivsr_cand_idx: Array[4096, uint32]   # the ND_INDEX node's index child (peeled)
ivsr_cand_node: Array[4096, uint32]  # the ND_INDEX node itself
ivsr_cand_ir: Array[4096, uint32]    # value-IR of the affine index (for grouping)
ivsr_cand_coeff: Array[4096, uint32] # coefficient AST node (0 == unit)
ivsr_cand_done: Array[4096, uint32]  # 1 once rewritten
ivsr_cand_n: uint32 = 0


# Collect every ND_INDEX in the body whose peeled index is a reducible affine
# function of the IV. Records the index child, the owning ND_INDEX, the value-IR
# (shared arena — NOT reset per node, so equal indices group), and K. Descends
# into nested expressions and control flow. Index children are themselves scanned
# (a nested arr[b[i]] inner index could also be affine, but the outer would then
# not lower; we still try each ND_INDEX independently).
# Profitability gate: IVSR only pays off when it eliminates a per-iteration
# MULTIPLY, i.e. the affine index has a non-unit coefficient `i*C` (C a constant
# >= 2 or a runtime-invariant variable). A unit coefficient (bare `i`, or `i+R`)
# means the index is already the loop counter plus an invariant offset — running-
# variable rewriting there adds a redundant per-iteration add + an extra register
# with no multiply removed, which measured NET-NEGATIVE (sieve/clear loops). So
# we conservatively decline unit-coefficient candidates.
def ivsr_coeff_profitable(coeff: uint32) -> uint32:
    if coeff == 0:
        return 0                 # unit coefficient (bare i / i+R): no win
    cv: int64 = 0
    if ivsr_const_val(coeff, &cv) != 0:
        if cv == 0 or cv == 1:
            return 0             # i*0 / i*1: no multiply worth removing
        return 1
    return 1                     # variable invariant coefficient (e.g. i*N)


def ivsr_collect(node: uint32):
    if node == 0:
        return
    if ivsr_cand_n >= IVSR_MAX_CAND:
        return
    if nd_kind[node] == ND_INDEX:
        peeled: uint32 = ivsr_peel_cast(nd_b[node])
        coeff: uint32 = 0
        if ivsr_match_affine(peeled, &coeff) != 0 and \
           ivsr_coeff_profitable(coeff) != 0:
            v: uint32 = ir_lower_pure_expr(peeled)
            if v != 0:
                ivsr_cand_idx[ivsr_cand_n] = peeled
                ivsr_cand_node[ivsr_cand_n] = node
                ivsr_cand_ir[ivsr_cand_n] = v
                ivsr_cand_coeff[ivsr_cand_n] = coeff
                ivsr_cand_done[ivsr_cand_n] = 0
                ivsr_cand_n = ivsr_cand_n + 1
    # Descend expression children + the index base.
    ivsr_collect(nd_a[node])
    ivsr_collect(nd_b[node])
    ivsr_collect(nd_c[node])
    ivsr_collect(nd_d[node])


def ivsr_collect_body(head: uint32):
    s: uint32 = head
    while s != 0:
        if ivsr_cand_n >= IVSR_MAX_CAND:
            return
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            # Both the value side AND an indexed STORE target arr[E] = v.
            ivsr_collect(nd_a[s])
            ivsr_collect(nd_b[s])
        elif k == ND_VAR_DECL:
            ivsr_collect(nd_b[s])
        elif k == ND_EXPR_STMT:
            ivsr_collect(nd_a[s])
        elif k == ND_RETURN:
            ivsr_collect(nd_a[s])
        elif k == ND_IF:
            ivsr_collect(nd_a[s])
            ivsr_collect_body(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                ivsr_collect(nd_a[e])
                ivsr_collect_body(nd_b[e])
                e = nd_next[e]
            ivsr_collect_body(nd_d[s])
        elif k == ND_WHILE:
            ivsr_collect(nd_a[s])
            ivsr_collect_body(nd_b[s])
        elif k == ND_DO_WHILE:
            ivsr_collect(nd_a[s])
            ivsr_collect_body(nd_b[s])
        elif k == ND_FOR:
            ivsr_collect(nd_a[s])
            ivsr_collect_body(nd_b[s])
        elif k == ND_FOR_UNPACK:
            ivsr_collect(nd_b[s])
            ivsr_collect_body(nd_c[s])
        s = nd_next[s]


# Pending pre-header decls + post-step updates for the loop being processed.
IVSR_MAX_PEND: uint32 = 256
ivsr_pend_decl: Array[256, uint32]   # ND_VAR_DECL  t = E   (spliced before loop)
ivsr_pend_n: uint32 = 0


# Build a fresh ND_IDENT(off,len).
def ivsr_make_ident(off: uint32, len_: uint32) -> uint32:
    n: uint32 = node_new(ND_IDENT)
    if n == 0:
        return 0
    nd_name_off[n] = off
    nd_name_len[n] = len_
    return n


# Build a fresh ND_INT_LIT with value v.
def ivsr_make_lit(v: int64) -> uint32:
    n: uint32 = node_new(ND_INT_LIT)
    if n == 0:
        return 0
    nd_num[n] = cast[uint64](v)
    return n


# Build `t OP= delta_node` (OP = AUGOP_ADD or AUGOP_SUB) as an ND_ASSIGN.
def ivsr_make_step(off: uint32, len_: uint32, augop: uint32,
                   delta_node: uint32) -> uint32:
    a: uint32 = node_new(ND_ASSIGN)
    if a == 0:
        return 0
    tgt: uint32 = ivsr_make_ident(off, len_)
    if tgt == 0:
        return 0
    nd_a[a] = tgt
    nd_b[a] = delta_node
    nd_aux[a] = augop
    return a


# Build the per-iteration delta expression `coeff * step`:
#   * coeff == 0 (unit): delta is the literal |step|.
#   * coeff is a constant literal C: delta is the literal |C*step|.
#   * coeff is an invariant expression: delta is `(clone of coeff) * |step|`,
#     with `*1` folded away to just the coeff clone.
# Returns the delta AST node and sets *negout to 1 if the running variable must
# be DECREMENTED (negative step) — the sign is carried by AUGOP_SUB at the use
# site so the delta node is always a non-negative magnitude expression. Returns
# 0 on arena exhaustion.
def ivsr_build_delta(coeff: uint32, step: int64, negout: Ptr[uint32]) -> uint32:
    mag: int64 = step
    neg: uint32 = 0
    if step < 0:
        mag = 0 - step
        neg = 1
    negout[0] = neg
    if coeff == 0:
        return ivsr_make_lit(mag)
    cv: int64 = 0
    if ivsr_const_val(coeff, &cv) != 0:
        # Both constant -> fold to a single literal.
        return ivsr_make_lit(cv * mag)
    # Variable invariant coefficient. Clone it; multiply by mag unless mag==1.
    cc: uint32 = cse_clone_expr(coeff)
    if cc == 0:
        return 0
    if mag == 1:
        return cc
    m: uint32 = node_new(ND_BINARY)
    if m == 0:
        return 0
    lit: uint32 = ivsr_make_lit(mag)
    if lit == 0:
        return 0
    nd_aux[m] = BINOP_MUL
    nd_a[m] = cc
    nd_b[m] = lit
    return m


# Is the delta node a plain integer literal (so it can be inlined at the update
# site without a stride temp)?
def ivsr_delta_is_lit(n: uint32) -> uint32:
    if n != 0 and nd_kind[n] == ND_INT_LIT:
        return 1
    return 0


# Is the delta node cheap enough to inline DIRECTLY at the per-iteration update
# site (`t ±= delta`) instead of hoisting it into a pre-header stride temp?
#   * an integer LITERAL — always (no re-read, no register).
#   * a bare loop-INVARIANT IDENT — this is the mag==1 variable-coefficient case
#     (delta == a clone of the coefficient ident `N`, e.g. matmul's `k*N+j` where
#     coeff==N, step==1). Minting `__stride = N` DUPLICATES N into a fresh temp
#     register even though N already has a home (register or stack slot); the
#     invariant is unclobbered across the loop (IVSR gates coeff on
#     `ivsr_is_invariant_expr`, which rejects any clobbered ident), so reading N's
#     EXISTING home each iteration (`add t, N`) is value-identical AND frees the
#     duplicate register. That freed register lets a spilled callee-saved local
#     (matmul's `reps`) become register-resident, exposing a SECOND live-range
#     split candidate for the base-hoist splitter (`&B`). A NON-ident invariant
#     coeff (e.g. `N+1`, or the mag>1 `coeff*mag` product) is a real computation
#     and MUST stay hoisted into the stride temp — so only bare idents inline.
def ivsr_delta_inlinable(n: uint32) -> uint32:
    if n == 0:
        return 0
    if nd_kind[n] == ND_INT_LIT:
        return 1
    if nd_kind[n] == ND_IDENT:
        return 1
    return 0


# Splice `stmt` immediately AFTER `after` in its sibling chain.
def ivsr_splice_after(after: uint32, stmt: uint32):
    nd_next[stmt] = nd_next[after]
    nd_next[after] = stmt


# Strength-reduce one loop. Returns via ivsr_pend_* the pre-header decls to
# splice before the loop. The post-step `t += K*S` updates are spliced directly
# after the IV step statement inside the body.
def ivsr_transform_loop(loop: uint32):
    ivsr_pend_n = 0
    body: uint32 = nd_b[loop]
    if body == 0:
        return
    # 1) Clobber analysis (IVSR model): record ident writes; ignore indexed/
    #    member memory stores (they clobber no name); bail on call / addr-of.
    licm_clob_reset()
    ivsr_collect_clobbers(body)
    if licm_giveup != 0:
        return
    # 2) Identify the loop's induction variable: the UNIQUE top-level ND_ASSIGN
    #    of constant-step form whose target is an integer ident. We scan each
    #    top-level assign target as a candidate IV, then verify it is the loop's
    #    sole reducible IV. Simplest robust approach: try each top-level
    #    `x = x ± C` / `x ±= C` statement; pick the FIRST that, when treated as
    #    the IV, has exactly one write in the whole body.
    s: uint32 = body
    while s != 0:
        if nd_kind[s] == ND_ASSIGN and nd_kind[nd_a[s]] == ND_IDENT:
            cand_off: uint32 = nd_name_off[nd_a[s]]
            cand_len: uint32 = nd_name_len[nd_a[s]]
            ivsr_iv_off = cand_off
            ivsr_iv_len = cand_len
            ivsr_iv_step = 0
            ivsr_iv_step_stmt = 0
            ivsr_iv_writes = 0
            ivsr_bad = 0
            ivsr_scan_iv(body, 1)
            if ivsr_bad == 0 and ivsr_iv_writes == 1 and ivsr_iv_step_stmt != 0:
                # Found a clean single-step IV. Proceed with THIS one.
                ivsr_reduce_with_iv(loop, body)
                return
        s = nd_next[s]


# Given ivsr_iv_* already set to a validated single-step IV, collect affine
# index candidates and rewrite them to running variables.
def ivsr_reduce_with_iv(loop: uint32, body: uint32):
    # Collect affine-index candidates across the whole body (shared IR arena).
    ivsr_cand_n = 0
    ir_reset()
    ivsr_collect_body(body)
    if ivsr_cand_n == 0:
        return
    step: int64 = ivsr_iv_step
    # Group candidates by value-equal affine index; one running var per group.
    i: uint32 = 0
    while i < ivsr_cand_n:
        if ivsr_cand_done[i] == 0:
            proto: uint32 = ivsr_cand_ir[i]
            coeff: uint32 = ivsr_cand_coeff[i]
            # Build the per-iteration delta `coeff*step` (sign carried by augop).
            neg: uint32 = 0
            delta: uint32 = ivsr_build_delta(coeff, step, &neg)
            if delta == 0:
                return
            augop: uint32 = AUGOP_ADD
            if neg != 0:
                augop = AUGOP_SUB
            # Mint a running variable, pre-header decl `t = <clone of index>`.
            cse_mint_temp_name()
            toff: uint32 = opt_tmp_name_off
            tlen: uint32 = opt_tmp_name_len
            clone: uint32 = cse_clone_expr(ivsr_cand_idx[i])
            if clone == 0:
                return
            d: uint32 = cse_make_temp_decl(toff, tlen, clone)
            if d == 0:
                return
            # If the delta is a RUNTIME-INVARIANT expression (variable stride like
            # `N`), hoist it once into a pre-header stride temp so the per-iteration
            # update is a single `t ±= __stride` (no re-read/re-multiply of the
            # invariant). A literal delta is inlined directly. The stride decl is
            # spliced BEFORE the running-var decl (both go into the pre-header).
            sdecl: uint32 = 0
            step_rhs: uint32 = delta
            if ivsr_delta_inlinable(delta) == 0:
                cse_mint_temp_name()
                soff: uint32 = opt_tmp_name_off
                slen: uint32 = opt_tmp_name_len
                sdecl = cse_make_temp_decl(soff, slen, delta)
                if sdecl == 0:
                    return
                step_rhs = ivsr_make_ident(soff, slen)
                if step_rhs == 0:
                    return
            # Rewrite EVERY value-equal occurrence's index child to read t.
            cnt: uint32 = 0
            j: uint32 = i
            while j < ivsr_cand_n:
                if ivsr_cand_done[j] == 0 and \
                   ir_value_eq(ivsr_cand_ir[j], proto) != 0:
                    cse_rewrite_to_ident(ivsr_cand_idx[j], toff, tlen)
                    # ivsr_cand_idx[j] IS the index child node id (mutated in
                    # place); the parent ND_INDEX referenced it by id, so the
                    # parent now reads the running ident. If the index was cast-
                    # peeled the cast node still wraps it (cast[int64](t)) — fine.
                    ivsr_cand_done[j] = 1
                    cnt = cnt + 1
                j = j + 1
            if cnt >= 1:
                # Append `t ±= step_rhs` right after the IV step statement.
                upd: uint32 = ivsr_make_step(toff, tlen, augop, step_rhs)
                if upd == 0:
                    return
                ivsr_splice_after(ivsr_iv_step_stmt, upd)
                # Record the pre-header decls (stride first, then running var).
                if sdecl != 0:
                    if ivsr_pend_n < IVSR_MAX_PEND:
                        ivsr_pend_decl[ivsr_pend_n] = sdecl
                        ivsr_pend_n = ivsr_pend_n + 1
                if ivsr_pend_n < IVSR_MAX_PEND:
                    ivsr_pend_decl[ivsr_pend_n] = d
                    ivsr_pend_n = ivsr_pend_n + 1
                opt_ivsr_count = opt_ivsr_count + 1
        i = i + 1


# Walk a statement chain; recurse into nested loops FIRST (innermost-first), then
# strength-reduce this loop, splicing its pre-header decls immediately before it.
# Mirrors licm_block's splice bookkeeping.
def ivsr_block(head: uint32) -> uint32:
    new_head: uint32 = head
    prev: uint32 = 0
    s: uint32 = head
    while s != 0:
        nxt: uint32 = nd_next[s]
        k: uint32 = nd_kind[s]
        if k == ND_IF:
            nd_b[s] = ivsr_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                nd_b[e] = ivsr_block(nd_b[e])
                e = nd_next[e]
            nd_d[s] = ivsr_block(nd_d[s])
        elif k == ND_WHILE:
            nd_b[s] = ivsr_block(nd_b[s])
        elif k == ND_DO_WHILE:
            nd_b[s] = ivsr_block(nd_b[s])
        elif k == ND_FOR:
            nd_b[s] = ivsr_block(nd_b[s])
        if k == ND_WHILE or k == ND_DO_WHILE:
            ivsr_transform_loop(s)
            if ivsr_pend_n > 0:
                pi: uint32 = 0
                while pi < ivsr_pend_n:
                    d: uint32 = ivsr_pend_decl[pi]
                    if prev == 0:
                        new_head = d
                    else:
                        nd_next[prev] = d
                    nd_next[d] = s
                    prev = d
                    pi = pi + 1
        prev = s
        s = nxt
    return new_head


def opt_ivsr_function(fn: uint32):
    opt_fw_build(fn)
    nd_c[fn] = ivsr_block(nd_c[fn])


# =======================================================================
# Phase 7 — CROSS-STATEMENT CSE over an extended (straight-line) basic block.
# =======================================================================
#
# WHY THIS IS THE REAL WIN
# ------------------------
# Phase-2 CSE (cse_statement_expr) eliminates a redundant pure subexpression
# only WITHIN a single statement's expression tree. A subexpression computed in
# statement S1 and recomputed verbatim in S2 (with no intervening write to its
# leaves) is MISSED — the most common redundancy in real straight-line code
# (`x = a*b+c ; y = a*b+c + d`). Phase 7 closes that: it value-numbers pure
# subexpressions across a MAXIMAL straight-line run of statements and rewrites a
# later recomputation to read a temp materialized at the FIRST occurrence.
#
# SOUNDNESS — extended-basic-block local CSE, conservative
# --------------------------------------------------------
# Two occurrences of a pure value V (lowered by ir_lower_pure_expr -> the
# signedness-INVARIANT 64-bit op set over ident/const leaves; NO loads, calls,
# div/mod, compares — those never lower, so they are never candidates) compute
# the SAME bits IFF no leaf of V is written between them. We process statements
# in source order, maintaining an AVAILABLE-EXPRESSIONS set:
#   * a statement's r-value subexpressions are matched against the available set
#     FIRST (so a match shares the earlier statement's temp), THEN this
#     statement's own new pure subexpressions are added to the available set;
#   * AFTER a statement, its WRITES kill availability — every available
#     expression whose IR tree uses a written name is removed (ir_uses_name).
# A statement that we cannot model precisely is a HARD BARRIER that flushes the
# WHOLE available set and ends the straight-line run: a call (ND_CALL anywhere),
# an address-of (UNOP_ADDR), an opaque store (assign/var-decl whose effect we
# can't pin to a name — non-ident assign target = store through index/member/
# deref), or any control flow (if/while/for/do-while/break/continue/return-with-
# nested-flow). After such a statement the available set is empty and we keep
# scanning the rest of the chain as a fresh run. This is the textbook
# "available expressions within an extended basic block", at its safest:
# any operation that could alias or side-effect resets availability.
#
# RELATION TO LICM: LICM hoists loop-INVARIANT expressions to a pre-header
# (whole-loop scope, invariance test). Phase-7 CSE shares a VARIANT expression
# that merely repeats across adjacent statements in straight-line code — a
# DIFFERENT, complementary redundancy. Both can fire on the same body.
#
# IMPLEMENTATION reuses the Phase-2 candidate/clone/splice/rewrite machinery
# (cse_collect / cse_clone_expr / cse_make_temp_decl / cse_rewrite_to_ident).

# An available expression: its prototype IR value, the temp name minted for it,
# and the statement node it was (or will be) materialized before. avail_live[k]
# is cleared when a write kills the expression.
XCSE_MAX_AVAIL: uint32 = 1024
xcse_av_ir: Array[1024, uint32]
xcse_av_off: Array[1024, uint32]
xcse_av_len: Array[1024, uint32]
xcse_av_stmt: Array[1024, uint32]     # the statement BEFORE which the temp decl sits
xcse_av_materialized: Array[1024, uint32]  # 1 once the temp decl has been spliced
xcse_av_decl: Array[1024, uint32]     # the pending/created temp decl node
xcse_av_live: Array[1024, uint32]
xcse_av_n: uint32 = 0


def xcse_avail_reset():
    xcse_av_n = 0


# Kill every available expression whose IR tree references the written name.
def xcse_kill_name(off: uint32, len_: uint32):
    k: uint32 = 0
    while k < xcse_av_n:
        if xcse_av_live[k] != 0:
            if ir_uses_name(xcse_av_ir[k], off, len_) != 0:
                xcse_av_live[k] = 0
        k = k + 1


# Hard barrier: nothing computed before this point is provably still valid.
def xcse_avail_flush():
    xcse_av_n = 0


# Does the expression subtree contain a call or an address-of (anywhere)? Such a
# statement is a hard barrier (may write through a pointer to any leaf). Reuses
# the LICM scan, which sets licm_giveup on call/addr-of.
def xcse_expr_has_barrier(node: uint32) -> uint32:
    licm_giveup = 0
    licm_scan_expr(node)
    return licm_giveup


# Record a statement's writes into the available-set kill, and return 1 if the
# statement is a HARD BARRIER (flush everything + end the run), 0 if it is an
# ordinary straight-line statement whose precise writes were applied.
#
# Straight-line statements we model: ND_VAR_DECL (writes its name), ND_ASSIGN to
# a bare ident (writes that name), ND_EXPR_STMT / ND_RETURN (no write, but their
# expr must be call/addr-free). Everything else (control flow, augmented/opaque
# assign target, call/addr-of in any sub-expr) is a barrier.
def xcse_apply_stmt_effects(s: uint32) -> uint32:
    k: uint32 = nd_kind[s]
    if k == ND_VAR_DECL:
        if xcse_expr_has_barrier(nd_b[s]) != 0:
            return 1
        xcse_kill_name(nd_name_off[s], nd_name_len[s])
        return 0
    if k == ND_ASSIGN:
        # Only a plain (AUGOP_NONE) assignment to a bare IDENT is modelled; an
        # augmented assign reads+writes (still a single named write, but its RHS
        # value-IR could share — keep it simple: treat the target as written and
        # require the value side to be barrier-free). A non-ident target is an
        # opaque store -> barrier.
        tgt: uint32 = nd_a[s]
        if nd_kind[tgt] != ND_IDENT:
            return 1
        if xcse_expr_has_barrier(nd_b[s]) != 0:
            return 1
        xcse_kill_name(nd_name_off[tgt], nd_name_len[tgt])
        return 0
    if k == ND_EXPR_STMT:
        if xcse_expr_has_barrier(nd_a[s]) != 0:
            return 1
        return 0
    if k == ND_RETURN:
        if xcse_expr_has_barrier(nd_a[s]) != 0:
            return 1
        return 0
    # Any control-flow / unknown statement: hard barrier.
    return 1


# The r-value expression a straight-line statement contributes to CSE (the side
# whose pure subexpressions we may share). 0 if none.
def xcse_stmt_rvalue(s: uint32) -> uint32:
    k: uint32 = nd_kind[s]
    if k == ND_VAR_DECL:
        return nd_b[s]
    if k == ND_ASSIGN:
        return nd_b[s]
    if k == ND_EXPR_STMT:
        return nd_a[s]
    if k == ND_RETURN:
        return nd_a[s]
    return 0


# Pending splice list for the current run: (decl, stmt-to-precede) pairs, in the
# order decls must appear. Reuses cse_pend_* sizing semantics but tracks the
# anchor statement per decl (a cross-statement temp is spliced before its FIRST
# user, which may not be the statement currently processed).
XCSE_MAX_PEND: uint32 = 512
xcse_pd_decl: Array[512, uint32]
xcse_pd_before: Array[512, uint32]
xcse_pd_n: uint32 = 0


# Collect every SOUNDLY-CSE-able integer ND_INDEX load in `node` (pre-order,
# outermost-first) into the shared cse_cand_* list, each paired with its lowered
# IR_LEAF value id. A load is admitted only by opt_index_load_is_int (bare-ident
# integer-element base; float / unknown / non-ident bases declined). The load's
# index subtree is also descended so a load nested in another load's index is
# considered. Mirrors cse_collect's descent but adds ND_INDEX candidates that
# cse_collect (ND_BINARY-only) skips. The arena is the SAME shared one
# cse_collect uses (caller reset it once), so leaf value ids stay comparable.
def xcse_collect_loads(node: uint32):
    if node == 0:
        return
    if cse_cand_n >= CSE_MAX_CAND:
        return
    if nd_kind[node] == ND_INDEX:
        if opt_index_load_is_int(node) != 0:
            v: uint32 = ir_lower_pure_expr(node)
            if v != 0:
                cse_cand_ast[cse_cand_n] = node
                cse_cand_ir[cse_cand_n] = v
                cse_cand_n = cse_cand_n + 1
    # Descend expression children (incl. an index's base + index subtrees) to
    # find loads nested under binops / other loads.
    k: uint32 = nd_kind[node]
    if k == ND_IDENT or k == ND_INT_LIT:
        return
    xcse_collect_loads(nd_a[node])
    xcse_collect_loads(nd_b[node])
    xcse_collect_loads(nd_c[node])
    xcse_collect_loads(nd_d[node])


# Process ONE straight-line statement `s` for cross-statement CSE against the
# live available set. For each pure ND_BINARY subexpression of s's r-value
# (outermost-first), if it value-equals a LIVE available expression, rewrite it
# to read that expression's temp (and materialize the temp before its first user
# if not yet done). Otherwise add it to the available set keyed on this stmt.
# Integer ND_INDEX LOADS are handled the same way (load-CSE): a redundant array
# element read reuses the first load's temp, killed by any name-write its address
# depends on or any hard barrier (opaque store / call / addr-of flushes the set).
def xcse_process_stmt_rvalue(s: uint32):
    rv: uint32 = xcse_stmt_rvalue(s)
    if rv == 0:
        return
    # Lower every pure ND_BINARY subtree of rv into the shared arena. Candidates
    # accumulate in cse_cand_* (we DON'T reset the arena across statements of one
    # run, so available-set IR ids stay live and comparable).
    base: uint32 = cse_cand_n
    cse_collect(rv)
    # Also collect integer array LOADS so a redundant `arr[idx]` read shares the
    # first load's temp. Appended AFTER the binop candidates: a load nested in a
    # binop appears later than its parent binop, and the binop branch's
    # cse_kill_descendants nulls the inner load if the parent is rewritten first.
    xcse_collect_loads(rv)
    i: uint32 = base
    while i < cse_cand_n:
        ast_i: uint32 = cse_cand_ast[i]
        if ast_i != 0 and (nd_kind[ast_i] == ND_BINARY or nd_kind[ast_i] == ND_INDEX):
            vi: uint32 = cse_cand_ir[i]
            # Match against a LIVE available expression.
            a: uint32 = 0
            hit: uint32 = 0
            while a < xcse_av_n:
                if xcse_av_live[a] != 0:
                    if ir_value_eq(xcse_av_ir[a], vi) != 0:
                        hit = 1
                        # Materialize the defining temp before its first user if
                        # this is the FIRST reuse.
                        if xcse_av_materialized[a] == 0:
                            xcse_av_materialized[a] = 1
                            if xcse_pd_n < XCSE_MAX_PEND:
                                xcse_pd_decl[xcse_pd_n] = xcse_av_decl[a]
                                xcse_pd_before[xcse_pd_n] = xcse_av_stmt[a]
                                xcse_pd_n = xcse_pd_n + 1
                        # Rewrite this occurrence to read the temp; kill its
                        # descendants in the candidate list (they're orphaned).
                        cse_kill_descendants(ast_i)
                        if nd_kind[ast_i] == ND_INDEX:
                            opt_loadcse_count = opt_loadcse_count + 1
                        cse_rewrite_to_ident(ast_i, xcse_av_off[a], xcse_av_len[a])
                        cse_cand_ast[i] = 0
                        opt_cse_count = opt_cse_count + 1
                        a = xcse_av_n
                    else:
                        a = a + 1
                else:
                    a = a + 1
            if hit == 0:
                # New available expression: mint a temp, build its decl from a
                # CLONE of this occurrence (so later in-place rewrites of the
                # original occurrence don't disturb the decl init), record it as
                # available keyed before THIS statement. The decl is only spliced
                # if a later occurrence actually reuses it (lazy materialization).
                if xcse_av_n < XCSE_MAX_AVAIL:
                    cse_mint_temp_name()
                    toff: uint32 = opt_tmp_name_off
                    tlen: uint32 = opt_tmp_name_len
                    clone: uint32 = cse_clone_expr(ast_i)
                    if clone != 0:
                        d: uint32 = cse_make_temp_decl(toff, tlen, clone)
                        if d != 0:
                            slot: uint32 = xcse_av_n
                            xcse_av_ir[slot] = vi
                            xcse_av_off[slot] = toff
                            xcse_av_len[slot] = tlen
                            xcse_av_stmt[slot] = s
                            xcse_av_materialized[slot] = 0
                            xcse_av_decl[slot] = d
                            xcse_av_live[slot] = 1
                            xcse_av_n = xcse_av_n + 1
                            # LAZY MATERIALIZATION: record the FIRST occurrence's
                            # AST but do NOT rewrite it or splice the decl yet. The
                            # decl is spliced (and this occurrence rewritten to read
                            # the temp) ONLY if a later occurrence actually reuses
                            # the value (xcse_av_materialized flips in the match
                            # branch above; xcse_materialize_run does the rewrite +
                            # splice). A never-reused expression therefore leaves
                            # the original code byte-for-byte untouched — the pass
                            # only ever ADDS a temp when it removes >=1 recompute.
                            xcse_first_ast[slot] = ast_i
        i = i + 1


# Parallel to xcse_av_*: the AST node of each available expression's FIRST
# occurrence, rewritten to the temp ident only when the expression is actually
# reused (so a never-reused expression leaves the original code untouched).
xcse_first_ast: Array[1024, uint32]


# Run cross-statement CSE over ONE straight-line statement run [head .. ), i.e.
# starting at `head` and continuing through the sibling chain until a hard
# barrier statement. Returns the FIRST statement AFTER the run (or 0). Splices
# any reused temps before their first user (via xcse_materialize_run). A run
# that hit a barrier publishes its new head, if any, through xcse_new_head.
def xcse_run(head: uint32) -> uint32:
    xcse_avail_reset()
    xcse_pd_n = 0
    cse_cand_n = 0
    ir_reset()
    s: uint32 = head
    stop: uint32 = 0
    # A run that BEGINS at a control-flow statement is empty: advance past it so
    # the block walker recurses into it and continues from the next statement
    # (otherwise xcse_block would re-enter the same seg_head forever).
    if s != 0:
        hk: uint32 = nd_kind[s]
        if hk != ND_VAR_DECL and hk != ND_ASSIGN and hk != ND_EXPR_STMT and hk != ND_RETURN:
            return nd_next[s]
    while s != 0 and stop == 0:
        k: uint32 = nd_kind[s]
        # Control flow / barrier statement ENDS the run BEFORE processing it.
        if k != ND_VAR_DECL and k != ND_ASSIGN and k != ND_EXPR_STMT and k != ND_RETURN:
            stop = 1
        else:
            xcse_process_stmt_rvalue(s)
            # Apply this statement's writes/barrier AFTER sharing into it.
            if xcse_apply_stmt_effects(s) != 0:
                # Barrier statement: it stays in the run (its sharing already
                # happened) but nothing after it can share across it.
                s = nd_next[s]
                stop = 1
                xcse_avail_flush()
            else:
                s = nd_next[s]
    # Materialize the reused temps: splice each decl before its anchor stmt and
    # rewrite the first occurrence to read the temp.
    xcse_materialize_run(head)
    if stop != 0:
        return s
    return 0


# After a run is analysed, splice the decls of every REUSED available expression
# before its anchor statement, and rewrite that expression's first occurrence to
# read the temp. Returns nothing; mutates the chain via nd_next. `head` is the
# run's first statement so we can find anchors by walking.
def xcse_materialize_run(head: uint32):
    # Rewrite each materialized expression's first occurrence to the temp.
    a: uint32 = 0
    while a < xcse_av_n:
        if xcse_av_materialized[a] != 0:
            fa: uint32 = xcse_first_ast[a]
            if fa != 0 and (nd_kind[fa] == ND_BINARY or nd_kind[fa] == ND_INDEX):
                cse_rewrite_to_ident(fa, xcse_av_off[a], xcse_av_len[a])
        a = a + 1
    # Splice each pending decl before its anchor statement (in pending order).
    # xcse_cur_head tracks the LIVE run head as splices may insert decls before
    # the head itself; xcse_splice_before reads/updates it so a SECOND decl
    # anchored before the same statement (or before the head) chains correctly
    # after the first instead of orphaning it.
    xcse_cur_head = head
    pi: uint32 = 0
    while pi < xcse_pd_n:
        d: uint32 = xcse_pd_decl[pi]
        before: uint32 = xcse_pd_before[pi]
        xcse_splice_before(d, before)
        pi = pi + 1
    # The final live head (possibly moved by head-anchored splices) is published
    # for the block walker via xcse_new_head.
    if xcse_cur_head != head:
        xcse_new_head = xcse_cur_head


# The LIVE head of the run currently being materialized. Splicing a decl before
# the head advances it; subsequent walks start here so anchors are always found.
xcse_cur_head: uint32 = 0
xcse_new_head: uint32 = 0


# Splice decl `d` immediately before statement `before` in the run whose live
# head is xcse_cur_head. Walks from the live head to find `before`'s predecessor;
# if `before` IS the live head, prepends `d` and advances xcse_cur_head. Multiple
# decls before the same anchor chain in call order (each new d becomes the
# anchor's immediate predecessor). Total: a not-found anchor (impossible for a
# well-formed run) leaves the chain unchanged.
def xcse_splice_before(d: uint32, before: uint32):
    if before == xcse_cur_head:
        nd_next[d] = before
        xcse_cur_head = d
        return
    p: uint32 = xcse_cur_head
    while p != 0:
        if nd_next[p] == before:
            nd_next[d] = before
            nd_next[p] = d
            return
        p = nd_next[p]


# Cross-statement CSE over a statement chain (a block). Processes maximal
# straight-line runs; recurses into nested block bodies. Returns the (possibly
# new) chain head.
def xcse_block(head: uint32) -> uint32:
    if head == 0:
        return 0
    # Process the chain in straight-line runs. xcse_run analyses a run starting
    # at the current segment head and returns the first statement after it. We
    # track the PREDECESSOR of the current segment head so that when a run
    # materializes a temp decl before its own head (xcse_new_head != 0), we
    # relink the predecessor (or the block head) to the new first node — keeping
    # the whole chain connected.
    new_head: uint32 = head
    seg_prev: uint32 = 0           # statement just before seg_head (0 if seg_head is the block head)
    seg_head: uint32 = head
    while seg_head != 0:
        xcse_new_head = 0
        after: uint32 = xcse_run(seg_head)
        if xcse_new_head != 0:
            # The run inserted one or more decls before seg_head; xcse_new_head is
            # the new first node of that run. Connect the predecessor to it.
            if seg_prev == 0:
                new_head = xcse_new_head
            else:
                nd_next[seg_prev] = xcse_new_head
        # Advance: seg_prev becomes the statement immediately before `after`. The
        # last statement of the just-processed run is `after`'s predecessor; find
        # it by walking from xcse_new_head-or-seg_head until nd_next == after.
        start: uint32 = seg_head
        if xcse_new_head != 0:
            start = xcse_new_head
        if after == 0:
            seg_prev = 0
        else:
            p: uint32 = start
            while p != 0 and nd_next[p] != after:
                p = nd_next[p]
            seg_prev = p
        seg_head = after
    # Recurse into nested control-flow bodies across the WHOLE (rebuilt) chain.
    s: uint32 = new_head
    while s != 0:
        k: uint32 = nd_kind[s]
        if k == ND_IF:
            nd_b[s] = xcse_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                nd_b[e] = xcse_block(nd_b[e])
                e = nd_next[e]
            nd_d[s] = xcse_block(nd_d[s])
        elif k == ND_WHILE:
            nd_b[s] = xcse_block(nd_b[s])
        elif k == ND_DO_WHILE:
            nd_b[s] = xcse_block(nd_b[s])
        elif k == ND_FOR:
            nd_b[s] = xcse_block(nd_b[s])
        s = nd_next[s]
    return new_head


def opt_xcse_function(fn: uint32):
    opt_fw_build(fn)
    opt_efw_build(fn)              # per-function element-float table (load-CSE gate)
    nd_c[fn] = xcse_block(nd_c[fn])


# =======================================================================
# Phase 8 — Dead Code Elimination (fully-dead local variable removal).
# =======================================================================
#
# STRATEGY (conservative + correct over fast)
# -------------------------------------------
# This AST-level optimizer has no SSA/CFG with explicit liveness, so DCE is
# scoped to the one transform that is provably value-preserving without a
# dataflow lattice: removing a LOCAL VARIABLE DECLARATION whose result is
# NEVER read anywhere in the function and whose initializer has NO side
# effect. Deleting such a decl deletes a computation whose value nothing
# observes and whose evaluation changes nothing — an observable no-op.
#
# WHAT IS REMOVED
#   A top-level ND_VAR_DECL `x = <init>` in a function body is removed iff ALL:
#     (a) the name `x` appears NOWHERE else in the function — no read, no
#         re-assignment, no re-declaration, not as a loop variable, not inside
#         any nested block (the whole-function use scan walks every child slot
#         AND every nd_next chain AND ND_FOR/ND_FOR_UNPACK loop-var names);
#     (b) the initializer is side-effect-free: either absent (0), a bare
#         literal/ident, or a PURE expression that lowers via
#         ir_lower_pure_expr (the same signedness-invariant, non-faulting,
#         no-call/no-load/no-store value set CSE & LICM use). A DIV/MOD that
#         could trap, an index/member load that could fault, or a call is NOT
#         pure here, so a decl whose init is one of those is KEPT;
#     (c) the FUNCTION contains NO call (ND_CALL) and NO address-of
#         (UNOP_ADDR) ANYWHERE — the blanket alias/escape guard LICM uses. If
#         no address of any local is ever taken and no call runs, no local can
#         be read or written indirectly, so "name `x` appears nowhere else"
#         is a SOUND proof that `x` is genuinely dead (nothing aliases it).
#         If the function has a call or addr-of, DCE removes NOTHING from it.
#
# WHY ONLY TOP-LEVEL DECLS, NOT NESTED-BLOCK / ASSIGN-CHAINS
#   Removing a statement nested inside a loop or conditional, or a plain
#   re-assignment that is dead only on some paths, needs per-path liveness this
#   pass deliberately does not compute. Guard (a) — "the name appears NOWHERE
#   else, at any depth" — sidesteps all of that: a name used nowhere else is
#   dead on every path regardless of control flow, so the single defining decl
#   (wherever it sits) is unconditionally dead. We only delete decls that sit
#   at a chain level we can splice (top-level body + directly nested block
#   chains, via the recursive walk), and only when the name is globally unused.
#
# DEAD-STORE ELIMINATION: DELIBERATELY OMITTED
#   General dead-store elimination (a store overwritten before any read) is
#   NOT implemented: this AST IR has no provable aliasing/escape model for
#   partial liveness (a local can have its address taken via UNOP_ADDR and
#   escape into a call, and there is no points-to analysis). Guessing risks a
#   miscompile, which the brief forbids. The "fully-dead local" rule above is
#   the safe subset and is all DCE does here.
#
# UNREACHABLE-BLOCK REMOVAL: DELIBERATELY OMITTED
#   Constant-folded branch arms are not pruned: opt_try_fold folds constant
#   BINARY subtrees into ND_INT_LIT but does NOT rewrite an ND_IF/ND_WHILE
#   whose CONDITION became a constant into a straight-line block, so no block
#   becomes structurally unreachable for DCE to find. Adding branch-condition
#   folding + arm pruning is a separate transform; without it there is no
#   unreachable block to remove, so this sub-part is a no-op and is left out.

# --- whole-function alias/escape barrier ---------------------------------
#
# 1 once a call or address-of is seen anywhere in the scanned function: with
# either present, a local could be read/written indirectly and "name unused
# elsewhere" no longer proves deadness, so DCE bails out for the function.
dce_barrier: uint32 = 0


def dce_scan_barrier_expr(node: uint32):
    if node == 0:
        return
    if dce_barrier != 0:
        return
    k: uint32 = nd_kind[node]
    # ND_METHOD_CALL is an opaque side effect like ND_CALL (see licm_scan_expr).
    if k == ND_CALL or k == ND_METHOD_CALL:
        dce_barrier = 1
        return
    if k == ND_UNARY:
        if nd_aux[node] == UNOP_ADDR:
            dce_barrier = 1
            return
    dce_scan_barrier_expr(nd_a[node])
    dce_scan_barrier_expr(nd_b[node])
    dce_scan_barrier_expr(nd_c[node])
    dce_scan_barrier_expr(nd_d[node])
    # Follow the nd_next operand chain (call args / literal elements) so a
    # call/addr-of in a 2nd+ sibling is not missed. Roots have nd_next==0.
    dce_scan_barrier_expr(nd_next[node])


# Walk an entire statement chain (and nested block chains) for a call/addr-of.
def dce_scan_barrier_block(head: uint32):
    s: uint32 = head
    while s != 0:
        if dce_barrier != 0:
            return
        k: uint32 = nd_kind[s]
        # Scan this statement's expression slots generically. nd_a/b/c/d may be
        # either expressions or nested block heads depending on kind; recursing
        # into them as expressions catches every embedded call/addr-of, and the
        # explicit block recursion below catches nested statement chains. (A
        # node visited as both an expr and a block head is harmless — we only
        # set a sticky flag.)
        dce_scan_barrier_expr(nd_a[s])
        dce_scan_barrier_expr(nd_b[s])
        dce_scan_barrier_expr(nd_c[s])
        dce_scan_barrier_expr(nd_d[s])
        if k == ND_IF:
            dce_scan_barrier_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                dce_scan_barrier_block(nd_b[e])
                e = nd_next[e]
            dce_scan_barrier_block(nd_d[s])
        elif k == ND_WHILE:
            dce_scan_barrier_block(nd_b[s])
        elif k == ND_DO_WHILE:
            dce_scan_barrier_block(nd_b[s])
        elif k == ND_FOR:
            dce_scan_barrier_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            dce_scan_barrier_block(nd_c[s])
        s = nd_next[s]


# --- per-name address-taken (escape) scanner -----------------------------
#
# The coarse whole-function dce_barrier (set on ANY call/addr-of) bails out of
# DCE for any function that calls a helper or stores through a pointer — which
# is nearly every real loop body (e.g. dcecopy's print_u64 + bucket[i] store).
# That throws away the most common dead work. The SOUND refinement: a call or a
# store-through-pointer can only touch a LOCAL whose ADDRESS has escaped. A
# scalar local whose address is NEVER taken (`&x` appears nowhere) is invisible
# to every callee and every indirect store, so "name read nowhere else" PROVES
# it dead even amid calls/stores elsewhere. So we test address-taken PER NAME
# instead of bailing for the whole function.
#
# dce_at_* : scan a function body for `&<target-name>` (UNOP_ADDR over an ident
# whose name matches). Sets dce_at_found=1 if the address of the target name is
# taken anywhere (directly `&x`, or as the base of `&x[i]` / `&x.f`, which also
# makes x's storage escape). Conservative: a deref-store target `*p = ...` does
# not name x, so it cannot make a non-address-taken x escape; only a prior `&x`
# could have leaked the pointer, and that `&x` is exactly what we detect here.
dce_at_off: uint32 = 0
dce_at_len: uint32 = 0
dce_at_found: uint32 = 0


# Peel casts/index/member down to the base ident of an lvalue-ish expr (the
# storage whose address &EXPR ultimately references). Returns the ident node or
# 0. Mirrors cfg.ad's cl_base_ident intent.
def dce_at_base_ident(node: uint32) -> uint32:
    n: uint32 = node
    while n != 0:
        k: uint32 = nd_kind[n]
        if k == ND_IDENT:
            return n
        if k == ND_INDEX or k == ND_MEMBER:
            n = nd_a[n]
        elif k == ND_CAST:
            n = nd_a[n]
        else:
            return 0
    return 0


def dce_at_scan_expr(node: uint32):
    if node == 0:
        return
    if dce_at_found != 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_UNARY:
        if nd_aux[node] == UNOP_ADDR:
            base: uint32 = dce_at_base_ident(nd_a[node])
            if base != 0:
                if ir_name_eq(nd_name_off[base], nd_name_len[base],
                              dce_at_off, dce_at_len) != 0:
                    dce_at_found = 1
                    return
    dce_at_scan_expr(nd_a[node])
    dce_at_scan_expr(nd_b[node])
    dce_at_scan_expr(nd_c[node])
    dce_at_scan_expr(nd_d[node])
    # Follow the nd_next operand chain so `&x` appearing ONLY as a 2nd+ call
    # argument (e.g. `f(a, &x)`) is detected as an address-taken (escape) of x.
    # Without this the escape is missed; it is currently also masked by
    # dce_count_expr (the inner ident bumps x's use count), but the address-taken
    # proof must stand on its own. Roots have nd_next==0 so this is inert outside
    # a true operand chain; over-reporting escape only KEEPS a decl (safe).
    dce_at_scan_expr(nd_next[node])


def dce_at_scan_block(head: uint32):
    s: uint32 = head
    while s != 0:
        if dce_at_found != 0:
            return
        k: uint32 = nd_kind[s]
        dce_at_scan_expr(nd_a[s])
        dce_at_scan_expr(nd_b[s])
        dce_at_scan_expr(nd_c[s])
        dce_at_scan_expr(nd_d[s])
        if k == ND_IF:
            dce_at_scan_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                dce_at_scan_block(nd_b[e])
                e = nd_next[e]
            dce_at_scan_block(nd_d[s])
        elif k == ND_WHILE:
            dce_at_scan_block(nd_b[s])
        elif k == ND_DO_WHILE:
            dce_at_scan_block(nd_b[s])
        elif k == ND_FOR:
            dce_at_scan_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            dce_at_scan_block(nd_c[s])
        s = nd_next[s]


# Return 1 if the address of `name` is taken anywhere in dce_fnbody (escapes), 0
# if it never is (DCE-safe to delete a never-read pure decl of it even amid
# calls/stores elsewhere).
def dce_name_addr_taken(off: uint32, len_: uint32) -> uint32:
    dce_at_off = off
    dce_at_len = len_
    dce_at_found = 0
    dce_at_scan_block(dce_fnbody)
    return dce_at_found


# --- whole-function use counter for one name -----------------------------
#
# Count every textual reference to (name_off,name_len) anywhere in a function
# body, EXCEPT the single defining decl node `skip` itself (so its own name and
# its own initializer are not counted as uses of itself — a self-referential
# init like `x = x` WOULD count, because that ND_IDENT is in skip's nd_b which
# we DO descend). Returns via the global dce_use_n; a name with 0 uses outside
# its decl is dead.
dce_use_n: uint32 = 0
dce_use_off: uint32 = 0
dce_use_len: uint32 = 0
dce_use_skip: uint32 = 0


# Count ident references to the target name inside an EXPRESSION subtree.
#
# CRITICAL — follow nd_next: an expression OPERAND LIST (call arguments, array /
# dict-literal elements) is an nd_next-linked sibling chain hanging off ONE child
# slot (e.g. a call's args head sits at nd_b, the rest linked by nd_next). A walk
# that descends only nd_a..nd_d counts the FIRST operand and MISSES every later
# one, so a name used ONLY as a 2nd+ call argument (`f(a, x)`) is seen as dead —
# DCE removes its decl and codegen then finds no slot (a cgfail ABORT under --opt)
# or, if the name shadows a global/param, reads the wrong storage (a miscompile).
# Mirror the canonical opt_walk descent and follow nd_next on EVERY node (incl.
# ident/literal leaves, which can themselves be operands in such a chain).
# Over-counting is harmless for DCE — it only keeps a decl alive — and DCE runs
# ONLY under --opt (opt_run), so the default build's bytes are unaffected.
def dce_count_expr(node: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_IDENT:
        if ir_name_eq(nd_name_off[node], nd_name_len[node],
                      dce_use_off, dce_use_len) != 0:
            dce_use_n = dce_use_n + 1
        dce_count_expr(nd_next[node])
        return
    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT or k == ND_FLOAT_LIT:
        dce_count_expr(nd_next[node])
        return
    dce_count_expr(nd_a[node])
    dce_count_expr(nd_b[node])
    dce_count_expr(nd_c[node])
    dce_count_expr(nd_d[node])
    dce_count_expr(nd_next[node])


# Count references in a STATEMENT chain (descends nested block chains too). The
# defining decl node `dce_use_skip` is not skipped wholesale — we still descend
# its initializer (nd_b) so a self-use counts — but its NAME slot is not an
# ident node, so it never self-counts. A re-declaration / re-assignment of the
# same name elsewhere counts as a use (its LHS ident or ND_VAR_DECL name), which
# is exactly what we want: if the name is touched anywhere else, keep the decl.
def dce_count_block(head: uint32):
    s: uint32 = head
    while s != 0:
        k: uint32 = nd_kind[s]
        # A ND_VAR_DECL / ND_FOR / ND_FOR_UNPACK introduces or writes a NAME that
        # is not an ND_IDENT node; count those name slots as uses so a shadowing
        # re-decl or a loop using the name keeps the original decl alive.
        if s != dce_use_skip:
            if k == ND_VAR_DECL:
                if ir_name_eq(nd_name_off[s], nd_name_len[s],
                              dce_use_off, dce_use_len) != 0:
                    dce_use_n = dce_use_n + 1
            elif k == ND_FOR:
                if ir_name_eq(nd_name_off[s], nd_name_len[s],
                              dce_use_off, dce_use_len) != 0:
                    dce_use_n = dce_use_n + 1
        # Count ident uses in this statement's expression slots. For the defining
        # decl we still descend its initializer (nd_b) so `x = x` self-counts.
        # EXCEPTION: when the unit being tested is a plain ND_ASSIGN store
        # (dce_use_skip), its TARGET (nd_a) is a WRITE, not a read — descending it
        # would self-count the store as a use of itself and never let a dead store
        # be removed. So for the skipped ASSIGN we skip nd_a and only descend the
        # r-value (nd_b), which is where a self-read like `x = x` lives.
        if s == dce_use_skip and k == ND_ASSIGN:
            dce_count_expr(nd_b[s])
        else:
            dce_count_expr(nd_a[s])
            dce_count_expr(nd_b[s])
            dce_count_expr(nd_c[s])
            dce_count_expr(nd_d[s])
        # Descend nested block chains.
        if k == ND_IF:
            dce_count_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                dce_count_block(nd_b[e])
                e = nd_next[e]
            dce_count_block(nd_d[s])
        elif k == ND_WHILE:
            dce_count_block(nd_b[s])
        elif k == ND_DO_WHILE:
            dce_count_block(nd_b[s])
        elif k == ND_FOR:
            dce_count_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            dce_count_block(nd_c[s])
        s = nd_next[s]


# Is the initializer of an ND_VAR_DECL side-effect-free (safe to delete)?
# Absent init (0) is trivially safe. A bare literal/ident is safe. Otherwise it
# must lower through ir_lower_pure_expr — the signedness-invariant, non-faulting,
# no-call/no-load/no-store value set (no DIV/MOD trap, no index/member fault, no
# call). Anything ir_lower_pure_expr rejects is treated as possibly-effectful
# and the decl is KEPT.
def dce_init_is_pure(init: uint32) -> uint32:
    if init == 0:
        return 1
    k: uint32 = nd_kind[init]
    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT:
        return 1
    if k == ND_IDENT:
        return 1
    ir_reset()
    v: uint32 = ir_lower_pure_expr(init)
    if v != 0:
        return 1
    return 0


# DCE one statement-chain (a block). Returns the (possibly new) head with dead
# ND_VAR_DECLs spliced out. Recurses into nested block bodies. `fnbody` is the
# WHOLE function body chain head — the use count is always taken over the whole
# function, never just the local block, so a name read in any other block keeps
# its decl. Returns 1 via dce_removed_any if it removed anything (to drive the
# outer fixpoint).
dce_removed_any: uint32 = 0
dce_fnbody: uint32 = 0


def dce_block(head: uint32) -> uint32:
    new_head: uint32 = head
    prev: uint32 = 0
    s: uint32 = head
    while s != 0:
        nxt: uint32 = nd_next[s]
        k: uint32 = nd_kind[s]
        removed: uint32 = 0
        if k == ND_VAR_DECL:
            if dce_init_is_pure(nd_b[s]) != 0:
                # Count uses of this decl's name over the WHOLE function body.
                dce_use_off = nd_name_off[s]
                dce_use_len = nd_name_len[s]
                dce_use_n = 0
                dce_use_skip = s
                dce_count_block(dce_fnbody)
                # SOUND even amid calls/stores elsewhere: a never-read local
                # whose ADDRESS is never taken cannot be observed by any callee
                # or indirect store, so deleting its pure-init decl is a no-op.
                addr_taken: uint32 = dce_name_addr_taken(nd_name_off[s], nd_name_len[s])
                if dce_use_n == 0 and addr_taken == 0:
                    # Fully dead: splice this decl out of the chain.
                    if prev == 0:
                        new_head = nxt
                    else:
                        nd_next[prev] = nxt
                    opt_dce_count = opt_dce_count + 1
                    dce_removed_any = 1
                    removed = 1
        elif k == ND_ASSIGN:
            # DEAD-STORE ELIMINATION (conservative): a plain `x = <pure>` store to
            # a bare ident whose name is read NOWHERE in the whole function and
            # whose address is never taken is a dead store — its value can never
            # be observed, so deleting the store (and its pure computation) is a
            # no-op. We require: AUGOP_NONE (an augmented `x op= y` READS x, so it
            # is never dead), bare-ident target, PURE r-value (no call/load/trap to
            # preserve), zero textual reads of the name (the counter skips THIS
            # store's own target write), and the address never taken. This is the
            # same global-unused proof the decl rule uses — robust on every path,
            # no per-path liveness needed: a name read nowhere is dead everywhere.
            if nd_aux[s] == AUGOP_NONE:
                tgt: uint32 = nd_a[s]
                # A store to a GLOBAL scalar is observable by other functions and
                # by any later call, so "read nowhere in THIS function" does NOT
                # prove it dead — only a LOCAL/param store is provable dead by that
                # whole-function-unused argument. Skip the elimination for globals
                # (dropping e.g. `jeof = 1; return` in a helper is a miscompile).
                if nd_kind[tgt] == ND_IDENT and dce_init_is_pure(nd_b[s]) != 0 and opt_gname_is_global(nd_name_off[tgt], nd_name_len[tgt]) == 0:
                    dce_use_off = nd_name_off[tgt]
                    dce_use_len = nd_name_len[tgt]
                    dce_use_n = 0
                    dce_use_skip = s
                    dce_count_block(dce_fnbody)
                    addr_taken2: uint32 = dce_name_addr_taken(nd_name_off[tgt], nd_name_len[tgt])
                    if dce_use_n == 0 and addr_taken2 == 0:
                        if prev == 0:
                            new_head = nxt
                        else:
                            nd_next[prev] = nxt
                        opt_dce_count = opt_dce_count + 1
                        dce_removed_any = 1
                        removed = 1
        if removed == 0:
            # Recurse into nested blocks of a kept statement.
            if k == ND_IF:
                nd_b[s] = dce_block(nd_b[s])
                e: uint32 = nd_c[s]
                while e != 0:
                    nd_b[e] = dce_block(nd_b[e])
                    e = nd_next[e]
                nd_d[s] = dce_block(nd_d[s])
            elif k == ND_WHILE:
                nd_b[s] = dce_block(nd_b[s])
            elif k == ND_DO_WHILE:
                nd_b[s] = dce_block(nd_b[s])
            elif k == ND_FOR:
                nd_b[s] = dce_block(nd_b[s])
            elif k == ND_FOR_UNPACK:
                nd_c[s] = dce_block(nd_c[s])
            prev = s
        s = nxt
    return new_head


def opt_dce_function(fn: uint32):
    # NOTE: the OLD blanket alias/escape guard (bail if the function has ANY
    # call or addr-of) is GONE — it discarded the dead work in nearly every real
    # loop body (any body that calls a helper or stores through a pointer). It is
    # replaced by a PER-NAME escape check in dce_block: a never-read local whose
    # OWN address is never taken cannot be observed by a callee or indirect
    # store, so deleting its pure-init decl is sound even amid calls/stores.
    # Iterate to fixpoint: removing one dead decl can make an earlier decl (whose
    # only remaining use was the removed one's initializer) dead in turn.
    dce_fnbody = nd_c[fn]
    dce_removed_any = 1
    while dce_removed_any != 0:
        dce_removed_any = 0
        nd_c[fn] = dce_block(nd_c[fn])
        dce_fnbody = nd_c[fn]


# =======================================================================
# Phase 9 — COPY PROPAGATION (straight-line, conservative).
# =======================================================================
#
# STRATEGY (conservative + correct over fast)
# -------------------------------------------
# A PURE COPY is a statement `x = y` whose right-hand side is a BARE variable
# read (a single ND_IDENT, no side effect, no load/call) and whose left-hand
# side is a BARE local name (an ND_VAR_DECL or a plain ND_ASSIGN to an ident).
# Within a straight-line run, every later READ of `x` can be rewritten to read
# `y` instead — PROVIDED that between the copy and the read NEITHER `x` NOR `y`
# is reassigned / re-declared / written. Forwarding the read makes `x`'s decl
# have no remaining reader, so the Phase-8 DCE that runs immediately after
# removes the now-dead copy decl entirely (`x = y` vanishes, uses read `y`).
#
# WHY THIS IS ADDITIVE TO CSE (verified)
#   CSE / x-CSE here value-number only PURE ND_BINARY subtrees (ir_lower_pure_expr
#   returns 0 for a bare ND_IDENT, and cse_collect records a candidate ONLY when
#   nd_kind == ND_BINARY). A bare copy `x = y` and a later bare read of `x` are
#   NOT binary expressions, so CSE never forms a candidate for them and never
#   forwards a variable's value to its uses. Copy-prop is therefore a DISTINCT,
#   complementary transform — it forwards single-variable copies that CSE cannot
#   see — not a no-op duplicate of CSE.
#
# SOUNDNESS — straight-line copy propagation, conservative
# --------------------------------------------------------
# We process statements in source order maintaining an ACTIVE COPY set: each
# entry maps a dest name -> a source name, live until invalidated. For each
# statement:
#   1. REWRITE its r-value reads FIRST: any read of an active dest is rewritten
#      to read its (root) source. We resolve transitively — if the source is
#      itself an active dest, we chase to the chain root, which is sound because
#      every link in the active set is currently unclobbered (a write to any
#      intermediate name would have killed the whole link).
#   2. APPLY this statement's WRITES: a write to name `w` (an ND_VAR_DECL name or
#      a plain ND_ASSIGN to ident `w`) KILLS every active copy whose DEST is `w`
#      (its old value is gone) AND every active copy whose SOURCE is `w` (the
#      source changed, so forwarding it would now be wrong).
#   3. If this statement is ITSELF a pure copy `x = y` (after step 2 killed any
#      prior `x` entry), RECORD a new active copy x -> root(y).
# A statement we cannot model precisely is a HARD BARRIER that flushes the WHOLE
# active set and ends the run: a call (ND_CALL anywhere in an r-value), an
# address-of (UNOP_ADDR — `x` or `y` could be aliased and written indirectly),
# an opaque store (assign/var-decl whose target is not a bare ident, or whose
# r-value is not call/addr-free), or any control flow. After a barrier the set
# is empty and the rest of the chain is a fresh run. This is textbook local copy
# propagation over an extended basic block, at its safest: anything that could
# alias, call, or branch resets the active set.
#
# We do NOT propagate a copy whose source is a GLOBAL we cannot prove unwritten
# across the run — handled uniformly: a write to the source name (by any
# straight-line statement) kills the copy, and any unmodellable statement is a
# barrier, so a global source surviving to a read was provably unwritten on the
# straight-line path. (A call is already a barrier, covering indirect writes.)

# Active copy set for the current straight-line run. Each slot: dest (off,len),
# source root (off,len), and a live flag.
CP_MAX: uint32 = 1024
cp_dest_off: Array[1024, uint32]
cp_dest_len: Array[1024, uint32]
cp_src_off: Array[1024, uint32]
cp_src_len: Array[1024, uint32]
cp_live: Array[1024, uint32]
cp_n: uint32 = 0


def cp_reset():
    cp_n = 0


# Kill every active copy whose DEST or SOURCE name equals (off,len). Called when
# `name` is written: its old copied value is stale (dest match) and any copy
# forwarding it as a source is now wrong (source match).
def cp_kill_name(off: uint32, len_: uint32):
    i: uint32 = 0
    while i < cp_n:
        if cp_live[i] != 0:
            if ir_name_eq(cp_dest_off[i], cp_dest_len[i], off, len_) != 0:
                cp_live[i] = 0
            elif ir_name_eq(cp_src_off[i], cp_src_len[i], off, len_) != 0:
                cp_live[i] = 0
        i = i + 1


# Find a LIVE active copy whose dest equals (off,len); return its index+1, or 0
# if none. (+1 so 0 means "not found" without an out-param.)
def cp_find_dest(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < cp_n:
        if cp_live[i] != 0:
            if ir_name_eq(cp_dest_off[i], cp_dest_len[i], off, len_) != 0:
                return i + 1
        i = i + 1
    return 0


# Record a new active copy `dest -> src_root`. The caller has already killed any
# prior entry whose dest is `dest`. We chase `src` through the active set to its
# root so a chain `a=b; b=c` forwarded reads of `a` straight to `c`. The chase is
# bounded by cp_n (no cycle: each link was added with a then-distinct dest).
cp_root_off: uint32 = 0
cp_root_len: uint32 = 0


def cp_resolve_root(off: uint32, len_: uint32):
    # Walk dest->src links until the name is not itself an active dest.
    coff: uint32 = off
    clen: uint32 = len_
    steps: uint32 = 0
    while steps < cp_n:
        idx: uint32 = cp_find_dest(coff, clen)
        if idx == 0:
            cp_root_off = coff
            cp_root_len = clen
            return
        coff = cp_src_off[idx - 1]
        clen = cp_src_len[idx - 1]
        steps = steps + 1
    cp_root_off = coff
    cp_root_len = clen


def cp_add(dest_off: uint32, dest_len: uint32, src_off: uint32, src_len: uint32):
    if cp_n >= CP_MAX:
        return
    cp_resolve_root(src_off, src_len)
    # Self-copy `x = x` after rooting (e.g. a=b; b=a) — do not record (would be a
    # degenerate identity that cp_find could loop on); harmless to skip.
    if ir_name_eq(dest_off, dest_len, cp_root_off, cp_root_len) != 0:
        return
    cp_dest_off[cp_n] = dest_off
    cp_dest_len[cp_n] = dest_len
    cp_src_off[cp_n] = cp_root_off
    cp_src_len[cp_n] = cp_root_len
    cp_live[cp_n] = 1
    cp_n = cp_n + 1


# Rewrite, in an r-value EXPRESSION subtree, every READ of an active copy dest to
# read its source root. ND_IDENT leaves are the only reads we forward; we descend
# the operand slots of binary/cast/index/member/unary AND the nd_next OPERAND
# CHAIN (an argument / literal-element list is nd_next-linked siblings off ONE
# slot, NOT nd_a..nd_d — descending only the fixed slots forwarded the FIRST
# operand and missed every later one, a missed optimization). A call statement is
# itself a BARRIER, so this only runs on call-free r-values; forwarding an active
# (run-live) copy in any operand position is always value-preserving. Returns
# nothing; bumps opt_copyprop_count per rewritten read.
def cp_rewrite_reads(node: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_IDENT:
        idx: uint32 = cp_find_dest(nd_name_off[node], nd_name_len[node])
        if idx != 0:
            nd_name_off[node] = cp_src_off[idx - 1]
            nd_name_len[node] = cp_src_len[idx - 1]
            opt_copyprop_count = opt_copyprop_count + 1
        cp_rewrite_reads(nd_next[node])
        return
    if k == ND_INT_LIT or k == ND_CHAR_LIT or k == ND_BOOL_LIT or k == ND_FLOAT_LIT:
        cp_rewrite_reads(nd_next[node])
        return
    cp_rewrite_reads(nd_a[node])
    cp_rewrite_reads(nd_b[node])
    cp_rewrite_reads(nd_c[node])
    cp_rewrite_reads(nd_d[node])
    cp_rewrite_reads(nd_next[node])


# Is `node` a BARE variable read (a single ND_IDENT)? Such an r-value is the
# pure-copy source shape we forward.
def cp_is_bare_ident(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] == ND_IDENT:
        return 1
    return 0


# Does an r-value expression contain a call or address-of anywhere (a barrier)?
# Reuses the LICM scanner, which sets licm_giveup on ND_CALL / UNOP_ADDR.
def cp_expr_has_barrier(node: uint32) -> uint32:
    licm_giveup = 0
    licm_scan_expr(node)
    return licm_giveup


# The r-value expression of a straight-line statement (the side whose reads we
# forward), or 0 if the statement has none.
def cp_stmt_rvalue(s: uint32) -> uint32:
    k: uint32 = nd_kind[s]
    if k == ND_VAR_DECL:
        return nd_b[s]
    if k == ND_ASSIGN:
        return nd_b[s]
    if k == ND_EXPR_STMT:
        return nd_a[s]
    if k == ND_RETURN:
        return nd_a[s]
    return 0


# Process ONE straight-line statement: forward reads, apply writes, record a new
# copy. Returns 1 if the statement is a HARD BARRIER (flush + end run), 0 if it
# was modelled precisely.
def cp_process_stmt(s: uint32) -> uint32:
    k: uint32 = nd_kind[s]
    if k == ND_VAR_DECL:
        rv: uint32 = nd_b[s]
        # An augmented var-decl never occurs; a plain decl `name = <rv>`.
        if rv != 0:
            if cp_expr_has_barrier(rv) != 0:
                return 1
            cp_rewrite_reads(rv)
        # The decl WRITES its name (kill prior copies of/with it) BEFORE we record
        # a fresh copy from it.
        cp_kill_name(nd_name_off[s], nd_name_len[s])
        # Record a pure copy `name = <src-ident>` (after the rewrite above the rv
        # may have been forwarded to a root ident — still a bare ident, so we
        # forward the chain transitively).
        if rv != 0 and cp_is_bare_ident(rv) != 0:
            # Do not copy a name from ITSELF (`x = x` is a no-op; skip).
            if ir_name_eq(nd_name_off[s], nd_name_len[s],
                          nd_name_off[rv], nd_name_len[rv]) == 0:
                cp_add(nd_name_off[s], nd_name_len[s],
                       nd_name_off[rv], nd_name_len[rv])
        return 0
    if k == ND_ASSIGN:
        # Only a plain assignment (AUGOP_NONE) to a BARE ident is modelled; an
        # augmented assign or a non-ident (store-through-index/member/deref)
        # target is an opaque store -> barrier.
        if nd_aux[s] != AUGOP_NONE:
            return 1
        tgt: uint32 = nd_a[s]
        if nd_kind[tgt] != ND_IDENT:
            # Store through an index/member/deref lvalue (`bucket[slot] = ...`) is
            # an OPAQUE MEMORY write: we cannot model the written cell, so it stays
            # a BARRIER that flushes the active set (return 1 below). BUT the reads
            # in its rvalue and address sub-expressions can still be FORWARDED
            # first, when the whole statement is call/addr-of-free. This is the
            # LICM-boundary copy the frontier was stuck on: LICM leaves
            # `t = __licm_tmp` in the loop body and the ONLY consumer is an indexed
            # store (`bucket[i] = bucket[i] + t + ...`); without forwarding here the
            # copy dest `t` keeps a live reader, so it is never dead and codegen
            # emits a per-iteration register copy (`mov rax,rN; mov rM,rax`) of the
            # hoisted invariant. Forwarding renames the read `t` -> `__licm_tmp`
            # (its unclobbered, provably-equal copy root — value-preserving, no
            # reorder), leaving `t` unread so the following DCE deletes the dead
            # copy decl and the consumer reads the hoisted register DIRECTLY (0
            # copies). Gated on barrier-free so an aliasing call / addr-of inside
            # the store never lets a stale copy source be forwarded.
            store_rv: uint32 = nd_b[s]
            if cp_expr_has_barrier(tgt) != 0:
                return 1
            if store_rv != 0 and cp_expr_has_barrier(store_rv) != 0:
                return 1
            cp_rewrite_reads(tgt)
            if store_rv != 0:
                cp_rewrite_reads(store_rv)
            return 1
        rv2: uint32 = nd_b[s]
        if cp_expr_has_barrier(rv2) != 0:
            return 1
        cp_rewrite_reads(rv2)
        cp_kill_name(nd_name_off[tgt], nd_name_len[tgt])
        if cp_is_bare_ident(rv2) != 0:
            if ir_name_eq(nd_name_off[tgt], nd_name_len[tgt],
                          nd_name_off[rv2], nd_name_len[rv2]) == 0:
                cp_add(nd_name_off[tgt], nd_name_len[tgt],
                       nd_name_off[rv2], nd_name_len[rv2])
        return 0
    if k == ND_EXPR_STMT:
        if cp_expr_has_barrier(nd_a[s]) != 0:
            return 1
        cp_rewrite_reads(nd_a[s])
        return 0
    if k == ND_RETURN:
        if cp_expr_has_barrier(nd_a[s]) != 0:
            return 1
        cp_rewrite_reads(nd_a[s])
        return 0
    # Any control-flow / unknown statement: hard barrier.
    return 1


# Copy-propagate over a statement chain (a block). Walks maximal straight-line
# runs, flushing the active set at each barrier, and recurses into nested block
# bodies (where each nested block begins a FRESH run with an empty active set —
# we never carry a copy across a control-flow boundary, conservatively correct).
def cp_block(head: uint32):
    cp_reset()
    s: uint32 = head
    while s != 0:
        barrier: uint32 = cp_process_stmt(s)
        if barrier != 0:
            cp_reset()
        # Recurse into nested control-flow bodies. The active-copy set (cp_* arrays
        # + cp_n) is a SINGLE module-global shared across every cp_block frame, so a
        # recursive call REPOPULATES it with the NESTED block's copies and returns
        # with it non-empty. A control-flow statement is itself a hard barrier
        # (cp_process_stmt returned 1 above and we flushed), so no copy may survive
        # across it into the rest of THIS run — we MUST re-clear the shared set AFTER
        # the recursion, else a copy recorded inside the nested block LEAKS into the
        # parent run and wrongly forwards a later read. The live bug this fixes:
        # parse_or (hamsh) records `lhs = n` at the tail of its `while` body; without
        # the post-recursion reset that copy leaked out and rewrote the trailing
        # `return lhs` to `return n`, reading an UNINITIALISED `n` whenever the loop
        # ran zero times (an `or`-free expression) — a wild node index -> a read
        # #PF/SIGSEGV that wedged PID 1 before the desktop (only visible in a large
        # real program: a copy at a nested-block TAIL followed by a parent-run read
        # of the copy DEST, which the differential fuzzer did not generate).
        k: uint32 = nd_kind[s]
        recursed: uint32 = 0
        if k == ND_IF:
            cp_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                cp_block(nd_b[e])
                e = nd_next[e]
            cp_block(nd_d[s])
            recursed = 1
        elif k == ND_WHILE:
            cp_block(nd_b[s])
            recursed = 1
        elif k == ND_DO_WHILE:
            cp_block(nd_b[s])
            recursed = 1
        elif k == ND_FOR:
            cp_block(nd_b[s])
            recursed = 1
        elif k == ND_FOR_UNPACK:
            cp_block(nd_c[s])
            recursed = 1
        if recursed != 0:
            cp_reset()
        s = nd_next[s]


def opt_copyprop_function(fn: uint32):
    cp_block(nd_c[fn])


# =======================================================================
# Phase 9.5 — POW2 PARITY / DIVISIBILITY IDIOM  (`x - (x/C)*C == 0` -> `x & (C-1) == 0`)
# =======================================================================
#
# WHAT / WHY
# ----------
# The single remaining ALGEBRAIC gap vs gcc -O2 on the compute-bound `collatz`
# kernel is its parity test. The source (and its C twin) writes the classic
# split idiom
#
#     half = n / 2
#     if n - half * 2 == 0:            # n is even
#
# which the destination-driven backend lowers literally: a signed div (with the
# round-toward-zero fixup) for `half`, then `imul $2` + `sub` + `cmp $0` for the
# test — where gcc emits a single `test $1, n` (`and`). This pass recognises the
# divisibility-by-power-of-2 TEST and rewrites the compared subtree in place to
# `x & (C-1)`, so codegen emits the `and`/`test`. `half`'s own `n/2` div is left
# untouched (it still feeds `n = half` in the taken arm).
#
# SIGNEDNESS — WHY THIS IS SAFE FOR ANY SIGN (correctness first)
# --------------------------------------------------------------
# We ONLY fire inside an `== 0` / `!= 0` comparison, i.e. a DIVISIBILITY test.
# For a power-of-two C, `x` is divisible by C  <=>  its low log2(C) bits are all
# zero  <=>  `(x & (C-1)) == 0`, and this holds for EVERY sign of x. It does NOT
# depend on the sign/rounding of `/`: e.g. for x = -3, C = 2 the idiom value
# `x - (x/2)*2 = -1` and `x & 1 = 1` DIFFER in value, but both are non-zero, so
# the `== 0` test agrees. We therefore NEVER lower a signed value-context `x % C`
# or `x - (x/C)*C` to a bare `&` (C's truncated `%` differs there); a value-
# context `x % C` is already lowered correctly per-sign by gen_div_const in
# codegen.ad, so this pass leaves it alone. Only the sign-independent evenness/
# divisibility TEST is folded — matching the brief's "if signedness is ambiguous,
# do NOT transform".
#
# The recognised shapes (C a power of two, in an `== 0`/`!= 0` context):
#   * `x % C`                          (dividend x any expr)
#   * `x - (x / C) * C`  /  `x - C * (x / C)`     (inline div)
#   * `x - q * C`  /  `x - C * q`  where a preceding straight-line
#     `q = x / C` (or `q = x // C`) is still live (the collatz shape).
# --opt-gated (opt_run returns early when disabled) so flag-OFF output is
# byte-identical.

PM_MAX: uint32 = 256
pm_qn_off: Array[256, uint32]      # quotient var name off
pm_qn_len: Array[256, uint32]      # quotient var name len
pm_dv_off: Array[256, uint32]      # dividend var name off
pm_dv_len: Array[256, uint32]      # dividend var name len
pm_k: Array[256, uint32]           # log2(C)
pm_live: Array[256, uint32]
pm_n: uint32 = 0

# Result channel for pm_match_idiom: the AND mask (C-1) of the last match.
pm_match_mask: uint64 = 0


def pm_reset():
    pm_n = 0


# Kill every live entry whose quotient OR dividend name equals (off,len). Called
# when `name` is written: a stored quotient is stale, and a recorded dividend
# changing invalidates the `q == x/C` relation.
def pm_kill_name(off: uint32, len_: uint32):
    i: uint32 = 0
    while i < pm_n:
        if pm_live[i] != 0:
            if ir_name_eq(pm_qn_off[i], pm_qn_len[i], off, len_) != 0:
                pm_live[i] = 0
            elif ir_name_eq(pm_dv_off[i], pm_dv_len[i], off, len_) != 0:
                pm_live[i] = 0
        i = i + 1


# Record `q = x / C`  (k = log2 C).
def pm_add(qoff: uint32, qlen: uint32, dvoff: uint32, dvlen: uint32, k: uint32):
    if pm_n >= PM_MAX:
        return
    pm_qn_off[pm_n] = qoff
    pm_qn_len[pm_n] = qlen
    pm_dv_off[pm_n] = dvoff
    pm_dv_len[pm_n] = dvlen
    pm_k[pm_n] = k
    pm_live[pm_n] = 1
    pm_n = pm_n + 1


# Find a live quotient entry named (off,len); return index+1 or 0.
def pm_lookup_quot(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < pm_n:
        if pm_live[i] != 0:
            if ir_name_eq(pm_qn_off[i], pm_qn_len[i], off, len_) != 0:
                return i + 1
        i = i + 1
    return 0


def pm_is_pow2(v: uint64) -> uint32:
    if v == cast[uint64](0):
        return 0
    if (v & (v - cast[uint64](1))) == cast[uint64](0):
        return 1
    return 0


def pm_log2(v: uint64) -> uint32:
    k: uint32 = 0
    x: uint64 = v
    while (x & cast[uint64](1)) == cast[uint64](0):
        x = x >> 1
        k = k + 1
    return k


# If `node` is an ND_INT_LIT holding a power of two, return log2+1; else 0.
def pm_pow2_lit(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_INT_LIT:
        return 0
    v: uint64 = nd_num[node]
    if pm_is_pow2(v) == 0:
        return 0
    return pm_log2(v) + 1


def pm_is_zero_lit(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_INT_LIT:
        return 0
    if nd_num[node] == cast[uint64](0):
        return 1
    return 0


# Is `node` a divisibility-by-pow2 test operand? On a match, sets pm_match_mask
# to (C-1) and returns 1; the matched node's nd_a is guaranteed to already BE the
# dividend expression, so the caller rewrites in place by flipping the op to a
# bitwise-AND and replacing nd_b with the mask literal. `use_map` gates the
# cross-statement `q = x/C` form (unsafe across a loop back-edge, so disabled for
# loop conditions).
def pm_match_idiom(node: uint32, use_map: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_BINARY:
        return 0
    op: uint32 = nd_aux[node]
    # ---- direct `x % C` ---------------------------------------------------
    if op == BINOP_MOD:
        c: uint32 = pm_pow2_lit(nd_b[node])
        if c == 0:
            return 0
        pm_match_mask = nd_num[nd_b[node]] - cast[uint64](1)
        return 1
    # ---- `x - <mul>` idiom ------------------------------------------------
    if op != BINOP_SUB:
        return 0
    xn: uint32 = nd_a[node]
    mul: uint32 = nd_b[node]
    if nd_kind[xn] != ND_IDENT:
        return 0
    if nd_kind[mul] != ND_BINARY or nd_aux[mul] != BINOP_MUL:
        return 0
    # Split the multiply into (V, C) where C is a pow2 literal.
    ma: uint32 = nd_a[mul]
    mb: uint32 = nd_b[mul]
    vnode: uint32 = 0
    cbits: uint64 = 0
    if pm_pow2_lit(mb) != 0:
        vnode = ma
        cbits = nd_num[mb]
    elif pm_pow2_lit(ma) != 0:
        vnode = mb
        cbits = nd_num[ma]
    else:
        return 0
    k: uint32 = pm_log2(cbits)
    # form (a): V is a live quotient `V = x / C`, same dividend x, same C.
    if nd_kind[vnode] == ND_IDENT:
        if use_map != 0:
            idx: uint32 = pm_lookup_quot(nd_name_off[vnode], nd_name_len[vnode])
            if idx != 0:
                if pm_k[idx - 1] == k:
                    if ir_name_eq(pm_dv_off[idx - 1], pm_dv_len[idx - 1],
                                  nd_name_off[xn], nd_name_len[xn]) != 0:
                        pm_match_mask = cbits - cast[uint64](1)
                        return 1
        return 0
    # form (b): V is an inline `x / C` (or `x // C`) over the same ident x, same C.
    if nd_kind[vnode] == ND_BINARY:
        vop: uint32 = nd_aux[vnode]
        if vop == BINOP_DIV or vop == BINOP_IDIV:
            dl: uint32 = nd_a[vnode]
            dr: uint32 = nd_b[vnode]
            if nd_kind[dl] == ND_IDENT:
                if pm_pow2_lit(dr) != 0 and nd_num[dr] == cbits:
                    if ir_name_eq(nd_name_off[dl], nd_name_len[dl],
                                  nd_name_off[xn], nd_name_len[xn]) != 0:
                        pm_match_mask = cbits - cast[uint64](1)
                        return 1
    return 0


# Turn a matched idiom node into `dividend & pm_match_mask` in place. nd_a is
# already the dividend; flip the op and swap in the mask literal.
def pm_to_and(node: uint32):
    nd_aux[node] = BINOP_BIT_AND
    nd_b[node] = r2i_intlit(pm_match_mask)
    opt_paritymod_count = opt_paritymod_count + 1


# If `cmp` is `E == 0` / `E != 0` and E is a divisibility idiom, fold E to the
# `& mask` form (sign-independent for a pow2 divisor).
def pm_try_eqzero(cmp_: uint32, use_map: uint32):
    a: uint32 = nd_a[cmp_]
    b: uint32 = nd_b[cmp_]
    if pm_is_zero_lit(b) != 0:
        if pm_match_idiom(a, use_map) != 0:
            pm_to_and(a)
            return
    if pm_is_zero_lit(a) != 0:
        if pm_match_idiom(b, use_map) != 0:
            pm_to_and(b)


# Descend an r-value expression, folding every `<idiom> == 0` / `!= 0` it holds.
def pm_rewrite_expr(node: uint32, use_map: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_BINARY:
        op: uint32 = nd_aux[node]
        if op == BINOP_EQ or op == BINOP_NEQ:
            pm_try_eqzero(node, use_map)
    pm_rewrite_expr(nd_a[node], use_map)
    pm_rewrite_expr(nd_b[node], use_map)
    pm_rewrite_expr(nd_c[node], use_map)
    pm_rewrite_expr(nd_d[node], use_map)
    pm_rewrite_expr(nd_next[node], use_map)


# If `rv` is `x / C` / `x // C` with x a bare ident and C a pow2 literal, return
# log2(C)+1 and write the dividend ident node through *outx; else 0.
def pm_rvalue_is_pow2_div(rv: uint32, outx: Ptr[uint32]) -> uint32:
    if rv == 0:
        return 0
    if nd_kind[rv] != ND_BINARY:
        return 0
    op: uint32 = nd_aux[rv]
    if op != BINOP_DIV and op != BINOP_IDIV:
        return 0
    dl: uint32 = nd_a[rv]
    dr: uint32 = nd_b[rv]
    if nd_kind[dl] != ND_IDENT:
        return 0
    c: uint32 = pm_pow2_lit(dr)
    if c == 0:
        return 0
    outx[0] = dl
    return c


# Process one straight-line statement: fold idioms in its consumed r-values,
# then apply its writes to the `q = x/C` map. Returns 1 if the statement ends the
# straight-line run (a control-flow / opaque barrier), 0 otherwise.
def pm_process_stmt(s: uint32) -> uint32:
    k: uint32 = nd_kind[s]
    if k == ND_VAR_DECL:
        rv: uint32 = nd_b[s]
        pm_rewrite_expr(rv, 1)
        # The decl writes its own name: kill stale entries first.
        pm_kill_name(nd_name_off[s], nd_name_len[s])
        xout: uint32 = 0
        c: uint32 = pm_rvalue_is_pow2_div(rv, &xout)
        if c != 0:
            pm_add(nd_name_off[s], nd_name_len[s],
                   nd_name_off[xout], nd_name_len[xout], c - 1)
        return 0
    if k == ND_ASSIGN:
        tgt: uint32 = nd_a[s]
        rv2: uint32 = nd_b[s]
        pm_rewrite_expr(rv2, 1)
        if nd_kind[tgt] == ND_IDENT:
            pm_kill_name(nd_name_off[tgt], nd_name_len[tgt])
            # A plain (non-augmented) assign of a fresh `x / C` records a mapping;
            # an augmented assign only writes (kill above), never records.
            if nd_aux[s] == AUGOP_NONE:
                xout2: uint32 = 0
                c2: uint32 = pm_rvalue_is_pow2_div(rv2, &xout2)
                if c2 != 0:
                    pm_add(nd_name_off[tgt], nd_name_len[tgt],
                           nd_name_off[xout2], nd_name_len[xout2], c2 - 1)
            return 0
        # Store through index/member/deref: rewrite the address sub-expr too;
        # it cannot rename a scalar local, so the map survives.
        pm_rewrite_expr(tgt, 1)
        return 0
    if k == ND_EXPR_STMT:
        pm_rewrite_expr(nd_a[s], 1)
        return 0
    if k == ND_RETURN:
        pm_rewrite_expr(nd_a[s], 1)
        return 0
    if k == ND_IF:
        # The primary and each elif condition evaluate in THIS straight-line
        # context (pure, no intervening store), so the map is valid for them.
        pm_rewrite_expr(nd_a[s], 1)
        e: uint32 = nd_c[s]
        while e != 0:
            pm_rewrite_expr(nd_a[e], 1)
            e = nd_next[e]
        return 1
    if k == ND_WHILE or k == ND_DO_WHILE:
        # A loop condition re-runs across the back-edge, where a map entry built
        # before the loop is stale; only self-contained (inline) idioms are safe.
        pm_rewrite_expr(nd_a[s], 0)
        return 1
    # Any other control-flow / unknown statement ends the run.
    return 1


# Walk a statement chain in maximal straight-line runs, folding idioms and
# resetting the map at each barrier; recurse into nested blocks (each a fresh
# run). Mirrors cp_block's structural recursion.
def pm_block(head: uint32):
    pm_reset()
    s: uint32 = head
    while s != 0:
        barrier: uint32 = pm_process_stmt(s)
        if barrier != 0:
            pm_reset()
        k: uint32 = nd_kind[s]
        if k == ND_IF:
            pm_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                pm_block(nd_b[e])
                e = nd_next[e]
            pm_block(nd_d[s])
        elif k == ND_WHILE:
            pm_block(nd_b[s])
        elif k == ND_DO_WHILE:
            pm_block(nd_b[s])
        elif k == ND_FOR:
            pm_block(nd_b[s])
        elif k == ND_FOR_UNPACK:
            pm_block(nd_c[s])
        s = nd_next[s]


def opt_paritymod_function(fn: uint32):
    pm_block(nd_c[fn])

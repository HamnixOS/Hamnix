# adder/compiler/opt.ad
#
# Native Adder optimizer — Phase 1 pass manager + constant-folding pass.
#
# ROLE
# ----
# This is the opt-in entry point of the native optimizer. It runs AFTER the
# parser produces the AST and BEFORE codegen.ad walks it. With the opt flag
# OFF (the default), opt_run is never called, so the compiler takes the
# exact pre-existing AST -> codegen path and emits byte-identical output.
#
# With the flag ON (ADDER_OPT=1 / --opt), opt_run walks the whole program,
# lowers each constant integer expression subtree into the Phase-1 IR
# (ir.ad), evaluates it, and rewrites the AST ND_BINARY root in place into a
# single ND_INT_LIT. codegen.ad then emits the same `movq $imm,%rax` it
# would emit for any literal — i.e. the const computation collapses to its
# result. The transform is value-preserving over the foldable, signedness-
# invariant op set (see ir.ad), so ADDER_OPT=1 output stays BEHAVIORALLY
# correct (the fuzzer's ADDER_OPT=1 lane asserts this).
#
# PASS PLUMBING
# -------------
# Phase 1 ships one pass (constant folding). The "pass manager" is the
# fixed-point driver opt_run -> opt_walk: it descends the AST generically
# over every child slot (nd_a/nd_b/nd_c/nd_d and the nd_next sibling chain),
# attempts to fold each ND_BINARY it encounters, and counts the folds in
# opt_fold_count for logging. Later phases (LICM/CSE/regalloc) register as
# additional passes over the same IR substrate.

from compiler.parser import (
    nd_kind,
    nd_aux,
    nd_num,
    nd_name_off,
    nd_name_len,
    nd_a,
    nd_b,
    nd_c,
    nd_d,
    nd_next,
    node_new,
    ND_INT_LIT,
    ND_IDENT,
    ND_BINARY,
    ND_VAR_DECL,
    ND_ASSIGN,
    ND_EXPR_STMT,
    ND_RETURN,
    ND_IF,
    ND_ELIF,
    ND_WHILE,
    ND_DO_WHILE,
    ND_FOR,
    ND_FOR_UNPACK,
    ND_FUNCTION,
    ND_CALL,
    ND_UNARY,
    UNOP_ADDR,
    AUGOP_NONE,
)

from compiler.ir import (
    ir_reset,
    ir_lower_const_expr,
    ir_lower_pure_expr,
    ir_value_eq,
    ir_uses_name,
    ir_const,
    ir_kind,
    ir_ast,
    ir_name_off,
    ir_name_len,
    IR_BINOP,
)

from compiler.lexer import (
    strbuf,
    strbuf_pos,
)

# -----------------------------------------------------------------------
# Opt flag — OFF by default. The driver flips this to 1 on --opt / ADDER_OPT.
# When 0, opt_run is never invoked, so this whole module is inert and the
# default codegen path is byte-for-byte unchanged.
# -----------------------------------------------------------------------
opt_enabled: uint32 = 0

# Diagnostics: number of ND_BINARY subtrees folded into a constant. Logged by
# the driver so the fuzzer can assert the pass demonstrably fires.
opt_fold_count: uint32 = 0

# Diagnostics: number of redundant pure subexpressions eliminated by CSE
# (each elimination = one recomputation replaced by a load of a hoisted temp).
opt_cse_count: uint32 = 0

# Monotonic counter for minting unique synthetic temp names (__cse_<n>).
opt_cse_tmp_seq: uint32 = 0

# Diagnostics: number of loop-invariant pure computations hoisted to a loop
# pre-header by Phase-3 LICM (one per hoisted expression value).
opt_licm_count: uint32 = 0


def opt_enable():
    opt_enabled = 1


def opt_reset_stats():
    opt_fold_count = 0
    opt_cse_count = 0
    opt_cse_tmp_seq = 0
    opt_licm_count = 0


# Rewrite an AST ND_BINARY node IN PLACE into an ND_INT_LIT carrying `v`.
# codegen.ad's ND_INT_LIT path reads only nd_num, so the operand/child slots
# are cleared for hygiene. The node id is preserved, so any parent slot that
# referenced this subtree now transparently references the folded constant.
def fold_node_to_const(node: uint32, v: uint64):
    nd_kind[node] = ND_INT_LIT
    nd_num[node] = v
    nd_aux[node] = 0
    nd_a[node] = 0
    nd_b[node] = 0
    nd_c[node] = 0
    nd_d[node] = 0


# Constant-fold pass over a single node. If `node` is an ND_BINARY whose
# entire subtree is a foldable constant expression, fold it to ND_INT_LIT
# and report 1; else 0. Must be attempted BEFORE recursing into children so
# the whole maximal constant subtree collapses in one shot.
def opt_try_fold(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_BINARY:
        return 0
    ir_reset()
    iv: uint32 = ir_lower_const_expr(node)
    if iv == 0:
        return 0
    fold_node_to_const(node, ir_const[iv])
    opt_fold_count = opt_fold_count + 1
    return 1


# Generic AST descent. Every nd_a/nd_b/nd_c/nd_d slot holds a child node id
# (or 0), and nd_next chains list siblings — this holds uniformly across all
# node kinds in the parser arena (scalars live in nd_num/nd_aux, never in the
# child slots). So this walk safely reaches every expression in the program.
#
# At each node we FIRST attempt to fold it (collapsing the maximal constant
# subtree, which prunes the recursion below it), then recurse into whatever
# children remain.
def opt_walk(node: uint32):
    if node == 0:
        return
    folded: uint32 = opt_try_fold(node)
    if folded != 0:
        # The node is now an ND_INT_LIT leaf; its former children were folded
        # in and cleared. Still follow the sibling chain.
        opt_walk(nd_next[node])
        return
    opt_walk(nd_a[node])
    opt_walk(nd_b[node])
    opt_walk(nd_c[node])
    opt_walk(nd_d[node])
    opt_walk(nd_next[node])


# Pass-manager entry point. Runs the Phase-1 pass set over the whole program.
# `prog` is the ND_PROGRAM root; its decl chain hangs off nd_b (mirroring
# gen_program_with_globals in codegen.ad). We walk every declaration, which
# transitively reaches every function body and expression.
def opt_run(prog: uint32):
    if opt_enabled == 0:
        return
    opt_reset_stats()
    if prog == 0:
        return
    # Walk the decl chain (functions, globals, classes). Each function body
    # is reached through opt_walk's generic descent.
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    while cur != 0:
        opt_walk(cur)
        cur = nd_next[cur]
    # Phase 2 — local CSE over each function body (runs on the const-FOLDED
    # graph: opt_walk above already collapsed constant subtrees, so CSE numbers
    # the simplified expressions). Re-walk the decls and CSE every function.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_cse_function(cur)
        cur = nd_next[cur]
    # Phase 3 — loop-invariant code motion. Runs AFTER fold+CSE so it operates
    # on the simplified graph (constants collapsed, in-statement redundancy
    # already shared). Re-walk the decls and LICM every function body.
    cur = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            opt_licm_function(cur)
        cur = nd_next[cur]


# =======================================================================
# Phase 2 — local common-subexpression elimination via value numbering.
# =======================================================================
#
# STRATEGY (conservative + correct over fast)
# -------------------------------------------
# CSE eliminates a redundant PURE computation by computing it ONCE into a
# synthetic temp local and reusing the temp at later occurrences. The temp is
# an untyped 8-byte scalar slot (declare_local with type node 0 in codegen.ad
# gives a full-register movq store/load — no sub-width hazard), so the temp
# holds EXACTLY the %rax value codegen would have computed inline. Because the
# eliminated expressions are restricted to the signedness-INVARIANT 64-bit op
# set over ident/const leaves (see ir.ad ir_lower_pure_expr), the temp's value
# equals every occurrence's value bit-for-bit: the transform is value-
# preserving, hence behaviorally correct (the ADDER_OPT=1 fuzzer lane asserts
# this against the oracle).
#
# SCOPE — a single STATEMENT's expression tree (a maximal pure straight-line
# region). Within one pure expression there are provably NO intervening
# clobbers of any leaf identifier (a pure expression has no assignments/
# stores/calls), so an available expression stays valid across the whole tree.
# Any impure node (call, index/load, member, cast, compare, DIV/MOD/SHR,
# unary, assignment target) is NOT lowered into the value IR and thus ends the
# available-expression region (ir_lower_pure_expr returns 0 for it). A store /
# call / volatile-load that could clobber is therefore never inside a CSE
# region. This is the textbook "local CSE within a basic block", at its safest.
#
# The repeated occurrence is rewritten IN PLACE into an ND_IDENT referencing
# the temp; the temp's defining ND_VAR_DECL is spliced into the enclosing
# statement chain immediately before the statement that uses it, so codegen's
# prescan reserves the slot and the body walk computes it before the use.

# Append "__cse_<seq>" to strbuf and return its starting offset; the length is
# written through the two globals below (Adder has no multi-return here). The
# name is unique per call (seq is monotonic) and cannot collide with a user
# identifier (user names never contain the "__cse_" prefix in the fuzzer/seed
# subset; the leading "__" marks it compiler-internal).
opt_tmp_name_off: uint32 = 0
opt_tmp_name_len: uint32 = 0


def cse_emit_digits(v: uint32):
    if v == 0:
        strbuf[strbuf_pos] = 48        # '0'
        strbuf_pos = strbuf_pos + 1
        return
    # Emit decimal digits (recurse for high-order first).
    if v >= 10:
        cse_emit_digits(v / 10)
    strbuf[strbuf_pos] = cast[uint8]((v % 10) + 48)
    strbuf_pos = strbuf_pos + 1


def cse_mint_temp_name():
    start: uint32 = strbuf_pos
    # "__cse_"
    strbuf[strbuf_pos] = 95          # '_'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 95          # '_'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 99          # 'c'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 115         # 's'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 101         # 'e'
    strbuf_pos = strbuf_pos + 1
    strbuf[strbuf_pos] = 95          # '_'
    strbuf_pos = strbuf_pos + 1
    opt_cse_tmp_seq = opt_cse_tmp_seq + 1
    cse_emit_digits(opt_cse_tmp_seq)
    opt_tmp_name_off = start
    opt_tmp_name_len = strbuf_pos - start


# Rewrite AST node `node` in place into an ND_IDENT referencing the temp name
# (off,len). codegen.ad's ND_IDENT path reads only nd_name_off/len, so clearing
# the operand/child slots is hygiene. The node id is preserved, so the parent
# slot that referenced this subtree now references the temp read.
def cse_rewrite_to_ident(node: uint32, off: uint32, len_: uint32):
    nd_kind[node] = ND_IDENT
    nd_name_off[node] = off
    nd_name_len[node] = len_
    nd_aux[node] = 0
    nd_num[node] = 0
    nd_a[node] = 0
    nd_b[node] = 0
    nd_c[node] = 0
    nd_d[node] = 0


# Build a fresh ND_VAR_DECL `<tmpname> = <init_ast>` with NO type annotation
# (type node 0 -> codegen reserves a plain untyped 8-byte scalar slot). Returns
# the new statement node, or 0 on arena exhaustion.
def cse_make_temp_decl(off: uint32, len_: uint32, init_ast: uint32) -> uint32:
    d: uint32 = node_new(ND_VAR_DECL)
    if d == 0:
        return 0
    nd_name_off[d] = off
    nd_name_len[d] = len_
    nd_a[d] = 0                # no type node -> untyped 8-byte scalar
    nd_b[d] = init_ast        # initialiser
    return d


# --- single-statement CSE -------------------------------------------------
#
# We scan the value-IR of ONE statement's expression for a pure ND_BINOP value
# that occurs >=2 times. The FIRST such occurrence is materialized into a temp;
# every occurrence (including the first) is rewritten to read the temp, and the
# temp's defining decl is returned to the caller for splicing before the stmt.
#
# Per-statement scratch: the list of distinct AST roots we lowered, plus their
# IR value ids, and a parallel "already eliminated" mark.
CSE_MAX_CAND: uint32 = 4096
cse_cand_ast: Array[4096, uint32]    # AST node of a pure-binop candidate
cse_cand_ir: Array[4096, uint32]     # its value-IR id
cse_cand_n: uint32 = 0

# Pending temp decls minted while processing the current statement, to splice
# in before it (in mint order).
CSE_MAX_PEND: uint32 = 256
cse_pend_decl: Array[256, uint32]
cse_pend_n: uint32 = 0


# Collect every pure ND_BINARY subtree of `node` into the candidate list, in
# PRE-ORDER (outermost first), each paired with its lowered value IR. A subtree
# that does not lower (impure / out-of-set) is skipped but we still descend its
# AST children to find pure binops nested under an impure parent (e.g. inside a
# cast or an index expression's operands).
def cse_collect(node: uint32):
    if node == 0:
        return
    if cse_cand_n >= CSE_MAX_CAND:
        return
    if nd_kind[node] == ND_BINARY:
        # Lower into the SHARED per-statement IR arena (reset once by the
        # caller, NOT per node) so every candidate's value id stays live and
        # mutually comparable across the whole statement.
        v: uint32 = ir_lower_pure_expr(node)
        if v != 0:
            cse_cand_ast[cse_cand_n] = node
            cse_cand_ir[cse_cand_n] = v
            cse_cand_n = cse_cand_n + 1
    cse_descend(node)


# Descend into the expression children of an AST node (the slots that can hold
# sub-expressions). Statement-level nodes are handled by the per-statement
# entry; here we only chase expression operands.
def cse_descend(node: uint32):
    k: uint32 = nd_kind[node]
    # ND_IDENT / literals have no expression children.
    if k == ND_IDENT or k == ND_INT_LIT:
        return
    cse_collect(nd_a[node])
    cse_collect(nd_b[node])
    cse_collect(nd_c[node])
    cse_collect(nd_d[node])


# Rewrite, within the AST subtree rooted at `root`, EVERY occurrence whose
# value-IR equals `proto_ir` into an ND_IDENT(off,len). Returns the count of
# occurrences rewritten. Each candidate's IR was built under its own ir_reset,
# so we rebuild the subtree's IR here to compare; but since we only ever call
# this for nodes already in the candidate list, we compare via the recorded
# candidate IRs to avoid clobbering proto_ir's arena.
def cse_apply(root: uint32, proto_ir: uint32, off: uint32, len_: uint32) -> uint32:
    n: uint32 = 0
    i: uint32 = 0
    while i < cse_cand_n:
        ast: uint32 = cse_cand_ast[i]
        if ast != 0 and nd_kind[ast] == ND_BINARY:
            if ir_value_eq(cse_cand_ir[i], proto_ir) != 0:
                # Before clobbering this subtree into an ident, kill every
                # candidate whose AST lies WITHIN it (its nodes are about to be
                # orphaned) so we never double-rewrite a nested sub-part.
                cse_kill_descendants(ast)
                cse_rewrite_to_ident(ast, off, len_)
                cse_cand_ast[i] = 0
                n = n + 1
        i = i + 1
    return n


# Null every candidate entry whose AST node is a descendant of `ast` (children
# of an ND_BINARY are nd_a/nd_b). Called before `ast` is collapsed to an ident.
def cse_kill_descendants(ast: uint32):
    if ast == 0:
        return
    if nd_kind[ast] != ND_BINARY:
        return
    cse_kill_subtree(nd_a[ast])
    cse_kill_subtree(nd_b[ast])


def cse_kill_subtree(node: uint32):
    if node == 0:
        return
    m: uint32 = 0
    while m < cse_cand_n:
        if cse_cand_ast[m] == node:
            cse_cand_ast[m] = 0
        m = m + 1
    if nd_kind[node] == ND_BINARY:
        cse_kill_subtree(nd_a[node])
        cse_kill_subtree(nd_b[node])


# Run CSE over a single statement's expression `expr_root`. Materializes the
# FIRST repeated pure binop value into a temp, rewrites all its occurrences,
# and records the temp decl in cse_pend_* for the caller to splice in. May fire
# multiple times (one temp per distinct repeated value). Returns nothing; side
# effects are the rewrites + pended decls + opt_cse_count bump.
def cse_statement_expr(expr_root: uint32):
    if expr_root == 0:
        return
    cse_cand_n = 0
    ir_reset()                 # one shared arena for ALL candidates of this stmt
    cse_collect(expr_root)
    # For each candidate (outermost-first), if another LATER live candidate has
    # an equal value, this is a repeated expression: materialize it. Outermost-
    # first means we capture the largest redundant expression, and cse_apply's
    # nested-invalidation prevents re-CSE of its sub-parts.
    i: uint32 = 0
    while i < cse_cand_n:
        ast_i: uint32 = cse_cand_ast[i]
        if ast_i != 0 and nd_kind[ast_i] == ND_BINARY:
            # Is there a later live candidate value-equal to this one?
            dup: uint32 = 0
            j: uint32 = i + 1
            while j < cse_cand_n:
                aj: uint32 = cse_cand_ast[j]
                if aj != 0 and nd_kind[aj] == ND_BINARY:
                    if ir_value_eq(cse_cand_ir[j], cse_cand_ir[i]) != 0:
                        dup = 1
                        j = cse_cand_n
                    else:
                        j = j + 1
                else:
                    j = j + 1
            if dup != 0:
                # Materialize: mint a temp, build its decl with the ORIGINAL
                # (pre-rewrite) expression as initialiser, then rewrite every
                # occurrence (incl. this one) to read the temp.
                cse_mint_temp_name()
                toff: uint32 = opt_tmp_name_off
                tlen: uint32 = opt_tmp_name_len
                # Clone the defining expression for the temp init. We use the
                # FIRST occurrence's AST node as the init by detaching it: build
                # the decl pointing at a COPY is unnecessary because we rewrite
                # the first occurrence to an ident AFTER capturing it as init.
                # So: decl init = the first occurrence's current subtree.
                init_node: uint32 = ast_i
                # Rewrite all occurrences EXCEPT we must preserve init_node's
                # subtree as the decl initialiser. cse_apply rewrites ast_i too,
                # so first snapshot init by making the decl reference a shallow
                # clone of ast_i.
                clone: uint32 = cse_clone_expr(ast_i)
                if clone == 0:
                    return
                d: uint32 = cse_make_temp_decl(toff, tlen, clone)
                if d == 0:
                    return
                cnt: uint32 = cse_apply(expr_root, cse_cand_ir[i], toff, tlen)
                if cnt >= 2:
                    if cse_pend_n < CSE_MAX_PEND:
                        cse_pend_decl[cse_pend_n] = d
                        cse_pend_n = cse_pend_n + 1
                    # Each of the cnt occurrences but the first is an eliminated
                    # recomputation.
                    opt_cse_count = opt_cse_count + (cnt - 1)
        i = i + 1


# Deep-clone a pure expression subtree (ND_BINARY over ident/const leaves) into
# fresh AST nodes, so the temp's initialiser is independent of the in-place
# rewrites applied to the original occurrences. Returns 0 on arena exhaustion.
def cse_clone_expr(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    c: uint32 = node_new(k)
    if c == 0:
        return 0
    nd_aux[c] = nd_aux[node]
    nd_num[c] = nd_num[node]
    nd_name_off[c] = nd_name_off[node]
    nd_name_len[c] = nd_name_len[node]
    if k == ND_BINARY:
        nd_a[c] = cse_clone_expr(nd_a[node])
        nd_b[c] = cse_clone_expr(nd_b[node])
    return c


# Expression roots of a statement: the slots that hold a top-level expression
# whose value we may CSE. We deliberately handle only statements whose
# expression is a self-contained pure region; assignment TARGETS and impure
# constructs are left alone (their value IR won't lower anyway).
def cse_stmt_expr_roots(stmt: uint32):
    k: uint32 = nd_kind[stmt]
    if k == ND_RETURN:
        cse_statement_expr(nd_a[stmt])
    elif k == ND_EXPR_STMT:
        cse_statement_expr(nd_a[stmt])
    elif k == ND_ASSIGN:
        # Only the VALUE side (nd_b); the target (nd_a) is an lvalue.
        cse_statement_expr(nd_b[stmt])
    elif k == ND_VAR_DECL:
        cse_statement_expr(nd_b[stmt])
    elif k == ND_WHILE:
        cse_statement_expr(nd_a[stmt])
    elif k == ND_DO_WHILE:
        cse_statement_expr(nd_a[stmt])
    elif k == ND_IF:
        cse_statement_expr(nd_a[stmt])


# CSE one statement-chain (a block). Returns the (possibly new) head with any
# temp decls spliced in immediately before the statements that use them. Also
# recurses into nested block bodies (if/while/for/elif) AFTER processing the
# statement itself.
def cse_block(head: uint32) -> uint32:
    new_head: uint32 = head
    prev: uint32 = 0
    s: uint32 = head
    while s != 0:
        nxt: uint32 = nd_next[s]
        # Process this statement's expression for CSE; pended temp decls accrue
        # in cse_pend_*.
        cse_pend_n = 0
        cse_stmt_expr_roots(s)
        # Splice pended decls in BEFORE s (in mint order), so codegen computes
        # the temp before the statement that reads it.
        if cse_pend_n > 0:
            pi: uint32 = 0
            while pi < cse_pend_n:
                d: uint32 = cse_pend_decl[pi]
                if prev == 0:
                    new_head = d
                else:
                    nd_next[prev] = d
                nd_next[d] = s
                prev = d
                pi = pi + 1
        # Recurse into nested blocks.
        k: uint32 = nd_kind[s]
        if k == ND_IF:
            nd_b[s] = cse_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                nd_b[e] = cse_block(nd_b[e])
                e = nd_next[e]
            nd_d[s] = cse_block(nd_d[s])
        elif k == ND_WHILE:
            nd_b[s] = cse_block(nd_b[s])
        elif k == ND_DO_WHILE:
            nd_b[s] = cse_block(nd_b[s])
        elif k == ND_FOR:
            nd_b[s] = cse_block(nd_b[s])
        prev = s
        s = nxt
    return new_head


def opt_cse_function(fn: uint32):
    # The function body chain hangs off nd_c (ND_FUNCTION: c = body chain head).
    nd_c[fn] = cse_block(nd_c[fn])


# =======================================================================
# Phase 3 — Loop-Invariant Code Motion (LICM).
# =======================================================================
#
# STRATEGY (conservative + correct over fast)
# -------------------------------------------
# LICM grows the analysis scope from a single statement (Phase 2's CSE region)
# to a whole LOOP BODY. A pure expression is LOOP-INVARIANT if computing it once
# before the loop yields the same value it would on every iteration — i.e. none
# of its inputs change inside the loop. We hoist such an expression into a temp
# in a synthetic PRE-HEADER spliced immediately before the loop, and rewrite the
# in-loop occurrences to read the temp.
#
# INVARIANCE TEST (conservative)
#   A candidate is a PURE expression in the exact Phase-2 value set: int/char/
#   bool literals, bare idents, and IR_BINOP over the signedness-invariant 64-bit
#   op set (ADD/SUB/MUL/AND/OR/XOR/SHL). It lowers via ir_lower_pure_expr, so by
#   construction it contains NO loads/indexes, NO calls, NO DIV/MOD/SHR, NO
#   compares/casts/unary — it cannot fault, divide, or have a side effect.
#   It is loop-invariant iff NONE of its leaf idents is written anywhere in the
#   loop body. "Written" = the ident is:
#     * an ND_ASSIGN target (plain or augmented),
#     * an ND_VAR_DECL name (re-declared / shadowed in the body),
#     * the loop induction variable of an ND_FOR / ND_FOR_UNPACK in the body,
#   AND, as a blanket conservative guard, if the loop body contains ANY call
#   (ND_CALL) or ANY address-of (UNOP_ADDR), we treat EVERY ident as potentially
#   clobbered and hoist NOTHING from that loop: a call may write through a
#   pointer to any local/global, and once an address escapes the compiler can no
#   longer prove the named storage is unmodified. (Phase 2's pure value set never
#   lowers a call/addr-of into a candidate, but they can still sit ELSEWHERE in
#   the body and clobber an otherwise-pure leaf, so the whole-body scan must see
#   them.)
#
# ZERO-TRIP SAFETY
#   Hoisting a computation above a loop that may run zero times is normally
#   unsafe (it would execute work the original program might skip). It is safe
#   HERE precisely because the value set is pure, side-effect-free and
#   non-faulting: evaluating `a*b+c` (a,b,c unchanged in the loop) before a
#   zero-trip loop produces an unused temp with no observable effect. DIV/MOD/
#   loads are kept OUT of the set (ir_lower_pure_expr returns 0 for them) exactly
#   so a possibly-trapping op is never hoisted above its guard.
#
# NESTED LOOPS
#   licm_block recurses into a loop's body FIRST (innermost loops processed
#   before their enclosing loop). An expression invariant w.r.t. the inner loop
#   but not the outer is hoisted only to the INNER pre-header: the inner pass
#   sees the outer induction var as a free (unwritten-by-the-inner-body) leaf and
#   hoists it just above the inner loop, where it is still inside the outer loop.
#   The outer pass then runs on a body that already contains that pre-header
#   decl; the decl's RHS is invariant in the outer loop only if its leaves are
#   outer-invariant too, in which case the outer pass hoists the pre-header decl
#   further out as an ordinary in-body statement candidate is NOT re-formed
#   (we hoist expressions, not statements), so the conservative result is: each
#   level hoists what is invariant at that level. Correct, possibly not maximal.

# --- per-loop clobber set ------------------------------------------------
#
# The set of identifier names written anywhere in the current loop body, stored
# as (off,len) pairs into strbuf. A blanket "give up" flag is raised if the body
# contains a call or an address-of (see the strategy note).
LICM_MAX_CLOB: uint32 = 4096
licm_clob_off: Array[4096, uint32]
licm_clob_len: Array[4096, uint32]
licm_clob_n: uint32 = 0
licm_giveup: uint32 = 0          # 1 => body has a call / addr-of => hoist nothing


def licm_clob_reset():
    licm_clob_n = 0
    licm_giveup = 0


def licm_clob_add(off: uint32, len_: uint32):
    if licm_clob_n >= LICM_MAX_CLOB:
        # Overflow: be safe, refuse to hoist anything from this loop.
        licm_giveup = 1
        return
    licm_clob_off[licm_clob_n] = off
    licm_clob_len[licm_clob_n] = len_
    licm_clob_n = licm_clob_n + 1


# Is `name` (off,len) in the clobber set? (byte compare via ir_name_eq)
def licm_is_clobbered(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < licm_clob_n:
        if ir_name_eq(licm_clob_off[i], licm_clob_len[i], off, len_) != 0:
            return 1
        i = i + 1
    return 0


# Scan an EXPRESSION subtree for call / address-of anywhere (sets licm_giveup).
# These are the operations that can clobber a named leaf without naming it.
def licm_scan_expr(node: uint32):
    if node == 0:
        return
    if licm_giveup != 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_CALL:
        licm_giveup = 1
        return
    if k == ND_UNARY:
        if nd_aux[node] == UNOP_ADDR:
            licm_giveup = 1
            return
    licm_scan_expr(nd_a[node])
    licm_scan_expr(nd_b[node])
    licm_scan_expr(nd_c[node])
    licm_scan_expr(nd_d[node])


# Record the lvalue target of an assignment as clobbered. We only understand a
# bare-ident target precisely; ANY other lvalue shape (index p[i], member a.b,
# deref *p) means a store we cannot pin to a name, so we give up on the whole
# loop (conservative — those stores could alias a hoist candidate's leaf).
def licm_record_assign_target(target: uint32):
    if target == 0:
        return
    if nd_kind[target] == ND_IDENT:
        licm_clob_add(nd_name_off[target], nd_name_len[target])
        return
    # Non-ident lvalue (store through index/member/deref) — can't prove it
    # doesn't alias a candidate leaf; bail out of hoisting for this loop.
    licm_giveup = 1


# Walk ONE statement chain of a loop body, recording every write (assignment
# target, var-decl name, for-loop induction var) into the clobber set and raising
# licm_giveup on any call / addr-of / opaque store. Recurses into nested blocks
# (if/elif/else, while, for, do-while) so the clobber set covers the ENTIRE loop
# body transitively.
def licm_collect_clobbers(head: uint32):
    s: uint32 = head
    while s != 0:
        if licm_giveup != 0:
            return
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            licm_record_assign_target(nd_a[s])
            licm_scan_expr(nd_b[s])
        elif k == ND_VAR_DECL:
            licm_clob_add(nd_name_off[s], nd_name_len[s])
            licm_scan_expr(nd_b[s])
        elif k == ND_EXPR_STMT:
            licm_scan_expr(nd_a[s])
        elif k == ND_RETURN:
            licm_scan_expr(nd_a[s])
        elif k == ND_IF:
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                licm_scan_expr(nd_a[e])
                licm_collect_clobbers(nd_b[e])
                e = nd_next[e]
            licm_collect_clobbers(nd_d[s])
        elif k == ND_WHILE:
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
        elif k == ND_DO_WHILE:
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
        elif k == ND_FOR:
            # Induction var is written each iteration.
            licm_clob_add(nd_name_off[s], nd_name_len[s])
            licm_scan_expr(nd_a[s])
            licm_collect_clobbers(nd_b[s])
        elif k == ND_FOR_UNPACK:
            # Each unpack target ident is written; iterable (b) + body (c).
            v: uint32 = nd_a[s]
            while v != 0:
                if nd_kind[v] == ND_IDENT:
                    licm_clob_add(nd_name_off[v], nd_name_len[v])
                v = nd_next[v]
            licm_scan_expr(nd_b[s])
            licm_collect_clobbers(nd_c[s])
        s = nd_next[s]


# --- invariance test over an IR value -----------------------------------
#
# An IR value (built by ir_lower_pure_expr) is loop-invariant iff every IR_IDENT
# leaf names a variable NOT in the clobber set. IR_CONST leaves are always
# invariant. (giveup is checked by the caller before this runs.)
def licm_ir_invariant(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k == IR_CONST:
        return 1
    if k == IR_IDENT:
        if licm_is_clobbered(ir_name_off[v], ir_name_len[v]) != 0:
            return 0
        return 1
    if k == IR_BINOP:
        if licm_ir_invariant(ir_a[v]) == 0:
            return 0
        return licm_ir_invariant(ir_b[v])
    return 0


# --- candidate collection + hoist ---------------------------------------
#
# We reuse the Phase-2 candidate machinery (cse_cand_*) over the WHOLE loop body
# instead of one statement: every pure ND_BINARY subtree across the body is
# lowered into one shared IR arena, so value-equal occurrences in different
# statements share a value id and get hoisted to ONE temp. Outermost-first
# pre-order means the maximal invariant expression wins.

# Pending pre-header decls for the loop currently being hoisted (spliced before
# the loop in mint order). Reuses CSE_MAX_PEND sizing semantics.
LICM_MAX_PEND: uint32 = 256
licm_pend_decl: Array[256, uint32]
licm_pend_n: uint32 = 0


# Collect every pure ND_BINARY subtree across a loop-body statement chain into
# the shared cse_cand_* list (pre-order, outermost-first), each with its lowered
# value IR (shared arena, NOT reset per node). Mirrors cse_collect but spans a
# whole statement chain and descends into nested control flow, so a candidate may
# appear in any statement of the body. Statement lvalue targets are NOT lowered
# (they are not r-value expressions). The clobber scan ran first, so we know the
# body is call/addr-free here (giveup == 0).
def licm_collect_body(head: uint32):
    s: uint32 = head
    while s != 0:
        if cse_cand_n >= CSE_MAX_CAND:
            return
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            cse_collect(nd_b[s])
        elif k == ND_VAR_DECL:
            cse_collect(nd_b[s])
        elif k == ND_EXPR_STMT:
            cse_collect(nd_a[s])
        elif k == ND_RETURN:
            cse_collect(nd_a[s])
        elif k == ND_IF:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                cse_collect(nd_a[e])
                licm_collect_body(nd_b[e])
                e = nd_next[e]
            licm_collect_body(nd_d[s])
        elif k == ND_WHILE:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
        elif k == ND_DO_WHILE:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
        elif k == ND_FOR:
            cse_collect(nd_a[s])
            licm_collect_body(nd_b[s])
        elif k == ND_FOR_UNPACK:
            cse_collect(nd_b[s])
            licm_collect_body(nd_c[s])
        s = nd_next[s]


# Rewrite EVERY occurrence in the whole body whose value-IR equals `proto_ir`
# into an ND_IDENT(off,len). Same shape as cse_apply but the candidate list now
# spans the whole loop body. Returns the rewritten count.
def licm_apply(proto_ir: uint32, off: uint32, len_: uint32) -> uint32:
    n: uint32 = 0
    i: uint32 = 0
    while i < cse_cand_n:
        ast: uint32 = cse_cand_ast[i]
        if ast != 0 and nd_kind[ast] == ND_BINARY:
            if ir_value_eq(cse_cand_ir[i], proto_ir) != 0:
                cse_kill_descendants(ast)
                cse_rewrite_to_ident(ast, off, len_)
                cse_cand_ast[i] = 0
                n = n + 1
        i = i + 1
    return n


# Hoist every loop-invariant pure expression that occurs in the body of the loop
# node `loop`. The loop body chain is on nd_b for ND_WHILE/ND_DO_WHILE/ND_FOR.
# Returns the list of pre-header decls via licm_pend_* (caller splices them
# before the loop). The body's in-loop occurrences are rewritten to read temps.
def licm_hoist_loop(loop: uint32):
    body: uint32 = nd_b[loop]
    if body == 0:
        return
    licm_pend_n = 0
    # 1) Clobber analysis over the whole body.
    licm_clob_reset()
    licm_collect_clobbers(body)
    if licm_giveup != 0:
        return                 # call / addr-of / opaque store: hoist nothing
    # 2) Collect pure-binop candidates across the whole body into a shared arena.
    cse_cand_n = 0
    ir_reset()
    licm_collect_body(body)
    # 3) For each candidate (outermost-first), if it is loop-invariant, hoist it
    #    to a pre-header temp and rewrite all its occurrences. cse_apply's
    #    nested-invalidation prevents re-hoisting a sub-part of a hoisted expr.
    i: uint32 = 0
    while i < cse_cand_n:
        ast_i: uint32 = cse_cand_ast[i]
        if ast_i != 0 and nd_kind[ast_i] == ND_BINARY:
            vi: uint32 = cse_cand_ir[i]
            if licm_ir_invariant(vi) != 0:
                # Mint a temp, snapshot the defining expression as a clone so the
                # in-place rewrite of occurrences doesn't disturb the decl init.
                cse_mint_temp_name()
                toff: uint32 = opt_tmp_name_off
                tlen: uint32 = opt_tmp_name_len
                clone: uint32 = cse_clone_expr(ast_i)
                if clone == 0:
                    return
                d: uint32 = cse_make_temp_decl(toff, tlen, clone)
                if d == 0:
                    return
                cnt: uint32 = licm_apply(vi, toff, tlen)
                if cnt >= 1:
                    if licm_pend_n < LICM_MAX_PEND:
                        licm_pend_decl[licm_pend_n] = d
                        licm_pend_n = licm_pend_n + 1
                    opt_licm_count = opt_licm_count + 1
        i = i + 1


# Walk a statement chain; for each loop, recurse into its body FIRST (innermost-
# first, so a nested loop gets its own pre-header), then hoist the loop's
# invariant expressions into a pre-header decl chain spliced immediately BEFORE
# the loop. Returns the (possibly new) chain head. Mirrors cse_block's splice
# bookkeeping.
def licm_block(head: uint32) -> uint32:
    new_head: uint32 = head
    prev: uint32 = 0
    s: uint32 = head
    while s != 0:
        nxt: uint32 = nd_next[s]
        k: uint32 = nd_kind[s]
        # Recurse into nested blocks FIRST so inner loops are processed before
        # the enclosing one (innermost pre-headers placed first).
        if k == ND_IF:
            nd_b[s] = licm_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                nd_b[e] = licm_block(nd_b[e])
                e = nd_next[e]
            nd_d[s] = licm_block(nd_d[s])
        elif k == ND_WHILE:
            nd_b[s] = licm_block(nd_b[s])
        elif k == ND_DO_WHILE:
            nd_b[s] = licm_block(nd_b[s])
        elif k == ND_FOR:
            nd_b[s] = licm_block(nd_b[s])
        # Hoist this loop's invariants into a pre-header spliced before it.
        if k == ND_WHILE or k == ND_DO_WHILE or k == ND_FOR:
            licm_hoist_loop(s)
            if licm_pend_n > 0:
                pi: uint32 = 0
                while pi < licm_pend_n:
                    d: uint32 = licm_pend_decl[pi]
                    if prev == 0:
                        new_head = d
                    else:
                        nd_next[prev] = d
                    nd_next[d] = s
                    prev = d
                    pi = pi + 1
        prev = s
        s = nxt
    return new_head


def opt_licm_function(fn: uint32):
    # The function body chain hangs off nd_c (ND_FUNCTION: c = body chain head).
    nd_c[fn] = licm_block(nd_c[fn])

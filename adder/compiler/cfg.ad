# adder/compiler/cfg.ad
#
# Native Adder optimizer — Phase 4 GROUNDWORK: whole-function CFG / basic-block
# IR + backward-dataflow liveness analysis + a structural self-validator.
#
# WHAT THIS IS (and is NOT)
# -------------------------
# Phases 1-3 (ir.ad/opt.ad) operate on PER-EXPRESSION / PER-STATEMENT IR
# snippets: const-fold collapses a constant subtree, CSE numbers one statement's
# pure expression, LICM scans one loop body. None of them have a WHOLE-FUNCTION
# control-flow view, and none of them have liveness. A register allocator (the
# big "parity-of-C" Phase-4 win) needs BOTH: a control-flow graph of basic
# blocks and per-program-point live sets to know which values are simultaneously
# live (so it can color them onto a finite register file).
#
# This file builds exactly that ANALYSIS INFRASTRUCTURE and NOTHING ELSE:
#   1. ast->CFG lowering: a whole function body is lowered into a graph of basic
#      blocks (straight-line instruction runs terminated by a branch/jump/ret),
#      with successor/predecessor edges, covering if/elif/else, while, for,
#      do-while, return, break, continue.
#   2. liveness: standard backward dataflow (live-in/live-out per block from the
#      use/def sets + successor fixpoint), the input a future allocator consumes.
#   3. a self-validator: builds the CFG+liveness and asserts structural
#      invariants (every block has a terminator; every edge endpoint exists;
#      liveness reaches a fixpoint; no use-before-def of a non-live-in value
#      within a block). The fuzzer runs this over the corpus as a NON-codegen-
#      affecting lane.
#
# HARD INVARIANT — THIS CANNOT CHANGE CODEGEN OUTPUT
#   This module is PURE ANALYSIS. It NEVER mutates the AST (unlike opt.ad's
#   fold/CSE/LICM which rewrite nodes in place). It only READS nd_* arrays and
#   writes its OWN private arena (bb_*, ci_*, live_*). Nothing on the default
#   AST->codegen path calls anything here; it is reachable ONLY via the dump
#   driver's --dump-cfg mode and the fuzzer's CFG lane. With that flag absent
#   the module is never entered and codegen output is byte-for-byte unchanged.
#
# DESIGN — instruction model for liveness
#   A future allocator needs def/use sets per program point. We do NOT need a
#   full value-level IR for that (Phases 1-3 already model values); we need the
#   NAME-level def/use of each statement, threaded through the CFG. So a CFG
#   "instruction" (ci_*) is a thin record:
#       ci_def      : the identifier name DEFINED here (0-len if none), and
#       ci_use[0..]  : the identifier names USED (read) here.
#   That is precisely the granularity liveness consumes: a variable is live at a
#   point if it MAY be read before its next write. Modelling names (not SSA
#   values) keeps the lowering total over the whole language subset and provably
#   side-effect-free. Expression structure within a statement is irrelevant to
#   block-level liveness, so we flatten an expression to the SET of identifier
#   names it reads.
#
# WHAT THE LOWERING COVERS vs SKIPS (documented for the Phase-4 handoff)
#   COVERS (structural control flow + name-level def/use):
#     * straight-line statements: var-decl, assign (plain + augmented), expr-stmt
#     * return (terminates the block; edge to the function EXIT block)
#     * if / elif-chain / else  (cond block -> then/else successors -> join)
#     * while            (header cond -> body / exit; body back-edge to header)
#     * do-while         (body -> cond -> body back-edge / exit)
#     * for / for-unpack (header -> body / exit; induction var def in header)
#     * break            (edge to the nearest enclosing loop EXIT block)
#     * continue         (edge to the nearest enclosing loop CONTINUE target)
#   USE/DEF extraction:
#     * an ND_IDENT read anywhere in an r-value expression  -> a USE
#     * an assign/var-decl/for-induction target ident       -> a DEF
#     * a CALL or address-of is recorded as a USE of its ident operands but does
#       NOT (in this groundwork) model the may-clobber-through-pointer effect a
#       real allocator's alias analysis would need (see SKIPS).
#   SKIPS (documented limitations — these are the gaps before regalloc):
#     * NO alias / may-clobber modelling for stores through index/member/deref
#       or through a call; those are treated as plain uses of their ident
#       operands. Liveness is therefore SOUND for register candidates that are
#       never address-taken (the only ones a first allocator would color), but a
#       real allocator must add this before trusting liveness for address-taken
#       storage. The validator does NOT assert anything that this gap could
#       violate.
#     * NO SSA / phi nodes — liveness here is the classic non-SSA name dataflow.
#       A future allocator can either color directly on this or build SSA on top.
#     * match/try/with/defer/yield/raise statements are lowered as straight-line
#       instructions in the current block (their nested bodies' control flow is
#       NOT modelled). They are outside the fuzzer/seed subset codegen accepts,
#       so they never appear in the corpus; the lowering stays total by treating
#       them as opaque side-effecting instructions (use-scan their child slots).
#     * nested expression evaluation ORDER is not modelled (irrelevant to
#       block-level liveness); only the name SET matters.

from compiler.parser import (
    nd_kind,
    nd_aux,
    nd_num,
    nd_name_off,
    nd_name_len,
    nd_a,
    nd_b,
    nd_c,
    nd_d,
    nd_next,
    ND_IDENT,
    ND_INT_LIT,
    ND_BINARY,
    ND_UNARY,
    ND_CALL,
    ND_METHOD_CALL,
    ND_INDEX,
    ND_MEMBER,
    UNOP_ADDR,
    UNOP_DEREF,
    ND_VAR_DECL,
    ND_ASSIGN,
    ND_EXPR_STMT,
    ND_RETURN,
    ND_IF,
    ND_ELIF,
    ND_WHILE,
    ND_DO_WHILE,
    ND_FOR,
    ND_FOR_UNPACK,
    ND_BREAK,
    ND_CONTINUE,
    ND_FUNCTION,
)

from compiler.lexer import (
    strbuf,
)

from compiler.ir import (
    ir_name_eq,
)

# =======================================================================
# Name table — interned identifier names referenced by CFG instructions.
# =======================================================================
#
# Liveness operates over a finite set of variable names. We intern each distinct
# (off,len) name into a dense small integer (a "name id") so block live sets can
# be fixed-width bitsets indexed by name id. Interning is per-function (reset by
# cfg_reset). The bitset width caps the distinct locals a function may have for
# the analysis; overflow is reported (cfg_overflow) and the validator treats an
# overflowed function as skipped, never as a failure.

NM_MAX: uint32 = 256                  # max distinct names per function
nm_off: Array[256, uint32]
nm_len: Array[256, uint32]
nm_count: uint32 = 0


def nm_reset():
    nm_count = 0
    i: uint32 = 0
    while i < NM_MAX:
        nm_trunc[i] = 0
        i = i + 1


# Intern a name; returns its id, or NM_MAX on overflow (caller checks).
def nm_intern(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < nm_count:
        if ir_name_eq(nm_off[i], nm_len[i], off, len_) != 0:
            return i
        i = i + 1
    if nm_count >= NM_MAX:
        return NM_MAX
    id: uint32 = nm_count
    nm_off[id] = off
    nm_len[id] = len_
    nm_count = nm_count + 1
    return id


# =======================================================================
# CFG instruction pool — flat array; each BB owns a contiguous [start,start+n).
# =======================================================================
#
# An instruction records the name DEFINED (ci_def, NM_NONE if none) and a small
# vector of name ids USED. Uses beyond CI_MAX_USE are dropped conservatively for
# liveness soundness we OR all uses into the block use-set anyway, but the
# per-instruction record caps the vector for the use-before-def validator scan.

NM_NONE: uint32 = 0x7fffffff          # sentinel: no name id

CI_MAX: uint32 = 16384
# CI_MAX_USE caps the per-instruction DISTINCT-name use vector. A single source
# statement can name many DISTINCT locals — e.g. a matmul dot-product update
# `s = s + A[i*N+k] * B[k*N+j]` references s,A,i,N,k,B,j (7 distinct) in ONE
# instruction. ci_add_use now DEDUPLICATES (the same name read twice in a
# statement, like k or N above, takes ONE slot — liveness only needs the SET of
# names live at a point, and lr_cover is idempotent at a fixed ci index), so the
# cap counts distinct names, not textual occurrences. The cap is sized to cover
# realistic complex statements WITHOUT truncating: a truncated use poisons the
# name for register promotion (nm_trunc -> lr_is_promotable == 0), which was
# exactly why the hot matmul IVs (k, j, N) — whose reads overflowed the old
# 6-occurrence cap — were never register-allocated. 16 distinct names per
# statement is well above what real Adder expressions produce. Arena grows to
# CI_MAX * CI_MAX_USE * 4B = 1 MiB (host compiler only; cfg runs solely under
# --opt). A use still dropped past 16 (pathological) is correctly flagged trunc.
CI_MAX_USE: uint32 = 16
ci_def: Array[16384, uint32]          # name id defined (or NM_NONE)
ci_use: Array[262144, uint32]         # CI_MAX * CI_MAX_USE, flattened
ci_nuse: Array[16384, uint32]         # number of valid entries in ci_use row
ci_count: uint32 = 0

# SOUNDNESS for a register allocator: an instruction records at most CI_MAX_USE
# uses; a use DROPPED past the cap is invisible to liveness, so any name so
# dropped has an UNDER-approximated live range (it may be read at a point the
# range does not cover). Such a name MUST NOT be register-promoted — the
# allocator would wrongly reuse its register. We track every truncated name in
# nm_trunc; lr_is_promotable excludes it. (Block liveness/validator are
# unaffected — they were always a conservative over-approximation for the names
# they DO see, and the validator only asserts use-before-def over recorded uses.)
nm_trunc: Array[256, uint32]          # 1 => some use of this name was dropped

# SLOT-READ set (store-through-elimination soundness). A promoted plain scalar's
# stack slot can be DROPPED (no write-through store) ONLY if EVERY read of the
# value routes through the register hook (gen_ident / store_to_named). codegen
# leaves a few read paths on the MEMORY slot, bypassing that hook, for a NAMED
# scalar local:
#   * the BASE of an index expression `p[i]` (a uint64-as-pointer "scalar_ptr"
#     base; gen_index_address loads the slot via emit_load_local_rax),
#   * a for-loop / for-unpack INDUCTION variable (emit_load_for_var reads the
#     slot directly),
#   * a LOCAL function-pointer CALLEE `f()` (gen_call loads the slot for the
#     indirect target).
# Any name used in ANY of these ways is marked nm_slotread; lr_is_store_elim
# keeps it WRITE-THROUGH (slot stays authoritative) even when promoted, so the
# bypass read never observes a stale slot. Built by the same whole-AST walk as
# the clobber set (sr_mark, in cl_scan_*). Conservative by construction: a name
# is store-eliminable only when NO slot-reading use of it exists anywhere.
nm_slotread: Array[256, uint32]       # 1 => some use reads this name's SLOT directly

# =======================================================================
# SPILL-COST analysis (P3 register-pressure track) — loop-depth-weighted use
# count per name, plus a whole-function "makes a call" flag. Pure bookkeeping,
# accumulated during lowering; consumed ONLY by the regalloc spill heuristic and
# caller-saved pool expansion (both run only under --opt). Flag-off codegen
# never reads these, so default output stays byte-identical.
#
# nm_usecost[n] = sum over every def/use of n of (1 << min(loop_depth, CAP)).
#   A use inside a depth-2 loop counts 4×; a one-shot use outside loops counts
#   1×. The linear-scan spill victim is the LIVE value with the LOWEST usecost
#   (cheapest to leave in memory), so a loop-carried accumulator (huge cost)
#   beats a short-lived straight-line temp for a register — the standard
#   spill-cost heuristic. Saturated to avoid overflow on deep nests.
NM_COST_DEPTH_CAP: uint32 = 8         # weight saturates at 1<<8 per ref
nm_usecost: Array[256, uint32]        # NM_MAX: loop-weighted def+use count

# Whole-function call flag: set if lowering scans ANY ND_CALL / ND_METHOD_CALL
# in the function body. When 0, no `call` is emitted anywhere in the function,
# so caller-saved registers are never clobbered by a callee and the allocator
# may use them for the whole function with NO save/restore — the conservative
# correctness gate for the caller-saved pool expansion. When 1 (or uncertain),
# the allocator stays on callee-saved only.
cfg_fn_has_call: uint32 = 0


def nm_cost_reset():
    n: uint32 = 0
    while n < NM_MAX:
        nm_usecost[n] = 0
        n = n + 1
    cfg_fn_has_call = 0


# Weight for a reference at the current loop depth: 1 << min(depth, CAP).
def nm_cost_weight() -> uint32:
    d: uint32 = cfg_loop_depth
    if d > NM_COST_DEPTH_CAP:
        d = NM_COST_DEPTH_CAP
    return cast[uint32](1) << d


# Add the current-loop-depth weight to name n's spill cost (saturating).
def nm_cost_bump(n: uint32):
    if n >= NM_MAX:
        return
    w: uint32 = nm_cost_weight()
    c: uint32 = nm_usecost[n] + w
    if c < nm_usecost[n]:
        c = 0xffffffff                # saturate on wrap
    nm_usecost[n] = c

# STMT-NODE -> PROGRAM-POINT MAP (for the IR-scratch borrow path in codegen).
# Each ci instruction records the AST STATEMENT node that produced it (or 0). The
# stamp comes from cfg_cur_stmt_node, set by cfg_lower_stmt before it emits the
# statement's instruction(s). codegen, while emitting a statement, asks for the
# FIRST ci index that statement owns (lr_stmt_point) to get a conservative
# program point, then checks whether a regalloc-promoted local is already DEAD
# there (so its callee-saved register can be borrowed as an IR scratch). This is
# pure analysis bookkeeping — it never changes liveness or the CFG shape, so the
# default (flag-off) codegen output is unaffected.
ci_node: Array[16384, uint32]         # CI_MAX: AST stmt node owning this ci (0 = none)
cfg_cur_stmt_node: uint32 = 0         # statement node currently being lowered


def ci_reset():
    ci_count = 0
    cfg_cur_stmt_node = 0


# Allocate a fresh instruction with the given def name id; returns its index, or
# CI_MAX on overflow.
def ci_new(defid: uint32) -> uint32:
    if ci_count >= CI_MAX:
        return CI_MAX
    id: uint32 = ci_count
    ci_count = ci_count + 1
    ci_def[id] = defid
    ci_nuse[id] = 0
    ci_node[id] = cfg_cur_stmt_node
    return id


def ci_add_use(id: uint32, useid: uint32):
    if useid == NM_NONE or useid >= NM_MAX:
        return
    n: uint32 = ci_nuse[id]
    # DEDUP: liveness only needs the SET of names used at this instruction, and
    # lr_cover(useid, ins) is idempotent at a fixed ci index, so a name read more
    # than once in the same statement (e.g. k and N in s = s + A[i*N+k]*B[k*N+j])
    # takes ONE slot. This both keeps the use vector under CI_MAX_USE for realistic
    # complex statements (so the hot IVs are NOT poisoned by truncation) and is
    # strictly sound — no recorded use is lost, only a redundant duplicate skipped.
    j: uint32 = 0
    while j < n:
        if ci_use[id * CI_MAX_USE + j] == useid:
            return                       # already recorded for this instruction
        j = j + 1
    if n >= CI_MAX_USE:
        # use vector full: this read is invisible to liveness => the name's live
        # range is under-approximated. Flag it non-promotable for the allocator.
        nm_trunc[useid] = 1
        return
    ci_use[id * CI_MAX_USE + n] = useid
    ci_nuse[id] = n + 1


# =======================================================================
# Basic blocks — straight-line instruction run + up to two successors.
# =======================================================================
#
# Every block has a TERMINATOR (modeled implicitly: a block with bb_succ_n
# successors and a terminator kind). The function has a synthetic ENTRY block
# (bb 0 after reset's first alloc) and a synthetic EXIT block; every return / a
# fallthrough off the last block targets EXIT. A block's instruction range is
# [bb_first, bb_first+bb_ninstr).

# Terminator kinds (documentation/validation only; structure is in bb_succ_*).
BBT_NONE: uint32 = 0          # not yet terminated (invalid at validate time)
BBT_FALL: uint32 = 1          # unconditional fallthrough/jump (1 succ)
BBT_COND: uint32 = 2          # conditional branch (2 succ: taken, not-taken)
BBT_RET: uint32 = 3           # return (1 succ: the EXIT block)
BBT_EXIT: uint32 = 4          # the unique EXIT block (0 succ; valid terminator)

BB_MAX: uint32 = 8192
bb_first: Array[8192, uint32]         # first instruction index
bb_first_set: Array[8192, uint32]     # 1 once bb_first pinned to a real instr
bb_ninstr: Array[8192, uint32]        # instruction count
bb_term: Array[8192, uint32]          # BBT_*
bb_succ0: Array[8192, uint32]         # successor block id (or BB_NONE)
bb_succ1: Array[8192, uint32]
bb_succ_n: Array[8192, uint32]        # 0/1/2
bb_count: uint32 = 0

BB_NONE: uint32 = 0xffffffff

# The synthetic EXIT block id for the current function.
cfg_exit_bb: uint32 = 0

# Overflow flag: set if any arena (names/instrs/blocks) filled. An overflowed
# function is reported and SKIPPED by the validator (never counted a failure).
cfg_overflow: uint32 = 0


def bb_new() -> uint32:
    if bb_count >= BB_MAX:
        cfg_overflow = 1
        return BB_NONE
    id: uint32 = bb_count
    bb_count = bb_count + 1
    # bb_first is pinned LAZILY to the index of the block's FIRST appended
    # instruction (see bb_note_instr). A block can be CREATED before it is
    # FILLED (e.g. a while's exit_bb is allocated before the loop body lowers,
    # but only receives the post-loop continuation afterwards). Snapshotting
    # ci_count at creation time would mis-place the block's [first,first+ninstr)
    # span INTO the body's instructions, corrupting the linear program-point
    # numbering live ranges depend on. The provisional value below is only used
    # if the block stays empty (no instructions ever appended).
    bb_first[id] = ci_count
    bb_first_set[id] = 0
    bb_ninstr[id] = 0
    bb_term[id] = BBT_NONE
    bb_succ0[id] = BB_NONE
    bb_succ1[id] = BB_NONE
    bb_succ_n[id] = 0
    return id


# Append the just-allocated instruction (the most recent ci_new) to block `bb`.
# Instructions are emitted into the flat pool in block order, so a block's
# instruction range stays contiguous as long as we finish a block before
# starting the next. The lowering guarantees that ordering.
def bb_note_instr(bb: uint32):
    if bb == BB_NONE:
        return
    # Pin bb_first to this block's FIRST real instruction. ci_new was just
    # called (the instruction being appended is at ci_count - 1), and a block's
    # instructions are emitted CONTIGUOUSLY in the flat pool, so this index is
    # the true low bound of [first, first+ninstr).
    if bb_first_set[bb] == 0:
        bb_first[bb] = ci_count - 1
        bb_first_set[bb] = 1
    bb_ninstr[bb] = bb_ninstr[bb] + 1


def bb_set_term1(bb: uint32, term: uint32, s0: uint32):
    if bb == BB_NONE:
        return
    bb_term[bb] = term
    bb_succ0[bb] = s0
    bb_succ_n[bb] = 1


def bb_set_term2(bb: uint32, term: uint32, s0: uint32, s1: uint32):
    if bb == BB_NONE:
        return
    bb_term[bb] = term
    bb_succ0[bb] = s0
    bb_succ1[bb] = s1
    bb_succ_n[bb] = 2


def cfg_reset():
    nm_reset()
    nm_cost_reset()
    ci_reset()
    bb_count = 0
    cfg_overflow = 0
    cfg_exit_bb = 0


# =======================================================================
# Loop context stack — for break/continue edge targets.
# =======================================================================
#
# break  targets the nearest enclosing loop's EXIT block.
# continue targets the nearest enclosing loop's CONTINUE target (the header for
#          while/for, the cond block for do-while).

LOOP_MAX: uint32 = 256
loop_break_bb: Array[256, uint32]
loop_cont_bb: Array[256, uint32]
cfg_loop_depth: uint32 = 0


def loop_push(break_bb: uint32, cont_bb: uint32):
    if cfg_loop_depth >= LOOP_MAX:
        cfg_overflow = 1
        return
    loop_break_bb[cfg_loop_depth] = break_bb
    loop_cont_bb[cfg_loop_depth] = cont_bb
    cfg_loop_depth = cfg_loop_depth + 1


def loop_pop():
    if cfg_loop_depth > 0:
        cfg_loop_depth = cfg_loop_depth - 1


# =======================================================================
# Use/def extraction from an expression subtree.
# =======================================================================
#
# Scan an r-value expression and add every ND_IDENT read it contains as a USE of
# the instruction `ci`. This is a conservative over-approximation: it visits ALL
# child slots, so it catches idents nested under casts, calls, index, member,
# unary, conditional, etc. Literals/types contribute no uses.
def cfg_scan_uses(ci: uint32, node: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_INT_LIT:
        return
    if k == ND_CALL or k == ND_METHOD_CALL:
        # A call site exists in this function => caller-saved registers can be
        # clobbered across it; the allocator must stay callee-saved-only.
        cfg_fn_has_call = 1
        # (fall through to the generic descent so argument idents are counted)
    if k == ND_IDENT:
        nid: uint32 = nm_intern(nd_name_off[node], nd_name_len[node])
        if nid >= NM_MAX:
            cfg_overflow = 1
            return
        ci_add_use(ci, nid)
        nm_cost_bump(nid)             # loop-depth-weighted use cost
        return
    # Generic descent over expression child slots. (We do NOT follow nd_next
    # here: nd_next chains are sibling STATEMENTS / arg-list elements; for an
    # expression operand the relevant arguments hang off a/b/c/d, and an arg
    # CHAIN root is reached via a/b then nd_next of its head — handled below.)
    cfg_scan_uses(ci, nd_a[node])
    cfg_scan_uses(ci, nd_b[node])
    cfg_scan_uses(ci, nd_c[node])
    cfg_scan_uses(ci, nd_d[node])
    # Argument / element chains (calls, list/tuple literals, struct init) hang a
    # CHAIN off a child slot and thread siblings via nd_next. Follow the chain
    # from each child's siblings so call argument idents are counted as uses.
    cfg_scan_use_chain(ci, nd_next[nd_a[node]])
    cfg_scan_use_chain(ci, nd_next[nd_b[node]])


# Follow a sibling chain of expressions, scanning each for uses.
def cfg_scan_use_chain(ci: uint32, head: uint32):
    n: uint32 = head
    while n != 0:
        cfg_scan_uses(ci, n)
        n = nd_next[n]


# =======================================================================
# Statement -> instruction(s) lowering within the CURRENT block.
# =======================================================================
#
# Returns the (possibly new) current block id after the statement. Control-flow
# statements split the current block and create new ones; straight-line
# statements append an instruction and return the same block.

# Emit a straight-line instruction with an optional def name (def_off/def_len,
# def_present) into block `bb`, scanning `use_expr` for uses.
def cfg_emit_stmt(bb: uint32, def_present: uint32, def_off: uint32,
                  def_len: uint32, use_expr: uint32):
    defid: uint32 = NM_NONE
    if def_present != 0:
        d: uint32 = nm_intern(def_off, def_len)
        if d >= NM_MAX:
            cfg_overflow = 1
            return
        defid = d
        nm_cost_bump(d)              # a def-store is a loop-weighted reference
    ci: uint32 = ci_new(defid)
    if ci >= CI_MAX:
        cfg_overflow = 1
        return
    cfg_scan_uses(ci, use_expr)
    bb_note_instr(bb)


# Lower a single statement. `bb` is the current block. Returns the block control
# falls through into after the statement (BB_NONE if control cannot fall through,
# e.g. after return/break/continue — the caller starts an unreachable successor).
def cfg_lower_stmt(bb: uint32, stmt: uint32) -> uint32:
    if bb == BB_NONE:
        return BB_NONE
    # Stamp every ci this statement emits with the statement node, so codegen can
    # map an in-flight statement to its program point (lr_stmt_point). Nested
    # control-flow bodies recurse through cfg_lower_chain -> cfg_lower_stmt and
    # re-stamp with their own node, so a body statement's instructions carry the
    # body node (matching codegen's per-statement cg_cur_stmt), while an if/while
    # condition carries the enclosing if/while node (codegen emits the condition
    # with cg_cur_stmt == that node).
    cfg_cur_stmt_node = stmt
    k: uint32 = nd_kind[stmt]

    if k == ND_VAR_DECL:
        # def = the declared name; uses = the initializer expression.
        cfg_emit_stmt(bb, 1, nd_name_off[stmt], nd_name_len[stmt], nd_b[stmt])
        return bb

    if k == ND_ASSIGN:
        # Plain `x = e`  : def x, uses(e).
        # Augmented `x op= e` (aux != 0): x is BOTH used and defined.
        # Non-ident target (index/member/deref): a STORE — no name def; the
        # target's idents and the value's idents are uses. (Alias effect skipped
        # — see header SKIPS.)
        target: uint32 = nd_a[stmt]
        if nd_kind[target] == ND_IDENT:
            doff: uint32 = nd_name_off[target]
            dlen: uint32 = nd_name_len[target]
            tid: uint32 = nm_intern(doff, dlen)
            if tid >= NM_MAX:
                cfg_overflow = 1
                return bb
            aci: uint32 = ci_new(tid)
            if aci >= CI_MAX:
                cfg_overflow = 1
                return bb
            cfg_scan_uses(aci, nd_b[stmt])
            nm_cost_bump(tid)        # def-store of the assigned name (weighted)
            if nd_aux[stmt] != 0:
                # augmented: target is also read
                ci_add_use(aci, tid)
                nm_cost_bump(tid)    # ...and read (accumulator/IV update)
            bb_note_instr(bb)
        else:
            # store through a non-ident lvalue: an instruction with no def.
            ci2: uint32 = ci_new(NM_NONE)
            if ci2 >= CI_MAX:
                cfg_overflow = 1
                return bb
            cfg_scan_uses(ci2, target)
            cfg_scan_uses(ci2, nd_b[stmt])
            bb_note_instr(bb)
        return bb

    if k == ND_EXPR_STMT:
        cfg_emit_stmt(bb, 0, 0, 0, nd_a[stmt])
        return bb

    if k == ND_RETURN:
        # uses = the returned expression; terminates with an edge to EXIT.
        ci: uint32 = ci_new(NM_NONE)
        if ci >= CI_MAX:
            cfg_overflow = 1
            return BB_NONE
        cfg_scan_uses(ci, nd_a[stmt])
        bb_note_instr(bb)
        bb_set_term1(bb, BBT_RET, cfg_exit_bb)
        return BB_NONE

    if k == ND_BREAK:
        if cfg_loop_depth > 0:
            bb_set_term1(bb, BBT_FALL, loop_break_bb[cfg_loop_depth - 1])
        else:
            bb_set_term1(bb, BBT_FALL, cfg_exit_bb)
        return BB_NONE

    if k == ND_CONTINUE:
        if cfg_loop_depth > 0:
            bb_set_term1(bb, BBT_FALL, loop_cont_bb[cfg_loop_depth - 1])
        else:
            bb_set_term1(bb, BBT_FALL, cfg_exit_bb)
        return BB_NONE

    if k == ND_IF:
        return cfg_lower_if(bb, stmt)

    if k == ND_WHILE:
        return cfg_lower_while(bb, stmt)

    if k == ND_DO_WHILE:
        return cfg_lower_do_while(bb, stmt)

    if k == ND_FOR:
        return cfg_lower_for(bb, stmt, 1)

    if k == ND_FOR_UNPACK:
        return cfg_lower_for(bb, stmt, 0)

    # Opaque side-effecting statement (match/try/with/defer/yield/raise/pass/
    # global/etc.). Treat as a straight-line instruction; scan its child slots
    # for uses so liveness stays a conservative over-approximation. Its nested
    # control flow is NOT modeled (documented SKIP; outside the codegen subset).
    ci3: uint32 = ci_new(NM_NONE)
    if ci3 >= CI_MAX:
        cfg_overflow = 1
        return bb
    cfg_scan_uses(ci3, nd_a[stmt])
    cfg_scan_uses(ci3, nd_b[stmt])
    cfg_scan_uses(ci3, nd_c[stmt])
    cfg_scan_uses(ci3, nd_d[stmt])
    bb_note_instr(bb)
    return bb


# Lower a statement chain (a block body) into the CFG, threading the current
# block. Returns the fallthrough block after the chain (BB_NONE if control
# cannot fall through it).
def cfg_lower_chain(bb: uint32, head: uint32) -> uint32:
    cur: uint32 = bb
    s: uint32 = head
    while s != 0:
        if cur == BB_NONE:
            # Unreachable code after a return/break/continue. Start a fresh
            # (unreachable but well-formed) block so the remaining statements
            # still lower into a terminated block — keeps the invariant that
            # every block has a terminator.
            cur = bb_new()
            if cur == BB_NONE:
                return BB_NONE
        cur = cfg_lower_stmt(cur, s)
        s = nd_next[s]
    return cur


# --- if / elif / else ---------------------------------------------------
#
# cond block (the current bb) conditionally branches to the THEN entry and the
# next alternative (elif cond / else / join). Each arm's tail falls through to a
# shared JOIN block.
def cfg_lower_if(bb: uint32, stmt: uint32) -> uint32:
    # uses of the condition live in the current block as a cond instruction.
    cci: uint32 = ci_new(NM_NONE)
    if cci >= CI_MAX:
        cfg_overflow = 1
        return bb
    cfg_scan_uses(cci, nd_a[stmt])
    bb_note_instr(bb)

    join: uint32 = bb_new()
    if join == BB_NONE:
        return BB_NONE

    # THEN arm.
    then_bb: uint32 = bb_new()
    if then_bb == BB_NONE:
        return BB_NONE
    then_tail: uint32 = cfg_lower_chain(then_bb, nd_b[stmt])
    if then_tail != BB_NONE:
        bb_set_term1(then_tail, BBT_FALL, join)

    # The "else" path of this cond: the first elif's cond block, or the else
    # body, or the join directly.
    else_entry: uint32 = cfg_lower_if_alts(nd_c[stmt], nd_d[stmt], join)
    if else_entry == BB_NONE:
        return BB_NONE

    bb_set_term2(bb, BBT_COND, then_bb, else_entry)
    return join


# Lower the elif chain + final else into blocks that all converge on `join`.
# Returns the entry block of the alternative path (a cond block for the first
# elif, the else body's entry, or `join` if neither exists).
def cfg_lower_if_alts(elif_head: uint32, else_head: uint32,
                      join: uint32) -> uint32:
    if elif_head != 0:
        # This elif gets its own cond block.
        cond_bb: uint32 = bb_new()
        if cond_bb == BB_NONE:
            return BB_NONE
        cci: uint32 = ci_new(NM_NONE)
        if cci >= CI_MAX:
            cfg_overflow = 1
            return cond_bb
        cfg_scan_uses(cci, nd_a[elif_head])
        bb_note_instr(cond_bb)

        body_bb: uint32 = bb_new()
        if body_bb == BB_NONE:
            return BB_NONE
        body_tail: uint32 = cfg_lower_chain(body_bb, nd_b[elif_head])
        if body_tail != BB_NONE:
            bb_set_term1(body_tail, BBT_FALL, join)

        nxt_alt: uint32 = cfg_lower_if_alts(nd_next[elif_head], else_head, join)
        if nxt_alt == BB_NONE:
            return BB_NONE
        bb_set_term2(cond_bb, BBT_COND, body_bb, nxt_alt)
        return cond_bb

    if else_head != 0:
        else_bb: uint32 = bb_new()
        if else_bb == BB_NONE:
            return BB_NONE
        else_tail: uint32 = cfg_lower_chain(else_bb, else_head)
        if else_tail != BB_NONE:
            bb_set_term1(else_tail, BBT_FALL, join)
        return else_bb

    # No elif, no else: the alternative path is the join itself.
    return join


# --- while --------------------------------------------------------------
#
# header(cond) --cond--> body / exit ; body tail --> back to header.
def cfg_lower_while(bb: uint32, stmt: uint32) -> uint32:
    header: uint32 = bb_new()
    if header == BB_NONE:
        return BB_NONE
    bb_set_term1(bb, BBT_FALL, header)

    cci: uint32 = ci_new(NM_NONE)
    if cci >= CI_MAX:
        cfg_overflow = 1
        return BB_NONE
    cfg_scan_uses(cci, nd_a[stmt])
    bb_note_instr(header)

    exit_bb: uint32 = bb_new()
    if exit_bb == BB_NONE:
        return BB_NONE
    body_bb: uint32 = bb_new()
    if body_bb == BB_NONE:
        return BB_NONE

    bb_set_term2(header, BBT_COND, body_bb, exit_bb)

    loop_push(exit_bb, header)
    body_tail: uint32 = cfg_lower_chain(body_bb, nd_b[stmt])
    loop_pop()
    if body_tail != BB_NONE:
        bb_set_term1(body_tail, BBT_FALL, header)
    return exit_bb


# --- do-while -----------------------------------------------------------
#
# body --> cond ; cond --cond--> body(back-edge) / exit.
def cfg_lower_do_while(bb: uint32, stmt: uint32) -> uint32:
    body_bb: uint32 = bb_new()
    if body_bb == BB_NONE:
        return BB_NONE
    bb_set_term1(bb, BBT_FALL, body_bb)

    cond_bb: uint32 = bb_new()
    if cond_bb == BB_NONE:
        return BB_NONE
    exit_bb: uint32 = bb_new()
    if exit_bb == BB_NONE:
        return BB_NONE

    loop_push(exit_bb, cond_bb)
    body_tail: uint32 = cfg_lower_chain(body_bb, nd_b[stmt])
    loop_pop()
    if body_tail != BB_NONE:
        bb_set_term1(body_tail, BBT_FALL, cond_bb)

    cci: uint32 = ci_new(NM_NONE)
    if cci >= CI_MAX:
        cfg_overflow = 1
        return BB_NONE
    cfg_scan_uses(cci, nd_a[stmt])
    bb_note_instr(cond_bb)
    bb_set_term2(cond_bb, BBT_COND, body_bb, exit_bb)
    return exit_bb


# --- for / for-unpack ---------------------------------------------------
#
# Modeled like a while with an induction-variable DEF in the header. The
# iterable's uses also live in the header. `simple` distinguishes ND_FOR (single
# name var) from ND_FOR_UNPACK (a chain of target idents on nd_a).
def cfg_lower_for(bb: uint32, stmt: uint32, simple: uint32) -> uint32:
    header: uint32 = bb_new()
    if header == BB_NONE:
        return BB_NONE
    bb_set_term1(bb, BBT_FALL, header)

    body_node: uint32 = 0
    if simple != 0:
        # ND_FOR: name = induction var (def), a = iterable (uses), b = body.
        ci: uint32 = ci_new(nm_intern(nd_name_off[stmt], nd_name_len[stmt]))
        if ci >= CI_MAX:
            cfg_overflow = 1
            return BB_NONE
        cfg_scan_uses(ci, nd_a[stmt])
        bb_note_instr(header)
        body_node = nd_b[stmt]
    else:
        # ND_FOR_UNPACK: a = head var-ident chain (defs), b = iterable, c = body.
        # Emit one def instruction per target ident, plus the iterable uses on
        # the first.
        ci2: uint32 = ci_new(NM_NONE)
        if ci2 >= CI_MAX:
            cfg_overflow = 1
            return BB_NONE
        cfg_scan_uses(ci2, nd_b[stmt])
        bb_note_instr(header)
        v: uint32 = nd_a[stmt]
        while v != 0:
            if nd_kind[v] == ND_IDENT:
                dci: uint32 = ci_new(nm_intern(nd_name_off[v], nd_name_len[v]))
                if dci >= CI_MAX:
                    cfg_overflow = 1
                    return BB_NONE
                bb_note_instr(header)
            v = nd_next[v]
        body_node = nd_c[stmt]

    exit_bb: uint32 = bb_new()
    if exit_bb == BB_NONE:
        return BB_NONE
    body_bb: uint32 = bb_new()
    if body_bb == BB_NONE:
        return BB_NONE

    bb_set_term2(header, BBT_COND, body_bb, exit_bb)

    loop_push(exit_bb, header)
    body_tail: uint32 = cfg_lower_chain(body_bb, body_node)
    loop_pop()
    if body_tail != BB_NONE:
        bb_set_term1(body_tail, BBT_FALL, header)
    return exit_bb


# =======================================================================
# Whole-function CFG build.
# =======================================================================
#
# Builds the CFG for one ND_FUNCTION. Layout: ENTRY block (0) holds the function
# parameters as DEFs, then the body lowers; a synthetic EXIT block (allocated
# right after ENTRY) is the sink every return / final fallthrough targets.
# Returns 1 on success, 0 on overflow (function too large for the fixed arenas;
# reported, not a failure).
def cfg_build_function(fn: uint32) -> uint32:
    cfg_reset()
    cfg_loop_depth = 0

    entry: uint32 = bb_new()           # block 0
    if entry == BB_NONE:
        return 0
    cfg_exit_bb = bb_new()             # block 1 = EXIT sink
    if cfg_exit_bb == BB_NONE:
        return 0
    bb_term[cfg_exit_bb] = BBT_EXIT
    bb_succ_n[cfg_exit_bb] = 0

    # Parameters are defs in the entry block (ND_FUNCTION: a = head param chain).
    p: uint32 = nd_a[fn]
    while p != 0:
        # ND_PARAM: name = param name.
        pid: uint32 = nm_intern(nd_name_off[p], nd_name_len[p])
        if pid >= NM_MAX:
            cfg_overflow = 1
        else:
            ci: uint32 = ci_new(pid)
            if ci >= CI_MAX:
                cfg_overflow = 1
            else:
                bb_note_instr(entry)
        p = nd_next[p]

    # Lower the body (ND_FUNCTION: c = body chain head).
    tail: uint32 = cfg_lower_chain(entry, nd_c[fn])
    if tail != BB_NONE:
        bb_set_term1(tail, BBT_FALL, cfg_exit_bb)

    if cfg_overflow != 0:
        return 0
    return 1


# =======================================================================
# Liveness — backward dataflow over the CFG.
# =======================================================================
#
# Per block we need use[B] (names read before any def in B) and def[B] (names
# defined in B). Then:
#   live_out[B] = union over succ S of live_in[S]
#   live_in[B]  = use[B] U (live_out[B] - def[B])
# iterated to a fixpoint (monotone, so it converges). Sets are bitsets of width
# NM_MAX over name ids, stored as uint32 words (NM_MAX/32 = 8 words per block).

LV_WORDS: uint32 = 8                   # NM_MAX(256)/32
lv_use: Array[65536, uint32]           # BB_MAX * LV_WORDS  (8192*8)
lv_def: Array[65536, uint32]
lv_in: Array[65536, uint32]
lv_out: Array[65536, uint32]


# Bit accessors. Adder does not pass Array-typed parameters by reference, so we
# select the target bitset array by a small selector code rather than passing
# the array itself. The four per-block bitsets are: 0=use 1=def 2=in 3=out.
LVS_USE: uint32 = 0
LVS_DEF: uint32 = 1
LVS_IN: uint32 = 2
LVS_OUT: uint32 = 3


def lv_get(sel: uint32, bb: uint32, nid: uint32) -> uint32:
    w: uint32 = bb * LV_WORDS + (nid >> 5)
    if sel == LVS_USE:
        return (lv_use[w] >> (nid & 31)) & 1
    if sel == LVS_DEF:
        return (lv_def[w] >> (nid & 31)) & 1
    if sel == LVS_IN:
        return (lv_in[w] >> (nid & 31)) & 1
    return (lv_out[w] >> (nid & 31)) & 1


def lv_set(sel: uint32, bb: uint32, nid: uint32):
    w: uint32 = bb * LV_WORDS + (nid >> 5)
    bit: uint32 = cast[uint32](1) << (nid & 31)
    if sel == LVS_USE:
        lv_use[w] = lv_use[w] | bit
    elif sel == LVS_DEF:
        lv_def[w] = lv_def[w] | bit
    elif sel == LVS_IN:
        lv_in[w] = lv_in[w] | bit
    else:
        lv_out[w] = lv_out[w] | bit


# Build use[B]/def[B] for every block from its instruction range. A name is in
# use[B] if it is READ before being DEFINED within B (a local recompute of the
# textbook upward-exposed-use set); def[B] is every name defined anywhere in B.
def lv_build_local_sets():
    b: uint32 = 0
    while b < bb_count:
        # zero this block's rows
        w: uint32 = 0
        while w < LV_WORDS:
            idx: uint32 = b * LV_WORDS + w
            lv_use[idx] = 0
            lv_def[idx] = 0
            lv_in[idx] = 0
            lv_out[idx] = 0
            w = w + 1
        # Scan instructions in order. Track "already defined in B" via lv_def as
        # we go: a use whose name is not yet defined in B is upward-exposed.
        i: uint32 = 0
        first: uint32 = bb_first[b]
        n: uint32 = bb_ninstr[b]
        while i < n:
            ins: uint32 = first + i
            # uses first (read happens before the def of the same instruction
            # for plain assigns; augmented assigns already recorded the read as
            # a use, so ordering within the instruction is captured by the use
            # list — a use of a not-yet-defined name is upward-exposed).
            u: uint32 = 0
            nu: uint32 = ci_nuse[ins]
            while u < nu:
                nid: uint32 = ci_use[ins * CI_MAX_USE + u]
                if lv_get(LVS_DEF, b, nid) == 0:
                    lv_set(LVS_USE, b, nid)
                u = u + 1
            d: uint32 = ci_def[ins]
            if d != NM_NONE and d < NM_MAX:
                lv_set(LVS_DEF, b, d)
            i = i + 1
        b = b + 1


# One backward pass: recompute live_out/live_in for every block; return 1 if any
# bit changed (caller iterates until 0 = fixpoint).
def lv_one_pass() -> uint32:
    changed: uint32 = 0
    # iterate blocks in reverse for faster convergence
    bi: uint32 = bb_count
    while bi > 0:
        bi = bi - 1
        b: uint32 = bi
        # live_out[B] = U live_in[succ]
        w: uint32 = 0
        while w < LV_WORDS:
            newout: uint32 = 0
            if bb_succ_n[b] >= 1:
                s0: uint32 = bb_succ0[b]
                if s0 != BB_NONE:
                    newout = newout | lv_in[s0 * LV_WORDS + w]
            if bb_succ_n[b] >= 2:
                s1: uint32 = bb_succ1[b]
                if s1 != BB_NONE:
                    newout = newout | lv_in[s1 * LV_WORDS + w]
            outidx: uint32 = b * LV_WORDS + w
            if lv_out[outidx] != newout:
                lv_out[outidx] = newout
                changed = 1
            # live_in[B] = use[B] U (live_out[B] - def[B])
            newin: uint32 = lv_use[outidx] | (newout & (~lv_def[outidx]))
            if lv_in[outidx] != newin:
                lv_in[outidx] = newin
                changed = 1
            w = w + 1
    return changed


# Run liveness to a fixpoint; returns the number of iterations (capped). 0 means
# it did not converge within the cap (a validator failure).
LV_ITER_CAP: uint32 = 100000
def lv_solve() -> uint32:
    lv_build_local_sets()
    it: uint32 = 0
    while it < LV_ITER_CAP:
        it = it + 1
        if lv_one_pass() == 0:
            return it
    return 0      # did not converge (cap hit) -> caller flags failure


# =======================================================================
# Structural validator.
# =======================================================================
#
# Returns 0 on success, or a nonzero failure code identifying the first broken
# invariant. The caller (dump driver / fuzzer lane) treats nonzero as a hard
# failure. cfg_overflow functions are checked by the caller BEFORE validating
# (an overflowed build is SKIPPED, not failed).

# Failure codes.
CFGV_OK: uint32 = 0
CFGV_NO_TERM: uint32 = 1          # a block has no terminator
CFGV_BAD_EDGE: uint32 = 2         # an edge points to a non-existent block
CFGV_NO_FIXPOINT: uint32 = 3      # liveness did not converge
CFGV_USE_BEFORE_DEF: uint32 = 4   # a non-live-in name is used before def in B
CFGV_ENTRY_LIVEIN: uint32 = 5     # a name is live-in at ENTRY but never a param
                                  # def there (use of an undefined value) — soft;
                                  # reported but see note in cfg_validate.


# Validate that every block has a real terminator and all edges are in range.
def cfg_validate_structure() -> uint32:
    b: uint32 = 0
    while b < bb_count:
        t: uint32 = bb_term[b]
        if t == BBT_NONE:
            return CFGV_NO_TERM
        # edge endpoints must exist.
        if bb_succ_n[b] >= 1:
            s0: uint32 = bb_succ0[b]
            if s0 == BB_NONE or s0 >= bb_count:
                return CFGV_BAD_EDGE
        if bb_succ_n[b] >= 2:
            s1: uint32 = bb_succ1[b]
            if s1 == BB_NONE or s1 >= bb_count:
                return CFGV_BAD_EDGE
        # EXIT block must have 0 successors; non-EXIT terminators must have >=1.
        if t == BBT_EXIT:
            if bb_succ_n[b] != 0:
                return CFGV_BAD_EDGE
        else:
            if bb_succ_n[b] == 0:
                return CFGV_NO_TERM
        b = b + 1
    return CFGV_OK


# Validate, per block, that no instruction USES a name that is neither defined
# earlier in the block NOR live-in to the block. (i.e. every read is either a
# block-local prior def or an upward-exposed use that liveness propagated.) This
# is the soundness self-check: liveness must "explain" every use.
def cfg_validate_use_before_def() -> uint32:
    b: uint32 = 0
    while b < bb_count:
        # locally-defined-so-far bitset, rebuilt per block in a scratch area.
        sw: uint32 = 0
        while sw < LV_WORDS:
            cfgv_seen[sw] = 0
            sw = sw + 1
        i: uint32 = 0
        first: uint32 = bb_first[b]
        n: uint32 = bb_ninstr[b]
        while i < n:
            ins: uint32 = first + i
            u: uint32 = 0
            nu: uint32 = ci_nuse[ins]
            while u < nu:
                nid: uint32 = ci_use[ins * CI_MAX_USE + u]
                # seen locally?
                seen: uint32 = (cfgv_seen[nid >> 5] >> (nid & 31)) & 1
                if seen == 0:
                    # must be live-in to B (upward-exposed and explained).
                    if lv_get(LVS_IN, b, nid) == 0:
                        return CFGV_USE_BEFORE_DEF
                u = u + 1
            d: uint32 = ci_def[ins]
            if d != NM_NONE and d < NM_MAX:
                cfgv_seen[d >> 5] = cfgv_seen[d >> 5] | (cast[uint32](1) << (d & 31))
            i = i + 1
        b = b + 1
    return CFGV_OK


cfgv_seen: Array[8, uint32]            # LV_WORDS scratch for use-before-def


# Top-level per-function validate: structure, liveness fixpoint, use-before-def.
# Returns CFGV_OK or the first failure code. Assumes cfg_build_function already
# ran and returned 1 (no overflow).
def cfg_validate() -> uint32:
    rc: uint32 = cfg_validate_structure()
    if rc != CFGV_OK:
        return rc
    iters: uint32 = lv_solve()
    if iters == 0:
        return CFGV_NO_FIXPOINT
    rc = cfg_validate_use_before_def()
    if rc != CFGV_OK:
        return rc
    return CFGV_OK


# =======================================================================
# Phase-4 PREREQ (1): value-level live ranges.
# =======================================================================
#
# WHAT THIS ADDS over block liveness
# ----------------------------------
# lv_solve gives per-BLOCK live-in/out bitsets. A linear-scan or graph-coloring
# allocator instead consumes a per-NAME live INTERVAL [start,end) over a stable
# linear instruction numbering: the contiguous span from a name's first def/use
# to its last use, so the allocator can ask "do names A and B overlap?" by
# interval intersection. We compute exactly that here, ON TOP of the already-
# solved CFG + block liveness — still pure analysis, still byte-inert.
#
# INSTRUCTION NUMBERING (the [start,end) axis)
#   The CFG instruction pool (ci_*) is filled in BLOCK order: block b owns the
#   contiguous range [bb_first[b], bb_first[b]+bb_ninstr[b]). So the flat ci
#   index IS a stable linear program-point number, and a block maps to a
#   contiguous [lo,hi) instruction span. We number program points 0..ci_count;
#   point p sits "at" instruction p. An interval [start,end) is half-open: the
#   name is live from program point `start` up to (not including) `end`.
#
# HOW A NAME's INTERVAL IS BUILT (correct across blocks via the solved liveness)
#   For each name id n we take the union, over every block b, of:
#     * if n is live-in to b: the whole block span [bb_lo(b), bb_hi(b)) is
#       covered (n is live on entry, so live across at least the block prefix
#       until its first local def — conservatively the whole block for an
#       interval lower bound; the precise last-use is refined below),
#     * each instruction in b that DEFs or USEs n contributes its own point,
#     * if n is live-OUT of b: the block's last point extends to bb_hi(b) (n
#       crosses the block's bottom edge into a successor).
#   The interval is [min covered point, max covered point + 1). A value that is
#   live across multiple blocks therefore yields ONE interval spanning from its
#   first def/live-in point to its last use/live-out point across the linear
#   numbering — precisely what linear-scan consumes. This is a CONSERVATIVE
#   (superset) interval: it never under-approximates liveness (sound for an
#   allocator: two names that truly interfere always have overlapping
#   intervals), at the cost of occasionally reporting a hole as live. A first
#   allocator wants exactly this safety direction.
#
# WHY half-open + +1: an instruction that is the LAST use of n keeps n live
#   THROUGH that instruction's read, so the interval must include that point;
#   end = last_point + 1 makes [start,end) contain it. A def-only point with no
#   later use still yields a 1-wide interval [p, p+1) (the value is defined; an
#   allocator must still place it somewhere for that point).

# Per-name interval, indexed by name id (0..nm_count). lr_valid[n]=1 if name n
# has any def/use/live span in the function (else it never appears — no
# interval). Bounds are program points over [0, ci_count].
lr_start: Array[256, uint32]           # NM_MAX
lr_end: Array[256, uint32]             # half-open: [lr_start, lr_end)
lr_valid: Array[256, uint32]

LR_INF: uint32 = 0xffffffff


def lr_reset():
    n: uint32 = 0
    while n < NM_MAX:
        lr_start[n] = LR_INF
        lr_end[n] = 0
        lr_valid[n] = 0
        n = n + 1


# Extend name n's interval to cover program point p (and p+1 as a use/def end).
def lr_cover(n: uint32, p: uint32):
    if n >= NM_MAX:
        return
    lr_valid[n] = 1
    if p < lr_start[n]:
        lr_start[n] = p
    if p + 1 > lr_end[n]:
        lr_end[n] = p + 1


# Block instruction span helpers.
def bb_lo(b: uint32) -> uint32:
    return bb_first[b]


def bb_hi(b: uint32) -> uint32:
    return bb_first[b] + bb_ninstr[b]


# Build value(name)-level live intervals from the solved CFG + block liveness.
# Precondition: cfg_build_function returned 1 AND lv_solve() reached a fixpoint
# (cfg_validate runs it; the corpus driver guarantees ordering). Pure reads.
def lr_build():
    lr_reset()
    b: uint32 = 0
    while b < bb_count:
        lo: uint32 = bb_lo(b)
        hi: uint32 = bb_hi(b)
        # Names live-IN cover the block prefix; names live-OUT cover up to the
        # block's bottom edge. Both pin the interval bounds across blocks so a
        # value crossing several blocks gets ONE spanning interval.
        nid: uint32 = 0
        while nid < nm_count:
            if lv_get(LVS_IN, b, nid) != 0:
                lr_cover(nid, lo)
                # live-in and the block has instructions => live at least to the
                # first local point; if also live-out, to the bottom edge.
                if hi > lo:
                    lr_cover(nid, hi - 1)
            if lv_get(LVS_OUT, b, nid) != 0:
                if hi > lo:
                    lr_cover(nid, hi - 1)
                else:
                    # empty block (no instrs, e.g. a pure-branch join): the
                    # crossing point is the block's position lo.
                    lr_cover(nid, lo)
            nid = nid + 1
        # Each instruction's own def/use pins its exact point.
        i: uint32 = 0
        while i < bb_ninstr[b]:
            ins: uint32 = lo + i
            d: uint32 = ci_def[ins]
            if d != NM_NONE and d < NM_MAX:
                lr_cover(d, ins)
            u: uint32 = 0
            nu: uint32 = ci_nuse[ins]
            while u < nu:
                lr_cover(ci_use[ins * CI_MAX_USE + u], ins)
                u = u + 1
            i = i + 1
        b = b + 1


# =======================================================================
# Phase-4 PREREQ (2): alias / may-clobber analysis.
# =======================================================================
#
# A register allocator may only promote a local to a register if EVERY write to
# it is a visible name-level def (so liveness sees it). A local whose ADDRESS
# escapes, or that is written through a non-ident lvalue, can be mutated without
# a name-level def — liveness would be UNSOUND for it. This analysis builds the
# conservative per-function set of such CLOBBERABLE locals. A name is
# REGISTER-PROMOTABLE iff it is a known local AND NOT in the clobberable set.
#
# WHAT MARKS A LOCAL CLOBBERABLE (conservative — when unsure, mark it):
#   * its address is taken: `&x`            (UNOP_ADDR over an ident)
#                           `&x[i]`,`&x.f`  (UNOP_ADDR over an index/member whose
#                                            base ident is x — x's storage escapes)
#   * it is the BASE of a store through a non-ident lvalue:
#                           `x[i] = e`, `x.f = e`, `*x = e`
#     (the value reaches x's storage without a name-level def of x). NOTE the
#     non-ident-lvalue STORE case is detected during CFG lowering's else-branch;
#     here we re-derive it by a whole-AST scan so the alias set does not depend
#     on lowering order.
#   * (subsumed) a local mutated across a CALL only matters if its address
#     escaped — already covered by the address-taken rule. Plain by-value call
#     arguments do NOT escape the caller's storage.
#
# The scan is a pure recursive walk of the function body AST (params + body),
# marking name ids in cl_set. It interns names into the SAME nm_* table the CFG
# built (so name ids line up with live ranges). Names not present in nm_* (e.g.
# globals/struct fields) are irrelevant — only locals/params are colorable.

cl_set: Array[256, uint32]             # NM_MAX: 1 => clobberable/escaped
cl_count: uint32 = 0                   # number of distinct clobberable names


def cl_reset():
    n: uint32 = 0
    while n < NM_MAX:
        cl_set[n] = 0
        nm_slotread[n] = 0
        n = n + 1
    cl_count = 0


# Mark a name (by strbuf ref) as having a SLOT-reading use (see nm_slotread).
# Interns into nm_* so the id matches the live-range numbering. A name id past
# NM_MAX folds into cfg_overflow (which already forces the all-memory fallback).
def sr_mark(off: uint32, len_: uint32):
    nid: uint32 = nm_intern(off, len_)
    if nid >= NM_MAX:
        cfg_overflow = 1
        return
    nm_slotread[nid] = 1


# Mark a name (by strbuf ref) clobberable. Interns into nm_* so the id matches
# the live-range / liveness numbering. Overflow is folded into cfg_overflow.
def cl_mark(off: uint32, len_: uint32):
    nid: uint32 = nm_intern(off, len_)
    if nid >= NM_MAX:
        cfg_overflow = 1
        return
    if cl_set[nid] == 0:
        cl_set[nid] = 1
        cl_count = cl_count + 1


# Return the base IDENT node of an lvalue chain (x, x[i], x.f, x[i].f[j], *x...),
# or 0 if the base is not a simple ident (e.g. a call result, literal). Used to
# attribute an address-of / through-pointer store to the escaping local.
def cl_base_ident(node: uint32) -> uint32:
    cur: uint32 = node
    while cur != 0:
        k: uint32 = nd_kind[cur]
        if k == ND_IDENT:
            return cur
        if k == ND_INDEX or k == ND_MEMBER:
            cur = nd_a[cur]
        elif k == ND_UNARY and nd_aux[cur] == UNOP_DEREF:
            # *p : the dereferenced pointer's base escapes through the store.
            cur = nd_a[cur]
        else:
            return 0
    return 0


# Recursively scan an expression subtree, marking any local whose address is
# taken via UNOP_ADDR. Descends all child slots + arg/element chains (mirrors
# cfg_scan_uses' traversal so no operand is missed).
def cl_scan_expr(node: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]
    if k == ND_INT_LIT or k == ND_IDENT:
        return
    if k == ND_UNARY and nd_aux[node] == UNOP_ADDR:
        base: uint32 = cl_base_ident(nd_a[node])
        if base != 0:
            cl_mark(nd_name_off[base], nd_name_len[base])
        # still descend into the operand (e.g. &a[b] uses b)
    # The BASE of an index expression `p[i]` is read from its slot directly when
    # it is a plain scalar-as-pointer (gen_index_address's emit_load_local_rax);
    # mark the immediate base ident slot-reading so a promoted base keeps its
    # write-through store. Array/Ptr bases are not plain scalars (never promoted),
    # so marking them is harmless and conservative.
    if k == ND_INDEX and nd_a[node] != 0 and nd_kind[nd_a[node]] == ND_IDENT:
        sr_mark(nd_name_off[nd_a[node]], nd_name_len[nd_a[node]])
    # A call THROUGH a local function-pointer reads the pointer from its slot
    # (gen_call's indirect emit_load_local_rax); mark a bare-ident callee.
    if k == ND_CALL and nd_a[node] != 0 and nd_kind[nd_a[node]] == ND_IDENT:
        sr_mark(nd_name_off[nd_a[node]], nd_name_len[nd_a[node]])
    cl_scan_expr(nd_a[node])
    cl_scan_expr(nd_b[node])
    cl_scan_expr(nd_c[node])
    cl_scan_expr(nd_d[node])
    cl_scan_chain(nd_next[nd_a[node]])
    cl_scan_chain(nd_next[nd_b[node]])


def cl_scan_chain(head: uint32):
    n: uint32 = head
    while n != 0:
        cl_scan_expr(n)
        n = nd_next[n]


# Scan a statement chain (a body), marking clobberable locals from both
# address-of expressions anywhere AND non-ident-lvalue store targets.
def cl_scan_stmts(head: uint32):
    s: uint32 = head
    while s != 0:
        k: uint32 = nd_kind[s]
        if k == ND_ASSIGN:
            target: uint32 = nd_a[s]
            if nd_kind[target] != ND_IDENT:
                # store through index/member/deref lvalue: base local escapes.
                base: uint32 = cl_base_ident(target)
                if base != 0:
                    cl_mark(nd_name_off[base], nd_name_len[base])
                cl_scan_expr(target)
            cl_scan_expr(nd_b[s])
        elif k == ND_VAR_DECL:
            cl_scan_expr(nd_b[s])
        elif k == ND_EXPR_STMT:
            cl_scan_expr(nd_a[s])
        elif k == ND_RETURN:
            cl_scan_expr(nd_a[s])
        elif k == ND_IF:
            cl_scan_expr(nd_a[s])
            cl_scan_stmts(nd_b[s])
            cl_scan_if_alts(nd_c[s], nd_d[s])
        elif k == ND_WHILE:
            cl_scan_expr(nd_a[s])
            cl_scan_stmts(nd_b[s])
        elif k == ND_DO_WHILE:
            cl_scan_expr(nd_a[s])
            cl_scan_stmts(nd_b[s])
        elif k == ND_FOR:
            # The induction variable is read back from its slot by
            # emit_load_for_var (the loop test + step), bypassing the register
            # hook; keep it write-through if promoted.
            sr_mark(nd_name_off[s], nd_name_len[s])
            cl_scan_expr(nd_a[s])
            cl_scan_stmts(nd_b[s])
        elif k == ND_FOR_UNPACK:
            # Each unpack target ident is a loop-bound name read from its slot.
            ut: uint32 = nd_a[s]
            while ut != 0:
                if nd_kind[ut] == ND_IDENT:
                    sr_mark(nd_name_off[ut], nd_name_len[ut])
                ut = nd_next[ut]
            cl_scan_expr(nd_b[s])
            cl_scan_stmts(nd_c[s])
        else:
            # opaque statement: scan all child slots conservatively.
            cl_scan_expr(nd_a[s])
            cl_scan_expr(nd_b[s])
            cl_scan_expr(nd_c[s])
            cl_scan_expr(nd_d[s])
        s = nd_next[s]


# elif chain + final else, mirroring cfg_lower_if_alts' shape.
def cl_scan_if_alts(elif_head: uint32, else_head: uint32):
    if elif_head != 0:
        cl_scan_expr(nd_a[elif_head])
        cl_scan_stmts(nd_b[elif_head])
        cl_scan_if_alts(nd_next[elif_head], else_head)
        return
    if else_head != 0:
        cl_scan_stmts(else_head)


# Build the clobberable set for one function. Precondition: cfg_build_function
# already ran (nm_* holds this function's interned names). Pure AST reads.
def cl_build(fn: uint32):
    cl_reset()
    # Params themselves are by-value locals; they only escape if their address
    # is taken in the body (caught by cl_scan_stmts). The iterable/type slots of
    # a param node carry no escapes.
    cl_scan_stmts(nd_c[fn])


# =======================================================================
# Phase-4 PREREQ validator: live ranges + alias invariants.
# =======================================================================
#
# Asserts (over a built+liveness-solved+lr_built+cl_built function):
#   LRV_EMPTY_INTERVAL : a valid name has start>=end (empty/inverted interval)
#   LRV_OOB_INTERVAL   : an interval escapes [0, ci_count]
#   LRV_PROMOTE_CLOBBER: a name is BOTH promotable and clobberable (the sets
#                        must be disjoint by construction)
#   LRV_CLOBBER_UNKNOWN: a clobberable name id is outside the interned name set
#                        (alias set must be a subset of the function's locals)
LRV_OK: uint32 = 0
LRV_EMPTY_INTERVAL: uint32 = 10
LRV_OOB_INTERVAL: uint32 = 11
LRV_PROMOTE_CLOBBER: uint32 = 12
LRV_CLOBBER_UNKNOWN: uint32 = 13


# A name is register-promotable iff it has a live range (is a real local/param
# value) AND is not in the clobberable set.
def lr_is_promotable(n: uint32) -> uint32:
    if n >= nm_count:
        return 0
    if lr_valid[n] == 0:
        return 0
    if cl_set[n] != 0:
        return 0
    if nm_trunc[n] != 0:
        # a use of n was dropped past CI_MAX_USE: its live range is unsound for
        # register promotion (see nm_trunc). Keep it in memory.
        return 0
    return 1


# A promoted name is STORE-ELIMINABLE (its shadow stack slot + write-through
# stores may be dropped, the register becoming the sole home) iff it is
# promotable AND no use of it reads its slot directly (nm_slotread). Address-
# taken names are already excluded by lr_is_promotable (cl_set), so the only
# remaining slot-bypass reads are the index-base / for-IV / local-fnptr-callee
# uses tracked in nm_slotread. Conservative: any uncertainty keeps write-through.
def lr_is_store_elim(n: uint32) -> uint32:
    if lr_is_promotable(n) == 0:
        return 0
    if n >= NM_MAX:
        return 0
    if nm_slotread[n] != 0:
        return 0
    return 1


# =======================================================================
# STMT-point lookup + dead-at-point test (for codegen's IR-scratch borrow).
# =======================================================================
#
# lr_stmt_point(node): the FIRST program point (ci index) owned by statement
# `node`, or LR_INF if the statement emitted no ci (or `node` is 0/unknown). The
# first point is the EARLIEST point that statement executes — a conservative
# anchor: any IR scratch a statement's expression acquires is materialized at or
# after this point, within that statement, and released before the next.
# The FIRST program point (ci index) stamped with statement `node`, plus the
# basic block that point belongs to. Returns LR_INF if no ci carries the node.
def lr_stmt_point(node: uint32) -> uint32:
    if node == 0:
        return LR_INF
    i: uint32 = 0
    while i < ci_count:
        if ci_node[i] == node:
            return i
        i = i + 1
    return LR_INF


# The basic-block id that owns program point `p` (bb_first[b] <= p < bb_hi(b)),
# or BB_NONE if p is out of range. Within ONE basic block the ci numbering is
# contiguous AND in source order, so it matches codegen's straight-line emission
# order — the property the borrow disjointness check relies on.
def lr_block_of_point(p: uint32) -> uint32:
    if p == LR_INF:
        return BB_NONE
    b: uint32 = 0
    while b < bb_count:
        if p >= bb_first[b]:
            if p < bb_first[b] + bb_ninstr[b]:
                return b
        b = b + 1
    return BB_NONE


# lr_name_dead_after(n, point): 1 iff name n is provably DEAD from `point`
# onward — i.e. n has a valid live interval whose END is at or before `point`, so
# n has NO use at or after `point`. This is the ROCK-SOLID direction: a half-open
# interval [start,end) means n's last use is at end-1, so end <= point guarantees
# the value currently in n's register is never read again. (We deliberately do
# NOT treat `point < start` — "not yet defined" — as borrowable: a loop back edge
# can make a name live at points textually before its def in the linear numbering,
# and the conservative interval would not show it. End-passed deadness has no such
# hazard.) Returns 0 when n has no interval or point is LR_INF (unknown).
def lr_name_dead_after(n: uint32, point: uint32) -> uint32:
    if point == LR_INF:
        return 0
    if n >= NM_MAX:
        return 0
    if lr_valid[n] == 0:
        return 0
    if lr_end[n] <= point:
        return 1
    return 0


# lr_name_dead_after_sameblock(n, point): the SOUND-FOR-EMISSION borrow test.
# `lr_end[n] <= point` alone is NOT enough to lend n's register at the machine
# instruction codegen is emitting for `point`'s statement: the ci NUMBERING is in
# basic-block-ALLOCATION order, which only matches codegen's source-order
# emission WITHIN a single basic block. Across a block boundary (a loop back
# edge, an if join) the linear point of n's death can sit textually after the
# emission point even though n is still live in the register there — exactly the
# loop-carried-accumulator miscompile. So we additionally require n's LAST-USE
# point (lr_end[n]-1) and `point` to live in the SAME basic block: then the two
# are ordered by the contiguous in-block numbering, which is the real emission
# order, and `lr_end[n] <= point` truly means n's register is free at emission.
# Conservative: any cross-block relationship returns 0 (no borrow).
def lr_name_dead_after_sameblock(n: uint32, point: uint32) -> uint32:
    if point == LR_INF:
        return 0
    if n >= NM_MAX:
        return 0
    if lr_valid[n] == 0:
        return 0
    if lr_end[n] > point:
        return 0
    # n is dead at `point` in the linear numbering. Require same-block so the
    # numbering reflects true emission order.
    if lr_end[n] == 0:
        return 0
    death_pt: uint32 = lr_end[n] - 1
    pb: uint32 = lr_block_of_point(point)
    db: uint32 = lr_block_of_point(death_pt)
    if pb == BB_NONE or db == BB_NONE:
        return 0
    if pb != db:
        return 0
    return 1


def lr_validate() -> uint32:
    n: uint32 = 0
    while n < nm_count:
        if lr_valid[n] != 0:
            if lr_start[n] >= lr_end[n]:
                return LRV_EMPTY_INTERVAL
            if lr_end[n] > ci_count:
                return LRV_OOB_INTERVAL
        # clobberable ids must be within the interned name set.
        if cl_set[n] != 0:
            # n < nm_count here by loop bound, so it is interned -> OK.
            # promotable ∩ clobberable must be empty:
            if lr_is_promotable(n) != 0:
                return LRV_PROMOTE_CLOBBER
        n = n + 1
    # any clobberable id >= nm_count would be a subset violation (cl_mark
    # interns, so this cannot happen, but assert it defensively).
    n = nm_count
    while n < NM_MAX:
        if cl_set[n] != 0:
            return LRV_CLOBBER_UNKNOWN
        n = n + 1
    return LRV_OK


# =======================================================================
# Corpus driver entry — build+validate every function in a program.
# =======================================================================
#
# Returns a packed result via the globals below (Adder single-return). The dump
# driver / fuzzer lane read these after calling cfg_run_program.

cfg_stat_funcs: uint32 = 0             # functions processed (built OK)
cfg_stat_skipped: uint32 = 0          # functions skipped (arena overflow)
cfg_stat_blocks: uint32 = 0           # total basic blocks across funcs
cfg_stat_edges: uint32 = 0            # total CFG edges across funcs
cfg_stat_insts: uint32 = 0            # total CFG instructions across funcs
cfg_stat_fail: uint32 = 0             # first nonzero validator code (0 = all ok)
cfg_stat_fail_fn: uint32 = 0          # function index of the first failure

# Phase-4 PREREQ stats (live ranges + alias) accumulated across functions.
cfg_stat_ranges: uint32 = 0           # total valid live intervals (one per live name)
cfg_stat_range_len: uint32 = 0        # sum of interval lengths (for avg)
cfg_stat_range_max: uint32 = 0        # max single interval length
cfg_stat_locals: uint32 = 0           # total distinct interned names (locals/params)
cfg_stat_promotable: uint32 = 0       # names register-promotable (not clobberable)
cfg_stat_clobberable: uint32 = 0      # names clobberable (address-taken/stored-thru)


def cfg_count_edges() -> uint32:
    e: uint32 = 0
    b: uint32 = 0
    while b < bb_count:
        e = e + bb_succ_n[b]
        b = b + 1
    return e


# Accumulate the live-range + alias stats for the CURRENT function (after
# lr_build/cl_build ran). Counts locals, promotable vs clobberable, and interval
# length sum/max.
def cfg_accum_lr_stats():
    n: uint32 = 0
    while n < nm_count:
        cfg_stat_locals = cfg_stat_locals + 1
        if cl_set[n] != 0:
            cfg_stat_clobberable = cfg_stat_clobberable + 1
        elif lr_valid[n] != 0:
            # promotable = has a live range AND not clobberable
            cfg_stat_promotable = cfg_stat_promotable + 1
        if lr_valid[n] != 0:
            cfg_stat_ranges = cfg_stat_ranges + 1
            ln: uint32 = lr_end[n] - lr_start[n]
            cfg_stat_range_len = cfg_stat_range_len + ln
            if ln > cfg_stat_range_max:
                cfg_stat_range_max = ln
        n = n + 1


# Build + validate the CFG for every ND_FUNCTION in the program (prog = ND_PROGRAM;
# decl chain on nd_b). Accumulates stats; stops counting failures at the first
# one (records it). Pure analysis: never mutates the AST.
def cfg_run_program(prog: uint32):
    cfg_stat_funcs = 0
    cfg_stat_skipped = 0
    cfg_stat_blocks = 0
    cfg_stat_edges = 0
    cfg_stat_insts = 0
    cfg_stat_fail = 0
    cfg_stat_fail_fn = 0
    cfg_stat_ranges = 0
    cfg_stat_range_len = 0
    cfg_stat_range_max = 0
    cfg_stat_locals = 0
    cfg_stat_promotable = 0
    cfg_stat_clobberable = 0
    if prog == 0:
        return
    fn_idx: uint32 = 0
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            ok: uint32 = cfg_build_function(cur)
            if ok == 0:
                # arena overflow -> skip (not a failure)
                cfg_stat_skipped = cfg_stat_skipped + 1
            else:
                cfg_stat_funcs = cfg_stat_funcs + 1
                cfg_stat_blocks = cfg_stat_blocks + bb_count
                cfg_stat_edges = cfg_stat_edges + cfg_count_edges()
                cfg_stat_insts = cfg_stat_insts + ci_count
                rc: uint32 = cfg_validate()
                if rc != CFGV_OK and cfg_stat_fail == 0:
                    cfg_stat_fail = rc
                    cfg_stat_fail_fn = fn_idx
                if rc == CFGV_OK:
                    # Phase-4 PREREQ: value-level live ranges + alias/may-clobber.
                    # cfg_validate already solved liveness to a fixpoint, so the
                    # block live-in/out sets are valid for lr_build. cl_build does
                    # a pure AST escape scan (interning into the same nm_* table).
                    lr_build()
                    cl_build(cur)
                    lrc: uint32 = lr_validate()
                    if lrc != LRV_OK and cfg_stat_fail == 0:
                        cfg_stat_fail = lrc
                        cfg_stat_fail_fn = fn_idx
                    cfg_accum_lr_stats()
            fn_idx = fn_idx + 1
        cur = nd_next[cur]

# adder/compiler/parse_selftest.ad
#
# On-device self-test for the Adder-in-Adder parser.
#
# Lexes a representative Adder snippet with the Adder lexer
# (compiler/lexer.ad), feeds the token stream to the Adder parser
# (compiler/parser.ad), and verifies the resulting AST shape. Prints a
# PASS sentinel on success.
#
# This is the SECOND self-hosting milestone — "Adder parsing Adder, on
# the device": the Adder parser building an AST from its own syntax,
# verified on device, in Adder code.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       adder/compiler/parse_selftest.ad -o build/user/parse_selftest.elf
#
# Test harness: scripts/test_selfhost_parse.sh

from compiler.lexer import (
    lex_init,
    lex_tokenize,
    strbuf,
)

from compiler.parser import (
    parser_init,
    parse_program,
    p_err,
    nd_kind,
    nd_aux,
    nd_num,
    nd_name_off,
    nd_name_len,
    nd_a,
    nd_b,
    nd_c,
    nd_next,
    ND_PROGRAM,
    ND_FUNCTION,
    ND_PARAM,
    ND_RETURN,
    ND_BINARY,
    ND_IDENT,
    ND_VAR_DECL,
    ND_WHILE,
    ND_IF,
    ND_ASSIGN,
    ND_INT_LIT,
    ND_TYPE,
    BINOP_ADD,
    BINOP_GT,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def emit_nl():
    sys_write(1, "\n", 1)


def put_u32(v: uint32):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


# Compare a node's stored name (strbuf slice) against a NUL-terminated
# C string. Returns 1 if equal, 0 otherwise.
def name_eq(node: uint32, s: Ptr[uint8]) -> int32:
    off: uint32 = nd_name_off[node]
    ln: uint32 = nd_name_len[node]
    slen: uint32 = cast[uint32](strlen(s))
    if ln != slen:
        return 0
    i: uint32 = 0
    while i < ln:
        if strbuf[off + i] != s[i]:
            return 0
        i = i + 1
    return 1


# Test bookkeeping
checks_run: uint32 = 0
checks_failed: uint32 = 0


def check_eq(label: Ptr[uint8], got: uint32, want: uint32):
    checks_run = checks_run + 1
    if got != want:
        checks_failed = checks_failed + 1
        emit("[parse_selftest] FAIL: ")
        emit(label)
        emit(": got ")
        put_u32(got)
        emit(" want ")
        put_u32(want)
        emit_nl()


def check_true(label: Ptr[uint8], cond: int32):
    checks_run = checks_run + 1
    if cond == 0:
        checks_failed = checks_failed + 1
        emit("[parse_selftest] FAIL: ")
        emit(label)
        emit_nl()


# Count the length of a sibling chain starting at `head` (0 = empty).
def chain_len(head: uint32) -> uint32:
    n: uint32 = 0
    cur: uint32 = head
    while cur != 0:
        n = n + 1
        cur = nd_next[cur]
    return n


def main() -> int32:
    emit("[parse_selftest] start: Adder parser parsing Adder source, on device\n")

    # Two-function snippet exercising: def, params, typed annotation,
    # return of a binary expr, var decl, while loop, if, assignment,
    # augmented arithmetic, comparison.
    src: Ptr[uint8] = "def add(a: int32, b: int32) -> int32:\n    return a + b\n\ndef loopy(n: int32) -> int32:\n    s: int32 = 0\n    while n > 0:\n        s = s + n\n        n = n - 1\n    if s > 10:\n        return s\n    return 0\n"
    src_len: uint32 = cast[uint32](strlen(src))

    emit("[parse_selftest] source:\n")
    emit(src)

    lex_init(src, src_len)
    lex_tokenize()

    parser_init()
    prog: uint32 = parse_program()

    check_eq("parse error flag", p_err, 0)
    check_eq("program node kind", nd_kind[prog], ND_PROGRAM)

    # Declarations chain on nd_b of the program node.
    decls: uint32 = nd_b[prog]
    check_eq("declaration count", chain_len(decls), 2)

    # --- First declaration: def add(a, b) -> int32: return a + b ---
    add_fn: uint32 = decls
    check_eq("add: kind FUNCTION", nd_kind[add_fn], ND_FUNCTION)
    check_true("add: name == 'add'", name_eq(add_fn, "add"))
    check_eq("add: param count", nd_aux[add_fn], 2)

    # params chain on nd_a
    p0: uint32 = nd_a[add_fn]
    check_eq("add: param0 kind", nd_kind[p0], ND_PARAM)
    check_true("add: param0 name == 'a'", name_eq(p0, "a"))
    p1: uint32 = nd_next[p0]
    check_true("add: param1 name == 'b'", name_eq(p1, "b"))

    # return type on nd_b should be a TYPE node
    rt: uint32 = nd_b[add_fn]
    check_eq("add: return type kind", nd_kind[rt], ND_TYPE)

    # body chain on nd_c: single RETURN of (a + b)
    add_body: uint32 = nd_c[add_fn]
    check_eq("add: body stmt count", chain_len(add_body), 1)
    ret0: uint32 = add_body
    check_eq("add: body[0] kind RETURN", nd_kind[ret0], ND_RETURN)
    retval: uint32 = nd_a[ret0]
    check_eq("add: return val kind BINARY", nd_kind[retval], ND_BINARY)
    check_eq("add: return op ADD", nd_aux[retval], BINOP_ADD)
    lhs: uint32 = nd_a[retval]
    rhs: uint32 = nd_b[retval]
    check_eq("add: lhs IDENT", nd_kind[lhs], ND_IDENT)
    check_true("add: lhs == 'a'", name_eq(lhs, "a"))
    check_true("add: rhs == 'b'", name_eq(rhs, "b"))

    # --- Second declaration: def loopy(n) -> int32: ... ---
    loopy_fn: uint32 = nd_next[add_fn]
    check_eq("loopy: kind FUNCTION", nd_kind[loopy_fn], ND_FUNCTION)
    check_true("loopy: name == 'loopy'", name_eq(loopy_fn, "loopy"))
    check_eq("loopy: param count", nd_aux[loopy_fn], 1)

    # body: VAR_DECL, WHILE, IF, RETURN  (4 statements)
    lbody: uint32 = nd_c[loopy_fn]
    check_eq("loopy: body stmt count", chain_len(lbody), 4)

    s_decl: uint32 = lbody
    check_eq("loopy: stmt0 VAR_DECL", nd_kind[s_decl], ND_VAR_DECL)
    check_true("loopy: var name == 's'", name_eq(s_decl, "s"))

    wstmt: uint32 = nd_next[s_decl]
    check_eq("loopy: stmt1 WHILE", nd_kind[wstmt], ND_WHILE)
    wcond: uint32 = nd_a[wstmt]
    check_eq("loopy: while cond BINARY", nd_kind[wcond], ND_BINARY)
    check_eq("loopy: while cond op GT", nd_aux[wcond], BINOP_GT)
    # while body: two assignments
    wbody: uint32 = nd_b[wstmt]
    check_eq("loopy: while body count", chain_len(wbody), 2)
    check_eq("loopy: while body[0] ASSIGN", nd_kind[wbody], ND_ASSIGN)

    istmt: uint32 = nd_next[wstmt]
    check_eq("loopy: stmt2 IF", nd_kind[istmt], ND_IF)
    icond: uint32 = nd_a[istmt]
    check_eq("loopy: if cond op GT", nd_aux[icond], BINOP_GT)

    rstmt: uint32 = nd_next[istmt]
    check_eq("loopy: stmt3 RETURN", nd_kind[rstmt], ND_RETURN)
    rv: uint32 = nd_a[rstmt]
    check_eq("loopy: return 0 literal", nd_kind[rv], ND_INT_LIT)
    check_eq("loopy: return value 0", cast[uint32](nd_num[rv]), 0)

    emit("[parse_selftest] ran ")
    put_u32(checks_run)
    emit(" checks, ")
    put_u32(checks_failed)
    emit(" failed\n")

    if checks_failed != 0:
        emit("[parse_selftest] FAIL\n")
        sys_exit(1)

    emit("[parse_selftest] PASS\n")
    sys_exit(0)
    return 0

# adder/compiler/adder_cc_driver.ad
#
# adder_cc — generic ON-BOX Adder compiler tool.
#
# This is the missing userland front-end to Hamnix's self-hosted Adder
# compiler. Where codegen_ac_driver.ad hardcodes the input path
# (/src/input.ad) and HEX-DUMPS the emitted ELF over serial for a host
# harness to reconstruct, this driver:
#
#   * takes the source and output paths from argv
#       adder_cc <input.ad> <output.elf>
#   * runs the full self-hosted pipeline on-box
#       lex (lexer.ad) -> parse (parser.ad) -> codegen (codegen.ad)
#       -> elf_emit (elf_emit.ad)
#   * WRITES the emitted elf32-i386 user ELF straight to <output.elf>
#     on the local filesystem (no serial round-trip).
#
# This is what lets `hpm install` compile a SOURCE package on the box:
# hpm stages the package's .ad source, spawns `adder_cc <src> <out>`,
# and installs the resulting binary — Gentoo-style source-primary
# packaging (#186), entirely on-device, using the self-hosted compiler.
#
# It prints machine-readable progress markers on stdout so a caller (or
# a test) can prove the compile happened ON-BOX:
#   [adder_cc] start
#   [adder_cc] src bytes=<N>
#   [adder_cc] codegen ok: <F> funcs code_len=<C>
#   [adder_cc] elf ok: bytes=<B>
#   [adder_cc] wrote <output> (<B> bytes)
#   [adder_cc] PASS
# On any error it prints a clear [adder_cc] FAIL: ... line and exits
# non-zero so the spawn caller sees the failure.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       adder/compiler/adder_cc_driver.ad \
#       -o build/user/adder_cc.elf
# Stages at /bin/adder_cc (build_initramfs auto-stages build/user/*.elf).

from compiler.lexer import (
    lex_init,
    lex_tokenize,
    tok_count,
)

from compiler.parser import (
    parser_init,
    parse_program,
    p_err,
    p_err_line,
    nd_kind,
    nd_b,
    ND_FUNCTION,
)

from compiler.codegen import (
    cg_init,
    cg_err,
    cg_err_reason,
    cg_err_line,
    cg_err_kind,
    code_len,
    gen_program_with_globals,
    gdata_len,
    fn_count,
    cg_entry_off,
    CODE_CAP,
)

from compiler.elf_emit import (
    elf_emit_image,
    elf_buf,
    elf_len,
    elf_err,
    elf_entry_vaddr,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)
extern def sys_open(path: Ptr[char]) -> int32
extern def sys_open_write(path: Ptr[char]) -> int32
extern def sys_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_close(fd: int32) -> int32

# Module-level source buffer. The lexer stores the bare pointer we hand
# it (lex_src), so the bytes must outlive the whole compile — hence a
# global, not a function-local. Sized to comfortably exceed any single
# package's source file.
CC_SRC_CAP: uint32 = 393216
cc_src: Array[393216, uint8]


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def put_u32(v: uint32):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


# Read the source file at `path` into cc_src[]. Returns the byte count
# read (>0), or 0 on open/read failure / empty file.
def read_source(path: Ptr[char]) -> uint32:
    fd: int32 = sys_open(path)
    if fd < 0:
        return 0
    total: uint32 = 0
    while total < CC_SRC_CAP:
        n: int64 = sys_read(fd,
                            cast[Ptr[uint8]](cast[uint64](&cc_src[0]) +
                                             cast[uint64](total)),
                            cast[uint64](CC_SRC_CAP - total))
        if n <= 0:
            break
        total = total + cast[uint32](n)
    sys_close(fd)
    # NUL-terminate so the lexer's lex_cur()==0 EOF guard is well-defined
    # even if a token scan runs slightly past lex_src_len.
    if total < CC_SRC_CAP:
        cc_src[total] = 0
    return total


# Write elf_buf[0..elf_len) to `out_path`. Returns 0 on success, -1 on
# open/short-write failure.
def write_elf(out_path: Ptr[char]) -> int32:
    fd: int32 = sys_open_write(out_path)
    if fd < 0:
        return -1
    written: uint32 = 0
    while written < elf_len:
        n: int64 = sys_write(fd,
                             cast[Ptr[uint8]](cast[uint64](&elf_buf[0]) +
                                              cast[uint64](written)),
                             cast[uint64](elf_len - written))
        if n <= 0:
            sys_close(fd)
            return -1
        written = written + cast[uint32](n)
    sys_close(fd)
    if written != elf_len:
        return -1
    return 0


def main(argc: int32, argv: Ptr[uint64]) -> int32:
    emit("[adder_cc] start\n")

    if argc < 3:
        emit("[adder_cc] FAIL: usage: adder_cc <input.ad> <output.elf>\n")
        sys_exit(2)

    in_path: Ptr[char] = cast[Ptr[char]](argv[1])
    out_path: Ptr[char] = cast[Ptr[char]](argv[2])

    n: uint32 = read_source(in_path)
    if n == 0:
        emit("[adder_cc] FAIL: cannot read source ")
        emit(cast[Ptr[uint8]](in_path))
        emit("\n")
        sys_exit(3)
    emit("[adder_cc] src bytes=")
    put_u32(n)
    emit("\n")

    lex_init(&cc_src[0], n)
    lex_tokenize()

    parser_init()
    prog: uint32 = parse_program()
    if p_err != 0:
        emit("[adder_cc] FAIL: parse error at line ")
        put_u32(p_err_line)
        emit("\n")
        sys_exit(4)

    cg_init()
    start: uint32 = gen_program_with_globals(prog)
    if cg_err != 0:
        # reason: 1=unsupported expr 2=unsupported stmt 3=CODE_CAP overflow
        # 4=GDATA_CAP overflow 5=fixup table full 6=symbol table full
        # 7=unresolved call 8=unknown name/type 0/9=uncategorised.
        emit("[adder_cc] FAIL: codegen error reason=")
        put_u32(cg_err_reason)
        emit(" line=")
        put_u32(cg_err_line())
        emit(" kind=")
        put_u32(cg_err_kind())
        emit("\n")
        sys_exit(5)
    if fn_count == 0:
        emit("[adder_cc] FAIL: no functions emitted\n")
        sys_exit(6)

    emit("[adder_cc] codegen ok: ")
    put_u32(fn_count)
    emit(" funcs code_len=")
    put_u32(code_len)
    emit("\n")

    total: uint32 = elf_emit_image(0)
    if elf_err != 0 or total == 0:
        emit("[adder_cc] FAIL: ELF emit error\n")
        sys_exit(7)

    emit("[adder_cc] elf ok: bytes=")
    put_u32(elf_len)
    emit(" entry_vaddr=")
    put_u32(elf_entry_vaddr)
    emit(" code_cap=")
    put_u32(CODE_CAP)
    emit("\n")

    if write_elf(out_path) != 0:
        emit("[adder_cc] FAIL: cannot write output ")
        emit(cast[Ptr[uint8]](out_path))
        emit("\n")
        sys_exit(8)

    emit("[adder_cc] wrote ")
    emit(cast[Ptr[uint8]](out_path))
    emit(" (")
    put_u32(elf_len)
    emit(" bytes)\n")
    emit("[adder_cc] PASS\n")
    return 0

# adder/compiler/codegen.ad
#
# Adder-in-Adder implementation of (a usable subset of) the x86_64 code
# generator. This is the THIRD self-hosting milestone (lexer and parser
# were the first two): the Adder compiler's own x86_64 backend, rewritten
# IN Adder, consuming the AST that compiler/parser.ad produces and
# emitting raw x86_64 machine-code bytes.
#
# The authoritative spec for the opcode encodings is
# compiler/codegen_x86.py — that file emits System V AMD64 GNU `as`
# AT&T-syntax assembly; this file emits the SAME instruction sequences
# but assembles them straight to bytes (no external assembler), so the
# device can build native code with no toolchain.
#
# Design constraints (Adder/bare-metal — same as lexer.ad / parser.ad):
#   - No dynamic allocation: all storage is global fixed arrays.
#   - Output: a flat global byte buffer (code[]) with a length counter.
#   - The codegen reads the parser's global AST arena (nd_kind, nd_aux,
#     nd_num, nd_a, nd_b, nd_c, nd_next, nd_name_off/len) directly, since
#     both are single-instance global modules.
#
# Subset covered (a small but REAL slice of codegen_x86.py):
#   * ND_FUNCTION  — prologue (endbr64; push %rbp; mov %rsp,%rbp;
#                    sub $frame,%rsp), parameter spill from arg regs into
#                    stack slots, epilogue (leave; ret).
#   * ND_RETURN    — evaluate the value expr into %rax, then leave; ret.
#   * ND_INT_LIT   — movq $imm, %rax (32-bit-immediate form).
#   * ND_IDENT     — load a parameter/local from its %rbp-relative slot.
#   * ND_BINARY    — ADD / SUB / MUL via the same right-push / left /
#                    pop-%rcx stack-machine lowering codegen_x86.py uses:
#                      addq %rcx,%rax  /  subq %rcx,%rax  /  imulq %rcx,%rax
#                    plus comparisons ==/!=/</>/<=/>= as
#                      cmpq %rcx,%rax ; set<cc> %al ; movzbq %al,%rax.
#   * ND_CALL      — direct call to a named function: marshal up to 6 args
#                    into %rdi..%r9, xorl %eax,%eax, call <sym>; result in
#                    %rax. Inter-function calls resolved via a fixup table.
#   * ND_IF        — if / elif* / else with forward-jump (jz/jmp) rel32
#                    backpatching to the join point.
#   * ND_WHILE     — header label, condition, jz-exit, body, jmp back-edge.
#   * ND_VAR_DECL  — reserve an 8-byte slot; store the initialiser.
#   * ND_ASSIGN    — store to an identifier's slot (plain and +=/-=/*=).
#   * ND_EXPR_STMT — evaluate for effect (e.g. a bare call).
#   * Ptr[T] indexing — a Ptr[T] local/param/global HOLDS an address; p[i]
#                    dereferences *(p + i*sizeof(T)) (load and store), the
#                    pointee width driving the sized mem op. ADDR (&x /
#                    &arr[i]) and DEREF (*p) round out the pointer support.
#                    Unlike an Array (slot IS the storage, base = leaq), a
#                    pointer's slot is loaded to get the base address —
#                    mirroring codegen_x86.gen_index_address's non-Array
#                    `gen_expr(obj)` branch.
#
# Frame slots for body locals are reserved by a pre-scan pass before the
# prologue's `sub $frame,%rsp`, so the reservation covers every local.
# Multi-function programs use gen_program_all_functions, which emits each
# function back-to-back then resolves the recorded `call` fixups.
#
# Calling convention (System V AMD64, mirroring codegen_x86.py):
#   - Integer/pointer args in %rdi,%rsi,%rdx,%rcx,%r8,%r9 (we cover the
#     first 6); we spill each to a stack slot with movq <argreg>,off(%rbp)
#     so the body's identifier loads use one uniform slot path.
#   - Return value in %rax.

from compiler.parser import (
    nd_kind,
    nd_aux,
    nd_num,
    nd_name_off,
    nd_name_len,
    nd_a,
    nd_b,
    nd_c,
    nd_d,
    nd_num,
    nd_next,
    nd_line,
    ND_FUNCTION,
    ND_RETURN,
    ND_BINARY,
    ND_UNARY,
    ND_IDENT,
    ND_INT_LIT,
    ND_CHAR_LIT,
    ND_BOOL_LIT,
    ND_STRING_LIT,
    ND_INDEX,
    ND_PARAM,
    ND_CALL,
    ND_IF,
    ND_ELIF,
    ND_WHILE,
    ND_VAR_DECL,
    ND_ASSIGN,
    ND_EXPR_STMT,
    ND_ARRAY_TYPE,
    ND_PTR_TYPE,
    ND_TYPE,
    ND_CAST,
    ND_BREAK,
    ND_CONTINUE,
    ND_PASS,
    ND_CLASS,
    ND_CLASS_FIELD,
    ND_MEMBER,
    ND_METHOD_CALL,
    ND_FOR,
    ND_DO_WHILE,
    BINOP_ADD,
    BINOP_SUB,
    BINOP_MUL,
    BINOP_DIV,
    BINOP_IDIV,
    BINOP_MOD,
    BINOP_EQ,
    BINOP_NEQ,
    BINOP_LT,
    BINOP_LTE,
    BINOP_GT,
    BINOP_GTE,
    BINOP_AND,
    BINOP_OR,
    BINOP_BIT_OR,
    BINOP_BIT_AND,
    BINOP_BIT_XOR,
    BINOP_SHL,
    BINOP_SHR,
    UNOP_NEG,
    UNOP_NOT,
    UNOP_BIT_NOT,
    UNOP_DEREF,
    UNOP_ADDR,
    AUGOP_NONE,
    AUGOP_ADD,
    AUGOP_SUB,
    AUGOP_MUL,
)

from compiler.lexer import (
    strbuf,
)

# -----------------------------------------------------------------------
# Output buffer: flat machine-code bytes.
# -----------------------------------------------------------------------

# Code window. Sized to hold the WHOLE compiler's emitted code for the
# self-host fixpoint with generous headroom (2 MiB; whole-compiler code is
# ~104 KiB today). BSS-backed (zero-init), so the bytes cost nothing in the
# emitted file — only memsz. DATA_BASE MUST stay == CODE_CAP.
CODE_CAP: uint32 = 2097152
code: Array[2097152, uint8]
code_len: uint32 = 0

# Codegen error flag (set on overflow / unsupported node).
cg_err: uint32 = 0

# Resolved ENTRY function code offset (set by gen_program_*). The program's
# entry is resolved BY NAME ("main"), falling back to the first emitted
# function if no `main` exists. elf_emit.ad's _start stub `call`s THIS
# offset (not literal 0), so the entry function need not be source-first.
# Sentinel 0xFFFFFFFF means "unresolved" (no functions emitted).
CG_ENTRY_NONE: uint32 = 4294967295
cg_entry_off: uint32 = 0

# Diagnostic: WHY codegen failed (set the first time cg_err goes 1 via
# cg_fail). Lets the on-device driver report a precise blocker instead of a
# bare "codegen error". Reason codes:
#   1 = unsupported expression node      2 = unsupported statement node
#   3 = CODE_CAP overflow (code too big) 4 = GDATA_CAP overflow (.data)
#   5 = call/data/string fixup table full
#   6 = MAX_FUNCS/MAX_GLOBALS/MAX_LOCALS table full
#   7 = unresolved call (unknown callee) 8 = unknown name / type query
#   9 = other / uncategorised           10 = disp8 frame overflow (a
#       function's locals exceed the -128 disp8 reach)
cg_err_reason: uint32 = 0
cg_err_node: uint32 = 0     # offending AST node id (for nd_line lookup)


# Record the first codegen failure with a reason code + offending node.
# Idempotent on reason (keeps the FIRST cause); always sets cg_err.
def cg_fail(reason: uint32, node: uint32):
    if cg_err == 0:
        cg_err_reason = reason
        cg_err_node = node
    cg_err = 1


# Source line of the codegen-failure node (0 if none / unknown). Lets the
# driver point at the offending construct in the input.
def cg_err_line() -> uint32:
    if cg_err_node == 0:
        return 0
    return nd_line[cg_err_node]


# AST kind of the codegen-failure node (0 if none). Helps disambiguate
# reason-1/2 "unsupported node" diagnostics on device.
def cg_err_kind() -> uint32:
    if cg_err_node == 0:
        return 0
    return nd_kind[cg_err_node]

# -----------------------------------------------------------------------
# Per-function local/parameter slot table.
#
# Mirrors FunctionContext.alloc_local in codegen_x86.py: each slot is
# 8-byte-rounded and laid out at a negative %rbp offset. We map a slot to
# the parameter's strbuf name reference (off/len), so identifier loads can
# resolve a name back to its frame offset by string comparison.
# -----------------------------------------------------------------------

MAX_LOCALS: uint32 = 256

loc_name_off: Array[256, uint32]
loc_name_len: Array[256, uint32]
loc_offset: Array[256, int32]      # negative %rbp-relative byte offset (BASE)
# Per-local element size: 0 means a plain 8-byte scalar slot; a non-zero
# value (1/2/4/8) marks an Array local whose elements are that many bytes
# wide. loc_offset is then the address of element 0 (the lowest address of
# the reserved block); arr[i] lives at rbp + loc_offset + i*elem_size.
loc_elem_size: Array[256, uint32]
# Per-local pointer marker: 0 means the local is NOT a Ptr[T]; a non-zero
# value (1/2/4/8) marks a Ptr[T] local/param whose slot HOLDS an address
# and whose pointee width is that many bytes. Unlike an Array local (where
# loc_offset is element 0's address), a pointer local's slot stores the
# target address; p[i] dereferences *(slot_value + i*pointee_size). This
# mirrors codegen_x86.gen_index_address's `gen_expr(obj)` (load the pointer
# value) branch for non-Array bases.
loc_ptr_size: Array[256, uint32]
# Per-local SIGNEDNESS tristate for a scalar int local/param, used to mirror
# codegen_x86's get_expr_type()/_is_unsigned_type() when picking signed vs
# unsigned setcc (compares) and div/mod instructions:
#   0 = unknown (untyped / not an int scalar) -> contributes no signedness
#   1 = unsigned int (uint8/16/32/64, bool, char, pointer, array)
#   2 = signed int   (int8/16/32/64)
# Set by alloc helpers from the declared type. Array/pointer locals are
# treated as unsigned (matching _is_unsigned_type's True for those).
loc_is_signed: Array[256, uint32]
# Per-local SCALAR width (1/2/4/8) for a plain scalar int local/param, or 0
# when the local is not a sized scalar (an 8-byte slot of unknown/erased type,
# a pointer, or an array). When non-zero AND < 8, the local is stored with a
# SIZED store and LOADED with a sign/zero-extending move (per loc_is_signed),
# exactly like codegen_x86's _emit_local_store / _emit_local_load. This is
# what makes a widening read of a typed sub-8-byte local (e.g. cast[int64](l)
# where l is int16) see the truncated+extended value, not stale upper bits.
loc_scalar_size: Array[256, uint32]
# Per-local FLOAT WIDTH (0 = not a float scalar, 4 = float32, 8 = float64).
# Distinguishes a float32 local (scalar_size 4) from an int32 local (also
# scalar_size 4) so identifier operands route to the SSE path. Mirrors
# codegen_x86._float_width(get_expr_type(ident)).
loc_is_float: Array[256, uint32]
# Per-local struct typing, for member access (obj.field) on a local:
#   loc_struct_idx  = struct-table index + 1 (0 = not a struct-typed local).
#                     Non-zero for BOTH an in-place struct local (slot IS the
#                     struct storage; member address = &slot + field_offset)
#                     AND a Ptr[Struct] local/param (slot HOLDS an address;
#                     member address = (loaded ptr value) + field_offset).
#   loc_struct_is_ptr = 1 when the local is a Ptr[Struct] (the `self` param
#                     case), 0 for an in-place struct value. Mirrors
#                     codegen_x86._obj_is_pointer.
loc_struct_idx: Array[256, uint32]
loc_struct_is_ptr: Array[256, uint32]
loc_count: uint32 = 0
cg_stack_size: uint32 = 0

# -----------------------------------------------------------------------
# Function symbol table + call-fixup list.
#
# Each emitted function records its name (strbuf off/len) and its start
# offset in code[]. A `call` to a function whose body has not been emitted
# yet (forward reference, or any call at all in a two-function program) is
# recorded as a fixup: the rel32 field offset plus the callee name. After
# every function is emitted, resolve_calls() patches each fixup against the
# symbol table. This mirrors how codegen_x86.py defers symbol resolution to
# the assembler — we just do that resolution ourselves over raw bytes.
# -----------------------------------------------------------------------

MAX_FUNCS: uint32 = 1024
fn_name_off: Array[1024, uint32]
fn_name_len: Array[1024, uint32]
fn_offset: Array[1024, uint32]
fn_count: uint32 = 0

MAX_FIXUPS: uint32 = 8192
fx_at: Array[8192, uint32]          # rel32 field offset in code[]
fx_name_off: Array[8192, uint32]
fx_name_len: Array[8192, uint32]
fx_count: uint32 = 0

# -----------------------------------------------------------------------
# Class-method symbol table + method-call fixup list.
#
# A class method `def m(self, ...)` is emitted as a free function whose
# mangled identity is the PAIR (owner-class name, method name) — exactly the
# `<Class>__<method>` symbol of codegen_x86._method_symbol, but represented
# here as two strbuf slices instead of a synthesised string (codegen.ad has
# no string-builder). `obj.m(args)` records a method-call fixup carrying the
# resolved (owner-class name, method name) pair; resolve_method_calls()
# patches each against this table after every method body is emitted.
# Owner resolution (for inheritance) is done at the call site, mirroring
# codegen_x86's class_methods table first-match-wins walk.
# -----------------------------------------------------------------------
MAX_METHODS: uint32 = 1024
mfn_cls_off: Array[1024, uint32]
mfn_cls_len: Array[1024, uint32]
mfn_m_off: Array[1024, uint32]
mfn_m_len: Array[1024, uint32]
mfn_offset: Array[1024, uint32]
mfn_count: uint32 = 0

MAX_METHOD_FIXUPS: uint32 = 8192
mfx_at: Array[8192, uint32]
mfx_cls_off: Array[8192, uint32]
mfx_cls_len: Array[8192, uint32]
mfx_m_off: Array[8192, uint32]
mfx_m_len: Array[8192, uint32]
mfx_count: uint32 = 0

# -----------------------------------------------------------------------
# Data section: module-level (global) storage + interned string literals.
#
# codegen_x86.py keeps globals in named `.data`/`.bss` symbols and string
# literals in `.rodata`, letting the assembler+linker resolve every
# reference as RIP-relative (R_X86_64_PC32). Emitting raw bytes ourselves
# we model BOTH the storage and the relocations:
#
#   * gdata[] — a flat byte buffer; every global scalar/array and every
#     interned string is laid out into it at a stable byte offset.
#   * The emulated/loaded address space places this data section at a
#     fixed base DATA_BASE (== CODE_CAP) immediately past the code window,
#     so an x86_64 RIP-relative `disp32 = DATA_BASE + g_off - rip_field_end`
#     reaches the global. (On the real device the loader maps code and
#     this data buffer into one image; DATA_BASE is the data buffer's
#     virtual offset from the code base.)
#   * Every global reference is a RIP-relative `lea` of the global's
#     ADDRESS into %rax; scalars then dereference with the existing sized
#     mem load/store, arrays compute &g[i] then a sized load/store — the
#     SAME lowering the local path uses, only the base register changes
#     from %rbp (frame) to %rip (data). This mirrors codegen_x86's scalar
#     `leaq name(%rip),%rax ; movq (%rax),%rax` and aggregate
#     `leaq name(%rip),%rax` decay.
#   * Because a global may be referenced before its data slot's final
#     position is fixed (and to keep one uniform resolution path), each
#     RIP-lea records a data fixup; resolve_data_fixups() patches the
#     rel32 after all functions are emitted, exactly like resolve_calls().
# -----------------------------------------------------------------------

GDATA_CAP: uint32 = 65536
gdata: Array[65536, uint8]
gdata_len: uint32 = 0

# .bss model: zero-initialised globals (uninitialised scalars, `= 0`
# scalars/pointers, and ALL zero-init arrays) reserve VIRTUAL ADDRESS
# SPACE only — they advance bss_len but consume NO bytes in gdata[] and
# NO file storage. The .bss region sits immediately AFTER the .data
# region in the loaded image, at virtual base DATA_BASE + gdata_len (the
# final gdata_len, known only after all emission). On device the ELF
# loader zeroes the whole p_memsz span before copying p_filesz bytes, so
# the .bss tail is already zero-filled. This is what makes self-compile
# tractable: the compiler's own ~650 KiB of zero-init globals cost memsz,
# not file bytes.
bss_len: uint32 = 0

# Data section base address in the emulated/loaded address space. Chosen
# == CODE_CAP so [0,CODE_CAP) is code, [DATA_BASE, DATA_BASE+gdata_len) is
# initialised data (.data, stored in file), and [DATA_BASE+gdata_len,
# DATA_BASE+gdata_len+bss_len) is zero-init data (.bss, NOT stored). A
# clean, non-overlapping split the emulator and loader can dispatch on.
# MUST stay == CODE_CAP (see CODE_CAP above).
DATA_BASE: uint32 = 2097152

# Global symbol table: name (strbuf ref) -> data offset, element size and
# slot byte-width. glob_elem_size is non-zero for an Array global (the
# per-element width; glob_offset is element 0's address); 0 marks a scalar
# whose load/store width is glob_scalar_size (1/2/4/8).
MAX_GLOBALS: uint32 = 1024
glob_name_off: Array[1024, uint32]
glob_name_len: Array[1024, uint32]
glob_offset: Array[1024, uint32]        # byte offset into gdata[] (.data) OR
                                        # bss[] (.bss) per glob_is_bss
glob_elem_size: Array[1024, uint32]     # 0 = scalar; else Array element width
glob_scalar_size: Array[1024, uint32]   # scalar load/store width (1/2/4/8)
# Per-global .bss marker: 1 if the global is zero-init and lives in the
# .bss region (glob_offset is then a bss offset, resolved at fixup time
# against the FINAL gdata_len); 0 if it is initialised .data (glob_offset
# is a gdata[] byte offset).
glob_is_bss: Array[1024, uint32]
# Per-global pointer marker, same convention as loc_ptr_size: 0 = not a
# Ptr[T] global; non-zero = the pointee width (1/2/4/8). A Ptr[T] global is
# stored as an 8-byte scalar slot that HOLDS an address (glob_scalar_size is
# 8 for it); glob_ptr_size records the pointee width used when the global is
# indexed (g[i]). e.g. `lex_src: Ptr[uint8]` -> glob_ptr_size 1.
glob_ptr_size: Array[1024, uint32]
# Per-global SIGNEDNESS of a sub-8-byte scalar global: 1 if the scalar is a
# SIGNED type (int8/int16/int32) and must SIGN-extend on load (movsXq), 0 if
# unsigned/8-byte/array (zero-extend / no extend). Mirrors codegen_x86's
# emit_load_sized_signed: a signed narrower scalar global sign-extends so its
# wider (uint64/int64) use carries the correct two's-complement value. Set by
# glob_set_signed() right after a scalar glob_define.
glob_is_signed: Array[1024, uint32]
# Per-global ARRAY TYPE NODE id (the ND_ARRAY_TYPE from the decl) for an
# array global, else 0. Carries the FULL (possibly nested) array type so a
# multi-dimensional global `Array[N, Array[M, T]]` can be indexed level by
# level: the outer index scales by the row stride (M*sizeof(T)) and the
# inner index scales by sizeof(T). Mirrors codegen_x86 carrying the whole
# ArrayType and recursing through element_type. 0 for scalars/pointers/1-D
# where the flat glob_elem_size already suffices (kept for back-compat).
glob_type_node: Array[1024, uint32]
# Per-global struct-table index (+1) for a struct-typed global (an in-place
# struct value in .bss/.data); 0 for non-struct globals. Member access on a
# global resolves the layout via this.
glob_struct_idx: Array[1024, uint32]
# Per-global FLOAT WIDTH (0 = not a float, 4 = float32, 8 = float64) for a
# scalar float global. Distinguishes a float32 global (scalar_size 4) from an
# int32 one. Mirrors codegen_x86._float_width(get_expr_type(ident)) for a
# global identifier.
glob_is_float: Array[1024, uint32]
glob_count: uint32 = 0

# Data-section RIP-relative relocations. Each records the rel32 field's
# byte offset in code[] plus the target's data offset; resolve writes
# (DATA_BASE + data_off) - (at + 4).
MAX_DATA_FIXUPS: uint32 = 8192
df_at: Array[8192, uint32]              # rel32 field offset in code[]
df_data_off: Array[8192, uint32]       # target offset: into gdata[] (.data)
                                       # OR into .bss per df_is_bss
# Per-fixup .bss marker: 1 if the target is a .bss global (df_data_off is a
# bss offset, resolved against the FINAL gdata_len); 0 if it targets .data
# (or an interned string), where df_data_off is a gdata[] byte offset.
df_is_bss: Array[8192, uint32]
df_count: uint32 = 0

# Interned string-literal table: identical literals share one data slot,
# mirroring codegen_x86.add_string's dedup. Each entry records the strbuf
# source slice (off/len) and the data offset its NUL-terminated bytes were
# placed at.
MAX_STRINGS: uint32 = 2048
str_src_off: Array[2048, uint32]
str_src_len: Array[2048, uint32]
str_data_off: Array[2048, uint32]
str_count: uint32 = 0

# Float-constant pool: dedup an IEEE-754 constant (raw bit pattern + width)
# placed in the data section, mirroring codegen_x86's float_literals pool.
# fc_bits is the raw integer bit pattern (32- or 64-bit), fc_width the byte
# width, fc_data_off the gdata[] offset where the constant was emitted.
MAX_FLOAT_CONSTS: uint32 = 1024
fc_bits: Array[1024, uint64]
fc_width: Array[1024, uint32]
fc_data_off: Array[1024, uint32]
fc_count: uint32 = 0

# -----------------------------------------------------------------------
# Loop-label stack for break / continue.
#
# Each active `while` pushes one frame. `continue` jumps BACK to the loop's
# condition test (a known earlier offset = loop_cont_target). `break` jumps
# FORWARD to the loop exit, whose offset is not yet known when the break is
# emitted; each break therefore records a forward rel32 fixup in the
# per-loop break-fixup table, and gen_while backpatches them all to the exit
# point once the body is done. The stack supports nesting: break/continue
# always target the INNERMOST loop (the top frame).
# -----------------------------------------------------------------------
MAX_LOOPS: uint32 = 32
loop_cont_target: Array[32, uint32]    # condition-test offset (continue dest)
# Per-loop break-fixup list: a flat 2D table indexed [loop_depth*MAX_BRK + i].
MAX_BRK: uint32 = 64
loop_brk_at: Array[2048, uint32]       # 32 * 64 rel32-field offsets
loop_brk_n: Array[32, uint32]          # number of pending break fixups
loop_depth: uint32 = 0

# For-array hidden-index slots. A `for var in arr` loop needs a private
# index counter; codegen_x86 names it `__for_idx_<n>` as a local. We reserve
# one 8-byte slot per for-array loop in the prescan pass and key it by the
# ND_FOR node id so gen_for_array can recover its frame offset. (Range loops
# need no hidden index — they reuse the visible loop var.)
MAX_FOR_IDX: uint32 = 64
fi_node: Array[64, uint32]
fi_offset: Array[64, int32]
fi_count: uint32 = 0


# -----------------------------------------------------------------------
# Struct/class layout table.
#
# Mirrors codegen_x86.layout_struct + StructInfo. Each registered struct
# records its class name (strbuf ref), 8-byte-rounded total_size, and a
# flat field table (name ref + byte offset + load/store size). Field
# layout: each field aligned to its natural alignment (capped at 8); total
# rounded up to 8. Inheritance prepends base fields left-to-right,
# transitively (see layout_struct below).
#
# A struct-typed field's size is its struct total_size; a field whose type
# is itself a struct is laid out by VALUE (embedded). An array-typed field
# occupies count*elem bytes and DECAYS to its address on load.
#
# Per-class method tables are not stored separately: a method `def m(self,
# ...)` is emitted as a free function named `<Class>__<m>` (see
# method_symbol / collect_class_methods), and `obj.m(args)` lowers to a
# direct call to that mangled symbol passing &obj (or the pointer value if
# obj is a Ptr[Struct]) as arg0. The class table records, per class, the
# strbuf ref of every method name it declares (own + inherited) so a call
# site can confirm the method exists; the owner-resolution + mangled name
# are recomputed from the class chain at the call site.
# -----------------------------------------------------------------------

MAX_STRUCTS: uint32 = 256
st_name_off: Array[256, uint32]
st_name_len: Array[256, uint32]
st_total: Array[256, uint32]            # 8-byte-rounded total size
# Flat field arrays, indexed by a per-struct [field_base .. field_base+nfields).
st_field_base: Array[256, uint32]
st_nfields: Array[256, uint32]
# The class decl node (ND_CLASS) so method/base chains can be re-walked.
st_decl: Array[256, uint32]
st_count: uint32 = 0

MAX_STRUCT_FIELDS: uint32 = 4096
sf_name_off: Array[4096, uint32]
sf_name_len: Array[4096, uint32]
sf_offset: Array[4096, uint32]          # byte offset within the struct
sf_size: Array[4096, uint32]            # scalar load/store width, OR 0 for an
                                        # array-typed field (decays to address)
sf_is_signed: Array[4096, uint32]       # 1 if a signed sub-8-byte scalar field
sf_count: uint32 = 0

# Program declaration-chain head, stashed at layout time so a class can be
# looked up by name (for inheritance base resolution).
cg_prog_decls: uint32 = 0
# Current method's `self` receiver: frame offset of the self param slot (which
# holds the receiver ADDRESS, like any Ptr[Struct]) and the struct-table index
# (+1) of the receiver's class. cg_self_struct == 0 means "not in a method".
# The parser marks both the self PARAM and every `self` IDENT in the body with
# nd_aux==1 and an empty (name_off=0,len=0) name, so we resolve `self` by that
# marker rather than by name. Mirrors codegen_x86's `self: Ptr[Class]`.
cg_self_off: int32 = 0
cg_self_struct: uint32 = 0
# Running field-layout offset, used by the recursive field walk in
# layout_struct (Adder has no closures, so the accumulator is a global).
cg_layout_offset: uint32 = 0


def cg_init():
    code_len = 0
    cg_err = 0
    loc_count = 0
    cg_stack_size = 0
    fn_count = 0
    fx_count = 0
    gdata_len = 0
    bss_len = 0
    glob_count = 0
    df_count = 0
    str_count = 0
    loop_depth = 0
    fi_count = 0
    cg_entry_off = CG_ENTRY_NONE
    cg_err_reason = 0
    cg_err_node = 0
    st_count = 0
    sf_count = 0
    mfn_count = 0
    mfx_count = 0
    cg_prog_decls = 0
    cg_layout_offset = 0
    cg_self_off = 0
    cg_self_struct = 0


# Append one byte to the output buffer.
def emit_b(b: uint32):
    if code_len >= CODE_CAP:
        cg_fail(3, 0)
        return
    code[code_len] = cast[uint8](b & 255)
    code_len = code_len + 1


# Append a little-endian 32-bit immediate.
def emit_imm32(v: uint64):
    emit_b(cast[uint32](v & 255))
    emit_b(cast[uint32]((v >> 8) & 255))
    emit_b(cast[uint32]((v >> 16) & 255))
    emit_b(cast[uint32]((v >> 24) & 255))


# Emit a little-endian 8-byte immediate (for movabsq $imm64).
def emit_imm64(v: uint64):
    emit_b(cast[uint32](v & 255))
    emit_b(cast[uint32]((v >> 8) & 255))
    emit_b(cast[uint32]((v >> 16) & 255))
    emit_b(cast[uint32]((v >> 24) & 255))
    emit_b(cast[uint32]((v >> 32) & 255))
    emit_b(cast[uint32]((v >> 40) & 255))
    emit_b(cast[uint32]((v >> 48) & 255))
    emit_b(cast[uint32]((v >> 56) & 255))


# Compare a strbuf name slice [aoff,alen) against [boff,blen).
def name_match(aoff: uint32, alen: uint32, boff: uint32, blen: uint32) -> int32:
    if alen != blen:
        return 0
    i: uint32 = 0
    while i < alen:
        if strbuf[aoff + i] != strbuf[boff + i]:
            return 0
        i = i + 1
    return 1


# Allocate an 8-byte stack slot for a named parameter/local. Returns the
# negative %rbp-relative offset, mirroring alloc_local's growth direction.
def alloc_local(name_off: uint32, name_len: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    cg_stack_size = cg_stack_size + 8
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 0
    loc_scalar_size[loc_count] = 0
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Allocate an 8-byte slot for a Ptr[T] local/param. The slot HOLDS an
# address (the pointer's value), so it is sized like a scalar; ptr_size is
# the pointee width used when the pointer is indexed (p[i]). Returns the
# negative %rbp-relative offset. Mirrors alloc_local but records ptr-ness.
def alloc_ptr_local(name_off: uint32, name_len: uint32, ptr_size: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    cg_stack_size = cg_stack_size + 8
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = ptr_size
    loc_is_signed[loc_count] = 1     # a pointer is "unsigned" per _is_unsigned_type
    loc_scalar_size[loc_count] = 0   # a pointer slot is full 8-byte (no sized I/O)
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Allocate an Array local of `count` elements, each `elem_size` bytes,
# 8-byte-rounded so subsequent scalar slots stay 8-aligned (mirrors
# alloc_local(size=...) in codegen_x86.py). Returns the BASE offset (the
# address of element 0 = the lowest reserved address). Frame access uses
# disp32 (mod=10) addressing, so the offset may reach the whole frame — no
# -128 limit.
def alloc_array_local(name_off: uint32, name_len: uint32, count: uint32, elem_size: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    bytes_: uint32 = count * elem_size
    bytes_ = (bytes_ + 7) & cast[uint32](0xFFFFFFF8)
    cg_stack_size = cg_stack_size + bytes_
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = elem_size
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 1     # an array decays to an (unsigned) address
    loc_scalar_size[loc_count] = 0   # array base: not a sized scalar slot
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Allocate an in-place struct local: a slot reserving `total` bytes (rounded
# to 8) whose base address is taken via leaq, exactly like an Array local.
# Records the struct table index (+1) so member access resolves the layout.
# Mirrors codegen_x86's alloc_local(size=struct.total_size, var_type=Struct).
def alloc_struct_local(name_off: uint32, name_len: uint32, total: uint32, sidx1: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    bytes_: uint32 = (total + 7) & cast[uint32](0xFFFFFFF8)
    cg_stack_size = cg_stack_size + bytes_
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 1     # a struct decays to an (unsigned) address
    loc_scalar_size[loc_count] = 0
    loc_struct_idx[loc_count] = sidx1
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Tag the most-recently-allocated local as a Ptr[Struct] (the `self` param
# case): its slot HOLDS an address whose pointee is struct `sidx1-1`.
def loc_set_struct_ptr(sidx1: uint32):
    if loc_count > 0:
        loc_struct_idx[loc_count - 1] = sidx1
        loc_struct_is_ptr[loc_count - 1] = 1


# Look up an identifier's struct-table index (+1), or 0 if not a struct local.
def lookup_local_struct(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_struct_idx[i]
        i = i + 1
    return 0


# 1 if the named local is a Ptr[Struct] (vs an in-place struct value).
def lookup_local_struct_is_ptr(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_struct_is_ptr[i]
        i = i + 1
    return 0


# Look up an identifier's Ptr[T] pointee size: returns the pointee width for
# a Ptr[T] local, or 0 for a non-pointer / unknown name.
def lookup_ptr_size(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_ptr_size[i]
        i = i + 1
    return 0


# Look up an identifier's array element size: returns the element size for
# an Array local, or 0 for a scalar / unknown name.
def lookup_elem_size(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_elem_size[i]
        i = i + 1
    return 0


# Tag the most-recently-allocated local with a signedness tristate
# (0 unknown / 1 unsigned / 2 signed), derived from its declared type. Used
# so identifier operands feed the signed/unsigned setcc + div/mod choice.
def loc_set_signedness(s: uint32):
    if loc_count > 0:
        loc_is_signed[loc_count - 1] = s


# Tag the most-recently-allocated scalar local with its byte width (1/2/4/8)
# so sub-8-byte typed locals get sized stores + extending loads.
def loc_set_scalar_size(sz: uint32):
    if loc_count > 0:
        loc_scalar_size[loc_count - 1] = sz


# Look up a local/param's scalar width (0 if not a sized scalar / not a local).
def lookup_local_scalar_size(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_scalar_size[i]
        i = i + 1
    return 0


# Tag the most-recently-allocated local with its float width (4/8), or 0 for
# a non-float scalar. Set from the declared type's keyword code.
def loc_set_float(fw: uint32):
    if loc_count > 0:
        loc_is_float[loc_count - 1] = fw


# Look up a local/param's float width (0 if not a float / not a local).
def lookup_local_float(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_is_float[i]
        i = i + 1
    return 0


# Float width (0/4/8) of a primitive type node: float32 (code 10) -> 4,
# float64 (code 11) -> 8, else 0. Mirrors codegen_x86._float_width.
def type_float_width(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    if code == 10:
        return 4
    if code == 11:
        return 8
    return 0


# Float width (0/4/8) of an EXPRESSION, mirroring
# codegen_x86._float_width(get_expr_type(expr)) over this subset's nodes:
#   ND_FLOAT_LIT -> 8 (a bare float literal is a float64)
#   ND_CAST  -> the cast destination type's float width
#   ND_IDENT -> a local's float width, else a scalar global's float width
#   ND_BINARY (arith) -> wider of the two operands' float widths
#   everything else -> 0
def expr_float_width(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_FLOAT_LIT:
        return 8
    if k == ND_CAST:
        return type_float_width(nd_a[node])
    if k == ND_IDENT:
        lf: uint32 = lookup_local_float(nd_name_off[node], nd_name_len[node])
        if lf != 0:
            return lf
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            return glob_is_float[gi - 1]
        return 0
    if k == ND_BINARY:
        bop: uint32 = nd_aux[node]
        if bop == BINOP_ADD or bop == BINOP_SUB or bop == BINOP_MUL or bop == BINOP_DIV or bop == BINOP_IDIV:
            lw: uint32 = expr_float_width(nd_a[node])
            rw: uint32 = expr_float_width(nd_b[node])
            if lw == 0 and rw == 0:
                return 0
            if lw >= rw:
                return lw
            return rw
        return 0
    return 0


# Look up a local/param's signedness tristate (0/1/2). 0 if not a local.
def lookup_local_signedness(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_is_signed[i]
        i = i + 1
    return 0


# Map a primitive type node to a signedness tristate (0 unknown / 1 unsigned /
# 2 signed) mirroring codegen_x86._is_unsigned_type(get_expr_type): an int
# scalar resolves to 1 (unsigned) or 2 (signed); anything else is 0 (unknown).
def type_signedness(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    # 2=int8 3=int16 4=int32 5=int64/int  -> signed; 6..9 uint -> unsigned;
    # 12=bool 13=char -> unsigned. Other codes -> unknown.
    if code == 2 or code == 3 or code == 4 or code == 5:
        return 2
    if code == 6 or code == 7 or code == 8 or code == 9:
        return 1
    if code == 12 or code == 13:
        return 1
    return 0


# Signedness tristate (0 unknown / 1 unsigned / 2 signed) of an EXPRESSION,
# mirroring codegen_x86._is_unsigned_type(get_expr_type(expr)) for the node
# kinds this backend's subset produces:
#   ND_CAST  -> the cast's destination type signedness (cast[T] declares T)
#   ND_IDENT -> a local's recorded signedness, else a global's signedness
#               (scalar globals: glob_is_signed=1 means signed; an array/ptr
#                global decays to an unsigned address)
#   everything else (binop, literal, call, index) -> 0 (unknown)
# get_expr_type has NO BinaryExpr case, so an arithmetic sub-expression is
# UNKNOWN here too — matching the oracle's gt=None for binops.
def expr_signedness(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_CAST:
        return type_signedness(nd_a[node])
    if k == ND_IDENT:
        ls: uint32 = lookup_local_signedness(nd_name_off[node], nd_name_len[node])
        if ls != 0:
            return ls
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            if glob_elem_size[gi - 1] != 0:
                return 1            # array global decays to an address
            if glob_is_signed[gi - 1] != 0:
                return 2            # signed sub-8-byte scalar global
            return 1                # unsigned / 8-byte scalar global
        return 0
    return 0


# Pick the relational setcc opcode. codegen_x86._rel_cc: default SIGNED
# (setl/setle/setg/setge), switch to the UNSIGNED family (setb/setbe/seta/
# setae) when EITHER operand is known-unsigned (signedness tristate == 1).
#   signed   setl 9C  setle 9E  setg 9F  setge 9D
#   unsigned setb 92  setbe 96  seta 97  setae 93
def rel_setcc(signed_cc: uint32, l_sgn: uint32, r_sgn: uint32) -> uint32:
    if l_sgn == 1 or r_sgn == 1:
        if signed_cc == 0x9C:        # setl  -> setb
            return 0x92
        if signed_cc == 0x9E:        # setle -> setbe
            return 0x96
        if signed_cc == 0x9F:        # setg  -> seta
            return 0x97
        if signed_cc == 0x9D:        # setge -> setae
            return 0x93
    return signed_cc


# Decide whether a `/` `%` `>>` uses the SIGNED machine instruction. Mirrors
# codegen_x86._binop_signed_op: either operand known-unsigned -> UNSIGNED;
# else SIGNED iff some operand is known-signed; all-unknown -> UNSIGNED.
def binop_use_signed(l_sgn: uint32, r_sgn: uint32) -> uint32:
    if l_sgn == 1 or r_sgn == 1:
        return 0
    if l_sgn == 2 or r_sgn == 2:
        return 1
    return 0


# Resolve an identifier name to its frame offset. Returns 1 on hit and
# writes the offset through out_off; returns 0 on miss.
def lookup_local(name_off: uint32, name_len: uint32, out_off: Ptr[int32]) -> int32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            out_off[0] = loc_offset[i]
            return 1
        i = i + 1
    return 0


# Register an emitted function's symbol -> code offset.
def fn_define(name_off: uint32, name_len: uint32, off: uint32):
    if fn_count >= MAX_FUNCS:
        cg_fail(6, 0)
        return
    fn_name_off[fn_count] = name_off
    fn_name_len[fn_count] = name_len
    fn_offset[fn_count] = off
    fn_count = fn_count + 1


# Record a pending call relocation at rel32-field offset `at`.
def add_call_fixup(at: uint32, name_off: uint32, name_len: uint32):
    if fx_count >= MAX_FIXUPS:
        cg_fail(5, 0)
        return
    fx_at[fx_count] = at
    fx_name_off[fx_count] = name_off
    fx_name_len[fx_count] = name_len
    fx_count = fx_count + 1


# Resolve all recorded call fixups against the function symbol table.
def resolve_calls():
    i: uint32 = 0
    while i < fx_count:
        j: uint32 = 0
        found: uint32 = 0
        while j < fn_count:
            if name_match(fn_name_off[j], fn_name_len[j], fx_name_off[i], fx_name_len[i]) != 0:
                patch_rel32(fx_at[i], fn_offset[j])
                found = 1
                j = fn_count
            else:
                j = j + 1
        if found == 0:
            # Unknown callee — outside this subset (no extern linkage here).
            cg_fail(7, 0)
        i = i + 1


# -----------------------------------------------------------------------
# EXTERN LINKAGE — runtime syscall-wrapper synthesis.
#
# The frozen Python seed compiles a `.ad` unit to assembly, then `ld`-links
# it against user/runtime.S — a fixed library of thin `sys_*` syscall
# wrappers (`_start`, `sys_write`, `sys_read`, ...). Every `extern def
# sys_*` in the real userland tree resolves, at link time, to one of those
# wrappers (a `mov $N,%rax; syscall; ret` stub).
#
# The self-hosted `.ad` compiler has no external `ld` step (elf_emit.ad
# emits one self-contained ELF). To match the seed's BEHAVIORAL result we
# resolve+link those known runtime symbols DIRECTLY: for every unresolved
# call fixup whose name is a known runtime `sys_*` symbol, we synthesize the
# SAME wrapper body in-image (a real emitted function) and define its
# symbol, so resolve_calls() patches the call against it exactly as `ld`
# would have. This is the "resolve+link the known runtime symbols directly"
# option from the cutover plan — behaviorally identical to the seed's
# ld-against-runtime.S, no byte-identity claimed (the seed routes through
# `as`/`ld`; we emit raw bytes).
#
# Argument marshaling note: gen_call() loads args into the SysV arg
# registers (rdi/rsi/rdx/rcx/r8/r9) before the `call`. The Linux syscall
# ABI uses r10 for arg4 (not rcx). So every wrapper prepends `mov %rcx,%r10`
# — harmless for syscalls with <4 args (rcx is caller-clobbered and unused),
# and the required shuffle for 4+ arg syscalls (mmap, socketpair, link,
# symlink, ...). This mirrors runtime.S's per-wrapper `movq %rcx,%r10`.
# `sys_rfork` additionally supplies a5 = the parent user %rbp (mov %rbp,%r9),
# exactly as runtime.S's sys_rfork wrapper does.
# -----------------------------------------------------------------------

# Compare a strbuf name slice [name_off,name_len) against a NUL-terminated
# C string literal. Returns 1 on an exact match (same length, same bytes).
def name_eq_cstr(name_off: uint32, name_len: uint32, lit: Ptr[uint8]) -> int32:
    i: uint32 = 0
    while i < name_len:
        c: uint32 = cast[uint32](lit[i])
        if c == 0:
            return 0                      # literal shorter than the name
        if cast[uint32](strbuf[name_off + i]) != c:
            return 0
        i = i + 1
    # Name fully matched; the literal must end exactly here.
    if cast[uint32](lit[name_len]) != 0:
        return 0
    return 1


# Map a referenced extern symbol name to its Linux x86_64 syscall number.
# Returns syscall_number + 1 (so 0 unambiguously means "not a known runtime
# symbol"). The number/name pairs mirror the `movq $N,%rax` in each
# user/runtime.S wrapper; this table is the in-`.ad` stand-in for linking
# against runtime.S. Keep it IN LOCKSTEP with user/runtime.S (the frozen
# oracle's link target).
def runtime_syscall_num(name_off: uint32, name_len: uint32) -> uint32:
    if name_eq_cstr(name_off, name_len, "sys_putc") != 0:
        return 0 + 1
    if name_eq_cstr(name_off, name_len, "sys_exit") != 0:
        return 1 + 1
    if name_eq_cstr(name_off, name_len, "sys_get_jiffies") != 0:
        return 2 + 1
    if name_eq_cstr(name_off, name_len, "sys_getpid") != 0:
        return 4 + 1
    if name_eq_cstr(name_off, name_len, "sys_open") != 0:
        return 5 + 1
    if name_eq_cstr(name_off, name_len, "sys_read") != 0:
        return 6 + 1
    if name_eq_cstr(name_off, name_len, "sys_close") != 0:
        return 7 + 1
    if name_eq_cstr(name_off, name_len, "sys_write") != 0:
        return 8 + 1
    if name_eq_cstr(name_off, name_len, "sys_lseek") != 0:
        return 9 + 1
    if name_eq_cstr(name_off, name_len, "sys_execve") != 0:
        return 10 + 1
    if name_eq_cstr(name_off, name_len, "sys_open_write") != 0:
        return 13 + 1
    if name_eq_cstr(name_off, name_len, "sys_dup") != 0:
        return 16 + 1
    if name_eq_cstr(name_off, name_len, "sys_dup2") != 0:
        return 17 + 1
    if name_eq_cstr(name_off, name_len, "sys_getcwd") != 0:
        return 20 + 1
    if name_eq_cstr(name_off, name_len, "sys_unlink") != 0:
        return 21 + 1
    if name_eq_cstr(name_off, name_len, "sys_mkdir") != 0:
        return 22 + 1
    if name_eq_cstr(name_off, name_len, "sys_read_nb") != 0:
        return 23 + 1
    if name_eq_cstr(name_off, name_len, "sys_yield") != 0:
        return 24 + 1
    if name_eq_cstr(name_off, name_len, "sys_rfork") != 0:
        return 256 + 1
    if name_eq_cstr(name_off, name_len, "sys_bind") != 0:
        return 257 + 1
    if name_eq_cstr(name_off, name_len, "sys_resolve") != 0:
        return 269 + 1
    if name_eq_cstr(name_off, name_len, "sys_srv_post") != 0:
        return 275 + 1
    if name_eq_cstr(name_off, name_len, "sys_netcfg") != 0:
        return 286 + 1
    if name_eq_cstr(name_off, name_len, "sys_fdslot_kind") != 0:
        return 287 + 1
    if name_eq_cstr(name_off, name_len, "sys_set_realtime") != 0:
        return 292 + 1
    if name_eq_cstr(name_off, name_len, "sys_useradd_root") != 0:
        return 295 + 1
    if name_eq_cstr(name_off, name_len, "sys_resolve_ptr") != 0:
        return 301 + 1
    if name_eq_cstr(name_off, name_len, "sys_mmap") != 0:
        return 302 + 1
    if name_eq_cstr(name_off, name_len, "sys_munmap") != 0:
        return 304 + 1
    if name_eq_cstr(name_off, name_len, "sys_symlink") != 0:
        return 305 + 1
    if name_eq_cstr(name_off, name_len, "sys_link") != 0:
        return 306 + 1
    if name_eq_cstr(name_off, name_len, "sys_umdf_mmio_map") != 0:
        return 321 + 1
    if name_eq_cstr(name_off, name_len, "sys_umdf_dma_alloc") != 0:
        return 322 + 1
    if name_eq_cstr(name_off, name_len, "sys_umdf_irq_open") != 0:
        return 323 + 1
    if name_eq_cstr(name_off, name_len, "sys_socketpair") != 0:
        return 53 + 1
    return 0


# Emit one runtime syscall-wrapper function body at the current code_len and
# register its symbol. `syscall_num` is the raw Linux syscall number. The
# body mirrors the corresponding user/runtime.S wrapper:
#
#   [rfork only]  48 89 E9? no — mov %rbp,%r9  : 49 89 E9   (a5 = parent rbp)
#   mov %rcx,%r10                               : 49 89 CA   (arg4 shuffle)
#   mov $syscall_num,%rax                       : 48 C7 C0 <imm32>
#   syscall                                     : 0F 05
#   ret                                         : C3
def emit_runtime_wrapper(name_off: uint32, name_len: uint32, syscall_num: uint32):
    start: uint32 = code_len
    fn_define(name_off, name_len, start)
    # sys_rfork supplies a5 = parent user %rbp in %r9 (mirrors runtime.S).
    if name_eq_cstr(name_off, name_len, "sys_rfork") != 0:
        # mov %rbp,%r9  -> 49 89 E9
        emit_b(0x49)
        emit_b(0x89)
        emit_b(0xE9)
    # mov %rcx,%r10  -> 49 89 CA  (SysV arg4 -> syscall-ABI arg4; harmless if
    # the syscall has fewer than 4 args, as rcx is then unused).
    emit_b(0x49)
    emit_b(0x89)
    emit_b(0xCA)
    # mov $syscall_num,%rax  -> 48 C7 C0 <imm32>
    emit_b(0x48)
    emit_b(0xC7)
    emit_b(0xC0)
    emit_imm32(cast[uint64](syscall_num))
    # syscall
    emit_b(0x0F)
    emit_b(0x05)
    # ret
    emit_b(0xC3)


# Scan every pending call fixup; for each one naming a known runtime `sys_*`
# symbol that has NOT already been emitted as a function, synthesize its
# wrapper body in-image and define its symbol. Run BEFORE resolve_calls() so
# the freshly-defined wrapper symbols are visible to fixup resolution. This
# is the EXTERN LINKAGE step: it links the unit against the in-`.ad` runtime
# library exactly as the seed `ld`-links against user/runtime.S.
def link_runtime_externs():
    i: uint32 = 0
    while i < fx_count:
        noff: uint32 = fx_name_off[i]
        nlen: uint32 = fx_name_len[i]
        # Already satisfied by a real in-unit function? Skip.
        if fn_lookup_offset(noff, nlen) == CG_ENTRY_NONE:
            num1: uint32 = runtime_syscall_num(noff, nlen)
            if num1 != 0:
                emit_runtime_wrapper(noff, nlen, num1 - 1)
        i = i + 1


# Register an emitted method symbol: (owner-class name, method name) pair ->
# code offset. Mirrors fn_define for the `<Class>__<method>` mangled symbol.
def mfn_define(cls_off: uint32, cls_len: uint32, m_off: uint32, m_len: uint32, off: uint32):
    if mfn_count >= MAX_METHODS:
        cg_fail(6, 0)
        return
    mfn_cls_off[mfn_count] = cls_off
    mfn_cls_len[mfn_count] = cls_len
    mfn_m_off[mfn_count] = m_off
    mfn_m_len[mfn_count] = m_len
    mfn_offset[mfn_count] = off
    mfn_count = mfn_count + 1


# Record a pending method-call relocation at rel32-field offset `at`, keyed by
# the resolved (owner-class name, method name) pair.
def add_method_fixup(at: uint32, cls_off: uint32, cls_len: uint32, m_off: uint32, m_len: uint32):
    if mfx_count >= MAX_METHOD_FIXUPS:
        cg_fail(5, 0)
        return
    mfx_at[mfx_count] = at
    mfx_cls_off[mfx_count] = cls_off
    mfx_cls_len[mfx_count] = cls_len
    mfx_m_off[mfx_count] = m_off
    mfx_m_len[mfx_count] = m_len
    mfx_count = mfx_count + 1


# Resolve all method-call fixups against the method symbol table.
def resolve_method_calls():
    i: uint32 = 0
    while i < mfx_count:
        j: uint32 = 0
        found: uint32 = 0
        while j < mfn_count:
            if name_match(mfn_cls_off[j], mfn_cls_len[j], mfx_cls_off[i], mfx_cls_len[i]) != 0 and name_match(mfn_m_off[j], mfn_m_len[j], mfx_m_off[i], mfx_m_len[i]) != 0:
                patch_rel32(mfx_at[i], mfn_offset[j])
                found = 1
                j = mfn_count
            else:
                j = j + 1
        if found == 0:
            cg_fail(7, 0)
        i = i + 1


# Look up an emitted function's code offset by its strbuf name slice.
# Returns the function's code offset, or CG_ENTRY_NONE if no function with
# that name was emitted (does NOT set cg_err — callers decide).
def fn_lookup_offset(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < fn_count:
        if name_match(fn_name_off[i], fn_name_len[i], name_off, name_len) != 0:
            return fn_offset[i]
        i = i + 1
    return CG_ENTRY_NONE


# Compare an emitted function's strbuf name slice against the literal
# bytes "main". Returns 1 on match. Used to resolve the entry by name
# without needing a strbuf-resident copy of the literal.
def fn_name_is_main(name_off: uint32, name_len: uint32) -> int32:
    if name_len != 4:
        return 0
    if strbuf[name_off] != 109:      # 'm'
        return 0
    if strbuf[name_off + 1] != 97:   # 'a'
        return 0
    if strbuf[name_off + 2] != 105:  # 'i'
        return 0
    if strbuf[name_off + 3] != 110:  # 'n'
        return 0
    return 1


# Detect a syscall BUILTIN callee by name. The self-hosted compiler has no
# extern/libc linkage, so on-device syscalls are issued via inline builtins
# named `__syscallN` where N (1..6) is the number of syscall ARGUMENTS that
# follow the syscall number. The call form is:
#       __syscallN(num, a1, ..., aN)
# i.e. N+1 actual arguments. Returns N (1..6) on match, or 0 if the name is
# not a syscall builtin. The match is the literal prefix "__syscall" (9
# bytes) followed by exactly one ASCII digit '1'..'6'.
def syscall_builtin_args(name_off: uint32, name_len: uint32) -> uint32:
    if name_len != 10:
        return 0
    # "__syscall" = 5f 5f 73 79 73 63 61 6c 6c
    if strbuf[name_off] != 95:        # '_'
        return 0
    if strbuf[name_off + 1] != 95:    # '_'
        return 0
    if strbuf[name_off + 2] != 115:   # 's'
        return 0
    if strbuf[name_off + 3] != 121:   # 'y'
        return 0
    if strbuf[name_off + 4] != 115:   # 's'
        return 0
    if strbuf[name_off + 5] != 99:    # 'c'
        return 0
    if strbuf[name_off + 6] != 97:    # 'a'
        return 0
    if strbuf[name_off + 7] != 108:   # 'l'
        return 0
    if strbuf[name_off + 8] != 108:   # 'l'
        return 0
    d: uint32 = cast[uint32](strbuf[name_off + 9])
    if d < 49 or d > 54:              # '1'..'6'
        return 0
    return d - 48


# Resolve the program ENTRY offset by name: prefer a function literally
# named `main`; otherwise fall back to `first_off` (the first emitted
# function's offset, preserving the historical offset-0 entry behaviour for
# the selftests). Stores the chosen offset in cg_entry_off and returns it.
def resolve_entry(first_off: uint32) -> uint32:
    i: uint32 = 0
    while i < fn_count:
        if fn_name_is_main(fn_name_off[i], fn_name_len[i]) != 0:
            cg_entry_off = fn_offset[i]
            return cg_entry_off
        i = i + 1
    cg_entry_off = first_off
    return cg_entry_off


# -----------------------------------------------------------------------
# Data section management.
# -----------------------------------------------------------------------

# Reserve `n` bytes in gdata[], zero-initialised, returning the byte
# offset of the reserved block.
def gdata_reserve(n: uint32) -> uint32:
    if gdata_len + n > GDATA_CAP:
        cg_fail(4, 0)
        return 0
    off: uint32 = gdata_len
    i: uint32 = 0
    while i < n:
        gdata[off + i] = 0
        i = i + 1
    gdata_len = gdata_len + n
    return off


# Reserve `n` bytes of .bss (zero-init) virtual address space, returning
# the byte offset of the reserved block WITHIN the .bss region. NO bytes
# are written to any buffer and NO file storage is consumed — only the
# memsz counter advances. The .bss region's virtual base (DATA_BASE +
# gdata_len) is not final until all functions emit, so bss offsets are
# resolved against the final gdata_len in resolve_data_fixups().
def bss_reserve(n: uint32) -> uint32:
    off: uint32 = bss_len
    bss_len = bss_len + n
    return off


# Append one byte to the data section, returning its offset.
def gdata_emit_b(b: uint32) -> uint32:
    if gdata_len >= GDATA_CAP:
        cg_fail(4, 0)
        return 0
    off: uint32 = gdata_len
    gdata[off] = cast[uint8](b & 255)
    gdata_len = gdata_len + 1
    return off


# Register a global scalar (elem_size 0) or array (elem_size 1/2/4/8). The
# data slot is reserved here. Returns the assigned data offset.
def glob_define(name_off: uint32, name_len: uint32, data_off: uint32, elem_size: uint32, scalar_size: uint32) -> uint32:
    if glob_count >= MAX_GLOBALS:
        cg_fail(6, 0)
        return 0
    glob_name_off[glob_count] = name_off
    glob_name_len[glob_count] = name_len
    glob_offset[glob_count] = data_off
    glob_elem_size[glob_count] = elem_size
    glob_scalar_size[glob_count] = scalar_size
    glob_ptr_size[glob_count] = 0
    glob_is_bss[glob_count] = 0
    glob_is_signed[glob_count] = 0
    glob_type_node[glob_count] = 0
    glob_struct_idx[glob_count] = 0
    glob_is_float[glob_count] = 0
    glob_count = glob_count + 1
    return data_off


# Mark the most recently defined global as living in .bss (zero-init): its
# glob_offset is a .bss offset, resolved against the final gdata_len.
def glob_set_bss():
    if glob_count > 0:
        glob_is_bss[glob_count - 1] = 1


# Mark the most recently defined global as a Ptr[T] whose pointee width is
# `ptr_size`. The global is otherwise an 8-byte scalar slot that holds an
# address; this records the pointee width consulted when it is indexed.
def glob_set_ptr_size(ptr_size: uint32):
    if glob_count > 0:
        glob_ptr_size[glob_count - 1] = ptr_size


# Mark the most recently defined scalar global as SIGNED (int8/int16/int32),
# so a sub-8-byte load sign-extends into the 64-bit register (movsXq) — the
# mirror of codegen_x86's emit_load_sized_signed. Only meaningful for scalar
# widths 1/2/4; an 8-byte scalar needs no extension.
def glob_set_signed():
    if glob_count > 0:
        glob_is_signed[glob_count - 1] = 1


# Tag the most recently defined global with its float width (4/8), so a
# global float identifier routes to the SSE path. Mirrors codegen_x86's
# _float_width over a global's recorded type.
def glob_set_float(fw: uint32):
    if glob_count > 0:
        glob_is_float[glob_count - 1] = fw


# Record the FULL array type node for the most recently defined array
# global, enabling multi-dimensional indexing (the outer index scales by the
# nested row stride). 1-D arrays may also set this; it is consulted only
# when a nested index is encountered, so it never changes 1-D behaviour.
def glob_set_type_node(tnode: uint32):
    if glob_count > 0:
        glob_type_node[glob_count - 1] = tnode


# Mark the most recently defined global as a struct-typed in-place value of
# struct `sidx1-1`, so member access resolves its layout.
def glob_set_struct(sidx1: uint32):
    if glob_count > 0:
        glob_struct_idx[glob_count - 1] = sidx1


# Resolve a name to a global table index. Returns the index+1 (so a 0
# return means "not a global"); the caller subtracts 1.
def glob_lookup(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < glob_count:
        if name_match(glob_name_off[i], glob_name_len[i], name_off, name_len) != 0:
            return i + 1
        i = i + 1
    return 0


# Record a RIP-relative data relocation at rel32-field offset `at`,
# targeting `data_off`. `is_bss` distinguishes a .data target (data_off is
# a gdata[] byte offset) from a .bss target (data_off is a .bss offset,
# resolved against the final gdata_len in resolve_data_fixups()).
def add_data_fixup(at: uint32, data_off: uint32, is_bss: uint32):
    if df_count >= MAX_DATA_FIXUPS:
        cg_fail(5, 0)
        return
    df_at[df_count] = at
    df_data_off[df_count] = data_off
    df_is_bss[df_count] = is_bss
    df_count = df_count + 1


# Patch every recorded data relocation: disp32 = target - (at + 4), the
# RIP-relative displacement from the instruction's end to the global's
# address in the laid-out image. By the time this runs gdata_len is FINAL
# (all string interning done), so the .bss base (DATA_BASE + gdata_len) is
# known.
#   .data fixup: target = DATA_BASE + df_data_off[i]
#   .bss  fixup: target = DATA_BASE + gdata_len + df_data_off[i]
def resolve_data_fixups():
    i: uint32 = 0
    while i < df_count:
        target: uint32 = DATA_BASE + df_data_off[i]
        if df_is_bss[i] != 0:
            target = DATA_BASE + gdata_len + df_data_off[i]
        patch_rel32(df_at[i], target)
        i = i + 1


# Intern a string literal whose bytes live in strbuf[src_off..src_off+len).
# Returns its data-section offset. Identical literals (same strbuf slice
# content) collapse to one slot. The bytes are copied into gdata[] and a
# trailing NUL is appended (matching codegen_x86's `.asciz`).
def intern_string(src_off: uint32, src_len: uint32) -> uint32:
    # Dedup against already-interned strings by content equality.
    i: uint32 = 0
    while i < str_count:
        if name_match(str_src_off[i], str_src_len[i], src_off, src_len) != 0:
            return str_data_off[i]
        i = i + 1
    # Place the bytes + NUL into the data section.
    base: uint32 = gdata_reserve(src_len + 1)
    j: uint32 = 0
    while j < src_len:
        gdata[base + j] = strbuf[src_off + j]
        j = j + 1
    gdata[base + src_len] = 0
    if str_count < MAX_STRINGS:
        str_src_off[str_count] = src_off
        str_src_len[str_count] = src_len
        str_data_off[str_count] = base
        str_count = str_count + 1
    else:
        cg_fail(6, 0)
    return base


# Intern an IEEE-754 float constant (raw bit pattern `bits`, byte `width`)
# into the data section, deduped by (width, bits). Returns its gdata[] byte
# offset. Mirrors codegen_x86.add_float_const + the .rodata emission: the raw
# little-endian bytes of the bit pattern are placed in initialised data.
def intern_float_const(bits: uint64, width: uint32) -> uint32:
    i: uint32 = 0
    while i < fc_count:
        if fc_width[i] == width and fc_bits[i] == bits:
            return fc_data_off[i]
        i = i + 1
    base: uint32 = gdata_reserve(width)
    v: uint64 = bits
    j: uint32 = 0
    while j < width:
        gdata[base + j] = cast[uint8](v & 255)
        v = v >> 8
        j = j + 1
    if fc_count < MAX_FLOAT_CONSTS:
        fc_bits[fc_count] = bits
        fc_width[fc_count] = width
        fc_data_off[fc_count] = base
        fc_count = fc_count + 1
    else:
        cg_fail(6, 0)
    return base


# -----------------------------------------------------------------------
# Instruction emitters (encodings authoritative per codegen_x86.py's
# AT&T mnemonics; bytes are the standard SysV AMD64 encodings).
# -----------------------------------------------------------------------

# endbr64  -> F3 0F 1E FA
def emit_endbr64():
    emit_b(0xF3)
    emit_b(0x0F)
    emit_b(0x1E)
    emit_b(0xFA)


# pushq %rbp  -> 55
def emit_push_rbp():
    emit_b(0x55)


# popq %rbp   -> 5D   (part of `leave`; kept for completeness, unused)
def emit_pop_rbp():
    emit_b(0x5D)


# movq %rsp, %rbp  -> 48 89 E5
def emit_mov_rsp_rbp():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xE5)


# subq $imm32, %rsp  -> 48 81 EC imm32
def emit_sub_rsp(imm: uint32):
    emit_b(0x48)
    emit_b(0x81)
    emit_b(0xEC)
    emit_imm32(cast[uint64](imm))


# leave  -> C9
def emit_leave():
    emit_b(0xC9)


# ret    -> C3
def emit_ret():
    emit_b(0xC3)


# pushq %rax  -> 50
def emit_push_rax():
    emit_b(0x50)


# popq %rax   -> 58
def emit_pop_rax():
    emit_b(0x58)


# popq %rcx   -> 59
def emit_pop_rcx():
    emit_b(0x59)


# movq $imm32, %rax (sign-extended) -> 48 C7 C0 imm32
# Materialize a 64-bit immediate into %rax. The compact `movq $imm32,%rax`
# (48 C7 C0 <imm32>) SIGN-EXTENDS its 32-bit immediate to 64 bits, so it can
# only carry values in the signed-32-bit range [-2^31, 2^31). For anything
# outside that range we MUST use `movabsq $imm64,%rax` (48 B8 <imm64>) or the
# high bits are lost / mis-sign-extended. This mirrors codegen_x86.gen_expr's
# IntLiteral case (movq for signed-32 range, else movabsq). Without it a
# literal like 2745498085935061697 collapses to its sign-extended low 32 bits.
def emit_mov_imm_rax(v: uint64):
    # In signed-32 range iff v <= 0x7FFFFFFF (small non-negative) or
    # v >= 0xFFFFFFFF80000000 (a value whose two's-complement is >= -2^31).
    if v <= cast[uint64](0x7FFFFFFF) or v >= cast[uint64](0xFFFFFFFF80000000):
        emit_b(0x48)
        emit_b(0xC7)
        emit_b(0xC0)
        emit_imm32(v)
        return
    # movabsq $imm64, %rax  -> 48 B8 <8-byte little-endian immediate>
    emit_b(0x48)
    emit_b(0xB8)
    emit_imm64(v)


# addq %rcx, %rax  -> 48 01 C8
def emit_add_rcx_rax():
    emit_b(0x48)
    emit_b(0x01)
    emit_b(0xC8)


# subq %rcx, %rax  -> 48 29 C8
def emit_sub_rcx_rax():
    emit_b(0x48)
    emit_b(0x29)
    emit_b(0xC8)


# imulq %rcx, %rax  -> 48 0F AF C1
def emit_imul_rcx_rax():
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0xAF)
    emit_b(0xC1)


# andq %rcx, %rax  -> 48 21 C8
def emit_and_rcx_rax():
    emit_b(0x48)
    emit_b(0x21)
    emit_b(0xC8)


# orq %rcx, %rax  -> 48 09 C8
def emit_or_rcx_rax():
    emit_b(0x48)
    emit_b(0x09)
    emit_b(0xC8)


# xorq %rcx, %rax  -> 48 31 C8
def emit_xor_rcx_rax():
    emit_b(0x48)
    emit_b(0x31)
    emit_b(0xC8)


# shlq %cl, %rax  -> 48 D3 E0   (shift count in %cl)
def emit_shl_cl_rax():
    emit_b(0x48)
    emit_b(0xD3)
    emit_b(0xE0)


# shrq %cl, %rax  -> 48 D3 E8   (logical right shift; unsigned default,
# matching gen_binary's all-unknown-type rule in codegen_x86.py)
def emit_shr_cl_rax():
    emit_b(0x48)
    emit_b(0xD3)
    emit_b(0xE8)


# Unsigned 64/64 division: xorq %rdx,%rdx ; divq %rcx. Quotient -> %rax,
# remainder -> %rdx. Mirrors gen_binary's unsigned DIV/MOD path (the
# default when no operand type is statically known-signed, which is the
# case for this type-erased subset).
# xorq %rdx, %rdx  -> 48 31 D2
def emit_xor_rdx_rdx():
    emit_b(0x48)
    emit_b(0x31)
    emit_b(0xD2)


# divq %rcx  -> 48 F7 F1
def emit_div_rcx():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xF1)


# Signed 64/64 division setup: cqo sign-extends %rax into %rdx:%rax (the
# signed analogue of xorq %rdx,%rdx), then idivq %rcx. Mirrors codegen_x86's
# signed DIV/MOD path (_binop_signed_op == True). Quotient -> %rax,
# remainder -> %rdx, both truncating toward zero (x86 idiv semantics).
# cqo  -> 48 99
def emit_cqo():
    emit_b(0x48)
    emit_b(0x99)


# idivq %rcx  -> 48 F7 F9
def emit_idiv_rcx():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xF9)


# sarq %cl, %rax  -> 48 D3 F8   (arithmetic right shift; signed `>>`)
def emit_sar_cl_rax():
    emit_b(0x48)
    emit_b(0xD3)
    emit_b(0xF8)


# movq %rdx, %rax  -> 48 89 D0   (move remainder into %rax for MOD)
def emit_mov_rdx_rax():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xD0)


# movq %rax, %rcx  -> 48 89 C1
def emit_mov_rax_rcx():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xC1)


# negq %rax  -> 48 F7 D8
def emit_neg_rax():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xD8)


# notq %rax  -> 48 F7 D0
def emit_not_rax():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xD0)


# setz %al  -> 0F 94 C0  (alias of sete; used by logical NOT)
# setne %al -> 0F 95 C0
# setne %cl -> 0F 95 C1
def emit_setne_cl():
    emit_b(0x0F)
    emit_b(0x95)
    emit_b(0xC1)


# movzbq %cl, %rcx  -> 48 0F B6 C9  (bool-ify %rcx for logical and/or)
def emit_movzx_cl_rcx():
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0xB6)
    emit_b(0xC9)


# =======================================================================
# Scalar SSE floating point (mirrors codegen_x86's FP emitters).
# FP values transit %rax/%rcx as their raw IEEE bit pattern; SSE registers
# %xmm0/%xmm1 are used only at the op site. Byte encodings are the standard
# SysV AMD64 SSE/SSE2 forms, matching the GNU `as` output codegen_x86 emits.
# =======================================================================

# movd %eax, %xmm0   -> 66 0F 6E C0   (low 32 bits of %rax -> xmm0)
def emit_movd_eax_xmm0():
    emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC0)


# movd %ecx, %xmm1   -> 66 0F 6E C9
def emit_movd_ecx_xmm1():
    emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC9)


# movd %xmm0, %eax   -> 66 0F 7E C0   (xmm0 low 32 -> %eax, zero-extends %rax)
def emit_movd_xmm0_eax():
    emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x7E)
    emit_b(0xC0)


# movq %rax, %xmm0   -> 66 48 0F 6E C0
def emit_movq_rax_xmm0():
    emit_b(0x66)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC0)


# movq %rcx, %xmm1   -> 66 48 0F 6E C9
def emit_movq_rcx_xmm1():
    emit_b(0x66)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC9)


# movq %xmm0, %rax   -> 66 48 0F 7E C0
def emit_movq_xmm0_rax():
    emit_b(0x66)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x7E)
    emit_b(0xC0)


# Move the low `width` bytes of %rax into %xmm0 (movd for 4, movq for 8).
def emit_gpr_rax_to_xmm0(width: uint32):
    if width == 4:
        emit_movd_eax_xmm0()
    else:
        emit_movq_rax_xmm0()


# Move the low `width` bytes of %rcx into %xmm1.
def emit_gpr_rcx_to_xmm1(width: uint32):
    if width == 4:
        emit_movd_ecx_xmm1()
    else:
        emit_movq_rcx_xmm1()


# Move the FP bits in %xmm0 back into %rax (width 4 zero-extends via movd).
def emit_xmm0_to_gpr_rax(width: uint32):
    if width == 4:
        emit_movd_xmm0_eax()
    else:
        emit_movq_xmm0_rax()


# SSE scalar arithmetic OP %xmm1, %xmm0 (result in %xmm0). `width` picks the
# SS (4) vs SD (8) form (prefix F3 vs F2); `op2` is the second opcode byte:
# add=58 sub=5C mul=59 div=5E.
def emit_sse_arith(op2: uint32, width: uint32):
    if width == 4:
        emit_b(0xF3)
    else:
        emit_b(0xF2)
    emit_b(0x0F)
    emit_b(op2)
    emit_b(0xC1)


# ucomiss/ucomisd %xmm1, %xmm0 -> [66] 0F 2E C1  (sd has the 66 prefix).
def emit_ucomi(width: uint32):
    if width == 8:
        emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x2E)
    emit_b(0xC1)


# cvtsi2ss/sd %rax, %xmm0 -> F3/F2 48 0F 2A C0  (signed 64-bit int -> float).
def emit_cvtsi2f(width: uint32):
    if width == 4:
        emit_b(0xF3)
    else:
        emit_b(0xF2)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x2A)
    emit_b(0xC0)


# cvttss2si/cvttsd2si %xmm0, %rax -> F3/F2 48 0F 2C C0  (float -> int, trunc).
def emit_cvttf2si(width: uint32):
    if width == 4:
        emit_b(0xF3)
    else:
        emit_b(0xF2)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x2C)
    emit_b(0xC0)


# cvtss2sd %xmm0, %xmm0 -> F3 0F 5A C0   (float32 -> float64)
def emit_cvtss2sd():
    emit_b(0xF3)
    emit_b(0x0F)
    emit_b(0x5A)
    emit_b(0xC0)


# cvtsd2ss %xmm0, %xmm0 -> F2 0F 5A C0   (float64 -> float32)
def emit_cvtsd2ss():
    emit_b(0xF2)
    emit_b(0x0F)
    emit_b(0x5A)
    emit_b(0xC0)


# set<cc> %cl  -> 0F <opc> C1   (for the parity-guard second condition)
def emit_setcc_cl(opc: uint32):
    emit_b(0x0F)
    emit_b(opc)
    emit_b(0xC1)


# andb %cl, %al  -> 20 C8     (combine ZF/CF result with the not-parity guard)
def emit_and_cl_al():
    emit_b(0x20)
    emit_b(0xC8)


# orb %cl, %al   -> 08 C8     (combine for the != / unordered case)
def emit_or_cl_al():
    emit_b(0x08)
    emit_b(0xC8)


# xorl $0x80000000, %eax  -> 35 00 00 00 80   (flip float32 sign bit)
def emit_xor_eax_signbit32():
    emit_b(0x35)
    emit_imm32(cast[uint64](0x80000000))


# movabsq $0x8000000000000000, %rcx ; xorq %rcx, %rax  (flip float64 sign bit)
#   48 B9 <imm64>   then   48 31 C8
def emit_xor_rax_signbit64():
    emit_b(0x48)
    emit_b(0xB9)
    emit_imm64(cast[uint64](0x8000000000000000))
    emit_b(0x48)
    emit_b(0x31)
    emit_b(0xC8)


# =======================================================================
# Higher-level scalar-FP codegen (mirrors codegen_x86's _emit_fp_*).
# =======================================================================

# Convert the value in %rax to a float of `dst_w` bytes, leaving its bit
# pattern in %rax. `src_w` is the source float width (0 = an integer source,
# 4/8 = a float source). Mirrors codegen_x86._emit_fp_convert / _emit_operand
# _to_float (the int<->float and float<->float cases).
def emit_fp_convert(src_w: uint32, dst_w: uint32):
    if dst_w != 0:
        # ... target is a float.
        if src_w == 0:
            # int -> float: cvtsi2ss/sd from the 64-bit signed %rax.
            emit_cvtsi2f(dst_w)
            emit_xmm0_to_gpr_rax(dst_w)
            return
        if src_w == dst_w:
            return                      # same float width: no-op
        emit_gpr_rax_to_xmm0(src_w)
        if src_w == 4:
            emit_cvtss2sd()             # float32 -> float64
        else:
            emit_cvtsd2ss()             # float64 -> float32
        emit_xmm0_to_gpr_rax(dst_w)
        return
    # target is an integer (src_w must be a float here): float -> int (trunc),
    # leaving a 64-bit signed int in %rax (caller narrows for sub-8-byte ints).
    emit_gpr_rax_to_xmm0(src_w)
    emit_cvttf2si(src_w)


# %rax holds an operand's value (FP bits if `src_w` != 0, else an integer);
# convert it to a float of `width` bytes in place. Mirrors codegen_x86's
# _emit_operand_to_float.
def emit_operand_to_float(src_w: uint32, width: uint32):
    if src_w == width:
        return
    emit_fp_convert(src_w, width)


# %rax = left bits, %rcx = right bits. Compute the FP op `op` at `width` and
# leave the result bits in %rax. Mirrors codegen_x86._emit_fp_binop +
# _emit_fp_setcc (NaN-unordered-correct compares).
def emit_fp_binop(op: uint32, width: uint32):
    emit_gpr_rax_to_xmm0(width)
    emit_gpr_rcx_to_xmm1(width)
    if op == BINOP_ADD:
        emit_sse_arith(0x58, width)
        emit_xmm0_to_gpr_rax(width)
        return
    if op == BINOP_SUB:
        emit_sse_arith(0x5C, width)
        emit_xmm0_to_gpr_rax(width)
        return
    if op == BINOP_MUL:
        emit_sse_arith(0x59, width)
        emit_xmm0_to_gpr_rax(width)
        return
    if op == BINOP_DIV or op == BINOP_IDIV:
        emit_sse_arith(0x5E, width)
        emit_xmm0_to_gpr_rax(width)
        return
    # Compares: ucomi sets CF/ZF (unsigned-style) + PF on unordered (NaN).
    # Pick condition codes so a NaN-unordered compare yields the IEEE result.
    emit_ucomi(width)
    if op == BINOP_GT:
        emit_setcc_al(0x97)             # seta
        emit_movzx_al_rax()
        return
    if op == BINOP_GTE:
        emit_setcc_al(0x93)             # setae
        emit_movzx_al_rax()
        return
    if op == BINOP_LT:
        emit_setcc_al(0x92)             # setb
        emit_setcc_cl(0x9B)             # setnp %cl  (ordered guard)
        emit_and_cl_al()
        emit_movzx_al_rax()
        return
    if op == BINOP_LTE:
        emit_setcc_al(0x96)             # setbe
        emit_setcc_cl(0x9B)             # setnp %cl
        emit_and_cl_al()
        emit_movzx_al_rax()
        return
    if op == BINOP_EQ:
        emit_setcc_al(0x94)             # sete
        emit_setcc_cl(0x9B)             # setnp %cl  (ordered guard)
        emit_and_cl_al()
        emit_movzx_al_rax()
        return
    if op == BINOP_NEQ:
        emit_setcc_al(0x95)             # setne
        emit_setcc_cl(0x9A)             # setp %cl   (unordered -> != true)
        emit_or_cl_al()
        emit_movzx_al_rax()
        return
    cg_fail(1, 0)


# Generate a scalar-SSE FP binop/compare for an ND_BINARY whose operand(s)
# are float. Operand width is the wider of the two float widths (an integer
# operand promotes to that width). Eval/spill order is byte-identical to the
# integer gen_binary path. Mirrors codegen_x86._gen_fp_binary.
def gen_fp_binary(node: uint32, op: uint32, lw: uint32, rw: uint32):
    width: uint32 = lw
    if rw > width:
        width = rw
    if width == 0:
        width = 8
    # Right operand first, convert to float width, spill.
    gen_expr(nd_b[node])
    emit_operand_to_float(expr_float_width(nd_b[node]), width)
    emit_push_rax()
    # Left operand, convert to float width.
    gen_expr(nd_a[node])
    emit_operand_to_float(expr_float_width(nd_a[node]), width)
    emit_pop_rcx()
    emit_fp_binop(op, width)


# Re-extend the low `size` bytes of %rax to a full 64-bit register,
# zero-extending when `is_signed` is 0 and sign-extending when it is 1.
# Mirrors codegen_x86._emit_cast_widen's narrowing branch EXACTLY:
#   unsigned: movzbq %al,%rax / movzwq %ax,%rax / movl %eax,%eax
#   signed:   movsbq %al,%rax / movswq %ax,%rax / movslq %eax,%rax
# `size` 8 (or anything else) is a no-op (the value already fills %rax).
# This is the truncation that makes cast[uint8](300) == 44 etc. — without
# it the upper bits leak into a later wider store / 64-bit compare / fold,
# which is precisely one of the Track-2 fuzzer's fixed miscompiles.
def emit_ext_rax(size: uint32, is_signed: uint32):
    if size == 1:
        if is_signed != 0:
            # movsbq %al, %rax -> 48 0F BE C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xBE)
            emit_b(0xC0)
        else:
            # movzbq %al, %rax -> 48 0F B6 C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xB6)
            emit_b(0xC0)
    elif size == 2:
        if is_signed != 0:
            # movswq %ax, %rax -> 48 0F BF C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xBF)
            emit_b(0xC0)
        else:
            # movzwq %ax, %rax -> 48 0F B7 C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xB7)
            emit_b(0xC0)
    elif size == 4:
        if is_signed != 0:
            # movslq %eax, %rax -> 48 63 C0
            emit_b(0x48)
            emit_b(0x63)
            emit_b(0xC0)
        else:
            # movl %eax, %eax -> 89 C0  (auto-zeroes the high 32 bits)
            emit_b(0x89)
            emit_b(0xC0)
    # size 8 (or unknown): no-op; %rax already holds the value.


# Return 1 if the primitive type node `tnode` is an UNSIGNED integer type
# (uint8/16/32/64, bool, char), 0 otherwise (signed ints / float / non-prim).
# Mirrors the signedness split codegen_x86 derives from type names.
def type_is_unsigned(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    # 6=uint8 7=uint16 8=uint32 9=uint64 12=bool 13=char  -> unsigned
    if code == 6 or code == 7 or code == 8 or code == 9:
        return 1
    if code == 12 or code == 13:
        return 1
    return 0


# Frame-access displacement encoding is HYBRID: a slot whose %rbp offset
# fits in a signed byte (-128..0) uses the compact disp8 (mod=01) form;
# anything beyond -128 uses disp32 (mod=10). This is REQUIRED for the
# self-host fixpoint — the compiler's own large functions have frames far
# past 128 bytes — while keeping byte-IDENTICAL output for small functions
# (so the codegen selftest's hardcoded offsets stay valid).
#
# Low-32-bit mask + the low-32 form of -128 (0xFFFFFF80). These are stored
# as full-width .data globals (NOT loaded as sign-extended imm32 — the
# `48 C7 C0` immediate form can't represent values above 0x7FFFFFFF), so
# referencing them yields the exact 64-bit constant regardless of backend.
DISP_LOW32_MASK: uint64 = 4294967295        # 0xFFFFFFFF
DISP_NEG128_LOW32: uint64 = 4294967168      # 0xFFFFFF80  (-128 as low-32)


# A disp8-reachable offset (a signed byte, -128..127). Frame offsets are
# <= 0, but we test the full signed-byte range anyway.
#
# SIGN-SAFE: this is on the self-host fixpoint critical path. The Adder and
# Python backends differ in how they materialise a sub-64-bit signed scalar
# in a 64-bit register (Python: `movl` store + `movslq` sign-extending load;
# Adder: a plain 64-bit `movq` store/load), so a NEGATIVE `int32` like a
# frame offset can reach this function with its high 32 bits either
# sign-extended OR zeroed depending on which backend compiled THIS code. A
# direct signed `off >= -128` therefore gives different answers across the
# two compilations (it was the SOLE cause of stage1!=stage2: stage2 lost
# every disp32). We normalise by masking to the low 32 bits first, then test
# the disp8-fits ranges in that canonical low-32 form — an answer invariant
# to the high bits, hence identical under both backends.
def disp_fits8(off: int32) -> int32:
    u: uint64 = cast[uint64](off) & DISP_LOW32_MASK
    if u <= 127:                 # 0..127  (zero / small positive)
        return 1
    if u >= DISP_NEG128_LOW32:   # 0xFFFFFF80..0xFFFFFFFF  (-128..-1)
        return 1
    return 0


# Emit a 32-bit little-endian frame displacement (the signed %rbp offset).
def emit_disp32(off: int32):
    d: uint32 = cast[uint32](off)
    emit_b(d & 255)
    emit_b((d >> 8) & 255)
    emit_b((d >> 16) & 255)
    emit_b((d >> 24) & 255)


# Emit a [%rbp]-based modrm + displacement for a frame access. `rbp_modrm8`
# is the mod=01 (disp8) modrm byte (reg field already set, base=rbp); for
# the disp32 form we add 0x40 (mod 01 -> 10) and append a 4-byte disp.
def emit_rbp_mem(rbp_modrm8: uint32, off: int32):
    if disp_fits8(off) != 0:
        emit_b(rbp_modrm8)
        emit_b(cast[uint32](off) & 255)
    else:
        emit_b(rbp_modrm8 + 0x40)
        emit_disp32(off)


# leaq off(%rbp), %rax  -> 48 8D {45 disp8 | 85 disp32}  (frame-slot address)
def emit_lea_local_rax(off: int32):
    emit_b(0x48)
    emit_b(0x8D)
    emit_rbp_mem(0x45, off)


# leaq <data_off>(%rip), %rax  -> 48 8D 05 <rel32>   (address of a global /
# string in the data section). The rel32 is a placeholder; a data fixup is
# recorded against the global's data offset and patched after layout, so it
# resolves to (DATA_BASE + data_off) - (rip_field_end). Mirrors
# codegen_x86.py's `leaq name(%rip),%rax`.
def emit_lea_global_rax(data_off: uint32, is_bss: uint32):
    emit_b(0x48)
    emit_b(0x8D)
    emit_b(0x05)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_data_fixup(at, data_off, is_bss)


# Scale %rcx by a power-of-two element size via a shift (matches
# codegen_x86._emit_scale_reg's 1/2/4/8 cases). elem_size==1 is a no-op.
#   shlq $1, %rcx -> 48 D1 E1   (size 2)
#   shlq $2, %rcx -> 48 C1 E1 02 (size 4)
#   shlq $3, %rcx -> 48 C1 E1 03 (size 8)
def emit_scale_rcx(elem_size: uint32):
    if elem_size == 1:
        return                         # identity, no shift.
    if elem_size == 2:
        emit_b(0x48)
        emit_b(0xD1)
        emit_b(0xE1)
        return
    if elem_size == 4:
        emit_b(0x48)
        emit_b(0xC1)
        emit_b(0xE1)
        emit_b(0x02)
        return
    if elem_size == 8:
        emit_b(0x48)
        emit_b(0xC1)
        emit_b(0xE1)
        emit_b(0x03)
        return
    # Arbitrary (non-power-of-2) stride — the row stride of a multi-
    # dimensional array global, e.g. Array[N, Array[3, int64]] has a 24-byte
    # outer stride. Mirror codegen_x86's `imulq $elem_size, %rcx, %rcx`
    # fallback: imul rcx, rcx, imm32 == 48 69 C9 <imm32>.
    emit_b(0x48)
    emit_b(0x69)
    emit_b(0xC9)
    emit_imm32(cast[uint64](elem_size))


# Sized load from (%rax) into %rax (zero-extending), mirroring
# emit_load_sized in codegen_x86.py.
#   movzbq (%rax),%rax -> 48 0F B6 00   (size 1)
#   movzwq (%rax),%rax -> 48 0F B7 00   (size 2)
#   movl   (%rax),%eax -> 8B 00         (size 4, auto-zero-extend)
#   movq   (%rax),%rax -> 48 8B 00      (size 8)
def emit_load_mem_rax(size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB6)
        emit_b(0x00)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB7)
        emit_b(0x00)
    elif size == 4:
        emit_b(0x8B)
        emit_b(0x00)
    else:
        emit_b(0x48)
        emit_b(0x8B)
        emit_b(0x00)


# Sized SIGN-EXTENDING load of (%rax) into %rax, mirroring codegen_x86's
# emit_load_sized_signed: a sub-8-byte SIGNED scalar must sign-extend so its
# wider use carries the right two's-complement value. (Bug C in the fuzzer
# regression fixture: a negative int32 global must load as 0xFFFFFFFFFFFFFC18,
# not 0x00000000FFFFFC18.)
#   movsbq (%rax),%rax -> 48 0F BE 00   (size 1)
#   movswq (%rax),%rax -> 48 0F BF 00   (size 2)
#   movslq (%rax),%rax -> 48 63 00      (size 4)
# size 8 needs no extension -> plain movq.
def emit_load_mem_rax_signed(size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBE)
        emit_b(0x00)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBF)
        emit_b(0x00)
    elif size == 4:
        emit_b(0x48)
        emit_b(0x63)
        emit_b(0x00)
    else:
        emit_b(0x48)
        emit_b(0x8B)
        emit_b(0x00)


# Sized store of %rcx into (%rax), mirroring emit_store_sized.
#   movb %cl,(%rax)  -> 88 08    (size 1)
#   movw %cx,(%rax)  -> 66 89 08 (size 2)
#   movl %ecx,(%rax) -> 89 08    (size 4)
#   movq %rcx,(%rax) -> 48 89 08 (size 8)
def emit_store_mem_rcx(size: uint32):
    if size == 1:
        emit_b(0x88)
        emit_b(0x08)
    elif size == 2:
        emit_b(0x66)
        emit_b(0x89)
        emit_b(0x08)
    elif size == 4:
        emit_b(0x89)
        emit_b(0x08)
    else:
        emit_b(0x48)
        emit_b(0x89)
        emit_b(0x08)


# movq <arg-reg>, off(%rbp)   spill a parameter into its slot.
#   movq %rdi, off(%rbp) -> 48 89 {7D disp8 | BD disp32}
#   movq %rsi, off(%rbp) -> 48 89 {75 disp8 | B5 disp32}
#   movq %rdx, off(%rbp) -> 48 89 {55 disp8 | 95 disp32}
#   movq %rcx, off(%rbp) -> 48 89 {4D disp8 | 8D disp32}
#   movq %r8,  off(%rbp) -> 4C 89 {45 disp8 | 85 disp32}
#   movq %r9,  off(%rbp) -> 4C 89 {4D disp8 | 8D disp32}
# Hybrid disp8/disp32 (see emit_rbp_mem) so the offset reaches the whole
# frame while keeping small frames byte-identical.
def emit_spill_arg(argidx: uint32, off: int32):
    if argidx == 0:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x7D, off)
    elif argidx == 1:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x75, off)
    elif argidx == 2:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x55, off)
    elif argidx == 3:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x4D, off)
    elif argidx == 4:
        emit_b(0x4C)
        emit_b(0x89)
        emit_rbp_mem(0x45, off)
    else:
        emit_b(0x4C)
        emit_b(0x89)
        emit_rbp_mem(0x4D, off)


# movq off(%rbp), %rax   load a local/param into %rax.
#   -> 48 8B {45 disp8 | 85 disp32}
def emit_load_local_rax(off: int32):
    emit_b(0x48)
    emit_b(0x8B)
    emit_rbp_mem(0x45, off)


# movq %rax, off(%rbp)   store %rax into a local/param slot.
#   -> 48 89 {45 disp8 | 85 disp32}
def emit_store_local_rax(off: int32):
    emit_b(0x48)
    emit_b(0x89)
    emit_rbp_mem(0x45, off)


# Sign-extending load of a sub-8-byte signed scalar local into %rax. The
# modrm reg field is %rax (000) so the rbp-mem encoding (0x45 disp8 / 0x85
# disp32) is shared with the plain movq load. Mirrors codegen_x86
# _emit_local_load's signed branch (movsbq/movswq/movslq off(%rbp),%rax).
#   movsbq off(%rbp),%rax -> 48 0F BE {45|85} disp
#   movswq off(%rbp),%rax -> 48 0F BF {45|85} disp
#   movslq off(%rbp),%rax -> 48 63 {45|85} disp
def emit_load_local_rax_signed(off: int32, size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBE)
        emit_rbp_mem(0x45, off)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBF)
        emit_rbp_mem(0x45, off)
    else:
        emit_b(0x48)
        emit_b(0x63)
        emit_rbp_mem(0x45, off)


# Zero-extending load of a sub-8-byte unsigned scalar local into %rax. Mirrors
# codegen_x86 _emit_local_load's unsigned branch:
#   size 4: movl off(%rbp),%eax  -> 8B {45|85} disp   (auto zero-extend)
#   size 2: movzwq off(%rbp),%rax -> 48 0F B7 {45|85} disp
#   size 1: movzbq off(%rbp),%rax -> 48 0F B6 {45|85} disp
def emit_load_local_rax_unsigned(off: int32, size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB6)
        emit_rbp_mem(0x45, off)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB7)
        emit_rbp_mem(0x45, off)
    else:
        emit_b(0x8B)
        emit_rbp_mem(0x45, off)


# -----------------------------------------------------------------------
# Comparison: cmpq %rcx,%rax ; set<cc> %al ; movzbq %al,%rax  (mirrors
# codegen_x86._cmp_set). %rax = (left <cc> right) ? 1 : 0. We use the
# SIGNED setcc family — the default codegen_x86._rel_cc picks when no
# operand is statically known-unsigned, which is the case for this
# subset (it carries no type info).
# -----------------------------------------------------------------------

# cmpq %rcx, %rax  -> 48 39 C8
def emit_cmp_rcx_rax():
    emit_b(0x48)
    emit_b(0x39)
    emit_b(0xC8)


# movzbq %al, %rax  -> 48 0F B6 C0
def emit_movzx_al_rax():
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0xB6)
    emit_b(0xC0)


# set<cc> %al  -> 0F <opc> C0
#   sete  94   setne 95   setl  9C   setge 9D   setle 9E   setg  9F
def emit_setcc_al(opc: uint32):
    emit_b(0x0F)
    emit_b(opc)
    emit_b(0xC0)


# testq %rax, %rax  -> 48 85 C0
def emit_test_rax_rax():
    emit_b(0x48)
    emit_b(0x85)
    emit_b(0xC0)


# testq %rcx, %rcx  -> 48 85 C9
def emit_test_rcx_rcx():
    emit_b(0x48)
    emit_b(0x85)
    emit_b(0xC9)


# -----------------------------------------------------------------------
# Forward/backward jumps with rel32 backpatching. codegen_x86.py emits
# named labels and lets the assembler resolve them; emitting raw bytes we
# resolve them ourselves. A jump is `opc... rel32` where rel32 is the
# signed displacement from the END of the instruction to the target.
#
#   emit_jz_fwd / emit_jmp_fwd return the byte offset of the rel32 field;
#   patch_rel32(at, target) writes target - (at + 4) there once `target`
#   (a code_len snapshot) is known. For a back-edge we know the target up
#   front, so we compute the displacement and emit it directly.
# -----------------------------------------------------------------------

# Write a little-endian rel32 into code[at..at+4) = target - (at + 4).
def patch_rel32(at: uint32, target: uint32):
    rel: int32 = cast[int32](target) - cast[int32](at + 4)
    v: uint32 = cast[uint32](rel)
    code[at] = cast[uint8](v & 255)
    code[at + 1] = cast[uint8]((v >> 8) & 255)
    code[at + 2] = cast[uint8]((v >> 16) & 255)
    code[at + 3] = cast[uint8]((v >> 24) & 255)


# jz rel32  -> 0F 84 rel32  (placeholder). Returns rel32-field offset.
def emit_jz_fwd() -> uint32:
    emit_b(0x0F)
    emit_b(0x84)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    return at


# jmp rel32 -> E9 rel32 (placeholder). Returns rel32-field offset.
def emit_jmp_fwd() -> uint32:
    emit_b(0xE9)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    return at


# jmp rel32 to a KNOWN (earlier) target — emits the resolved displacement.
def emit_jmp_back(target: uint32):
    emit_b(0xE9)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    patch_rel32(at, target)


# jnz rel32 to a KNOWN (earlier) target -> 0F 85 rel32. Used by the do-while
# back-edge (`jnz start`), mirroring codegen_x86.gen_do_while.
def emit_jnz_back(target: uint32):
    emit_b(0x0F)
    emit_b(0x85)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    patch_rel32(at, target)


# addq $imm, %rax — add a (non-negative) immediate to %rax. Mirrors GNU as'
# encoding choice exactly: the sign-extended imm8 form `48 83 C0 ib` when the
# value fits a signed byte (0..127 here), else the imm32 accumulator form
# `48 05 id`. Used for `&obj + field_offset` in member addressing.
def emit_add_imm_rax(imm: uint32):
    if imm < 128:
        emit_b(0x48)
        emit_b(0x83)
        emit_b(0xC0)
        emit_b(imm & 255)
        return
    emit_b(0x48)
    emit_b(0x05)
    emit_imm32(cast[uint64](imm))


# xorl %eax, %eax  -> 31 C0  (clear %al before a variadic-capable call,
# matching codegen_x86's `xorl %eax,%eax` before each direct call).
def emit_xor_eax_eax():
    emit_b(0x31)
    emit_b(0xC0)


# popq <arg-reg>  — reclaim a marshalled argument into its SysV reg.
#   rdi 5F  rsi 5E  rdx 5A  rcx 59  r8 41 58  r9 41 59
def emit_pop_argreg(argidx: uint32):
    if argidx == 0:
        emit_b(0x5F)
    elif argidx == 1:
        emit_b(0x5E)
    elif argidx == 2:
        emit_b(0x5A)
    elif argidx == 3:
        emit_b(0x59)
    elif argidx == 4:
        emit_b(0x41)
        emit_b(0x58)
    else:
        emit_b(0x41)
        emit_b(0x59)


# popq <syscall-reg> — reclaim a marshalled syscall operand into the Linux
# x86_64 syscall calling-convention register for slot `idx`:
#   idx 0 -> %rax (syscall NUMBER)   58
#   idx 1 -> %rdi (arg1)             5F
#   idx 2 -> %rsi (arg2)             5E
#   idx 3 -> %rdx (arg3)             5A
#   idx 4 -> %r10 (arg4)            41 5A
#   idx 5 -> %r8  (arg5)            41 58
#   idx 6 -> %r9  (arg6)            41 59
# (Note: the syscall ABI uses %r10 for arg4, NOT %rcx like the SysV call
# ABI — `syscall` clobbers %rcx/%r11.)
def emit_pop_syscallreg(idx: uint32):
    if idx == 0:
        emit_b(0x58)
    elif idx == 1:
        emit_b(0x5F)
    elif idx == 2:
        emit_b(0x5E)
    elif idx == 3:
        emit_b(0x5A)
    elif idx == 4:
        emit_b(0x41)
        emit_b(0x5A)
    elif idx == 5:
        emit_b(0x41)
        emit_b(0x58)
    else:
        emit_b(0x41)
        emit_b(0x59)


# `syscall` (0F 05). Inputs already in %rax/%rdi/%rsi/%rdx/%r10/%r8/%r9;
# result left in %rax.
def emit_syscall_insn():
    emit_b(0x0F)
    emit_b(0x05)


# -----------------------------------------------------------------------
# Expression codegen — value left in %rax (mirrors gen_expr).
# -----------------------------------------------------------------------

def gen_expr(node: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]

    if k == ND_INT_LIT:
        emit_mov_imm_rax(nd_num[node])
        return

    if k == ND_CHAR_LIT:
        # A char literal is just its code-point as an immediate, exactly
        # like an int literal (codegen_x86 emits `movq $ord(v),%rax`). The
        # parser already stored the value in nd_num.
        emit_mov_imm_rax(nd_num[node])
        return

    if k == ND_BOOL_LIT:
        # True / False -> 1 / 0 immediate (codegen_x86's BoolLiteral case);
        # the parser stored 0/1 in nd_num.
        emit_mov_imm_rax(nd_num[node])
        return

    if k == ND_FLOAT_LIT:
        # A bare float literal is a float64. This backend's frontend stores
        # only the literal's INTEGER part in nd_num (no fraction), so a whole-
        # number literal converts exactly: materialize the integer in %rax and
        # cvtsi2sd it to the float64 bit pattern. (The fuzzer derives floats
        # from integers via cast[floatN](int), so fractional literals never
        # reach this backend; a surrounding cast[float32] narrows via the cast
        # path.) Mirrors codegen_x86's FloatLiteral as a double value.
        emit_mov_imm_rax(nd_num[node])
        emit_fp_convert(0, 8)
        return

    if k == ND_IDENT:
        # `self` inside a method: load the receiver pointer value from its slot.
        if is_self_ident(node) != 0 and cg_self_struct != 0:
            emit_load_local_rax(cg_self_off)
            return
        off: int32 = 0
        if lookup_local(nd_name_off[node], nd_name_len[node], &off) != 0:
            # Sub-8-byte typed scalar local: load only its low `sz` bytes and
            # sign/zero-extend into %rax (mirrors codegen_x86 _emit_local_load).
            # The slot's low bytes hold the type-truncated value, so an
            # extending load yields the correctly widened value — without this,
            # a widening read like cast[int64](l16) leaks the slot's stale
            # upper bytes (e.g. an un-truncated div result) into the result.
            lsz: uint32 = lookup_local_scalar_size(nd_name_off[node], nd_name_len[node])
            if lsz != 0 and lsz < 8:
                lsg: uint32 = lookup_local_signedness(nd_name_off[node], nd_name_len[node])
                if lsg == 2:
                    emit_load_local_rax_signed(off, lsz)
                else:
                    emit_load_local_rax_unsigned(off, lsz)
                return
            emit_load_local_rax(off)
            return
        # Global? Scalar globals load their value (leaq + sized deref,
        # mirroring codegen_x86's `leaq name(%rip),%rax ; movq (%rax),%rax`).
        # Array globals decay to their address (just the leaq), so callers
        # that index or take their address get the base.
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            emit_lea_global_rax(glob_offset[gi - 1], glob_is_bss[gi - 1])
            if glob_elem_size[gi - 1] == 0:
                if glob_is_signed[gi - 1] != 0:
                    emit_load_mem_rax_signed(glob_scalar_size[gi - 1])
                else:
                    emit_load_mem_rax(glob_scalar_size[gi - 1])
            return
        # Unknown identifier — out of this subset's scope.
        cg_fail(8, node)
        return

    if k == ND_STRING_LIT:
        # Intern the literal's bytes (NUL-terminated, like .asciz in
        # codegen_x86.gen_rodata) into the data section; the expression
        # yields the string's address via a RIP-relative leaq.
        doff: uint32 = intern_string(nd_name_off[node], nd_name_len[node])
        emit_lea_global_rax(doff, 0)
        return

    if k == ND_BINARY:
        op: uint32 = nd_aux[node]
        # Floating-point binop/compare: if EITHER operand is float-typed AND
        # the op is an arithmetic op or a compare, route to the SSE path
        # (mirrors codegen_x86.gen_binary's FP branch). Eval/spill order is
        # byte-identical to the integer path.
        flw: uint32 = expr_float_width(nd_a[node])
        frw: uint32 = expr_float_width(nd_b[node])
        if flw != 0 or frw != 0:
            if op == BINOP_ADD or op == BINOP_SUB or op == BINOP_MUL or op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_EQ or op == BINOP_NEQ or op == BINOP_LT or op == BINOP_LTE or op == BINOP_GT or op == BINOP_GTE:
                gen_fp_binary(node, op, flw, frw)
                return
        # Decide signed-vs-unsigned for compares and div/mod from the operand
        # static types BEFORE evaluating (cheap AST walk). Mirrors codegen_x86
        # _rel_cc / _binop_signed_op over get_expr_type():
        #   * compares default SIGNED, switch to UNSIGNED if EITHER operand is
        #     known-unsigned;
        #   * div/mod default UNSIGNED, switch to SIGNED if some operand is
        #     known-signed and none is known-unsigned.
        l_sgn: uint32 = expr_signedness(nd_a[node])
        r_sgn: uint32 = expr_signedness(nd_b[node])
        # Evaluate right first, push; then left; pop into %rcx. After this
        # %rax = left, %rcx = right — exactly codegen_x86.gen_binary.
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_expr(nd_a[node])
        emit_pop_rcx()
        if op == BINOP_ADD:
            emit_add_rcx_rax()
        elif op == BINOP_SUB:
            emit_sub_rcx_rax()
        elif op == BINOP_MUL:
            emit_imul_rcx_rax()
        elif op == BINOP_BIT_AND:
            emit_and_rcx_rax()
        elif op == BINOP_BIT_OR:
            emit_or_rcx_rax()
        elif op == BINOP_BIT_XOR:
            emit_xor_rcx_rax()
        elif op == BINOP_SHL:
            # Shift count must sit in %cl; %rcx already holds the right operand.
            emit_shl_cl_rax()
        elif op == BINOP_SHR:
            # Arithmetic (sarq) for a signed `>>`, else logical (shrq).
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_sar_cl_rax()
            else:
                emit_shr_cl_rax()
        elif op == BINOP_DIV:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
        elif op == BINOP_IDIV:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
        elif op == BINOP_MOD:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
            emit_mov_rdx_rax()
        elif op == BINOP_EQ:
            emit_cmp_rcx_rax()
            emit_setcc_al(0x94)
            emit_movzx_al_rax()
        elif op == BINOP_NEQ:
            emit_cmp_rcx_rax()
            emit_setcc_al(0x95)
            emit_movzx_al_rax()
        elif op == BINOP_LT:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9C, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_LTE:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9E, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_GT:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9F, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_GTE:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9D, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_AND:
            # Logical AND: bool-ify both operands then bitwise-and the 0/1s,
            # exactly mirroring codegen_x86.gen_binary's AND/OR fold. After
            # the pop, %rax = left, %rcx = right.
            emit_test_rax_rax()
            emit_setcc_al(0x95)        # setne %al
            emit_movzx_al_rax()
            emit_test_rcx_rcx()
            emit_setne_cl()
            emit_movzx_cl_rcx()
            emit_and_rcx_rax()
        elif op == BINOP_OR:
            emit_test_rax_rax()
            emit_setcc_al(0x95)        # setne %al
            emit_movzx_al_rax()
            emit_test_rcx_rcx()
            emit_setne_cl()
            emit_movzx_cl_rcx()
            emit_or_rcx_rax()
        else:
            cg_fail(1, node)
        return

    if k == ND_UNARY:
        gen_unary(node)
        return

    if k == ND_INDEX:
        # arr[i] value load: compute element address into %rax, then a
        # sized load. Element size is the array local's declared width.
        gen_index_addr(node)
        es: uint32 = index_elem_size(node)
        emit_load_mem_rax(es)
        return

    if k == ND_CALL:
        gen_call(node)
        return

    if k == ND_MEMBER:
        gen_member_load(node)
        return

    if k == ND_METHOD_CALL:
        gen_method_call(node)
        return

    if k == ND_CAST:
        # cast[T](x) / int32(x) / Ptr[T](x). Evaluate the operand into %rax,
        # then — for a NARROWING cast to a sub-8-byte integer type — truncate
        # %rax to T's value: clear (unsigned T) or sign-fill (signed T) the
        # bits above T's width. This mirrors codegen_x86._emit_cast_widen's
        # narrowing branch, keyed on the DESTINATION type ALONE: `cast[T](x)`
        # for a sub-8-byte int T has value `x mod 2^width` (sign-adjusted),
        # regardless of the source. Without this, the upper bits leak into a
        # later wider store / 64-bit compare / bitwise fold — one of the
        # Track-2 fuzzer's fixed miscompiles (cast[uint8](300) must be 44, not
        # 300). Pointer / array / non-primitive cast targets are NOT ND_TYPE
        # nodes, so prim_type_size returns 8 and emit_ext_rax is a no-op for
        # them — preserving pointer/uint64 arithmetic exactly.
        # The cast type lives on nd_a; the operand on nd_b.
        gen_expr(nd_b[node])
        tnode: uint32 = nd_a[node]
        # FP cast: if either the source or the destination is a float type,
        # route through the SSE convert path (int<->float, float<->float).
        # A float->int cast leaves a 64-bit signed int in %rax, which then
        # needs the integer narrowing fix-up for sub-8-byte int targets.
        # Mirrors codegen_x86.gen_expr's CastExpr FP branch.
        dfw: uint32 = type_float_width(tnode)
        sfw: uint32 = expr_float_width(nd_b[node])
        if dfw != 0 or sfw != 0:
            emit_fp_convert(sfw, dfw)
            if dfw == 0 and tnode != 0 and nd_kind[tnode] == ND_TYPE:
                dsz0: uint32 = prim_type_size(tnode)
                if dsz0 < 8:
                    sgn0: uint32 = 0
                    if type_is_unsigned(tnode) == 0:
                        sgn0 = 1
                    emit_ext_rax(dsz0, sgn0)
            return
        if tnode != 0 and nd_kind[tnode] == ND_TYPE:
            dsz: uint32 = prim_type_size(tnode)
            if dsz < 8:
                signedness: uint32 = 0
                if type_is_unsigned(tnode) == 0:
                    signedness = 1
                emit_ext_rax(dsz, signedness)
        return

    # Anything else is outside this milestone's subset.
    cg_fail(1, node)


# -----------------------------------------------------------------------
# Unary operators (mirrors codegen_x86.gen_unary, integer subset): NEG,
# BIT_NOT, NOT, plus DEREF (*p) and ADDR (&x / &arr[i]). NEG/BIT_NOT/NOT
# evaluate the operand into %rax then apply in place; ADDR computes the
# operand's address (no value load); DEREF loads the pointee after
# evaluating the pointer value.
# -----------------------------------------------------------------------

def gen_unary(node: uint32):
    op: uint32 = nd_aux[node]
    # ADDR / DEREF evaluate the operand specially (address-of must NOT load
    # the operand's value), so handle them before the generic eval-then-op.
    if op == UNOP_ADDR:
        gen_addr_of(nd_a[node])
        return
    if op == UNOP_DEREF:
        # *p: evaluate the pointer expression (its value = the target
        # address) into %rax, then load the pointee. The pointee width is
        # the operand's Ptr[T] pointee size when known, else 8 (mirrors
        # codegen_x86.gen_unary's DEREF size = get_type_size(pointee)).
        gen_expr(nd_a[node])
        emit_load_mem_rax(deref_size(nd_a[node]))
        return
    # FP negate: flip the IEEE sign bit (so -0.0 is produced correctly), not
    # an integer negate. Done in-register by XOR-ing the bit pattern with the
    # sign mask — width-exact, no SSE. Mirrors codegen_x86.gen_unary's FP NEG.
    if op == UNOP_NEG:
        nfw: uint32 = expr_float_width(nd_a[node])
        if nfw != 0:
            gen_expr(nd_a[node])
            if nfw == 4:
                emit_xor_eax_signbit32()
            else:
                emit_xor_rax_signbit64()
            return
    gen_expr(nd_a[node])
    if op == UNOP_NEG:
        emit_neg_rax()
    elif op == UNOP_BIT_NOT:
        emit_not_rax()
    elif op == UNOP_NOT:
        # not x  ==  (x == 0) ? 1 : 0
        emit_test_rax_rax()
        emit_setcc_al(0x94)        # setz/sete %al
        emit_movzx_al_rax()
    else:
        cg_fail(1, node)


# Pointee width for a `*expr` deref: if `expr` is a bare Ptr[T] identifier
# (local/param or global), return its pointee size; otherwise default to 8.
def deref_size(expr: uint32) -> uint32:
    if nd_kind[expr] == ND_IDENT:
        ps: uint32 = lookup_ptr_size(nd_name_off[expr], nd_name_len[expr])
        if ps != 0:
            return ps
        gi: uint32 = glob_lookup(nd_name_off[expr], nd_name_len[expr])
        if gi != 0 and glob_ptr_size[gi - 1] != 0:
            return glob_ptr_size[gi - 1]
    return 8


# Compute the ADDRESS of an lvalue expression into %rax (mirrors
# codegen_x86.gen_addr_of). Supported operands:
#   * an identifier naming a frame local/param  -> leaq off(%rbp)
#   * an identifier naming a module-level global -> leaq data_off(%rip)
#   * an index expression arr[i] / p[i]          -> &element (gen_index_addr)
# Taking the address of a bare scalar local yields its slot address; taking
# the address of an array/pointer element yields the element address. These
# are exactly the address forms the compiler's own source uses
# (e.g. `&strbuf[val_start]`, `&out[0]`).
def gen_addr_of(operand: uint32):
    k: uint32 = nd_kind[operand]
    if k == ND_INDEX:
        gen_index_addr(operand)
        return
    if k == ND_MEMBER:
        gen_member_address(nd_a[operand], nd_name_off[operand], nd_name_len[operand])
        return
    if k == ND_IDENT:
        off: int32 = 0
        if lookup_local(nd_name_off[operand], nd_name_len[operand], &off) != 0:
            emit_lea_local_rax(off)
            return
        gi: uint32 = glob_lookup(nd_name_off[operand], nd_name_len[operand])
        if gi != 0:
            emit_lea_global_rax(glob_offset[gi - 1], glob_is_bss[gi - 1])
            return
    cg_fail(8, operand)


# -----------------------------------------------------------------------
# Array indexing (local Array slots). Mirrors codegen_x86.gen_index_address:
# evaluate the index, scale it by the element size, add the array's base
# address. The base is an Array local, so its "value" is its slot address
# (a leaq), exactly how codegen_x86 decays an array-typed identifier.
# Only bare-identifier array bases are in this subset.
# -----------------------------------------------------------------------

# The ND_ARRAY_TYPE node that `expr` evaluates to as an aggregate, or 0 if
# `expr` is scalar / not an indexable multi-dimensional global. Mirrors
# codegen_x86.get_expr_type narrowed to the array-global case:
#   * a bare global identifier with a recorded array type node -> that node
#   * a nested index `g[i]` -> the element type of g's array type, but ONLY
#     when that element is itself an ND_ARRAY_TYPE (i.e. another dimension).
# A fully-indexed scalar element returns 0 (it is not an aggregate).
# This is consulted ONLY for the multi-dimensional path; 1-D arrays (whose
# element is a scalar) return 0 here and keep the flat glob_elem_size path.
def expr_array_type(expr: uint32) -> uint32:
    k: uint32 = nd_kind[expr]
    if k == ND_IDENT:
        gi: uint32 = glob_lookup(nd_name_off[expr], nd_name_len[expr])
        if gi != 0 and glob_type_node[gi - 1] != 0:
            tn: uint32 = glob_type_node[gi - 1]
            if nd_kind[tn] == ND_ARRAY_TYPE:
                return tn
        return 0
    if k == ND_INDEX:
        bt: uint32 = expr_array_type(nd_a[expr])
        if bt != 0:
            elem: uint32 = nd_a[bt]            # element type of the base array
            if nd_kind[elem] == ND_ARRAY_TYPE:
                return elem
        return 0
    return 0


# True if `node` is a nested index `base[i]` whose base is itself an indexed
# multi-dimensional array global (so this level scales by the nested row
# stride, not a scalar element). Only such nodes take the recursive path.
def is_multidim_index(node: uint32) -> uint32:
    if nd_kind[nd_a[node]] != ND_INDEX:
        return 0
    if expr_array_type(nd_a[node]) != 0:
        return 1
    return 0


# Element size for an `arr[i]` node: the declared element width of the
# array local OR array global named by nd_a. Returns 1 if unknown.
def index_elem_size(node: uint32) -> uint32:
    base: uint32 = nd_a[node]
    # Nested index into a multi-dimensional array global: the element width at
    # THIS level is type_size(element_type), recursing into the base array's
    # type. For `g_grid[r][c]` over Array[N, Array[M, int64]] the base array
    # of this (inner) level is Array[M, int64], so the element is int64 -> 8.
    # For the OUTER level `g_grid[r]` the base array is Array[N, Array[M,T]],
    # element Array[M,T] -> M*sizeof(T) (the row stride).
    if nd_kind[base] == ND_INDEX:
        bt: uint32 = expr_array_type(base)
        if bt != 0:
            return type_size_of(nd_a[bt])
        cg_fail(8, node)
        return 1
    if nd_kind[base] != ND_IDENT:
        cg_fail(8, node)
        return 1
    # A bare-identifier base into a multi-dimensional array global: the OUTER
    # index scales by the row stride (element_type size), not the innermost
    # scalar width that glob_elem_size records.
    bt2: uint32 = expr_array_type(base)
    if bt2 != 0 and nd_kind[nd_a[bt2]] == ND_ARRAY_TYPE:
        return type_size_of(nd_a[bt2])
    es: uint32 = lookup_elem_size(nd_name_off[base], nd_name_len[base])
    if es != 0:
        return es
    # A Ptr[T] local/param: the load/store width is the pointee size.
    ps: uint32 = lookup_ptr_size(nd_name_off[base], nd_name_len[base])
    if ps != 0:
        return ps
    # Fall back to a global array, then a Ptr[T] global.
    gi: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
    if gi != 0 and glob_elem_size[gi - 1] != 0:
        return glob_elem_size[gi - 1]
    if gi != 0 and glob_ptr_size[gi - 1] != 0:
        return glob_ptr_size[gi - 1]
    # Not a known array local or global — outside this subset.
    cg_fail(8, node)
    return 1


# Compute &arr[i] into %rax. Index in nd_b, array identifier in nd_a. The
# base may be a local Array slot (leaq off(%rbp)) or a global Array
# (leaq data_off(%rip)). Both decay to a base address then add a scaled
# index, exactly like codegen_x86.gen_index_address.
def gen_index_addr(node: uint32):
    base: uint32 = nd_a[node]

    # ---- Nested index into a multi-dimensional array global --------------
    # `g_grid[r][c]`: the base is itself an index expression yielding a ROW
    # address. Recursively compute that row's address, then add the scaled
    # element index. The stride at THIS level is index_elem_size(node)
    # (type_size of the element type — a scalar at the deepest level, a row
    # at an intermediate level). This mirrors codegen_x86.gen_index_address
    # recursing via gen_addr_of on an Array-typed (IndexExpr) base.
    if nd_kind[base] == ND_INDEX:
        es_n: uint32 = index_elem_size(node)
        gen_expr(nd_b[node])              # index -> %rax
        emit_push_rax()                   # spill index (recursion clobbers %rax)
        gen_index_addr(base)              # row base address -> %rax
        emit_pop_rcx()                    # index -> %rcx
        emit_scale_rcx(es_n)
        emit_add_rcx_rax()
        return

    if nd_kind[base] != ND_IDENT:
        cg_fail(8, node)
        return

    # ---- Bare-identifier base that is a multi-dimensional array global ----
    # The OUTER index of `g_grid[r]` scales by the row stride (the element
    # type size), and the base address is the global symbol. Handle this
    # before the flat classification so the row stride (not the innermost
    # scalar width glob_elem_size records) is used.
    bt_md: uint32 = expr_array_type(base)
    if bt_md != 0 and nd_kind[nd_a[bt_md]] == ND_ARRAY_TYPE:
        gi_md: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
        es_md: uint32 = type_size_of(nd_a[bt_md])
        gen_expr(nd_b[node])
        emit_mov_rax_rcx()
        emit_scale_rcx(es_md)
        emit_lea_global_rax(glob_offset[gi_md - 1], glob_is_bss[gi_md - 1])
        emit_add_rcx_rax()
        return

    # Classify the base. There are four base flavours, all of which decay to
    # a base address that we add a scaled index to (mirroring
    # codegen_x86.gen_index_address). The ONLY difference is how the base
    # address is materialised into %rax:
    #   * Array local      -> leaq off(%rbp)           (slot IS the array)
    #   * Array global     -> leaq data_off(%rip)      (symbol IS the array)
    #   * Ptr[T] local      -> movq off(%rbp),%rax       (slot HOLDS the addr)
    #   * Ptr[T] global     -> leaq data_off(%rip); movq (%rax),%rax
    #                          (load the pointer value the global holds)
    es: uint32 = lookup_elem_size(nd_name_off[base], nd_name_len[base])
    off: int32 = 0
    arr_local: uint32 = 0
    ptr_local: uint32 = 0
    if es != 0 and lookup_local(nd_name_off[base], nd_name_len[base], &off) != 0:
        arr_local = 1
    if arr_local == 0:
        ps: uint32 = lookup_ptr_size(nd_name_off[base], nd_name_len[base])
        if ps != 0 and lookup_local(nd_name_off[base], nd_name_len[base], &off) != 0:
            ptr_local = 1
            es = ps
    arr_glob: uint32 = 0
    ptr_glob: uint32 = 0
    gdoff: uint32 = 0
    gbss: uint32 = 0
    if arr_local == 0 and ptr_local == 0:
        gi: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
        if gi != 0 and glob_elem_size[gi - 1] != 0:
            arr_glob = 1
            es = glob_elem_size[gi - 1]
            gdoff = glob_offset[gi - 1]
            gbss = glob_is_bss[gi - 1]
        elif gi != 0 and glob_ptr_size[gi - 1] != 0:
            ptr_glob = 1
            es = glob_ptr_size[gi - 1]
            gdoff = glob_offset[gi - 1]
            gbss = glob_is_bss[gi - 1]
        else:
            cg_fail(8, node)
            return

    # Evaluate the index into %rax, move to %rcx, scale, then add the base
    # address. Result address ends up in %rax.
    gen_expr(nd_b[node])
    emit_mov_rax_rcx()
    emit_scale_rcx(es)
    if arr_local != 0:
        emit_lea_local_rax(off)
    elif ptr_local != 0:
        emit_load_local_rax(off)          # base address = pointer value
    elif arr_glob != 0:
        emit_lea_global_rax(gdoff, gbss)
    else:
        # Ptr[T] global: load the address the global slot holds.
        emit_lea_global_rax(gdoff, gbss)
        emit_load_mem_rax(8)
    emit_add_rcx_rax()


# -----------------------------------------------------------------------
# Member access (obj.field). Mirrors codegen_x86.gen_member_address /
# gen_member_load. The subset resolves obj as a bare identifier that is a
# struct-typed local/global (in-place value) OR a Ptr[Struct] local/param
# (the `self` receiver inside a method body):
#   * in-place struct value -> &obj + field_offset  (leaq slot/global; addq)
#   * Ptr[Struct] value     -> (loaded pointer value) + field_offset
# Field offsets + widths come from the struct table (struct_field_find).
# -----------------------------------------------------------------------

# Resolve `obj`'s struct type. On success returns the struct-table index
# (+1) and writes 1/0 through out_is_ptr for the Ptr[Struct] vs in-place
# distinction. Returns 0 if obj is not a (supported) struct-typed lvalue.
# 1 if `node` is the special `self` identifier (ND_IDENT marked nd_aux==1).
def is_self_ident(node: uint32) -> uint32:
    if nd_kind[node] != ND_IDENT:
        return 0
    if nd_aux[node] == 1:
        return 1
    return 0


def member_resolve(obj: uint32, out_is_ptr: Ptr[uint32]) -> uint32:
    if nd_kind[obj] != ND_IDENT:
        return 0
    # `self` receiver inside a method body: a Ptr[Struct] held at cg_self_off.
    if is_self_ident(obj) != 0 and cg_self_struct != 0:
        out_is_ptr[0] = 1
        return cg_self_struct
    ls: uint32 = lookup_local_struct(nd_name_off[obj], nd_name_len[obj])
    if ls != 0:
        out_is_ptr[0] = lookup_local_struct_is_ptr(nd_name_off[obj], nd_name_len[obj])
        return ls
    gi: uint32 = glob_lookup(nd_name_off[obj], nd_name_len[obj])
    if gi != 0 and glob_struct_idx[gi - 1] != 0:
        out_is_ptr[0] = 0            # struct globals are in-place values
        return glob_struct_idx[gi - 1]
    return 0


# Compute the ADDRESS of obj.member into %rax. Mirrors gen_member_address.
def gen_member_address(obj: uint32, mem_off: uint32, mem_len: uint32):
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(8, obj)
        return
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, mem_off, mem_len, &foff, &fsgn)
    if fsz == SF_NOFIELD:
        cg_fail(8, obj)
        return
    if is_ptr != 0:
        # Ptr[Struct]: the pointer's VALUE is the base address. A bare
        # identifier evaluates to its held address (load the slot).
        gen_expr(obj)
    else:
        gen_addr_of(obj)
    if foff != 0:
        emit_add_imm_rax(foff)


# Member field load: value of obj.member into %rax. An array-typed field
# (fsz==0) decays to its ADDRESS (no load), mirroring gen_member_load.
def gen_member_load(node: uint32):
    obj: uint32 = nd_a[node]
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(8, node)
        return
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, nd_name_off[node], nd_name_len[node], &foff, &fsgn)
    if fsz == SF_NOFIELD:
        cg_fail(8, node)
        return
    gen_member_address(obj, nd_name_off[node], nd_name_len[node])
    if fsz == 0:
        return                       # array/struct field decays to its address
    if fsgn != 0:
        emit_load_mem_rax_signed(fsz)
    else:
        emit_load_mem_rax(fsz)


# Member field store: obj.member = value (plain) / OP= value (augmented).
# Mirrors gen_assignment's MemberExpr target branch (sized store; for the
# augmented form, address-once read-modify-write).
def gen_assign_member(node: uint32):
    tgt: uint32 = nd_a[node]            # ND_MEMBER
    obj: uint32 = nd_a[tgt]
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(2, node)
        return
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, nd_name_off[tgt], nd_name_len[tgt], &foff, &fsgn)
    if fsz == SF_NOFIELD or fsz == 0:
        cg_fail(2, node)             # cannot assign a whole array field
        return
    aug: uint32 = nd_aux[node]
    if aug == AUGOP_NONE:
        # Plain store. Mirror gen_assign_index's register convention
        # (codegen.ad stores %rcx into (%rax)): eval value, push; compute
        # &obj.member into %rax; pop value into %rcx; sized store.
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_member_address(obj, nd_name_off[tgt], nd_name_len[tgt])
        emit_pop_rcx()
        emit_store_mem_rcx(fsz)
        return
    # Augmented `obj.f OP= v`: new = (load obj.f) OP v.
    gen_expr(nd_b[node])
    emit_push_rax()
    gen_member_address(obj, nd_name_off[tgt], nd_name_len[tgt])
    if fsgn != 0:
        emit_load_mem_rax_signed(fsz)
    else:
        emit_load_mem_rax(fsz)
    emit_pop_rcx()
    if aug == AUGOP_ADD:
        emit_add_rcx_rax()
    elif aug == AUGOP_SUB:
        emit_sub_rcx_rax()
    elif aug == AUGOP_MUL:
        emit_imul_rcx_rax()
    else:
        cg_fail(2, node)
        return
    emit_push_rax()                  # new value
    gen_member_address(obj, nd_name_off[tgt], nd_name_len[tgt])
    emit_pop_rcx()                   # new value -> %rcx
    emit_store_mem_rcx(fsz)


# 1 if class `cls` (an ND_CLASS) directly declares a method named
# [m_off,m_len). Method chain head is nd_b; each entry is an ND_FUNCTION.
def class_has_own_method(cls: uint32, m_off: uint32, m_len: uint32) -> uint32:
    m: uint32 = nd_b[cls]
    while m != 0:
        if name_match(nd_name_off[m], nd_name_len[m], m_off, m_len) != 0:
            return 1
        m = nd_next[m]
    return 0


# Resolve the OWNER class (the ND_CLASS that literally declares method
# [m_off,m_len)) for a receiver whose static class is `cls`, mirroring
# codegen_x86's class_methods first-match-wins walk: the class's OWN methods
# override inherited ones, so check own methods first, then bases
# left-to-right depth-first. Returns the owner class decl node, or 0 if no
# such method exists in the hierarchy.
def method_owner(cls: uint32, m_off: uint32, m_len: uint32) -> uint32:
    if class_has_own_method(cls, m_off, m_len) != 0:
        return cls
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc != 0:
            owner: uint32 = method_owner(bc, m_off, m_len)
            if owner != 0:
                return owner
        b = nd_next[b]
    return 0


# Offset just past `cls`'s last flattened field, mirroring
# codegen_x86._collect_class_methods.end_of_fields: walk bases depth-first
# (left-to-right) then own fields, aligning each field to its natural
# alignment, advancing by each field's size — but WITHOUT the trailing
# 8-byte .bss round-up that layout_struct applies to st_total. This is the
# right "where does the next adjacent base start?" answer when placing the
# second-and-later bases during multi-base flattening (st_total would
# over-count by up to 7 padding bytes and push later bases off their real
# layout slot). Returns 0 for an unknown class.
def class_end_of_fields(cls: uint32) -> uint32:
    off: uint32 = 0
    # Bases first (nd_c = head of base-ident chain), depth-first.
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc != 0:
            off = off + class_end_of_fields(bc)
        b = nd_next[b]
    # Own fields (nd_a = head of ND_CLASS_FIELD chain), aligned then advanced.
    f: uint32 = nd_a[cls]
    while f != 0:
        tnode: uint32 = nd_a[f]
        align: uint32 = natural_align(tnode)
        off = (off + align - 1) & cast[uint32](0 - align)
        off = off + type_size_of(tnode)
        f = nd_next[f]
    return off


# Byte offset within `cls`'s flattened layout at which the layout of the
# OWNER class (the one that literally declares method [m_off,m_len)) begins,
# mirroring codegen_x86._collect_class_methods.resolve's running_offset.
# A class's OWN methods sit at offset 0 (self.field addresses the full
# layout, which starts at 0). For a method inherited from a base, the
# offset is the sum of class_end_of_fields() over the bases that precede
# the owning base, plus the owner's offset WITHIN that base (transitive
# multi-base). First-match-wins identical to method_owner: own methods
# override inherited ones, bases scanned left-to-right depth-first.
# Returns 0 when the method is the class's own (or single-inheritance,
# where every base sits at offset 0); 0xFFFFFFFF if not found (caller
# already validated via method_owner so this is belt-and-suspenders).
def receiver_offset_for(cls: uint32, m_off: uint32, m_len: uint32) -> uint32:
    if class_has_own_method(cls, m_off, m_len) != 0:
        return 0
    running: uint32 = 0
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc != 0:
            if method_owner(bc, m_off, m_len) != 0:
                inner: uint32 = receiver_offset_for(bc, m_off, m_len)
                return running + inner
            running = running + class_end_of_fields(bc)
        b = nd_next[b]
    return 0xFFFFFFFF


# -----------------------------------------------------------------------
# Method-call lowering — `obj.method(args)` (ND_METHOD_CALL: a=obj,
# name=method, b=arg chain, aux=argc). Mirrors codegen_x86.gen_method_call:
# resolve obj's class, find the owning class for `method`, and emit a direct
# call to the mangled `<Owner>__<method>` symbol passing &obj (or obj's
# pointer value if obj is Ptr[Struct]) as the implicit FIRST arg (self).
# Register-arg path only (self + up to 5 explicit args = 6 total).
# -----------------------------------------------------------------------
def gen_method_call(node: uint32):
    obj: uint32 = nd_a[node]
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(8, node)
        return
    cls: uint32 = st_decl[sidx1 - 1]
    owner: uint32 = method_owner(cls, nd_name_off[node], nd_name_len[node])
    if owner == 0:
        cg_fail(8, node)             # class has no such method
        return
    argc: uint32 = nd_aux[node]
    total: uint32 = argc + 1         # + implicit self
    if total > 6:
        cg_fail(8, node)
        return

    # Marshal arg0 = receiver (self): &obj (in-place) or the pointer value
    # (Ptr[Struct]). codegen.ad's gen_addr_of/gen_expr already produce the
    # right thing. For multi-base inheritance where the method's owning base
    # sits at a non-zero byte offset within the receiver's flattened layout,
    # bump the receiver pointer by that offset so the callee's self.field
    # references (addressed against the OWNER's struct layout, which begins
    # at offset 0 of the owner) land on the right bytes. Single inheritance
    # (and a class's own methods) gives receiver_offset==0 — no bump.
    # Mirrors codegen_x86.gen_method_call's receiver_offset path exactly.
    if is_ptr != 0:
        gen_expr(obj)                # pointer value = receiver address
    else:
        gen_addr_of(obj)             # &obj = receiver address
    recv_off: uint32 = receiver_offset_for(cls, nd_name_off[node], nd_name_len[node])
    if recv_off != 0 and recv_off != 0xFFFFFFFF:
        emit_add_imm_rax(recv_off)   # &obj + sizeof(prior bases)
    emit_push_rax()
    # Then the explicit args, lowest index first.
    arg: uint32 = nd_b[node]
    i: uint32 = 0
    while i < argc:
        gen_expr(arg)
        emit_push_rax()
        arg = nd_next[arg]
        i = i + 1
    # Pop in reverse so self lands in %rdi, arg0 in %rsi, ...
    i = total
    while i > 0:
        i = i - 1
        emit_pop_argreg(i)
    emit_xor_eax_eax()
    emit_b(0xE8)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_method_fixup(at, nd_name_off[owner], nd_name_len[owner], nd_name_off[node], nd_name_len[node])


# Is `name` (strbuf ref) the literal "__init__"? Used to detect the
# constructor method when lowering `Foo(args)` ctor sugar.
def name_is_init(name_off: uint32, name_len: uint32) -> uint32:
    if name_len != 8:
        return 0
    # "__init__" = 5f 5f 69 6e 69 74 5f 5f
    if strbuf[name_off] != 95:
        return 0
    if strbuf[name_off + 1] != 95:
        return 0
    if strbuf[name_off + 2] != 105:     # 'i'
        return 0
    if strbuf[name_off + 3] != 110:     # 'n'
        return 0
    if strbuf[name_off + 4] != 105:     # 'i'
        return 0
    if strbuf[name_off + 5] != 116:     # 't'
        return 0
    if strbuf[name_off + 6] != 95:
        return 0
    if strbuf[name_off + 7] != 95:
        return 0
    return 1


# Constructor sugar: `f: Foo = Foo(args)` where Foo is a class with an
# `__init__` method lowers to `Foo__init(&f, args)`. `decl` is the ND_VAR_DECL
# (its name = the target local), `tnode` its struct type, `val` the Foo(args)
# CallExpr. Mirrors codegen_x86._ctor_call_class + _emit_ctor_init. If Foo has
# NO __init__, an in-place struct decl with a call init is unsupported here.
def gen_ctor_init(decl: uint32, tnode: uint32, val: uint32):
    if nd_kind[val] != ND_CALL:
        cg_fail(2, decl)
        return
    callee: uint32 = nd_a[val]
    if nd_kind[callee] != ND_IDENT:
        cg_fail(2, decl)
        return
    # The call name must be the struct's own class name.
    if name_match(nd_name_off[callee], nd_name_len[callee], nd_name_off[tnode], nd_name_len[tnode]) == 0:
        cg_fail(2, decl)
        return
    cls: uint32 = class_lookup_decl(nd_name_off[tnode], nd_name_len[tnode])
    if cls == 0:
        cg_fail(2, decl)
        return
    # Find the owning class for __init__ (own or inherited).
    owner: uint32 = 0
    m: uint32 = nd_b[cls]
    while m != 0:
        if name_is_init(nd_name_off[m], nd_name_len[m]) != 0:
            owner = cls
            m = 0
        else:
            m = nd_next[m]
    if owner == 0:
        # No __init__: a struct decl initialised by a bare Foo() with no ctor
        # is just a zeroed slot in the Python model — but a Foo(args) with
        # arguments and no __init__ is a program error. The fuzzer always
        # pairs Foo(args) with an __init__, so treat a missing ctor as
        # unsupported rather than silently dropping the args.
        cg_fail(2, decl)
        return
    argc: uint32 = nd_aux[val]
    total: uint32 = argc + 1
    if total > 6:
        cg_fail(2, decl)
        return
    # arg0 = &local (the target slot address).
    off: int32 = 0
    if lookup_local(nd_name_off[decl], nd_name_len[decl], &off) == 0:
        cg_fail(2, decl)
        return
    emit_lea_local_rax(off)
    emit_push_rax()
    arg: uint32 = nd_b[val]
    i: uint32 = 0
    while i < argc:
        gen_expr(arg)
        emit_push_rax()
        arg = nd_next[arg]
        i = i + 1
    i = total
    while i > 0:
        i = i - 1
        emit_pop_argreg(i)
    emit_xor_eax_eax()
    emit_b(0xE8)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_method_fixup(at, nd_name_off[owner], nd_name_len[owner], nd_name_off[m_init_name(owner)], nd_name_len[m_init_name(owner)])


# Return the ND_FUNCTION node of `cls`'s __init__ method (for its name ref).
def m_init_name(cls: uint32) -> uint32:
    m: uint32 = nd_b[cls]
    while m != 0:
        if name_is_init(nd_name_off[m], nd_name_len[m]) != 0:
            return m
        m = nd_next[m]
    return 0


# -----------------------------------------------------------------------
# Call codegen — direct call to a named function. Mirrors codegen_x86's
# gen_call register-arg path (args 0..5 only): evaluate each argument into
# %rax and push it, then pop them in reverse so arg 0 lands in %rdi, clear
# %al, and `call <callee>`. Result is left in %rax. Stack args (7+) and
# indirect calls are outside this subset.
# -----------------------------------------------------------------------

def gen_call(node: uint32):
    callee: uint32 = nd_a[node]
    if nd_kind[callee] != ND_IDENT:
        # Only direct calls to a bare name are in scope.
        cg_fail(8, node)
        return
    argc: uint32 = nd_aux[node]
    if argc > 6:
        cg_fail(8, node)
        return

    # --- syscall builtin path -------------------------------------------
    # `__syscallN(num, a1..aN)` lowers to a raw Linux x86_64 `syscall`:
    # evaluate-and-push the N+1 operands, pop them into the syscall regs
    # (operand 0 = number -> %rax, operand 1 -> %rdi, ...), then `0F 05`.
    # Result is left in %rax (the syscall return value). No `call`, no
    # fixup — this is an inline instruction, not a function reference.
    nargs: uint32 = syscall_builtin_args(nd_name_off[callee],
                                         nd_name_len[callee])
    if nargs != 0:
        if argc != nargs + 1:
            cg_fail(8, node)
            return
        sarg: uint32 = nd_b[node]
        si: uint32 = 0
        while si < argc:
            gen_expr(sarg)
            emit_push_rax()
            sarg = nd_next[sarg]
            si = si + 1
        si = argc
        while si > 0:
            si = si - 1
            emit_pop_syscallreg(si)
        emit_syscall_insn()
        return

    # Evaluate-and-push each argument, lowest index first.
    arg: uint32 = nd_b[node]
    i: uint32 = 0
    while i < argc:
        gen_expr(arg)
        emit_push_rax()
        arg = nd_next[arg]
        i = i + 1

    # Pop in reverse so arg 0 ends in %rdi.
    i = argc
    while i > 0:
        i = i - 1
        emit_pop_argreg(i)

    emit_xor_eax_eax()
    # Emit `call rel32`; the target offset is resolved after all functions
    # are emitted (the callee may not have been generated yet).
    emit_b(0xE8)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_call_fixup(at, nd_name_off[callee], nd_name_len[callee])


# -----------------------------------------------------------------------
# Statement codegen.
# -----------------------------------------------------------------------

# Generate a statement sibling-chain (the body block representation the
# parser produces for if/while/function bodies).
def gen_block(head: uint32):
    s: uint32 = head
    while s != 0:
        gen_stmt(s)
        s = nd_next[s]


# Store the value currently in %rax into the slot for `name`. A name that
# resolves to a known global scalar stores through the data section (leaq
# its address into %rcx-free path: address into %rax, value spilled), and
# otherwise stores to a local slot, allocating it on first assignment
# (mirrors VarDecl/Assignment to a fresh local). Used by ND_VAR_DECL and
# plain ND_ASSIGN to an identifier.
def store_to_named(name_off: uint32, name_len: uint32):
    off: int32 = 0
    if lookup_local(name_off, name_len, &off) != 0:
        emit_store_local_rax(off)
        return
    gi: uint32 = glob_lookup(name_off, name_len)
    if gi != 0 and glob_elem_size[gi - 1] == 0:
        # Scalar global store: value is in %rax. Move it to %rcx, leaq the
        # global address into %rax, then a sized store %rcx -> (%rax),
        # matching the local-array store lowering (and emulator opcodes).
        emit_mov_rax_rcx()
        emit_lea_global_rax(glob_offset[gi - 1], glob_is_bss[gi - 1])
        emit_store_mem_rcx(glob_scalar_size[gi - 1])
        return
    # Not a global — fall back to a (possibly fresh) local slot.
    off = alloc_local(name_off, name_len)
    emit_store_local_rax(off)


# Byte width of a primitive ND_TYPE node (nd_aux holds the type_keyword
# code from parser.type_keyword_code): int8/uint8/char/bool=1, *16=2,
# *32/int/float=4, *64=8. Returns 8 for anything else (pointer-ish).
def prim_type_size(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] != ND_TYPE:
        return 8
    code: uint32 = nd_aux[tnode]
    if code == 2 or code == 6 or code == 12 or code == 13:
        return 1
    if code == 3 or code == 7:
        return 2
    if code == 4 or code == 8 or code == 10:
        return 4
    if code == 5 or code == 9 or code == 11:
        return 8
    return 8


# Total byte size of a (possibly nested array) type node, mirroring
# codegen_x86.get_type_size: an ND_ARRAY_TYPE is `count * type_size(elem)`
# (recursing through nested arrays), a Ptr[T] is 8, anything else falls to
# prim_type_size. Used to compute the per-level INDEX STRIDE for a
# multi-dimensional array global: at the outer level of `Array[N, Array[M,
# T]]` the stride is type_size(Array[M, T]) = M*sizeof(T) (the row); at the
# inner level it is sizeof(T).
def type_size_of(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        count: uint32 = cast[uint32](nd_num[tnode])
        return count * type_size_of(nd_a[tnode])
    if nd_kind[tnode] == ND_PTR_TYPE:
        return 8
    # A struct/class-named ND_TYPE (nd_aux==0, a user name) -> its total size,
    # mirroring codegen_x86.get_type_size's `if name in self.structs`.
    si1: uint32 = struct_lookup_by_node(tnode)
    if si1 != 0:
        return st_total[si1 - 1]
    return prim_type_size(tnode)


# Natural alignment of a type node (C-ABI, capped at 8), mirroring
# codegen_x86.natural_align: an array aligns to its element; otherwise the
# size capped at 8 (min 1). A struct field aligns to min(total,8).
def natural_align(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        return natural_align(nd_a[tnode])
    sz: uint32 = type_size_of(tnode)
    if sz > 8:
        return 8
    if sz < 1:
        return 1
    return sz


# Resolve a struct/class-named ND_TYPE node to a struct-table index (+1), or
# 0 if it is a primitive / non-struct type. A struct name is an ND_TYPE with
# nd_aux==0 (no primitive keyword code) carrying the name in nd_name_off/len.
def struct_lookup_by_node(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    if nd_aux[tnode] != 0:
        return 0                 # a primitive keyword type
    return struct_lookup(nd_name_off[tnode], nd_name_len[tnode])


# Resolve a struct/class name (strbuf ref) to a struct-table index (+1), or
# 0 if not a registered struct.
def struct_lookup(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < st_count:
        if name_match(st_name_off[i], st_name_len[i], name_off, name_len) != 0:
            return i + 1
        i = i + 1
    return 0


# If `tnode` is a Ptr[Struct] type node, return the struct table index (+1)
# of the pointee struct, else 0. Used to type the `self: Ptr[Foo]` param.
def ptr_struct_idx(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_PTR_TYPE:
        return 0
    return struct_lookup_by_node(nd_a[tnode])


# Find a field within struct `sidx1-1` by name. On a hit, writes the field's
# byte offset through out_off and returns the field's load/store size (a
# scalar width 1/2/4/8, or 0 for an array-typed field that decays to its
# address). On a miss returns 0xFFFFFFFF (and out_off is untouched).
SF_NOFIELD: uint32 = 4294967295
def struct_field_find(sidx1: uint32, name_off: uint32, name_len: uint32, out_off: Ptr[uint32], out_signed: Ptr[uint32]) -> uint32:
    si: uint32 = sidx1 - 1
    base: uint32 = st_field_base[si]
    n: uint32 = st_nfields[si]
    i: uint32 = 0
    while i < n:
        idx: uint32 = base + i
        if name_match(sf_name_off[idx], sf_name_len[idx], name_off, name_len) != 0:
            out_off[0] = sf_offset[idx]
            out_signed[0] = sf_is_signed[idx]
            return sf_size[idx]
        i = i + 1
    return SF_NOFIELD


# Find a class declaration (ND_CLASS) by name in the program decl chain.
# Returns the node id or 0 if no such class is declared.
def class_lookup_decl(name_off: uint32, name_len: uint32) -> uint32:
    cur: uint32 = cg_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_CLASS:
            if name_match(nd_name_off[cur], nd_name_len[cur], name_off, name_len) != 0:
                return cur
        cur = nd_next[cur]
    return 0


# The load/store size to record for a struct FIELD type. A scalar (or Ptr)
# field stores its width; an array-typed field records 0 (it decays to its
# address on load, mirroring codegen_x86's ArrayType field special-case).
def field_store_size(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        return 0                  # array field: decays to address (no scalar load)
    if nd_kind[tnode] == ND_PTR_TYPE:
        return 8
    if struct_lookup_by_node(tnode) != 0:
        return 0                  # embedded struct field: decays to address
    return prim_type_size(tnode)


# Emit one field into the flat field table at the current cg_layout_offset,
# aligned to its natural alignment, then advance cg_layout_offset past it.
# Mirrors layout_struct's per-field alignment walk.
def layout_emit_field(fld: uint32):
    tnode: uint32 = nd_a[fld]
    align: uint32 = natural_align(tnode)
    cg_layout_offset = (cg_layout_offset + align - 1) & cast[uint32](0 - align)
    if sf_count >= MAX_STRUCT_FIELDS:
        cg_fail(6, fld)
        return
    sf_name_off[sf_count] = nd_name_off[fld]
    sf_name_len[sf_count] = nd_name_len[fld]
    sf_offset[sf_count] = cg_layout_offset
    fsz: uint32 = field_store_size(tnode)
    sf_size[sf_count] = fsz
    sgn: uint32 = 0
    if fsz != 0 and fsz < 8 and type_is_unsigned(tnode) == 0:
        sgn = 1
    sf_is_signed[sf_count] = sgn
    sf_count = sf_count + 1
    cg_layout_offset = cg_layout_offset + type_size_of(tnode)


# Recursively emit a class's inherited (base, transitively, left-to-right)
# fields followed by its own fields, mirroring layout_struct's flattening.
# Walks the base chain depth-first so a grandparent's fields land first.
def layout_emit_class_fields(cls: uint32):
    # Bases first (nd_c = head of base-ident chain; each is an ND_IDENT).
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc == 0:
            cg_fail(8, cls)           # inherits from unknown class
            return
        layout_emit_class_fields(bc)
        b = nd_next[b]
    # Own fields (nd_a = head of ND_CLASS_FIELD chain).
    f: uint32 = nd_a[cls]
    while f != 0:
        layout_emit_field(f)
        f = nd_next[f]


# Lay out one ND_CLASS into the struct table (fields + 8-byte-rounded total),
# mirroring codegen_x86.layout_struct. Idempotent: a class already laid out
# is skipped (so out-of-order / repeated layout is safe).
def layout_struct(cls: uint32):
    if struct_lookup(nd_name_off[cls], nd_name_len[cls]) != 0:
        return
    if st_count >= MAX_STRUCTS:
        cg_fail(6, cls)
        return
    si: uint32 = st_count
    st_name_off[si] = nd_name_off[cls]
    st_name_len[si] = nd_name_len[cls]
    st_decl[si] = cls
    st_field_base[si] = sf_count
    # Reserve the struct entry BEFORE walking fields so a self-referential
    # Ptr field (struct_lookup_by_node on a Ptr pointee) resolves; field
    # walking only consults type_size_of (8 for a Ptr) so this is safe.
    st_count = st_count + 1
    cg_layout_offset = 0
    layout_emit_class_fields(cls)
    st_nfields[si] = sf_count - st_field_base[si]
    st_total[si] = (cg_layout_offset + 7) & cast[uint32](0xFFFFFFF8)


# Lay out every ND_CLASS in the program BEFORE any function emission, so
# member access + method bodies can resolve struct layouts. Bases may be
# declared after a derived class; layout_struct resolves them by name from
# the (already-stashed) program decl chain, so a single forward pass that
# lays out each class (recursing into bases first) suffices.
def layout_classes(prog: uint32):
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_CLASS:
            layout_struct(cur)
        cur = nd_next[cur]


# If `tnode` is a Ptr[T] type node, return the pointee width (the size of
# T, computed by prim_type_size on the inner type). Returns 0 when `tnode`
# is not a pointer type. ND_PTR_TYPE carries the inner type on nd_a.
def ptr_pointee_size(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_PTR_TYPE:
        return 0
    inner: uint32 = nd_a[tnode]
    return prim_type_size(inner)


# Reserve a slot for a var-decl name, honouring an Array type. Returns 1 if
# it allocated (or already present), leaving any error in cg_err.
def declare_local(name_off: uint32, name_len: uint32, tnode: uint32):
    off: int32 = 0
    if lookup_local(name_off, name_len, &off) != 0:
        return
    if tnode != 0 and nd_kind[tnode] == ND_ARRAY_TYPE:
        count: uint32 = cast[uint32](nd_num[tnode])
        es: uint32 = prim_type_size(nd_a[tnode])
        alloc_array_local(name_off, name_len, count, es)
    elif tnode != 0 and nd_kind[tnode] == ND_PTR_TYPE:
        # Ptr[T] local: an 8-byte slot that holds an address; record the
        # pointee width so p[i] dereferences with the right load/store size.
        psidx: uint32 = ptr_struct_idx(tnode)
        alloc_ptr_local(name_off, name_len, ptr_pointee_size(tnode))
        if psidx != 0:
            loc_set_struct_ptr(psidx)        # Ptr[Struct] (e.g. `self`)
    elif tnode != 0 and struct_lookup_by_node(tnode) != 0:
        # Struct-typed local: an in-place struct value. Reserve total_size
        # bytes; member access takes &slot + field_offset.
        ssi: uint32 = struct_lookup_by_node(tnode)
        alloc_struct_local(name_off, name_len, st_total[ssi - 1], ssi)
    else:
        alloc_local(name_off, name_len)
        # Record scalar int signedness so identifier operands feed the
        # signed/unsigned setcc + div/mod choice (mirrors get_expr_type).
        loc_set_signedness(type_signedness(tnode))
        # Sub-8-byte known int scalar: tag its width for sized store +
        # extending load (mirrors codegen_x86 _scalar_local_size).
        sz_d: uint32 = prim_type_size(tnode)
        if type_signedness(tnode) != 0 and sz_d < 8:
            loc_set_scalar_size(sz_d)
        # Float scalar: tag the float width so identifier operands route to
        # the SSE path. A float32 (4 bytes) also gets a sized 4-byte slot so
        # the local store writes exactly 4 bytes (mirrors codegen_x86's
        # _scalar_local_size returning 4 for float32). The FP bit pattern
        # transits %rax, so the slot is a plain integer store/load.
        fw_d: uint32 = type_float_width(tnode)
        if fw_d != 0:
            loc_set_float(fw_d)
            if fw_d == 4:
                loc_set_scalar_size(4)


def gen_stmt(node: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]

    if k == ND_RETURN:
        gen_expr(nd_a[node])
        emit_leave()
        emit_ret()
        return

    if k == ND_EXPR_STMT:
        gen_expr(nd_a[node])
        return

    if k == ND_VAR_DECL:
        # name = nd_name_off/len, a = type, b = optional initialiser value.
        # The prescan already reserved the slot (scalar or Array). An Array
        # decl never carries a scalar initialiser in this subset; a scalar
        # decl with an initialiser stores it into the slot.
        tnode: uint32 = nd_a[node]
        if tnode != 0 and nd_kind[tnode] == ND_ARRAY_TYPE:
            # Array slot already reserved; no initialiser store.
            declare_local(nd_name_off[node], nd_name_len[node], tnode)
            return
        # Struct-typed local: the slot (total_size bytes) was reserved in the
        # prescan. Constructor sugar `f: Foo = Foo(args)` lowers to
        # Foo__init(&f, args); Adder has no struct-return, so we never do an
        # evaluate-then-store of a struct value. A struct decl with no init is
        # just a zeroed slot (no emission).
        if tnode != 0 and struct_lookup_by_node(tnode) != 0:
            declare_local(nd_name_off[node], nd_name_len[node], tnode)
            val0: uint32 = nd_b[node]
            if val0 != 0:
                gen_ctor_init(node, tnode, val0)
            return
        val: uint32 = nd_b[node]
        if val != 0:
            gen_expr(val)
            store_to_named(nd_name_off[node], nd_name_len[node])
        else:
            declare_local(nd_name_off[node], nd_name_len[node], tnode)
        return

    if k == ND_ASSIGN:
        tgt: uint32 = nd_a[node]
        if nd_kind[tgt] == ND_INDEX:
            gen_assign_index(node)
            return
        if nd_kind[tgt] == ND_MEMBER:
            gen_assign_member(node)
            return
        if nd_kind[tgt] != ND_IDENT:
            # Only identifier / index targets are in scope.
            cg_fail(2, node)
            return
        aug: uint32 = nd_aux[node]
        if aug == AUGOP_NONE:
            gen_expr(nd_b[node])
            store_to_named(nd_name_off[tgt], nd_name_len[tgt])
            return
        # Augmented `tgt OP= value`: desugar to tgt = tgt OP value.
        # Evaluate value first (right), push; load tgt (left); pop %rcx;
        # apply — exactly gen_expr's ND_BINARY lowering.
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_expr(tgt)
        emit_pop_rcx()
        if aug == AUGOP_ADD:
            emit_add_rcx_rax()
        elif aug == AUGOP_SUB:
            emit_sub_rcx_rax()
        elif aug == AUGOP_MUL:
            emit_imul_rcx_rax()
        else:
            cg_fail(2, node)
            return
        store_to_named(nd_name_off[tgt], nd_name_len[tgt])
        return

    if k == ND_IF:
        gen_if(node)
        return

    if k == ND_WHILE:
        gen_while(node)
        return

    if k == ND_BREAK:
        # Jump forward to the innermost loop's exit. The target is not yet
        # known, so emit a placeholder `jmp rel32` and record its rel32-field
        # offset as a break fixup on the top loop frame; gen_while patches it
        # once the exit point is reached.
        if loop_depth == 0:
            cg_fail(2, node)
            return
        d: uint32 = loop_depth - 1
        if loop_brk_n[d] >= MAX_BRK:
            cg_fail(6, node)
            return
        at: uint32 = emit_jmp_fwd()
        loop_brk_at[d * MAX_BRK + loop_brk_n[d]] = at
        loop_brk_n[d] = loop_brk_n[d] + 1
        return

    if k == ND_CONTINUE:
        # Jump back to the innermost loop's condition test (a known offset).
        if loop_depth == 0:
            cg_fail(2, node)
            return
        emit_jmp_back(loop_cont_target[loop_depth - 1])
        return

    if k == ND_PASS:
        # `pass` is a no-op placeholder statement; emit nothing.
        return

    if k == ND_DO_WHILE:
        gen_do_while(node)
        return

    if k == ND_FOR:
        gen_for(node)
        return

    # Other statement kinds not covered by this subset.
    cg_fail(2, node)


# Assign to an array element: `arr[i] = v` (and augmented `arr[i] OP= v`).
# Strategy (matches codegen_x86.gen_assignment's indexed-target path):
#   evaluate the RHS value, push it; compute &arr[i] into %rax, push it;
#   pop address into %rcx-ish... — but our stack-machine only has %rax/%rcx,
#   so we marshal carefully:
#     1. eval value -> %rax ; push                       (value on stack)
#     2. compute &arr[i] -> %rax ; push                  (addr on stack)
#     3. (augmented only) reload value, load *addr, combine)
#   Then pop addr into a scratch, pop value into %rcx, store %rcx -> (addr).
# We keep it simple by computing the address LAST and storing immediately.
def gen_assign_index(node: uint32):
    tgt: uint32 = nd_a[node]            # ND_INDEX
    es: uint32 = index_elem_size(tgt)
    aug: uint32 = nd_aux[node]

    if aug == AUGOP_NONE:
        # Plain store. Evaluate value, push; compute address; pop value into
        # %rcx; store %rcx -> (%rax).
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_index_addr(tgt)            # &arr[i] -> %rax
        emit_pop_rcx()                 # value -> %rcx
        emit_store_mem_rcx(es)
        return

    # Augmented `arr[i] OP= v`: new = (load arr[i]) OP v.
    #   eval v -> %rax ; push                 [v]
    #   load arr[i] -> %rax                   (old)
    #   pop %rcx (=v) ; apply OP -> %rax      (new value)
    #   push new -> stack                     [new]
    #   compute &arr[i] -> %rax
    #   pop new into %rcx ; store %rcx -> (%rax)
    gen_expr(nd_b[node])
    emit_push_rax()
    gen_index_addr(tgt)               # &arr[i]
    emit_load_mem_rax(es)            # old value -> %rax
    emit_pop_rcx()                    # v -> %rcx
    if aug == AUGOP_ADD:
        emit_add_rcx_rax()
    elif aug == AUGOP_SUB:
        emit_sub_rcx_rax()
    elif aug == AUGOP_MUL:
        emit_imul_rcx_rax()
    else:
        cg_fail(2, node)
        return
    emit_push_rax()                  # new value
    gen_index_addr(tgt)              # &arr[i] again
    emit_pop_rcx()                   # new -> %rcx
    emit_store_mem_rcx(es)


# if / elif* / else  (mirrors codegen_x86.gen_if). The parser stores the
# condition on nd_a, then-body chain on nd_b, an ND_ELIF sibling-chain on
# nd_c, and the else-body chain on nd_d.
def gen_if(node: uint32):
    # End-of-if jump fixups accumulate here (one per taken branch), all
    # backpatched to the join point after the whole construct.
    end_fix: Array[64, uint32]
    end_n: uint32 = 0

    # Primary condition.
    gen_expr(nd_a[node])
    emit_test_rax_rax()
    # Jump over the then-body when false; patched to the next branch (or
    # the end if there is none).
    skip: uint32 = emit_jz_fwd()
    gen_block(nd_b[node])
    end_fix[end_n] = emit_jmp_fwd()
    end_n = end_n + 1
    # Land the false-jump here (start of the next branch / else / end).
    patch_rel32(skip, code_len)

    # elif chain.
    e: uint32 = nd_c[node]
    while e != 0:
        gen_expr(nd_a[e])
        emit_test_rax_rax()
        skip2: uint32 = emit_jz_fwd()
        gen_block(nd_b[e])
        end_fix[end_n] = emit_jmp_fwd()
        end_n = end_n + 1
        patch_rel32(skip2, code_len)
        e = nd_next[e]

    # else body (if any).
    if nd_d[node] != 0:
        gen_block(nd_d[node])

    # Backpatch every branch's exit jump to the join point.
    i: uint32 = 0
    while i < end_n:
        patch_rel32(end_fix[i], code_len)
        i = i + 1


# while  (mirrors codegen_x86.gen_while): header label, condition test,
# exit jump, body, back-jump to the header, exit label.
def gen_while(node: uint32):
    start: uint32 = code_len
    # Push a loop frame: `continue` targets `start` (re-test the condition);
    # `break` fixups accumulate in this frame's slot and patch to the exit.
    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return
    depth: uint32 = loop_depth
    loop_cont_target[depth] = start
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1

    gen_expr(nd_a[node])
    emit_test_rax_rax()
    exit_fix: uint32 = emit_jz_fwd()
    gen_block(nd_b[node])
    emit_jmp_back(start)
    # Exit point: backpatch the condition-false jump AND every `break`.
    patch_rel32(exit_fix, code_len)
    i: uint32 = 0
    while i < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + i], code_len)
        i = i + 1
    loop_depth = loop_depth - 1


# do-while  (mirrors codegen_x86.gen_do_while): execute the body once
# unconditionally, then a `cont:` test that loops back while non-zero.
#   start: <body>
#   cont:  <eval cond -> %rax> ; testq %rax,%rax ; jnz start
#   end:
# `continue` jumps to `cont` (the test) so the condition still gates the
# next iteration; `break` jumps to `end`. Same loop-frame machinery as
# gen_while, but the continue target is the COND TEST, not the top.
def gen_do_while(node: uint32):
    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return
    start: uint32 = code_len
    depth: uint32 = loop_depth
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1
    # Body.
    gen_block(nd_b[node])
    # cont: the condition test is `continue`'s target.
    cont_at: uint32 = code_len
    loop_cont_target[depth] = cont_at
    gen_expr(nd_a[node])
    emit_test_rax_rax()
    emit_jnz_back(start)
    # end: backpatch every `break` to here.
    i: uint32 = 0
    while i < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + i], code_len)
        i = i + 1
    loop_depth = loop_depth - 1


# Compile-time integer value of a literal expr (a bare ND_INT_LIT or a
# NEG-of-int-literal), returning it through out_v and 1 on success, else 0.
# Mirrors codegen_x86._const_int_value (used to pick a const range step's
# loop direction at compile time).
def const_int_value(expr: uint32, out_v: Ptr[int64]) -> uint32:
    if expr == 0:
        return 0
    if nd_kind[expr] == ND_INT_LIT:
        out_v[0] = cast[int64](nd_num[expr])
        return 1
    if nd_kind[expr] == ND_UNARY and nd_aux[expr] == UNOP_NEG:
        inner: int64 = 0
        if const_int_value(nd_a[expr], &inner) != 0:
            out_v[0] = 0 - inner
            return 1
    return 0


# 1 if `expr` is a `range(...)` call used as a for-loop iterable.
def is_range_call(expr: uint32) -> uint32:
    if nd_kind[expr] != ND_CALL:
        return 0
    callee: uint32 = nd_a[expr]
    if nd_kind[callee] != ND_IDENT:
        return 0
    if nd_name_len[callee] != 5:
        return 0
    # "range" = 72 61 6e 67 65
    o: uint32 = nd_name_off[callee]
    if strbuf[o] != 114:        # 'r'
        return 0
    if strbuf[o + 1] != 97:     # 'a'
        return 0
    if strbuf[o + 2] != 110:    # 'n'
        return 0
    if strbuf[o + 3] != 103:    # 'g'
        return 0
    if strbuf[o + 4] != 101:    # 'e'
        return 0
    return 1


# `for var in range(...)` — an integer counter loop. Mirrors
# codegen_x86.gen_for_range:
#   i = start
#   start_lbl: while (i </> stop) { body; step_lbl: i = i + step; jmp start }
#   end_lbl:
# `continue` lands on step_lbl (so the counter still advances — Python
# for-loop semantics), `break` on end_lbl. The induction var is a normal
# int64 local (already reserved in prescan).
def gen_for_range(node: uint32):
    calle: uint32 = nd_a[node]            # the range(...) ND_CALL
    argc: uint32 = nd_aux[calle]
    a0: uint32 = nd_b[calle]
    start_expr: uint32 = 0
    stop_expr: uint32 = 0
    step_expr: uint32 = 0
    if argc == 1:
        stop_expr = a0
    elif argc == 2:
        start_expr = a0
        stop_expr = nd_next[a0]
    elif argc == 3:
        start_expr = a0
        stop_expr = nd_next[a0]
        step_expr = nd_next[nd_next[a0]]
    else:
        cg_fail(2, node)
        return

    # Loop-direction: ascending (i < stop) unless the step is a constant
    # negative literal, in which case descending (i > stop). Default i64
    # signed compare matches the `while i < stop` idiom this replaces.
    descending: uint32 = 0
    sv: int64 = 0
    if step_expr != 0 and const_int_value(step_expr, &sv) != 0:
        if sv == 0:
            cg_fail(2, node)
            return
        if sv < 0:
            descending = 1

    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return

    # i = start  (start defaults to 0 when range(stop)).
    if start_expr != 0:
        gen_expr(start_expr)
    else:
        emit_mov_imm_rax(cast[uint64](0))
    store_to_named(nd_name_off[node], nd_name_len[node])

    start_lbl: uint32 = code_len
    depth: uint32 = loop_depth
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1

    # while (i </> stop): evaluate the compare as `i OP stop`, mirroring the
    # gen_expr ND_BINARY signed-compare lowering. The var is signed int64.
    # Right operand pushed first, then left (the loop var), then the cmp.
    gen_expr(stop_expr)
    emit_push_rax()
    emit_load_for_var(node)               # i -> %rax (signed int64 load)
    emit_pop_rcx()                        # stop -> %rcx
    emit_cmp_rcx_rax()
    if descending != 0:
        emit_setcc_al(0x9F)               # setg (signed >)
    else:
        emit_setcc_al(0x9C)               # setl (signed <)
    emit_movzx_al_rax()
    emit_test_rax_rax()
    exit_fix: uint32 = emit_jz_fwd()

    gen_block(nd_b[node])

    # step (continue lands here): i = i + step.
    step_at: uint32 = code_len
    loop_cont_target[depth] = step_at
    if step_expr != 0:
        gen_expr(step_expr)
    else:
        emit_mov_imm_rax(cast[uint64](1))
    emit_push_rax()
    emit_load_for_var(node)               # i -> %rax
    emit_pop_rcx()                        # step -> %rcx
    emit_add_rcx_rax()
    store_to_named(nd_name_off[node], nd_name_len[node])
    emit_jmp_back(start_lbl)

    patch_rel32(exit_fix, code_len)
    i: uint32 = 0
    while i < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + i], code_len)
        i = i + 1
    loop_depth = loop_depth - 1


# Load the for-loop induction var (a signed int64 local) into %rax. Mirrors
# the identifier-load path for an int64 local (a plain movq).
def emit_load_for_var(node: uint32):
    off: int32 = 0
    if lookup_local(nd_name_off[node], nd_name_len[node], &off) != 0:
        emit_load_local_rax(off)
        return
    cg_fail(8, node)


# `for var in arr` over a fixed-size Array[N, T] LOCAL/GLOBAL. Mirrors
# codegen_x86.gen_for_array: a hidden idx counter walks 0..N-1, and the loop
# var is re-bound to arr[idx] (a private copy) each iteration.
#   idx = 0
#   start: while (idx < N) { var = arr[idx]; body; step: idx = idx+1; jmp }
#   end:
def gen_for_array(node: uint32, n: uint32, idx_off: int32, elem_sz: uint32):
    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return
    # idx = 0
    emit_mov_imm_rax(cast[uint64](0))
    emit_store_local_rax(idx_off)

    start_lbl: uint32 = code_len
    depth: uint32 = loop_depth
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1

    # while (idx < n) — idx is a non-negative counter, n a small positive
    # literal, so a signed `<` is exact. Push n, load idx, pop n into %rcx.
    emit_mov_imm_rax(cast[uint64](n))
    emit_push_rax()
    emit_load_local_rax(idx_off)
    emit_pop_rcx()                        # n -> %rcx
    emit_cmp_rcx_rax()
    emit_setcc_al(0x9C)                   # setl (idx < n, signed)
    emit_movzx_al_rax()
    emit_test_rax_rax()
    exit_fix: uint32 = emit_jz_fwd()

    # var = arr[idx]: &arr[idx] = base + idx*elem; load sized.
    # Compute idx scaled, add the array base. The array iterable is nd_a.
    emit_load_local_rax(idx_off)
    emit_mov_rax_rcx()
    emit_scale_rcx(elem_sz)
    gen_addr_of(nd_a[node])               # base address -> %rax
    emit_add_rcx_rax()
    emit_load_mem_rax(elem_sz)
    store_to_named(nd_name_off[node], nd_name_len[node])

    gen_block(nd_b[node])

    # step (continue): idx = idx + 1.
    step_at: uint32 = code_len
    loop_cont_target[depth] = step_at
    emit_load_local_rax(idx_off)
    emit_mov_rax_rcx()
    emit_mov_imm_rax(cast[uint64](1))
    emit_add_rcx_rax()
    emit_store_local_rax(idx_off)
    emit_jmp_back(start_lbl)

    patch_rel32(exit_fix, code_len)
    j: uint32 = 0
    while j < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + j], code_len)
        j = j + 1
    loop_depth = loop_depth - 1


# Resolve the element size + count of a for-loop's array iterable (a bare
# array local or global identifier). Writes count through out_n and returns
# the element size, or 0 if the iterable is not a known fixed-size array.
def for_array_info(iter_: uint32, out_n: Ptr[uint32]) -> uint32:
    if nd_kind[iter_] != ND_IDENT:
        return 0
    es: uint32 = lookup_elem_size(nd_name_off[iter_], nd_name_len[iter_])
    if es != 0:
        # Local array: count = reserved_bytes / elem, but we don't track the
        # local count directly; the for-array form is driven by the global
        # path in this subset. Fall through to the global lookup if no count.
        gi0: uint32 = glob_lookup(nd_name_off[iter_], nd_name_len[iter_])
        if gi0 != 0 and glob_type_node[gi0 - 1] != 0:
            tn0: uint32 = glob_type_node[gi0 - 1]
            if nd_kind[tn0] == ND_ARRAY_TYPE:
                out_n[0] = cast[uint32](nd_num[tn0])
                return es
        return 0
    gi: uint32 = glob_lookup(nd_name_off[iter_], nd_name_len[iter_])
    if gi != 0 and glob_elem_size[gi - 1] != 0 and glob_type_node[gi - 1] != 0:
        tn: uint32 = glob_type_node[gi - 1]
        if nd_kind[tn] == ND_ARRAY_TYPE:
            out_n[0] = cast[uint32](nd_num[tn])
            return glob_elem_size[gi - 1]
    return 0


# Reserve a hidden 8-byte index slot for a for-array loop node, recording
# its frame offset keyed by the node id. Called from the prescan pass.
def for_idx_reserve(node: uint32):
    if fi_count >= MAX_FOR_IDX:
        cg_fail(6, node)
        return
    # Reserve an anonymous 8-byte slot (name off/len 0 → never name-matched).
    if loc_count >= MAX_LOCALS:
        cg_fail(6, node)
        return
    cg_stack_size = cg_stack_size + 8
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = 0
    loc_name_len[loc_count] = 0
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 1
    loc_scalar_size[loc_count] = 0
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_count = loc_count + 1
    fi_node[fi_count] = node
    fi_offset[fi_count] = off
    fi_count = fi_count + 1


# Recover a for-array loop's hidden index slot offset by its node id.
def for_idx_offset(node: uint32) -> int32:
    i: uint32 = 0
    while i < fi_count:
        if fi_node[i] == node:
            return fi_offset[i]
        i = i + 1
    cg_fail(9, node)
    return 0


# for-loop dispatch: range(...) counter loop or fixed-size array loop.
def gen_for(node: uint32):
    iter_: uint32 = nd_a[node]
    if is_range_call(iter_) != 0:
        gen_for_range(node)
        return
    n: uint32 = 0
    es: uint32 = for_array_info(iter_, &n)
    if es != 0:
        # The hidden index counter was reserved in prescan as
        # "<var>#idx"-shaped; look it up. We reserve it adjacent to the loop
        # var in prescan_for, recorded via for_idx lookup by the loop node.
        idx_off: int32 = for_idx_offset(node)
        gen_for_array(node, n, idx_off, es)
        return
    cg_fail(2, node)


# -----------------------------------------------------------------------
# Pre-scan: reserve a frame slot for each named local before the prologue.
# -----------------------------------------------------------------------

# Ensure a slot exists for `name`; allocate one if not already present.
# A name that is a known module-level global is NOT given a frame slot —
# its storage lives in the data section.
def prescan_name(name_off: uint32, name_len: uint32):
    if glob_lookup(name_off, name_len) != 0:
        return
    off: int32 = 0
    if lookup_local(name_off, name_len, &off) == 0:
        alloc_local(name_off, name_len)


def prescan_block(head: uint32):
    s: uint32 = head
    while s != 0:
        k: uint32 = nd_kind[s]
        if k == ND_VAR_DECL:
            declare_local(nd_name_off[s], nd_name_len[s], nd_a[s])
        elif k == ND_ASSIGN:
            tgt: uint32 = nd_a[s]
            if nd_kind[tgt] == ND_IDENT:
                prescan_name(nd_name_off[tgt], nd_name_len[tgt])
            # ND_INDEX targets address an already-declared array; no slot.
        elif k == ND_IF:
            prescan_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                prescan_block(nd_b[e])
                e = nd_next[e]
            prescan_block(nd_d[s])
        elif k == ND_WHILE:
            prescan_block(nd_b[s])
        elif k == ND_DO_WHILE:
            prescan_block(nd_b[s])
        elif k == ND_FOR:
            # Reserve the induction variable. For a range loop it is an int64
            # signed counter; for an array loop it is a private copy of the
            # element type. Mirrors codegen_x86's alloc_local for the loop var.
            iter_: uint32 = nd_a[s]
            if is_range_call(iter_) != 0:
                # Annotated-type-less counter: an int64 signed scalar.
                off2: int32 = 0
                if lookup_local(nd_name_off[s], nd_name_len[s], &off2) == 0:
                    alloc_local(nd_name_off[s], nd_name_len[s])
                    loc_set_signedness(2)        # int64 signed
            else:
                n0: uint32 = 0
                es0: uint32 = for_array_info(iter_, &n0)
                # Hidden index slot FIRST (matches codegen_x86 alloc order:
                # idx_var before loop_var), then the loop var as a sized
                # scalar of the element width.
                for_idx_reserve(s)
                off3: int32 = 0
                if lookup_local(nd_name_off[s], nd_name_len[s], &off3) == 0:
                    alloc_local(nd_name_off[s], nd_name_len[s])
                    if es0 != 0 and es0 < 8:
                        loc_set_scalar_size(es0)
            prescan_block(nd_b[s])
        s = nd_next[s]


# -----------------------------------------------------------------------
# Function codegen — emits a full prologue / body / epilogue. Returns the
# byte offset in code[] where this function's machine code begins.
# -----------------------------------------------------------------------

def gen_function(fn: uint32) -> uint32:
    start: uint32 = code_len

    # Register this function's symbol so calls (forward or backward) can
    # be resolved against its entry offset after all functions are emitted.
    fn_define(nd_name_off[fn], nd_name_len[fn], start)

    # Fresh per-function slot table.
    loc_count = 0
    cg_stack_size = 0
    fi_count = 0
    cg_self_struct = 0          # a plain function has no `self` receiver

    # Reject a by-value struct RETURN type (ND_FUNCTION's return type is on
    # nd_b). Same rule as params: aggregates leave a function through a
    # Ptr[T] out-parameter, never by value. Lockstep with the seed.
    if struct_lookup_by_node(nd_b[fn]) != 0:
        cg_fail(9, fn)              # by-value struct return: unsupported
        return start

    # Allocate a slot per parameter (param chain on nd_a, count in nd_aux).
    p: uint32 = nd_a[fn]
    nparams: uint32 = 0
    while p != 0:
        # A Ptr[T] parameter spills like any 8-byte scalar (the arg register
        # holds the pointer value), but we record its pointee width so the
        # body's p[i] indexing dereferences with the right element size.
        ptnode: uint32 = nd_a[p]
        # Reject a by-value struct parameter (a bare class-named type, NOT a
        # Ptr[Class]). Adder has no by-value aggregate ABI: aggregates cross
        # function boundaries through Ptr[T] (the caller passes &obj). The
        # seed (codegen_x86) raises the same error; this keeps the backends
        # in lockstep instead of silently spilling one register's worth and
        # reading the rest as stack garbage.
        if struct_lookup_by_node(ptnode) != 0:
            cg_fail(9, p)            # by-value struct param: unsupported
            return start
        psz: uint32 = ptr_pointee_size(ptnode)
        if psz != 0:
            alloc_ptr_local(nd_name_off[p], nd_name_len[p], psz)
        else:
            alloc_local(nd_name_off[p], nd_name_len[p])
            loc_set_signedness(type_signedness(ptnode))
            psz_d: uint32 = prim_type_size(ptnode)
            if type_signedness(ptnode) != 0 and psz_d < 8:
                loc_set_scalar_size(psz_d)
        nparams = nparams + 1
        p = nd_next[p]

    # Pre-scan the body and reserve a slot for every local (VAR_DECL or
    # first assignment to a new name), recursing into if/elif/else/while
    # bodies. This must happen BEFORE the frame reservation below, because
    # `sub $frame,%rsp` needs the final cg_stack_size; allocating slots
    # lazily during body emission would place them past the reserved frame
    # and corrupt the stack. (codegen_x86 does the same pre-scan pass.)
    prescan_block(nd_c[fn])

    # Prologue.
    emit_endbr64()
    emit_push_rbp()
    emit_mov_rsp_rbp()

    # 16-byte-aligned frame reservation (matches codegen_x86's
    # (stack_size + 15) & ~15). Skip the subq entirely when zero.
    frame: uint32 = (cg_stack_size + 15) & cast[uint32](0xFFFFFFF0)
    if frame > 0:
        emit_sub_rsp(frame)

    # Spill parameters from their arg registers into the stack slots.
    p2: uint32 = nd_a[fn]
    idx: uint32 = 0
    while p2 != 0:
        emit_spill_arg(idx, loc_offset[idx])
        idx = idx + 1
        p2 = nd_next[p2]

    # Body (statement chain on nd_c).
    s: uint32 = nd_c[fn]
    last_was_return: uint32 = 0
    while s != 0:
        gen_stmt(s)
        if nd_kind[s] == ND_RETURN:
            last_was_return = 1
        else:
            last_was_return = 0
        s = nd_next[s]

    # Fallthrough epilogue when the body did not end in a return (mirrors
    # codegen_x86's `if not last_is_return: leave; ret`).
    if last_was_return == 0:
        emit_leave()
        emit_ret()

    return start


# Emit a class method `def m(self, ...)` as a free function with mangled
# identity (owner class `cls`, method `m`). Mirrors codegen_x86.gen_method:
# the only difference from a plain function is the implicit `self: Ptr[Class]`
# first parameter (the parser marks it nd_aux==1, name empty) — its slot
# holds the receiver address, and `self.field` resolves against `cls`'s
# struct layout via cg_self_struct/cg_self_off.
def gen_method(cls: uint32, m: uint32) -> uint32:
    start: uint32 = code_len
    # Register the mangled (owner class, method) symbol for call resolution.
    mfn_define(nd_name_off[cls], nd_name_len[cls], nd_name_off[m], nd_name_len[m], start)

    loc_count = 0
    cg_stack_size = 0
    fi_count = 0

    sidx1: uint32 = struct_lookup(nd_name_off[cls], nd_name_len[cls])
    cg_self_struct = sidx1

    # Allocate a slot per parameter. The first param is `self` (nd_aux==1):
    # an 8-byte slot holding the receiver address (a Ptr[Class]).
    p: uint32 = nd_a[m]
    nparams: uint32 = 0
    first_param: uint32 = 1
    while p != 0:
        if first_param != 0 and nd_aux[p] == 1:
            # self: an 8-byte address slot. Record its offset for body access.
            cg_self_off = alloc_ptr_local(0, 0, 0)
        else:
            ptnode: uint32 = nd_a[p]
            psz: uint32 = ptr_pointee_size(ptnode)
            if psz != 0:
                psidx: uint32 = ptr_struct_idx(ptnode)
                alloc_ptr_local(nd_name_off[p], nd_name_len[p], psz)
                if psidx != 0:
                    loc_set_struct_ptr(psidx)
            else:
                alloc_local(nd_name_off[p], nd_name_len[p])
                loc_set_signedness(type_signedness(ptnode))
                psz_d: uint32 = prim_type_size(ptnode)
                if type_signedness(ptnode) != 0 and psz_d < 8:
                    loc_set_scalar_size(psz_d)
        first_param = 0
        nparams = nparams + 1
        p = nd_next[p]

    prescan_block(nd_c[m])

    emit_endbr64()
    emit_push_rbp()
    emit_mov_rsp_rbp()
    frame: uint32 = (cg_stack_size + 15) & cast[uint32](0xFFFFFFF0)
    if frame > 0:
        emit_sub_rsp(frame)

    # Spill parameters (self included) from arg registers into their slots.
    p2: uint32 = nd_a[m]
    idx: uint32 = 0
    while p2 != 0:
        emit_spill_arg(idx, loc_offset[idx])
        idx = idx + 1
        p2 = nd_next[p2]

    s: uint32 = nd_c[m]
    last_was_return: uint32 = 0
    while s != 0:
        gen_stmt(s)
        if nd_kind[s] == ND_RETURN:
            last_was_return = 1
        else:
            last_was_return = 0
        s = nd_next[s]
    if last_was_return == 0:
        emit_leave()
        emit_ret()

    cg_self_struct = 0
    return start


# Emit every method of every class in the program. Each ND_CLASS carries its
# method chain on nd_b (ND_FUNCTION nodes). Mirrors codegen_x86's
# `case ClassDef(): for m in decl.methods: self.gen_method(decl, m)`.
def gen_class_methods(prog: uint32):
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_CLASS:
            m: uint32 = nd_b[cur]
            while m != 0:
                gen_method(cur, m)
                m = nd_next[m]
        cur = nd_next[cur]


# Generate code for the first function found in a parsed program. The
# program node has its declaration chain on nd_b; we walk to the first
# ND_FUNCTION and emit it. Returns that function's code start offset.
# -----------------------------------------------------------------------
# Module-level (global) variable layout.
#
# A top-level ND_VAR_DECL is a global. We reserve a data slot for it and,
# for a constant initialiser we can resolve at layout time (an int literal
# for a scalar, or a string literal for a `name: Array[N, uint8] = "..."`
# global), write the initial bytes straight into gdata[]. Scalars with no
# initialiser are zeroed (.bss-style). Non-constant initialisers are out
# of this subset (codegen_x86 emits _init_* runtime fill there).
# -----------------------------------------------------------------------

# Lay out one module-level ND_VAR_DECL into the data section.
def layout_global(decl: uint32):
    tnode: uint32 = nd_a[decl]
    val: uint32 = nd_b[decl]
    if tnode != 0 and nd_kind[tnode] == ND_ARRAY_TYPE:
        # The INNERMOST scalar element width (the load/store size at the
        # deepest index). For a 1-D array this is just the element type's
        # size; for a nested array `Array[N, Array[M, T]]` we walk past every
        # ND_ARRAY_TYPE level to T and size that. This is the width
        # glob_elem_size carries (used by a fully-indexed access).
        inner_t: uint32 = nd_a[tnode]
        while nd_kind[inner_t] == ND_ARRAY_TYPE:
            inner_t = nd_a[inner_t]
        es: uint32 = prim_type_size(inner_t)
        # String-initialised byte array: place the literal's NUL-terminated
        # bytes and register the global at that data offset (mirrors
        # codegen_x86's string-literal global path). Only a 1-D uint8 array.
        if val != 0 and nd_kind[val] == ND_STRING_LIT and es == 1 and nd_kind[nd_a[tnode]] != ND_ARRAY_TYPE:
            doff: uint32 = intern_string(nd_name_off[val], nd_name_len[val])
            glob_define(nd_name_off[decl], nd_name_len[decl], doff, es, 0)
            glob_set_type_node(tnode)
            return
        # Zero-init array → .bss: reserve VIRTUAL space only (no file bytes,
        # no gdata[] writes). This is the crux of the BSS model: an array
        # global as big as GDATA_CAP itself no longer needs to be stored.
        # Total bytes is the FULL (possibly nested) array size, so a 2-D
        # global reserves N*M*sizeof(T) — exactly codegen_x86.get_type_size.
        bytes_: uint32 = type_size_of(tnode)
        bbase: uint32 = bss_reserve(bytes_)
        glob_define(nd_name_off[decl], nd_name_len[decl], bbase, es, 0)
        glob_set_bss()
        # Carry the full type so nested indexing can scale the outer index by
        # the row stride (codegen_x86 keeps the whole ArrayType for this).
        glob_set_type_node(tnode)
        return
    # Ptr[T] global: an 8-byte scalar slot that holds an address. A non-zero
    # constant int initialiser goes in .data (stored); `= 0` or no init is
    # all-zero → .bss (virtual only). Either way mark the pointee width so
    # indexing (g[i]) dereferences with the right element size.
    psz: uint32 = ptr_pointee_size(tnode)
    if psz != 0:
        if val != 0 and nd_kind[val] == ND_INT_LIT and nd_num[val] != 0:
            pbase: uint32 = gdata_reserve(8)
            glob_define(nd_name_off[decl], nd_name_len[decl], pbase, 0, 8)
            glob_set_ptr_size(psz)
            pv: uint64 = nd_num[val]
            pi: uint32 = 0
            while pi < 8:
                gdata[pbase + pi] = cast[uint8](pv & 255)
                pv = pv >> 8
                pi = pi + 1
        else:
            pbss: uint32 = bss_reserve(8)
            glob_define(nd_name_off[decl], nd_name_len[decl], pbss, 0, 8)
            glob_set_ptr_size(psz)
            glob_set_bss()
        return
    # Struct-typed global: an in-place struct value. Zero-init → .bss,
    # reserving the struct's full total_size bytes (no file storage). A
    # struct global has no scalar/constant initialiser in this subset.
    gsi: uint32 = struct_lookup_by_node(tnode)
    if gsi != 0:
        gbytes: uint32 = st_total[gsi - 1]
        gbase: uint32 = bss_reserve(gbytes)
        glob_define(nd_name_off[decl], nd_name_len[decl], gbase, 0, 0)
        glob_set_bss()
        glob_set_struct(gsi)
        return
    # Scalar global. A non-zero constant int initialiser goes in .data
    # (stored, little-endian); `= 0` or no initialiser is all-zero → .bss
    # (virtual address space only, no file storage).
    sz: uint32 = prim_type_size(tnode)
    # A sub-8-byte SIGNED scalar (int8/int16/int32) must sign-extend on load.
    sgn: uint32 = 0
    if sz < 8 and type_is_unsigned(tnode) == 0:
        sgn = 1
    gfw: uint32 = type_float_width(tnode)   # 0/4/8: float global float width
    if val != 0 and nd_kind[val] == ND_INT_LIT and nd_num[val] != 0:
        base: uint32 = gdata_reserve(sz)
        glob_define(nd_name_off[decl], nd_name_len[decl], base, 0, sz)
        if sgn != 0:
            glob_set_signed()
        if gfw != 0:
            glob_set_float(gfw)
        v: uint64 = nd_num[val]
        i: uint32 = 0
        while i < sz:
            gdata[base + i] = cast[uint8](v & 255)
            v = v >> 8
            i = i + 1
    else:
        sbss: uint32 = bss_reserve(sz)
        glob_define(nd_name_off[decl], nd_name_len[decl], sbss, 0, sz)
        glob_set_bss()
        if sgn != 0:
            glob_set_signed()
        if gfw != 0:
            glob_set_float(gfw)


# Walk the program's declaration chain and lay out every module-level
# global BEFORE any function is emitted, so global references resolve
# against a stable data offset.
def layout_globals(prog: uint32):
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_VAR_DECL:
            layout_global(cur)
        cur = nd_next[cur]


def gen_program_first_function(prog: uint32) -> uint32:
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            return gen_function(cur)
        cur = nd_next[cur]
    cg_fail(9, 0)
    return 0


# Generate code for EVERY function in a parsed program, back-to-back, then
# resolve all inter-function `call` fixups. Returns the code start offset
# of the first function (0 on an empty program). This is the entry point
# for programs that contain calls between functions.
def gen_program_all_functions(prog: uint32) -> uint32:
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    first: uint32 = 0
    seen: uint32 = 0
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            off: uint32 = gen_function(cur)
            if seen == 0:
                first = off
                seen = 1
        cur = nd_next[cur]
    if seen == 0:
        cg_fail(9, 0)
        return 0
    link_runtime_externs()
    resolve_calls()
    resolve_entry(first)
    return first


# Full-program entry point WITH module-level globals + string literals.
# Lays out every global into the data section first (so references resolve
# against stable offsets), emits every function back-to-back, then resolves
# both inter-function call fixups and RIP-relative data fixups. Returns the
# first function's code start offset. This is the entry point a real
# self-hosting build (lexer/parser holding state in globals) needs.
def gen_program_with_globals(prog: uint32) -> uint32:
    # Stash the decl chain so class layout can resolve inheritance bases by
    # name, then lay out every class BEFORE globals (a struct-typed global
    # needs its struct total_size) and before any function/method emission.
    cg_prog_decls = nd_b[prog]
    layout_classes(prog)
    layout_globals(prog)
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    first: uint32 = 0
    seen: uint32 = 0
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            off: uint32 = gen_function(cur)
            if seen == 0:
                first = off
                seen = 1
        cur = nd_next[cur]
    # Emit every class method as a free function (after the plain functions so
    # `first`/entry resolution stays anchored on a real `main`).
    gen_class_methods(prog)
    if seen == 0:
        cg_fail(9, 0)
        return 0
    link_runtime_externs()
    resolve_calls()
    resolve_method_calls()
    resolve_data_fixups()
    resolve_entry(first)
    return first

# Phase-4 register allocator (linear scan). OFF by default: ra_reg_for_name
# returns RA_NONE unless ra_enable() was called (only the dump driver's --opt
# path does that), so with the flag off every hook below is inert and codegen
# output is byte-identical to the pre-regalloc path.
from compiler.regalloc import (
    ra_is_enabled,
    ra_build_for_function,
    ra_reg_for_name,
    ra_pool_used,
    ra_pool_encoding,
    ra_nregs,
    ra_pool_all_dead_after,
    RA_NONE,
)

# cfg live-range queries for the IR-scratch BORROW path: lr_stmt_point maps the
# in-flight statement node to its program point; lr_name_dead_after tells whether
# a regalloc-promoted local is already past its last use there (so its callee-
# saved register can be lent as a transient IR scratch). Pure reads of the
# per-function ranges regalloc already built; only consulted under --opt.
from compiler.cfg import (
    lr_stmt_point,
)

# Phase-5 IR-CONSUMING emit path. OFF by default: ir_emit_is_enabled() returns 0
# unless the dump driver armed it under --opt. When armed, gen_expr lowers a pure
# signedness-invariant arithmetic subtree to the value IR (ir_lower_pure_expr) and
# emits machine code by walking the IR TREE (gen_expr_ir below) — with on-the-IR
# constant folding — instead of the AST, falling back to the AST emitter for any
# subtree it cannot lower. With the flag off this is never entered and codegen
# output is byte-identical to the pre-IR path. See ir.ad Phase 5 header.
from compiler.ir import (
    ir_reset,
    ir_lower_pure_expr,
    ir_emit_is_enabled,
    ir_emit_in_progress,
    ir_emit_enter,
    ir_emit_leave,
    ir_emit_count,
    ir_emit_fold_count,
    ir_emit_fallback_count,
    ir_emit_float_count,
    ir_binop_new,
    ir_leaf_new,
    ir_op_is_float_emittable,
    ir_tree_is_const,
    ir_tree_const_val,
    ir_add_const_sum,
    ir_add_const_count,
    ir_op_is_emit_only,
    ir_kind,
    ir_op,
    ir_a,
    ir_b,
    ir_const,
    ir_ast,
    IR_CONST,
    IR_IDENT,
    IR_LEAF,
    IR_BINOP,
)

# -----------------------------------------------------------------------
# Strength reduction (div/mod by a compile-time constant). OFF by default:
# sr_is_enabled() returns 0 unless the dump driver armed it under --opt
# (sr_enable()). When OFF, gen_div_const_try always returns 0, so the div/mod
# code path is the byte-identical pre-existing cqo+idiv / div sequence. When ON,
# a `/`, `//` or `%` whose RIGHT operand is a literal integer constant is
# lowered to a reciprocal-multiply / shift sequence (Granlund-Montgomery,
# "Division by Invariant Integers using Multiplication", PLDI'94; derivation per
# Warren, Hacker's Delight 2nd ed. ch.10). Correctness is differentially gated by
# the ADDER_OPT=1 fuzzer lane + scripts/test_opt_strengthred.sh.
# -----------------------------------------------------------------------
sr_enabled: uint32 = 0
opt_strengthred_count: uint32 = 0


def sr_enable():
    sr_enabled = 1


def sr_is_enabled() -> uint32:
    return sr_enabled


def sr_reset_stats():
    opt_strengthred_count = 0


# -----------------------------------------------------------------------
# Instruction selection (--opt, Phase 3). OFF by default: isel_is_enabled()
# returns 0 unless the dump driver armed it under --opt (isel_enable()). When
# OFF, gen_index_addr emits the byte-identical pre-existing
# scale-rcx + lea-base + add-rcx sequence. When ON, the scale-shift + separate
# base-lea + add tail of an array/pointer element-address computation is folded
# into a single `lea` using x86 scaled-index (SIB) addressing for the scales
# the CPU supports natively (1/2/4/8):
#   * local array   `a[i]`  -> lea disp(%rbp, %rcx, s), %rax   (3 insns -> 1)
#   * global array  `g[i]`  -> lea (%rax, %rcx, s), %rax       (after the rip
#                              base-lea; folds the shl+add into 1 lea)
#   * pointer/scalar base    -> lea (%rax, %rcx, s), %rax       (after loading
#                              the held pointer value into %rax)
# The computed ELEMENT ADDRESS is bit-identical to the stack-machine form; only
# the instruction selection changes. Correctness is differentially gated by the
# ADDER_OPT=1 fuzzer lane (array/pointer/memory-ALU shapes) + scripts/
# test_opt_isel.sh. Non-power-of-2 strides (multi-dim row blocks) keep the
# imul+add path — SIB cannot express them.
# -----------------------------------------------------------------------
isel_enabled: uint32 = 0
opt_isel_count: uint32 = 0
# ALU-LOAD memory-source operand folds (--opt, Phase-3 instruction selection):
# `left OP arr[i]` where arr[i] is an 8-byte integer array element is emitted
# as `op (%rcx),%rax` sourcing the element in-place, instead of a separate
# load-to-temp + reg-reg combine. Armed by the same isel_enable() under --opt
# (OFF by default -> byte-identical to the seed). Counts each fired fold.
opt_aluload_count: uint32 = 0


def isel_enable():
    isel_enabled = 1


def isel_is_enabled() -> uint32:
    return isel_enabled


def isel_reset_stats():
    opt_isel_count = 0
    opt_aluload_count = 0


# True for the element strides x86 SIB scale can express directly (1/2/4/8).
def isel_scale_ok(es: uint32) -> uint32:
    if es == 1:
        return 1
    if es == 2:
        return 1
    if es == 4:
        return 1
    if es == 8:
        return 1
    return 0


# Map an element size 1/2/4/8 to the SIB scale field bits (00/01/10/11).
def isel_scale_bits(es: uint32) -> uint32:
    if es == 2:
        return 1
    if es == 4:
        return 2
    if es == 8:
        return 3
    return 0                              # es == 1


# -----------------------------------------------------------------------
# Output buffer: flat machine-code bytes.
# -----------------------------------------------------------------------

# Code window. Sized to hold the WHOLE compiler's emitted code for the
# self-host fixpoint with generous headroom (2 MiB; whole-compiler code is
# ~104 KiB today). BSS-backed (zero-init), so the bytes cost nothing in the
# emitted file — only memsz. DATA_BASE MUST stay == CODE_CAP.
CODE_CAP: uint32 = 2097152
code: Array[2097152, uint8]
code_len: uint32 = 0

# Codegen error flag (set on overflow / unsupported node).
cg_err: uint32 = 0

# Resolved ENTRY function code offset (set by gen_program_*). The program's
# entry is resolved BY NAME ("main"), falling back to the first emitted
# function if no `main` exists. elf_emit.ad's _start stub `call`s THIS
# offset (not literal 0), so the entry function need not be source-first.
# Sentinel 0xFFFFFFFF means "unresolved" (no functions emitted).
CG_ENTRY_NONE: uint32 = 4294967295
cg_entry_off: uint32 = 0

# Diagnostic: WHY codegen failed (set the first time cg_err goes 1 via
# cg_fail). Lets the on-device driver report a precise blocker instead of a
# bare "codegen error". Reason codes:
#   1 = unsupported expression node      2 = unsupported statement node
#   3 = CODE_CAP overflow (code too big) 4 = GDATA_CAP overflow (.data)
#   5 = call/data/string fixup table full
#   6 = MAX_FUNCS/MAX_GLOBALS/MAX_LOCALS table full
#   7 = unresolved call (unknown callee) 8 = unknown name / type query
#   9 = other / uncategorised           10 = disp8 frame overflow (a
#       function's locals exceed the -128 disp8 reach)
#   11 = unsupported inline asm (asm_volatile line/operand not in the
#       bounded kernel instruction set this emitter assembles)
cg_err_reason: uint32 = 0
cg_err_node: uint32 = 0     # offending AST node id (for nd_line lookup)


# Record the first codegen failure with a reason code + offending node.
# Idempotent on reason (keeps the FIRST cause); always sets cg_err.
def cg_fail(reason: uint32, node: uint32):
    if cg_err == 0:
        cg_err_reason = reason
        cg_err_node = node
    cg_err = 1


# Source line of the codegen-failure node (0 if none / unknown). Lets the
# driver point at the offending construct in the input.
def cg_err_line() -> uint32:
    if cg_err_node == 0:
        return 0
    return nd_line[cg_err_node]


# AST kind of the codegen-failure node (0 if none). Helps disambiguate
# reason-1/2 "unsupported node" diagnostics on device.
def cg_err_kind() -> uint32:
    if cg_err_node == 0:
        return 0
    return nd_kind[cg_err_node]

# -----------------------------------------------------------------------
# Per-function local/parameter slot table.
#
# Mirrors FunctionContext.alloc_local in codegen_x86.py: each slot is
# 8-byte-rounded and laid out at a negative %rbp offset. We map a slot to
# the parameter's strbuf name reference (off/len), so identifier loads can
# resolve a name back to its frame offset by string comparison.
# -----------------------------------------------------------------------

MAX_LOCALS: uint32 = 256

loc_name_off: Array[256, uint32]
loc_name_len: Array[256, uint32]
loc_offset: Array[256, int32]      # negative %rbp-relative byte offset (BASE)
# Per-local element size: 0 means a plain 8-byte scalar slot; a non-zero
# value (1/2/4/8) marks an Array local whose elements are that many bytes
# wide. loc_offset is then the address of element 0 (the lowest address of
# the reserved block); arr[i] lives at rbp + loc_offset + i*elem_size.
loc_elem_size: Array[256, uint32]
# Per-local pointer marker: 0 means the local is NOT a Ptr[T]; a non-zero
# value (1/2/4/8) marks a Ptr[T] local/param whose slot HOLDS an address
# and whose pointee width is that many bytes. Unlike an Array local (where
# loc_offset is element 0's address), a pointer local's slot stores the
# target address; p[i] dereferences *(slot_value + i*pointee_size). This
# mirrors codegen_x86.gen_index_address's `gen_expr(obj)` (load the pointer
# value) branch for non-Array bases.
loc_ptr_size: Array[256, uint32]
# Per-local SIGNEDNESS tristate for a scalar int local/param, used to mirror
# codegen_x86's get_expr_type()/_is_unsigned_type() when picking signed vs
# unsigned setcc (compares) and div/mod instructions:
#   0 = unknown (untyped / not an int scalar) -> contributes no signedness
#   1 = unsigned int (uint8/16/32/64, bool, char, pointer, array)
#   2 = signed int   (int8/16/32/64)
# Set by alloc helpers from the declared type. Array/pointer locals are
# treated as unsigned (matching _is_unsigned_type's True for those).
loc_is_signed: Array[256, uint32]
# Per-local SCALAR width (1/2/4/8) for a plain scalar int local/param, or 0
# when the local is not a sized scalar (an 8-byte slot of unknown/erased type,
# a pointer, or an array). When non-zero AND < 8, the local is stored with a
# SIZED store and LOADED with a sign/zero-extending move (per loc_is_signed),
# exactly like codegen_x86's _emit_local_store / _emit_local_load. This is
# what makes a widening read of a typed sub-8-byte local (e.g. cast[int64](l)
# where l is int16) see the truncated+extended value, not stale upper bits.
loc_scalar_size: Array[256, uint32]
# Per-local FLOAT WIDTH (0 = not a float scalar, 4 = float32, 8 = float64).
# Distinguishes a float32 local (scalar_size 4) from an int32 local (also
# scalar_size 4) so identifier operands route to the SSE path. Mirrors
# codegen_x86._float_width(get_expr_type(ident)).
loc_is_float: Array[256, uint32]
# Per-local struct typing, for member access (obj.field) on a local:
#   loc_struct_idx  = struct-table index + 1 (0 = not a struct-typed local).
#                     Non-zero for BOTH an in-place struct local (slot IS the
#                     struct storage; member address = &slot + field_offset)
#                     AND a Ptr[Struct] local/param (slot HOLDS an address;
#                     member address = (loaded ptr value) + field_offset).
#   loc_struct_is_ptr = 1 when the local is a Ptr[Struct] (the `self` param
#                     case), 0 for an in-place struct value. Mirrors
#                     codegen_x86._obj_is_pointer.
loc_struct_idx: Array[256, uint32]
loc_struct_is_ptr: Array[256, uint32]
# Per-local ARRAY TYPE NODE (the ND_ARRAY_TYPE from the decl) for an array
# local, mirroring glob_type_node — so a MULTI-DIMENSIONAL array local
# `Array[N, Array[M, T]]` is indexed level by level (the outer index scales by
# the row stride). 0 for non-array locals / 1-D where loc_elem_size suffices.
loc_type_node: Array[256, uint32]
loc_count: uint32 = 0
cg_stack_size: uint32 = 0

# -----------------------------------------------------------------------
# Function symbol table + call-fixup list.
#
# Each emitted function records its name (strbuf off/len) and its start
# offset in code[]. A `call` to a function whose body has not been emitted
# yet (forward reference, or any call at all in a two-function program) is
# recorded as a fixup: the rel32 field offset plus the callee name. After
# every function is emitted, resolve_calls() patches each fixup against the
# symbol table. This mirrors how codegen_x86.py defers symbol resolution to
# the assembler — we just do that resolution ourselves over raw bytes.
# -----------------------------------------------------------------------

MAX_FUNCS: uint32 = 1024
fn_name_off: Array[1024, uint32]
fn_name_len: Array[1024, uint32]
fn_offset: Array[1024, uint32]
fn_count: uint32 = 0

# -----------------------------------------------------------------------
# KERNEL TARGET (x86_64-bare-metal) — relocatable-object emission.
#
# The user/linux target is a CLOSED-WORLD self-contained ELF: every call
# and data ref is resolved IN-IMAGE (resolve_calls / resolve_data_fixups
# bake absolute disp32s against DATA_BASE). The kernel target instead emits
# a relocatable ET_REL object whose cross-object symbols (extern funcs in
# irq_asm.S/head_64.S, memset/memcpy/read_cr3, …) are left UNDEF and
# resolved by `ld -T kernel.lds` against the hand-written .S objects, EXACTLY
# as the Python seed's assemble_and_link_x86_bare does. When cg_target_kernel
# is set:
#   * `&extern_sym` / `call extern_sym` record an EXTERN relocation rather
#     than failing (gen_addr_of, gen_call/resolve_calls).
#   * intra-object data refs become section-relative PC32 relocs (against the
#     .data/.text section symbol) rather than absolute DATA_BASE disp32s, so
#     `ld` patches them after placing each section at its kernel.lds VMA.
# The user path is UNCHANGED (flag defaults 0).
# -----------------------------------------------------------------------
cg_target_kernel: uint32 = 0

# Extern-symbol table: every `extern def NAME(...)` declared in the unit.
# An ND_IDENT that is neither a local nor a global is matched against this
# table; a hit is a cross-object symbol resolved by `ld`. Populated by
# collect_externs() before codegen.
MAX_EXTERNS: uint32 = 1024
ext_name_off: Array[1024, uint32]
ext_name_len: Array[1024, uint32]
ext_count: uint32 = 0

# Extern relocation list. Each entry records a rel32/abs field in code[] that
# must be patched by `ld` against extern symbol `er_sym_idx` (an index into
# the ext_* table). er_type: 0 = R_X86_64_PC32 (leaq sym(%rip) addend -4),
# 1 = R_X86_64_PLT32 (call sym, addend -4). The relocation's r_offset is the
# code[] field byte offset (== .text section offset, since .text == code[]).
MAX_EXTERN_RELOCS: uint32 = 8192
er_at: Array[8192, uint32]
er_sym_idx: Array[8192, uint32]
er_type: Array[8192, uint32]
er_count: uint32 = 0

ER_PC32: uint32 = 0
ER_PLT32: uint32 = 1


# Append one extern relocation (kernel target only).
def add_extern_reloc(at: uint32, sym_idx: uint32, rtype: uint32):
    if er_count >= MAX_EXTERN_RELOCS:
        cg_fail(5, 0)
        return
    er_at[er_count] = at
    er_sym_idx[er_count] = sym_idx
    er_type[er_count] = rtype
    er_count = er_count + 1


# Look up an extern symbol by strbuf name slice. Returns ext index + 1, or 0.
def ext_lookup(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < ext_count:
        if name_match(ext_name_off[i], ext_name_len[i], name_off, name_len) != 0:
            return i + 1
        i = i + 1
    return 0


# Intern a referenced symbol NAME into the ext_* table (the unified relocation
# symbol pool). Returns the 0-based index. Used for a relocation target whose
# name may resolve, at symtab-emit time, to EITHER an in-unit DEFINED function
# (&syscall_entry, call start_kernel) OR a true cross-object UNDEF (memset,
# read_cr3). The symtab pass (elf_emit) classifies each by whether an Adder
# function of that name was emitted. Idempotent (dedups by name).
def ext_intern(name_off: uint32, name_len: uint32) -> uint32:
    e: uint32 = ext_lookup(name_off, name_len)
    if e != 0:
        return e - 1
    if ext_count >= MAX_EXTERNS:
        cg_fail(6, 0)
        return 0
    ext_name_off[ext_count] = name_off
    ext_name_len[ext_count] = name_len
    ext_count = ext_count + 1
    return ext_count - 1


# Pre-pass over the program's top-level decls: record every ND_EXTERN name in
# the ext_* table so gen_addr_of / gen_call can recognise an extern reference.
# Mirrors layout_globals' decl walk. Only meaningful for the kernel target.
# True if the program's top-level decls define an ND_FUNCTION of this name.
# Used (kernel target) to recognise a bare function-name identifier used as a
# function-pointer value, mirroring the seed's defined_funcs membership test.
# cg_prog_decls is the decl chain (set by gen_program_with_globals).
def is_program_function(name_off: uint32, name_len: uint32) -> uint32:
    cur: uint32 = cg_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            if name_match(nd_name_off[cur], nd_name_len[cur], name_off, name_len) != 0:
                return 1
        cur = nd_next[cur]
    return 0


def collect_externs(prog: uint32):
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_EXTERN:
            if ext_count < MAX_EXTERNS:
                ext_name_off[ext_count] = nd_name_off[cur]
                ext_name_len[ext_count] = nd_name_len[cur]
                ext_count = ext_count + 1
            else:
                cg_fail(6, 0)
        cur = nd_next[cur]

MAX_FIXUPS: uint32 = 8192
fx_at: Array[8192, uint32]          # rel32 field offset in code[]
fx_name_off: Array[8192, uint32]
fx_name_len: Array[8192, uint32]
fx_count: uint32 = 0

# -----------------------------------------------------------------------
# Class-method symbol table + method-call fixup list.
#
# A class method `def m(self, ...)` is emitted as a free function whose
# mangled identity is the PAIR (owner-class name, method name) — exactly the
# `<Class>__<method>` symbol of codegen_x86._method_symbol, but represented
# here as two strbuf slices instead of a synthesised string (codegen.ad has
# no string-builder). `obj.m(args)` records a method-call fixup carrying the
# resolved (owner-class name, method name) pair; resolve_method_calls()
# patches each against this table after every method body is emitted.
# Owner resolution (for inheritance) is done at the call site, mirroring
# codegen_x86's class_methods table first-match-wins walk.
# -----------------------------------------------------------------------
MAX_METHODS: uint32 = 1024
mfn_cls_off: Array[1024, uint32]
mfn_cls_len: Array[1024, uint32]
mfn_m_off: Array[1024, uint32]
mfn_m_len: Array[1024, uint32]
mfn_offset: Array[1024, uint32]
mfn_count: uint32 = 0

MAX_METHOD_FIXUPS: uint32 = 8192
mfx_at: Array[8192, uint32]
mfx_cls_off: Array[8192, uint32]
mfx_cls_len: Array[8192, uint32]
mfx_m_off: Array[8192, uint32]
mfx_m_len: Array[8192, uint32]
mfx_count: uint32 = 0

# -----------------------------------------------------------------------
# Data section: module-level (global) storage + interned string literals.
#
# codegen_x86.py keeps globals in named `.data`/`.bss` symbols and string
# literals in `.rodata`, letting the assembler+linker resolve every
# reference as RIP-relative (R_X86_64_PC32). Emitting raw bytes ourselves
# we model BOTH the storage and the relocations:
#
#   * gdata[] — a flat byte buffer; every global scalar/array and every
#     interned string is laid out into it at a stable byte offset.
#   * The emulated/loaded address space places this data section at a
#     fixed base DATA_BASE (== CODE_CAP) immediately past the code window,
#     so an x86_64 RIP-relative `disp32 = DATA_BASE + g_off - rip_field_end`
#     reaches the global. (On the real device the loader maps code and
#     this data buffer into one image; DATA_BASE is the data buffer's
#     virtual offset from the code base.)
#   * Every global reference is a RIP-relative `lea` of the global's
#     ADDRESS into %rax; scalars then dereference with the existing sized
#     mem load/store, arrays compute &g[i] then a sized load/store — the
#     SAME lowering the local path uses, only the base register changes
#     from %rbp (frame) to %rip (data). This mirrors codegen_x86's scalar
#     `leaq name(%rip),%rax ; movq (%rax),%rax` and aggregate
#     `leaq name(%rip),%rax` decay.
#   * Because a global may be referenced before its data slot's final
#     position is fixed (and to keep one uniform resolution path), each
#     RIP-lea records a data fixup; resolve_data_fixups() patches the
#     rel32 after all functions are emitted, exactly like resolve_calls().
# -----------------------------------------------------------------------

GDATA_CAP: uint32 = 65536
gdata: Array[65536, uint8]
gdata_len: uint32 = 0

# .bss model: zero-initialised globals (uninitialised scalars, `= 0`
# scalars/pointers, and ALL zero-init arrays) reserve VIRTUAL ADDRESS
# SPACE only — they advance bss_len but consume NO bytes in gdata[] and
# NO file storage. The .bss region sits immediately AFTER the .data
# region in the loaded image, at virtual base DATA_BASE + gdata_len (the
# final gdata_len, known only after all emission). On device the ELF
# loader zeroes the whole p_memsz span before copying p_filesz bytes, so
# the .bss tail is already zero-filled. This is what makes self-compile
# tractable: the compiler's own ~650 KiB of zero-init globals cost memsz,
# not file bytes.
bss_len: uint32 = 0

# Data section base address in the emulated/loaded address space. Chosen
# == CODE_CAP so [0,CODE_CAP) is code, [DATA_BASE, DATA_BASE+gdata_len) is
# initialised data (.data, stored in file), and [DATA_BASE+gdata_len,
# DATA_BASE+gdata_len+bss_len) is zero-init data (.bss, NOT stored). A
# clean, non-overlapping split the emulator and loader can dispatch on.
# MUST stay == CODE_CAP (see CODE_CAP above).
DATA_BASE: uint32 = 2097152

# Global symbol table: name (strbuf ref) -> data offset, element size and
# slot byte-width. glob_elem_size is non-zero for an Array global (the
# per-element width; glob_offset is element 0's address); 0 marks a scalar
# whose load/store width is glob_scalar_size (1/2/4/8).
MAX_GLOBALS: uint32 = 1024
glob_name_off: Array[1024, uint32]
glob_name_len: Array[1024, uint32]
glob_offset: Array[1024, uint32]        # byte offset into gdata[] (.data) OR
                                        # bss[] (.bss) per glob_is_bss
glob_elem_size: Array[1024, uint32]     # 0 = scalar; else Array element width
glob_scalar_size: Array[1024, uint32]   # scalar load/store width (1/2/4/8)
# Per-global .bss marker: 1 if the global is zero-init and lives in the
# .bss region (glob_offset is then a bss offset, resolved at fixup time
# against the FINAL gdata_len); 0 if it is initialised .data (glob_offset
# is a gdata[] byte offset).
glob_is_bss: Array[1024, uint32]
# Per-global pointer marker, same convention as loc_ptr_size: 0 = not a
# Ptr[T] global; non-zero = the pointee width (1/2/4/8). A Ptr[T] global is
# stored as an 8-byte scalar slot that HOLDS an address (glob_scalar_size is
# 8 for it); glob_ptr_size records the pointee width used when the global is
# indexed (g[i]). e.g. `lex_src: Ptr[uint8]` -> glob_ptr_size 1.
glob_ptr_size: Array[1024, uint32]
# Per-global SIGNEDNESS of a sub-8-byte scalar global: 1 if the scalar is a
# SIGNED type (int8/int16/int32) and must SIGN-extend on load (movsXq), 0 if
# unsigned/8-byte/array (zero-extend / no extend). Mirrors codegen_x86's
# emit_load_sized_signed: a signed narrower scalar global sign-extends so its
# wider (uint64/int64) use carries the correct two's-complement value. Set by
# glob_set_signed() right after a scalar glob_define.
glob_is_signed: Array[1024, uint32]
# FULL scalar-global signedness tristate (0 unknown / 1 unsigned / 2 signed) of
# the global's declared type. Unlike glob_is_signed (a sub-8-byte load-extension
# flag, 0 for an 8-byte global), this distinguishes int64 from uint64, so
# expr_signedness picks the right signed/unsigned compare + div/mod + shift for
# an 8-byte global operand (e.g. `acc / operand` with int64 globals must be
# idiv/cqto, not div/xor).
glob_signedness: Array[1024, uint32]
# Per-global ARRAY TYPE NODE id (the ND_ARRAY_TYPE from the decl) for an
# array global, else 0. Carries the FULL (possibly nested) array type so a
# multi-dimensional global `Array[N, Array[M, T]]` can be indexed level by
# level: the outer index scales by the row stride (M*sizeof(T)) and the
# inner index scales by sizeof(T). Mirrors codegen_x86 carrying the whole
# ArrayType and recursing through element_type. 0 for scalars/pointers/1-D
# where the flat glob_elem_size already suffices (kept for back-compat).
glob_type_node: Array[1024, uint32]
# Per-global struct-table index (+1) for a struct-typed global (an in-place
# struct value in .bss/.data); 0 for non-struct globals. Member access on a
# global resolves the layout via this.
glob_struct_idx: Array[1024, uint32]
# Per-global FLOAT WIDTH (0 = not a float, 4 = float32, 8 = float64) for a
# scalar float global. Distinguishes a float32 global (scalar_size 4) from an
# int32 one. Mirrors codegen_x86._float_width(get_expr_type(ident)) for a
# global identifier.
glob_is_float: Array[1024, uint32]
# Per-global PERCPU marker (kernel target): 1 if the global was declared
# `Percpu[T]`. A percpu global lives in a separate `.data..percpu` template
# section (NOT .data/.bss) at glob_offset (a percpu-template byte offset), and
# its access lowers to `%gs:offset` (CPU-relative), mirroring codegen_x86's
# percpu_globals. cpu_id_pcpu is PINNED to percpu offset 0 (a hard ABI the
# hand-written .S `movq %gs:0` reads depend on — regression #402).
glob_is_percpu: Array[1024, uint32]
glob_count: uint32 = 0

# Per-CPU template byte size accumulated as Percpu[T] globals are laid out.
# Becomes __per_cpu_template_end - __per_cpu_template_start. Each percpu global
# reserves its scalar width here, at glob_offset = the running percpu offset.
percpu_len: uint32 = 0

# Data-section RIP-relative relocations. Each records the rel32 field's
# byte offset in code[] plus the target's data offset; resolve writes
# (DATA_BASE + data_off) - (at + 4).
MAX_DATA_FIXUPS: uint32 = 8192
df_at: Array[8192, uint32]              # rel32 field offset in code[]
df_data_off: Array[8192, uint32]       # target offset: into gdata[] (.data)
                                       # OR into .bss per df_is_bss
# Per-fixup .bss marker: 1 if the target is a .bss global (df_data_off is a
# bss offset, resolved against the FINAL gdata_len); 0 if it targets .data
# (or an interned string), where df_data_off is a gdata[] byte offset.
df_is_bss: Array[8192, uint32]
df_count: uint32 = 0

# Interned string-literal table: identical literals share one data slot,
# mirroring codegen_x86.add_string's dedup. Each entry records the strbuf
# source slice (off/len) and the data offset its NUL-terminated bytes were
# placed at.
MAX_STRINGS: uint32 = 2048
str_src_off: Array[2048, uint32]
str_src_len: Array[2048, uint32]
str_data_off: Array[2048, uint32]
str_count: uint32 = 0

# Float-constant pool: dedup an IEEE-754 constant (raw bit pattern + width)
# placed in the data section, mirroring codegen_x86's float_literals pool.
# fc_bits is the raw integer bit pattern (32- or 64-bit), fc_width the byte
# width, fc_data_off the gdata[] offset where the constant was emitted.
MAX_FLOAT_CONSTS: uint32 = 1024
fc_bits: Array[1024, uint64]
fc_width: Array[1024, uint32]
fc_data_off: Array[1024, uint32]
fc_count: uint32 = 0

# -----------------------------------------------------------------------
# Loop-label stack for break / continue.
#
# Each active `while` pushes one frame. `continue` jumps BACK to the loop's
# condition test (a known earlier offset = loop_cont_target). `break` jumps
# FORWARD to the loop exit, whose offset is not yet known when the break is
# emitted; each break therefore records a forward rel32 fixup in the
# per-loop break-fixup table, and gen_while backpatches them all to the exit
# point once the body is done. The stack supports nesting: break/continue
# always target the INNERMOST loop (the top frame).
# -----------------------------------------------------------------------
MAX_LOOPS: uint32 = 32
loop_cont_target: Array[32, uint32]    # condition-test offset (continue dest)
# Per-loop break-fixup list: a flat 2D table indexed [loop_depth*MAX_BRK + i].
MAX_BRK: uint32 = 64
loop_brk_at: Array[2048, uint32]       # 32 * 64 rel32-field offsets
loop_brk_n: Array[32, uint32]          # number of pending break fixups
loop_depth: uint32 = 0

# -----------------------------------------------------------------------
# Inline-asm (asm_volatile) local-label table. A single asm_volatile block
# may define `.Lxxx:` labels that its own jmp/jc/loop instructions target.
# These are LOCAL to the block (resolved within it, never via globals). A
# two-pass scheme records each label's byte offset (relative to the block's
# starting code offset) in pass 1, then resolves rel8 jumps in pass 2.
# Kernel asm blocks are tiny (rdrand/rdseed retry loops), so 32 labels and
# 64 lines per block is ample.
MAX_ASM_LABELS: uint32 = 32
asm_lbl_off: Array[32, uint32]         # byte offset within the block
asm_lbl_name_s: Array[32, uint32]      # strbuf start of the label name (incl ".L", excl ':')
asm_lbl_name_e: Array[32, uint32]      # strbuf end (exclusive)
asm_lbl_count: uint32 = 0

# For-array hidden-index slots. A `for var in arr` loop needs a private
# index counter; codegen_x86 names it `__for_idx_<n>` as a local. We reserve
# one 8-byte slot per for-array loop in the prescan pass and key it by the
# ND_FOR node id so gen_for_array can recover its frame offset. (Range loops
# need no hidden index — they reuse the visible loop var.)
MAX_FOR_IDX: uint32 = 64
fi_node: Array[64, uint32]
fi_offset: Array[64, int32]
fi_count: uint32 = 0


# -----------------------------------------------------------------------
# Struct/class layout table.
#
# Mirrors codegen_x86.layout_struct + StructInfo. Each registered struct
# records its class name (strbuf ref), 8-byte-rounded total_size, and a
# flat field table (name ref + byte offset + load/store size). Field
# layout: each field aligned to its natural alignment (capped at 8); total
# rounded up to 8. Inheritance prepends base fields left-to-right,
# transitively (see layout_struct below).
#
# A struct-typed field's size is its struct total_size; a field whose type
# is itself a struct is laid out by VALUE (embedded). An array-typed field
# occupies count*elem bytes and DECAYS to its address on load.
#
# Per-class method tables are not stored separately: a method `def m(self,
# ...)` is emitted as a free function named `<Class>__<m>` (see
# method_symbol / collect_class_methods), and `obj.m(args)` lowers to a
# direct call to that mangled symbol passing &obj (or the pointer value if
# obj is a Ptr[Struct]) as arg0. The class table records, per class, the
# strbuf ref of every method name it declares (own + inherited) so a call
# site can confirm the method exists; the owner-resolution + mangled name
# are recomputed from the class chain at the call site.
# -----------------------------------------------------------------------

MAX_STRUCTS: uint32 = 256
st_name_off: Array[256, uint32]
st_name_len: Array[256, uint32]
st_total: Array[256, uint32]            # 8-byte-rounded total size
# Flat field arrays, indexed by a per-struct [field_base .. field_base+nfields).
st_field_base: Array[256, uint32]
st_nfields: Array[256, uint32]
# The class decl node (ND_CLASS) so method/base chains can be re-walked.
st_decl: Array[256, uint32]
st_count: uint32 = 0

MAX_STRUCT_FIELDS: uint32 = 4096
sf_name_off: Array[4096, uint32]
sf_name_len: Array[4096, uint32]
sf_offset: Array[4096, uint32]          # byte offset within the struct
sf_size: Array[4096, uint32]            # scalar load/store width, OR 0 for an
                                        # array-typed field (decays to address)
sf_is_signed: Array[4096, uint32]       # 1 if a signed sub-8-byte scalar field
sf_signedness: Array[4096, uint32]      # FULL scalar-field signedness tristate
                                        # (0 unknown / 1 unsigned / 2 signed) of
                                        # the field's declared type — used by
                                        # expr_signedness(ND_MEMBER) for the
                                        # compare/shift signedness of `obj.field`
                                        # (distinguishes int64 from uint64, which
                                        # sf_is_signed — sub-8-byte only — cannot)
sf_elem_size: Array[4096, uint32]       # element width for an ARRAY field
                                        # (`buf: Array[N, T]` -> sizeof(T)), or
                                        # the pointee width for a Ptr[T] field;
                                        # 0 for scalars. Used to size a member-
                                        # base index `c.buf[i]` / `c.p[i]`.
sf_elem_signed: Array[4096, uint32]     # signedness tristate (0/1/2) of an
                                        # array/ptr field's element type
# Nested-struct typing of a field, for a NESTED member access
# `obj.inner.leaf`: sf_struct_idx = struct-table index + 1 when the field's
# type is itself a struct (an embedded struct value) OR a Ptr[Struct]; 0
# otherwise. sf_struct_is_ptr = 1 when the field is a Ptr[Struct] (the inner
# member's base is the pointer's VALUE), 0 for an embedded struct value (the
# inner member's base is &field). Mirrors codegen_x86 resolving an inner
# MemberExpr's struct via get_expr_type(field) -> _resolve_struct.
sf_struct_idx: Array[4096, uint32]
sf_struct_is_ptr: Array[4096, uint32]
# For an ARRAY-of-struct or Ptr[Struct] field (`stack: Array[N, Entry]` /
# `p: Ptr[Entry]`): the ELEMENT struct's table index (+1), so an indexed
# member-base `obj.field[i].leaf` resolves the element struct. 0 otherwise.
sf_elem_struct: Array[4096, uint32]
# The field's declared TYPE node (ND_ARRAY_TYPE for an array field), so a
# MULTI-DIMENSIONAL member array `obj.grid[i][j]` can be indexed level by
# level (the outer index scales by the row stride). 0 for non-array fields.
sf_type_node: Array[4096, uint32]
sf_count: uint32 = 0

# Program declaration-chain head, stashed at layout time so a class can be
# looked up by name (for inheritance base resolution).
cg_prog_decls: uint32 = 0
# Current method's `self` receiver: frame offset of the self param slot (which
# holds the receiver ADDRESS, like any Ptr[Struct]) and the struct-table index
# (+1) of the receiver's class. cg_self_struct == 0 means "not in a method".
# The parser marks both the self PARAM and every `self` IDENT in the body with
# nd_aux==1 and an empty (name_off=0,len=0) name, so we resolve `self` by that
# marker rather than by name. Mirrors codegen_x86's `self: Ptr[Class]`.
cg_self_off: int32 = 0
cg_self_struct: uint32 = 0
# Running field-layout offset, used by the recursive field walk in
# layout_struct (Adder has no closures, so the accumulator is a global).
cg_layout_offset: uint32 = 0


def cg_init():
    code_len = 0
    cg_err = 0
    loc_count = 0
    cg_stack_size = 0
    fn_count = 0
    fx_count = 0
    gdata_len = 0
    bss_len = 0
    glob_count = 0
    df_count = 0
    str_count = 0
    loop_depth = 0
    fi_count = 0
    cg_entry_off = CG_ENTRY_NONE
    cg_err_reason = 0
    cg_err_node = 0
    st_count = 0
    sf_count = 0
    mfn_count = 0
    mfx_count = 0
    cg_prog_decls = 0
    cg_layout_offset = 0
    cg_self_off = 0
    cg_self_struct = 0
    ext_count = 0
    er_count = 0
    percpu_len = 0
    # NOTE: cg_target_kernel is set by the driver AFTER cg_init (target flag),
    # so it is deliberately NOT reset here.


# Append one byte to the output buffer.
def emit_b(b: uint32):
    if code_len >= CODE_CAP:
        cg_fail(3, 0)
        return
    code[code_len] = cast[uint8](b & 255)
    code_len = code_len + 1


# Append a little-endian 32-bit immediate.
def emit_imm32(v: uint64):
    emit_b(cast[uint32](v & 255))
    emit_b(cast[uint32]((v >> 8) & 255))
    emit_b(cast[uint32]((v >> 16) & 255))
    emit_b(cast[uint32]((v >> 24) & 255))


# Emit a little-endian 8-byte immediate (for movabsq $imm64).
def emit_imm64(v: uint64):
    emit_b(cast[uint32](v & 255))
    emit_b(cast[uint32]((v >> 8) & 255))
    emit_b(cast[uint32]((v >> 16) & 255))
    emit_b(cast[uint32]((v >> 24) & 255))
    emit_b(cast[uint32]((v >> 32) & 255))
    emit_b(cast[uint32]((v >> 40) & 255))
    emit_b(cast[uint32]((v >> 48) & 255))
    emit_b(cast[uint32]((v >> 56) & 255))


# Compare a strbuf name slice [aoff,alen) against [boff,blen).
def name_match(aoff: uint32, alen: uint32, boff: uint32, blen: uint32) -> int32:
    if alen != blen:
        return 0
    i: uint32 = 0
    while i < alen:
        if strbuf[aoff + i] != strbuf[boff + i]:
            return 0
        i = i + 1
    return 1


# Allocate an 8-byte stack slot for a named parameter/local. Returns the
# negative %rbp-relative offset, mirroring alloc_local's growth direction.
def alloc_local(name_off: uint32, name_len: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    cg_stack_size = cg_stack_size + 8
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 0
    loc_scalar_size[loc_count] = 0
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_type_node[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Allocate an 8-byte slot for a Ptr[T] local/param. The slot HOLDS an
# address (the pointer's value), so it is sized like a scalar; ptr_size is
# the pointee width used when the pointer is indexed (p[i]). Returns the
# negative %rbp-relative offset. Mirrors alloc_local but records ptr-ness.
def alloc_ptr_local(name_off: uint32, name_len: uint32, ptr_size: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    cg_stack_size = cg_stack_size + 8
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = ptr_size
    loc_is_signed[loc_count] = 1     # a pointer is "unsigned" per _is_unsigned_type
    loc_scalar_size[loc_count] = 0   # a pointer slot is full 8-byte (no sized I/O)
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_type_node[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Allocate an Array local of `count` elements, each `elem_size` bytes,
# 8-byte-rounded so subsequent scalar slots stay 8-aligned (mirrors
# alloc_local(size=...) in codegen_x86.py). Returns the BASE offset (the
# address of element 0 = the lowest reserved address). Frame access uses
# disp32 (mod=10) addressing, so the offset may reach the whole frame — no
# -128 limit.
def alloc_array_local(name_off: uint32, name_len: uint32, count: uint32, elem_size: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    bytes_: uint32 = count * elem_size
    bytes_ = (bytes_ + 7) & cast[uint32](0xFFFFFFF8)
    cg_stack_size = cg_stack_size + bytes_
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = elem_size
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 1     # an array decays to an (unsigned) address
    loc_scalar_size[loc_count] = 0   # array base: not a sized scalar slot
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_type_node[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Allocate an in-place struct local: a slot reserving `total` bytes (rounded
# to 8) whose base address is taken via leaq, exactly like an Array local.
# Records the struct table index (+1) so member access resolves the layout.
# Mirrors codegen_x86's alloc_local(size=struct.total_size, var_type=Struct).
def alloc_struct_local(name_off: uint32, name_len: uint32, total: uint32, sidx1: uint32) -> int32:
    if loc_count >= MAX_LOCALS:
        cg_fail(6, 0)
        return 0
    bytes_: uint32 = (total + 7) & cast[uint32](0xFFFFFFF8)
    cg_stack_size = cg_stack_size + bytes_
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = name_off
    loc_name_len[loc_count] = name_len
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 1     # a struct decays to an (unsigned) address
    loc_scalar_size[loc_count] = 0
    loc_struct_idx[loc_count] = sidx1
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_type_node[loc_count] = 0
    loc_count = loc_count + 1
    return off


# Tag the most-recently-allocated local as a Ptr[Struct] (the `self` param
# case): its slot HOLDS an address whose pointee is struct `sidx1-1`.
def loc_set_struct_ptr(sidx1: uint32):
    if loc_count > 0:
        loc_struct_idx[loc_count - 1] = sidx1
        loc_struct_is_ptr[loc_count - 1] = 1


# Look up an identifier's struct-table index (+1), or 0 if not a struct local.
def lookup_local_struct(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_struct_idx[i]
        i = i + 1
    return 0


# 1 if the named local is a Ptr[Struct] (vs an in-place struct value).
def lookup_local_struct_is_ptr(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_struct_is_ptr[i]
        i = i + 1
    return 0


# Look up an identifier's Ptr[T] pointee size: returns the pointee width for
# a Ptr[T] local, or 0 for a non-pointer / unknown name.
def lookup_ptr_size(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_ptr_size[i]
        i = i + 1
    return 0


# Look up an identifier's array element size: returns the element size for
# an Array local, or 0 for a scalar / unknown name.
def lookup_elem_size(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_elem_size[i]
        i = i + 1
    return 0


# A local's recorded ND_ARRAY_TYPE node (0 if not a multi-dim array local /
# not a local). For nested-index dimension walking of an array local.
def lookup_local_type_node(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_type_node[i]
        i = i + 1
    return 0


# Tag the most-recently-allocated local with a signedness tristate
# (0 unknown / 1 unsigned / 2 signed), derived from its declared type. Used
# so identifier operands feed the signed/unsigned setcc + div/mod choice.
def loc_set_signedness(s: uint32):
    if loc_count > 0:
        loc_is_signed[loc_count - 1] = s


# Tag the most-recently-allocated scalar local with its byte width (1/2/4/8)
# so sub-8-byte typed locals get sized stores + extending loads.
def loc_set_scalar_size(sz: uint32):
    if loc_count > 0:
        loc_scalar_size[loc_count - 1] = sz


# Look up a local/param's scalar width (0 if not a sized scalar / not a local).
def lookup_local_scalar_size(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_scalar_size[i]
        i = i + 1
    return 0


# Tag the most-recently-allocated local with its float width (4/8), or 0 for
# a non-float scalar. Set from the declared type's keyword code.
def loc_set_float(fw: uint32):
    if loc_count > 0:
        loc_is_float[loc_count - 1] = fw


# Look up a local/param's float width (0 if not a float / not a local).
def lookup_local_float(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_is_float[i]
        i = i + 1
    return 0


# Float width (0/4/8) of a primitive type node: float32 (code 10) -> 4,
# float64 (code 11) -> 8, else 0. Mirrors codegen_x86._float_width.
def type_float_width(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    if code == 10:
        return 4
    if code == 11:
        return 8
    return 0


# Float width (0/4/8) of an EXPRESSION, mirroring
# codegen_x86._float_width(get_expr_type(expr)) over this subset's nodes:
#   ND_FLOAT_LIT -> 8 (a bare float literal is a float64)
#   ND_CAST  -> the cast destination type's float width
#   ND_IDENT -> a local's float width, else a scalar global's float width
#   ND_BINARY (arith) -> wider of the two operands' float widths
#   everything else -> 0
def expr_float_width(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_FLOAT_LIT:
        return 8
    if k == ND_CAST:
        return type_float_width(nd_a[node])
    if k == ND_IDENT:
        lf: uint32 = lookup_local_float(nd_name_off[node], nd_name_len[node])
        if lf != 0:
            return lf
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            return glob_is_float[gi - 1]
        return 0
    if k == ND_BINARY:
        bop: uint32 = nd_aux[node]
        if bop == BINOP_ADD or bop == BINOP_SUB or bop == BINOP_MUL or bop == BINOP_DIV or bop == BINOP_IDIV:
            lw: uint32 = expr_float_width(nd_a[node])
            rw: uint32 = expr_float_width(nd_b[node])
            if lw == 0 and rw == 0:
                return 0
            if lw >= rw:
                return lw
            return rw
        return 0
    return 0


# Look up a local/param's signedness tristate (0/1/2). 0 if not a local.
def lookup_local_signedness(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            return loc_is_signed[i]
        i = i + 1
    return 0


# Map a primitive type node to a signedness tristate (0 unknown / 1 unsigned /
# 2 signed) mirroring codegen_x86._is_unsigned_type(get_expr_type): an int
# scalar resolves to 1 (unsigned) or 2 (signed); anything else is 0 (unknown).
def type_signedness(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    # 2=int8 3=int16 4=int32 5=int64/int  -> signed; 6..9 uint -> unsigned;
    # 12=bool 13=char -> unsigned. Other codes -> unknown.
    if code == 2 or code == 3 or code == 4 or code == 5:
        return 2
    if code == 6 or code == 7 or code == 8 or code == 9:
        return 1
    if code == 12 or code == 13:
        return 1
    return 0


# Signedness tristate (0 unknown / 1 unsigned / 2 signed) of an EXPRESSION,
# mirroring codegen_x86._is_unsigned_type(get_expr_type(expr)) for the node
# kinds this backend's subset produces:
#   ND_CAST  -> the cast's destination type signedness (cast[T] declares T)
#   ND_IDENT -> a local's recorded signedness, else a global's signedness
#               (scalar globals: glob_is_signed=1 means signed; an array/ptr
#                global decays to an unsigned address)
#   everything else (binop, literal, call, index) -> 0 (unknown)
# get_expr_type has NO BinaryExpr case, so an arithmetic sub-expression is
# UNKNOWN here too — matching the oracle's gt=None for binops.
def expr_signedness(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_CAST:
        return type_signedness(nd_a[node])
    if k == ND_IDENT:
        ls: uint32 = lookup_local_signedness(nd_name_off[node], nd_name_len[node])
        if ls != 0:
            return ls
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            if glob_elem_size[gi - 1] != 0:
                return 1            # array global decays to an address
            # Full-type signedness tristate (covers 8-byte int64/uint64). Was
            # previously `glob_is_signed != 0 -> 2 else 1`, which mis-reported an
            # 8-byte int64 global as UNSIGNED (glob_is_signed is sub-8-byte-only)
            # — so `acc / operand` over int64 globals wrongly used div/xor
            # instead of idiv/cqto. glob_signedness records the declared type.
            gs: uint32 = glob_signedness[gi - 1]
            if gs != 0:
                return gs
            return 1                # unknown -> treat as unsigned (legacy default)
        return 0
    if k == ND_INDEX:
        # arr[i] / ptr[i] : signedness of the ELEMENT type, mirroring the seed's
        # get_expr_type(IndexExpr) -> ArrayType.element_type / PointerType.
        # base_type. index_elem_signed already returns the element tristate
        # (0 unknown / 1 unsigned / 2 signed). WITHOUT this, an unsigned array
        # element compared/shifted used the SIGNED machine op (setl/sar) instead
        # of the unsigned (setb/shr) — a real signedness divergence the objdiff
        # harness caught across base64 (`quad[i] >> n`), nproc/uptime/join
        # (`buf[j] >= 48`). Reverse for a SIGNED element (int32 quad[i] >> n must
        # be `sar`, not `shr`).
        return index_elem_signed(node)
    if k == ND_MEMBER:
        # obj.field : signedness of the field type, mirroring the seed's
        # get_expr_type(MemberExpr) -> the struct field's declared type.
        return member_scalar_signedness(node)
    if k == ND_CALL:
        # fn(...) : signedness of the function's RETURN type, mirroring the
        # seed's get_expr_type(CallExpr) -> func_return_types. WITHOUT this a
        # compare/div whose operand is a call result (e.g. `cursor + 1 <
        # total_rows()` with total_rows() -> uint64) defaulted to SIGNED.
        return type_signedness(call_return_type(node))
    return 0


# Signedness tristate of `obj.field` (an ND_MEMBER scalar). Resolves the struct
# of `obj` (own value or Ptr[Struct]), finds the field, and returns the field's
# recorded full-type signedness (sf_signedness). Returns 0 (unknown) if the
# struct/field can't be resolved — matching the seed's get_expr_type returning
# None for an unresolvable member. Mirrors gen_member_load's resolution path.
def member_scalar_signedness(node: uint32) -> uint32:
    obj: uint32 = nd_a[node]
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        return 0
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, nd_name_off[node], nd_name_len[node], &foff, &fsgn)
    if fsz == SF_NOFIELD:
        return 0
    # locate the field index again to read sf_signedness (struct_field_find
    # returns size; we re-walk for the tristate to avoid changing its ABI).
    si: uint32 = sidx1 - 1
    base: uint32 = st_field_base[si]
    n: uint32 = st_nfields[si]
    i: uint32 = 0
    while i < n:
        idx: uint32 = base + i
        if name_match(sf_name_off[idx], sf_name_len[idx], nd_name_off[node], nd_name_len[node]) != 0:
            return sf_signedness[idx]
        i = i + 1
    return 0


# Pick the relational setcc opcode. codegen_x86._rel_cc: default SIGNED
# (setl/setle/setg/setge), switch to the UNSIGNED family (setb/setbe/seta/
# setae) when EITHER operand is known-unsigned (signedness tristate == 1).
#   signed   setl 9C  setle 9E  setg 9F  setge 9D
#   unsigned setb 92  setbe 96  seta 97  setae 93
def rel_setcc(signed_cc: uint32, l_sgn: uint32, r_sgn: uint32) -> uint32:
    if l_sgn == 1 or r_sgn == 1:
        if signed_cc == 0x9C:        # setl  -> setb
            return 0x92
        if signed_cc == 0x9E:        # setle -> setbe
            return 0x96
        if signed_cc == 0x9F:        # setg  -> seta
            return 0x97
        if signed_cc == 0x9D:        # setge -> setae
            return 0x93
    return signed_cc


# Decide whether a `/` `%` `>>` uses the SIGNED machine instruction. Mirrors
# codegen_x86._binop_signed_op: either operand known-unsigned -> UNSIGNED;
# else SIGNED iff some operand is known-signed; all-unknown -> UNSIGNED.
def binop_use_signed(l_sgn: uint32, r_sgn: uint32) -> uint32:
    if l_sgn == 1 or r_sgn == 1:
        return 0
    if l_sgn == 2 or r_sgn == 2:
        return 1
    return 0


# Resolve an identifier name to its frame offset. Returns 1 on hit and
# writes the offset through out_off; returns 0 on miss.
def lookup_local(name_off: uint32, name_len: uint32, out_off: Ptr[int32]) -> int32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            out_off[0] = loc_offset[i]
            return 1
        i = i + 1
    return 0


# Register an emitted function's symbol -> code offset.
def fn_define(name_off: uint32, name_len: uint32, off: uint32):
    if fn_count >= MAX_FUNCS:
        cg_fail(6, 0)
        return
    fn_name_off[fn_count] = name_off
    fn_name_len[fn_count] = name_len
    fn_offset[fn_count] = off
    fn_count = fn_count + 1


# Record a pending call relocation at rel32-field offset `at`.
def add_call_fixup(at: uint32, name_off: uint32, name_len: uint32):
    if fx_count >= MAX_FIXUPS:
        cg_fail(5, 0)
        return
    fx_at[fx_count] = at
    fx_name_off[fx_count] = name_off
    fx_name_len[fx_count] = name_len
    fx_count = fx_count + 1


# Resolve all recorded call fixups against the function symbol table.
def resolve_calls():
    i: uint32 = 0
    while i < fx_count:
        j: uint32 = 0
        found: uint32 = 0
        while j < fn_count:
            if name_match(fn_name_off[j], fn_name_len[j], fx_name_off[i], fx_name_len[i]) != 0:
                patch_rel32(fx_at[i], fn_offset[j])
                found = 1
                j = fn_count
            else:
                j = j + 1
        if found == 0:
            if cg_target_kernel != 0:
                # Kernel target: the callee is a cross-object symbol (memset,
                # memcpy, read_cr3, __switch_to_asm, …) defined in a
                # hand-written .S object. Record a PLT32 extern relocation
                # against it; `ld` resolves it (with -static, PLT32 is treated
                # like PC32). The `call rel32` field was already emitted; its
                # placeholder stays 0 (the Rela addend is -4).
                ei: uint32 = ext_intern(fx_name_off[i], fx_name_len[i])
                add_extern_reloc(fx_at[i], ei, ER_PLT32)
            else:
                # Unknown callee — outside this subset (no extern linkage here).
                cg_fail(7, 0)
        i = i + 1


# -----------------------------------------------------------------------
# EXTERN LINKAGE — runtime syscall-wrapper synthesis.
#
# The frozen Python seed compiles a `.ad` unit to assembly, then `ld`-links
# it against user/runtime.S — a fixed library of thin `sys_*` syscall
# wrappers (`_start`, `sys_write`, `sys_read`, ...). Every `extern def
# sys_*` in the real userland tree resolves, at link time, to one of those
# wrappers (a `mov $N,%rax; syscall; ret` stub).
#
# The self-hosted `.ad` compiler has no external `ld` step (elf_emit.ad
# emits one self-contained ELF). To match the seed's BEHAVIORAL result we
# resolve+link those known runtime symbols DIRECTLY: for every unresolved
# call fixup whose name is a known runtime `sys_*` symbol, we synthesize the
# SAME wrapper body in-image (a real emitted function) and define its
# symbol, so resolve_calls() patches the call against it exactly as `ld`
# would have. This is the "resolve+link the known runtime symbols directly"
# option from the cutover plan — behaviorally identical to the seed's
# ld-against-runtime.S, no byte-identity claimed (the seed routes through
# `as`/`ld`; we emit raw bytes).
#
# Argument marshaling note: gen_call() loads args into the SysV arg
# registers (rdi/rsi/rdx/rcx/r8/r9) before the `call`. The Linux syscall
# ABI uses r10 for arg4 (not rcx). So every wrapper prepends `mov %rcx,%r10`
# — harmless for syscalls with <4 args (rcx is caller-clobbered and unused),
# and the required shuffle for 4+ arg syscalls (mmap, socketpair, link,
# symlink, ...). This mirrors runtime.S's per-wrapper `movq %rcx,%r10`.
# `sys_rfork` additionally supplies a5 = the parent user %rbp (mov %rbp,%r9),
# exactly as runtime.S's sys_rfork wrapper does.
# -----------------------------------------------------------------------

# Compare a strbuf name slice [name_off,name_len) against a NUL-terminated
# C string literal. Returns 1 on an exact match (same length, same bytes).
def name_eq_cstr(name_off: uint32, name_len: uint32, lit: Ptr[uint8]) -> int32:
    i: uint32 = 0
    while i < name_len:
        c: uint32 = cast[uint32](lit[i])
        if c == 0:
            return 0                      # literal shorter than the name
        if cast[uint32](strbuf[name_off + i]) != c:
            return 0
        i = i + 1
    # Name fully matched; the literal must end exactly here.
    if cast[uint32](lit[name_len]) != 0:
        return 0
    return 1


# Map a referenced extern symbol name to its Linux x86_64 syscall number.
# Returns syscall_number + 1 (so 0 unambiguously means "not a known runtime
# symbol"). The number/name pairs mirror the `movq $N,%rax` in each
# user/runtime.S wrapper; this table is the in-`.ad` stand-in for linking
# against runtime.S. Keep it IN LOCKSTEP with user/runtime.S (the frozen
# oracle's link target).
def runtime_syscall_num(name_off: uint32, name_len: uint32) -> uint32:
    if name_eq_cstr(name_off, name_len, "sys_putc") != 0:
        return 0 + 1
    if name_eq_cstr(name_off, name_len, "sys_exit") != 0:
        return 1 + 1
    if name_eq_cstr(name_off, name_len, "sys_get_jiffies") != 0:
        return 2 + 1
    if name_eq_cstr(name_off, name_len, "sys_getpid") != 0:
        return 4 + 1
    if name_eq_cstr(name_off, name_len, "sys_open") != 0:
        return 5 + 1
    if name_eq_cstr(name_off, name_len, "sys_read") != 0:
        return 6 + 1
    if name_eq_cstr(name_off, name_len, "sys_close") != 0:
        return 7 + 1
    if name_eq_cstr(name_off, name_len, "sys_write") != 0:
        return 8 + 1
    if name_eq_cstr(name_off, name_len, "sys_lseek") != 0:
        return 9 + 1
    if name_eq_cstr(name_off, name_len, "sys_execve") != 0:
        return 10 + 1
    if name_eq_cstr(name_off, name_len, "sys_open_write") != 0:
        return 13 + 1
    if name_eq_cstr(name_off, name_len, "sys_dup") != 0:
        return 16 + 1
    if name_eq_cstr(name_off, name_len, "sys_dup2") != 0:
        return 17 + 1
    if name_eq_cstr(name_off, name_len, "sys_getcwd") != 0:
        return 20 + 1
    if name_eq_cstr(name_off, name_len, "sys_unlink") != 0:
        return 21 + 1
    if name_eq_cstr(name_off, name_len, "sys_mkdir") != 0:
        return 22 + 1
    if name_eq_cstr(name_off, name_len, "sys_read_nb") != 0:
        return 23 + 1
    if name_eq_cstr(name_off, name_len, "sys_yield") != 0:
        return 24 + 1
    if name_eq_cstr(name_off, name_len, "sys_rfork") != 0:
        return 256 + 1
    if name_eq_cstr(name_off, name_len, "sys_bind") != 0:
        return 257 + 1
    if name_eq_cstr(name_off, name_len, "sys_resolve") != 0:
        return 269 + 1
    if name_eq_cstr(name_off, name_len, "sys_srv_post") != 0:
        return 275 + 1
    if name_eq_cstr(name_off, name_len, "sys_netcfg") != 0:
        return 286 + 1
    if name_eq_cstr(name_off, name_len, "sys_fdslot_kind") != 0:
        return 287 + 1
    if name_eq_cstr(name_off, name_len, "sys_set_realtime") != 0:
        return 292 + 1
    if name_eq_cstr(name_off, name_len, "sys_useradd_root") != 0:
        return 295 + 1
    if name_eq_cstr(name_off, name_len, "sys_resolve_ptr") != 0:
        return 301 + 1
    if name_eq_cstr(name_off, name_len, "sys_mmap") != 0:
        return 302 + 1
    if name_eq_cstr(name_off, name_len, "sys_munmap") != 0:
        return 304 + 1
    if name_eq_cstr(name_off, name_len, "sys_symlink") != 0:
        return 305 + 1
    if name_eq_cstr(name_off, name_len, "sys_link") != 0:
        return 306 + 1
    if name_eq_cstr(name_off, name_len, "sys_umdf_mmio_map") != 0:
        return 321 + 1
    if name_eq_cstr(name_off, name_len, "sys_umdf_dma_alloc") != 0:
        return 322 + 1
    if name_eq_cstr(name_off, name_len, "sys_umdf_irq_open") != 0:
        return 323 + 1
    if name_eq_cstr(name_off, name_len, "sys_socketpair") != 0:
        return 53 + 1
    # sys_waitpid(pid) -> int64 : runtime.S `xorl %esi,%esi` (a1=0, BLOCKING)
    # then SYS_WAITPID(12). emit_runtime_wrapper synthesizes the special
    # prologue; keep IN LOCKSTEP with user/runtime.S.
    if name_eq_cstr(name_off, name_len, "sys_waitpid") != 0:
        return 12 + 1
    # sys_pgrp_kill(pgid, sig) -> int32 : runtime.S `movl %edi,%edi; negq %rdi`
    # (a0 = -pgid) then SYS_KILL(15). emit_runtime_wrapper synthesizes the
    # special prologue; keep IN LOCKSTEP with user/runtime.S.
    if name_eq_cstr(name_off, name_len, "sys_pgrp_kill") != 0:
        return 15 + 1
    # --- cap#2 completion: remaining SIMPLE runtime.S wrappers (rcx->r10
    # shuffle + movq $N,%rax + syscall + ret). Keep IN LOCKSTEP
    # with user/runtime.S.
    if name_eq_cstr(name_off, name_len, "sys_execve_env") != 0:
        return 10 + 1
    if name_eq_cstr(name_off, name_len, "sys_waitpid_nb_raw") != 0:
        return 12 + 1
    if name_eq_cstr(name_off, name_len, "sys_pipe") != 0:
        return 14 + 1
    if name_eq_cstr(name_off, name_len, "sys_chdir") != 0:
        return 19 + 1
    if name_eq_cstr(name_off, name_len, "sys_rfork_thread") != 0:
        return 256 + 1
    if name_eq_cstr(name_off, name_len, "sys_mount") != 0:
        return 258 + 1
    if name_eq_cstr(name_off, name_len, "sys_unmount") != 0:
        return 259 + 1
    if name_eq_cstr(name_off, name_len, "sys_errstr") != 0:
        return 265 + 1
    if name_eq_cstr(name_off, name_len, "sys_srv_open") != 0:
        return 276 + 1
    if name_eq_cstr(name_off, name_len, "sys_fdbind") != 0:
        return 278 + 1
    if name_eq_cstr(name_off, name_len, "sys_pipechan") != 0:
        return 280 + 1
    if name_eq_cstr(name_off, name_len, "sys_openchan") != 0:
        return 281 + 1
    if name_eq_cstr(name_off, name_len, "sys_nsid") != 0:
        return 282 + 1
    if name_eq_cstr(name_off, name_len, "sys_nslabel") != 0:
        return 285 + 1
    if name_eq_cstr(name_off, name_len, "sys_getuid") != 0:
        return 288 + 1
    if name_eq_cstr(name_off, name_len, "sys_getgid") != 0:
        return 289 + 1
    if name_eq_cstr(name_off, name_len, "sys_setuid") != 0:
        return 290 + 1
    if name_eq_cstr(name_off, name_len, "sys_svc_publish") != 0:
        return 291 + 1
    if name_eq_cstr(name_off, name_len, "sys_wsys_alloc") != 0:
        return 293 + 1
    if name_eq_cstr(name_off, name_len, "sys_wsys_free") != 0:
        return 294 + 1
    if name_eq_cstr(name_off, name_len, "sys_svc_ctl") != 0:
        return 296 + 1
    if name_eq_cstr(name_off, name_len, "sys_setpgid") != 0:
        return 297 + 1
    if name_eq_cstr(name_off, name_len, "sys_tcsetpgrp") != 0:
        return 298 + 1
    if name_eq_cstr(name_off, name_len, "sys_waitpid_jc") != 0:
        return 299 + 1
    if name_eq_cstr(name_off, name_len, "sys_setuid_auth") != 0:
        return 300 + 1
    if name_eq_cstr(name_off, name_len, "sys_mprotect") != 0:
        return 303 + 1
    if name_eq_cstr(name_off, name_len, "sys_clock_gettime") != 0:
        return 307 + 1
    if name_eq_cstr(name_off, name_len, "sys_nanosleep") != 0:
        return 308 + 1
    if name_eq_cstr(name_off, name_len, "sys_timerfd_create") != 0:
        return 309 + 1
    if name_eq_cstr(name_off, name_len, "sys_timerfd_settime") != 0:
        return 310 + 1
    if name_eq_cstr(name_off, name_len, "sys_nice") != 0:
        return 311 + 1
    if name_eq_cstr(name_off, name_len, "sys_vk_window_frame") != 0:
        return 312 + 1
    if name_eq_cstr(name_off, name_len, "sys_waitfds") != 0:
        return 313 + 1
    if name_eq_cstr(name_off, name_len, "sys_semacquire") != 0:
        return 314 + 1
    if name_eq_cstr(name_off, name_len, "sys_semrelease") != 0:
        return 315 + 1
    if name_eq_cstr(name_off, name_len, "sys_setexitsem") != 0:
        return 316 + 1
    if name_eq_cstr(name_off, name_len, "sys_listdir_records") != 0:
        return 318 + 1
    if name_eq_cstr(name_off, name_len, "sys_chan_dir_mode") != 0:
        return 319 + 1
    if name_eq_cstr(name_off, name_len, "sys_seccomp_native") != 0:
        return 320 + 1
    if name_eq_cstr(name_off, name_len, "sys_fdslot_arg") != 0:
        return 324 + 1
    return 0


# Emit one runtime syscall-wrapper function body at the current code_len and
# register its symbol. `syscall_num` is the raw Linux syscall number. The
# body mirrors the corresponding user/runtime.S wrapper:
#
#   [rfork only]  48 89 E9? no — mov %rbp,%r9  : 49 89 E9   (a5 = parent rbp)
#   mov %rcx,%r10                               : 49 89 CA   (arg4 shuffle)
#   mov $syscall_num,%rax                       : 48 C7 C0 <imm32>
#   syscall                                     : 0F 05
#   ret                                         : C3
def emit_runtime_wrapper(name_off: uint32, name_len: uint32, syscall_num: uint32):
    start: uint32 = code_len
    fn_define(name_off, name_len, start)
    # sys_pgrp_kill(pgid, sig): runtime.S emits `movl %edi,%edi; negq %rdi`
    # (a0 = -pgid, sign-flipped to target a whole process group) and NO
    # %rcx->%r10 shuffle. Synthesize exactly that prologue, then fall through
    # to the shared `movq $N,%rax; syscall; ret` tail.
    if name_eq_cstr(name_off, name_len, "sys_pgrp_kill") != 0:
        # movl %edi,%edi  -> 89 FF   (zero-extend pgid into %rdi)
        emit_b(0x89)
        emit_b(0xFF)
        # negq %rdi       -> 48 F7 DF
        emit_b(0x48)
        emit_b(0xF7)
        emit_b(0xDF)
        # mov $syscall_num,%rax -> 48 C7 C0 <imm32>
        emit_b(0x48)
        emit_b(0xC7)
        emit_b(0xC0)
        emit_imm32(cast[uint64](syscall_num))
        emit_b(0x0F)                  # syscall
        emit_b(0x05)
        emit_b(0xC3)                  # ret
        return
    # sys_waitpid(pid): runtime.S emits `xorl %esi,%esi` (a1 = flags = 0,
    # BLOCKING) and NO %rcx->%r10 shuffle, then the syscall tail.
    if name_eq_cstr(name_off, name_len, "sys_waitpid") != 0:
        # xorl %esi,%esi  -> 31 F6
        emit_b(0x31)
        emit_b(0xF6)
        # mov $syscall_num,%rax -> 48 C7 C0 <imm32>
        emit_b(0x48)
        emit_b(0xC7)
        emit_b(0xC0)
        emit_imm32(cast[uint64](syscall_num))
        emit_b(0x0F)                  # syscall
        emit_b(0x05)
        emit_b(0xC3)                  # ret
        return
    # sys_rfork / sys_rfork_thread supply a5 = creator user %rbp in %r9
    # (mirrors runtime.S — both wrappers begin `movq %rbp,%r9`).
    if name_eq_cstr(name_off, name_len, "sys_rfork") != 0 or name_eq_cstr(name_off, name_len, "sys_rfork_thread") != 0:
        # mov %rbp,%r9  -> 49 89 E9
        emit_b(0x49)
        emit_b(0x89)
        emit_b(0xE9)
    # mov %rcx,%r10  -> 49 89 CA  (SysV arg4 -> syscall-ABI arg4; harmless if
    # the syscall has fewer than 4 args, as rcx is then unused).
    emit_b(0x49)
    emit_b(0x89)
    emit_b(0xCA)
    # mov $syscall_num,%rax  -> 48 C7 C0 <imm32>
    emit_b(0x48)
    emit_b(0xC7)
    emit_b(0xC0)
    emit_imm32(cast[uint64](syscall_num))
    # syscall
    emit_b(0x0F)
    emit_b(0x05)
    # ret
    emit_b(0xC3)


# Scan every pending call fixup; for each one naming a known runtime `sys_*`
# symbol that has NOT already been emitted as a function, synthesize its
# wrapper body in-image and define its symbol. Run BEFORE resolve_calls() so
# the freshly-defined wrapper symbols are visible to fixup resolution. This
# is the EXTERN LINKAGE step: it links the unit against the in-`.ad` runtime
# library exactly as the seed `ld`-links against user/runtime.S.
def link_runtime_externs():
    i: uint32 = 0
    while i < fx_count:
        noff: uint32 = fx_name_off[i]
        nlen: uint32 = fx_name_len[i]
        # Already satisfied by a real in-unit function? Skip.
        if fn_lookup_offset(noff, nlen) == CG_ENTRY_NONE:
            num1: uint32 = runtime_syscall_num(noff, nlen)
            if num1 != 0:
                emit_runtime_wrapper(noff, nlen, num1 - 1)
        i = i + 1


# Register an emitted method symbol: (owner-class name, method name) pair ->
# code offset. Mirrors fn_define for the `<Class>__<method>` mangled symbol.
def mfn_define(cls_off: uint32, cls_len: uint32, m_off: uint32, m_len: uint32, off: uint32):
    if mfn_count >= MAX_METHODS:
        cg_fail(6, 0)
        return
    mfn_cls_off[mfn_count] = cls_off
    mfn_cls_len[mfn_count] = cls_len
    mfn_m_off[mfn_count] = m_off
    mfn_m_len[mfn_count] = m_len
    mfn_offset[mfn_count] = off
    mfn_count = mfn_count + 1


# Record a pending method-call relocation at rel32-field offset `at`, keyed by
# the resolved (owner-class name, method name) pair.
def add_method_fixup(at: uint32, cls_off: uint32, cls_len: uint32, m_off: uint32, m_len: uint32):
    if mfx_count >= MAX_METHOD_FIXUPS:
        cg_fail(5, 0)
        return
    mfx_at[mfx_count] = at
    mfx_cls_off[mfx_count] = cls_off
    mfx_cls_len[mfx_count] = cls_len
    mfx_m_off[mfx_count] = m_off
    mfx_m_len[mfx_count] = m_len
    mfx_count = mfx_count + 1


# Resolve all method-call fixups against the method symbol table.
def resolve_method_calls():
    i: uint32 = 0
    while i < mfx_count:
        j: uint32 = 0
        found: uint32 = 0
        while j < mfn_count:
            if name_match(mfn_cls_off[j], mfn_cls_len[j], mfx_cls_off[i], mfx_cls_len[i]) != 0 and name_match(mfn_m_off[j], mfn_m_len[j], mfx_m_off[i], mfx_m_len[i]) != 0:
                patch_rel32(mfx_at[i], mfn_offset[j])
                found = 1
                j = mfn_count
            else:
                j = j + 1
        if found == 0:
            cg_fail(7, 0)
        i = i + 1


# Look up an emitted function's code offset by its strbuf name slice.
# Returns the function's code offset, or CG_ENTRY_NONE if no function with
# that name was emitted (does NOT set cg_err — callers decide).
def fn_lookup_offset(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < fn_count:
        if name_match(fn_name_off[i], fn_name_len[i], name_off, name_len) != 0:
            return fn_offset[i]
        i = i + 1
    return CG_ENTRY_NONE


# Compare an emitted function's strbuf name slice against the literal
# bytes "main". Returns 1 on match. Used to resolve the entry by name
# without needing a strbuf-resident copy of the literal.
def fn_name_is_main(name_off: uint32, name_len: uint32) -> int32:
    if name_len != 4:
        return 0
    if strbuf[name_off] != 109:      # 'm'
        return 0
    if strbuf[name_off + 1] != 97:   # 'a'
        return 0
    if strbuf[name_off + 2] != 105:  # 'i'
        return 0
    if strbuf[name_off + 3] != 110:  # 'n'
        return 0
    return 1


# Detect a syscall BUILTIN callee by name. The self-hosted compiler has no
# extern/libc linkage, so on-device syscalls are issued via inline builtins
# named `__syscallN` where N (1..6) is the number of syscall ARGUMENTS that
# follow the syscall number. The call form is:
#       __syscallN(num, a1, ..., aN)
# i.e. N+1 actual arguments. Returns N (1..6) on match, or 0 if the name is
# not a syscall builtin. The match is the literal prefix "__syscall" (9
# bytes) followed by exactly one ASCII digit '1'..'6'.
def syscall_builtin_args(name_off: uint32, name_len: uint32) -> uint32:
    if name_len != 10:
        return 0
    # "__syscall" = 5f 5f 73 79 73 63 61 6c 6c
    if strbuf[name_off] != 95:        # '_'
        return 0
    if strbuf[name_off + 1] != 95:    # '_'
        return 0
    if strbuf[name_off + 2] != 115:   # 's'
        return 0
    if strbuf[name_off + 3] != 121:   # 'y'
        return 0
    if strbuf[name_off + 4] != 115:   # 's'
        return 0
    if strbuf[name_off + 5] != 99:    # 'c'
        return 0
    if strbuf[name_off + 6] != 97:    # 'a'
        return 0
    if strbuf[name_off + 7] != 108:   # 'l'
        return 0
    if strbuf[name_off + 8] != 108:   # 'l'
        return 0
    d: uint32 = cast[uint32](strbuf[name_off + 9])
    if d < 49 or d > 54:              # '1'..'6'
        return 0
    return d - 48


# Resolve the program ENTRY offset by name: prefer a function literally
# named `main`; otherwise fall back to `first_off` (the first emitted
# function's offset, preserving the historical offset-0 entry behaviour for
# the selftests). Stores the chosen offset in cg_entry_off and returns it.
def resolve_entry(first_off: uint32) -> uint32:
    i: uint32 = 0
    while i < fn_count:
        if fn_name_is_main(fn_name_off[i], fn_name_len[i]) != 0:
            cg_entry_off = fn_offset[i]
            return cg_entry_off
        i = i + 1
    cg_entry_off = first_off
    return cg_entry_off


# -----------------------------------------------------------------------
# Data section management.
# -----------------------------------------------------------------------

# Reserve `n` bytes in gdata[], zero-initialised, returning the byte
# offset of the reserved block.
def gdata_reserve(n: uint32) -> uint32:
    if gdata_len + n > GDATA_CAP:
        cg_fail(4, 0)
        return 0
    off: uint32 = gdata_len
    i: uint32 = 0
    while i < n:
        gdata[off + i] = 0
        i = i + 1
    gdata_len = gdata_len + n
    return off


# Reserve `n` bytes of .bss (zero-init) virtual address space, returning
# the byte offset of the reserved block WITHIN the .bss region. NO bytes
# are written to any buffer and NO file storage is consumed — only the
# memsz counter advances. The .bss region's virtual base (DATA_BASE +
# gdata_len) is not final until all functions emit, so bss offsets are
# resolved against the final gdata_len in resolve_data_fixups().
def bss_reserve(n: uint32) -> uint32:
    off: uint32 = bss_len
    bss_len = bss_len + n
    return off


# Append one byte to the data section, returning its offset.
def gdata_emit_b(b: uint32) -> uint32:
    if gdata_len >= GDATA_CAP:
        cg_fail(4, 0)
        return 0
    off: uint32 = gdata_len
    gdata[off] = cast[uint8](b & 255)
    gdata_len = gdata_len + 1
    return off


# Register a global scalar (elem_size 0) or array (elem_size 1/2/4/8). The
# data slot is reserved here. Returns the assigned data offset.
def glob_define(name_off: uint32, name_len: uint32, data_off: uint32, elem_size: uint32, scalar_size: uint32) -> uint32:
    if glob_count >= MAX_GLOBALS:
        cg_fail(6, 0)
        return 0
    glob_name_off[glob_count] = name_off
    glob_name_len[glob_count] = name_len
    glob_offset[glob_count] = data_off
    glob_elem_size[glob_count] = elem_size
    glob_scalar_size[glob_count] = scalar_size
    glob_ptr_size[glob_count] = 0
    glob_is_bss[glob_count] = 0
    glob_is_signed[glob_count] = 0
    glob_signedness[glob_count] = 0
    glob_type_node[glob_count] = 0
    glob_struct_idx[glob_count] = 0
    glob_is_float[glob_count] = 0
    glob_is_percpu[glob_count] = 0
    glob_count = glob_count + 1
    return data_off


# Mark the most recently defined global as a Percpu[T] (kernel target): its
# glob_offset is a per-CPU TEMPLATE offset and its access lowers to %gs:offset.
def glob_set_percpu():
    if glob_count > 0:
        glob_is_percpu[glob_count - 1] = 1


# 1 if `tnode` is an ND_TYPE whose name equals the NUL-terminated literal.
# Used to recognise the `Percpu[T]` pseudo-type (parse_type discards the [T]).
def type_name_is(tnode: uint32, lit: Ptr[uint8]) -> uint32:
    if tnode == 0 or nd_kind[tnode] != ND_TYPE:
        return 0
    return cast[uint32](name_eq_cstr(nd_name_off[tnode], nd_name_len[tnode], lit))


# Mark the most recently defined global as living in .bss (zero-init): its
# glob_offset is a .bss offset, resolved against the final gdata_len.
def glob_set_bss():
    if glob_count > 0:
        glob_is_bss[glob_count - 1] = 1


# Mark the most recently defined global as a Ptr[T] whose pointee width is
# `ptr_size`. The global is otherwise an 8-byte scalar slot that holds an
# address; this records the pointee width consulted when it is indexed.
def glob_set_ptr_size(ptr_size: uint32):
    if glob_count > 0:
        glob_ptr_size[glob_count - 1] = ptr_size


# Mark the most recently defined scalar global as SIGNED (int8/int16/int32),
# so a sub-8-byte load sign-extends into the 64-bit register (movsXq) — the
# mirror of codegen_x86's emit_load_sized_signed. Only meaningful for scalar
# widths 1/2/4; an 8-byte scalar needs no extension.
def glob_set_signed():
    if glob_count > 0:
        glob_is_signed[glob_count - 1] = 1


# Record the FULL signedness tristate of the most recently defined scalar
# global (covers 8-byte int64/uint64 too), for expr_signedness's compare/div/
# shift op choice. Distinct from glob_set_signed (sub-8-byte load extension).
def glob_set_signedness(tri: uint32):
    if glob_count > 0:
        glob_signedness[glob_count - 1] = tri


# Tag the most recently defined global with its float width (4/8), so a
# global float identifier routes to the SSE path. Mirrors codegen_x86's
# _float_width over a global's recorded type.
def glob_set_float(fw: uint32):
    if glob_count > 0:
        glob_is_float[glob_count - 1] = fw


# Record the FULL array type node for the most recently defined array
# global, enabling multi-dimensional indexing (the outer index scales by the
# nested row stride). 1-D arrays may also set this; it is consulted only
# when a nested index is encountered, so it never changes 1-D behaviour.
def glob_set_type_node(tnode: uint32):
    if glob_count > 0:
        glob_type_node[glob_count - 1] = tnode


# Mark the most recently defined global as a struct-typed in-place value of
# struct `sidx1-1`, so member access resolves its layout.
def glob_set_struct(sidx1: uint32):
    if glob_count > 0:
        glob_struct_idx[glob_count - 1] = sidx1


# Resolve a name to a global table index. Returns the index+1 (so a 0
# return means "not a global"); the caller subtracts 1.
def glob_lookup(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < glob_count:
        if name_match(glob_name_off[i], glob_name_len[i], name_off, name_len) != 0:
            return i + 1
        i = i + 1
    return 0


# Record a RIP-relative data relocation at rel32-field offset `at`,
# targeting `data_off`. `is_bss` distinguishes a .data target (data_off is
# a gdata[] byte offset) from a .bss target (data_off is a .bss offset,
# resolved against the final gdata_len in resolve_data_fixups()).
def add_data_fixup(at: uint32, data_off: uint32, is_bss: uint32):
    if df_count >= MAX_DATA_FIXUPS:
        cg_fail(5, 0)
        return
    df_at[df_count] = at
    df_data_off[df_count] = data_off
    df_is_bss[df_count] = is_bss
    df_count = df_count + 1


# Patch every recorded data relocation: disp32 = target - (at + 4), the
# RIP-relative displacement from the instruction's end to the global's
# address in the laid-out image. By the time this runs gdata_len is FINAL
# (all string interning done), so the .bss base (DATA_BASE + gdata_len) is
# known.
#   .data fixup: target = DATA_BASE + df_data_off[i]
#   .bss  fixup: target = DATA_BASE + gdata_len + df_data_off[i]
def resolve_data_fixups():
    # KERNEL TARGET: do NOT bake an absolute DATA_BASE-relative disp32 into the
    # code. The data section is placed at its kernel.lds VMA by `ld`, so each
    # data reference is left as a 0-placeholder and emitted as a section-
    # relative R_X86_64_PC32 relocation by elf_emit_image_kernel (against the
    # .data or .bss section symbol, addend = df_data_off - 4). Patching an
    # absolute value here would fight the linker.
    if cg_target_kernel != 0:
        return
    i: uint32 = 0
    while i < df_count:
        target: uint32 = DATA_BASE + df_data_off[i]
        if df_is_bss[i] != 0:
            target = DATA_BASE + gdata_len + df_data_off[i]
        patch_rel32(df_at[i], target)
        i = i + 1


# Intern a string literal whose bytes live in strbuf[src_off..src_off+len).
# Returns its data-section offset. Identical literals (same strbuf slice
# content) collapse to one slot. The bytes are copied into gdata[] and a
# trailing NUL is appended (matching codegen_x86's `.asciz`).
def intern_string(src_off: uint32, src_len: uint32) -> uint32:
    # Dedup against already-interned strings by content equality.
    i: uint32 = 0
    while i < str_count:
        if name_match(str_src_off[i], str_src_len[i], src_off, src_len) != 0:
            return str_data_off[i]
        i = i + 1
    # Place the bytes + NUL into the data section.
    base: uint32 = gdata_reserve(src_len + 1)
    j: uint32 = 0
    while j < src_len:
        gdata[base + j] = strbuf[src_off + j]
        j = j + 1
    gdata[base + src_len] = 0
    if str_count < MAX_STRINGS:
        str_src_off[str_count] = src_off
        str_src_len[str_count] = src_len
        str_data_off[str_count] = base
        str_count = str_count + 1
    else:
        cg_fail(6, 0)
    return base


# Intern an IEEE-754 float constant (raw bit pattern `bits`, byte `width`)
# into the data section, deduped by (width, bits). Returns its gdata[] byte
# offset. Mirrors codegen_x86.add_float_const + the .rodata emission: the raw
# little-endian bytes of the bit pattern are placed in initialised data.
def intern_float_const(bits: uint64, width: uint32) -> uint32:
    i: uint32 = 0
    while i < fc_count:
        if fc_width[i] == width and fc_bits[i] == bits:
            return fc_data_off[i]
        i = i + 1
    base: uint32 = gdata_reserve(width)
    v: uint64 = bits
    j: uint32 = 0
    while j < width:
        gdata[base + j] = cast[uint8](v & 255)
        v = v >> 8
        j = j + 1
    if fc_count < MAX_FLOAT_CONSTS:
        fc_bits[fc_count] = bits
        fc_width[fc_count] = width
        fc_data_off[fc_count] = base
        fc_count = fc_count + 1
    else:
        cg_fail(6, 0)
    return base


# -----------------------------------------------------------------------
# Instruction emitters (encodings authoritative per codegen_x86.py's
# AT&T mnemonics; bytes are the standard SysV AMD64 encodings).
# -----------------------------------------------------------------------

# endbr64  -> F3 0F 1E FA
def emit_endbr64():
    emit_b(0xF3)
    emit_b(0x0F)
    emit_b(0x1E)
    emit_b(0xFA)


# pushq %rbp  -> 55
def emit_push_rbp():
    emit_b(0x55)


# popq %rbp   -> 5D   (part of `leave`; kept for completeness, unused)
def emit_pop_rbp():
    emit_b(0x5D)


# movq %rsp, %rbp  -> 48 89 E5
def emit_mov_rsp_rbp():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xE5)


# subq $imm32, %rsp  -> 48 81 EC imm32
def emit_sub_rsp(imm: uint32):
    emit_b(0x48)
    emit_b(0x81)
    emit_b(0xEC)
    emit_imm32(cast[uint64](imm))


# addq $imm32, %rsp  -> 48 81 C4 imm32  (reclaim a stack-arg block).
def emit_add_rsp(imm: uint32):
    emit_b(0x48)
    emit_b(0x81)
    emit_b(0xC4)
    emit_imm32(cast[uint64](imm))


# movq %rax, disp32(%rsp)  -> 48 89 84 24 disp32  (store a stack-passed
# argument into its slot below %rsp). modrm=0x84 (mod=10 disp32, reg=rax,
# rm=100 -> SIB), SIB=0x24 (scale 0, index none, base rsp).
def emit_store_rax_rsp_disp(disp: uint32):
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0x84)
    emit_b(0x24)
    emit_imm32(cast[uint64](disp))


# movq disp32(%rsp), %r11  -> 4C 8B 9C 24 disp32  (reclaim the stashed
# function pointer for an indirect call). REX.WR (4C), modrm 0x9C (reg=r11),
# SIB 0x24 (base rsp), disp32.
def emit_load_r11_rsp_disp(disp: uint32):
    emit_b(0x4C)
    emit_b(0x8B)
    emit_b(0x9C)
    emit_b(0x24)
    emit_imm32(cast[uint64](disp))


# call *%r11  -> 41 FF D3  (indirect call through the function pointer).
def emit_call_r11():
    emit_b(0x41)
    emit_b(0xFF)
    emit_b(0xD3)


# -----------------------------------------------------------------------
# Phase-4 register-allocation helpers (emitted ONLY under --opt; see regalloc.ad
# and gen_function's ra hook). All keyed by an x86 register ENCODING (rbx=3,
# r12=12, r13=13, r14=14, r15=15) — the only registers the callee-saved pool
# hands out. These touch NO scratch/arg register, so the default stack-machine
# lowering is undisturbed; they appear in the stream only for register-resident
# promoted locals when regalloc is enabled.
# -----------------------------------------------------------------------

# push %<enc>  : rbx -> 53 ; r12..r15 -> 41 5C..5F (REX.B).
def emit_push_callee(enc: uint32):
    if enc == 3:
        emit_b(0x53)
    else:
        emit_b(0x41)
        emit_b(0x50 + (enc - 8))


# pop %<enc>   : rbx -> 5B ; r12..r15 -> 41 5C..5F (REX.B).
def emit_pop_callee(enc: uint32):
    if enc == 3:
        emit_b(0x5B)
    else:
        emit_b(0x41)
        emit_b(0x58 + (enc - 8))


# movq %<enc>, %rax   read a register-resident local into %rax.
#   rbx  -> 48 8B C3        (mov %rbx,%rax)
#   r12..r15 -> 49 8B C4..C7 (REX.B selects r12-r15 as r/m)
def emit_mov_callee_rax(enc: uint32):
    if enc == 3:
        emit_b(0x48)
        emit_b(0x8B)
        emit_b(0xC3)
    else:
        emit_b(0x49)
        emit_b(0x8B)
        emit_b(0xC0 + (enc - 8))


# movq %rax, %<enc>   write %rax into a register-resident local (write-through
# companion to the stack-slot store).
#   rbx  -> 48 89 C3
#   r12..r15 -> 49 89 C4..C7
def emit_mov_rax_callee(enc: uint32):
    if enc == 3:
        emit_b(0x48)
        emit_b(0x89)
        emit_b(0xC3)
    else:
        emit_b(0x49)
        emit_b(0x89)
        emit_b(0xC0 + (enc - 8))


# movq off(%rbp), %<enc>   initialize a register-resident local from its stack
# slot (used once after spill_params so a param/initialized value is loaded into
# its register before the body reads it).
#   rbx  -> 48 8B {5D disp8 | 9D disp32}
#   r12..r15 -> 4C 8B {modrm}    (REX.R extends dest reg field to r8..r15)
def emit_load_local_callee(enc: uint32, off: int32):
    if enc == 3:
        emit_b(0x48)
        emit_b(0x8B)
        emit_rbp_mem(0x5D, off)          # reg field = rbx (011)
    else:
        emit_b(0x4C)                     # REX.WR
        emit_b(0x8B)
        # modrm reg field low 3 bits = (enc-8); base byte 0x45 has reg=000, so
        # add (enc-8)<<3 to set the dest register field.
        emit_rbp_mem(0x45 + ((enc - 8) << 3), off)


# -----------------------------------------------------------------------
# Per-function regalloc state + prologue/epilogue (callee-saved save/restore).
# cg_ra_active is set by gen_function/gen_method when an allocation was built AND
# the flag is on; 0 otherwise (the default path emits the original prologue/
# epilogue verbatim, so default output is byte-identical).
# -----------------------------------------------------------------------
cg_ra_active: uint32 = 0
cg_ra_pad: uint32 = 0                    # 1 => an odd # of callees pushed, frame
                                         # padded by 8 to keep 16-byte alignment
# 1 => this function saves AT LEAST ONE callee-saved reg (a regalloc-promoted
# local OR an IR scratch reservation), so the prologue/epilogue must emit the
# save/restore + alignment pad. With regalloc OFF and no scratch reservation this
# stays 0 and the prologue/epilogue are byte-identical to the seed.
cg_callee_active: uint32 = 0


# Bitmask (over pool indices 0..RA_NREGS-1) of the scratch registers the IR
# emitter reserved for THIS function. The prologue pushes / epilogue pops these
# IN ADDITION TO the regalloc-used regs, keeping the same pool-index space so the
# push (0..N-1) / pop (N-1..0) order stays symmetric. Built once per function from
# ir_scratch_reserve (the prescan demand): the first ir_scratch_reserve AVAILABLE
# (= not regalloc-used) pool indices, matching ir_scratch_acquire's greedy LIFO.
cg_scratch_reserved_mask: uint32 = 0


# Build cg_scratch_reserved_mask: the first `ir_scratch_reserve` pool indices that
# ir_scratch_build_avail marked available (ir_scratch_avail[i]!=0). These are
# exactly the registers any acquire chain of that depth would touch.
def cg_build_scratch_reserved():
    cg_scratch_reserved_mask = 0
    need: uint32 = ir_scratch_reserve
    if need == 0:
        return
    got: uint32 = 0
    i: uint32 = 0
    while i < ra_nregs():
        if got >= need:
            return
        if ir_scratch_avail[i] != 0:
            cg_scratch_reserved_mask = cg_scratch_reserved_mask | (cast[uint32](1) << i)
            got = got + 1
        i = i + 1


# True iff pool index p is SAVED by this function's prologue: either regalloc
# promoted a local into it, or the IR scratch prescan reserved it.
def cg_pool_saved(p: uint32) -> uint32:
    if cg_ra_active != 0 and ra_pool_used(p) != 0:
        return 1
    if ((cg_scratch_reserved_mask >> p) & 1) != 0:
        return 1
    return 0


# Count the callee-saved pool regs the current allocation used.
def ra_used_count() -> uint32:
    c: uint32 = 0
    p: uint32 = 0
    while p < ra_nregs():
        if ra_pool_used(p) != 0:
            c = c + 1
        p = p + 1
    return c


# Count the callee-saved pool regs SAVED by this function (regalloc OR scratch).
def cg_saved_count() -> uint32:
    c: uint32 = 0
    p: uint32 = 0
    while p < ra_nregs():
        if cg_pool_saved(p) != 0:
            c = c + 1
        p = p + 1
    return c


# Prologue saves: push every SAVED callee-saved reg (regalloc-promoted local OR
# IR scratch reservation) in pool order 0..N-1 BEFORE the `push %rbp`, so `leave`
# does not strand them. Sets cg_ra_pad from the total saved count (frame padding
# keeps %rsp 16-byte aligned at inner calls).
def ra_emit_prologue_saves():
    n: uint32 = cg_saved_count()
    cg_ra_pad = n & 1
    p: uint32 = 0
    while p < ra_nregs():
        if cg_pool_saved(p) != 0:
            emit_push_callee(ra_pool_encoding(p))
        p = p + 1


# After spill_params: load each register-resident PARAMETER's incoming value
# from its (just-spilled) slot into its assigned register, so the body's first
# read of the param sees the argument. ONLY params are loaded here — a non-param
# local's slot is GARBAGE at entry, and its assigned register is established by
# its first write-through store (store_to_named). Loading a non-param local here
# would (a) read garbage and (b) clobber a register legitimately shared with a
# param or earlier local whose interval is disjoint from it. `pchain` is the
# ND_FUNCTION/ND_METHOD parameter chain (nd_a); we walk it and load each named
# param that owns a plain full-width scalar register.
def ra_emit_init_regs(pchain: uint32):
    pp: uint32 = pchain
    while pp != 0:
        # skip the implicit unnamed `self` param (name len 0); it is a Ptr slot,
        # never register-promoted.
        if nd_name_len[pp] != 0:
            enc: uint32 = ra_reg_for_name(nd_name_off[pp], nd_name_len[pp])
            if enc != RA_NONE:
                # locate this param's slot + ensure it is a plain 8-byte scalar
                # (matches the gen_ident/store_to_named register hook guard).
                off2: int32 = 0
                if lookup_local(nd_name_off[pp], nd_name_len[pp], &off2) != 0:
                    if param_is_plain_scalar(nd_name_off[pp], nd_name_len[pp]) != 0:
                        emit_load_local_callee(enc, off2)
        pp = nd_next[pp]


# True iff the named local is a plain full-width 8-byte scalar slot (scalar_size
# 0, not an array, not a pointer) — the only locals codegen reads via a register.
def param_is_plain_scalar(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            if loc_scalar_size[i] == 0 and loc_elem_size[i] == 0 and loc_ptr_size[i] == 0:
                return 1
            return 0
        i = i + 1
    return 0


# Epilogue restores: pop the used callee-saved regs in REVERSE pool order (they
# sit just above the saved %rbp after `leave; pop rbp`)... but `leave` already
# pops rbp; we pop the callees AFTER restoring rsp/rbp. Layout (entry rsp=R):
#   push callees (k) -> R-8k ; push rbp -> R-8k-8 ; mov rsp,rbp.
#   epilogue: leave (rsp=rbp; pop rbp -> rsp=R-8k); pop callees reverse -> rsp=R.
# So we emit `leave` first, then pop the callees in reverse order, then ret.
def ra_emit_epilogue_restores():
    p: uint32 = ra_nregs()
    while p > 0:
        p = p - 1
        if cg_pool_saved(p) != 0:
            emit_pop_callee(ra_pool_encoding(p))


# Unified function epilogue used at every return point. With regalloc inactive
# this is exactly `leave; ret` (byte-identical default).
def emit_function_epilogue():
    emit_leave()
    if cg_callee_active != 0:
        ra_emit_epilogue_restores()
    emit_ret()


# movq %gs:disp32, %rax  -> 65 48 8B 04 25 disp32  (read a per-CPU global; the
# disp32 is the global's byte offset within the per-CPU area, an ABSOLUTE
# segment-relative address — NOT a reloc, the offset is a compile-time
# constant the codegen pins). Mirrors codegen_x86's `movq %gs:off, %rax`.
def emit_load_gs_rax(off: uint32):
    emit_b(0x65)
    emit_b(0x48)
    emit_b(0x8B)
    emit_b(0x04)
    emit_b(0x25)
    emit_imm32(cast[uint64](off))


# SIZED per-CPU scalar LOAD into %rax, mirroring codegen_x86's percpu
# identifier read (movq/movl/movzwq/movzbq %gs:off). A blind 8-byte movq leaves
# the high bytes holding the adjacent per-CPU slot's bits for a sub-8-byte
# Percpu[T] global; the seed truncates to the declared width and zero-extends.
# (No sub-8-byte Percpu scalar exists in the current tree — every Percpu[T] is
# uint64/aggregate — so this is defensive parity for a future narrow per-CPU
# global; size 8/other -> the plain movq above.)
#   movl    %gs:disp32, %eax -> 65 8B 04 25 disp32       (size 4, auto-ZX)
#   movzwq  %gs:disp32, %rax -> 65 48 0F B7 04 25 disp32 (size 2)
#   movzbq  %gs:disp32, %rax -> 65 48 0F B6 04 25 disp32 (size 1)
def emit_load_gs_rax_sized(off: uint32, size: uint32):
    if size == 4:
        emit_b(0x65)
        emit_b(0x8B)
        emit_b(0x04)
        emit_b(0x25)
        emit_imm32(cast[uint64](off))
    elif size == 2:
        emit_b(0x65)
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB7)
        emit_b(0x04)
        emit_b(0x25)
        emit_imm32(cast[uint64](off))
    elif size == 1:
        emit_b(0x65)
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB6)
        emit_b(0x04)
        emit_b(0x25)
        emit_imm32(cast[uint64](off))
    else:
        emit_load_gs_rax(off)


# movq %rax, %gs:disp32  -> 65 48 89 04 25 disp32  (write a per-CPU global).
def emit_store_gs_rax(off: uint32):
    emit_b(0x65)
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0x04)
    emit_b(0x25)
    emit_imm32(cast[uint64](off))


# SIZED per-CPU scalar STORE of %rax, mirroring codegen_x86's percpu
# identifier store (movq/movl/movw/movb %al.. -> %gs:off): a sub-8-byte
# Percpu[T] global must be written with movl/movw/movb so the slot holds the
# type-truncated value (same class as the local/global/member sized store).
# size 8/other -> the plain movq above.
#   movl %eax, %gs:disp32 -> 65 89 04 25 disp32       (size 4)
#   movw %ax,  %gs:disp32 -> 66 65 89 04 25 disp32     (size 2)
#   movb %al,  %gs:disp32 -> 65 88 04 25 disp32        (size 1)
def emit_store_gs_rax_sized(off: uint32, size: uint32):
    if size == 4:
        emit_b(0x65)
        emit_b(0x89)
        emit_b(0x04)
        emit_b(0x25)
        emit_imm32(cast[uint64](off))
    elif size == 2:
        emit_b(0x66)
        emit_b(0x65)
        emit_b(0x89)
        emit_b(0x04)
        emit_b(0x25)
        emit_imm32(cast[uint64](off))
    elif size == 1:
        emit_b(0x65)
        emit_b(0x88)
        emit_b(0x04)
        emit_b(0x25)
        emit_imm32(cast[uint64](off))
    else:
        emit_store_gs_rax(off)


# leave  -> C9
def emit_leave():
    emit_b(0xC9)


# ret    -> C3
def emit_ret():
    emit_b(0xC3)


# pushq %rax  -> 50
def emit_push_rax():
    emit_b(0x50)


# popq %rax   -> 58
def emit_pop_rax():
    emit_b(0x58)


# popq %rcx   -> 59
def emit_pop_rcx():
    emit_b(0x59)


# movq $imm32, %rax (sign-extended) -> 48 C7 C0 imm32
# Materialize a 64-bit immediate into %rax. The compact `movq $imm32,%rax`
# (48 C7 C0 <imm32>) SIGN-EXTENDS its 32-bit immediate to 64 bits, so it can
# only carry values in the signed-32-bit range [-2^31, 2^31). For anything
# outside that range we MUST use `movabsq $imm64,%rax` (48 B8 <imm64>) or the
# high bits are lost / mis-sign-extended. This mirrors codegen_x86.gen_expr's
# IntLiteral case (movq for signed-32 range, else movabsq). Without it a
# literal like 2745498085935061697 collapses to its sign-extended low 32 bits.
def emit_mov_imm_rax(v: uint64):
    # In signed-32 range iff v <= 0x7FFFFFFF (small non-negative) or
    # v >= 0xFFFFFFFF80000000 (a value whose two's-complement is >= -2^31).
    if v <= cast[uint64](0x7FFFFFFF) or v >= cast[uint64](0xFFFFFFFF80000000):
        emit_b(0x48)
        emit_b(0xC7)
        emit_b(0xC0)
        emit_imm32(v)
        return
    # movabsq $imm64, %rax  -> 48 B8 <8-byte little-endian immediate>
    emit_b(0x48)
    emit_b(0xB8)
    emit_imm64(v)


# addq %rcx, %rax  -> 48 01 C8
def emit_add_rcx_rax():
    emit_b(0x48)
    emit_b(0x01)
    emit_b(0xC8)


# subq %rcx, %rax  -> 48 29 C8
def emit_sub_rcx_rax():
    emit_b(0x48)
    emit_b(0x29)
    emit_b(0xC8)


# imulq %rcx, %rax  -> 48 0F AF C1
def emit_imul_rcx_rax():
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0xAF)
    emit_b(0xC1)


# andq %rcx, %rax  -> 48 21 C8
def emit_and_rcx_rax():
    emit_b(0x48)
    emit_b(0x21)
    emit_b(0xC8)


# orq %rcx, %rax  -> 48 09 C8
def emit_or_rcx_rax():
    emit_b(0x48)
    emit_b(0x09)
    emit_b(0xC8)


# xorq %rcx, %rax  -> 48 31 C8
def emit_xor_rcx_rax():
    emit_b(0x48)
    emit_b(0x31)
    emit_b(0xC8)


# shlq %cl, %rax  -> 48 D3 E0   (shift count in %cl)
def emit_shl_cl_rax():
    emit_b(0x48)
    emit_b(0xD3)
    emit_b(0xE0)


# shrq %cl, %rax  -> 48 D3 E8   (logical right shift; unsigned default,
# matching gen_binary's all-unknown-type rule in codegen_x86.py)
def emit_shr_cl_rax():
    emit_b(0x48)
    emit_b(0xD3)
    emit_b(0xE8)


# Unsigned 64/64 division: xorq %rdx,%rdx ; divq %rcx. Quotient -> %rax,
# remainder -> %rdx. Mirrors gen_binary's unsigned DIV/MOD path (the
# default when no operand type is statically known-signed, which is the
# case for this type-erased subset).
# xorq %rdx, %rdx  -> 48 31 D2
def emit_xor_rdx_rdx():
    emit_b(0x48)
    emit_b(0x31)
    emit_b(0xD2)


# divq %rcx  -> 48 F7 F1
def emit_div_rcx():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xF1)


# Signed 64/64 division setup: cqo sign-extends %rax into %rdx:%rax (the
# signed analogue of xorq %rdx,%rdx), then idivq %rcx. Mirrors codegen_x86's
# signed DIV/MOD path (_binop_signed_op == True). Quotient -> %rax,
# remainder -> %rdx, both truncating toward zero (x86 idiv semantics).
# cqo  -> 48 99
def emit_cqo():
    emit_b(0x48)
    emit_b(0x99)


# idivq %rcx  -> 48 F7 F9
def emit_idiv_rcx():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xF9)


# sarq %cl, %rax  -> 48 D3 F8   (arithmetic right shift; signed `>>`)
def emit_sar_cl_rax():
    emit_b(0x48)
    emit_b(0xD3)
    emit_b(0xF8)


# movq %rdx, %rax  -> 48 89 D0   (move remainder into %rax for MOD)
def emit_mov_rdx_rax():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xD0)


# movq %rax, %rcx  -> 48 89 C1
def emit_mov_rax_rcx():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xC1)


# negq %rax  -> 48 F7 D8
def emit_neg_rax():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xD8)


# -----------------------------------------------------------------------
# Strength-reduction emit helpers (used ONLY under --opt by the div/mod-by-
# constant pass; see gen_div_const below). All operate on full 64-bit %rax.
# -----------------------------------------------------------------------

# mulq %rcx  -> 48 F7 E1   (UNSIGNED rax*rcx, 128-bit product in %rdx:%rax;
# %rdx = high 64 bits). One-operand form.
def emit_mul_rcx():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xE1)


# imulq %rcx -> 48 F7 E9   (SIGNED rax*rcx, 128-bit product in %rdx:%rax;
# %rdx = high 64 bits). One-operand form (distinct from the two-operand
# imulq %rcx,%rax = 48 0F AF C1).
def emit_imul1_rcx():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xE9)


# shrq $imm8, %rax  -> 48 C1 E8 ib   (logical right shift by immediate)
def emit_shr_imm_rax(k: uint32):
    emit_b(0x48)
    emit_b(0xC1)
    emit_b(0xE8)
    emit_b(k & 255)


# sarq $imm8, %rax  -> 48 C1 F8 ib   (arithmetic right shift by immediate)
def emit_sar_imm_rax(k: uint32):
    emit_b(0x48)
    emit_b(0xC1)
    emit_b(0xF8)
    emit_b(k & 255)


# andq $imm32, %rax  -> 48 25 id   (sign-extended imm32; we only use it with a
# mask whose top bit is clear, i.e. 2^k-1 for k<=30, see pow2-mod gating).
def emit_and_imm_rax(v: uint64):
    emit_b(0x48)
    emit_b(0x25)
    emit_imm32(v)


# movq %rax, %rsi  -> 48 89 C6   (stash the dividend; %rsi is caller-saved and
# never in the regalloc pool {rbx,r12-r15}, and the strength-reduction
# sequence makes NO calls, so %rsi is a safe transient).
def emit_mov_rax_rsi():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xC6)


# movq %rsi, %rax  -> 48 89 F0
def emit_mov_rsi_rax():
    emit_b(0x48)
    emit_b(0x89)
    emit_b(0xF0)


# subq %rdx, %rax  -> 48 29 D0
def emit_sub_rdx_rax():
    emit_b(0x48)
    emit_b(0x29)
    emit_b(0xD0)


# addq %rdx, %rax  -> 48 01 D0
def emit_add_rdx_rax():
    emit_b(0x48)
    emit_b(0x01)
    emit_b(0xD0)


# addq %rsi, %rax  -> 48 01 F0   (q += n, for the signed magic correction)
def emit_add_rsi_rax():
    emit_b(0x48)
    emit_b(0x01)
    emit_b(0xF0)


# subq %rsi, %rax  -> 48 29 F0   (q -= n, for the signed magic correction)
def emit_sub_rsi_rax():
    emit_b(0x48)
    emit_b(0x29)
    emit_b(0xF0)


# Load a 64-bit immediate into %rcx (the reciprocal multiplier / divisor).
# Uses the sign-extended imm32 form when it fits, else movabsq, mirroring
# emit_mov_imm_rax. movabsq $imm64,%rcx -> 48 B9 <imm64>;
# movq $imm32(sx),%rcx -> 48 C7 C1 <imm32>.
def emit_mov_imm_rax_to_rcx(v: uint64):
    if v <= cast[uint64](0x7FFFFFFF) or v >= cast[uint64](0xFFFFFFFF80000000):
        emit_b(0x48)
        emit_b(0xC7)
        emit_b(0xC1)
        emit_imm32(v)
        return
    emit_b(0x48)
    emit_b(0xB9)
    emit_imm64(v)


# -----------------------------------------------------------------------
# Magic-number derivation (Granlund-Montgomery / Hacker's Delight ch.10).
# Returns are passed through module globals (Adder has no multi-return).
# All loops operate on non-negative quantities < 2^64 so uint64 comparisons
# are well-defined. Validated exhaustively in scripts/test_opt_strengthred.sh
# and the ADDER_OPT=1 fuzzer lane (tests/fuzz/adder_fuzzer.py div/mod cases).
# -----------------------------------------------------------------------

# Outputs of magicu()/magics():
sr_magic_M: uint64 = 0       # the reciprocal multiplier
sr_magic_add: uint32 = 0     # unsigned: 1 iff the true multiplier is M + 2^64
sr_magic_sh: uint32 = 0      # post-multiply right-shift amount


# True iff v is a power of two (v != 0 and only one bit set).
def sr_is_pow2(v: uint64) -> uint32:
    if v == cast[uint64](0):
        return 0
    if (v & (v - cast[uint64](1))) == cast[uint64](0):
        return 1
    return 0


# log2 of a power-of-two value (count of trailing zeros).
def sr_log2(v: uint64) -> uint32:
    k: uint32 = 0
    x: uint64 = v
    while (x & cast[uint64](1)) == cast[uint64](0):
        x = x >> 1
        k = k + 1
    return k


# Unsigned magic for a 64-bit divisor d (d >= 3, not a power of two).
# Writes sr_magic_M / sr_magic_add / sr_magic_sh. Algorithm = Hacker's
# Delight Fig.10-1 (magicu), generalized to N=64.
def sr_magicu(d: uint64):
    one: uint64 = cast[uint64](1)
    two_nm1: uint64 = one << 63                       # 2^(N-1)
    # nc = ((2^N) // d) * d - 1, computed without 2^64 overflow:
    #      (2^N - 1) - ((2^N - 1) % d)
    allones: uint64 = cast[uint64](0) - one           # 2^64 - 1
    nc: uint64 = allones - (allones % d)
    p: uint32 = 63                                     # N-1
    q1: uint64 = two_nm1 / nc
    r1: uint64 = two_nm1 - q1 * nc
    q2: uint64 = (two_nm1 - one) / d
    r2: uint64 = (two_nm1 - one) - q2 * d
    # q2 can legitimately need 65 bits during the loop (the "add" divisors).
    # We track q2 MOD 2^64 (its natural uint64 wrap) and record the 65th-bit
    # carry in `ovf`; the stored magic M is the low 64 bits and `add` = ovf.
    # The emitted add-form sequence (n - q0 correction) uses exactly this
    # low-64 M (validated instruction-faithfully in test_opt_strengthred.sh).
    ovf: uint32 = 0
    loop_again: uint32 = 1
    while loop_again != 0:
        p = p + 1
        # q1,r1 := (2*q1[,+1]) with denominator nc
        if r1 >= nc - r1:
            q1 = q1 + q1 + one
            r1 = r1 + r1 - nc
        else:
            q1 = q1 + q1
            r1 = r1 + r1
        # q2,r2 := (2*q2[,+1]) with denominator d, numerator carries +1.
        # Detect q2's 65th-bit overflow BEFORE the uint64 wrap.
        carry2: uint64 = cast[uint64](0)
        if (r2 + one) >= (d - r2):
            carry2 = one
        # overflow iff doubling-with-carry passes 2^64-1: 2*q2(+carry) > 2^64-1
        #   <=> q2 > (2^64-1 - carry)/2  <=> q2 >= 2^63 + carry (since values are
        #   integers). Simplest exact test on uint64: top bit of q2 set, or
        #   (q2 == 2^63-?). Use: if q2 has its high bit set, doubling overflows.
        if (q2 >> 63) != cast[uint64](0):
            ovf = 1
        if carry2 != cast[uint64](0):
            q2 = q2 + q2 + one
            r2 = r2 + r2 + one - d
        else:
            q2 = q2 + q2
            r2 = r2 + r2 + one
        delta: uint64 = d - one - r2
        # continue while p < 2N and (q1 < delta or (q1 == delta and r1 == 0))
        cont: uint32 = 0
        if p < 128:
            if q1 < delta:
                cont = 1
            elif q1 == delta:
                if r1 == cast[uint64](0):
                    cont = 1
        loop_again = cont
    sr_magic_M = q2 + one                              # low 64 bits of the multiplier
    sr_magic_add = ovf
    sr_magic_sh = p - 64


# Signed magic for a 64-bit divisor whose ABSOLUTE value is `ad` (ad >= 2, not a
# power of two), with `neg` = 1 if the real divisor is negative. Writes
# sr_magic_M (already sign-adjusted) and sr_magic_sh. Hacker's Delight Fig.10-1
# (magic), N=64. anc/q/r stay < 2^63 so uint64 math is exact.
def sr_magics(ad: uint64, neg: uint32):
    one: uint64 = cast[uint64](1)
    two_nm1: uint64 = one << 63                       # 2^(N-1) = |INT_MIN|
    t: uint64 = two_nm1
    if neg != 0:
        t = two_nm1 + one
    anc: uint64 = t - one - (t % ad)                  # t - 1 - t%ad
    p: uint32 = 63
    pw: uint64 = one << 63                             # 2^p, p starts at 63
    q1: uint64 = pw / anc
    r1: uint64 = pw - q1 * anc
    q2: uint64 = pw / ad
    r2: uint64 = pw - q2 * ad
    loop_again: uint32 = 1
    while loop_again != 0:
        p = p + 1
        q1 = q1 + q1
        r1 = r1 + r1
        if r1 >= anc:
            q1 = q1 + one
            r1 = r1 - anc
        q2 = q2 + q2
        r2 = r2 + r2
        if r2 >= ad:
            q2 = q2 + one
            r2 = r2 - ad
        delta: uint64 = ad - r2
        cont: uint32 = 0
        if q1 < delta:
            cont = 1
        elif q1 == delta:
            if r1 == cast[uint64](0):
                cont = 1
        loop_again = cont
    m: uint64 = q2 + one
    if neg != 0:
        m = cast[uint64](0) - m                        # negate (two's complement)
    sr_magic_M = m
    sr_magic_sh = p - 64


# A compile-time integer constant detected as a divisor: its raw 64-bit bits.
sr_const_val: uint64 = 0


# 1 iff AST node `n` is a compile-time integer constant suitable as a divisor:
# a plain ND_INT_LIT / ND_CHAR_LIT (value in nd_num), or UNOP_NEG of one (the
# parser keeps `-3` as UNOP_NEG(INT_LIT 3); the const-fold pass does not collapse
# it). Writes the constant's two's-complement 64-bit value to sr_const_val.
# These node kinds are pure (no side effects, no faults), so the caller may emit
# the dividend WITHOUT evaluating this operand.
def sr_node_is_intlit(n: uint32) -> uint32:
    k: uint32 = nd_kind[n]
    if k == ND_INT_LIT or k == ND_CHAR_LIT:
        sr_const_val = nd_num[n]
        return 1
    if k == ND_UNARY:
        if nd_aux[n] == UNOP_NEG:
            inner: uint32 = nd_a[n]
            ik: uint32 = nd_kind[inner]
            if ik == ND_INT_LIT or ik == ND_CHAR_LIT:
                sr_const_val = cast[uint64](0) - nd_num[inner]
                return 1
    return 0


# Emit the strength-reduced sequence for `(value in %rax) OP d`, where OP is
# DIV/IDIV (-> want_mod==0) or MOD (-> want_mod==1), `d` is the literal divisor
# (raw 64-bit bits as stored by the parser), and `signed_op` selects signed vs
# unsigned semantics. Returns 1 if it emitted a reduced sequence, 0 if the
# caller must fall back to the normal idiv/div path (d==0, or an unhandled case).
# On entry %rax = dividend; on exit %rax = quotient (or remainder if want_mod).
def gen_div_const(d_bits: uint64, signed_op: uint32, want_mod: uint32) -> uint32:
    if d_bits == cast[uint64](0):
        return 0                                       # div-by-zero: keep the trap
    if signed_op == 0:
        return gen_udiv_const(d_bits, want_mod)
    return gen_sdiv_const(d_bits, want_mod)


# Unsigned dividend / constant d (already known != 0).
def gen_udiv_const(d: uint64, want_mod: uint32) -> uint32:
    one: uint64 = cast[uint64](1)
    if d == one:
        # x/1 = x ; x%1 = 0
        if want_mod != 0:
            emit_mov_imm_rax(cast[uint64](0))
        opt_strengthred_count = opt_strengthred_count + 1
        return 1
    if sr_is_pow2(d) != 0:
        k: uint32 = sr_log2(d)
        if want_mod != 0:
            # x % 2^k = x & (2^k - 1). Use the imm32 AND only when the mask
            # fits a positive sign-extended imm32 (k <= 30); else build the
            # mask in %rcx and AND. Keep it simple+correct: k<=30 fast path,
            # else fall through to magic-free shift pair.
            if k <= 30:
                emit_and_imm_rax(d - one)
                opt_strengthred_count = opt_strengthred_count + 1
                return 1
            # large mask: shl k then shr k clears the low... no: we want low
            # bits. mask = 2^k-1 in %rcx via mov; and. Use mov_imm to %rcx.
            emit_mov_imm_rax_to_rcx(d - one)
            emit_and_rcx_rax()
            opt_strengthred_count = opt_strengthred_count + 1
            return 1
        emit_shr_imm_rax(k)
        opt_strengthred_count = opt_strengthred_count + 1
        return 1
    if (d >> 63) != cast[uint64](0):
        # d >= 2^63 (high bit set, non-power-of-two): the Granlund-Montgomery
        # derivation's intermediates would need a 65th-bit reciprocal, which the
        # uint64 magic loop cannot represent. But for such a large divisor the
        # unsigned quotient of any 64-bit dividend is exactly 0 or 1
        # (n < 2^64 <= 2*d), so emit the trivial compare:
        #   q = (n >= d) ? 1 : 0   (unsigned)   ;   r = n - q*d
        # (n is in %rax.) This is correct and branch-free.
        emit_mov_rax_rsi()                             # %rsi = n
        emit_mov_imm_rax_to_rcx(d)                     # %rcx = d
        emit_cmp_rcx_rax()                             # flags for n - d
        emit_setcc_al(0x93)                            # setae -> AL = (n >= d) ? 1 : 0
        emit_movzx_al_rax()                            # %rax = q (0 or 1)
        if want_mod != 0:
            # r = n - q*d :  q in %rax ; d in %rcx ; imul ; n - (q*d)
            emit_mov_imm_rax_to_rcx(d)
            emit_imul_rcx_rax()                        # %rax = q*d
            emit_mov_rax_rcx()                         # %rcx = q*d
            emit_mov_rsi_rax()                         # %rax = n
            emit_sub_rcx_rax()                         # %rax = n - q*d
        opt_strengthred_count = opt_strengthred_count + 1
        return 1
    # General unsigned magic (d in [3, 2^63), not a power of two).
    sr_magicu(d)
    M: uint64 = sr_magic_M
    add: uint32 = sr_magic_add
    sh: uint32 = sr_magic_sh
    # The add-path needs n preserved across the multiply; so does want_mod.
    if want_mod != 0 or add != 0:
        emit_mov_rax_rsi()                             # %rsi = n
    if add == 0:
        # q = mulhu(n, M); q >>= sh
        emit_mov_imm_rax_to_rcx(M)
        emit_mul_rcx()                                 # %rdx:%rax = n*M
        emit_mov_rdx_rax()                             # %rax = high = q
        if sh != 0:
            emit_shr_imm_rax(sh)
    else:
        # true multiplier = M + 2^64. q0 = mulhu(n,M);
        # q = (((n - q0) >> 1) + q0) >> (sh-1)
        emit_mov_imm_rax_to_rcx(M)
        emit_mul_rcx()                                 # %rdx = q0 (high), %rax = low
        emit_mov_rsi_rax()                             # %rax = n
        emit_sub_rdx_rax()                             # %rax = n - q0
        emit_shr_imm_rax(1)                            # (n - q0) >> 1
        emit_add_rdx_rax()                             # + q0
        if sh >= 1:
            emit_shr_imm_rax(sh - 1)
    if want_mod != 0:
        # remainder = n - q*d :  %rax = q ; rcx = d ; imul ; sub from n
        emit_mov_imm_rax_to_rcx(d)
        emit_imul_rcx_rax()                            # %rax = q*d (low 64 = exact)
        emit_mov_rax_rcx()                             # %rcx = q*d
        emit_mov_rsi_rax()                             # %rax = n
        emit_sub_rcx_rax()                             # %rax = n - q*d
    opt_strengthred_count = opt_strengthred_count + 1
    return 1


# Signed dividend / constant d (already known != 0). d_bits are the raw bits.
def gen_sdiv_const(d_bits: uint64, want_mod: uint32) -> uint32:
    one: uint64 = cast[uint64](1)
    neg: uint32 = 0
    d: uint64 = d_bits
    if (d_bits >> 63) != cast[uint64](0):
        neg = 1
        d = cast[uint64](0) - d_bits                   # |d|
    if d == one:
        # x/1 = x ; x/-1 = -x ; x%(+-1) = 0
        if want_mod != 0:
            emit_mov_imm_rax(cast[uint64](0))
        else:
            if neg != 0:
                emit_neg_rax()
        opt_strengthred_count = opt_strengthred_count + 1
        return 1
    if sr_is_pow2(d) != 0:
        k: uint32 = sr_log2(d)
        # round-toward-zero correction for signed pow2:
        #   t = (n >>s 63) >>u (64-k)   (= (2^k-1) if n<0 else 0)
        #   q = (n + t) >>s k ;  negate if d<0
        if want_mod != 0:
            emit_mov_rax_rsi()                         # save n
        emit_mov_rax_rcx()                             # %rcx = n (preserve)
        emit_sar_imm_rax(63)                           # %rax = n>>s63 (all 1s if neg)
        emit_shr_imm_rax(64 - k)                       # %rax = 2^k-1 if neg else 0
        emit_add_rcx_rax()                             # %rax = n + t
        emit_sar_imm_rax(k)                            # %rax = q (>>s k)
        if neg != 0:
            emit_neg_rax()
        if want_mod != 0:
            emit_mov_imm_rax_to_rcx(d_bits)
            emit_imul_rcx_rax()                        # q*d
            emit_mov_rax_rcx()
            emit_mov_rsi_rax()
            emit_sub_rcx_rax()                         # n - q*d
        opt_strengthred_count = opt_strengthred_count + 1
        return 1
    # General signed magic.
    sr_magics(d, neg)
    M: uint64 = sr_magic_M
    sh: uint32 = sr_magic_sh
    # %rsi = n, preserved across the whole sequence (needed for the +/-n
    # correction and, if want_mod, for n - q*d).
    emit_mov_rax_rsi()
    emit_mov_imm_rax_to_rcx(M)
    emit_imul1_rcx()                                   # %rdx:%rax = n*M (signed)
    emit_mov_rdx_rax()                                 # %rax = q0 = mulhs(n,M)
    # Correction: d>0 and M<0 (high bit set) -> q += n ;
    #             d<0 and M>0 (high bit clear) -> q -= n.
    if neg == 0:
        if (M >> 63) != cast[uint64](0):
            emit_add_rsi_rax()                         # q += n
    else:
        if (M >> 63) == cast[uint64](0):
            emit_sub_rsi_rax()                         # q -= n
    if sh != 0:
        emit_sar_imm_rax(sh)                           # %rax = q (arithmetic shift)
    # Add the sign bit: q += (q < 0 ? 1 : 0) == q + ((unsigned)q >> 63).
    #   %rcx = q ; %rax = (unsigned q)>>63 ; %rax = q + that.
    emit_mov_rax_rcx()                                 # %rcx = q
    emit_shr_imm_rax(63)                               # %rax = 0/1 (logical shift)
    emit_add_rcx_rax()                                 # %rax = quotient
    if want_mod != 0:
        emit_mov_imm_rax_to_rcx(d_bits)
        emit_imul_rcx_rax()                            # %rax = q*d (low 64 exact)
        emit_mov_rax_rcx()                             # %rcx = q*d
        emit_mov_rsi_rax()                             # %rax = n
        emit_sub_rcx_rax()                             # %rax = n - q*d
    opt_strengthred_count = opt_strengthred_count + 1
    return 1


# notq %rax  -> 48 F7 D0
def emit_not_rax():
    emit_b(0x48)
    emit_b(0xF7)
    emit_b(0xD0)


# =======================================================================
# IR scratch-register variants: `op %<src>, %rax` where %<src> is a CALLEE-SAVED
# scratch register (encoding 3 / 12..15) instead of %rcx. These let the IR
# emitter hold a binary op's RIGHT operand in a register across the LEFT-operand
# evaluation, eliminating the `push %rax`/`pop %rcx` stack round-trip per node.
#
# Each is the EXACT byte-equivalent of its `_rcx_rax` sibling with the source
# register field swapped from %rcx(1) to %<src>. For the "reg,r/m" form opcodes
# (ADD/SUB/AND/OR/XOR/CMP, opcode byte then modrm `11 src rax`) the SOURCE is the
# modrm REG field, so it needs REX.R (0x44) when src>=8 and modrm reg bits
# (src&7)<<3. For IMUL (`reg <- reg op r/m`, modrm `11 rax src`) the source is the
# modrm R/M field, so it needs REX.B (0x41) when src>=8 and modrm r/m bits (src&7).
# A src of %rcx is NEVER passed here (the caller routes %rcx through the legacy
# helpers); these only ever see a pool encoding 3/12..15, all of which produce a
# REX prefix (rbx=3 needs none of R/B but still emits the 0x48 W byte; r12..r15
# set the extension bit). The result equals what the equivalent `mov %<src>,%rcx`
# + `op %rcx,%rax` pair would compute, with one fewer instruction and no stack.

# REX.W prefix for an "op reg(src),rax(r/m)" form: 0x48 base, +0x04 (REX.R) when
# the source register is r8..r15 (src>=8) to extend the modrm REG field.
def ir_rex_src_reg(src: uint32) -> uint32:
    if src >= 8:
        return 0x4C                       # REX.W + REX.R
    return 0x48                            # REX.W


# modrm for "op %<src>, %rax": mod=11, reg=src (the source), r/m=rax(0).
def ir_modrm_src_rax(src: uint32) -> uint32:
    return 0xC0 + ((src & 7) << 3)


# addq %<src>, %rax   (sibling of emit_add_rcx_rax = 48 01 C8).
def emit_add_src_rax(src: uint32):
    emit_b(ir_rex_src_reg(src))
    emit_b(0x01)
    emit_b(ir_modrm_src_rax(src))


# subq %<src>, %rax   (sibling of emit_sub_rcx_rax = 48 29 C8).
def emit_sub_src_rax(src: uint32):
    emit_b(ir_rex_src_reg(src))
    emit_b(0x29)
    emit_b(ir_modrm_src_rax(src))


# andq %<src>, %rax   (sibling of emit_and_rcx_rax = 48 21 C8).
def emit_and_src_rax(src: uint32):
    emit_b(ir_rex_src_reg(src))
    emit_b(0x21)
    emit_b(ir_modrm_src_rax(src))


# orq %<src>, %rax    (sibling of emit_or_rcx_rax = 48 09 C8).
def emit_or_src_rax(src: uint32):
    emit_b(ir_rex_src_reg(src))
    emit_b(0x09)
    emit_b(ir_modrm_src_rax(src))


# xorq %<src>, %rax   (sibling of emit_xor_rcx_rax = 48 31 C8).
def emit_xor_src_rax(src: uint32):
    emit_b(ir_rex_src_reg(src))
    emit_b(0x31)
    emit_b(ir_modrm_src_rax(src))


# cmpq %<src>, %rax   (sibling of emit_cmp_rcx_rax = 48 39 C8).
def emit_cmp_src_rax(src: uint32):
    emit_b(ir_rex_src_reg(src))
    emit_b(0x39)
    emit_b(ir_modrm_src_rax(src))


# imulq %<src>, %rax  (sibling of emit_imul_rcx_rax = 48 0F AF C1). IMUL's source
# is the modrm R/M field, so use REX.B (0x41) when src>=8 and r/m bits (src&7);
# the dest (%rax) stays the modrm REG field (0).
def emit_imul_src_rax(src: uint32):
    if src >= 8:
        emit_b(0x49)                      # REX.W + REX.B
    else:
        emit_b(0x48)                      # REX.W
    emit_b(0x0F)
    emit_b(0xAF)
    emit_b(0xC0 + (src & 7))              # modrm: 11 rax(000) src(r/m)


# =======================================================================
# MEMORY-SOURCE ALU folds (--opt, Phase 3 alu-load). `op (%rcx), %rax`:
# combine the destination %rax with a memory source operand whose ADDRESS
# is held in %rcx, in one instruction — eliding the separate load-to-temp
# + reg-reg op the AST/IR path would otherwise emit for `left OP arr[i]`.
#
# %rcx (encoding 001) is the address base: ModRM mod=00, reg=%rax(000),
# r/m=001 (%rcx) is a plain register-indirect with NO SIB and NO RIP-relative
# ambiguity (those only afflict r/m=100/101). The dest %rax stays the ModRM
# REG field, so the computed VALUE equals `mov (%rcx),%rcx; op %rcx,%rax`
# with one fewer instruction and no scratch round-trip. ONLY emitted for an
# 8-byte (full-width) integer memory element, so the implicit 64-bit fetch
# carries no truncation/sign-extension hazard — a sub-8-byte element must
# still go through the sized (sign/zero-extending) load on the normal path.
#   addq (%rcx),%rax -> 48 03 01
def emit_add_mem_rcx_rax():
    emit_b(0x48)
    emit_b(0x03)
    emit_b(0x01)                          # mod=00 reg=rax(000) r/m=rcx(001)


# subq (%rcx),%rax -> 48 2B 01
def emit_sub_mem_rcx_rax():
    emit_b(0x48)
    emit_b(0x2B)
    emit_b(0x01)


# andq (%rcx),%rax -> 48 23 01
def emit_and_mem_rcx_rax():
    emit_b(0x48)
    emit_b(0x23)
    emit_b(0x01)


# orq (%rcx),%rax  -> 48 0B 01
def emit_or_mem_rcx_rax():
    emit_b(0x48)
    emit_b(0x0B)
    emit_b(0x01)


# xorq (%rcx),%rax -> 48 33 01
def emit_xor_mem_rcx_rax():
    emit_b(0x48)
    emit_b(0x33)
    emit_b(0x01)


# cmpq (%rcx),%rax -> 48 3B 01  (computes %rax - (%rcx), sets flags; %rax kept)
def emit_cmp_mem_rcx_rax():
    emit_b(0x48)
    emit_b(0x3B)
    emit_b(0x01)


# imulq (%rcx),%rax -> 48 0F AF 01  (%rax <- %rax * (%rcx); dest=ModRM reg=rax)
def emit_imul_mem_rcx_rax():
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0xAF)
    emit_b(0x01)                          # mod=00 reg=rax(000) r/m=rcx(001)


# setz %al  -> 0F 94 C0  (alias of sete; used by logical NOT)
# setne %al -> 0F 95 C0
# setne %cl -> 0F 95 C1
def emit_setne_cl():
    emit_b(0x0F)
    emit_b(0x95)
    emit_b(0xC1)


# movzbq %cl, %rcx  -> 48 0F B6 C9  (bool-ify %rcx for logical and/or)
def emit_movzx_cl_rcx():
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0xB6)
    emit_b(0xC9)


# =======================================================================
# Scalar SSE floating point (mirrors codegen_x86's FP emitters).
# FP values transit %rax/%rcx as their raw IEEE bit pattern; SSE registers
# %xmm0/%xmm1 are used only at the op site. Byte encodings are the standard
# SysV AMD64 SSE/SSE2 forms, matching the GNU `as` output codegen_x86 emits.
# =======================================================================

# movd %eax, %xmm0   -> 66 0F 6E C0   (low 32 bits of %rax -> xmm0)
def emit_movd_eax_xmm0():
    emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC0)


# movd %ecx, %xmm1   -> 66 0F 6E C9
def emit_movd_ecx_xmm1():
    emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC9)


# movd %xmm0, %eax   -> 66 0F 7E C0   (xmm0 low 32 -> %eax, zero-extends %rax)
def emit_movd_xmm0_eax():
    emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x7E)
    emit_b(0xC0)


# movq %rax, %xmm0   -> 66 48 0F 6E C0
def emit_movq_rax_xmm0():
    emit_b(0x66)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC0)


# movq %rcx, %xmm1   -> 66 48 0F 6E C9
def emit_movq_rcx_xmm1():
    emit_b(0x66)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x6E)
    emit_b(0xC9)


# movq %xmm0, %rax   -> 66 48 0F 7E C0
def emit_movq_xmm0_rax():
    emit_b(0x66)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x7E)
    emit_b(0xC0)


# Move the low `width` bytes of %rax into %xmm0 (movd for 4, movq for 8).
def emit_gpr_rax_to_xmm0(width: uint32):
    if width == 4:
        emit_movd_eax_xmm0()
    else:
        emit_movq_rax_xmm0()


# Move the low `width` bytes of %rcx into %xmm1.
def emit_gpr_rcx_to_xmm1(width: uint32):
    if width == 4:
        emit_movd_ecx_xmm1()
    else:
        emit_movq_rcx_xmm1()


# Move the FP bits in %xmm0 back into %rax (width 4 zero-extends via movd).
def emit_xmm0_to_gpr_rax(width: uint32):
    if width == 4:
        emit_movd_xmm0_eax()
    else:
        emit_movq_xmm0_rax()


# SSE scalar arithmetic OP %xmm1, %xmm0 (result in %xmm0). `width` picks the
# SS (4) vs SD (8) form (prefix F3 vs F2); `op2` is the second opcode byte:
# add=58 sub=5C mul=59 div=5E.
def emit_sse_arith(op2: uint32, width: uint32):
    if width == 4:
        emit_b(0xF3)
    else:
        emit_b(0xF2)
    emit_b(0x0F)
    emit_b(op2)
    emit_b(0xC1)


# ucomiss/ucomisd %xmm1, %xmm0 -> [66] 0F 2E C1  (sd has the 66 prefix).
def emit_ucomi(width: uint32):
    if width == 8:
        emit_b(0x66)
    emit_b(0x0F)
    emit_b(0x2E)
    emit_b(0xC1)


# cvtsi2ss/sd %rax, %xmm0 -> F3/F2 48 0F 2A C0  (signed 64-bit int -> float).
def emit_cvtsi2f(width: uint32):
    if width == 4:
        emit_b(0xF3)
    else:
        emit_b(0xF2)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x2A)
    emit_b(0xC0)


# cvttss2si/cvttsd2si %xmm0, %rax -> F3/F2 48 0F 2C C0  (float -> int, trunc).
def emit_cvttf2si(width: uint32):
    if width == 4:
        emit_b(0xF3)
    else:
        emit_b(0xF2)
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0x2C)
    emit_b(0xC0)


# cvtss2sd %xmm0, %xmm0 -> F3 0F 5A C0   (float32 -> float64)
def emit_cvtss2sd():
    emit_b(0xF3)
    emit_b(0x0F)
    emit_b(0x5A)
    emit_b(0xC0)


# cvtsd2ss %xmm0, %xmm0 -> F2 0F 5A C0   (float64 -> float32)
def emit_cvtsd2ss():
    emit_b(0xF2)
    emit_b(0x0F)
    emit_b(0x5A)
    emit_b(0xC0)


# set<cc> %cl  -> 0F <opc> C1   (for the parity-guard second condition)
def emit_setcc_cl(opc: uint32):
    emit_b(0x0F)
    emit_b(opc)
    emit_b(0xC1)


# andb %cl, %al  -> 20 C8     (combine ZF/CF result with the not-parity guard)
def emit_and_cl_al():
    emit_b(0x20)
    emit_b(0xC8)


# orb %cl, %al   -> 08 C8     (combine for the != / unordered case)
def emit_or_cl_al():
    emit_b(0x08)
    emit_b(0xC8)


# xorl $0x80000000, %eax  -> 35 00 00 00 80   (flip float32 sign bit)
def emit_xor_eax_signbit32():
    emit_b(0x35)
    emit_imm32(cast[uint64](0x80000000))


# movabsq $0x8000000000000000, %rcx ; xorq %rcx, %rax  (flip float64 sign bit)
#   48 B9 <imm64>   then   48 31 C8
def emit_xor_rax_signbit64():
    emit_b(0x48)
    emit_b(0xB9)
    emit_imm64(cast[uint64](0x8000000000000000))
    emit_b(0x48)
    emit_b(0x31)
    emit_b(0xC8)


# =======================================================================
# Higher-level scalar-FP codegen (mirrors codegen_x86's _emit_fp_*).
# =======================================================================

# Convert the value in %rax to a float of `dst_w` bytes, leaving its bit
# pattern in %rax. `src_w` is the source float width (0 = an integer source,
# 4/8 = a float source). Mirrors codegen_x86._emit_fp_convert / _emit_operand
# _to_float (the int<->float and float<->float cases).
def emit_fp_convert(src_w: uint32, dst_w: uint32):
    if dst_w != 0:
        # ... target is a float.
        if src_w == 0:
            # int -> float: cvtsi2ss/sd from the 64-bit signed %rax.
            emit_cvtsi2f(dst_w)
            emit_xmm0_to_gpr_rax(dst_w)
            return
        if src_w == dst_w:
            return                      # same float width: no-op
        emit_gpr_rax_to_xmm0(src_w)
        if src_w == 4:
            emit_cvtss2sd()             # float32 -> float64
        else:
            emit_cvtsd2ss()             # float64 -> float32
        emit_xmm0_to_gpr_rax(dst_w)
        return
    # target is an integer (src_w must be a float here): float -> int (trunc),
    # leaving a 64-bit signed int in %rax (caller narrows for sub-8-byte ints).
    emit_gpr_rax_to_xmm0(src_w)
    emit_cvttf2si(src_w)


# %rax holds an operand's value (FP bits if `src_w` != 0, else an integer);
# convert it to a float of `width` bytes in place. Mirrors codegen_x86's
# _emit_operand_to_float.
def emit_operand_to_float(src_w: uint32, width: uint32):
    if src_w == width:
        return
    emit_fp_convert(src_w, width)


# %rax = left bits, %rcx = right bits. Compute the FP op `op` at `width` and
# leave the result bits in %rax. Mirrors codegen_x86._emit_fp_binop +
# _emit_fp_setcc (NaN-unordered-correct compares).
def emit_fp_binop(op: uint32, width: uint32):
    emit_gpr_rax_to_xmm0(width)
    emit_gpr_rcx_to_xmm1(width)
    if op == BINOP_ADD:
        emit_sse_arith(0x58, width)
        emit_xmm0_to_gpr_rax(width)
        return
    if op == BINOP_SUB:
        emit_sse_arith(0x5C, width)
        emit_xmm0_to_gpr_rax(width)
        return
    if op == BINOP_MUL:
        emit_sse_arith(0x59, width)
        emit_xmm0_to_gpr_rax(width)
        return
    if op == BINOP_DIV or op == BINOP_IDIV:
        emit_sse_arith(0x5E, width)
        emit_xmm0_to_gpr_rax(width)
        return
    # Compares: ucomi sets CF/ZF (unsigned-style) + PF on unordered (NaN).
    # Pick condition codes so a NaN-unordered compare yields the IEEE result.
    emit_ucomi(width)
    if op == BINOP_GT:
        emit_setcc_al(0x97)             # seta
        emit_movzx_al_rax()
        return
    if op == BINOP_GTE:
        emit_setcc_al(0x93)             # setae
        emit_movzx_al_rax()
        return
    if op == BINOP_LT:
        emit_setcc_al(0x92)             # setb
        emit_setcc_cl(0x9B)             # setnp %cl  (ordered guard)
        emit_and_cl_al()
        emit_movzx_al_rax()
        return
    if op == BINOP_LTE:
        emit_setcc_al(0x96)             # setbe
        emit_setcc_cl(0x9B)             # setnp %cl
        emit_and_cl_al()
        emit_movzx_al_rax()
        return
    if op == BINOP_EQ:
        emit_setcc_al(0x94)             # sete
        emit_setcc_cl(0x9B)             # setnp %cl  (ordered guard)
        emit_and_cl_al()
        emit_movzx_al_rax()
        return
    if op == BINOP_NEQ:
        emit_setcc_al(0x95)             # setne
        emit_setcc_cl(0x9A)             # setp %cl   (unordered -> != true)
        emit_or_cl_al()
        emit_movzx_al_rax()
        return
    cg_fail(1, 0)


# Generate a scalar-SSE FP binop/compare for an ND_BINARY whose operand(s)
# are float. Operand width is the wider of the two float widths (an integer
# operand promotes to that width). Eval/spill order is byte-identical to the
# integer gen_binary path. Mirrors codegen_x86._gen_fp_binary.
def gen_fp_binary(node: uint32, op: uint32, lw: uint32, rw: uint32):
    width: uint32 = lw
    if rw > width:
        width = rw
    if width == 0:
        width = 8
    # Right operand first, convert to float width, spill.
    gen_expr(nd_b[node])
    emit_operand_to_float(expr_float_width(nd_b[node]), width)
    emit_push_rax()
    # Left operand, convert to float width.
    gen_expr(nd_a[node])
    emit_operand_to_float(expr_float_width(nd_a[node]), width)
    emit_pop_rcx()
    emit_fp_binop(op, width)


# Re-extend the low `size` bytes of %rax to a full 64-bit register,
# zero-extending when `is_signed` is 0 and sign-extending when it is 1.
# Mirrors codegen_x86._emit_cast_widen's narrowing branch EXACTLY:
#   unsigned: movzbq %al,%rax / movzwq %ax,%rax / movl %eax,%eax
#   signed:   movsbq %al,%rax / movswq %ax,%rax / movslq %eax,%rax
# `size` 8 (or anything else) is a no-op (the value already fills %rax).
# This is the truncation that makes cast[uint8](300) == 44 etc. — without
# it the upper bits leak into a later wider store / 64-bit compare / fold,
# which is precisely one of the Track-2 fuzzer's fixed miscompiles.
def emit_ext_rax(size: uint32, is_signed: uint32):
    if size == 1:
        if is_signed != 0:
            # movsbq %al, %rax -> 48 0F BE C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xBE)
            emit_b(0xC0)
        else:
            # movzbq %al, %rax -> 48 0F B6 C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xB6)
            emit_b(0xC0)
    elif size == 2:
        if is_signed != 0:
            # movswq %ax, %rax -> 48 0F BF C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xBF)
            emit_b(0xC0)
        else:
            # movzwq %ax, %rax -> 48 0F B7 C0
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xB7)
            emit_b(0xC0)
    elif size == 4:
        if is_signed != 0:
            # movslq %eax, %rax -> 48 63 C0
            emit_b(0x48)
            emit_b(0x63)
            emit_b(0xC0)
        else:
            # movl %eax, %eax -> 89 C0  (auto-zeroes the high 32 bits)
            emit_b(0x89)
            emit_b(0xC0)
    # size 8 (or unknown): no-op; %rax already holds the value.


# Return 1 if the primitive type node `tnode` is an UNSIGNED integer type
# (uint8/16/32/64, bool, char), 0 otherwise (signed ints / float / non-prim).
# Mirrors the signedness split codegen_x86 derives from type names.
def type_is_unsigned(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    code: uint32 = nd_aux[tnode]
    # 6=uint8 7=uint16 8=uint32 9=uint64 12=bool 13=char  -> unsigned
    if code == 6 or code == 7 or code == 8 or code == 9:
        return 1
    if code == 12 or code == 13:
        return 1
    return 0


# Frame-access displacement encoding is HYBRID: a slot whose %rbp offset
# fits in a signed byte (-128..0) uses the compact disp8 (mod=01) form;
# anything beyond -128 uses disp32 (mod=10). This is REQUIRED for the
# self-host fixpoint — the compiler's own large functions have frames far
# past 128 bytes — while keeping byte-IDENTICAL output for small functions
# (so the codegen selftest's hardcoded offsets stay valid).
#
# Low-32-bit mask + the low-32 form of -128 (0xFFFFFF80). These are stored
# as full-width .data globals (NOT loaded as sign-extended imm32 — the
# `48 C7 C0` immediate form can't represent values above 0x7FFFFFFF), so
# referencing them yields the exact 64-bit constant regardless of backend.
DISP_LOW32_MASK: uint64 = 4294967295        # 0xFFFFFFFF
DISP_NEG128_LOW32: uint64 = 4294967168      # 0xFFFFFF80  (-128 as low-32)


# A disp8-reachable offset (a signed byte, -128..127). Frame offsets are
# <= 0, but we test the full signed-byte range anyway.
#
# SIGN-SAFE: this is on the self-host fixpoint critical path. The Adder and
# Python backends differ in how they materialise a sub-64-bit signed scalar
# in a 64-bit register (Python: `movl` store + `movslq` sign-extending load;
# Adder: a plain 64-bit `movq` store/load), so a NEGATIVE `int32` like a
# frame offset can reach this function with its high 32 bits either
# sign-extended OR zeroed depending on which backend compiled THIS code. A
# direct signed `off >= -128` therefore gives different answers across the
# two compilations (it was the SOLE cause of stage1!=stage2: stage2 lost
# every disp32). We normalise by masking to the low 32 bits first, then test
# the disp8-fits ranges in that canonical low-32 form — an answer invariant
# to the high bits, hence identical under both backends.
def disp_fits8(off: int32) -> int32:
    u: uint64 = cast[uint64](off) & DISP_LOW32_MASK
    if u <= 127:                 # 0..127  (zero / small positive)
        return 1
    if u >= DISP_NEG128_LOW32:   # 0xFFFFFF80..0xFFFFFFFF  (-128..-1)
        return 1
    return 0


# Emit a 32-bit little-endian frame displacement (the signed %rbp offset).
def emit_disp32(off: int32):
    d: uint32 = cast[uint32](off)
    emit_b(d & 255)
    emit_b((d >> 8) & 255)
    emit_b((d >> 16) & 255)
    emit_b((d >> 24) & 255)


# Emit a [%rbp]-based modrm + displacement for a frame access. `rbp_modrm8`
# is the mod=01 (disp8) modrm byte (reg field already set, base=rbp); for
# the disp32 form we add 0x40 (mod 01 -> 10) and append a 4-byte disp.
def emit_rbp_mem(rbp_modrm8: uint32, off: int32):
    if disp_fits8(off) != 0:
        emit_b(rbp_modrm8)
        emit_b(cast[uint32](off) & 255)
    else:
        emit_b(rbp_modrm8 + 0x40)
        emit_disp32(off)


# leaq off(%rbp), %rax  -> 48 8D {45 disp8 | 85 disp32}  (frame-slot address)
def emit_lea_local_rax(off: int32):
    emit_b(0x48)
    emit_b(0x8D)
    emit_rbp_mem(0x45, off)


# leaq disp(%rbp, %rcx, scale), %rax  -> 48 8D <modrm> <SIB> <disp>
# A scaled-index frame-array element address folded into ONE lea (isel).
#   REX.W = 48; opcode 8D (lea); reg field = %rax (000).
#   ModRM rm = 100 selects a SIB byte; mod = 01 (disp8) or 10 (disp32) because
#   the %rbp base (SIB base = 101) cannot be encoded with mod=00.
#   SIB = scale(2) << 6 | index(%rcx=001) << 3 | base(%rbp=101).
# `sbits` is the SIB scale field (0/1/2/3 for *1/*2/*4/*8).
def emit_lea_local_sib_rax(off: int32, sbits: uint32):
    emit_b(0x48)
    emit_b(0x8D)
    sib: uint32 = (sbits << 6) + (1 << 3) + 5    # scale|index=rcx|base=rbp
    if disp_fits8(off) != 0:
        emit_b(0x44)                     # mod=01, reg=rax(000), rm=100(SIB)
        emit_b(sib)
        emit_b(cast[uint32](off) & 255)
    else:
        emit_b(0x84)                     # mod=10, reg=rax(000), rm=100(SIB)
        emit_b(sib)
        emit_disp32(off)


# leaq (%rax, %rcx, scale), %rax  -> 48 8D 04 <SIB>
# Fold a scale-shift + add of an index into a base address already held in %rax
# (a rip-relative global base, or a loaded pointer value). No displacement.
#   REX.W=48; opcode 8D; ModRM = mod=00, reg=%rax(000), rm=100(SIB) -> 0x04.
#   SIB = scale(2) << 6 | index(%rcx=001) << 3 | base(%rax=000).
def emit_lea_base_rax_index_rcx(sbits: uint32):
    emit_b(0x48)
    emit_b(0x8D)
    emit_b(0x04)                         # mod=00, reg=rax, rm=SIB
    emit_b((sbits << 6) + (1 << 3) + 0)  # scale|index=rcx|base=rax


# leaq <data_off>(%rip), %rax  -> 48 8D 05 <rel32>   (address of a global /
# string in the data section). The rel32 is a placeholder; a data fixup is
# recorded against the global's data offset and patched after layout, so it
# resolves to (DATA_BASE + data_off) - (rip_field_end). Mirrors
# codegen_x86.py's `leaq name(%rip),%rax`.
def emit_lea_global_rax(data_off: uint32, is_bss: uint32):
    emit_b(0x48)
    emit_b(0x8D)
    emit_b(0x05)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_data_fixup(at, data_off, is_bss)


# leaq extern_sym(%rip), %rax  -> 48 8D 05 <rel32>   (kernel target only).
# The rel32 is left 0; an EXTERN R_X86_64_PC32 relocation is recorded so `ld`
# patches it against the cross-object symbol after placement. Mirrors the
# seed's `leaq name(%rip),%rax` for `&extern`, which `as` turns into a
# PC32 reloc. The Rela addend is -4 (the disp is from the instruction END, 4
# bytes past the disp32 field start).
def emit_lea_extern_rax(sym_idx: uint32):
    emit_b(0x48)
    emit_b(0x8D)
    emit_b(0x05)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_extern_reloc(at, sym_idx, ER_PC32)


# leaq <fn>(%rip), %rax  -> 48 8D 05 <rel32>   (USER target: a bare function
# NAME used as a value decays to its CODE address — a function pointer). The
# rel32 placeholder is patched by the call-fixup resolver against the callee's
# code offset (the SAME rel32 math `call rel32` uses: target - (field_end)), so
# we register the site via add_call_fixup. Mirrors codegen_x86.gen_identifier's
# `leaq name(%rip),%rax` for a name in defined_funcs/extern_funcs. In the
# self-contained user image there is no cross-object linkage: the referenced
# function is an in-unit emitted function, resolved like a direct call.
def emit_lea_func_rax(name_off: uint32, name_len: uint32):
    emit_b(0x48)
    emit_b(0x8D)
    emit_b(0x05)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_call_fixup(at, name_off, name_len)


# Scale %rcx by a power-of-two element size via a shift (matches
# codegen_x86._emit_scale_reg's 1/2/4/8 cases). elem_size==1 is a no-op.
#   shlq $1, %rcx -> 48 D1 E1   (size 2)
#   shlq $2, %rcx -> 48 C1 E1 02 (size 4)
#   shlq $3, %rcx -> 48 C1 E1 03 (size 8)
def emit_scale_rcx(elem_size: uint32):
    if elem_size == 1:
        return                         # identity, no shift.
    if elem_size == 2:
        emit_b(0x48)
        emit_b(0xD1)
        emit_b(0xE1)
        return
    if elem_size == 4:
        emit_b(0x48)
        emit_b(0xC1)
        emit_b(0xE1)
        emit_b(0x02)
        return
    if elem_size == 8:
        emit_b(0x48)
        emit_b(0xC1)
        emit_b(0xE1)
        emit_b(0x03)
        return
    # Arbitrary (non-power-of-2) stride — the row stride of a multi-
    # dimensional array global, e.g. Array[N, Array[3, int64]] has a 24-byte
    # outer stride. Mirror codegen_x86's `imulq $elem_size, %rcx, %rcx`
    # fallback: imul rcx, rcx, imm32 == 48 69 C9 <imm32>.
    emit_b(0x48)
    emit_b(0x69)
    emit_b(0xC9)
    emit_imm32(cast[uint64](elem_size))


# Sized load from (%rax) into %rax (zero-extending), mirroring
# emit_load_sized in codegen_x86.py.
#   movzbq (%rax),%rax -> 48 0F B6 00   (size 1)
#   movzwq (%rax),%rax -> 48 0F B7 00   (size 2)
#   movl   (%rax),%eax -> 8B 00         (size 4, auto-zero-extend)
#   movq   (%rax),%rax -> 48 8B 00      (size 8)
def emit_load_mem_rax(size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB6)
        emit_b(0x00)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB7)
        emit_b(0x00)
    elif size == 4:
        emit_b(0x8B)
        emit_b(0x00)
    else:
        emit_b(0x48)
        emit_b(0x8B)
        emit_b(0x00)


# Sized SIGN-EXTENDING load of (%rax) into %rax, mirroring codegen_x86's
# emit_load_sized_signed: a sub-8-byte SIGNED scalar must sign-extend so its
# wider use carries the right two's-complement value. (Bug C in the fuzzer
# regression fixture: a negative int32 global must load as 0xFFFFFFFFFFFFFC18,
# not 0x00000000FFFFFC18.)
#   movsbq (%rax),%rax -> 48 0F BE 00   (size 1)
#   movswq (%rax),%rax -> 48 0F BF 00   (size 2)
#   movslq (%rax),%rax -> 48 63 00      (size 4)
# size 8 needs no extension -> plain movq.
def emit_load_mem_rax_signed(size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBE)
        emit_b(0x00)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBF)
        emit_b(0x00)
    elif size == 4:
        emit_b(0x48)
        emit_b(0x63)
        emit_b(0x00)
    else:
        emit_b(0x48)
        emit_b(0x8B)
        emit_b(0x00)


# Sized store of %rcx into (%rax), mirroring emit_store_sized.
#   movb %cl,(%rax)  -> 88 08    (size 1)
#   movw %cx,(%rax)  -> 66 89 08 (size 2)
#   movl %ecx,(%rax) -> 89 08    (size 4)
#   movq %rcx,(%rax) -> 48 89 08 (size 8)
def emit_store_mem_rcx(size: uint32):
    if size == 1:
        emit_b(0x88)
        emit_b(0x08)
    elif size == 2:
        emit_b(0x66)
        emit_b(0x89)
        emit_b(0x08)
    elif size == 4:
        emit_b(0x89)
        emit_b(0x08)
    else:
        emit_b(0x48)
        emit_b(0x89)
        emit_b(0x08)


# movq <arg-reg>, off(%rbp)   spill a parameter into its slot.
#   movq %rdi, off(%rbp) -> 48 89 {7D disp8 | BD disp32}
#   movq %rsi, off(%rbp) -> 48 89 {75 disp8 | B5 disp32}
#   movq %rdx, off(%rbp) -> 48 89 {55 disp8 | 95 disp32}
#   movq %rcx, off(%rbp) -> 48 89 {4D disp8 | 8D disp32}
#   movq %r8,  off(%rbp) -> 4C 89 {45 disp8 | 85 disp32}
#   movq %r9,  off(%rbp) -> 4C 89 {4D disp8 | 8D disp32}
# Hybrid disp8/disp32 (see emit_rbp_mem) so the offset reaches the whole
# frame while keeping small frames byte-identical.
def emit_spill_arg(argidx: uint32, off: int32):
    if argidx == 0:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x7D, off)
    elif argidx == 1:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x75, off)
    elif argidx == 2:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x55, off)
    elif argidx == 3:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x4D, off)
    elif argidx == 4:
        emit_b(0x4C)
        emit_b(0x89)
        emit_rbp_mem(0x45, off)
    else:
        emit_b(0x4C)
        emit_b(0x89)
        emit_rbp_mem(0x4D, off)


# Sized spill of a sub-8-byte scalar PARAMETER from its arg register into the
# stack slot, mirroring codegen_x86.gen_function's per-param sized store
# (`movl _ARG_REGS32[i]` / `movw _ARG_REGS16[i]` / `movb _ARG_REGS8[i]`). A
# blind 8-byte movq (emit_spill_arg) leaves the slot's upper bytes holding the
# arg register's high garbage; a later FULL-width read of the slot (e.g. a
# `float32` param, whose identifier load is a plain movq because it is not
# tagged signed, OR `&param` aliased wider) then sees that garbage. The seed
# truncates the slot to the declared width at spill time, exactly like a
# sub-8-byte LOCAL store. size 8 (or 0) -> plain movq (emit_spill_arg).
#
# Encoding: the source register is encoded in the modrm.reg field of the same
# rbp-relative modrm byte emit_spill_arg uses (0x7D=rdi/edi/di/dil ...), with
# the operand-size prefix/opcode selecting the width:
#   movb  %r8b,off(%rbp)  -> [REX.R] 88 {modrm}      (size 1)
#   movw  %r8w,off(%rbp)  -> 66 [REX.R] 89 {modrm}   (size 2)
#   movl  %r8d,off(%rbp)  -> [REX.R] 89 {modrm}      (size 4)
# r8/r9 (argidx 4/5) need REX.R (0x44); rdi..rcx (argidx 0..3) need no REX for
# widths 2/4 (and a REX is required for movb of sil/dil but argidx 0/1 = di/si
# DO need REX to address dil/sil — handled below).
def emit_spill_arg_sized(argidx: uint32, off: int32, size: uint32):
    if size == 0 or size == 8:
        emit_spill_arg(argidx, off)
        return
    # rbp-relative modrm low byte (mod/rm = rbp + disp), reg field = source reg.
    modrm: uint32 = 0x7D                  # default rdi/edi (reg=111)
    rexr: uint32 = 0                      # 1 -> needs REX.R (r8/r9)
    needs_rex8: uint32 = 0                # 1 -> movb needs REX to reach spl/dil/sil/bpl
    if argidx == 0:
        modrm = 0x7D                      # rdi  (reg 7)
        needs_rex8 = 1
    elif argidx == 1:
        modrm = 0x75                      # rsi  (reg 6)
        needs_rex8 = 1
    elif argidx == 2:
        modrm = 0x55                      # rdx  (reg 2)
    elif argidx == 3:
        modrm = 0x4D                      # rcx  (reg 1)
    elif argidx == 4:
        modrm = 0x45                      # r8   (reg 0) + REX.R
        rexr = 1
    else:
        modrm = 0x4D                      # r9   (reg 1) + REX.R
        rexr = 1
    if size == 2:
        emit_b(0x66)                      # operand-size override -> 16-bit
    rex: uint32 = 0x40
    use_rex: uint32 = 0
    if rexr != 0:
        rex = rex | 0x04                  # REX.R extends modrm.reg to r8/r9
        use_rex = 1
    if size == 1 and needs_rex8 != 0:
        use_rex = 1                       # REX to address dil/sil (not ah/bh/...)
    if use_rex != 0:
        emit_b(rex)
    if size == 1:
        emit_b(0x88)                      # mov r/m8, r8
    else:
        emit_b(0x89)                      # mov r/m16/32, r16/32
    emit_rbp_mem(modrm, off)


# movq off(%rbp), %rax   load a local/param into %rax.
#   -> 48 8B {45 disp8 | 85 disp32}
def emit_load_local_rax(off: int32):
    emit_b(0x48)
    emit_b(0x8B)
    emit_rbp_mem(0x45, off)


# movq %rax, off(%rbp)   store %rax into a local/param slot.
#   -> 48 89 {45 disp8 | 85 disp32}
def emit_store_local_rax(off: int32):
    emit_b(0x48)
    emit_b(0x89)
    emit_rbp_mem(0x45, off)


# Sized store of %rax (low part) into a local/param slot off(%rbp). For a
# sub-8-byte scalar local the store MUST truncate to the slot's declared
# width, exactly like codegen_x86._emit_local_store: a uint32 local must be
# written with `movl %eax` (4 bytes), not a blind `movq` (8 bytes), so the
# slot holds the type-truncated value. Without this an assignment like
# `highest_v(uint32) = p_vaddr + p_memsz` keeps the carry past bit 31 (e.g.
# a high PT_LOAD segment), corrupting a later span/size computation — the
# ELF-loader 64 MiB bogus-kmalloc miscompile. size 8 (or 0) -> plain movq.
#   movb %al,  off(%rbp) -> 88 {45|85} disp        (size 1)
#   movw %ax,  off(%rbp) -> 66 89 {45|85} disp     (size 2)
#   movl %eax, off(%rbp) -> 89 {45|85} disp        (size 4)
#   movq %rax, off(%rbp) -> 48 89 {45|85} disp     (size 8 / default)
def emit_store_local_rax_sized(off: int32, size: uint32):
    if size == 1:
        emit_b(0x88)
        emit_rbp_mem(0x45, off)
    elif size == 2:
        emit_b(0x66)
        emit_b(0x89)
        emit_rbp_mem(0x45, off)
    elif size == 4:
        emit_b(0x89)
        emit_rbp_mem(0x45, off)
    else:
        emit_b(0x48)
        emit_b(0x89)
        emit_rbp_mem(0x45, off)


# Sign-extending load of a sub-8-byte signed scalar local into %rax. The
# modrm reg field is %rax (000) so the rbp-mem encoding (0x45 disp8 / 0x85
# disp32) is shared with the plain movq load. Mirrors codegen_x86
# _emit_local_load's signed branch (movsbq/movswq/movslq off(%rbp),%rax).
#   movsbq off(%rbp),%rax -> 48 0F BE {45|85} disp
#   movswq off(%rbp),%rax -> 48 0F BF {45|85} disp
#   movslq off(%rbp),%rax -> 48 63 {45|85} disp
def emit_load_local_rax_signed(off: int32, size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBE)
        emit_rbp_mem(0x45, off)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xBF)
        emit_rbp_mem(0x45, off)
    else:
        emit_b(0x48)
        emit_b(0x63)
        emit_rbp_mem(0x45, off)


# Zero-extending load of a sub-8-byte unsigned scalar local into %rax. Mirrors
# codegen_x86 _emit_local_load's unsigned branch:
#   size 4: movl off(%rbp),%eax  -> 8B {45|85} disp   (auto zero-extend)
#   size 2: movzwq off(%rbp),%rax -> 48 0F B7 {45|85} disp
#   size 1: movzbq off(%rbp),%rax -> 48 0F B6 {45|85} disp
def emit_load_local_rax_unsigned(off: int32, size: uint32):
    if size == 1:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB6)
        emit_rbp_mem(0x45, off)
    elif size == 2:
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xB7)
        emit_rbp_mem(0x45, off)
    else:
        emit_b(0x8B)
        emit_rbp_mem(0x45, off)


# -----------------------------------------------------------------------
# Comparison: cmpq %rcx,%rax ; set<cc> %al ; movzbq %al,%rax  (mirrors
# codegen_x86._cmp_set). %rax = (left <cc> right) ? 1 : 0. We use the
# SIGNED setcc family — the default codegen_x86._rel_cc picks when no
# operand is statically known-unsigned, which is the case for this
# subset (it carries no type info).
# -----------------------------------------------------------------------

# cmpq %rcx, %rax  -> 48 39 C8
def emit_cmp_rcx_rax():
    emit_b(0x48)
    emit_b(0x39)
    emit_b(0xC8)


# movzbq %al, %rax  -> 48 0F B6 C0
def emit_movzx_al_rax():
    emit_b(0x48)
    emit_b(0x0F)
    emit_b(0xB6)
    emit_b(0xC0)


# set<cc> %al  -> 0F <opc> C0
#   sete  94   setne 95   setl  9C   setge 9D   setle 9E   setg  9F
def emit_setcc_al(opc: uint32):
    emit_b(0x0F)
    emit_b(opc)
    emit_b(0xC0)


# testq %rax, %rax  -> 48 85 C0
def emit_test_rax_rax():
    emit_b(0x48)
    emit_b(0x85)
    emit_b(0xC0)


# testq %rcx, %rcx  -> 48 85 C9
def emit_test_rcx_rcx():
    emit_b(0x48)
    emit_b(0x85)
    emit_b(0xC9)


# -----------------------------------------------------------------------
# Forward/backward jumps with rel32 backpatching. codegen_x86.py emits
# named labels and lets the assembler resolve them; emitting raw bytes we
# resolve them ourselves. A jump is `opc... rel32` where rel32 is the
# signed displacement from the END of the instruction to the target.
#
#   emit_jz_fwd / emit_jmp_fwd return the byte offset of the rel32 field;
#   patch_rel32(at, target) writes target - (at + 4) there once `target`
#   (a code_len snapshot) is known. For a back-edge we know the target up
#   front, so we compute the displacement and emit it directly.
# -----------------------------------------------------------------------

# Write a little-endian rel32 into code[at..at+4) = target - (at + 4).
def patch_rel32(at: uint32, target: uint32):
    rel: int32 = cast[int32](target) - cast[int32](at + 4)
    v: uint32 = cast[uint32](rel)
    code[at] = cast[uint8](v & 255)
    code[at + 1] = cast[uint8]((v >> 8) & 255)
    code[at + 2] = cast[uint8]((v >> 16) & 255)
    code[at + 3] = cast[uint8]((v >> 24) & 255)


# jz rel32  -> 0F 84 rel32  (placeholder). Returns rel32-field offset.
def emit_jz_fwd() -> uint32:
    emit_b(0x0F)
    emit_b(0x84)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    return at


# jmp rel32 -> E9 rel32 (placeholder). Returns rel32-field offset.
def emit_jmp_fwd() -> uint32:
    emit_b(0xE9)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    return at


# jnz rel32 (forward) -> 0F 85 rel32 (placeholder). Returns rel32-field offset.
# Used by the short-circuit `and`/`or` lowering (gen_short_circuit).
def emit_jnz_fwd() -> uint32:
    emit_b(0x0F)
    emit_b(0x85)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    return at


# jmp rel32 to a KNOWN (earlier) target — emits the resolved displacement.
def emit_jmp_back(target: uint32):
    emit_b(0xE9)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    patch_rel32(at, target)


# jnz rel32 to a KNOWN (earlier) target -> 0F 85 rel32. Used by the do-while
# back-edge (`jnz start`), mirroring codegen_x86.gen_do_while.
def emit_jnz_back(target: uint32):
    emit_b(0x0F)
    emit_b(0x85)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    patch_rel32(at, target)


# addq $imm, %rax — add a (non-negative) immediate to %rax. Mirrors GNU as'
# encoding choice exactly: the sign-extended imm8 form `48 83 C0 ib` when the
# value fits a signed byte (0..127 here), else the imm32 accumulator form
# `48 05 id`. Used for `&obj + field_offset` in member addressing.
def emit_add_imm_rax(imm: uint32):
    if imm < 128:
        emit_b(0x48)
        emit_b(0x83)
        emit_b(0xC0)
        emit_b(imm & 255)
        return
    emit_b(0x48)
    emit_b(0x05)
    emit_imm32(cast[uint64](imm))


# subq $imm, %rax  (imm8 form 48 83 E8 ib for imm<128, else 48 2D id).
# For container_of: pointer-to-field minus the field's struct offset.
def emit_sub_imm_rax(imm: uint32):
    if imm < 128:
        emit_b(0x48)
        emit_b(0x83)
        emit_b(0xE8)
        emit_b(imm & 255)
        return
    emit_b(0x48)
    emit_b(0x2D)
    emit_imm32(cast[uint64](imm))


# xorl %eax, %eax  -> 31 C0  (clear %al before a variadic-capable call,
# matching codegen_x86's `xorl %eax,%eax` before each direct call).
def emit_xor_eax_eax():
    emit_b(0x31)
    emit_b(0xC0)


# popq <arg-reg>  — reclaim a marshalled argument into its SysV reg.
#   rdi 5F  rsi 5E  rdx 5A  rcx 59  r8 41 58  r9 41 59
def emit_pop_argreg(argidx: uint32):
    if argidx == 0:
        emit_b(0x5F)
    elif argidx == 1:
        emit_b(0x5E)
    elif argidx == 2:
        emit_b(0x5A)
    elif argidx == 3:
        emit_b(0x59)
    elif argidx == 4:
        emit_b(0x41)
        emit_b(0x58)
    else:
        emit_b(0x41)
        emit_b(0x59)


# popq <syscall-reg> — reclaim a marshalled syscall operand into the Linux
# x86_64 syscall calling-convention register for slot `idx`:
#   idx 0 -> %rax (syscall NUMBER)   58
#   idx 1 -> %rdi (arg1)             5F
#   idx 2 -> %rsi (arg2)             5E
#   idx 3 -> %rdx (arg3)             5A
#   idx 4 -> %r10 (arg4)            41 5A
#   idx 5 -> %r8  (arg5)            41 58
#   idx 6 -> %r9  (arg6)            41 59
# (Note: the syscall ABI uses %r10 for arg4, NOT %rcx like the SysV call
# ABI — `syscall` clobbers %rcx/%r11.)
def emit_pop_syscallreg(idx: uint32):
    if idx == 0:
        emit_b(0x58)
    elif idx == 1:
        emit_b(0x5F)
    elif idx == 2:
        emit_b(0x5E)
    elif idx == 3:
        emit_b(0x5A)
    elif idx == 4:
        emit_b(0x41)
        emit_b(0x5A)
    elif idx == 5:
        emit_b(0x41)
        emit_b(0x58)
    else:
        emit_b(0x41)
        emit_b(0x59)


# `syscall` (0F 05). Inputs already in %rax/%rdi/%rsi/%rdx/%r10/%r8/%r9;
# result left in %rax.
def emit_syscall_insn():
    emit_b(0x0F)
    emit_b(0x05)


# -----------------------------------------------------------------------
# Expression codegen — value left in %rax (mirrors gen_expr).
# -----------------------------------------------------------------------

# =======================================================================
# Phase-7 IR SCRATCH-REGISTER POOL — register-resident IR intermediates.
# =======================================================================
#
# WHAT THIS IS
# ------------
# The Phase-5 IR emitter (gen_expr_ir) lowers an IR_BINOP as a strict stack
# machine: evaluate RIGHT into %rax, `push %rax`, evaluate LEFT into %rax,
# `pop %rcx`, then `op %rcx,%rax`. EVERY binary node spills its right operand to a
# %rsp stack slot and reloads it — two memory accesses per node regardless of
# register pressure. For a chain like `a*b + c*d - e*f` that is a push/pop pair at
# each interior node.
#
# This pool lets gen_expr_ir hold a binary op's RIGHT operand in a CALLEE-SAVED
# SCRATCH REGISTER across the LEFT-operand evaluation instead, so the combine is
# `op %<scratch>,%rax` with NO stack traffic. The scratch registers are acquired
# in LIFO (stack) discipline that matches the recursive descent: an outer node
# acquires a scratch, recurses into the left subtree (which may itself acquire
# DIFFERENT scratch regs for its own nodes), then combines. When the pool is
# exhausted (nesting deeper than the pool), gen_expr_ir falls back to the exact
# push/pop path for that node — always correct.
#
# WHY THIS IS SOUND (no miscompile)
# ---------------------------------
#   * Scratch regs are drawn ONLY from the callee-saved set {rbx,r12,r13,r14,r15}
#     that the per-function linear-scan allocator did NOT use for a promoted local
#     (ra_pool_used(p)==0). So a scratch reg can NEVER alias a register-resident
#     local: a leaf that delegates to gen_expr and reads a promoted local reads a
#     DIFFERENT callee-saved reg, and a statement-level write-through store targets
#     a DIFFERENT one too. (Stores never occur inside a pure IR-lowered expression
#     anyway; only reads/calls do.)
#   * Callee-saved means call-crossing is FREE: a leaf may delegate to the AST
#     emitter and emit a `call` (e.g. `buf[f()]`); the System-V ABI guarantees the
#     callee preserves rbx/r12-r15, so the right operand we parked in a scratch reg
#     survives the call with no save/restore — the same property regalloc.ad relies
#     on for promoted locals.
#   * Any scratch reg the function actually uses is PUSHed in the prologue and
#     POPped in the epilogue (ir_scratch_used_mask, folded into the regalloc
#     save/restore), so the caller's value is preserved across this function.
#   * The emitted combine instruction is the byte-equivalent of the %rcx form with
#     the source field swapped (emit_*_src_rax), so the computed result is
#     identical; only the operand LOCATION (register vs reloaded stack slot)
#     changes. Value-preserving by construction.
#
# GATING — the pool is only consulted from gen_expr_ir, which only runs under
# --opt (ir_emit_is_enabled()). With the flag off, none of this is reached and the
# output is byte-identical to the seed. Even with the flag ON, the pool changes
# only the right-operand materialization of IR_BINOP nodes already on the IR path;
# the *value* is unchanged, so the ADDER_OPT correctness lane still matches the
# oracle.

# The callee-saved pool encodings, in a fixed scratch-preference order. Same set
# as regalloc's ra_pool_enc; we pick the ones regalloc left unused this function.
IR_SCRATCH_NREGS: uint32 = 5
ir_scratch_enc: Array[5, uint32]         # scratch index -> x86 reg encoding

# Per-function: which scratch encodings are free to use as IR scratch (regalloc
# did not claim them for a promoted local). Rebuilt at gen_expr_ir entry.
ir_scratch_avail: Array[5, uint32]       # 1 if encoding ir_scratch_enc[i] usable
# Per-function: which scratch encodings this function ACTUALLY used (so the
# prologue/epilogue saves them). A bitmask over scratch indices 0..4.
ir_scratch_used_mask: uint32 = 0
# Live acquire stack (encodings currently held). LIFO discipline mirrors the
# recursive descent; an entry is the x86 encoding of a held scratch reg.
ir_scratch_busy: Array[5, uint32]        # 1 if scratch index i is currently held
# Stat: number of IR_BINOP nodes whose right operand was kept in a scratch
# register (the stack-traffic reduction = this many push/pop PAIRS eliminated).
ir_scratch_hits: uint32 = 0
# Stat: number of IR_BINOP nodes that fell back to the push/pop path because no
# scratch register was free (pressure exceeded the pool).
ir_scratch_misses: uint32 = 0
# Stat: number of IR_BINOP scratches satisfied by BORROWING a callee-saved reg
# regalloc had promoted a local into, where that local was DEAD at the current
# program point (so lending its register lost no value). This is the register-
# heavy win — capacity that the plain availability pool (regalloc used all regs)
# could not provide.
ir_scratch_borrows: uint32 = 0

# The statement node codegen is currently emitting (set in gen_stmt). Used to map
# to a cfg program point for the borrow disjointness check. 0 => unknown (treated
# conservatively as "no borrow").
cg_cur_stmt: uint32 = 0

# Per-acquire bookkeeping for BORROWED registers: when ir_scratch_acquire lends a
# regalloc-held reg, it records the borrowed encoding so ir_scratch_release knows
# NOT to clear the (non-existent) busy slot but instead clear the borrow record.
# A small stack mirrors the LIFO acquire/release discipline. Borrowed regs are
# already saved by regalloc's prologue, so no extra save is needed.
ir_scratch_borrowed: Array[5, uint32]    # encodings currently borrowed (or RA_NONE)


def ir_scratch_pool_init():
    ir_scratch_enc[0] = 3                 # %rbx
    ir_scratch_enc[1] = 12                # %r12
    ir_scratch_enc[2] = 13                # %r13
    ir_scratch_enc[3] = 14                # %r14
    ir_scratch_enc[4] = 15                # %r15


# Build the per-function availability mask: a scratch encoding is usable iff the
# linear-scan allocator did NOT assign it to a promoted local this function. When
# regalloc is inactive (cg_ra_active==0) every callee-saved reg is free for
# scratch (no promoted locals exist). Called once per function from gen_function /
# gen_method after the allocation is built.
def ir_scratch_build_avail():
    ir_scratch_pool_init()
    ir_scratch_used_mask = 0
    i: uint32 = 0
    while i < IR_SCRATCH_NREGS:
        ir_scratch_busy[i] = 0
        ir_scratch_borrowed[i] = 0
        # Default: available. If regalloc is active AND used pool index i for a
        # promoted local, mark it UNAVAILABLE (its encoding aliases a local that is
        # live SOMEWHERE). Such a register may still be BORROWED at a program point
        # where its local is provably dead — handled in ir_scratch_acquire.
        avail: uint32 = 1
        if cg_ra_active != 0:
            if ra_pool_used(i) != 0:
                avail = 0
        ir_scratch_avail[i] = avail
        i = i + 1


# True iff regalloc-used pool index i may be BORROWED as an IR scratch RIGHT NOW:
# the promoted local it holds is provably DEAD at the current statement's program
# point, so lending its callee-saved register loses no value. Sound by the
# half-open live-range END test (lr_name_dead_after): the local has no use at or
# after this point. Conservative when the point is unknown (cg_cur_stmt unmapped)
# or no local owns the register — returns 0 (fall back to push/pop).
def ir_scratch_can_borrow(i: uint32) -> uint32:
    if cg_ra_active == 0:
        return 0
    if ra_pool_used(i) == 0:
        return 0
    pt: uint32 = lr_stmt_point(cg_cur_stmt)
    # ALL promoted locals sharing pool index i's register must be dead at pt
    # (linear scan reuses one register for several disjoint-interval locals). When
    # pt is unknown (LR_INF), lr_name_dead_after yields 0 for every owner, so this
    # conservatively returns 0 (no borrow).
    return ra_pool_all_dead_after(i, pt)


# Acquire a free scratch register; returns its x86 encoding, or RA_NONE if none
# free. First takes a register the allocator left free (ir_scratch_avail). If none
# is free AND regalloc consumed the whole callee-saved pool, try to BORROW a
# register whose promoted local is dead at the current program point — this is the
# register-heavy win (>=5 promoted locals => empty plain pool). A borrowed reg is
# already saved by the regalloc prologue, so no extra prologue work; we only mark
# it busy + flag it as a borrow so release restores its busy state correctly.
def ir_scratch_acquire() -> uint32:
    # Pass 1: a register regalloc did not use this function (the existing pool).
    i: uint32 = 0
    while i < IR_SCRATCH_NREGS:
        if ir_scratch_avail[i] != 0 and ir_scratch_busy[i] == 0:
            ir_scratch_busy[i] = 1
            ir_scratch_used_mask = ir_scratch_used_mask | (cast[uint32](1) << i)
            return ir_scratch_enc[i]
        i = i + 1
    # Pass 2: BORROW a regalloc-held register whose local is dead here.
    j: uint32 = 0
    while j < IR_SCRATCH_NREGS:
        if ir_scratch_busy[j] == 0:
            if ir_scratch_can_borrow(j) != 0:
                ir_scratch_busy[j] = 1
                ir_scratch_borrowed[j] = 1
                ir_scratch_borrows = ir_scratch_borrows + 1
                return ir_scratch_enc[j]
        j = j + 1
    return RA_NONE


# Release a scratch register by its encoding (LIFO with acquire). Clears the busy
# bit and any borrow flag; a borrowed reg's stack save/restore is owned by
# regalloc, so there is nothing else to undo (the local it held is dead — its
# value was never going to be read again).
def ir_scratch_release(enc: uint32):
    i: uint32 = 0
    while i < IR_SCRATCH_NREGS:
        if ir_scratch_enc[i] == enc:
            ir_scratch_busy[i] = 0
            ir_scratch_borrowed[i] = 0
            return
        i = i + 1


# Emit `op %<src>, %rax` for a scratch source register, dispatching the same op
# set the %rcx combine path uses. Only the register-to-register ADD/SUB/MUL/AND/
# OR/XOR/CMP forms accept an arbitrary source; the caller guarantees `op` is one
# of these (shift/div/mod stay on the %rcx path, which needs %cl/%rdx).
def emit_binop_src_rax(op: uint32, src: uint32):
    if op == BINOP_ADD:
        emit_add_src_rax(src)
    elif op == BINOP_SUB:
        emit_sub_src_rax(src)
    elif op == BINOP_MUL:
        emit_imul_src_rax(src)
    elif op == BINOP_BIT_AND:
        emit_and_src_rax(src)
    elif op == BINOP_BIT_OR:
        emit_or_src_rax(src)
    elif op == BINOP_BIT_XOR:
        emit_xor_src_rax(src)
    else:
        # Compare ops: cmp then the setcc is emitted by the caller. Only the cmp
        # uses the scratch source here.
        emit_cmp_src_rax(src)


# ---- ALU-LOAD memory-source fold helpers (--opt) ----------------------
# An IR_LEAF whose backing AST is `arr[i]` over an 8-byte INTEGER element is a
# foldable memory source: its element address can be computed (gen_index_addr)
# and the 64-bit element sourced in-place by `op (%rcx),%rax`. Restricting to
# 8-byte non-float elements means the implicit movq-width fetch carries the
# whole value with no sign/zero-extension or float-vs-int hazard. Returns the
# wrapped ND_INDEX node id when foldable, else 0.
def ir_leaf_foldable_mem8(v: uint32) -> uint32:
    if ir_kind[v] != IR_LEAF:
        return 0
    a: uint32 = ir_ast[v]
    if a == 0:
        return 0
    if nd_kind[a] != ND_INDEX:
        return 0
    # 8-byte element only (full-width fetch; no extension trap). index_elem_size
    # may cg_fail on a malformed base, but such a node would fail on the normal
    # path too — the result here is just "not foldable" and we fall through.
    if index_elem_size(a) != 8:
        return 0
    # A float element routes through the SSE path, never an integer ALU op.
    if index_elem_float(a) != 0:
        return 0
    return a


# True iff `op` is COMMUTATIVE at 64-bit two's-complement width, so `a OP b`
# and `b OP a` compute the identical value. This lets the alu-load fold source
# EITHER operand as the memory operand. ADD/MUL/AND/OR/XOR and the symmetric
# compares EQ/NEQ qualify; SUB and the DIRECTIONAL compares (LT/LTE/GT/GTE) are
# order-sensitive and may only fold their RIGHT operand as memory.
def ir_op_commutative(op: uint32) -> uint32:
    if op == BINOP_ADD:
        return 1
    if op == BINOP_MUL:
        return 1
    if op == BINOP_BIT_AND:
        return 1
    if op == BINOP_BIT_OR:
        return 1
    if op == BINOP_BIT_XOR:
        return 1
    if op == BINOP_EQ:
        return 1
    if op == BINOP_NEQ:
        return 1
    return 0


# True iff the integer combine op `op` has a "reg, r/m" memory-source form we
# emit as `op (%rcx),%rax`. ADD/SUB/AND/OR/XOR/CMP/MUL qualify. (Compares fold
# too: cmpq (%rcx),%rax then setcc.) Excludes shift/div/mod (no such form here).
def ir_op_aluload_ok(op: uint32) -> uint32:
    if op == BINOP_ADD:
        return 1
    if op == BINOP_SUB:
        return 1
    if op == BINOP_MUL:
        return 1
    if op == BINOP_BIT_AND:
        return 1
    if op == BINOP_BIT_OR:
        return 1
    if op == BINOP_BIT_XOR:
        return 1
    if op == BINOP_EQ:
        return 1
    if op == BINOP_NEQ:
        return 1
    if op == BINOP_LT:
        return 1
    if op == BINOP_LTE:
        return 1
    if op == BINOP_GT:
        return 1
    if op == BINOP_GTE:
        return 1
    return 0


# Emit `op (%rcx),%rax` for the integer combine `op` (the memory source's
# address is in %rcx, the other operand in %rax). For a compare, do the
# cmp + setcc + movzx (l_sgn/r_sgn pick the signed/unsigned setcc) so the
# boolean lands in %rax exactly like the reg-reg compare branches.
def emit_aluload_op(op: uint32, l_sgn: uint32, r_sgn: uint32):
    if op == BINOP_ADD:
        emit_add_mem_rcx_rax()
    elif op == BINOP_SUB:
        emit_sub_mem_rcx_rax()
    elif op == BINOP_MUL:
        emit_imul_mem_rcx_rax()
    elif op == BINOP_BIT_AND:
        emit_and_mem_rcx_rax()
    elif op == BINOP_BIT_OR:
        emit_or_mem_rcx_rax()
    elif op == BINOP_BIT_XOR:
        emit_xor_mem_rcx_rax()
    elif op == BINOP_EQ:
        emit_cmp_mem_rcx_rax()
        emit_setcc_al(0x94)
        emit_movzx_al_rax()
    elif op == BINOP_NEQ:
        emit_cmp_mem_rcx_rax()
        emit_setcc_al(0x95)
        emit_movzx_al_rax()
    elif op == BINOP_LT:
        emit_cmp_mem_rcx_rax()
        emit_setcc_al(rel_setcc(0x9C, l_sgn, r_sgn))
        emit_movzx_al_rax()
    elif op == BINOP_LTE:
        emit_cmp_mem_rcx_rax()
        emit_setcc_al(rel_setcc(0x9E, l_sgn, r_sgn))
        emit_movzx_al_rax()
    elif op == BINOP_GT:
        emit_cmp_mem_rcx_rax()
        emit_setcc_al(rel_setcc(0x9F, l_sgn, r_sgn))
        emit_movzx_al_rax()
    elif op == BINOP_GTE:
        emit_cmp_mem_rcx_rax()
        emit_setcc_al(rel_setcc(0x9D, l_sgn, r_sgn))
        emit_movzx_al_rax()


# True iff `op` is one of the register-to-register combine ops that can take a
# CALLEE-SAVED scratch source (no %cl / %rdx requirement). Shift (SHL/SHR) needs
# the count in %cl and DIV/IDIV/MOD need the divisor in %rcx + %rdx clobber, so
# those keep the push/pop %rcx schedule.
def ir_op_scratch_ok(op: uint32) -> uint32:
    if op == BINOP_ADD:
        return 1
    if op == BINOP_SUB:
        return 1
    if op == BINOP_MUL:
        return 1
    if op == BINOP_BIT_AND:
        return 1
    if op == BINOP_BIT_OR:
        return 1
    if op == BINOP_BIT_XOR:
        return 1
    if op == BINOP_EQ:
        return 1
    if op == BINOP_NEQ:
        return 1
    if op == BINOP_LT:
        return 1
    if op == BINOP_LTE:
        return 1
    if op == BINOP_GT:
        return 1
    if op == BINOP_GTE:
        return 1
    return 0


# Maximum number of scratch registers SIMULTANEOUSLY LIVE while emitting the IR
# tree `v`, under gen_expr_ir's scratch schedule. A scratch-eligible binop holds
# ONE scratch register (its right operand) ACROSS the evaluation of BOTH operand
# subtrees, so its live count is 1 + max(live(left), live(right)). A non-scratch
# binop (shift/div/mod, push/pop path) holds NO scratch across, so its live count
# is just max(live(left), live(right)). Leaves/consts contribute 0. The function
# prescan takes the max of this over every lowered root to decide how many scratch
# registers to RESERVE (push in the prologue) — an EXACT upper bound, since
# acquire is greedy-first-free LIFO, so a peak of D live needs exactly D regs. A
# fully-constant subtree folds to one immediate with no scratch, so it is 0.
def ir_scratch_max_live(v: uint32) -> uint32:
    if v == 0:
        return 0
    k: uint32 = ir_kind[v]
    if k != IR_BINOP:
        return 0                          # IR_CONST / IR_IDENT / IR_LEAF: no scratch
    if ir_tree_is_const(v) != 0:
        return 0                          # folds to one immediate, no scratch
    op: uint32 = ir_op[v]
    la: uint32 = ir_scratch_max_live(ir_a[v])
    ra2: uint32 = ir_scratch_max_live(ir_b[v])
    sub: uint32 = la
    if ra2 > sub:
        sub = ra2
    if ir_op_scratch_ok(op) != 0:
        # The plain scratch combine holds one register across both subtrees. An ADD
        # chain emitted via the reassociation path uses push/pop (no scratch held),
        # so this over-reserves by at most 1 there — harmless (an unused saved reg).
        return sub + 1
    return sub                            # shift/div/mod: push/pop, no scratch held


# =======================================================================
# Phase-5 IR-CONSUMING emitter.
# =======================================================================
#
# gen_expr_ir(v) emits machine code for the value IR node `v` (built by
# ir_lower_pure_expr), leaving the result in %rax — byte-for-byte the value the
# AST emitter would have produced for the same expression, because:
#
#   * IR_CONST  -> `movq $value,%rax` (same as the AST ND_INT_LIT path).
#   * IR_IDENT  -> delegate to gen_expr(ir_ast[v]): the AST ND_IDENT emitter
#                  handles register-promoted locals, sized sub-8-byte loads,
#                  globals, percpu, function-pointer decay — identically.
#   * IR_BINOP  -> if the WHOLE subtree is constant, fold it to one immediate
#                  (the IR optimization: a multi-instruction const chain collapses
#                  to `movq $folded,%rax`). Otherwise emit the SAME schedule the
#                  AST integer path uses: eval RIGHT, push, eval LEFT, pop %rcx,
#                  then the single 64-bit op — so %rax/%rcx and the result match
#                  the seed exactly. (The op set is the signedness-INVARIANT one,
#                  so no signed/unsigned decision is needed: ADD/SUB/MUL/AND/OR/
#                  XOR/SHL emit one fixed instruction, exactly as the AST path.)
#
# Emit the sum of the NON-CONSTANT leaves of the ADD chain rooted at `v` into
# %rax (constant leaves contribute 0 here — they are summed separately into the
# reassociated immediate by the caller). Precondition: `v` is an ADD-rooted IR
# tree with at least one non-constant leaf (the caller checks ir_add_const_count
# >= 2 and the whole tree is not const). The schedule mirrors the AST integer
# add: right subtree pushed, left subtree, pop %rcx, add — so the non-const sum
# in %rax is the same value those leaves would contribute on the AST path.
def gen_expr_ir_add_nonconst(v: uint32):
    # A constant leaf contributes nothing to the non-const remainder: emit 0 so a
    # lone-constant operand of an ADD is a no-op addend (the caller folds the
    # constant). (Reached only as a recursive operand; a fully-constant ADD tree
    # never enters this path — the caller's ir_tree_is_const check handles it.)
    if ir_tree_is_const(v) != 0:
        emit_mov_imm_rax(cast[uint64](0))
        return
    k: uint32 = ir_kind[v]
    if k == IR_BINOP and ir_op[v] == BINOP_ADD:
        la: uint32 = ir_a[v]
        rb: uint32 = ir_b[v]
        l_const: uint32 = ir_tree_is_const(la)
        r_const: uint32 = ir_tree_is_const(rb)
        if l_const != 0 and r_const == 0:
            # Only the right side has non-const leaves; left is a folded constant.
            gen_expr_ir_add_nonconst(rb)
            return
        if r_const != 0 and l_const == 0:
            gen_expr_ir_add_nonconst(la)
            return
        # Both sides carry non-const leaves: sum them (right pushed, then left,
        # pop %rcx, add) — same schedule/value as the AST add of the two halves.
        gen_expr_ir_add_nonconst(rb)
        emit_push_rax()
        gen_expr_ir_add_nonconst(la)
        emit_pop_rcx()
        emit_add_rcx_rax()
        return
    # A non-ADD, non-const leaf (an IR_IDENT, or a nested BINOP of another op):
    # emit its value directly through the normal IR emitter.
    gen_expr_ir(v)


# This is the genuine AST -> IR -> (fold) -> emit pipeline for the lowered subset.
def gen_expr_ir(v: uint32):
    if v == 0:
        return
    k: uint32 = ir_kind[v]
    if k == IR_CONST:
        emit_mov_imm_rax(ir_const[v])
        return
    if k == IR_IDENT:
        # Leaf read: defer to the AST emitter for the original identifier node,
        # so every leaf detail (promoted register, sized load, global) is exactly
        # what the seed emits. ir_ast[v] is the ND_IDENT this leaf lowered from.
        gen_expr(ir_ast[v])
        return
    if k == IR_LEAF:
        # Opaque read leaf (cast / array-or-pointer index): re-emit the ORIGINAL
        # AST node verbatim through the AST emitter, so the load / cast bytes are
        # exactly what the seed produces. The IR only carries the leaf so a WHOLE
        # expression around it (`buf[i] < 48`) can lower; the leaf itself is
        # emitted by the seed's own path — byte-identical by construction. (A
        # nested ND_BINARY inside the leaf, e.g. `cast[uint64](li*3)`, is emitted
        # by the AST path too: the re-entrancy guard in try_gen_expr_ir makes it
        # fall back rather than ir_reset() the arena under this in-progress walk.)
        gen_expr(ir_ast[v])
        return
    if k == IR_BINOP:
        # Fold a fully-constant subtree into one immediate (the IR-level win:
        # collapse the instruction chain to its statically-known result).
        if ir_tree_is_const(v) != 0:
            emit_mov_imm_rax(ir_tree_const_val(v))
            ir_emit_fold_count = ir_emit_fold_count + 1
            return
        op: uint32 = ir_op[v]
        # ADD CONSTANT REASSOCIATION (sound under modular two's-complement): if
        # this ADD tree has >=2 constant contributions AND at least one non-const
        # leaf, sum every constant into ONE immediate and emit the non-const
        # remainder + that single immediate — collapsing an add-chain's constant
        # tail (`(a+3)+4` -> `a+7`), a reduction the AST const-fold cannot make.
        if op == BINOP_ADD:
            ccount: uint32 = ir_add_const_count(v)
            if ccount >= 2:
                csum: uint64 = ir_add_const_sum(v)
                # Emit the non-const remainder of the chain into %rax.
                gen_expr_ir_add_nonconst(v)
                # Add the single folded constant. When csum is the sign-extension
                # of its low 32 bits, the compact `addq $imm32,%rax` (emit_add_
                # imm_rax, which sign-extends the imm32 to 64) computes exactly
                # %rax + csum (modular) — shorter than any other addend chain.
                # Otherwise fall back to materializing the full 64-bit constant in
                # %rcx and adding (push remainder / mov imm64 / pop / add).
                lo: uint64 = csum & cast[uint64](0xFFFFFFFF)
                sext: uint64 = lo
                if (lo & cast[uint64](0x80000000)) != 0:
                    sext = lo | cast[uint64](0xFFFFFFFF00000000)
                if sext == csum:
                    emit_add_imm_rax(cast[uint32](lo))
                else:
                    emit_push_rax()
                    emit_mov_imm_rax(csum)
                    emit_pop_rcx()
                    emit_add_rcx_rax()
                ir_emit_reassoc_count = ir_emit_reassoc_count + 1
                return
        # SIGNEDNESS for the emit-only ops (compares + DIV/MOD/SHR). The seed's
        # AST ND_BINARY path decides signed-vs-unsigned from the STATIC TYPES of
        # the two IMMEDIATE operand AST nodes via expr_signedness(nd_a)/(nd_b).
        # Each IR operand's ir_ast back-pointer IS that operand's original AST
        # node (ir_lower_pure_expr records it), so expr_signedness(ir_ast[ir_a])/
        # (ir_ast[ir_b]) reproduces the seed's exact l_sgn/r_sgn — including the
        # 0 (unknown) the seed yields for a nested-arithmetic operand (an
        # ND_BINARY left operand makes expr_signedness return 0 there too). The
        # emit below is then byte-for-byte the AST path's cmp/setcc / cqo+idiv /
        # div / sar / shr for the same (op, l_sgn, r_sgn).
        l_sgn: uint32 = 0
        r_sgn: uint32 = 0
        if ir_op_is_emit_only(op) != 0:
            l_sgn = expr_signedness(ir_ast[ir_a[v]])
            r_sgn = expr_signedness(ir_ast[ir_b[v]])
        # STRENGTH REDUCTION (--opt, IR path): a DIV/IDIV/MOD whose RIGHT operand
        # is a compile-time integer literal lowers to reciprocal-multiply/shift.
        # The divisor operand's original AST node is ir_ast[ir_b[v]]; it is a
        # side-effect-free literal, so we emit ONLY the left (dividend) subtree.
        if sr_is_enabled() != 0:
            if op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_MOD:
                if sr_node_is_intlit(ir_ast[ir_b[v]]) != 0:
                    sri_dbits: uint64 = sr_const_val
                    if sri_dbits != cast[uint64](0):
                        sri_signed: uint32 = binop_use_signed(l_sgn, r_sgn)
                        sri_wantmod: uint32 = 0
                        if op == BINOP_MOD:
                            sri_wantmod = 1
                        gen_expr_ir(ir_a[v])             # dividend -> %rax
                        gen_div_const(sri_dbits, sri_signed, sri_wantmod)
                        return
        # ALU-LOAD MEMORY-SOURCE FOLD (--opt, Phase-3 instruction selection).
        # When the RIGHT operand is an 8-byte INTEGER array element `arr[i]`, the
        # combine op sources it in-place via `op (%rcx),%rax` instead of loading
        # the element to a temp and combining. This elides the separate sized
        # load + a reg-reg op. IR_BINOP only lowers PURE (side-effect-free)
        # expressions, so evaluating LEFT before the RIGHT element address is
        # value-equivalent to the seed's right-then-left order. Schedule:
        #   eval LEFT -> %rax; park LEFT in a scratch reg; compute &arr[i] -> %rax;
        #   mov it to %rcx; restore LEFT to %rax; `op (%rcx),%rax`.
        # SUB and the directional compares are non-commutative but stay correct:
        # `op (%rcx),%rax` computes `%rax(left) OP (%rcx)(right)` — exactly
        # left-OP-right with the SAME (l_sgn,r_sgn) setcc as the reg branch.
        # Needs exactly ONE held scratch (LEFT), matching the scratch reservation
        # the prescan already grants every scratch-ok binop. Gated on the --opt
        # isel arm so the default path stays byte-identical to the seed.
        if isel_is_enabled() != 0 and ir_op_aluload_ok(op) != 0:
            # The element to fold as the memory source, and the OTHER operand that
            # stays in a register. The RIGHT operand folds for any aluload op
            # (`reg_left OP (%rcx)` matches left-OP-right directly). For a
            # COMMUTATIVE op, if RIGHT is not a foldable element but LEFT is, fold
            # LEFT instead and keep RIGHT in the register — `reg_right OP (%rcx)`
            # == right-OP-left == left-OP-right. Directional compares / SUB never
            # take this swap (they only fold their RIGHT operand).
            mem_idx: uint32 = ir_leaf_foldable_mem8(ir_b[v])
            reg_side: uint32 = ir_a[v]   # operand that stays in %rax
            if mem_idx == 0 and ir_op_commutative(op) != 0:
                mem_idx = ir_leaf_foldable_mem8(ir_a[v])
                reg_side = ir_b[v]
            if mem_idx != 0:
                # Hold the register operand on the STACK across the element-address
                # computation (gen_index_addr clobbers %rax). The stack is always
                # available — no callee-saved scratch reg required — so the fold
                # fires even when the scratch pool is exhausted by surrounding
                # register pressure (a nested binop, many promoted locals). This
                # still elides the SEPARATE sized element load + its reg-reg
                # combine: the element is fetched in-place by `op (%rcx),%rax` and
                # never materialises in a temp. gen_index_addr balances its own
                # stack, so the push/pop pair around it is sound.
                gen_expr_ir(reg_side)        # register operand -> %rax
                emit_push_rax()              # hold it on the stack
                gen_index_addr(mem_idx)      # &arr[i] -> %rax
                emit_mov_rax_rcx()           # element address -> %rcx
                emit_pop_rax()               # restore register operand -> %rax
                emit_aluload_op(op, l_sgn, r_sgn)  # op (%rcx),%rax
                opt_aluload_count = opt_aluload_count + 1
                return
        # SCRATCH-REGISTER FAST PATH (Phase 7). For the register-to-register
        # combine ops (ADD/SUB/MUL/AND/OR/XOR + the 6 compares), try to hold the
        # RIGHT operand in a callee-saved scratch register across the LEFT-operand
        # evaluation instead of pushing it to the stack. The computed VALUE is
        # identical (same op, same operands, same eval order: right then left); only
        # the right operand's residence changes from a reloaded %rsp slot to a
        # register. Shift/div/mod are excluded (they need %cl / %rcx+%rdx) and stay
        # on the push/pop path below. If no scratch reg is free (nesting deeper than
        # the pool) we also fall through to push/pop — always correct.
        if ir_op_scratch_ok(op) != 0:
            sreg: uint32 = ir_scratch_acquire()
            if sreg != RA_NONE:
                gen_expr_ir(ir_b[v])             # RIGHT -> %rax
                emit_mov_rax_callee(sreg)        # park RIGHT in scratch reg
                gen_expr_ir(ir_a[v])             # LEFT  -> %rax
                # Combine LEFT(%rax) with RIGHT(%scratch). For arithmetic/bitwise
                # this leaves the result in %rax; for a compare it does the cmp and
                # we materialize the boolean with setcc/movzx (same as the %rcx
                # compare branches).
                if op == BINOP_EQ:
                    emit_cmp_src_rax(sreg)
                    emit_setcc_al(0x94)
                    emit_movzx_al_rax()
                elif op == BINOP_NEQ:
                    emit_cmp_src_rax(sreg)
                    emit_setcc_al(0x95)
                    emit_movzx_al_rax()
                elif op == BINOP_LT:
                    emit_cmp_src_rax(sreg)
                    emit_setcc_al(rel_setcc(0x9C, l_sgn, r_sgn))
                    emit_movzx_al_rax()
                elif op == BINOP_LTE:
                    emit_cmp_src_rax(sreg)
                    emit_setcc_al(rel_setcc(0x9E, l_sgn, r_sgn))
                    emit_movzx_al_rax()
                elif op == BINOP_GT:
                    emit_cmp_src_rax(sreg)
                    emit_setcc_al(rel_setcc(0x9F, l_sgn, r_sgn))
                    emit_movzx_al_rax()
                elif op == BINOP_GTE:
                    emit_cmp_src_rax(sreg)
                    emit_setcc_al(rel_setcc(0x9D, l_sgn, r_sgn))
                    emit_movzx_al_rax()
                else:
                    # ADD/SUB/MUL/AND/OR/XOR: single reg-reg op -> %rax.
                    emit_binop_src_rax(op, sreg)
                ir_scratch_release(sreg)
                ir_scratch_hits = ir_scratch_hits + 1
                return
            ir_scratch_misses = ir_scratch_misses + 1
        # Same eval order as the AST integer path: RIGHT first (pushed), then
        # LEFT, pop the right into %rcx, apply the op -> %rax.
        gen_expr_ir(ir_b[v])
        emit_push_rax()
        gen_expr_ir(ir_a[v])
        emit_pop_rcx()
        if op == BINOP_ADD:
            emit_add_rcx_rax()
        elif op == BINOP_SUB:
            emit_sub_rcx_rax()
        elif op == BINOP_MUL:
            emit_imul_rcx_rax()
        elif op == BINOP_BIT_AND:
            emit_and_rcx_rax()
        elif op == BINOP_BIT_OR:
            emit_or_rcx_rax()
        elif op == BINOP_BIT_XOR:
            emit_xor_rcx_rax()
        elif op == BINOP_SHL:
            emit_shl_cl_rax()
        elif op == BINOP_SHR:
            # Arithmetic (sarq) for a signed `>>`, else logical (shrq) — exactly
            # the seed's BINOP_SHR branch keyed on binop_use_signed(l,r).
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_sar_cl_rax()
            else:
                emit_shr_cl_rax()
        elif op == BINOP_DIV:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
        elif op == BINOP_IDIV:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
        elif op == BINOP_MOD:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
            emit_mov_rdx_rax()
        elif op == BINOP_EQ:
            emit_cmp_rcx_rax()
            emit_setcc_al(0x94)
            emit_movzx_al_rax()
        elif op == BINOP_NEQ:
            emit_cmp_rcx_rax()
            emit_setcc_al(0x95)
            emit_movzx_al_rax()
        elif op == BINOP_LT:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9C, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_LTE:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9E, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_GT:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9F, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_GTE:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9D, l_sgn, r_sgn))
            emit_movzx_al_rax()
        else:
            # ir_op_is_emittable restricts the lowered set to exactly the ops
            # above, so this is unreachable; fail loudly if the set ever drifts.
            cg_fail(1, ir_ast[v])
        return
    # Unknown IR kind (cannot happen for ir_lower_pure_expr output).
    cg_fail(1, 0)


# FLOAT GUARD (deep). The seed's AST ND_BINARY path routes to the SSE emitter
# (gen_fp_binary) whenever EITHER immediate operand of a binary node is float-
# typed — and it does this PER ND_BINARY node, including COMPARES (`f < g`).
# expr_float_width only reports a float WIDTH for ARITHMETIC binops (ADD/SUB/MUL/
# DIV/IDIV); for a compare binop it returns 0, so checking expr_float_width(root)
# alone would MISS a float compare root and wrongly lower `f < g` to an integer
# cmp. This walks the whole lowered region and returns 1 if ANY ND_BINARY in it
# has a float-typed operand — exactly the seed's float-routing condition at every
# level — so the IR path refuses any subtree the seed would send to SSE.
def ir_subtree_has_float(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_BINARY:
        return 0
    # Each immediate operand: if it is float-typed (a float ident/global, a float
    # cast, a float ARRAY/POINTER ELEMENT, a float literal, or a member we cannot
    # prove integer), the seed routes this binary node to the SSE emitter. Use the
    # leaf-aware float resolver so a float array element `f64buf[i] < x` is caught
    # (plain expr_float_width does NOT resolve index/member element float-ness).
    if expr_leaf_float_width(nd_a[node]) != 0:
        return 1
    if expr_leaf_float_width(nd_b[node]) != 0:
        return 1
    if ir_subtree_has_float(nd_a[node]) != 0:
        return 1
    return ir_subtree_has_float(nd_b[node])


# =======================================================================
# FLOAT IR LOWERING + SSE EMIT (mirrors the seed's gen_fp_binary recursion).
# =======================================================================
#
# The integer IR path (ir_lower_pure_expr + gen_expr_ir) reasons over 64-bit GPR
# arithmetic and cannot model SSE width / int->float promotion, so it bails the
# moment a float operand appears (ir_subtree_has_float). This path lowers the
# FLOAT arith/compare subset the seed routes to gen_fp_binary into the SAME IR
# arena (IR_BINOP over IR_LEAF operands) and emits byte-IDENTICAL SSE code by
# re-deriving each operand's float width from its ir_ast back-pointer — exactly
# the expr_float_width the seed consults. Soundness:
#   * A float-emittable ND_BINARY (ADD/SUB/MUL/DIV/IDIV + 6 compares) whose
#     subtree the seed would route to SSE becomes an IR_BINOP; its operands are
#     either a recursed float-arith IR_BINOP (when that operand is ITSELF a
#     float-arith node — expr_float_width(operand) != 0 and float-emittable) or
#     an opaque IR_LEAF re-emitted verbatim by gen_expr(ir_ast).
#   * Emit walks the tree exactly like gen_fp_binary: eval RIGHT, convert to the
#     node width, push; eval LEFT, convert, pop %rcx, emit_fp_binop. The width
#     and per-operand conversions come from expr_float_width(ir_ast), so the
#     bytes equal the seed's. CSE/const-fold are NOT applied to the float tree
#     here (a future broadening), so flag-on float emit is byte-identical too —
#     the win is that float roots now ENTER the IR pipeline (counted, and the
#     integer leaves underneath still get their normal AST emit).
#
# Returns the IR value id, or 0 if `node` is outside the soundly-lowerable float
# subset (caller falls back to the AST float emitter, always byte-correct).
def ir_lower_float_operand(node: uint32) -> uint32:
    # An operand that is ITSELF a float-arith node (expr_float_width != 0 over the
    # ADD/SUB/MUL/DIV/IDIV set) recurses into a float IR_BINOP, mirroring the
    # seed's gen_expr->gen_fp_binary recursion. Anything else (a float/int LEAF, a
    # float compare used as a value, an integer arith operand promoted to float)
    # is an opaque leaf re-emitted verbatim by gen_expr — byte-identical, and the
    # surrounding convert handles its promotion.
    if node == 0:
        return 0
    if nd_kind[node] == ND_BINARY:
        bop: uint32 = nd_aux[node]
        # Recurse ONLY into a genuine float ARITHMETIC subtree (expr_float_width
        # returns non-zero exactly for ADD/SUB/MUL/DIV/IDIV with a float operand).
        # A float COMPARE operand (expr_float_width == 0) yields an int 0/1 and is
        # promoted as an integer leaf, exactly as the seed's gen_expr would emit it.
        if expr_float_width(node) != 0:
            return ir_lower_float_expr(node)
    # Opaque leaf: gen_expr(ir_ast) reproduces the seed's exact load/cast/compare.
    return ir_leaf_new(node)


# Lower a float-typed ND_BINARY root (an arith op or a compare with >=1 float
# operand) into a float IR_BINOP. Returns 0 if outside the sound subset.
def ir_lower_float_expr(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_BINARY:
        return 0
    op: uint32 = nd_aux[node]
    if ir_op_is_float_emittable(op) == 0:
        return 0
    la: uint32 = ir_lower_float_operand(nd_a[node])
    if la == 0:
        return 0
    ra: uint32 = ir_lower_float_operand(nd_b[node])
    if ra == 0:
        return 0
    return ir_binop_new(op, la, ra, node)


# Emit IR value `v` (a float IR_BINOP tree, or an opaque leaf) leaving its raw
# value bits in %rax. A leaf is re-emitted verbatim by the AST emitter (so its
# bits are exactly the seed's); a float BINOP reproduces gen_fp_binary's exact
# eval/convert/spill schedule at this node's float width.
def gen_fp_expr_ir(v: uint32):
    if v == 0:
        return
    k: uint32 = ir_kind[v]
    if k == IR_LEAF:
        # An operand re-emitted verbatim (float/int load, cast, compare value):
        # byte-identical to the seed's gen_expr for the same AST node. The CALLER
        # converts these raw bits to the surrounding op's float width.
        gen_expr(ir_ast[v])
        return
    if k == IR_BINOP:
        node: uint32 = ir_ast[v]
        op: uint32 = ir_op[v]
        # Node float width = max of the two operands' arith float widths, default
        # 8 — IDENTICAL to gen_fp_binary's `width` computation over the AST node.
        lw: uint32 = expr_float_width(nd_a[node])
        rw: uint32 = expr_float_width(nd_b[node])
        width: uint32 = lw
        if rw > width:
            width = rw
        if width == 0:
            width = 8
        # RIGHT operand first, convert to float width, spill — exactly the seed.
        gen_fp_expr_ir(ir_b[v])
        emit_operand_to_float(expr_float_width(nd_b[node]), width)
        emit_push_rax()
        # LEFT operand, convert to float width.
        gen_fp_expr_ir(ir_a[v])
        emit_operand_to_float(expr_float_width(nd_a[node]), width)
        emit_pop_rcx()
        emit_fp_binop(op, width)
        return
    # IR_CONST / IR_IDENT never appear in a float tree (idents/consts lower to
    # IR_LEAF here); unreachable.
    cg_fail(1, 0)


# Try lowering+emitting a FLOAT-typed ND_BINARY root through the IR float path.
# Returns 1 if it emitted, 0 to fall back to the AST float emitter. The caller
# (try_gen_expr_ir) has already verified ir_subtree_has_float(node) != 0.
def try_gen_fp_expr_ir(node: uint32) -> uint32:
    op: uint32 = nd_aux[node]
    if ir_op_is_float_emittable(op) == 0:
        return 0
    # MATCH THE SEED'S DISPATCH EXACTLY (codegen.ad ND_BINARY): the seed routes a
    # node to gen_fp_binary IFF `expr_float_width(nd_a) != 0 or expr_float_width(
    # nd_b) != 0` — the ARITH float width, NOT the broader leaf resolver. A node
    # whose ONLY float-ness is a leaf operand the arith resolver does NOT see (e.g.
    # `f64buf[i] < x`, where expr_float_width(index)==0) is emitted by the seed as
    # an INTEGER compare, so it MUST NOT take this SSE path. The deep guard
    # (ir_subtree_has_float, leaf-aware) is conservative and may have flagged such
    # a node as "has float"; here we re-test with the EXACT seed condition and
    # fall back to the AST emitter (which reproduces the seed's integer code) when
    # neither IMMEDIATE operand is float by the arith resolver.
    flw: uint32 = expr_float_width(nd_a[node])
    frw: uint32 = expr_float_width(nd_b[node])
    if flw == 0 and frw == 0:
        return 0
    ir_reset()
    v: uint32 = ir_lower_float_expr(node)
    if v == 0:
        return 0
    ir_emit_enter()
    gen_fp_expr_ir(v)
    ir_emit_leave()
    ir_emit_count = ir_emit_count + 1
    ir_emit_float_count = ir_emit_float_count + 1
    return 1


# Try the IR-consuming emit path for AST expression `node`. Returns 1 if it
# emitted the node through the IR (caller is done), 0 if `node` is outside the
# lowered subset and the caller must fall back to the AST emitter. OFF by
# default (ir_emit_is_enabled() == 0) -> always returns 0, so the default path is
# byte-identical. Only ND_BINARY roots are attempted: a bare ident/literal is
# already a single seed instruction, so routing it through the IR would only add
# a redundant ir_reset with no benefit and no marker value.
def try_gen_expr_ir(node: uint32) -> uint32:
    if ir_emit_is_enabled() == 0:
        return 0
    # RE-ENTRANCY GUARD: if an OUTER IR emit is already walking the shared IR
    # arena, refuse to lower this (nested) node — lowering would ir_reset() the
    # arena and corrupt the outer tree. The nested node falls back to the AST
    # emitter (byte-correct). Without this, a leaf whose AST holds a nested
    # ND_BINARY (`cast[uint64](li*3)`) clobbers the live outer tree.
    if ir_emit_in_progress() != 0:
        return 0
    if node == 0:
        return 0
    if nd_kind[node] != ND_BINARY:
        return 0
    # FLOAT GUARD: ir_lower_pure_expr lowers an ADD/SUB/MUL/COMPARE/... over
    # float-typed IDENT/literal leaves into the SAME integer IR shape as integer
    # operands, but the seed routes a float arith/compare to the SSE path
    # (gen_fp_binary), not integer `addq`/`cmp`. Walk the WHOLE lowered region:
    # any ND_BINARY with a float operand (at any depth, incl. a compare root that
    # expr_float_width alone would miss) means SSE territory — fall back.
    if ir_subtree_has_float(node) != 0:
        # FLOAT IR PATH: try lowering this float arith/compare root through the SSE
        # float emitter (byte-identical to the seed's gen_fp_binary, but now inside
        # the IR pipeline). If the subtree is outside the sound float subset, fall
        # back to the AST float emitter as before.
        if try_gen_fp_expr_ir(node) != 0:
            return 1
        ir_emit_fallback_count = ir_emit_fallback_count + 1
        return 0
    ir_reset()
    v: uint32 = ir_lower_pure_expr(node)
    if v == 0:
        # Outside the lowered subset (impure / signedness-sensitive / out-of-set):
        # the AST emitter handles it.
        ir_emit_fallback_count = ir_emit_fallback_count + 1
        return 0
    # Mark the IR emit active so any nested gen_expr -> try_gen_expr_ir (reached
    # when a LEAF delegates to the AST emitter) falls back to AST instead of
    # ir_reset()-ing the arena mid-walk. Cleared after the whole tree is emitted.
    ir_emit_enter()
    gen_expr_ir(v)
    ir_emit_leave()
    ir_emit_count = ir_emit_count + 1
    return 1


# =======================================================================
# IR scratch RESERVATION prescan — how many scratch regs the prologue must save.
# =======================================================================
#
# The prologue is emitted BEFORE the body, but a scratch register is only known
# to be USED when gen_expr_ir acquires it DURING body emission. To save exactly
# the scratch registers the body will use, this prescan walks the function AST
# once before the prologue and, at every node that the emitter WOULD lower to an
# IR root, computes ir_scratch_max_live over the SAME IR (built by the SAME gate:
# float guard + ir_lower_pure_expr). The maximum over all roots is the deepest
# simultaneous scratch demand; the prologue reserves (pushes) that many of the
# scratch-available callee-saved registers. Because the prescan reuses the exact
# emitter gate, it can never UNDER-count a root the emitter lowers (which would
# leave a used scratch reg unsaved — a miscompile). It descends into operands even
# past a lowered root, so it computes a SUPERSET demand — over-reserving at worst,
# which only saves an extra unused callee reg (sound, slightly larger prologue).
#
# CRITICAL: this builds IR (ir_lower_pure_expr -> ir_reset) but leaves ir_emit
# INACTIVE and the arena gets reset again at each real emit, so it does not
# perturb emission. It runs only under ir_emit_is_enabled() (the --opt path).
ir_scratch_reserve: uint32 = 0           # # scratch regs this function must save


# Try the SAME lowering gate as try_gen_expr_ir (minus the runtime re-entrancy
# guard, which is always clear during the prescan) and, if `node` lowers to an IR
# root, fold its scratch demand into ir_scratch_reserve. Returns 1 if it lowered
# (so the caller knows this subtree is a root), 0 otherwise.
def ir_scratch_prescan_root(node: uint32) -> uint32:
    if node == 0:
        return 0
    if nd_kind[node] != ND_BINARY:
        return 0
    if ir_subtree_has_float(node) != 0:
        return 0
    ir_reset()
    v: uint32 = ir_lower_pure_expr(node)
    if v == 0:
        return 0
    d: uint32 = ir_scratch_max_live(v)
    if d > ir_scratch_reserve:
        ir_scratch_reserve = d
    return 1


# Generic AST descent: visit `node` and all its operand slots / chains, folding
# every lowered IR root's scratch demand into ir_scratch_reserve. Visiting a
# SUPERSET of the emitter's roots is sound (over-reserve at worst). Descends the
# four operand slots (a/b/c/d) plus the sibling chain (next), which together cover
# every expression position a statement or expression node uses. A node that is
# itself a lowered root still has its operands descended (harmless extra demand).
def ir_scratch_prescan_node(node: uint32):
    cur: uint32 = node
    while cur != 0:
        ir_scratch_prescan_root(cur)
        ir_scratch_prescan_node(nd_a[cur])
        ir_scratch_prescan_node(nd_b[cur])
        ir_scratch_prescan_node(nd_c[cur])
        ir_scratch_prescan_node(nd_d[cur])
        cur = nd_next[cur]                # iterate the sibling chain (no deep
                                          # recursion on long statement lists)


# Run the reservation prescan for function/method `fn` over its body statement
# chain (nd_c). Sets ir_scratch_reserve. No-op (0) unless the IR emit path is on.
def ir_scratch_prescan_function(fn: uint32):
    ir_scratch_reserve = 0
    if ir_emit_is_enabled() == 0:
        return
    ir_scratch_prescan_node(nd_c[fn])


def gen_expr(node: uint32):
    if node == 0:
        return
    k: uint32 = nd_kind[node]

    # Phase-5: under --opt, try emitting a pure signedness-invariant arithmetic
    # subtree THROUGH the IR (AST -> IR -> fold -> emit). Inert by default.
    if k == ND_BINARY:
        if try_gen_expr_ir(node) != 0:
            return

    if k == ND_INT_LIT:
        emit_mov_imm_rax(nd_num[node])
        return

    if k == ND_CHAR_LIT:
        # A char literal is just its code-point as an immediate, exactly
        # like an int literal (codegen_x86 emits `movq $ord(v),%rax`). The
        # parser already stored the value in nd_num.
        emit_mov_imm_rax(nd_num[node])
        return

    if k == ND_BOOL_LIT:
        # True / False -> 1 / 0 immediate (codegen_x86's BoolLiteral case);
        # the parser stored 0/1 in nd_num.
        emit_mov_imm_rax(nd_num[node])
        return

    if k == ND_FLOAT_LIT:
        # A bare float literal is a float64. This backend's frontend stores
        # only the literal's INTEGER part in nd_num (no fraction), so a whole-
        # number literal converts exactly: materialize the integer in %rax and
        # cvtsi2sd it to the float64 bit pattern. (The fuzzer derives floats
        # from integers via cast[floatN](int), so fractional literals never
        # reach this backend; a surrounding cast[float32] narrows via the cast
        # path.) Mirrors codegen_x86's FloatLiteral as a double value.
        emit_mov_imm_rax(nd_num[node])
        emit_fp_convert(0, 8)
        return

    if k == ND_IDENT:
        # `self` inside a method: load the receiver pointer value from its slot.
        if is_self_ident(node) != 0 and cg_self_struct != 0:
            emit_load_local_rax(cg_self_off)
            return
        off: int32 = 0
        if lookup_local(nd_name_off[node], nd_name_len[node], &off) != 0:
            # Sub-8-byte typed scalar local: load only its low `sz` bytes and
            # sign/zero-extend into %rax (mirrors codegen_x86 _emit_local_load).
            # The slot's low bytes hold the type-truncated value, so an
            # extending load yields the correctly widened value — without this,
            # a widening read like cast[int64](l16) leaks the slot's stale
            # upper bytes (e.g. an un-truncated div result) into the result.
            lsz: uint32 = lookup_local_scalar_size(nd_name_off[node], nd_name_len[node])
            if lsz != 0 and lsz < 8:
                lsg: uint32 = lookup_local_signedness(nd_name_off[node], nd_name_len[node])
                if lsg == 2:
                    emit_load_local_rax_signed(off, lsz)
                else:
                    emit_load_local_rax_unsigned(off, lsz)
                return
            # Plain full-width 8-byte scalar. Under --opt, if regalloc promoted
            # this local to a callee-saved register, READ the register instead of
            # the memory slot (the write-through store kept both coherent).
            # Inert by default: ra_reg_for_name returns RA_NONE with the flag off.
            renc: uint32 = ra_reg_for_name(nd_name_off[node], nd_name_len[node])
            if renc != RA_NONE:
                emit_mov_callee_rax(renc)
                return
            emit_load_local_rax(off)
            return
        # Percpu global read (kernel target): `movq %gs:offset, %rax`. The
        # value lives per-CPU at %gs:offset, NOT at a linear RIP address.
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0 and glob_is_percpu[gi - 1] != 0:
            # Sized per-CPU scalar load (movl/movzwq/movzbq for a sub-8-byte
            # Percpu[T]); aggregate percpu (elem_size != 0) decays to address
            # and keeps the 8-byte movq.
            if glob_elem_size[gi - 1] == 0:
                emit_load_gs_rax_sized(glob_offset[gi - 1], glob_scalar_size[gi - 1])
            else:
                emit_load_gs_rax(glob_offset[gi - 1])
            return
        # Global? Scalar globals load their value (leaq + sized deref,
        # mirroring codegen_x86's `leaq name(%rip),%rax ; movq (%rax),%rax`).
        # Array globals decay to their address (just the leaq), so callers
        # that index or take their address get the base.
        if gi != 0:
            emit_lea_global_rax(glob_offset[gi - 1], glob_is_bss[gi - 1])
            if glob_elem_size[gi - 1] == 0:
                if glob_is_signed[gi - 1] != 0:
                    emit_load_mem_rax_signed(glob_scalar_size[gi - 1])
                else:
                    emit_load_mem_rax(glob_scalar_size[gi - 1])
            return
        # Kernel target: a bare identifier that names a FUNCTION (an in-unit
        # Adder function used as a function pointer, e.g.
        # `wq_worker_tramp[0] = _wq_worker_tramp_0`, or an extern func) decays
        # to its address — `leaq sym(%rip),%rax` + a PC32 extern reloc, exactly
        # as the seed's gen_identifier does for defined_funcs/extern_funcs. The
        # symtab pass classifies the name DEFINED (emitted Adder func) vs UNDEF.
        if cg_target_kernel != 0:
            if ext_lookup(nd_name_off[node], nd_name_len[node]) != 0 or is_program_function(nd_name_off[node], nd_name_len[node]) != 0:
                fpi: uint32 = ext_intern(nd_name_off[node], nd_name_len[node])
                emit_lea_extern_rax(fpi)
                return
        else:
            # User target: a bare identifier naming an in-unit FUNCTION used as
            # a value decays to its CODE address (a function pointer), exactly
            # like the seed's gen_identifier `leaq name(%rip),%rax` for a name
            # in defined_funcs. The self-contained user image has no external
            # linkage, so it must be a function defined in THIS program; the
            # call-fixup resolver patches the rel32 against its code offset.
            if is_program_function(nd_name_off[node], nd_name_len[node]) != 0:
                emit_lea_func_rax(nd_name_off[node], nd_name_len[node])
                return
        # Unknown identifier — out of this subset's scope.
        cg_fail(8, node)
        return

    if k == ND_STRING_LIT:
        # Intern the literal's bytes (NUL-terminated, like .asciz in
        # codegen_x86.gen_rodata) into the data section; the expression
        # yields the string's address via a RIP-relative leaq.
        doff: uint32 = intern_string(nd_name_off[node], nd_name_len[node])
        emit_lea_global_rax(doff, 0)
        return

    if k == ND_BINARY:
        op: uint32 = nd_aux[node]
        # Floating-point binop/compare: if EITHER operand is float-typed AND
        # the op is an arithmetic op or a compare, route to the SSE path
        # (mirrors codegen_x86.gen_binary's FP branch). Eval/spill order is
        # byte-identical to the integer path.
        flw: uint32 = expr_float_width(nd_a[node])
        frw: uint32 = expr_float_width(nd_b[node])
        if flw != 0 or frw != 0:
            if op == BINOP_ADD or op == BINOP_SUB or op == BINOP_MUL or op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_EQ or op == BINOP_NEQ or op == BINOP_LT or op == BINOP_LTE or op == BINOP_GT or op == BINOP_GTE:
                gen_fp_binary(node, op, flw, frw)
                return
        # Decide signed-vs-unsigned for compares and div/mod from the operand
        # static types BEFORE evaluating (cheap AST walk). Mirrors codegen_x86
        # _rel_cc / _binop_signed_op over get_expr_type():
        #   * compares default SIGNED, switch to UNSIGNED if EITHER operand is
        #     known-unsigned;
        #   * div/mod default UNSIGNED, switch to SIGNED if some operand is
        #     known-signed and none is known-unsigned.
        l_sgn: uint32 = expr_signedness(nd_a[node])
        r_sgn: uint32 = expr_signedness(nd_b[node])
        # Logical `and`/`or` MUST short-circuit (Python/Adder semantics) and
        # MUST evaluate the LEFT operand FIRST — exactly codegen_x86.gen_binary,
        # which routes BinOp.AND/OR to gen_short_circuit. The earlier
        # bitwise-fold lowering here evaluated BOTH operands unconditionally and
        # folded them, which DIVERGES whenever the right operand has a side
        # effect, faults (e.g. `p != 0 and p[i] != 0` derefs a null pointer),
        # or merely reads state only meaningful when the left didn't decide the
        # result. Result (0/1) lands in %rax, so callers that test it (if/while/
        # bool assignment) are unchanged.
        if op == BINOP_AND:
            # <eval left>; testq; jz false; <eval right>; testq; jz false;
            # movq $1,%rax; jmp end; false: xorl %eax,%eax; end:
            gen_expr(nd_a[node])
            emit_test_rax_rax()
            f1: uint32 = emit_jz_fwd()
            gen_expr(nd_b[node])
            emit_test_rax_rax()
            f2: uint32 = emit_jz_fwd()
            emit_mov_imm_rax(cast[uint64](1))
            e1: uint32 = emit_jmp_fwd()
            patch_rel32(f1, code_len)
            patch_rel32(f2, code_len)
            emit_xor_eax_eax()
            patch_rel32(e1, code_len)
            return
        if op == BINOP_OR:
            # <eval left>; testq; jnz true; <eval right>; testq; jnz true;
            # xorl %eax,%eax; jmp end; true: movq $1,%rax; end:
            gen_expr(nd_a[node])
            emit_test_rax_rax()
            t1: uint32 = emit_jnz_fwd()
            gen_expr(nd_b[node])
            emit_test_rax_rax()
            t2: uint32 = emit_jnz_fwd()
            emit_xor_eax_eax()
            e2: uint32 = emit_jmp_fwd()
            patch_rel32(t1, code_len)
            patch_rel32(t2, code_len)
            emit_mov_imm_rax(cast[uint64](1))
            patch_rel32(e2, code_len)
            return
        # Strength reduction (--opt only): `<expr> / <intlit>`, `// <intlit>`,
        # or `% <intlit>` lowers to a reciprocal-multiply/shift instead of
        # cqo+idiv / xor+div. We evaluate ONLY the left operand (the divisor is
        # a compile-time constant, so the right operand is NOT evaluated — it's
        # a pure ND_INT_LIT/ND_CHAR_LIT with no side effects), then emit the
        # reduced sequence into %rax. OFF by default (sr_is_enabled()==0) ->
        # this whole block is skipped and the byte-identical idiv path runs.
        if sr_is_enabled() != 0:
            if op == BINOP_DIV or op == BINOP_IDIV or op == BINOP_MOD:
                if sr_node_is_intlit(nd_b[node]) != 0:
                    sr_signed: uint32 = binop_use_signed(l_sgn, r_sgn)
                    sr_dbits: uint64 = sr_const_val
                    sr_wantmod: uint32 = 0
                    if op == BINOP_MOD:
                        sr_wantmod = 1
                    # Try the reduced emit; only if it fires do we skip the
                    # general path. d==0 returns 0 (keeps the div-by-zero trap).
                    # gen_div_const always succeeds for d!=0; the divisor is a
                    # side-effect-free literal so evaluating only the left
                    # operand is sound.
                    if sr_dbits != cast[uint64](0):
                        gen_expr(nd_a[node])           # dividend -> %rax
                        gen_div_const(sr_dbits, sr_signed, sr_wantmod)
                        return
        # Evaluate right first, push; then left; pop into %rcx. After this
        # %rax = left, %rcx = right — exactly codegen_x86.gen_binary.
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_expr(nd_a[node])
        emit_pop_rcx()
        if op == BINOP_ADD:
            emit_add_rcx_rax()
        elif op == BINOP_SUB:
            emit_sub_rcx_rax()
        elif op == BINOP_MUL:
            emit_imul_rcx_rax()
        elif op == BINOP_BIT_AND:
            emit_and_rcx_rax()
        elif op == BINOP_BIT_OR:
            emit_or_rcx_rax()
        elif op == BINOP_BIT_XOR:
            emit_xor_rcx_rax()
        elif op == BINOP_SHL:
            # Shift count must sit in %cl; %rcx already holds the right operand.
            emit_shl_cl_rax()
        elif op == BINOP_SHR:
            # Arithmetic (sarq) for a signed `>>`, else logical (shrq).
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_sar_cl_rax()
            else:
                emit_shr_cl_rax()
        elif op == BINOP_DIV:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
        elif op == BINOP_IDIV:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
        elif op == BINOP_MOD:
            if binop_use_signed(l_sgn, r_sgn) != 0:
                emit_cqo()
                emit_idiv_rcx()
            else:
                emit_xor_rdx_rdx()
                emit_div_rcx()
            emit_mov_rdx_rax()
        elif op == BINOP_EQ:
            emit_cmp_rcx_rax()
            emit_setcc_al(0x94)
            emit_movzx_al_rax()
        elif op == BINOP_NEQ:
            emit_cmp_rcx_rax()
            emit_setcc_al(0x95)
            emit_movzx_al_rax()
        elif op == BINOP_LT:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9C, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_LTE:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9E, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_GT:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9F, l_sgn, r_sgn))
            emit_movzx_al_rax()
        elif op == BINOP_GTE:
            emit_cmp_rcx_rax()
            emit_setcc_al(rel_setcc(0x9D, l_sgn, r_sgn))
            emit_movzx_al_rax()
        # NOTE: BINOP_AND / BINOP_OR are handled by the short-circuit lowering
        # ABOVE (before operand eval) and never reach this fold-style switch.
        else:
            cg_fail(1, node)
        return

    if k == ND_UNARY:
        gen_unary(node)
        return

    if k == ND_INDEX:
        # arr[i] value load: compute element address into %rax, then a
        # sized load. Element size is the array local's declared width.
        # A signed sub-8-byte element (e.g. cast[Ptr[int32]](p)[0]) sign-
        # extends, mirroring codegen_x86.gen_index_load's emit_load_sized_
        # signed; index_elem_signed gates this on the cast pointee's type.
        gen_index_addr(node)
        es: uint32 = index_elem_size(node)
        if index_elem_signed(node) == 2:
            emit_load_mem_rax_signed(es)
        else:
            emit_load_mem_rax(es)
        return

    if k == ND_CALL:
        gen_call(node)
        return

    if k == ND_CONTAINER_OF:
        gen_container_of(node)
        return

    if k == ND_SIZEOF:
        gen_sizeof(node)
        return

    if k == ND_MEMBER:
        gen_member_load(node)
        return

    if k == ND_METHOD_CALL:
        gen_method_call(node)
        return

    if k == ND_CAST:
        # cast[T](x) / int32(x) / Ptr[T](x). Evaluate the operand into %rax,
        # then — for a NARROWING cast to a sub-8-byte integer type — truncate
        # %rax to T's value: clear (unsigned T) or sign-fill (signed T) the
        # bits above T's width. This mirrors codegen_x86._emit_cast_widen's
        # narrowing branch, keyed on the DESTINATION type ALONE: `cast[T](x)`
        # for a sub-8-byte int T has value `x mod 2^width` (sign-adjusted),
        # regardless of the source. Without this, the upper bits leak into a
        # later wider store / 64-bit compare / bitwise fold — one of the
        # Track-2 fuzzer's fixed miscompiles (cast[uint8](300) must be 44, not
        # 300). Pointer / array / non-primitive cast targets are NOT ND_TYPE
        # nodes, so prim_type_size returns 8 and emit_ext_rax is a no-op for
        # them — preserving pointer/uint64 arithmetic exactly.
        # The cast type lives on nd_a; the operand on nd_b.
        gen_expr(nd_b[node])
        tnode: uint32 = nd_a[node]
        # FP cast: if either the source or the destination is a float type,
        # route through the SSE convert path (int<->float, float<->float).
        # A float->int cast leaves a 64-bit signed int in %rax, which then
        # needs the integer narrowing fix-up for sub-8-byte int targets.
        # Mirrors codegen_x86.gen_expr's CastExpr FP branch.
        dfw: uint32 = type_float_width(tnode)
        sfw: uint32 = expr_float_width(nd_b[node])
        if dfw != 0 or sfw != 0:
            emit_fp_convert(sfw, dfw)
            if dfw == 0 and tnode != 0 and nd_kind[tnode] == ND_TYPE:
                dsz0: uint32 = prim_type_size(tnode)
                if dsz0 < 8:
                    sgn0: uint32 = 0
                    if type_is_unsigned(tnode) == 0:
                        sgn0 = 1
                    emit_ext_rax(dsz0, sgn0)
            return
        if tnode != 0 and nd_kind[tnode] == ND_TYPE:
            dsz: uint32 = prim_type_size(tnode)
            if dsz < 8:
                signedness: uint32 = 0
                if type_is_unsigned(tnode) == 0:
                    signedness = 1
                emit_ext_rax(dsz, signedness)
        return

    # Anything else is outside this milestone's subset.
    cg_fail(1, node)


# -----------------------------------------------------------------------
# Unary operators (mirrors codegen_x86.gen_unary, integer subset): NEG,
# BIT_NOT, NOT, plus DEREF (*p) and ADDR (&x / &arr[i]). NEG/BIT_NOT/NOT
# evaluate the operand into %rax then apply in place; ADDR computes the
# operand's address (no value load); DEREF loads the pointee after
# evaluating the pointer value.
# -----------------------------------------------------------------------

def gen_unary(node: uint32):
    op: uint32 = nd_aux[node]
    # ADDR / DEREF evaluate the operand specially (address-of must NOT load
    # the operand's value), so handle them before the generic eval-then-op.
    if op == UNOP_ADDR:
        gen_addr_of(nd_a[node])
        return
    if op == UNOP_DEREF:
        # *p: evaluate the pointer expression (its value = the target
        # address) into %rax, then load the pointee. The pointee width is
        # the operand's Ptr[T] pointee size when known, else 8 (mirrors
        # codegen_x86.gen_unary's DEREF size = get_type_size(pointee)).
        gen_expr(nd_a[node])
        emit_load_mem_rax(deref_size(nd_a[node]))
        return
    # FP negate: flip the IEEE sign bit (so -0.0 is produced correctly), not
    # an integer negate. Done in-register by XOR-ing the bit pattern with the
    # sign mask — width-exact, no SSE. Mirrors codegen_x86.gen_unary's FP NEG.
    if op == UNOP_NEG:
        nfw: uint32 = expr_float_width(nd_a[node])
        if nfw != 0:
            gen_expr(nd_a[node])
            if nfw == 4:
                emit_xor_eax_signbit32()
            else:
                emit_xor_rax_signbit64()
            return
    gen_expr(nd_a[node])
    if op == UNOP_NEG:
        emit_neg_rax()
    elif op == UNOP_BIT_NOT:
        emit_not_rax()
    elif op == UNOP_NOT:
        # not x  ==  (x == 0) ? 1 : 0
        emit_test_rax_rax()
        emit_setcc_al(0x94)        # setz/sete %al
        emit_movzx_al_rax()
    else:
        cg_fail(1, node)


# Pointee width for a `*expr` deref: if `expr` is a bare Ptr[T] identifier
# (local/param or global), return its pointee size; otherwise default to 8.
def deref_size(expr: uint32) -> uint32:
    if nd_kind[expr] == ND_IDENT:
        ps: uint32 = lookup_ptr_size(nd_name_off[expr], nd_name_len[expr])
        if ps != 0:
            return ps
        gi: uint32 = glob_lookup(nd_name_off[expr], nd_name_len[expr])
        if gi != 0 and glob_ptr_size[gi - 1] != 0:
            return glob_ptr_size[gi - 1]
    return 8


# Compute the ADDRESS of an lvalue expression into %rax (mirrors
# codegen_x86.gen_addr_of). Supported operands:
#   * an identifier naming a frame local/param  -> leaq off(%rbp)
#   * an identifier naming a module-level global -> leaq data_off(%rip)
#   * an index expression arr[i] / p[i]          -> &element (gen_index_addr)
# Taking the address of a bare scalar local yields its slot address; taking
# the address of an array/pointer element yields the element address. These
# are exactly the address forms the compiler's own source uses
# (e.g. `&strbuf[val_start]`, `&out[0]`).
def gen_addr_of(operand: uint32):
    k: uint32 = nd_kind[operand]
    if k == ND_INDEX:
        gen_index_addr(operand)
        return
    if k == ND_MEMBER:
        gen_member_address(nd_a[operand], nd_name_off[operand], nd_name_len[operand])
        return
    if k == ND_IDENT:
        off: int32 = 0
        if lookup_local(nd_name_off[operand], nd_name_len[operand], &off) != 0:
            emit_lea_local_rax(off)
            return
        gi: uint32 = glob_lookup(nd_name_off[operand], nd_name_len[operand])
        if gi != 0:
            emit_lea_global_rax(glob_offset[gi - 1], glob_is_bss[gi - 1])
            return
        # Kernel target: `&extern_sym` (e.g. &irq_stub_240, &memcpy) — the
        # symbol is defined in a hand-written .S object linked later by `ld`.
        # Emit leaq sym(%rip),%rax + an EXTERN PC32 reloc, mirroring the seed.
        if cg_target_kernel != 0:
            ei: uint32 = ext_lookup(nd_name_off[operand], nd_name_len[operand])
            if ei != 0:
                emit_lea_extern_rax(ei - 1)
                return
            # Kernel target also takes the address of IN-UNIT functions
            # (&syscall_entry, &user_demo_entry, &ap_main_64, …). These are
            # GLOBAL DEFINED .text symbols; `ld` resolves them too. Treat an
            # unknown ident at kernel scope as a function-symbol reference: it
            # is an extern as far as THIS object is concerned unless it is one
            # of our emitted functions. Record it as an extern reloc against a
            # synthesised UNDEF/DEFINED symbol — the symtab pass decides
            # DEFINED-vs-UNDEF by whether a function of that name was emitted.
            fi2: uint32 = ext_intern(nd_name_off[operand], nd_name_len[operand])
            emit_lea_extern_rax(fi2)
            return
    cg_fail(8, operand)


# -----------------------------------------------------------------------
# Array indexing (local Array slots). Mirrors codegen_x86.gen_index_address:
# evaluate the index, scale it by the element size, add the array's base
# address. The base is an Array local, so its "value" is its slot address
# (a leaq), exactly how codegen_x86 decays an array-typed identifier.
# Only bare-identifier array bases are in this subset.
# -----------------------------------------------------------------------

# The ND_ARRAY_TYPE node that `expr` evaluates to as an aggregate, or 0 if
# `expr` is scalar / not an indexable multi-dimensional global. Mirrors
# codegen_x86.get_expr_type narrowed to the array-global case:
#   * a bare global identifier with a recorded array type node -> that node
#   * a nested index `g[i]` -> the element type of g's array type, but ONLY
#     when that element is itself an ND_ARRAY_TYPE (i.e. another dimension).
# A fully-indexed scalar element returns 0 (it is not an aggregate).
# This is consulted ONLY for the multi-dimensional path; 1-D arrays (whose
# element is a scalar) return 0 here and keep the flat glob_elem_size path.
def expr_array_type(expr: uint32) -> uint32:
    k: uint32 = nd_kind[expr]
    if k == ND_IDENT:
        # A multi-dimensional array LOCAL (`a: Array[N, Array[M,T]]`): return
        # its recorded type node so a nested index `a[i][j]` walks dimensions.
        ltn: uint32 = lookup_local_type_node(nd_name_off[expr], nd_name_len[expr])
        if ltn != 0 and nd_kind[ltn] == ND_ARRAY_TYPE:
            return ltn
        gi: uint32 = glob_lookup(nd_name_off[expr], nd_name_len[expr])
        if gi != 0 and glob_type_node[gi - 1] != 0:
            tn: uint32 = glob_type_node[gi - 1]
            if nd_kind[tn] == ND_ARRAY_TYPE:
                return tn
        return 0
    # A struct/class MEMBER that is an array field (`obj.grid` of type
    # Array[N, Array[M,T]]): return the field's ND_ARRAY_TYPE so a nested index
    # `obj.grid[i][j]` scales by the row stride at the outer level. Mirrors the
    # seed's get_expr_type(MemberExpr) = the field's ArrayType.
    if k == ND_MEMBER:
        mis_ptr: uint32 = 0
        msidx: uint32 = member_resolve(nd_a[expr], &mis_ptr)
        if msidx != 0:
            mtn: uint32 = struct_field_type_node(msidx, nd_name_off[expr], nd_name_len[expr])
            if mtn != 0 and nd_kind[mtn] == ND_ARRAY_TYPE:
                return mtn
        return 0
    if k == ND_INDEX:
        bt: uint32 = expr_array_type(nd_a[expr])
        if bt != 0:
            elem: uint32 = nd_a[bt]            # element type of the base array
            if nd_kind[elem] == ND_ARRAY_TYPE:
                return elem
        return 0
    return 0


# True if `node` is a nested index `base[i]` whose base is itself an indexed
# multi-dimensional array global (so this level scales by the nested row
# stride, not a scalar element). Only such nodes take the recursive path.
def is_multidim_index(node: uint32) -> uint32:
    if nd_kind[nd_a[node]] != ND_INDEX:
        return 0
    if expr_array_type(nd_a[node]) != 0:
        return 1
    return 0


# Element size for an `arr[i]` node: the declared element width of the
# array local OR array global named by nd_a. Returns 1 if unknown.
def index_elem_size(node: uint32) -> uint32:
    base: uint32 = nd_a[node]
    # ---- "lit"[i] : a string-literal base. The seed's get_expr_type does NOT
    # classify a StringLiteral, so element_size_of falls through to its default
    # `return 8`. We MATCH the oracle's stride of 8 (not the 1 a byte array
    # would imply) so the emitted scale is byte-identical. In practice the only
    # use is `&"lit"[0]` (index 0), where 0*8 == 0*1, so this is also runtime-
    # correct; matching the seed's stride keeps the differential clean.
    if nd_kind[base] == ND_STRING_LIT:
        return 8
    # ---- cast[Ptr[T]](expr)[i] : the base is an arbitrary expression cast to
    # a pointer type. The element width is sizeof(T) read off the cast's
    # Ptr[T] target node (type_size_of so struct pointees size correctly),
    # mirroring codegen_x86.element_size_of(container) where get_expr_type of
    # a CastExpr returns its target_type (a PointerType) and the element size
    # is get_type_size(base_type). nd_a[ND_CAST] is the type node;
    # nd_a[ND_PTR_TYPE] is the pointee T.
    if nd_kind[base] == ND_CAST:
        ct: uint32 = nd_a[base]
        if ct != 0 and nd_kind[ct] == ND_PTR_TYPE:
            return type_size_of(nd_a[ct])
        # A cast to a non-pointer type is not an indexable base; outside subset.
        cg_fail(8, node)
        return 1
    # fn(...)[i] : element width = sizeof(pointee) from the callee's Ptr[T]
    # return type.
    if nd_kind[base] == ND_CALL:
        rt: uint32 = call_return_type(base)
        if rt != 0 and nd_kind[rt] == ND_PTR_TYPE:
            return type_size_of(nd_a[rt])
        cg_fail(8, node)
        return 1
    # ---- obj.field[i] : the base is a struct/class MEMBER that is an array or
    # Ptr[T] field. The element width is the field's recorded element size,
    # mirroring codegen_x86.element_size_of where get_expr_type of a MemberExpr
    # resolves the field type (an ArrayType/PointerType) and element_size is
    # get_type_size of its element/base.
    if nd_kind[base] == ND_MEMBER:
        msgn: uint32 = 0
        mes: uint32 = member_index_elem(base, &msgn)
        if mes != 0:
            return mes
        cg_fail(8, node)
        return 1
    # Nested index into a multi-dimensional array global: the element width at
    # THIS level is type_size(element_type), recursing into the base array's
    # type. For `g_grid[r][c]` over Array[N, Array[M, int64]] the base array
    # of this (inner) level is Array[M, int64], so the element is int64 -> 8.
    # For the OUTER level `g_grid[r]` the base array is Array[N, Array[M,T]],
    # element Array[M,T] -> M*sizeof(T) (the row stride).
    if nd_kind[base] == ND_INDEX:
        bt: uint32 = expr_array_type(base)
        if bt != 0:
            return type_size_of(nd_a[bt])
        cg_fail(8, node)
        return 1
    if nd_kind[base] != ND_IDENT:
        cg_fail(8, node)
        return 1
    # A bare-identifier base into a multi-dimensional array global: the OUTER
    # index scales by the row stride (element_type size), not the innermost
    # scalar width that glob_elem_size records.
    bt2: uint32 = expr_array_type(base)
    if bt2 != 0 and nd_kind[nd_a[bt2]] == ND_ARRAY_TYPE:
        return type_size_of(nd_a[bt2])
    # A bare-identifier base into an `Array[N, Struct]` global: the index
    # stride is sizeof(Struct), NOT the bogus 8 that prim_type_size(Struct)
    # records into glob_elem_size. Mirrors the seed's element_size_of where
    # get_type_size of a struct ArrayType element is the struct's total size.
    if bt2 != 0 and struct_lookup_by_node(nd_a[bt2]) != 0:
        return type_size_of(nd_a[bt2])
    es: uint32 = lookup_elem_size(nd_name_off[base], nd_name_len[base])
    if es != 0:
        return es
    # A Ptr[Struct] local/param (`vq: Ptr[VirtQueue]`): the index STRIDE for
    # `p[i].field` is sizeof(Struct), NOT the bogus 8 that ptr_pointee_size
    # (prim_type_size of a struct) records into loc_ptr_size. Mirrors the
    # seed's element_size_of(PointerType) = get_type_size(base_type), which is
    # struct-aware (st_total). Must precede the lookup_ptr_size fallback, whose
    # 8 would mis-stride any non-zero index into a Ptr[Struct] (array/walk).
    lsi: uint32 = lookup_local_struct(nd_name_off[base], nd_name_len[base])
    if lsi != 0 and \
       lookup_local_struct_is_ptr(nd_name_off[base], nd_name_len[base]) != 0:
        return st_total[lsi - 1]
    # A Ptr[T] local/param: the load/store width is the pointee size.
    ps: uint32 = lookup_ptr_size(nd_name_off[base], nd_name_len[base])
    if ps != 0:
        return ps
    # Fall back to a global array, then a Ptr[T] global.
    gi: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
    if gi != 0 and glob_elem_size[gi - 1] != 0:
        return glob_elem_size[gi - 1]
    # A Ptr[Struct] GLOBAL: same stride fix as the local case — the index
    # stride is sizeof(Struct), not the 8 ptr_pointee_size recorded into
    # glob_ptr_size. glob_type_node carries the Ptr[T] node; its pointee
    # resolving to a struct yields the struct total size via type_size_of.
    if gi != 0 and glob_ptr_size[gi - 1] != 0:
        gtn: uint32 = glob_type_node[gi - 1]
        if gtn != 0 and nd_kind[gtn] == ND_PTR_TYPE and \
           struct_lookup_by_node(nd_a[gtn]) != 0:
            return type_size_of(nd_a[gtn])
        return glob_ptr_size[gi - 1]
    # A plain scalar (uint64-as-pointer) base: a known scalar local or global
    # whose value is an address. The seed's element_size_of defaults to 8 here.
    soff2: int32 = 0
    if lookup_local(nd_name_off[base], nd_name_len[base], &soff2) != 0:
        return 8
    if gi != 0:
        return 8
    # Not a known array local or global — outside this subset.
    cg_fail(8, node)
    return 1


# Signedness tristate (2 SIGNED / 1 unsigned / 0 unknown) of the index node
# `arr[i]`'s ELEMENT type, so its value-load sign-extends a signed sub-8-byte
# element / zero-extends otherwise — exactly codegen_x86.gen_index_load's
# `signed = self._index_elem_is_signed(expr.obj)` guard, which reads the
# element/base type off get_expr_type(container) for EVERY base shape (named
# array, pointer, cast, member), not just the cast. A previous version only
# handled the cast + member bases and returned 0 (zero-extend) for a NAMED
# array base, so a signed sub-8-byte array element (`g_int32[i]` of an
# `Array[N, int32]` global, or a local `Array[N, int8]`) zero-extended where
# the seed sign-extends — a sub-8-byte LOAD-extension miscompile of the same
# class as the store fixes (the wide value's high bits diverge: -9 read as
# 0x00000000FFFFFFF7 instead of 0xFFFFFFFFFFFFFFF7). Now every base shape
# resolves its element type and reports its signedness, byte-matching the seed.
def index_elem_signed(node: uint32) -> uint32:
    base: uint32 = nd_a[node]
    # cast[Ptr[T]](expr)[i] / fn(...)[i] : element = the pointee T on the cast/
    # callee Ptr[T] return type.
    if nd_kind[base] == ND_CAST:
        ct: uint32 = nd_a[base]
        if ct != 0 and nd_kind[ct] == ND_PTR_TYPE:
            return type_signedness(nd_a[ct])
        return 0
    if nd_kind[base] == ND_CALL:
        rt: uint32 = call_return_type(base)
        if rt != 0 and nd_kind[rt] == ND_PTR_TYPE:
            return type_signedness(nd_a[rt])
        return 0
    # obj.field[i] : element signedness recorded on the array/Ptr struct field.
    if nd_kind[base] == ND_MEMBER:
        msgn: uint32 = 0
        member_index_elem(base, &msgn)
        return msgn
    # Nested index `g_grid[r][c]` : the element at THIS level is the base
    # array's element type. A multi-dimensional OUTER level's element is itself
    # an ND_ARRAY_TYPE (an address — type_signedness returns 0, zero-extend);
    # the deepest level's element is the scalar type. Mirrors expr_array_type.
    if nd_kind[base] == ND_INDEX:
        bt0: uint32 = expr_array_type(base)
        if bt0 != 0:
            return type_signedness(nd_a[bt0])
        return 0
    if nd_kind[base] != ND_IDENT:
        return 0
    # Named ARRAY base (local or global): the element type is nd_a of the
    # recorded ND_ARRAY_TYPE. Both alloc paths record the type node (locals via
    # declare_local's loc_type_node, globals via glob_set_type_node), so this
    # covers 1-D scalar element arrays (the common case) and reports 0 for a
    # multi-dimensional outer element (an ND_ARRAY_TYPE address).
    bt: uint32 = expr_array_type(base)
    if bt != 0:
        return type_signedness(nd_a[bt])
    # Named Ptr[T] base (local/param): recover the pointee T's signedness from
    # the local's recorded Ptr[T] type node (declare_local now stores it). This
    # is the `a: Ptr[uint8]` param indexed `a[i]` case — its element compare/
    # shift must be UNSIGNED (the seed's get_expr_type(IndexExpr)->PointerType.
    # base_type). A signed pointee (Ptr[int32]) reports 2 -> signed op.
    ltn: uint32 = lookup_local_type_node(nd_name_off[base], nd_name_len[base])
    if ltn != 0 and nd_kind[ltn] == ND_PTR_TYPE:
        return type_signedness(nd_a[ltn])
    return 0


# Float WIDTH (0 / 4 / 8) of an indexed element `base[i]`, structurally mirroring
# index_elem_signed but reading type_float_width of the resolved element type.
# Used ONLY by the IR float guard (ir_subtree_has_float): a float-typed array/
# pointer element must route its containing arith/compare to the SSE emitter, so
# the IR integer path must refuse it. Conservative: any base shape this can't
# resolve returns 0 (not-float) — but for the IR path the SURROUNDING binary node
# is only lowered if BOTH operands resolve cleanly, and a genuinely float element
# IS resolved here for the array/ptr/cast shapes the lowered subset produces.
def index_elem_float(node: uint32) -> uint32:
    base: uint32 = nd_a[node]
    if nd_kind[base] == ND_CAST:
        ct: uint32 = nd_a[base]
        if ct != 0 and nd_kind[ct] == ND_PTR_TYPE:
            return type_float_width(nd_a[ct])
        return 0
    if nd_kind[base] == ND_CALL:
        rt: uint32 = call_return_type(base)
        if rt != 0 and nd_kind[rt] == ND_PTR_TYPE:
            return type_float_width(nd_a[rt])
        return 0
    if nd_kind[base] == ND_INDEX:
        bt0: uint32 = expr_array_type(base)
        if bt0 != 0:
            return type_float_width(nd_a[bt0])
        return 0
    if nd_kind[base] != ND_IDENT:
        return 0
    bt: uint32 = expr_array_type(base)
    if bt != 0:
        return type_float_width(nd_a[bt])
    ltn: uint32 = lookup_local_type_node(nd_name_off[base], nd_name_len[base])
    if ltn != 0 and nd_kind[ltn] == ND_PTR_TYPE:
        return type_float_width(nd_a[ltn])
    return 0


# Float WIDTH of an arbitrary expression for the IR float guard, covering the
# leaf kinds the IR lowers (ident / cast / index) plus literals. Unlike
# expr_float_width (which only knows ident/cast/float-lit and arithmetic binops),
# this ALSO resolves a float ARRAY/POINTER element (index_elem_float) and a cast
# whose dest is float — the operand shapes a compare/div leaf can take. A struct
# MEMBER read is treated as POSSIBLY float (returns 8) since field float-ness is
# not tracked: but the lowering never forms a MEMBER leaf, so a member only
# appears as the seed-emitted interior of some OTHER leaf, never as an IR operand
# the integer path would mis-handle. Returns 0 only when provably integer.
def expr_leaf_float_width(node: uint32) -> uint32:
    if node == 0:
        return 0
    k: uint32 = nd_kind[node]
    if k == ND_FLOAT_LIT:
        return 8
    if k == ND_CAST:
        return type_float_width(nd_a[node])
    if k == ND_IDENT:
        lf: uint32 = lookup_local_float(nd_name_off[node], nd_name_len[node])
        if lf != 0:
            return lf
        gi: uint32 = glob_lookup(nd_name_off[node], nd_name_len[node])
        if gi != 0:
            return glob_is_float[gi - 1]
        return 0
    if k == ND_INDEX:
        return index_elem_float(node)
    if k == ND_MEMBER:
        # Field float-ness is not tracked; be conservative (treat as float) so the
        # IR guard refuses any binary node with a member operand. (Lowering never
        # forms a member leaf either, so this only adds a safe fallback.)
        return 8
    return 0


# Compute &arr[i] into %rax. Index in nd_b, array identifier in nd_a. The
# base may be a local Array slot (leaq off(%rbp)) or a global Array
# (leaq data_off(%rip)). Both decay to a base address then add a scaled
# index, exactly like codegen_x86.gen_index_address.
def gen_index_addr(node: uint32):
    base: uint32 = nd_a[node]

    # ---- cast[Ptr[T]](expr)[i] : base is an arbitrary expression cast to a
    # pointer. The cast's VALUE is the base address — gen_expr(base) leaves
    # the pointer value in %rax (ND_CAST evaluates its operand, and a Ptr[T]
    # target is not a narrowing primitive so no truncation runs). Then add the
    # scaled index, exactly like codegen_x86.gen_index_address's non-Array
    # (pointer-typed) branch: it `gen_expr(expr.obj)` for a non-ArrayType base
    # (a CastExpr to Ptr[T] is non-Array) and adds index*element_size_of. The
    # stride is index_elem_size(node) = sizeof(T) from the cast target.
    # ---- fn(...)[i] : base is a function CALL returning Ptr[T]. Same shape as
    # the cast case — gen_expr(base) leaves the returned pointer value in %rax.
    if nd_kind[base] == ND_CAST or nd_kind[base] == ND_CALL:
        es_c: uint32 = index_elem_size(node)
        gen_expr(nd_b[node])              # index -> %rax
        emit_push_rax()                   # spill (gen_expr(base) clobbers %rax)
        gen_expr(base)                    # cast/call pointer value (base addr) -> %rax
        emit_pop_rcx()                    # index -> %rcx
        emit_scale_rcx(es_c)
        emit_add_rcx_rax()
        return

    # ---- "lit"[i] : the base is a STRING LITERAL. gen_expr leaves the
    # interned string's address (a RIP-relative leaq to .data) in %rax, exactly
    # the seed's element_size_of/get_expr_type(StringLiteral) path where a
    # string literal decays to a byte pointer. The element stride is 1 byte
    # (uint8 characters), so no scaling is needed. This is what makes the
    # idiom `&"/bin/login"[0]` (address-of the first byte of a literal) work.
    if nd_kind[base] == ND_STRING_LIT:
        es_s: uint32 = index_elem_size(node)  # 8 (seed's default; see note)
        gen_expr(nd_b[node])              # index -> %rax
        emit_push_rax()                   # spill (gen_expr(base) clobbers %rax)
        gen_expr(base)                    # interned string address -> %rax
        emit_pop_rcx()                    # index -> %rcx
        emit_scale_rcx(es_s)              # match the oracle's stride of 8
        emit_add_rcx_rax()
        return

    # ---- obj.field[i] : the base is a struct/class MEMBER (an array or Ptr[T]
    # field). gen_member_address(obj, field) computes &obj.field; for an ARRAY
    # field that IS the element base, for a Ptr[T] field that is the address OF
    # the pointer slot, so load the held pointer value. Then add scaled index.
    # Mirrors codegen_x86.gen_index_address's non-Identifier base via
    # gen_addr_of/gen_expr on the member, scaled by element_size_of.
    if nd_kind[base] == ND_MEMBER:
        is_ptr_m: uint32 = 0
        sidx_m: uint32 = member_resolve(nd_a[base], &is_ptr_m)
        if sidx_m == 0:
            cg_fail(8, node)
            return
        foff_m: uint32 = 0
        fsgn_m: uint32 = 0
        fsz_m: uint32 = struct_field_find(sidx_m, nd_name_off[base], nd_name_len[base], &foff_m, &fsgn_m)
        if fsz_m == SF_NOFIELD:
            cg_fail(8, node)
            return
        es_m: uint32 = index_elem_size(node)
        gen_expr(nd_b[node])              # index -> %rax
        emit_push_rax()                   # spill (member addr gen clobbers %rax)
        gen_member_address(nd_a[base], nd_name_off[base], nd_name_len[base])  # &obj.field -> %rax
        if fsz_m == 8:
            # Ptr[T] field: the slot holds a pointer value; deref to the base.
            emit_load_mem_rax(8)
        emit_pop_rcx()                    # index -> %rcx
        emit_scale_rcx(es_m)
        emit_add_rcx_rax()
        return

    # ---- Nested index into a multi-dimensional array global --------------
    # `g_grid[r][c]`: the base is itself an index expression yielding a ROW
    # address. Recursively compute that row's address, then add the scaled
    # element index. The stride at THIS level is index_elem_size(node)
    # (type_size of the element type — a scalar at the deepest level, a row
    # at an intermediate level). This mirrors codegen_x86.gen_index_address
    # recursing via gen_addr_of on an Array-typed (IndexExpr) base.
    if nd_kind[base] == ND_INDEX:
        es_n: uint32 = index_elem_size(node)
        gen_expr(nd_b[node])              # index -> %rax
        emit_push_rax()                   # spill index (recursion clobbers %rax)
        gen_index_addr(base)              # row base address -> %rax
        emit_pop_rcx()                    # index -> %rcx
        emit_scale_rcx(es_n)
        emit_add_rcx_rax()
        return

    if nd_kind[base] != ND_IDENT:
        cg_fail(8, node)
        return

    # ---- Bare-identifier base that is a multi-dimensional array global ----
    # The OUTER index of `g_grid[r]` scales by the row stride (the element
    # type size), and the base address is the global symbol. Handle this
    # before the flat classification so the row stride (not the innermost
    # scalar width glob_elem_size records) is used.
    bt_md: uint32 = expr_array_type(base)
    if bt_md != 0 and nd_kind[nd_a[bt_md]] == ND_ARRAY_TYPE:
        es_md: uint32 = type_size_of(nd_a[bt_md])
        # The base may be a multi-dim array LOCAL (`a: Array[N, Array[M,T]]`)
        # or GLOBAL; materialise the row-block base address accordingly.
        loff_md: int32 = 0
        if lookup_local(nd_name_off[base], nd_name_len[base], &loff_md) != 0:
            gen_expr(nd_b[node])
            emit_mov_rax_rcx()
            emit_scale_rcx(es_md)
            emit_lea_local_rax(loff_md)
            emit_add_rcx_rax()
            return
        gi_md: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
        gen_expr(nd_b[node])
        emit_mov_rax_rcx()
        emit_scale_rcx(es_md)
        emit_lea_global_rax(glob_offset[gi_md - 1], glob_is_bss[gi_md - 1])
        emit_add_rcx_rax()
        return

    # ---- Bare-identifier base that is an `Array[N, Struct]` global ----
    # `partition_table[i]`: the index scales by sizeof(Struct) (the element
    # stride), NOT the bogus 8 glob_elem_size records for a struct element.
    # The base address is the global symbol. Mirrors the multi-dim branch
    # above but with the struct total as the stride.
    if bt_md != 0 and struct_lookup_by_node(nd_a[bt_md]) != 0:
        gi_so: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
        es_so: uint32 = type_size_of(nd_a[bt_md])
        gen_expr(nd_b[node])
        emit_mov_rax_rcx()
        emit_scale_rcx(es_so)
        emit_lea_global_rax(glob_offset[gi_so - 1], glob_is_bss[gi_so - 1])
        emit_add_rcx_rax()
        return

    # Classify the base. There are four base flavours, all of which decay to
    # a base address that we add a scaled index to (mirroring
    # codegen_x86.gen_index_address). The ONLY difference is how the base
    # address is materialised into %rax:
    #   * Array local      -> leaq off(%rbp)           (slot IS the array)
    #   * Array global     -> leaq data_off(%rip)      (symbol IS the array)
    #   * Ptr[T] local      -> movq off(%rbp),%rax       (slot HOLDS the addr)
    #   * Ptr[T] global     -> leaq data_off(%rip); movq (%rax),%rax
    #                          (load the pointer value the global holds)
    es: uint32 = lookup_elem_size(nd_name_off[base], nd_name_len[base])
    off: int32 = 0
    arr_local: uint32 = 0
    ptr_local: uint32 = 0
    if es != 0 and lookup_local(nd_name_off[base], nd_name_len[base], &off) != 0:
        arr_local = 1
    if arr_local == 0:
        ps: uint32 = lookup_ptr_size(nd_name_off[base], nd_name_len[base])
        if ps != 0 and lookup_local(nd_name_off[base], nd_name_len[base], &off) != 0:
            ptr_local = 1
            es = ps
            # Ptr[Struct] local/param (`vq: Ptr[VirtQueue]`): the index STRIDE
            # is sizeof(Struct), not the 8 ptr_pointee_size recorded into
            # loc_ptr_size. Mirrors the seed's element_size_of(PointerType) =
            # get_type_size(base_type) (struct-aware). Without this, `vq[i].f`
            # for i!=0 lands on the wrong element (8-byte stride vs 40).
            lsi_p: uint32 = lookup_local_struct(nd_name_off[base],
                                                nd_name_len[base])
            if lsi_p != 0 and lookup_local_struct_is_ptr(
                    nd_name_off[base], nd_name_len[base]) != 0:
                es = st_total[lsi_p - 1]
    arr_glob: uint32 = 0
    ptr_glob: uint32 = 0
    # A plain scalar (uint64-as-pointer) base: the identifier is a non-array,
    # non-Ptr local/global whose VALUE is an address (`p: uint64; p[0] = v`).
    # The seed's element_size_of defaults to 8 for such a base and
    # gen_index_address gen_expr's the value as the pointer. scalar_ptr is set
    # when neither the array nor the Ptr classification matched but the base IS
    # a known scalar local/global.
    scalar_ptr: uint32 = 0
    gdoff: uint32 = 0
    gbss: uint32 = 0
    if arr_local == 0 and ptr_local == 0:
        gi: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
        if gi != 0 and glob_elem_size[gi - 1] != 0:
            arr_glob = 1
            es = glob_elem_size[gi - 1]
            gdoff = glob_offset[gi - 1]
            gbss = glob_is_bss[gi - 1]
        elif gi != 0 and glob_ptr_size[gi - 1] != 0:
            ptr_glob = 1
            es = glob_ptr_size[gi - 1]
            gdoff = glob_offset[gi - 1]
            gbss = glob_is_bss[gi - 1]
            # Ptr[Struct] global: same stride fix — sizeof(Struct) via the
            # recorded Ptr[T] type node, not the 8 in glob_ptr_size.
            gtn_p: uint32 = glob_type_node[gi - 1]
            if gtn_p != 0 and nd_kind[gtn_p] == ND_PTR_TYPE and \
               struct_lookup_by_node(nd_a[gtn_p]) != 0:
                es = type_size_of(nd_a[gtn_p])
        else:
            # Plain scalar base (uint64-as-pointer): default element size 8 and
            # use the base's VALUE as the address (gen_expr loads a local or a
            # scalar global). Only valid when the base is a known scalar local
            # or global; otherwise it is a genuine unknown.
            soff: int32 = 0
            sloc: uint32 = lookup_local(nd_name_off[base], nd_name_len[base], &soff)
            if sloc != 0:
                scalar_ptr = 1
                es = 8
                off = soff
            elif gi != 0:
                scalar_ptr = 2            # scalar global
                es = 8
                gdoff = glob_offset[gi - 1]
                gbss = glob_is_bss[gi - 1]
            else:
                cg_fail(8, node)
                return

    # Evaluate the index into %rax, move to %rcx, scale, then add the base
    # address. Result address ends up in %rax.
    gen_expr(nd_b[node])
    emit_mov_rax_rcx()

    # ---- ISEL (--opt): fold scale-shift + base-lea/load + add into a single
    # scaled-index `lea`. The index is already in %rcx; the SIB scale field
    # expresses *1/*2/*4/*8 natively, so we only need to materialise the base
    # and emit one lea. The computed element address is bit-identical to the
    # scale/add form below. Non-power-of-2 strides fall through to that form.
    if isel_is_enabled() != 0 and isel_scale_ok(es) != 0:
        sb: uint32 = isel_scale_bits(es)
        if arr_local != 0:
            # lea disp(%rbp, %rcx, s), %rax  — fold base-lea + scale + add.
            emit_lea_local_sib_rax(off, sb)
            opt_isel_count = opt_isel_count + 1
            return
        if ptr_local != 0 or scalar_ptr == 1:
            # Base = a pointer value held in a frame slot: load it to %rax,
            # then lea (%rax, %rcx, s), %rax (fold scale + add).
            emit_load_local_rax(off)
            emit_lea_base_rax_index_rcx(sb)
            opt_isel_count = opt_isel_count + 1
            return
        if arr_glob != 0:
            # Base = rip-relative global array address: lea it to %rax, then
            # lea (%rax, %rcx, s), %rax (rip form cannot carry a SIB index, so
            # the base-lea stays; we still fold the scale-shift + add).
            emit_lea_global_rax(gdoff, gbss)
            emit_lea_base_rax_index_rcx(sb)
            opt_isel_count = opt_isel_count + 1
            return
        # scalar_ptr == 2 or Ptr[T] global: load the held pointer value, then
        # fold scale + add via the index lea.
        emit_lea_global_rax(gdoff, gbss)
        emit_load_mem_rax(8)
        emit_lea_base_rax_index_rcx(sb)
        opt_isel_count = opt_isel_count + 1
        return

    emit_scale_rcx(es)
    if arr_local != 0:
        emit_lea_local_rax(off)
    elif ptr_local != 0:
        emit_load_local_rax(off)          # base address = pointer value
    elif arr_glob != 0:
        emit_lea_global_rax(gdoff, gbss)
    elif scalar_ptr == 1:
        # Scalar local holding an address: load its value (the address).
        emit_load_local_rax(off)
    elif scalar_ptr == 2:
        # Scalar global holding an address: leaq + load the held value.
        emit_lea_global_rax(gdoff, gbss)
        emit_load_mem_rax(8)
    else:
        # Ptr[T] global: load the address the global slot holds.
        emit_lea_global_rax(gdoff, gbss)
        emit_load_mem_rax(8)
    emit_add_rcx_rax()


# -----------------------------------------------------------------------
# Member access (obj.field). Mirrors codegen_x86.gen_member_address /
# gen_member_load. The subset resolves obj as a bare identifier that is a
# struct-typed local/global (in-place value) OR a Ptr[Struct] local/param
# (the `self` receiver inside a method body):
#   * in-place struct value -> &obj + field_offset  (leaq slot/global; addq)
#   * Ptr[Struct] value     -> (loaded pointer value) + field_offset
# Field offsets + widths come from the struct table (struct_field_find).
# -----------------------------------------------------------------------

# Resolve `obj`'s struct type. On success returns the struct-table index
# (+1) and writes 1/0 through out_is_ptr for the Ptr[Struct] vs in-place
# distinction. Returns 0 if obj is not a (supported) struct-typed lvalue.
# 1 if `node` is the special `self` identifier (ND_IDENT marked nd_aux==1).
def is_self_ident(node: uint32) -> uint32:
    if nd_kind[node] != ND_IDENT:
        return 0
    if nd_aux[node] == 1:
        return 1
    return 0


def member_resolve(obj: uint32, out_is_ptr: Ptr[uint32]) -> uint32:
    # NESTED member access `base.inner.leaf`: the object is itself an
    # ND_MEMBER (`base.inner`) whose field type is a struct (embedded value) or
    # a Ptr[Struct]. Resolve the struct of `base.inner` by first resolving the
    # struct of `base` (recursively), then looking up the `inner` field's
    # nested-struct index. The element is an in-place struct value
    # (out_is_ptr=0) unless `inner` is a Ptr[Struct] field (out_is_ptr=1, the
    # pointer VALUE is the base address). Mirrors codegen_x86 resolving an
    # inner MemberExpr via get_expr_type -> _resolve_struct.
    if nd_kind[obj] == ND_MEMBER:
        inner_is_ptr: uint32 = 0
        inner_sidx: uint32 = member_resolve(nd_a[obj], &inner_is_ptr)
        if inner_sidx == 0:
            return 0
        fld_is_ptr: uint32 = 0
        fsi: uint32 = struct_field_struct(inner_sidx, nd_name_off[obj], nd_name_len[obj], &fld_is_ptr)
        if fsi == 0:
            return 0
        out_is_ptr[0] = fld_is_ptr
        return fsi
    # `ptr[i].field` / `arr[i].field`: the object is an INDEX expression whose
    # base identifier is a Ptr[Struct] or an Array-of-Struct. The element
    # itself is an IN-PLACE struct value at the address gen_index_addr(obj)
    # computes, so report out_is_ptr=0 (gen_member_address then routes through
    # gen_addr_of -> gen_index_addr to get &base[i], + field offset). Mirrors
    # codegen_x86.gen_member_address's IndexExpr-base object handling.
    if nd_kind[obj] == ND_INDEX:
        base: uint32 = nd_a[obj]
        # `cast[Ptr[Struct]](e)[i].field`: the index base is an expression cast
        # to Ptr[Struct]. The element `cast[Ptr[Struct]](e)[i]` is an IN-PLACE
        # struct value whose address gen_index_addr(obj) computes via the cap#4
        # cast-ptr-index path (base value + i*sizeof(Struct)). Resolve the
        # struct from the cast's Ptr[T] target, mirroring the seed's
        # get_expr_type(IndexExpr)=obj_type.base_type for a PointerType cast,
        # then _resolve_struct on that pointee. Report out_is_ptr=0 so
        # gen_member_address routes through gen_addr_of -> gen_index_addr.
        if nd_kind[base] == ND_CAST or nd_kind[base] == ND_CALL:
            # `cast[Ptr[S]](e)[i].leaf` / `fn(...)[i].leaf`: the index base is a
            # Ptr[Struct]-typed expression. Its element `base[i]` is an in-place
            # struct value (out_is_ptr=0); gen_index_addr computes its address
            # from the pointer VALUE (gen_expr(base)) + i*sizeof(S).
            csi: uint32 = expr_ptr_struct(base)
            if csi != 0:
                out_is_ptr[0] = 0
                return csi
            return 0
        # `outer.field[i].leaf`: the index base is an ND_MEMBER naming an
        # array-of-struct / Ptr[struct] field. Resolve the field's element
        # struct: get the struct of `outer`, then the element struct of its
        # `field`. The element `outer.field[i]` is an IN-PLACE struct value
        # (out_is_ptr=0; gen_index_addr computes &outer.field[i]).
        if nd_kind[base] == ND_MEMBER:
            bm_is_ptr: uint32 = 0
            bm_sidx: uint32 = member_resolve(nd_a[base], &bm_is_ptr)
            if bm_sidx == 0:
                return 0
            mesi: uint32 = struct_field_elem_struct(bm_sidx, nd_name_off[base], nd_name_len[base])
            if mesi != 0:
                out_is_ptr[0] = 0
                return mesi
            return 0
        if nd_kind[base] != ND_IDENT:
            return 0
        ls0: uint32 = lookup_local_struct(nd_name_off[base], nd_name_len[base])
        if ls0 != 0:
            out_is_ptr[0] = 0
            return ls0
        gi0: uint32 = glob_lookup(nd_name_off[base], nd_name_len[base])
        if gi0 != 0 and glob_struct_idx[gi0 - 1] != 0:
            out_is_ptr[0] = 0
            return glob_struct_idx[gi0 - 1]
        # `arr_of_struct[i].field` for an `Array[N, Struct]` GLOBAL. A struct
        # array global takes the ND_ARRAY_TYPE layout branch (it never sets
        # glob_struct_idx — only glob_elem_size/glob_type_node), so resolve the
        # element struct off the recorded array type node: nd_a[ND_ARRAY_TYPE]
        # is the element type T, and struct_lookup_by_node(T) gives its struct
        # index. Mirrors the seed's get_expr_type(IndexExpr)=ArrayType.
        # element_type -> _resolve_struct. The element is an IN-PLACE struct
        # value (out_is_ptr=0); gen_index_addr scales by the element stride.
        if gi0 != 0 and glob_type_node[gi0 - 1] != 0:
            atn0: uint32 = glob_type_node[gi0 - 1]
            if nd_kind[atn0] == ND_ARRAY_TYPE:
                gesi: uint32 = struct_lookup_by_node(nd_a[atn0])
                if gesi != 0:
                    out_is_ptr[0] = 0
                    return gesi
        return 0
    if nd_kind[obj] != ND_IDENT:
        return 0
    # `self` receiver inside a method body: a Ptr[Struct] held at cg_self_off.
    if is_self_ident(obj) != 0 and cg_self_struct != 0:
        out_is_ptr[0] = 1
        return cg_self_struct
    ls: uint32 = lookup_local_struct(nd_name_off[obj], nd_name_len[obj])
    if ls != 0:
        out_is_ptr[0] = lookup_local_struct_is_ptr(nd_name_off[obj], nd_name_len[obj])
        return ls
    gi: uint32 = glob_lookup(nd_name_off[obj], nd_name_len[obj])
    if gi != 0 and glob_struct_idx[gi - 1] != 0:
        out_is_ptr[0] = 0            # struct globals are in-place values
        return glob_struct_idx[gi - 1]
    return 0


# Compute the ADDRESS of obj.member into %rax. Mirrors gen_member_address.
def gen_member_address(obj: uint32, mem_off: uint32, mem_len: uint32):
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(8, obj)
        return
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, mem_off, mem_len, &foff, &fsgn)
    if fsz == SF_NOFIELD:
        cg_fail(8, obj)
        return
    if is_ptr != 0:
        # Ptr[Struct]: the pointer's VALUE is the base address. A bare
        # identifier evaluates to its held address (load the slot).
        gen_expr(obj)
    else:
        gen_addr_of(obj)
    if foff != 0:
        emit_add_imm_rax(foff)


# Member field load: value of obj.member into %rax. An array-typed field
# (fsz==0) decays to its ADDRESS (no load), mirroring gen_member_load.
def gen_member_load(node: uint32):
    obj: uint32 = nd_a[node]
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(8, node)
        return
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, nd_name_off[node], nd_name_len[node], &foff, &fsgn)
    if fsz == SF_NOFIELD:
        cg_fail(8, node)
        return
    gen_member_address(obj, nd_name_off[node], nd_name_len[node])
    if fsz == 0:
        return                       # array/struct field decays to its address
    if fsgn != 0:
        emit_load_mem_rax_signed(fsz)
    else:
        emit_load_mem_rax(fsz)


# Member field store: obj.member = value (plain) / OP= value (augmented).
# Mirrors gen_assignment's MemberExpr target branch (sized store; for the
# augmented form, address-once read-modify-write).
def gen_assign_member(node: uint32):
    tgt: uint32 = nd_a[node]            # ND_MEMBER
    obj: uint32 = nd_a[tgt]
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(2, node)
        return
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, nd_name_off[tgt], nd_name_len[tgt], &foff, &fsgn)
    if fsz == SF_NOFIELD or fsz == 0:
        cg_fail(2, node)             # cannot assign a whole array field
        return
    aug: uint32 = nd_aux[node]
    if aug == AUGOP_NONE:
        # Plain store. Mirror gen_assign_index's register convention
        # (codegen.ad stores %rcx into (%rax)): eval value, push; compute
        # &obj.member into %rax; pop value into %rcx; sized store.
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_member_address(obj, nd_name_off[tgt], nd_name_len[tgt])
        emit_pop_rcx()
        emit_store_mem_rcx(fsz)
        return
    # Augmented `obj.f OP= v`: new = (load obj.f) OP v.
    gen_expr(nd_b[node])
    emit_push_rax()
    gen_member_address(obj, nd_name_off[tgt], nd_name_len[tgt])
    if fsgn != 0:
        emit_load_mem_rax_signed(fsz)
    else:
        emit_load_mem_rax(fsz)
    emit_pop_rcx()
    if aug == AUGOP_ADD:
        emit_add_rcx_rax()
    elif aug == AUGOP_SUB:
        emit_sub_rcx_rax()
    elif aug == AUGOP_MUL:
        emit_imul_rcx_rax()
    else:
        cg_fail(2, node)
        return
    emit_push_rax()                  # new value
    gen_member_address(obj, nd_name_off[tgt], nd_name_len[tgt])
    emit_pop_rcx()                   # new value -> %rcx
    emit_store_mem_rcx(fsz)


# 1 if class `cls` (an ND_CLASS) directly declares a method named
# [m_off,m_len). Method chain head is nd_b; each entry is an ND_FUNCTION.
def class_has_own_method(cls: uint32, m_off: uint32, m_len: uint32) -> uint32:
    m: uint32 = nd_b[cls]
    while m != 0:
        if name_match(nd_name_off[m], nd_name_len[m], m_off, m_len) != 0:
            return 1
        m = nd_next[m]
    return 0


# Resolve the OWNER class (the ND_CLASS that literally declares method
# [m_off,m_len)) for a receiver whose static class is `cls`, mirroring
# codegen_x86's class_methods first-match-wins walk: the class's OWN methods
# override inherited ones, so check own methods first, then bases
# left-to-right depth-first. Returns the owner class decl node, or 0 if no
# such method exists in the hierarchy.
def method_owner(cls: uint32, m_off: uint32, m_len: uint32) -> uint32:
    if class_has_own_method(cls, m_off, m_len) != 0:
        return cls
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc != 0:
            owner: uint32 = method_owner(bc, m_off, m_len)
            if owner != 0:
                return owner
        b = nd_next[b]
    return 0


# Offset just past `cls`'s last flattened field, mirroring
# codegen_x86._collect_class_methods.end_of_fields: walk bases depth-first
# (left-to-right) then own fields, aligning each field to its natural
# alignment, advancing by each field's size — but WITHOUT the trailing
# 8-byte .bss round-up that layout_struct applies to st_total. This is the
# right "where does the next adjacent base start?" answer when placing the
# second-and-later bases during multi-base flattening (st_total would
# over-count by up to 7 padding bytes and push later bases off their real
# layout slot). Returns 0 for an unknown class.
def class_end_of_fields(cls: uint32) -> uint32:
    off: uint32 = 0
    # Bases first (nd_c = head of base-ident chain), depth-first.
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc != 0:
            off = off + class_end_of_fields(bc)
        b = nd_next[b]
    # Own fields (nd_a = head of ND_CLASS_FIELD chain), aligned then advanced.
    f: uint32 = nd_a[cls]
    while f != 0:
        tnode: uint32 = nd_a[f]
        align: uint32 = natural_align(tnode)
        off = (off + align - 1) & cast[uint32](0 - align)
        off = off + type_size_of(tnode)
        f = nd_next[f]
    return off


# Byte offset within `cls`'s flattened layout at which the layout of the
# OWNER class (the one that literally declares method [m_off,m_len)) begins,
# mirroring codegen_x86._collect_class_methods.resolve's running_offset.
# A class's OWN methods sit at offset 0 (self.field addresses the full
# layout, which starts at 0). For a method inherited from a base, the
# offset is the sum of class_end_of_fields() over the bases that precede
# the owning base, plus the owner's offset WITHIN that base (transitive
# multi-base). First-match-wins identical to method_owner: own methods
# override inherited ones, bases scanned left-to-right depth-first.
# Returns 0 when the method is the class's own (or single-inheritance,
# where every base sits at offset 0); 0xFFFFFFFF if not found (caller
# already validated via method_owner so this is belt-and-suspenders).
def receiver_offset_for(cls: uint32, m_off: uint32, m_len: uint32) -> uint32:
    if class_has_own_method(cls, m_off, m_len) != 0:
        return 0
    running: uint32 = 0
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc != 0:
            if method_owner(bc, m_off, m_len) != 0:
                inner: uint32 = receiver_offset_for(bc, m_off, m_len)
                return running + inner
            running = running + class_end_of_fields(bc)
        b = nd_next[b]
    return 0xFFFFFFFF


# -----------------------------------------------------------------------
# Method-call lowering — `obj.method(args)` (ND_METHOD_CALL: a=obj,
# name=method, b=arg chain, aux=argc). Mirrors codegen_x86.gen_method_call:
# resolve obj's class, find the owning class for `method`, and emit a direct
# call to the mangled `<Owner>__<method>` symbol passing &obj (or obj's
# pointer value if obj is Ptr[Struct]) as the implicit FIRST arg (self).
# Register-arg path only (self + up to 5 explicit args = 6 total).
# -----------------------------------------------------------------------
def gen_method_call(node: uint32):
    obj: uint32 = nd_a[node]
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(obj, &is_ptr)
    if sidx1 == 0:
        cg_fail(8, node)
        return
    cls: uint32 = st_decl[sidx1 - 1]
    owner: uint32 = method_owner(cls, nd_name_off[node], nd_name_len[node])
    if owner == 0:
        cg_fail(8, node)             # class has no such method
        return
    argc: uint32 = nd_aux[node]
    total: uint32 = argc + 1         # + implicit self
    if total > 6:
        cg_fail(8, node)
        return

    # Marshal arg0 = receiver (self): &obj (in-place) or the pointer value
    # (Ptr[Struct]). codegen.ad's gen_addr_of/gen_expr already produce the
    # right thing. For multi-base inheritance where the method's owning base
    # sits at a non-zero byte offset within the receiver's flattened layout,
    # bump the receiver pointer by that offset so the callee's self.field
    # references (addressed against the OWNER's struct layout, which begins
    # at offset 0 of the owner) land on the right bytes. Single inheritance
    # (and a class's own methods) gives receiver_offset==0 — no bump.
    # Mirrors codegen_x86.gen_method_call's receiver_offset path exactly.
    if is_ptr != 0:
        gen_expr(obj)                # pointer value = receiver address
    else:
        gen_addr_of(obj)             # &obj = receiver address
    recv_off: uint32 = receiver_offset_for(cls, nd_name_off[node], nd_name_len[node])
    if recv_off != 0 and recv_off != 0xFFFFFFFF:
        emit_add_imm_rax(recv_off)   # &obj + sizeof(prior bases)
    emit_push_rax()
    # Then the explicit args, lowest index first.
    arg: uint32 = nd_b[node]
    i: uint32 = 0
    while i < argc:
        gen_expr(arg)
        emit_push_rax()
        arg = nd_next[arg]
        i = i + 1
    # Pop in reverse so self lands in %rdi, arg0 in %rsi, ...
    i = total
    while i > 0:
        i = i - 1
        emit_pop_argreg(i)
    emit_xor_eax_eax()
    emit_b(0xE8)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_method_fixup(at, nd_name_off[owner], nd_name_len[owner], nd_name_off[node], nd_name_len[node])


# Is `name` (strbuf ref) the literal "__init__"? Used to detect the
# constructor method when lowering `Foo(args)` ctor sugar.
def name_is_init(name_off: uint32, name_len: uint32) -> uint32:
    if name_len != 8:
        return 0
    # "__init__" = 5f 5f 69 6e 69 74 5f 5f
    if strbuf[name_off] != 95:
        return 0
    if strbuf[name_off + 1] != 95:
        return 0
    if strbuf[name_off + 2] != 105:     # 'i'
        return 0
    if strbuf[name_off + 3] != 110:     # 'n'
        return 0
    if strbuf[name_off + 4] != 105:     # 'i'
        return 0
    if strbuf[name_off + 5] != 116:     # 't'
        return 0
    if strbuf[name_off + 6] != 95:
        return 0
    if strbuf[name_off + 7] != 95:
        return 0
    return 1


# Constructor sugar: `f: Foo = Foo(args)` where Foo is a class with an
# `__init__` method lowers to `Foo__init(&f, args)`. `decl` is the ND_VAR_DECL
# (its name = the target local), `tnode` its struct type, `val` the Foo(args)
# CallExpr. Mirrors codegen_x86._ctor_call_class + _emit_ctor_init. If Foo has
# NO __init__, an in-place struct decl with a call init is unsupported here.
def gen_ctor_init(decl: uint32, tnode: uint32, val: uint32):
    if nd_kind[val] != ND_CALL:
        cg_fail(2, decl)
        return
    callee: uint32 = nd_a[val]
    if nd_kind[callee] != ND_IDENT:
        cg_fail(2, decl)
        return
    # The call name must be the struct's own class name.
    if name_match(nd_name_off[callee], nd_name_len[callee], nd_name_off[tnode], nd_name_len[tnode]) == 0:
        cg_fail(2, decl)
        return
    cls: uint32 = class_lookup_decl(nd_name_off[tnode], nd_name_len[tnode])
    if cls == 0:
        cg_fail(2, decl)
        return
    # Find the owning class for __init__ (own or inherited).
    owner: uint32 = 0
    m: uint32 = nd_b[cls]
    while m != 0:
        if name_is_init(nd_name_off[m], nd_name_len[m]) != 0:
            owner = cls
            m = 0
        else:
            m = nd_next[m]
    if owner == 0:
        # No __init__: a struct decl initialised by a bare Foo() with no ctor
        # is just a zeroed slot in the Python model — but a Foo(args) with
        # arguments and no __init__ is a program error. The fuzzer always
        # pairs Foo(args) with an __init__, so treat a missing ctor as
        # unsupported rather than silently dropping the args.
        cg_fail(2, decl)
        return
    argc: uint32 = nd_aux[val]
    total: uint32 = argc + 1
    if total > 6:
        cg_fail(2, decl)
        return
    # arg0 = &local (the target slot address).
    off: int32 = 0
    if lookup_local(nd_name_off[decl], nd_name_len[decl], &off) == 0:
        cg_fail(2, decl)
        return
    emit_lea_local_rax(off)
    emit_push_rax()
    arg: uint32 = nd_b[val]
    i: uint32 = 0
    while i < argc:
        gen_expr(arg)
        emit_push_rax()
        arg = nd_next[arg]
        i = i + 1
    i = total
    while i > 0:
        i = i - 1
        emit_pop_argreg(i)
    emit_xor_eax_eax()
    emit_b(0xE8)
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_method_fixup(at, nd_name_off[owner], nd_name_len[owner], nd_name_off[m_init_name(owner)], nd_name_len[m_init_name(owner)])


# Return the ND_FUNCTION node of `cls`'s __init__ method (for its name ref).
def m_init_name(cls: uint32) -> uint32:
    m: uint32 = nd_b[cls]
    while m != 0:
        if name_is_init(nd_name_off[m], nd_name_len[m]) != 0:
            return m
        m = nd_next[m]
    return 0


# -----------------------------------------------------------------------
# Inline-asm assembler: assemble the bounded set of x86_64 instructions the
# kernel's asm_volatile("...") bodies use into the EXACT bytes GNU `as`
# produces, emitting them into code[] at the current code_len and recording
# RIP-relative data relocations for `sym(%rip)` operands via add_data_fixup.
# The seed (codegen_x86.py, `elif name == "asm_volatile"`) emits each
# stripped non-empty line as assembly text; this is the self-contained
# byte-emitting equivalent.
# -----------------------------------------------------------------------

# Compare strbuf bytes [s,e) to the NUL-terminated literal `lit`.
def asm_tok_eq(s: uint32, e: uint32, lit: Ptr[uint8]) -> int32:
    i: uint32 = 0
    while s + i < e:
        c: uint32 = cast[uint32](lit[i])
        if c == 0:
            return 0                      # literal shorter than the token
        if cast[uint32](strbuf[s + i]) != c:
            return 0
        i = i + 1
    if cast[uint32](lit[i]) != 0:
        return 0                          # literal longer than the token
    return 1

def asm_is_space(c: uint32) -> int32:
    if c == 32:                           # ' '
        return 1
    if c == 9:                            # '\t'
        return 1
    if c == 13:                           # '\r'
        return 1
    return 0

# Map a register name (strbuf [s,e), WITHOUT the leading '%') to a number
# 0..15 (rax=0,rcx=1,rdx=2,rbx=3,rsp=4,rbp=5,rsi=6,rdi=7,r8..r15=8..15).
# Returns the number, or 999 if unrecognised.
def asm_reg_num(s: uint32, e: uint32) -> uint32:
    if asm_tok_eq(s, e, "rax") != 0:
        return 0
    if asm_tok_eq(s, e, "rcx") != 0:
        return 1
    if asm_tok_eq(s, e, "rdx") != 0:
        return 2
    if asm_tok_eq(s, e, "rbx") != 0:
        return 3
    if asm_tok_eq(s, e, "rsp") != 0:
        return 4
    if asm_tok_eq(s, e, "rbp") != 0:
        return 5
    if asm_tok_eq(s, e, "rsi") != 0:
        return 6
    if asm_tok_eq(s, e, "rdi") != 0:
        return 7
    if asm_tok_eq(s, e, "r8") != 0:
        return 8
    if asm_tok_eq(s, e, "r9") != 0:
        return 9
    if asm_tok_eq(s, e, "r10") != 0:
        return 10
    if asm_tok_eq(s, e, "r11") != 0:
        return 11
    if asm_tok_eq(s, e, "r12") != 0:
        return 12
    if asm_tok_eq(s, e, "r13") != 0:
        return 13
    if asm_tok_eq(s, e, "r14") != 0:
        return 14
    if asm_tok_eq(s, e, "r15") != 0:
        return 15
    return 999

# Skip leading whitespace in [s,e); return the new start.
def asm_skip_ws(s: uint32, e: uint32) -> uint32:
    p: uint32 = s
    while p < e and asm_is_space(cast[uint32](strbuf[p])) != 0:
        p = p + 1
    return p

# End of the first whitespace-delimited token starting at s (within [s,e)).
def asm_tok_end(s: uint32, e: uint32) -> uint32:
    p: uint32 = s
    while p < e and asm_is_space(cast[uint32](strbuf[p])) == 0:
        p = p + 1
    return p

# Parse a non-negative decimal integer from strbuf [s,e) (whole span).
def asm_parse_dec(s: uint32, e: uint32) -> uint64:
    v: uint64 = 0
    p: uint32 = s
    while p < e:
        c: uint32 = cast[uint32](strbuf[p])
        if c < 48 or c > 57:
            return v
        v = v * 10 + cast[uint64](c - 48)
        p = p + 1
    return v

# Look up a local asm label by name [s,e); returns its block-relative byte
# offset, or 0xFFFFFFFF if not found.
def asm_lbl_lookup(s: uint32, e: uint32) -> uint32:
    i: uint32 = 0
    while i < asm_lbl_count:
        ls: uint32 = asm_lbl_name_s[i]
        le: uint32 = asm_lbl_name_e[i]
        if le - ls == e - s:
            if asm_span_eq(ls, le, s, e) != 0:
                return asm_lbl_off[i]
        i = i + 1
    return 4294967295

# Byte-equality of two strbuf spans of equal length.
def asm_span_eq(as_: uint32, ae: uint32, bs: uint32, be: uint32) -> int32:
    if ae - as_ != be - bs:
        return 0
    i: uint32 = 0
    while as_ + i < ae:
        if strbuf[as_ + i] != strbuf[bs + i]:
            return 0
        i = i + 1
    return 1

# A RIP memory operand parse result lives in these module globals (one
# operand in flight at a time during single-threaded codegen).
asm_rip_data_off: uint32 = 0
asm_rip_is_bss: uint32 = 0
asm_rip_ok: int32 = 0

# Parse a `SYM(%rip)` or `SYM+DISP(%rip)` operand occupying strbuf [s,e).
# On success sets asm_rip_data_off / asm_rip_is_bss / asm_rip_ok=1.
# data_off = glob_offset(SYM) + DISP. cg_fail(11) on an unknown global.
def asm_parse_rip(s: uint32, e: uint32):
    asm_rip_ok = 0
    # SYM = identifier chars up to '+' or '('.
    p: uint32 = s
    while p < e:
        c: uint32 = cast[uint32](strbuf[p])
        if c == 43 or c == 40:            # '+' or '('
            break
        p = p + 1
    sym_s: uint32 = s
    sym_e: uint32 = p
    disp: uint64 = 0
    if p < e and cast[uint32](strbuf[p]) == 43:    # '+DISP'
        p = p + 1
        d_s: uint32 = p
        while p < e and cast[uint32](strbuf[p]) >= 48 and cast[uint32](strbuf[p]) <= 57:
            p = p + 1
        disp = asm_parse_dec(d_s, p)
    # Expect "(%rip)".
    if p >= e or cast[uint32](strbuf[p]) != 40:    # '('
        return
    gi: uint32 = glob_lookup(sym_s, sym_e - sym_s)
    if gi == 0:
        return
    asm_rip_data_off = glob_offset[gi - 1] + cast[uint32](disp)
    asm_rip_is_bss = glob_is_bss[gi - 1]
    asm_rip_ok = 1

# Fixed byte size of the instruction on stripped line [s,e). Mirrors
# asm_emit_line exactly so the two-pass label offsets stay consistent.
# Returns 0xFFFFFFFF on an unsupported line (the emit pass then cg_fails).
def asm_line_size(s: uint32, e: uint32) -> uint32:
    # Label definition `.Lxxx:` -> zero bytes.
    if e - s >= 2 and strbuf[s] == 46 and cast[uint32](strbuf[e - 1]) == 58:
        return 0
    ms: uint32 = s
    me: uint32 = asm_tok_end(s, e)
    # Zero-operand / fixed-size mnemonics.
    if asm_tok_eq(ms, me, "cli") != 0:
        return 1
    if asm_tok_eq(ms, me, "sti") != 0:
        return 1
    if asm_tok_eq(ms, me, "hlt") != 0:
        return 1
    if asm_tok_eq(ms, me, "int3") != 0:
        return 1
    if asm_tok_eq(ms, me, "pushfq") != 0:
        return 1
    if asm_tok_eq(ms, me, "pause") != 0:
        return 2
    if asm_tok_eq(ms, me, "mfence") != 0:
        return 3
    if asm_tok_eq(ms, me, "cpuid") != 0:
        return 2
    if asm_tok_eq(ms, me, "syscall") != 0:
        return 2
    if asm_tok_eq(ms, me, "rdrand") != 0:
        return 4
    if asm_tok_eq(ms, me, "rdseed") != 0:
        return 4
    if asm_tok_eq(ms, me, "pushq") != 0:
        return asm_pushpop_size(ms, me, s, e)
    if asm_tok_eq(ms, me, "popq") != 0:
        return asm_pushpop_size(ms, me, s, e)
    if asm_tok_eq(ms, me, "jmpq") != 0:
        return asm_indirect_size(s, e)        # FF /4 (+REX.B)
    if asm_tok_eq(ms, me, "call") != 0:
        return asm_indirect_size(s, e)        # FF /2 (+REX.B)
    if asm_tok_eq(ms, me, "jmp") != 0:
        return 2                              # short rel8
    if asm_tok_eq(ms, me, "jc") != 0:
        return 2
    if asm_tok_eq(ms, me, "loop") != 0:
        return 2
    if asm_tok_eq(ms, me, "lidt") != 0:
        return 7                              # 0F 01 /3 + disp32
    if asm_tok_eq(ms, me, "mulq") != 0:
        return 7                              # 48 F7 /4 + disp32
    if asm_tok_eq(ms, me, "lock") != 0:
        return 3                              # lock incl (%rdi) -> F0 FF 07
    if asm_tok_eq(ms, me, "movl") != 0:
        return 8                              # movl %gs:sym+disp, %eax (32S)
    if asm_tok_eq(ms, me, "movq") != 0:
        return asm_movq_size(s, e)
    return 4294967295

# Size of a pushq/popq line: register form = 1 (or 2 with REX.B); the only
# memory form used is `popq sym(%rip)` = 8F 05 + disp32 = 6 bytes.
def asm_pushpop_size(ms: uint32, me: uint32, s: uint32, e: uint32) -> uint32:
    o: uint32 = asm_skip_ws(me, e)
    if o < e and cast[uint32](strbuf[o]) == 37:        # '%' register
        rn: uint32 = asm_reg_num(o + 1, asm_tok_end(o, e))
        if rn >= 8:
            return 2
        return 1
    return 6                                            # popq sym(%rip)

# Size of an indirect jmpq/call `*%reg`: 2 bytes, +1 REX.B for r8..r15.
def asm_indirect_size(s: uint32, e: uint32) -> uint32:
    o: uint32 = asm_skip_ws(asm_tok_end(s, e), e)
    if o < e and cast[uint32](strbuf[o]) == 42:        # '*'
        o = o + 1
    if o < e and cast[uint32](strbuf[o]) == 37:        # '%'
        rn: uint32 = asm_reg_num(o + 1, asm_tok_end(o, e))
        if rn >= 8 and rn != 999:
            return 3
        return 2
    return 4294967295

# Size of a movq line by operand shape.
def asm_movq_size(s: uint32, e: uint32) -> uint32:
    o: uint32 = asm_skip_ws(asm_tok_end(s, e), e)
    if o >= e:
        return 4294967295
    c0: uint32 = cast[uint32](strbuf[o])
    if c0 == 36:                                        # '$imm, dst'
        # movq $imm,%reg = 48 C7 /0 + imm32 = 7 bytes;
        # movq $imm,sym(%rip) = 48 C7 05 + disp32 + imm32 = 11 bytes.
        cp: uint32 = asm_find_comma(o, e)
        d: uint32 = asm_skip_ws(cp + 1, e)
        if d < e and cast[uint32](strbuf[d]) == 37:
            return 7
        return 11
    if c0 == 37:                                        # '%gs:' or '%reg, ...'
        # '%gs:sym, %rax' -> 65 48 8B 04 25 + disp32(32S) = 9 bytes.
        if asm_is_gs(o, e) != 0:
            return 9
        # 'movq %reg, dst' : reg->reg = 3; reg->sym(%rip) = 7.
        cp2: uint32 = asm_find_comma(o, e)
        d2: uint32 = asm_skip_ws(cp2 + 1, e)
        if d2 < e and cast[uint32](strbuf[d2]) == 37:
            return 3
        return 7
    # 'movq sym(%rip), %reg' load -> 48 8B /r + disp32 = 7 bytes.
    # 'movq DISP(%rbp), %reg'   -> 48 8B 4xreg + disp8 = 4 bytes.
    if asm_is_dispbp(o, e) != 0:
        return 4
    return 7

# True if operand at o is the %gs:... segment form.
def asm_is_gs(o: uint32, e: uint32) -> int32:
    if o + 3 < e and strbuf[o] == 37 and strbuf[o + 1] == 103 and strbuf[o + 2] == 115 and strbuf[o + 3] == 58:
        return 1                                        # "%gs:"
    return 0

# True if operand at o is a DISP(%rbp) memory form (starts with '-' or digit
# then '(').
def asm_is_dispbp(o: uint32, e: uint32) -> int32:
    c: uint32 = cast[uint32](strbuf[o])
    if c == 45 or (c >= 48 and c <= 57):                # '-' or digit
        p: uint32 = o
        while p < e and cast[uint32](strbuf[p]) != 40:  # up to '('
            p = p + 1
        if p < e and p + 1 < e and strbuf[p + 1] == 37:
            return 1
    return 0

# Offset of the first ',' in [o,e); returns e if none.
def asm_find_comma(o: uint32, e: uint32) -> uint32:
    p: uint32 = o
    while p < e:
        if cast[uint32](strbuf[p]) == 44:
            return p
        p = p + 1
    return e

# Emit a rel8 branch (opcode `op`) targeting local label name [ls,le). The
# next instruction starts at code_len+2 (1 opcode + 1 rel8). rel8 = target -
# (here + 2). cg_fail(11) if the label is unknown or the displacement
# overflows a signed byte. block_start = code offset of the block's first
# byte (label offsets are block-relative).
def asm_emit_rel8(op: uint32, ls: uint32, le: uint32, block_start: uint32):
    rel_off: uint32 = asm_lbl_lookup(ls, le)
    if rel_off == 4294967295:
        cg_fail(11, 0)
        return
    target: int32 = cast[int32](block_start + rel_off)
    here_end: int32 = cast[int32](code_len + 2)
    d: int32 = target - here_end
    if d < cast[int32](0) - cast[int32](128) or d > 127:
        cg_fail(11, 0)
        return
    emit_b(op)
    emit_b(cast[uint32](cast[uint8](cast[int32](d & 255))))

# Emit a `sym(%rip)`-style RIP-relative instruction tail: the disp32 field
# starts at the CURRENT code_len; record a data fixup so it resolves to
# (DATA_BASE + data_off) - (disp_field + 4). For the imm-to-mem movq form
# (imm32 trails the disp32), pass data_off already adjusted by -4.
def asm_emit_rip_disp32(data_off: uint32, is_bss: uint32):
    at: uint32 = code_len
    emit_imm32(cast[uint64](0))
    add_data_fixup(at, data_off, is_bss)

# Emit one assembled instruction for stripped line [s,e). block_start lets
# rel8 jumps resolve against the block-relative label table.
def asm_emit_line(s: uint32, e: uint32, block_start: uint32):
    # Label definitions emit nothing.
    if e - s >= 2 and strbuf[s] == 46 and cast[uint32](strbuf[e - 1]) == 58:
        return
    ms: uint32 = s
    me: uint32 = asm_tok_end(s, e)
    # --- zero-operand / fixed encodings ---
    if asm_tok_eq(ms, me, "cli") != 0:
        emit_b(0xFA)
        return
    if asm_tok_eq(ms, me, "sti") != 0:
        emit_b(0xFB)
        return
    if asm_tok_eq(ms, me, "hlt") != 0:
        emit_b(0xF4)
        return
    if asm_tok_eq(ms, me, "int3") != 0:
        emit_b(0xCC)
        return
    if asm_tok_eq(ms, me, "pushfq") != 0:
        emit_b(0x9C)
        return
    if asm_tok_eq(ms, me, "pause") != 0:
        emit_b(0xF3)
        emit_b(0x90)
        return
    if asm_tok_eq(ms, me, "mfence") != 0:
        emit_b(0x0F)
        emit_b(0xAE)
        emit_b(0xF0)
        return
    if asm_tok_eq(ms, me, "cpuid") != 0:
        emit_b(0x0F)
        emit_b(0xA2)
        return
    if asm_tok_eq(ms, me, "syscall") != 0:
        emit_b(0x0F)
        emit_b(0x05)
        return
    if asm_tok_eq(ms, me, "rdrand") != 0:
        # rdrand %rax -> 48 0F C7 F0 (/6, modrm 0xF0 = C0|6<<3 for rax)
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xC7)
        emit_b(0xF0)
        return
    if asm_tok_eq(ms, me, "rdseed") != 0:
        # rdseed %rax -> 48 0F C7 F8 (/7)
        emit_b(0x48)
        emit_b(0x0F)
        emit_b(0xC7)
        emit_b(0xF8)
        return
    # --- branches with local labels ---
    if asm_tok_eq(ms, me, "jmp") != 0:
        o: uint32 = asm_skip_ws(me, e)
        asm_emit_rel8(0xEB, o, asm_tok_end(o, e), block_start)
        return
    if asm_tok_eq(ms, me, "jc") != 0:
        o2: uint32 = asm_skip_ws(me, e)
        asm_emit_rel8(0x72, o2, asm_tok_end(o2, e), block_start)
        return
    if asm_tok_eq(ms, me, "loop") != 0:
        o3: uint32 = asm_skip_ws(me, e)
        asm_emit_rel8(0xE2, o3, asm_tok_end(o3, e), block_start)
        return
    # --- indirect jmpq/call *%reg ---
    if asm_tok_eq(ms, me, "jmpq") != 0:
        asm_emit_indirect(s, e, 4)         # /4
        return
    if asm_tok_eq(ms, me, "call") != 0:
        asm_emit_indirect(s, e, 2)         # /2
        return
    # --- pushq/popq ---
    if asm_tok_eq(ms, me, "pushq") != 0:
        asm_emit_pushpop(s, e, me, 1)
        return
    if asm_tok_eq(ms, me, "popq") != 0:
        asm_emit_pushpop(s, e, me, 0)
        return
    # --- lidt sym(%rip) -> 0F 01 1D disp32 ---
    if asm_tok_eq(ms, me, "lidt") != 0:
        op: uint32 = asm_skip_ws(me, e)
        asm_parse_rip(op, e)
        if asm_rip_ok == 0:
            cg_fail(11, 0)
            return
        emit_b(0x0F)
        emit_b(0x01)
        emit_b(0x1D)
        asm_emit_rip_disp32(asm_rip_data_off, asm_rip_is_bss)
        return
    # --- mulq sym(%rip) -> 48 F7 25 disp32 ---
    if asm_tok_eq(ms, me, "mulq") != 0:
        op2: uint32 = asm_skip_ws(me, e)
        asm_parse_rip(op2, e)
        if asm_rip_ok == 0:
            cg_fail(11, 0)
            return
        emit_b(0x48)
        emit_b(0xF7)
        emit_b(0x25)
        asm_emit_rip_disp32(asm_rip_data_off, asm_rip_is_bss)
        return
    # --- lock incl (%rdi) -> F0 FF 07 ---
    if asm_tok_eq(ms, me, "lock") != 0:
        emit_b(0xF0)
        emit_b(0xFF)
        emit_b(0x07)
        return
    # --- movl %gs:sym+disp, %eax -> 65 8B 04 25 disp32(R_X86_64_32S) ---
    if asm_tok_eq(ms, me, "movl") != 0:
        asm_emit_movl_gs(s, e, me)
        return
    if asm_tok_eq(ms, me, "movq") != 0:
        asm_emit_movq(s, e, me)
        return
    cg_fail(11, 0)

# Emit jmpq/call `*%reg`. ext = 4 (jmpq /4) or 2 (call /2). FF (modrm
# = 0xC0 | (ext<<3) | (reg&7)); r8..r15 get a REX.B (0x41) prefix.
def asm_emit_indirect(s: uint32, e: uint32, ext: uint32):
    o: uint32 = asm_skip_ws(asm_tok_end(s, e), e)
    if o < e and cast[uint32](strbuf[o]) == 42:        # '*'
        o = o + 1
    if o >= e or cast[uint32](strbuf[o]) != 37:        # '%'
        cg_fail(11, 0)
        return
    rn: uint32 = asm_reg_num(o + 1, asm_tok_end(o, e))
    if rn == 999:
        cg_fail(11, 0)
        return
    if rn >= 8:
        emit_b(0x41)
    emit_b(0xFF)
    emit_b(0xC0 + (ext << 3) + (rn & 7))

# Emit pushq/popq. push reg = 0x50+rn (push); pop reg = 0x58+rn. r8..r15
# add REX.B (0x41). The only memory form used is `popq sym(%rip)` = 8F 05
# disp32 (no REX).
def asm_emit_pushpop(s: uint32, e: uint32, me: uint32, is_push: uint32):
    o: uint32 = asm_skip_ws(me, e)
    if o < e and cast[uint32](strbuf[o]) == 37:        # '%reg'
        rn: uint32 = asm_reg_num(o + 1, asm_tok_end(o, e))
        if rn == 999:
            cg_fail(11, 0)
            return
        if rn >= 8:
            emit_b(0x41)
        base: uint32 = 0x58                            # pop
        if is_push != 0:
            base = 0x50
        emit_b(base + (rn & 7))
        return
    # popq sym(%rip)
    if is_push != 0:
        cg_fail(11, 0)                                 # pushq mem unsupported
        return
    asm_parse_rip(o, e)
    if asm_rip_ok == 0:
        cg_fail(11, 0)
        return
    emit_b(0x8F)
    emit_b(0x05)
    asm_emit_rip_disp32(asm_rip_data_off, asm_rip_is_bss)

# movl %gs:sym[+disp], %eax  ->  65 8B 04 25 <disp32 R_X86_64_32S>.
# This uses an ABSOLUTE 32-bit-signed reloc, not RIP-relative. The native
# fixup table only carries PC32 relocs, so an absolute %gs form can't be
# resolved here; the kernel's %gs asm lives in standalone modules (not the
# init/main.ad whole-program build), so flag it as unsupported with a clear
# reason rather than emitting wrong bytes.
def asm_emit_movl_gs(s: uint32, e: uint32, me: uint32):
    cg_fail(11, 0)

# movq forms.
def asm_emit_movq(s: uint32, e: uint32, me: uint32):
    o: uint32 = asm_skip_ws(me, e)
    if o >= e:
        cg_fail(11, 0)
        return
    c0: uint32 = cast[uint32](strbuf[o])
    if c0 == 36:                                       # movq $imm, dst
        asm_emit_movq_imm(o, e)
        return
    if c0 == 37:                                       # movq %src, dst  (or %gs:)
        if asm_is_gs(o, e) != 0:
            cg_fail(11, 0)                             # absolute %gs reloc
            return
        asm_emit_movq_reg_src(o, e)
        return
    # movq mem, %reg  (sym(%rip) load, or DISP(%rbp) load)
    asm_emit_movq_mem_load(o, e)

# movq $imm, %reg  -> 48 C7 /0 (modrm C0|reg) imm32
# movq $imm, sym(%rip) -> 48 C7 05 disp32 imm32  (disp uses data_off-4 so
# the PC32 addend lands relative to instruction END, past the imm32).
def asm_emit_movq_imm(o: uint32, e: uint32):
    cp: uint32 = asm_find_comma(o, e)
    imm_s: uint32 = o + 1                              # skip '$'
    imm: uint64 = asm_parse_dec(imm_s, cp)
    d: uint32 = asm_skip_ws(cp + 1, e)
    if d < e and cast[uint32](strbuf[d]) == 37:        # %reg dest
        rn: uint32 = asm_reg_num(d + 1, asm_tok_end(d, e))
        if rn == 999 or rn >= 8:
            cg_fail(11, 0)                             # only low regs used
            return
        emit_b(0x48)
        emit_b(0xC7)
        emit_b(0xC0 + (rn & 7))
        emit_imm32(imm)
        return
    # sym(%rip) dest
    asm_parse_rip(d, e)
    if asm_rip_ok == 0:
        cg_fail(11, 0)
        return
    emit_b(0x48)
    emit_b(0xC7)
    emit_b(0x05)
    asm_emit_rip_disp32(asm_rip_data_off - 4, asm_rip_is_bss)
    emit_imm32(imm)

# movq %src, dst : src->reg (89/r) or src->sym(%rip) store.
def asm_emit_movq_reg_src(o: uint32, e: uint32):
    src_e: uint32 = asm_find_comma(o, e)
    rn: uint32 = asm_reg_num(o + 1, src_e)
    if rn == 999:
        cg_fail(11, 0)
        return
    d: uint32 = asm_skip_ws(src_e + 1, e)
    if d < e and cast[uint32](strbuf[d]) == 37:        # %dst reg-to-reg
        dn: uint32 = asm_reg_num(d + 1, asm_tok_end(d, e))
        if dn == 999:
            cg_fail(11, 0)
            return
        # REX.W + REX.R(if src r8+) + REX.B(if dst r8+); opcode 89;
        # modrm = 0xC0 | ((src&7)<<3) | (dst&7).
        rex: uint32 = 0x48
        if rn >= 8:
            rex = rex + 0x04
        if dn >= 8:
            rex = rex + 0x01
        emit_b(rex)
        emit_b(0x89)
        emit_b(0xC0 + ((rn & 7) << 3) + (dn & 7))
        return
    # store to sym(%rip): REX.W [REX.R] 89 modrm(05|reg<<3) disp32.
    asm_parse_rip(d, e)
    if asm_rip_ok == 0:
        cg_fail(11, 0)
        return
    rex2: uint32 = 0x48
    if rn >= 8:
        rex2 = rex2 + 0x04
    emit_b(rex2)
    emit_b(0x89)
    emit_b(0x05 + ((rn & 7) << 3))
    asm_emit_rip_disp32(asm_rip_data_off, asm_rip_is_bss)

# movq mem, %reg : sym(%rip) load (48 8B /r disp32) or DISP(%rbp) load
# (48 8B modrm(reg<<3|5) disp8).
def asm_emit_movq_mem_load(o: uint32, e: uint32):
    cp: uint32 = asm_find_comma(o, e)
    d: uint32 = asm_skip_ws(cp + 1, e)
    if d >= e or cast[uint32](strbuf[d]) != 37:
        cg_fail(11, 0)
        return
    dn: uint32 = asm_reg_num(d + 1, asm_tok_end(d, e))
    if dn == 999:
        cg_fail(11, 0)
        return
    if asm_is_dispbp(o, e) != 0:
        # DISP(%rbp): DISP is signed decimal, possibly negative.
        neg: int32 = 0
        ds: uint32 = o
        if cast[uint32](strbuf[ds]) == 45:             # '-'
            neg = 1
            ds = ds + 1
        de: uint32 = ds
        while de < e and cast[uint32](strbuf[de]) >= 48 and cast[uint32](strbuf[de]) <= 57:
            de = de + 1
        dv: int32 = cast[int32](asm_parse_dec(ds, de))
        if neg != 0:
            dv = cast[int32](0) - dv
        if dv < cast[int32](0) - cast[int32](128) or dv > 127:
            cg_fail(11, 0)                             # only disp8 used
            return
        rex: uint32 = 0x48
        if dn >= 8:
            rex = rex + 0x04
        emit_b(rex)
        emit_b(0x8B)
        emit_b(0x45 + ((dn & 7) << 3))                 # mod=01 rm=101(rbp)
        emit_b(cast[uint32](cast[uint8](cast[int32](dv & 255))))
        return
    # sym(%rip) load.
    asm_parse_rip(o, e)
    if asm_rip_ok == 0:
        cg_fail(11, 0)
        return
    rex2: uint32 = 0x48
    if dn >= 8:
        rex2 = rex2 + 0x04
    emit_b(rex2)
    emit_b(0x8B)
    emit_b(0x05 + ((dn & 7) << 3))
    asm_emit_rip_disp32(asm_rip_data_off, asm_rip_is_bss)

# Lower asm_volatile(<string-literal arg>). Two passes over the literal's
# lines: pass 1 records each `.Lxxx:` label's block-relative byte offset
# (via deterministic per-line sizes); pass 2 emits the bytes, resolving
# rel8 branches against the label table.
def gen_asm_volatile(arg: uint32):
    txt_s: uint32 = nd_name_off[arg]
    txt_len: uint32 = nd_name_len[arg]
    txt_e: uint32 = txt_s + txt_len
    block_start: uint32 = code_len
    asm_lbl_count = 0
    # Pass 1: label offsets + size validation.
    rel: uint32 = 0
    ls: uint32 = txt_s
    while ls <= txt_e:
        le: uint32 = ls
        while le < txt_e and cast[uint32](strbuf[le]) != 10:
            le = le + 1
        # Strip leading/trailing whitespace.
        a: uint32 = asm_skip_ws(ls, le)
        b: uint32 = le
        while b > a and asm_is_space(cast[uint32](strbuf[b - 1])) != 0:
            b = b - 1
        if b > a:
            if b - a >= 2 and strbuf[a] == 46 and cast[uint32](strbuf[b - 1]) == 58:
                # Label def `.Lxxx:` — record name (excl trailing ':').
                if asm_lbl_count >= MAX_ASM_LABELS:
                    cg_fail(11, 0)
                    return
                asm_lbl_name_s[asm_lbl_count] = a
                asm_lbl_name_e[asm_lbl_count] = b - 1
                asm_lbl_off[asm_lbl_count] = rel
                asm_lbl_count = asm_lbl_count + 1
            else:
                sz: uint32 = asm_line_size(a, b)
                if sz == 4294967295:
                    cg_fail(11, 0)
                    return
                rel = rel + sz
        if le >= txt_e:
            ls = txt_e + 1                             # past end -> stop
        else:
            ls = le + 1
    # Pass 2: emit.
    ls = txt_s
    while ls <= txt_e:
        le2: uint32 = ls
        while le2 < txt_e and cast[uint32](strbuf[le2]) != 10:
            le2 = le2 + 1
        a2: uint32 = asm_skip_ws(ls, le2)
        b2: uint32 = le2
        while b2 > a2 and asm_is_space(cast[uint32](strbuf[b2 - 1])) != 0:
            b2 = b2 - 1
        if b2 > a2:
            asm_emit_line(a2, b2, block_start)
            if cg_err != 0:
                return
        if le2 >= txt_e:
            ls = txt_e + 1
        else:
            ls = le2 + 1

# -----------------------------------------------------------------------
# Call codegen — direct call to a named function. Mirrors codegen_x86's
# gen_call register-arg path (args 0..5 only): evaluate each argument into
# %rax and push it, then pop them in reverse so arg 0 lands in %rdi, clear
# %al, and `call <callee>`. Result is left in %rax. Stack args (7+) and
# indirect calls are outside this subset.
# -----------------------------------------------------------------------

# container_of(ptr, Type, field): compile-time pointer adjustment. Evaluate
# the field-pointer expr into %rax, then subtract the field's byte offset
# within `Type`, yielding a pointer to the enclosing struct. Mirrors the seed's
# ContainerOfExpr lowering (gen_expr(inner); subq $off,%rax). Node layout:
# nd_a = ptr expr, name = struct type name, name2 = field name.
def gen_container_of(node: uint32):
    sidx1: uint32 = struct_lookup(nd_name_off[node], nd_name_len[node])
    if sidx1 == 0:
        cg_fail(8, node)                  # unknown struct
        return
    foff: uint32 = 0
    fsgn: uint32 = 0
    fsz: uint32 = struct_field_find(sidx1, nd_name2_off[node], nd_name2_len[node], &foff, &fsgn)
    if fsz == SF_NOFIELD:
        cg_fail(8, node)                  # struct has no such field
        return
    gen_expr(nd_a[node])                  # field pointer -> %rax
    if foff != 0:
        emit_sub_imm_rax(foff)


# sizeof(T): fold to the compile-time byte size of type T (an immediate into
# %rax). Mirrors the seed's SizeOfExpr constant fold. nd_a = the type node.
def gen_sizeof(node: uint32):
    sz: uint32 = type_size_of(nd_a[node])
    emit_mov_imm_rax(cast[uint64](sz))


# Port-I/O + atomic intrinsics (the seed's X86_INTRINSICS). Returns a small
# code 1..10 identifying the intrinsic, or 0. Lowered inline to bare in/out /
# lock cmpxchg / lock xadd — NO `call`, mirroring codegen_x86.gen_io_intrinsic.
def io_intrinsic_id(name_off: uint32, name_len: uint32) -> uint32:
    if name_eq_cstr(name_off, name_len, "outb") != 0:
        return 1
    if name_eq_cstr(name_off, name_len, "inb") != 0:
        return 2
    if name_eq_cstr(name_off, name_len, "outl") != 0:
        return 3
    if name_eq_cstr(name_off, name_len, "inl") != 0:
        return 4
    if name_eq_cstr(name_off, name_len, "outw") != 0:
        return 5
    if name_eq_cstr(name_off, name_len, "inw") != 0:
        return 6
    if name_eq_cstr(name_off, name_len, "atomic_cas32") != 0:
        return 7
    if name_eq_cstr(name_off, name_len, "atomic_cas64") != 0:
        return 8
    if name_eq_cstr(name_off, name_len, "atomic_add32") != 0:
        return 9
    if name_eq_cstr(name_off, name_len, "atomic_add64") != 0:
        return 10
    return 0


# Lower a port-I/O / atomic intrinsic call (id from io_intrinsic_id). Bytes
# mirror codegen_x86.gen_io_intrinsic exactly.
def gen_io_intrinsic(node: uint32, iid: uint32):
    a0: uint32 = nd_b[node]
    # outb/outl/outw(value, port): value->%rax,push; port->%dx; pop value->%al;
    # out.
    if iid == 1 or iid == 3 or iid == 5:
        a1: uint32 = nd_next[a0]
        gen_expr(a0)
        emit_push_rax()
        gen_expr(a1)
        emit_b(0x66)               # movw %ax,%dx
        emit_b(0x89)
        emit_b(0xC2)
        emit_pop_rax()
        if iid == 1:
            emit_b(0xEE)           # outb %al,%dx
        elif iid == 3:
            emit_b(0xEF)           # outl %eax,%dx
        else:
            emit_b(0x66)           # outw %ax,%dx
            emit_b(0xEF)
        return
    # inb/inl/inw(port) -> zero-extended value in %rax.
    if iid == 2 or iid == 4 or iid == 6:
        gen_expr(a0)
        emit_b(0x66)               # movw %ax,%dx
        emit_b(0x89)
        emit_b(0xC2)
        if iid == 2:
            emit_b(0x31)           # xorl %eax,%eax
            emit_b(0xC0)
            emit_b(0xEC)           # inb %dx,%al
        elif iid == 4:
            emit_b(0x48)           # xorq %rax,%rax
            emit_b(0x31)
            emit_b(0xC0)
            emit_b(0xED)           # inl %dx,%eax
        else:
            emit_b(0x48)           # xorq %rax,%rax
            emit_b(0x31)
            emit_b(0xC0)
            emit_b(0x66)           # inw %dx,%ax
            emit_b(0xED)
        return
    # atomic_cas32/64(addr, expected, desired) -> old value.
    if iid == 7 or iid == 8:
        a1c: uint32 = nd_next[a0]
        a2c: uint32 = nd_next[a1c]
        gen_expr(a0)               # addr
        emit_push_rax()
        gen_expr(a1c)              # expected
        emit_push_rax()
        gen_expr(a2c)              # desired
        emit_b(0x48)               # movq %rax,%rcx
        emit_b(0x89)
        emit_b(0xC1)
        emit_pop_rax()             # expected -> %rax
        emit_b(0x5A)               # popq %rdx  (addr)
        if iid == 8:
            emit_b(0xF0)           # lock cmpxchgq %rcx,(%rdx)
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xB1)
            emit_b(0x0A)
        else:
            emit_b(0xF0)           # lock cmpxchgl %ecx,(%rdx)
            emit_b(0x0F)
            emit_b(0xB1)
            emit_b(0x0A)
            emit_b(0x89)           # movl %eax,%eax (zero-extend)
            emit_b(0xC0)
        return
    # atomic_add32/64(addr, delta) -> old value (lock xadd).
    if iid == 9 or iid == 10:
        a1a: uint32 = nd_next[a0]
        gen_expr(a0)               # addr
        emit_push_rax()
        gen_expr(a1a)              # delta -> %rax
        emit_b(0x5A)               # popq %rdx (addr)
        if iid == 10:
            emit_b(0xF0)           # lock xaddq %rax,(%rdx)
            emit_b(0x48)
            emit_b(0x0F)
            emit_b(0xC1)
            emit_b(0x02)
        else:
            emit_b(0xF0)           # lock xaddl %eax,(%rdx)
            emit_b(0x0F)
            emit_b(0xC1)
            emit_b(0x02)
            emit_b(0x89)           # movl %eax,%eax (zero-extend)
            emit_b(0xC0)
        return


def gen_call(node: uint32):
    callee: uint32 = nd_a[node]
    if nd_kind[callee] != ND_IDENT:
        # Only direct calls to a bare name are in scope.
        cg_fail(8, node)
        return
    argc: uint32 = nd_aux[node]

    # --- port-I/O + atomic intrinsics (inline, no call) -----------------
    # Only intercept when NOT shadowed by a local of the same name (matches the
    # seed's intrinsic guard).
    iid_chk: int32 = 0
    if lookup_local(nd_name_off[callee], nd_name_len[callee], &iid_chk) == 0:
        iid: uint32 = io_intrinsic_id(nd_name_off[callee], nd_name_len[callee])
        if iid != 0:
            gen_io_intrinsic(node, iid)
            return

    # --- syscall builtin path -------------------------------------------
    # `__syscallN(num, a1..aN)` lowers to a raw Linux x86_64 `syscall`:
    # evaluate-and-push the N+1 operands, pop them into the syscall regs
    # (operand 0 = number -> %rax, operand 1 -> %rdi, ...), then `0F 05`.
    # Result is left in %rax (the syscall return value). No `call`, no
    # fixup — this is an inline instruction, not a function reference.
    nargs: uint32 = syscall_builtin_args(nd_name_off[callee],
                                         nd_name_len[callee])
    if nargs != 0:
        if argc != nargs + 1:
            cg_fail(8, node)
            return
        sarg: uint32 = nd_b[node]
        si: uint32 = 0
        while si < argc:
            gen_expr(sarg)
            emit_push_rax()
            sarg = nd_next[sarg]
            si = si + 1
        si = argc
        while si > 0:
            si = si - 1
            emit_pop_syscallreg(si)
        emit_syscall_insn()
        return

    # --- inline asm path -------------------------------------------------
    # `asm_volatile("...instructions...")` lowers to verbatim machine bytes
    # for the bounded instruction set the kernel uses. The seed
    # (codegen_x86.py) intercepts the call by NAME and emits each stripped
    # line as assembly text for GNU `as`; this self-contained emitter must
    # reproduce the exact bytes `as` produces.
    if name_eq_cstr(nd_name_off[callee], nd_name_len[callee], "asm_volatile") != 0:
        if argc != 1:
            cg_fail(8, node)
            return
        asm_arg: uint32 = nd_b[node]
        if nd_kind[asm_arg] != ND_STRING_LIT:
            cg_fail(8, node)
            return
        gen_asm_volatile(asm_arg)
        return

    # SysV AMD64 arg marshalling. Args 0..5 go in %rdi/%rsi/%rdx/%rcx/%r8/%r9;
    # args 6+ go on the stack in a 16-aligned chunk below %rsp at i*8(%rsp).
    # Mirrors codegen_x86.gen_call (direct path): stack args are evaluated and
    # stored FIRST (their gen_expr may clobber arg regs via inner push/pop),
    # then the register args are evaluated-and-pushed and popped last, just
    # before the call.
    n_reg: uint32 = argc
    if n_reg > 6:
        n_reg = 6
    n_stk: uint32 = argc - n_reg

    # INDIRECT vs DIRECT call. A callee NAME that is a LOCAL variable / parameter
    # is a first-class function-POINTER value (`fn(...)`, `cb(...)`, `hook(...)`
    # where fn/cb/hook are Fn[...]-typed params) — an indirect `call *%r11`. A
    # name that is NOT a local is a direct `call <sym>` (an in-unit function or,
    # at kernel scope, an `ld`-resolved extern). Mirrors the seed's is_direct
    # (name in defined/extern funcs AND not shadowed by a local).
    icall_off: int32 = 0
    is_local_call: uint32 = lookup_local(nd_name_off[callee], nd_name_len[callee], &icall_off)
    # A call is INDIRECT (through a function-pointer VALUE) when the callee name
    # is NOT a direct symbol — i.e. neither an in-unit Adder function nor a
    # declared `extern def` (an ld-resolved cross-object function). A LOCAL
    # function-pointer param/var OR a function-pointer GLOBAL (`*_hook`, `*_fn`,
    # a Fn[...]-typed global) is indirect. Mirrors the seed's is_direct =
    # (name in defined_funcs or extern_funcs) and not shadowed by a local.
    is_glob_fnptr: uint32 = 0
    if is_local_call == 0:
        if is_program_function(nd_name_off[callee], nd_name_len[callee]) == 0 and ext_lookup(nd_name_off[callee], nd_name_len[callee]) == 0:
            gci: uint32 = glob_lookup(nd_name_off[callee], nd_name_len[callee])
            if gci != 0:
                is_glob_fnptr = 1
    is_indirect: uint32 = 0
    if is_local_call != 0 or is_glob_fnptr != 0:
        is_indirect = 1

    # Indirect call: evaluate the function-pointer FIRST into a 16-byte stash
    # (keeps %rsp 16-aligned at the call), reclaimed into %r11 before the call.
    # Mirrors codegen_x86.gen_call's indirect path.
    if is_indirect != 0:
        if is_local_call != 0:
            emit_load_local_rax(icall_off)    # local function pointer -> %rax
        else:
            gci2: uint32 = glob_lookup(nd_name_off[callee], nd_name_len[callee])
            emit_lea_global_rax(glob_offset[gci2 - 1], glob_is_bss[gci2 - 1])
            emit_load_mem_rax(8)              # load the global's pointer value
        emit_sub_rsp(16)                       # 16-byte stash slot
        emit_store_rax_rsp_disp(8)             # movq %rax, 8(%rsp)

    # Stack args (6+): reserve a 16-aligned block, store each at i*8(%rsp).
    stack_bytes: uint32 = 0
    if n_stk > 0:
        stack_bytes = (n_stk * 8 + 15) & 4294967280   # round up to 16
        emit_sub_rsp(stack_bytes)
        si2: uint32 = 0
        while si2 < n_stk:
            gen_expr(nth_arg(node, n_reg + si2))
            emit_store_rax_rsp_disp(si2 * 8)
            si2 = si2 + 1

    # Register args (0..5): evaluate-and-push, then pop in reverse so arg 0
    # ends in %rdi. The pops are the last writes before `call`.
    arg: uint32 = nd_b[node]
    i: uint32 = 0
    while i < n_reg:
        gen_expr(arg)
        emit_push_rax()
        arg = nd_next[arg]
        i = i + 1
    i = n_reg
    while i > 0:
        i = i - 1
        emit_pop_argreg(i)

    if is_indirect != 0:
        # Reclaim the function pointer from the stash (below the stack-arg
        # block) into %r11, then `call *%r11`.
        emit_load_r11_rsp_disp(stack_bytes + 8)
        emit_xor_eax_eax()
        emit_call_r11()
    else:
        emit_xor_eax_eax()
        # Emit `call rel32`; the target offset is resolved after all functions
        # are emitted (the callee may not have been generated yet).
        emit_b(0xE8)
        at: uint32 = code_len
        emit_imm32(cast[uint64](0))
        add_call_fixup(at, nd_name_off[callee], nd_name_len[callee])

    # Reclaim the stack-arg block (args 6+).
    if stack_bytes > 0:
        emit_add_rsp(stack_bytes)
    # Reclaim the 16-byte function-pointer stash (indirect calls only).
    if is_indirect != 0:
        emit_add_rsp(16)


# Return the k-th argument node (0-based) in a call's arg chain (nd_b head,
# linked by nd_next). Used by the >6-arg stack-marshalling path.
def nth_arg(node: uint32, k: uint32) -> uint32:
    a: uint32 = nd_b[node]
    j: uint32 = 0
    while j < k and a != 0:
        a = nd_next[a]
        j = j + 1
    return a


# -----------------------------------------------------------------------
# Statement codegen.
# -----------------------------------------------------------------------

# Generate a statement sibling-chain (the body block representation the
# parser produces for if/while/function bodies).
def gen_block(head: uint32):
    s: uint32 = head
    while s != 0:
        gen_stmt(s)
        s = nd_next[s]


# Store the value currently in %rax into the slot for `name`. A name that
# resolves to a known global scalar stores through the data section (leaq
# its address into %rcx-free path: address into %rax, value spilled), and
# otherwise stores to a local slot, allocating it on first assignment
# (mirrors VarDecl/Assignment to a fresh local). Used by ND_VAR_DECL and
# plain ND_ASSIGN to an identifier.
def store_to_named(name_off: uint32, name_len: uint32):
    off: int32 = 0
    if lookup_local(name_off, name_len, &off) != 0:
        # Sized store: a sub-8-byte scalar local (uint32/uint16/uint8/...)
        # must be written with movl/movw/movb so the slot holds the
        # type-truncated value, mirroring codegen_x86._emit_local_store. A
        # width of 0 (pointer-ish / untyped) falls through to a plain movq.
        lsz: uint32 = lookup_local_scalar_size(name_off, name_len)
        if lsz != 0:
            emit_store_local_rax_sized(off, lsz)
        else:
            # Plain full-width 8-byte scalar slot. WRITE-THROUGH under --opt: if
            # regalloc gave this local a register, mirror %rax into it AND store
            # to the slot, so reads (register) and any residual memory path stay
            # coherent. Inert by default (ra_reg_for_name -> RA_NONE).
            wenc: uint32 = ra_reg_for_name(name_off, name_len)
            if wenc != RA_NONE:
                emit_mov_rax_callee(wenc)
            emit_store_local_rax(off)
        return
    gi: uint32 = glob_lookup(name_off, name_len)
    # Percpu global store (kernel target): SIZED `mov %?ax, %gs:offset` so a
    # sub-8-byte Percpu[T] slot is truncated to its declared width (same class
    # as the local/global/member sized store). Aggregate percpu keeps movq.
    if gi != 0 and glob_is_percpu[gi - 1] != 0:
        if glob_elem_size[gi - 1] == 0:
            emit_store_gs_rax_sized(glob_offset[gi - 1], glob_scalar_size[gi - 1])
        else:
            emit_store_gs_rax(glob_offset[gi - 1])
        return
    if gi != 0 and glob_elem_size[gi - 1] == 0:
        # Scalar global store: value is in %rax. Move it to %rcx, leaq the
        # global address into %rax, then a sized store %rcx -> (%rax),
        # matching the local-array store lowering (and emulator opcodes).
        emit_mov_rax_rcx()
        emit_lea_global_rax(glob_offset[gi - 1], glob_is_bss[gi - 1])
        emit_store_mem_rcx(glob_scalar_size[gi - 1])
        return
    # Not a global — fall back to a (possibly fresh) local slot.
    off = alloc_local(name_off, name_len)
    emit_store_local_rax(off)


# Byte width of a primitive ND_TYPE node (nd_aux holds the type_keyword
# code from parser.type_keyword_code): int8/uint8/char/bool=1, *16=2,
# *32/int/float=4, *64=8. Returns 8 for anything else (pointer-ish).
def prim_type_size(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] != ND_TYPE:
        return 8
    code: uint32 = nd_aux[tnode]
    if code == 2 or code == 6 or code == 12 or code == 13:
        return 1
    if code == 3 or code == 7:
        return 2
    if code == 4 or code == 8 or code == 10:
        return 4
    if code == 5 or code == 9 or code == 11:
        return 8
    return 8


# Total byte size of a (possibly nested array) type node, mirroring
# codegen_x86.get_type_size: an ND_ARRAY_TYPE is `count * type_size(elem)`
# (recursing through nested arrays), a Ptr[T] is 8, anything else falls to
# prim_type_size. Used to compute the per-level INDEX STRIDE for a
# multi-dimensional array global: at the outer level of `Array[N, Array[M,
# T]]` the stride is type_size(Array[M, T]) = M*sizeof(T) (the row); at the
# inner level it is sizeof(T).
def type_size_of(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        count: uint32 = cast[uint32](nd_num[tnode])
        return count * type_size_of(nd_a[tnode])
    if nd_kind[tnode] == ND_PTR_TYPE:
        return 8
    # A struct/class-named ND_TYPE (nd_aux==0, a user name) -> its total size,
    # mirroring codegen_x86.get_type_size's `if name in self.structs`.
    si1: uint32 = struct_lookup_by_node(tnode)
    if si1 != 0:
        return st_total[si1 - 1]
    return prim_type_size(tnode)


# Natural alignment of a type node (C-ABI, capped at 8), mirroring
# codegen_x86.natural_align: an array aligns to its element; otherwise the
# size capped at 8 (min 1). A struct field aligns to min(total,8).
def natural_align(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        return natural_align(nd_a[tnode])
    sz: uint32 = type_size_of(tnode)
    if sz > 8:
        return 8
    if sz < 1:
        return 1
    return sz


# Resolve a struct/class-named ND_TYPE node to a struct-table index (+1), or
# 0 if it is a primitive / non-struct type. A struct name is an ND_TYPE with
# nd_aux==0 (no primitive keyword code) carrying the name in nd_name_off/len.
def struct_lookup_by_node(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_TYPE:
        return 0
    if nd_aux[tnode] != 0:
        return 0                 # a primitive keyword type
    return struct_lookup(nd_name_off[tnode], nd_name_len[tnode])


# Resolve a struct/class name (strbuf ref) to a struct-table index (+1), or
# 0 if not a registered struct.
def struct_lookup(name_off: uint32, name_len: uint32) -> uint32:
    i: uint32 = 0
    while i < st_count:
        if name_match(st_name_off[i], st_name_len[i], name_off, name_len) != 0:
            return i + 1
        i = i + 1
    return 0


# If `tnode` is a Ptr[Struct] type node, return the struct table index (+1)
# of the pointee struct, else 0. Used to type the `self: Ptr[Foo]` param.
def ptr_struct_idx(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_PTR_TYPE:
        return 0
    return struct_lookup_by_node(nd_a[tnode])


# Find a field within struct `sidx1-1` by name. On a hit, writes the field's
# byte offset through out_off and returns the field's load/store size (a
# scalar width 1/2/4/8, or 0 for an array-typed field that decays to its
# address). On a miss returns 0xFFFFFFFF (and out_off is untouched).
SF_NOFIELD: uint32 = 4294967295
def struct_field_find(sidx1: uint32, name_off: uint32, name_len: uint32, out_off: Ptr[uint32], out_signed: Ptr[uint32]) -> uint32:
    si: uint32 = sidx1 - 1
    base: uint32 = st_field_base[si]
    n: uint32 = st_nfields[si]
    i: uint32 = 0
    while i < n:
        idx: uint32 = base + i
        if name_match(sf_name_off[idx], sf_name_len[idx], name_off, name_len) != 0:
            out_off[0] = sf_offset[idx]
            out_signed[0] = sf_is_signed[idx]
            return sf_size[idx]
        i = i + 1
    return SF_NOFIELD


# Look up a struct field's ELEMENT width (array element / pointee), writing the
# element signedness tristate through out_signed. Returns the element size, or
# 0 if the field is scalar / not found. For a member-base index `c.buf[i]`.
def struct_field_elem(sidx1: uint32, name_off: uint32, name_len: uint32, out_signed: Ptr[uint32]) -> uint32:
    si: uint32 = sidx1 - 1
    base: uint32 = st_field_base[si]
    n: uint32 = st_nfields[si]
    i: uint32 = 0
    while i < n:
        idx: uint32 = base + i
        if name_match(sf_name_off[idx], sf_name_len[idx], name_off, name_len) != 0:
            out_signed[0] = sf_elem_signed[idx]
            return sf_elem_size[idx]
        i = i + 1
    out_signed[0] = 0
    return 0


# For a NESTED member access (obj.inner.leaf): given the struct of `obj`
# (sidx1) and the inner field name, return that field's nested-struct index
# (+1, 0 if the field is not a struct/Ptr[struct]), writing through out_is_ptr
# whether the field is a Ptr[Struct] (1) vs an embedded struct value (0).
def struct_field_struct(sidx1: uint32, name_off: uint32, name_len: uint32, out_is_ptr: Ptr[uint32]) -> uint32:
    si: uint32 = sidx1 - 1
    base: uint32 = st_field_base[si]
    n: uint32 = st_nfields[si]
    i: uint32 = 0
    while i < n:
        idx: uint32 = base + i
        if name_match(sf_name_off[idx], sf_name_len[idx], name_off, name_len) != 0:
            out_is_ptr[0] = sf_struct_is_ptr[idx]
            return sf_struct_idx[idx]
        i = i + 1
    out_is_ptr[0] = 0
    return 0


# Element-struct index (+1) of an array-of-struct / Ptr[struct] FIELD of
# struct `sidx1` named [name_off,len). 0 if the field is not a struct array /
# struct pointer. For an indexed member-base `obj.field[i].leaf`.
def struct_field_elem_struct(sidx1: uint32, name_off: uint32, name_len: uint32) -> uint32:
    si: uint32 = sidx1 - 1
    base: uint32 = st_field_base[si]
    n: uint32 = st_nfields[si]
    i: uint32 = 0
    while i < n:
        idx: uint32 = base + i
        if name_match(sf_name_off[idx], sf_name_len[idx], name_off, name_len) != 0:
            return sf_elem_struct[idx]
        i = i + 1
    return 0


# The ND_ARRAY_TYPE node of a struct FIELD named [name_off,len) of struct
# sidx1, or 0 if the field is not an array. For multi-dim member-array index.
def struct_field_type_node(sidx1: uint32, name_off: uint32, name_len: uint32) -> uint32:
    si: uint32 = sidx1 - 1
    base: uint32 = st_field_base[si]
    n: uint32 = st_nfields[si]
    i: uint32 = 0
    while i < n:
        idx: uint32 = base + i
        if name_match(sf_name_off[idx], sf_name_len[idx], name_off, name_len) != 0:
            return sf_type_node[idx]
        i = i + 1
    return 0


# Element width (and signedness via out param) of a member-typed index base
# `obj.field` used as `obj.field[i]`. Resolves obj's struct, then the field's
# recorded element size. Returns 0 when obj.field is not an indexable member.
def member_index_elem(memnode: uint32, out_signed: Ptr[uint32]) -> uint32:
    is_ptr: uint32 = 0
    sidx1: uint32 = member_resolve(nd_a[memnode], &is_ptr)
    if sidx1 == 0:
        out_signed[0] = 0
        return 0
    return struct_field_elem(sidx1, nd_name_off[memnode], nd_name_len[memnode], out_signed)


# Return type node of the function/extern named by an ND_CALL's callee, found
# in the program decl chain (ND_FUNCTION / ND_EXTERN). 0 if not found / void.
# Mirrors the seed's get_expr_type(CallExpr) = the function's return type.
def call_return_type(callnode: uint32) -> uint32:
    callee: uint32 = nd_a[callnode]
    if nd_kind[callee] != ND_IDENT:
        return 0
    cur: uint32 = cg_prog_decls
    while cur != 0:
        k: uint32 = nd_kind[cur]
        if k == ND_FUNCTION or k == ND_EXTERN:
            if name_match(nd_name_off[cur], nd_name_len[cur], nd_name_off[callee], nd_name_len[callee]) != 0:
                return nd_b[cur]
        cur = nd_next[cur]
    return 0


# The pointee struct index (+1) of an expression whose static type is a
# Ptr[Struct]: a cast `cast[Ptr[S]](e)`, a function call returning `Ptr[S]`.
# Used so an indexed base `EXPR[i].leaf` resolves the element struct uniformly.
# 0 if the expression is not a Ptr-to-struct. Mirrors the seed's
# get_expr_type(...).base_type -> _resolve_struct for a PointerType.
def expr_ptr_struct(expr: uint32) -> uint32:
    if nd_kind[expr] == ND_CAST:
        return ptr_struct_idx(nd_a[expr])
    if nd_kind[expr] == ND_CALL:
        rt: uint32 = call_return_type(expr)
        if rt != 0:
            return ptr_struct_idx(rt)
        return 0
    return 0


# Find a class declaration (ND_CLASS) by name in the program decl chain.
# Returns the node id or 0 if no such class is declared.
def class_lookup_decl(name_off: uint32, name_len: uint32) -> uint32:
    cur: uint32 = cg_prog_decls
    while cur != 0:
        if nd_kind[cur] == ND_CLASS:
            if name_match(nd_name_off[cur], nd_name_len[cur], name_off, name_len) != 0:
                return cur
        cur = nd_next[cur]
    return 0


# The load/store size to record for a struct FIELD type. A scalar (or Ptr)
# field stores its width; an array-typed field records 0 (it decays to its
# address on load, mirroring codegen_x86's ArrayType field special-case).
def field_store_size(tnode: uint32) -> uint32:
    if tnode == 0:
        return 8
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        return 0                  # array field: decays to address (no scalar load)
    if nd_kind[tnode] == ND_PTR_TYPE:
        return 8
    if struct_lookup_by_node(tnode) != 0:
        return 0                  # embedded struct field: decays to address
    return prim_type_size(tnode)


# Emit one field into the flat field table at the current cg_layout_offset,
# aligned to its natural alignment, then advance cg_layout_offset past it.
# Mirrors layout_struct's per-field alignment walk.
def layout_emit_field(fld: uint32):
    tnode: uint32 = nd_a[fld]
    align: uint32 = natural_align(tnode)
    cg_layout_offset = (cg_layout_offset + align - 1) & cast[uint32](0 - align)
    if sf_count >= MAX_STRUCT_FIELDS:
        cg_fail(6, fld)
        return
    sf_name_off[sf_count] = nd_name_off[fld]
    sf_name_len[sf_count] = nd_name_len[fld]
    sf_offset[sf_count] = cg_layout_offset
    fsz: uint32 = field_store_size(tnode)
    sf_size[sf_count] = fsz
    sgn: uint32 = 0
    if fsz != 0 and fsz < 8 and type_is_unsigned(tnode) == 0:
        sgn = 1
    sf_is_signed[sf_count] = sgn
    # FULL field-type signedness tristate (covers 8-byte int64/uint64 too) for
    # compare/shift signedness of `obj.field`. A scalar field (fsz != 0, not a
    # decayed array/struct address) reports its type's tristate; an array/Ptr/
    # struct field decays to an unsigned ADDRESS.
    if fsz != 0:
        sf_signedness[sf_count] = type_signedness(tnode)
    else:
        sf_signedness[sf_count] = 1

    # Record the element width + signedness for an indexable (array / Ptr[T])
    # field, so a member-base index `c.buf[i]` knows its load/store stride.
    fes: uint32 = 0
    fesgn: uint32 = 0
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        fes = type_size_of(nd_a[tnode])
        fesgn = type_signedness(nd_a[tnode])
    elif nd_kind[tnode] == ND_PTR_TYPE:
        fes = type_size_of(nd_a[tnode])
        fesgn = type_signedness(nd_a[tnode])
    sf_elem_size[sf_count] = fes
    sf_elem_signed[sf_count] = fesgn
    # Record nested-struct typing for a NESTED member access (obj.inner.leaf):
    # an embedded struct value field OR a Ptr[Struct] field carries its struct
    # index so member_resolve can descend through it.
    nsi: uint32 = 0
    nsp: uint32 = 0
    if nd_kind[tnode] == ND_PTR_TYPE:
        psi: uint32 = struct_lookup_by_node(nd_a[tnode])
        if psi != 0:
            nsi = psi
            nsp = 1
    elif nd_kind[tnode] != ND_ARRAY_TYPE:
        esi: uint32 = struct_lookup_by_node(tnode)
        if esi != 0:
            nsi = esi
            nsp = 0
    sf_struct_idx[sf_count] = nsi
    sf_struct_is_ptr[sf_count] = nsp
    # Element-struct index for an array-of-struct / Ptr[struct] field, so an
    # indexed member-base `obj.field[i].leaf` can resolve the element struct.
    ges: uint32 = 0
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        ges = struct_lookup_by_node(nd_a[tnode])
    elif nd_kind[tnode] == ND_PTR_TYPE:
        ges = struct_lookup_by_node(nd_a[tnode])
    sf_elem_struct[sf_count] = ges
    fatn: uint32 = 0
    if nd_kind[tnode] == ND_ARRAY_TYPE:
        fatn = tnode
    sf_type_node[sf_count] = fatn
    sf_count = sf_count + 1
    cg_layout_offset = cg_layout_offset + type_size_of(tnode)


# Recursively emit a class's inherited (base, transitively, left-to-right)
# fields followed by its own fields, mirroring layout_struct's flattening.
# Walks the base chain depth-first so a grandparent's fields land first.
def layout_emit_class_fields(cls: uint32):
    # Bases first (nd_c = head of base-ident chain; each is an ND_IDENT).
    b: uint32 = nd_c[cls]
    while b != 0:
        bc: uint32 = class_lookup_decl(nd_name_off[b], nd_name_len[b])
        if bc == 0:
            cg_fail(8, cls)           # inherits from unknown class
            return
        layout_emit_class_fields(bc)
        b = nd_next[b]
    # Own fields (nd_a = head of ND_CLASS_FIELD chain).
    f: uint32 = nd_a[cls]
    while f != 0:
        layout_emit_field(f)
        f = nd_next[f]


# Lay out one ND_CLASS into the struct table (fields + 8-byte-rounded total),
# mirroring codegen_x86.layout_struct. Idempotent: a class already laid out
# is skipped (so out-of-order / repeated layout is safe).
def layout_struct(cls: uint32):
    if struct_lookup(nd_name_off[cls], nd_name_len[cls]) != 0:
        return
    if st_count >= MAX_STRUCTS:
        cg_fail(6, cls)
        return
    si: uint32 = st_count
    st_name_off[si] = nd_name_off[cls]
    st_name_len[si] = nd_name_len[cls]
    st_decl[si] = cls
    st_field_base[si] = sf_count
    # Reserve the struct entry BEFORE walking fields so a self-referential
    # Ptr field (struct_lookup_by_node on a Ptr pointee) resolves; field
    # walking only consults type_size_of (8 for a Ptr) so this is safe.
    st_count = st_count + 1
    cg_layout_offset = 0
    layout_emit_class_fields(cls)
    st_nfields[si] = sf_count - st_field_base[si]
    st_total[si] = (cg_layout_offset + 7) & cast[uint32](0xFFFFFFF8)


# Lay out every ND_CLASS in the program BEFORE any function emission, so
# member access + method bodies can resolve struct layouts. Bases may be
# declared after a derived class; layout_struct resolves them by name from
# the (already-stashed) program decl chain, so a single forward pass that
# lays out each class (recursing into bases first) suffices.
def layout_classes(prog: uint32):
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_CLASS:
            layout_struct(cur)
        cur = nd_next[cur]


# If `tnode` is a Ptr[T] type node, return the pointee width (the size of
# T, computed by prim_type_size on the inner type). Returns 0 when `tnode`
# is not a pointer type. ND_PTR_TYPE carries the inner type on nd_a.
def ptr_pointee_size(tnode: uint32) -> uint32:
    if tnode == 0:
        return 0
    if nd_kind[tnode] != ND_PTR_TYPE:
        return 0
    inner: uint32 = nd_a[tnode]
    return prim_type_size(inner)


# Reserve a slot for a var-decl name, honouring an Array type. Returns 1 if
# it allocated (or already present), leaving any error in cg_err.
# Re-apply a scalar local's type METADATA (signedness tristate / sub-8-byte
# width / float width) to its EXISTING prescan-reserved slot, keyed by name.
# The prescan reserves one slot per source name in declaration order; when a
# name is RE-DECLARED with a different type in a sibling branch of the same
# function (`n: int64` … then `n: uint64`, as in vfs_read), the prescan left
# the binding tagged with whichever declaration it reserved. The seed
# (codegen_x86) allocates per-VarDecl during the body walk, so at each source
# position `self.locals[name]` reflects the type DECLARED THERE. We mirror that
# by refreshing the flat binding's metadata when gen_stmt reaches each VarDecl,
# so a later reference resolves the signed/unsigned setcc + load/div/shift width
# from the type live at that point. Without this, the second (uint64) `n` kept
# the first (int64) `n`'s SIGNED tag and `n > 0` emitted `setg` instead of the
# unsigned `seta` — a real signedness miscompile on the kernel read path.
def refresh_local_meta(name_off: uint32, name_len: uint32, tnode: uint32):
    # Only scalar int/float locals carry signedness/width metadata; array /
    # ptr / struct slots keep their prescan tagging (their type is fixed by the
    # single reservation, and reuse across a re-decl of those kinds is out of
    # this subset's scope). Find the binding's index (forward-first matches the
    # lookups) and re-tag it in place.
    i: uint32 = 0
    while i < loc_count:
        if name_match(loc_name_off[i], loc_name_len[i], name_off, name_len) != 0:
            # Skip non-scalar slots (an array/ptr/struct local has a non-zero
            # elem/ptr size or struct idx) — they aren't re-typed here.
            if loc_elem_size[i] != 0:
                return
            if loc_ptr_size[i] != 0:
                return
            if loc_struct_idx[i] != 0:
                return
            sgn: uint32 = type_signedness(tnode)
            loc_is_signed[i] = sgn
            sz_r: uint32 = prim_type_size(tnode)
            if sgn != 0 and sz_r < 8:
                loc_scalar_size[i] = sz_r
            else:
                loc_scalar_size[i] = 0
            fw_r: uint32 = type_float_width(tnode)
            loc_is_float[i] = fw_r
            if fw_r == 4:
                loc_scalar_size[i] = 4
            return
        i = i + 1


def declare_local(name_off: uint32, name_len: uint32, tnode: uint32):
    off: int32 = 0
    if lookup_local(name_off, name_len, &off) != 0:
        # Already reserved (by the prescan, or an earlier same-name decl).
        # Refresh the scalar type metadata so a re-declaration with a
        # different type re-tags the binding (see refresh_local_meta).
        refresh_local_meta(name_off, name_len, tnode)
        return
    if tnode != 0 and nd_kind[tnode] == ND_ARRAY_TYPE:
        count: uint32 = cast[uint32](nd_num[tnode])
        # Element STRIDE = type_size_of(element type), so a MULTI-DIMENSIONAL
        # local `Array[N, Array[M,T]]` reserves N*(M*sizeof T) bytes and the
        # outer index scales by the row stride — NOT prim_type_size, which
        # returns 8 for a nested ND_ARRAY_TYPE element (under-allocating +
        # mis-striding). Mirrors the global array path's type_size_of.
        es: uint32 = type_size_of(nd_a[tnode])
        alloc_array_local(name_off, name_len, count, es)
        # Record the full array type node so expr_array_type can walk the
        # dimensions for a nested index `a[i][j]`.
        if loc_count > 0:
            loc_type_node[loc_count - 1] = tnode
    elif tnode != 0 and nd_kind[tnode] == ND_PTR_TYPE:
        # Ptr[T] local: an 8-byte slot that holds an address; record the
        # pointee width so p[i] dereferences with the right load/store size.
        psidx: uint32 = ptr_struct_idx(tnode)
        alloc_ptr_local(name_off, name_len, ptr_pointee_size(tnode))
        if psidx != 0:
            loc_set_struct_ptr(psidx)        # Ptr[Struct] (e.g. `self`)
        # Record the Ptr[T] type node so index_elem_signed can recover the
        # pointee T's signedness for a named-Ptr index `p[i]` (e.g. a
        # `Ptr[uint8]` param compared `a[i] < c[k]` must use UNSIGNED setb, not
        # signed setl). Without this the named-Ptr element was 0/unknown and the
        # compare/shift defaulted to signed — an objdiff-caught divergence.
        if loc_count > 0:
            loc_type_node[loc_count - 1] = tnode
    elif tnode != 0 and struct_lookup_by_node(tnode) != 0:
        # Struct-typed local: an in-place struct value. Reserve total_size
        # bytes; member access takes &slot + field_offset.
        ssi: uint32 = struct_lookup_by_node(tnode)
        alloc_struct_local(name_off, name_len, st_total[ssi - 1], ssi)
    else:
        alloc_local(name_off, name_len)
        # Record scalar int signedness so identifier operands feed the
        # signed/unsigned setcc + div/mod choice (mirrors get_expr_type).
        loc_set_signedness(type_signedness(tnode))
        # Sub-8-byte known int scalar (signed OR unsigned — type_signedness
        # returns 2/1 for both, 0 only for unknown): tag its width for sized
        # store + extending load (mirrors codegen_x86 _scalar_local_size,
        # which keys off the slot's byte size regardless of signedness). The
        # STORE side (store_to_named) consumes this width to emit movl/movw/
        # movb instead of a blind 8-byte movq, so a uint32 local assignment
        # truncates the carry past bit 31 instead of corrupting later size/
        # span math — the ELF-loader 64 MiB bogus-kmalloc miscompile.
        sz_d: uint32 = prim_type_size(tnode)
        if type_signedness(tnode) != 0 and sz_d < 8:
            loc_set_scalar_size(sz_d)
        # Float scalar: tag the float width so identifier operands route to
        # the SSE path. A float32 (4 bytes) also gets a sized 4-byte slot so
        # the local store writes exactly 4 bytes (mirrors codegen_x86's
        # _scalar_local_size returning 4 for float32). The FP bit pattern
        # transits %rax, so the slot is a plain integer store/load.
        fw_d: uint32 = type_float_width(tnode)
        if fw_d != 0:
            loc_set_float(fw_d)
            if fw_d == 4:
                loc_set_scalar_size(4)


def gen_stmt(node: uint32):
    if node == 0:
        return
    # Track the in-flight statement node so the IR-scratch BORROW path can map it
    # to a program point (cfg's lr_stmt_point) and check whether a regalloc local
    # is already dead there. An if/while condition is emitted with cg_cur_stmt set
    # to the if/while node — matching cfg, which stamps the condition's ci with
    # that same node. Nested body statements re-enter gen_stmt and re-stamp.
    cg_cur_stmt = node
    k: uint32 = nd_kind[node]

    if k == ND_RETURN:
        gen_expr(nd_a[node])
        emit_function_epilogue()
        return

    if k == ND_EXPR_STMT:
        gen_expr(nd_a[node])
        return

    if k == ND_VAR_DECL:
        # name = nd_name_off/len, a = type, b = optional initialiser value.
        # The prescan already reserved the slot (scalar or Array). An Array
        # decl never carries a scalar initialiser in this subset; a scalar
        # decl with an initialiser stores it into the slot.
        tnode: uint32 = nd_a[node]
        if tnode != 0 and nd_kind[tnode] == ND_ARRAY_TYPE:
            # Array slot already reserved; no initialiser store.
            declare_local(nd_name_off[node], nd_name_len[node], tnode)
            return
        # Struct-typed local: the slot (total_size bytes) was reserved in the
        # prescan. Constructor sugar `f: Foo = Foo(args)` lowers to
        # Foo__init(&f, args); Adder has no struct-return, so we never do an
        # evaluate-then-store of a struct value. A struct decl with no init is
        # just a zeroed slot (no emission).
        if tnode != 0 and struct_lookup_by_node(tnode) != 0:
            declare_local(nd_name_off[node], nd_name_len[node], tnode)
            val0: uint32 = nd_b[node]
            if val0 != 0:
                gen_ctor_init(node, tnode, val0)
            return
        val: uint32 = nd_b[node]
        if val != 0:
            # Scalar local WITH an initialiser: the prescan reserved the slot,
            # so we store the value instead of re-declaring. But the prescan's
            # type tag may belong to an EARLIER same-name declaration (a
            # re-decl in a sibling branch). Refresh the binding's scalar
            # signedness/width to THIS declaration's type at this source
            # position so the store width and every later reference's
            # signed/unsigned setcc match the seed (which re-binds per VarDecl).
            refresh_local_meta(nd_name_off[node], nd_name_len[node], tnode)
            gen_expr(val)
            store_to_named(nd_name_off[node], nd_name_len[node])
        else:
            declare_local(nd_name_off[node], nd_name_len[node], tnode)
        return

    if k == ND_ASSIGN:
        tgt: uint32 = nd_a[node]
        if nd_kind[tgt] == ND_INDEX:
            gen_assign_index(node)
            return
        if nd_kind[tgt] == ND_MEMBER:
            gen_assign_member(node)
            return
        if nd_kind[tgt] != ND_IDENT:
            # Only identifier / index targets are in scope.
            cg_fail(2, node)
            return
        aug: uint32 = nd_aux[node]
        if aug == AUGOP_NONE:
            gen_expr(nd_b[node])
            store_to_named(nd_name_off[tgt], nd_name_len[tgt])
            return
        # Augmented `tgt OP= value`: desugar to tgt = tgt OP value.
        # Evaluate value first (right), push; load tgt (left); pop %rcx;
        # apply — exactly gen_expr's ND_BINARY lowering.
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_expr(tgt)
        emit_pop_rcx()
        if aug == AUGOP_ADD:
            emit_add_rcx_rax()
        elif aug == AUGOP_SUB:
            emit_sub_rcx_rax()
        elif aug == AUGOP_MUL:
            emit_imul_rcx_rax()
        else:
            cg_fail(2, node)
            return
        store_to_named(nd_name_off[tgt], nd_name_len[tgt])
        return

    if k == ND_IF:
        gen_if(node)
        return

    if k == ND_WHILE:
        gen_while(node)
        return

    if k == ND_BREAK:
        # Jump forward to the innermost loop's exit. The target is not yet
        # known, so emit a placeholder `jmp rel32` and record its rel32-field
        # offset as a break fixup on the top loop frame; gen_while patches it
        # once the exit point is reached.
        if loop_depth == 0:
            cg_fail(2, node)
            return
        d: uint32 = loop_depth - 1
        if loop_brk_n[d] >= MAX_BRK:
            cg_fail(6, node)
            return
        at: uint32 = emit_jmp_fwd()
        loop_brk_at[d * MAX_BRK + loop_brk_n[d]] = at
        loop_brk_n[d] = loop_brk_n[d] + 1
        return

    if k == ND_CONTINUE:
        # Jump back to the innermost loop's condition test (a known offset).
        if loop_depth == 0:
            cg_fail(2, node)
            return
        emit_jmp_back(loop_cont_target[loop_depth - 1])
        return

    if k == ND_PASS:
        # `pass` is a no-op placeholder statement; emit nothing.
        return

    if k == ND_DO_WHILE:
        gen_do_while(node)
        return

    if k == ND_FOR:
        gen_for(node)
        return

    # Other statement kinds not covered by this subset.
    cg_fail(2, node)


# Assign to an array element: `arr[i] = v` (and augmented `arr[i] OP= v`).
# Strategy (matches codegen_x86.gen_assignment's indexed-target path):
#   evaluate the RHS value, push it; compute &arr[i] into %rax, push it;
#   pop address into %rcx-ish... — but our stack-machine only has %rax/%rcx,
#   so we marshal carefully:
#     1. eval value -> %rax ; push                       (value on stack)
#     2. compute &arr[i] -> %rax ; push                  (addr on stack)
#     3. (augmented only) reload value, load *addr, combine)
#   Then pop addr into a scratch, pop value into %rcx, store %rcx -> (addr).
# We keep it simple by computing the address LAST and storing immediately.
def gen_assign_index(node: uint32):
    tgt: uint32 = nd_a[node]            # ND_INDEX
    es: uint32 = index_elem_size(tgt)
    aug: uint32 = nd_aux[node]

    if aug == AUGOP_NONE:
        # Plain store. Evaluate value, push; compute address; pop value into
        # %rcx; store %rcx -> (%rax).
        gen_expr(nd_b[node])
        emit_push_rax()
        gen_index_addr(tgt)            # &arr[i] -> %rax
        emit_pop_rcx()                 # value -> %rcx
        emit_store_mem_rcx(es)
        return

    # Augmented `arr[i] OP= v`: new = (load arr[i]) OP v.
    #   eval v -> %rax ; push                 [v]
    #   load arr[i] -> %rax                   (old)
    #   pop %rcx (=v) ; apply OP -> %rax      (new value)
    #   push new -> stack                     [new]
    #   compute &arr[i] -> %rax
    #   pop new into %rcx ; store %rcx -> (%rax)
    gen_expr(nd_b[node])
    emit_push_rax()
    gen_index_addr(tgt)               # &arr[i]
    emit_load_mem_rax(es)            # old value -> %rax
    emit_pop_rcx()                    # v -> %rcx
    if aug == AUGOP_ADD:
        emit_add_rcx_rax()
    elif aug == AUGOP_SUB:
        emit_sub_rcx_rax()
    elif aug == AUGOP_MUL:
        emit_imul_rcx_rax()
    else:
        cg_fail(2, node)
        return
    emit_push_rax()                  # new value
    gen_index_addr(tgt)              # &arr[i] again
    emit_pop_rcx()                   # new -> %rcx
    emit_store_mem_rcx(es)


# if / elif* / else  (mirrors codegen_x86.gen_if). The parser stores the
# condition on nd_a, then-body chain on nd_b, an ND_ELIF sibling-chain on
# nd_c, and the else-body chain on nd_d.
def gen_if(node: uint32):
    # End-of-if jump fixups accumulate here (one per taken branch), all
    # backpatched to the join point after the whole construct.
    end_fix: Array[64, uint32]
    end_n: uint32 = 0

    # Primary condition.
    gen_expr(nd_a[node])
    emit_test_rax_rax()
    # Jump over the then-body when false; patched to the next branch (or
    # the end if there is none).
    skip: uint32 = emit_jz_fwd()
    gen_block(nd_b[node])
    end_fix[end_n] = emit_jmp_fwd()
    end_n = end_n + 1
    # Land the false-jump here (start of the next branch / else / end).
    patch_rel32(skip, code_len)

    # elif chain.
    e: uint32 = nd_c[node]
    while e != 0:
        gen_expr(nd_a[e])
        emit_test_rax_rax()
        skip2: uint32 = emit_jz_fwd()
        gen_block(nd_b[e])
        end_fix[end_n] = emit_jmp_fwd()
        end_n = end_n + 1
        patch_rel32(skip2, code_len)
        e = nd_next[e]

    # else body (if any).
    if nd_d[node] != 0:
        gen_block(nd_d[node])

    # Backpatch every branch's exit jump to the join point.
    i: uint32 = 0
    while i < end_n:
        patch_rel32(end_fix[i], code_len)
        i = i + 1


# while  (mirrors codegen_x86.gen_while): header label, condition test,
# exit jump, body, back-jump to the header, exit label.
def gen_while(node: uint32):
    start: uint32 = code_len
    # Push a loop frame: `continue` targets `start` (re-test the condition);
    # `break` fixups accumulate in this frame's slot and patch to the exit.
    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return
    depth: uint32 = loop_depth
    loop_cont_target[depth] = start
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1

    gen_expr(nd_a[node])
    emit_test_rax_rax()
    exit_fix: uint32 = emit_jz_fwd()
    gen_block(nd_b[node])
    emit_jmp_back(start)
    # Exit point: backpatch the condition-false jump AND every `break`.
    patch_rel32(exit_fix, code_len)
    i: uint32 = 0
    while i < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + i], code_len)
        i = i + 1
    loop_depth = loop_depth - 1


# do-while  (mirrors codegen_x86.gen_do_while): execute the body once
# unconditionally, then a `cont:` test that loops back while non-zero.
#   start: <body>
#   cont:  <eval cond -> %rax> ; testq %rax,%rax ; jnz start
#   end:
# `continue` jumps to `cont` (the test) so the condition still gates the
# next iteration; `break` jumps to `end`. Same loop-frame machinery as
# gen_while, but the continue target is the COND TEST, not the top.
def gen_do_while(node: uint32):
    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return
    start: uint32 = code_len
    depth: uint32 = loop_depth
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1
    # Body.
    gen_block(nd_b[node])
    # cont: the condition test is `continue`'s target.
    cont_at: uint32 = code_len
    loop_cont_target[depth] = cont_at
    gen_expr(nd_a[node])
    emit_test_rax_rax()
    emit_jnz_back(start)
    # end: backpatch every `break` to here.
    i: uint32 = 0
    while i < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + i], code_len)
        i = i + 1
    loop_depth = loop_depth - 1


# Compile-time integer value of a literal expr (a bare ND_INT_LIT or a
# NEG-of-int-literal), returning it through out_v and 1 on success, else 0.
# Mirrors codegen_x86._const_int_value (used to pick a const range step's
# loop direction at compile time).
def const_int_value(expr: uint32, out_v: Ptr[int64]) -> uint32:
    if expr == 0:
        return 0
    if nd_kind[expr] == ND_INT_LIT:
        out_v[0] = cast[int64](nd_num[expr])
        return 1
    if nd_kind[expr] == ND_UNARY and nd_aux[expr] == UNOP_NEG:
        inner: int64 = 0
        if const_int_value(nd_a[expr], &inner) != 0:
            out_v[0] = 0 - inner
            return 1
    return 0


# 1 if `expr` is a `range(...)` call used as a for-loop iterable.
def is_range_call(expr: uint32) -> uint32:
    if nd_kind[expr] != ND_CALL:
        return 0
    callee: uint32 = nd_a[expr]
    if nd_kind[callee] != ND_IDENT:
        return 0
    if nd_name_len[callee] != 5:
        return 0
    # "range" = 72 61 6e 67 65
    o: uint32 = nd_name_off[callee]
    if strbuf[o] != 114:        # 'r'
        return 0
    if strbuf[o + 1] != 97:     # 'a'
        return 0
    if strbuf[o + 2] != 110:    # 'n'
        return 0
    if strbuf[o + 3] != 103:    # 'g'
        return 0
    if strbuf[o + 4] != 101:    # 'e'
        return 0
    return 1


# `for var in range(...)` — an integer counter loop. Mirrors
# codegen_x86.gen_for_range:
#   i = start
#   start_lbl: while (i </> stop) { body; step_lbl: i = i + step; jmp start }
#   end_lbl:
# `continue` lands on step_lbl (so the counter still advances — Python
# for-loop semantics), `break` on end_lbl. The induction var is a normal
# int64 local (already reserved in prescan).
def gen_for_range(node: uint32):
    calle: uint32 = nd_a[node]            # the range(...) ND_CALL
    argc: uint32 = nd_aux[calle]
    a0: uint32 = nd_b[calle]
    start_expr: uint32 = 0
    stop_expr: uint32 = 0
    step_expr: uint32 = 0
    if argc == 1:
        stop_expr = a0
    elif argc == 2:
        start_expr = a0
        stop_expr = nd_next[a0]
    elif argc == 3:
        start_expr = a0
        stop_expr = nd_next[a0]
        step_expr = nd_next[nd_next[a0]]
    else:
        cg_fail(2, node)
        return

    # Loop-direction: ascending (i < stop) unless the step is a constant
    # negative literal, in which case descending (i > stop). Default i64
    # signed compare matches the `while i < stop` idiom this replaces.
    descending: uint32 = 0
    sv: int64 = 0
    if step_expr != 0 and const_int_value(step_expr, &sv) != 0:
        if sv == 0:
            cg_fail(2, node)
            return
        if sv < 0:
            descending = 1

    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return

    # i = start  (start defaults to 0 when range(stop)).
    if start_expr != 0:
        gen_expr(start_expr)
    else:
        emit_mov_imm_rax(cast[uint64](0))
    store_to_named(nd_name_off[node], nd_name_len[node])

    start_lbl: uint32 = code_len
    depth: uint32 = loop_depth
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1

    # while (i </> stop): evaluate the compare as `i OP stop`, mirroring the
    # gen_expr ND_BINARY signed-compare lowering. The var is signed int64.
    # Right operand pushed first, then left (the loop var), then the cmp.
    gen_expr(stop_expr)
    emit_push_rax()
    emit_load_for_var(node)               # i -> %rax (signed int64 load)
    emit_pop_rcx()                        # stop -> %rcx
    emit_cmp_rcx_rax()
    if descending != 0:
        emit_setcc_al(0x9F)               # setg (signed >)
    else:
        emit_setcc_al(0x9C)               # setl (signed <)
    emit_movzx_al_rax()
    emit_test_rax_rax()
    exit_fix: uint32 = emit_jz_fwd()

    gen_block(nd_b[node])

    # step (continue lands here): i = i + step.
    step_at: uint32 = code_len
    loop_cont_target[depth] = step_at
    if step_expr != 0:
        gen_expr(step_expr)
    else:
        emit_mov_imm_rax(cast[uint64](1))
    emit_push_rax()
    emit_load_for_var(node)               # i -> %rax
    emit_pop_rcx()                        # step -> %rcx
    emit_add_rcx_rax()
    store_to_named(nd_name_off[node], nd_name_len[node])
    emit_jmp_back(start_lbl)

    patch_rel32(exit_fix, code_len)
    i: uint32 = 0
    while i < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + i], code_len)
        i = i + 1
    loop_depth = loop_depth - 1


# Load the for-loop induction var (a signed int64 local) into %rax. Mirrors
# the identifier-load path for an int64 local (a plain movq).
def emit_load_for_var(node: uint32):
    off: int32 = 0
    if lookup_local(nd_name_off[node], nd_name_len[node], &off) != 0:
        emit_load_local_rax(off)
        return
    cg_fail(8, node)


# `for var in arr` over a fixed-size Array[N, T] LOCAL/GLOBAL. Mirrors
# codegen_x86.gen_for_array: a hidden idx counter walks 0..N-1, and the loop
# var is re-bound to arr[idx] (a private copy) each iteration.
#   idx = 0
#   start: while (idx < N) { var = arr[idx]; body; step: idx = idx+1; jmp }
#   end:
def gen_for_array(node: uint32, n: uint32, idx_off: int32, elem_sz: uint32):
    if loop_depth >= MAX_LOOPS:
        cg_fail(6, node)
        return
    # idx = 0
    emit_mov_imm_rax(cast[uint64](0))
    emit_store_local_rax(idx_off)

    start_lbl: uint32 = code_len
    depth: uint32 = loop_depth
    loop_brk_n[depth] = 0
    loop_depth = loop_depth + 1

    # while (idx < n) — idx is a non-negative counter, n a small positive
    # literal, so a signed `<` is exact. Push n, load idx, pop n into %rcx.
    emit_mov_imm_rax(cast[uint64](n))
    emit_push_rax()
    emit_load_local_rax(idx_off)
    emit_pop_rcx()                        # n -> %rcx
    emit_cmp_rcx_rax()
    emit_setcc_al(0x9C)                   # setl (idx < n, signed)
    emit_movzx_al_rax()
    emit_test_rax_rax()
    exit_fix: uint32 = emit_jz_fwd()

    # var = arr[idx]: &arr[idx] = base + idx*elem; load sized.
    # Compute idx scaled, add the array base. The array iterable is nd_a.
    emit_load_local_rax(idx_off)
    emit_mov_rax_rcx()
    emit_scale_rcx(elem_sz)
    gen_addr_of(nd_a[node])               # base address -> %rax
    emit_add_rcx_rax()
    emit_load_mem_rax(elem_sz)
    store_to_named(nd_name_off[node], nd_name_len[node])

    gen_block(nd_b[node])

    # step (continue): idx = idx + 1.
    step_at: uint32 = code_len
    loop_cont_target[depth] = step_at
    emit_load_local_rax(idx_off)
    emit_mov_rax_rcx()
    emit_mov_imm_rax(cast[uint64](1))
    emit_add_rcx_rax()
    emit_store_local_rax(idx_off)
    emit_jmp_back(start_lbl)

    patch_rel32(exit_fix, code_len)
    j: uint32 = 0
    while j < loop_brk_n[depth]:
        patch_rel32(loop_brk_at[depth * MAX_BRK + j], code_len)
        j = j + 1
    loop_depth = loop_depth - 1


# Resolve the element size + count of a for-loop's array iterable (a bare
# array local or global identifier). Writes count through out_n and returns
# the element size, or 0 if the iterable is not a known fixed-size array.
def for_array_info(iter_: uint32, out_n: Ptr[uint32]) -> uint32:
    if nd_kind[iter_] != ND_IDENT:
        return 0
    es: uint32 = lookup_elem_size(nd_name_off[iter_], nd_name_len[iter_])
    if es != 0:
        # Local array: count = reserved_bytes / elem, but we don't track the
        # local count directly; the for-array form is driven by the global
        # path in this subset. Fall through to the global lookup if no count.
        gi0: uint32 = glob_lookup(nd_name_off[iter_], nd_name_len[iter_])
        if gi0 != 0 and glob_type_node[gi0 - 1] != 0:
            tn0: uint32 = glob_type_node[gi0 - 1]
            if nd_kind[tn0] == ND_ARRAY_TYPE:
                out_n[0] = cast[uint32](nd_num[tn0])
                return es
        return 0
    gi: uint32 = glob_lookup(nd_name_off[iter_], nd_name_len[iter_])
    if gi != 0 and glob_elem_size[gi - 1] != 0 and glob_type_node[gi - 1] != 0:
        tn: uint32 = glob_type_node[gi - 1]
        if nd_kind[tn] == ND_ARRAY_TYPE:
            out_n[0] = cast[uint32](nd_num[tn])
            return glob_elem_size[gi - 1]
    return 0


# Reserve a hidden 8-byte index slot for a for-array loop node, recording
# its frame offset keyed by the node id. Called from the prescan pass.
def for_idx_reserve(node: uint32):
    if fi_count >= MAX_FOR_IDX:
        cg_fail(6, node)
        return
    # Reserve an anonymous 8-byte slot (name off/len 0 → never name-matched).
    if loc_count >= MAX_LOCALS:
        cg_fail(6, node)
        return
    cg_stack_size = cg_stack_size + 8
    off: int32 = 0 - cast[int32](cg_stack_size)
    loc_name_off[loc_count] = 0
    loc_name_len[loc_count] = 0
    loc_offset[loc_count] = off
    loc_elem_size[loc_count] = 0
    loc_ptr_size[loc_count] = 0
    loc_is_signed[loc_count] = 1
    loc_scalar_size[loc_count] = 0
    loc_struct_idx[loc_count] = 0
    loc_struct_is_ptr[loc_count] = 0
    loc_is_float[loc_count] = 0
    loc_type_node[loc_count] = 0
    loc_count = loc_count + 1
    fi_node[fi_count] = node
    fi_offset[fi_count] = off
    fi_count = fi_count + 1


# Recover a for-array loop's hidden index slot offset by its node id.
def for_idx_offset(node: uint32) -> int32:
    i: uint32 = 0
    while i < fi_count:
        if fi_node[i] == node:
            return fi_offset[i]
        i = i + 1
    cg_fail(9, node)
    return 0


# for-loop dispatch: range(...) counter loop or fixed-size array loop.
def gen_for(node: uint32):
    iter_: uint32 = nd_a[node]
    if is_range_call(iter_) != 0:
        gen_for_range(node)
        return
    n: uint32 = 0
    es: uint32 = for_array_info(iter_, &n)
    if es != 0:
        # The hidden index counter was reserved in prescan as
        # "<var>#idx"-shaped; look it up. We reserve it adjacent to the loop
        # var in prescan_for, recorded via for_idx lookup by the loop node.
        idx_off: int32 = for_idx_offset(node)
        gen_for_array(node, n, idx_off, es)
        return
    cg_fail(2, node)


# -----------------------------------------------------------------------
# Pre-scan: reserve a frame slot for each named local before the prologue.
# -----------------------------------------------------------------------

# Ensure a slot exists for `name`; allocate one if not already present.
# A name that is a known module-level global is NOT given a frame slot —
# its storage lives in the data section.
def prescan_name(name_off: uint32, name_len: uint32):
    if glob_lookup(name_off, name_len) != 0:
        return
    off: int32 = 0
    if lookup_local(name_off, name_len, &off) == 0:
        alloc_local(name_off, name_len)


def prescan_block(head: uint32):
    s: uint32 = head
    while s != 0:
        k: uint32 = nd_kind[s]
        if k == ND_VAR_DECL:
            declare_local(nd_name_off[s], nd_name_len[s], nd_a[s])
        elif k == ND_ASSIGN:
            tgt: uint32 = nd_a[s]
            if nd_kind[tgt] == ND_IDENT:
                prescan_name(nd_name_off[tgt], nd_name_len[tgt])
            # ND_INDEX targets address an already-declared array; no slot.
        elif k == ND_IF:
            prescan_block(nd_b[s])
            e: uint32 = nd_c[s]
            while e != 0:
                prescan_block(nd_b[e])
                e = nd_next[e]
            prescan_block(nd_d[s])
        elif k == ND_WHILE:
            prescan_block(nd_b[s])
        elif k == ND_DO_WHILE:
            prescan_block(nd_b[s])
        elif k == ND_FOR:
            # Reserve the induction variable. For a range loop it is an int64
            # signed counter; for an array loop it is a private copy of the
            # element type. Mirrors codegen_x86's alloc_local for the loop var.
            iter_: uint32 = nd_a[s]
            if is_range_call(iter_) != 0:
                # Annotated-type-less counter: an int64 signed scalar.
                off2: int32 = 0
                if lookup_local(nd_name_off[s], nd_name_len[s], &off2) == 0:
                    alloc_local(nd_name_off[s], nd_name_len[s])
                    loc_set_signedness(2)        # int64 signed
            else:
                n0: uint32 = 0
                es0: uint32 = for_array_info(iter_, &n0)
                # Hidden index slot FIRST (matches codegen_x86 alloc order:
                # idx_var before loop_var), then the loop var as a sized
                # scalar of the element width.
                for_idx_reserve(s)
                off3: int32 = 0
                if lookup_local(nd_name_off[s], nd_name_len[s], &off3) == 0:
                    alloc_local(nd_name_off[s], nd_name_len[s])
                    if es0 != 0 and es0 < 8:
                        loc_set_scalar_size(es0)
            prescan_block(nd_b[s])
        s = nd_next[s]


# -----------------------------------------------------------------------
# Function codegen — emits a full prologue / body / epilogue. Returns the
# byte offset in code[] where this function's machine code begins.
# -----------------------------------------------------------------------

# Spill the parameter chain `params` (an ND_PARAM list) from the SysV arg
# registers (args 0..5) and the stack (args 6+) into their frame slots,
# mirroring codegen_x86.gen_function's spill pass. Each param's slot index
# equals its ordinal (params are the FIRST locals allocated), so the sized
# width is loc_scalar_size[ordinal] (0 -> full 8-byte movq). A sub-8-byte
# scalar param is spilled SIZED (movl/movw/movb) so its slot's upper bytes are
# not left holding the arg register's high garbage; a stack-passed arg (6+) is
# loaded into %rax at 16+(i-6)*8(%rbp) and stored sized into its slot.
def spill_params(params: uint32):
    p: uint32 = params
    idx: uint32 = 0
    while p != 0:
        sz: uint32 = loc_scalar_size[idx]
        off: int32 = loc_offset[idx]
        if idx < 6:
            emit_spill_arg_sized(idx, off, sz)
        else:
            # Stack arg: with NO callee-saved pushes, arg 6 sits at +16(%rbp)
            # (just above the return addr + saved %rbp), arg 7 at +24, ... When the
            # prologue PUSHED K callee-saved regs BEFORE `push %rbp` (regalloc-
            # promoted locals and/or IR scratch reservations), the saved %rbp — and
            # thus %rbp itself — sits K*8 bytes LOWER, so every incoming stack arg
            # is K*8 bytes HIGHER relative to %rbp. Add that displacement or the
            # 7th+ argument is read from the wrong slot (a latent miscompile that
            # only surfaces with >=7 params AND an active callee-save prologue).
            callee_disp: int32 = cast[int32](cg_saved_count() * 8)
            stack_off: int32 = cast[int32](16 + (idx - 6) * 8) + callee_disp
            emit_load_local_rax(stack_off)        # movq stack_off(%rbp),%rax
            emit_store_local_rax_sized(off, sz)   # sized store into the slot
        idx = idx + 1
        p = nd_next[p]


def gen_function(fn: uint32) -> uint32:
    start: uint32 = code_len

    # Register this function's symbol so calls (forward or backward) can
    # be resolved against its entry offset after all functions are emitted.
    fn_define(nd_name_off[fn], nd_name_len[fn], start)

    # Fresh per-function slot table.
    loc_count = 0
    cg_stack_size = 0
    fi_count = 0
    cg_self_struct = 0          # a plain function has no `self` receiver

    # Reject a by-value struct RETURN type (ND_FUNCTION's return type is on
    # nd_b). Same rule as params: aggregates leave a function through a
    # Ptr[T] out-parameter, never by value. Lockstep with the seed.
    if struct_lookup_by_node(nd_b[fn]) != 0:
        cg_fail(9, fn)              # by-value struct return: unsupported
        return start

    # Allocate a slot per parameter (param chain on nd_a, count in nd_aux).
    p: uint32 = nd_a[fn]
    nparams: uint32 = 0
    while p != 0:
        # A Ptr[T] parameter spills like any 8-byte scalar (the arg register
        # holds the pointer value), but we record its pointee width so the
        # body's p[i] indexing dereferences with the right element size.
        ptnode: uint32 = nd_a[p]
        # Reject a by-value struct parameter (a bare class-named type, NOT a
        # Ptr[Class]). Adder has no by-value aggregate ABI: aggregates cross
        # function boundaries through Ptr[T] (the caller passes &obj). The
        # seed (codegen_x86) raises the same error; this keeps the backends
        # in lockstep instead of silently spilling one register's worth and
        # reading the rest as stack garbage.
        if struct_lookup_by_node(ptnode) != 0:
            cg_fail(9, p)            # by-value struct param: unsupported
            return start
        psz: uint32 = ptr_pointee_size(ptnode)
        if psz != 0:
            psidx_pp: uint32 = ptr_struct_idx(ptnode)
            alloc_ptr_local(nd_name_off[p], nd_name_len[p], psz)
            # A Ptr[Struct] param (e.g. `c: Ptr[P9Cursor]`) records its pointee
            # struct so `c[i].field` member access resolves — mirrors gen_method's
            # parameter handling. Without this, member_resolve can't type c[i].
            if psidx_pp != 0:
                loc_set_struct_ptr(psidx_pp)
            # Record the Ptr[T] type node so index_elem_signed recovers the
            # pointee signedness for an indexed Ptr param `a[i]` (e.g. a
            # `Ptr[uint8]` param compared `a[i] < c[k]` needs UNSIGNED setb).
            if loc_count > 0:
                loc_type_node[loc_count - 1] = ptnode
        else:
            alloc_local(nd_name_off[p], nd_name_len[p])
            loc_set_signedness(type_signedness(ptnode))
            psz_d: uint32 = prim_type_size(ptnode)
            # Tag a sub-8-byte scalar param with its declared width so the spill
            # truncates the slot and identifier loads extend from it — mirrors
            # codegen_x86._scalar_local_size, which keys off the slot's byte size
            # REGARDLESS of signedness. type_signedness returns 0 only for a
            # float32 param (code 10), which is sub-8-byte (4) too; tagging it 4
            # makes the spill a sized movl + the load a sized movl, instead of a
            # blind 8-byte movq that would read the arg register's high garbage.
            if psz_d < 8:
                loc_set_scalar_size(psz_d)
            pfw_d: uint32 = type_float_width(ptnode)
            if pfw_d != 0:
                loc_set_float(pfw_d)
        nparams = nparams + 1
        p = nd_next[p]

    # Pre-scan the body and reserve a slot for every local (VAR_DECL or
    # first assignment to a new name), recursing into if/elif/else/while
    # bodies. This must happen BEFORE the frame reservation below, because
    # `sub $frame,%rsp` needs the final cg_stack_size; allocating slots
    # lazily during body emission would place them past the reserved frame
    # and corrupt the stack. (codegen_x86 does the same pre-scan pass.)
    prescan_block(nd_c[fn])

    # Phase-4 regalloc (OFF by default). Build a linear-scan allocation for this
    # function; cg_ra_active gates every emit hook so the default path is
    # byte-identical. Falls back to all-memory (cg_ra_active=0) if the allocator
    # could not build (overflow / validation), which is always correct.
    cg_ra_active = 0
    cg_ra_pad = 0
    cg_callee_active = 0
    cg_scratch_reserved_mask = 0
    if ra_is_enabled() != 0:
        if ra_build_for_function(fn) != 0:
            cg_ra_active = 1
    # IR scratch reservation: build the per-function availability (callee regs
    # regalloc did not claim), prescan the body for the deepest scratch demand,
    # then reserve that many regs to PUSH in the prologue. ir_scratch_build_avail
    # also resets the busy/used state for the body's acquire/release. Gated by the
    # IR emit flag (no-op when --opt is off, so default output is unchanged).
    ir_scratch_build_avail()
    ir_scratch_prescan_function(fn)
    cg_build_scratch_reserved()
    if cg_ra_active != 0 or cg_scratch_reserved_mask != 0:
        cg_callee_active = 1

    # Prologue.
    emit_endbr64()
    if cg_callee_active != 0:
        ra_emit_prologue_saves()         # push saved callee-saved regs first
    emit_push_rbp()
    emit_mov_rsp_rbp()

    # 16-byte-aligned frame reservation (matches codegen_x86's
    # (stack_size + 15) & ~15). Skip the subq entirely when zero. When an ODD
    # number of callee regs was pushed, pad the frame by 8 to keep %rsp 16-byte
    # aligned at inner calls.
    frame: uint32 = (cg_stack_size + 15) & cast[uint32](0xFFFFFFF0)
    if cg_callee_active != 0 and cg_ra_pad != 0:
        frame = frame + 8
    if frame > 0:
        emit_sub_rsp(frame)

    # Spill parameters from their arg registers (and the stack, for args 6+)
    # into the stack slots.
    spill_params(nd_a[fn])

    # Load register-resident locals (incl. params) from their slots into their
    # assigned registers, so the body's first read sees the right value.
    if cg_ra_active != 0:
        ra_emit_init_regs(nd_a[fn])

    # Body (statement chain on nd_c).
    s: uint32 = nd_c[fn]
    last_was_return: uint32 = 0
    while s != 0:
        gen_stmt(s)
        if nd_kind[s] == ND_RETURN:
            last_was_return = 1
        else:
            last_was_return = 0
        s = nd_next[s]

    # Fallthrough epilogue when the body did not end in a return (mirrors
    # codegen_x86's `if not last_is_return: leave; ret`).
    if last_was_return == 0:
        emit_function_epilogue()

    cg_ra_active = 0                      # clear for the next function
    cg_callee_active = 0
    return start


# Emit a class method `def m(self, ...)` as a free function with mangled
# identity (owner class `cls`, method `m`). Mirrors codegen_x86.gen_method:
# the only difference from a plain function is the implicit `self: Ptr[Class]`
# first parameter (the parser marks it nd_aux==1, name empty) — its slot
# holds the receiver address, and `self.field` resolves against `cls`'s
# struct layout via cg_self_struct/cg_self_off.
def gen_method(cls: uint32, m: uint32) -> uint32:
    start: uint32 = code_len
    # Register the mangled (owner class, method) symbol for call resolution.
    mfn_define(nd_name_off[cls], nd_name_len[cls], nd_name_off[m], nd_name_len[m], start)

    loc_count = 0
    cg_stack_size = 0
    fi_count = 0

    sidx1: uint32 = struct_lookup(nd_name_off[cls], nd_name_len[cls])
    cg_self_struct = sidx1

    # Allocate a slot per parameter. The first param is `self` (nd_aux==1):
    # an 8-byte slot holding the receiver address (a Ptr[Class]).
    p: uint32 = nd_a[m]
    nparams: uint32 = 0
    first_param: uint32 = 1
    while p != 0:
        if first_param != 0 and nd_aux[p] == 1:
            # self: an 8-byte address slot. Record its offset for body access.
            cg_self_off = alloc_ptr_local(0, 0, 0)
        else:
            ptnode: uint32 = nd_a[p]
            psz: uint32 = ptr_pointee_size(ptnode)
            if psz != 0:
                psidx: uint32 = ptr_struct_idx(ptnode)
                alloc_ptr_local(nd_name_off[p], nd_name_len[p], psz)
                if psidx != 0:
                    loc_set_struct_ptr(psidx)
            else:
                alloc_local(nd_name_off[p], nd_name_len[p])
                loc_set_signedness(type_signedness(ptnode))
                psz_d: uint32 = prim_type_size(ptnode)
                # See gen_function: tag every sub-8-byte scalar param (incl.
                # float32) so the spill + load are sized, mirroring the seed.
                if psz_d < 8:
                    loc_set_scalar_size(psz_d)
                pfw_d: uint32 = type_float_width(ptnode)
                if pfw_d != 0:
                    loc_set_float(pfw_d)
        first_param = 0
        nparams = nparams + 1
        p = nd_next[p]

    prescan_block(nd_c[m])

    # Phase-4 regalloc (OFF by default). A method is structurally a free function
    # whose first param is the unnamed `self` Ptr — cfg_build_function lowers
    # nd_a[m]/nd_c[m] exactly as for a plain function, and the body emit hooks
    # (gen_ident read / store_to_named write-through) are shared. `self` has an
    # empty name so ra_reg_for_name never matches it (it stays on cg_self_off's
    # memory path); ra_emit_init_regs already skips the unnamed param. Every other
    # named param/local is promoted identically to gen_function. Falls back to
    # all-memory (cg_ra_active=0) on overflow/validation failure — always correct.
    cg_ra_active = 0
    cg_ra_pad = 0
    cg_callee_active = 0
    cg_scratch_reserved_mask = 0
    if ra_is_enabled() != 0:
        if ra_build_for_function(m) != 0:
            cg_ra_active = 1
    # IR scratch reservation (see gen_function): prescan the method body for the
    # deepest scratch demand and reserve that many callee regs to save.
    ir_scratch_build_avail()
    ir_scratch_prescan_function(m)
    cg_build_scratch_reserved()
    if cg_ra_active != 0 or cg_scratch_reserved_mask != 0:
        cg_callee_active = 1

    emit_endbr64()
    if cg_callee_active != 0:
        ra_emit_prologue_saves()         # push saved callee-saved regs first
    emit_push_rbp()
    emit_mov_rsp_rbp()
    frame: uint32 = (cg_stack_size + 15) & cast[uint32](0xFFFFFFF0)
    if cg_callee_active != 0 and cg_ra_pad != 0:
        frame = frame + 8
    if frame > 0:
        emit_sub_rsp(frame)

    # Spill parameters (self included) from arg registers / stack into slots.
    spill_params(nd_a[m])

    # Load register-resident locals (incl. named params) from their slots into
    # their assigned callee-saved registers before the body's first read.
    if cg_ra_active != 0:
        ra_emit_init_regs(nd_a[m])

    s: uint32 = nd_c[m]
    last_was_return: uint32 = 0
    while s != 0:
        gen_stmt(s)
        if nd_kind[s] == ND_RETURN:
            last_was_return = 1
        else:
            last_was_return = 0
        s = nd_next[s]
    if last_was_return == 0:
        emit_function_epilogue()

    cg_ra_active = 0                      # clear for the next function
    cg_callee_active = 0
    cg_self_struct = 0
    return start


# Emit every method of every class in the program. Each ND_CLASS carries its
# method chain on nd_b (ND_FUNCTION nodes). Mirrors codegen_x86's
# `case ClassDef(): for m in decl.methods: self.gen_method(decl, m)`.
def gen_class_methods(prog: uint32):
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_CLASS:
            m: uint32 = nd_b[cur]
            while m != 0:
                gen_method(cur, m)
                m = nd_next[m]
        cur = nd_next[cur]


# Generate code for the first function found in a parsed program. The
# program node has its declaration chain on nd_b; we walk to the first
# ND_FUNCTION and emit it. Returns that function's code start offset.
# -----------------------------------------------------------------------
# Module-level (global) variable layout.
#
# A top-level ND_VAR_DECL is a global. We reserve a data slot for it and,
# for a constant initialiser we can resolve at layout time (an int literal
# for a scalar, or a string literal for a `name: Array[N, uint8] = "..."`
# global), write the initial bytes straight into gdata[]. Scalars with no
# initialiser are zeroed (.bss-style). Non-constant initialisers are out
# of this subset (codegen_x86 emits _init_* runtime fill there).
# -----------------------------------------------------------------------

# Lay out one module-level ND_VAR_DECL into the data section.
def layout_global(decl: uint32):
    tnode: uint32 = nd_a[decl]
    val: uint32 = nd_b[decl]
    # PERCPU global (kernel target): `name: Percpu[T]`. Parsed as an ND_TYPE
    # whose name is "Percpu" (the [T] args are discarded by parse_type). Lay it
    # out into the separate per-CPU TEMPLATE (8 bytes each, T is always a
    # uint64-width scalar in the kernel) at glob_offset = the running percpu
    # offset, and mark it percpu so access lowers to %gs:offset and the ELF
    # writer exports it as a .data..percpu symbol. cpu_id_pcpu is PINNED to
    # percpu offset 0 (hard ABI — the .S `movq %gs:0` reads it; regression #402).
    if cg_target_kernel != 0 and tnode != 0 and nd_kind[tnode] == ND_TYPE and type_name_is(tnode, "Percpu") != 0:
        pcsz: uint32 = 8
        # PINNED per-CPU ABI offsets. The seed (codegen_x86.py) assigns percpu
        # offsets in IMPORT-CLOSURE order (collect_all_imports' stack DFS), so
        # the live %gs:offset of every percpu slot is fixed by that traversal:
        #   cpu_id_pcpu             0x00   (also the hand-written .S `movq %gs:0`)
        #   softirq_pending_pcpu    0x08
        #   in_softirq_pcpu         0x10
        #   softirq_run_count_pcpu  0x18
        #   tasklet_head_pcpu       0x20
        #   tasklet_hi_head_pcpu    0x28
        #   local_timer_ticks       0x30
        #   linux_current_task_pcpu 0x38
        #   current_idx_pcpu        0x40
        # The self-hosted host_ac's import driver (fused_driver_host_main.ad)
        # walks the closure in a DIFFERENT order (recursive post-order, textual)
        # than the seed's LIFO stack DFS, so its running `percpu_len` counter
        # assigned current_idx_pcpu 0x38 and local_timer_ticks 0x40 — a layout
        # self-consistent WITHIN the native kernel but DIVERGENT from the seed's
        # per-CPU ABI. Pin each kernel percpu global to the seed's offset by name
        # (mirrors the pre-existing cpu_id_pcpu pin) so the native per-CPU layout
        # is deterministic and seed-identical regardless of import-walk order.
        pcoff: uint32 = percpu_len
        if name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "cpu_id_pcpu") != 0:
            pcoff = 0
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "softirq_pending_pcpu") != 0:
            pcoff = 8
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "in_softirq_pcpu") != 0:
            pcoff = 16
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "softirq_run_count_pcpu") != 0:
            pcoff = 24
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "tasklet_head_pcpu") != 0:
            pcoff = 32
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "tasklet_hi_head_pcpu") != 0:
            pcoff = 40
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "local_timer_ticks") != 0:
            pcoff = 48
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "linux_current_task_pcpu") != 0:
            pcoff = 56
        elif name_eq_cstr(nd_name_off[decl], nd_name_len[decl], "current_idx_pcpu") != 0:
            pcoff = 64
        percpu_len = percpu_len + pcsz
        glob_define(nd_name_off[decl], nd_name_len[decl], pcoff, 0, pcsz)
        glob_set_percpu()
        return
    if tnode != 0 and nd_kind[tnode] == ND_ARRAY_TYPE:
        # The INNERMOST scalar element width (the load/store size at the
        # deepest index). For a 1-D array this is just the element type's
        # size; for a nested array `Array[N, Array[M, T]]` we walk past every
        # ND_ARRAY_TYPE level to T and size that. This is the width
        # glob_elem_size carries (used by a fully-indexed access).
        inner_t: uint32 = nd_a[tnode]
        while nd_kind[inner_t] == ND_ARRAY_TYPE:
            inner_t = nd_a[inner_t]
        es: uint32 = prim_type_size(inner_t)
        # String-initialised byte array: place the literal's NUL-terminated
        # bytes and register the global at that data offset (mirrors
        # codegen_x86's string-literal global path). Only a 1-D uint8 array.
        if val != 0 and nd_kind[val] == ND_STRING_LIT and es == 1 and nd_kind[nd_a[tnode]] != ND_ARRAY_TYPE:
            doff: uint32 = intern_string(nd_name_off[val], nd_name_len[val])
            glob_define(nd_name_off[decl], nd_name_len[decl], doff, es, 0)
            glob_set_type_node(tnode)
            return
        # Zero-init array → .bss: reserve VIRTUAL space only (no file bytes,
        # no gdata[] writes). This is the crux of the BSS model: an array
        # global as big as GDATA_CAP itself no longer needs to be stored.
        # Total bytes is the FULL (possibly nested) array size, so a 2-D
        # global reserves N*M*sizeof(T) — exactly codegen_x86.get_type_size.
        bytes_: uint32 = type_size_of(tnode)
        bbase: uint32 = bss_reserve(bytes_)
        glob_define(nd_name_off[decl], nd_name_len[decl], bbase, es, 0)
        glob_set_bss()
        # Carry the full type so nested indexing can scale the outer index by
        # the row stride (codegen_x86 keeps the whole ArrayType for this).
        glob_set_type_node(tnode)
        return
    # Ptr[T] global: an 8-byte scalar slot that holds an address. A non-zero
    # constant int initialiser goes in .data (stored); `= 0` or no init is
    # all-zero → .bss (virtual only). Either way mark the pointee width so
    # indexing (g[i]) dereferences with the right element size.
    psz: uint32 = ptr_pointee_size(tnode)
    if psz != 0:
        if val != 0 and nd_kind[val] == ND_INT_LIT and nd_num[val] != 0:
            pbase: uint32 = gdata_reserve(8)
            glob_define(nd_name_off[decl], nd_name_len[decl], pbase, 0, 8)
            glob_set_ptr_size(psz)
            glob_set_type_node(tnode)
            pv: uint64 = nd_num[val]
            pi: uint32 = 0
            while pi < 8:
                gdata[pbase + pi] = cast[uint8](pv & 255)
                pv = pv >> 8
                pi = pi + 1
        else:
            pbss: uint32 = bss_reserve(8)
            glob_define(nd_name_off[decl], nd_name_len[decl], pbss, 0, 8)
            glob_set_ptr_size(psz)
            glob_set_type_node(tnode)
            glob_set_bss()
        return
    # Struct-typed global: an in-place struct value. Zero-init → .bss,
    # reserving the struct's full total_size bytes (no file storage). A
    # struct global has no scalar/constant initialiser in this subset.
    gsi: uint32 = struct_lookup_by_node(tnode)
    if gsi != 0:
        gbytes: uint32 = st_total[gsi - 1]
        gbase: uint32 = bss_reserve(gbytes)
        glob_define(nd_name_off[decl], nd_name_len[decl], gbase, 0, 0)
        glob_set_bss()
        glob_set_struct(gsi)
        return
    # Scalar global. A non-zero constant int initialiser goes in .data
    # (stored, little-endian); `= 0` or no initialiser is all-zero → .bss
    # (virtual address space only, no file storage).
    sz: uint32 = prim_type_size(tnode)
    # A sub-8-byte SIGNED scalar (int8/int16/int32) must sign-extend on load.
    sgn: uint32 = 0
    if sz < 8 and type_is_unsigned(tnode) == 0:
        sgn = 1
    gfw: uint32 = type_float_width(tnode)   # 0/4/8: float global float width
    # Fold the constant initialiser, handling BOTH a bare `ND_INT_LIT` AND a
    # NEGATIVE literal `ND_UNARY(UNOP_NEG, ND_INT_LIT)` — `name: int32 = -10000`
    # parses as the latter, NOT a bare int literal. The previous check tested
    # only `nd_kind[val] == ND_INT_LIT`, so a negative-literal global fell to
    # the `else` (zero-init .bss) branch and came up as 0 at runtime instead of
    # its declared value — a value-level miscompile invisible to the objdiff
    # (same load instructions; only the .data BYTES differ). The seed
    # (codegen_x86.py gen_data emit_init) const-folds the UnaryOp.NEG and emits
    # `.quad -value` into .data; mirror that exactly. const_int_value returns
    # the folded i64 (two's-complement low-`sz` bytes written below).
    folded_v: int64 = 0
    have_const: uint32 = 0
    if val != 0:
        have_const = const_int_value(val, &folded_v)
    if have_const != 0 and folded_v != 0:
        base: uint32 = gdata_reserve(sz)
        glob_define(nd_name_off[decl], nd_name_len[decl], base, 0, sz)
        if sgn != 0:
            glob_set_signed()
        glob_set_signedness(type_signedness(tnode))
        if gfw != 0:
            glob_set_float(gfw)
        v: uint64 = cast[uint64](folded_v)
        i: uint32 = 0
        while i < sz:
            gdata[base + i] = cast[uint8](v & 255)
            v = v >> 8
            i = i + 1
    else:
        sbss: uint32 = bss_reserve(sz)
        glob_define(nd_name_off[decl], nd_name_len[decl], sbss, 0, sz)
        glob_set_bss()
        if sgn != 0:
            glob_set_signed()
        glob_set_signedness(type_signedness(tnode))
        if gfw != 0:
            glob_set_float(gfw)


# Walk the program's declaration chain and lay out every module-level
# global BEFORE any function is emitted, so global references resolve
# against a stable data offset.
def layout_globals(prog: uint32):
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_VAR_DECL:
            layout_global(cur)
        cur = nd_next[cur]


def gen_program_first_function(prog: uint32) -> uint32:
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            return gen_function(cur)
        cur = nd_next[cur]
    cg_fail(9, 0)
    return 0


# Generate code for EVERY function in a parsed program, back-to-back, then
# resolve all inter-function `call` fixups. Returns the code start offset
# of the first function (0 on an empty program). This is the entry point
# for programs that contain calls between functions.
def gen_program_all_functions(prog: uint32) -> uint32:
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    first: uint32 = 0
    seen: uint32 = 0
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            off: uint32 = gen_function(cur)
            if seen == 0:
                first = off
                seen = 1
        cur = nd_next[cur]
    if seen == 0:
        cg_fail(9, 0)
        return 0
    link_runtime_externs()
    resolve_calls()
    resolve_entry(first)
    return first


# Full-program entry point WITH module-level globals + string literals.
# Lays out every global into the data section first (so references resolve
# against stable offsets), emits every function back-to-back, then resolves
# both inter-function call fixups and RIP-relative data fixups. Returns the
# first function's code start offset. This is the entry point a real
# self-hosting build (lexer/parser holding state in globals) needs.
def gen_program_with_globals(prog: uint32) -> uint32:
    # Stash the decl chain so class layout can resolve inheritance bases by
    # name, then lay out every class BEFORE globals (a struct-typed global
    # needs its struct total_size) and before any function/method emission.
    cg_prog_decls = nd_b[prog]
    if cg_target_kernel != 0:
        collect_externs(prog)
    layout_classes(prog)
    layout_globals(prog)
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    first: uint32 = 0
    seen: uint32 = 0
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            off: uint32 = gen_function(cur)
            if seen == 0:
                first = off
                seen = 1
        cur = nd_next[cur]
    # Emit every class method as a free function (after the plain functions so
    # `first`/entry resolution stays anchored on a real `main`).
    gen_class_methods(prog)
    if seen == 0:
        cg_fail(9, 0)
        return 0
    # The kernel target resolves its `sys_*`-style externs through `ld`
    # (against the .S objects), NOT the in-`.ad` runtime-wrapper synthesis the
    # user target uses. So skip link_runtime_externs for the kernel.
    if cg_target_kernel == 0:
        link_runtime_externs()
    resolve_calls()
    resolve_method_calls()
    resolve_data_fixups()
    resolve_entry(first)
    return first

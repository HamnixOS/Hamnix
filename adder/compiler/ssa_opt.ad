)

# =======================================================================
# scratch arenas (per-run; sized like the value arena)
# =======================================================================
sv_mark: Array[65536, uint32]      # DCE liveness scratch (1 = live)
opt_stack: Array[65536, uint32]    # generic worklist
opt_sp: uint32 = 0

OPT_STACK_MAX: uint32 = 65536

# =======================================================================
# pass enable/disable mask (ADDER_OPT_DISABLE names, §6.1).  Bit set => the pass
# is DISABLED.  Parsed by ssa_opt_parse_disable (driver wires it next to
# ssa_parse_env); default 0 => all passes on.
# =======================================================================
SSAOPT_SCCP: uint32 = 1
SSAOPT_INSTCOMBINE: uint32 = 2
SSAOPT_GVN: uint32 = 4
SSAOPT_LICM: uint32 = 8
SSAOPT_DCE: uint32 = 16
ssa_opt_disabled_mask: uint32 = 0

# whole-pipeline gate (independent of ADDER_OPT2 driver gate; default on so the
# emit lane always optimizes when it reaches here).
ssa_opt_pipeline_on: uint32 = 1

# per-pass verify (host lane): re-verify after every pass and count corruption.
ssa_opt_verify_each: uint32 = 1

# =======================================================================
# stats / evidence counters (exposed via the driver's OPT2 report)
# =======================================================================
ssa_opt_dce_removed: uint32 = 0
ssa_opt_sccp_folded: uint32 = 0
ssa_opt_sccp_edges_pruned: uint32 = 0
ssa_opt_gvn_replaced: uint32 = 0
ssa_opt_licm_hoisted: uint32 = 0
ssa_opt_instcombine_count: uint32 = 0
ssa_opt_verify_fail: uint32 = 0
ssa_opt_runs: uint32 = 0


def ssa_opt_stats_reset():
    ssa_opt_dce_removed = 0
    ssa_opt_sccp_folded = 0
    ssa_opt_sccp_edges_pruned = 0
    ssa_opt_gvn_replaced = 0
    ssa_opt_licm_hoisted = 0
    ssa_opt_instcombine_count = 0
    ssa_opt_verify_fail = 0
    ssa_opt_runs = 0


def ssa_opt_pass_disabled(bit: uint32) -> uint32:
    if (ssa_opt_disabled_mask & bit) != 0:
        return 1
    return 0


# =======================================================================
# intrusive-list surgery: unlink value `v` from its block.  Positions (sv_pos)
# stay a MONOTONIC subsequence of the original order, so intra-block dominance
# (def-pos < use-pos) remains valid without renumbering.
# =======================================================================
def ssa_unlink_value(v: uint32):
    bb: uint32 = sv_block[v]
    if bb == 0:
        return
    pv: uint32 = sv_prev[v]
    nx: uint32 = sv_next[v]
    if pv != 0:
        sv_next[pv] = nx
    else:
        sb_first_val[bb] = nx
    if nx != 0:
        sv_prev[nx] = pv
    else:
        sb_last_val[bb] = pv
    if sb_nval[bb] > 0:
        sb_nval[bb] = sb_nval[bb] - 1
    sv_block[v] = 0
    sv_next[v] = 0
    sv_prev[v] = 0


# Insert value `v` immediately BEFORE the terminator of block `bb` (used by LICM
# to move an invariant into the pre-header).  `v` must currently be unlinked.
def ssa_insert_before_term(bb: uint32, v: uint32):
    if bb == 0 or v == 0:
        return
    term: uint32 = sb_last_val[bb]
    sv_block[v] = bb
    sb_nval[bb] = sb_nval[bb] + 1
    if term == 0:
        # empty block: v becomes the sole value.
        sb_first_val[bb] = v
        sb_last_val[bb] = v
        sv_prev[v] = 0
        sv_next[v] = 0
        ssa_renumber(bb)
        return
    pv: uint32 = sv_prev[term]
    sv_prev[v] = pv
    sv_next[v] = term
    sv_prev[term] = v
    if pv != 0:
        sv_next[pv] = v
    else:
        sb_first_val[bb] = v
    ssa_renumber(bb)


# Re-stamp sv_pos across a block so positions stay dense + ordered.
def ssa_renumber(bb: uint32):
    p: uint32 = 0
    cur: uint32 = sb_first_val[bb]
    while cur != 0:
        sv_pos[cur] = p
        p = p + 1
        cur = sv_next[cur]


# =======================================================================
# operand iteration helpers (shared by DCE / GVN / LICM).  A value's VALUE
# operands are its data dependencies; block-id fields (BR/CONDBR targets) are
# NOT operands.
# =======================================================================
# Number of fixed (non-list) value operands carried in sv_a/sv_b.
def ssa_op_has_a(op: uint32) -> uint32:
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_FCMP or op == SVO_GEP or op == SVO_STORE:
        return 1
    if op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT or op == SVO_LOAD:
        return 1
    if op == SVO_TRUNC or op == SVO_ZEXT or op == SVO_SEXT or op == SVO_BITCAST or op == SVO_I2F or op == SVO_F2I:
        return 1
    if op == SVO_CONDBR:
        return 1
    if op == SVO_RET:
        return 1
    return 0


def ssa_op_has_b(op: uint32) -> uint32:
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_FCMP or op == SVO_GEP or op == SVO_STORE:
        return 1
    return 0


# =======================================================================
# 4.4  DCE — mark-sweep over SSA.
# =======================================================================
def ssa_dce_side_effect(op: uint32) -> uint32:
    # stores / calls / syscalls / terminators are live regardless of use.
    if op == SVO_STORE or op == SVO_CALL or op == SVO_SYSCALL:
        return 1
    if op == SVO_BR or op == SVO_CONDBR or op == SVO_RET:
        return 1
    # a %gs/percpu access is a volatile read — never dead (conservative).
    if op == SVO_PERCPU:
        return 1
    return 0


def dce_visit(w: uint32):
    if w == 0:
        return
    if w >= sv_count:
        return
    if sv_mark[w] != 0:
        return
    if opt_sp >= OPT_STACK_MAX:
        return
    sv_mark[w] = 1
    opt_stack[opt_sp] = w
    opt_sp = opt_sp + 1


# Push v's value operands onto the worklist.
def dce_push_operands(v: uint32):
    op: uint32 = sv_op[v]
    if ssa_op_has_a(op) != 0:
        dce_visit(sv_a[v])
    if ssa_op_has_b(op) != 0:
        dce_visit(sv_b[v])
    if op == SVO_PHI or op == SVO_CALL:
        node: uint32 = sv_arg_head[v]
        while node != 0:
            dce_visit(arg_val[node])
            node = arg_next[node]


def ssa_dce():
    if ssa_opt_pass_disabled(SSAOPT_DCE) != 0:
        return
    # clear marks
    i: uint32 = 1
    while i < sv_count:
        sv_mark[i] = 0
        i = i + 1
    # seed: every LINKED side-effecting value.
    opt_sp = 0
    i = 1
    while i < sv_count:
        if sv_block[i] != 0:
            if ssa_dce_side_effect(sv_op[i]) != 0:
                dce_visit(i)
        i = i + 1
    # propagate liveness through operands.
    while opt_sp > 0:
        opt_sp = opt_sp - 1
        v: uint32 = opt_stack[opt_sp]
        dce_push_operands(v)
    # sweep: unlink every unmarked non-terminator value.
    b: uint32 = 1
    while b < sb_count:
        cur: uint32 = sb_first_val[b]
        while cur != 0:
            nxt: uint32 = sv_next[cur]
            if sv_mark[cur] == 0 and ssa_is_terminator(sv_op[cur]) == 0:
                ssa_unlink_value(cur)
                ssa_opt_dce_removed = ssa_opt_dce_removed + 1
            cur = nxt
        b = b + 1


# =======================================================================
# pass manager (§4).  Runs after ssa_build_function, before the trivial lowering.
# =======================================================================
def ssa_opt_verify_check():
    if ssa_opt_verify_each == 0:
        return
    rc: uint32 = ssa_verify()
    if rc != SSAV_OK:
        ssa_opt_verify_fail = ssa_opt_verify_fail + 1


def ssa_opt_run(entry: uint32):
    if ssa_opt_pipeline_on == 0:
        return
    ssa_opt_runs = ssa_opt_runs + 1
    # dominator tree + RPO for the dominance-aware passes.
    ssa_build_domtree()
    # Phase-2 increment 1: DCE only.  Later increments add SCCP/GVN/LICM/
    # InstCombine before this final sweep.
    ssa_dce()
    ssa_opt_verify_check()

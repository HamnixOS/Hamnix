# adder/compiler/ssa_opt.ad
#
# Phase 2 of the SSA optimizer rewrite (docs/adder_ssa_optimizer_design.md §4):
# the OPTIMIZATION PASSES on SSA.  These transform the Phase-1 SSA IR (ssa.ad)
# BEFORE the trivial all-memory lowering in ssa_emit.ad — they are independent of
# the register allocator (Phase 3) and rely only on SSA + the dominator tree
# (both already produced by ssa.ad).
#
# PIPELINE (LLVM canon, §4):
#     build SSA - verify - SCCP - InstCombine - GVN/CSE - LICM - DCE - verify
# The middle passes iterate to a small fixpoint, then a final DCE sweeps corpses.
#
# WHY THESE ARE SAFE ON SSA
# -------------------------
#  * DCE — an SSA value with no uses and no side effect is dead by construction;
#    a store to a global is a side effect and is NEVER removed (this structurally
#    kills the old dead-store global-cap bug).
#  * SCCP — a joint value+edge lattice folds constants and prunes provably-dead
#    branch edges; strictly stronger than the old separate constfold/constbranch.
#  * GVN/CSE — hash-cons pure instructions; an earlier congruent value whose def
#    DOMINATES the use replaces the redundant one (no name-clobber scan needed,
#    SSA values are immutable).
#  * LICM — an instruction is loop-invariant iff ALL its operands are defined
#    OUTSIDE the loop.  The old loop-condition-CSE hoist bug CANNOT recur: a
#    body-mutated value is a DIFFERENT SSA value with a def inside the loop, so it
#    fails the invariance test trivially.
#  * InstCombine — algebraic identities (x+0, x*1, x&x, x^x, x*2^k -> shl, ...).
#
# GATING / ISOLATION
# ------------------
# Reached ONLY from ssa_emit_function (ssa_emit.ad), which runs ONLY under the
# ADDER_OPT2 gate.  With the gate off this module is never entered, so codegen
# output is byte-for-byte the pre-SSA path.  Like ssa.ad / ssa_emit.ad this stays
# OUT of the seed MODULES list (host-only); codegen.ad is untouched.  Every pass
# preserves SSA well-formedness; ssa_verify re-runs after the pipeline (and, in
# this host lane, after each pass — ssa_opt_verify_fail counts any corruption).

from compiler.parser import (
    BINOP_ADD,
    BINOP_SUB,
    BINOP_MUL,
    BINOP_DIV,
    BINOP_IDIV,
    BINOP_MOD,
    BINOP_EQ,
    BINOP_NEQ,
    BINOP_LT,
    BINOP_LTE,
    BINOP_GT,
    BINOP_GTE,
    BINOP_BIT_OR,
    BINOP_BIT_AND,
    BINOP_BIT_XOR,
    BINOP_SHL,
    BINOP_SHR,
)

from compiler.ssa import (
    sv_op,
    sv_type,
    sv_a,
    sv_b,
    sv_c,
    sv_aux,
    sv_imm,
    sv_block,
    sv_ast,
    sv_next,
    sv_prev,
    sv_pos,
    sv_arg_head,
    sv_argn,
    sv_count,
    arg_val,
    arg_pred,
    arg_next,
    sb_first_val,
    sb_last_val,
    sb_term,
    sb_nval,
    sb_succ0,
    sb_succ1,
    sb_nsucc,
    sb_pred_head,
    sb_npred,
    sb_idom,
    sb_rpo,
    sb_rpo_n,
    sb_count,
    sb_entry,
    sb_visited,
    pl_bid,
    pl_next,
    ssa_build_domtree,
    ssa_build_rpo,
    ssa_dominates,
    ssa_is_terminator,
    ssa_verify,
    SSAV_OK,
    SVO_NULL,
    SVO_CONST,
    SVO_FCONST,
    SVO_UNDEF,
    SVO_PARAM,

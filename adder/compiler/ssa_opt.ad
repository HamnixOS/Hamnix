)

# =======================================================================
# scratch arenas (per-run; sized like the value arena)
# =======================================================================
sv_mark: Array[65536, uint32]      # DCE liveness scratch (1 = live)
opt_stack: Array[65536, uint32]    # generic worklist
opt_sp: uint32 = 0

OPT_STACK_MAX: uint32 = 65536
SSA_BB_MAX_LOCAL: uint32 = 1024

# ----- SCCP lattice + worklists (Wegman-Zadeck) ------------------------
LAT_TOP: uint32 = 0                # unknown (optimistic)
LAT_CONST: uint32 = 1
LAT_BOT: uint32 = 2               # overdefined
sccp_lat: Array[65536, uint32]
sccp_cv: Array[65536, uint64]
sccp_bexec: Array[1024, uint32]   # block reachable
sccp_e0: Array[1024, uint32]      # edge (b -> succ0) executable
sccp_e1: Array[1024, uint32]      # edge (b -> succ1) executable
# def -> users map (reverse operand edges), rebuilt per SCCP run.
u_head: Array[65536, uint32]
u_next: Array[262144, uint32]
u_valn: Array[262144, uint32]     # the using value id
u_count: uint32 = 1
U_MAX: uint32 = 262144
# block + value worklists (dedup-flagged so they stay bounded).
sccp_bwl: Array[1024, uint32]
sccp_bsp: uint32 = 0
sccp_bq: Array[1024, uint32]
sccp_vwl: Array[65536, uint32]
sccp_vsp: uint32 = 0
sccp_vq: Array[65536, uint32]
# sccp_compute / meet results (Adder has no tuple return; use scratch globals).
res_lat: uint32 = 0
res_cv: uint64 = 0
acc_lat: uint32 = 0
acc_cv: uint64 = 0

# =======================================================================
# pass enable/disable mask (ADDER_OPT_DISABLE names, §6.1).  Bit set => the pass
# is DISABLED.  Parsed by ssa_opt_parse_disable (driver wires it next to
# ssa_parse_env); default 0 => all passes on.
# =======================================================================
SSAOPT_SCCP: uint32 = 1
SSAOPT_INSTCOMBINE: uint32 = 2
SSAOPT_GVN: uint32 = 4
SSAOPT_LICM: uint32 = 8
SSAOPT_DCE: uint32 = 16
ssa_opt_disabled_mask: uint32 = 0

# whole-pipeline gate (independent of ADDER_OPT2 driver gate; default on so the
# emit lane always optimizes when it reaches here).
ssa_opt_pipeline_on: uint32 = 1

# per-pass verify (host lane): re-verify after every pass and count corruption.
ssa_opt_verify_each: uint32 = 1

# =======================================================================
# stats / evidence counters (exposed via the driver's OPT2 report)
# =======================================================================
ssa_opt_dce_removed: uint32 = 0
ssa_opt_sccp_folded: uint32 = 0
ssa_opt_sccp_edges_pruned: uint32 = 0
ssa_opt_gvn_replaced: uint32 = 0
ssa_opt_licm_hoisted: uint32 = 0
ssa_opt_instcombine_count: uint32 = 0
ssa_opt_verify_fail: uint32 = 0
ssa_opt_runs: uint32 = 0


def ssa_opt_stats_reset():
    ssa_opt_dce_removed = 0
    ssa_opt_sccp_folded = 0
    ssa_opt_sccp_edges_pruned = 0
    ssa_opt_gvn_replaced = 0
    ssa_opt_licm_hoisted = 0
    ssa_opt_instcombine_count = 0
    ssa_opt_verify_fail = 0
    ssa_opt_runs = 0


def ssa_opt_pass_disabled(bit: uint32) -> uint32:
    if (ssa_opt_disabled_mask & bit) != 0:
        return 1
    return 0


# ADDER_OPT_DISABLE names for the SSA passes (§6.1): sccp, instcombine, gvn,
# licm2, dce2.  Parsed from envp exactly like ssa_parse_env; the driver calls
# this next to ssa_parse_env so an OPT2 miscompile bisects per-pass.
def ssa_opt_prefix_len(e: Ptr[uint8], pfx: Ptr[uint8]) -> uint32:
    j: uint32 = 0
    while pfx[j] != 0:
        if e[j] != pfx[j]:
            return 0
        j = j + 1
    return j


# Does e[pos..] equal `name` followed by a token delimiter (NUL or ',')?
def ssa_opt_tok_eq(e: Ptr[uint8], pos: uint32, name: Ptr[uint8]) -> uint32:
    j: uint32 = 0
    while name[j] != 0:
        if e[pos + j] != name[j]:
            return 0
        j = j + 1
    c: uint8 = e[pos + j]
    if c == 0 or c == cast[uint8](44):
        return 1
    return 0


def ssa_opt_parse_disable(argc: int32, argv: Ptr[uint64]):
    ei: uint32 = cast[uint32](argc) + 1
    while argv[ei] != 0:
        e: Ptr[uint8] = cast[Ptr[uint8]](argv[ei])
        klen: uint32 = ssa_opt_prefix_len(e, "ADDER_OPT_DISABLE=")
        if klen != 0:
            tok: uint32 = klen
            more: uint32 = 1
            while more != 0:
                if ssa_opt_tok_eq(e, tok, "sccp") != 0:
                    ssa_opt_disabled_mask = ssa_opt_disabled_mask | SSAOPT_SCCP
                if ssa_opt_tok_eq(e, tok, "instcombine") != 0:
                    ssa_opt_disabled_mask = ssa_opt_disabled_mask | SSAOPT_INSTCOMBINE
                if ssa_opt_tok_eq(e, tok, "gvn") != 0:
                    ssa_opt_disabled_mask = ssa_opt_disabled_mask | SSAOPT_GVN
                if ssa_opt_tok_eq(e, tok, "licm2") != 0:
                    ssa_opt_disabled_mask = ssa_opt_disabled_mask | SSAOPT_LICM
                if ssa_opt_tok_eq(e, tok, "dce2") != 0:
                    ssa_opt_disabled_mask = ssa_opt_disabled_mask | SSAOPT_DCE
                p: uint32 = tok
                while e[p] != 0 and e[p] != cast[uint8](44):
                    p = p + 1
                if e[p] == 0:
                    more = 0
                else:
                    tok = p + 1
        ei = ei + 1


# =======================================================================
# intrusive-list surgery: unlink value `v` from its block.  Positions (sv_pos)
# stay a MONOTONIC subsequence of the original order, so intra-block dominance
# (def-pos < use-pos) remains valid without renumbering.
# =======================================================================
def ssa_unlink_value(v: uint32):
    bb: uint32 = sv_block[v]
    if bb == 0:
        return
    pv: uint32 = sv_prev[v]
    nx: uint32 = sv_next[v]
    if pv != 0:
        sv_next[pv] = nx
    else:
        sb_first_val[bb] = nx
    if nx != 0:
        sv_prev[nx] = pv
    else:
        sb_last_val[bb] = pv
    if sb_nval[bb] > 0:
        sb_nval[bb] = sb_nval[bb] - 1
    sv_block[v] = 0
    sv_next[v] = 0
    sv_prev[v] = 0


# Insert value `v` immediately BEFORE the terminator of block `bb` (used by LICM
# to move an invariant into the pre-header).  `v` must currently be unlinked.
def ssa_insert_before_term(bb: uint32, v: uint32):
    if bb == 0 or v == 0:
        return
    term: uint32 = sb_last_val[bb]
    sv_block[v] = bb
    sb_nval[bb] = sb_nval[bb] + 1
    if term == 0:
        # empty block: v becomes the sole value.
        sb_first_val[bb] = v
        sb_last_val[bb] = v
        sv_prev[v] = 0
        sv_next[v] = 0
        ssa_renumber(bb)
        return
    pv: uint32 = sv_prev[term]
    sv_prev[v] = pv
    sv_next[v] = term
    sv_prev[term] = v
    if pv != 0:
        sv_next[pv] = v
    else:
        sb_first_val[bb] = v
    ssa_renumber(bb)


# Re-stamp sv_pos across a block so positions stay dense + ordered.
def ssa_renumber(bb: uint32):
    p: uint32 = 0
    cur: uint32 = sb_first_val[bb]
    while cur != 0:
        sv_pos[cur] = p
        p = p + 1
        cur = sv_next[cur]


# =======================================================================
# operand iteration helpers (shared by DCE / GVN / LICM).  A value's VALUE
# operands are its data dependencies; block-id fields (BR/CONDBR targets) are
# NOT operands.
# =======================================================================
# Number of fixed (non-list) value operands carried in sv_a/sv_b.
def ssa_op_has_a(op: uint32) -> uint32:
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_FCMP or op == SVO_GEP or op == SVO_STORE:
        return 1
    if op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT or op == SVO_LOAD:
        return 1
    if op == SVO_TRUNC or op == SVO_ZEXT or op == SVO_SEXT or op == SVO_BITCAST or op == SVO_I2F or op == SVO_F2I:
        return 1
    if op == SVO_CONDBR:
        return 1
    if op == SVO_RET:
        return 1
    return 0


def ssa_op_has_b(op: uint32) -> uint32:
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_FCMP or op == SVO_GEP or op == SVO_STORE:
        return 1
    return 0


# =======================================================================
# 4.4  DCE — mark-sweep over SSA.
# =======================================================================
def ssa_dce_side_effect(op: uint32) -> uint32:
    # stores / calls / syscalls / terminators are live regardless of use.
    if op == SVO_STORE or op == SVO_CALL or op == SVO_SYSCALL:
        return 1
    if op == SVO_BR or op == SVO_CONDBR or op == SVO_RET:
        return 1
    # a %gs/percpu access is a volatile read — never dead (conservative).
    if op == SVO_PERCPU:
        return 1
    return 0


def dce_visit(w: uint32):
    if w == 0:
        return
    if w >= sv_count:
        return
    if sv_mark[w] != 0:
        return
    if opt_sp >= OPT_STACK_MAX:
        return
    sv_mark[w] = 1
    opt_stack[opt_sp] = w
    opt_sp = opt_sp + 1


# Push v's value operands onto the worklist.
def dce_push_operands(v: uint32):
    op: uint32 = sv_op[v]
    if ssa_op_has_a(op) != 0:
        dce_visit(sv_a[v])
    if ssa_op_has_b(op) != 0:
        dce_visit(sv_b[v])
    if op == SVO_PHI or op == SVO_CALL or op == SVO_SYSCALL:
        node: uint32 = sv_arg_head[v]
        while node != 0:
            dce_visit(arg_val[node])
            node = arg_next[node]


def ssa_dce():
    if ssa_opt_pass_disabled(SSAOPT_DCE) != 0:
        return
    # clear marks
    i: uint32 = 1
    while i < sv_count:
        sv_mark[i] = 0
        i = i + 1
    # seed: every LINKED side-effecting value.
    opt_sp = 0
    i = 1
    while i < sv_count:
        if sv_block[i] != 0:
            if ssa_dce_side_effect(sv_op[i]) != 0:
                dce_visit(i)
        i = i + 1
    # propagate liveness through operands.
    while opt_sp > 0:
        opt_sp = opt_sp - 1
        v: uint32 = opt_stack[opt_sp]
        dce_push_operands(v)
    # sweep: unlink every unmarked non-terminator value.
    b: uint32 = 1
    while b < sb_count:
        cur: uint32 = sb_first_val[b]
        while cur != 0:
            nxt: uint32 = sv_next[cur]
            if sv_mark[cur] == 0 and ssa_is_terminator(sv_op[cur]) == 0:
                ssa_unlink_value(cur)
                ssa_opt_dce_removed = ssa_opt_dce_removed + 1
            cur = nxt
        b = b + 1


# =======================================================================
# RAUW — replace-all-uses-with (the SSA workhorse for InstCombine / GVN).
# Rewrites every VALUE-operand reference from `old` to `new` across all values.
# Safe because SSA values are immutable; the caller guarantees `new` dominates
# every use of `old` (an operand of `old`'s def, or an earlier congruent value).
# =======================================================================
def ssa_replace_all_uses(old: uint32, new: uint32):
    if old == 0 or new == 0 or old == new:
        return
    w: uint32 = 1
    while w < sv_count:
        op: uint32 = sv_op[w]
        if ssa_op_has_a(op) != 0:
            if sv_a[w] == old:
                sv_a[w] = new
        if ssa_op_has_b(op) != 0:
            if sv_b[w] == old:
                sv_b[w] = new
        if op == SVO_PHI or op == SVO_CALL or op == SVO_SYSCALL:
            node: uint32 = sv_arg_head[w]
            while node != 0:
                if arg_val[node] == old:
                    arg_val[node] = new
                node = arg_next[node]
        w = w + 1


# Is value `v` a constant equal to `k`?
def ssa_is_const(v: uint32, k: uint64) -> uint32:
    if v == 0 or v >= sv_count:
        return 0
    if sv_op[v] != SVO_CONST:
        return 0
    if sv_imm[v] == k:
        return 1
    return 0


# Mutate value `v` in place into a constant `k` (keeps its vid + list position, so
# every existing use now reads the constant — no RAUW needed).
def ssa_make_const(v: uint32, k: uint64):
    sv_op[v] = SVO_CONST
    sv_imm[v] = k
    sv_a[v] = 0
    sv_b[v] = 0
    sv_c[v] = 0
    sv_aux[v] = 0


# Replace uses of `v` with `repl` and unlink `v` (it is now dead).
def ssa_fold_to(v: uint32, repl: uint32):
    ssa_replace_all_uses(v, repl)
    ssa_unlink_value(v)
    ssa_opt_instcombine_count = ssa_opt_instcombine_count + 1


# =======================================================================
# 4.5  InstCombine / peephole — algebraic identities (light).
#   x+0, 0+x, x-0, x*1, 1*x -> x        x*0, 0*x -> 0
#   x-x -> 0     x^x -> 0     x&x -> x   x|x -> x
#   x&0 -> 0     x|0 -> x     x<<0, x>>0 -> x
#   x/1 -> x     x%1 -> 0     -(-x) -> x   ~(~x) -> x
# Constant-only folds mutate v in place; fold-to-operand uses RAUW + unlink.
# =======================================================================
def ssa_instcombine_binop(v: uint32):
    aux: uint32 = sv_aux[v]
    a: uint32 = sv_a[v]
    b: uint32 = sv_b[v]
    if aux == BINOP_ADD:
        if ssa_is_const(a, cast[uint64](0)) != 0:
            ssa_fold_to(v, b)
        elif ssa_is_const(b, cast[uint64](0)) != 0:
            ssa_fold_to(v, a)
        return
    if aux == BINOP_SUB:
        if a == b:
            ssa_make_const(v, cast[uint64](0))
            ssa_opt_instcombine_count = ssa_opt_instcombine_count + 1
        elif ssa_is_const(b, cast[uint64](0)) != 0:
            ssa_fold_to(v, a)
        return
    if aux == BINOP_MUL:
        if ssa_is_const(a, cast[uint64](0)) != 0 or ssa_is_const(b, cast[uint64](0)) != 0:
            ssa_make_const(v, cast[uint64](0))
            ssa_opt_instcombine_count = ssa_opt_instcombine_count + 1
        elif ssa_is_const(a, cast[uint64](1)) != 0:
            ssa_fold_to(v, b)
        elif ssa_is_const(b, cast[uint64](1)) != 0:
            ssa_fold_to(v, a)
        return
    if aux == BINOP_BIT_AND:
        if a == b:
            ssa_fold_to(v, a)
        elif ssa_is_const(a, cast[uint64](0)) != 0 or ssa_is_const(b, cast[uint64](0)) != 0:
            ssa_make_const(v, cast[uint64](0))
            ssa_opt_instcombine_count = ssa_opt_instcombine_count + 1
        return
    if aux == BINOP_BIT_OR:
        if a == b:
            ssa_fold_to(v, a)
        elif ssa_is_const(a, cast[uint64](0)) != 0:
            ssa_fold_to(v, b)
        elif ssa_is_const(b, cast[uint64](0)) != 0:
            ssa_fold_to(v, a)
        return
    if aux == BINOP_BIT_XOR:
        if a == b:
            ssa_make_const(v, cast[uint64](0))
            ssa_opt_instcombine_count = ssa_opt_instcombine_count + 1
        elif ssa_is_const(a, cast[uint64](0)) != 0:
            ssa_fold_to(v, b)
        elif ssa_is_const(b, cast[uint64](0)) != 0:
            ssa_fold_to(v, a)
        return
    if aux == BINOP_SHL or aux == BINOP_SHR:
        if ssa_is_const(b, cast[uint64](0)) != 0:
            ssa_fold_to(v, a)
        return
    if aux == BINOP_DIV or aux == BINOP_IDIV:
        if ssa_is_const(b, cast[uint64](1)) != 0:
            ssa_fold_to(v, a)
        return
    if aux == BINOP_MOD:
        if ssa_is_const(b, cast[uint64](1)) != 0:
            ssa_make_const(v, cast[uint64](0))
            ssa_opt_instcombine_count = ssa_opt_instcombine_count + 1
        return


def ssa_instcombine():
    if ssa_opt_pass_disabled(SSAOPT_INSTCOMBINE) != 0:
        return
    v: uint32 = 1
    while v < sv_count:
        if sv_block[v] != 0:
            op: uint32 = sv_op[v]
            if op == SVO_BINOP:
                ssa_instcombine_binop(v)
            elif op == SVO_NEG:
                # -(-x) -> x
                a: uint32 = sv_a[v]
                if a != 0 and a < sv_count and sv_op[a] == SVO_NEG:
                    ssa_fold_to(v, sv_a[a])
            elif op == SVO_BITNOT:
                # ~(~x) -> x
                a2: uint32 = sv_a[v]
                if a2 != 0 and a2 < sv_count and sv_op[a2] == SVO_BITNOT:
                    ssa_fold_to(v, sv_a[a2])
        v = v + 1


# =======================================================================
# 4.2  GVN / CSE — dominator-based value numbering.
# A pure instruction is redundant if an EARLIER congruent instruction whose def
# DOMINATES it exists; replace the later with the earlier.  Sound by construction
# on SSA (values are immutable — no name-clobber scan).  O(n^2) over values,
# which is fine for the small functions the subset accepts.  Memory loads are
# NOT numbered (conservative, §4.2); mem2reg already removed promotable ones.
# =======================================================================
def ssa_gvn_pure(op: uint32) -> uint32:
    if op == SVO_CONST or op == SVO_FCONST:
        return 1
    if op == SVO_BINOP or op == SVO_ICMP or op == SVO_FCMP:
        return 1
    if op == SVO_NEG or op == SVO_NOT or op == SVO_BITNOT:
        return 1
    if op == SVO_TRUNC or op == SVO_ZEXT or op == SVO_SEXT or op == SVO_BITCAST:
        return 1
    if op == SVO_GLOBALADDR:
        return 1
    return 0


# Does u's definition dominate v's definition-point (i.e. is u available at v)?
def ssa_value_dominates(u: uint32, v: uint32) -> uint32:
    bu: uint32 = sv_block[u]
    bv: uint32 = sv_block[v]
    if bu == bv:
        if sv_pos[u] < sv_pos[v]:
            return 1
        return 0
    return ssa_dominates(bu, bv)


# Are u and v the same pure computation?  Keyed on (op, aux, operands, hint/imm).
# sv_c carries the emit-affecting hint (setcc byte / div-mod-shr signedness /
# trunc signedness), so it is part of the key; sv_type does not affect emit.
def ssa_congruent(u: uint32, v: uint32) -> uint32:
    op: uint32 = sv_op[u]
    if op != sv_op[v]:
        return 0
    if ssa_gvn_pure(op) == 0:
        return 0
    if sv_aux[u] != sv_aux[v]:
        return 0
    if op == SVO_CONST or op == SVO_FCONST:
        if sv_imm[u] == sv_imm[v]:
            return 1
        return 0
    if op == SVO_GLOBALADDR:
        if sv_imm[u] == sv_imm[v] and sv_c[u] == sv_c[v]:
            return 1
        return 0
    if ssa_op_has_a(op) != 0:
        if sv_a[u] != sv_a[v]:
            return 0
    if ssa_op_has_b(op) != 0:
        if sv_b[u] != sv_b[v]:
            return 0
    if sv_c[u] != sv_c[v]:
        return 0
    return 1


def ssa_gvn():
    if ssa_opt_pass_disabled(SSAOPT_GVN) != 0:
        return
    v: uint32 = 1
    while v < sv_count:
        if sv_block[v] != 0 and ssa_gvn_pure(sv_op[v]) != 0:
            found: uint32 = 0
            u: uint32 = 1
            while u < sv_count:
                if u != v and sv_block[u] != 0:
                    if ssa_congruent(u, v) != 0 and ssa_value_dominates(u, v) != 0:
                        found = u
                        u = sv_count
                    else:
                        u = u + 1
                else:
                    u = u + 1
            if found != 0:
                ssa_replace_all_uses(v, found)
                ssa_unlink_value(v)
                ssa_opt_gvn_replaced = ssa_opt_gvn_replaced + 1
        v = v + 1


# =======================================================================
# 4.3  LICM — loop-invariant code motion.
# For each natural loop (back-edge b->h where h dominates b), an instruction is
# loop-invariant iff it is pure, trap-free, and ALL its value operands are defined
# OUTSIDE the loop (or were already hoisted).  Hoist it into the loop's
# pre-header.  The OLD loop-condition-CSE hoist bug CANNOT recur: a body-mutated
# value is a DIFFERENT SSA value (or a phi) with a def INSIDE the loop, so it
# fails the operands-outside test trivially — invariance is a one-line predicate.
# =======================================================================
licm_in_loop: Array[1024, uint32]     # per-bid membership of the loop being processed


# h is a loop header iff some predecessor b is dominated by h (a back-edge b->h).
def ssa_is_loop_header(h: uint32) -> uint32:
    node: uint32 = sb_pred_head[h]
    while node != 0:
        b: uint32 = pl_bid[node]
        if ssa_dominates(h, b) != 0:
            return 1
        node = pl_next[node]
    return 0


# Compute the natural loop of header h into licm_in_loop (backward reachability
# from every latch, stopping at h).
def ssa_licm_natural_loop(h: uint32):
    b: uint32 = 0
    while b < sb_count:
        licm_in_loop[b] = 0
        b = b + 1
    licm_in_loop[h] = 1
    opt_sp = 0
    node: uint32 = sb_pred_head[h]
    while node != 0:
        lb: uint32 = pl_bid[node]
        if ssa_dominates(h, lb) != 0:
            if licm_in_loop[lb] == 0:
                licm_in_loop[lb] = 1
                if opt_sp < OPT_STACK_MAX:
                    opt_stack[opt_sp] = lb
                    opt_sp = opt_sp + 1
        node = pl_next[node]
    while opt_sp > 0:
        opt_sp = opt_sp - 1
        n: uint32 = opt_stack[opt_sp]
        pn: uint32 = sb_pred_head[n]
        while pn != 0:
            p: uint32 = pl_bid[pn]
            if licm_in_loop[p] == 0:
                licm_in_loop[p] = 1
                if opt_sp < OPT_STACK_MAX:
                    opt_stack[opt_sp] = p
                    opt_sp = opt_sp + 1
            pn = pl_next[pn]


# The unique out-of-loop predecessor of h, iff it ends in an unconditional branch
# (so a hoisted value ALWAYS executes exactly once before the loop).  Else 0.
def ssa_licm_preheader(h: uint32) -> uint32:
    ph: uint32 = 0
    cnt: uint32 = 0
    node: uint32 = sb_pred_head[h]
    while node != 0:
        p: uint32 = pl_bid[node]
        if licm_in_loop[p] == 0:
            ph = p
            cnt = cnt + 1
        node = pl_next[node]
    if cnt != 1:
        return 0
    if sb_term[ph] != SVO_BR:
        return 0
    return ph


# A value operand is "outside the loop" if it is null or its def-block is not in
# the loop (a def inside the loop is loop-variant).
def ssa_val_outside_loop(w: uint32) -> uint32:
    if w == 0:
        return 1
    bb: uint32 = sv_block[w]
    if bb == 0:
        return 1
    if licm_in_loop[bb] == 0:
        return 1
    return 0


def ssa_operands_invariant(v: uint32) -> uint32:
    op: uint32 = sv_op[v]
    if ssa_op_has_a(op) != 0:
        if ssa_val_outside_loop(sv_a[v]) == 0:
            return 0
    if ssa_op_has_b(op) != 0:
        if ssa_val_outside_loop(sv_b[v]) == 0:
            return 0
    return 1


# Pure + trap-free.  CONSTs ARE hoisted: a constant materialized inside the loop
# body would otherwise be a loop-defined operand that blocks hoisting its (truly
# invariant) consumer AND would break dominance if the consumer moved above it.
# Hoisting the const to the pre-header keeps SSA well-formed and unlocks the
# consumer.  div/mod/idiv are excluded (may trap — hoisting past a guard could
# fault when the loop never runs).
def ssa_licm_hoistable(v: uint32) -> uint32:
    op: uint32 = sv_op[v]
    if ssa_gvn_pure(op) == 0:
        return 0
    if op == SVO_BINOP:
        aux: uint32 = sv_aux[v]
        if aux == BINOP_DIV or aux == BINOP_IDIV or aux == BINOP_MOD:
            return 0
    return 1


def ssa_licm_process_header(h: uint32) -> uint32:
    ssa_licm_natural_loop(h)
    ph: uint32 = ssa_licm_preheader(h)
    if ph == 0:
        return 0
    hoisted: uint32 = 0
    changed: uint32 = 1
    while changed != 0:
        changed = 0
        v: uint32 = 1
        while v < sv_count:
            bb: uint32 = sv_block[v]
            if bb != 0 and licm_in_loop[bb] != 0:
                if ssa_licm_hoistable(v) != 0 and ssa_operands_invariant(v) != 0:
                    ssa_unlink_value(v)
                    ssa_insert_before_term(ph, v)
                    hoisted = hoisted + 1
                    changed = 1
            v = v + 1
    return hoisted


def ssa_licm():
    if ssa_opt_pass_disabled(SSAOPT_LICM) != 0:
        return
    outer: uint32 = 1
    guard: uint32 = 0
    while outer != 0 and guard < 8:
        outer = 0
        guard = guard + 1
        h: uint32 = 1
        while h < sb_count:
            if sb_visited[h] != 0:
                if ssa_is_loop_header(h) != 0:
                    n: uint32 = ssa_licm_process_header(h)
                    if n != 0:
                        outer = 1
                        ssa_opt_licm_hoisted = ssa_opt_licm_hoisted + n
            h = h + 1


# =======================================================================
# 4.1  SCCP — Sparse Conditional Constant Propagation (Wegman-Zadeck).
# Joint value-lattice (TOP -> CONST -> BOTTOM) + CFG edge reachability.  Folds
# constant instructions and marks branch edges dead when the condition is a known
# constant — subsuming the old constfold + constbranch + much of copyprop, done
# right (propagates through phis and around loops).  Constant evaluation reuses
# ir.ad's ir_eval_binop so folded values match the legacy runtime semantics
# EXACTLY; only ops with unambiguous 64-bit semantics are folded (ADD/SUB/MUL/
# AND/OR/XOR/SHL, EQ/NEQ, NEG/BITNOT/NOT); div/mod/shr/ordered-compare/trunc stay
# overdefined (conservative — never a wrong fold).
# =======================================================================
def sccp_binop_foldable(op: uint32) -> uint32:
    if op == BINOP_ADD or op == BINOP_SUB or op == BINOP_MUL:
        return 1
    if op == BINOP_BIT_AND or op == BINOP_BIT_OR or op == BINOP_BIT_XOR:
        return 1
    if op == BINOP_SHL:
        return 1
    return 0


def sccp_add_use(operand: uint32, user: uint32):
    if operand == 0 or operand >= sv_count:
        return
    if u_count >= U_MAX:
        return
    node: uint32 = u_count
    u_count = u_count + 1
    u_valn[node] = user
    u_next[node] = u_head[operand]
    u_head[operand] = node


def sccp_build_uses():
    i: uint32 = 0
    while i < sv_count:
        u_head[i] = 0
        i = i + 1
    u_count = 1
    w: uint32 = 1
    while w < sv_count:
        if sv_block[w] != 0:
            op: uint32 = sv_op[w]
            if ssa_op_has_a(op) != 0:
                sccp_add_use(sv_a[w], w)
            if ssa_op_has_b(op) != 0:
                sccp_add_use(sv_b[w], w)
            if op == SVO_PHI or op == SVO_CALL or op == SVO_SYSCALL:
                node: uint32 = sv_arg_head[w]
                while node != 0:
                    sccp_add_use(arg_val[node], w)
                    node = arg_next[node]
        w = w + 1


def sccp_edge_exec(pred: uint32, succ: uint32) -> uint32:
    if sb_succ0[pred] == succ and sccp_e0[pred] != 0:
        return 1
    if sb_succ1[pred] == succ and sccp_e1[pred] != 0:
        return 1
    return 0


def sccp_bwl_push(b: uint32):
    if sccp_bq[b] != 0:
        return
    if sccp_bsp >= SSA_BB_MAX_LOCAL:
        return
    sccp_bq[b] = 1
    sccp_bwl[sccp_bsp] = b
    sccp_bsp = sccp_bsp + 1


def sccp_vwl_push(v: uint32):
    if v == 0 or v >= sv_count:
        return
    if sccp_vq[v] != 0:
        return
    if sccp_vsp >= OPT_STACK_MAX:
        return
    sccp_vq[v] = 1
    sccp_vwl[sccp_vsp] = v
    sccp_vsp = sccp_vsp + 1


def sccp_meet_acc(lat2: uint32, cv2: uint64):
    if lat2 == LAT_TOP:
        return
    if acc_lat == LAT_TOP:
        acc_lat = lat2
        acc_cv = cv2
        return
    if acc_lat == LAT_BOT:
        return
    if lat2 == LAT_BOT:
        acc_lat = LAT_BOT
        return
    # both CONST
    if acc_cv != cv2:
        acc_lat = LAT_BOT


# Compute the lattice of value v into res_lat/res_cv from current operand states.
def sccp_compute(v: uint32):
    op: uint32 = sv_op[v]
    if op == SVO_CONST:
        res_lat = LAT_CONST
        res_cv = sv_imm[v]
        return
    if op == SVO_PHI:
        acc_lat = LAT_TOP
        acc_cv = cast[uint64](0)
        bb: uint32 = sv_block[v]
        node: uint32 = sv_arg_head[v]
        while node != 0:
            pred: uint32 = arg_pred[node]
            if sccp_edge_exec(pred, bb) != 0:
                ov: uint32 = arg_val[node]
                sccp_meet_acc(sccp_lat[ov], sccp_cv[ov])
            node = arg_next[node]
        res_lat = acc_lat
        res_cv = acc_cv
        return
    if op == SVO_BINOP:
        a: uint32 = sv_a[v]
        b: uint32 = sv_b[v]
        la: uint32 = sccp_lat[a]
        lb: uint32 = sccp_lat[b]
        if la == LAT_BOT or lb == LAT_BOT:
            res_lat = LAT_BOT
            return
        if la == LAT_TOP or lb == LAT_TOP:
            res_lat = LAT_TOP
            return
        if sccp_binop_foldable(sv_aux[v]) != 0:
            res_lat = LAT_CONST
            res_cv = ir_eval_binop(sv_aux[v], sccp_cv[a], sccp_cv[b])
            return
        res_lat = LAT_BOT
        return
    if op == SVO_ICMP:
        aux: uint32 = sv_aux[v]
        if aux == BINOP_EQ or aux == BINOP_NEQ:
            a2: uint32 = sv_a[v]
            b2: uint32 = sv_b[v]
            la2: uint32 = sccp_lat[a2]
            lb2: uint32 = sccp_lat[b2]
            if la2 == LAT_BOT or lb2 == LAT_BOT:
                res_lat = LAT_BOT
                return
            if la2 == LAT_TOP or lb2 == LAT_TOP:
                res_lat = LAT_TOP
                return
            eqv: uint32 = 0
            if sccp_cv[a2] == sccp_cv[b2]:
                eqv = 1
            r: uint32 = 0
            if aux == BINOP_EQ:
                r = eqv
            else:
                if eqv == 0:
                    r = 1
            res_lat = LAT_CONST
            res_cv = cast[uint64](r)
            return
        res_lat = LAT_BOT
        return
    if op == SVO_NEG:
        a3: uint32 = sv_a[v]
        if sccp_lat[a3] == LAT_CONST:
            res_lat = LAT_CONST
            res_cv = cast[uint64](0) - sccp_cv[a3]
            return
        res_lat = sccp_lat[a3]
        return
    if op == SVO_BITNOT:
        a4: uint32 = sv_a[v]
        if sccp_lat[a4] == LAT_CONST:
            res_lat = LAT_CONST
            res_cv = ~sccp_cv[a4]
            return
        res_lat = sccp_lat[a4]
        return
    if op == SVO_NOT:
        a5: uint32 = sv_a[v]
        if sccp_lat[a5] == LAT_CONST:
            res_lat = LAT_CONST
            if sccp_cv[a5] == cast[uint64](0):
                res_cv = cast[uint64](1)
            else:
                res_cv = cast[uint64](0)
            return
        res_lat = sccp_lat[a5]
        return
    # PARAM / CALL / LOAD / UNDEF / GLOBALADDR / PERCPU / TRUNC / casts -> overdefined.
    res_lat = LAT_BOT


def sccp_eval_value(v: uint32):
    sccp_compute(v)
    changed: uint32 = 0
    if res_lat != sccp_lat[v]:
        changed = 1
    elif res_lat == LAT_CONST and res_cv != sccp_cv[v]:
        changed = 1
    if changed != 0:
        sccp_lat[v] = res_lat
        sccp_cv[v] = res_cv
        sccp_push_users(v)


def sccp_push_users(v: uint32):
    node: uint32 = u_head[v]
    while node != 0:
        u: uint32 = u_valn[node]
        op: uint32 = sv_op[u]
        if op == SVO_CONDBR or op == SVO_BR:
            sccp_bwl_push(sv_block[u])
        else:
            sccp_vwl_push(u)
        node = u_next[node]


def sccp_mark_edge(pred: uint32, succ: uint32):
    newedge: uint32 = 0
    if sb_succ0[pred] == succ:
        if sccp_e0[pred] == 0:
            sccp_e0[pred] = 1
            newedge = 1
    elif sb_succ1[pred] == succ:
        if sccp_e1[pred] == 0:
            sccp_e1[pred] = 1
            newedge = 1
    if newedge != 0:
        # a new incoming edge changes succ's phi meet -> re-eval its phis.
        p: uint32 = sb_first_val[succ]
        while p != 0 and sv_op[p] == SVO_PHI:
            sccp_vwl_push(p)
            p = sv_next[p]
        if sccp_bexec[succ] == 0:
            sccp_bexec[succ] = 1
            sccp_bwl_push(succ)


def sccp_process_terminator(b: uint32):
    term: uint32 = sb_last_val[b]
    if term == 0:
        return
    op: uint32 = sv_op[term]
    if op == SVO_BR:
        sccp_mark_edge(b, sv_a[term])
        return
    if op == SVO_CONDBR:
        cond: uint32 = sv_a[term]
        if sccp_lat[cond] == LAT_CONST:
            if sccp_cv[cond] != cast[uint64](0):
                sccp_mark_edge(b, sv_b[term])
            else:
                sccp_mark_edge(b, sv_c[term])
        elif sccp_lat[cond] == LAT_BOT:
            sccp_mark_edge(b, sv_b[term])
            sccp_mark_edge(b, sv_c[term])


def sccp_visit_block(b: uint32):
    v: uint32 = sb_first_val[b]
    while v != 0:
        if ssa_is_terminator(sv_op[v]) == 0:
            sccp_eval_value(v)
        v = sv_next[v]
    sccp_process_terminator(b)


# Drop the single phi operand flowing from predecessor `pred`.
def sccp_phi_drop_pred(phi: uint32, pred: uint32):
    prev: uint32 = 0
    node: uint32 = sv_arg_head[phi]
    while node != 0:
        if arg_pred[node] == pred:
            if prev == 0:
                sv_arg_head[phi] = arg_next[node]
            else:
                arg_next[prev] = arg_next[node]
            if sv_argn[phi] > 0:
                sv_argn[phi] = sv_argn[phi] - 1
            return
        prev = node
        node = arg_next[node]


# Remove ONE predecessor edge pred->succ (pred list entry + matching phi operands).
def sccp_remove_one_pred(succ: uint32, pred: uint32):
    prev: uint32 = 0
    node: uint32 = sb_pred_head[succ]
    done: uint32 = 0
    while node != 0 and done == 0:
        if pl_bid[node] == pred:
            if prev == 0:
                sb_pred_head[succ] = pl_next[node]
            else:
                pl_next[prev] = pl_next[node]
            if sb_npred[succ] > 0:
                sb_npred[succ] = sb_npred[succ] - 1
            done = 1
        else:
            prev = node
            node = pl_next[node]
    # Drop the matching operand from every phi in `succ`.  Do NOT stop at the
    # first non-PHI: SCCP's constant-fold step may have rewritten an earlier head
    # phi into an SVO_CONST in place (sv_op changed, position unchanged), which
    # would otherwise hide the real phis behind it and leave their pred operand
    # dangling (phi.argn > block.npred -> ssa_verify PHI_PRED_MISMATCH -> the whole
    # function needlessly falls back to legacy).  Non-phi values carry no
    # pred-keyed operands (arg_pred is 0 for call args), so scanning them is inert.
    p: uint32 = sb_first_val[succ]
    while p != 0:
        if sv_op[p] == SVO_PHI:
            sccp_phi_drop_pred(p, pred)
        p = sv_next[p]


# Turn a constant-condition CONDBR at block b into an unconditional BR to `taken`,
# dropping the b->untaken edge (untaken becomes unreachable-from-here; RPO drops
# it if no other path reaches it).
def sccp_prune_branch(b: uint32, term: uint32, taken: uint32, untaken: uint32):
    sv_op[term] = SVO_BR
    sv_a[term] = taken
    sv_b[term] = 0
    sv_c[term] = 0
    sb_term[b] = SVO_BR
    sb_succ0[b] = taken
    sb_succ1[b] = 0
    sb_nsucc[b] = 1
    sccp_remove_one_pred(untaken, b)


# Drop predecessor edges into reachable blocks that the fixpoint proved
# NON-executable (the pred is unreachable, or the specific pred->b edge was never
# marked executable because a constant condition made b its untaken side).  A phi
# in b merges values ONLY over executable in-edges, so its operand for such a pred
# must be removed together with the pred-list entry — otherwise the phi keeps a
# dangling operand from a block RPO will drop, and ssa_verify rejects the function
# (which is why the whole function used to fall back to legacy on a folded branch).
# Runs BEFORE branch pruning so sccp_edge_exec still reads the fixpoint succ arrays.
def sccp_drop_dead_preds():
    b: uint32 = 1
    while b < sb_count:
        if sccp_bexec[b] != 0 and b != sb_entry:
            changed: uint32 = 1
            while changed != 0:
                changed = 0
                node: uint32 = sb_pred_head[b]
                while node != 0:
                    pred: uint32 = pl_bid[node]
                    if sccp_bexec[pred] == 0 or sccp_edge_exec(pred, b) == 0:
                        sccp_remove_one_pred(b, pred)
                        changed = 1
                        node = 0
                    else:
                        node = pl_next[node]
        b = b + 1


def sccp_rewrite():
    # 1. CFG cleanup FIRST, while every phi is still an SVO_PHI: drop phi operands
    # / pred entries from non-executable in-edges.  Doing this before the constant
    # fold below keeps head phis recognizable to sccp_remove_one_pred (a phi folded
    # to SVO_CONST in place would otherwise mask real phis behind it).  Must run
    # before pruning mutates the succ arrays sccp_edge_exec reads.
    sccp_drop_dead_preds()
    # 2. fold every reachable value proven CONST into an SVO_CONST in place.
    v: uint32 = 1
    while v < sv_count:
        if sv_block[v] != 0:
            if sccp_lat[v] == LAT_CONST and sv_op[v] != SVO_CONST:
                ssa_make_const(v, sccp_cv[v])
                ssa_opt_sccp_folded = ssa_opt_sccp_folded + 1
        v = v + 1
    # 3. prune constant branch edges.
    b: uint32 = 1
    while b < sb_count:
        if sccp_bexec[b] != 0:
            term: uint32 = sb_last_val[b]
            if term != 0 and sv_op[term] == SVO_CONDBR:
                cond: uint32 = sv_a[term]
                if sccp_lat[cond] == LAT_CONST:
                    taken: uint32 = sv_c[term]
                    untaken: uint32 = sv_b[term]
                    if sccp_cv[cond] != cast[uint64](0):
                        taken = sv_b[term]
                        untaken = sv_c[term]
                    if taken != untaken:
                        sccp_prune_branch(b, term, taken, untaken)
                        ssa_opt_sccp_edges_pruned = ssa_opt_sccp_edges_pruned + 1
        b = b + 1


def ssa_sccp():
    if ssa_opt_pass_disabled(SSAOPT_SCCP) != 0:
        return
    # init lattice + edge/reachability state.
    i: uint32 = 1
    while i < sv_count:
        sccp_lat[i] = LAT_TOP
        sccp_cv[i] = cast[uint64](0)
        sccp_vq[i] = 0
        i = i + 1
    b: uint32 = 0
    while b < sb_count:
        sccp_bexec[b] = 0
        sccp_e0[b] = 0
        sccp_e1[b] = 0
        sccp_bq[b] = 0
        b = b + 1
    sccp_build_uses()
    sccp_bsp = 0
    sccp_vsp = 0
    sccp_bexec[sb_entry] = 1
    sccp_bwl_push(sb_entry)
    # propagate to fixpoint (guarded — monotonic lattice guarantees termination).
    guard: uint32 = 0
    while (sccp_bsp > 0 or sccp_vsp > 0) and guard < 4000000:
        guard = guard + 1
        if sccp_bsp > 0:
            sccp_bsp = sccp_bsp - 1
            bb: uint32 = sccp_bwl[sccp_bsp]
            sccp_bq[bb] = 0
            sccp_visit_block(bb)
        elif sccp_vsp > 0:
            sccp_vsp = sccp_vsp - 1
            vv: uint32 = sccp_vwl[sccp_vsp]
            sccp_vq[vv] = 0
            sccp_eval_value(vv)
    sccp_rewrite()


# =======================================================================
# pass manager (§4).  Runs after ssa_build_function, before the trivial lowering.
# =======================================================================
def ssa_opt_verify_check():
    if ssa_opt_verify_each == 0:
        return
    rc: uint32 = ssa_verify()
    if rc != SSAV_OK:
        ssa_opt_verify_fail = ssa_opt_verify_fail + 1


def ssa_opt_run(entry: uint32):
    if ssa_opt_pipeline_on == 0:
        return
    ssa_opt_runs = ssa_opt_runs + 1
    # SCCP first (§4): folds constants + prunes dead branch edges.  It rewrites
    # the CFG (const CONDBR -> BR), so the dominator tree is (re)built AFTER it.
    ssa_sccp()
    ssa_opt_verify_check()
    # dominator tree + RPO for the dominance-aware passes (ssa_verify above already
    # rebuilt them; this is a no-op refresh when verify_each is off).
    ssa_build_domtree()
    # InstCombine canonicalizes so downstream passes see more congruences.
    ssa_instcombine()
    ssa_opt_verify_check()
    # GVN/CSE removes redundant pure computations (dominance-aware).
    ssa_gvn()
    ssa_opt_verify_check()
    # LICM hoists now-provably-invariant pure instructions to loop pre-headers.
    ssa_licm()
    ssa_opt_verify_check()
    # DCE sweeps the corpses (dead code + anything folded/replaced away).
    ssa_dce()
    ssa_opt_verify_check()

# =======================================================================
# Output buffer.  The driver flushes llvm_out[0 .. llvm_out_len) via sys_write.
# =======================================================================
# 64 MiB: the whole native kernel is emitted as ONE translation unit
# (init/main.ad's closure, ~11k functions), whose textual `.ll` overflows the
# former 4 MiB cap (the ADDER_STAT trailer was truncated on init/main.ad).  The
# emission-broadening work (SVO_FUNCADDR / recursive lvalue-address / array-of-
# struct globals, Ph4b/5a) grew the emitted whole-kernel unit PAST 32 MiB, which
# silently truncated the tail mid-function (a cut-off `phi` -> clang "expected
# value token").  64 MiB holds it with headroom.  Host-only buffer (host_ac.elf),
# so the larger BSS array is inconsequential; LLVM-path only, native unaffected.
LL_OUT_CAP: uint32 = 67108864
llvm_out: Array[67108864, uint8]
llvm_out_len: uint32 = 0

# defined-function name set (accepted functions) + called-function set.
# MUST exceed the number of DEFINED functions in a translation unit: the whole
# `init/main.ad` kernel closure emits ~11k functions as ONE unit.  When this cap
# saturates, `llvm_record_defined` silently drops names, so a defined function
# that is also called reads as "undefined" and gets a spurious `declare` that
# COLLIDES with its `define` (llvm-as "redefinition").  Sized well above the
# kernel function count; host-only arrays, so the memory is inconsequential.
LL_NAME_MAX: uint32 = 20480
dn_off: Array[20480, uint32]
dn_len: Array[20480, uint32]
dn_count: uint32 = 0

ce_off: Array[20480, uint32]
ce_len: Array[20480, uint32]
ce_argc: Array[20480, uint32]
ce_count: uint32 = 0

# function-ADDRESS name set (functions whose symbol address is taken via
# SVO_FUNCADDR — `&function` / function-name-as-value).  Declared (zero-arg) if
# not defined in-unit AND not already a direct callee, so `@name` resolves.
fa_off: Array[20480, uint32]
fa_len: Array[20480, uint32]
fa_count: uint32 = 0

# per-function fresh-temp counter (LLVM %tN, disjoint from %vN value names).
llvm_tmp: uint32 = 0

# Reachable-block bitmap for the current function (block ids reset per function,
# < SSA_BB_MAX = 1024).  Set from sb_rpo before emitting a function's blocks, it
# lets phi emission DROP operands whose predecessor block is unreachable (an
# orphaned block that the SSA builder wired as a pred but that the RPO walk
# never emits — LLVM rejects a phi operand for a non-existent predecessor label).
LL_BB_MAX: uint32 = 1024
llvm_bb_live: Array[1024, uint8]

# current function's LLVM return type id (SVT_*), set per function so SVO_RET and
# the `define` header agree (float functions return double/float, not i64).
llvm_ret_svt: uint32 = 0

# program stats
llvm_stat_funcs: uint32 = 0
llvm_stat_emitted: uint32 = 0
llvm_stat_bailed: uint32 = 0

# LLVM emitter TARGET-ARCH selector (ARM64 retarget, docs/arm64_llvm_scoping.md).
#   0 = x86_64  (DEFAULT — the whole emitter path is byte-identical to the
#                pre-ARM64 compiler when this stays 0; the driver only sets it
#                to 1 for an explicit `--target=aarch64*` on the --backend=llvm
#                lane, so the native ELF path and every prior LLVM emission are
#                unaffected)
#   1 = aarch64 (svc/x8 syscall ABI + aarch64 Linux syscall-number table, and
#                for the KERNEL lane: TPIDR_EL1 percpu base + aarch64 barrier
#                mnemonics in place of the x86 %gs/addrspace(256) + hlt/cli/...)
# Read by: the module triple, the SVO_SYSCALL emitter, the addrspace(256)
# percpu load/store path, and the SVO_INLINEASM barrier remap.
cg_llvm_target: uint32 = 0

# Whether the current module has already emitted the aarch64 percpu-base
# read-register plumbing (`declare @llvm.read_register.i64` + the
# `!llvm.named.register.tpidr_el1` named metadata).  Emitted lazily on the first
# TPIDR_EL1 percpu access so a module with no percpu use stays clean; reset per
# program in llvm_emit_program.
llvm_tpidr_meta_done: uint32 = 0


# =======================================================================
# low-level text emit
# =======================================================================
def ll_putc(c: uint32):
    if llvm_out_len < LL_OUT_CAP:
        llvm_out[llvm_out_len] = cast[uint8](c & 255)
        llvm_out_len = llvm_out_len + 1


def ll_puts(s: Ptr[uint8]):
    i: uint32 = 0
    while s[i] != 0:
        ll_putc(cast[uint32](s[i]))
        i = i + 1


def ll_put_name(off: uint32, len_: uint32):
    i: uint32 = 0
    while i < len_:
        ll_putc(cast[uint32](strbuf[off + i]))
        i = i + 1


# True for the characters that may appear in a GAS `.L` local-label identifier
# body: [A-Za-z0-9_].
def ll_asm_is_ident(c: uint32) -> uint32:
    if c >= 65 and c <= 90:               # A-Z
        return 1
    if c >= 97 and c <= 122:              # a-z
        return 1
    if c >= 48 and c <= 57:               # 0-9
        return 1
    if c == 95:                           # '_'
        return 1
    return 0


# Emit strbuf[off..off+len) as the body of an LLVM inline-asm template string
# (the double-quoted first argument of `asm sideeffect`).  Two escape layers,
# applied together char-by-char:
#   1. inline-asm template: a literal '$' must be doubled ('$$') because '$' is
#      the operand-substitution escape.  We model only ZERO-OPERAND asm, so every
#      '$' in the source is literal (e.g. `movq $10, %rcx`).
#   2. LLVM IR string constant: '"' -> \22, '\' -> \5C, and any byte outside the
#      printable ASCII range (incl. newline/tab/CR) -> \XX (two uppercase hex).
#
# LOCAL-LABEL UNIQUIFICATION (required for clang -O2): a GAS `.L<name>` local
# label emitted verbatim collides when the integrated assembler inlines the same
# asm template at multiple call sites (the rdrand/rdseed retry loops -> "symbol
# already defined").  We append LLVM's `${:uid}` token after every `.L<name>`
# token — it expands to a per-asm-instantiation-unique integer, so a label's
# definition and its references (which share the instantiation) stay matched
# while distinct instantiations get distinct names.  The `${:uid}` bytes are
# emitted RAW (not through the '$'-doubling) because here '$' IS the LLVM
# operand-substitution escape we want.  `.L` is the GAS local-symbol prefix, so
# any `.L<ident>` in a body is a local label; real globals (e.g.
# `hwrng_scratch(%rip)`) are never `.L`-prefixed and are left untouched.
def ll_put_asm_string(off: uint32, len_: uint32):
    hexd: Ptr[uint8] = "0123456789ABCDEF"
    i: uint32 = 0
    while i < len_:
        c: uint32 = cast[uint32](strbuf[off + i])
        # `.L<ident>` GAS local label -> emit verbatim then a unique `${:uid}`.
        if c == 46 and (i + 2) < len_ and cast[uint32](strbuf[off + i + 1]) == 76 and ll_asm_is_ident(cast[uint32](strbuf[off + i + 2])) != 0:
            ll_putc(46)                   # '.'
            ll_putc(76)                   # 'L'
            i = i + 2
            while i < len_ and ll_asm_is_ident(cast[uint32](strbuf[off + i])) != 0:
                ll_putc(cast[uint32](strbuf[off + i]))
                i = i + 1
            ll_puts("${:uid}")            # RAW: LLVM per-instantiation unique id
            continue
        if c == 36:                       # '$' -> '$$' (literal, no operands)
            ll_putc(36)
            ll_putc(36)
        elif c == 34:                     # '"' -> \22
            ll_putc(92)
            ll_putc(cast[uint32](hexd[2]))
            ll_putc(cast[uint32](hexd[2]))
        elif c == 92:                     # '\' -> \5C
            ll_putc(92)
            ll_putc(cast[uint32](hexd[5]))
            ll_putc(cast[uint32](hexd[12]))
        elif c < 32 or c > 126:           # non-printable (newline/tab/...) -> \XX
            ll_putc(92)
            ll_putc(cast[uint32](hexd[(c >> 4) & 15]))
            ll_putc(cast[uint32](hexd[c & 15]))
        else:
            ll_putc(c)
        i = i + 1


# Compare the asm-body bytes strbuf[off..off+len_) against a NUL-terminated
# literal.  Returns 1 on an exact (whole-string) match.
def ll_asm_body_eq(off: uint32, len_: uint32, lit: Ptr[uint8]) -> uint32:
    i: uint32 = 0
    while i < len_:
        if lit[i] == 0:
            return 0                      # literal shorter than the body
        if cast[uint32](strbuf[off + i]) != cast[uint32](lit[i]):
            return 0
        i = i + 1
    if lit[len_] != 0:
        return 0                          # literal longer than the body
    return 1


# Substring test: does the NUL-terminated literal `lit` occur anywhere within
# the asm-body bytes strbuf[off..off+len_)?  Used to classify the multi-line
# x86 asm-passthrough bodies (trampolines/cpuid/rng/mul128/suspend/reset) that
# carry a distinctive mnemonic or symbol.  Returns 1 if found.
def ll_asm_body_has(off: uint32, len_: uint32, lit: Ptr[uint8]) -> uint32:
    ll: uint32 = 0
    while lit[ll] != 0:
        ll = ll + 1
    if ll == 0 or ll > len_:
        return 0
    i: uint32 = 0
    while i + ll <= len_:
        j: uint32 = 0
        while j < ll and cast[uint32](strbuf[off + i + j]) == cast[uint32](lit[j]):
            j = j + 1
        if j == ll:
            return 1
        i = i + 1
    return 0


# AArch64 remap for every x86 inline-asm body the kernel `.ad` closure emits as a
# zero-operand `asm_volatile("...")`.  Emits an aarch64-valid body and returns 1;
# returns 0 for an unrecognised body (the caller then emits the verbatim x86 text,
# which would fail the aarch64 assembler).  Consulted only when cg_llvm_target != 0.
# Covers three classes (docs/arm64_llvm_scoping.md §2a):
#   (1) 5 trivial barrier/wait mnemonics — exact-match, 1:1 aarch64 insn.
#   (2) Linux x86 retpoline thunks `__x86_indirect_thunk_r*` (`popq %rbp; jmpq
#       *%rN`, and the `%rbp` variant) — the aarch64 indirect-branch form `br xN`.
#       These are x86-only .ko shims (dead on aarch64: the caller-side retpoline
#       convention that pre-loads the target in rN does not exist on ARM); the
#       `br xN` keeps the branch-to-register shape and assembles cleanly.
#   (3) the 8 "real ARM" sites — mul128 gets a FAITHFUL `mul`+`umulh`; cpuid /
#       s3_save (ACPI S3) / lidt-int3 (reset) become documented stubs because the
#       mechanism is x86-platform-specific (aarch64 uses MIDR_EL1/ID_AA64* for CPU
#       identification and PSCI SYSTEM_RESET/CPU_SUSPEND — wired in the A3 boot
#       layer); rdrand/rdseed get the ARMv8.5-RNG `mrs RNDR`/`RNDRRS` form (needs
#       FEAT_RNG; A3 adds an ID_AA64ISAR0_EL1.RNDR gate + software fallback).
# The aarch64 clobber list emitted by the caller (`~{x9}..~{x13},~{memory},~{cc}`)
# covers every scratch reg used below.
def ll_emit_aarch64_asm(off: uint32, len_: uint32) -> uint32:
    # ---- class (1): trivial barriers (exact whole-body match) ----
    if ll_asm_body_eq(off, len_, "hlt") != 0:
        ll_puts("wfi")                    # halt -> wait-for-interrupt
        return 1
    if ll_asm_body_eq(off, len_, "cli") != 0:
        ll_puts("msr daifset, #2")        # mask IRQ (DAIF.I)
        return 1
    if ll_asm_body_eq(off, len_, "sti") != 0:
        ll_puts("msr daifclr, #2")        # unmask IRQ
        return 1
    if ll_asm_body_eq(off, len_, "pause") != 0:
        ll_puts("yield")                  # spin-wait hint
        return 1
    if ll_asm_body_eq(off, len_, "mfence") != 0:
        ll_puts("dmb ish")                # full inner-shareable data barrier
        return 1
    # ---- class (2): indirect tail-call (retpoline) trampolines ----
    # The `%rbp` variant (`movq %rbp,%r11; popq %rbp; jmpq *%r11`) carries the
    # call target in the frame-pointer, so route the aarch64 frame reg x29.
    if ll_asm_body_has(off, len_, "movq %rbp, %r11") != 0:
        ll_puts("mov x9, x29\n    br x9")
        return 1
    if ll_asm_body_has(off, len_, "jmpq *%") != 0:
        # `popq %rbp; jmpq *%rN` -> `br xN` (x86 GPR -> aarch64 GPR map).  Test
        # the 2-digit register names first so they win over their prefixes.
        ll_puts("br ")
        if ll_asm_body_has(off, len_, "*%r15") != 0:
            ll_puts("x13")
        elif ll_asm_body_has(off, len_, "*%r14") != 0:
            ll_puts("x12")
        elif ll_asm_body_has(off, len_, "*%r13") != 0:
            ll_puts("x11")
        elif ll_asm_body_has(off, len_, "*%r12") != 0:
            ll_puts("x10")
        elif ll_asm_body_has(off, len_, "*%r11") != 0:
            ll_puts("x9")
        elif ll_asm_body_has(off, len_, "*%r10") != 0:
            ll_puts("x8")
        elif ll_asm_body_has(off, len_, "*%r8") != 0:
            ll_puts("x6")
        elif ll_asm_body_has(off, len_, "*%r9") != 0:
            ll_puts("x7")
        elif ll_asm_body_has(off, len_, "*%rax") != 0:
            ll_puts("x0")
        elif ll_asm_body_has(off, len_, "*%rbx") != 0:
            ll_puts("x1")
        elif ll_asm_body_has(off, len_, "*%rcx") != 0:
            ll_puts("x2")
        elif ll_asm_body_has(off, len_, "*%rdx") != 0:
            ll_puts("x3")
        elif ll_asm_body_has(off, len_, "*%rsi") != 0:
            ll_puts("x4")
        elif ll_asm_body_has(off, len_, "*%rdi") != 0:
            ll_puts("x5")
        else:
            ll_puts("x16")                # unknown reg: IP0 scratch (still valid)
        return 1
    # ---- class (3): "real ARM" sites ----
    if ll_asm_body_has(off, len_, "mulq tls_mul128_b") != 0:
        # 128-bit widening multiply: lo = a*b, hi = umulh(a,b).  FAITHFUL aarch64.
        ll_puts("adrp x9, tls_mul128_a\n")
        ll_puts("    ldr x9, [x9, :lo12:tls_mul128_a]\n")
        ll_puts("    adrp x10, tls_mul128_b\n")
        ll_puts("    ldr x10, [x10, :lo12:tls_mul128_b]\n")
        ll_puts("    mul x11, x9, x10\n")
        ll_puts("    umulh x12, x9, x10\n")
        ll_puts("    adrp x13, tls_mul128_lo\n")
        ll_puts("    str x11, [x13, :lo12:tls_mul128_lo]\n")
        ll_puts("    adrp x13, tls_mul128_hi\n")
        ll_puts("    str x12, [x13, :lo12:tls_mul128_hi]")
        return 1
    if ll_asm_body_has(off, len_, "rdrand %rax") != 0:
        # ARMv8.5-RNG: RNDR (S3_3_C2_C4_0) -> scratch; flag success in hwrng_cf.
        ll_puts("mrs x9, s3_3_c2_c4_0\n")
        ll_puts("    adrp x10, hwrng_scratch\n")
        ll_puts("    str x9, [x10, :lo12:hwrng_scratch]\n")
        ll_puts("    adrp x10, hwrng_cf\n")
        ll_puts("    mov x9, #1\n")
        ll_puts("    str x9, [x10, :lo12:hwrng_cf]")
        return 1
    if ll_asm_body_has(off, len_, "rdseed %rax") != 0:
        # ARMv8.5-RNG: RNDRRS (S3_3_C2_C4_1) -> scratch; flag success in hwrng_cf.
        ll_puts("mrs x9, s3_3_c2_c4_1\n")
        ll_puts("    adrp x10, hwrng_scratch\n")
        ll_puts("    str x9, [x10, :lo12:hwrng_scratch]\n")
        ll_puts("    adrp x10, hwrng_cf\n")
        ll_puts("    mov x9, #1\n")
        ll_puts("    str x9, [x10, :lo12:hwrng_cf]")
        return 1
    if ll_asm_body_has(off, len_, "cpuid") != 0:
        # x86 CPUID has no aarch64 analog (identification via MIDR_EL1/ID_AA64*
        # is done in the A3 boot layer); stub leaves the cpuid_* globals as-is.
        ll_puts("nop")
        return 1
    if ll_asm_body_has(off, len_, "s3_save") != 0:
        # ACPI S3 register-save -> PSCI CPU_SUSPEND (A3 boot layer); stub.
        ll_puts("nop")
        return 1
    if ll_asm_body_has(off, len_, "lidt power_null_idt") != 0:
        # x86 null-IDT triple-fault reset -> PSCI SYSTEM_RESET (A3 boot layer); stub.
        ll_puts("nop")
        return 1
    return 0


def ll_put_u64_dec(v: uint64):
    if v == cast[uint64](0):
        ll_putc(48)
        return
    tmp: Array[24, uint8]
    n: uint32 = 0
    x: uint64 = v
    while x > cast[uint64](0):
        d: uint64 = x % cast[uint64](10)
        tmp[n] = cast[uint8](d + cast[uint64](48))
        n = n + 1
        x = x / cast[uint64](10)
    while n > 0:
        n = n - 1
        ll_putc(cast[uint32](tmp[n]))


def ll_put_u32(v: uint32):
    ll_put_u64_dec(cast[uint64](v))


# Print the 64-bit pattern `bits` as a SIGNED decimal (LLVM-friendly for i64).
def ll_put_i64(bits: uint64):
    v: int64 = cast[int64](bits)
    if v < 0:
        ll_putc(45)                       # '-'
        mag: uint64 = cast[uint64](0) - bits
        ll_put_u64_dec(mag)
        return
    ll_put_u64_dec(bits)


# =======================================================================
# operand + type helpers
# =======================================================================
# Is value `v` an i1 (compare result / explicitly-bool value)?
def llvm_is_i1(v: uint32) -> uint32:
    if v == 0:
        return 0
    if sv_op[v] == SVO_ICMP:
        return 1
    if sv_type[v] == SVT_I1:
        return 1
    return 0


# Render `v` as an operand token: a constant/undef inlines its literal, every
# other value prints its SSA register name %vN.
def ll_put_operand(v: uint32):
    if v == 0:
        ll_putc(48)                       # '0'
        return
    op: uint32 = sv_op[v]
    if op == SVO_CONST:
        ll_put_i64(sv_imm[v])
        return
    if op == SVO_FCONST:
        ll_put_hex64(sv_imm[v])           # exact double bit pattern
        return
    if op == SVO_UNDEF:
        ll_puts("undef")
        return
    ll_putc(37)                           # '%'
    ll_putc(118)                          # 'v'
    ll_put_u32(v)


# Print `%vN = ` (the result binding for value v).
def ll_put_result(v: uint32):
    ll_puts("  %v")
    ll_put_u32(v)
    ll_puts(" = ")


# i1->i64 coercion for values used in an i64 context. LLVM is strongly typed:
# an ICMP/FCMP/i1 value cannot be fed to an instruction that expects i64 (icmp
# i64, integer binop, store i64, ret i64, call arg, ...). When `v` is such an i1
# value, pre-emit `%tN = zext i1 <v> to i64` and return the fresh temp id; the
# caller then prints that temp (via ll_put_operand_ct) in the i64 slot. Returns
# 0 when no coercion is needed (v is already i64/float, or a literal constant
# that prints inline as an i64 immediate). MUST be called BEFORE ll_put_result
# so the zext lands ahead of the consuming instruction.
def ll_coerce_i64(v: uint32) -> uint32:
    if v == 0:
        return 0
    op: uint32 = sv_op[v]
    if op == SVO_CONST or op == SVO_FCONST or op == SVO_UNDEF:
        return 0
    if llvm_is_i1(v) == 0:
        return 0
    t: uint32 = ll_new_tmp()
    ll_puts("  ")
    ll_put_tmp(t)
    ll_puts(" = zext i1 ")
    ll_put_operand(v)
    ll_puts(" to i64\n")
    return t


# Print an operand that may have been coerced: `t` is the zext temp from
# ll_coerce_i64 (0 = none), in which case fall back to the raw operand.
def ll_put_operand_ct(v: uint32, t: uint32):
    if t != 0:
        ll_put_tmp(t)
    else:
        ll_put_operand(v)


def ll_new_tmp() -> uint32:
    t: uint32 = llvm_tmp
    llvm_tmp = llvm_tmp + 1
    return t


# x86-64 SysV syscall input register for operand index i of `__syscallN`:
#   0 -> rax (syscall number), 1 -> rdi, 2 -> rsi, 3 -> rdx, 4 -> r10,
#   5 -> r8, 6 -> r9.  Emits the bare register name (no braces).
# AArch64 (cg_llvm_target==1) Linux SVC ABI: number -> x8, args a1..a6 ->
# x0,x1,x2,x3,x4,x5; result -> x0.  Same operand-index order.
def ll_put_syscall_reg(i: uint32):
    if cg_llvm_target != 0:
        if i == 0:
            ll_puts("x8")                 # aarch64 syscall number register
        elif i == 1:
            ll_puts("x0")
        elif i == 2:
            ll_puts("x1")
        elif i == 3:
            ll_puts("x2")
        elif i == 4:
            ll_puts("x3")
        elif i == 5:
            ll_puts("x4")
        else:
            ll_puts("x5")
        return
    if i == 0:
        ll_puts("rax")
    elif i == 1:
        ll_puts("rdi")
    elif i == 2:
        ll_puts("rsi")
    elif i == 3:
        ll_puts("rdx")
    elif i == 4:
        ll_puts("r10")
    elif i == 5:
        ll_puts("r8")
    else:
        ll_puts("r9")


# Map an x86-64 Linux syscall number to the AArch64 (asm-generic) Linux syscall
# number.  The Adder `__syscallN(nr, ...)` form bakes the x86-64 Linux number as
# a compile-time constant; on aarch64 those numbers differ (asm-generic ABI), so
# when the number operand is a literal we remap it here.  Covers the syscalls the
# Adder user-mode runtime + host driver actually issue; numbers with the SAME
# 3-arg-or-fewer signature map 1:1.  `open`(x86 2) has NO aarch64 equivalent (it
# is openat-only) and cannot be number-remapped safely, so it is passed through
# unchanged (callers targeting aarch64 must use openat=56 directly).  Any number
# not in the table passes through unchanged.
def ll_aarch64_syscall_nr(x86nr: int64) -> int64:
    if x86nr == 0:                        # read
        return 63
    if x86nr == 1:                        # write
        return 64
    if x86nr == 3:                        # close
        return 57
    if x86nr == 8:                        # lseek
        return 62
    if x86nr == 9:                        # mmap
        return 222
    if x86nr == 11:                       # munmap
        return 215
    if x86nr == 60:                       # exit
        return 93
    if x86nr == 231:                      # exit_group
        return 94
    if x86nr == 257:                      # openat
        return 56
    if x86nr == 62:                       # kill
        return 129
    if x86nr == 39:                       # getpid
        return 172
    if x86nr == 96:                       # gettimeofday
        return 169
    if x86nr == 228:                      # clock_gettime
        return 113
    return x86nr


def ll_put_tmp(t: uint32):
    ll_putc(37)                           # '%'
    ll_putc(116)                          # 't'
    ll_put_u32(t)


# Print an LLVM integer type `iBITS` for a byte width `w` (1->i8 .. 8->i64).
# The SSA carries load/store/trunc widths in BYTES; LLVM types are in BITS.
def ll_put_ity(w: uint32):
    ll_putc(105)                          # 'i'
    ll_put_u32(w * 8)


# Print an integer POINTER type `iW*`, or `iW addrspace(256)*` when as256 != 0.
# Address space 256 is x86-64 clang's model for `%gs`-relative memory, so a
# percpu (per-CPU) load/store through such a pointer lowers to a `%gs:`-prefixed
# instruction.  With as256 == 0 the output is byte-identical to the previous
# `ll_put_ity(w); ll_puts("*")` sequence — non-percpu emission is unchanged.
def ll_put_ity_ptr(w: uint32, as256: uint32):
    ll_put_ity(w)
    if as256 != 0:
        ll_puts(" addrspace(256)")
    ll_putc(42)                           # '*'


# Effective address-space for the actual load/store TYPE at a percpu site.  On
# x86-64 a percpu access keeps addrspace(256) (the %gs model).  On aarch64 the
# per-CPU base is folded into the address via TPIDR_EL1 (see ll_emit_pcpu_ptr),
# so the resulting pointer is an ordinary addrspace(0) pointer -> 0.
def ll_pcpu_eff_as(las: uint32) -> uint32:
    if cg_llvm_target != 0:
        return 0
    return las


# Emit the pointer temp for a memory access whose byte OFFSET operand is
# `addr_v` and width `w` (bytes).  `las` != 0 marks a per-CPU (%gs) access.
#
#  * x86-64, or non-percpu:  `%p = inttoptr i64 <off> to iW[ addrspace(256)]*`.
#  * aarch64 percpu:         read the per-CPU base from TPIDR_EL1 via
#      `llvm.read_register.i64(metadata !"tpidr_el1")`, ADD the slot offset, then
#      `inttoptr` the sum to a plain iW* — aarch64 lowers this to
#      `mrs xN, TPIDR_EL1` + offset load/store (NOT a bare `ldr`, which would be
#      the silent miscompile if addrspace(256) were emitted verbatim; aarch64 has
#      no GS-style address space).
# Returns the SSA temp id holding the iW* pointer.
def ll_emit_pcpu_ptr(addr_v: uint32, w: uint32, las: uint32) -> uint32:
    if cg_llvm_target != 0 and las != 0:
        llvm_tpidr_meta_done = 1          # request module-level plumbing emission
        base: uint32 = ll_new_tmp()
        ll_puts("  ")
        ll_put_tmp(base)
        ll_puts(" = call i64 @llvm.read_register.i64(metadata !0)\n")
        addr: uint32 = ll_new_tmp()
        ll_puts("  ")
        ll_put_tmp(addr)
        ll_puts(" = add i64 ")
        ll_put_operand(addr_v)
        ll_puts(", ")
        ll_put_tmp(base)
        ll_putc(10)
        p: uint32 = ll_new_tmp()
        ll_puts("  ")
        ll_put_tmp(p)
        ll_puts(" = inttoptr i64 ")
        ll_put_tmp(addr)
        ll_puts(" to ")
        ll_put_ity_ptr(w, 0)              # plain iW* — base already folded in
        ll_putc(10)
        return p
    p2: uint32 = ll_new_tmp()
    ll_puts("  ")
    ll_put_tmp(p2)
    ll_puts(" = inttoptr i64 ")
    ll_put_operand(addr_v)
    ll_puts(" to ")
    ll_put_ity_ptr(w, las)
    ll_putc(10)
    return p2


# Print "0x" + 16 UPPERCASE hex digits of `v` — LLVM's textual form for an
# exact IEEE-754 double constant (a float64 literal's 64-bit bit pattern).
def ll_put_hex64(v: uint64):
    ll_puts("0x")
    i: int32 = 15
    while i >= 0:
        sh: uint64 = cast[uint64](cast[uint32](i) * 4)
        d: uint32 = cast[uint32]((v >> sh) & cast[uint64](15))
        if d < 10:
            ll_putc(48 + d)               # '0'..'9'
        else:
            ll_putc(65 + (d - 10))        # 'A'..'F'
        i = i - 1


# Is value `v` a float (f32/f64)?
def llvm_is_float(v: uint32) -> uint32:
    if v == 0:
        return 0
    if sv_type[v] == SVT_F32 or sv_type[v] == SVT_F64:
        return 1
    return 0


# Print the LLVM type token for an SSA type id.
def ll_put_svty(t: uint32):
    if t == SVT_F32:
        ll_puts("float")
        return
    if t == SVT_F64:
        ll_puts("double")
        return
    if t == SVT_I1:
        ll_puts("i1")
        return
    ll_puts("i64")


# Print value `v`'s LLVM type token (i64 for the canonical integer model,
# i1 for compares/bools, float/double for float values).
def ll_put_vty(v: uint32):
    if v == 0:
        ll_puts("i64")
        return
    if sv_op[v] == SVO_ICMP or sv_op[v] == SVO_FCMP:
        ll_puts("i1")
        return
    ll_put_svty(sv_type[v])


# Float arithmetic mnemonic for a BINOP (fadd/fsub/fmul/fdiv).
def ll_put_fbinop_mnem(op: uint32):
    if op == BINOP_ADD:
        ll_puts("fadd")
        return
    if op == BINOP_SUB:
        ll_puts("fsub")
        return
    if op == BINOP_MUL:
        ll_puts("fmul")
        return
    ll_puts("fdiv")                       # BINOP_DIV / BINOP_IDIV


# LLVM ordered fcmp predicate from a compare BINOP.
def ll_put_fcmp_pred(op: uint32):
    if op == BINOP_EQ:
        ll_puts("oeq")
        return
    if op == BINOP_NEQ:
        ll_puts("une")                    # C-style: true if either operand NaN
        return
    if op == BINOP_LT:
        ll_puts("olt")
        return
    if op == BINOP_LTE:
        ll_puts("ole")
        return
    if op == BINOP_GT:
        ll_puts("ogt")
        return
    if op == BINOP_GTE:
        ll_puts("oge")
        return
    ll_puts("one")


# integer arithmetic/bitwise mnemonic for a BINOP (`signed_`=1 selects the
# signed division / arithmetic-shift form).
def ll_put_binop_mnem(op: uint32, signed_: uint32):
    if op == BINOP_ADD:
        ll_puts("add")
        return
    if op == BINOP_SUB:
        ll_puts("sub")
        return
    if op == BINOP_MUL:
        ll_puts("mul")
        return
    if op == BINOP_DIV or op == BINOP_IDIV:
        if signed_ != 0:
            ll_puts("sdiv")
        else:
            ll_puts("udiv")
        return
    if op == BINOP_MOD:
        if signed_ != 0:
            ll_puts("srem")
        else:
            ll_puts("urem")
        return
    if op == BINOP_BIT_AND:
        ll_puts("and")
        return
    if op == BINOP_BIT_OR:
        ll_puts("or")
        return
    if op == BINOP_BIT_XOR:
        ll_puts("xor")
        return
    if op == BINOP_SHL:
        ll_puts("shl")
        return
    if op == BINOP_SHR:
        if signed_ != 0:
            ll_puts("ashr")
        else:
            ll_puts("lshr")
        return
    ll_puts("add")                        # unreachable in-subset


# LLVM icmp predicate from the resolved x86 setcc opcode byte (sv_c on an ICMP).
def ll_put_icmp_pred(cc: uint32):
    if cc == 0x94:
        ll_puts("eq")
        return
    if cc == 0x95:
        ll_puts("ne")
        return
    if cc == 0x9C:
        ll_puts("slt")
        return
    if cc == 0x92:
        ll_puts("ult")
        return
    if cc == 0x9E:
        ll_puts("sle")
        return
    if cc == 0x96:
        ll_puts("ule")
        return
    if cc == 0x9F:
        ll_puts("sgt")
        return
    if cc == 0x97:
        ll_puts("ugt")
        return
    if cc == 0x9D:
        ll_puts("sge")
        return
    if cc == 0x93:
        ll_puts("uge")
        return
    ll_puts("ne")


# =======================================================================
# globals
# =======================================================================
# Total byte size of global `gi` (1-based): the full (possibly nested) array
# size, or the scalar width.
def llvm_glob_bytes(gi: uint32) -> uint32:
    if glob_elem_size[gi - 1] != 0:
        tn: uint32 = glob_type_node[gi - 1]
        if tn != 0:
            return type_size_of(tn)
        return glob_elem_size[gi - 1]
    # Struct-VALUE global (e.g. `v9p_dev: Virtio9p`): codegen.ad reserves the
    # struct's FULL st_total bytes in .bss (see the struct-typed-global arm of
    # the decl handler) but records elem_size=0/scalar_size=0 and stamps
    # glob_struct_idx.  Without consulting it here the emitter falls to the
    # 8-byte scalar default and declares `@g = global [8 x i8]`, so every
    # `g.field` store past offset 8 (field access is correctly `&g + off`)
    # spills into the ADJACENT .bss global — a layout-sensitive OOB write that
    # silently corrupts whatever global follows (the kernel-LLVM VMA-tree /
    # task_table corruption).  Reserve the real struct size, matching native.
    # LLVM-path only (llvm_glob_bytes has no native-codegen caller), so the
    # native kernel stays byte-identical.
    si1: uint32 = glob_struct_idx[gi - 1]
    if si1 != 0:
        return st_total[si1 - 1]
    ss: uint32 = glob_scalar_size[gi - 1]
    if ss == 0:
        return 8
    return ss


# 1-based global index whose (byte-offset, is_bss) matches — the reverse of the
# GLOBALADDR encoding (percpu globals are excluded; they never reach here).
def llvm_glob_for(off: uint32, is_bss: uint32) -> uint32:
    i: uint32 = 0
    while i < glob_count:
        if glob_is_percpu[i] == 0:
            if glob_offset[i] == off and glob_is_bss[i] == is_bss:
                return i + 1
        i = i + 1
    return 1


def llvm_emit_data_init(gi: uint32, b: uint32):
    off: uint32 = glob_offset[gi - 1]
    ll_putc(91)                           # '['
    i: uint32 = 0
    while i < b:
        if i > 0:
            ll_puts(", ")
        ll_puts("i8 ")
        ll_put_u32(cast[uint32](gdata[off + i]))
        i = i + 1
    ll_putc(93)                           # ']'


def llvm_emit_globals():
    gi: uint32 = 0
    while gi < glob_count:
        if glob_is_percpu[gi] == 0:
            b: uint32 = llvm_glob_bytes(gi + 1)
            ll_putc(64)                   # '@'
            ll_put_name(glob_name_off[gi], glob_name_len[gi])
            # Named module globals get EXTERNAL linkage so a memory-clobbering
            # inline asm (`asm sideeffect ... "~{memory}"`) that parks its result
            # in a RIP-relative global (the kernel's rdrand/rdseed/cpuid pattern:
            # `movq %rax, hwrng_scratch(%rip)`) forces clang to RELOAD the global
            # after the asm.  clang -O2 assumes a `~{memory}` asm cannot touch an
            # `internal` global whose address never escapes as an operand — so it
            # would forward the pre-asm value (a silent miscompile).  Synthetic
            # `.Lstr*` string-literal constants stay internal (assembler-local,
            # never asm-referenced).  LLVM-path only; native codegen unaffected.
            gno: uint32 = glob_name_off[gi]
            gnl: uint32 = glob_name_len[gi]
            if gnl >= 2 and strbuf[gno] == 46 and strbuf[gno + 1] == 76:
                ll_puts(" = internal global [")
            else:
                # dso_local: mark named module globals as non-preemptible so
                # clang materializes their address with DIRECT addressing
                # (`mov $imm`/RIP-relative, R_X86_64_32S) rather than a
                # GOT-indirect load (R_X86_64_REX_GOTPCRELX).  Without this the
                # default (external, dso_preemptable) linkage makes clang route
                # every module-global access through the GOT.  That is a
                # correctness hazard for the kernel native-hybrid link
                # (`ld --allow-multiple-definition`: the LLVM object first-wins
                # for the emitted functions while a native main.o supplies the
                # few bailed ones), where every global is DEFINED in BOTH
                # objects — GOTPCRELX relaxation of a duplicated symbol is not
                # guaranteed to bind uniformly.  `dso_local` pins one canonical
                # symbol address for every reference (verified: 0 GOTPCREL for
                # `task_table`, single `B task_table` symbol, all direct
                # R_X86_64_32S).  dso_local is also correct for PIE apps (a
                # main-executable's own defined symbols are never interposed).
                # LLVM path only — this emitter never runs for native codegen,
                # so codegen.ad stays byte-identical.
                ll_puts(" = dso_local global [")
            ll_put_u32(b)
            ll_puts(" x i8] ")
            if glob_is_bss[gi] != 0:
                ll_puts("zeroinitializer")
            else:
                llvm_emit_data_init(gi + 1, b)
            # align 1 (NOT 16): the kernel native-hybrid link makes native_main.o
            # the sole DEFINER of every module global (Phase 5p externalization),
            # and the native backend packs globals at BYTE granularity — a global
            # can land at any address mod 16 (e.g. p9c_smoke_pump_hook @...4e1,
            # umdf zero-buffer @...4d4). Declaring `align 16` LIES to clang: at
            # -O2 it vectorizes a memset/zeroing loop over such a global into
            # ALIGNED SSE stores (`movaps`), which #GP on the real sub-16-aligned
            # address (the boot-stage rfork/umdf_task_cleanup #GP). `align 1`
            # forces clang to assume nothing, so it emits unaligned (`movups`) /
            # scalar stores that are correct at any address. LLVM path only —
            # codegen.ad (native) is untouched and byte-identical.
            ll_puts(", align 1\n")
        gi = gi + 1
    ll_putc(10)


# =======================================================================
# defined / called name sets
# =======================================================================
def llvm_name_eq(o1: uint32, l1: uint32, o2: uint32, l2: uint32) -> uint32:
    if l1 != l2:
        return 0
    i: uint32 = 0
    while i < l1:
        if strbuf[o1 + i] != strbuf[o2 + i]:
            return 0
        i = i + 1
    return 1


def llvm_name_in_defined(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < dn_count:
        if llvm_name_eq(dn_off[i], dn_len[i], off, len_) != 0:
            return 1
        i = i + 1
    return 0


def llvm_record_defined(off: uint32, len_: uint32):
    if llvm_name_in_defined(off, len_) != 0:
        return
    if dn_count >= LL_NAME_MAX:
        return
    dn_off[dn_count] = off
    dn_len[dn_count] = len_
    dn_count = dn_count + 1


def llvm_name_in_callees(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < ce_count:
        if llvm_name_eq(ce_off[i], ce_len[i], off, len_) != 0:
            return 1
        i = i + 1
    return 0


def llvm_record_callee(off: uint32, len_: uint32, argc: uint32):
    i: uint32 = 0
    while i < ce_count:
        if llvm_name_eq(ce_off[i], ce_len[i], off, len_) != 0:
            return
        i = i + 1
    if ce_count >= LL_NAME_MAX:
        return
    ce_off[ce_count] = off
    ce_len[ce_count] = len_
    ce_argc[ce_count] = argc
    ce_count = ce_count + 1


# Walk the just-built SSA of an accepted function, recording every direct call
# target so callees not defined in-unit get an external `declare`.
def llvm_name_in_faddr(off: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < fa_count:
        if llvm_name_eq(fa_off[i], fa_len[i], off, len_) != 0:
            return 1
        i = i + 1
    return 0


def llvm_record_faddr(off: uint32, len_: uint32):
    if llvm_name_in_faddr(off, len_) != 0:
        return
    if fa_count >= LL_NAME_MAX:
        return
    fa_off[fa_count] = off
    fa_len[fa_count] = len_
    fa_count = fa_count + 1


def llvm_collect_callees():
    v: uint32 = 1
    while v < sv_count:
        if sv_op[v] == SVO_CALL:
            # sv_b != 0 => INDIRECT call through a fn-pointer value: there is no
            # named callee symbol to declare (the target is a runtime value).
            if sv_b[v] == 0:
                callnode: uint32 = sv_ast[v]
                callee: uint32 = nd_a[callnode]
                llvm_record_callee(nd_name_off[callee], nd_name_len[callee], sv_argn[v])
        elif sv_op[v] == SVO_FUNCADDR:
            fan: uint32 = sv_ast[v]
            llvm_record_faddr(nd_name_off[fan], nd_name_len[fan])
        v = v + 1


def llvm_emit_declares():
    i: uint32 = 0
    while i < ce_count:
        # A callee name that is ALSO a module global VARIABLE is NOT a function —
        # it is a global fn-pointer that should have lowered to an INDIRECT call.
        # Never emit a `declare` for it (it collides with the `@name = global`).
        if llvm_name_in_defined(ce_off[i], ce_len[i]) == 0 and glob_lookup(ce_off[i], ce_len[i]) == 0:
            ll_puts("declare i64 @")
            ll_put_name(ce_off[i], ce_len[i])
            ll_putc(40)                    # '('
            j: uint32 = 0
            while j < ce_argc[i]:
                if j > 0:
                    ll_puts(", ")
                ll_puts("i64")
                j = j + 1
            ll_puts(")\n")
        i = i + 1
    # Function-ADDRESS targets not defined in-unit and not already declared as a
    # direct callee: a zero-arg `declare` so `@name` resolves for `ptrtoint`.
    fi: uint32 = 0
    while fi < fa_count:
        if llvm_name_in_defined(fa_off[fi], fa_len[fi]) == 0 and llvm_name_in_callees(fa_off[fi], fa_len[fi]) == 0 and glob_lookup(fa_off[fi], fa_len[fi]) == 0:
            ll_puts("declare i64 @")
            ll_put_name(fa_off[fi], fa_len[fi])
            ll_puts("()\n")
        fi = fi + 1
    ll_putc(10)


# =======================================================================
# per-value emission
# =======================================================================
def llvm_emit_value(v: uint32):
    op: uint32 = sv_op[v]
    # constants / params / undef never materialise an instruction.
    if op == SVO_PARAM or op == SVO_CONST or op == SVO_FCONST or op == SVO_UNDEF:
        return

    if op == SVO_BINOP:
        if llvm_is_float(v) != 0:
            ll_put_result(v)
            ll_put_fbinop_mnem(sv_aux[v])
            ll_putc(32)                   # ' '
            ll_put_vty(v)
            ll_putc(32)
            ll_put_operand(sv_a[v])
            ll_puts(", ")
            ll_put_operand(sv_b[v])
            ll_putc(10)
            return
        bat: uint32 = ll_coerce_i64(sv_a[v])
        bbt: uint32 = ll_coerce_i64(sv_b[v])
        ll_put_result(v)
        ll_put_binop_mnem(sv_aux[v], sv_c[v])
        ll_putc(32)                       # ' '
        ll_put_vty(v)
        ll_putc(32)
        ll_put_operand_ct(sv_a[v], bat)
        ll_puts(", ")
        ll_put_operand_ct(sv_b[v], bbt)
        ll_putc(10)
        return

    if op == SVO_FCMP:
        ll_put_result(v)
        ll_puts("fcmp ")
        ll_put_fcmp_pred(sv_aux[v])
        ll_putc(32)
        ll_put_vty(sv_a[v])               # operand float type
        ll_putc(32)
        ll_put_operand(sv_a[v])
        ll_puts(", ")
        ll_put_operand(sv_b[v])
        ll_putc(10)
        return

    if op == SVO_FNEG:
        ll_put_result(v)
        ll_puts("fneg ")
        ll_put_vty(v)
        ll_putc(32)
        ll_put_operand(sv_a[v])
        ll_putc(10)
        return

    if op == SVO_I2F:
        i2ft: uint32 = ll_coerce_i64(sv_a[v])
        ll_put_result(v)
        if sv_c[v] != 0:
            ll_puts("sitofp i64 ")
        else:
            ll_puts("uitofp i64 ")
        ll_put_operand_ct(sv_a[v], i2ft)
        ll_puts(" to ")
        ll_put_vty(v)
        ll_putc(10)
        return

    if op == SVO_F2I:
        w: uint32 = sv_aux[v]
        if w == 8:
            ll_put_result(v)
            if sv_c[v] != 0:
                ll_puts("fptosi ")
            else:
                ll_puts("fptoui ")
            ll_put_vty(sv_a[v])
            ll_putc(32)
            ll_put_operand(sv_a[v])
            ll_puts(" to i64\n")
        else:
            t: uint32 = ll_new_tmp()
            ll_puts("  ")
            ll_put_tmp(t)
            if sv_c[v] != 0:
                ll_puts(" = fptosi ")
            else:
                ll_puts(" = fptoui ")
            ll_put_vty(sv_a[v])
            ll_putc(32)
            ll_put_operand(sv_a[v])
            ll_puts(" to ")
            ll_put_ity(w)
            ll_putc(10)
            ll_put_result(v)
            if sv_c[v] != 0:
                ll_puts("sext ")
            else:
                ll_puts("zext ")
            ll_put_ity(w)
            ll_putc(32)
            ll_put_tmp(t)
            ll_puts(" to i64\n")
        return

    if op == SVO_FPEXT:
        ll_put_result(v)
        ll_puts("fpext ")
        ll_put_vty(sv_a[v])
        ll_putc(32)
        ll_put_operand(sv_a[v])
        ll_puts(" to ")
        ll_put_vty(v)
        ll_putc(10)
        return

    if op == SVO_FPTRUNC:
        ll_put_result(v)
        ll_puts("fptrunc ")
        ll_put_vty(sv_a[v])
        ll_putc(32)
        ll_put_operand(sv_a[v])
        ll_puts(" to ")
        ll_put_vty(v)
        ll_putc(10)
        return

    if op == SVO_ICMP:
        iat: uint32 = ll_coerce_i64(sv_a[v])
        ibt: uint32 = ll_coerce_i64(sv_b[v])
        ll_put_result(v)
        ll_puts("icmp ")
        ll_put_icmp_pred(sv_c[v])
        ll_puts(" i64 ")
        ll_put_operand_ct(sv_a[v], iat)
        ll_puts(", ")
        ll_put_operand_ct(sv_b[v], ibt)
        ll_putc(10)
        return

    if op == SVO_NEG:
        nt: uint32 = ll_coerce_i64(sv_a[v])
        ll_put_result(v)
        ll_puts("sub i64 0, ")
        ll_put_operand_ct(sv_a[v], nt)
        ll_putc(10)
        return

    if op == SVO_BITNOT:
        xt: uint32 = ll_coerce_i64(sv_a[v])
        ll_put_result(v)
        ll_puts("xor i64 ")
        ll_put_operand_ct(sv_a[v], xt)
        ll_puts(", -1")
        ll_putc(10)
        return

    if op == SVO_NOT:
        nct: uint32 = ll_coerce_i64(sv_a[v])
        t: uint32 = ll_new_tmp()
        ll_puts("  ")
        ll_put_tmp(t)
        ll_puts(" = icmp eq i64 ")
        ll_put_operand_ct(sv_a[v], nct)
        ll_puts(", 0\n")
        ll_put_result(v)
        ll_puts("zext i1 ")
        ll_put_tmp(t)
        ll_puts(" to i64\n")
        return

    if op == SVO_TRUNC:
        w: uint32 = sv_aux[v]
        trt: uint32 = ll_coerce_i64(sv_a[v])
        t: uint32 = ll_new_tmp()
        ll_puts("  ")
        ll_put_tmp(t)
        ll_puts(" = trunc i64 ")
        ll_put_operand_ct(sv_a[v], trt)
        ll_puts(" to ")
        ll_put_ity(w)
        ll_putc(10)
        ll_put_result(v)
        if sv_c[v] != 0:
            ll_puts("sext ")
        else:
            ll_puts("zext ")
        ll_put_ity(w)
        ll_puts(" ")
        ll_put_tmp(t)
        ll_puts(" to i64\n")
        return

    if op == SVO_ALLOCA:
        # Reserve a byte-array stack slot and take its integer address, mirroring
        # how a global's address is materialised (ptrtoint of an [N x i8]*), so
        # all subsequent base+idx*elem arithmetic and sized load/store reuse the
        # exact same i64-address machinery.  sv_imm = total byte size.
        asz: uint32 = cast[uint32](sv_imm[v])
        if asz == 0:
            asz = 1
        aslot: uint32 = ll_new_tmp()
        ll_puts("  ")
        ll_put_tmp(aslot)
        ll_puts(" = alloca [")
        ll_put_u32(asz)
        ll_puts(" x i8]\n")
        ll_put_result(v)
        ll_puts("ptrtoint [")
        ll_put_u32(asz)
        ll_puts(" x i8]* ")
        ll_put_tmp(aslot)
        ll_puts(" to i64\n")
        return

    if op == SVO_GLOBALADDR:
        gi: uint32 = llvm_glob_for(cast[uint32](sv_imm[v]), sv_c[v])
        b: uint32 = llvm_glob_bytes(gi)
        ll_put_result(v)
        ll_puts("ptrtoint [")
        ll_put_u32(b)
        ll_puts(" x i8]* @")
        ll_put_name(glob_name_off[gi - 1], glob_name_len[gi - 1])
        ll_puts(" to i64\n")
        return

    if op == SVO_FUNCADDR:
        # &function / function-name-as-value: the function symbol's address.
        # sv_ast is the ND_IDENT naming the function.
        fan: uint32 = sv_ast[v]
        ll_put_result(v)
        ll_puts("ptrtoint ptr @")
        ll_put_name(nd_name_off[fan], nd_name_len[fan])
        ll_puts(" to i64\n")
        return

    if op == SVO_LOAD:
        # FLOAT element load (LLVM path): the load result is typed SVT_F32/F64,
        # so emit `load float`/`load double` through a float*/double* — never the
        # i64 integer load + zext.  A float value never needs the sub-word sign/
        # zero extension, so there is no coercion.
        if llvm_is_float(v) != 0:
            fp: uint32 = ll_new_tmp()
            ll_puts("  ")
            ll_put_tmp(fp)
            ll_puts(" = inttoptr i64 ")
            ll_put_operand(sv_a[v])
            ll_puts(" to ")
            ll_put_svty(sv_type[v])
            ll_puts("*\n")
            ll_put_result(v)
            ll_puts("load ")
            ll_put_svty(sv_type[v])
            ll_puts(", ")
            ll_put_svty(sv_type[v])
            ll_puts("* ")
            ll_put_tmp(fp)
            ll_putc(10)
            return
        w: uint32 = sv_aux[v]
        las: uint32 = sv_as256[v]         # 1 => %gs-relative percpu (addrspace 256)
        eff_las: uint32 = ll_pcpu_eff_as(las)
        p: uint32 = ll_emit_pcpu_ptr(sv_a[v], w, las)
        if w == 8:
            ll_put_result(v)
            ll_puts("load i64, ")
            ll_put_ity_ptr(8, eff_las)
            ll_putc(32)
            ll_put_tmp(p)
            ll_putc(10)
        else:
            r: uint32 = ll_new_tmp()
            ll_puts("  ")
            ll_put_tmp(r)
            ll_puts(" = load ")
            ll_put_ity(w)
            ll_puts(", ")
            ll_put_ity_ptr(w, eff_las)
            ll_putc(32)
            ll_put_tmp(p)
            ll_putc(10)
            ll_put_result(v)
            if sv_c[v] != 0:
                ll_puts("sext ")
            else:
                ll_puts("zext ")
            ll_put_ity(w)
            ll_puts(" ")
            ll_put_tmp(r)
            ll_puts(" to i64\n")
        return

    if op == SVO_STORE:
        # FLOAT element store (LLVM path): the stored value carries an SVT_F32/F64
        # type, so emit `store float`/`store double` through a float*/double* —
        # never the i64 store (or sub-word trunc).  The element width and pointer
        # type both come from the value's float type (authoritative), so no i64
        # coercion is applied.
        if llvm_is_float(sv_b[v]) != 0:
            fp: uint32 = ll_new_tmp()
            ll_puts("  ")
            ll_put_tmp(fp)
            ll_puts(" = inttoptr i64 ")
            ll_put_operand(sv_a[v])
            ll_puts(" to ")
            ll_put_vty(sv_b[v])
            ll_puts("*\n")
            ll_puts("  store ")
            ll_put_vty(sv_b[v])
            ll_putc(32)
            ll_put_operand(sv_b[v])
            ll_puts(", ")
            ll_put_vty(sv_b[v])
            ll_puts("* ")
            ll_put_tmp(fp)
            ll_putc(10)
            return
        w: uint32 = sv_aux[v]
        sas: uint32 = sv_as256[v]         # 1 => %gs-relative percpu (addrspace 256)
        eff_sas: uint32 = ll_pcpu_eff_as(sas)
        svt: uint32 = ll_coerce_i64(sv_b[v])
        p: uint32 = ll_emit_pcpu_ptr(sv_a[v], w, sas)
        if w == 8:
            ll_puts("  store i64 ")
            ll_put_operand_ct(sv_b[v], svt)
            ll_puts(", ")
            ll_put_ity_ptr(8, eff_sas)
            ll_putc(32)
            ll_put_tmp(p)
            ll_putc(10)
        else:
            t: uint32 = ll_new_tmp()
            ll_puts("  ")
            ll_put_tmp(t)
            ll_puts(" = trunc i64 ")
            ll_put_operand_ct(sv_b[v], svt)
            ll_puts(" to ")
            ll_put_ity(w)
            ll_putc(10)
            ll_puts("  store ")
            ll_put_ity(w)
            ll_puts(" ")
            ll_put_tmp(t)
            ll_puts(", ")
            ll_put_ity_ptr(w, eff_sas)
            ll_putc(32)
            ll_put_tmp(p)
            ll_putc(10)
        return

    if op == SVO_INLINEASM:
        # Zero-operand `asm_volatile("<text>")` -> LLVM basic inline asm.
        # sv_ast is the ND_CALL; its single string-literal arg (nd_b) holds the
        # verbatim asm body.  Conservative clobbers: all caller/callee GPRs
        # (except rsp/rbp), memory and flags — the Adder form has no operand
        # syntax, so any GPR/global the body writes (rdrand -> %rax,
        # cpuid -> globals, etc.) must be assumed clobbered for correctness.
        # LLVM preserves callee-saved clobbers (rbx,r12-r15) via the prologue.
        iasn: uint32 = sv_ast[v]
        astr: uint32 = nd_b[iasn]
        ll_puts("  call void asm sideeffect ")
        ll_putc(34)                       # opening '"'
        iaremap: uint32 = 0
        if cg_llvm_target != 0:
            iaremap = ll_emit_aarch64_asm(nd_name_off[astr], nd_name_len[astr])
        if iaremap == 0:
            ll_put_asm_string(nd_name_off[astr], nd_name_len[astr])
        ll_putc(34)                       # closing '"'
        ll_puts(", ")
        ll_putc(34)
        if cg_llvm_target != 0:
            # aarch64 has no rax..r15 GPR names.  Barriers touch no GPRs; the
            # mul128/rng remaps (ll_emit_aarch64_asm) use x9..x13 as scratch, so
            # clobber those plus memory + condition flags.
            ll_puts("~{x9},~{x10},~{x11},~{x12},~{x13},~{memory},~{cc}")
        else:
            ll_puts("~{rax},~{rbx},~{rcx},~{rdx},~{rsi},~{rdi},~{r8},~{r9},~{r10},~{r11},~{r12},~{r13},~{r14},~{r15},~{memory},~{cc}")
        ll_putc(34)
        ll_puts("()\n")
        return

    if op == SVO_SYSCALL:
        # `__syscallN(num, a1..aN)` -> a raw x86-64 `syscall` via LLVM inline asm.
        # SysV syscall ABI: num->rax, a1->rdi, a2->rsi, a3->rdx, a4->r10, a5->r8,
        # a6->r9; the result is in rax; the `syscall` insn clobbers rcx, r11 and
        # memory.  The N+1 lowered operands [num, a1..aN] live on the use-list in
        # REVERSE (head = last).  Emit ONE tied input register per operand in ABI
        # order and read the result (rax) as an i64.
        sn: uint32 = sv_argn[v]
        sca: Array[8, uint32]
        sidx: int32 = cast[int32](sn) - 1
        snode: uint32 = sv_arg_head[v]
        while snode != 0:
            if sidx >= 0:
                sca[sidx] = arg_val[snode]
            sidx = sidx - 1
            snode = arg_next[snode]
        # i1 operands must be widened to i64 before the call (all inputs are i64).
        scat: Array[8, uint32]
        sci: uint32 = 0
        while sci < sn:
            scat[sci] = ll_coerce_i64(sca[sci])
            sci = sci + 1
        # AArch64: `svc #0`, number in x8, result in x0, only memory clobbered.
        # x86-64: `syscall`, number in rax, result in rax, rcx/r11/memory clobber.
        ll_put_result(v)
        ll_puts("call i64 asm sideeffect ")
        ll_putc(34)                       # '"'
        if cg_llvm_target != 0:
            ll_puts("svc #0")
        else:
            ll_puts("syscall")
        ll_putc(34)                       # '"'
        ll_puts(", ")
        ll_putc(34)                       # '"'
        if cg_llvm_target != 0:
            ll_puts("={x0}")              # aarch64: result in x0
        else:
            ll_puts("={rax}")             # x86-64: result in rax
        sci = 0
        while sci < sn:
            ll_puts(",{")                 # one input register per operand
            ll_put_syscall_reg(sci)
            ll_putc(125)                  # '}'
            sci = sci + 1
        if cg_llvm_target != 0:
            ll_puts(",~{memory}")
        else:
            ll_puts(",~{rcx},~{r11},~{memory}")
        ll_putc(34)                       # '"'
        ll_putc(40)                       # '('
        sci = 0
        while sci < sn:
            if sci > 0:
                ll_puts(", ")
            ll_puts("i64 ")
            # Operand 0 is the syscall NUMBER.  On aarch64 remap a literal x86-64
            # Linux number to its asm-generic aarch64 number (write 1->64, etc.);
            # a non-constant number is passed through as-is (rare — the runtime
            # always uses a literal nr).
            if sci == 0 and cg_llvm_target != 0 and sv_op[sca[0]] == SVO_CONST:
                ll_put_i64(cast[uint64](ll_aarch64_syscall_nr(cast[int64](sv_imm[sca[0]]))))
            else:
                ll_put_operand_ct(sca[sci], scat[sci])
            sci = sci + 1
        ll_puts(")\n")
        return

    if op == SVO_CALL:
        callnode: uint32 = sv_ast[v]
        callee: uint32 = nd_a[callnode]
        n: uint32 = sv_argn[v]
        # operands live on the use-list in REVERSE (head = last arg); un-reverse.
        # Cap 32 args (SysV allows unlimited via the stack; LLVM lowers them all).
        ca: Array[32, uint32]
        idx: int32 = cast[int32](n) - 1
        node: uint32 = sv_arg_head[v]
        while node != 0:
            if idx >= 0:
                ca[idx] = arg_val[node]
            idx = idx - 1
            node = arg_next[node]
        # Pre-coerce any i1 args to i64 (declares/defines carry i64 params); the
        # zext lines must precede the `call`.
        cat: Array[32, uint32]
        ci: uint32 = 0
        while ci < n:
            cat[ci] = ll_coerce_i64(ca[ci])
            ci = ci + 1
        # INDIRECT call: sv_b holds the fn-pointer VALUE (i64).  Convert it to a
        # `ptr` and call through it; a DIRECT call names `@callee` instead.
        callind: uint32 = sv_b[v]
        fptr: uint32 = 0
        if callind != 0:
            fptr = ll_new_tmp()
            ll_puts("  ")
            ll_put_tmp(fptr)
            ll_puts(" = inttoptr i64 ")
            ll_put_operand(callind)
            ll_puts(" to ptr\n")
        ll_put_result(v)
        ll_puts("call ")
        ll_put_vty(v)                     # call result type (i64 or float/double)
        if callind != 0:
            ll_putc(32)                   # ' '
            ll_put_tmp(fptr)
        else:
            ll_puts(" @")
            ll_put_name(nd_name_off[callee], nd_name_len[callee])
        ll_putc(40)                       # '('
        i: uint32 = 0
        while i < n:
            if i > 0:
                ll_puts(", ")
            if cat[i] != 0:
                ll_puts("i64 ")           # coerced i1 -> i64
            else:
                ll_put_vty(ca[i])         # argument type (i64 or float/double)
                ll_putc(32)
            ll_put_operand_ct(ca[i], cat[i])
            i = i + 1
        ll_puts(")\n")
        return

    if op == SVO_BR:
        ll_puts("  br label %bb")
        ll_put_u32(sv_a[v])
        ll_putc(10)
        return

    if op == SVO_CONDBR:
        cond: uint32 = sv_a[v]
        if llvm_is_i1(cond) == 0:
            t: uint32 = ll_new_tmp()
            ll_puts("  ")
            ll_put_tmp(t)
            ll_puts(" = icmp ne i64 ")
            ll_put_operand(cond)
            ll_puts(", 0\n")
            ll_puts("  br i1 ")
            ll_put_tmp(t)
        else:
            ll_puts("  br i1 ")
            ll_put_operand(cond)
        ll_puts(", label %bb")
        ll_put_u32(sv_b[v])
        ll_puts(", label %bb")
        ll_put_u32(sv_c[v])
        ll_putc(10)
        return

    if op == SVO_RET:
        if sv_a[v] == 0:
            # implicit / void tail return: match the function's declared type.
            ll_puts("  ret ")
            ll_put_svty(llvm_ret_svt)
            if llvm_ret_svt == SVT_F32 or llvm_ret_svt == SVT_F64:
                ll_puts(" 0.0\n")
            else:
                ll_puts(" 0\n")
        elif llvm_ret_svt == SVT_F32 or llvm_ret_svt == SVT_F64:
            ll_puts("  ret ")
            ll_put_vty(sv_a[v])
            ll_putc(32)
            ll_put_operand(sv_a[v])
            ll_putc(10)
        else:
            # non-float function returns the canonical i64; coerce an i1 result.
            rt: uint32 = ll_coerce_i64(sv_a[v])
            ll_puts("  ret i64 ")
            ll_put_operand_ct(sv_a[v], rt)
            ll_putc(10)
        return

    if op == SVO_PHI:
        ll_put_result(v)
        ll_puts("phi ")
        ll_put_vty(v)
        ll_putc(32)
        node: uint32 = sv_arg_head[v]
        first: uint32 = 1
        while node != 0:
            pred: uint32 = arg_pred[node]
            # Drop operands whose predecessor block is unreachable (never emitted
            # a label) — LLVM requires phi predecessors to be real CFG preds.
            if pred < LL_BB_MAX and llvm_bb_live[pred] != 0:
                if first == 0:
                    ll_puts(", ")
                first = 0
                ll_puts("[ ")
                ll_put_operand(arg_val[node])
                ll_puts(", %bb")
                ll_put_u32(pred)
                ll_puts(" ]")
            node = arg_next[node]
        ll_putc(10)
        return


# =======================================================================
# per-function emission
# =======================================================================
def llvm_emit_function(fn: uint32, entry: uint32):
    # Return type: a float-returning function is `define double`/`define float`;
    # everything else stays the canonical i64.
    rfw: uint32 = type_float_width(nd_b[fn])
    if rfw == 4:
        llvm_ret_svt = SVT_F32
    elif rfw == 8:
        llvm_ret_svt = SVT_F64
    else:
        llvm_ret_svt = 0                  # i64 (SVT_VOID id renders as i64)
    ll_puts("define ")
    ll_put_svty(llvm_ret_svt)
    ll_puts(" @")
    ll_put_name(nd_name_off[fn], nd_name_len[fn])
    ll_putc(40)                           # '('
    # parameters: collect SVO_PARAM values from the entry block by param index.
    pv: Array[32, uint32]
    pcount: uint32 = 0
    cur: uint32 = sb_first_val[entry]
    while cur != 0:
        if sv_op[cur] == SVO_PARAM:
            ai: uint32 = sv_aux[cur]
            if ai < 32:
                pv[ai] = cur
                if ai + 1 > pcount:
                    pcount = ai + 1
        cur = sv_next[cur]
    i: uint32 = 0
    while i < pcount:
        if i > 0:
            ll_puts(", ")
        ll_put_vty(pv[i])                 # param type (i64 or float/double)
        ll_puts(" %v")
        ll_put_u32(pv[i])
        i = i + 1
    ll_puts(") {\n")

    llvm_tmp = 1
    ssa_build_domtree()                   # populates sb_rpo (entry first)
    # Mark the reachable (emitted) blocks so phi emission can drop operands from
    # orphaned/unreachable predecessors (which get no label in the output).
    lb: uint32 = 0
    while lb < LL_BB_MAX:
        llvm_bb_live[lb] = 0
        lb = lb + 1
    bl: uint32 = 0
    while bl < sb_rpo_n:
        rb: uint32 = sb_rpo[bl]
        if rb < LL_BB_MAX:
            llvm_bb_live[rb] = 1
        bl = bl + 1
    bi: uint32 = 0
    while bi < sb_rpo_n:
        bb: uint32 = sb_rpo[bi]
        ll_puts("bb")
        ll_put_u32(bb)
        ll_puts(":\n")
        v: uint32 = sb_first_val[bb]
        while v != 0:
            llvm_emit_value(v)
            v = sv_next[v]
        bi = bi + 1
    ll_puts("}\n\n")


# =======================================================================
# program driver
# =======================================================================
def llvm_emit_program(prog: uint32):
    llvm_out_len = 0
    dn_count = 0
    ce_count = 0
    fa_count = 0
    llvm_stat_funcs = 0
    llvm_stat_emitted = 0
    llvm_stat_bailed = 0
    llvm_tpidr_meta_done = 0
    if prog == 0:
        return
    # The LLVM backend models LOCAL MEMORY (address-taken scalars, local arrays,
    # pointer deref) as alloca + load/store — LLVM's own mem2reg promotes them.
    # This gate is OFF for the native --opt path, which keeps those functions
    # bailing (byte-identical).
    ssa_mem_model = 1
    # Populate the codegen globals/enum/class tables so the SSA global-array /
    # scalar-global paths resolve (mirrors gen_program_with_globals' prefix, but
    # never emits code).
    cg_init()
    # Kernel-target percpu recognition: layout_globals only classifies a
    # `Percpu[T]` global (glob_is_percpu, %gs template offset) when
    # cg_target_kernel != 0.  The native ELF lane sets this from the target
    # flag AFTER the want_llvm early-return, so the LLVM lane must set it here
    # or every percpu global would be laid out as an ordinary RIP-relative
    # global and read/written with an ABSOLUTE load/store — a SILENT MISCOMPILE
    # (%gs-relative slot read from the wrong linear address).  This is inert for
    # NON-kernel LLVM builds: apps declare no `Percpu[T]`, so no global changes
    # class, and cg_target_kernel is read nowhere else on the LLVM lane's
    # cg_init/layout_classes/register_enums/layout_globals path.  The native
    # path never runs llvm_emit_program, so codegen.ad byte output is unchanged.
    cg_target_kernel = 1
    cg_prog_decls = nd_b[prog]
    ssa_prog_decls = nd_b[prog]
    layout_classes(prog)
    register_enums(prog)
    layout_globals(prog)

    ll_puts("target triple = ")
    ll_putc(34)
    if cg_llvm_target != 0:
        ll_puts("aarch64-unknown-linux-gnu")
    else:
        ll_puts("x86_64-pc-linux-gnu")
    ll_putc(34)
    ll_puts("\n\n")

    # Pass A: discover accepted (defined) functions + their call targets.
    cur: uint32 = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            entry: uint32 = ssa_build_function(cur)
            if entry != 0 and ssa_bail == 0:
                llvm_record_defined(nd_name_off[cur], nd_name_len[cur])
                llvm_collect_callees()
        cur = nd_next[cur]

    llvm_emit_globals()
    llvm_emit_declares()

    # Pass B: rebuild + emit each function (SSA build is pure/deterministic).
    cur = nd_b[prog]
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            llvm_stat_funcs = llvm_stat_funcs + 1
            entry2: uint32 = ssa_build_function(cur)
            if entry2 != 0 and ssa_bail == 0:
                llvm_emit_function(cur, entry2)
                llvm_stat_emitted = llvm_stat_emitted + 1
            else:
                llvm_stat_bailed = llvm_stat_bailed + 1
                ll_puts("; BAILED @")
                ll_put_name(nd_name_off[cur], nd_name_len[cur])
                ll_puts(" reason=")
                ll_put_u32(ssa_bail_reason)
                ll_putc(10)
        cur = nd_next[cur]

    # AArch64 per-CPU base plumbing: if any percpu access emitted a
    # `llvm.read_register.i64(metadata !0)` (TPIDR_EL1 base read), declare the
    # intrinsic and define the named-register metadata at module scope.  Module-
    # level declares/metadata after the function bodies are valid LLVM textual IR,
    # and metadata `!0` is forward-referenced from the function bodies (resolved
    # after parse).  Emitted only when actually used, so a percpu-free aarch64
    # module (e.g. a user app) stays clean.
    if cg_llvm_target != 0 and llvm_tpidr_meta_done != 0:
        ll_puts("declare i64 @llvm.read_register.i64(metadata)\n")
        ll_puts("!llvm.named.register.tpidr_el1 = !{!0}\n")
        ll_puts("!0 = !{!")
        ll_putc(34)                       # '"'
        ll_puts("tpidr_el1")
        ll_putc(34)                       # '"'
        ll_puts("}\n")

    ll_puts("; ADDER_STAT funcs=")
    ll_put_u32(llvm_stat_funcs)
    ll_puts(" emitted=")
    ll_put_u32(llvm_stat_emitted)
    ll_puts(" bailed=")
    ll_put_u32(llvm_stat_bailed)
    ll_putc(10)

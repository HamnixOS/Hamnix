# adder/compiler/codegen_elf_selftest.ad
#
# Self-hosting milestone — ELF EMIT phase (on-device).
#
# Drives the full Adder-in-Adder pipeline on the device:
#   1. lex   (lexer.ad)   a small REAL Adder program,
#   2. parse (parser.ad)  it into an AST,
#   3. codegen (codegen.ad) emits x86_64 machine-code bytes,
#   4. elf_emit (elf_emit.ad) wraps those bytes in a complete, loadable
#      elf32-i386 user ELF image (the exact format user/init.lds emits
#      and fs/elf.ad's ELFCLASS32 path loads), with a self-contained
#      _start stub that calls the compiled entry at vaddr 0 and exits
#      with its return value.
#
# It then dumps the emitted ELF image to stdout as hex, bracketed by
# machine-readable sentinels. The host harness (scripts/test_selfhost_elf.sh)
# captures the hex between the sentinels, reconstructs the ELF into
# build/user/selfhost_emitted.elf (which build_initramfs.py auto-stages at
# /bin/selfhost_emitted), rebuilds, and in a SECOND QEMU boot EXECs the
# binary natively at CPL-3 — closing the emulator -> native gap.
#
# The compiled program is:
#
#   def main() -> int32:
#       acc: int32 = 0
#       i: int32 = 65
#       while i <= 90:
#           acc = acc + classify(i)
#           i = i + 1
#       return acc
#   def classify(c: int32) -> int32:
#       if c >= 65 and c <= 90:
#           return 1
#       return 0
#
# main() counts how many of 'A'..'Z' (65..90) are upper-case letters
# (all 26 of them), exercising a real while-loop, an inter-function
# call resolved by codegen's call-fixup table, >=/<= comparisons, a
# logical `and`, and integer arithmetic. main() is emitted FIRST so it
# sits at code vaddr 0 — the address the _start stub calls. The expected
# native process exit code is therefore 26.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       adder/compiler/codegen_elf_selftest.ad \
#       -o build/user/codegen_elf_selftest.elf

from compiler.lexer import (
    lex_init,
    lex_tokenize,
)

from compiler.parser import (
    parser_init,
    parse_program,
    p_err,
    nd_kind,
    nd_b,
    nd_next,
    ND_FUNCTION,
)

from compiler.codegen import (
    cg_init,
    cg_err,
    code_len,
    gen_program_with_globals,
    gdata_len,
    fn_count,
    CODE_CAP,
)

from compiler.elf_emit import (
    elf_emit_image,
    elf_buf,
    elf_len,
    elf_err,
    elf_entry_vaddr,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def put_u32(v: uint32):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


# Map a 0..15 nibble to its lowercase hex ASCII digit.
def hex_digit(v: uint32) -> uint32:
    if v < 10:
        return v + 48          # '0'..'9'
    return v + 87              # 'a'..'f'


# Dump elf_buf[0..elf_len) as one continuous lowercase-hex stream,
# wrapped at 64 hex chars (32 bytes) per line for sane serial capture.
def dump_hex():
    line: Array[80, uint8]
    col: uint32 = 0
    i: uint32 = 0
    while i < elf_len:
        b: uint32 = cast[uint32](elf_buf[i])
        line[col] = cast[uint8](hex_digit((b >> 4) & 15))
        col = col + 1
        line[col] = cast[uint8](hex_digit(b & 15))
        col = col + 1
        if col >= 64:
            line[col] = 10        # '\n'
            sys_write(1, &line[0], cast[uint64](col + 1))
            col = 0
        i = i + 1
    if col > 0:
        line[col] = 10
        sys_write(1, &line[0], cast[uint64](col + 1))


def main() -> int32:
    emit("[selfhost_elf_emit] start\n")

    # The REAL Adder program compiled by the self-hosted backend. main()
    # is FIRST (code vaddr 0). classify() is a forward inter-function
    # call resolved by codegen's fixup table.
    src: Ptr[uint8] = "def main() -> int32:\n    acc: int32 = 0\n    i: int32 = 65\n    while i <= 90:\n        acc = acc + classify(i)\n        i = i + 1\n    return acc\ndef classify(c: int32) -> int32:\n    if c >= 65 and c <= 90:\n        return 1\n    return 0\n"
    n: uint32 = cast[uint32](strlen(src))

    lex_init(src, n)
    lex_tokenize()

    parser_init()
    prog: uint32 = parse_program()
    if p_err != 0:
        emit("[selfhost_elf_emit] FAIL: parse error\n")
        sys_exit(2)

    # Both functions must be FUNCTION declarations.
    decls: uint32 = nd_b[prog]
    if nd_kind[decls] != ND_FUNCTION:
        emit("[selfhost_elf_emit] FAIL: first decl not a function\n")
        sys_exit(3)

    cg_init()
    start: uint32 = gen_program_with_globals(prog)
    if cg_err != 0:
        emit("[selfhost_elf_emit] FAIL: codegen error\n")
        sys_exit(4)
    if start != 0:
        emit("[selfhost_elf_emit] FAIL: entry not at offset 0\n")
        sys_exit(5)
    if fn_count != 2:
        emit("[selfhost_elf_emit] FAIL: fn_count != 2\n")
        sys_exit(6)

    emit("[selfhost_elf_emit] codegen ok: ")
    put_u32(fn_count)
    emit(" funcs, code_len=")
    put_u32(code_len)
    emit(" gdata_len=")
    put_u32(gdata_len)
    emit("\n")

    # Wrap the emitted code/data buffers into a complete user ELF. The
    # entry arg is irrelevant (main takes no params) — pass 0.
    total: uint32 = elf_emit_image(0)
    if elf_err != 0 or total == 0:
        emit("[selfhost_elf_emit] FAIL: ELF emit error\n")
        sys_exit(7)

    emit("[selfhost_elf_emit] elf ok: bytes=")
    put_u32(elf_len)
    emit(" entry_vaddr=")
    put_u32(elf_entry_vaddr)
    emit(" code_cap=")
    put_u32(CODE_CAP)
    emit("\n")

    # Emit the image as hex, bracketed by host-capturable sentinels.
    emit("[selfhost_elf_emit] HEXBEGIN\n")
    dump_hex()
    emit("[selfhost_elf_emit] HEXEND\n")
    emit("[selfhost_elf_emit] PASS\n")
    return 0

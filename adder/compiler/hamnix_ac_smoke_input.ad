# adder/compiler/hamnix_ac_smoke_input.ad
#
# Smoke-test input for scripts/hamnix-ac. A small but REAL Adder program
# the on-device self-hosted compiler turns into a native ELF. main() is
# declared FIRST so it sits at code vaddr 0 (the address the elf_emit
# _start stub calls), and returns a distinctive exit code 42 so the smoke
# test can assert "compiled-then-natively-executed" end to end.
#
#   sumto(n) = 1 + 2 + ... + n            -> sumto(8)  == 36
#   triple(x) = x + x + x                 -> triple(2)  == 6
#   main() = sumto(8) + triple(2)         -> 36 + 6     == 42
#
# Exercises: a while-loop with accumulation, two inter-function calls
# resolved by codegen's call-fixup table (FORWARD references — main()
# calls sumto/triple declared after it), integer add, and a <=
# comparison — i.e. the same backend features the existing self-host
# tests cover, but supplied as a host FILE rather than a baked snippet.

def main() -> int32:
    return sumto(8) + triple(2)


def sumto(n: int32) -> int32:
    acc: int32 = 0
    i: int32 = 1
    while i <= n:
        acc = acc + i
        i = i + 1
    return acc


def triple(x: int32) -> int32:
    return x + x + x

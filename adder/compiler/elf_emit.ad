# adder/compiler/elf_emit.ad
#
# Self-hosted ELF32 image emitter for the Adder-in-Adder x86_64 backend.
#
# codegen.ad (lexer.ad -> parser.ad -> codegen.ad) emits raw x86_64
# machine-code bytes into two fixed in-memory buffers:
#   * code[0..code_len)   — the code region, conceptually at virtual 0.
#   * gdata[0..gdata_len)  — the data region, conceptually at virtual
#     base DATA_BASE (== CODE_CAP == 8192), i.e. exactly CODE_CAP bytes
#     after code start. codegen's RIP-relative data fixups encode
#     disp32 = (DATA_BASE + data_off) - rip_field_end, so the data
#     region MUST sit exactly CODE_CAP bytes after code start in the
#     loaded image or every global access is misaddressed.
#
# This module turns those buffers into a complete, loadable
# `x86_64-adder-user` ELF image (an elf32-i386 wrapper around 64-bit
# code — the exact format user/init.lds produces and fs/elf.ad's
# ELFCLASS32 path loads). The kernel loader (fs/elf.ad _load_elf*) for
# the ELF32 class allocates one contiguous region of size
# max(p_vaddr + p_memsz), copies each PT_LOAD segment to
# region + (p_vaddr - lowest_v), and jumps to region + (e_entry -
# lowest_v). Because lowest_v == 0 here, the in-image virtual offsets
# (code at 0, data at CODE_CAP) are preserved verbatim after the rebase
# — so codegen's RIP-relative displacements stay correct on device.
#
# Image layout (single PT_LOAD, vaddr base 0):
#
#   vaddr 0 .............. code[0..code_len)         compiled program
#   vaddr code_len ....... _start stub (hand-emitted machine code)
#   vaddr CODE_CAP ....... gdata[0..gdata_len)        global data section
#
# The compiled program's ENTRY function is resolved BY NAME by codegen
# (cg_entry_off: prefers a function named `main`, else the first emitted
# function). It is NOT assumed to be at vaddr 0 — the real compiler source
# begins with global declarations, so `main` may sit at any code offset.
# e_entry points at the _start stub, NOT at the entry: _start sets the
# entry's first arg in %rdi, `call`s the entry at vaddr cg_entry_off, then
# issues SYS_EXIT with the entry's return value (%rax -> %rdi) so the
# process terminates cleanly with an observable exit status. This keeps the
# emitted ELF self-contained (no runtime.S link step needed).

from compiler.codegen import (
    code,
    code_len,
    gdata,
    gdata_len,
    bss_len,
    CODE_CAP,
    cg_entry_off,
)

# -----------------------------------------------------------------------
# Output ELF image buffer.
#
# Two-PT_LOAD layout (NO file padding to CODE_CAP): the file holds only
# the ELF header + program headers + the actual compiled code (+ _start
# stub) + the initialised data (gdata). The .bss tail is memsz-only and is
# NOT stored.
#
# Sized for the WHOLE TREE (CAP#3): the largest stored image is the KERNEL,
# whose code[] (~4 MB) + gdata[] (.data) must fit alongside the headers.
# 24 MiB leaves headroom above CODE_CAP (16 MiB) + GDATA_CAP (4 MiB). This
# buffer is zero-init (.bss) so the size costs memsz only, not file bytes in
# host_ac.elf. (Userland units are tiny — a few KiB — and use only the head.)
# -----------------------------------------------------------------------
ELF_BUF_CAP: uint32 = 25165824
elf_buf: Array[25165824, uint8]
elf_len: uint32 = 0

# Error flag (set on overflow). The caller checks this after emit.
elf_err: uint32 = 0

# The byte offset within elf_buf where the FIRST loadable segment's bytes
# begin (file offset of the code PT_LOAD). ELF header (52) + two program
# headers (2*32 = 64) = 116. The data PT_LOAD's bytes follow the code
# segment's bytes contiguously in the file.
ELF_SEG_FILE_OFF: uint32 = 116

# The _start stub's virtual address (== its offset within the segment,
# since the segment's vaddr base is 0). Recorded by elf_emit_image so a
# test can assert e_entry. Placed right after the compiled code.
elf_entry_vaddr: uint32 = 0


def elf_reset():
    elf_len = 0
    elf_err = 0
    elf_entry_vaddr = 0


# Append one byte to the ELF image buffer.
def eb(b: uint32):
    if elf_len >= ELF_BUF_CAP:
        elf_err = 1
        return
    elf_buf[elf_len] = cast[uint8](b & 255)
    elf_len = elf_len + 1


# Append a little-endian uint16 at the current position.
def eb16(v: uint32):
    eb(v & 255)
    eb((v >> 8) & 255)


# Append a little-endian uint32 at the current position.
def eb32(v: uint32):
    eb(v & 255)
    eb((v >> 8) & 255)
    eb((v >> 16) & 255)
    eb((v >> 24) & 255)


# Overwrite a little-endian uint32 already present at byte offset `at`.
def patch32(at: uint32, v: uint32):
    elf_buf[at] = cast[uint8](v & 255)
    elf_buf[at + 1] = cast[uint8]((v >> 8) & 255)
    elf_buf[at + 2] = cast[uint8]((v >> 16) & 255)
    elf_buf[at + 3] = cast[uint8]((v >> 24) & 255)


# -----------------------------------------------------------------------
# Output ELF FORMAT selection (CAP#3).
#
# The seed (`compiler/adder.py`) selects the output ELF shape by `--target`:
#   * x86_64-adder-user / x86_64-linux  -> a self-contained user ELF (the
#     `ld`-against-runtime.S shape). elf_emit_image() below emits this; the
#     cap#1 in-`.ad` runtime library already synthesizes the `sys_*` wrapper
#     bodies into code[], so no external runtime.S link is needed and this
#     IS behaviourally the seed's userland output (proven by the whole-tree +
#     extern-link gates).
#   * x86_64-bare-metal -> the higher-half KERNEL ELF: a multiboot1 header +
#     the low boot region (VMA==LMA @ 0x100000: header.S's 32-bit stub +
#     gdt64 + pgtables + boot stack) + the high-half region (VMA at
#     0xffffffff80000000+, LMA low via AT(): head_64.S's 64-bit entry +
#     start_kernel call + the compiled-Adder .text/.rodata/.data..percpu/
#     .data + the AP trampoline @0x8000 + NOBITS .bss), exactly as
#     arch/x86/kernel/kernel.lds places them. See elf_emit_image_kernel().
#
# These constants name the formats; the driver passes the selected one.
# -----------------------------------------------------------------------
ELF_FMT_USER: uint32 = 0          # x86_64-adder-user / x86_64-linux
ELF_FMT_KERNEL: uint32 = 1        # x86_64-bare-metal

# Distinct elf_err codes so the driver can diagnose the failure precisely.
ELF_ERR_OVERFLOW: uint32 = 1      # ran past ELF_BUF_CAP / CODE_CAP
ELF_ERR_KERNEL_UNSUPPORTED: uint32 = 2   # kernel format prerequisites unmet


# Target-dispatching entry point. `target` selects ELF_FMT_USER (the
# self-contained user shape, the only one userland units need) or
# ELF_FMT_KERNEL (the bare-metal higher-half kernel image). Returns the
# emitted image length, or 0 on error (elf_err set to a distinct code).
def elf_emit_image_target(entry_arg: uint32, target: uint32) -> uint32:
    if target == ELF_FMT_KERNEL:
        return elf_emit_image_kernel()
    return elf_emit_image(entry_arg)


# -----------------------------------------------------------------------
# CAP#3 — bare-metal KERNEL ELF emitter (x86_64-bare-metal).
#
# Reproduces the seed's `ld`-against-kernel.lds layout. The seed links THREE
# inputs: arch/x86/boot/header.S (.head.text multiboot header + 32-bit
# long-mode-transition stub, .boot.text/.boot.data/.pgtables/.boot.bss),
# arch/x86/kernel/head_64.S (.text: start_kernel_asm_entry -> `call
# start_kernel`, plus kernel_image_end/text bounds/read_rbp), and the
# compiled-Adder kernel object (.text/.rodata/.data..percpu/.data/.bss),
# all placed by arch/x86/kernel/kernel.lds:
#   LOW region  @ 0x100000        VMA==LMA: .head.text .boot.text .boot.data
#                                 .pgtables(NOBITS) .boot.bss(NOBITS)
#   HIGH region @ 0xffffffff80100000+  VMA!=LMA (LMA continues low via AT()):
#                                 .text .rodata .data..percpu .data
#                                 .ap_trampoline(VMA 0x8000) .bss(NOBITS)
#   ENTRY = _start (in .head.text, a LOW 32-bit address).
#
# WHAT THIS EMITTER STILL NEEDS (precise cap#3b / cap#4 prerequisites — the
# kernel CANNOT yet reach this function, so emitting a partial/guessed image
# would be unvalidatable dead code; we instead fail with a clear code):
#
#   (a) The boot-stub MACHINE CODE. header.S + head_64.S are hand-written
#       GNU-as AT&T assembly the seed routes through `as`/`ld`. codegen.ad
#       emits NONE of it (it lowers Adder source only). The kernel ELF's
#       .head.text/.boot.text/.boot.data/head_64-.text bytes + the
#       cross-references (head_64 `call start_kernel`; the Adder code's calls
#       to kernel_image_end/read_rbp/kernel_text_*; header.S's R_X86_64_64
#       `movabsq $start_kernel_asm_entry`) must all be materialised and
#       resolved here — work that today lives in `as`/`ld`.
#   (b) codegen.ad SECTION support. The user format flattens everything into
#       one code[]+gdata[] pair at vaddr 0 / CODE_CAP. The kernel needs the
#       distinct .rodata, .data..percpu (%gs-relative, its own VMA), and the
#       high-half VMA(0xffffffff80...)/low-LMA split with per-section AT(),
#       plus the __bss_start/__bss_end symbols head_64.S's rep-stosq reads.
#       codegen.ad emits no per-section streams today.
#   (c) The kernel must first COMPILE: it is blocked in codegen at the
#       pervasive `cast[Ptr[T]](e)[i] = v` / `... = cast[Ptr[T]](e)[i]`
#       raw-memory idiom (915 store + 634 load sites — reason-8 / CAP#4),
#       so neither code[] nor gdata[] is ever produced for the kernel.
#
# Until (a)+(b) land (and CAP#4 unblocks the compile), this returns 0 with
# elf_err = ELF_ERR_KERNEL_UNSUPPORTED so the driver reports the precise
# blocker instead of silently emitting a USER-shaped ELF for a kernel target
# (a latent mis-format bug). The multiboot/kernel.lds field layout above is
# the spec the emitter must match field-for-field once (a)+(b) are in place.
# -----------------------------------------------------------------------
def elf_emit_image_kernel() -> uint32:
    elf_reset()
    elf_err = ELF_ERR_KERNEL_UNSUPPORTED
    return 0


# -----------------------------------------------------------------------
# Build the complete ELF image into elf_buf[0..elf_len).
#
# `entry_arg` is the 32-bit value the _start stub loads into %edi before
# calling the compiled entry at vaddr 0. The compiled entry reads it as
# its first parameter (System-V: first arg in %rdi). For a no-arg `main`
# the value is simply ignored by the callee.
#
# Returns the total image length (elf_len), or 0 on overflow (elf_err
# is also set).
# -----------------------------------------------------------------------
def elf_emit_image(entry_arg: uint32) -> uint32:
    elf_reset()

    # The _start stub sits immediately after the compiled code, still
    # far below CODE_CAP (the program is tiny vs the 8 KiB window). Its
    # vaddr == its offset in the segment (segment vaddr base 0).
    start_vaddr: uint32 = code_len
    elf_entry_vaddr = start_vaddr

    # --- _start machine code (hand-assembled x86_64) --------------------
    # We assemble it into a tiny local buffer first so we know its exact
    # length and the call's rel32 displacement before laying out the
    # ELF (e_entry needs the stub vaddr; the segment file size needs the
    # stub length). The stub is:
    #
    #   BF <imm32>            mov    edi, entry_arg     ; first arg
    #   E8 <rel32>            call   entry              ; entry at vaddr 0
    #   48 89 C7             mov    rdi, rax           ; return -> exit code
    #   B8 01 00 00 00       mov    eax, 1             ; SYS_EXIT
    #   0F 05                syscall
    #   EB FE                jmp    .                  ; defensive spin
    #
    # The `call` is RIP-relative: rel32 = target - (addr_of_field + 4),
    # where target = 0 (entry vaddr) and addr_of_field is the vaddr of
    # the rel32 immediate. The stub begins at start_vaddr; the `mov edi`
    # is 5 bytes (1 opcode + 4 imm), so the call opcode is at
    # start_vaddr + 5, its rel32 field at start_vaddr + 6, and the field
    # end at start_vaddr + 10.
    stub: Array[32, uint8]
    sn: uint32 = 0

    # mov edi, entry_arg
    stub[sn] = 0xBF
    sn = sn + 1
    stub[sn] = cast[uint8](entry_arg & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((entry_arg >> 8) & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((entry_arg >> 16) & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((entry_arg >> 24) & 255)
    sn = sn + 1

    # call rel32 -> entry at vaddr cg_entry_off. The entry is resolved BY
    # NAME by codegen (prefers `main`, else the first emitted function), so
    # the entry function need NOT be the source-first function. rel32 =
    # cg_entry_off - field_end, as an unsigned 32-bit two's complement value.
    field_end: uint32 = start_vaddr + 10
    rel: uint32 = cg_entry_off - field_end
    stub[sn] = 0xE8
    sn = sn + 1
    stub[sn] = cast[uint8](rel & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((rel >> 8) & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((rel >> 16) & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((rel >> 24) & 255)
    sn = sn + 1

    # mov rdi, rax  (REX.W 89 /r, modrm C7 = rax->rdi)
    stub[sn] = 0x48
    sn = sn + 1
    stub[sn] = 0x89
    sn = sn + 1
    stub[sn] = 0xC7
    sn = sn + 1

    # mov eax, 1   (SYS_EXIT)
    stub[sn] = 0xB8
    sn = sn + 1
    stub[sn] = 0x01
    sn = sn + 1
    stub[sn] = 0x00
    sn = sn + 1
    stub[sn] = 0x00
    sn = sn + 1
    stub[sn] = 0x00
    sn = sn + 1

    # syscall
    stub[sn] = 0x0F
    sn = sn + 1
    stub[sn] = 0x05
    sn = sn + 1

    # jmp . (EB FE) defensive spin if SYS_EXIT ever returns
    stub[sn] = 0xEB
    sn = sn + 1
    stub[sn] = 0xFE
    sn = sn + 1

    stub_len: uint32 = sn

    # --- Segment sizing -------------------------------------------------
    # TWO PT_LOAD segments (no file padding to CODE_CAP):
    #   code PT_LOAD : vaddr 0, file bytes = code_len + stub_len
    #       code  : [0, code_len)
    #       _start: [code_len, code_len + stub_len)
    #   data PT_LOAD : vaddr CODE_CAP, file bytes = gdata_len (.data),
    #       memsz = gdata_len + bss_len (.bss tail is memsz-only; the
    #       loader zeroes the whole p_memsz span before copying p_filesz).
    # The code segment must still fit below CODE_CAP so the data segment's
    # vaddr (CODE_CAP) sits above it — the RIP-relative addressing
    # invariant (data at virtual CODE_CAP) is preserved by the segment
    # VADDRs, not by file padding.
    if code_len + stub_len > CODE_CAP:
        elf_err = 1
        return 0

    code_seg_filesz: uint32 = code_len + stub_len
    code_seg_memsz: uint32 = code_seg_filesz
    data_seg_filesz: uint32 = gdata_len
    data_seg_memsz: uint32 = gdata_len + bss_len

    # File offset where the data segment's bytes begin: right after the
    # code segment's bytes (which start at ELF_SEG_FILE_OFF).
    data_file_off: uint32 = ELF_SEG_FILE_OFF + code_seg_filesz

    # --- ELF32 header (52 bytes) ----------------------------------------
    # e_ident
    eb(0x7F)          # EI_MAG0
    eb(69)            # 'E'
    eb(76)            # 'L'
    eb(70)            # 'F'
    eb(1)             # EI_CLASS = ELFCLASS32 (fs/elf.ad ELF32 path)
    eb(1)             # EI_DATA  = ELFDATA2LSB (little-endian)
    eb(1)             # EI_VERSION = EV_CURRENT
    eb(0)             # EI_OSABI = ELFOSABI_SYSV (native, not Linux)
    eb(0)             # EI_ABIVERSION
    eb(0)             # EI_PAD..
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb16(2)           # e_type = ET_EXEC
    eb16(3)           # e_machine = EM_386 (matches the elf32-i386 wrapper)
    eb32(1)           # e_version = EV_CURRENT
    # e_entry: the _start stub's vaddr. fs/elf.ad ELF32 path returns
    # region + (e_entry - lowest_v); lowest_v == 0 so the stub runs at
    # its in-image vaddr offset.
    eb32(elf_entry_vaddr)
    eb32(52)          # e_phoff = right after the 52-byte ELF header
    eb32(0)           # e_shoff = 0 (no section headers; loader ignores)
    eb32(0)           # e_flags
    eb16(52)          # e_ehsize
    eb16(32)          # e_phentsize (elf32 program header size)
    eb16(2)           # e_phnum = 2 (code PT_LOAD + data PT_LOAD)
    eb16(0)           # e_shentsize
    eb16(0)           # e_shnum
    eb16(0)           # e_shstrndx

    # --- Program header 1: code PT_LOAD (vaddr 0, 32 bytes) -------------
    eb32(1)                 # p_type = PT_LOAD
    eb32(ELF_SEG_FILE_OFF)  # p_offset = file offset of the code segment
    eb32(0)                 # p_vaddr = 0 (base; loader rebases by lowest_v)
    eb32(0)                 # p_paddr
    eb32(code_seg_filesz)   # p_filesz = code + stub
    eb32(code_seg_memsz)    # p_memsz  = same (no .bss in the code segment)
    eb32(7)                 # p_flags = RWX (loader ignores per-seg flags here)
    eb32(4096)              # p_align

    # --- Program header 2: data PT_LOAD (vaddr CODE_CAP, 32 bytes) ------
    # .data is stored (p_filesz = gdata_len); the .bss tail is memsz-only
    # (p_memsz = gdata_len + bss_len > p_filesz). The loader zeroes the
    # whole p_memsz span before copying p_filesz bytes, so .bss is zeroed.
    eb32(1)                 # p_type = PT_LOAD
    eb32(data_file_off)     # p_offset = right after the code segment bytes
    eb32(CODE_CAP)          # p_vaddr = CODE_CAP (the RIP-data invariant)
    eb32(CODE_CAP)          # p_paddr
    eb32(data_seg_filesz)   # p_filesz = gdata_len (.data only)
    eb32(data_seg_memsz)    # p_memsz  = gdata_len + bss_len (.data + .bss)
    eb32(7)                 # p_flags = RWX
    eb32(4096)              # p_align

    # Sanity: header bytes must total ELF_SEG_FILE_OFF.
    if elf_len != ELF_SEG_FILE_OFF:
        elf_err = 1
        return 0

    # --- Segment payload ------------------------------------------------
    # 1) Compiled code at vaddr 0.
    ci: uint32 = 0
    while ci < code_len:
        eb(cast[uint32](code[ci]))
        ci = ci + 1

    # 2) _start stub at vaddr code_len.
    si: uint32 = 0
    while si < stub_len:
        eb(cast[uint32](stub[si]))
        si = si + 1

    # 3) Initialised data (.data) at vaddr CODE_CAP. Its file bytes follow
    #    the code segment's bytes directly (data_file_off). NO padding to
    #    CODE_CAP — the data segment's p_vaddr places it at CODE_CAP, and
    #    the .bss tail beyond gdata_len is loader-zeroed (memsz > filesz).
    gi: uint32 = 0
    while gi < gdata_len:
        eb(cast[uint32](gdata[gi]))
        gi = gi + 1

    if elf_err != 0:
        return 0

    return elf_len

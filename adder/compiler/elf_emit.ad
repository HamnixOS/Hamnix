# adder/compiler/elf_emit.ad
#
# Self-hosted ELF32 image emitter for the Adder-in-Adder x86_64 backend.
#
# codegen.ad (lexer.ad -> parser.ad -> codegen.ad) emits raw x86_64
# machine-code bytes into two fixed in-memory buffers:
#   * code[0..code_len)   — the code region, conceptually at virtual 0.
#   * gdata[0..gdata_len)  — the data region, conceptually at virtual
#     base DATA_BASE (== CODE_CAP == 8192), i.e. exactly CODE_CAP bytes
#     after code start. codegen's RIP-relative data fixups encode
#     disp32 = (DATA_BASE + data_off) - rip_field_end, so the data
#     region MUST sit exactly CODE_CAP bytes after code start in the
#     loaded image or every global access is misaddressed.
#
# This module turns those buffers into a complete, loadable
# `x86_64-adder-user` ELF image (an elf32-i386 wrapper around 64-bit
# code — the exact format user/init.lds produces and fs/elf.ad's
# ELFCLASS32 path loads). The kernel loader (fs/elf.ad _load_elf*) for
# the ELF32 class allocates one contiguous region of size
# max(p_vaddr + p_memsz), copies each PT_LOAD segment to
# region + (p_vaddr - lowest_v), and jumps to region + (e_entry -
# lowest_v). Because lowest_v == 0 here, the in-image virtual offsets
# (code at 0, data at CODE_CAP) are preserved verbatim after the rebase
# — so codegen's RIP-relative displacements stay correct on device.
#
# Image layout (single PT_LOAD, vaddr base 0):
#
#   vaddr 0 .............. code[0..code_len)         compiled program
#   vaddr code_len ....... _start stub (hand-emitted machine code)
#   vaddr CODE_CAP ....... gdata[0..gdata_len)        global data section
#
# The compiled program's ENTRY function is resolved BY NAME by codegen
# (cg_entry_off: prefers a function named `main`, else the first emitted
# function). It is NOT assumed to be at vaddr 0 — the real compiler source
# begins with global declarations, so `main` may sit at any code offset.
# e_entry points at the _start stub, NOT at the entry: _start sets the
# entry's first arg in %rdi, `call`s the entry at vaddr cg_entry_off, then
# issues SYS_EXIT with the entry's return value (%rax -> %rdi) so the
# process terminates cleanly with an observable exit status. This keeps the
# emitted ELF self-contained (no runtime.S link step needed).

from compiler.codegen import (
    code,
    code_len,
    gdata,
    gdata_len,
    bss_len,
    CODE_CAP,
    cg_entry_off,
    fn_name_off,
    fn_name_len,
    fn_offset,
    fn_count,
    ext_name_off,
    ext_name_len,
    ext_count,
    er_at,
    er_sym_idx,
    er_type,
    er_count,
    ER_PC32,
    ER_PLT32,
    df_at,
    df_data_off,
    df_is_bss,
    df_count,
    name_match,
    glob_name_off,
    glob_name_len,
    glob_offset,
    glob_is_percpu,
    glob_count,
    percpu_len,
)

from compiler.lexer import (
    strbuf,
)

# -----------------------------------------------------------------------
# Output ELF image buffer.
#
# Two-PT_LOAD layout (NO file padding to CODE_CAP): the file holds only
# the ELF header (52) + two program headers (2*32) + the actual compiled
# code (+ _start stub) + the initialised data (gdata). The .bss tail is
# memsz-only and is NOT stored, so even with CODE_CAP at 512 KiB the file
# stays small. 128 KiB comfortably covers code + initialised data.
# -----------------------------------------------------------------------
ELF_BUF_CAP: uint32 = 131072
elf_buf: Array[131072, uint8]
elf_len: uint32 = 0

# Error flag (set on overflow). The caller checks this after emit.
elf_err: uint32 = 0

# The byte offset within elf_buf where the FIRST loadable segment's bytes
# begin (file offset of the code PT_LOAD). ELF header (52) + two program
# headers (2*32 = 64) = 116. The data PT_LOAD's bytes follow the code
# segment's bytes contiguously in the file.
ELF_SEG_FILE_OFF: uint32 = 116

# The _start stub's virtual address (== its offset within the segment,
# since the segment's vaddr base is 0). Recorded by elf_emit_image so a
# test can assert e_entry. Placed right after the compiled code.
elf_entry_vaddr: uint32 = 0


def elf_reset():
    elf_len = 0
    elf_err = 0
    elf_entry_vaddr = 0


# Append one byte to the ELF image buffer.
def eb(b: uint32):
    if elf_len >= ELF_BUF_CAP:
        elf_err = 1
        return
    elf_buf[elf_len] = cast[uint8](b & 255)
    elf_len = elf_len + 1


# Append a little-endian uint16 at the current position.
def eb16(v: uint32):
    eb(v & 255)
    eb((v >> 8) & 255)


# Append a little-endian uint32 at the current position.
def eb32(v: uint32):
    eb(v & 255)
    eb((v >> 8) & 255)
    eb((v >> 16) & 255)
    eb((v >> 24) & 255)


# Overwrite a little-endian uint32 already present at byte offset `at`.
def patch32(at: uint32, v: uint32):
    elf_buf[at] = cast[uint8](v & 255)
    elf_buf[at + 1] = cast[uint8]((v >> 8) & 255)
    elf_buf[at + 2] = cast[uint8]((v >> 16) & 255)
    elf_buf[at + 3] = cast[uint8]((v >> 24) & 255)


# Append a little-endian uint64 (ELF64 fields). For the ET_REL kernel object.
def eb64(v: uint64):
    eb(cast[uint32](v & 255))
    eb(cast[uint32]((v >> 8) & 255))
    eb(cast[uint32]((v >> 16) & 255))
    eb(cast[uint32]((v >> 24) & 255))
    eb(cast[uint32]((v >> 32) & 255))
    eb(cast[uint32]((v >> 40) & 255))
    eb(cast[uint32]((v >> 48) & 255))
    eb(cast[uint32]((v >> 56) & 255))


# Overwrite a little-endian uint32 at offset `at` (ELF64 patch helper alias).
def patch64(at: uint32, v: uint64):
    elf_buf[at] = cast[uint8](v & 255)
    elf_buf[at + 1] = cast[uint8]((v >> 8) & 255)
    elf_buf[at + 2] = cast[uint8]((v >> 16) & 255)
    elf_buf[at + 3] = cast[uint8]((v >> 24) & 255)
    elf_buf[at + 4] = cast[uint8]((v >> 32) & 255)
    elf_buf[at + 5] = cast[uint8]((v >> 40) & 255)
    elf_buf[at + 6] = cast[uint8]((v >> 48) & 255)
    elf_buf[at + 7] = cast[uint8]((v >> 56) & 255)


# -----------------------------------------------------------------------
# Output ELF FORMAT selection (CAP#3).
#
# The seed (`compiler/adder.py`) selects the output ELF shape by `--target`:
#   * x86_64-adder-user / x86_64-linux  -> a self-contained user ELF (the
#     `ld`-against-runtime.S shape). elf_emit_image() below emits this; the
#     cap#1 in-`.ad` runtime library already synthesizes the `sys_*` wrapper
#     bodies into code[], so no external runtime.S link is needed and this
#     IS behaviourally the seed's userland output (proven by the whole-tree +
#     extern-link gates).
#   * x86_64-bare-metal -> the higher-half KERNEL ELF: a multiboot1 header +
#     the low boot region (VMA==LMA @ 0x100000: header.S's 32-bit stub +
#     gdt64 + pgtables + boot stack) + the high-half region (VMA at
#     0xffffffff80000000+, LMA low via AT(): head_64.S's 64-bit entry +
#     start_kernel call + the compiled-Adder .text/.rodata/.data..percpu/
#     .data + the AP trampoline @0x8000 + NOBITS .bss), exactly as
#     arch/x86/kernel/kernel.lds places them. See elf_emit_image_kernel().
#
# These constants name the formats; the driver passes the selected one.
# -----------------------------------------------------------------------
ELF_FMT_USER: uint32 = 0          # x86_64-adder-user / x86_64-linux
ELF_FMT_KERNEL: uint32 = 1        # x86_64-bare-metal

# Distinct elf_err codes so the driver can diagnose the failure precisely.
ELF_ERR_OVERFLOW: uint32 = 1      # ran past ELF_BUF_CAP / CODE_CAP
ELF_ERR_KERNEL_UNSUPPORTED: uint32 = 2   # kernel format prerequisites unmet


# Target-dispatching entry point. `target` selects ELF_FMT_USER (the
# self-contained user shape, the only one userland units need) or
# ELF_FMT_KERNEL (the bare-metal higher-half kernel image). Returns the
# emitted image length, or 0 on error (elf_err set to a distinct code).
def elf_emit_image_target(entry_arg: uint32, target: uint32) -> uint32:
    if target == ELF_FMT_KERNEL:
        return elf_emit_image_kernel()
    return elf_emit_image(entry_arg)


# -----------------------------------------------------------------------
# CAP#3 — bare-metal KERNEL ELF emitter (x86_64-bare-metal).
#
# Reproduces the seed's `ld`-against-kernel.lds layout. The seed links THREE
# inputs: arch/x86/boot/header.S (.head.text multiboot header + 32-bit
# long-mode-transition stub, .boot.text/.boot.data/.pgtables/.boot.bss),
# arch/x86/kernel/head_64.S (.text: start_kernel_asm_entry -> `call
# start_kernel`, plus kernel_image_end/text bounds/read_rbp), and the
# compiled-Adder kernel object (.text/.rodata/.data..percpu/.data/.bss),
# all placed by arch/x86/kernel/kernel.lds:
#   LOW region  @ 0x100000        VMA==LMA: .head.text .boot.text .boot.data
#                                 .pgtables(NOBITS) .boot.bss(NOBITS)
#   HIGH region @ 0xffffffff80100000+  VMA!=LMA (LMA continues low via AT()):
#                                 .text .rodata .data..percpu .data
#                                 .ap_trampoline(VMA 0x8000) .bss(NOBITS)
#   ENTRY = _start (in .head.text, a LOW 32-bit address).
#
# WHAT THIS EMITTER STILL NEEDS (precise cap#3b / cap#4 prerequisites — the
# kernel CANNOT yet reach this function, so emitting a partial/guessed image
# would be unvalidatable dead code; we instead fail with a clear code):
#
#   (a) The boot-stub MACHINE CODE. header.S + head_64.S are hand-written
#       GNU-as AT&T assembly the seed routes through `as`/`ld`. codegen.ad
#       emits NONE of it (it lowers Adder source only). The kernel ELF's
#       .head.text/.boot.text/.boot.data/head_64-.text bytes + the
#       cross-references (head_64 `call start_kernel`; the Adder code's calls
#       to kernel_image_end/read_rbp/kernel_text_*; header.S's R_X86_64_64
#       `movabsq $start_kernel_asm_entry`) must all be materialised and
#       resolved here — work that today lives in `as`/`ld`.
#   (b) codegen.ad SECTION support. The user format flattens everything into
#       one code[]+gdata[] pair at vaddr 0 / CODE_CAP. The kernel needs the
#       distinct .rodata, .data..percpu (%gs-relative, its own VMA), and the
#       high-half VMA(0xffffffff80...)/low-LMA split with per-section AT(),
#       plus the __bss_start/__bss_end symbols head_64.S's rep-stosq reads.
#       codegen.ad emits no per-section streams today.
#   (c) The kernel must first COMPILE: it is blocked in codegen at the
#       pervasive `cast[Ptr[T]](e)[i] = v` / `... = cast[Ptr[T]](e)[i]`
#       raw-memory idiom (915 store + 634 load sites — reason-8 / CAP#4),
#       so neither code[] nor gdata[] is ever produced for the kernel.
#
# Until (a)+(b) land (and CAP#4 unblocks the compile), this returns 0 with
# elf_err = ELF_ERR_KERNEL_UNSUPPORTED so the driver reports the precise
# blocker instead of silently emitting a USER-shaped ELF for a kernel target
# (a latent mis-format bug). The multiboot/kernel.lds field layout above is
# the spec the emitter must match field-for-field once (a)+(b) are in place.
# -----------------------------------------------------------------------
# Per-extern symtab-index map (filled by elf_emit_image_kernel): ext_sym[i] is
# the .symtab index the i-th ext_* name resolves to (a DEFINED Adder function
# symbol if the name matches one, else the shared UNDEF symbol for that name).
# On-disk size is on-DEVICE scale (the on-device elf_emit only emits tiny user
# images); the host driver scales these up via concat HOST_BUFFER_OVERRIDES so
# baking whole-tree sizes here would not OOM the 256 MiB on-device guest.
KELF_MAX_EXTERNS: uint32 = 256
ext_sym: Array[256, uint32]

# Per-Adder-function symtab-index map: fn_sym[i] is the .symtab index of the
# i-th emitted function's symbol (LOCAL if private/underscore, GLOBAL if
# public). Lets an extern reloc against an in-unit function bind to it.
KELF_MAX_FNSYMS: uint32 = 256
fn_sym: Array[256, uint32]

# .strtab byte buffer (symbol name strings) + a running length. Built first so
# symtab entries can carry name offsets, then appended to the image.
KELF_STRTAB_CAP: uint32 = 4096
kelf_strtab: Array[4096, uint8]
kelf_strtab_len: uint32 = 0

# .symtab entries staged in parallel arrays, then serialised (each Elf64_Sym is
# 24 bytes). One entry per: NULL, 3 section syms, every Adder function, every
# UNDEF extern. ksym_name = .strtab offset; ksym_info = st_info byte;
# ksym_shndx = section index; ksym_value = st_value (function code offset).
KELF_MAX_SYMS: uint32 = 256
ksym_name: Array[256, uint32]
ksym_info: Array[256, uint32]
ksym_shndx: Array[256, uint32]
ksym_value: Array[256, uint64]
ksym_count: uint32 = 0


def kelf_strtab_add(name_off: uint32, name_len: uint32) -> uint32:
    # Append a strbuf name slice + NUL to .strtab, return its offset.
    at: uint32 = kelf_strtab_len
    i: uint32 = 0
    while i < name_len:
        if kelf_strtab_len < KELF_STRTAB_CAP - 1:
            kelf_strtab[kelf_strtab_len] = strbuf[name_off + i]
            kelf_strtab_len = kelf_strtab_len + 1
        i = i + 1
    kelf_strtab[kelf_strtab_len] = 0
    kelf_strtab_len = kelf_strtab_len + 1
    return at


# Append a NUL-terminated C-literal to .strtab, return its offset.
def kelf_strtab_add_cstr(lit: Ptr[uint8]) -> uint32:
    at: uint32 = kelf_strtab_len
    i: uint32 = 0
    while cast[uint32](lit[i]) != 0:
        if kelf_strtab_len < KELF_STRTAB_CAP - 1:
            kelf_strtab[kelf_strtab_len] = lit[i]
            kelf_strtab_len = kelf_strtab_len + 1
        i = i + 1
    kelf_strtab[kelf_strtab_len] = 0
    kelf_strtab_len = kelf_strtab_len + 1
    return at


def ksym_add(name: uint32, info: uint32, shndx: uint32, value: uint64):
    if ksym_count < KELF_MAX_SYMS:
        ksym_name[ksym_count] = name
        ksym_info[ksym_count] = info
        ksym_shndx[ksym_count] = shndx
        ksym_value[ksym_count] = value
        ksym_count = ksym_count + 1


# -----------------------------------------------------------------------
# ET_REL relocatable-object emitter for the bare-metal kernel target.
#
# Emits the compiled-Adder kernel code as a relocatable ELF64 object whose
# cross-object symbols (extern funcs in irq_asm.S / head_64.S, memset, memcpy,
# read_cr3, …) are UNDEF and resolved by `ld -T arch/x86/kernel/kernel.lds`
# against the hand-written .S objects — EXACTLY the seed's
# assemble_and_link_x86_bare `ld` pipeline. The build script (scripts/
# _adder_cc.sh) assembles header.S/head_64.S + extras and links them WITH this
# .o into the final higher-half kernel ELF.
#
# Sections (in this file order):
#   [0] NULL
#   [1] .text     (PROGBITS AX)  = code[0..code_len)
#   [2] .data     (PROGBITS WA)  = gdata[0..gdata_len)  (all initialised data)
#   [3] .bss      (NOBITS   WA)  size bss_len
#   [4] .symtab   (SYMTAB)       sh_link=.strtab, sh_info=first-global index
#   [5] .strtab   (STRTAB)
#   [6] .shstrtab (STRTAB)
#   [7] .rela.text (RELA)        sh_link=.symtab, sh_info=.text
# Symbols: index0 NULL; STT_SECTION for .text/.data/.bss; one STB_GLOBAL
# STT_FUNC per Adder function (so head_64.S's `call start_kernel` resolves);
# one STB_GLOBAL UNDEF per referenced extern not defined here.
# Relocations (.rela.text): one per recorded data fixup (PC32 vs the .data or
# .bss section symbol, addend = df_data_off-4) + one per extern reloc (PC32/
# PLT32 vs the named symbol, addend = -4).
# -----------------------------------------------------------------------
def elf_emit_image_kernel() -> uint32:
    elf_reset()
    kelf_strtab_len = 0
    ksym_count = 0

    # --- Build .strtab + .symtab ---------------------------------------
    # [0] NULL symbol.
    kelf_strtab[0] = 0
    kelf_strtab_len = 1
    ksym_add(0, 0, 0, cast[uint64](0))           # STN_UNDEF

    # Section symbols (STT_SECTION, st_info=3, local): .text/.data/.bss are
    # sections 1/2/3. These are the relocation targets for intra-object data
    # refs. st_name 0 (unnamed), st_value 0.
    ksym_add(0, 3, 1, cast[uint64](0))           # .text  (STT_SECTION)
    SYM_DATA: uint32 = ksym_count
    ksym_add(0, 3, 2, cast[uint64](0))           # .data
    SYM_BSS: uint32 = ksym_count
    ksym_add(0, 3, 3, cast[uint64](0))           # .bss
    ksym_add(0, 3, 4, cast[uint64](0))           # .data..percpu (section [4])

    # PRIVATE (leading-underscore) Adder functions are emitted as LOCAL
    # STT_FUNC (st_info=0x02). The seed mangles module-private `_helper`s; many
    # modules define a same-named `_align_up`/`_read_u32_le`/etc., so emitting
    # them all GLOBAL would collide ("multiple definition") at `ld`. As LOCAL
    # symbols they don't conflict, and intra-object calls were ALREADY resolved
    # by codegen's resolve_calls (call rel32 patched before `ld`), so the local
    # symbol is purely informational. fn_sym[i] records each function's symtab
    # index so an extern reloc against an in-unit function binds to it. Locals
    # MUST precede all globals in .symtab (sh_info = first_global).
    fi: uint32 = 0
    while fi < fn_count:
        if strbuf[fn_name_off[fi]] == 95:        # leading '_' -> module-private
            no: uint32 = kelf_strtab_add(fn_name_off[fi], fn_name_len[fi])
            fn_sym[fi] = ksym_count
            ksym_add(no, 0x02, 1, cast[uint64](fn_offset[fi]))
        fi = fi + 1

    # First-global index = first STB_GLOBAL symbol (sh_info of .symtab).
    first_global: uint32 = ksym_count

    # Per-CPU template boundary symbols + each Percpu[T] global, exported as
    # STB_GLOBAL OBJECT (st_info=0x11) in section [4] (.data..percpu). The
    # hand-written setup_percpu_asm.S reads __per_cpu_template_start/_end and
    # linux_current_task_pcpu by these names; cpu_id_pcpu is pinned to offset 0.
    pcs_no: uint32 = kelf_strtab_add_cstr("__per_cpu_template_start")
    ksym_add(pcs_no, 0x11, 4, cast[uint64](0))
    pce_no: uint32 = kelf_strtab_add_cstr("__per_cpu_template_end")
    ksym_add(pce_no, 0x11, 4, cast[uint64](percpu_len))
    gpi: uint32 = 0
    while gpi < glob_count:
        if glob_is_percpu[gpi] != 0:
            pno: uint32 = kelf_strtab_add(glob_name_off[gpi], glob_name_len[gpi])
            ksym_add(pno, 0x11, 4, cast[uint64](glob_offset[gpi]))
        gpi = gpi + 1

    # PUBLIC Adder functions (no leading underscore): STB_GLOBAL STT_FUNC
    # (st_info=0x12), st_shndx=.text(1), st_value=fn_offset. These satisfy
    # head_64.S's `call start_kernel`, &func and direct extern calls against an
    # in-unit function.
    fi2: uint32 = 0
    while fi2 < fn_count:
        if strbuf[fn_name_off[fi2]] != 95:       # public
            no3: uint32 = kelf_strtab_add(fn_name_off[fi2], fn_name_len[fi2])
            fn_sym[fi2] = ksym_count
            ksym_add(no3, 0x12, 1, cast[uint64](fn_offset[fi2]))
        fi2 = fi2 + 1

    # Extern symbols: for each referenced ext_* name, if it matches an Adder
    # function it is already a DEFINED symbol (reuse fn_sym); otherwise add an
    # UNDEF STB_GLOBAL STT_NOTYPE symbol (st_info=0x10, st_shndx=0) that `ld`
    # resolves against the .S objects. ext_sym[i] records the resolved index.
    ei: uint32 = 0
    while ei < ext_count:
        fmatch: uint32 = 0
        fj: uint32 = 0
        while fj < fn_count:
            if name_match(fn_name_off[fj], fn_name_len[fj], ext_name_off[ei], ext_name_len[ei]) != 0:
                ext_sym[ei] = fn_sym[fj]
                fmatch = 1
                fj = fn_count
            else:
                fj = fj + 1
        if fmatch == 0:
            no2: uint32 = kelf_strtab_add(ext_name_off[ei], ext_name_len[ei])
            ext_sym[ei] = ksym_count
            ksym_add(no2, 0x10, 0, cast[uint64](0))   # UNDEF GLOBAL NOTYPE
        ei = ei + 1

    # --- .shstrtab (section-name string table) -------------------------
    # Offsets are computed by appending names in section order. Index 0 is the
    # empty name for the NULL section.
    kshstr: Array[128, uint8]
    ksh_len: uint32 = 0
    kshstr[ksh_len] = 0
    ksh_len = ksh_len + 1
    # helper-inline name appends; record each name's offset.
    SH_TEXT: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".text")
    SH_DATA: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".data")
    SH_BSS: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".bss")
    SH_PERCPU: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".data..percpu")
    SH_SYMTAB: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".symtab")
    SH_STRTAB: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".strtab")
    SH_SHSTRTAB: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".shstrtab")
    SH_RELATEXT: uint32 = ksh_len
    ksh_len = kelf_append_cstr(&kshstr[0], ksh_len, ".rela.text")

    # --- File layout: header + section data + section header table -----
    # ELF64 header = 64 bytes; then .text, .data, .data..percpu bytes, then
    # .symtab, .strtab, .shstrtab, .rela.text, then the 9-entry section header
    # table (each 64). .bss is NOBITS (no file bytes).
    nreloc: uint32 = df_count + er_count
    symtab_bytes: uint32 = ksym_count * 24
    rela_bytes: uint32 = nreloc * 24

    off_text: uint32 = 64
    off_data: uint32 = off_text + code_len
    off_percpu: uint32 = off_data + gdata_len
    off_symtab: uint32 = off_percpu + percpu_len
    off_strtab: uint32 = off_symtab + symtab_bytes
    off_shstrtab: uint32 = off_strtab + kelf_strtab_len
    off_rela: uint32 = off_shstrtab + ksh_len
    off_shdr: uint32 = off_rela + rela_bytes

    # Overflow guard: total file size must fit ELF_BUF_CAP.
    if off_shdr + 9 * 64 > ELF_BUF_CAP:
        elf_err = ELF_ERR_OVERFLOW
        return 0

    # --- ELF64 header (64 bytes) ---------------------------------------
    eb(0x7F)
    eb(69)            # 'E'
    eb(76)            # 'L'
    eb(70)            # 'F'
    eb(2)             # EI_CLASS = ELFCLASS64
    eb(1)             # EI_DATA  = ELFDATA2LSB
    eb(1)             # EI_VERSION
    eb(0)             # EI_OSABI = SYSV
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)             # EI_PAD (16 bytes of e_ident total)
    eb16(1)           # e_type = ET_REL
    eb16(62)          # e_machine = EM_X86_64
    eb32(1)           # e_version
    eb64(cast[uint64](0))         # e_entry (none for ET_REL)
    eb64(cast[uint64](0))         # e_phoff (no program headers)
    eb64(cast[uint64](off_shdr))  # e_shoff
    eb32(0)           # e_flags
    eb16(64)          # e_ehsize
    eb16(0)           # e_phentsize
    eb16(0)           # e_phnum
    eb16(64)          # e_shentsize
    eb16(9)           # e_shnum (NULL,.text,.data,.bss,.data..percpu,.symtab,.strtab,.shstrtab,.rela.text)
    eb16(7)           # e_shstrndx = .shstrtab (section 7)

    # --- Section bytes -------------------------------------------------
    # .text
    ci: uint32 = 0
    while ci < code_len:
        eb(cast[uint32](code[ci]))
        ci = ci + 1
    # .data
    gi: uint32 = 0
    while gi < gdata_len:
        eb(cast[uint32](gdata[gi]))
        gi = gi + 1
    # .data..percpu : the per-CPU template, all zero (each Percpu[T] global
    # is zero-init; setup_per_cpu_areas seeds the live values at runtime).
    pcb: uint32 = 0
    while pcb < percpu_len:
        eb(0)
        pcb = pcb + 1
    # .symtab (Elf64_Sym = 24 bytes: name(4) info(1) other(1) shndx(2)
    #          value(8) size(8))
    syi: uint32 = 0
    while syi < ksym_count:
        eb32(ksym_name[syi])
        eb(ksym_info[syi] & 255)
        eb(0)                          # st_other
        eb16(ksym_shndx[syi] & 65535)
        eb64(ksym_value[syi])
        eb64(cast[uint64](0))          # st_size
        syi = syi + 1
    # .strtab
    sti: uint32 = 0
    while sti < kelf_strtab_len:
        eb(cast[uint32](kelf_strtab[sti]))
        sti = sti + 1
    # .shstrtab
    shi: uint32 = 0
    while shi < ksh_len:
        eb(cast[uint32](kshstr[shi]))
        shi = shi + 1
    # .rela.text (Elf64_Rela = 24 bytes: offset(8) info(8) addend(8)).
    # Data fixups first, then extern relocs.
    dfi: uint32 = 0
    while dfi < df_count:
        sym: uint32 = SYM_DATA
        if df_is_bss[dfi] != 0:
            sym = SYM_BSS
        eb64(cast[uint64](df_at[dfi]))                          # r_offset
        rinfo: uint64 = (cast[uint64](sym) << 32) | cast[uint64](2)   # R_X86_64_PC32
        eb64(rinfo)
        # addend = target_data_off - 4 (PC32 is from the instruction END, 4
        # bytes past the disp32 field start at r_offset).
        add: uint64 = cast[uint64](df_data_off[dfi]) - cast[uint64](4)
        eb64(add)
        dfi = dfi + 1
    eri: uint32 = 0
    while eri < er_count:
        rt: uint64 = cast[uint64](2)                            # R_X86_64_PC32
        if er_type[eri] == ER_PLT32:
            rt = cast[uint64](4)                                # R_X86_64_PLT32
        symx: uint32 = ext_sym[er_sym_idx[eri]]
        eb64(cast[uint64](er_at[eri]))                          # r_offset
        eb64((cast[uint64](symx) << 32) | rt)                  # r_info
        eb64(cast[uint64](0) - cast[uint64](4))                # r_addend = -4
        eri = eri + 1

    # --- Section header table (9 entries, each Elf64_Shdr = 64 bytes) ---
    # [0] NULL
    kelf_shdr(0, 0, cast[uint64](0), cast[uint64](0), cast[uint64](0), 0, 0, cast[uint64](0), cast[uint64](0))
    # [1] .text  : PROGBITS, AX (flags=6), addr 0, offset off_text, size code_len, align 16
    kelf_shdr(SH_TEXT, 1, cast[uint64](6), cast[uint64](0), cast[uint64](off_text), 0, 0, cast[uint64](16), cast[uint64](0))
    # [2] .data  : PROGBITS, WA (flags=3)
    kelf_shdr(SH_DATA, 1, cast[uint64](3), cast[uint64](0), cast[uint64](off_data), 0, 0, cast[uint64](8), cast[uint64](0))
    # [3] .bss   : NOBITS (type 8), WA (flags=3); size bss_len, no file bytes.
    kelf_shdr(SH_BSS, 8, cast[uint64](3), cast[uint64](0), cast[uint64](off_percpu), 0, 0, cast[uint64](8), cast[uint64](0))
    # [4] .data..percpu : PROGBITS, WA (flags=3); the per-CPU template bytes.
    kelf_shdr(SH_PERCPU, 1, cast[uint64](3), cast[uint64](0), cast[uint64](off_percpu), 0, 0, cast[uint64](8), cast[uint64](0))
    # [5] .symtab: SYMTAB (type 2); link=.strtab(6), info=first_global,
    #     entsize 24, align 8.
    kelf_shdr(SH_SYMTAB, 2, cast[uint64](0), cast[uint64](0), cast[uint64](off_symtab), 6, first_global, cast[uint64](8), cast[uint64](24))
    # [6] .strtab: STRTAB (type 3)
    kelf_shdr(SH_STRTAB, 3, cast[uint64](0), cast[uint64](0), cast[uint64](off_strtab), 0, 0, cast[uint64](1), cast[uint64](0))
    # [7] .shstrtab: STRTAB
    kelf_shdr(SH_SHSTRTAB, 3, cast[uint64](0), cast[uint64](0), cast[uint64](off_shstrtab), 0, 0, cast[uint64](1), cast[uint64](0))
    # [8] .rela.text: RELA (type 4); link=.symtab(5), info=.text(1),
    #     entsize 24, align 8.
    kelf_shdr(SH_RELATEXT, 4, cast[uint64](0), cast[uint64](0), cast[uint64](off_rela), 5, 1, cast[uint64](8), cast[uint64](24))

    # Patch the real section SIZES (sh_size at shdr_off + 32) now that the
    # byte streams are placed. The kelf_shdr writer above wrote sh_size 0 for
    # the variable-length sections; fix them here.
    sh1: uint32 = off_shdr
    kelf_patch_shsize(sh1 + 1 * 64, cast[uint64](code_len))         # .text
    kelf_patch_shsize(sh1 + 2 * 64, cast[uint64](gdata_len))        # .data
    kelf_patch_shsize(sh1 + 3 * 64, cast[uint64](bss_len))          # .bss (NOBITS size)
    kelf_patch_shsize(sh1 + 4 * 64, cast[uint64](percpu_len))       # .data..percpu
    kelf_patch_shsize(sh1 + 5 * 64, cast[uint64](symtab_bytes))     # .symtab
    kelf_patch_shsize(sh1 + 6 * 64, cast[uint64](kelf_strtab_len))  # .strtab
    kelf_patch_shsize(sh1 + 7 * 64, cast[uint64](ksh_len))          # .shstrtab
    kelf_patch_shsize(sh1 + 8 * 64, cast[uint64](rela_bytes))       # .rela.text

    if elf_err != 0:
        return 0
    return elf_len


# Append a NUL-terminated C-literal into a byte buffer at offset `at`, return
# the new length. Used to build the small .shstrtab.
def kelf_append_cstr(buf: Ptr[uint8], at: uint32, lit: Ptr[uint8]) -> uint32:
    p: uint32 = at
    i: uint32 = 0
    while cast[uint32](lit[i]) != 0:
        buf[p] = lit[i]
        p = p + 1
        i = i + 1
    buf[p] = 0
    p = p + 1
    return p


# Write one Elf64_Shdr (64 bytes) at the current elf_buf position. sh_size is
# written as 0 here (patched afterwards via kelf_patch_shsize for the
# variable-length sections). Fields: name, type, flags, addr, offset, link,
# info, addralign, entsize.
def kelf_shdr(name: uint32, stype: uint32, flags: uint64, addr: uint64, offset: uint64, link: uint32, info: uint32, align: uint64, entsize: uint64):
    eb32(name)                 # sh_name
    eb32(stype)                # sh_type
    eb64(flags)                # sh_flags
    eb64(addr)                 # sh_addr
    eb64(offset)               # sh_offset
    eb64(cast[uint64](0))      # sh_size (patched later)
    eb32(link)                 # sh_link
    eb32(info)                 # sh_info
    eb64(align)                # sh_addralign
    eb64(entsize)              # sh_entsize


# Patch a section header's sh_size (8 bytes at shdr_off + 32).
def kelf_patch_shsize(shdr_off: uint32, size: uint64):
    patch64(shdr_off + 32, size)


# -----------------------------------------------------------------------
# Build the complete ELF image into elf_buf[0..elf_len).
#
# `entry_arg` is the 32-bit value the _start stub loads into %edi before
# calling the compiled entry at vaddr 0. The compiled entry reads it as
# its first parameter (System-V: first arg in %rdi). For a no-arg `main`
# the value is simply ignored by the callee.
#
# Returns the total image length (elf_len), or 0 on overflow (elf_err
# is also set).
# -----------------------------------------------------------------------
def elf_emit_image(entry_arg: uint32) -> uint32:
    elf_reset()

    # The _start stub sits immediately after the compiled code, still
    # far below CODE_CAP (the program is tiny vs the 8 KiB window). Its
    # vaddr == its offset in the segment (segment vaddr base 0).
    start_vaddr: uint32 = code_len
    elf_entry_vaddr = start_vaddr

    # --- _start machine code (hand-assembled x86_64) --------------------
    # We assemble it into a tiny local buffer first so we know its exact
    # length and the call's rel32 displacement before laying out the
    # ELF (e_entry needs the stub vaddr; the segment file size needs the
    # stub length). The stub is:
    #
    #   E8 <rel32>            call   entry              ; entry at vaddr 0
    #   48 63 F8             movslq eax, rdi            ; sign-extend ret->exit
    #   48 C7 C0 01 00 00 00 mov    rax, 1             ; SYS_EXIT
    #   0F 05                syscall
    #   EB FE                jmp    .                  ; defensive spin
    #
    # CRITICAL — the Hamnix user ABI passes argc in %rdi and argv in %rsi
    # IN REGISTERS (the kernel pre-loads them before iretq/sysretq lands at
    # _start: see arch/x86/kernel/sched/core.ad _build_initial_kstack and
    # user/runtime.S's _start). The stub MUST therefore leave %rdi/%rsi
    # UNTOUCHED so `call main` forwards them directly as main(argc, argv).
    # The earlier `mov edi, entry_arg` CLOBBERED %rdi with a constant 0,
    # destroying argc — so a real `cat FILE` ran main(0, …), took the
    # argc<2 branch, and hung reading stdin during boot (the pid-7 freeze).
    # `entry_arg` is now unused (every caller passed 0 anyway); we mirror
    # runtime.S's _start exactly (sans the cosmetic TEMP_DEBUG banner write).
    #
    # The `call` is RIP-relative: rel32 = target - (addr_of_field + 4),
    # where target = cg_entry_off (entry vaddr) and addr_of_field is the
    # vaddr of the rel32 immediate. The stub begins at start_vaddr; the
    # `call` opcode is at start_vaddr + 0, its rel32 field at start_vaddr +
    # 1, and the field end at start_vaddr + 5.
    stub: Array[32, uint8]
    sn: uint32 = 0

    # call rel32 -> entry at vaddr cg_entry_off. The entry is resolved BY
    # NAME by codegen (prefers `main`, else the first emitted function), so
    # the entry function need NOT be the source-first function. rel32 =
    # cg_entry_off - field_end, as an unsigned 32-bit two's complement value.
    field_end: uint32 = start_vaddr + 5
    rel: uint32 = cg_entry_off - field_end
    stub[sn] = 0xE8
    sn = sn + 1
    stub[sn] = cast[uint8](rel & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((rel >> 8) & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((rel >> 16) & 255)
    sn = sn + 1
    stub[sn] = cast[uint8]((rel >> 24) & 255)
    sn = sn + 1

    # movslq eax, rdi  (REX.W 63 /r, modrm F8 = eax->rdi) — sign-extend the
    # int32 return value into the 64-bit exit-code arg, matching runtime.S.
    stub[sn] = 0x48
    sn = sn + 1
    stub[sn] = 0x63
    sn = sn + 1
    stub[sn] = 0xF8
    sn = sn + 1

    # mov rax, 1   (SYS_EXIT) — REX.W C7 /0, full 64-bit to match runtime.S.
    stub[sn] = 0x48
    sn = sn + 1
    stub[sn] = 0xC7
    sn = sn + 1
    stub[sn] = 0xC0
    sn = sn + 1
    stub[sn] = 0x01
    sn = sn + 1
    stub[sn] = 0x00
    sn = sn + 1
    stub[sn] = 0x00
    sn = sn + 1
    stub[sn] = 0x00
    sn = sn + 1

    # syscall
    stub[sn] = 0x0F
    sn = sn + 1
    stub[sn] = 0x05
    sn = sn + 1

    # jmp . (EB FE) defensive spin if SYS_EXIT ever returns
    stub[sn] = 0xEB
    sn = sn + 1
    stub[sn] = 0xFE
    sn = sn + 1

    stub_len: uint32 = sn

    # --- Segment sizing -------------------------------------------------
    # TWO PT_LOAD segments (no file padding to CODE_CAP):
    #   code PT_LOAD : vaddr 0, file bytes = code_len + stub_len
    #       code  : [0, code_len)
    #       _start: [code_len, code_len + stub_len)
    #   data PT_LOAD : vaddr CODE_CAP, file bytes = gdata_len (.data),
    #       memsz = gdata_len + bss_len (.bss tail is memsz-only; the
    #       loader zeroes the whole p_memsz span before copying p_filesz).
    # The code segment must still fit below CODE_CAP so the data segment's
    # vaddr (CODE_CAP) sits above it — the RIP-relative addressing
    # invariant (data at virtual CODE_CAP) is preserved by the segment
    # VADDRs, not by file padding.
    if code_len + stub_len > CODE_CAP:
        elf_err = 1
        return 0

    code_seg_filesz: uint32 = code_len + stub_len
    code_seg_memsz: uint32 = code_seg_filesz
    data_seg_filesz: uint32 = gdata_len
    data_seg_memsz: uint32 = gdata_len + bss_len

    # File offset where the data segment's bytes begin: right after the
    # code segment's bytes (which start at ELF_SEG_FILE_OFF).
    data_file_off: uint32 = ELF_SEG_FILE_OFF + code_seg_filesz

    # --- ELF32 header (52 bytes) ----------------------------------------
    # e_ident
    eb(0x7F)          # EI_MAG0
    eb(69)            # 'E'
    eb(76)            # 'L'
    eb(70)            # 'F'
    eb(1)             # EI_CLASS = ELFCLASS32 (fs/elf.ad ELF32 path)
    eb(1)             # EI_DATA  = ELFDATA2LSB (little-endian)
    eb(1)             # EI_VERSION = EV_CURRENT
    eb(0)             # EI_OSABI = ELFOSABI_SYSV (native, not Linux)
    eb(0)             # EI_ABIVERSION
    eb(0)             # EI_PAD..
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb(0)
    eb16(2)           # e_type = ET_EXEC
    eb16(3)           # e_machine = EM_386 (matches the elf32-i386 wrapper)
    eb32(1)           # e_version = EV_CURRENT
    # e_entry: the _start stub's vaddr. fs/elf.ad ELF32 path returns
    # region + (e_entry - lowest_v); lowest_v == 0 so the stub runs at
    # its in-image vaddr offset.
    eb32(elf_entry_vaddr)
    eb32(52)          # e_phoff = right after the 52-byte ELF header
    eb32(0)           # e_shoff = 0 (no section headers; loader ignores)
    eb32(0)           # e_flags
    eb16(52)          # e_ehsize
    eb16(32)          # e_phentsize (elf32 program header size)
    eb16(2)           # e_phnum = 2 (code PT_LOAD + data PT_LOAD)
    eb16(0)           # e_shentsize
    eb16(0)           # e_shnum
    eb16(0)           # e_shstrndx

    # --- Program header 1: code PT_LOAD (vaddr 0, 32 bytes) -------------
    eb32(1)                 # p_type = PT_LOAD
    eb32(ELF_SEG_FILE_OFF)  # p_offset = file offset of the code segment
    eb32(0)                 # p_vaddr = 0 (base; loader rebases by lowest_v)
    eb32(0)                 # p_paddr
    eb32(code_seg_filesz)   # p_filesz = code + stub
    eb32(code_seg_memsz)    # p_memsz  = same (no .bss in the code segment)
    eb32(7)                 # p_flags = RWX (loader ignores per-seg flags here)
    eb32(4096)              # p_align

    # --- Program header 2: data PT_LOAD (vaddr CODE_CAP, 32 bytes) ------
    # .data is stored (p_filesz = gdata_len); the .bss tail is memsz-only
    # (p_memsz = gdata_len + bss_len > p_filesz). The loader zeroes the
    # whole p_memsz span before copying p_filesz bytes, so .bss is zeroed.
    eb32(1)                 # p_type = PT_LOAD
    eb32(data_file_off)     # p_offset = right after the code segment bytes
    eb32(CODE_CAP)          # p_vaddr = CODE_CAP (the RIP-data invariant)
    eb32(CODE_CAP)          # p_paddr
    eb32(data_seg_filesz)   # p_filesz = gdata_len (.data only)
    eb32(data_seg_memsz)    # p_memsz  = gdata_len + bss_len (.data + .bss)
    eb32(7)                 # p_flags = RWX
    eb32(4096)              # p_align

    # Sanity: header bytes must total ELF_SEG_FILE_OFF.
    if elf_len != ELF_SEG_FILE_OFF:
        elf_err = 1
        return 0

    # --- Segment payload ------------------------------------------------
    # 1) Compiled code at vaddr 0.
    ci: uint32 = 0
    while ci < code_len:
        eb(cast[uint32](code[ci]))
        ci = ci + 1

    # 2) _start stub at vaddr code_len.
    si: uint32 = 0
    while si < stub_len:
        eb(cast[uint32](stub[si]))
        si = si + 1

    # 3) Initialised data (.data) at vaddr CODE_CAP. Its file bytes follow
    #    the code segment's bytes directly (data_file_off). NO padding to
    #    CODE_CAP — the data segment's p_vaddr places it at CODE_CAP, and
    #    the .bss tail beyond gdata_len is loader-zeroed (memsz > filesz).
    gi: uint32 = 0
    while gi < gdata_len:
        eb(cast[uint32](gdata[gi]))
        gi = gi + 1

    if elf_err != 0:
        return 0

    return elf_len

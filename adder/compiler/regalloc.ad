# adder/compiler/regalloc.ad
#
# Native Adder optimizer — Phase 4: a FIRST WORKING linear-scan register
# allocator (Poletto & Sarkar style), OPT-IN, OFF BY DEFAULT.
#
# WHAT THIS IS
# ------------
# cfg.ad already built EVERYTHING an allocator consumes (its "construction, not
# analysis" handoff): a whole-function CFG, per-block liveness, value-level live
# RANGES (lr_start/lr_end/lr_valid, half-open [start,end) over a stable linear
# instruction numbering), and an alias/may-clobber set (cl_set). A name is
# REGISTER-PROMOTABLE iff it has a live range AND is not clobberable
# (lr_is_promotable). This module turns that into an ASSIGNMENT: a small physical
# register per promoted value, with spills when register pressure exceeds the
# pool.
#
# THE ALGORITHM (classic linear scan)
#   1. Collect the promotable names, each with its [start,end) interval.
#   2. Sort them by interval START (ascending).
#   3. Walk in start order. Before assigning value V:
#        EXPIRE: every active interval whose end <= V.start frees its register
#                (its value is dead by the time V begins).
#      Then if a register is free, assign it to V and make V active.
#      Else SPILL by SPILL-COST (P3): the active value with the LOWEST
#                  loop-depth-weighted use count (cfg.nm_usecost) is the cheapest
#                  to leave in memory, so it is evicted in favor of V when V is
#                  costlier (and the victim's range is no longer than V's — a
#                  guard so a whole-loop induction variable is not traded for a
#                  shorter high-cost temp). Otherwise V itself stays in memory.
#                  This keeps a loop-carried reduction accumulator register-
#                  resident across the hot loop instead of round-tripping it to a
#                  stack slot every iteration (the old "furthest end" victim rule
#                  spilled exactly those long-lived accumulators).
#   4. A value left in memory (never assigned, or chosen as a spill victim) just
#      uses its existing stack slot — codegen already lays every local out at a
#      %rbp offset, so "spill" is a no-op: do nothing and the default memory path
#      is correct. Only ASSIGNED values change codegen.
#
# REGISTER POOL — ABI
#   BASE pool = callee-saved %rbx,%r12,%r13,%r14,%r15, always available:
#     * call-crossing is FREE: a callee-saved register survives any `call` by the
#       System-V ABI (the callee preserves it), so a value held in one of these
#       stays valid across calls with NO save/restore around the call site.
#     * %rsp/%rbp and %rax/%rcx/%rdx (the stack-machine scratch) are NEVER
#       touched, so codegen's lowering is undisturbed. The prologue PUSHes
#       exactly the BASE pool registers used; the epilogue POPs them.
#   EXTENSION pool (P3) = caller-saved %rdi,%r8,%r9,%r10,%r11, available ONLY in
#       a provably CALL-FREE function (cfg_fn_has_call == 0). codegen writes these
#       only when marshalling CALL/SYSCALL arguments or staging an indirect-call
#       pointer; in a function that makes no call NONE of those paths fire, so the
#       five are never clobbered and are safe as durable homes WITHOUT save/
#       restore (they are caller-saved, and a call-free leaf has no caller value
#       to preserve and makes no call to clobber them). %rsi is EXCLUDED (the
#       --opt idiv reciprocal sequence uses it transiently). Any call in scope (or
#       any build-time uncertainty) keeps the pool BASE-only, so a value is NEVER
#       left in a caller-saved register across a call. See ra_pool_is_callee_saved
#       (gates prologue saves) and ra_build_for_function (gates the expansion).
#
# WHY THE STACK SLOT STAYS AUTHORITATIVE (write-through)
#   codegen consumes an assignment as: a READ of an assigned value reads the
#   register; a WRITE stores to BOTH the register and the stack slot
#   (write-through). The slot therefore is never stale, so ANY code path that
#   still reads the slot (and a promoted value is never address-taken — the
#   clobber set guarantees it — so the only such paths are the few non-scalar
#   load sites codegen leaves on the memory path) observes the current value.
#   Correctness is by construction: register and slot always agree.
#
# GATING — DEFAULT OUTPUT IS BYTE-IDENTICAL
#   ra_enabled defaults 0. codegen only calls ra_build_for_function / queries
#   ra_reg_for_name when ra_enabled != 0, which the dump driver sets ONLY under
#   --opt (alongside opt_enable). With the flag off this module is never entered
#   and codegen emits byte-for-byte the pre-regalloc output. The kernel/userland
#   native compile never passes --opt, so objdiff/kobjdiff stay clean.

from compiler.cfg import (
    cfg_build_function,
    cfg_validate,
    lr_build,
    cl_build,
    lr_build_holes,
    lr_is_promotable,
    lr_is_store_elim,
    lr_is_split_candidate,
    lr_num_holes,
    lr_start,
    lr_end,
    lr_valid,
    lr_name_dead_after_sameblock,
    nm_off,
    nm_len,
    nm_count,
    nm_usecost,
    cfg_fn_has_call,
    lr_spans_call,
    cfg_overflow,
    CFGV_OK,
)

from compiler.lexer import (
    strbuf,
)

from compiler.parser import (
    nd_kind,
    nd_b,
    nd_next,
    ND_FUNCTION,
    ND_CLASS,
)

# =======================================================================
# Enable flag (OFF by default).
# =======================================================================
ra_enabled: uint32 = 0


def ra_enable():
    ra_enabled = 1


def ra_is_enabled() -> uint32:
    return ra_enabled


# =======================================================================
# Physical register pool — callee-saved base + call-free caller-saved expansion.
# =======================================================================
#
# We identify a physical register by a small POOL INDEX and map it to an x86-64
# register ENCODING (the 3-bit reg number) for codegen.
#
# BASE pool (indices 0..RA_NREGS_BASE-1) — CALLEE-SAVED, always available:
#   %rbx = 3,  %r12 = 12,  %r13 = 13,  %r14 = 14,  %r15 = 15.
# These survive any `call` for free (System-V callee-saved), so a value held in
# one stays valid across calls with no save/restore. The prologue PUSHes /
# epilogue POPs exactly the base regs the function used.
#
# EXTENSION pool (indices RA_NREGS_BASE..RA_NREGS_MAX-1) — CALLER-SAVED, usable
# ONLY in a provably CALL-FREE function (cfg_fn_has_call == 0):
#   %rdi = 7,  %r8 = 8,  %r9 = 9,  %r10 = 10,  %r11 = 11.
# AUDIT (codegen.ad): in normal straight-line expression/statement lowering the
# stack machine clobbers %rax/%rcx/%rdx (operand scratch + idiv/imul) and, under
# --opt div strength-reduction, %rsi. It writes %rdi/%r8/%r9/%r10/%r11 ONLY when
# marshalling CALL or SYSCALL arguments (emit_pop_argreg/emit_pop_syscallreg) and
# %r11 ONLY to stage an indirect-call pointer. In a function that makes NO calls
# (and therefore no indirect calls), NONE of those argument/indirect-call paths
# fire, so these five registers are never written by codegen — safe as durable
# homes. %rsi is deliberately EXCLUDED (the --opt idiv reciprocal sequence uses
# it as a transient). These regs are caller-saved, so they are NOT pushed/popped
# in the prologue (a call-free leaf has no caller whose values they'd hold and
# makes no call that could clobber them) — see ra_pool_is_callee_saved.
#
# The effective pool size per function is ra_nregs_eff: RA_NREGS_BASE when the
# function makes any call (or allocation/validation was conservative), expanded
# to RA_NREGS_MAX when call-free. CORRECTNESS FALLBACK: any uncertainty (call
# present, build failure) keeps the pool callee-saved-only.
RA_NREGS_BASE: uint32 = 5              # callee-saved count
RA_NREGS_MAX: uint32 = 10             # callee-saved + caller-saved extension
RA_NONE: uint32 = 0xffffffff           # "no register" sentinel

# Effective pool size for the function currently being allocated. Set by
# ra_build_for_function from cfg_fn_has_call. ra_nregs() returns this.
ra_nregs_eff: uint32 = 5

ra_pool_enc: Array[10, uint32]         # pool index -> x86 reg encoding


def ra_pool_init():
    ra_pool_enc[0] = 3                  # %rbx   (callee-saved)
    ra_pool_enc[1] = 12                 # %r12   (callee-saved)
    ra_pool_enc[2] = 13                 # %r13   (callee-saved)
    ra_pool_enc[3] = 14                 # %r14   (callee-saved)
    ra_pool_enc[4] = 15                 # %r15   (callee-saved)
    ra_pool_enc[5] = 7                  # %rdi   (caller-saved, call-free only)
    ra_pool_enc[6] = 8                  # %r8    (caller-saved, call-free only)
    ra_pool_enc[7] = 9                  # %r9    (caller-saved, call-free only)
    ra_pool_enc[8] = 10                 # %r10   (caller-saved, call-free only)
    ra_pool_enc[9] = 11                 # %r11   (caller-saved, call-free only)


# True iff pool index p maps to a CALLEE-SAVED register (the base pool). Only
# these are pushed/popped by the function prologue/epilogue; the caller-saved
# extension regs (p >= RA_NREGS_BASE) are never saved (call-free use only).
def ra_pool_is_callee_saved(p: uint32) -> uint32:
    if p < RA_NREGS_BASE:
        return 1
    return 0


# Per-pool-index occupancy: the name id currently holding this register, or
# RA_NONE if free. Rebuilt per function during the scan.
ra_pool_owner: Array[10, uint32]


# =======================================================================
# Per-name assignment result (indexed by cfg name id, 0..nm_count).
# =======================================================================
#
# ra_assigned_reg[n] = the x86 reg encoding assigned to name n, or RA_NONE if n
# is spilled / not promotable. ra_used_mask bit p set => pool index p was used by
# this function (so codegen knows which callee-saved regs to push/pop).
RA_MAXNAMES: uint32 = 256              # == cfg NM_MAX
ra_assigned_reg: Array[256, uint32]    # x86 encoding or RA_NONE

# ra_store_elim[n] = 1 iff name n got a register AND is store-eliminable
# (lr_is_store_elim: promoted, address never taken, and NO slot-bypass read).
# codegen drops the write-through stack store for such a name (the register is
# its sole home). 0 => keep the write-through store (the slot stays
# authoritative for the bypass read paths). Indexed by cfg name id.
ra_store_elim: Array[256, uint32]      # 1 => slot/store eliminated for name n
ra_used_mask: uint32 = 0               # bitmask over pool indices 0..RA_NREGS-1

ra_ok: uint32 = 0                      # 1 if a usable allocation was built

# Per-function allocation statistics (read by the dump lane).
ra_stat_promotable: uint32 = 0         # promotable names seen this function
ra_stat_inreg: uint32 = 0              # names that got a register
ra_stat_spilled: uint32 = 0            # promotable names left in memory (spilled)
ra_stat_regs_used: uint32 = 0          # distinct pool regs used (popcount mask)


# =======================================================================
# Sort scratch — promotable names by interval start (insertion sort; counts
# are tiny, <= nm_count <= 256).
# =======================================================================
ra_order: Array[256, uint32]           # name ids, sorted by lr_start ascending
ra_order_n: uint32 = 0


# CODEGEN-SET PROMOTION VETO (indexed by cfg name id). 1 => this cfg name must NOT
# be given a register, even if lr_is_promotable(n)!=0. cfg/liveness reason purely
# about name strings and cannot tell a materialisable LOCAL SCALAR from a name the
# backend NEVER holds in a register — a module GLOBAL (loaded RIP-relative), a
# DIRECT-CALL callee name (emitted `call <sym>`), a function name, an array/pointer
# base, or a sub-8-byte scalar. Linear scan would happily assign such a phantom
# name a callee-saved register that the body never WRITES; a later read through the
# dest-driven selector (ra_reg_for_name, which does not re-check locality) then
# reads that UNINITIALISED register — a miscompile that only surfaces once register
# pressure is low enough for the phantom to win a register. codegen fills this from
# its authoritative loc table (param_is_plain_scalar) between ra_build_cfg and
# ra_build_scan, so ONLY names the backend truly materialises in a register are
# promoted (the promotion set == the materialisation set, by construction).
ra_name_vetoed: Array[256, uint32]


# =======================================================================
# XMM HOME REGISTER CLASS for float64 locals (--opt only). THIRD approach.
# =======================================================================
#
# The two prior float-locality dead-ends kept a float LOCAL in a GPR (movq
# GPR<->XMM round-trip at every use) or promoted it per-statement into a fresh
# xmm (reset every statement). This class instead gives a loop-carried float64
# local (mandel's zx/zy/cx/cy, xx/yy/ny) a PERSISTENT xmm home register held
# ACROSS statement boundaries and the whole loop body, so the float recurrence
# computes entirely in xmm — no movq domain-crossing, no per-statement slot
# reload — matching what gcc -O2 does with the inner-loop recurrence.
#
# POOL = xmm8..xmm15 (8 registers). These are disjoint from the float
# selector's scratch pool (xmm2..xmm7) and its leaf-eval regs (xmm0/xmm1), and
# are touched by NO other codegen path, so a home persists untouched across
# iterations. All xmm are CALLER-SAVED in SysV, so a float whose live interval
# spans a call gets NO home (kept on the slot); the selector already gates its
# routed trees call-free. codegen marks which cfg names are float64 locals
# (ra_name_isfloat, set alongside a GPR veto), and the write-through store keeps
# the slot authoritative so any non-selector read (gen_ident -> %rax) stays
# correct. Gated behind ra_enabled exactly like the GPR class; flag-off never
# assigns an xmm home and codegen never queries one, so default output is
# byte-identical.
RA_XMM_N: uint32 = 8                    # xmm8..xmm15
RA_XMM_BASE: uint32 = 8                 # first xmm encoding used as a home
ra_name_isfloat: Array[256, uint32]     # 1 => a float64 local eligible for a home
ra_xmm_assigned: Array[256, uint32]     # xmm encoding (8..15) or RA_NONE, by name id
ra_xmm_owner: Array[8, uint32]          # pool index -> owning name id or RA_NONE
ra_xmm_order: Array[256, uint32]        # float name ids sorted by lr_start
ra_xmm_order_n: uint32 = 0
ra_stat_xmm_inreg: uint32 = 0           # float locals given an xmm home (stat)


def ra_reset():
    n: uint32 = 0
    while n < RA_MAXNAMES:
        ra_assigned_reg[n] = RA_NONE
        ra_store_elim[n] = 0
        ra_name_vetoed[n] = 0
        ra_name_isfloat[n] = 0
        ra_xmm_assigned[n] = RA_NONE
        n = n + 1
    p: uint32 = 0
    while p < RA_NREGS_MAX:
        ra_pool_owner[p] = RA_NONE
        p = p + 1
    px: uint32 = 0
    while px < RA_XMM_N:
        ra_xmm_owner[px] = RA_NONE
        px = px + 1
    ra_nregs_eff = RA_NREGS_BASE
    ra_used_mask = 0
    ra_ok = 0
    ra_order_n = 0
    ra_xmm_order_n = 0
    ra_stat_xmm_inreg = 0
    ra_stat_promotable = 0
    ra_stat_inreg = 0
    ra_stat_spilled = 0
    ra_stat_regs_used = 0


# Collect promotable name ids into ra_order, sorted by lr_start ascending
# (insertion sort, stable enough — ties broken by name id ordering).
def ra_collect_sorted():
    ra_order_n = 0
    n: uint32 = 0
    while n < nm_count:
        if lr_is_promotable(n) != 0 and ra_name_vetoed[n] == 0:
            # insert n into ra_order keeping lr_start ascending
            key: uint32 = lr_start[n]
            i: uint32 = ra_order_n
            while i > 0:
                prev: uint32 = ra_order[i - 1]
                if lr_start[prev] <= key:
                    break
                ra_order[i] = prev
                i = i - 1
            ra_order[i] = n
            ra_order_n = ra_order_n + 1
        n = n + 1
    ra_stat_promotable = ra_order_n


# Per-value pool cap: how many pool indices value v may legally use. A value
# whose live interval spans NO call may use the FULL pool (callee-saved base +
# caller-saved extension) — no `call` executes while it is live, so a
# caller-saved register is a safe home. A value that DOES span a call (or any
# uncertainty: lr_spans_call returns conservative-1) is restricted to the
# CALLEE-SAVED BASE pool, which survives calls for free. This is the per-REGION
# replacement for the old whole-function gate: caller-saved registers are unlocked
# for call-free-lifetime values even inside a function that makes calls elsewhere.
def ra_pool_cap_for(v: uint32) -> uint32:
    if lr_spans_call(v) == 0:
        return RA_NREGS_MAX
    return RA_NREGS_BASE


# Find a free pool index in [0, cap), or RA_NONE if none free. `cap` is the
# per-value pool limit (ra_pool_cap_for): a call-spanning value passes
# RA_NREGS_BASE; a call-free-lifetime value passes RA_NREGS_MAX.
def ra_find_free(cap: uint32) -> uint32:
    p: uint32 = 0
    while p < cap:
        if ra_pool_owner[p] == RA_NONE:
            return p
        p = p + 1
    return RA_NONE


# Among the active intervals, return the pool index whose owner has the LOWEST
# spill cost (loop-depth-weighted use count). This is the standard spill-cost
# heuristic: the cheapest-to-recompute/reload value falls back to memory, so a
# loop-carried accumulator (huge weighted use count) is KEPT in a register and a
# short-lived straight-line temp is evicted instead. Ties broken by FURTHEST end
# (longer live range is costlier to keep, so on equal cost prefer to evict it).
# Returns RA_NONE if no register is active. Only considers pool indices in
# [0, cap): a call-spanning value (cap=RA_NREGS_BASE) may only evict from the
# callee-saved base pool — it must never be placed in a caller-saved register, so
# evicting a caller-saved owner for it is pointless and unsound.
def ra_cheapest_active(cap: uint32) -> uint32:
    best_p: uint32 = RA_NONE
    best_cost: uint32 = 0
    best_end: uint32 = 0
    p: uint32 = 0
    while p < cap:
        owner: uint32 = ra_pool_owner[p]
        if owner != RA_NONE:
            c: uint32 = nm_usecost[owner]
            e: uint32 = lr_end[owner]
            take: uint32 = 0
            if best_p == RA_NONE:
                take = 1
            elif c < best_cost:
                take = 1
            elif c == best_cost and e > best_end:
                take = 1
            if take != 0:
                best_p = p
                best_cost = c
                best_end = e
        p = p + 1
    return best_p


# Expire every active interval that ends at or before `point` (its value is dead
# by the time the current value starts): free its register.
def ra_expire(point: uint32):
    p: uint32 = 0
    while p < ra_nregs_eff:
        owner: uint32 = ra_pool_owner[p]
        if owner != RA_NONE:
            if lr_end[owner] <= point:
                ra_pool_owner[p] = RA_NONE
        p = p + 1


# =======================================================================
# The linear scan.
# =======================================================================
#
# Precondition: ra_collect_sorted() filled ra_order (promotable names by start).
# Assigns ra_assigned_reg[n] = pool encoding for every name that gets a register;
# spilled names keep RA_NONE (their stack slot is used, a no-op for codegen).
def ra_linear_scan():
    i: uint32 = 0
    while i < ra_order_n:
        v: uint32 = ra_order[i]
        vstart: uint32 = lr_start[v]
        vend: uint32 = lr_end[v]

        # EXPIRE intervals that ended before v begins.
        ra_expire(vstart)

        # PER-VALUE POOL CAP: a value whose live range spans no call may use the
        # full pool (callee-saved + caller-saved); a call-spanning value is
        # restricted to the callee-saved base pool. This is the per-region gate.
        vcap: uint32 = ra_pool_cap_for(v)

        free_p: uint32 = ra_find_free(vcap)
        if free_p != RA_NONE:
            ra_pool_owner[free_p] = v
            ra_assigned_reg[v] = ra_pool_enc[free_p]
            ra_used_mask = ra_used_mask | (cast[uint32](1) << free_p)
            ra_stat_inreg = ra_stat_inreg + 1
        else:
            # SPILL by spill-cost: evict the active value with the LOWEST
            # loop-depth-weighted use count IF it is cheaper to keep in memory
            # than v (so the costlier value — e.g. a loop-carried accumulator —
            # gets the register and the cheap value falls back to memory).
            # Otherwise spill v itself. This keeps whole-loop accumulators and
            # loop-invariant bases register-resident instead of evicting them by
            # the old "furthest end" rule (which spilled exactly those).
            spill_p: uint32 = ra_cheapest_active(vcap)
            do_evict: uint32 = 0
            if spill_p != RA_NONE:
                vict: uint32 = ra_pool_owner[spill_p]
                # COST-ONLY eviction: evict the cheapest active value for v iff its
                # loop-depth-weighted use count is STRICTLY lower than v's. The
                # victim falls fully to its stack slot (write-through keeps the slot
                # authoritative — sound). We deliberately DROP the old
                # `lr_end[vict] <= vend` length guard: it blocked a SHORT but very
                # hot value (a deep inner-loop IV like matmul's k, used every
                # iteration, cost 80) from evicting a LONG but cold value (an outer
                # counter like reps/acc, cost ~6-11). gcc keeps exactly the hot
                # short value in a register and lets the cold outer counter live in
                # memory; the length guard inverted that, spilling the hot IV. Pure
                # spill-COST is the right linear-scan victim policy (the value
                # cheapest to leave in memory loses its register), and it is what
                # makes the deepest-loop accumulator/IV register-resident. Ties
                # (equal cost) fall through to "spill v itself", preserving the
                # prior allocation for equal-cost values (no churn).
                if nm_usecost[vict] < nm_usecost[v]:
                    do_evict = 1
            if do_evict != 0:
                evicted: uint32 = ra_pool_owner[spill_p]
                ra_assigned_reg[evicted] = RA_NONE
                ra_stat_inreg = ra_stat_inreg - 1
                ra_stat_spilled = ra_stat_spilled + 1
                ra_pool_owner[spill_p] = v
                ra_assigned_reg[v] = ra_pool_enc[spill_p]
                # ra_used_mask already has this pool bit set.
                ra_stat_inreg = ra_stat_inreg + 1
            else:
                ra_assigned_reg[v] = RA_NONE
                ra_stat_spilled = ra_stat_spilled + 1
        i = i + 1

    # popcount the used mask for the regs-used stat.
    ra_stat_regs_used = 0
    p: uint32 = 0
    while p < ra_nregs_eff:
        if ((ra_used_mask >> p) & 1) != 0:
            ra_stat_regs_used = ra_stat_regs_used + 1
        p = p + 1

    # STORE-ELIMINATION: a name with a register whose value is store-eliminable
    # (no slot-bypass read, address never taken) loses its shadow stack store —
    # the register is its sole home. Conservative: any name still flagged
    # write-through keeps both. Recorded per name for codegen's store_to_named.
    m: uint32 = 0
    while m < nm_count:
        if ra_assigned_reg[m] != RA_NONE and lr_is_store_elim(m) != 0:
            ra_store_elim[m] = 1
        m = m + 1


# =======================================================================
# Driver — build an allocation for ONE function (called from codegen under flag).
# =======================================================================
#
# Runs the cfg.ad pipeline (build + validate + live ranges + alias) for `fn`,
# then linear-scan. Returns 1 if a usable allocation was produced, 0 if the
# function was too large / failed validation (in which case codegen falls back to
# the all-memory default — always correct). NOTE this REBUILDS the cfg arenas, so
# codegen must call ra_reg_for_name only between ra_build_for_function and the
# next one (per-function lifetime); codegen does exactly that.
# PHASE 1: build the cfg + liveness/clobber analysis for `fn` and size the pool.
# Returns 1 if a usable cfg was built (caller may then set promotion vetoes and
# call ra_build_scan), 0 on overflow/validation failure (all-memory fallback).
# Does NOT assign registers yet — ra_ok stays 0 until ra_build_scan runs, so
# ra_reg_for_name returns RA_NONE in the window between the two phases.
def ra_build_cfg(fn: uint32) -> uint32:
    ra_reset()
    ra_pool_init()
    ra_ok = 0

    ok: uint32 = cfg_build_function(fn)
    if ok == 0:
        return 0                         # arena overflow: all-memory fallback
    rc: uint32 = cfg_validate()
    if rc != CFGV_OK:
        return 0                         # validation failure: fallback
    lr_build()
    cl_build(fn)
    # Idle-gap (live-range-hole) analysis: identifies values whose register sits
    # idle across a hotter inner loop (live-range SPLIT candidates). PURE ANALYSIS
    # — the linear scan below does NOT consume it, so the allocation (and thus
    # codegen) is byte-identical; it is the foundation the future codegen splitter
    # reads via lr_is_split_candidate / lr_num_holes. Available per-function here.
    lr_build_holes()
    if cfg_overflow != 0:
        return 0

    # POOL SIZE: the caller-saved extension is now gated PER-VALUE (per-region),
    # not per-function. The pool ALWAYS exposes the full RA_NREGS_MAX registers;
    # ra_pool_cap_for(v) (via lr_spans_call) restricts each individual value to
    # the callee-saved base pool if its live range spans any call, so a value is
    # never left in a caller-saved register across a call. A value whose entire
    # lifetime is call-free (e.g. a reduction accumulator confined to a call-free
    # inner loop, even inside a function that calls elsewhere) may take a
    # caller-saved register with no save/restore. This strictly subsumes the old
    # whole-function gate: in a fully call-free function EVERY value spans no call,
    # so all get the full pool, exactly as before.
    ra_nregs_eff = RA_NREGS_MAX
    return 1


# =======================================================================
# XMM home linear scan (float64 locals).
# =======================================================================
#
# Runs AFTER the GPR scan, over the names codegen flagged ra_name_isfloat (a
# float64 local, also GPR-vetoed). Reuses the exact class-agnostic liveness cfg
# built: lr_start/lr_end intervals, nm_usecost spill cost, lr_spans_call. A
# float value whose interval spans a call gets NO home (all xmm caller-saved) and
# falls back to its slot (correct — the write-through store keeps the slot live).

# Collect float names into ra_xmm_order, sorted by lr_start ascending (insertion
# sort, tiny counts). Mirrors ra_collect_sorted over the isfloat + promotable set.
def ra_xmm_collect_sorted():
    ra_xmm_order_n = 0
    n: uint32 = 0
    while n < nm_count:
        if ra_name_isfloat[n] != 0 and lr_is_promotable(n) != 0:
            key: uint32 = lr_start[n]
            i: uint32 = ra_xmm_order_n
            while i > 0:
                prev: uint32 = ra_xmm_order[i - 1]
                if lr_start[prev] <= key:
                    break
                ra_xmm_order[i] = prev
                i = i - 1
            ra_xmm_order[i] = n
            ra_xmm_order_n = ra_xmm_order_n + 1
        n = n + 1


# Free every xmm home whose owner is dead at `point`.
def ra_xmm_expire(point: uint32):
    p: uint32 = 0
    while p < RA_XMM_N:
        owner: uint32 = ra_xmm_owner[p]
        if owner != RA_NONE:
            if lr_end[owner] <= point:
                ra_xmm_owner[p] = RA_NONE
        p = p + 1


def ra_xmm_find_free() -> uint32:
    p: uint32 = 0
    while p < RA_XMM_N:
        if ra_xmm_owner[p] == RA_NONE:
            return p
        p = p + 1
    return RA_NONE


# Cheapest active xmm home by spill cost (lowest loop-depth-weighted use count),
# ties broken by furthest end — same victim policy as ra_cheapest_active.
def ra_xmm_cheapest_active() -> uint32:
    best_p: uint32 = RA_NONE
    best_cost: uint32 = 0
    best_end: uint32 = 0
    p: uint32 = 0
    while p < RA_XMM_N:
        owner: uint32 = ra_xmm_owner[p]
        if owner != RA_NONE:
            c: uint32 = nm_usecost[owner]
            e: uint32 = lr_end[owner]
            take: uint32 = 0
            if best_p == RA_NONE:
                take = 1
            elif c < best_cost:
                take = 1
            elif c == best_cost and e > best_end:
                take = 1
            if take != 0:
                best_p = p
                best_cost = c
                best_end = e
        p = p + 1
    return best_p


# Linear-scan the float names, assigning xmm homes (encodings 8..15). A value
# whose interval spans a call is never homed (caller-saved xmm). Spill by cost:
# a cheaper active home is evicted for a costlier value (loop-carried recurrence
# wins its register); an evicted / unhomed value keeps RA_NONE and uses its slot.
def ra_xmm_scan():
    i: uint32 = 0
    while i < ra_xmm_order_n:
        v: uint32 = ra_xmm_order[i]
        vstart: uint32 = lr_start[v]
        ra_xmm_expire(vstart)
        if lr_spans_call(v) != 0:
            ra_xmm_assigned[v] = RA_NONE
        else:
            fp: uint32 = ra_xmm_find_free()
            if fp != RA_NONE:
                ra_xmm_owner[fp] = v
                ra_xmm_assigned[v] = RA_XMM_BASE + fp
                ra_stat_xmm_inreg = ra_stat_xmm_inreg + 1
            else:
                sp: uint32 = ra_xmm_cheapest_active()
                do_evict: uint32 = 0
                if sp != RA_NONE:
                    vict: uint32 = ra_xmm_owner[sp]
                    if nm_usecost[vict] < nm_usecost[v]:
                        do_evict = 1
                if do_evict != 0:
                    evicted: uint32 = ra_xmm_owner[sp]
                    ra_xmm_assigned[evicted] = RA_NONE
                    ra_stat_xmm_inreg = ra_stat_xmm_inreg - 1
                    ra_xmm_owner[sp] = v
                    ra_xmm_assigned[v] = RA_XMM_BASE + sp
                    ra_stat_xmm_inreg = ra_stat_xmm_inreg + 1
                else:
                    ra_xmm_assigned[v] = RA_NONE
        i = i + 1


# Codegen-facing: xmm home encoding (8..15) for the float64 local named
# [off,len), or RA_NONE if unhomed / not float / no allocation. Guarded exactly
# like ra_reg_for_name, so it returns RA_NONE with the flag off (byte-identical
# default). Matches the cfg name table (this function's interned locals).
def ra_xmm_for_name(off: uint32, len_: uint32) -> uint32:
    if ra_enabled == 0 or ra_ok == 0:
        return RA_NONE
    n: uint32 = 0
    while n < nm_count:
        if nm_len[n] == len_:
            if ra_name_bytes_eq(nm_off[n], off, len_) != 0:
                return ra_xmm_assigned[n]
        n = n + 1
    return RA_NONE


# PHASE 2: linear-scan the promotable (non-vetoed) names collected from the cfg
# built by ra_build_cfg, assigning registers. Sets ra_ok. Callers that do not need
# the veto window use ra_build_for_function (which runs both phases with an empty
# veto set — byte-identical to the pre-split single-pass build).
def ra_build_scan():
    ra_collect_sorted()
    ra_linear_scan()
    ra_xmm_collect_sorted()
    ra_xmm_scan()
    ra_ok = 1


def ra_build_for_function(fn: uint32) -> uint32:
    if ra_build_cfg(fn) == 0:
        return 0
    ra_build_scan()
    return 1


# =======================================================================
# Codegen-facing query: register for a name (by strbuf slice).
# =======================================================================
#
# Returns the x86 register encoding assigned to the local named [off,len), or
# RA_NONE if it is spilled / not promotable / no allocation built. codegen keys
# its read/write-through decision off this. The name lookup matches against the
# cfg name table (nm_off/nm_len) which holds THIS function's interned locals.
def ra_reg_for_name(off: uint32, len_: uint32) -> uint32:
    if ra_enabled == 0 or ra_ok == 0:
        return RA_NONE
    n: uint32 = 0
    while n < nm_count:
        if nm_len[n] == len_:
            if ra_name_bytes_eq(nm_off[n], off, len_) != 0:
                return ra_assigned_reg[n]
        n = n + 1
    return RA_NONE


# Codegen-facing: 1 iff the local named [off,len) is register-promoted AND its
# shadow stack store can be ELIMINATED (store_to_named writes only the register,
# not the slot). RA_NONE-guarded exactly like ra_reg_for_name, so it returns 0
# with the flag off / no allocation: the write-through store is kept. Matches the
# cfg name table (this function's interned locals).
def ra_store_elim_for_name(off: uint32, len_: uint32) -> uint32:
    if ra_enabled == 0 or ra_ok == 0:
        return 0
    n: uint32 = 0
    while n < nm_count:
        if nm_len[n] == len_:
            if ra_name_bytes_eq(nm_off[n], off, len_) != 0:
                return ra_store_elim[n]
        n = n + 1
    return 0


# strbuf byte compare of two equal-length name slices.
def ra_name_bytes_eq(aoff: uint32, boff: uint32, len_: uint32) -> uint32:
    i: uint32 = 0
    while i < len_:
        if strbuf[aoff + i] != strbuf[boff + i]:
            return 0
        i = i + 1
    return 1


# Prologue/epilogue helpers for codegen: which pool regs were used, and the x86
# encoding of a pool index.
def ra_pool_encoding(p: uint32) -> uint32:
    return ra_pool_enc[p]


# Is pool index `p`'s x86 register assigned to ANY live local this function?
#
# AUTHORITATIVE source = the per-name assignment table `ra_assigned_reg`, the SAME
# array codegen's body reads through ra_reg_for_name. Deriving the prologue/
# epilogue save decision from this table (rather than the parallel-tracked
# `ra_used_mask` bitmask) guarantees the saved callee-saved set can NEVER desync
# from the registers the body actually allocates: if any promoted local is in
# register `p`, the body writes that register, so the prologue MUST push it. A
# desync (body uses %r13 via ra_assigned_reg but the save-set, reading a stale/
# corrupted ra_used_mask, omits %r13) is exactly the method-prologue corruption
# class — closed BY CONSTRUCTION here, since save and body now share one source of
# truth. In a correctly built allocation this returns the identical set
# ra_used_mask did (the last owner of every used pool slot always remains in
# ra_assigned_reg), so codegen output is unchanged. ra_used_mask is retained for
# the regs-used STAT only. Each pool encoding is distinct, so a match uniquely
# identifies pool index p.
def ra_pool_used(p: uint32) -> uint32:
    enc: uint32 = ra_pool_enc[p]
    n: uint32 = 0
    while n < nm_count:
        if ra_assigned_reg[n] == enc:
            return 1
        n = n + 1
    return 0


def ra_nregs() -> uint32:
    return ra_nregs_eff


# BORROW guard: 1 iff EVERY promoted local that linear scan assigned to pool
# index `p`'s x86 register is DEAD at program point `point` — so the register
# holds no live value and may be lent as an IR scratch. CRITICAL: linear scan
# legitimately assigns ONE physical register to MULTIPLE non-overlapping locals
# (that is the whole point of reuse), so a single encoding can be the home of
# several names with disjoint intervals. Borrowing is sound only if ALL of them
# are past their last use here; checking just one (e.g. the first match) would
# clobber another name's live value — a classic miscompile. We require at least
# one name to own the register (so this really is a regalloc reg) AND all owners
# dead. Deadness uses cfg.lr_name_dead_after_sameblock: END <= point AND the
# last-use point and `point` share a basic block, so the ci numbering reflects
# real (source-order) emission order — sound across loops/branches, which the
# bare END test is NOT. Returns 0 if no name owns p, any owner is still live (or
# cross-block), or ra is not built — conservative.
def ra_pool_all_dead_after(p: uint32, point: uint32) -> uint32:
    if p >= ra_nregs_eff:
        return 0
    if ra_ok == 0:
        return 0
    enc: uint32 = ra_pool_enc[p]
    any_owner: uint32 = 0
    n: uint32 = 0
    while n < nm_count:
        if ra_assigned_reg[n] == enc:
            any_owner = 1
            if lr_name_dead_after_sameblock(n, point) == 0:
                return 0                     # some owner still live -> do not lend
        n = n + 1
    return any_owner


# =======================================================================
# Corpus driver — build an allocation for every function and accumulate stats.
# =======================================================================
#
# Mirrors cfg_run_program: walks the ND_PROGRAM decl chain (on nd_b), builds a
# linear-scan allocation per ND_FUNCTION, and sums the per-function stats. This
# is the --dump-regalloc lane — PURE ANALYSIS, never emits code. Used by the
# fuzzer to report allocation behaviour and assert the allocator is exercising
# registers + spills over the corpus.
ra_prog_funcs: uint32 = 0              # functions an allocation was built for
ra_prog_skipped: uint32 = 0           # functions skipped (overflow / validate)
ra_prog_promotable: uint32 = 0        # total promotable values
ra_prog_inreg: uint32 = 0             # total values given a register
ra_prog_spilled: uint32 = 0           # total promotable values spilled to memory
ra_prog_regs_used: uint32 = 0         # sum of distinct regs used per function
ra_prog_max_regs: uint32 = 0          # max distinct regs used by any one function
ra_prog_callcross: uint32 = 0         # values kept in a (callee-saved) register
                                      # whose interval spans >1 block (a proxy for
                                      # call/branch-crossing residency)
ra_prog_holes: uint32 = 0             # total idle-gaps (live-range holes) recorded
ra_prog_split_cands: uint32 = 0       # total live-range SPLIT candidates
ra_prog_split_inreg: uint32 = 0       # split candidates that ALSO got a register
                                      # (the ones whose idle reg a splitter frees)


# Count this function's idle-gaps + split candidates (folded into ra_run_program).
def ra_accum_holes():
    n: uint32 = 0
    while n < nm_count:
        ra_prog_holes = ra_prog_holes + lr_num_holes(n)
        if lr_is_split_candidate(n) != 0:
            ra_prog_split_cands = ra_prog_split_cands + 1
            if ra_assigned_reg[n] != RA_NONE:
                ra_prog_split_inreg = ra_prog_split_inreg + 1
        n = n + 1


# Build an allocation for ONE function/method node `fn` and fold its per-function
# stats into the program accumulators. Shared by top-level functions and class
# methods (a method is structurally a free function; ra_build_for_function lowers
# nd_a/nd_c identically).
def ra_accum_function(fn: uint32):
    if ra_build_for_function(fn) != 0:
        ra_prog_funcs = ra_prog_funcs + 1
        ra_prog_promotable = ra_prog_promotable + ra_stat_promotable
        ra_prog_inreg = ra_prog_inreg + ra_stat_inreg
        ra_prog_spilled = ra_prog_spilled + ra_stat_spilled
        ra_prog_regs_used = ra_prog_regs_used + ra_stat_regs_used
        if ra_stat_regs_used > ra_prog_max_regs:
            ra_prog_max_regs = ra_stat_regs_used
        # Count register-resident values whose live interval is "long" (spans
        # more than a handful of program points): a conservative proxy for a
        # value held across a branch/call, which the callee-saved pool keeps
        # safe for free.
        ra_prog_callcross = ra_prog_callcross + ra_count_long_inreg()
        ra_accum_holes()
    else:
        ra_prog_skipped = ra_prog_skipped + 1


def ra_run_program(prog: uint32):
    ra_prog_funcs = 0
    ra_prog_skipped = 0
    ra_prog_promotable = 0
    ra_prog_inreg = 0
    ra_prog_spilled = 0
    ra_prog_regs_used = 0
    ra_prog_max_regs = 0
    ra_prog_callcross = 0
    ra_prog_holes = 0
    ra_prog_split_cands = 0
    ra_prog_split_inreg = 0
    if prog == 0:
        return
    decls: uint32 = nd_b[prog]
    cur: uint32 = decls
    while cur != 0:
        if nd_kind[cur] == ND_FUNCTION:
            ra_accum_function(cur)
        elif nd_kind[cur] == ND_CLASS:
            # Class methods hang off nd_b (head method chain); each is an
            # ND_FUNCTION promotable exactly like a free function.
            m: uint32 = nd_b[cur]
            while m != 0:
                ra_accum_function(m)
                m = nd_next[m]
        cur = nd_next[cur]


# Count register-resident names whose interval length > RA_LONG_SPAN. A long
# interval crosses intervening instructions (often a branch or a call), which is
# exactly what the callee-saved pool is chosen to make safe. This is a STAT
# proxy, not a correctness assertion.
RA_LONG_SPAN: uint32 = 4
def ra_count_long_inreg() -> uint32:
    c: uint32 = 0
    n: uint32 = 0
    while n < nm_count:
        if ra_assigned_reg[n] != RA_NONE:
            if (lr_end[n] - lr_start[n]) > RA_LONG_SPAN:
                c = c + 1
        n = n + 1
    return c

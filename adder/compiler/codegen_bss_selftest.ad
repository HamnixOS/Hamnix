# adder/compiler/codegen_bss_selftest.ad
#
# Self-hosting milestone — BSS + .data ELF EMIT phase (on-device).
#
# Companion to codegen_elf_selftest.ad. That test proved the native
# RIP-relative path for an all-code program (gdata_len == 0, no globals).
# This test closes the remaining native gap: a program that uses BOTH a
# zero-init array global (.bss — reserves virtual address space only, NO
# file bytes) AND initialised data globals (.data — a string literal and
# a non-zero scalar, stored in the file). The on-device ELF loader zeroes
# the whole p_memsz span before copying p_filesz bytes, so the .bss tail
# is zero on entry; the emitted RIP-relative leaqs reach both regions.
#
# Drives the full Adder-in-Adder pipeline on the device (lex -> parse ->
# codegen -> elf_emit), then dumps the emitted ELF as hex between
# machine-readable sentinels. The host harness (scripts/test_selfhost_bss.sh)
# reconstructs the ELF, stages it at /bin/selfhost_bss_emitted, and in a
# SECOND QEMU boot EXECs it natively at CPL-3.
#
# The compiled program is:
#
#   tag:  Array[8, uint32]            # zero-init array -> .bss
#   name: Array[4, uint8] = "Hi"      # string literal  -> .data ('H','i',0)
#   base: int32 = 10                  # non-zero scalar  -> .data
#   def main() -> int32:
#       tag[0] = 3
#       tag[1] = 4
#       return tag[0] + tag[1] + name[1] + base
#
# main() writes into the .bss array, reads it back, ALSO reads an
# initialised .data byte (name[1] == 'i' == 105) and the .data scalar
# (base == 10), and returns 3 + 4 + 105 + 10 = 122. main() is emitted
# FIRST so it sits at code vaddr 0 — the address the _start stub calls.
# The expected native process exit code is therefore 122.
#
# Build:
#   python3 -m compiler.adder compile --target=x86_64-adder-user \
#       adder/compiler/codegen_bss_selftest.ad \
#       -o build/user/codegen_bss_selftest.elf

from compiler.lexer import (
    lex_init,
    lex_tokenize,
)

from compiler.parser import (
    parser_init,
    parse_program,
    p_err,
    nd_kind,
    nd_b,
    nd_next,
    ND_FUNCTION,
)

from compiler.codegen import (
    cg_init,
    cg_err,
    code_len,
    gen_program_with_globals,
    gdata_len,
    bss_len,
    fn_count,
    CODE_CAP,
)

from compiler.elf_emit import (
    elf_emit_image,
    elf_buf,
    elf_len,
    elf_err,
    elf_entry_vaddr,
)

extern def sys_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64
extern def sys_exit(code: uint64)


def strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def emit(msg: Ptr[uint8]):
    sys_write(1, msg, strlen(msg))


def put_u32(v: uint32):
    if v == 0:
        sys_write(1, "0", 1)
        return
    digits: Array[16, uint8]
    i: uint64 = 0
    n: uint32 = v
    while n != 0:
        digits[i] = cast[uint8](n % 10) + 48
        n = n / 10
        i = i + 1
    out: Array[16, uint8]
    j: uint64 = 0
    while j < i:
        out[j] = digits[i - 1 - j]
        j = j + 1
    sys_write(1, &out[0], i)


# Map a 0..15 nibble to its lowercase hex ASCII digit.
def hex_digit(v: uint32) -> uint32:
    if v < 10:
        return v + 48          # '0'..'9'
    return v + 87              # 'a'..'f'


# Dump elf_buf[0..elf_len) as one continuous lowercase-hex stream,
# wrapped at 64 hex chars (32 bytes) per line for sane serial capture.
def dump_hex():
    line: Array[80, uint8]
    col: uint32 = 0
    i: uint32 = 0
    while i < elf_len:
        b: uint32 = cast[uint32](elf_buf[i])
        line[col] = cast[uint8](hex_digit((b >> 4) & 15))
        col = col + 1
        line[col] = cast[uint8](hex_digit(b & 15))
        col = col + 1
        if col >= 64:
            line[col] = 10        # '\n'
            sys_write(1, &line[0], cast[uint64](col + 1))
            col = 0
        i = i + 1
    if col > 0:
        line[col] = 10
        sys_write(1, &line[0], cast[uint64](col + 1))


def main() -> int32:
    emit("[selfhost_bss_emit] start\n")

    # The REAL Adder program compiled by the self-hosted backend. main()
    # is FIRST (code vaddr 0). `tag` is a zero-init array (.bss), `name`
    # is a string literal global (.data), `base` is a non-zero scalar
    # (.data).
    src: Ptr[uint8] = "tag: Array[8, uint32]\nname: Array[4, uint8] = \"Hi\"\nbase: int32 = 10\ndef main() -> int32:\n    tag[0] = 3\n    tag[1] = 4\n    return tag[0] + tag[1] + name[1] + base\n"
    n: uint32 = cast[uint32](strlen(src))

    lex_init(src, n)
    lex_tokenize()

    parser_init()
    prog: uint32 = parse_program()
    if p_err != 0:
        emit("[selfhost_bss_emit] FAIL: parse error\n")
        sys_exit(2)

    decls: uint32 = nd_b[prog]

    cg_init()
    start: uint32 = gen_program_with_globals(prog)
    if cg_err != 0:
        emit("[selfhost_bss_emit] FAIL: codegen error\n")
        sys_exit(4)
    if start != 0:
        emit("[selfhost_bss_emit] FAIL: entry not at offset 0\n")
        sys_exit(5)

    # The .bss model: zero-init `tag` (8 * 4 = 32 bytes) costs memsz only,
    # NOT file bytes. .data holds only "Hi\0" (3) + base int32 (4) = 7.
    if gdata_len != 7:
        emit("[selfhost_bss_emit] FAIL: gdata_len != 7 (got ")
        put_u32(gdata_len)
        emit(")\n")
        sys_exit(6)
    if bss_len != 32:
        emit("[selfhost_bss_emit] FAIL: bss_len != 32 (got ")
        put_u32(bss_len)
        emit(")\n")
        sys_exit(7)

    emit("[selfhost_bss_emit] codegen ok: code_len=")
    put_u32(code_len)
    emit(" gdata_len=")
    put_u32(gdata_len)
    emit(" bss_len=")
    put_u32(bss_len)
    emit("\n")

    # Wrap the emitted code/data buffers into a complete user ELF (two
    # PT_LOAD segments: code at vaddr 0, data at vaddr CODE_CAP with a
    # memsz-only .bss tail). main() takes no params -> entry arg 0.
    total: uint32 = elf_emit_image(0)
    if elf_err != 0 or total == 0:
        emit("[selfhost_bss_emit] FAIL: ELF emit error\n")
        sys_exit(8)

    emit("[selfhost_bss_emit] elf ok: bytes=")
    put_u32(elf_len)
    emit(" entry_vaddr=")
    put_u32(elf_entry_vaddr)
    emit(" code_cap=")
    put_u32(CODE_CAP)
    emit("\n")

    # Emit the image as hex, bracketed by host-capturable sentinels.
    emit("[selfhost_bss_emit] HEXBEGIN\n")
    dump_hex()
    emit("[selfhost_bss_emit] HEXEND\n")
    emit("[selfhost_bss_emit] PASS\n")
    return 0

# tests/test_compiler_strlen_clamp.ad
#
# Regression fixture for the `strlen` and `clamp` compile-time builtins.
#
# strlen(s: Ptr[uint8]) -> uint64
#   Returns the number of bytes before the first NUL terminator in the string
#   pointed to by `s`. Lowered inline via `repne scasb` — no call, no heap.
#
# clamp(x, lo, hi) -> same type
#   Returns lo if x < lo, hi if x > hi, otherwise x.
#   Lowered inline via two cmpq + cmovl/cmovg — no call, no branch, no heap.
#
# The C driver calls each function and checks the return value.

# ── strlen tests ──────────────────────────────────────────────────────────────

# Static byte-array globals so the C driver can run these without a libc.
empty_str:  Array[4,  uint8] = "\0"
hello_str:  Array[8,  uint8] = "hello"
x_str:      Array[4,  uint8] = "X"
long_str:   Array[16, uint8] = "Hello, World!"

# Empty string: length 0.
def test_strlen_empty() -> int32:
    n: uint64 = strlen(cast[Ptr[uint8]](&empty_str[0]))
    return cast[int32](n)     # expect 0

# "hello": length 5.
def test_strlen_hello() -> int32:
    n: uint64 = strlen(cast[Ptr[uint8]](&hello_str[0]))
    return cast[int32](n)     # expect 5

# Single character "X": length 1.
def test_strlen_one() -> int32:
    n: uint64 = strlen(cast[Ptr[uint8]](&x_str[0]))
    return cast[int32](n)     # expect 1

# String literal pointer (placed in .rodata by the compiler).
def test_strlen_literal() -> int32:
    s: Ptr[uint8] = cast[Ptr[uint8]]("Adder")
    n: uint64 = strlen(s)
    return cast[int32](n)     # expect 5

# Longer string: "Hello, World!" is 13 bytes.
def test_strlen_long() -> int32:
    n: uint64 = strlen(cast[Ptr[uint8]](&long_str[0]))
    return cast[int32](n)     # expect 13

# Two strlen calls in the same function (verify the inline emits correctly
# twice — no label collision, no register conflict).
def test_strlen_twice() -> int32:
    a: uint64 = strlen(cast[Ptr[uint8]](&hello_str[0]))   # 5
    b: uint64 = strlen(cast[Ptr[uint8]](&x_str[0]))       # 1
    return cast[int32](a + b)  # expect 6

# ── clamp tests ───────────────────────────────────────────────────────────────

# x below lo: result is lo.
def test_clamp_below() -> int32:
    result: int32 = clamp(cast[int32](3), cast[int32](10), cast[int32](20))
    return result             # expect 10

# x above hi: result is hi.
def test_clamp_above() -> int32:
    result: int32 = clamp(cast[int32](30), cast[int32](10), cast[int32](20))
    return result             # expect 20

# x within range: result is x.
def test_clamp_mid() -> int32:
    result: int32 = clamp(cast[int32](15), cast[int32](10), cast[int32](20))
    return result             # expect 15

# x exactly at lo: result is lo (not clamped down).
def test_clamp_at_lo() -> int32:
    result: int32 = clamp(cast[int32](10), cast[int32](10), cast[int32](20))
    return result             # expect 10

# x exactly at hi: result is hi (not clamped up).
def test_clamp_at_hi() -> int32:
    result: int32 = clamp(cast[int32](20), cast[int32](10), cast[int32](20))
    return result             # expect 20

# Negative values.
def test_clamp_neg() -> int32:
    result: int32 = clamp(cast[int32](0 - 5), cast[int32](0 - 10), cast[int32](0))
    return result             # expect -5

# clamp with 64-bit values.
def test_clamp_i64() -> int32:
    result: int64 = clamp(cast[int64](1000), cast[int64](500), cast[int64](2000))
    return cast[int32](result)  # expect 1000

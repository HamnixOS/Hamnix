# test_compiler_augmented_assign.ad — compound/augmented assignment operators
#
# Verifies that `a OP= b` is correctly lowered for all supported operators,
# both for simple Identifier targets and for MemberExpr / IndexExpr targets.
#
# Functions return a small integer the C driver can assert without any printf.

class Pair:
    x: int32
    y: int32

# ---- Identifier target tests ----

# x += 1 ten times: 0 + 10*1 = 10
def test_plus_eq() -> int32:
    x: int32 = 0
    i: int32 = 0
    while i < 10:
        x += 1
        i = i + 1
    return x

# x -= 3 five times: 20 - 15 = 5
def test_minus_eq() -> int32:
    x: int32 = 20
    i: int32 = 0
    while i < 5:
        x -= 3
        i = i + 1
    return x

# x *= 2 three times: 3 * 8 = 24
def test_star_eq() -> int32:
    x: int32 = 3
    i: int32 = 0
    while i < 3:
        x *= 2
        i = i + 1
    return x

# flags |= mask repeatedly: 0 | 1 | 2 | 4 = 7
def test_pipe_eq() -> int32:
    flags: int32 = 0
    flags |= 1
    flags |= 2
    flags |= 4
    return flags

# flags &= mask: 0xFF & 0x0F = 15
def test_amp_eq() -> int32:
    flags: int32 = 255
    flags &= 15
    return flags

# flags ^= val: 0b1010 ^ 0b1111 = 0b0101 = 5
def test_caret_eq() -> int32:
    flags: int32 = 10
    flags ^= 15
    return flags

# x <<= 2: 3 << 2 = 12
def test_shl_eq() -> int32:
    x: int32 = 3
    x <<= 2
    return x

# x >>= 1: 24 >> 1 = 12
def test_shr_eq() -> int32:
    x: int32 = 24
    x >>= 1
    return x

# x %= 7: 22 % 7 = 1
def test_mod_eq() -> int32:
    x: int32 = 22
    x %= 7
    return x

# ---- MemberExpr target test ----

# p.x += 5; p.y -= 2: result = p.x + p.y = (10+5) + (8-2) = 21
def test_member_eq() -> int32:
    p: Pair
    p.x = 10
    p.y = 8
    p.x += 5
    p.y -= 2
    return p.x + p.y

# ---- IndexExpr target test ----

# arr[1] += 100: 5 + 100 = 105
def test_index_eq() -> int32:
    arr: Array[4, int32]
    arr[0] = 1
    arr[1] = 5
    arr[2] = 3
    arr[3] = 4
    arr[1] += 100
    return arr[1]

# test_compiler_sizeof.ad — compile-time sizeof(T) builtin
#
# sizeof(T) folds to an integer constant at codegen time: no runtime call,
# no heap, just `movq $N, %rax`. Works for scalars, pointers, arrays, and
# structs (where N is the struct's ABI layout size).
#
# Each function returns the value of sizeof(T) so a C driver can assert.

class TwoInts:
    a: int32
    b: int32

# sizeof scalar types
def sizeof_int8() -> int32:
    return cast[int32](sizeof(int8))

def sizeof_int16() -> int32:
    return cast[int32](sizeof(int16))

def sizeof_int32() -> int32:
    return cast[int32](sizeof(int32))

def sizeof_int64() -> int32:
    return cast[int32](sizeof(int64))

def sizeof_uint8() -> int32:
    return cast[int32](sizeof(uint8))

def sizeof_uint16() -> int32:
    return cast[int32](sizeof(uint16))

def sizeof_uint32() -> int32:
    return cast[int32](sizeof(uint32))

def sizeof_uint64() -> int32:
    return cast[int32](sizeof(uint64))

# sizeof pointer (always 8 on x86_64)
def sizeof_ptr() -> int32:
    return cast[int32](sizeof(Ptr[uint8]))

# sizeof array: Array[N, T] = N * sizeof(T)
def sizeof_arr8() -> int32:
    return cast[int32](sizeof(Array[8, uint8]))

def sizeof_arr4i() -> int32:
    return cast[int32](sizeof(Array[4, int32]))

# sizeof struct: TwoInts = {int32, int32} = 8 bytes
def sizeof_two_ints() -> int32:
    return cast[int32](sizeof(TwoInts))

# sizeof usable in arithmetic expression: sizeof(int32) * 2 = 8
def sizeof_times2() -> int32:
    return cast[int32](sizeof(int32) * 2)

# sizeof in a variable initializer
def sizeof_in_expr() -> int32:
    n: int64 = sizeof(uint64)
    return cast[int32](n)

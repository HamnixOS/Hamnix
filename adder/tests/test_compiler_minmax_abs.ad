# test_compiler_minmax_abs.ad — inline min/max/abs builtins
#
# min(a, b), max(a, b), abs(x) are lowered inline to cmp + cmov — zero
# hidden control flow, zero heap allocation, no call instruction. They are
# only intercepted when the name is not shadowed by a local or user-defined
# function, so user code that defines its own min/max/abs is not affected.
#
# Each function returns a small integer the C driver can assert.

def test_min_a_less() -> int32:
    a: int32 = 3
    b: int32 = 7
    return cast[int32](min(a, b))

def test_min_b_less() -> int32:
    a: int32 = 9
    b: int32 = 2
    return cast[int32](min(a, b))

def test_min_equal() -> int32:
    a: int32 = 5
    b: int32 = 5
    return cast[int32](min(a, b))

def test_max_a_greater() -> int32:
    a: int32 = 9
    b: int32 = 4
    return cast[int32](max(a, b))

def test_max_b_greater() -> int32:
    a: int32 = 2
    b: int32 = 8
    return cast[int32](max(a, b))

def test_max_equal() -> int32:
    a: int32 = 6
    b: int32 = 6
    return cast[int32](max(a, b))

def test_abs_pos() -> int32:
    x: int32 = 5
    return cast[int32](abs(x))

def test_abs_neg() -> int32:
    x: int32 = 0 - 5
    return cast[int32](abs(x))

def test_abs_zero() -> int32:
    x: int32 = 0
    return cast[int32](abs(x))

# min/max on int64
def test_min_i64() -> int32:
    a: int64 = 100
    b: int64 = 200
    return cast[int32](min(a, b))

def test_max_i64() -> int32:
    a: int64 = 100
    b: int64 = 200
    return cast[int32](max(a, b))

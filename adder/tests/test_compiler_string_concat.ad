# test_compiler_string_concat.ad — adjacent string-literal concatenation fixture
#
# Adjacent strings `"foo" "bar"` desugar to a single literal `"foobar"`
# at parse time (the way C and Python work). This file exercises the
# feature so the host-side execution test can verify the emitted bytes.

# All four functions return a known integer derived from inspecting the
# string, so the C driver can assert the values without any printf glue.

def strlen_simple(s: Ptr[uint8]) -> int32:
    n: int32 = 0
    while s[n] != 0:
        n = n + 1
    return n

# Direct adjacent-literal: "Hello, " "World!" -> "Hello, World!"
# Length == 13
def concat_basic() -> int32:
    s: Ptr[uint8] = cast[Ptr[uint8]]("Hello, " "World!")
    return strlen_simple(s)

# Three-way concatenation: "foo" "bar" "baz" -> "foobarbaz"
# Length == 9
def concat_triple() -> int32:
    s: Ptr[uint8] = cast[Ptr[uint8]]("foo" "bar" "baz")
    return strlen_simple(s)

# Mix of escape sequences across adjacent pieces: "\n" "\t" -> "\n\t"
# Length == 2
def concat_escapes() -> int32:
    s: Ptr[uint8] = cast[Ptr[uint8]]("\n" "\t")
    return strlen_simple(s)

# Concatenation inside a function call argument.
# "ab" "cd" -> "abcd", length 4.
def concat_in_arg() -> int32:
    s: Ptr[uint8] = cast[Ptr[uint8]]("ab" "cd")
    return strlen_simple(s)

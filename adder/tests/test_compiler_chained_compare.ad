# test_compiler_chained_compare.ad — Python-style chained comparisons
#
# Python: `a OP1 b OP2 c` means `(a OP1 b) and (b OP2 c)`, NOT the
# C-style `(a OP1 b) OP2 c` where a boolean (0/1) is compared to c.
#
# Tests cover:
#   - Simple 2-link chain (false branch): a < b < c where a > b
#   - Simple 2-link chain (true branch): a < b < c where a < b < c
#   - Range check lo <= x < hi (true branch)
#   - Range check lo <= x < hi (false branch, x >= hi)
#   - 3-link chain (true branch): a < b < c < d
#   - 3-link chain (false branch, middle pair fails): a < b < c < d, b > c
#
# Each function returns 1 (true) or 0 (false) so a C driver can assert.

# 5 < 1 < 3 => False  (5 < 1 is already false)
def test_lt_false() -> int32:
    a: int32 = 5
    b: int32 = 1
    c: int32 = 3
    if a < b < c:
        return 1
    return 0

# 0 < 2 < 5 => True
def test_lt_true() -> int32:
    a: int32 = 0
    b: int32 = 2
    c: int32 = 5
    if a < b < c:
        return 1
    return 0

# Range check: 10 <= 15 < 20 => True
def test_range_true() -> int32:
    lo: int32 = 10
    x: int32 = 15
    hi: int32 = 20
    if lo <= x < hi:
        return 1
    return 0

# Range check: 10 <= 25 < 20 => False  (25 < 20 fails)
def test_range_false() -> int32:
    lo: int32 = 10
    x: int32 = 25
    hi: int32 = 20
    if lo <= x < hi:
        return 1
    return 0

# 3-link: 1 < 2 < 3 < 4 => True
def test_3way_true() -> int32:
    a: int32 = 1
    b: int32 = 2
    c: int32 = 3
    d: int32 = 4
    if a < b < c < d:
        return 1
    return 0

# 3-link: 1 < 5 < 3 < 4 => False  (5 < 3 fails)
def test_3way_false() -> int32:
    a: int32 = 1
    b: int32 = 5
    c: int32 = 3
    d: int32 = 4
    if a < b < c < d:
        return 1
    return 0

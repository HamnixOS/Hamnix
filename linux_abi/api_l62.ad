# linux_abi/api_l62.ad
#
# L62: ships the IPv4/IPv6 netfilter table anchors plus a real
# (non-shim) backing for the seven usb-common helpers that L61 had to
# patch through at the Linux-ABI level. Five Debian 6.12 modules in
# this batch:
#
#   * usb-common.ko        — USB common helpers (LED triggers, fwnode
#                              property strings, match_string); 13 UND,
#                              7 new at L61
#   * ip_tables.ko         — IPv4 netfilter table engine (xt_*, ipt_*,
#                              nf_log_trace, nf_skb_duplicated DATA);
#                              72 UND, 32 new
#   * ip6_tables.ko        — IPv6 netfilter table engine (same as
#                              ip_tables + ipv6_find_hdr); 73 UND, 33
#                              new (32 shared with ip_tables + 1)
#   * iptable_filter.ko    — IPv4 FILTER chain (depends on ip_tables
#                              for ipt_*, adds xt_*_template +
#                              xt_hook_ops_alloc); 14 UND, 8 new
#   * iptable_nat.ko       — IPv4 NAT chain (ipt_* + xt_*_template +
#                              nf_nat_ipv4_register_fn /
#                              _unregister_fn); 17 UND, 9 new (7 shared
#                              with iptable_filter + 2 nf_nat_ipv4_*)
#
# As a side effect this batch also fully covers arp_tables.ko (66 UND,
# all already in the L<=62 surface — the 26 ARP-tables symbols are a
# strict subset of the ip_tables.ko UND set) and iptable_mangle.ko (14
# UND, fully shared with iptable_filter). Those two ride along
# untested but loadable.
#
# This is the first L-batch to land:
#   * xt_table register/find/replace lifecycle (separate from L54's
#     xt_match/xt_target registration surface)
#   * The struct xt_table_info container + per-cpu counter helpers
#   * ipt_* (the iptables-specific glue that sits between ip_tables
#     and individual chain modules — iptable_filter / iptable_nat /
#     iptable_mangle all consume the same five-symbol ipt_* surface)
#   * xt_hook_ops_alloc + xt_register_template / xt_unregister_template
#     (the chain-module registration interface introduced in 6.x)
#   * Three new netfilter DATA exports: xt_recseq (per-cpu seqcount),
#     nf_skb_duplicated (per-cpu uint8 flag), xt_tee_enabled
#     (static-key boolean)
#   * The four usb-common runtime helpers that LED-trigger / fwnode
#     code in modern usb-common.ko reaches for: led_trigger_*,
#     match_string, device_property_read_string,
#     fwnode_property_match_property_string, __dev_fwnode_const DATA
#
# Stub philosophy mirrors L54..L61:
#   * Every shim is init-cold for our env (we have no userspace
#     `iptables` binary attaching rules, no LED hardware, no fwnode
#     graph). Each returns 0 / NULL / void to keep init_module on
#     the happy path.
#   * DATA backings are sized to the largest field offset any init
#     reader touches — 64 bytes is plenty for xt_recseq (a seqcount
#     is two longs), 8 bytes for nf_skb_duplicated (one u8 padded),
#     64 bytes for xt_tee_enabled (static_key is one atomic_t).
#   * The five ipt_* helpers all return success because iptable_filter
#     / iptable_nat / iptable_mangle's init_module body does an early
#     return if ipt_register_table fails. Pre/post exit unregisters
#     are pure void no-ops.
#
# UND analysis (`readelf -s --wide`, missing-after-L61):
#   usb-common.ko        7 missing
#   ip_tables.ko         32 missing
#   ip6_tables.ko        33 missing  (32 shared w/ ip_tables + ipv6_find_hdr)
#   iptable_filter.ko    8 missing   (5 ipt_* + 1 xt_hook_ops_alloc +
#                                       2 xt_*_template)
#   iptable_nat.ko       9 missing   (7 shared w/ iptable_filter +
#                                       nf_nat_ipv4_register_fn /
#                                       nf_nat_ipv4_unregister_fn)
#   arp_tables.ko        0 missing   (all 26 shared w/ ip_tables)
#   iptable_mangle.ko    0 missing   (all 8 shared w/ iptable_filter)
#   union                50 unique
#
# Naming notes:
#   * Adder reserves `bytes`, `match`, `case`, `file` -> renamed to
#     `nbytes` / `mt` / `cse` / `filp`.
#   * The "_l_" prefix marks the Hamnix-side shim; "_l62_" is the
#     L62-specific tag for DATA backings.
#
# Groups (10):
#   1.  xt_table_info lifecycle (alloc / free / replace / check)
#   2.  xt_table register / find / template
#   3.  xt_match / xt_target lookup + check + to_user
#   4.  xt_counters (xt_counters_alloc, percpu, copy)
#   5.  xt_proto_init / xt_proto_fini / xt_hook_ops_alloc
#   6.  ipt_ family (alloc_initial_table, do_table, register/unregister)
#   7.  Netfilter helpers (nf_log_trace, nf_nat_ipv4_*, ipv6_find_hdr)
#   8.  usb-common helpers (LED triggers, fwnode props, match_string)
#   9.  DATA exports (xt_recseq, nf_skb_duplicated, xt_tee_enabled,
#                       __dev_fwnode_const)
#   10. Misc (__copy_overflow, __sw_hweight32)

from linux_abi.exports import _add_export


# =====================================================================
# Group 1: xt_table_info lifecycle
# =====================================================================
#
# Linux:
#   struct xt_table_info *xt_alloc_table_info(unsigned int size);
#   void                  xt_free_table_info(struct xt_table_info *info);
#   struct xt_table_info *xt_replace_table(struct xt_table *table,
#                                            unsigned int num_counters,
#                                            struct xt_table_info *newinfo,
#                                            int *error);
#   int  xt_check_table_hooks(const struct xt_table_info *info,
#                              unsigned int valid_hooks);
#   int  xt_check_entry_offsets(const void *base, const char *elems,
#                                unsigned int target_offset,
#                                unsigned int next_offset);
#
# ip_tables.ko / ip6_tables.ko / arp_tables.ko all consume this set
# from their setsockopt path (IPT_SO_SET_REPLACE) when userspace
# `iptables-restore` would push a new rule table. None of that fires
# at insmod time — the symbol just needs to resolve so the .text
# fragments inside ip_tables.ko can relocate.

def _l_xt_alloc_table_info(size: uint32) -> uint64:
    # struct xt_table_info *xt_alloc_table_info(unsigned int size);
    # Linux uses vmalloc-ish memory for large tables. Stub returns 0
    # (== NULL), which init-path callers in ip_tables don't reach;
    # IPT_SO_SET_REPLACE handlers gracefully fail with -ENOMEM.
    return 0


def _l_xt_free_table_info(info: uint64):
    # void xt_free_table_info(struct xt_table_info *info);
    return


def _l_xt_replace_table(table: uint64, num_counters: uint32,
                         newinfo: uint64, error: uint64) -> uint64:
    # struct xt_table_info *xt_replace_table(...);
    # Returns the old table_info or NULL on error. We write 0 to
    # *error and return NULL — runtime path; insmod doesn't reach.
    if error != 0:
        ep: Ptr[int32] = cast[Ptr[int32]](error)
        ep[0] = 0
    return 0


def _l_xt_check_table_hooks(info: uint64, valid_hooks: uint32) -> int32:
    # int xt_check_table_hooks(const struct xt_table_info *info,
    #                           unsigned int valid_hooks);
    return 0


def _l_xt_check_entry_offsets(base: uint64, elems: uint64,
                                target_offset: uint32,
                                next_offset: uint32) -> int32:
    # int xt_check_entry_offsets(const void *base, const char *elems,
    #                              unsigned int, unsigned int);
    return 0


def _l_xt_alloc_entry_offsets(num: uint32) -> uint64:
    # unsigned int *xt_alloc_entry_offsets(unsigned int num);
    # Real Linux: kvmalloc_array(num, sizeof(unsigned int)). Stub
    # returns NULL; callers (ip_tables setsockopt path) treat that
    # as -ENOMEM.
    return 0


def _l_xt_find_jump_offset(offsets: uint64, target: uint32,
                            size: uint32) -> int32:
    # bool xt_find_jump_offset(const unsigned int *offsets,
    #                           unsigned int target, unsigned int size);
    # Linux returns true if `target` is in the offsets array. Stub
    # returns false (0); not exercised at init time.
    return 0


# =====================================================================
# Group 2: xt_table register / find / template
# =====================================================================
#
# Linux:
#   struct xt_table *xt_register_table(struct net *net,
#                                        const struct xt_table *table,
#                                        struct xt_table_info *bootstrap,
#                                        struct xt_table_info *newinfo);
#   void  xt_unregister_table(struct xt_table *table);
#   struct xt_table *xt_find_table(struct net *net, u8 af, const char *name);
#   struct xt_table *xt_find_table_lock(struct net *net, u8 af,
#                                         const char *name);
#   struct xt_table *xt_request_find_table_lock(struct net *net, u8 af,
#                                                  const char *name);
#   void  xt_table_unlock(struct xt_table *table);
#   int   xt_register_template(const struct xt_table *t,
#                                int(*table_init)(struct net *net));
#   void  xt_unregister_template(const struct xt_table *t);
#
# xt_register_template / xt_unregister_template are the 6.x chain-module
# entry points: iptable_filter.ko's init_module calls xt_register_template
# (passing &packet_filter and iptable_filter_table_init), and the
# matching unregister_template runs at rmmod time.

def _l_xt_register_table(net: uint64, table: uint64, bootstrap: uint64,
                          newinfo: uint64) -> uint64:
    # struct xt_table *xt_register_table(...);
    # Returns the registered table pointer or ERR_PTR(-errno). For our
    # init-cold path the real registration doesn't matter; return the
    # caller-supplied table pointer so a NULL-check passes.
    return table


def _l_xt_unregister_table(table: uint64):
    # void xt_unregister_table(struct xt_table *table);
    return


def _l_xt_find_table(net: uint64, af: uint8, name: uint64) -> uint64:
    # struct xt_table *xt_find_table(struct net *, u8, const char *);
    # Stub returns NULL ("not found"); init paths don't traverse this.
    return 0


def _l_xt_find_table_lock(net: uint64, af: uint8, name: uint64) -> uint64:
    # struct xt_table *xt_find_table_lock(struct net *, u8, const char *);
    # Returns the table with its mutex held, or ERR_PTR(-ENOENT). Stub
    # returns ERR_PTR(-ENOENT) = 0xFFFFFFFFFFFFFFFE so iptables-restore
    # paths fail cleanly instead of dereferencing NULL.
    return 0xFFFFFFFFFFFFFFFE


def _l_xt_request_find_table_lock(net: uint64, af: uint8,
                                    name: uint64) -> uint64:
    # struct xt_table *xt_request_find_table_lock(...);
    # Same return contract as xt_find_table_lock but auto-load via
    # request_module() if not yet present.
    return 0xFFFFFFFFFFFFFFFE


def _l_xt_table_unlock(table: uint64):
    # void xt_table_unlock(struct xt_table *table);
    return


def _l_xt_register_template(t: uint64, table_init: uint64) -> int32:
    # int xt_register_template(const struct xt_table *t,
    #                            int(*table_init)(struct net *net));
    # iptable_filter / iptable_nat / iptable_mangle each call this
    # once at insmod. Returns 0 on success; init body checks and
    # returns on negative.
    return 0


def _l_xt_unregister_template(t: uint64):
    # void xt_unregister_template(const struct xt_table *t);
    return


# =====================================================================
# Group 3: xt_match / xt_target lookup + check + to_user
# =====================================================================
#
# Linux:
#   struct xt_match  *xt_request_find_match(u8 af, const char *name, u8 rev);
#   struct xt_target *xt_request_find_target(u8 af, const char *name, u8 rev);
#   int  xt_find_revision(u8 af, const char *name, u8 revision,
#                          int target, int *err);
#   int  xt_check_match(struct xt_mtchk_param *par,
#                         unsigned int size, u16 proto, bool inv_proto);
#   int  xt_check_target(struct xt_tgchk_param *par,
#                         unsigned int size, u16 proto, bool inv_proto);
#   int  xt_match_to_user(const struct xt_entry_match *m,
#                           struct xt_entry_match __user *u);
#   int  xt_target_to_user(const struct xt_entry_target *t,
#                            struct xt_entry_target __user *u);
#
# request_find_* allocate / take refcount on a match/target; the
# `request` prefix triggers a request_module() call on miss. All
# stubs return 0 / NULL — none fire on insmod, only on
# iptables-restore.

def _l_xt_request_find_match(af: uint8, name: uint64, rev: uint8) -> uint64:
    # struct xt_match *xt_request_find_match(u8 af, const char *name, u8);
    return 0


def _l_xt_request_find_target(af: uint8, name: uint64, rev: uint8) -> uint64:
    # struct xt_target *xt_request_find_target(u8, const char *, u8);
    return 0


def _l_xt_find_revision(af: uint8, name: uint64, revision: uint8,
                         target: int32, err: uint64) -> int32:
    # int xt_find_revision(u8 af, const char *name, u8 revision,
    #                       int target, int *err);
    # On success: writes 0 to *err and returns 1 ("revision exists").
    if err != 0:
        ep: Ptr[int32] = cast[Ptr[int32]](err)
        ep[0] = 0
    return 1


def _l_xt_check_match(par: uint64, size: uint32, proto: uint16,
                       inv_proto: int32) -> int32:
    # int xt_check_match(struct xt_mtchk_param *par, ...);
    return 0


def _l_xt_check_target(par: uint64, size: uint32, proto: uint16,
                        inv_proto: int32) -> int32:
    # int xt_check_target(struct xt_tgchk_param *par, ...);
    return 0


def _l_xt_match_to_user(m: uint64, u: uint64) -> int32:
    # int xt_match_to_user(const struct xt_entry_match *m,
    #                       struct xt_entry_match __user *u);
    return 0


def _l_xt_target_to_user(t: uint64, u: uint64) -> int32:
    # int xt_target_to_user(const struct xt_entry_target *t,
    #                        struct xt_entry_target __user *u);
    return 0


# =====================================================================
# Group 4: xt_counters
# =====================================================================
#
# Linux:
#   struct xt_counters *xt_counters_alloc(unsigned int counters);
#   int  xt_copy_counters(struct xt_counters *counters,
#                          unsigned int num_counters,
#                          const void __user *user, unsigned int len);
#   bool xt_percpu_counter_alloc(struct xt_percpu_counter_alloc_state *,
#                                  struct xt_counters *counter);
#   void xt_percpu_counter_free(struct xt_counters *counter);

def _l_xt_counters_alloc(counters: uint32) -> uint64:
    # struct xt_counters *xt_counters_alloc(unsigned int);
    # Real Linux: vzalloc(counters * sizeof(struct xt_counters)). Stub
    # returns NULL; callers handle as -ENOMEM.
    return 0


def _l_xt_copy_counters(counters: uint64, num_counters: uint32,
                         user: uint64, length: uint32) -> int32:
    # int xt_copy_counters(struct xt_counters *, unsigned int,
    #                       const void __user *, unsigned int);
    return 0


def _l_xt_percpu_counter_alloc(state: uint64, counter: uint64) -> int32:
    # bool xt_percpu_counter_alloc(struct xt_percpu_counter_alloc_state *,
    #                                struct xt_counters *);
    # true == success. Return 1.
    return 1


def _l_xt_percpu_counter_free(counter: uint64):
    # void xt_percpu_counter_free(struct xt_counters *counter);
    return


# =====================================================================
# Group 5: xt_proto_init / xt_proto_fini / xt_hook_ops_alloc
# =====================================================================
#
# Linux:
#   int  xt_proto_init(struct net *net, u8 af);
#   void xt_proto_fini(struct net *net, u8 af);
#   struct nf_hook_ops *xt_hook_ops_alloc(const struct xt_table *table,
#                                            nf_hookfn *fn);
#
# xt_proto_init/fini set up the per-net /proc/net/{ip,ip6,arp}_tables_*
# entries and the per-net `xt[]` table array. ip_tables.ko's pernet
# init reaches xt_proto_init; if it returned a negative the pernet
# subsys registration would unwind. Stub returns 0 (success).
#
# xt_hook_ops_alloc kmallocs a struct nf_hook_ops array sized
# hweight32(table->valid_hooks). iptable_filter calls it once at
# init, then nf_register_net_hooks. Stub returns NULL; that triggers
# iptable_filter's init to set ret = -ENOMEM and bail. To keep the
# happy path, we'd need to allocate a real array — but iptable_filter
# is one of the chain modules and we expect it to load purely for the
# ABI symbol resolution. Return a small zero-init buffer instead so
# the array deref + write of (struct nf_hook_ops){.priv=..., .hook=...
# } from the caller writes into safe storage.

_l62_hook_ops_buf:         Array[256, uint8]


def _l_xt_proto_init(net: uint64, af: uint8) -> int32:
    # int xt_proto_init(struct net *net, u8 af);
    return 0


def _l_xt_proto_fini(net: uint64, af: uint8):
    # void xt_proto_fini(struct net *net, u8 af);
    return


def _l_xt_hook_ops_alloc(table: uint64, fn: uint64) -> uint64:
    # struct nf_hook_ops *xt_hook_ops_alloc(const struct xt_table *,
    #                                         nf_hookfn *);
    # Return our zero-init buffer. iptable_filter.ko's init writes the
    # caller's `fn` pointer into ops[i].hook + ops[i].priv = table,
    # then passes to nf_register_net_hooks (a no-op shim from L<=60).
    # No runtime callback fires.
    return cast[uint64](&_l62_hook_ops_buf[0])


# =====================================================================
# Group 6: ipt_ family (iptables glue)
# =====================================================================
#
# Linux:
#   struct xt_table_info *ipt_alloc_initial_table(const struct xt_table *);
#   unsigned int  ipt_do_table(void *priv, struct sk_buff *skb,
#                                const struct nf_hook_state *state);
#   int  ipt_register_table(struct net *net, const struct xt_table *table,
#                             const struct ipt_replace *repl,
#                             const struct nf_hook_ops *ops);
#   void ipt_unregister_table_pre_exit(struct net *net,
#                                        const char *name);
#   void ipt_unregister_table_exit(struct net *net, const char *name);
#
# iptable_filter / iptable_nat / iptable_mangle each call
# ipt_register_table in their pernet_init (passing their initial repl
# blob built from ipt_alloc_initial_table) and the two unregister
# variants in pernet_pre_exit / pernet_exit. ipt_do_table is the hot
# path; the .text references it but it doesn't fire at init.

def _l_ipt_alloc_initial_table(table: uint64) -> uint64:
    # struct xt_table_info *ipt_alloc_initial_table(const struct xt_table *);
    # Real Linux: kmalloc the initial xt_table_info + memcpy default
    # rules. Stub returns NULL; iptable_filter init body checks and
    # bails with -ENOMEM (still loads — module's .text + .data
    # relocate fine).
    return 0


def _l_ipt_do_table(priv: uint64, skb: uint64, state: uint64) -> uint32:
    # unsigned int ipt_do_table(void *priv, struct sk_buff *skb,
    #                             const struct nf_hook_state *state);
    # Returns one of NF_DROP=0 / NF_ACCEPT=1 / NF_STOLEN=2 / NF_QUEUE=3
    # / NF_REPEAT=4 / NF_STOP=5. Stub returns NF_ACCEPT (1).
    return 1


def _l_ipt_register_table(net: uint64, table: uint64, repl: uint64,
                            ops: uint64) -> int32:
    # int ipt_register_table(struct net *, const struct xt_table *,
    #                          const struct ipt_replace *,
    #                          const struct nf_hook_ops *);
    return 0


def _l_ipt_unregister_table_pre_exit(net: uint64, name: uint64):
    # void ipt_unregister_table_pre_exit(struct net *, const char *);
    return


def _l_ipt_unregister_table_exit(net: uint64, name: uint64):
    # void ipt_unregister_table_exit(struct net *, const char *);
    return


# =====================================================================
# Group 7: Netfilter helpers (nf_log_trace, nf_nat_ipv4_*, ipv6_find_hdr)
# =====================================================================
#
# Linux:
#   void nf_log_trace(struct net *net, u_int8_t pf, unsigned int hooknum,
#                      const struct sk_buff *skb,
#                      const struct net_device *in,
#                      const struct net_device *out,
#                      const struct nf_loginfo *loginfo,
#                      const char *fmt, ...);
#   unsigned int nf_nat_ipv4_register_fn(struct net *net,
#                                          const struct nf_hook_ops *ops);
#   void         nf_nat_ipv4_unregister_fn(struct net *net,
#                                            const struct nf_hook_ops *ops);
#   int  ipv6_find_hdr(const struct sk_buff *skb, unsigned int *offset,
#                       int target, unsigned short *fragoff, int *flags);
#
# nf_log_trace is called from ipt_do_table's TRACE rule path; not
# reached at insmod. The nf_nat_ipv4_* pair is referenced by
# iptable_nat's init. ipv6_find_hdr is consumed by ip6_tables for
# its IPv6 header parsing; only fires on actual packet receive.

def _l_nf_log_trace(net: uint64, pf: uint8, hooknum: uint32,
                     skb: uint64, in_: uint64, out: uint64,
                     loginfo: uint64, fmt: uint64):
    # void nf_log_trace(...); variadic tail dropped (no args at insmod).
    return


def _l_nf_nat_ipv4_register_fn(net: uint64, ops: uint64) -> uint32:
    # unsigned int nf_nat_ipv4_register_fn(struct net *,
    #                                        const struct nf_hook_ops *);
    return 0


def _l_nf_nat_ipv4_unregister_fn(net: uint64, ops: uint64):
    # void nf_nat_ipv4_unregister_fn(struct net *,
    #                                  const struct nf_hook_ops *);
    return


def _l_ipv6_find_hdr(skb: uint64, offset: uint64, target: int32,
                      fragoff: uint64, flags: uint64) -> int32:
    # int ipv6_find_hdr(const struct sk_buff *, unsigned int *offset,
    #                    int target, unsigned short *fragoff, int *flags);
    # Returns next-header value or -ENOENT. Stub returns -ENOENT (-2)
    # so the slow-path bail-out path runs (init-cold).
    return -2


# =====================================================================
# Group 8: usb-common helpers (LED triggers, fwnode, match_string)
# =====================================================================
#
# Linux:
#   void led_trigger_register_simple(const char *name,
#                                      struct led_trigger **tp);
#   void led_trigger_unregister_simple(struct led_trigger *trigger);
#   void led_trigger_blink_oneshot(struct led_trigger *trigger,
#                                    unsigned long delay_on,
#                                    unsigned long delay_off,
#                                    int invert);
#   int  match_string(const char * const *array, size_t n,
#                       const char *string);
#   int  device_property_read_string(struct device *dev,
#                                      const char *propname,
#                                      const char **val);
#   int  fwnode_property_match_property_string(struct fwnode_handle *fwnode,
#                                                const char *propname,
#                                                const char * const *array,
#                                                size_t n);
#
# usb-common.ko registers two LED triggers (usbport's "usb-host" and
# the usb-led "usb_gadget"); none of them ever fire because we have
# no LED class drivers. led_trigger_register_simple writes its second
# arg (`struct led_trigger **`) with the allocated trigger pointer —
# the stub writes a small zero-buffer pointer so dereference-on-
# unregister works.
#
# device_property_read_string and fwnode_property_match_property_string
# are reached from usb-common's "look up usbport-list under
# /sys/firmware/devicetree" path. Both return -ENODATA (-61).

_l62_led_trigger_buf:      Array[64, uint8]


def _l_led_trigger_register_simple(name: uint64, tp: uint64):
    # void led_trigger_register_simple(const char *name,
    #                                    struct led_trigger **tp);
    if tp != 0:
        tpp: Ptr[uint64] = cast[Ptr[uint64]](tp)
        tpp[0] = cast[uint64](&_l62_led_trigger_buf[0])
    return


def _l_led_trigger_unregister_simple(trigger: uint64):
    # void led_trigger_unregister_simple(struct led_trigger *);
    return


def _l_led_trigger_blink_oneshot(trigger: uint64, delay_on: uint64,
                                   delay_off: uint64, invert: int32):
    # void led_trigger_blink_oneshot(...);
    return


def _l_match_string(array: uint64, n: uint64, string: uint64) -> int32:
    # int match_string(const char * const *array, size_t n,
    #                    const char *string);
    # Linear-scan the array for a strcmp match; return the index, or
    # -EINVAL if not found / -EINVAL on NULL. Init-cold: usb-common
    # uses this for LED trigger name lookup which never resolves in
    # our env. Return -EINVAL.
    return -22


def _l_device_property_read_string(dev: uint64, propname: uint64,
                                    val: uint64) -> int32:
    # int device_property_read_string(struct device *dev,
    #                                   const char *propname,
    #                                   const char **val);
    # -ENODATA == no such property.
    return -61


def _l_fwnode_property_match_property_string(fwnode: uint64,
                                               propname: uint64,
                                               array: uint64,
                                               n: uint64) -> int32:
    # int fwnode_property_match_property_string(...);
    # Returns the matched index or -ENODATA.
    return -61


# =====================================================================
# Group 9: DATA exports
# =====================================================================
#
# Linux:
#   DEFINE_PER_CPU(seqcount_t, xt_recseq);                 # per-cpu seqcount
#   DECLARE_PER_CPU(u8, nf_skb_duplicated);                # per-cpu u8
#   struct static_key xt_tee_enabled;                       # static-key bool
#   const struct fwnode_operations dev_fwnode_ops;          # vtable
#
# These are referenced via relocations against the per-cpu base or
# direct address. Init-cold readers never traverse them — but the
# relocation machinery needs a non-NULL address pointing at safe
# storage. 64 bytes per backing covers the worst-case sizeof().
#
# `__dev_fwnode_const` is the `const` alias of `dev_fwnode` Linux
# exports for the device_to_fwnode() inline; ip_tables.ko's USB-port
# header pull (via usbcore -> usb-common -> driver core) drags it in.
# Wait — actually __dev_fwnode_const lives in the driver-core /
# usb-common boundary, not in ip_tables. Still backed by a 64-byte
# zero buffer.

_l62_xt_recseq_buf:        Array[64, uint8]
_l62_nf_skb_duplicated_buf: Array[8, uint8]
_l62_xt_tee_enabled_buf:   Array[64, uint8]
_l62_dev_fwnode_const_buf: Array[64, uint8]


# =====================================================================
# Group 10: Misc helpers (__copy_overflow, __sw_hweight32)
# =====================================================================
#
# Linux:
#   void __noreturn __copy_overflow(unsigned int size, unsigned long count);
#   unsigned int __sw_hweight32(unsigned int w);
#
# __copy_overflow is the panic helper invoked when copy_from_user /
# copy_to_user detect a destination smaller than the requested size
# at compile time. It's __noreturn in Linux; we make it a void return
# (the BUG_ON-like panic would never trigger at init since iptables
# table copies are bounded by their own size constants). If somehow
# called at runtime, returning is technically wrong, but the only way
# to reach this is a kernel-self-overflow which we won't hit.
#
# __sw_hweight32 is the software population-count fallback. Linux
# falls back to it when the CPU lacks POPCNT. Compute it inline.

def _l___copy_overflow(size: uint32, count: uint64):
    # void __noreturn __copy_overflow(unsigned int size, unsigned long);
    # Real Linux: WARN + BUG. Stub returns (treat as panic that didn't
    # fire; safe at init because no caller actually executes here).
    return


def _l___sw_hweight32(w: uint32) -> uint32:
    # unsigned int __sw_hweight32(unsigned int w);
    # Bit-twiddle popcount. SWAR algorithm — same as Linux's fallback.
    x: uint32 = w
    x = x - ((x >> 1) & 0x55555555)
    x = (x & 0x33333333) + ((x >> 2) & 0x33333333)
    x = (x + (x >> 4)) & 0x0f0f0f0f
    x = x + (x >> 8)
    x = x + (x >> 16)
    return x & 0x0000003f


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l62():
    # Called from linux_abi_exports_init() after the L61 batch.
    # Adds 48 new exports for the ip_tables / ip6_tables / arp_tables /
    # iptable_filter / usb-common batch.

    # ---- Group 1: xt_table_info lifecycle ----
    _add_export("xt_alloc_table_info",
                cast[uint64](&_l_xt_alloc_table_info))
    _add_export("xt_free_table_info",
                cast[uint64](&_l_xt_free_table_info))
    _add_export("xt_replace_table",
                cast[uint64](&_l_xt_replace_table))
    _add_export("xt_check_table_hooks",
                cast[uint64](&_l_xt_check_table_hooks))
    _add_export("xt_check_entry_offsets",
                cast[uint64](&_l_xt_check_entry_offsets))
    _add_export("xt_alloc_entry_offsets",
                cast[uint64](&_l_xt_alloc_entry_offsets))
    _add_export("xt_find_jump_offset",
                cast[uint64](&_l_xt_find_jump_offset))

    # ---- Group 2: xt_table register / find / template ----
    _add_export("xt_register_table",
                cast[uint64](&_l_xt_register_table))
    _add_export("xt_unregister_table",
                cast[uint64](&_l_xt_unregister_table))
    _add_export("xt_find_table",
                cast[uint64](&_l_xt_find_table))
    _add_export("xt_find_table_lock",
                cast[uint64](&_l_xt_find_table_lock))
    _add_export("xt_request_find_table_lock",
                cast[uint64](&_l_xt_request_find_table_lock))
    _add_export("xt_table_unlock",
                cast[uint64](&_l_xt_table_unlock))
    _add_export("xt_register_template",
                cast[uint64](&_l_xt_register_template))
    _add_export("xt_unregister_template",
                cast[uint64](&_l_xt_unregister_template))

    # ---- Group 3: xt_match / xt_target lookup + check + to_user ----
    _add_export("xt_request_find_match",
                cast[uint64](&_l_xt_request_find_match))
    _add_export("xt_request_find_target",
                cast[uint64](&_l_xt_request_find_target))
    _add_export("xt_find_revision",
                cast[uint64](&_l_xt_find_revision))
    _add_export("xt_check_match",
                cast[uint64](&_l_xt_check_match))
    _add_export("xt_check_target",
                cast[uint64](&_l_xt_check_target))
    _add_export("xt_match_to_user",
                cast[uint64](&_l_xt_match_to_user))
    _add_export("xt_target_to_user",
                cast[uint64](&_l_xt_target_to_user))

    # ---- Group 4: xt_counters ----
    _add_export("xt_counters_alloc",
                cast[uint64](&_l_xt_counters_alloc))
    _add_export("xt_copy_counters",
                cast[uint64](&_l_xt_copy_counters))
    _add_export("xt_percpu_counter_alloc",
                cast[uint64](&_l_xt_percpu_counter_alloc))
    _add_export("xt_percpu_counter_free",
                cast[uint64](&_l_xt_percpu_counter_free))

    # ---- Group 5: xt_proto + hook ops ----
    _add_export("xt_proto_init",
                cast[uint64](&_l_xt_proto_init))
    _add_export("xt_proto_fini",
                cast[uint64](&_l_xt_proto_fini))
    _add_export("xt_hook_ops_alloc",
                cast[uint64](&_l_xt_hook_ops_alloc))

    # ---- Group 6: ipt_ family ----

                cast[uint64](&_l_device_property_read_string))
    _add_export("fwnode_property_match_property_string",
                cast[uint64](&_l_fwnode_property_match_property_string))

    # ---- Group 9: DATA exports ----
    _add_export("xt_recseq",
                cast[uint64](&_l62_xt_recseq_buf[0]))
    _add_export("nf_skb_duplicated",
                cast[uint64](&_l62_nf_skb_duplicated_buf[0]))
    _add_export("xt_tee_enabled",
                cast[uint64](&_l62_xt_tee_enabled_buf[0]))
    _add_export("__dev_fwnode_const",
                cast[uint64](&_l62_dev_fwnode_const_buf[0]))

    # ---- Group 10: Misc helpers ----
    _add_export("__copy_overflow",
                cast[uint64](&_l___copy_overflow))
    _add_export("__sw_hweight32",
                cast[uint64](&_l___sw_hweight32))

                cast[uint64](&_l_ipt_alloc_initial_table))
    _add_export("ipt_do_table",
                cast[uint64](&_l_ipt_do_table))
    _add_export("ipt_register_table",
                cast[uint64](&_l_ipt_register_table))
    _add_export("ipt_unregister_table_pre_exit",
                cast[uint64](&_l_ipt_unregister_table_pre_exit))
    _add_export("ipt_unregister_table_exit",
                cast[uint64](&_l_ipt_unregister_table_exit))

    # ---- Group 7: Netfilter helpers ----
    _add_export("nf_log_trace",
                cast[uint64](&_l_nf_log_trace))

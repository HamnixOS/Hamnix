# linux_abi/u_libc.ad
#
# Hamnix-authored mini libc.so.6 stub - U-series. Mirrors the
# subset of glibc symbols that real Linux x86_64 binaries link
# against by default. The implementations forward to Hamnix's
# syscall layer (eventually under stock Linux numbers - see
# linux_abi/u_syscalls.ad).
#
# This is a DESIGN scaffold. Functions are declared but bodies
# are placeholder stubs that route to printk0 + return error
# values. Real implementations land in dependency order as
# U-series milestones progress.
#
# Dependency-ordered surface (the subset real Linux binaries
# actually link against):
#   1. printf family (printf, fprintf, sprintf, snprintf, puts,
#      fputs, putc) - depends on memcpy + syscall_write
#   2. malloc family (malloc, free, calloc, realloc) - depends
#      on brk/mmap syscalls
#   3. string family (strlen, strcmp, strcpy, strncpy, memmove,
#      memcpy, memset, memcmp) - pure
#   4. stdio (open, fopen, fclose, fread, fwrite, fgetc, fputc)
#      - depends on syscalls
#   5. errno (errno variable + perror)
#   6. process (exit, abort, getpid, fork, exec*)
#   7. time (time, clock, gettimeofday)
#   8. signal (signal, raise)
#
# For L-track INSIDE THE KERNEL, linux_abi/api_strings.ad already
# has strlen/sprintf etc. This file is the USER-facing parallel:
# when a Linux binary's PT_INTERP-loaded libc.so.6 calls printf,
# the symbol must resolve to a Hamnix-provided implementation
# living here.

from kernel.printk.printk import printk0, printk1
from mm.slab import kmalloc, kfree, kzalloc
from arch.x86.kernel.time import get_jiffies


# C-runtime memcpy / memset — same externs api_strings.ad pulls in.
# Hamnix's freestanding build supplies these from the toolchain. We
# wrap them in the u_memcpy / u_memset shims below so user binaries
# can resolve "memcpy" / "memset" against libc.so.6 without dragging
# in a second copy.
extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# Glibc-shaped errno. Real glibc has __thread int errno per-thread.
# For Hamnix's single-thread model we use a global.
u_errno: int32 = 0


# --- printf family ------------------------------------------------

def u_printf(fmt: Ptr[char]) -> int32:
    # Forward to printk0 for now. Real printf parses %d/%s/%f
    # and forwards bytes via SYS_write(1, ...).
    printk0(fmt)
    return 0

def u_fprintf(stream: uint64, fmt: Ptr[char]) -> int32:
    # Real fprintf routes to a FILE* (fd). For the kernel-side libc
    # shim we ignore the stream and forward to printk0.
    printk0(fmt)
    return 0

def u_sprintf(buf: Ptr[char], fmt: Ptr[char]) -> int32:
    # No real %-format parser yet — treat sprintf as strcpy(buf, fmt).
    # Caller is responsible for buf having room (matches glibc).
    ubuf: uint64 = cast[uint64](buf)
    if ubuf == 0 or cast[uint64](fmt) == 0:
        return 0
    pd: Ptr[uint8] = cast[Ptr[uint8]](buf)
    ps: Ptr[uint8] = cast[Ptr[uint8]](fmt)
    i: uint64 = 0
    while True:
        c: uint8 = ps[i]
        pd[i] = c
        if c == 0:
            return cast[int32](i)
        i = i + 1
    return 0

def u_snprintf(buf: Ptr[char], n: uint64, fmt: Ptr[char]) -> int32:
    # Bounded copy of fmt into buf. Writes at most n bytes total
    # (including the trailing NUL). Returns the number of bytes
    # written excluding the NUL (matches truncation semantics for
    # the simple no-args case).
    ubuf: uint64 = cast[uint64](buf)
    if ubuf == 0 or n == 0 or cast[uint64](fmt) == 0:
        return 0
    pd: Ptr[uint8] = cast[Ptr[uint8]](buf)
    ps: Ptr[uint8] = cast[Ptr[uint8]](fmt)
    # Reserve one byte for the terminator.
    cap: uint64 = n - 1
    i: uint64 = 0
    while i < cap:
        c: uint8 = ps[i]
        if c == 0:
            pd[i] = 0
            return cast[int32](i)
        pd[i] = c
        i = i + 1
    pd[i] = 0
    return cast[int32](i)

def u_puts(s: Ptr[char]) -> int32:
    printk0(s)
    printk0("\n")
    return 0

def u_fputs(s: Ptr[char], stream: uint64) -> int32:
    # Stream is ignored — kernel-side shim routes through printk0.
    printk0(s)
    return 0

def u_putc(c: int32, stream: uint64) -> int32:
    # Emit a single byte via printk0 by building a NUL-terminated
    # 2-byte buffer on the stack.
    tmp: Array[2, uint8]
    tmp[0] = cast[uint8](c & 0xFF)
    tmp[1] = 0
    printk0(cast[Ptr[char]](&tmp[0]))
    return c


# --- malloc family ------------------------------------------------

def u_malloc(size: uint64) -> uint64:
    # Kernel-side libc shim: forward straight to the slab. A real
    # userspace malloc would track chunks and grow via brk/mmap.
    return kmalloc(size)

def u_free(ptr: uint64):
    # glibc's free(NULL) is a no-op since C89. Match it.
    if ptr != 0:
        kfree(ptr)
    return

def u_calloc(nmemb: uint64, size: uint64) -> uint64:
    # Zero-initialised allocation. kzalloc already wraps the slab
    # with a memset, so a single call covers the whole request.
    total: uint64 = nmemb * size
    if total == 0:
        return 0
    return kzalloc(total)

def u_realloc(ptr: uint64, size: uint64) -> uint64:
    # Mirror exports.ad::_linux_krealloc_shim. The slab doesn't
    # expose an object-size lookup, so on grow we just memcpy
    # `size` bytes; the trailing tail may be garbage but the
    # caller's "grow buffer" intent is satisfied.
    if ptr == 0:
        return kmalloc(size)
    if size == 0:
        kfree(ptr)
        return 0
    fresh: uint64 = kmalloc(size)
    if fresh == 0:
        return 0
    memcpy(cast[Ptr[uint8]](fresh),
           cast[Ptr[uint8]](ptr), size)
    kfree(ptr)
    return fresh


# --- string family (pure, no syscalls) ----------------------------
#
# These mirror the in-kernel api_strings.ad helpers but match the
# glibc-shaped signatures user binaries expect (Ptr[char] string
# args, dst returned as uint64 because the loader treats every
# return value as an 8-byte slot). The bodies are hand-rolled —
# no syscalls, no dependency on additional infrastructure. NULL
# inputs are treated defensively (fail safe rather than fault).

def u_strlen(s: Ptr[char]) -> uint64:
    # size_t strlen(const char *s);
    if cast[uint64](s) == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    n: uint64 = 0
    while p[n] != 0:
        n = n + 1
    return n

def u_strcmp(a: Ptr[char], b: Ptr[char]) -> int32:
    # int strcmp(const char *a, const char *b);
    ua: uint64 = cast[uint64](a)
    ub: uint64 = cast[uint64](b)
    if ua == ub:
        return 0
    if ua == 0:
        return -1
    if ub == 0:
        return 1
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pb: Ptr[uint8] = cast[Ptr[uint8]](b)
    i: uint64 = 0
    while True:
        ca: uint8 = pa[i]
        cb: uint8 = pb[i]
        if ca != cb:
            if ca < cb:
                return -1
            return 1
        if ca == 0:
            return 0
        i = i + 1
    return 0

def u_strncmp(a: Ptr[char], b: Ptr[char], n: uint64) -> int32:
    # int strncmp(const char *a, const char *b, size_t n);
    if n == 0:
        return 0
    ua: uint64 = cast[uint64](a)
    ub: uint64 = cast[uint64](b)
    if ua == ub:
        return 0
    if ua == 0:
        return -1
    if ub == 0:
        return 1
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pb: Ptr[uint8] = cast[Ptr[uint8]](b)
    i: uint64 = 0
    while i < n:
        ca: uint8 = pa[i]
        cb: uint8 = pb[i]
        if ca != cb:
            if ca < cb:
                return -1
            return 1
        if ca == 0:
            return 0
        i = i + 1
    return 0

def u_strcpy(dst: Ptr[char], src: Ptr[char]) -> uint64:
    # char *strcpy(char *dst, const char *src);
    # Copies src (including its trailing NUL) into dst. Returns dst.
    udst: uint64 = cast[uint64](dst)
    if udst == 0 or cast[uint64](src) == 0:
        return udst
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    while True:
        c: uint8 = ps[i]
        pd[i] = c
        if c == 0:
            return udst
        i = i + 1
    return udst

def u_strncpy(dst: Ptr[char], src: Ptr[char], n: uint64) -> uint64:
    # char *strncpy(char *dst, const char *src, size_t n);
    # Linux semantics: copies up to n bytes; if src is shorter than n
    # the remainder of dst is zero-filled. If src is longer than n,
    # dst is NOT NUL-terminated.
    udst: uint64 = cast[uint64](dst)
    if udst == 0 or n == 0:
        return udst
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    if cast[uint64](src) == 0:
        i: uint64 = 0
        while i < n:
            pd[i] = 0
            i = i + 1
        return udst
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    src_done: int32 = 0
    while i < n:
        if src_done == 0:
            c: uint8 = ps[i]
            pd[i] = c
            if c == 0:
                src_done = 1
        else:
            pd[i] = 0
        i = i + 1
    return udst

def u_strchr(s: Ptr[char], c: int32) -> uint64:
    # char *strchr(const char *s, int c);
    # Returns pointer to first occurrence of (char)c, or NULL. If
    # c == '\0' the returned pointer is to the trailing NUL itself.
    us: uint64 = cast[uint64](s)
    if us == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    target: uint8 = cast[uint8](c & 0xFF)
    i: uint64 = 0
    while True:
        cur: uint8 = p[i]
        if cur == target:
            return us + i
        if cur == 0:
            return 0
        i = i + 1
    return 0

def u_strrchr(s: Ptr[char], c: int32) -> uint64:
    # char *strrchr(const char *s, int c);
    # Single forward pass; remember the most-recent hit.
    us: uint64 = cast[uint64](s)
    if us == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    target: uint8 = cast[uint8](c & 0xFF)
    last: uint64 = 0
    i: uint64 = 0
    while True:
        cur: uint8 = p[i]
        if cur == target:
            last = us + i
        if cur == 0:
            return last
        i = i + 1
    return last

def u_strstr(haystack: Ptr[char], needle: Ptr[char]) -> uint64:
    # char *strstr(const char *haystack, const char *needle);
    # Empty needle returns haystack (POSIX). NULL inputs return NULL.
    uh: uint64 = cast[uint64](haystack)
    un: uint64 = cast[uint64](needle)
    if uh == 0 or un == 0:
        return 0
    ph: Ptr[uint8] = cast[Ptr[uint8]](haystack)
    pn: Ptr[uint8] = cast[Ptr[uint8]](needle)
    if pn[0] == 0:
        return uh
    i: uint64 = 0
    while ph[i] != 0:
        j: uint64 = 0
        matched: int32 = 1
        while matched == 1:
            nc: uint8 = pn[j]
            if nc == 0:
                return uh + i
            hc: uint8 = ph[i + j]
            if hc == 0:
                return 0
            if hc != nc:
                matched = 0
            else:
                j = j + 1
        i = i + 1
    return 0

def u_strcat(dst: Ptr[char], src: Ptr[char]) -> uint64:
    # char *strcat(char *dst, const char *src);
    # Append src (including its NUL) to dst. Caller is responsible
    # for dst having room.
    udst: uint64 = cast[uint64](dst)
    if udst == 0 or cast[uint64](src) == 0:
        return udst
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    # Walk to end of dst.
    dlen: uint64 = 0
    while pd[dlen] != 0:
        dlen = dlen + 1
    # Copy src bytes including the terminating NUL.
    i: uint64 = 0
    while True:
        c: uint8 = ps[i]
        pd[dlen + i] = c
        if c == 0:
            return udst
        i = i + 1
    return udst

def u_memcpy(dst: uint64, src: uint64, n: uint64) -> uint64:
    # void *memcpy(void *dst, const void *src, size_t n);
    # Wraps the C-runtime memcpy extern.
    if dst == 0 or src == 0 or n == 0:
        return dst
    memcpy(cast[Ptr[uint8]](dst), cast[Ptr[uint8]](src), n)
    return dst

def u_memmove(dst: uint64, src: uint64, n: uint64) -> uint64:
    # void *memmove(void *dst, const void *src, size_t n);
    # Overlap-safe: forward copy when dst < src, backward otherwise.
    if dst == 0 or src == 0 or n == 0:
        return dst
    if dst == src:
        return dst
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    if dst < src:
        memcpy(pd, ps, n)
    else:
        i: uint64 = n
        while i > 0:
            i = i - 1
            pd[i] = ps[i]
    return dst

def u_memset(dst: uint64, c: int32, n: uint64) -> uint64:
    # void *memset(void *dst, int c, size_t n);
    # Wraps the C-runtime memset extern.
    if dst == 0 or n == 0:
        return dst
    memset(cast[Ptr[uint8]](dst), c, n)
    return dst

def u_memcmp(a: uint64, b: uint64, n: uint64) -> int32:
    # int memcmp(const void *a, const void *b, size_t n);
    if n == 0:
        return 0
    if a == b:
        return 0
    if a == 0:
        return -1
    if b == 0:
        return 1
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pb: Ptr[uint8] = cast[Ptr[uint8]](b)
    i: uint64 = 0
    while i < n:
        ca: uint8 = pa[i]
        cb: uint8 = pb[i]
        if ca != cb:
            if ca < cb:
                return -1
            return 1
        i = i + 1
    return 0


# --- stdlib / ctype (pure) ----------------------------------------

def u_atoi(s: Ptr[char]) -> int32:
    # int atoi(const char *s);
    # Skip leading ASCII whitespace, accept an optional '+' or '-',
    # then consume decimal digits. Stops at the first non-digit. No
    # overflow detection (matches glibc atoi — strtol is the safe
    # variant). NULL input returns 0.
    if cast[uint64](s) == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    i: uint64 = 0
    # Skip whitespace: ' ' (32), \t (9), \n (10), \v (11), \f (12),
    # \r (13). The contiguous 9..13 range collapses to one bounded
    # check; ' ' is the lone outlier.
    skipping: int32 = 1
    while skipping == 1:
        ch: uint8 = p[i]
        if ch == cast[uint8](32):
            i = i + 1
        else:
            if ch >= cast[uint8](9) and ch <= cast[uint8](13):
                i = i + 1
            else:
                skipping = 0
    sign: int32 = 1
    sc: uint8 = p[i]
    if sc == cast[uint8](45):       # '-'
        sign = -1
        i = i + 1
    else:
        if sc == cast[uint8](43):   # '+'
            i = i + 1
    acc: int32 = 0
    parsing: int32 = 1
    while parsing == 1:
        d: uint8 = p[i]
        if d < cast[uint8](48) or d > cast[uint8](57):
            parsing = 0
        else:
            acc = acc * 10 + cast[int32](d) - 48
            i = i + 1
    return acc * sign

def u_isdigit(c: int32) -> int32:
    # int isdigit(int c);  -> nonzero if c is a decimal digit.
    if c >= 48 and c <= 57:
        return 1
    return 0

def u_isalpha(c: int32) -> int32:
    # int isalpha(int c);
    if c >= 65 and c <= 90:
        return 1
    if c >= 97 and c <= 122:
        return 1
    return 0

def u_isspace(c: int32) -> int32:
    # int isspace(int c);  -> matches glibc: ' ', \t, \n, \v, \f, \r.
    if c == 32:
        return 1
    if c >= 9 and c <= 13:
        return 1
    return 0

def u_isupper(c: int32) -> int32:
    # int isupper(int c);
    if c >= 65 and c <= 90:
        return 1
    return 0

def u_islower(c: int32) -> int32:
    # int islower(int c);
    if c >= 97 and c <= 122:
        return 1
    return 0


# --- stdio (FILE*-shaped wrappers over syscalls) ------------------

def u_open(path: Ptr[char], flags: int32) -> int32:
    # Full SYS_open / SYS_openat plumbing is L3+ work.
    return -1

def u_close(fd: int32) -> int32:
    # No fd table on the kernel-side libc shim yet.
    return -1

def u_read(fd: int32, buf: uint64, n: uint64) -> int64:
    # No fd table yet.
    return -1

def u_write(fd: int32, buf: uint64, n: uint64) -> int64:
    # stdout/stderr land on printk0; everything else is unsupported.
    if fd == 1 or fd == 2:
        if buf == 0 or n == 0:
            return 0
        printk0(cast[Ptr[char]](buf))
        return cast[int64](n)
    return -1

def u_fopen(path: Ptr[char], mode: Ptr[char]) -> uint64:
    printk0("u_fopen: not yet wired\n")
    return 0

def u_fclose(stream: uint64) -> int32:
    return 0

def u_fread(buf: uint64, size: uint64, nmemb: uint64, stream: uint64) -> uint64:
    return 0

def u_fwrite(buf: uint64, size: uint64, nmemb: uint64, stream: uint64) -> uint64:
    return 0

def u_fgetc(stream: uint64) -> int32:
    return -1

def u_fputc(c: int32, stream: uint64) -> int32:
    return c


# --- errno --------------------------------------------------------

def u_perror(msg: Ptr[char]):
    printk0(msg)
    printk1(": errno=%d\n", cast[uint64](u_errno))
    return


# --- process ------------------------------------------------------

def u_exit(code: int32):
    # Real exit goes through SYS_exit_group; the syscall path isn't
    # wired yet. Log and busy-loop so a stray u_exit() halts the CPU
    # rather than returning into freed stack.
    printk1("u_exit %d\n", cast[uint64](code))
    while True:
        pass
    return

def u_abort():
    # Real abort raises SIGABRT. We have no signal delivery yet —
    # log and busy-loop. (Could route to kernel.panic::panic if we
    # ever decide abort() from a Linux binary should be fatal to the
    # whole kernel, but that's policy. For now: stop forward progress.)
    printk0("u_abort\n")
    while True:
        pass
    return

def u_getpid() -> int32:
    # Real getpid is SYS_getpid (39). No task-struct yet — placeholder.
    return 0

def u_fork() -> int32:
    printk0("u_fork: not supported on Hamnix yet\n")
    return -1

def u_execve(path: Ptr[char], argv: uint64, envp: uint64) -> int32:
    printk0("u_execve: not yet wired through syscall\n")
    return -1


# --- time ---------------------------------------------------------

def u_time() -> uint64:
    # Real time() returns seconds since epoch. No authoritative wall
    # clock yet (RTC read at boot lands in M16.68). For now report
    # seconds since boot via jiffies / HZ (HZ == 100 in Hamnix).
    return get_jiffies() / 100

def u_clock() -> uint64:
    # Real clock() returns CPU ticks. Stub returns 0.
    return 0

def u_gettimeofday(tv: uint64, tz: uint64) -> int32:
    return 0


# --- signal -------------------------------------------------------

def u_signal(signum: int32, handler: uint64) -> uint64:
    printk0("u_signal: signals not yet implemented\n")
    return 0

def u_raise(signum: int32) -> int32:
    printk1("u_raise: would deliver signal %d\n", cast[uint64](signum))
    return 0


# --- registration -------------------------------------------------

def u_libc_init():
    # Future: register the libc.so.6 symbol table under the U-series
    # dynamic linker (u_ldso.ad). For now just print a banner.
    printk0("u_libc: scaffold initialised\n")

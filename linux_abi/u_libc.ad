# linux_abi/u_libc.ad
#
# Hamnix-authored mini libc.so.6 stub - U-series. Mirrors the
# subset of glibc symbols that real Linux x86_64 binaries link
# against by default. The implementations forward to Hamnix's
# syscall layer (eventually under stock Linux numbers - see
# linux_abi/u_syscalls.ad).
#
# This is a DESIGN scaffold. Functions are declared but bodies
# are placeholder stubs that route to printk0 + return error
# values. Real implementations land in dependency order as
# U-series milestones progress.
#
# Dependency-ordered surface (the subset real Linux binaries
# actually link against):
#   1. printf family (printf, fprintf, sprintf, snprintf, puts,
#      fputs, putc) - depends on memcpy + syscall_write
#   2. malloc family (malloc, free, calloc, realloc) - depends
#      on brk/mmap syscalls
#   3. string family (strlen, strcmp, strcpy, strncpy, memmove,
#      memcpy, memset, memcmp) - pure
#   4. stdio (open, fopen, fclose, fread, fwrite, fgetc, fputc)
#      - depends on syscalls
#   5. errno (errno variable + perror)
#   6. process (exit, abort, getpid, fork, exec*)
#   7. time (time, clock, gettimeofday)
#   8. signal (signal, raise)
#
# For L-track INSIDE THE KERNEL, linux_abi/api_strings.ad already
# has strlen/sprintf etc. This file is the USER-facing parallel:
# when a Linux binary's PT_INTERP-loaded libc.so.6 calls printf,
# the symbol must resolve to a Hamnix-provided implementation
# living here.

from kernel.printk.printk import printk0, printk1


# Glibc-shaped errno. Real glibc has __thread int errno per-thread.
# For Hamnix's single-thread model we use a global.
u_errno: int32 = 0


# --- printf family ------------------------------------------------

def u_printf(fmt: Ptr[char]) -> int32:
    # Forward to printk0 for now. Real printf parses %d/%s/%f
    # and forwards bytes via SYS_write(1, ...).
    printk0(fmt)
    return 0

def u_fprintf(stream: uint64, fmt: Ptr[char]) -> int32:
    # Real fprintf routes to a FILE* (fd). Stub to printk0.
    printk0(fmt)
    return 0

def u_sprintf(buf: Ptr[char], fmt: Ptr[char]) -> int32:
    # Real sprintf formats into buf. Stub returns 0.
    printk0("u_sprintf: not yet implemented\n")
    return 0

def u_snprintf(buf: Ptr[char], n: uint64, fmt: Ptr[char]) -> int32:
    printk0("u_snprintf: not yet implemented\n")
    return 0

def u_puts(s: Ptr[char]) -> int32:
    printk0(s)
    printk0("\n")
    return 0

def u_fputs(s: Ptr[char], stream: uint64) -> int32:
    printk0(s)
    return 0

def u_putc(c: int32, stream: uint64) -> int32:
    # Stub. Real putc writes one byte via SYS_write.
    return c


# --- malloc family ------------------------------------------------

def u_malloc(size: uint64) -> uint64:
    # Forward to kmalloc for now. Real malloc tracks chunk metadata
    # and calls brk()/mmap() to grow the heap.
    printk0("u_malloc: not yet wired through syscall\n")
    return 0

def u_free(ptr: uint64):
    return

def u_calloc(nmemb: uint64, size: uint64) -> uint64:
    return 0

def u_realloc(ptr: uint64, size: uint64) -> uint64:
    return 0


# --- string family (pure, no syscalls) ----------------------------

def u_strlen(s: Ptr[char]) -> uint64:
    printk0("u_strlen: not yet implemented\n")
    return 0

def u_strcmp(a: Ptr[char], b: Ptr[char]) -> int32:
    printk0("u_strcmp: not yet implemented\n")
    return 0

def u_strcpy(dst: Ptr[char], src: Ptr[char]) -> uint64:
    printk0("u_strcpy: not yet implemented\n")
    return 0

def u_strncpy(dst: Ptr[char], src: Ptr[char], n: uint64) -> uint64:
    return 0

def u_memmove(dst: uint64, src: uint64, n: uint64) -> uint64:
    return dst

def u_memcpy(dst: uint64, src: uint64, n: uint64) -> uint64:
    return dst

def u_memset(dst: uint64, c: int32, n: uint64) -> uint64:
    return dst

def u_memcmp(a: uint64, b: uint64, n: uint64) -> int32:
    return 0


# --- stdio (FILE*-shaped wrappers over syscalls) ------------------

def u_open(path: Ptr[char], flags: int32) -> int32:
    # Real open forwards to SYS_open / SYS_openat.
    printk0("u_open: not yet wired through syscall\n")
    return -1

def u_fopen(path: Ptr[char], mode: Ptr[char]) -> uint64:
    printk0("u_fopen: not yet wired\n")
    return 0

def u_fclose(stream: uint64) -> int32:
    return 0

def u_fread(buf: uint64, size: uint64, nmemb: uint64, stream: uint64) -> uint64:
    return 0

def u_fwrite(buf: uint64, size: uint64, nmemb: uint64, stream: uint64) -> uint64:
    return 0

def u_fgetc(stream: uint64) -> int32:
    return -1

def u_fputc(c: int32, stream: uint64) -> int32:
    return c


# --- errno --------------------------------------------------------

def u_perror(msg: Ptr[char]):
    printk0(msg)
    printk1(": errno=%d\n", cast[uint64](u_errno))
    return


# --- process ------------------------------------------------------

def u_exit(code: int32):
    printk1("u_exit: would call SYS_exit_group(%d)\n", cast[uint64](code))
    return

def u_abort():
    printk0("u_abort: SIGABRT would fire here\n")
    return

def u_getpid() -> int32:
    # Real getpid is SYS_getpid (39). Stub returns 1.
    return 1

def u_fork() -> int32:
    printk0("u_fork: not supported on Hamnix yet\n")
    return -1

def u_execve(path: Ptr[char], argv: uint64, envp: uint64) -> int32:
    printk0("u_execve: not yet wired through syscall\n")
    return -1


# --- time ---------------------------------------------------------

def u_time() -> uint64:
    # Real time() returns seconds since epoch. We don't have
    # an authoritative wall clock yet (M16.68 RTC reads it
    # at boot; jiffies could supply seconds-since-boot for now).
    return 0

def u_clock() -> uint64:
    # Real clock() returns CPU ticks. Stub returns 0.
    return 0

def u_gettimeofday(tv: uint64, tz: uint64) -> int32:
    return 0


# --- signal -------------------------------------------------------

def u_signal(signum: int32, handler: uint64) -> uint64:
    printk0("u_signal: signals not yet implemented\n")
    return 0

def u_raise(signum: int32) -> int32:
    printk1("u_raise: would deliver signal %d\n", cast[uint64](signum))
    return 0


# --- registration -------------------------------------------------

def u_libc_init():
    # Future: register the libc.so.6 symbol table under the U-series
    # dynamic linker (u_ldso.ad). For now just print a banner.
    printk0("u_libc: scaffold initialised\n")

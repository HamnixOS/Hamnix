# linux_abi/api_irq.ad - L11 shims (Linux IRQ ABI).
#
# Stock Linux drivers wire interrupts through one of two near-identical
# entry points. The classic top-half-only form is request_irq; drivers
# that want to do the bulk of their work in a kernel thread reach for
# request_threaded_irq, where `handler` runs in IRQ context just long
# enough to ACK the device and decide whether the threaded `thread_fn`
# should be woken. M4.1 in the .ko regression suite walks this surface:
#
#   typedef irqreturn_t (*irq_handler_t)(int irq, void *dev_id);
#
#   int  request_irq(unsigned int irq, irq_handler_t handler,
#                    unsigned long flags, const char *name, void *dev);
#   int  request_threaded_irq(unsigned int irq, irq_handler_t handler,
#                             irq_handler_t thread_fn,
#                             unsigned long flags, const char *name,
#                             void *dev);
#   void free_irq(unsigned int irq, void *dev_id);
#   void synchronize_irq(unsigned int irq);
#
# Implementation strategy (L11 scope):
#
# Hamnix doesn't yet route hardware IDT vectors into module-registered
# handlers. The point of L11 is purely the registration shape: a module
# must be able to call request_irq() in its init path and free_irq()
# in its exit path without the loader exploding, and the matching slot
# bookkeeping has to be in place so a later milestone can wire it into
# the real ISR dispatch (arch/x86/kernel/idt.ad picks up the slot table
# and demuxes incoming vectors against handler_addr at that point).
#
# A 16-slot static table parallels the layout used by api_proc.ad and
# api_chrdev.ad — parallel arrays, indexed by slot, with the IRQ number
# itself used as a uniqueness key (irq 0 sentinels "free"). Linux's
# usual IRQ space goes 0..223 on x86_64 (the high vectors are reserved
# for IPIs and the local APIC); the M4.1 fixture uses 0x42 = 66, well
# inside that range.
#
# Threaded variant: the secondary thread_fn pointer is recorded but
# not started. When idt.ad lands, it'll spawn a kthread per non-NULL
# thread_fn slot using the L8 kthread machinery; for now we just keep
# the address live so the symmetric free_irq path can reason about it.
#
# free_irq's Linux prototype is `void free_irq(unsigned int, void *)`,
# but the kernel's actual implementation returns the dev_id cookie via
# its internal __free_irq path. The exported symbol is `void`-typed,
# so the caller discards anything we return — we keep uint64 here for
# the loader's uniform 8-byte relocation slot (same convention used by
# _l_unregister_chrdev in api_chrdev.ad).
#
# IRQF_* flags: Linux's <linux/interrupt.h> defines a couple dozen of
# these. M4.1 passes 0 (no flags), so for L11 we just expose the names
# that real drivers commonly reference at compile time. The shim itself
# stashes the flag bits verbatim — the IDT dispatcher in a later
# milestone is what acts on IRQF_SHARED / IRQF_TRIGGER_* / etc.

from linux_abi.exports import _add_export
from arch.x86.kernel.irq import register_irq_handler
from kernel.printk.printk import printk0, printk1, printk2
from kernel.sched.core import (
    kthread_create, WaitQueue, wq_init, wq_wait_prepare, wq_wait_cancel,
    wq_wait_commit, wq_wake_one,
)


# --- IRQF_* flag constants ------------------------------------------
#
# Values match include/linux/interrupt.h in Linux 6.12. We expose them
# here as named globals so future ad-side code (the IDT wire-in) can
# check the stored flag bits by name rather than magic numbers. Modules
# themselves carry these as their own #defines from <linux/interrupt.h>;
# the loader doesn't need to resolve them as symbols, but documenting
# them in this file keeps the L11 surface self-contained.

IRQF_TRIGGER_NONE:    uint64 = 0x00000000
IRQF_TRIGGER_RISING:  uint64 = 0x00000001
IRQF_TRIGGER_FALLING: uint64 = 0x00000002
IRQF_TRIGGER_HIGH:    uint64 = 0x00000004
IRQF_TRIGGER_LOW:     uint64 = 0x00000008
IRQF_SHARED:          uint64 = 0x00000080
IRQF_PROBE_SHARED:    uint64 = 0x00000100
IRQF_TIMER:           uint64 = 0x00000200
IRQF_PERCPU:          uint64 = 0x00000400
IRQF_NOBALANCING:     uint64 = 0x00000800
IRQF_IRQPOLL:         uint64 = 0x00001000
IRQF_ONESHOT:         uint64 = 0x00002000
IRQF_NO_SUSPEND:      uint64 = 0x00004000
IRQF_FORCE_RESUME:    uint64 = 0x00008000
IRQF_NO_THREAD:       uint64 = 0x00010000
IRQF_EARLY_RESUME:    uint64 = 0x00020000
IRQF_COND_SUSPEND:    uint64 = 0x00040000


# --- 64-slot static IRQ registration table --------------------------
#
# Slot layout (parallel arrays, same pattern as api_chrdev.ad):
#   irq_slot_irq      : IRQ number; 0 means "free slot"
#                       (Linux IRQ 0 is the timer and is never claimed
#                        via request_irq from a module, so 0 stays
#                        usable as a free-slot sentinel)
#   irq_slot_handler  : top-half handler address (irq_handler_t)
#   irq_slot_thread   : threaded handler address; 0 if not threaded
#   irq_slot_flags    : IRQF_* bits passed in at request time
#   irq_slot_name     : caller-owned Ptr[char] cast to uint64
#   irq_slot_dev      : the void *dev cookie; passed back to the
#                       handler and required to match on free_irq.
#
# Slot count: 64. NVMe with 16 MSI-X vectors + e1000e + ahci + r8169 +
# virtio queues fit comfortably; bumped from 16 when the MSI-X pool
# went in (see _l_irq_alloc_msix_vector below).

MAX_IRQ_SLOTS: uint64 = 64

irq_slot_irq:     Array[64, uint32]
irq_slot_handler: Array[64, uint64]
irq_slot_thread:  Array[64, uint64]
irq_slot_flags:   Array[64, uint64]
irq_slot_name:    Array[64, uint64]
irq_slot_dev:     Array[64, uint64]


def _irq_find_free_slot() -> int32:
    # Returns slot index 0..MAX_IRQ_SLOTS-1, or -1 if full.
    i: uint64 = 0
    while i < MAX_IRQ_SLOTS:
        if irq_slot_irq[i] == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _irq_find_by_irq(irq: uint32, dev: uint64) -> int32:
    # Linux looks up by (irq, dev_id) — shared IRQs (IRQF_SHARED) can
    # have multiple registrations on the same line, distinguished by
    # dev_id. We don't materialize shared chains yet, but the dev_id
    # match below is still the right key: a free_irq() on (irq, dev)
    # has to find the slot whose dev_cookie matches what was passed
    # to the corresponding request_irq().
    i: uint64 = 0
    while i < MAX_IRQ_SLOTS:
        if irq_slot_irq[i] == irq:
            if irq_slot_dev[i] == dev:
                return cast[int32](i)
        i = i + 1
    return -1


# --- M16-pivot.c: Linux-handler -> Fn[None] trampoline --------------
#
# Hamnix's IRQ dispatcher (arch/x86/kernel/irq.ad) calls a registered
# Fn[None] handler when the IDT fires. Linux's irq_handler_t is
# `irqreturn_t (*)(int irq, void *dev_id)` — a different signature.
# We bridge them with a per-vector trampoline that reads back the
# stored Linux handler + (irq, dev_id) from the L11 slot table and
# invokes it through a first-class function pointer cast.
#
# For the e1000e bring-up V0 we hard-code a single dedicated
# trampoline at vector 0x47 (E1000E_IRQ_VECTOR — re-used from the
# hand-rolled driver's MSI programming). If a future driver needs
# a different vector we add another trampoline; for now one is
# sufficient.
#
# The trampoline runs in IRQ context. The LAPIC EOI is handled by
# do_irq() after this returns (we MUST NOT EOI here — see the
# guard in arch/x86/kernel/irq.ad).

E1000E_MSI_VECTOR_FOR_L_TRAMP: uint32 = 0x47

# irqreturn_t values (include/linux/irqreturn.h).
IRQ_NONE:        int32 = 0
IRQ_HANDLED:     int32 = 1
IRQ_WAKE_THREAD: int32 = 2


# ====================================================================
# THREADED IRQ THREADS
# ====================================================================
#
# request_threaded_irq(handler, thread_fn, ...) registers a hard-IRQ top
# half (`handler`) that runs in interrupt context just long enough to ACK
# the device and decide whether the heavy `thread_fn` should run. When the
# top half returns IRQ_WAKE_THREAD (or when there is NO primary handler —
# the "default primary" oneshot pattern), we wake a dedicated kthread that
# runs thread_fn(irq, dev_id) in process context, so a heavy handler does
# NOT execute in hard-IRQ context (low IRQ latency, the whole point).
#
# kthread_create takes a no-arg entry, so we bind a fixed pool of
# per-thread trampolines to threaded-IRQ slot indices: irqthread_tramp[k]
# drives the k-th threaded registration. Each has its own wait queue; the
# top half sets irqthread_pending[k] and wq_wake_one()s it.

MAX_IRQ_THREADS: uint64 = 8

irqthread_slot:    Array[8, int32]      # owning irq_slot index, -1 = free
irqthread_fn:      Array[8, uint64]     # thread_fn address
irqthread_dev:     Array[8, uint64]     # dev_id cookie
irqthread_irq:     Array[8, uint32]     # irq number (for thread_fn arg)
irqthread_pending: Array[8, uint64]     # 1 = top half asked us to run
irqthread_wq:      Array[8, WaitQueue]
irqthread_in_use:  Array[8, uint64]     # 1 = spawned
irqthread_runs:    Array[8, uint64]     # diagnostic: thread_fn invocations
irqthread_tramp:   Array[8, Fn[None]]
irqthread_tramp_init: uint64 = 0


def _irqthread_body(k: uint64):
    # The per-thread loop: sleep until the top half wakes us, then run
    # thread_fn(irq, dev_id) in CPL0 process context.
    while True:
        wq_wait_prepare(&irqthread_wq[k])
        if irqthread_pending[k] != 0:
            wq_wait_cancel(&irqthread_wq[k])
        else:
            wq_wait_commit(&irqthread_wq[k])
        # Consume the pending flag and run thread_fn (possibly several
        # coalesced wakeups -> one run, which is the oneshot contract).
        if irqthread_pending[k] != 0:
            irqthread_pending[k] = 0
            fn: uint64 = irqthread_fn[k]
            if fn != 0:
                tfn: Fn[int32, uint32, uint64] = \
                    cast[Fn[int32, uint32, uint64]](fn)
                tfn(irqthread_irq[k], irqthread_dev[k])
                irqthread_runs[k] = irqthread_runs[k] + 1


def _irqthread_tramp_0():
    _irqthread_body(0)


def _irqthread_tramp_1():
    _irqthread_body(1)


def _irqthread_tramp_2():
    _irqthread_body(2)


def _irqthread_tramp_3():
    _irqthread_body(3)


def _irqthread_tramp_4():
    _irqthread_body(4)


def _irqthread_tramp_5():
    _irqthread_body(5)


def _irqthread_tramp_6():
    _irqthread_body(6)


def _irqthread_tramp_7():
    _irqthread_body(7)


def _irqthread_tramp_pool_init():
    if irqthread_tramp_init != 0:
        return
    irqthread_tramp_init = 1
    irqthread_tramp[0] = _irqthread_tramp_0
    irqthread_tramp[1] = _irqthread_tramp_1
    irqthread_tramp[2] = _irqthread_tramp_2
    irqthread_tramp[3] = _irqthread_tramp_3
    irqthread_tramp[4] = _irqthread_tramp_4
    irqthread_tramp[5] = _irqthread_tramp_5
    irqthread_tramp[6] = _irqthread_tramp_6
    irqthread_tramp[7] = _irqthread_tramp_7
    j: uint64 = 0
    while j < MAX_IRQ_THREADS:
        irqthread_slot[j] = -1
        irqthread_in_use[j] = 0
        irqthread_pending[j] = 0
        wq_init(&irqthread_wq[j])
        j = j + 1


def _irqthread_spawn(slot: uint64, irq: uint32, thread_fn: uint64,
                     dev: uint64) -> int32:
    # Allocate a thread index, spawn its kthread, bind it to irq_slot
    # `slot`. Returns the thread index, or -1 on failure.
    _irqthread_tramp_pool_init()
    k: uint64 = 0
    while k < MAX_IRQ_THREADS:
        if irqthread_in_use[k] == 0:
            irqthread_in_use[k]  = 1
            irqthread_slot[k]    = cast[int32](slot)
            irqthread_fn[k]      = thread_fn
            irqthread_dev[k]     = dev
            irqthread_irq[k]     = irq
            irqthread_pending[k] = 0
            # name0 = 'irq#thr\0' — character 0 in the TOP byte, the
            # order _buf_put_name0 (fs/procfs.ad) decodes.
            name0: uint64 = 0x6972712374687200
            sched_slot: int32 = kthread_create(
                cast[uint64](irqthread_tramp[k]), name0)
            if sched_slot < 0:
                irqthread_in_use[k] = 0
                return -1
            printk2("[irq-thread] spawned for irq 0x%x thread_fn=%p\n",
                    cast[uint64](irq), thread_fn)
            return cast[int32](k)
        k = k + 1
    printk0("[irq-thread] pool exhausted (8/8)\n")
    return -1


def _irqthread_wake_for_irq(irq: uint32):
    # Top half asked the thread for `irq` to run: set pending + wake.
    k: uint64 = 0
    while k < MAX_IRQ_THREADS:
        if irqthread_in_use[k] != 0 and irqthread_irq[k] == irq:
            irqthread_pending[k] = 1
            wq_wake_one(&irqthread_wq[k])
        k = k + 1


def _l_msix_dispatch(vector: uint32):
    # Generic per-vector dispatch path. Look up the slot whose irq
    # matches `vector` and call the registered Linux irq_handler_t
    # with (irq, dev_id). irq_handler_t returns irqreturn_t (IRQ_NONE
    # / IRQ_HANDLED / IRQ_WAKE_THREAD); we discard the value because
    # we don't materialise the shared-IRQ demux chain at this layer
    # (each MSI-X vector is by construction single-handler) and the
    # threaded-wake path is consumed only by request_threaded_irq's
    # secondary kthread, which isn't running yet.
    #
    # This function is called from BOTH the dedicated e1000e
    # trampoline (vector 0x47, kept for back-compat with the
    # single-MSI-vector wire-up commit e26cf32) and from each of the
    # 16 hand-rolled MSI-X pool trampolines (_l_msix_tramp_50 ..
    # _l_msix_tramp_5F). Centralising the lookup keeps the slot-
    # table layout single-sourced.
    #
    # SHARED-IRQ DEMUX: vector 0x47 is the generic single-MSI delivery
    # vector that EVERY device's pci_enable_msi programs (e1000e NIC +
    # snd_hda_intel's azx controller both land here). So a single
    # vector can have multiple registered handlers. We must call ALL
    # of them, not just the first — each Linux irq_handler_t reads its
    # own device's interrupt-status register and returns IRQ_NONE when
    # the interrupt wasn't its source, exactly like Linux's shared-IRQ
    # action chain. Calling only the first handler (the original
    # behaviour) meant the HDA controller's azx_interrupt never ran
    # when e1000e had already claimed slot 0 on irq 0x47, so the RIRB
    # was never drained and codec verb reads timed out.
    i: uint64 = 0
    while i < MAX_IRQ_SLOTS:
        if irq_slot_irq[i] == vector:
            h_addr: uint64 = irq_slot_handler[i]
            t_addr: uint64 = irq_slot_thread[i]
            d_cookie: uint64 = irq_slot_dev[i]
            if h_addr != 0:
                hfn: Fn[int32, uint32, uint64] = \
                    cast[Fn[int32, uint32, uint64]](h_addr)
                rc: int32 = hfn(vector, d_cookie)
                # THREADED IRQ: a primary handler that returns
                # IRQ_WAKE_THREAD asks us to run the registered thread_fn
                # in process context — wake the bound irq-thread instead
                # of running thread_fn here in hard-IRQ context.
                if rc == IRQ_WAKE_THREAD and t_addr != 0:
                    _irqthread_wake_for_irq(vector)
            elif t_addr != 0:
                # No primary handler but a thread_fn registered: the
                # "default primary" oneshot pattern. Linux's
                # irq_default_primary_handler returns IRQ_WAKE_THREAD
                # unconditionally — so always wake the thread.
                _irqthread_wake_for_irq(vector)
        i = i + 1


def _l_e1000e_irq_trampoline():
    # Back-compat alias for the e1000e single-MSI-vector wire-up
    # (commit e26cf32). Vector 0x47 is reserved for the e1000e MSI
    # path; the MSI-X pool starts at 0x50 so it can't collide.
    _l_msix_dispatch(E1000E_MSI_VECTOR_FOR_L_TRAMP)


# --- MSI-X IDT vector pool ------------------------------------------
#
# Per-vector trampolines for the 0x50..0x5F MSI-X dispatch band.
# Each trampoline is a tiny shim that forwards to _l_msix_dispatch
# with its own (compile-time-constant) vector number. We need 16
# distinct function pointers because the IDT dispatch table
# (arch/x86/kernel/irq.ad::irq_handlers) is keyed by IDT vector and
# Adder's Fn[None] type can't carry per-instance state — closures
# aren't supported. The trampoline-per-vector pattern matches the
# way Linux's arch/x86/kernel/idt.c generates per-vector entry stubs.
#
# The pool starts at 0x50 (immediately past the existing 0x40..0x4F
# band used by INTx/single-MSI consumers: virtio-net INTx 0x40,
# virtio-blk 0x43, e1000e MSI 0x47, virtio-net MSI-X 0x49..0x4B) and
# runs through 0x5F. 16 vectors is enough for nvme on a 1-CPU box
# (admin queue + 15 IO queues). idt.ad's irq band runs 32..95, so
# 0x50..0x5F is firmly inside the populated IDT gates / irq_stub
# table.
#
# Pool state: msix_pool_in_use[i] is 1 if pool slot i (vector
# 0x50+i) is allocated, 0 if free. msix_pool_name[i] mirrors the
# caller-supplied diagnostic name (so /proc/interrupts-style dumps
# could format it later); unused at the moment but cheap.

MSIX_POOL_BASE_VECTOR: uint32 = 0x50
MSIX_POOL_SIZE:        uint64 = 16

msix_pool_in_use: Array[16, uint32]
msix_pool_name:   Array[16, uint64]


def _l_msix_tramp_50():
    _l_msix_dispatch(0x50)


def _l_msix_tramp_51():
    _l_msix_dispatch(0x51)


def _l_msix_tramp_52():
    _l_msix_dispatch(0x52)


def _l_msix_tramp_53():
    _l_msix_dispatch(0x53)


def _l_msix_tramp_54():
    _l_msix_dispatch(0x54)


def _l_msix_tramp_55():
    _l_msix_dispatch(0x55)


def _l_msix_tramp_56():
    _l_msix_dispatch(0x56)


def _l_msix_tramp_57():
    _l_msix_dispatch(0x57)


def _l_msix_tramp_58():
    _l_msix_dispatch(0x58)


def _l_msix_tramp_59():
    _l_msix_dispatch(0x59)


def _l_msix_tramp_5A():
    _l_msix_dispatch(0x5A)


def _l_msix_tramp_5B():
    _l_msix_dispatch(0x5B)


def _l_msix_tramp_5C():
    _l_msix_dispatch(0x5C)


def _l_msix_tramp_5D():
    _l_msix_dispatch(0x5D)


def _l_msix_tramp_5E():
    _l_msix_dispatch(0x5E)


def _l_msix_tramp_5F():
    _l_msix_dispatch(0x5F)


# Static dispatch table: pool index -> trampoline Fn[None] for that
# vector. Populated once at boot via _l_msix_pool_init() because
# Adder doesn't currently emit .quad relocations to function symbols
# in static array initialisers when the array is declared at file
# scope (the e1000e single-trampoline path uses runtime &fn-as-
# uint64 + cast for the same reason).
msix_pool_tramp: Array[16, Fn[None]]
msix_pool_tramp_initialised: uint32 = 0


def _l_msix_pool_init():
    # Idempotent one-shot initialiser. Called lazily from
    # _l_irq_alloc_msix_vector so the pool comes alive on first use
    # without ordering against linux_abi_exports_init.
    if msix_pool_tramp_initialised != 0:
        return
    msix_pool_tramp_initialised = 1
    msix_pool_tramp[0]  = _l_msix_tramp_50
    msix_pool_tramp[1]  = _l_msix_tramp_51
    msix_pool_tramp[2]  = _l_msix_tramp_52
    msix_pool_tramp[3]  = _l_msix_tramp_53
    msix_pool_tramp[4]  = _l_msix_tramp_54
    msix_pool_tramp[5]  = _l_msix_tramp_55
    msix_pool_tramp[6]  = _l_msix_tramp_56
    msix_pool_tramp[7]  = _l_msix_tramp_57
    msix_pool_tramp[8]  = _l_msix_tramp_58
    msix_pool_tramp[9]  = _l_msix_tramp_59
    msix_pool_tramp[10] = _l_msix_tramp_5A
    msix_pool_tramp[11] = _l_msix_tramp_5B
    msix_pool_tramp[12] = _l_msix_tramp_5C
    msix_pool_tramp[13] = _l_msix_tramp_5D
    msix_pool_tramp[14] = _l_msix_tramp_5E
    msix_pool_tramp[15] = _l_msix_tramp_5F


def _l_irq_alloc_msix_vector(name: uint64) -> int32:
    # Reserve one MSI-X IDT vector from the 0x50..0x5F pool and
    # install its trampoline at irq_handlers[vector] so a future
    # device write to LAPIC:vector dispatches into _l_msix_dispatch,
    # which then looks up the (irq=vector, handler, dev_id) tuple in
    # the slot table the Linux driver's request_irq populated.
    # Returns the allocated IDT vector (0x50..0x5F) on success, or
    # -1 if the pool is exhausted. `name` is recorded for diagnostics.
    _l_msix_pool_init()
    i: uint64 = 0
    while i < MSIX_POOL_SIZE:
        if msix_pool_in_use[i] == 0:
            msix_pool_in_use[i] = 1
            msix_pool_name[i]   = name
            vector: uint32 = MSIX_POOL_BASE_VECTOR + cast[uint32](i)
            register_irq_handler(cast[uint64](vector),
                                 msix_pool_tramp[i])
            printk1("[msix] allocated IDT vector 0x%x\n",
                    cast[uint64](vector))
            return cast[int32](vector)
        i = i + 1
    printk0("[msix] vector pool exhausted (16 / 16 in use)\n")
    return -1


def _l_irq_free_msix_vector(vector: uint32):
    # Release a previously-allocated MSI-X IDT vector. We zero the
    # in_use bit + name; the irq_handlers[vector] slot is left set
    # to the trampoline (a stray late delivery dispatches through
    # _l_msix_dispatch which scans the slot table and finds no
    # matching irq — silent drop, which is what Linux does for an
    # IRQ that fires post-free_irq).
    if vector < MSIX_POOL_BASE_VECTOR:
        return
    idx: uint32 = vector - MSIX_POOL_BASE_VECTOR
    if cast[uint64](idx) >= MSIX_POOL_SIZE:
        return
    msix_pool_in_use[cast[uint64](idx)] = 0
    msix_pool_name[cast[uint64](idx)]   = 0


# --- request_irq / request_threaded_irq -----------------------------

def _l_request_irq(irq: uint32, handler: uint64, flags: uint64,
                   name: uint64, dev: uint64) -> int32:
    # Linux semantics:
    #   irq == 0 is the timer — modules aren't supposed to claim it.
    #   We accept it anyway (no negative-errno return here is harmless
    #   for L11) so M4.1's fixed-pick of irq 0x42 isn't a special case.
    # Returns 0 on success, -EBUSY (-16) if the IRQ is already claimed
    # by a non-shareable handler, -ENOMEM (-12) if the slot table is
    # full.
    #
    # L11 does NOT touch the IDT. The handler is recorded for the
    # later milestone that wires arch/x86/kernel/idt.ad to consult
    # this table — at that point a real interrupt on `irq` calls
    # handler(irq, dev). Until then it's pure bookkeeping.

    # Reject IRQF_SHARED collisions only when dev_id matches — Linux's
    # rule is "two non-shared handlers on the same line is -EBUSY".
    # For L11 we approximate that with a simpler "any existing slot
    # for this irq with the same dev_id is a collision".
    if _irq_find_by_irq(irq, dev) >= 0:
        return -16                                # -EBUSY

    slot: int32 = _irq_find_free_slot()
    if slot < 0:
        return -12                                # -ENOMEM

    s: uint64 = cast[uint64](slot)
    irq_slot_irq[s]     = irq
    irq_slot_handler[s] = handler
    irq_slot_thread[s]  = 0
    irq_slot_flags[s]   = flags
    irq_slot_name[s]    = name
    irq_slot_dev[s]     = dev

    # M16-pivot.c: when the Linux driver's request_irq lands on our
    # e1000e bring-up vector, install the trampoline so the IDT
    # dispatcher's Fn[None] entry calls back into the real Linux
    # handler with the (irq, dev_id) args Linux drivers expect.
    if irq == E1000E_MSI_VECTOR_FOR_L_TRAMP:
        printk2("[request_irq] linux handler @ %p dev_id=%p -> vector 0x47 trampoline\n",
                handler, dev)
        register_irq_handler(cast[uint64](E1000E_MSI_VECTOR_FOR_L_TRAMP),
                             _l_e1000e_irq_trampoline)
    elif irq >= MSIX_POOL_BASE_VECTOR and \
         irq < (MSIX_POOL_BASE_VECTOR + cast[uint32](MSIX_POOL_SIZE)):
        # Vector belongs to the MSI-X pool. _l_irq_alloc_msix_vector
        # already installed its trampoline at irq_handlers[vector],
        # so we just leave a diagnostic trail and let dispatch pick
        # the slot up from the table populated above.
        printk2("[request_irq] linux handler @ %p -> MSI-X vector 0x%x\n",
                handler, cast[uint64](irq))
    return 0


def _l_request_threaded_irq(irq: uint32, handler: uint64,
                             thread_fn: uint64, flags: uint64,
                             name: uint64, dev: uint64) -> int32:
    # Threaded variant: same bookkeeping plus the secondary thread_fn
    # pointer. The IDT wire-in milestone is what'll spawn a kthread
    # against thread_fn; for L11 we just keep the address live. A
    # NULL `handler` with a non-NULL `thread_fn` is the "default
    # primary handler" pattern (Linux's __setup_irq inserts
    # irq_default_primary_handler in that case) — we accept it as-is.
    if _irq_find_by_irq(irq, dev) >= 0:
        return -16                                # -EBUSY

    slot: int32 = _irq_find_free_slot()
    if slot < 0:
        return -12                                # -ENOMEM

    s: uint64 = cast[uint64](slot)
    irq_slot_irq[s]     = irq
    irq_slot_handler[s] = handler
    irq_slot_thread[s]  = thread_fn
    irq_slot_flags[s]   = flags
    irq_slot_name[s]    = name
    irq_slot_dev[s]     = dev
    # THREADED IRQ: actually SPAWN the irq thread now. The top half wakes
    # it (IRQ_WAKE_THREAD or default-primary) and thread_fn runs in the
    # kthread, NOT in hard-IRQ context. Spawn only once per irq number.
    if thread_fn != 0:
        if _irqthread_find_for_irq(irq) < 0:
            _irqthread_spawn(s, irq, thread_fn, dev)
    if irq == E1000E_MSI_VECTOR_FOR_L_TRAMP:
        printk2("[request_threaded_irq] linux handler @ %p dev_id=%p -> vector 0x47 trampoline\n",
                handler, dev)
        register_irq_handler(cast[uint64](E1000E_MSI_VECTOR_FOR_L_TRAMP),
                             _l_e1000e_irq_trampoline)
    elif irq >= MSIX_POOL_BASE_VECTOR and \
         irq < (MSIX_POOL_BASE_VECTOR + cast[uint32](MSIX_POOL_SIZE)):
        printk2("[request_threaded_irq] linux handler @ %p -> MSI-X vector 0x%x\n",
                handler, cast[uint64](irq))
    return 0


def _irqthread_find_for_irq(irq: uint32) -> int32:
    # Return the thread index already bound to `irq`, or -1.
    k: uint64 = 0
    while k < MAX_IRQ_THREADS:
        if irqthread_in_use[k] != 0 and irqthread_irq[k] == irq:
            return cast[int32](k)
        k = k + 1
    return -1


def _l_free_irq(irq: uint32, dev: uint64) -> uint64:
    # Linux: void free_irq(unsigned int, void *) — but kernel-internal
    # __free_irq returns the dev_id cookie of the removed registration.
    # The exported symbol is void-typed; uniformly returning uint64
    # here keeps the loader's relocation slot regular (see api_chrdev.ad
    # _l_unregister_chrdev for the same pattern).
    #
    # A free_irq() on an unregistered (irq, dev) pair is a soft warning
    # in real Linux (printk + WARN_ON); for L11 we silently no-op so
    # the M4.1 teardown path stays clean.
    slot: int32 = _irq_find_by_irq(irq, dev)
    if slot < 0:
        return 0
    s: uint64 = cast[uint64](slot)
    irq_slot_irq[s]     = 0
    irq_slot_handler[s] = 0
    irq_slot_thread[s]  = 0
    irq_slot_flags[s]   = 0
    irq_slot_name[s]    = 0
    irq_slot_dev[s]     = 0
    return 0                                      # NULL (matches Linux's void)


def _l_synchronize_irq(irq: uint32):
    # Real Linux: spins until any in-flight handler for `irq` has
    # returned, then returns. On a uniprocessor + cooperative kernel
    # with no IDT routing yet, no handler can ever be in flight, so
    # the post-condition holds trivially. No-op.
    return


# --- threaded-IRQ selftest --------------------------------------------
#
# Proves request_threaded_irq actually SPAWNS a thread and runs thread_fn
# in thread (kthread) context, not in the hard-IRQ top half. The primary
# handler returns IRQ_WAKE_THREAD and records an ordering tick; the
# dispatch (_l_msix_dispatch, the hard-IRQ path) only WAKES the thread; a
# later yield lets the thread run thread_fn, which records a strictly
# later ordering tick. So thread_tick > handler_tick proves deferral.

irqt_test_order: uint64 = 0
irqt_test_handler_tick: uint64 = 0
irqt_test_thread_tick: uint64 = 0
irqt_test_thread_ran: uint64 = 0
IRQT_TEST_VECTOR: uint32 = 0x50          # MSI-X pool base


def _irqt_test_handler(irq: uint32, dev: uint64) -> int32:
    # Hard-IRQ top half: record order, ask for the thread.
    irqt_test_order = irqt_test_order + 1
    irqt_test_handler_tick = irqt_test_order
    return IRQ_WAKE_THREAD


def _irqt_test_thread_fn(irq: uint32, dev: uint64) -> int32:
    # Threaded bottom half: runs in the kthread, AFTER dispatch returned.
    irqt_test_order = irqt_test_order + 1
    irqt_test_thread_tick = irqt_test_order
    irqt_test_thread_ran = 1
    return IRQ_HANDLED


def irq_threaded_selftest_register():
    # Phase 1 (run from process context): register the threaded IRQ so its
    # kthread is spawned. Must run with the scheduler up.
    _l_request_threaded_irq(IRQT_TEST_VECTOR,
                            cast[uint64](&_irqt_test_handler),
                            cast[uint64](&_irqt_test_thread_fn),
                            0, 0, 0)


def irq_threaded_selftest_fire():
    # Phase 2: simulate the IRQ via the hard-IRQ dispatch path. This runs
    # the top half (records handler_tick, returns IRQ_WAKE_THREAD) and
    # wakes the thread; thread_fn does NOT run yet (it's a kthread).
    _l_msix_dispatch(IRQT_TEST_VECTOR)


def irq_threaded_selftest_thread_ran() -> uint64:
    return irqt_test_thread_ran


def irq_threaded_selftest_ordered() -> uint64:
    # 1 if thread_fn ran strictly AFTER the hard-IRQ handler (deferred).
    if irqt_test_thread_ran == 0:
        return 0
    if irqt_test_thread_tick > irqt_test_handler_tick:
        return 1
    return 0


# --- registration ---------------------------------------------------

def linux_abi_register_irq():
    # Called once from linux_abi_exports_init alongside the other
    # per-subsystem registrations. Order doesn't matter — the export
    # table is name-keyed — but grouping by milestone keeps the boot
    # log readable.
    _add_export("request_irq",
                cast[uint64](&_l_request_irq))
    _add_export("request_threaded_irq",
                cast[uint64](&_l_request_threaded_irq))
    _add_export("free_irq",
                cast[uint64](&_l_free_irq))
    _add_export("synchronize_irq",
                cast[uint64](&_l_synchronize_irq))

# linux_abi/api_alx.ad
#
# Multi-NIC scale-out (round 2), Qualcomm Atheros (alx.ko) leg. The
# stock Debian alx.ko (covering AR8161/AR8162/AR8171/AR8172 — common
# in Asus/Acer/HP laptops) has 106 UND symbols; 102 are already
# exported by L1..L68 + api_e1000e/r8169/igb. This file closes the
# remaining 4-symbol gap:
#
#   * dev_kfree_skb_any_reason  — kfree_skb variant carrying a drop
#                                  reason enum
#   * mdio_mii_ioctl            — generic MII ioctl forwarder, used
#                                  by the MAC's .ndo_eth_ioctl path
#   * pcie_get_readrq           — read the PCIe device's current
#                                  Max Read Request Size
#   * pci_ioremap_bar           — map a PCI BAR into the kernel
#                                  iomem space (one-shot variant)
#
# All four are init-cold (alx's probe path; ioctl never fires at
# insmod). Stubbed to plausible benign returns so probe completes.
#
# Naming convention: "_alx_" prefix marks the Hamnix-side shim,
# matching the established "_e1k_" / "_r8k_" / "_igb_" prefixes.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree, kzalloc


# =====================================================================
# Group 1: sk_buff with drop reason
# =====================================================================
#
# dev_kfree_skb_any_reason is the newer (post-5.15) sk_buff free that
# carries a drop-reason enum for the kfree_skb tracepoint. Every NIC
# driver in 6.12+ calls this from its TX cleanup / RX drop paths.
# We treat it as a plain free (the drop-reason ftrace tracepoint we
# don't have anyway). Backing free mirrors the e1000e/r8169 sk_buff
# layout (kzalloc base == skb pointer; just kfree(skb) — NULL-safe).

def _alx_dev_kfree_skb_any_reason(skb: uint64, reason: int32):
    # void dev_kfree_skb_any_reason(struct sk_buff *, enum
    #                                 skb_drop_reason);
    # Both flavours (irq + process context). NULL-safe.
    if skb == 0:
        return
    kfree(skb)


# =====================================================================
# Group 2: MII ioctl forwarder
# =====================================================================
#
# mdio_mii_ioctl is libphy's generic MII ioctl handler. The driver's
# .ndo_eth_ioctl points at it (or wraps it) so userspace can do
# `ethtool -r ethN` etc. With no PHY behind the MAC, every read
# returns 0xffff and writes are dropped. -ENOTSUPP would also work,
# but returning 0 keeps the ioctl path silent.

def _alx_mdio_mii_ioctl(mii: uint64, mii_data: uint64, cmd: int32) -> int32:
    # int mdio_mii_ioctl(const struct mii_if_info *, struct mii_ioctl_data *,
    #                     int cmd);
    # Init-cold; the only consumer is userspace ioctl which doesn't
    # fire at insmod. Return success (0) so the driver doesn't surface
    # an error to user-space if anything calls into the path.
    return 0


# =====================================================================
# Group 3: PCIe extensions
# =====================================================================

def _alx_pcie_get_readrq(pdev: uint64) -> int32:
    # int pcie_get_readrq(struct pci_dev *);
    # Returns the device's current Max Read Request Size, in bytes.
    # Linux returns one of 128, 256, 512, 1024, 2048, 4096. The most
    # conservative + safest default is 128 — every PCIe device supports
    # at least that, and the driver uses the value only to gate further
    # tuning (`if (readrq < target) pcie_set_readrq(...)`).
    return 128


def _alx_pci_ioremap_bar(pdev: uint64, bar: int32) -> uint64:
    # void __iomem *pci_ioremap_bar(struct pci_dev *, int bar);
    # One-shot helper: read the BAR's base/length from the pci_dev and
    # ioremap it. Hamnix is identity-mapped, so we can return the BAR
    # phys address directly. The pci_dev layout is owned by api_pci.ad;
    # rather than depend on that struct we lean on the fact that QEMU's
    # AR816x emulation isn't a thing — alx's probe will bail at
    # pci_match_id before touching iomem on our env. Returning 0 (NULL)
    # would cause an OOPS on a real device; instead, hand back a benign
    # 4-KiB scratch page that absorbs MMIO reads/writes harmlessly.
    return kzalloc(4096)


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_alx():
    # 4 new exports beyond api_e1000e + api_r8169 + api_igb. Owns the
    # symbols that recur across the round-2 NIC batch (alx is registered
    # first; atlantic/sky2/tg3 reuse the same names via the global
    # _add_export table).
    _add_export("dev_kfree_skb_any_reason",
                cast[uint64](&_alx_dev_kfree_skb_any_reason))
    _add_export("mdio_mii_ioctl",
                cast[uint64](&_alx_mdio_mii_ioctl))
    _add_export("pcie_get_readrq",
                cast[uint64](&_alx_pcie_get_readrq))
    _add_export("pci_ioremap_bar",
                cast[uint64](&_alx_pci_ioremap_bar))

# linux_abi/u_memfd_secret.ad -- the Linux memfd_secret(2) syscall (nr 447).
#
# memfd_secret() returns an anonymous file fd backed by RAM that is NOT
# exposed through /proc/PID/mem and is NOT mappable by anyone else, even
# the kernel during context switches (Linux pins it at a kernel-private
# direct map). It is the modern "secret buffer" primitive that crypto
# libraries (gnutls, libgcrypt, OpenSSL 3.x with secure-heap enabled),
# secret-store daemons (gnome-keyring, secret-service), and language
# runtimes use to hold key material that must survive process-internal
# memory disclosure attacks (heap spraying, /proc/self/mem cat, core
# dump). Tools that probe for it: glibc 2.34+ (a memfd_secret available
# guard around malloc_arena_safety code), libsodium's secure_alloc
# fallback, and any new systemd-credential consumer.
#
#   int memfd_secret(unsigned int flags)
#
# Flags (uapi/linux/memfd.h):
#   FD_CLOEXEC (0x80000)  -- set close-on-exec on the new fd.
#
# Strategy in Hamnix:
#   * memfd_secret is mechanically a memfd_create with extra "no
#     /proc/PID/mem read" enforcement on top. We allocate a real
#     tmpfs-backed memfd (via vfs_open_memfd, the same primitive
#     memfd_create uses), then mark the resulting fd "secret" in a
#     per-fd bitmap maintained here. Read/write/lseek/ftruncate on the
#     fd works -- the OWNING task can use the buffer normally.
#   * The "no /proc/PID/mem readback" half is enforceable by the
#     existing /proc/PID/mem reader checking memfd_secret_is_secret(fd)
#     and skipping pages backed by a secret memfd. The native
#     /proc/PID/mem path here (devproc) doesn't expose arbitrary task
#     memory at all (it only surfaces ctl/stat/cmdline files), so the
#     enforcement is already in place by absence -- which IS the design:
#     a path that cannot be opened to read raw process memory cannot
#     leak a memfd_secret either. The bitmap is the hook for any future
#     /proc reader to gate against.
#   * The signature is intentionally compatible with future hardening:
#     callers test secret-ness via memfd_secret_is_secret(fd) without
#     having to know how the per-fd state is stored.
#
# Layer: confined Layer-2 leaf. Imports only fs/vfs's memfd primitive +
# printk + uaccess. It does not touch 9P / Chan / Layer-1 code.

from fs.vfs import (
    vfs_open_memfd,
)
from kernel.printk.printk import (
    printk0, printk1,
)


# Linux flags accepted by memfd_secret(2). Only FD_CLOEXEC is defined;
# any other bit -> EINVAL.
MFS_FD_CLOEXEC:  uint64 = 0x80000
MFS_VALID_FLAGS: uint64 = 0x80000

# Negative-errno convention.
MFS_EINVAL: int64 = -22
MFS_ENOSYS: int64 = -38

# Per-fd "is this fd backed by a memfd_secret?" bitmap. Indexed by the
# raw fd number; capped at MFS_FD_CAP which mirrors the Linux-ABI fd
# table size (_VFS_NR_FDS). Updates happen only at memfd_secret(2)
# allocation and at fd close (mfs_close_fd hook); reads are O(1).
MFS_FD_CAP: uint64 = 16
_mfs_secret_bitmap: Array[16, uint8]


def memfd_secret_init():
    # Called once at u_syscalls_init() bring-up. Zero the bitmap so a
    # cold boot starts with no fd marked secret (the table itself is
    # BSS-zeroed; the explicit init is documentation + defense against
    # a relink that ever changes BSS semantics).
    i: uint64 = 0
    while i < MFS_FD_CAP:
        _mfs_secret_bitmap[i] = 0
        i = i + 1


def memfd_secret_mark(fd: int32):
    # Internal: record `fd` as backed by a memfd_secret. Bounds-check the
    # raw fd to defend against a corrupted return from vfs_open_memfd.
    if fd < 0:
        return
    fdu: uint64 = cast[uint64](fd)
    if fdu >= MFS_FD_CAP:
        return
    _mfs_secret_bitmap[fdu] = 1


def memfd_secret_is_secret(fd: int32) -> int32:
    # PUBLIC: any future /proc/PID/mem reader (or coredump / ptrace
    # PEEKDATA path) should call this before exposing the bytes a memfd
    # holds; returns 1 iff the fd was allocated via memfd_secret(2).
    # A bad/closed fd -> 0 (not secret) per the simplest safe default
    # (the caller's own access-check will reject a bad fd anyway).
    if fd < 0:
        return 0
    fdu: uint64 = cast[uint64](fd)
    if fdu >= MFS_FD_CAP:
        return 0
    if _mfs_secret_bitmap[fdu] != 0:
        return 1
    return 0


def memfd_secret_close_fd(fd: int32):
    # PUBLIC: called from the central close path (_u_close in
    # u_syscalls.ad) when an fd is being released, so a future fd
    # allocation that reuses the same slot starts non-secret. Idempotent.
    if fd < 0:
        return
    fdu: uint64 = cast[uint64](fd)
    if fdu >= MFS_FD_CAP:
        return
    _mfs_secret_bitmap[fdu] = 0


# =====================================================================
# memfd_secret(flags)  --  nr 447
# =====================================================================
def memfd_secret_handler(a0: uint64, a1: uint64, a2: uint64,
                         a3: uint64, a4: uint64, a5: uint64) -> int64:
    flags: uint64 = a0
    # Reject unknown flags (Linux do_memfd_secret valid-flags check).
    if (flags & ~MFS_VALID_FLAGS) != 0:
        return MFS_EINVAL
    # Allocate a real anonymous memfd backing. Name is fixed ("secret")
    # because the syscall takes no name argument. MFD_ALLOW_SEALING is
    # NOT set: a Linux memfd_secret cannot be sealed independently of
    # its address-space pinning, and we mirror that by not enabling the
    # tmpfs sealing flag on this slot.
    name: Ptr[char] = "secret"
    fd: int32 = vfs_open_memfd(name, 0)
    if fd < 0:
        return cast[int64](fd)
    # Mark the new fd as backed by a memfd_secret. MFD_CLOEXEC handling
    # is a documented no-op here (no FD_CLOEXEC bitmap on this Layer-2
    # surface), matching the rest of u_syscalls.ad's stance for the
    # *_CLOEXEC flag bits.
    memfd_secret_mark(fd)
    return cast[int64](fd)

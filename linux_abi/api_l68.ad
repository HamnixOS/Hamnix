# linux_abi/api_l68.ad
#
# L68: ships six more Debian 6.12 modules. Three are pure ride-alongs
# (zero new exports — every UND symbol already covered by L<=67); the
# other three need 6 new exports across two small groups.
#
#   * xt_owner.ko        — netfilter `-m owner` match (matches packets
#                            by the originating socket's uid/gid; the
#                            classic `iptables -m owner --uid-owner`).
#                            9 UND, 0 missing. Fully covered by L<=67:
#                            const_pcpu_hot DATA, __fentry__, make_kgid,
#                            make_kuid, _raw_read_{lock,unlock}_bh,
#                            __x86_return_thunk, xt_register_match,
#                            xt_unregister_match. Test-only.
#   * xt_REDIRECT.ko     — netfilter `-j REDIRECT` target (the iptables
#                            sibling of nft_redir; rewrites a packet's
#                            destination to a local port for transparent
#                            proxying). 10 UND, 0 missing — the L66
#                            nf_nat_redirect_ipv4 / _ipv6 batch plus the
#                            L54 nf_ct_netns_get/_put and xt_register_
#                            targets / xt_unregister_targets surface
#                            already cover everything. Test-only.
#   * nft_nat.ko         — nftables `nat` expression (the runtime that
#                            backs `snat to <addr>` and `dnat to <addr>`
#                            rules; nftables sibling of `iptables -j
#                            SNAT/DNAT`). 13 UND, 0 missing — every
#                            symbol lands on the L<=67 surface:
#                            nf_ct_netns_get/_put (L54), nf_nat_setup_
#                            info (L60), nft_chain_validate_dependency /
#                            nft_chain_validate_hooks / nft_dump_register
#                            / nft_parse_register_load (L65/L66),
#                            nft_register_expr / nft_unregister_expr
#                            (L65), nla_put (L55), and the fentry /
#                            return-thunk / stack-chk standards.
#                            Test-only.
#   * nft_quota.ko       — nftables `quota` stateful object + expression
#                            (counts bytes against a configured cap;
#                            consumed by `quota over 1 mbytes drop`
#                            style rules). 14 UND, 3 new (nft_obj_notify,
#                            nft_register_obj, nft_unregister_obj).
#   * nft_limit.ko       — nftables `limit` expression + stateful object
#                            (token-bucket rate-limit; `limit rate 10/
#                            second`). 16 UND, 0 unique missing — both
#                            new symbols beyond nft_quota
#                            (nft_register_obj / nft_unregister_obj)
#                            already ship with nft_quota above. The
#                            remaining UND lands on the L<=67 surface
#                            plus ktime_get (L57) and the _raw_spin_
#                            lock_bh / unlock_bh pair (L50).
#   * xt_socket.ko       — netfilter `-m socket` match (transparent-
#                            proxy aid: matches packets that already
#                            have a local socket lookup, the basis for
#                            TPROXY-style flows). 14 UND, 3 new
#                            (nf_sk_lookup_slow_v4, nf_sk_lookup_slow_
#                            v6, sock_gen_put). Other UND lands on the
#                            L<=67 surface (xt_register_matches /
#                            xt_unregister_matches, nf_defrag_ipv4/v6_
#                            enable/disable, ___ratelimit, __warn_
#                            printk, _printk, fentry, return-thunk,
#                            stack-chk).
#
# Module count in tests/linux-modules/ after L68: 58 + 6 = 64.
#
# UND analysis (`nm -u`, missing-after-L67):
#   xt_owner.ko        0 missing
#   xt_REDIRECT.ko     0 missing
#   nft_nat.ko         0 missing
#   nft_quota.ko       3 missing
#   nft_limit.ko       2 missing (both shipped by nft_quota above)
#   xt_socket.ko       3 missing
#   union              6 unique
#
# 6 new exports across 2 groups:
#
#   1.  nftables stateful-object registry + notify
#         (nft_register_obj, nft_unregister_obj, nft_obj_notify)
#   2.  Netfilter socket lookup + sock refcount put
#         (nf_sk_lookup_slow_v4, nf_sk_lookup_slow_v6, sock_gen_put)
#
# Stub philosophy mirrors L51..L67: every shim is init-cold for our
# env (no userspace nftables ruleset, no live netfilter packet path,
# no real socket table). Each returns success / 0 / NULL / void so
# init_module stays on the happy path. The two nf_sk_lookup_slow_*
# entries return NULL (== "no matching socket") because they're
# packet-path lookups that only fire from inside a hook chain we
# never traverse at insmod.
#
# Naming notes:
#   * Adder reserves `bytes`, `match`, `case`, `file`, `field`, `type`
#     -> renamed where they would collide (nft_obj_notify's `report`
#     arg is fine).
#   * The "_l_" prefix marks the Hamnix-side shim.

from linux_abi.exports import _add_export


# =====================================================================
# Group 1: nftables stateful-object registry + notify (nft_quota, nft_limit)
# =====================================================================
#
# Linux:
#   int  nft_register_obj(struct nft_object_type *obj_type);
#   void nft_unregister_obj(struct nft_object_type *obj_type);
#   void nft_obj_notify(struct net *net, const struct nft_table *table,
#                          struct nft_object *obj, u32 portid, u32 seq,
#                          int event, u16 flags, int family, int report,
#                          gfp_t gfp);
#
# nft_register_obj / nft_unregister_obj:
#   Called from each nft_*_obj module's init_module / cleanup_module
#   to publish a stateful-object operator into the nf_tables core's
#   nft_object_type list. Both nft_quota.ko and nft_limit.ko register
#   one object type each on insmod. In Hamnix there is no nf_tables
#   core (deferred until a later L milestone), so the register stub
#   just returns 0 ("registered ok") and unregister is void — same
#   convention as L65's nft_register_expr / nft_unregister_expr pair.
#
# nft_obj_notify:
#   Fires a netlink notification for stateful-object state changes
#   (typically when a quota object is exhausted or reset). With no
#   netlink listener wired through nf_tables in our env, the
#   notification has no consumer; pure no-op. Real Linux builds an
#   NFT_MSG_NEWOBJ skb and feeds it through nfnetlink_send.

def _l_nft_register_obj(obj_type: uint64) -> int32:
    # 0 == "registered ok". The real Linux body grabs nf_tables_mutex
    # and pushes obj_type onto the nft_object_type list; we have no
    # list to push onto, so the stub is a pure success return that
    # keeps nft_quota / nft_limit init_module on the happy path.
    return 0


def _l_nft_unregister_obj(obj_type: uint64):
    # cleanup_module never runs in our env; no-op.
    return


def _l_nft_obj_notify(net: uint64, table: uint64, obj: uint64,
                       portid: uint32, seq: uint32, event: int32,
                       flags: uint16, family: int32, report: int32,
                       gfp: uint32):
    # No netlink listener wired through nf_tables; the notification
    # has no consumer. Pure no-op — never reached at insmod (only
    # fires from the runtime rule-commit / quota-exhaust path).
    return


# =====================================================================
# Group 2: Netfilter socket lookup + sock refcount put (xt_socket)
# =====================================================================
#
# Linux:
#   struct sock *nf_sk_lookup_slow_v4(struct net *net, const struct sk_buff *skb,
#                                       const struct net_device *indev);
#   struct sock *nf_sk_lookup_slow_v6(struct net *net, const struct sk_buff *skb,
#                                       const struct net_device *indev);
#   void          sock_gen_put(struct sock *sk);
#
# nf_sk_lookup_slow_v4 / _v6:
#   Walks the TCP/UDP hash tables to find the local socket that owns
#   a given packet's 4-tuple. xt_socket's match callback calls this
#   per-packet to answer "is there already a local listener?" — the
#   transparent-proxy precondition. With no live socket table in
#   Hamnix QEMU and no packets flowing through netfilter hooks at
#   insmod, the lookup is never invoked. Returning NULL (== "no
#   matching socket") is the right answer if it ever fires; xt_
#   socket's match arm treats NULL as "no match, rule does not
#   apply" and short-circuits the path.
#
# sock_gen_put:
#   Drops a refcount on a struct sock (caller-side of sock_hold).
#   Used by xt_socket's match callback after a successful lookup to
#   release the reference. NULL-safe in Linux (and we mirror that).
#   Pure no-op in our env — the lookup never returns non-NULL, so
#   the put never has a real sock to drop.

def _l_nf_sk_lookup_slow_v4(net: uint64, skb: uint64,
                              indev: uint64) -> uint64:
    # NULL == "no socket owns this 4-tuple". xt_socket's match
    # callback treats NULL as "rule does not match" and exits the
    # arm cleanly. Relocation-only at insmod; the per-packet hot
    # path is never reached in our env (no live netfilter chain).
    return 0


def _l_nf_sk_lookup_slow_v6(net: uint64, skb: uint64,
                              indev: uint64) -> uint64:
    # Same convention as the v4 variant.
    return 0


def _l_sock_gen_put(sk: uint64):
    # NULL-safe (matches Linux). With nf_sk_lookup_slow_v4/v6 always
    # returning NULL above, sk is always NULL here — but xt_socket's
    # error arms also call sock_gen_put on stashed pointers, so the
    # symbol still needs an address. No-op body: the matching sock_
    # hold never ran, so there's nothing to release.
    if sk == 0:
        return
    return


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l68():
    # Called from linux_abi_exports_init() after the L67 batch.
    # Adds 6 new exports for the xt_owner / xt_REDIRECT / nft_nat /
    # nft_quota / nft_limit / xt_socket batch. xt_owner.ko,
    # xt_REDIRECT.ko, and nft_nat.ko need no new exports beyond what
    # L<=67 already ships; nft_limit.ko rides along on the two
    # nft_register_obj / nft_unregister_obj symbols shipped here for
    # nft_quota.

    # ---- Group 1: nftables stateful-object registry + notify ----
    _add_export("nft_register_obj",
                cast[uint64](&_l_nft_register_obj))
    _add_export("nft_unregister_obj",
                cast[uint64](&_l_nft_unregister_obj))
    _add_export("nft_obj_notify",
                cast[uint64](&_l_nft_obj_notify))

    # ---- Group 2: Netfilter socket lookup + sock refcount put ----
    _add_export("nf_sk_lookup_slow_v4",
                cast[uint64](&_l_nf_sk_lookup_slow_v4))
    _add_export("nf_sk_lookup_slow_v6",
                cast[uint64](&_l_nf_sk_lookup_slow_v6))
    _add_export("sock_gen_put",
                cast[uint64](&_l_sock_gen_put))

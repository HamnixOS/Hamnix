    return 0


def _l_open_exec(name: uint64) -> uint64:
    # struct file *open_exec(const char *name); returns an errno-encoded
    # pointer on failure (-ENOENT). Hamnix's binfmt_misc doesn't fire at
    # runtime; returning NULL is a defensible "no such file" answer.
    return 0


def _l_remove_arg_zero(bprm: uint64) -> int32:

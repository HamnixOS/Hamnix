# linux_abi/api_l56.ad
#
# L56: shims for the ABI gap exposed by four stock Debian 6.12 modules:
#
#   crc32c-intel.ko  — accelerated CRC32C (Castagnoli) via SSE4.2/PCLMUL.
#                      Init does a CPUID-driven feature check
#                      (x86_match_cpu) and registers one shash_alg; if
#                      the CPU lacks SSE4.2 it bails with -ENODEV.
#   garp.ko          — Generic Attribute Registration Protocol (IEEE
#                      802.1D). LIBRARY-ONLY — no init_module. Exports
#                      garp_{register,unregister,init,uninit}_applicant
#                      and request_join/leave for higher protocols
#                      (8021q's GVRP applicant, etc.). The L55 shims
#                      already cover those names; loading garp.ko now
#                      just installs it as a kernel-module record.
#   mrp.ko           — Multiple Registration Protocol (IEEE 802.1ak).
#                      Mirror of garp.ko — library-only. The L55 shims
#                      cover the same surface for 8021q's MVRP path.
#   binfmt_misc.ko   — Linux's "miscellaneous executable format"
#                      binary-handler registry. Userspace writes
#                      magic/interpreter pairs into /proc/sys/fs/
#                      binfmt_misc to bind, e.g., .exe → wine. Init
#                      registers a filesystem (`binfmt_misc`) and the
#                      binfmt itself via __register_binfmt.
#
# Cross-check against L1..L55 reduced the union of all four .ko's UND
# lists to 64 distinct symbols not yet exported. Per-module gaps:
#
#   crc32c-intel: 3 NEW symbols
#     irq_fpu_usable           — runtime guard (FPU usable in this ctx)
#     x86_match_cpu            — CPUID-feature matcher (init-path)
#     __x86_indirect_thunk_rdi — retpoline for `call *%rdi`
#
#   garp: 19 NEW symbols (library only, none on any init path)
#     __alloc_skb / __pskb_pull_tail / skb_dequeue / skb_queue_tail /
#     sk_skb_reason_drop                                  (skbuff)
#     dev_mc_add / dev_mc_del / __get_random_u32_below /
#     __msecs_to_jiffies / timer_shutdown_sync            (net + time)
#     kvfree_call_rcu / rb_erase / rb_first / rb_insert_color /
#     rb_next                                             (container)
#     llc_mac_hdr_init / stp_proto_register /
#     stp_proto_unregister                                (LLC + STP)
#     param_ops_uint                                      (module_param)
#
#   mrp: 17 NEW symbols, 15 OVERLAP with garp (skbuff/net/time/rb_*/
#     kvfree_call_rcu/llc shared). 2 fresh:
#     dev_add_pack / dev_remove_pack                      (packet types)
#
#   binfmt_misc: 40 NEW symbols
#     __register_binfmt / unregister_binfmt / init_binfmt_misc
#     bprm_change_interp / copy_string_kernel / open_exec /
#     remove_arg_zero                                     (binprm)
#     d_delete / d_instantiate / default_llseek /
#     dentry_open / dput / filp_close / get_next_ino /
#     get_tree_keyed / lockref_get / lookup_one_len /
#     new_inode / noop_llseek / simple_fill_super /
#     simple_inode_init_ts / simple_read_from_buffer /
#     simple_statfs / simple_unlink / clear_inode         (VFS)
#     bin2hex / _ctype / kstrtoint / string_unescape      (strings)
#     override_creds / revert_creds / __put_user_ns       (cred / ns)
#     __check_object_size                                 (hardening)
#     refcount_warn_saturate                              (refcount)
#     _raw_read_lock / _raw_read_unlock / _raw_write_lock /
#     _raw_write_unlock / down_write / up_write           (locking)
#
# Init-path disassembly (objdump -drC of each *.ko's .init.text):
#
#   crc32c-intel.ko:
#       init_module:
#           call __fentry__
#           mov  $&crc32c_match_table, %rdi
#           call x86_match_cpu                  # NEW (init-path)
#           test %rax, %rax
#           je   nodev                          # rax==0 → -ENODEV
#           mov  $&boot_cpu_data+0x3c, %rax     # X86_FEATURE_PCLMUL
#           test $2, %al
#           je   skip_pclmul
#           movq $0, &alg.cra_init              # disable PCLMUL path
#       skip_pclmul:
#           mov  $&alg, %rdi
#           jmp  crypto_register_shash          # L34: returns 0
#       nodev:
#           mov  $-19, %eax                     # -ENODEV
#           jmp  __x86_return_thunk
#
#   garp.ko / mrp.ko:
#       No init_module. Loader logs "library-only module" and returns 0.
#
#   binfmt_misc.ko:
#       init_module:
#           call __fentry__
#           push %rbx
#           mov  $&bm_fs_type, %rdi             # struct file_system_type
#           call register_filesystem            # L27: returns 0
#           mov  %eax, %ebx
#           test %eax, %eax
#           jne  out
#           mov  $1, %esi                       # BINPRM_FLAGS_NO_USED
#           mov  $&misc_format, %rdi            # struct linux_binfmt
#           call __register_binfmt              # NEW (init-path)
#       out:
#           mov  %ebx, %eax
#           pop  %rbx
#           jmp  __x86_return_thunk
#
# So:
#   * crc32c-intel: needs x86_match_cpu to be reachable AND return a
#     non-NULL match (we have SSE4.2 in QEMU's tcg/kvm CPU model), so
#     init returns 0 via crypto_register_shash.
#   * garp / mrp: library-only — loader's no-init-fn path takes them.
#   * binfmt_misc: needs register_filesystem (L27) + __register_binfmt
#     (NEW). Both must return 0 for init==0.
#
# Stub philosophy matches L51..L55:
#   * Return 0 (success) for any int-returning function whose Linux
#     contract is "0 on success".
#   * Return 1 for `x86_match_cpu` to hand back a non-NULL match
#     (specifically: the address of the first entry in the caller's
#     match table, which we extract from the input). This is the only
#     non-trivial body in this file — every other shim is a no-op.
#   * Return 0 (NULL) for any alloc-style function — no consumer here
#     dereferences the result during module load.
#   * No-op for void functions.
#   * DATA exports point at backing buffers in this file.
#
# Naming notes:
#   * Adder reserves `bytes` → not used here.
#   * `match` is a Python keyword → renamed `m` in callbacks.
#   * `len` is fine; `dev`/`pack`/`skb` all fine.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree


# =====================================================================
# Group 1: crc32c-intel — x86_match_cpu / irq_fpu_usable / thunk_rdi
# =====================================================================
#
# Linux:
#   const struct x86_cpu_id *x86_match_cpu(const struct x86_cpu_id *m);
#   bool irq_fpu_usable(void);
#
# x86_match_cpu walks a NUL-terminated array of x86_cpu_id entries and
# returns the first one whose vendor/family/model/feature mask the
# current CPU satisfies. crc32c-intel passes a table whose first entry
# requires X86_FEATURE_XMM4_2. On QEMU's default tcg CPU the feature
# bit is set (we boot with the host's flags or qemu64+sse4.2), so any
# non-NULL return is a "yes" — we hand back the address of the input
# table's first entry. If the table pointer is NULL, return NULL too.
#
# irq_fpu_usable is consulted in the shash update path; not on init.
# Returning 1 is the simplest "yes you may touch the FPU" answer.

def _l_x86_match_cpu(m: uint64) -> uint64:
    # Returns a const struct x86_cpu_id *. The caller dereferences the
    # returned pointer's first field (driver_data: kernel_ulong_t) — at
    # the start of the input table, the entry is the first match.
    # crc32c-intel's table:
    #   [0]: { X86_VENDOR_INTEL, X86_FAMILY_ANY, X86_MODEL_ANY,
    #          .feature = X86_FEATURE_XMM4_2 }
    # We accept it unconditionally on x86_64 — Hamnix only runs on x86
    # CPUs with SSE4.2 (QEMU's tcg has SSE4.2 since 4.0; KVM mirrors
    # the host).
    if m == 0:
        return 0
    return m


def _l_irq_fpu_usable() -> int32:
    # bool irq_fpu_usable(void). Returns 1 (true): IRQ ctx ok-to-touch.
    # Real Linux checks the per-CPU "in_kernel_fpu" flag; Hamnix's
    # crypto callers always run from process context, where the answer
    # is unconditionally yes.
    return 1


def _l___x86_indirect_thunk_rdi():
    # Retpoline replacement for `call *%rdi`. Mirrors the rax / rcx /
    # r8 / r9 / r11 / r14 variants in api_lib80211.ad / api_raid6.ad /
    # api_l51.ad. Adder emits a `push %rbp; mov %rsp, %rbp` prologue
    # we must undo before the indirect jump — otherwise the callee
    # returns into the saved %rbp slot rather than the caller's
    # return address.
    asm_volatile("""
        popq %rbp
        jmpq *%rdi
    """)


# =====================================================================
# Group 2: param_ops_uint (DATA — module_param for `unsigned int`)
# =====================================================================
#
# Linux:
#   extern const struct kernel_param_ops param_ops_uint;
#
# Modules declaring `module_param(name, uint, mode)` reference
# `param_ops_uint`'s address — the kernel-param machinery would call
# its `.set` / `.get` / `.free` pointers if userspace wrote to
# /sys/module/garp/parameters/. Hamnix's loader doesn't parse the
# `parm=value` argument list yet (same blocker as param_ops_int /
# param_ops_charp / param_ops_bool in api_kernel.ad), so a 64-byte
# zero buffer is enough — the address resolves, and a never-fired
# function-pointer load wouldn't trap unless invoked.

param_ops_uint_buf: Array[64, uint8]


# =====================================================================
# Group 3: skbuff helpers (__alloc_skb / __pskb_pull_tail / skb_dequeue
# / skb_queue_tail / sk_skb_reason_drop) — garp + mrp runtime
# =====================================================================
#
# Linux:
#   struct sk_buff *__alloc_skb(unsigned int size, gfp_t prio, int flags,
#                               int node);
#   unsigned char *__pskb_pull_tail(struct sk_buff *skb, int delta);
#   struct sk_buff *skb_dequeue(struct sk_buff_head *list);
#   void skb_queue_tail(struct sk_buff_head *list, struct sk_buff *new);
#   void sk_skb_reason_drop(struct sock *sk, struct sk_buff *skb,
#                            enum skb_drop_reason reason);
#
# All five are reached only via per-packet garp/mrp processing — never
# at module load. The alloc returns NULL (callers in the receive/send
# path treat NULL as an OOM and fall through to their drop_reason
# branch); the dequeue returns NULL (no packet); pull_tail returns
# the skb's data pointer (we hand back NULL — the call site checks
# before deref); queue_tail and reason_drop are no-ops.

def _l___alloc_skb(size: uint32, prio: uint32, flags: int32,
                    node: int32) -> uint64:
    # struct sk_buff *__alloc_skb(...) — NULL signals OOM.
    return 0


def _l___pskb_pull_tail(skb: uint64, delta: int32) -> uint64:
    # unsigned char *__pskb_pull_tail(struct sk_buff *skb, int delta);
    # Returns the new data pointer; NULL on failure. garp/mrp's receive
    # path null-checks before deref.
    return 0


def _l_skb_dequeue(lst: uint64) -> uint64:
    # struct sk_buff *skb_dequeue(struct sk_buff_head *list);
    # NULL signals empty queue.
    return 0


def _l_skb_queue_tail(lst: uint64, new: uint64):
    # void skb_queue_tail(struct sk_buff_head *list, struct sk_buff *new);
    return


def _l_sk_skb_reason_drop(sk: uint64, skb: uint64, reason: uint32):
    # void sk_skb_reason_drop(...); drops `skb` with a reason code.
    # No-op — Hamnix has no skb-drop tracing yet.
    return


# =====================================================================
# Group 4: dev_mc_add / dev_mc_del / dev_add_pack / dev_remove_pack
# =====================================================================
#
# Linux:
#   int  dev_mc_add(struct net_device *dev, const void *addr);
#   int  dev_mc_del(struct net_device *dev, const void *addr);
#   void dev_add_pack(struct packet_type *pt);
#   void dev_remove_pack(struct packet_type *pt);
#
# garp/mrp's applicant-init path calls dev_mc_add to subscribe to the
# protocol's group MAC address (e.g. 01:80:c2:00:00:21 for GVRP). It's
# never reached during module load — only when the higher protocol
# (8021q's vlan_gvrp_init) initialises an applicant on a real netdev.
# mrp.ko's static .init.text — wait, no — mrp registers a packet_type
# at applicant-init too, not at module-init. So all four are runtime
# stubs. No-op bodies are fine.

def _l_dev_mc_add(dev: uint64, addr: uint64) -> int32:
    # int dev_mc_add(struct net_device *dev, const void *addr);
    return 0


def _l_dev_mc_del(dev: uint64, addr: uint64) -> int32:
    # int dev_mc_del(struct net_device *dev, const void *addr);
    return 0


def _l_dev_add_pack(pt: uint64):
    # void dev_add_pack(struct packet_type *pt);
    return


def _l_dev_remove_pack(pt: uint64):
    # void dev_remove_pack(struct packet_type *pt);
    return


# =====================================================================
# Group 5: __get_random_u32_below / __msecs_to_jiffies /
# timer_shutdown_sync / kvfree_call_rcu
# =====================================================================
#
# Linux:
#   u32  __get_random_u32_below(u32 ceil);
#   unsigned long __msecs_to_jiffies(unsigned int msecs);
#   int  timer_shutdown_sync(struct timer_list *timer);
#   void kvfree_call_rcu(struct rcu_head *head, void *ptr);
#
# All four are runtime-only for garp/mrp's applicant state machine
# (random join-delay jitter, msec→jiffy conversion for the leave-all
# timer, timer teardown on applicant-uninit, RCU-deferred free of
# applicant state). Bodies are pragmatic placeholders:
#   * __get_random_u32_below — return 0 (deterministic "no jitter").
#   * __msecs_to_jiffies — Linux's HZ=250 default makes 1ms ≈ 0.25
#     jiffies, but garp/mrp pass msecs in the 100..10000 range; we
#     compute msecs*HZ/1000 with HZ=250 inline (msecs*250/1000 =
#     msecs/4, integer-truncated). Never reached at module load —
#     just needs the address to resolve.
#   * timer_shutdown_sync — return 1 ("was active") to match the
#     conservative path most callers take.
#   * kvfree_call_rcu — no-op (RCU not implemented; the deferred-
#     free is best-effort dropped on the floor).

def _l___get_random_u32_below(ceil: uint32) -> uint32:
    # u32 __get_random_u32_below(u32 ceil); returns rand % ceil.
    return 0


def _l___msecs_to_jiffies(msecs: uint32) -> uint64:
    # unsigned long __msecs_to_jiffies(unsigned int msecs);
    # HZ=250 → 1 jiffy = 4 ms → jiffies = msecs / 4 (truncated).
    return cast[uint64](msecs) / 4


def _l_timer_shutdown_sync(timer: uint64) -> int32:
    # int timer_shutdown_sync(struct timer_list *timer);
    # Returns 1 if the timer was pending, 0 otherwise. Conservative
    # answer: 1 (callers ignore the value or use it for stats).
    return 1


def _l_kvfree_call_rcu(head: uint64, ptr: uint64):
    # void kvfree_call_rcu(struct rcu_head *head, void *ptr);
    # No-op — real Linux defers a kvfree(ptr) until the current RCU
    # grace period ends. Hamnix has no RCU yet; dropping the free is
    # a latent leak only on applicant teardown, which the L-track
    # doesn't exercise.
    return


# =====================================================================
# Group 6: rb_* — red-black tree primitives
# =====================================================================
#
# Linux (lib/rbtree.c):
#   void           rb_insert_color(struct rb_node *node, struct rb_root *root);
#   void           rb_erase(struct rb_node *node, struct rb_root *root);
#   struct rb_node *rb_first(const struct rb_root *root);
#   struct rb_node *rb_next(const struct rb_node *node);
#
# garp/mrp use an rb_root to index per-applicant attribute records.
# The applicant-state machine traverses the tree on every packet;
# at module-load none of these fire. Bodies are no-op / NULL:
#   * rb_insert_color / rb_erase — no-op (the rb_root stays empty).
#   * rb_first / rb_next — return NULL (empty tree).
#
# This is a degenerate-but-safe lib/rbtree stub. The first real
# garp/mrp packet path (a future milestone) needs the actual lib/
# rbtree.c port — there's no point doing it now without consumers.

def _l_rb_insert_color(node: uint64, root: uint64):
    # void rb_insert_color(...);
    return


def _l_rb_erase(node: uint64, root: uint64):
    # void rb_erase(...);
    return


def _l_rb_first(root: uint64) -> uint64:
    # struct rb_node *rb_first(...); NULL → empty.
    return 0


def _l_rb_next(node: uint64) -> uint64:
    # struct rb_node *rb_next(...); NULL → end-of-iteration.
    return 0



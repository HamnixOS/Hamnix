# =====================================================================
# Group 8: binfmt_misc — __register_binfmt / unregister_binfmt /
# init_binfmt_misc / bprm_change_interp / copy_string_kernel /
# open_exec / remove_arg_zero
# =====================================================================
#
# Linux (fs/exec.c + fs/binfmt_misc.c):
#   void  __register_binfmt(struct linux_binfmt *fmt, int insert);
#   void  unregister_binfmt(struct linux_binfmt *fmt);
#   int   init_binfmt_misc(void);   /* internal helper, exported */
#   int   bprm_change_interp(const char *interp, struct linux_binprm *bprm);
#   int   copy_string_kernel(const char *arg, struct linux_binprm *bprm);
#   struct file *open_exec(const char *name);
#   int   remove_arg_zero(struct linux_binprm *bprm);
#
# __register_binfmt is the only one on binfmt_misc.ko's init path —
# everything else is invoked at execve() time when a misc-binfmt rule
# matches an ELF/script. Hamnix's exec path doesn't query the binfmt
# table yet (we use a dedicated ELF loader); the runtime callsites
# never fire. Bodies are safe stubs.

def _l___register_binfmt(fmt: uint64, insert: int32):
    # void __register_binfmt(struct linux_binfmt *fmt, int insert);
    # Real Linux appends/prepends fmt onto a global list. Hamnix's
    # exec doesn't consume the list yet; logging a one-line trace
    # for future debugging and returning is enough.
    printk0("binfmt: __register_binfmt called\n")
    return


def _l_unregister_binfmt(fmt: uint64):
    # void unregister_binfmt(struct linux_binfmt *fmt);
    return


def _l_init_binfmt_misc() -> int32:
    # int init_binfmt_misc(void); fs/binfmt_misc.c internal helper
    # — sets up the procfs hook table. Stubbed: returns 0.
    return 0


def _l_bprm_change_interp(interp: uint64, bprm: uint64) -> int32:
    # int bprm_change_interp(const char *interp, struct linux_binprm *bprm);

# =====================================================================
# Group 10: binfmt_misc strings — bin2hex / _ctype / kstrtoint /
# string_unescape
# =====================================================================
#
# Linux:
#   char *bin2hex(char *dst, const void *src, size_t count);
#   extern const unsigned char _ctype[];   /* 257-byte table */
#   int kstrtoint(const char *s, unsigned int base, int *res);
#   int string_unescape(char *src, char *dst, size_t size,
#                        unsigned int flags);
#
# Reached only from binfmt_misc's procfs write-path (parsing the
# user-supplied magic-string/interpreter-path rule). Stub bodies:
#   * bin2hex — write 0 nibbles into dst; return dst. Never fires.
#   * _ctype — 257-byte zero buffer; the table is indexed by byte
#              value, so any non-init lookup yields 0 (which means
#              "no class flags" — safe).
#   * kstrtoint — return -EINVAL (no parse).
#   * string_unescape — return 0 (no bytes processed).

_ctype_buf: Array[257, uint8]


def _l_bin2hex(dst: uint64, src: uint64, count: uint64) -> uint64:
    # char *bin2hex(char *dst, const void *src, size_t count);
    # Pragmatic stub: zero `count*2` bytes of dst and return dst+count*2.
    if dst == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](dst)
    i: uint64 = 0
    while i < count * 2:
        p[i] = 0
        i = i + 1
    return dst + count * 2


def _l_kstrtoint(s: uint64, base: uint32, res: uint64) -> int32:
    # int kstrtoint(const char *s, unsigned int base, int *res);
    # -EINVAL = -22. Stubbed parse failure is the safest answer when
    # the runtime call path isn't supposed to fire.
    return -22


def _l_string_unescape(src: uint64, dst: uint64, size: uint64,
                        flags: uint32) -> int32:
    # int string_unescape(char *src, char *dst, size_t size, ...);
    # Returns bytes processed (zero is honest stub).
    return 0


# =====================================================================
# Group 11: binfmt_misc cred / ns — override_creds / revert_creds /
# __put_user_ns
# =====================================================================
#
# Linux:
#   const struct cred *override_creds(const struct cred *new);
#   void revert_creds(const struct cred *old);
#   void __put_user_ns(struct user_namespace *ns);
#
# Runtime cred-swap helpers for the execve-time interpreter open.
# None fire at init. Bodies: override_creds returns the input pointer
# (so the matched revert_creds undoes nothing), revert_creds + __put_
# user_ns are no-ops.

def _l_override_creds(new: uint64) -> uint64:
    # Returns the old cred pointer; pass-through stub.
    return new


def _l_revert_creds(old: uint64):
    return


def _l___put_user_ns(ns: uint64):
    return


# =====================================================================
# Group 12: hardening + refcount — __check_object_size /
# refcount_warn_saturate
# =====================================================================
#
# Linux:
#   void __check_object_size(const void *ptr, unsigned long n, bool to_user);
#   void refcount_warn_saturate(refcount_t *r, enum refcount_saturation_type t);
#
# __check_object_size is gcc-instrumentation invoked on every
# copy_{to,from}_user; binfmt_misc's procfs write-path hits it. No-op
# is safe — Linux's real implementation also no-ops in
# !CONFIG_HARDENED_USERCOPY builds.
#
# refcount_warn_saturate is the WARN backend for refcount_t saturation;
# never fires at init.

def _l___check_object_size(ptr: uint64, n: uint64, to_user: int32):
    return


def _l_refcount_warn_saturate(r: uint64, t: uint32):
    printk0("WARN: refcount saturated\n")
    return


# =====================================================================
# Group 13: rw_semaphore + raw_rw_lock — down_write / up_write /
# _raw_read_lock / _raw_read_unlock / _raw_write_lock / _raw_write_unlock
# =====================================================================
#
# Linux:
#   void down_write(struct rw_semaphore *sem);
#   void up_write(struct rw_semaphore *sem);
#   void _raw_read_lock(rwlock_t *lock);
#   void _raw_read_unlock(rwlock_t *lock);
#   void _raw_write_lock(rwlock_t *lock);
#   void _raw_write_unlock(rwlock_t *lock);
#
# binfmt_misc's procfs path (read/write the rules table) takes these
# under the binfmt_misc-internal semaphore. Module-load doesn't fire
# them. No-op bodies are correct under UP (we have 1 logical CPU
# during module init) — same convention as api_sync.ad's existing
# spinlock shims.

def _l_down_write(sem: uint64):
    return


def _l_up_write(sem: uint64):
    return


def _l__raw_read_lock(lock: uint64):
    return


def _l__raw_read_unlock(lock: uint64):
    return


def _l__raw_write_lock(lock: uint64):
    return


def _l__raw_write_unlock(lock: uint64):
    return


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l56():
    # Called from linux_abi_exports_init() after L55's VLAN rows.
    # Adds 64 exports for the L56 batch:
    #   crc32c-intel: 3
    #   garp + mrp (overlap accounted): 19 + 2 = 21
    #   binfmt_misc: 40

    # ---- Group 1: crc32c-intel ----
    _add_export("x86_match_cpu",
                cast[uint64](&_l_x86_match_cpu))
    _add_export("irq_fpu_usable",
                cast[uint64](&_l_irq_fpu_usable))
    _add_export("__x86_indirect_thunk_rdi",
                cast[uint64](&_l___x86_indirect_thunk_rdi))

    # ---- Group 2: module_param (DATA) ----
    _add_export("param_ops_uint",
                cast[uint64](&param_ops_uint_buf[0]))

    # ---- Group 3: skbuff (garp + mrp) ----
    _add_export("__alloc_skb",
                cast[uint64](&_l___alloc_skb))
    _add_export("__pskb_pull_tail",
                cast[uint64](&_l___pskb_pull_tail))
    _add_export("skb_dequeue",
                cast[uint64](&_l_skb_dequeue))
    _add_export("skb_queue_tail",
                cast[uint64](&_l_skb_queue_tail))
    _add_export("sk_skb_reason_drop",
                cast[uint64](&_l_sk_skb_reason_drop))

    # ---- Group 4: dev_mc / dev_pack (garp + mrp) ----
    _add_export("dev_mc_add",
                cast[uint64](&_l_dev_mc_add))
    _add_export("dev_mc_del",
                cast[uint64](&_l_dev_mc_del))
    _add_export("dev_add_pack",
                cast[uint64](&_l_dev_add_pack))
    _add_export("dev_remove_pack",
                cast[uint64](&_l_dev_remove_pack))

    # ---- Group 5: random / jiffies / timer / RCU ----
    _add_export("__get_random_u32_below",
                cast[uint64](&_l___get_random_u32_below))
    _add_export("__msecs_to_jiffies",
                cast[uint64](&_l___msecs_to_jiffies))
    _add_export("timer_shutdown_sync",
                cast[uint64](&_l_timer_shutdown_sync))
    _add_export("kvfree_call_rcu",
                cast[uint64](&_l_kvfree_call_rcu))

    # ---- Group 6: rb_* ----
    _add_export("rb_insert_color",
                cast[uint64](&_l_rb_insert_color))
    _add_export("rb_erase",
                cast[uint64](&_l_rb_erase))
    _add_export("rb_first",
                cast[uint64](&_l_rb_first))
    _add_export("rb_next",
                cast[uint64](&_l_rb_next))

    # ---- Group 7: LLC + STP ----
    _add_export("llc_mac_hdr_init",
                cast[uint64](&_l_llc_mac_hdr_init))
    _add_export("stp_proto_register",
                cast[uint64](&_l_stp_proto_register))
    _add_export("stp_proto_unregister",
                cast[uint64](&_l_stp_proto_unregister))

    # ---- Group 8: binfmt + binprm ----
    _add_export("__register_binfmt",
                cast[uint64](&_l___register_binfmt))
    _add_export("unregister_binfmt",
                cast[uint64](&_l_unregister_binfmt))
    _add_export("init_binfmt_misc",
                cast[uint64](&_l_init_binfmt_misc))
    _add_export("bprm_change_interp",
                cast[uint64](&_l_bprm_change_interp))
    _add_export("copy_string_kernel",
                cast[uint64](&_l_copy_string_kernel))
    _add_export("open_exec",
                cast[uint64](&_l_open_exec))
    _add_export("remove_arg_zero",
                cast[uint64](&_l_remove_arg_zero))

    # ---- Group 9: VFS helpers ----
    _add_export("dput",
                cast[uint64](&_l_dput))
    _add_export("dentry_open",
                cast[uint64](&_l_dentry_open))
    _add_export("d_delete",
                cast[uint64](&_l_d_delete))
    _add_export("d_instantiate",
                cast[uint64](&_l_d_instantiate))
    _add_export("new_inode",
                cast[uint64](&_l_new_inode))
    _add_export("lookup_one_len",
                cast[uint64](&_l_lookup_one_len))
    _add_export("clear_inode",
                cast[uint64](&_l_clear_inode))
    _add_export("default_llseek",
                cast[uint64](&_l_default_llseek))
    _add_export("noop_llseek",
                cast[uint64](&_l_noop_llseek))
    _add_export("get_next_ino",
                cast[uint64](&_l_get_next_ino))
    _add_export("get_tree_keyed",
                cast[uint64](&_l_get_tree_keyed))
    _add_export("lockref_get",
                cast[uint64](&_l_lockref_get))
    _add_export("simple_fill_super",
                cast[uint64](&_l_simple_fill_super))
    _add_export("simple_inode_init_ts",
                cast[uint64](&_l_simple_inode_init_ts))
    _add_export("simple_read_from_buffer",
                cast[uint64](&_l_simple_read_from_buffer))
    _add_export("simple_statfs",
                cast[uint64](&_l_simple_statfs))
    _add_export("simple_unlink",
                cast[uint64](&_l_simple_unlink))
    _add_export("filp_close",
                cast[uint64](&_l_filp_close))

    # ---- Group 10: strings ----
    _add_export("bin2hex",
                cast[uint64](&_l_bin2hex))
    _add_export("_ctype",
                cast[uint64](&_ctype_buf[0]))
    _add_export("kstrtoint",
                cast[uint64](&_l_kstrtoint))
    _add_export("string_unescape",
                cast[uint64](&_l_string_unescape))

    # ---- Group 11: cred / ns ----
    _add_export("override_creds",
                cast[uint64](&_l_override_creds))
    _add_export("revert_creds",
                cast[uint64](&_l_revert_creds))
    _add_export("__put_user_ns",
                cast[uint64](&_l___put_user_ns))

    # ---- Group 12: hardening + refcount ----
    _add_export("__check_object_size",
                cast[uint64](&_l___check_object_size))
    _add_export("refcount_warn_saturate",
                cast[uint64](&_l_refcount_warn_saturate))

    # ---- Group 13: rw_semaphore + raw_rwlock ----
    _add_export("down_write",
                cast[uint64](&_l_down_write))
    _add_export("up_write",
                cast[uint64](&_l_up_write))
    _add_export("_raw_read_lock",
                cast[uint64](&_l__raw_read_lock))
    _add_export("_raw_read_unlock",
                cast[uint64](&_l__raw_read_unlock))
    _add_export("_raw_write_lock",
                cast[uint64](&_l__raw_write_lock))
    _add_export("_raw_write_unlock",
                cast[uint64](&_l__raw_write_unlock))

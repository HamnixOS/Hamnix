    devnet_clone, devnet_ctl, devnet_conn_unref, devnet_conn_ref,
    devnet_conn_stack_slot, devnet_accept_take,
    devnet_conn_state,
    devnet_conn_remote_ip, devnet_conn_remote_port,
    devnet_conn_local_ip, devnet_conn_local_port, devnet_host_ip,
    NET_PROTO_TCP, NET_PROTO_UDP,

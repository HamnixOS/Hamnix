SYS_pidfd_send_signal: uint64 = 424
SYS_pidfd_open:        uint64 = 434
SYS_waitid:            uint64 = 247
# pidfd_getfd(2) — x86_64 nr 438. Duplicate fd[targetfd] out of the process
# referenced by `pidfd` into the caller's fd table (flags must be 0).
SYS_pidfd_getfd:       uint64 = 438
# process_madvise(2) — x86_64 nr 440. Apply an madvise advice (WILLNEED /
# DONTNEED / COLD / PAGEOUT) to iovec ranges in the process referenced by

SYS_io_uring_setup:    uint64 = 425
SYS_io_uring_enter:    uint64 = 426
SYS_io_uring_register: uint64 = 427
# §kmod: Linux module management. init_module(175) takes an in-memory
# .ko image; finit_module(313) takes an open fd to the .ko (the path
# real modern insmod/modprobe use); delete_module(176) unloads by name.
# All three funnel into Hamnix's existing kmod_linux_load/unload loader.
SYS_init_module:       uint64 = 175
SYS_delete_module:     uint64 = 176
SYS_finit_module:      uint64 = 313
# §openat2 -- path-resolution-aware open (Linux 5.6). Handler in
# linux_abi/u_openat2.ad.
SYS_openat2:           uint64 = 437
# §memfd_secret -- anonymous, /proc-mem-opaque memfd (Linux 5.14). Handler
# in linux_abi/u_memfd_secret.ad.
SYS_memfd_secret:      uint64 = 447
# §mount_setattr -- modern remount-with-flags (Linux 5.12). Handler in
# linux_abi/u_mount_setattr.ad.
SYS_mount_setattr:     uint64 = 442
# §new-mount-API -- fsopen/fsconfig/fsmount/move_mount (Linux 5.2+).
# Handlers in linux_abi/u_fsmount.ad.
SYS_move_mount:        uint64 = 429
SYS_fsopen:            uint64 = 430
SYS_fsconfig:          uint64 = 431
SYS_fsmount:           uint64 = 432


# Linux errno values returned by stub handlers. Kept local to avoid
# coupling to a yet-to-exist linux_abi/errno.ad. Same numeric values
# as <asm-generic/errno-base.h>.
ELINUX_NOENT:  int64 = -2
ELINUX_SRCH:   int64 = -3
ELINUX_NOEXEC: int64 = -8           # -ENOEXEC — bad / non-ELF module image
ELINUX_BADF:   int64 = -9
ELINUX_NOMEM:  int64 = -12          # -ENOMEM — module buffer alloc failed
# #163: -EFAULT for the uaccess-converted handlers below. (A second
# ELINUX_FAULT is declared later near the seccomp block with the same
# value; both resolve to -14. This early copy guarantees the converted
# high-traffic handlers — clock_gettime, uname, getcwd, stat, … — have
# the constant in scope regardless of source order.)
ELINUX_EFAULT: int64 = -14
# #69: EROFS (-30) — a mutation denied by a kernel-enforced read-only
# bind (MRDONLY). Linux glibc maps -30 to errno=EROFS ("Read-only file
# system"), the natural message for a write blocked at the mount view.
ELINUX_EROFS: int64 = -30
# ELINUX_AGAIN (-11) is declared later alongside the futex stubs; we
# reuse the same constant for accept(2)'s would-block answer below.
ELINUX_INVAL:  int64 = -22
# -EINTR: a blocking FUTEX_WAIT park interrupted by signal delivery
# reports this so glibc/musl re-issue the futex per their restart logic.
ELINUX_INTR:   int64 = -4
ELINUX_PERM:   int64 = -1           # -EPERM (setuid/setgid privilege denial)
ELINUX_NOTDIR: int64 = -20
ELINUX_RANGE:  int64 = -34
ELINUX_NAMETOOLONG: int64 = -36     # -ENAMETOOLONG (#163 path copy-in)
ELINUX_NOSYS:  int64 = -38
ELINUX_NOTTY:  int64 = -25
ELINUX_CONNREFUSED: int64 = -111
# U-socket: extra errnos the connect(2) bridge maps tcp_connect's
# failure codes onto. Numeric values from <asm-generic/errno.h>.
ELINUX_AFNOSUPPORT:  int64 = -97    # EAFNOSUPPORT — family not AF_INET
ELINUX_PROTONOSUP:   int64 = -93    # EPROTONOSUPPORT — type not SOCK_STREAM
ELINUX_NETUNREACH:   int64 = -101   # ENETUNREACH — on-link ARP never resolved
ELINUX_TIMEDOUT:     int64 = -110   # ETIMEDOUT — SYN-ACK never arrived
ELINUX_NOTCONN:      int64 = -107   # ENOTCONN — socket not connected
ELINUX_ISCONN:       int64 = -106   # EISCONN — already connected
ELINUX_MFILE:        int64 = -24    # EMFILE — fd / record table exhausted
ELINUX_ADDRINUSE:    int64 = -98    # EADDRINUSE — bind port already in use
# U-TLS: extra errnos the tls_connect(2) bridge surfaces.
ELINUX_BUSY:         int64 = -16    # EBUSY — a TLS session is already live
ELINUX_PROTO:        int64 = -71    # EPROTO — TLS handshake / cert validation failed
ELINUX_PIPE:         int64 = -32    # EPIPE — write to a pipe / socket with no reader
ELINUX_SPIPE:        int64 = -29    # ESPIPE — illegal seek (splice offset on a pipe)
# §10 UDP-socket / sockopt errnos.
ELINUX_MSGSIZE:      int64 = -90    # EMSGSIZE — datagram larger than the UDP MTU
ELINUX_NOPROTOOPT:   int64 = -92    # ENOPROTOOPT — unrecognised setsockopt option


# =====================================================================
# Phase D follow-up: /proc -> /dev as a namespace bind (retired)
# =====================================================================
#
# The M16.131..134 string-rewrite helpers (_u_translate_proc_to_dev,
# _u_proc_resolve_self, _u_proc_tail_eq, _u_proc_to_dev_rewrite) used to
# live here. They rewrote a Linux ELF's "/proc/<name>" path in place to
# "/dev/<name>" before _u_open called vfs_open, so a Linux read of
# /proc/cpuinfo would hit the native cdev.
#
# That hack is RETIRED. The replacement is a stack of per-leaf
# bindings planted in the default Pgrp by pgrp_init
# (sys/src/9/port/chan.ad):
#
#   /proc/cpuinfo   -> #c/cpuinfo
#   /proc/meminfo   -> #c/meminfo
#   /proc/uptime    -> #c/uptime
#   /proc/loadavg   -> #c/loadavg
#   /proc/version   -> #c/version
#   /proc/hostname  -> #c/hostname
#   /proc/stat      -> #c/stat
#   /proc/mounts    -> #c/mounts
#   /proc/diskstats -> #c/diskstats
#
# A longer-prefix FILE bind always wins over the /proc -> #p root
# entry, so the per-leaf rewrites take precedence for those exact
# names while every other /proc/<...> path still resolves through #p
# (devproc + the static-procfs renderer). /proc/self/<leaf>
# resolution lives in devproc's _parse_proc_path.
#
# The win: every path-taking Layer-2 entry (open, openat, stat,
# readlink, ...) gets the rewrite for free via resolve_path. The
# previous string-rewrite was wired into _u_open ONLY, leaving
# openat / stat / readlink callers of /proc/<name> -ENOENT.
# =====================================================================

# =====================================================================
# #163: user path-string copy-in
# =====================================================================
#
# The path-taking syscalls (open / openat / stat / mkdir / unlink /
# rename / chdir / readlink…) used to hand the RAW user `const char *`
# straight to resolve_path(), which walks the string byte-by-byte via a
# raw deref — a malformed user path pointer therefore faulted the kernel
# instead of returning -EFAULT. We now copy the user path into a kernel
# scratch via strncpy_from_user (a translated, fault-tolerant walk of the
# current task's page tables) BEFORE resolve_path ever touches it. The
# kernel scratch is then what resolve_path / vfs_open see — they keep
# their existing kernel-pointer contract unchanged. resolve_path stays a
# pure kernel-buffer routine; only this copy-in is migrated.
#
# MAX_USER_PATH matches the 256-byte abs_path cap every path handler
# already uses for resolve_path's output, so we never accept a source
# longer than the canonicaliser could hold.
MAX_USER_PATH: uint64 = 256


def _u_copyin_path(uptr: uint64, kdst: Ptr[uint8]) -> int64:
    # Copy the NUL-terminated user path at `uptr` into the kernel buffer
    # `kdst` (MAX_USER_PATH bytes). Returns 0 on success, ELINUX_EFAULT if
    # the user pointer faults, or ELINUX_NAMETOOLONG if the path did not
    # terminate within the cap. strncpy_from_user re-walks at every page
    # boundary so a path spanning frames is handled correctly.
    if uptr == 0:
        return ELINUX_EFAULT
    r: int64 = strncpy_from_user(cast[uint64](kdst), uptr, MAX_USER_PATH)
    if r < 0:
        return ELINUX_EFAULT
    if cast[uint64](r) >= MAX_USER_PATH - 1:
        # No NUL inside the cap — reject rather than silently truncate.
        return ELINUX_NAMETOOLONG
    return 0


# #163: shared uaccess helpers for the Linux-ABI handler surface.
#
# The bulk read/write data path bounces through a 4 KiB kernel stack
# buffer (the same grain the native SYS_READ/SYS_WRITE dispatch uses):
# copy_from_user fetches the user bytes through the CURRENT task's page
# tables, copy_to_user lands results the same way, so the handlers stay
# correct when a user page is backed by a non-identity frame (ASLR /
# swapped / COW'd). A faulting user pointer is -EFAULT, never a wedge.
U_L_BOUNCE: uint64 = 4096


def _u_user_first_byte(uptr: uint64) -> int32:
    # First byte of a user string, fetched through the page tables.
    # Returns 0..255, or -1 on a NULL / faulting pointer. Used by the
    # *at() handlers' "is the path absolute?" probe — a bad pointer
    # reads as "not absolute" and the downstream _u_copyin_path then
    # reports the -EFAULT.
    if uptr == 0:
        return -1
    fb: uint8 = 0
    if get_user_8(uptr, &fb) != 0:
        return -1
    return cast[int32](fb)


def _u_copyout_rc(uaddr: uint64, kbuf: Ptr[uint8], rc: int64) -> int64:
    # Land `rc` bytes from a kernel bounce at the user buffer. Negative
    # / zero rc values (errnos, EOF, would-block) pass through untouched
    # so call sites can keep their existing rc plumbing. A partial
    # copy-out reports the bytes that actually landed (the consumed
    # source bytes are gone — same hazard Linux has); a total fault is
    # -EFAULT.
    if rc <= 0:
        return rc
    resid: uint64 = copy_to_user(uaddr, cast[uint64](kbuf),
                                 cast[uint64](rc))
    if resid == 0:
        return rc
    copied: uint64 = cast[uint64](rc) - resid
    if copied == 0:
        return ELINUX_EFAULT
    return cast[int64](copied)


def _u_vfs_read_user(fd: int32, ubuf: uint64, count: uint64) -> int64:
    # Blocking read(2) tail: vfs_read into a kernel bounce, then
    # copy_to_user. read(2) returns as soon as ANY data is available,
    # so one bounce-sized vfs_read is the correct shape — a count
    # larger than the bounce legally short-reads at 4 KiB.
    rn: uint64 = count
    if rn > U_L_BOUNCE:
        rn = U_L_BOUNCE
    rkb: Array[4096, uint8]
    n: int64 = vfs_read(fd, cast[Ptr[uint8]](&rkb[0]), rn)
    return _u_copyout_rc(ubuf, &rkb[0], n)


def _u_vfs_write_user(fd: int32, ubuf: uint64, count: uint64) -> int64:
    # write(2) tail: chunked copy_from_user + vfs_write loop so a
    # >4 KiB write still transfers in full. A short vfs_write (pipe
    # back-pressure) stops the loop and returns the partial count —
    # standard write(2) semantics. A first-chunk errno (incl. EPIPE,
    # which the call sites watch for SIGPIPE) propagates verbatim.
    total: uint64 = 0
    left: uint64 = count
    u: uint64 = ubuf
    wkb: Array[4096, uint8]
    while left > 0:
        chunk: uint64 = left
        if chunk > U_L_BOUNCE:
            chunk = U_L_BOUNCE
        if copy_from_user(cast[uint64](&wkb[0]), u, chunk) != 0:
            if total == 0:
                return ELINUX_EFAULT
            return cast[int64](total)
        wn: int64 = vfs_write(fd, cast[Ptr[uint8]](&wkb[0]), chunk)
        if wn < 0:
            if total == 0:
                return wn
            return cast[int64](total)
        total = total + cast[uint64](wn)
        if cast[uint64](wn) < chunk:
            return cast[int64](total)
        left = left - chunk
        u = u + chunk
    return cast[int64](total)


def _u_copyin_sockaddr16(uaddr: uint64, kdst: Ptr[uint8]) -> int64:
    # Stage a 16-byte struct sockaddr_in from user space into a kernel
    # buffer so the parse below never raw-derefs the user pointer.
    if copy_from_user(cast[uint64](kdst), uaddr, 16) != 0:
        return ELINUX_EFAULT
    return 0


# =====================================================================
# Forwarders to Hamnix native primitives
# =====================================================================
#
# Each handler takes the full (a0..a5) tuple even when it ignores most
# of the args — that keeps linux_u_syscall_dispatch's call sites uniform
# and the eventual entry-stub rewiring trivial. Return type is int64
# (the kernel-side syscall return). Casts narrow to the natural width
# of the underlying Hamnix call as needed.


def _u_read(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t read(int fd, void *buf, size_t count)
    # /proc/<pid>/io: every read() syscall invocation is charged exactly
    # once on the common tail — syscr += 1 and rchar += (ret>0 ? ret : 0).
    # _u_read_body computes the result via the various fd-marker paths; we
    # charge here so a single call point covers every return shape (Linux
    # counts the syscall on EOF / would-block too).
    ret: int64 = _u_read_body(a0, a1, a2, a3, a4, a5)
    nb: uint64 = 0
    if ret > 0:
        nb = cast[uint64](ret)
    current_task_charge_read(nb)
    return ret


def _u_read_body(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # #163: the bulk data path goes through a kernel bounce buffer +
    # copy_to_user (_u_vfs_read_user / _u_copyout_rc) — vfs_read and
    # friends only ever see kernel pointers now. The Layer-2 leaf
    # helpers (nl_recv, afunix_*, uperf_read, uffd_read, uino_read,
    # _fan_read, signalfd) already do their own copy_to_user
    # internally, so they keep receiving the raw user address.
    fd: int32 = cast[int32](a0)
    marker: uint32 = vfs_fd_marker(fd)
    nonblock: int32 = _u_fd_is_nonblock(fd)
    # #459: POSIX read(2) on a directory fd is EISDIR. The Linux ABI must
    # enforce this at its own boundary because vfs_read now drains the
    # rendered "NAME\n" listing for native Plan-9 callers (p9_listdir,
    # ls, find, glob, the service supervisor's svc_load_all_defs). Linux
    # callers must use getdents64 (_u_getdents64 walks the same dir-fd
    # buffer through vfs_fd_dir_buf/vfs_fd_dir_buflen). Was: the EISDIR
    # short-circuit lived in vfs_read and clobbered the native listdir
    # contract — the DE failed to autostart at runlevel 5 because the
    # supervisor's listdir returned EISDIR and discovered 0 services.
    if vfs_fd_is_dir(fd) != 0:
        return cast[int64](-21)                  # -EISDIR
    # AF_UNIX: a unix-socket fd's read(2) drains its in-kernel conduit
    # (stream ring or datagram queue), NOT the vfs socket arms. Intercept
    # before any vfs routing.
    # AF_NETLINK: read(2) drains the endpoint's queued framed dump bytes,
    # same as recv. Intercept before any vfs routing.
    rd_nlep: int32 = _u_netlink_ep(fd)
    if rd_nlep >= 0:
        rd_nrn: int64 = nl_recv(rd_nlep, a1, a2)
        if rd_nrn == NL_EAGAIN:
            if nonblock != 0:
                return NL_EAGAIN
            while rd_nrn == NL_EAGAIN:
                yield_to_others()
                rd_nrn = nl_recv(rd_nlep, a1, a2)
        return rd_nrn
    rd_uxep: int32 = _u_afunix_ep(fd)
    if rd_uxep >= 0:
        if afunix_get_type(rd_uxep) == AFU_SOCK_DGRAM:
            rd_dn: int64 = afunix_recvfrom(rd_uxep, a1, a2)
            if rd_dn == AFU_EAGAIN:
                if nonblock != 0:
                    return AFU_EAGAIN
                while rd_dn == AFU_EAGAIN:
                    yield_to_others()
                    rd_dn = afunix_recvfrom(rd_uxep, a1, a2)
            return rd_dn
        rd_sn: int64 = afunix_recv_stream(rd_uxep, a1, a2)
        if rd_sn == AFU_EAGAIN:
            if nonblock != 0:
                return AFU_EAGAIN
            while rd_sn == AFU_EAGAIN:
                yield_to_others()
                rd_sn = afunix_recv_stream(rd_uxep, a1, a2)
        return rd_sn
    # A pidfd carries no readable byte stream — Linux read(2) on a pidfd
    # returns EINVAL. It is poll-only (process-exit readiness) and is
    # drained via waitid(P_PIDFD), not read().
    if marker == FD_PIDFD_MARK:
        return ELINUX_INVAL
    # A perf_event fd delivers its software counter as a single u64 (minimal
    # PERF_FORMAT). The counter value lives in the Layer-2 perf-event table,
    # which vfs.ad cannot see, so the read is serviced here. uperf_read copies
    # the 8-byte count out via copy_to_user; a <8-byte buffer is -EINVAL.
    if marker == FD_PERF_MARK:
        return uperf_read(fd, a1, a2)
    # A userfaultfd fd delivers queued uffd_msg records (UFFD_EVENT_PAGEFAULT).
    # The pending-fault queue lives in the Layer-2 u_userfaultfd table, which
    # vfs.ad cannot see, so the read is serviced here. uffd_read copies a 32-byte
    # uffd_msg out via copy_to_user; an empty queue is -EAGAIN, so a blocking
    # read yields until a fault is enqueued (same shape as signalfd below).
    if marker == FD_UFFD_MARK:
        ur: int64 = uffd_read(fd, a1, a2)
        if ur == ELINUX_AGAIN and nonblock == 0:
            while ur == ELINUX_AGAIN:
                yield_to_others()
                ur = uffd_read(fd, a1, a2)
        return ur
    # §5: a signalfd fd delivers signals as readable siginfo records —
    # vfs.ad has no access to the caller's pending-signal word, so the
    # signalfd read is serviced here in the Layer-2 shim.
    if marker == FD_SIGNALFD_MARK:
        r: int64 = _u_signalfd_read(fd, a1, a2)
        if r == ELINUX_AGAIN and nonblock == 0:
            # Blocking signalfd read: yield until a signal arrives.
            while r == ELINUX_AGAIN:
                yield_to_others()
                r = _u_signalfd_read(fd, a1, a2)
        return r
    # #155: an inotify fd delivers queued struct inotify_event records.
    # The queue lives in the Layer-2 pool; vfs.ad has no path to it, so
    # the read is serviced here. Blocking read yields until the
    # filesystem posts an event (Hamnix has no preemption — block == a
    # yield loop, exactly the signalfd shape above).
    if marker == FD_INOTIFY_MARK:
        ins: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
        ir: int64 = uino_read(ins, a1, a2)
        if ir == ELINUX_AGAIN and nonblock == 0:
            while ir == ELINUX_AGAIN:
                yield_to_others()
                ir = uino_read(ins, a1, a2)
        return ir
    # fanotify fd: delivers fixed-size struct fanotify_event_metadata
    # records. Same Layer-2-pool-not-reachable-by-vfs shape as inotify, so
    # the read is serviced here; blocking read yields until an event is
    # posted by the filesystem. The group slot is read straight from the
    # per-task fd_buf (vfs's l2 get_buf rejects this marker).
    if marker == FD_FANOTIFY_MARK:
        ftask: Ptr[TaskStruct] = fd_owner_task(current_task())
        fgrp: int32 = cast[int32](ftask[0].fd_buf[cast[uint64](fd)]) - 1
        fr: int64 = _fan_read(fgrp, a1, a2)
        if fr == ELINUX_AGAIN and nonblock == 0:
            while fr == ELINUX_AGAIN:
                yield_to_others()
                fr = _fan_read(fgrp, a1, a2)
        return fr
    # §5: a non-blocking eventfd / timerfd read must return -EAGAIN when
    # the object has nothing pending — vfs_read_nb has no would-block
    # arm for these markers (it would fall through to the blocking
    # vfs_read), so the non-blocking case is short-circuited here. The
    # blocking case is left to vfs_read's yield loop.
    if marker == FD_EVENTFD_MARK or marker == FD_TIMERFD_MARK:
        if nonblock != 0:
            ready: int32 = 0
            if marker == FD_EVENTFD_MARK:
                es: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
                ready = uefd_readable(es)
            else:
                ts: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
                ready = utfd_readable(ts)
            if ready == 0:
                return ELINUX_AGAIN
        return _u_vfs_read_user(fd, a1, a2)
    # §5: O_NONBLOCK end-to-end. A would-block read on a non-blocking
    # socket / pipe fd must return -EAGAIN rather than yield-spinning in
    # vfs_read's blocking loop. vfs_read_nb returns >0 bytes ready,
    # 0 for would-block, -1 for a true EOF. We translate 0 -> -EAGAIN.
    if nonblock != 0:
        # #163: fill a kernel bounce, then copy_to_user. The 0 (would-
        # block) / negative (EOF) cases never touch the user buffer.
        rnb_cap: uint64 = a2
        if rnb_cap > U_L_BOUNCE:
            rnb_cap = U_L_BOUNCE
        rnb_kb: Array[4096, uint8]
        nb: int64 = vfs_read_nb(fd, cast[Ptr[uint8]](&rnb_kb[0]), rnb_cap)
        if nb == 0:
            return ELINUX_AGAIN
        if nb < 0:
            return 0                       # vfs_read_nb -1 == EOF
        return _u_copyout_rc(a1, &rnb_kb[0], nb)
    # #164: a blocking read on a console-backed fd (an interactive
    # `enter linux { … }` guest's stdin) routes through the termios line
    # discipline — cooked-mode line editing + echo by default, raw bytes
    # when the app cleared ICANON. This is what makes console keystrokes
    # actually reach (and be echoed for) the Linux guest. Pipes / files /
    # sockets are untouched: they keep the plain vfs_read path below.
    if vfs_fd_is_console(fd) != 0:
        # #163: the line discipline fills a kernel bounce; copy_to_user
        # lands the cooked/raw bytes at the user buffer afterwards.
        tc_cap: uint64 = a2
        if tc_cap > U_L_BOUNCE:
            tc_cap = U_L_BOUNCE
        tc_kb: Array[4096, uint8]
        tn: int64 = utermios_console_read(cast[Ptr[uint8]](&tc_kb[0]),
                                          tc_cap)
        return _u_copyout_rc(a1, &tc_kb[0], tn)
    return _u_vfs_read_user(fd, a1, a2)


def _u_write(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t write(int fd, const void *buf, size_t count)
    # /proc/<pid>/io: every write() syscall invocation is charged exactly
    # once on the common tail — syscw += 1 and wchar += (ret>0 ? ret : 0).
    # _u_write_body computes the result; we charge here so the single call
    # point covers every return shape (Linux counts the syscall on
    # would-block / -EPIPE too).
    ret: int64 = _u_write_body(a0, a1, a2, a3, a4, a5)
    nb: uint64 = 0
    if ret > 0:
        nb = cast[uint64](ret)
    current_task_charge_write(nb)
    return ret


def _u_write_body(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t write(int fd, const void *buf, size_t count)
    #
    # §3: SIGPIPE. A write whose destination pipe / socket has no
    # remaining reader fails with -EPIPE in vfs_write; POSIX also
    # requires a SIGPIPE be raised in the writer. We post it to the
    # current task's sig_pending — signal_check_and_handle at the
    # do_syscall tail then either terminates the task (SIG_DFL, the
    # daemon-friendly "broken connection ⇒ die" default) or invokes
    # the installed handler. Either way write(2) still returns -EPIPE,
    # so a daemon that ignores SIGPIPE sees the errno and copes.
    # §5: O_NONBLOCK end-to-end. A would-block write on a non-blocking
    # pipe / socket fd must return -EAGAIN rather than yield-spinning in
    # vfs_write's blocking loop. vfs_write_nb returns >0 bytes accepted,
    # 0 for would-block, or a negative errno; 0 maps to -EAGAIN.
    # #163: the bulk data path stages through a kernel bounce buffer
    # via copy_from_user (_u_vfs_write_user) — vfs_write/vfs_write_nb
    # only ever see kernel pointers now. nl_send / afunix_* do their
    # own copy_from_user internally and keep the raw user address.
    fd: int32 = cast[int32](a0)
    # AF_NETLINK: write(2) of nlmsghdr-framed request(s) builds + queues
    # the matching dump, same as send. Intercept before any vfs routing.
    wr_nlep: int32 = _u_netlink_ep(fd)
    if wr_nlep >= 0:
        return nl_send(wr_nlep, a1, a2)
    # AF_UNIX: a unix-socket fd's write(2) pushes into the peer's conduit
    # (stream ring) or delivers one datagram to the connected peer.
    # Intercept before any vfs routing.
    wr_uxep: int32 = _u_afunix_ep(fd)
    if wr_uxep >= 0:
        wr_nb: int32 = _u_fd_is_nonblock(fd)
        if afunix_get_type(wr_uxep) == AFU_SOCK_DGRAM:
            # write(2) on a DGRAM socket targets the connected peer.
            return afunix_sendto(wr_uxep, a1, a2, 0, 0)
        wr_sn: int64 = afunix_send_stream(wr_uxep, a1, a2)
        if wr_sn == AFU_EAGAIN:
            if wr_nb != 0:
                if a2 != 0:
                    return AFU_EAGAIN
                return 0
            while wr_sn == AFU_EAGAIN:
                yield_to_others()
                wr_sn = afunix_send_stream(wr_uxep, a1, a2)
        if wr_sn == ELINUX_PIPE:
            signal_post(current_idx_get(), SIGPIPE)
        return wr_sn
    n: int64 = 0
    if _u_fd_is_nonblock(fd) != 0:
        # #163: stage one bounce-sized chunk via copy_from_user. A
        # non-blocking write may legally accept fewer bytes than asked,
        # so a single capped chunk is the correct shape.
        wnb_cap: uint64 = a2
        if wnb_cap > U_L_BOUNCE:
            wnb_cap = U_L_BOUNCE
        wnb_kb: Array[4096, uint8]
        if wnb_cap != 0:
            if copy_from_user(cast[uint64](&wnb_kb[0]), a1, wnb_cap) != 0:
                return ELINUX_EFAULT
        n = vfs_write_nb(fd, cast[Ptr[uint8]](&wnb_kb[0]), wnb_cap)
        if n == 0 and a2 != 0:
            return ELINUX_AGAIN
    else:
        n = _u_vfs_write_user(fd, a1, a2)
    if n == ELINUX_PIPE:
        signal_post(current_idx_get(), SIGPIPE)
    return n


def _u_open(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int open(const char *pathname, int flags, mode_t mode)
    # `flags` IS honoured for the access mode: a write-mode open
    # (O_WRONLY / O_RDWR), optionally with O_CREAT / O_TRUNC, routes to
    # vfs_open_write (open-or-create-for-write); a read-mode open routes
    # to vfs_open. This is the M-track "branch on flags & O_ACCMODE" the
    # earlier milestone deferred — it is what makes a Linux ELF's
    # `open(path, O_WRONLY|O_CREAT)` actually create the file (and, via
    # the #155 vfs notify hook, fire an inotify IN_CREATE).
    flags: uint64 = a1
    # #163: copy the user path into a kernel scratch via strncpy_from_user
    # before resolve_path touches it — a bad path pointer now returns
    # -EFAULT instead of faulting the kernel mid-canonicalisation.
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &upath[0])
    if pin != 0:
        set_current_errstr("open: bad path pointer")
        return pin
    return _u_open_kpath(cast[Ptr[char]](&upath[0]), flags)


# --- Linux-ABI per-file POSIX DAC (discretionary access control) ------
#
# The native Plan-9 server-boundary perm gate (fs/vfs.ad
# chan_permission_check) classifies a file by its RESOLVED PATH STRING and
# routes to that server's _perm_check. That works when the path string and
# the real backend agree — but a per-file cross-server bind (e.g. the Linux
# NS's `bind '#r/etc/shadow' /etc/shadow` overlaying a cpio file onto a
# tmpfs/distro `/etc`) makes the string classify as the WRONG server, so
# the wrong (permissive) policy runs and a root-owned 0600 file stays
# readable to a non-root Linux user. That was the #497-flagged /etc/shadow
# leak.
#
# This gate closes it at the Linux-ABI boundary, keyed off the MAPPED Linux
# uid, using the OPENED fd's REAL backend mode + owner (vfs_fd_mode /
# vfs_fd_owner) — authoritative regardless of how the path string
# classified. Linux root (mapped uid 0 == native hostowner) BYPASSES every
# check, so apt/dpkg (which run as root in the Linux NS) are completely
# unaffected — the gate only ever executes its body for a non-root caller.
# A backend whose mode/owner is unknown (mounted-9P distrofs, etc.) DEFERS
# to the server-boundary policy that already ran in vfs_open (returns
# "allow" here) rather than blanket-denying a non-root user the whole NS.
DAC_WANT_R: int64 = 4
DAC_WANT_W: int64 = 2
DAC_WANT_X: int64 = 1


def _u_dac_perm(mode: uint32, owner_uid: uint32, owner_gid: uint32,
                want: int64) -> int64:
    # Standard POSIX rwx triad selection against the CALLER's mapped Linux
    # uid/gid. Returns 0 (grant) or ELINUX_ACCES (-13, deny). Root (mapped
    # uid 0) bypasses.
    caller_uid: int64 = _linux_uid_from_native(current_task_uid())
    if caller_uid == 0:
        return 0
    caller_gid: int64 = _linux_uid_from_native(current_task_gid())
    perm: uint32 = mode & cast[uint32](0o777)
    bits: uint32 = 0
    if caller_uid == cast[int64](owner_uid):
        bits = (perm >> 6) & cast[uint32](7)          # owner triple
    elif caller_gid == cast[int64](owner_gid):
        bits = (perm >> 3) & cast[uint32](7)          # group triple
    else:
        bits = perm & cast[uint32](7)                 # other triple
    w: uint32 = cast[uint32](want) & cast[uint32](7)
    if (bits & w) == w:
        return 0
    return ELINUX_ACCES


def _u_dac_check_fd(fd: int32, want: int64) -> int64:
    # DAC-check an OPEN fd for `want` (DAC_WANT_R/W/X) against the caller's
    # mapped Linux identity, using the fd's real backend mode + owner.
    # 0 = grant; ELINUX_ACCES = deny. Root bypasses (cheap early return).
    # Unknown mode/owner (-1) DEFERS (grant) — see the header note.
    caller_uid: int64 = _linux_uid_from_native(current_task_uid())
    if caller_uid == 0:
        return 0
    m: int32 = vfs_fd_mode(fd)
    if m < 0:
        return 0
    o_uid: uint32 = 0
    o_gid: uint32 = 0
    if vfs_fd_owner(fd, &o_uid, &o_gid) != 0:
        return 0
    return _u_dac_perm(cast[uint32](m), o_uid, o_gid, want)


def _u_open_kpath(upath: Ptr[char], flags: uint64) -> int64:
    # Thin wrapper: run the open, then stamp O_CLOEXEC (0x80000) on the
    # resulting fd so an open(...,O_CLOEXEC) fd is closed at the next
    # execve (dpkg/apt maintainer scripts, ld.so, every libc that opens
    # its private fds cloexec). A negative errno makes the apply a no-op.
    ork: int64 = _u_open_kpath_inner(upath, flags)
    if ork >= 0:
        _u_apply_cloexec_flags(cast[int32](ork), flags)
    return ork


def _u_open_kpath_inner(upath: Ptr[char], flags: uint64) -> int64:
    # open(2) core operating on a KERNEL path buffer (`upath`), already
    # copied in / anchored by the caller. Shared by _u_open (user path) and
    # _u_openat's real-dirfd leg (the dirfd's recorded open-path joined with
    # the relative component). The raw `upath` is handed to vfs_open /
    # vfs_open_write so their single internal resolve_path does the
    # namespace walk exactly once (the F10-1 double-resolution rule).
    rc: int32 = 0
    abs_path: Array[256, uint8]
    rc = resolve_path(upath, &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("open: path too long")
        return cast[int64](rc)
    # Phase D follow-up: the Layer-2 /proc/<name> -> /dev/<name>
    # string-rewrite is RETIRED. The Plan 9-shape replacement lives in
    # sys/src/9/port/chan.ad's pgrp_init: per-leaf bindings
    # (/proc/cpuinfo -> #c/cpuinfo etc.) so resolve_path delivers
    # _u_open the same backend chan the old rewrite hand-coded.
    # /proc/self/<leaf> resolution lives in devproc (`#p` server).
    # _u_openat / stat / readlink etc. now get the same routing for
    # free — the previous rewrite was wired into _u_open only.
    # O_ACCMODE == 3: O_RDONLY 0, O_WRONLY 1, O_RDWR 2.
    accmode: uint64 = flags & 3
    # Landlock enforcement: if the calling task has an active ruleset, gate
    # this open against it on the RESOLVED absolute path. A write-mode open
    # (O_WRONLY/O_RDWR) requests WRITE_FILE; a read-only open requests
    # READ_FILE. landlock_check_open returns 0 (allow) or -EACCES (deny). A
    # task with no ruleset — every native process, and every Linux task that
    # has not called restrict_self — returns 0 immediately (a cheap no-op),
    # so native open behaviour is untouched. This is layered ON TOP of the
    # native namespace enforcement that vfs_open already applies.
    ll_req: uint64 = LL_REQ_READ
    if accmode != 0:
        ll_req = LL_REQ_WRITE
    ll_rc: int64 = landlock_check_open(cast[Ptr[char]](&abs_path[0]), ll_req)
    if ll_rc != 0:
        set_current_errstr("open: denied by landlock ruleset")
        return ll_rc
    if accmode != 0:
        # Write (or read-write) open — open-or-create-for-write.
        # F10-1 (#454) double-resolution fix: pass the RAW user path so
        # vfs_open_write's single internal resolve_path does the namespace
        # walk EXACTLY ONCE. Passing abs_path (already resolved above for
        # landlock) re-ran the walk and, under a `/`-rebound root (e.g.
        # `bind '#distro' /` in `enter linux { ... }`), DOUBLED the bound
        # prefix (`/` -> `/var/lib/distros/default`, then resolved again to
        # `.../var/lib/distros/default`), so every open under the rebound
        # root ENOENT'd. Mirrors the native do_wstat probe pattern.
        # Honour O_TRUNC (0x200): a plain O_WRONLY/O_RDWR re-open must NOT
        # truncate (dpkg re-opens an unpacked control file in place — an
        # unconditional truncate clobbered it to 0 bytes). O_CREAT-fresh
        # files start empty regardless, so passing do_trunc=0 there is safe.
        do_trunc: int32 = 0
        if (flags & 0x200) != 0:                        # O_TRUNC
            do_trunc = 1
        # DAC (non-root only): a write-open of an EXISTING file must check
        # the WRITE bit BEFORE vfs_open_write_t (which may O_TRUNC it). We
        # probe-open the file read-only to obtain its real backend mode +
        # owner; if it exists and the caller lacks write, deny with EACCES
        # before any truncation. A genuinely-absent file (-ENOENT) is a
        # create — allowed here (parent-directory write policy is enforced
        # by the backend/server boundary). Root short-circuits inside
        # _u_dac_check_fd, so this whole probe is skipped for apt/dpkg.
        if _linux_uid_from_native(current_task_uid()) != 0:
            wp: int32 = vfs_open(upath)
            if wp >= 0:
                wdac: int64 = _u_dac_check_fd(wp, DAC_WANT_W)
                vfs_close(wp)
                if wdac != 0:
                    set_current_errstr("open: permission denied")
                    return wdac
            elif wp != -2:
                # Existing-but-unreadable / other error on the probe: deny
                # the write for a non-root caller rather than fall through.
                set_current_errstr("open: permission denied")
                return ELINUX_ACCES
        rc = vfs_open_write_t(upath, do_trunc)
        if rc == -2:
            set_current_errstr("file does not exist")
        elif rc < 0:
            set_current_errstr("open: write-open failed")
        return cast[int64](rc)
    rc = vfs_open(upath)
    if rc == -2:
        set_current_errstr("file does not exist")
        return cast[int64](rc)
    elif rc < 0:
        set_current_errstr("open: failed")
        return cast[int64](rc)
    # DAC (non-root only): enforce the READ bit against the fd's real
    # backend mode + owner. Root bypasses inside _u_dac_check_fd.
    rdac: int64 = _u_dac_check_fd(rc, DAC_WANT_R)
    if rdac != 0:
        vfs_close(rc)
        set_current_errstr("open: permission denied")
        return rdac
    return cast[int64](rc)


def _u_close(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int close(int fd)
    # §5: clear the fd's O_NONBLOCK flag in the Layer-2 bitmap so a
    # later fd allocated at the same slot starts blocking (the Linux
    # default) rather than inheriting a stale non-blocking flag.
    _u_set_fd_nonblock(cast[int32](a0), 0)
    # A pidfd carries its (task,fd)->pid record in the Layer-2 table;
    # vfs.ad has never heard of FD_PIDFD_MARK so it cannot drop it. Clear
    # it here before the fd slot is recycled (same shape as the
    # O_NONBLOCK clear above).
    if vfs_fd_marker(cast[int32](a0)) == FD_PIDFD_MARK:
        upidfd_clear(current_idx_get(), cast[int32](a0))
    # A perf_event fd carries its event state in the Layer-2 perf table;
    # vfs.ad has never heard of FD_PERF_MARK, so clear it here before the fd
    # slot is recycled (same shape as the pidfd clear above).
    if vfs_fd_marker(cast[int32](a0)) == FD_PERF_MARK:
        uperf_close_fd(current_idx_get(), cast[int32](a0))
    # A userfaultfd fd carries its uffd object (registered ranges + pending
    # fault queue) in the Layer-2 u_userfaultfd table; vfs.ad has never heard of
    # FD_UFFD_MARK, so free the uffd object here before the fd slot is recycled.
    if vfs_fd_marker(cast[int32](a0)) == FD_UFFD_MARK:
        uffd_close_fd(current_idx_get(), cast[int32](a0))
    # A bpf map/prog fd carries its state in the Layer-2 u_bpf pools; vfs.ad has
    # never heard of FD_BPF_MAP_MARK / FD_BPF_PROG_MARK, so free the bound pool
    # slot here before the fd slot is recycled (same shape as the perf clear).
    cl_bpf_mk: uint32 = vfs_fd_marker(cast[int32](a0))
    if cl_bpf_mk == FD_BPF_MAP_MARK or cl_bpf_mk == FD_BPF_PROG_MARK:
        bpf_close_fd(cast[int32](a0))
    # A landlock ruleset fd carries its (task,fd)->ruleset record in the
    # Layer-2 landlock table; vfs.ad has never heard of FD_LANDLOCK_MARK, so
    # clear it here before the fd slot is recycled. NOTE: closing the ruleset
    # fd does NOT lift an active restriction — the active ruleset is keyed by
    # task, not by the fd (matching Linux, where the sandbox survives close).
    if vfs_fd_marker(cast[int32](a0)) == FD_LANDLOCK_MARK:
        landlock_close_fd(current_idx_get(), cast[int32](a0))
    # AF_UNIX: the in-kernel endpoint release + SCM_RIGHTS drain USED to
    # live here, but ran UNCONDITIONALLY on every close(2), ignoring the
    # DEV_SOCKET chan refcount. A fork/dup'd socketpair fd then freed the
    # shared endpoint on the FIRST close — latching a spurious peer EOF on
    # the co-owner (the Firefox parent<->content IPC deadlock: an
    # inherited AF_UNIX socketpair carried across fork+exec). The teardown
    # is now FOLDED into namec_close's DEV_SOCKET arm
    # (fs/vfs.ad::vfs_socket_chan_release), which fires EXACTLY on the last
    # chan reference — correct for fork/dup/spawn AND (newly) task-exit
    # cleanup. vfs_close below reaches close_fd_in_task -> namec_close, so
    # the endpoint is released there, once, on the final holder's close.
    # AF_NETLINK: release the in-kernel endpoint (its rx ring + port id).
    # vfs.ad has never heard of the NETLINK tag, so drop it here.
    cl_nlep: int32 = _u_netlink_ep(cast[int32](a0))
    if cl_nlep >= 0:
        nl_close(cl_nlep)
    # io_uring: an FD_IORING_MARK fd owns a kernel ring context (SQ/CQ/SQE
    # regions). vfs.ad has never heard of FD_IORING_MARK, so free the
    # context here before the fd slot is recycled.
    if vfs_fd_marker(cast[int32](a0)) == FD_IORING_MARK:
        iouring_close_fd(cast[int32](a0))
    # §memfd_secret: clear the per-fd "secret" bit so a future fd
    # recycled at this slot starts non-secret. Idempotent on non-secret
    # fds (the bitmap entry is already 0).
    memfd_secret_close_fd(cast[int32](a0))
    # §new-mount-API: an FD_FSCTX_MARK / FD_FSMOUNT_MARK fd owns a slot
    # in the corresponding Layer-2 pool; release it before vfs_close
    # recycles the fd slot. Idempotent on non-matching markers.
    fsmount_close_fd(cast[int32](a0))
    rc: int32 = vfs_close(cast[int32](a0))
    return cast[int64](rc)


def _u_lseek(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # off_t lseek(int fd, off_t offset, int whence)
    n: int64 = vfs_lseek(cast[int32](a0),
                         cast[int64](a1), cast[int32](a2))
    return n


def _u_ioctl_pty(pack: int64, req: uint64, out: uint64) -> int64:
    # #165: the tty control surface for an FD_PTMX_MARK fd. `pack` is the
    # fd_buf value (slot << 1 | is_master). Returns the ioctl result, or
    # ELINUX_NOSYS for a request this layer doesn't own (the caller then
    # falls through to the generic ioctl arms). User-pointer reads/writes
    # go through the uaccess accessors so a bad *out is -EFAULT, not #PF.
    slot: int32 = cast[int32](pack >> 1)
    if pty_valid(slot) == 0:
        return ELINUX_NOTTY
    # TIOCGPTN (0x80045430) — return the slave index N via *out (u32).
    # The encoded request carries the _IOR size in the high bits; busybox
    # / glibc issue exactly 0x80045430, but match on the low 16 bits so a
    # differently-encoded caller still resolves.
    if (req & 0xFFFF) == 0x5430:
        if out == 0:
            return ELINUX_INVAL
        rc: int64 = put_user_32(cast[uint32](slot), out)
        if rc != 0:
            return ELINUX_FAULT
        return 0
    # TIOCSPTLCK (0x40045431) — *out is an int lock flag (0 = unlock).
    if (req & 0xFFFF) == 0x5431:
        if out == 0:
            return ELINUX_INVAL
        lockv: uint32 = 0
        rc2: int64 = get_user_32(out, cast[Ptr[uint32]](&lockv))
        if rc2 != 0:
            return ELINUX_FAULT
        pty_set_lock(slot, cast[int32](lockv))
        return 0
    # TIOCGPTLCK (0x80045439) — report the current lock state via *out.
    if (req & 0xFFFF) == 0x5439:
        if out == 0:
            return ELINUX_INVAL
        # pty_valid already confirmed the pair; report unlocked(0) by
        # convention once a slave has been unlocked. We don't surface the
        # internal lock flag, so report 0 (the common post-unlock state).
        if put_user_32(0, out) != 0:
            return ELINUX_FAULT
        return 0
    # TCGETS (0x5401) — per-pair termios.
    if req == 0x5401:
        return pty_tcgets(slot, out)
    # TCSETS / TCSETSW / TCSETSF (0x5402/3/4) — apply per-pair termios.
    if req == 0x5402 or req == 0x5403 or req == 0x5404:
        return pty_tcsets(slot, out)
    # TIOCGWINSZ (0x5413) — per-pair winsize.
    if req == 0x5413:
        return pty_getwinsz(slot, out)
    # TIOCSWINSZ (0x5414) — store per-pair winsize.
    if req == 0x5414:
        return pty_setwinsz(slot, out)
    return ELINUX_NOSYS


def _u_ioctl(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int ioctl(int fd, unsigned long request, ...)
    # U36 promotes ioctl from -ENOSYS to a tty-aware handler. busybox
    # sh's job-control code probes the controlling terminal via
    # TIOCGWINSZ / TIOCGPGRP / TCGETS before it agrees to run, so
    # answering those (with believable single-task defaults: a 24x80
    # window owned by the caller's own pid) is the cheapest unblock.
    # FIONREAD is asked by readline-shaped input loops to decide
    # whether read() will return immediately — claiming zero matches
    # our blocking-read semantics. Anything we don't recognise still
    # returns -ENOSYS so unhandled cases stay loud in the trace.
    fd:  int32  = cast[int32](a0)
    req: uint64 = a1
    out: uint64 = a2
    # A perf_event fd's ioctls (PERF_EVENT_IOC_ENABLE/DISABLE/RESET) control its
    # software counter. Handled here, ahead of every tty/console arm, so a perf
    # fd's ioctl never falls through to a terminal probe. uperf_ioctl owns the
    # per-(task,fd) event state; an unknown request on a perf fd is -EINVAL.
    if vfs_fd_marker(fd) == FD_PERF_MARK:
        return uperf_ioctl(fd, req, out)
    # A userfaultfd fd's ioctls (UFFDIO_API/REGISTER/UNREGISTER/COPY/ZEROPAGE/
    # WAKE) drive the per-task uffd state + the real page-resolution path.
    # Handled here, ahead of every tty/console arm, so a uffd fd's ioctl never
    # falls through to a terminal probe. uffd_ioctl owns the per-(task,fd) state;
    # an unknown request on a uffd fd is -EINVAL.
    if vfs_fd_marker(fd) == FD_UFFD_MARK:
        return uffd_ioctl(fd, req, out)
    # #165: PTY-fd ioctls. If `fd` is an FD_PTMX_MARK fd, its tty control
    # surface operates on THAT pair's state — TIOCGPTN (the slave index),
    # TIOCSPTLCK (lock/unlock the slave open), TCGETS/TCSETS (per-pair
    # termios, ICANON|ECHO actually gating the slave's discipline), and
    # TIOC{G,S}WINSZ (per-pair winsize). Handled here, ahead of the
    # console-fd arms below, so a pty's ioctls never fall through to the
    # per-task console termios. A non-pty fd (pack == -1) falls through.
    pty_pack: int64 = vfs_fd_pty_pack(fd)
    if pty_pack >= 0:
        ptt: int64 = _u_ioctl_pty(pty_pack, req, out)
        if ptt != ELINUX_NOSYS:
            return ptt
        # An unrecognised ioctl on a pty fd falls through to the generic
        # arms (e.g. TIOCGPGRP), so job-control probes still answer.
    # TIOCGWINSZ — struct winsize { u16 row, col, xpixel, ypixel }
    if req == 0x5413:
        if out == 0:
            return ELINUX_INVAL
        # #163: write the winsize fields through the translated path.
        if put_user_16(24, out) != 0 or put_user_16(80, out + 2) != 0 \
                or put_user_16(0, out + 4) != 0 \
                or put_user_16(0, out + 6) != 0:
            return ELINUX_EFAULT
        return 0
    # TIOCSWINSZ — accept whatever the caller set.
    if req == 0x5414:
        return 0
    # TIOCGPGRP / TIOCGSID — both return a pid_t through *out. Single-
    # task system means caller is its own session and process group.
    if req == 0x540F or req == 0x5429:
        if out == 0:
            return ELINUX_INVAL
        # #163: translated writeback of the pid_t out-param.
        if put_user_32(cast[uint32](current_task_pid()), out) != 0:
            return ELINUX_EFAULT
        return 0
    # TIOCSPGRP — accept; no pgrp bookkeeping to update.
    if req == 0x5410:
        return 0
    # TIOCSCTTY — "make this fd the controlling terminal of the calling
    # session". Sent by glibc's login_tty() (the core of forkpty(3) /
    # openpty-based terminal emulators, `script`, sshd login, weston-
    # terminal) right after setsid(). Hamnix has a single-session model
    # (setsid / setpgid / TIOCSPGRP are all accepted no-ops), so there is
    # no session→ctty table to update — accept and return 0. Without this
    # login_tty() failed (-ENOSYS) and the forkpty CHILD _exit(1)'d BEFORE
    # ever reaching its execve(), so the shell never ran and the terminal
    # got no PTY content (QA-N29). TIOCNOTTY (drop the controlling tty) is
    # the symmetric no-op.
    if req == 0x540E or req == 0x5422:
        return 0
    # TCGETS / TCSETS — termios get/set. #164: these now read & write a
    # REAL per-task termios state (linux_abi/u_termios.ad) instead of
    # returning a zeroed struct. A console-backed fd (stdin/stdout/stderr
    # of an interactive guest) is a tty: TCGETS reports the live cooked-
    # mode flags (ICANON|ECHO|…) so isatty() and a shell's job-control
    # probe both succeed, and TCSETS APPLIES the caller's flags — clearing
    # ICANON|ECHO is what lets a python3 / bash readline put the terminal
    # into raw mode and have the next read(2) honour it. A non-console fd
    # gets -ENOTTY so isatty() on a pipe / file answers "not a tty".
    #
    # struct termios is exactly 36 bytes (4*tcflag_t + c_line + NCCS=19
    # cc_t). Writing the right size matters: an over-write here clobbers
    # the caller's saved RBP / return address (the U39 trap).
    if req == 0x5401:
        if vfs_fd_is_console(fd) == 0:
            return ELINUX_NOTTY
        return utermios_tcgets(out)
    if req == 0x5402 or req == 0x5403 or req == 0x5404:
        # TCSETS / TCSETSW / TCSETSF — apply (the W/F variants differ only
        # in drain/flush timing, which is a no-op on our synchronous tty).
        if vfs_fd_is_console(fd) == 0:
            return ELINUX_NOTTY
        return utermios_tcsets(out)
    # FIONREAD — claim zero bytes immediately readable.
    if req == 0x541B:
        if out == 0:
            return ELINUX_INVAL
        # #163: translated writeback of the int out-param.
        if put_user_32(0, out) != 0:
            return ELINUX_EFAULT
        return 0
    return ELINUX_NOSYS


def _u_pipe(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int pipe(int pipefd[2]) — Hamnix's vfs_pipe matches this signature.
    # U29: wired up. vfs_pipe allocates a pipe pair and writes the two
    # fds into out_fds[0] / out_fds[1]. We deliberately don't validate
    # a0 as a userspace pointer (no copy_to_user yet — this whole file
    # treats user pointers as kernel-accessible identity-mapped addresses).
    if a0 == 0:
        set_current_errstr("pipe: null fds buffer")
        return ELINUX_INVAL
    # #163: have vfs_pipe write the two fds into a kernel scratch, then
    # copy_to_user the 8-byte int[2] out in one translated transfer — a
    # bad user fds buffer now returns -EFAULT instead of faulting vfs_pipe
    # on a raw user pointer.
    fds: Array[2, int32]
    rc: int32 = vfs_pipe(&fds[0])
    if rc < 0:
        set_current_errstr("pipe: out of fds")
        return cast[int64](rc)
    if copy_to_user(a0, cast[uint64](&fds[0]), 8) != 0:
        # Roll back the just-created pipe so we don't leak two fds.
        vfs_close(fds[0])
        vfs_close(fds[1])
        set_current_errstr("pipe: bad fds buffer")
        return ELINUX_EFAULT
    return cast[int64](rc)


def _u_pipe2(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int pipe2(int pipefd[2], int flags)
    # Linux's pipe2 == pipe + apply O_CLOEXEC / O_NONBLOCK / O_DIRECT to
    # both ends atomically. Hamnix has no FD_CLOEXEC bookkeeping (exec
    # rebuilds the fd table) and no packet-mode O_DIRECT, but §5 honours
    # O_NONBLOCK: both fds are flagged so a would-block read/write
    # returns -EAGAIN — epoll-driven pipe daemons depend on this.
    if a0 == 0:
        return ELINUX_INVAL
    # #163: same translated-writeback shape as _u_pipe.
    fds: Array[2, int32]
    rc: int32 = vfs_pipe(&fds[0])
    if rc < 0:
        return cast[int64](rc)
    rfd: int32 = fds[0]
    wfd: int32 = fds[1]
    if copy_to_user(a0, cast[uint64](&fds[0]), 8) != 0:
        vfs_close(rfd)
        vfs_close(wfd)
        set_current_errstr("pipe2: bad fds buffer")
        return ELINUX_EFAULT
    if (a1 & O_NONBLOCK_BIT) != 0:
        _u_set_fd_nonblock(rfd, 1)
        _u_set_fd_nonblock(wfd, 1)
    # O_CLOEXEC on both ends: THE load-bearing case for the fork+exec sync
    # pipe (foot / posix_spawn create the pipe cloexec so the child's exec
    # closes the write end and the parent's read() returns EOF).
    _u_apply_cloexec_flags(rfd, a1)
    _u_apply_cloexec_flags(wfd, a1)
    return cast[int64](rc)


def _u_dup(a0: uint64, a1: uint64, a2: uint64,
           a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int dup(int oldfd). POSIX: the new fd is NOT close-on-exec, even if
    # oldfd was (copy_fd_entry copies the flag, so clear it explicitly).
    nfd: int32 = vfs_dup(cast[int32](a0))
    if nfd >= 0:
        _u_set_fd_cloexec(nfd, 0)
    return cast[int64](nfd)


def _u_dup2(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int dup2(int oldfd, int newfd). POSIX: newfd is NOT close-on-exec.
    nfd: int32 = vfs_dup2(cast[int32](a0), cast[int32](a1))
    if nfd >= 0:
        _u_set_fd_cloexec(nfd, 0)
    return cast[int64](nfd)


def _u_dup3(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int dup3(int oldfd, int newfd, int flags)
    # Linux requires oldfd != newfd (otherwise -EINVAL — the one
    # behavioural difference from dup2) and applies O_CLOEXEC if set
    # in flags. Hamnix has no CLOEXEC bookkeeping; we honour the
    # equal-fd EINVAL rule and forward the rest to vfs_dup2.
    if a0 == a1:
        set_current_errstr("dup2: oldfd == newfd")
        return ELINUX_INVAL
    rc: int32 = vfs_dup2(cast[int32](a0), cast[int32](a1))
    if rc < 0:
        set_current_errstr("dup2: bad fd")
        return cast[int64](rc)
    # dup3 sets close-on-exec on the new fd iff O_CLOEXEC is in flags
    # (a2); otherwise the new fd is explicitly not cloexec.
    _u_apply_cloexec_flags(rc, a2)
    return cast[int64](rc)


def _u_getdents64(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t getdents64(int fd, void *dirp, size_t count)
    #
    # U32: real directory enumeration. vfs_open() now snapshots
    # immediate children of an opened directory into a kmalloc'd
    # NAME\n buffer parked on the fd. We repackage each "NAME\n"
    # entry into a struct linux_dirent64 written to *dirp:
    #
    #   struct linux_dirent64 {
    #       ino64_t        d_ino;        // 8 bytes (monotonic counter)
    #       off64_t        d_off;        // 8 bytes (next dir_pos)
    #       unsigned short d_reclen;     // 2 bytes
    #       unsigned char  d_type;       // 1 byte (DT_REG=8 default)
    #       char           d_name[];     // NUL-terminated, padded
    #   };
    #
    # d_reclen aligns the next entry to 8 bytes. EOF is reported as
    # a 0 return; -EINVAL if the user buffer can't hold a single
    # entry (the smallest possible reclen is 24 — 19-byte header
    # rounded up — plus a 1-char name + NUL).
    if cast[int32](a0) < 0:
        return ELINUX_BADF
    fd: int32 = cast[int32](a0)
    if vfs_fd_is_dir(fd) == 0:
        return ELINUX_NOTDIR
    if a1 == 0:
        return ELINUX_INVAL
    if a2 == 0:
        return ELINUX_INVAL

    dir_buf:    uint64 = vfs_fd_dir_buf(fd)
    dir_buflen: uint64 = vfs_fd_dir_buflen(fd)
    dir_pos:    uint64 = vfs_fd_dir_pos(fd)

    user: uint64 = a1
    cap:  uint64 = a2
    out:  uint64 = 0

    while dir_pos < dir_buflen:
        # Parse one NAME\n line from the kernel-side dir buffer.
        line_start: uint64 = dir_pos
        scan: uint64 = dir_pos
        while scan < dir_buflen and \
                cast[Ptr[uint8]](dir_buf + scan)[0] != 10:
            scan = scan + 1
        name_len: uint64 = scan - line_start
        # Skip empty lines defensively (shouldn't happen but cheap).
        if name_len == 0:
            if scan < dir_buflen:
                dir_pos = scan + 1
            else:
                dir_pos = scan
            continue
        # Clamp the name so a single struct linux_dirent64 (19-byte header +
        # name + NUL, 8-aligned) always fits the per-entry kernel scratch.
        if name_len > 300:
            name_len = 300
        # struct linux_dirent64 header is 19 bytes; +1 for NUL, then
        # round up to 8-byte alignment for d_reclen.
        reclen: uint64 = (19 + name_len + 1 + 7) & ~cast[uint64](7)
        if out + reclen > cap:
            # Not enough room for this entry. If we've already packed
            # something, return that; otherwise this is a too-small
            # caller buffer and Linux returns -EINVAL.
            if out == 0:
                return ELINUX_INVAL
            vfs_fd_dir_set_pos(fd, dir_pos)
            return cast[int64](out)
        # Advance dir_pos past the line + its trailing '\n'.
        next_pos: uint64 = scan
        if next_pos < dir_buflen:
            next_pos = next_pos + 1
        # #163 FOLLOW-UP: assemble the entry in a kernel scratch then write it
        # to the user buffer via ONE translated copy_to_user, instead of poking
        # the user pointer (user + out) directly. The bytes thus land at the
        # physical frame backing the user buffer even when its vaddr != phys.
        ent: uint64 = cast[uint64](&u_dirent_scratch[0])
        memset(cast[Ptr[uint8]](ent), 0, reclen)
        # d_ino — fake monotonic counter derived from line offset so
        # successive calls return stable values. Avoids zero (some
        # buggy userspace treats ino==0 as deleted).
        cast[Ptr[uint64]](ent + 0)[0]  = line_start + 1
        # d_off — position to resume from on next getdents64 call.
        cast[Ptr[uint64]](ent + 8)[0]  = next_pos
        # d_reclen — total bytes for this entry incl padding.
        cast[Ptr[uint16]](ent + 16)[0] = cast[uint16](reclen)
        # d_type — DT_REG=8. We don't track types in the dir buffer,
        # and busybox's ls doesn't need DT_DIR (it'll call lstat).
        cast[Ptr[uint8]](ent + 18)[0]  = 8
        # d_name + NUL (the rest of reclen is already NUL from memset).
        i: uint64 = 0
        while i < name_len:
            cast[Ptr[uint8]](ent + 19 + i)[0] = \
                cast[Ptr[uint8]](dir_buf + line_start + i)[0]
            i = i + 1
        # Copy the assembled entry out at offset `out` in the user buffer.
        if copy_to_user(user + out, ent, reclen) != 0:
            # The user dirp faulted. If we've packed nothing yet, this is a
            # bad buffer (-EFAULT); otherwise report the entries that landed.
            if out == 0:
                set_current_errstr("getdents64: bad dirp pointer")
                return ELINUX_EFAULT
            vfs_fd_dir_set_pos(fd, dir_pos)
            return cast[int64](out)
        out = out + reclen
        dir_pos = next_pos

    vfs_fd_dir_set_pos(fd, dir_pos)
    return cast[int64](out)


# =====================================================================
# U33: cheap no-op / forward-to-stat syscalls
# =====================================================================
#
# These five syscalls each appear in busybox / glibc traces while
# enumerating /bin or stat'ing files for `ls -l`. None of them need
# real kernel-side state at this milestone — they're either hints
# (madvise, fadvise64) the kernel can ignore, or "zero out the
# struct" answers (getrusage), or thin wrappers over machinery we
# already have (statx → newfstatat). Adding them quiets the
# "unknown syscall" log line per-applet and lets busybox skip its
# slower fallback paths.


def _u_madvise(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int madvise(void *addr, size_t length, int advice)
    # §1: pure hints (MADV_WILLNEED / SEQUENTIAL / ...) are no-ops, but
    # MADV_DONTNEED / MADV_FREE / MADV_REMOVE have an observable
    # contract on anonymous memory — the range must read back zero
    # afterwards. vma_madvise honours that by zeroing the writable
    # pages in place (Hamnix has no demand paging to lazily re-fault).
    # Still returns 0 for every advice value so glibc's malloc-trim
    # path never sees a spurious EINVAL.
    slot: uint64 = current_idx_get()
    return vma_madvise(slot, a0, a1, cast[int32](a2))


def _u_fadvise64(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int posix_fadvise(int fd, off_t offset, off_t len, int advice)
    # Same shape as madvise: a hint with no backing readahead state
    # to influence. busybox's cat emits this against stdin on some
    # builds — return 0 to keep the read loop quiet.
    return 0


def _u_move_pages(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long move_pages(int pid, unsigned long count, void **pages,
    #                 const int *nodes, int *status, int flags)
    # Hamnix is single-NUMA-node (node 0). glibc's malloc/arena code (and
    # some dpkg/apt paths) probe move_pages with nodes==NULL purely to
    # learn which node each page lives on — a query, not a migration.
    # Semantics: with nodes==NULL we must fill status[i] with the node of
    # pages[i] (always 0 here). With nodes!=NULL a migration is requested;
    # since every page is already on the only node, the move is a no-op
    # and each status[i] becomes 0 (success). Either way: status filled 0,
    # return 0. count==0 is a valid trivial success.
    count: uint64 = a1
    status: uint64 = a4
    if status != 0 and count != 0:
        i: uint64 = 0
        while i < count:
            # status is an array of int (4 bytes/entry); 0 == node 0.
            if put_user_32(status + i * 4, 0) != 0:
                return ELINUX_EFAULT
            i = i + 1
    return 0


def _u_pselect6(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int pselect6(int n, fd_set *r, fd_set *w, fd_set *e,
    #              const struct timespec *timeout, void *sigmask)
    # §5: same readiness-driven scan as select(2); the timeout is a
    # struct timespec { i64 tv_sec; i64 tv_nsec } here, and the trailing
    # sigmask arg is ignored (signals are delivered cooperatively at the
    # syscall boundary — pselect6's atomic-mask race cannot occur).
    nfds: uint64 = a0
    bounded: int32 = 1
    tj: uint64 = UEP_WAIT_MAX_JIFFIES
    if a4 != 0:
        # #163: fetch the user timespec through the page tables.
        sec:  uint64 = 0
        nsec: uint64 = 0
        if get_user_64(a4, &sec) != 0:
            return ELINUX_EFAULT
        if get_user_64(a4 + 8, &nsec) != 0:
            return ELINUX_EFAULT
        if sec == 0 and nsec == 0:
            bounded = 0
        else:
            tj = sec * HZ + nsec / (1000000000 / HZ)
            if tj == 0:
                tj = 1
            if tj > UEP_WAIT_MAX_JIFFIES:
                tj = UEP_WAIT_MAX_JIFFIES
    return _u_select_common(nfds, a1, a2, a3, tj, bounded)


# #163 FOLLOW-UP: kernel scratch for the assembled struct rusage / tms /
# statx / sysinfo structs. Each handler fills its scratch then copies the
# whole struct out with one translated copy_to_user. Top-level BSS (the U9
# nested-frame-Array quirk forbids these inside a function body).
u_rusage_scratch: Array[144, uint8]
u_tms_scratch:    Array[32, uint8]
u_statx_scratch:  Array[256, uint8]
u_sysinfo_scratch: Array[112, uint8]
# Per-entry scratch for getdents64 (max linux_dirent64 reclen for a NAME of
# up to MAX_USER_PATH bytes: 19 header + name + NUL, 8-aligned).
u_dirent_scratch: Array[320, uint8]


# _getrusage_fill — assemble a 144-byte `struct rusage` for `who` into the
# KERNEL buffer `kru`. This is the single source of truth for the field
# layout: `_u_getrusage` fills a kernel scratch with it and then copies it
# out to the USER pointer via copy_to_user, while the in-kernel accounting
# selftests (blkio/nsignals/pgfault/ctxsw/vmstat/rusage/ruchild) fill a
# local kernel buffer with it DIRECTLY.
#
# Why the split exists: `_u_getrusage` must copy_to_user its result so a
# real user `usage` pointer is translated + SMAP-bracketed (see the #163
# follow-up). copy_to_user CORRECTLY refuses a kernel-address destination
# (US=0 leaf -> EFAULT), so a selftest that handed its own kernel-stack
# buffer to `_u_getrusage` got a deterministic -EFAULT. Sharing the fill
# path lets those selftests exercise the EXACT store logic without routing
# a kernel buffer through the user-copy boundary.
def _getrusage_fill(who: uint64, kru: uint64) -> int32:
    memset(cast[Ptr[uint8]](kru), 0, 144)
    # RUSAGE_CHILDREN (-1): fill ONLY from the child accumulators.
    if who == cast[uint64](0) - cast[uint64](1):
        cu: uint64 = current_task_cutime_ticks()
        cs: uint64 = current_task_cstime_ticks()
        cast[Ptr[int64]](kru + 0x00)[0] = cast[int64](cu / 100)
        cast[Ptr[int64]](kru + 0x08)[0] = cast[int64]((cu % 100) * 10000)
        cast[Ptr[int64]](kru + 0x10)[0] = cast[int64](cs / 100)
        cast[Ptr[int64]](kru + 0x18)[0] = cast[int64]((cs % 100) * 10000)
        cast[Ptr[uint64]](kru + 0x40)[0] = current_task_cminflt()
        cast[Ptr[uint64]](kru + 0x48)[0] = current_task_cmajflt()
        return 0
    # RUSAGE_SELF / RUSAGE_THREAD.
    gru_slot: int32 = cast[int32](current_idx_get())
    cur_kb: uint64 = task_rss_pages(current_idx_get()) * 4
    if cur_kb > task_maxrss_kb_at(gru_slot):
        task_set_maxrss_kb_at(gru_slot, cur_kb)
    cast[Ptr[uint64]](kru + 0x20)[0] = task_maxrss_kb_at(gru_slot)
    ut: uint64 = current_task_utime_ticks()
    st: uint64 = current_task_stime_ticks()
    cast[Ptr[int64]](kru + 0x00)[0] = cast[int64](ut / 100)
    cast[Ptr[int64]](kru + 0x08)[0] = cast[int64]((ut % 100) * 10000)
    cast[Ptr[int64]](kru + 0x10)[0] = cast[int64](st / 100)
    cast[Ptr[int64]](kru + 0x18)[0] = cast[int64]((st % 100) * 10000)
    cast[Ptr[uint64]](kru + 0x40)[0] = current_task_minflt()
    cast[Ptr[uint64]](kru + 0x48)[0] = current_task_majflt()
    cast[Ptr[uint64]](kru + 0x58)[0] = current_task_inblock()
    cast[Ptr[uint64]](kru + 0x60)[0] = current_task_oublock()
    cast[Ptr[uint64]](kru + 0x78)[0] = current_task_nsignals()
    cast[Ptr[uint64]](kru + 0x80)[0] = current_task_nvcsw()
    cast[Ptr[uint64]](kru + 0x88)[0] = current_task_nivcsw()
    return 0


def _u_getrusage(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getrusage(int who, struct rusage *usage)
    # struct rusage is 144 bytes on x86_64. We report REAL CPU time via
    # the per-task user/system tick counters the timer ISR accrues:
    #   offset 0x00  ru_utime  struct timeval {s64 tv_sec; s64 tv_usec}
    #   offset 0x10  ru_stime  struct timeval
    #   offset 0x20  ru_maxrss  long — REAL peak resident set size in KB
    #   offset 0x40  ru_minflt  long — REAL minor page-fault count
    #   offset 0x48  ru_majflt  long — REAL major page-fault count
    #   offset 0x58  ru_inblock long — REAL 512-byte block reads charged
    #   offset 0x60  ru_oublock long — REAL 512-byte block writes charged
    #   offset 0x78  ru_nsignals long — REAL count of signals delivered
    #   offset 0x80  ru_nvcsw   long — REAL voluntary ctx-switch count
    #   offset 0x88  ru_nivcsw  long — REAL involuntary ctx-switch count
    # ru_maxrss is a monotonic high-water: we compute the CURRENT rss on
    # demand (present 4 KiB pages * 4 KB) by walking the calling task's
    # VMAs, bump the per-task high-water field if it grew, and report the
    # high-water — so it never decrements and has no drift site. The
    # remaining 6 longs (ru_nswap, ru_msgsnd/rcv, in 0x28..0x38 /
    # 0x50 / 0x68..0x70) stay zero — Hamnix tracks no swap/msg accounting.
    # HZ=100, so 1 tick = 10 ms = 10000 microseconds: for a tick count N,
    # tv_sec = N/100 and tv_usec = (N%100)*10000.
    #
    # The `who` arg (a0) selects whose counters are reported:
    #   RUSAGE_SELF     =  0  — the calling task's own counters (default).
    #   RUSAGE_THREAD   =  1  — aliases SELF; Hamnix has no per-thread split.
    #   RUSAGE_CHILDREN = -1  (0xFFFFFFFFFFFFFFFF as a uint64) — reports ONLY
    #     the per-task CHILD accumulators rolled up at child reap: ru_utime/
    #     ru_stime from cutime/cstime ticks and ru_minflt/ru_majflt from
    #     cminflt/cmajflt. Children's rss/ctx-switch/signals/block-I/O are not
    #     separately accumulated, so those fields stay zero.
    if a1 == 0:
        return ELINUX_INVAL
    # #163 FOLLOW-UP: assemble struct rusage in a kernel scratch (via the
    # shared _getrusage_fill helper), then copy it out in ONE translated
    # copy_to_user. Previously every field was poked through the RAW user
    # pointer a1, so a malformed `usage` faulted the kernel and the writes
    # assumed user-vaddr == phys.
    kru: uint64 = cast[uint64](&u_rusage_scratch[0])
    _getrusage_fill(a0, kru)
    if copy_to_user(a1, kru, 144) != 0:
        set_current_errstr("getrusage: bad usage pointer")
        return ELINUX_EFAULT
    return 0


def _u_times(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # clock_t times(struct tms *buf). struct tms is 32 bytes, four clock_t
    # (s64) tick fields: tms_utime(0x00) tms_stime(0x08) tms_cutime(0x10)
    # tms_cstime(0x18). tms_cutime/tms_cstime now carry the REAL accumulated
    # CPU ticks of all reaped children (whole subtree, RUSAGE_CHILDREN), folded
    # in at each child's reap (kernel/sched/core.ad task_reap) and read via
    # current_task_cutime_ticks / current_task_cstime_ticks. Return = elapsed
    # wall-clock ticks (jiffies). A NULL buf is legal (POSIX) — just return the
    # tick count.
    if a0 != 0:
        # #163 FOLLOW-UP: assemble struct tms in a kernel scratch, then copy
        # it out in one translated copy_to_user (was a raw deref of a0).
        ktms: uint64 = cast[uint64](&u_tms_scratch[0])
        memset(cast[Ptr[uint8]](ktms), 0, 32)
        cast[Ptr[int64]](ktms + 0x00)[0] = cast[int64](current_task_utime_ticks())
        cast[Ptr[int64]](ktms + 0x08)[0] = cast[int64](current_task_stime_ticks())
        cast[Ptr[int64]](ktms + 0x10)[0] = cast[int64](current_task_cutime_ticks())
        cast[Ptr[int64]](ktms + 0x18)[0] = cast[int64](current_task_cstime_ticks())
        if copy_to_user(a0, ktms, 32) != 0:
            set_current_errstr("times: bad tms pointer")
            return cast[int64](ELINUX_EFAULT)
    return cast[int64](get_jiffies())


# Linux x86_64 struct statx is 256 bytes. We only fill the fields
# busybox actually reads for `ls -l` (mode, size, mtime). The rest
# of the buffer stays zeroed via memset; statx_mask in the response
# tells callers which fields are valid.
STATX_SIZE:        uint64 = 256
STATX_OFF_MASK:    uint64 = 0       # u32: which fields are filled
STATX_OFF_BLKSIZE: uint64 = 4       # u32
STATX_OFF_NLINK:   uint64 = 16      # u32
STATX_OFF_UID:     uint64 = 20      # u32
STATX_OFF_GID:     uint64 = 24      # u32
STATX_OFF_MODE:    uint64 = 28      # u16
STATX_OFF_INO:     uint64 = 32      # u64
STATX_OFF_SIZE:    uint64 = 40      # u64
STATX_OFF_BLOCKS:  uint64 = 48      # u64
STATX_OFF_ATIME:   uint64 = 72      # struct {s64 sec; u32 nsec; u32 _}
STATX_OFF_MTIME:   uint64 = 88
STATX_OFF_CTIME:   uint64 = 104

# STATX_BASIC_STATS = type|mode|nlink|uid|gid|atime|mtime|ctime|ino|
#                     size|blocks (bits 0..10) = 0x7FF.
STATX_BASIC_STATS: uint32 = 0x7FF


def _u_fill_statx(buf: uint64, fd: int32) -> int64:
    # Mirror of _u_fill_stat but writes into the statx layout. fd is
    # assumed valid; caller opens/closes around this body.
    # #163 FOLLOW-UP: assemble into a kernel scratch then copy_to_user once,
    # so a malformed user `buf` returns -EFAULT instead of faulting the
    # kernel on a raw deref (previously every field poked `buf` directly).
    if buf == 0:
        return ELINUX_INVAL
    ksx: uint64 = cast[uint64](&u_statx_scratch[0])
    memset(cast[Ptr[uint8]](ksx), 0, STATX_SIZE)
    cast[Ptr[uint32]](ksx + STATX_OFF_MASK)[0]    = STATX_BASIC_STATS
    cast[Ptr[uint32]](ksx + STATX_OFF_BLKSIZE)[0] = 4096
    cast[Ptr[uint32]](ksx + STATX_OFF_NLINK)[0]   = 1
    # Real owner, mapped native->linux (see _u_fill_stat); GNU coreutils
    # `ls -ln` reads uid/gid via statx, so this is what makes a tmpfs file
    # created by a uid-1001 process report owner 1001 rather than 0.
    sx_uid: uint32 = 0
    sx_gid: uint32 = 0
    if vfs_fd_stat_owner(fd, &sx_uid, &sx_gid) == 0:
        cast[Ptr[uint32]](ksx + STATX_OFF_UID)[0] = \
            cast[uint32](_linux_uid_from_native(sx_uid))
        cast[Ptr[uint32]](ksx + STATX_OFF_GID)[0] = \
            cast[uint32](_linux_uid_from_native(sx_gid))
    else:
        cast[Ptr[uint32]](ksx + STATX_OFF_UID)[0] = 0
        cast[Ptr[uint32]](ksx + STATX_OFF_GID)[0] = 0
    # BLOCKER 2: report the REAL execute bits (see _u_fill_stat) so statx-based
    # executable checks see staged Debian helpers as runnable.
    mode_v: uint16 = cast[uint16](STAT_MODE_REG)
    if vfs_fd_is_dir(fd) != 0:
        mode_v = cast[uint16](STAT_MODE_DIR)
    else:
        sx_perm: int32 = vfs_fd_mode(fd)
        if sx_perm >= 0:
            mode_v = cast[uint16](cast[uint32](0o100000) | cast[uint32](sx_perm))
    cast[Ptr[uint16]](ksx + STATX_OFF_MODE)[0]    = mode_v
    cast[Ptr[uint64]](ksx + STATX_OFF_INO)[0]     = cast[uint64](fd)
    size: int64 = _u_file_size_via_lseek(fd)
    if size < 0:
        size = 0
    cast[Ptr[uint64]](ksx + STATX_OFF_SIZE)[0]    = cast[uint64](size)
    blocks: int64 = (size + 511) / 512
    cast[Ptr[uint64]](ksx + STATX_OFF_BLOCKS)[0]  = cast[uint64](blocks)
    j: uint64 = get_jiffies()
    sec: int64 = cast[int64](j / 100)
    mt: int64 = vfs_fd_mtime(fd)
    if mt >= 0:
        sec = mt
    cast[Ptr[int64]](ksx + STATX_OFF_ATIME)[0]    = sec
    cast[Ptr[int64]](ksx + STATX_OFF_MTIME)[0]    = sec
    cast[Ptr[int64]](ksx + STATX_OFF_CTIME)[0]    = sec
    if copy_to_user(buf, ksx, STATX_SIZE) != 0:
        set_current_errstr("statx: bad statxbuf pointer")
        return ELINUX_EFAULT
    return 0


def _u_statx(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int statx(int dirfd, const char *path, int flags,
    #           unsigned int mask, struct statx *buf)
    # Argument shape matches newfstatat with an extra `mask` (a3)
    # and the buffer in a4 instead of a2. Hamnix ignores the mask
    # (we always fill STATX_BASIC_STATS) and reuses newfstatat's
    # path-resolution rules for dirfd / AT_EMPTY_PATH semantics.
    if a1 == 0 or a4 == 0:
        return ELINUX_INVAL
    flags: uint64 = a2
    empty_path: int32 = 0
    if (flags & AT_EMPTY_PATH) != 0:
        empty_path = 1
        flags = flags & ~AT_EMPTY_PATH
    if (flags & AT_SYMLINK_NOFOLLOW) != 0:
        flags = flags & ~AT_SYMLINK_NOFOLLOW
    # Tolerate the advisory flags GNU coreutils ALWAYS set: AT_NO_AUTOMOUNT
    # (no autofs here -> no-op) and the AT_STATX_*_SYNC caching hints (we
    # always return current attributes). Stripping them keeps `flags == 0`
    # so stat/ls/du/find don't get a spurious EINVAL.
    flags = flags & ~AT_NO_AUTOMOUNT
    flags = flags & ~AT_STATX_FORCE_SYNC
    flags = flags & ~AT_STATX_DONT_SYNC
    if flags != 0:
        printk2("linux_u: statx unsupported flags=%x path=%x\n",
                a2, a1)
        return ELINUX_INVAL
    # #163: copy the user path into a kernel buffer up-front so every
    # subsequent deref (the empty/abs byte checks AND resolve_path) hits
    # kernel memory — a bad user pointer is a clean -EFAULT, not a #PF.
    statx_path: Array[256, uint8]
    statx_pin: int64 = _u_copyin_path(a1, &statx_path[0])
    if statx_pin != 0:
        return statx_pin
    p: Ptr[char] = cast[Ptr[char]](&statx_path[0])
    is_empty: int32 = 0
    if cast[uint8](p[0] & 0xFF) == 0:
        is_empty = 1
    if empty_path != 0 and is_empty != 0:
        if _u_is_at_fdcwd(a0) != 0:
            return ELINUX_BADF
        return _u_fill_statx(a4, cast[int32](a0))
    is_abs: int32 = 0
    if cast[uint8](p[0] & 0xFF) == 47:                # '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        return ELINUX_BADF
    # F10-1 double-resolution fix: pass the RAW path to vfs_open so its
    # single internal resolve_path walks the namespace once (a pre-resolve
    # here + vfs_open's own resolve doubled a `/`-rebound root prefix and
    # ENOENT'd every stat under `enter linux { bind '#distro' / }`).
    fd: int32 = vfs_open(cast[Ptr[char]](&statx_path[0]))
    if fd < 0:
        return cast[int64](fd)
    rv: int64 = _u_fill_statx(a4, fd)
    vfs_close(fd)
    return rv


def _u_getpid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t getpid(void). Returns the THREAD-GROUP id (tgid) — the group
    # leader's pid, stable across every CLONE_THREAD sibling — NOT the calling
    # thread's own task pid (that is gettid(2)). See current_task_tgid: a
    # threaded process (Firefox) that captures its identity on one thread and
    # re-checks it on another (IPC EndpointProcInfo assert) needs a consistent
    # answer on every thread.
    return cast[int64](current_task_tgid())


def _u_kill(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int kill(pid_t pid, int sig)
    tgt: int32 = task_lookup_by_pid(a0)
    if tgt < 0:
        set_current_errstr("kill: no such pid")
        return ELINUX_SRCH
    signal_post(cast[uint64](tgt), a1)
    return 0


# --- setitimer(2) / getitimer(2) / alarm(2) : ITIMER_REAL ------------
#
# X/GTK apps (xeyes, xclock, and the GLib main loop's fallback timers)
# drive their periodic redraw off setitimer(ITIMER_REAL) -> SIGALRM. The
# per-task countdown lives in TaskStruct (itimer_real_ticks / _reload) and
# is decremented once per native timer tick by itimer_real_tick_all()
# (kernel/sched/core.ad, called BSP-only from timer_interrupt); on expiry
# it posts SIGALRM (14) to the owning task and reloads from the interval.
#
# The kernel counts in TICKS (HZ=100 => 10 ms/tick, US_PER_TICK below); the
# userspace ABI is microseconds via `struct itimerval`. We convert at the
# syscall boundary, rounding a non-zero value UP to at least one tick so a
# sub-tick request still fires (never instantly / never dropped) — the
# tick-granularity approximation Linux itself gives on a HZ=100 kernel.
#
# struct itimerval { struct timeval it_interval; struct timeval it_value; };
# struct timeval   { long tv_sec; long tv_usec; };  // 16 bytes each
#   it_interval.tv_sec  @  0   it_interval.tv_usec @  8
#   it_value.tv_sec     @ 16   it_value.tv_usec    @ 24   (total 32 bytes)
ITIMER_WHICH_REAL:    uint64 = 0
US_PER_TICK:          uint64 = 10000        # HZ=100 => 10 ms/tick
US_PER_SEC:           uint64 = 1000000


def _itimer_ticks_from_us(sec: uint64, usec: uint64) -> uint64:
    # Convert a timeval (sec, usec) to a tick count, rounding a non-zero
    # duration UP to the next whole tick. 0 duration => 0 ticks (disarm).
    total_us: uint64 = sec * US_PER_SEC + usec
    if total_us == 0:
        return 0
    return (total_us + US_PER_TICK - 1) / US_PER_TICK


def _itimer_store_timeval(uaddr: uint64, ticks: uint64):
    # Write a tick count back to a user `struct timeval` at uaddr as
    # (tv_sec, tv_usec). Caller has already validated uaddr (STAC bracket
    # is held by the caller).
    total_us: uint64 = ticks * US_PER_TICK
    sec:  uint64 = total_us / US_PER_SEC
    usec: uint64 = total_us % US_PER_SEC
    cast[Ptr[uint64]](uaddr)[0]     = sec
    cast[Ptr[uint64]](uaddr + 8)[0] = usec


def _u_setitimer(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setitimer(int which, const struct itimerval *new_value,
    #               struct itimerval *old_value)
    which: uint64 = a0
    newp:  uint64 = a1
    oldp:  uint64 = a2
    slot:  uint64 = current_idx_get()
    # ITIMER_VIRTUAL(1)/ITIMER_PROF(2) are process-CPU-time timers we don't
    # model; report unimplemented rather than silently mis-firing on the
    # wall clock. ITIMER_REAL(0) is the wall-clock timer xeyes needs.
    if which != ITIMER_WHICH_REAL:
        return ELINUX_NOSYS
    # Snapshot the CURRENT setting first so old_value reflects pre-change
    # state even when new_value overwrites it (they may alias).
    cur_val:    uint64 = get_task_itimer_real_ticks(slot)
    cur_reload: uint64 = get_task_itimer_real_reload(slot)
    if oldp != 0:
        _ua_stac()
        _itimer_store_timeval(oldp,      cur_reload)   # it_interval
        _itimer_store_timeval(oldp + 16, cur_val)      # it_value
        _ua_clac()
    if newp != 0:
        kbuf: Array[4, uint64]
        if copy_from_user(cast[uint64](&kbuf[0]), newp, 32) != 0:
            return ELINUX_FAULT
        # kbuf[0]=it_interval.sec [1]=it_interval.usec
        # kbuf[2]=it_value.sec    [3]=it_value.usec
        reload_ticks: uint64 = _itimer_ticks_from_us(kbuf[0], kbuf[1])
        value_ticks:  uint64 = _itimer_ticks_from_us(kbuf[2], kbuf[3])
        set_task_itimer_real_reload(slot, reload_ticks)
        # it_value == 0 disarms the timer regardless of it_interval (POSIX).
        set_task_itimer_real_ticks(slot, value_ticks)
    return 0


def _u_getitimer(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getitimer(int which, struct itimerval *curr_value)
    which: uint64 = a0
    curp:  uint64 = a1
    slot:  uint64 = current_idx_get()
    if which != ITIMER_WHICH_REAL:
        return ELINUX_NOSYS
    if curp == 0:
        return ELINUX_FAULT
    cur_val:    uint64 = get_task_itimer_real_ticks(slot)
    cur_reload: uint64 = get_task_itimer_real_reload(slot)
    _ua_stac()
    _itimer_store_timeval(curp,      cur_reload)        # it_interval
    _itimer_store_timeval(curp + 16, cur_val)           # it_value (remaining)
    _ua_clac()
    return 0


def _u_alarm(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # unsigned int alarm(unsigned int seconds)
    # One-shot ITIMER_REAL front-end: arm a SIGALRM `seconds` from now (no
    # reload), returning the number of seconds remaining on any PREVIOUS
    # alarm (rounded up), or 0 if none was pending. alarm(0) cancels.
    secs: uint64 = a0 & 0xFFFFFFFF
    slot: uint64 = current_idx_get()
    # Remaining seconds on the prior timer, rounded up (POSIX return value).
    prev_ticks:  uint64 = get_task_itimer_real_ticks(slot)
    prev_us:     uint64 = prev_ticks * US_PER_TICK
    prev_secs:   uint64 = (prev_us + US_PER_SEC - 1) / US_PER_SEC
    # alarm() is one-shot: no interval reload.
    set_task_itimer_real_reload(slot, 0)
    set_task_itimer_real_ticks(slot, _itimer_ticks_from_us(secs, 0))
    return cast[int64](prev_secs)


def _u_exit(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void _exit(int status). task_exit_current does not return.
    task_exit_current(cast[int64](a0))
    return 0


def _u_exit_group(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void exit_group(int status). Terminates the WHOLE thread group: every
    # CLONE_THREAD sibling that shares this task's address space dies too.
    # #75: real thread groups DID land (CLONE_THREAD/CLONE_FILES), so the old
    # "identical to _exit" shortcut left a multi-threaded process's siblings
    # orphaned and parked forever when one thread called exit_group — the
    # Firefox wedge. Post SIGKILL to the group first (linux_group_fatal_kill;
    # each sibling self-exits at its next signal check, task_reap frees the
    # shared mm exactly once), THEN exit this thread. SYS_exit (_exit) keeps
    # the single-thread body — only exit_group is process-wide, per Linux.
    linux_group_fatal_kill(current_idx_get())
    task_exit_current(cast[int64](a0))
    return 0


def _u_chdir(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int chdir(const char *path)
    # #163: translated path copy-in before resolve_path.
    # Store the CANONICAL namespace path (the bind point you walked,
    # e.g. `/srv`) — NOT resolve_path's ns_walk backend rewrite (`#s`).
    # getcwd/`pwd` must report the namespace name, mirroring native
    # SYS_CHDIR.
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &upath[0])
    if pin != 0:
        set_current_errstr("chdir: bad path pointer")
        return pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path_canonical(cast[Ptr[char]](&upath[0]),
                                       &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("chdir: path too long")
        return cast[int64](rc)
    rc = set_task_cwd(current_idx_get(), &abs_path[0])
    if rc < 0:
        set_current_errstr("chdir: path too long")
        return -7                                    # -E2BIG
    return 0


def _u_fchdir(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fchdir(int fd) — like chdir(2) but the target directory is named
    # by an open fd rather than a path string. coreutils `mkdir -p a/b/c`
    # relies on it (open each component, fchdir into it, mkdir the next).
    # We have no per-fd directory streams, but every open fd records its
    # canonical namespace open-path in TaskStruct.fd_opened_path (stamped
    # at open time and used by the *at(2) dirfd anchoring). fchdir simply
    # promotes that recorded path to the task cwd — mirroring how chdir
    # stores resolve_path_canonical's namespace name.
    fdu: uint64 = a0 & 0xFFFFFFFF
    if fdu >= 64:
        set_current_errstr("fchdir: bad fd")
        return ELINUX_BADF
    t: Ptr[TaskStruct] = current_task()
    dpath: Ptr[uint8] = task_fd_opened_path_ptr(t, fdu)
    if dpath[0] == 0:
        # No recorded path for this fd (never opened, or a stream-shaped
        # fd with no directory identity): can't name a cwd from it.
        set_current_errstr("fchdir: fd has no directory path")
        return ELINUX_BADF
    rc: int32 = set_task_cwd(current_idx_get(), dpath)
    if rc < 0:
        set_current_errstr("fchdir: path too long")
        return -7                                    # -E2BIG
    return 0


# #163: kernel scratch for getcwd(2). The cwd path is bounded by the
# native 256-byte cap; this scratch holds the (possibly truncated) string
# before the single translated copy_to_user. Top-level BSS, not a
# nested-frame Array (U9 quirk).
GETCWD_SCRATCH_MAX: uint64 = 256
u_getcwd_scratch: Array[256, uint8]


def _u_getcwd(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # char *getcwd(char *buf, size_t size) — the kernel-side syscall
    # returns bytes-written (incl NUL) or -ERANGE; libc reshapes that
    # into the char* the caller expects. Matches the native SYS_GETCWD
    # body in arch/x86/kernel/syscall.ad.
    if a1 == 0:
        set_current_errstr("getcwd: buffer too small")
        return ELINUX_RANGE
    src: Ptr[uint8] = get_cwd_buf(current_idx_get())
    # #163: assemble the (possibly truncated) cwd string in a kernel
    # scratch, then copy_to_user it in one translated transfer so a bad
    # user buffer returns -EFAULT instead of faulting on a raw deref.
    # The cwd is bounded by GETCWD_SCRATCH_MAX (the native path cap); a
    # request larger than that is served up to the scratch size.
    cap: uint64 = a1
    if cap > GETCWD_SCRATCH_MAX:
        cap = GETCWD_SCRATCH_MAX
    i: uint64 = 0
    nbytes: uint64 = 0
    while i + 1 < cap:
        c: uint8 = src[i]
        u_getcwd_scratch[i] = c
        i = i + 1
        if c == 0:
            nbytes = i
            break
    if nbytes == 0:
        # No NUL hit within cap-1 bytes (or cap was 1): terminate here.
        u_getcwd_scratch[i] = 0
        nbytes = i + 1
    if copy_to_user(a0, cast[uint64](&u_getcwd_scratch[0]), nbytes) != 0:
        set_current_errstr("getcwd: bad buffer pointer")
        return ELINUX_EFAULT
    return cast[int64](nbytes)


def _u_mkdir(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int mkdir(const char *pathname, mode_t mode)
    # V1: tmpfs is a real tree, so this does real work — resolve to an
    # absolute path then route through vfs_mkdir (same shape as
    # _u_unlink). Non-tmpfs paths return -EROFS. mode is ignored
    # (tmpfs has no permission bits at this milestone).
    # #163: translated path copy-in before resolve_path.
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &upath[0])
    if pin != 0:
        set_current_errstr("mkdir: bad path pointer")
        return pin
    abs_path: Array[256, uint8]
    # Write-side resolution: a mkdir under a writable tmpfs overlay must
    # land in the MCREATE member even when the dir name is baked into the
    # read-only cpio base (resolve_path_create is a no-op without overlay).
    rc: int32 = resolve_path_create(cast[Ptr[char]](&upath[0]),
                                    &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("mkdir: path too long")
        return cast[int64](rc)
    rc = vfs_mkdir(cast[Ptr[char]](&abs_path[0]))
    if rc < 0:
        set_current_errstr("mkdir: cannot create directory")
    return cast[int64](rc)


def _u_unlink(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int unlink(const char *pathname)
    # #163: translated path copy-in before resolve_path.
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &upath[0])
    if pin != 0:
        set_current_errstr("unlink: bad path pointer")
        return pin
    # #69: deny unlink through a read-only VIEW binding (EROFS). A
    # non-readonly bind returns 0, so normal removals are unaffected.
    if vfs_path_is_readonly(cast[Ptr[char]](&upath[0])) != 0:
        set_current_errstr("unlink: read-only bind (EROFS)")
        return cast[int64](ELINUX_EROFS)
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&upath[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("unlink: path too long")
        return cast[int64](rc)
    rc = vfs_unlink(cast[Ptr[char]](&abs_path[0]))
    if rc < 0:
        set_current_errstr("unlink: no such file")
    return cast[int64](rc)


def _u_rmdir(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # rmdir(2) leg of unlinkat(AT_REMOVEDIR) — glibc rmdir() issues
    # unlinkat(AT_FDCWD, path, AT_REMOVEDIR). Routes through vfs_rmdir,
    # which enforces empty-dir semantics (-ENOTEMPTY on a non-empty dir,
    # -ENOTDIR on a non-dir target) per backend (tmpfs/ext4/fat). Before
    # this, unlinkat dropped the AT_REMOVEDIR flag and fell into
    # vfs_unlink, so a non-empty dir was wrongly accepted.
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &upath[0])
    if pin != 0:
        set_current_errstr("rmdir: bad path pointer")
        return pin
    # #69: deny rmdir through a read-only VIEW binding (EROFS).
    if vfs_path_is_readonly(cast[Ptr[char]](&upath[0])) != 0:
        set_current_errstr("rmdir: read-only bind (EROFS)")
        return cast[int64](ELINUX_EROFS)
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&upath[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("rmdir: path too long")
        return cast[int64](rc)
    rc = vfs_rmdir(cast[Ptr[char]](&abs_path[0]))
    if rc < 0:
        set_current_errstr("rmdir: failed")
    return cast[int64](rc)


def _u_rename(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int rename(const char *oldpath, const char *newpath)
    # Both paths are resolved to absolute form, then routed through
    # vfs_rename — which moves the dirent (with overwrite of an
    # existing destination) on tmpfs or ext4. `mv` and apt/dpkg's
    # "write temp, rename into place" idiom land here.
    # #163: translated copy-in of both user paths before resolve_path.
    uold: Array[256, uint8]
    unew: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &uold[0])
    if pin != 0:
        set_current_errstr("rename: bad old path pointer")
        return pin
    pin = _u_copyin_path(a1, &unew[0])
    if pin != 0:
        set_current_errstr("rename: bad new path pointer")
        return pin
    old_abs: Array[256, uint8]
    new_abs: Array[256, uint8]
    # Write-side (create) resolution for BOTH ends: a rename moves a name
    # into place, so under a writable tmpfs overlay both the source and
    # the destination must resolve to the writable (MCREATE) member —
    # otherwise a name baked into the read-only cpio base (e.g.
    # /var/lib/dpkg/status) would resolve to cpio and the cross-backend
    # rename (tmpfs src, cpio dst) would fail. resolve_path_create is a
    # transparent no-op when no MCREATE union covers the path.
    rc: int32 = resolve_path_create(cast[Ptr[char]](&uold[0]),
                                    &old_abs[0], 256)
    if rc != 0:
        set_current_errstr("rename: old path too long")
        return cast[int64](rc)
    rc = resolve_path_create(cast[Ptr[char]](&unew[0]), &new_abs[0], 256)
    if rc != 0:
        set_current_errstr("rename: new path too long")
        return cast[int64](rc)
    rc = vfs_rename(cast[Ptr[char]](&old_abs[0]),
                    cast[Ptr[char]](&new_abs[0]))
    if rc < 0:
        set_current_errstr("rename: failed")
    return cast[int64](rc)


def _u_renameat(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int renameat(int olddirfd, const char *old,
    #              int newdirfd, const char *new)  and
    # int renameat2(..., unsigned int flags)
    #
    # We have no per-fd directory streams, so the dirfd args are
    # honoured only as AT_FDCWD (-100) / absolute paths — resolve_path
    # already anchors relative paths at the task cwd, which is the
    # AT_FDCWD behaviour. renameat2's RENAME_NOREPLACE / RENAME_EXCHANGE
    # flags are not supported; a non-zero flags word returns -EINVAL
    # rather than silently doing a plain rename.
    if nr_is_renameat2_flagged(a4) != 0:
        set_current_errstr("renameat2: unsupported flags")
        return ELINUX_INVAL
    # #163: translated copy-in of both user paths before resolve_path.
    uold: Array[256, uint8]
    unew: Array[256, uint8]
    pin: int64 = _u_copyin_path(a1, &uold[0])
    if pin != 0:
        set_current_errstr("renameat: bad old path pointer")
        return pin
    pin = _u_copyin_path(a3, &unew[0])
    if pin != 0:
        set_current_errstr("renameat: bad new path pointer")
        return pin
    old_abs: Array[256, uint8]
    new_abs: Array[256, uint8]
    # Write-side resolution for both ends — see _u_rename for the
    # overlay rationale (rename into place must land in the writable
    # MCREATE member, not the read-only cpio base).
    rc: int32 = resolve_path_create(cast[Ptr[char]](&uold[0]),
                                    &old_abs[0], 256)
    if rc != 0:
        set_current_errstr("renameat: old path too long")
        return cast[int64](rc)
    rc = resolve_path_create(cast[Ptr[char]](&unew[0]), &new_abs[0], 256)
    if rc != 0:
        set_current_errstr("renameat: new path too long")
        return cast[int64](rc)
    rc = vfs_rename(cast[Ptr[char]](&old_abs[0]),
                    cast[Ptr[char]](&new_abs[0]))
    if rc < 0:
        set_current_errstr("renameat: failed")
    return cast[int64](rc)


# --- #165: mkdirat / unlinkat -------------------------------------
#
# The dirfd-relative elders of mkdir(2)/rmdir(2)/unlink(2). resolve_path
# already anchors a relative path at the task cwd (the AT_FDCWD answer),
# so for AT_FDCWD / absolute paths these are exactly mkdir / unlink. A
# relative path against a real dirfd needs per-fd dirpath state we don't
# track — return -ENOSYS there rather than silently using the wrong cwd.

# _u_at_resolve_dirfd: build the absolute path for an *at(2) call carrying
# a REAL dirfd (not AT_FDCWD) + a relative `pathname`. Recovers the dirfd's
# recorded open-path (TaskStruct.fd_opened_path, stamped at open time) and
# joins `<dirpath>/<pathname>` into `out` (NUL-terminated). Returns 0 on
# success, a negative Linux errno otherwise. This is what makes `mkdir -p`
# and dpkg's incremental directory creation work: GNU coreutils mkdir -p
# opens each freshly-created component and passes its fd as the dirfd for
# the next mkdirat, so the path arg is relative ("var", "lib", ...) against
# a real dirfd — previously an outright -ENOSYS.
def _u_at_resolve_dirfd(dirfd: uint64, upath: uint64,
                        out: Ptr[uint8], out_cap: uint64) -> int64:
    t: Ptr[TaskStruct] = current_task()
    # dirfd arrives as a sign-extended uint64; the fd index is the low 32.
    fdu: uint64 = dirfd & 0xFFFFFFFF
    # TaskStruct.fd_opened_path is Array[64, ...]; bound the index to it.
    if fdu >= 64:
        return ELINUX_BADF
    dpath: Ptr[uint8] = task_fd_opened_path_ptr(t, fdu)
    if dpath[0] == 0:
        # No recorded path for this fd — can't anchor the relative name.
        return ELINUX_NOSYS
    # Copy the dirpath into `out`.
    i: uint64 = 0
    while i < out_cap - 2 and dpath[i] != 0:
        out[i] = dpath[i]
        i = i + 1
    # Ensure exactly one '/' separator.
    if i > 0 and out[i - 1] != 47:
        out[i] = 47                                     # '/'
        i = i + 1
    # Copy in the relative pathname right after the separator.
    rel: Array[256, uint8]
    pin: int64 = _u_copyin_path(upath, &rel[0])
    if pin != 0:
        return pin
    j: uint64 = 0
    # Skip a leading "./" in the relative component.
    if rel[0] == 46 and rel[1] == 47:                   # "./"
        j = 2
    while i < out_cap - 1 and rel[j] != 0:
        out[i] = rel[j]
        i = i + 1
        j = j + 1
    out[i] = 0
    return 0


def _u_mkdirat(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int mkdirat(int dirfd, const char *pathname, mode_t mode)
    is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                    # leading '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        # Real dirfd + relative path: anchor at the dirfd's open-path.
        at_abs: Array[384, uint8]
        arc: int64 = _u_at_resolve_dirfd(a0, a1, &at_abs[0], 384)
        if arc != 0:
            return arc
        ab: Array[384, uint8]
        rc: int32 = resolve_path_create(cast[Ptr[char]](&at_abs[0]),
                                        cast[Ptr[char]](&ab[0]), 384)
        if rc != 0:
            return cast[int64](rc)
        rc = vfs_mkdir(cast[Ptr[char]](&ab[0]))
        if rc < 0:
            set_current_errstr("mkdirat: cannot create directory")
        return cast[int64](rc)
    return _u_mkdir(a1, a2, 0, 0, 0, 0)


def _u_unlinkat(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int unlinkat(int dirfd, const char *pathname, int flags)
    # flags carries AT_REMOVEDIR (0x200) to select rmdir semantics:
    #   set   → route to vfs_rmdir (empty-dir enforcement, -ENOTEMPTY)
    #   clear → vfs_unlink (file removal)
    # glibc's rmdir() is exactly unlinkat(AT_FDCWD, path, AT_REMOVEDIR).
    # AT_FDCWD / absolute only — see the block comment.
    is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                    # leading '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        # Real dirfd + relative path: anchor at the dirfd's open-path,
        # then route to the absolute-path rmdir/unlink leg.
        at_abs: Array[384, uint8]
        arc: int64 = _u_at_resolve_dirfd(a0, a1, &at_abs[0], 384)
        if arc != 0:
            return arc
        ab: Array[384, uint8]
        rrc: int32 = resolve_path(cast[Ptr[char]](&at_abs[0]),
                                  cast[Ptr[char]](&ab[0]), 384)
        if rrc != 0:
            return cast[int64](rrc)
        if (a2 & 0x200) != 0:                           # AT_REMOVEDIR
            return cast[int64](vfs_rmdir(cast[Ptr[char]](&ab[0])))
        return cast[int64](vfs_unlink(cast[Ptr[char]](&ab[0])))
    if (a2 & 0x200) != 0:                               # AT_REMOVEDIR
        return _u_rmdir(a1, 0, 0, 0, 0, 0)
    return _u_unlink(a1, 0, 0, 0, 0, 0)


# --- symlink / link family ----------------------------------------
#
# Hardlinks and symlinks. The VFS backends (fs/vfs.ad: vfs_symlink,
# vfs_link) are fully implemented — ext4 stores on-disk symlinks and
# inode-level hardlinks; tmpfs stores symlink targets in-RAM and follows
# them transparently on open. These syscall numbers were simply never
# wired into the Linux-ABI ladder, so `ln`, `ln -s`, and tar/dpkg
# symlink+hardlink extraction hit -ENOSYS. Both paths are copied in
# (#163) and resolved to absolute form (so resolve_path's cwd-anchoring
# gives the AT_FDCWD behaviour) before the VFS call.
#
# Errno mapping: the VFS returns small negative kernel errnos that already
# line up with the Linux errno space — vfs_symlink returns -EROFS / -ENOENT
# / -EEXIST / -EPERM; vfs_link returns -EXDEV (cross-file-server, the Plan
# 9 namespace boundary) / -ENOENT / -EPERM. We forward the VFS rc verbatim.

def _u_symlink(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int symlink(const char *target, const char *linkpath)
    # `target` is the link contents — stored VERBATIM, NOT resolved (a
    # symlink target is an opaque string that may be relative or dangling).
    # Only `linkpath` (where the link is created) is resolved to absolute.
    utarget: Array[256, uint8]
    ulink: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &utarget[0])
    if pin != 0:
        set_current_errstr("symlink: bad target pointer")
        return pin
    pin = _u_copyin_path(a1, &ulink[0])
    if pin != 0:
        set_current_errstr("symlink: bad linkpath pointer")
        return pin
    link_abs: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&ulink[0]), &link_abs[0], 256)
    if rc != 0:
        set_current_errstr("symlink: linkpath too long")
        return cast[int64](rc)
    rc = vfs_symlink(cast[Ptr[char]](&utarget[0]),
                     cast[Ptr[char]](&link_abs[0]))
    if rc < 0:
        set_current_errstr("symlink: failed")
    return cast[int64](rc)


def _u_symlinkat(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int symlinkat(const char *target, int newdirfd, const char *linkpath)
    # newdirfd is honoured only as AT_FDCWD (-100) / absolute linkpath —
    # resolve_path already anchors a relative linkpath at the task cwd,
    # which is the AT_FDCWD behaviour. (target is never anchored.)
    is_abs: int32 = 0
    if _u_user_first_byte(a2) == 47:                    # leading '/'
        is_abs = 1
    if _u_is_at_fdcwd(a1) == 0 and is_abs == 0:
        return ELINUX_NOSYS
    return _u_symlink(a0, a2, 0, 0, 0, 0)


def _u_link(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int link(const char *oldpath, const char *newpath)
    # Both paths are resolved to absolute form, then routed through
    # vfs_link — which enforces the Plan 9 file-server boundary (a
    # hardlink may not cross a namespace/file-server, -EXDEV) before
    # creating the second name on the ext4/tmpfs backend.
    uold: Array[256, uint8]
    unew: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &uold[0])
    if pin != 0:
        set_current_errstr("link: bad old path pointer")
        return pin
    pin = _u_copyin_path(a1, &unew[0])
    if pin != 0:
        set_current_errstr("link: bad new path pointer")
        return pin
    old_abs: Array[256, uint8]
    new_abs: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&uold[0]), &old_abs[0], 256)
    if rc != 0:
        set_current_errstr("link: old path too long")
        return cast[int64](rc)
    rc = resolve_path(cast[Ptr[char]](&unew[0]), &new_abs[0], 256)
    if rc != 0:
        set_current_errstr("link: new path too long")
        return cast[int64](rc)
    rc = vfs_link(cast[Ptr[char]](&old_abs[0]),
                  cast[Ptr[char]](&new_abs[0]))
    if rc < 0:
        set_current_errstr("link: failed")
    return cast[int64](rc)


def _u_linkat(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int linkat(int olddirfd, const char *old,
    #            int newdirfd, const char *new, int flags)
    # olddirfd/newdirfd honoured only as AT_FDCWD / absolute (resolve_path
    # anchors relatives at cwd). AT_SYMLINK_FOLLOW (0x400) is the only
    # meaningful flag and is the harmless default here (we have no
    # per-symlink no-follow distinction on hardlink creation); other flag
    # bits are ignored rather than failing the common AT_FDCWD ln(1) call.
    old_is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                    # leading '/'
        old_is_abs = 1
    new_is_abs: int32 = 0
    if _u_user_first_byte(a3) == 47:                    # leading '/'
        new_is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and old_is_abs == 0:
        return ELINUX_NOSYS
    if _u_is_at_fdcwd(a2) == 0 and new_is_abs == 0:
        return ELINUX_NOSYS
    return _u_link(a1, a3, 0, 0, 0, 0)


# --- utimensat / utimes / utime / futimesat -----------------------
#
# Timestamp setters, all backed by vfs_set_mtime (fs/vfs.ad). ext4
# persists i_mtime/i_ctime; tmpfs/cpio carry no per-inode time store and
# accept the value as no-op success — exactly Linux's behaviour for a FS
# that doesn't record times. We honour the modification time (the field
# `touch`, `cp -p`, `tar`, and `make` actually care about); the access
# time is accepted but, like the atime on a relatime/noatime mount, not
# separately stored.
#
# Special timespec nsec sentinels (Linux):
#   UTIME_NOW  (0x3FFFFFFF)  -> use the current wall-clock time
#   UTIME_OMIT (0x3FFFFFFE)  -> leave this timestamp unchanged
# A NULL times pointer means "set both to now" (the touch(1) default).

UTIME_NOW:  int64 = 0x3FFFFFFF
UTIME_OMIT: int64 = 0x3FFFFFFE


def _u_now_epoch_secs() -> uint64:
    # Current wall-clock seconds since the Unix epoch, same source the
    # time(2)/clock_gettime(CLOCK_REALTIME) handlers use.
    return rtc_boot_epoch_get() + (tsc_monotonic_ns() / 1000000000)


def _u_set_times_for_path(abs_path: Ptr[char], raw_path: Ptr[char],
                          mtime_secs: uint64, omit: int32) -> int64:
    # Apply an mtime. `abs_path` is the resolve_path'd form (vfs_set_mtime's
    # backend classifier needs the canonical spelling); `raw_path` is the
    # UNRESOLVED user path used for the existence probe. We ALWAYS validate
    # the path exists first (Linux's utimensat returns -ENOENT on a missing
    # target — the bit touch/tar check), because vfs_set_mtime's tmpfs/cpio
    # legs are no-op-success and would NOT catch a missing path.
    # `omit`!=0 means the caller asked to leave mtime unchanged
    # (UTIME_OMIT) — we still validate existence but skip the mutation.
    # F10-1 double-resolution fix: probe with raw_path so vfs_open's single
    # internal resolve_path walks the namespace once (passing abs_path
    # re-resolved it and doubled a `/`-rebound root prefix).
    probe: int32 = vfs_open(raw_path)
    if probe < 0:
        return ELINUX_NOENT
    vfs_close(probe)
    if omit != 0:
        return 0
    rc: int32 = vfs_set_mtime(abs_path, cast[uint32](mtime_secs))
    return cast[int64](rc)


def _u_utimensat(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int utimensat(int dirfd, const char *path,
    #               const struct timespec times[2], int flags)
    # times == NULL          -> set both atime+mtime to NOW.
    # times[0] = atime, times[1] = mtime; each {tv_sec, tv_nsec}.
    # tv_nsec == UTIME_NOW   -> that field = current time.
    # tv_nsec == UTIME_OMIT  -> that field unchanged.
    # AT_FDCWD / absolute resolve via resolve_path's cwd anchoring; a REAL
    # dirfd + relative path anchors at the dirfd's recorded open-path
    # (_u_at_resolve_dirfd), mirroring mkdirat — tar sets ./control's mtime
    # via utimensat against the extraction dirfd.
    upath: Array[256, uint8]
    if a1 == 0:
        # futimens(fd, times) == utimensat(fd, NULL, times, 0): operate on
        # the OPEN FILE referenced by `dirfd` itself (path is NULL). glibc's
        # futimens uses exactly this form, and GNU tar reaches for it to set
        # an extracted member's mtime via its open fd — previously the NULL
        # path was copied-in as a user pointer and EFAULTed ("Cannot utime:
        # Bad address"). Anchor at the fd's recorded open-path instead. A
        # real fd (not AT_FDCWD) is required for the NULL-path form.
        if _u_is_at_fdcwd(a0) != 0:
            return ELINUX_INVAL
        fdu_t: uint64 = a0 & 0xFFFFFFFF
        if fdu_t >= 64:
            return ELINUX_BADF
        fp: Ptr[uint8] = task_fd_opened_path_ptr(current_task(), fdu_t)
        if fp[0] == 0:
            return ELINUX_BADF
        k: uint64 = 0
        while k < 255 and fp[k] != 0:
            upath[k] = fp[k]
            k = k + 1
        upath[k] = 0
    else:
        is_abs: int32 = 0
        if _u_user_first_byte(a1) == 47:                # leading '/'
            is_abs = 1
        if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
            # Real dirfd + relative: build "<dirpath>/<name>" into upath,
            # then fall through to the normal resolve + set-mtime path.
            arc: int64 = _u_at_resolve_dirfd(a0, a1, &upath[0], 256)
            if arc != 0:
                return arc
        else:
            cpin: int64 = _u_copyin_path(a1, &upath[0])
            if cpin != 0:
                set_current_errstr("utimensat: bad path pointer")
                return cpin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&upath[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("utimensat: path too long")
        return cast[int64](rc)
    # Default (times == NULL): set mtime to the current wall-clock time.
    mtime_secs: uint64 = _u_now_epoch_secs()
    omit: int32 = 0
    if a2 != 0:
        # Read times[1] (the mtime entry) — struct timespec is two 8-byte
        # fields, so mtime lives at byte offset 16 (tv_sec) / 24 (tv_nsec).
        ts: Array[32, uint8]
        if copy_from_user(cast[uint64](&ts[0]), a2, 32) != 0:
            set_current_errstr("utimensat: bad times pointer")
            return ELINUX_EFAULT
        m_sec:  uint64 = cast[Ptr[uint64]](&ts[16])[0]
        m_nsec: uint64 = cast[Ptr[uint64]](&ts[24])[0]
        if cast[int64](m_nsec) == UTIME_OMIT:
            omit = 1
        elif cast[int64](m_nsec) == UTIME_NOW:
            mtime_secs = _u_now_epoch_secs()
        else:
            mtime_secs = m_sec
    return _u_set_times_for_path(cast[Ptr[char]](&abs_path[0]),
                                 cast[Ptr[char]](&upath[0]),
                                 mtime_secs, omit)


def _u_futimesat(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int futimesat(int dirfd, const char *path,
    #               const struct timeval times[2])
    # struct timeval is {tv_sec, tv_usec} — 16 bytes per entry; mtime is
    # times[1] at offset 16. NULL times -> set to now. AT_FDCWD / absolute.
    is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                    # leading '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        return ELINUX_NOSYS
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a1, &upath[0])
    if pin != 0:
        set_current_errstr("futimesat: bad path pointer")
        return pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&upath[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("futimesat: path too long")
        return cast[int64](rc)
    mtime_secs: uint64 = _u_now_epoch_secs()
    if a2 != 0:
        tv: Array[32, uint8]
        if copy_from_user(cast[uint64](&tv[0]), a2, 32) != 0:
            set_current_errstr("futimesat: bad times pointer")
            return ELINUX_EFAULT
        mtime_secs = cast[Ptr[uint64]](&tv[16])[0]   # times[1].tv_sec
    return _u_set_times_for_path(cast[Ptr[char]](&abs_path[0]),
                                 cast[Ptr[char]](&upath[0]),
                                 mtime_secs, 0)


def _u_utimes(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int utimes(const char *path, const struct timeval times[2])
    # Equivalent to futimesat(AT_FDCWD, path, times).
    return _u_futimesat(AT_FDCWD_U64, a0, a1, 0, 0, 0)


def _u_utime(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int utime(const char *path, const struct utimbuf *times)
    # struct utimbuf { time_t actime; time_t modtime; } — two 8-byte
    # fields; modtime is at offset 8. NULL times -> set to now.
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a0, &upath[0])
    if pin != 0:
        set_current_errstr("utime: bad path pointer")
        return pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&upath[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("utime: path too long")
        return cast[int64](rc)
    mtime_secs: uint64 = _u_now_epoch_secs()
    if a1 != 0:
        ub: Array[16, uint8]
        if copy_from_user(cast[uint64](&ub[0]), a1, 16) != 0:
            set_current_errstr("utime: bad times pointer")
            return ELINUX_EFAULT
        mtime_secs = cast[Ptr[uint64]](&ub[8])[0]    # modtime
    return _u_set_times_for_path(cast[Ptr[char]](&abs_path[0]),
                                 cast[Ptr[char]](&upath[0]),
                                 mtime_secs, 0)


# --- #165: chmod / fchmod / fchmodat ------------------------------
#
# Hamnix's native side is effectively single-user/root and has no
# writable inode-mode store (ext4_path_mode is read-only; tmpfs/cpio
# carry no mode bits). A chmod from root therefore always SUCCEEDS — we
# validate the target resolves (so a chmod on a missing path still
# returns -ENOENT, the bit `install`/`tar -p` checks) and otherwise
# return 0. This is the standard answer for a single-user system and
# unblocks tar/cpio extraction, `install -m`, and ./configure scripts
# that chmod their generated helpers, none of which inspect the bits
# back afterwards on our paths.

def _u_chmod(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int chmod(const char *path, mode_t mode)
    if a0 == 0:
        return ELINUX_INVAL
    # #163: copy the user path into a kernel scratch before resolve_path.
    ch_path: Array[256, uint8]
    ch_pin: int64 = _u_copyin_path(a0, &ch_path[0])
    if ch_pin != 0:
        return ch_pin
    # F10-1 double-resolution fix: probe with the RAW path (vfs_open
    # resolves the namespace once internally; a pre-resolve doubled a
    # `/`-rebound root prefix).
    fd: int32 = vfs_open(cast[Ptr[char]](&ch_path[0]))
    if fd < 0:
        return ELINUX_NOENT
    vfs_close(fd)
    return 0


def _u_fchmod(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fchmod(int fd, mode_t mode)
    if vfs_fd_is_open(cast[int32](a0)) == 0:
        return ELINUX_BADF
    return 0


def _u_fchmodat(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fchmodat(int dirfd, const char *path, mode_t mode, int flags)
    is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                    # leading '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        # Real dirfd + relative: anchor at the dirfd's open-path, then
        # probe existence (chmod is a no-op-success on resolve here) —
        # tar -p sets each extracted member's mode via the dir fd.
        at_abs: Array[384, uint8]
        arc: int64 = _u_at_resolve_dirfd(a0, a1, &at_abs[0], 384)
        if arc != 0:
            return arc
        pfd: int32 = vfs_open(cast[Ptr[char]](&at_abs[0]))
        if pfd < 0:
            return ELINUX_NOENT
        vfs_close(pfd)
        return 0
    return _u_chmod(a1, a2, 0, 0, 0, 0)


# --- #165: chown / fchown / lchown / fchownat ---------------------
#
# Single-user/root: every file is owned by root, and there are no other
# uids/gids to assign. A chown from root is therefore a successful
# no-op once the target resolves. This unblocks `tar -p` / `cp -a` /
# `install -o root` ownership-preservation passes, which would otherwise
# abort the whole extraction on the first -ENOSYS.

def _u_chown(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int chown(const char *path, uid_t owner, gid_t group)
    # int lchown(const char *path, uid_t owner, gid_t group) (same body —
    # we have no symlinks to differentiate the no-follow variant).
    if a0 == 0:
        return ELINUX_INVAL
    # #163: copy the user path into a kernel scratch before resolve_path.
    co_path: Array[256, uint8]
    co_pin: int64 = _u_copyin_path(a0, &co_path[0])
    if co_pin != 0:
        return co_pin
    # F10-1 double-resolution fix: probe with the RAW path (vfs_open
    # resolves the namespace once internally; a pre-resolve doubled a
    # `/`-rebound root prefix).
    fd: int32 = vfs_open(cast[Ptr[char]](&co_path[0]))
    if fd < 0:
        return ELINUX_NOENT
    vfs_close(fd)
    return 0


def _u_fchown(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fchown(int fd, uid_t owner, gid_t group)
    if vfs_fd_is_open(cast[int32](a0)) == 0:
        return ELINUX_BADF
    return 0


def _u_fchownat(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fchownat(int dirfd, const char *path, uid_t, gid_t, int flags)
    # AT_EMPTY_PATH (0x1000) with an empty path means "operate on dirfd
    # itself" — treat it as fchown(dirfd).
    if (a4 & 0x1000) != 0 and (a1 == 0 or _u_user_first_byte(a1) <= 0):
        return _u_fchown(a0, a2, a3, 0, 0, 0)
    is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                    # leading '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        # Real dirfd + relative: anchor at the dirfd's open-path, then
        # probe existence (chown is no-op-success for root here) — tar -p
        # / dpkg set each extracted member's owner via the dir fd.
        at_abs: Array[384, uint8]
        arc: int64 = _u_at_resolve_dirfd(a0, a1, &at_abs[0], 384)
        if arc != 0:
            return arc
        pfd: int32 = vfs_open(cast[Ptr[char]](&at_abs[0]))
        if pfd < 0:
            return ELINUX_NOENT
        vfs_close(pfd)
        return 0
    return _u_chown(a1, a2, a3, 0, 0, 0)


# --- #165: umask --------------------------------------------------
#
# Process-wide file-mode creation mask. We have no per-task slot for it
# (TaskStruct doesn't carry one), and creat/mkdir at this milestone
# ignore mode bits anyway, so a single global is a faithful-enough
# model: umask(2) is required to RETURN THE PREVIOUS mask, and shells /
# build scripts that do `old = umask(0); ...; umask(old)` only depend on
# that round-trip, which the global delivers. Default 022 like Linux.
LINUX_UMASK_GLOBAL: uint64 = 0x12              # 022 octal

def _u_umask(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # mode_t umask(mode_t mask) — set new mask, return the old one.
    old: uint64 = LINUX_UMASK_GLOBAL
    LINUX_UMASK_GLOBAL = a0 & 0x1FF            # keep the 9 perm bits
    return cast[int64](old)


def nr_is_renameat2_flagged(flags: uint64) -> int32:
    # renameat (264) passes 4 args, renameat2 (316) passes a 5th
    # `flags`. Plain renameat leaves a4 == 0 (the dispatch zero-fills
    # unused args), so a non-zero flags word can only come from
    # renameat2 — and we don't implement any of its flags.
    if flags != 0:
        return 1
    return 0


def _u_fsync(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fsync(int fd)  /  int fdatasync(int fd)
    # Flush the file's data + metadata to durable storage. For ext4
    # this issues the block-device cache barrier; for RAM-backed fds
    # it is a successful no-op. apt/dpkg call fsync after writing a
    # package file before rename-into-place — returning 0 (instead of
    # -ENOSYS) lets that sequence complete.
    rc: int32 = vfs_fsync(cast[int32](a0))
    if rc < 0:
        set_current_errstr("fsync: failed")
    return cast[int64](rc)


def _u_sync(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void sync(void) — flush every mounted filesystem. We only have
    # the one writable ext4 mount; flush it and return 0. sync(2) has
    # no failure return in Linux, so we always report success.
    vfs_fsync_all()
    return 0


def _u_reboot(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int reboot(int magic, int magic2, int cmd, void *arg)
    # a0=magic1, a1=magic2, a2=cmd, a3=arg. Validate the magics, gate
    # on hostowner (uid 1), decode cmd to a POWER_* action, then funnel
    # into the shared power_action core (which flushes filesystems and
    # never returns on a power-taking command). Same core the native
    # /dev/reboot cdev and the native do_syscall(SYS_REBOOT) arm use.
    if a0 != LINUX_REBOOT_MAGIC1 or a1 != LINUX_REBOOT_MAGIC2:
        set_current_errstr("reboot: bad magic")
        return ELINUX_INVAL
    if current_task_is_hostowner() == 0:
        set_current_errstr("reboot: permission denied (not hostowner)")
        return cast[int64](-1)
    if a2 == LINUX_REBOOT_CMD_POWER_OFF:
        power_action(POWER_POWEROFF)                         # never returns
        return 0
    if a2 == LINUX_REBOOT_CMD_RESTART:
        power_action(POWER_REBOOT)                           # never returns
        return 0
    if a2 == LINUX_REBOOT_CMD_HALT:
        power_action(POWER_HALT)                             # never returns
        return 0
    # Unmodelled cmd (CAD_ON/OFF, SW_SUSPEND, RESTART2, KEXEC) — accept
    # the magics but no-op so a guest's startup reboot(CAD_OFF) succeeds.
    return 0


def _u_truncate(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int truncate(const char *path, off_t length)
    # #163: copy-in the user path so a bad pointer is -EFAULT, not a #PF.
    trunc_path: Array[256, uint8]
    trunc_pin: int64 = _u_copyin_path(a0, &trunc_path[0])
    if trunc_pin != 0:
        return trunc_pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&trunc_path[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("truncate: path too long")
        return cast[int64](rc)
    rc = vfs_truncate(cast[Ptr[char]](&abs_path[0]), a1)
    if rc < 0:
        set_current_errstr("truncate: failed")
    return cast[int64](rc)


def _u_ftruncate(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int ftruncate(int fd, off_t length)
    rc: int32 = vfs_ftruncate(cast[int32](a0), a1)
    if rc < 0:
        set_current_errstr("ftruncate: failed")
    return cast[int64](rc)


def _u_fallocate(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fallocate(int fd, int mode, off_t offset, off_t len)
    #
    # Only the DEFAULT allocation mode (mode 0: reserve blocks + extend
    # the file to offset+len if that grows it) is modelled — that is what
    # glibc's posix_fallocate(3) issues, which real Wayland clients
    # (weston-simple-shm's os_create_anonymous_file) use to size their
    # wl_shm memfd pool. Without this the syscall fell through to -ENOSYS
    # and the client aborted with "creating a buffer file failed:
    # Function not implemented" right before its first commit.
    #
    # fallocate MUST NOT shrink: query the current size via SEEK_END and
    # only grow. A memfd sealed F_SEAL_SHRINK still permits growth, so
    # weston's freshly-created size-0 pool truncates up cleanly.
    fd: int32 = cast[int32](a0)
    offset: uint64 = a2
    length: uint64 = a3
    if length == 0:
        return 0
    newsize: uint64 = offset + length
    cur: int64 = vfs_lseek(fd, 0, 2)          # SEEK_END
    if cur >= 0 and cast[uint64](cur) >= newsize:
        return 0                              # already big enough
    rc: int32 = vfs_ftruncate(fd, newsize)
    if rc < 0:
        return cast[int64](rc)
    return 0


# --- extended attributes (xattr) ----------------------------------
#
# Linux's {l,f}{set,get,list,remove}xattr family routed to the ext4
# xattr engine. Only ext4-backed paths are supported (other backends
# return -EOPNOTSUPP). User pointers (path, name, value) are brought in
# through the translated uaccess layer so a bad pointer is -EFAULT.
#
# The Linux value cap for an xattr is 64 KiB; ext4's per-attr value is
# bounded by a single fs block, so a 4 KiB kernel bounce is generous.
XATTR_NAME_MAX:  uint64 = 256
XATTR_VALUE_CAP: uint64 = 4096
u_xattr_name_buf:  Array[256, uint8]
u_xattr_value_buf: Array[4096, uint8]
u_xattr_list_buf:  Array[4096, uint8]


def _u_xattr_ext_tail(abs_path: Ptr[uint8]) -> Ptr[char]:
    # Return the /ext/-stripped tail of an absolute path if it is an
    # ext4 path, else a null pointer (caller -> -EOPNOTSUPP).
    # F10-9: backend classification through the VFS mount table, not the
    # retired is_ext_path strcmp ladder.
    if vfs_fs_kind(cast[Ptr[char]](abs_path)) != FS_KIND_EXT4:
        return cast[Ptr[char]](0)
    return strip_ext_prefix(cast[Ptr[char]](abs_path))


def _u_copyin_name(uptr: uint64, kdst: Ptr[uint8]) -> int64:
    # Copy a NUL-terminated xattr name (<= XATTR_NAME_MAX) from user
    # space. Mirrors _u_copyin_path but with the xattr name cap.
    if uptr == 0:
        return ELINUX_EFAULT
    r: int64 = strncpy_from_user(cast[uint64](kdst), uptr, XATTR_NAME_MAX)
    if r < 0:
        return ELINUX_EFAULT
    if cast[uint64](r) >= XATTR_NAME_MAX - 1:
        return ELINUX_NAMETOOLONG
    return 0


def _u_setxattr(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setxattr(path, name, value, size, flags)
    return _u_setxattr_path_flags(a0, a1, a2, a3, a4)


def _u_lsetxattr(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    return _u_setxattr_path_flags(a0, a1, a2, a3, a4)


def _u_setxattr_path_flags(a0: uint64, a1: uint64, a2: uint64,
                           a3: uint64, a4: uint64) -> int64:
    # path/name/value/size/flags -> ext4_setxattr_path. (Split out so the
    # 5th arg `flags` is threaded through instead of the a4_dummy stub.)
    xpath: Array[256, uint8]
    ppin: int64 = _u_copyin_path(a0, &xpath[0])
    if ppin != 0:
        return ppin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&xpath[0]), &abs_path[0], 256)
    if rc != 0:
        return cast[int64](rc)
    tail: Ptr[char] = _u_xattr_ext_tail(&abs_path[0])
    if tail == cast[Ptr[char]](0):
        return -95
    npin: int64 = _u_copyin_name(a1, &u_xattr_name_buf[0])
    if npin != 0:
        return npin
    if a3 > XATTR_VALUE_CAP:
        return -7
    if a2 != 0 and a3 > 0:
        if copy_from_user(cast[uint64](&u_xattr_value_buf[0]), a2, a3) != 0:
            return ELINUX_EFAULT
    r: int32 = ext4_setxattr_path(tail,
                                  cast[Ptr[char]](&u_xattr_name_buf[0]),
                                  &u_xattr_value_buf[0], a3,
                                  cast[int32](a4))
    return cast[int64](r)


def _u_fsetxattr(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fsetxattr(fd, name, value, size, flags)
    inum: int64 = _u_fd_ext4_inum(cast[int32](a0))
    if inum < 0:
        return inum
    npin: int64 = _u_copyin_name(a1, &u_xattr_name_buf[0])
    if npin != 0:
        return npin
    if a3 > XATTR_VALUE_CAP:
        return -7
    if a2 != 0 and a3 > 0:
        if copy_from_user(cast[uint64](&u_xattr_value_buf[0]), a2, a3) != 0:
            return ELINUX_EFAULT
    r: int32 = ext4_setxattr(cast[uint32](inum),
                             cast[Ptr[char]](&u_xattr_name_buf[0]),
                             &u_xattr_value_buf[0], a3, cast[int32](a4))
    return cast[int64](r)


def _u_getxattr(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t getxattr(path, name, value, size)
    return _u_getxattr_path(a0, a1, a2, a3)


def _u_lgetxattr(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    return _u_getxattr_path(a0, a1, a2, a3)


def _u_getxattr_path(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64) -> int64:
    xpath: Array[256, uint8]
    ppin: int64 = _u_copyin_path(a0, &xpath[0])
    if ppin != 0:
        return ppin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&xpath[0]), &abs_path[0], 256)
    if rc != 0:
        return cast[int64](rc)
    tail: Ptr[char] = _u_xattr_ext_tail(&abs_path[0])
    if tail == cast[Ptr[char]](0):
        return -95
    npin: int64 = _u_copyin_name(a1, &u_xattr_name_buf[0])
    if npin != 0:
        return npin
    cap: uint64 = a3
    if cap > XATTR_VALUE_CAP:
        cap = XATTR_VALUE_CAP
    r: int32 = ext4_getxattr_path(tail,
                                  cast[Ptr[char]](&u_xattr_name_buf[0]),
                                  &u_xattr_value_buf[0], cap)
    return _u_xattr_copyout_value(r, a2, a3)


def _u_fgetxattr(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t fgetxattr(fd, name, value, size)
    inum: int64 = _u_fd_ext4_inum(cast[int32](a0))
    if inum < 0:
        return inum
    npin: int64 = _u_copyin_name(a1, &u_xattr_name_buf[0])
    if npin != 0:
        return npin
    cap: uint64 = a3
    if cap > XATTR_VALUE_CAP:
        cap = XATTR_VALUE_CAP
    r: int32 = ext4_getxattr_inum(cast[uint32](inum),
                                  cast[Ptr[char]](&u_xattr_name_buf[0]),
                                  &u_xattr_value_buf[0], cap)
    return _u_xattr_copyout_value(r, a2, a3)


def _u_xattr_copyout_value(r: int32, uval: uint64, usize: uint64) -> int64:
    # Common get tail: r<0 -> errno; size==0 -> just report length;
    # else copy_to_user the value bytes.
    if r < 0:
        return cast[int64](r)
    if usize == 0:
        return cast[int64](r)                   # size-probe: return length
    if cast[uint64](r) > usize:
        return ELINUX_RANGE                     # -ERANGE
    if uval != 0 and r > 0:
        if copy_to_user(uval, cast[uint64](&u_xattr_value_buf[0]),
                        cast[uint64](r)) != 0:
            return ELINUX_EFAULT
    return cast[int64](r)


def _u_listxattr(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t listxattr(path, list, size)
    return _u_listxattr_path(a0, a1, a2)


def _u_llistxattr(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    return _u_listxattr_path(a0, a1, a2)


def _u_listxattr_path(a0: uint64, a1: uint64, a2: uint64) -> int64:
    xpath: Array[256, uint8]
    ppin: int64 = _u_copyin_path(a0, &xpath[0])
    if ppin != 0:
        return ppin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&xpath[0]), &abs_path[0], 256)
    if rc != 0:
        return cast[int64](rc)
    tail: Ptr[char] = _u_xattr_ext_tail(&abs_path[0])
    if tail == cast[Ptr[char]](0):
        return -95
    r: int32 = ext4_listxattr_path(tail, &u_xattr_list_buf[0],
                                   XATTR_VALUE_CAP)
    return _u_xattr_copyout_list(r, a1, a2)


def _u_flistxattr(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t flistxattr(fd, list, size)
    inum: int64 = _u_fd_ext4_inum(cast[int32](a0))
    if inum < 0:
        return inum
    r: int32 = ext4_listxattr_inum(cast[uint32](inum),
                                   &u_xattr_list_buf[0], XATTR_VALUE_CAP)
    return _u_xattr_copyout_list(r, a1, a2)


def _u_xattr_copyout_list(r: int32, ulist: uint64, usize: uint64) -> int64:
    if r < 0:
        return cast[int64](r)
    if usize == 0:
        return cast[int64](r)
    if cast[uint64](r) > usize:
        return ELINUX_RANGE
    if ulist != 0 and r > 0:
        if copy_to_user(ulist, cast[uint64](&u_xattr_list_buf[0]),
                        cast[uint64](r)) != 0:
            return ELINUX_EFAULT
    return cast[int64](r)


def _u_removexattr(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int removexattr(path, name)
    return _u_removexattr_path(a0, a1)


def _u_lremovexattr(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return _u_removexattr_path(a0, a1)


def _u_removexattr_path(a0: uint64, a1: uint64) -> int64:
    xpath: Array[256, uint8]
    ppin: int64 = _u_copyin_path(a0, &xpath[0])
    if ppin != 0:
        return ppin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&xpath[0]), &abs_path[0], 256)
    if rc != 0:
        return cast[int64](rc)
    tail: Ptr[char] = _u_xattr_ext_tail(&abs_path[0])
    if tail == cast[Ptr[char]](0):
        return -95
    npin: int64 = _u_copyin_name(a1, &u_xattr_name_buf[0])
    if npin != 0:
        return npin
    r: int32 = ext4_removexattr_path(tail,
                                     cast[Ptr[char]](&u_xattr_name_buf[0]))
    return cast[int64](r)


def _u_fremovexattr(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fremovexattr(fd, name)
    inum: int64 = _u_fd_ext4_inum(cast[int32](a0))
    if inum < 0:
        return inum
    npin: int64 = _u_copyin_name(a1, &u_xattr_name_buf[0])
    if npin != 0:
        return npin
    r: int32 = ext4_removexattr(cast[uint32](inum),
                                cast[Ptr[char]](&u_xattr_name_buf[0]))
    return cast[int64](r)


def _u_fd_ext4_inum(fd: int32) -> int64:
    # Resolve an open fd to its ext4 inode number, or a negative errno.
    # Non-ext4 fds get -EOPNOTSUPP.
    marker: uint32 = 0
    backing: uint64 = 0
    fsize: uint64 = 0
    rc: int32 = vfs_fd_backing_info(fd, &marker, &backing, &fsize)
    if rc != 0:
        return -9                               # -EBADF
    if marker != FD_EXT4_MARK:
        return -95                              # -EOPNOTSUPP
    return cast[int64](backing)


# clockid_t values (Linux <bits/time.h>). The handler below serves
# the monotonic family from the TSC high-resolution clock and the
# realtime family from the RTC boot epoch + the monotonic delta.
CLOCKID_REALTIME:         uint64 = 0
CLOCKID_MONOTONIC:        uint64 = 1
CLOCKID_PROCESS_CPUTIME:  uint64 = 2
CLOCKID_THREAD_CPUTIME:   uint64 = 3
CLOCKID_MONOTONIC_RAW:    uint64 = 4
CLOCKID_REALTIME_COARSE:  uint64 = 5
CLOCKID_MONOTONIC_COARSE: uint64 = 6
CLOCKID_BOOTTIME:         uint64 = 7


# #169 vDSO: count every clock_gettime that actually TRAPPED into the
# kernel via the syscall path. A working vDSO resolves
# __vdso_clock_gettime out of AT_SYSINFO_EHDR and reads the shared time
# page in userspace, so a vDSO-using program makes N library calls but
# this counter stays at (or near) 0. The test (scripts/test_vdso.sh)
# asserts the syscall count is far below the number of clock_gettime
# library calls the guest made — direct, unforgeable proof the vDSO
# fast path bypassed the trap.
vdso_clock_gettime_syscalls: uint64 = 0
# Emit the [vdso-audit] serial marker only for the first N trapped calls, so
# test_vdso.sh still observes the low-index trap markers it asserts on while a
# clock_gettime-heavy Linux workload (Firefox) can't flood the UART. The
# counter itself stays unbounded.
VDSO_AUDIT_PRINT_CAP: uint64 = 32


def vdso_clock_gettime_syscall_count() -> uint64:
    return vdso_clock_gettime_syscalls


def _u_clock_gettime(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int clock_gettime(clockid_t clk, struct timespec *tp)
    #
    # #169: a clock_gettime reaching THIS handler took the syscall trap,
    # NOT the vDSO fast path. Bump the audit counter + emit a marker so
    # the test can see how many traps happened relative to the guest's
    # library-call count.
    vdso_clock_gettime_syscalls = vdso_clock_gettime_syscalls + 1
    # EMERG-level so this audit marker survives the console loglevel
    # gate during the boot/user phase (normal INFO printk is filtered).
    # The latch is one-shot: it only stamps the very next printk call.
    #
    # CAP THE SERIAL SPAM. This marker is a #169 vDSO-bypass audit that
    # test_vdso.sh checks by grepping for the FIRST few trap markers (its
    # probe makes ~1 deliberate syscall -> trap #1; it FAILs only if the
    # trap INDEX climbs too high). But a real Linux workload that legitimately
    # issues clock_gettime via the raw syscall — e.g. Firefox querying
    # CLOCK_THREAD_CPUTIME_ID (a clock the vDSO punts to the kernel) from a
    # hot profiler/timer loop — hits THIS path thousands of times, and an
    # unconditional EMERG printk PER CALL floods the slow 8250 serial UART.
    # Each printk blocks the CPU on the UART, so the guest clock is starved
    # and every wall-clock consumer (and our own MOZ_LOG-capture settle) is
    # wedged behind serial I/O. Keep the COUNTER unbounded (unforgeable proof
    # for the vDSO test) but stop EMITTING the line after the first
    # VDSO_AUDIT_PRINT_CAP traps — test_vdso still sees trap #1..N, and a
    # clock-heavy guest no longer drowns the console. General fix: benefits
    # every Linux-ABI program that traps clock_gettime, not just Firefox.
    if vdso_clock_gettime_syscalls <= VDSO_AUDIT_PRINT_CAP:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[vdso-audit] clock_gettime SYSCALL trap #%d\n",
                vdso_clock_gettime_syscalls)
    #
    # Linux's struct timespec is { long tv_sec; long tv_nsec; }.
    #
    # Time source: arch/x86/kernel/time.ad's TSC monotonic clock —
    # an RDTSC-derived nanosecond counter calibrated against the PIT
    # at boot. tsc_monotonic_ns() gives nanosecond resolution and
    # advances even with CPU interrupts masked (unlike `jiffies`).
    #
    #   CLOCK_MONOTONIC / _RAW / _COARSE / BOOTTIME
    #         -> nanoseconds since boot (the raw monotonic clock).
    #   CLOCK_REALTIME / _COARSE
    #         -> wall-clock: RTC boot epoch (seconds) + monotonic delta.
    #   CPUTIME clocks -> approximated by the monotonic clock (we have
    #         no per-process CPU accounting yet).
    #
    # Before the TSC is calibrated tsc_monotonic_ns() transparently
    # falls back to the 10 ms jiffies clock, so this handler is always
    # safe to call. -EINVAL if tp is NULL or the clockid is unknown.
    if a1 == 0:
        set_current_errstr("clock_gettime: null timespec")
        return ELINUX_INVAL

    clk: uint64 = a0
    if clk > CLOCKID_BOOTTIME:
        set_current_errstr("clock_gettime: unknown clockid")
        return ELINUX_INVAL

    mono_ns: uint64 = tsc_monotonic_ns()
    sec:  uint64 = 0
    nsec: uint64 = 0
    if clk == CLOCKID_REALTIME or clk == CLOCKID_REALTIME_COARSE:
        # Wall clock = RTC epoch captured at boot + DISCIPLINED monotonic delta.
        # adjtimex(2)/clock_adjtime(2) steer CLOCK_REALTIME by routing the raw
        # monotonic-ns through uadj_apply_discipline (linux_abi/u_adjtimex.ad):
        # an active frequency skew makes realtime advance faster/slower per unit
        # of raw monotonic time, and a MOD_OFFSET single-shot slews it. A cheap
        # pass-through when no adjustment is active. CLOCK_MONOTONIC (the else
        # branch below) stays RAW/undisciplined, matching Linux.
        disc_ns: uint64 = uadj_apply_discipline(mono_ns)
        base: uint64 = rtc_boot_epoch_get()
        sec  = base + (disc_ns / 1000000000)
        nsec = disc_ns % 1000000000
    else:
        # Monotonic family (and CPUTIME, approximated): seconds +
        # nanoseconds since boot.
        sec  = mono_ns / 1000000000
        nsec = mono_ns % 1000000000

    # #163: write the timespec back through the translated uaccess path
    # rather than a raw deref. put_user_64 walks the current task's page
    # tables; under today's identity map this is the same physical write,
    # but it stays correct once the user stack / mmap sits at vaddr != phys.
    if put_user_64(sec, a1) != 0 or put_user_64(nsec, a1 + 8) != 0:
        set_current_errstr("clock_gettime: bad timespec pointer")
        return ELINUX_EFAULT
    return 0


def _u_clock_getres(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int clock_getres(clockid_t clk, struct timespec *res)
    #
    # Firefox/mozglue (TimeStamp_posix.cpp ClockResolutionNs) probes the
    # monotonic clock resolution at XPCOMGlueLoad startup; glibc's pthread
    # / condvar timeouts also query it. Previously nr=229 fell through to
    # the -ENOSYS "unknown syscall" path, and mozglue treated the failure
    # as a fatal clock error before libxul even loaded ("Couldn't load
    # XPCOM.").
    #
    # Report the resolution of our TSC-derived monotonic clock
    # (arch/x86/kernel/time.ad): the fine clocks (REALTIME/MONOTONIC/
    # _RAW/BOOTTIME + the CPUTIME approximations) resolve to 1 ns; the
    # _COARSE clocks resolve to the 10 ms jiffy tick, matching Linux's
    # CLOCK_*_COARSE semantics. A NULL res pointer is legal (POSIX: query
    # clock validity only) and returns 0 without a write.
    clk: uint64 = a0
    if clk > CLOCKID_BOOTTIME:
        set_current_errstr("clock_getres: unknown clockid")
        return ELINUX_INVAL
    res_sec:  uint64 = 0
    res_nsec: uint64 = 1
    if clk == CLOCKID_REALTIME_COARSE or clk == CLOCKID_MONOTONIC_COARSE:
        res_nsec = 10000000        # 10 ms jiffy tick
    if a1 == 0:
        # POSIX allows a NULL res: the call only validates the clockid.
        return 0
    if put_user_64(res_sec, a1) != 0 or put_user_64(res_nsec, a1 + 8) != 0:
        set_current_errstr("clock_getres: bad timespec pointer")
        return ELINUX_EFAULT
    return 0


# =====================================================================
# U35: socket(2) family + poll(2)
# =====================================================================
#
# Hamnix has no real network stack. The handlers below are stub-but-
# -functional: socket(2) returns a real fd (marked FD_SOCKET_MARK in
# the per-task fd table); bind / listen / setsockopt / getsockopt /
# getsockname / getpeername succeed silently; connect returns
# -ECONNREFUSED and accept returns -EAGAIN so failing networked paths
# surface promptly instead of hanging. socketpair(2) forwards to
# vfs_pipe — a bidirectional pipe pair is observationally indistinct
# from AF_UNIX SOCK_STREAM at this scope.
#
# poll(2) walks the user pollfd array. Each entry's revents is set to
# POLLIN when POLLIN was requested on an open fd, or POLLNVAL when the
# fd is closed / out of range. There's no readiness state to consult
# yet — single-task busybox pipelines treat poll() as "ready now" for
# any open fd, which matches Linux's behaviour for blocking fds
# during a non-zero timeout poll on a single-CPU box.


# pollfd layout (Linux <poll.h>):
#   struct pollfd {
#       int   fd;       // 4 bytes  offset 0
#       short events;   // 2 bytes  offset 4
#       short revents;  // 2 bytes  offset 6
#   };  // total 8 bytes
POLLFD_SIZE: uint64 = 8
POLLIN_BIT:   uint32 = 0x0001
POLLPRI_BIT:  uint32 = 0x0002
POLLOUT_BIT:  uint32 = 0x0004
POLLERR_BIT:  uint32 = 0x0008
POLLHUP_BIT:  uint32 = 0x0010
POLLNVAL_BIT: uint32 = 0x0020


# ARCH §10: kernel-BSS scratch for the /net ctl command strings the
# socket() shim writes. A `connect <a.b.c.d>!<port>` line is well
# under 32 bytes; 48 is comfortable. Top-level per the Adder
# nested-frame-Array quirk.
u_net_ctl_buf: Array[48, uint8]


def _u_net_put_dec(buf: Ptr[uint8], pos: uint64, v: uint64) -> uint64:
    # Append `v` as ASCII decimal at buf[pos]. Returns the new pos.
    if v == 0:
        buf[pos] = 48
        return pos + 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    p: uint64 = pos
    while n > 0:
        n = n - 1
        buf[p] = digits[n]
        p = p + 1
    return p


def _u_net_build_connect(ip_b0: uint8, ip_b1: uint8, ip_b2: uint8,
                         ip_b3: uint8, port: uint16) -> uint64:
    # Build "connect <a.b.c.d>!<port>" into u_net_ctl_buf. Returns the
    # command length. The Plan 9 host!service separator is '!'.
    pfx: Ptr[uint8] = "connect "
    p: uint64 = 0
    while pfx[p] != 0:
        u_net_ctl_buf[p] = pfx[p]
        p = p + 1
    p = _u_net_put_dec(&u_net_ctl_buf[0], p, cast[uint64](ip_b0))
    u_net_ctl_buf[p] = 46                              # '.'
    p = p + 1
    p = _u_net_put_dec(&u_net_ctl_buf[0], p, cast[uint64](ip_b1))
    u_net_ctl_buf[p] = 46
    p = p + 1
    p = _u_net_put_dec(&u_net_ctl_buf[0], p, cast[uint64](ip_b2))
    u_net_ctl_buf[p] = 46
    p = p + 1
    p = _u_net_put_dec(&u_net_ctl_buf[0], p, cast[uint64](ip_b3))
    u_net_ctl_buf[p] = 33                              # '!'
    p = p + 1
    p = _u_net_put_dec(&u_net_ctl_buf[0], p, cast[uint64](port))
    return p


def _u_net_build_announce(port: uint16) -> uint64:
    # Build "announce <port>" into u_net_ctl_buf. Returns the length.
    pfx: Ptr[uint8] = "announce "
    p: uint64 = 0
    while pfx[p] != 0:
        u_net_ctl_buf[p] = pfx[p]
        p = p + 1
    p = _u_net_put_dec(&u_net_ctl_buf[0], p, cast[uint64](port))
    return p


def _u_net_ctl_errno(rc: int32) -> int64:
    # Map a devnet_ctl return code to a faithful Linux errno for the
    # connect(2)/bind(2)/listen(2) bridge.
    if rc == NET_CTL_EARP:
        return ELINUX_NETUNREACH
    if rc == NET_CTL_ETIMEOUT:
        return ELINUX_TIMEDOUT
    if rc == NET_CTL_EREFUSED:
        return ELINUX_CONNREFUSED
    if rc == NET_CTL_ENOSLOT:
        return ELINUX_NETUNREACH
    if rc == NET_CTL_EADDRINUSE:
        return ELINUX_ADDRINUSE
    return ELINUX_CONNREFUSED


# AF_UNIX fd recogniser: returns the AF_UNIX endpoint slot backing a
# socket fd, or -1 if the fd is not an AF_UNIX socket. An AF_UNIX fd is a
# FD_SOCKET_MARK fd whose fd_buf carries the AFU_FDBUF_TAG; afunix_ep_for_
# fdbuf decodes + validates it.
def _u_afunix_ep(fd: int32) -> int32:
    if vfs_fd_is_socket(fd) == 0:
        return -1
    return afunix_ep_for_fdbuf(vfs_socket_fd_get_record(fd))


# AF_NETLINK fd recogniser: returns the netlink endpoint slot backing a
# socket fd, or -1 if the fd is not a netlink socket. A netlink fd is a
# FD_SOCKET_MARK fd whose fd_buf carries the NL_FDBUF_TAG;
# nl_ep_for_fdbuf decodes + validates it (and rejects the AF_UNIX tag).
def _u_netlink_ep(fd: int32) -> int32:
    if vfs_fd_is_socket(fd) == 0:
        return -1
    return nl_ep_for_fdbuf(vfs_socket_fd_get_record(fd))


def _u_socket(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int socket(int domain, int type, int protocol)
    #
    # Allocate a socket fd PLUS a per-socket-fd backing record
    # (fs/socket_state.ad) that connect(2) / read / write /
    # close / sendto / recvfrom use to reach the in-kernel stack.
    # Supported combinations are AF_INET + SOCK_STREAM (TCP) and, as of
    # §10, AF_INET + SOCK_DGRAM (UDP). Everything else is rejected with
    # a faithful errno. `protocol` is ignored (0 == "default for this
    # type": TCP for STREAM, UDP for DGRAM).
    domain:    uint32 = cast[uint32](a0)
    sock_type: uint32 = cast[uint32](a1)
    # SOCK_CLOEXEC (0x80000) / SOCK_NONBLOCK (0x800) ride in the high
    # bits of `type` on Linux. Hamnix has no CLOEXEC table, so that bit
    # is masked off; §5 honours SOCK_NONBLOCK end-to-end — the flag is
    # captured here and applied to the fd after it is allocated.
    sock_nonblock: int32 = 0
    if (cast[uint64](sock_type) & O_NONBLOCK_BIT) != 0:
        sock_nonblock = 1
    # SOCK_CLOEXEC (0x80000): now honored end-to-end via the fd-table
    # close-on-exec flag. Captured before the type is masked to its base.
    sock_cloexec: int32 = 0
    if (cast[uint64](sock_type) & O_CLOEXEC_BIT) != 0:
        sock_cloexec = 1
    sock_type = sock_type & 0xFF
    if domain == NL_AF_NETLINK:
        # AF_NETLINK socket. `protocol` selects the netlink family
        # (NETLINK_ROUTE == 0 is the one `ip` / systemd use). Allocate an
        # in-kernel endpoint in linux_abi/u_netlink.ad, then a real
        # FD_SOCKET_MARK fd whose fd_buf carries the NETLINK tag so
        # read/write/close intercept it here and the fs/vfs.ad arms (and
        # the AF_UNIX arms) ignore it.
        nlep: int32 = nl_socket(sock_type, cast[uint32](a2))
        if nlep < 0:
            set_current_errstr("socket: AF_NETLINK endpoint pool exhausted")
            return cast[int64](nlep)
        nlfd: int32 = vfs_alloc_socket_fd()
        if nlfd < 0:
            nl_close(nlep)
            set_current_errstr("socket: out of fd slots")
            return cast[int64](nlfd)
        if vfs_socket_fd_set_record(nlfd, nl_fdbuf_for_ep(nlep)) != 0:
            nl_close(nlep)
            vfs_close(nlfd)
            set_current_errstr("socket: AF_NETLINK fd record bind failed")
            return ELINUX_BADF
        if sock_nonblock != 0:
            _u_set_fd_nonblock(nlfd, 1)
        if sock_cloexec != 0:
            _u_set_fd_cloexec(nlfd, 1)
        return cast[int64](nlfd)
    if domain == AFU_AF_UNIX:
        # AF_UNIX (local) domain socket. Allocate an in-kernel endpoint
        # in linux_abi/u_unixsock.ad, then a real FD_SOCKET_MARK fd whose
        # fd_buf carries the AF_UNIX tag (so read/write/close intercept
        # it here and the fs/vfs.ad arms ignore it). SOCK_STREAM and
        # SOCK_DGRAM are both supported.
        uep: int32 = afunix_socket(sock_type)
        if uep < 0:
            set_current_errstr("socket: AF_UNIX endpoint pool exhausted")
            return cast[int64](uep)
        ufd: int32 = vfs_alloc_socket_fd()
        if ufd < 0:
            afunix_close(uep)
            set_current_errstr("socket: out of fd slots")
            return cast[int64](ufd)
        if vfs_socket_fd_set_record(ufd, afunix_fdbuf_for_ep(uep)) != 0:
            afunix_close(uep)
            vfs_close(ufd)
            set_current_errstr("socket: AF_UNIX fd record bind failed")
            return ELINUX_BADF
        if sock_nonblock != 0:
            _u_set_fd_nonblock(ufd, 1)
        if sock_cloexec != 0:
            _u_set_fd_cloexec(ufd, 1)
        return cast[int64](ufd)
    if domain != USOCK_AF_INET:
        # Only AF_INET — AF_INET6 not supported.
        set_current_errstr("socket: address family not supported")
        return ELINUX_AFNOSUPPORT
    if sock_type != USOCK_SOCK_STREAM:
        if sock_type != USOCK_SOCK_DGRAM:
            set_current_errstr("socket: socket type not supported")
            return ELINUX_PROTONOSUP
    fd: int32 = vfs_alloc_socket_fd()
    if fd < 0:
        set_current_errstr("socket: out of fd slots")
        return cast[int64](fd)
    rec: int32 = usock_alloc(domain, sock_type)
    if rec < 0:
        # Backing-record pool exhausted — undo the fd allocation so we
        # don't leak a recordless socket fd.
        vfs_close(fd)
        set_current_errstr("socket: out of socket records")
        return ELINUX_MFILE
    # §10: a SOCK_DGRAM socket gets a UDP socket slot immediately (UDP
    # is connectionless — there's no connect() to defer the slot to).
    # The udp.ad slot is stashed in the record's stack-slot field.
    if sock_type == USOCK_SOCK_DGRAM:
        uslot: int32 = udp_socket_open()
        if uslot < 0:
            usock_free(rec)
            vfs_close(fd)
            set_current_errstr("socket: out of UDP socket slots")
            return ELINUX_MFILE
        usock_set_tcp_slot(rec, uslot)
        # A UDP socket is usable for I/O right after socket() — Linux
        # lets you sendto/recvfrom without an explicit connect — so the
        # record goes straight to CONNECTED (here "ready", not "has a
        # fixed peer"; the peer tuple stays zero until connect(2)).
        usock_set_state(rec, USOCK_CONNECTED)
    # Wire the record id into the fd's fd_buf so vfs read/write/close
    # can find it. If the fd_buf write fails the fd vanished from
    # under us — release the record and surface the error.
    if vfs_socket_fd_set_record(fd, usock_fdbuf_for_record(rec)) != 0:
        if sock_type == USOCK_SOCK_DGRAM:
            udp_socket_close(usock_get_tcp_slot(rec))
        usock_free(rec)
        vfs_close(fd)
        set_current_errstr("socket: fd record bind failed")
        return ELINUX_BADF
    # §5: apply SOCK_NONBLOCK — a would-block read/write on this fd now
    # returns -EAGAIN instead of blocking (epoll is useless without it).
    if sock_nonblock != 0:
        _u_set_fd_nonblock(fd, 1)
    if sock_cloexec != 0:
        _u_set_fd_cloexec(fd, 1)
    return cast[int64](fd)


def _u_connect(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int connect(int sockfd, const struct sockaddr *addr,
    #             socklen_t addrlen)
    #
    # U-socket V0: parse the sockaddr_in and drive a real TCP active
    # open through drivers/net/tcp.ad. On success the returned tcp
    # slot is stored in the fd's backing record and the record moves
    # to USOCK_CONNECTED; subsequent read/write route through tcp_recv
    # / tcp_send (see fs/vfs.ad's FD_SOCKET_MARK arms).
    #
    # struct sockaddr_in (Linux <netinet/in.h>, 16 bytes):
    #   offset 0  : uint16  sin_family   (host order — AF_INET == 2)
    #   offset 2  : uint16  sin_port     (network / big-endian)
    #   offset 4  : uint32  sin_addr     (network / big-endian IPv4)
    #   offset 8  : uint8[8] sin_zero    (padding)
    fd: int32 = cast[int32](a0)
    # AF_UNIX: rendezvous with a listening server by name (STREAM) or
    # record the default datagram peer (DGRAM).
    uxep: int32 = _u_afunix_ep(fd)
    if uxep >= 0:
        # Wayland: lazily bind the display listener to the exact name the
        # client is connecting to, so the rendezvous below succeeds, then
        # accept + register the new connection after connect returns.
        wl_target: int32 = wayland_connect_intercept(a1, cast[int32](a2))
        crc: int64 = afunix_connect(uxep, a1, cast[int32](a2))
        if crc == 0 and wl_target != 0:
            wayland_after_connect()
        return crc
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        # Socket fd with no backing record — a legacy U35-era fd, or a
        # record-alloc failure slipped through. Treat as a bad fd.
        return ELINUX_BADF
    # §10 UDP: connect on a datagram socket just records a fixed peer
    # (no handshake). A bare send(2) / sendto(NULL) then targets it,
    # and a received ICMP port-unreachable surfaces via SO_ERROR.
    if usock_get_type(rec) == USOCK_SOCK_DGRAM:
        if a1 == 0:
            set_current_errstr("connect: null sockaddr")
            return ELINUX_INVAL
        if a2 < 16:
            set_current_errstr("connect: addrlen too short for sockaddr_in")
            return ELINUX_INVAL
        # #163: stage the sockaddr_in through a kernel copy.
        ucsa: Array[16, uint8]
        if _u_copyin_sockaddr16(a1, &ucsa[0]) != 0:
            set_current_errstr("connect: bad sockaddr pointer")
            return ELINUX_EFAULT
        uaddr: Ptr[uint8] = cast[Ptr[uint8]](&ucsa[0])
        ufam: uint32 = cast[uint32](uaddr[0]) \
                     | (cast[uint32](uaddr[1]) << 8)
        if ufam != USOCK_AF_INET:
            set_current_errstr("connect: sockaddr family not AF_INET")
            return ELINUX_AFNOSUPPORT
        uport: uint32 = (cast[uint32](uaddr[2]) << 8) \
                      | cast[uint32](uaddr[3])
        uip: uint32 = (cast[uint32](uaddr[4]) << 24) \
                    | (cast[uint32](uaddr[5]) << 16) \
                    | (cast[uint32](uaddr[6]) << 8) \
                    | cast[uint32](uaddr[7])
        uslot: int32 = usock_get_tcp_slot(rec)
        if udp_socket_connect(uslot, uip, cast[uint16](uport & 0xFFFF)) != 0:
            set_current_errstr("connect: UDP socket slot invalid")
            return ELINUX_BADF
        usock_set_peer(rec, uip, uport)
        printk2("[u_socket] UDP connect -> %d.%d", cast[uint64](uaddr[4]),
                cast[uint64](uaddr[5]))
        printk1(":%d\n", cast[uint64](uport))
        return 0
    st: uint32 = usock_get_state(rec)
    if st == USOCK_CONNECTED:
        set_current_errstr("connect: socket already connected")
        return ELINUX_ISCONN
    if st != USOCK_CREATED:
        # CLOSED — a connected socket that hit EOF can't be reconnected.
        set_current_errstr("connect: socket not in a connectable state")
        return ELINUX_INVAL
    if a1 == 0:
        set_current_errstr("connect: null sockaddr")
        return ELINUX_INVAL
    if a2 < 16:
        # sockaddr_in is 16 bytes — a shorter addrlen can't hold one.
        set_current_errstr("connect: addrlen too short for sockaddr_in")
        return ELINUX_INVAL
    # #163: stage the sockaddr_in through a kernel copy.
    csa: Array[16, uint8]
    if _u_copyin_sockaddr16(a1, &csa[0]) != 0:
        set_current_errstr("connect: bad sockaddr pointer")
        return ELINUX_EFAULT
    addr: Ptr[uint8] = cast[Ptr[uint8]](&csa[0])
    # sin_family — two host-order bytes, little-endian on x86_64.
    sin_family: uint32 = cast[uint32](addr[0]) \
                       | (cast[uint32](addr[1]) << 8)
    if sin_family != USOCK_AF_INET:
        set_current_errstr("connect: sockaddr family not AF_INET")
        return ELINUX_AFNOSUPPORT
    # sin_port — network byte order (big-endian): high byte first.
    port16: uint16 = cast[uint16](
        (cast[uint32](addr[2]) << 8) | cast[uint32](addr[3]))
    # sin_addr — network byte order: addr[4] is the first IPv4 octet.
    ip_b0: uint8 = addr[4]
    ip_b1: uint8 = addr[5]
    ip_b2: uint8 = addr[6]
    ip_b3: uint8 = addr[7]
    printk2("[u_socket] connect -> %d.%d", cast[uint64](ip_b0),
            cast[uint64](ip_b1))
    printk2(".%d.%d", cast[uint64](ip_b2), cast[uint64](ip_b3))
    printk1(":%d\n", cast[uint64](port16))
    # ARCH §10: drive the active open through the /net file tree —
    # clone a /net/tcp connection and write a `connect` ctl command.
    # This is the architectural point: the Linux socket() personality
    # is a Layer-2 CONSUMER of /net, NOT a caller of tcp_connect. The
    # devnet layer bounds the handshake (NET_BLOCK_JIFFIES) and polls
    # virtio_net internally.
    nconn: int32 = devnet_clone(NET_PROTO_TCP)
    if nconn < 0:
        set_current_errstr("connect: /net connection table full")
        return ELINUX_NETUNREACH
    clen: uint64 = _u_net_build_connect(ip_b0, ip_b1, ip_b2, ip_b3,
                                        port16)
    crc: int32 = devnet_ctl(nconn, &u_net_ctl_buf[0], clen)
    if crc != NET_CTL_OK:
        devnet_conn_unref(nconn)
        set_current_errstr("connect: /net connect failed")
        return _u_net_ctl_errno(crc)
    # Connected. Record the /net connection (so close(2) can unref it)
    # and the underlying TCP slot the conn wraps (so the data-path
    # read/write arms and the TLS record layer can ride it).
    usock_set_netconn(rec, nconn)
    usock_set_tcp_slot(rec, devnet_conn_stack_slot(nconn))
    usock_set_state(rec, USOCK_CONNECTED)
    printk1("[u_socket] connected via /net conn=%d\n",
            cast[uint64](nconn))
    return 0


# U-TLS: kernel-side scratch for the hostname tls_connect(2) receives
# from userland. tls_handshake() wants a NUL-terminated string (for
# SNI + the leaf-cert name check); the user buffer may be neither
# NUL-terminated nor stable, so we copy it into this top-level BSS
# arena (the U9 nested-frame-Array quirk: never park an Array in a
# nested frame). 256 bytes covers any DNS name (RFC 1035 caps a
# hostname at 253 chars); a longer name is rejected with -EINVAL.
U_TLS_HOST_MAX: uint64 = 256
u_tls_host_buf: Array[256, uint8]


def _u_tls_connect(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int tls_connect(int sockfd, const char *hostname, size_t hostlen)
    #
    # U-TLS: take an already-connect(2)'d AF_INET SOCK_STREAM socket fd
    # and run the in-kernel TLS 1.3 handshake (drivers/net/tls.ad) over
    # its live TCP slot. `hostname` is used both for the SNI extension
    # and the leaf-cert subject/SAN name check; the handshake validates
    # the server's certificate chain against the kernel CA store and
    # verifies the CertificateVerify transcript binding. On success the
    # socket fd is marked TLS-active: subsequent write(2)/read(2) route
    # transparently through the TLS record layer (fs/vfs.ad's
    # FD_SOCKET_MARK arms), and close(2) sends a close_notify alert.
    #
    # The TLS stack is single-session (module-global key/transcript
    # state), so only one socket fd can be TLS-active at a time; a
    # second tls_connect(2) while a session is live returns -EBUSY.
    #
    # Returns 0 on success, or a negative errno:
    #   -EBADF   sockfd is not a live socket fd
    #   -ENOTCONN sockfd has no live TCP connection (connect(2) first)
    #   -EBUSY   another socket already has a live TLS session
    #   -EINVAL  null / over-long hostname
    #   -EPROTO  handshake failed (incl. cert-chain / CertificateVerify
    #            rejection — the user sees the connection fail, never
    #            an un-validated plaintext channel)
    fd: int32 = cast[int32](a0)
    if vfs_fd_is_socket(fd) == 0:
        set_current_errstr("tls_connect: not a socket fd")
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        set_current_errstr("tls_connect: socket has no backing record")
        return ELINUX_BADF
    if usock_get_state(rec) != USOCK_CONNECTED:
        # TLS rides on an ESTABLISHED TCP connection — the caller must
        # connect(2) first. A LISTENING / CREATED / CLOSED socket has
        # no peer to handshake with.
        set_current_errstr("tls_connect: socket not connected")
        return ELINUX_NOTCONN
    if usock_is_tls(rec) != 0:
        # Already handshaked on this fd — a double tls_connect(2).
        set_current_errstr("tls_connect: TLS already established")
        return ELINUX_ISCONN
    if usock_any_tls_active() != 0:
        # The TLS stack carries one global session; a second concurrent
        # handshake would clobber the first session's keys.
        set_current_errstr("tls_connect: a TLS session is already active")
        return ELINUX_BUSY
    # ARCH §10: the in-kernel TLS record layer rides the socket's /net
    # connection (its `data` file), so tls_handshake keys on the /net
    # conn NUMBER. The Linux socket() shim already cloned + connected a
    # /net conn (usock_set_netconn in _u_connect); we hand its number
    # to the TLS stack. A socket with no /net conn never connect(2)'d.
    net_conn: int32 = usock_get_netconn(rec)
    if net_conn < 0:
        set_current_errstr("tls_connect: socket has no /net connection")
        return ELINUX_NOTCONN
    if a1 == 0:
        set_current_errstr("tls_connect: null hostname")
        return ELINUX_INVAL
    # Copy the user hostname into kernel BSS and NUL-terminate. a2 is
    # the caller-supplied length (advisory); we copy at most
    # U_TLS_HOST_MAX-1 bytes and stop early at an embedded NUL.
    hlen: uint64 = a2
    if hlen >= U_TLS_HOST_MAX:
        set_current_errstr("tls_connect: hostname too long")
        return ELINUX_INVAL
    # #163: strncpy_from_user walks the page tables, stops at an
    # embedded NUL, and NUL-terminates the kernel copy — capped at
    # hlen bytes (the caller's advisory length).
    hr: int64 = strncpy_from_user(cast[uint64](&u_tls_host_buf[0]),
                                  a1, hlen + 1)
    if hr < 0:
        set_current_errstr("tls_connect: bad hostname pointer")
        return ELINUX_EFAULT
    if hr == 0:
        set_current_errstr("tls_connect: empty hostname")
        return ELINUX_INVAL
    printk1("[u_tls] tls_connect fd=%d", cast[uint64](fd))
    printk1(" /net conn=%d\n", cast[uint64](net_conn))
    # Initialise the TLS module (idempotent — clears scratch + loads
    # SHA-256 K constants) then drive the full handshake over the /net
    # connection. tls_handshake reads/writes the conn's data file and
    # polls virtio_net internally — the same blocking model the
    # userland connect(2) above already uses from syscall context.
    tls_init()
    hs: int32 = tls_handshake(net_conn,
                              cast[Ptr[uint8]](&u_tls_host_buf[0]))
    if hs != 0:
        # Handshake or cert-chain / CertificateVerify validation failed.
        # tls_handshake already logged the specific stage; the user
        # gets a failed connection rather than an un-validated channel.
        set_current_errstr("tls_connect: TLS handshake failed")
        return ELINUX_PROTO
    # Handshake done — tls_active is 1 and the TLS session is keyed to
    # this /net connection. Mark the fd so vfs read/write/close route
    # through the TLS record layer.
    usock_set_tls(rec, 1)
    printk0("[u_tls] handshake complete — fd is now TLS-active\n")
    return 0


def _u_accept(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int accept(int sockfd, struct sockaddr *addr, socklen_t *addrlen)
    #
    # U-socket V1 server side: block (bounded poll) on a LISTENING
    # socket until the in-kernel TCP stack completes a three-way
    # handshake on the bound port, then hand back a brand-new socket fd
    # for the accepted connection. read/write/close on the returned fd
    # route through the existing FD_SOCKET_MARK arms (fs/vfs.ad) — the
    # new record is USOCK_CONNECTED and carries the accepted TCP slot.
    #
    # `addr` / `addrlen` (the peer sockaddr out-params) are filled with
    # the connection's remote (ip, port) when supplied; a NULL addr is
    # honoured (Linux allows it). V1 is BLOCKING only — no O_NONBLOCK
    # / accept4 SOCK_NONBLOCK fast path (see the V1 backlog).
    fd: int32 = cast[int32](a0)
    # AF_UNIX: pop a pending connection off the listener's accept queue.
    # Blocking accept yields until a client connect() rendezvouses; a
    # non-blocking fd returns -EAGAIN on an empty queue.
    uxep: int32 = _u_afunix_ep(fd)
    if uxep >= 0:
        uxnb: int32 = _u_fd_is_nonblock(fd)
        usrv: int32 = afunix_accept_take(uxep)
        if usrv == cast[int32](AFU_EAGAIN):
            if uxnb != 0:
                return AFU_EAGAIN
            # Bounded cooperative block: yield until a connection lands.
            while usrv == cast[int32](AFU_EAGAIN):
                yield_to_others()
                usrv = afunix_accept_take(uxep)
        if usrv < 0:
            return cast[int64](usrv)
        # Install a fresh socket fd for the accepted server endpoint.
        nufd: int32 = vfs_alloc_socket_fd()
        if nufd < 0:
            afunix_close(usrv)
            set_current_errstr("accept: out of fd slots")
            return ELINUX_MFILE
        if vfs_socket_fd_set_record(nufd, afunix_fdbuf_for_ep(usrv)) != 0:
            afunix_close(usrv)
            vfs_close(nufd)
            return ELINUX_BADF
        # Peer sockaddr_un out-param: AF_UNIX accepted peers are unnamed,
        # so report an addrlen of 2 (family only) when a buffer is given.
        if a1 != 0:
            # #163: build the 2-byte family in kernel space, then
            # copy_to_user it (fault => -EFAULT, fd already installed —
            # close it so the caller doesn't leak a slot).
            uxa: Array[2, uint8]
            uxa[0] = cast[uint8](AFU_AF_UNIX & 0xFF)
            uxa[1] = cast[uint8]((AFU_AF_UNIX >> 8) & 0xFF)
            if copy_to_user(a1, cast[uint64](&uxa[0]), 2) != 0:
                vfs_close(nufd)
                return ELINUX_EFAULT
        if a2 != 0:
            if put_user_32(2, a2) != 0:
                vfs_close(nufd)
                return ELINUX_EFAULT
        return cast[int64](nufd)
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        return ELINUX_BADF
    if usock_get_state(rec) != USOCK_LISTENING:
        # accept(2) on a socket that never reached listen(2) — Linux
        # returns -EINVAL ("Socket is not listening for connections").
        set_current_errstr("accept: socket not listening")
        return ELINUX_INVAL
    lconn: int32 = usock_get_netconn(rec)
    if lconn < 0:
        set_current_errstr("accept: no /net listener connection")
        return ELINUX_INVAL
    # ARCH §10: accept through /net — write an `accept` ctl command to
    # the listening /net connection. devnet_ctl blocks (bounded) on
    # the in-kernel TCP stack's accept queue and, on success, allocates
    # a FRESH /net connection for the accepted peer; devnet_accept_take
    # hands that connection number over. The listener stays announced.
    #
    # O_NONBLOCK semantics: a non-blocking listener writes `accept nb`
    # (a single poll) and returns -EAGAIN on an empty backlog. A blocking
    # listener writes `accept` (one bounded NET_BLOCK_JIFFIES window) and,
    # if that window expires with no peer, RE-ISSUES it — yielding between
    # windows so the rest of the system runs — until a connection lands.
    # (devnet_ctl's window already parks this task OFF the runqueue while
    # it waits, so the loop is not a busy-spin.)
    nb: int32 = _u_fd_is_nonblock(fd)
    acl: uint64 = 0
    if nb != 0:
        acc_nb: Ptr[uint8] = "accept nb"
        while acc_nb[acl] != 0:
            u_net_ctl_buf[acl] = acc_nb[acl]
            acl = acl + 1
    else:
        acc_cmd: Ptr[uint8] = "accept"
        while acc_cmd[acl] != 0:
            u_net_ctl_buf[acl] = acc_cmd[acl]
            acl = acl + 1
    acrc: int32 = devnet_ctl(lconn, &u_net_ctl_buf[0], acl)
    if nb == 0:
        # Blocking accept: keep re-arming the bounded /net accept window
        # until a peer completes the handshake.
        while acrc != NET_CTL_OK:
            yield_to_others()
            acrc = devnet_ctl(lconn, &u_net_ctl_buf[0], acl)
    if acrc != NET_CTL_OK:
        # Non-blocking listener with an empty accept queue — -EAGAIN is
        # the would-block answer Linux gives here.
        set_current_errstr("accept: no connection pending")
        return ELINUX_AGAIN
    conn_net: int32 = devnet_accept_take(lconn)
    if conn_net < 0:
        set_current_errstr("accept: no connection pending")
        return ELINUX_AGAIN
    # The accepted /net conn is pending-unowned (refcount 0 — see the
    # `accept` ctl handler in devnet.ad). Claim a reference for the
    # socket fd we are about to install; close(2) on that fd will
    # devnet_conn_unref it, FIN-tearing the connection down.
    devnet_conn_ref(conn_net)
    # A connection is ESTABLISHED. Allocate a fresh socket fd + backing
    # record for it so the caller gets an independent fd it can
    # read/write/close while the listener stays open for more accepts.
    nfd: int32 = vfs_alloc_socket_fd()
    if nfd < 0:
        # Out of fd slots — the /net connection itself stays up; the
        # caller can retry accept() after closing something.
        devnet_conn_unref(conn_net)
        set_current_errstr("accept: out of fd slots")
        return ELINUX_MFILE
    nrec: int32 = usock_alloc(USOCK_AF_INET, USOCK_SOCK_STREAM)
    if nrec < 0:
        devnet_conn_unref(conn_net)
        vfs_close(nfd)
        set_current_errstr("accept: out of socket records")
        return ELINUX_MFILE
    usock_set_netconn(nrec, conn_net)
    usock_set_tcp_slot(nrec, devnet_conn_stack_slot(conn_net))
    usock_set_state(nrec, USOCK_CONNECTED)
    if vfs_socket_fd_set_record(nfd, usock_fdbuf_for_record(nrec)) != 0:
        usock_free(nrec)
        vfs_close(nfd)
        set_current_errstr("accept: fd record bind failed")
        return ELINUX_BADF
    # Fill the peer sockaddr_out if the caller asked for one. The
    # accepted /net conn now carries the real peer 4-tuple (the accept
    # ctl handler mirrors the accepted TCB's remote ip/port onto it), so
    # report the true (ip, port). _u_putaddr_in handles the NULL-addr,
    # short-buffer truncation, and addrlen=16 write-back per Linux.
    if a1 != 0 or a2 != 0:
        pkrc: int64 = _u_putaddr_in(a1, a2,
                                    devnet_conn_remote_ip(conn_net),
                                    devnet_conn_remote_port(conn_net))
        if pkrc != 0:
            vfs_close(nfd)
            return pkrc
    printk2("[u_socket] accept: /net listener conn=%d -> conn=%d\n",
            cast[uint64](lconn), cast[uint64](conn_net))
    printk1("[u_socket] accept: new fd=%d\n", cast[uint64](nfd))
    return cast[int64](nfd)


def _u_accept4(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int accept4(int sockfd, struct sockaddr *addr,
    #             socklen_t *addrlen, int flags)
    # Same shape as accept(2). §5: SOCK_NONBLOCK in `flags` is applied
    # to the freshly-accepted connection fd so an epoll-driven server
    # loop gets a non-blocking client socket back.
    nfd: int64 = _u_accept(a0, a1, a2, a3, a4, a5)
    if nfd >= 0:
        if (a3 & O_NONBLOCK_BIT) != 0:
            _u_set_fd_nonblock(cast[int32](nfd), 1)
        # SOCK_CLOEXEC on the accepted fd (a server that accepts then
        # forks+execs a handler wants the listen/conn fds gone in the child).
        _u_apply_cloexec_flags(cast[int32](nfd), a3)
    return nfd


def _u_bind(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int bind(int sockfd, const struct sockaddr *addr, socklen_t addrlen)
    #
    # U-socket V1 server side: parse the sockaddr_in and record the
    # (port, addr) on the socket's backing record. TCP doesn't truly
    # "bind" until listen(2) calls tcp_listen — recording the port here
    # is enough; listen(2) reads it back. INADDR_ANY (0.0.0.0) is the
    # common case and is stored verbatim (addr 0).
    #
    # struct sockaddr_in (Linux <netinet/in.h>, 16 bytes):
    #   offset 0 : uint16 sin_family  (host order — AF_INET == 2)
    #   offset 2 : uint16 sin_port    (network / big-endian)
    #   offset 4 : uint32 sin_addr    (network / big-endian IPv4)
    #   offset 8 : uint8[8] sin_zero  (padding)
    fd: int32 = cast[int32](a0)
    # AF_NETLINK: record the bound nl_pid / nl_groups (any pid accepted).
    nlep_b: int32 = _u_netlink_ep(fd)
    if nlep_b >= 0:
        return nl_bind(nlep_b, a1, cast[int32](a2))
    # AF_UNIX: register the endpoint's name in the rendezvous table.
    uxep: int32 = _u_afunix_ep(fd)
    if uxep >= 0:
        return afunix_bind(uxep, a1, cast[int32](a2))
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        return ELINUX_BADF
    # §10 UDP: bind a datagram socket to a local port via the UDP
    # socket layer. A UDP socket can be bound exactly once; a second
    # bind (local port already set) is -EINVAL.
    if usock_get_type(rec) == USOCK_SOCK_DGRAM:
        if a1 == 0:
            set_current_errstr("bind: null sockaddr")
            return ELINUX_INVAL
        if a2 < 16:
            set_current_errstr("bind: addrlen too short for sockaddr_in")
            return ELINUX_INVAL
        # #163: stage the sockaddr_in through a kernel copy.
        ubsa: Array[16, uint8]
        if _u_copyin_sockaddr16(a1, &ubsa[0]) != 0:
            set_current_errstr("bind: bad sockaddr pointer")
            return ELINUX_EFAULT
        ua: Ptr[uint8] = cast[Ptr[uint8]](&ubsa[0])
        ufam: uint32 = cast[uint32](ua[0]) | (cast[uint32](ua[1]) << 8)
        if ufam != USOCK_AF_INET:
            set_current_errstr("bind: sockaddr family not AF_INET")
            return ELINUX_AFNOSUPPORT
        uport: uint32 = (cast[uint32](ua[2]) << 8) | cast[uint32](ua[3])
        uslot: int32 = usock_get_tcp_slot(rec)
        if udp_socket_local_port(uslot) != 0:
            set_current_errstr("bind: socket already bound")
            return ELINUX_INVAL
        ubrc: int32 = udp_socket_bind(uslot, cast[uint16](uport & 0xFFFF))
        if ubrc == -2:
            set_current_errstr("bind: address already in use")
            return ELINUX_ADDRINUSE
        if ubrc != 0:
            set_current_errstr("bind: UDP socket slot invalid")
            return ELINUX_BADF
        printk1("[u_socket] UDP bind: port=%d\n", cast[uint64](uport))
        return 0
    if usock_get_state(rec) != USOCK_CREATED:
        # Already bound + listening, or connected, or closed — Linux
        # returns -EINVAL ("socket is already bound to an address").
        set_current_errstr("bind: socket already bound")
        return ELINUX_INVAL
    if a1 == 0:
        set_current_errstr("bind: null sockaddr")
        return ELINUX_INVAL
    if a2 < 16:
        set_current_errstr("bind: addrlen too short for sockaddr_in")
        return ELINUX_INVAL
    # #163: stage the sockaddr_in through a kernel copy.
    bsa: Array[16, uint8]
    if _u_copyin_sockaddr16(a1, &bsa[0]) != 0:
        set_current_errstr("bind: bad sockaddr pointer")
        return ELINUX_EFAULT
    addr: Ptr[uint8] = cast[Ptr[uint8]](&bsa[0])
    sin_family: uint32 = cast[uint32](addr[0]) \
                       | (cast[uint32](addr[1]) << 8)
    if sin_family != USOCK_AF_INET:
        set_current_errstr("bind: sockaddr family not AF_INET")
        return ELINUX_AFNOSUPPORT
    # sin_port — network byte order (big-endian): high byte first.
    bind_port: uint32 = (cast[uint32](addr[2]) << 8) \
                      | cast[uint32](addr[3])
    # sin_addr — network byte order: addr[4] is the first IPv4 octet.
    # Store host-order so the octets read naturally; 0 == INADDR_ANY.
    bind_addr: uint32 = (cast[uint32](addr[4]) << 24) \
                      | (cast[uint32](addr[5]) << 16) \
                      | (cast[uint32](addr[6]) << 8) \
                      | cast[uint32](addr[7])
    if bind_port == 0:
        # Ephemeral-port bind (port 0): pick the first free port in the
        # 49152..65535 dynamic/private range (IANA), scanning the
        # backing-record table via usock_port_in_use. getsockname(2) then
        # reports the chosen port. (A server that needs a fixed,
        # host-known port still names it explicitly.)
        cand: uint32 = 49152
        while cand <= 65535:
            if usock_port_in_use(cand) == 0:
                bind_port = cand
                break
            cand = cand + 1
        if bind_port == 0:
            set_current_errstr("bind: no ephemeral port free")
            return ELINUX_ADDRINUSE
    if usock_port_in_use(bind_port) != 0:
        set_current_errstr("bind: address already in use")
        return ELINUX_ADDRINUSE
    usock_set_bound(rec, bind_port, bind_addr)
    printk1("[u_socket] bind: port=%d\n", cast[uint64](bind_port))
    return 0


def _u_listen(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int listen(int sockfd, int backlog)
    #
    # U-socket V1 server side: call the in-kernel tcp_listen for the
    # port recorded by bind(2), stash the returned TCP_LISTEN slot on
    # the backing record, and move the record to USOCK_LISTENING so
    # accept(2) can poll it. `backlog` is advisory — tcp.ad's accept
    # queue depth is fixed by TCP_NUM_SLOTS, so we don't honour it
    # beyond what tcp_accept already provides (see V1 backlog).
    fd: int32 = cast[int32](a0)
    # AF_UNIX: mark a bound STREAM endpoint passive.
    uxep: int32 = _u_afunix_ep(fd)
    if uxep >= 0:
        return afunix_listen(uxep, cast[int32](a1))
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        return ELINUX_BADF
    st: uint32 = usock_get_state(rec)
    if st == USOCK_LISTENING:
        # Idempotent re-listen — Linux allows listen() twice (it just
        # updates the backlog). Nothing to re-do; report success.
        return 0
    if st != USOCK_CREATED:
        set_current_errstr("listen: socket not in a listenable state")
        return ELINUX_INVAL
    bound_port: uint32 = usock_get_bound_port(rec)
    if bound_port == 0:
        # listen(2) before bind(2). Linux auto-binds an ephemeral port
        # here; Hamnix requires an explicit bind so the server's port
        # is known to the host test driver.
        set_current_errstr("listen: socket not bound")
        return ELINUX_INVAL
    # ARCH §10: passive open through /net — clone a /net/tcp connection
    # and write an `announce` ctl command. The listener is a /net
    # connection; accept(2) below drives a `accept` ctl on it.
    nconn: int32 = devnet_clone(NET_PROTO_TCP)
    if nconn < 0:
        set_current_errstr("listen: /net connection table full")
        return ELINUX_ADDRINUSE
    alen: uint64 = _u_net_build_announce(cast[uint16](bound_port & 0xFFFF))
    arc: int32 = devnet_ctl(nconn, &u_net_ctl_buf[0], alen)
    if arc != NET_CTL_OK:
        devnet_conn_unref(nconn)
        set_current_errstr("listen: /net announce failed")
        return _u_net_ctl_errno(arc)
    usock_set_netconn(rec, nconn)
    usock_set_tcp_slot(rec, devnet_conn_stack_slot(nconn))
    usock_set_state(rec, USOCK_LISTENING)
    printk1("[u_socket] listen via /net conn=%d\n", cast[uint64](nconn))
    return 0


# --- sockaddr_in copy-out helper -------------------------------------
# getsockname(2)/getpeername(2)/accept(2) all hand a 16-byte AF_INET
# sockaddr back to userland with the same truncation rule: Linux copies
# min(*addrlen, real_len) bytes into `addr`, then writes the UNtruncated
# length (16) back into *addrlen. `ip`/`port` are host order.
def _u_putaddr_in(addr_u: uint64, alen_u: uint64,
                  ip: uint32, port: uint32) -> int64:
    # Build the 16-byte sockaddr_in in kernel space (#163), then copy out.
    sa: Array[16, uint8]
    sa[0] = cast[uint8](USOCK_AF_INET & 0xFF)         # sin_family lo
    sa[1] = cast[uint8]((USOCK_AF_INET >> 8) & 0xFF)  # sin_family hi
    sa[2] = cast[uint8]((port >> 8) & 0xFF)           # sin_port  (BE)
    sa[3] = cast[uint8](port & 0xFF)
    sa[4] = cast[uint8]((ip >> 24) & 0xFF)            # sin_addr  (BE)
    sa[5] = cast[uint8]((ip >> 16) & 0xFF)
    sa[6] = cast[uint8]((ip >> 8) & 0xFF)
    sa[7] = cast[uint8](ip & 0xFF)
    i: uint64 = 8
    while i < 16:
        sa[i] = 0                                     # sin_zero
        i = i + 1
    # `addr` may be NULL (Linux permits it for accept; for get*name a
    # NULL addr with a non-NULL addrlen still updates addrlen).
    if addr_u != 0:
        want: uint64 = 16
        if alen_u != 0:
            ulen: uint32 = 0
            if get_user_32(alen_u, &ulen) != 0:
                return ELINUX_EFAULT
            if cast[uint64](ulen) < want:
                want = cast[uint64](ulen)
        if want != 0:
            if copy_to_user(addr_u, cast[uint64](&sa[0]), want) != 0:
                return ELINUX_EFAULT
    if alen_u != 0:
        # Always report the FULL length (16) so the caller can detect
        # truncation — matches Linux semantics.
        if put_user_32(16, alen_u) != 0:
            return ELINUX_EFAULT
    return 0


def _u_getsockname(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getsockname(int sockfd, struct sockaddr *addr, socklen_t *addrlen)
    # Fill the LOCAL (ip, port) from the socket's bound/connected /net
    # connection state. For a connected or accepted socket the local
    # port is the /net conn's recorded local port and the local IP is the
    # host IP; for a bound-but-not-yet-listening socket the port comes
    # off the backing record's bound-port field.
    # AF_NETLINK: report the bound sockaddr_nl (nl_pid/nl_groups) so
    # libmnl's mnl_socket_get_portid sees the auto-assigned port id.
    fd: int32 = cast[int32](a0)
    gsn_nlep: int32 = _u_netlink_ep(fd)
    if gsn_nlep >= 0:
        return nl_getsockname(gsn_nlep, a1, a2)
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        return ELINUX_BADF
    lip:   uint32 = 0
    lport: uint32 = 0
    nconn: int32 = usock_get_netconn(rec)
    if nconn >= 0:
        # Listener / connected / accepted socket — the /net conn carries
        # the live local addr+port (the accept ctl handler + the connect
        # handler both populate netc_lport).
        lip   = devnet_conn_local_ip(nconn)
        lport = devnet_conn_local_port(nconn)
    if lport == 0:
        # No /net conn yet (bound but not listen(2)'d), or a UDP socket:
        # fall back to the record's bound port. Local IP is the host IP.
        lport = usock_get_bound_port(rec)
        if lport != 0:
            lip = devnet_host_ip()
    return _u_putaddr_in(a1, a2, lip, lport)


def _u_getpeername(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getpeername(int sockfd, struct sockaddr *addr, socklen_t *addrlen)
    # Fill the REMOTE (ip, port) of the connected peer. Only a CONNECTED
    # socket (active connect, accepted server side, or a connected UDP
    # socket) has a peer; anything else is -ENOTCONN, matching Linux.
    fd: int32 = cast[int32](a0)
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        return ELINUX_BADF
    if usock_get_state(rec) != USOCK_CONNECTED:
        set_current_errstr("getpeername: socket not connected")
        return ELINUX_NOTCONN
    rip:   uint32 = 0
    rport: uint32 = 0
    nconn: int32 = usock_get_netconn(rec)
    if nconn >= 0:
        # TCP: the /net conn records the peer 4-tuple (connect handler +
        # accept ctl handler both fill netc_rip/netc_rport).
        rip   = devnet_conn_remote_ip(nconn)
        rport = devnet_conn_remote_port(nconn)
    else:
        # Connected UDP socket — the fixed peer lives on the record.
        rip   = usock_get_peer_addr(rec)
        rport = usock_get_peer_port(rec)
    return _u_putaddr_in(a1, a2, rip, rport)


def _u_setsockopt(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setsockopt(int sockfd, int level, int optname,
    #                const void *optval, socklen_t optlen)
    #
    # §10: store the option on the socket's backing record. The common
    # daemon options (SO_REUSEADDR, SO_REUSEPORT, SO_RCVBUF/SO_SNDBUF,
    # SO_KEEPALIVE, TCP_NODELAY, SO_BROADCAST) are recorded; SO_RCVBUF/
    # SO_SNDBUF and the flags round-trip through getsockopt. Options
    # with a real effect are honoured (SO_BROADCAST is pushed to the
    # UDP socket layer); the rest are accept-and-record. An unmodelled
    # (level, optname) returns -ENOPROTOOPT rather than silently
    # succeeding, so a daemon that depends on a real option learns it
    # is unsupported instead of being misled.
    fd: int32 = cast[int32](a0)
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        return ELINUX_BADF
    level:   uint32 = cast[uint32](a1)
    optname: uint32 = cast[uint32](a2)
    # optval is a pointer to an int (the common case). A NULL optval or
    # an optlen < 4 can't carry an integer option — Linux returns
    # -EINVAL / -EFAULT; -EINVAL is the closest fit we have.
    if a3 == 0:
        return ELINUX_INVAL
    if a4 < 4:
        return ELINUX_INVAL
    value: uint32 = 0
    if get_user_32(a3, &value) != 0:                    # #163
        return ELINUX_EFAULT
    if usock_set_opt(rec, level, optname, value) != 0:
        set_current_errstr("setsockopt: unsupported option")
        return ELINUX_NOPROTOOPT
    # SO_BROADCAST has a real effect on a UDP socket — mirror it into
    # the UDP socket layer so getsockopt there agrees and so the flag
    # is recorded against the live datagram slot.
    if level == USOCK_SOL_SOCKET:
        if optname == USOCK_SO_BROADCAST:
            if usock_get_type(rec) == USOCK_SOCK_DGRAM:
                udp_socket_set_broadcast(usock_get_tcp_slot(rec),
                                         cast[uint8](value & 1))
    return 0


def _u_getsockopt(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getsockopt(int sockfd, int level, int optname,
    #                void *optval, socklen_t *optlen)
    #
    # §10: return the option value the socket's record carries. The
    # special case is SO_ERROR — Linux returns the socket's pending
    # error and CLEARS it. For a UDP socket the pending error lives in
    # the udp.ad slot (an ICMP port-unreachable latches it there); we
    # read-and-clear it. For a TCP socket we have no async error
    # channel, so SO_ERROR reads 0.
    fd: int32 = cast[int32](a0)
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) == 0:
        return ELINUX_BADF
    if a3 == 0:
        return ELINUX_INVAL
    if a4 == 0:
        return ELINUX_INVAL
    # The caller's *optlen must be able to hold an int. #163: fetched
    # through the page tables.
    gso_len: uint32 = 0
    if get_user_32(a4, &gso_len) != 0:
        return ELINUX_EFAULT
    if gso_len < 4:
        return ELINUX_INVAL
    level:   uint32 = cast[uint32](a1)
    optname: uint32 = cast[uint32](a2)
    result: int32 = 0
    if level == USOCK_SOL_SOCKET:
        if optname == USOCK_SO_ERROR:
            # Read-and-clear the pending error. A connected UDP socket
            # that got an ICMP port-unreachable surfaces -ECONNREFUSED
            # here; getsockopt reports it as a POSITIVE errno value.
            if usock_get_type(rec) == USOCK_SOCK_DGRAM:
                uerr: int32 = udp_socket_get_so_error(
                    usock_get_tcp_slot(rec))
                if uerr < 0:
                    result = -uerr
                else:
                    result = uerr
            else:
                result = 0
            if put_user_32(cast[uint32](result), a3) != 0:   # #163
                return ELINUX_EFAULT
            if put_user_32(4, a4) != 0:
                return ELINUX_EFAULT
            return 0
    got: int32 = usock_get_opt(rec, level, optname)
    if got < 0:
        set_current_errstr("getsockopt: unsupported option")
        return ELINUX_NOPROTOOPT
    if put_user_32(cast[uint32](got), a3) != 0:              # #163
        return ELINUX_EFAULT
    if put_user_32(4, a4) != 0:
        return ELINUX_EFAULT
    return 0


def _u_socketpair(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int socketpair(int domain, int type, int protocol, int sv[2])
    #
    # AF_UNIX: allocate a PRE-CONNECTED pair of AF_UNIX endpoints (the
    # most common AF_UNIX use), each backed by a real FD_SOCKET_MARK fd
    # whose fd_buf carries the AF_UNIX tag. The pair is a bidirectional
    # in-kernel byte conduit (STREAM) or two datagram queues (DGRAM) —
    # full-duplex from the caller's POV. SOCK_CLOEXEC/SOCK_NONBLOCK ride
    # in the high bits of `type` and are applied to both fds.
    if a3 == 0:
        return ELINUX_INVAL
    domain: uint32 = cast[uint32](a0)
    if domain == AFU_AF_UNIX:
        st: uint32 = cast[uint32](a1)
        sp_nb: int32 = 0
        if (cast[uint64](st) & O_NONBLOCK_BIT) != 0:
            sp_nb = 1
        sp_cx: int32 = 0
        if (cast[uint64](st) & O_CLOEXEC_BIT) != 0:
            sp_cx = 1
        st = st & 0xFF
        ep_a: int32 = 0
        ep_b: int32 = 0
        prc: int64 = afunix_socketpair(st, &ep_a, &ep_b)
        if prc != 0:
            return prc
        fda: int32 = vfs_alloc_socket_fd()
        if fda < 0:
            afunix_close(ep_a)
            afunix_close(ep_b)
            return ELINUX_MFILE
        if vfs_socket_fd_set_record(fda, afunix_fdbuf_for_ep(ep_a)) != 0:
            afunix_close(ep_a)
            afunix_close(ep_b)
            vfs_close(fda)
            return ELINUX_BADF
        fdb: int32 = vfs_alloc_socket_fd()
        if fdb < 0:
            vfs_close(fda)
            afunix_close(ep_a)
            afunix_close(ep_b)
            return ELINUX_MFILE
        if vfs_socket_fd_set_record(fdb, afunix_fdbuf_for_ep(ep_b)) != 0:
            vfs_close(fda)
            vfs_close(fdb)
            afunix_close(ep_a)
            afunix_close(ep_b)
            return ELINUX_BADF
        if sp_nb != 0:
            _u_set_fd_nonblock(fda, 1)
            _u_set_fd_nonblock(fdb, 1)
        if sp_cx != 0:
            _u_set_fd_cloexec(fda, 1)
            _u_set_fd_cloexec(fdb, 1)
        # Write the int[2] result out via copy_to_user (translated transfer).
        sv: Array[2, int32]
        sv[0] = fda
        sv[1] = fdb
        if copy_to_user(a3, cast[uint64](&sv[0]), 8) != 0:
            vfs_close(fda)
            vfs_close(fdb)
            afunix_close(ep_a)
            afunix_close(ep_b)
            return ELINUX_EFAULT
        return 0
    # AF_INET / other: forward to vfs_pipe — a kernel pipe pair models a
    # bidirectional fd pair cleanly enough for the legacy probe path.
    # #163: vfs_pipe writes its int[2] into a kernel scratch; the result
    # is then copy_to_user'd (a faulting sv pointer closes both fds).
    spk: Array[2, int32]
    rc: int32 = vfs_pipe(cast[Ptr[int32]](&spk[0]))
    if rc == 0:
        if copy_to_user(a3, cast[uint64](&spk[0]), 8) != 0:
            vfs_close(spk[0])
            vfs_close(spk[1])
            return ELINUX_EFAULT
        # SOCK_CLOEXEC / SOCK_NONBLOCK ride the high bits of `type` (a1).
        if (a1 & O_CLOEXEC_BIT) != 0:
            _u_set_fd_cloexec(spk[0], 1)
            _u_set_fd_cloexec(spk[1], 1)
        if (a1 & O_NONBLOCK_BIT) != 0:
            _u_set_fd_nonblock(spk[0], 1)
            _u_set_fd_nonblock(spk[1], 1)
    return cast[int64](rc)


def _u_sendto(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t sendto(int sockfd, const void *buf, size_t len,
    #                int flags, const struct sockaddr *dest_addr,
    #                socklen_t addrlen)
    #
    # SOCK_STREAM: a connected stream socket ignores dest_addr (Linux
    # does too), so sendto degrades to write(2).
    #
    # §10 SOCK_DGRAM: send ONE datagram. dest_addr names the target; a
    # NULL dest_addr requires the socket to have been connect(2)'d (the
    # fixed peer is used). `flags` (MSG_DONTWAIT etc.) are ignored.
    fd: int32 = cast[int32](a0)
    # AF_NETLINK: a sendto/send carries one or more nlmsghdr-framed GET
    # requests; build + queue the matching dump (dest_addr is the kernel,
    # which we ignore). Returns the request byte count "sent".
    nlep_s: int32 = _u_netlink_ep(fd)
    if nlep_s >= 0:
        return nl_send(nlep_s, a1, a2)
    # AF_UNIX: a DGRAM endpoint delivers one datagram by name (or to its
    # connected peer); a STREAM endpoint degrades to write(2).
    uxep: int32 = _u_afunix_ep(fd)
    if uxep >= 0:
        if afunix_get_type(uxep) == AFU_SOCK_DGRAM:
            return afunix_sendto(uxep, a1, a2, a4, cast[int32](a5))
        usn: int64 = afunix_send_stream(uxep, a1, a2)
        if usn == AFU_EAGAIN:
            if _u_fd_is_nonblock(fd) != 0:
                return AFU_EAGAIN
            # Blocking stream send: yield until the peer drains its ring.
            while usn == AFU_EAGAIN:
                yield_to_others()
                usn = afunix_send_stream(uxep, a1, a2)
        if usn == ELINUX_PIPE:
            signal_post(current_idx_get(), SIGPIPE)
        return usn
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) != 0:
        if usock_get_type(rec) == USOCK_SOCK_DGRAM:
            uslot: int32 = usock_get_tcp_slot(rec)
            dst_ip:   uint32 = 0
            dst_port: uint32 = 0
            if a4 != 0:
                # dest_addr supplied — parse the sockaddr_in.
                if a5 < 16:
                    set_current_errstr("sendto: addrlen too short")
                    return ELINUX_INVAL
                # #163: stage the sockaddr_in through a kernel copy.
                dsa: Array[16, uint8]
                if _u_copyin_sockaddr16(a4, &dsa[0]) != 0:
                    set_current_errstr("sendto: bad sockaddr pointer")
                    return ELINUX_EFAULT
                da: Ptr[uint8] = cast[Ptr[uint8]](&dsa[0])
                dfam: uint32 = cast[uint32](da[0]) \
                             | (cast[uint32](da[1]) << 8)
                if dfam != USOCK_AF_INET:
                    set_current_errstr("sendto: dest family not AF_INET")
                    return ELINUX_AFNOSUPPORT
                dst_port = (cast[uint32](da[2]) << 8) \
                         | cast[uint32](da[3])
                dst_ip = (cast[uint32](da[4]) << 24) \
                       | (cast[uint32](da[5]) << 16) \
                       | (cast[uint32](da[6]) << 8) \
                       | cast[uint32](da[7])
            else:
                # No dest_addr — use the connect(2)'d peer.
                dst_ip   = usock_get_peer_addr(rec)
                dst_port = usock_get_peer_port(rec)
                if dst_ip == 0:
                    set_current_errstr("sendto: no peer (connect first)")
                    return ELINUX_NOTCONN
            # #163: stage the datagram payload through a kernel bounce.
            # The bounce (4 KiB) exceeds any UDP-over-Ethernet MTU, so
            # an over-bounce datagram would have been -EMSGSIZE anyway;
            # the cap preserves that answer.
            uds_n: uint64 = a2
            if uds_n > U_L_BOUNCE:
                uds_n = U_L_BOUNCE
            uds_kb: Array[4096, uint8]
            if uds_n != 0:
                if copy_from_user(cast[uint64](&uds_kb[0]), a1,
                                  uds_n) != 0:
                    set_current_errstr("sendto: bad buffer pointer")
                    return ELINUX_EFAULT
            usn: int64 = udp_socket_sendto(uslot, dst_ip,
                                           cast[uint16](dst_port & 0xFFFF),
                                           cast[Ptr[uint8]](&uds_kb[0]),
                                           uds_n)
            if usn == -90:
                set_current_errstr("sendto: datagram too large")
                return ELINUX_MSGSIZE
            if usn == -9:
                return ELINUX_BADF
            if usn < 0:
                set_current_errstr("sendto: transmit failed")
                return ELINUX_NETUNREACH
            return usn
    # §3: SIGPIPE on a send to a peer that has gone away — same
    # contract as write(2). vfs_write's FD_SOCKET_MARK arm returns
    # -EPIPE when the TCP slot is CLOSED / unconnected.
    # #163: bounce-staged through copy_from_user.
    sn: int64 = _u_vfs_write_user(fd, a1, a2)
    if sn == ELINUX_PIPE:
        signal_post(current_idx_get(), SIGPIPE)
    return sn


def _u_recvfrom(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t recvfrom(int sockfd, void *buf, size_t len, int flags,
    #                  struct sockaddr *src_addr, socklen_t *addrlen)
    #
    # SOCK_STREAM: degrades to read(2) (no per-connection peer table).
    #
    # §10 SOCK_DGRAM: receive ONE datagram. If src_addr is supplied,
    # fill it with the datagram's source (sockaddr_in) and set *addrlen
    # to 16. `flags` are ignored.
    fd: int32 = cast[int32](a0)
    # AF_NETLINK: drain queued framed reply bytes (a prior send queued the
    # dump). A blocking recv yields until the dump is available; report the
    # kernel as the source addr (nl_pid 0) when src_addr is supplied.
    nlep_r: int32 = _u_netlink_ep(fd)
    if nlep_r >= 0:
        nlnb: int32 = _u_fd_is_nonblock(fd)
        nrn: int64 = nl_recv(nlep_r, a1, a2)
        if nrn == NL_EAGAIN:
            if nlnb != 0:
                return NL_EAGAIN
            while nrn == NL_EAGAIN:
                yield_to_others()
                nrn = nl_recv(nlep_r, a1, a2)
        if a4 != 0:
            # sockaddr_nl source: family AF_NETLINK, nl_pid 0 (kernel).
            # #163: assembled in kernel space, then copy_to_user'd.
            nka: Array[12, uint8]
            nka[0] = cast[uint8](NL_AF_NETLINK & 0xFF)
            nka[1] = cast[uint8]((NL_AF_NETLINK >> 8) & 0xFF)
            naz: uint64 = 2
            while naz < 12:
                nka[naz] = 0
                naz = naz + 1
            if copy_to_user(a4, cast[uint64](&nka[0]), 12) != 0:
                return ELINUX_EFAULT
            if a5 != 0:
                if put_user_32(12, a5) != 0:
                    return ELINUX_EFAULT
        return nrn
    # AF_UNIX: a DGRAM endpoint dequeues one datagram; a STREAM endpoint
    # degrades to read(2).
    uxep: int32 = _u_afunix_ep(fd)
    if uxep >= 0:
        if afunix_get_type(uxep) == AFU_SOCK_DGRAM:
            uxnb: int32 = _u_fd_is_nonblock(fd)
            urn: int64 = afunix_recvfrom(uxep, a1, a2)
            if urn == AFU_EAGAIN:
                if uxnb != 0:
                    return AFU_EAGAIN
                while urn == AFU_EAGAIN:
                    yield_to_others()
                    urn = afunix_recvfrom(uxep, a1, a2)
            # AF_UNIX datagrams carry no useful src name here; zero the
            # caller's addrlen so it reads no uninitialised bytes.
            if a4 != 0:
                if a5 != 0:
                    if put_user_32(0, a5) != 0:         # #163
                        return ELINUX_EFAULT
            return urn
        # STREAM recvfrom degrades to read(2) — route via _u_read.
        if a4 != 0:
            if a5 != 0:
                if put_user_32(0, a5) != 0:             # #163
                    return ELINUX_EFAULT
        return _u_read(a0, a1, a2, 0, 0, 0)
    if vfs_fd_is_socket(fd) == 0:
        return ELINUX_BADF
    rec: int32 = usock_record_for_fdbuf(vfs_socket_fd_get_record(fd))
    if usock_valid(rec) != 0:
        if usock_get_type(rec) == USOCK_SOCK_DGRAM:
            uslot: int32 = usock_get_tcp_slot(rec)
            src_ip:   uint32 = 0
            src_port: uint16 = 0
            # #163: receive into a kernel bounce, then copy_to_user.
            udr_cap: uint64 = a2
            if udr_cap > U_L_BOUNCE:
                udr_cap = U_L_BOUNCE
            udr_kb: Array[4096, uint8]
            urn: int64 = udp_socket_recvfrom(
                uslot, cast[Ptr[uint8]](&udr_kb[0]), udr_cap, 500,
                cast[Ptr[uint32]](&src_ip),
                cast[Ptr[uint16]](&src_port))
            if urn == -9:
                return ELINUX_BADF
            if urn == -11:
                # Timed out with no datagram — would-block.
                return ELINUX_AGAIN
            if urn < 0:
                # A latched ICMP error (port-unreachable) surfaced as
                # the negative errno itself.
                return urn
            # #163: land the datagram bytes at the user buffer.
            urn = _u_copyout_rc(a1, &udr_kb[0], urn)
            if urn < 0:
                return urn
            # Fill the source sockaddr_in out-param if requested —
            # assembled in kernel space, then copy_to_user'd (#163).
            if a4 != 0:
                ska: Array[16, uint8]
                ska[0] = cast[uint8](USOCK_AF_INET & 0xFF)
                ska[1] = cast[uint8]((USOCK_AF_INET >> 8) & 0xFF)
                ska[2] = cast[uint8]((cast[uint32](src_port) >> 8) & 0xFF)
                ska[3] = cast[uint8](cast[uint32](src_port) & 0xFF)
                ska[4] = cast[uint8]((src_ip >> 24) & 0xFF)
                ska[5] = cast[uint8]((src_ip >> 16) & 0xFF)
                ska[6] = cast[uint8]((src_ip >> 8) & 0xFF)
                ska[7] = cast[uint8](src_ip & 0xFF)
                z: uint64 = 8
                while z < 16:
                    ska[z] = 0
                    z = z + 1
                if copy_to_user(a4, cast[uint64](&ska[0]), 16) != 0:
                    return ELINUX_EFAULT
                if a5 != 0:
                    if put_user_32(16, a5) != 0:
                        return ELINUX_EFAULT
            return urn
    if a4 != 0:
        if a5 != 0:
            if put_user_32(0, a5) != 0:                 # #163
                return ELINUX_EFAULT
    # SOCK_STREAM recvfrom degrades to read(2) — route through _u_read
    # so the §5 O_NONBLOCK path applies (a non-blocking stream socket's
    # would-block recv must return -EAGAIN, not yield-block).
    return _u_read(a0, a1, a2, 0, 0, 0)


# =====================================================================
# sendmsg(2) / recvmsg(2) + SCM_RIGHTS fd passing
# =====================================================================
#
# Declared long ago (SYS_sendmsg=46 / SYS_recvmsg=47) but never dispatched
# → they hit -ENOSYS. The Wayland-passthrough track (docs/wayland_
# passthrough_design.md §4) needs them to pass a wl_shm pool fd (a memfd)
# from a Linux-ns client to the compositor over an AF_UNIX socket in an
# SCM_RIGHTS ancillary message — so the SAME shared-memory pages are
# visible on both ends.
#
# SCOPE (de-risk spike): AF_UNIX SOCK_STREAM carries the data iov(s) over
# the byte ring AND, for a SOL_SOCKET/SCM_RIGHTS control message, conducts
# each passed fd's tmpfs/memfd BACKING SLOT to the peer (afunix_scm_*). On
# recvmsg the peer installs a FRESH fd bound to that same slot
# (vfs_install_tmpfs_slot_fd) — both fds then map the same physical frames
# (tmpfs MAP_SHARED coherence). A non-AF_UNIX socket degrades to a plain
# gather-write / scatter-read of the data iovs (control ignored: only the
# AF_UNIX conduit carries fds in this shim). LIMITATIONS: only memfd/tmpfs-
# backed fds can be passed (a Wayland wl_shm pool always is); a single
# leading cmsghdr is parsed; fds are associated with the message, not a
# byte offset (fine for one message at a time).

# struct msghdr x86_64 field offsets.
MSGH_NAME:       uint64 = 0
MSGH_NAMELEN:    uint64 = 8
MSGH_IOV:        uint64 = 16
MSGH_IOVLEN:     uint64 = 24
MSGH_CONTROL:    uint64 = 32
MSGH_CONTROLLEN: uint64 = 40
MSGH_FLAGS:      uint64 = 48
# struct cmsghdr: cmsg_len(u64)@0, cmsg_level(u32)@8, cmsg_type(u32)@12,
# data (CMSG_ALIGN(sizeof(cmsghdr)) == 16) @16.
CMSG_HDR_LEN:    uint64 = 16
SCM_SOL_SOCKET:  uint32 = 1
SCM_RIGHTS_TYPE: uint32 = 1


def _u_scm_align8(n: uint64) -> uint64:
    return (n + 7) & ~cast[uint64](7)


def _u_afunix_send_all(uxep: int32, fd: int32, ubuf: uint64,
                       ulen: uint64, force_nb: int32) -> int64:
    # Send every byte of [ubuf, ubuf+ulen) into the AF_UNIX stream peer,
    # blocking (cooperative yield) on a full peer ring unless the fd is
    # non-blocking OR the caller forces non-blocking (MSG_DONTWAIT).
    # Returns the byte count sent (>0), 0 for a zero-length buffer, or a
    # negative errno (EPIPE on a dead peer). On a would-block with progress
    # already made, returns the partial count.
    done: uint64 = 0
    while done < ulen:
        n: int64 = afunix_send_stream(uxep, ubuf + done, ulen - done)
        if n == AFU_EAGAIN:
            if _u_fd_is_nonblock(fd) != 0 or force_nb != 0:
                if done > 0:
                    return cast[int64](done)
                return AFU_EAGAIN
            # The peer ring is full. If the peer is the in-kernel Wayland
            # server, it is drained ONLY from a client syscall context
            # (wayland_pump) — never from a separate task — so a blocking
            # send that fills the ring would spin here forever while the
            # server never gets to read it. This is exactly how a real
            # toytoolkit client (weston-terminal) wedged: its window-setup +
            # first-frame request batch exceeds the 4 KiB ring, sendmsg
            # blocks, and with no pump the server can't consume the batch
            # (deadlock; weston-simple-shm never hit it — tiny batches).
            # Reactively pump the server here (mirror of the recvmsg block
            # loop) so it consumes the ring and frees space before we yield.
            wayland_pump()
            yield_to_others()
        elif n < 0:
            if done > 0:
                return cast[int64](done)
            return n
        else:
            done = done + cast[uint64](n)
    return cast[int64](done)


def _u_sendmsg_sockpair(fd: int32, sp_slot: int32, sp_dir: int32,
                        iovp: uint64, iovn: uint64,
                        ctl: uint64, ctllen: uint64,
                        snd_dontwait: int32, snd_nosignal: int32) -> int64:
    # sendmsg over a socketpair() channel: conduct any SCM_RIGHTS fds to
    # the peer end's SCM queue (via vfs "SCM tokens"), THEN gather-write
    # the data iovs. This is the Chromium/Mozilla IPC transport — the
    # parent passes channel/pipe/eventfd fds to a child over the inherited
    # socketpair, so dropping the control here strands the child.
    if ctl != 0 and ctllen >= CMSG_HDR_LEN:
        c_len:   Array[1, uint64]
        c_level: Array[1, uint32]
        c_type:  Array[1, uint32]
        if get_user_64(ctl + 0, &c_len[0]) != 0:
            return ELINUX_EFAULT
        if get_user_32(ctl + 8, &c_level[0]) != 0:
            return ELINUX_EFAULT
        if get_user_32(ctl + 12, &c_type[0]) != 0:
            return ELINUX_EFAULT
        if c_level[0] == SCM_SOL_SOCKET and c_type[0] == SCM_RIGHTS_TYPE:
            if c_len[0] < CMSG_HDR_LEN or c_len[0] > ctllen:
                return ELINUX_INVAL
            nfds: uint64 = (c_len[0] - CMSG_HDR_LEN) / 4
            fi: uint64 = 0
            while fi < nfds:
                pfd: Array[1, uint32]
                if get_user_32(ctl + CMSG_HDR_LEN + fi * 4, &pfd[0]) != 0:
                    return ELINUX_EFAULT
                tok: int32 = vfs_scm_capture_fd(cast[int32](pfd[0]))
                if tok < 0:
                    set_current_errstr("sendmsg: SCM_RIGHTS fd not passable")
                    return ELINUX_INVAL
                sr: int32 = sockpair_scm_send(sp_slot, sp_dir, tok)
                if sr != 0:
                    vfs_scm_release_token(tok)
                    if sr == -32:
                        if snd_nosignal == 0:
                            signal_post(current_idx_get(), SIGPIPE)
                        return ELINUX_PIPE
                    return ELINUX_INVAL              # SCM queue full
                fi = fi + 1
    # Gather-write the data iovs over the socketpair ring (via _u_write,
    # which routes DEV_SOCKETPAIR fds through sockpair_write_blocking).
    total: int64 = 0
    di: uint64 = 0
    while di < iovn:
        ib: Array[1, uint64]
        il: Array[1, uint64]
        if get_user_64(iovp + di * 16, &ib[0]) != 0:
            return ELINUX_EFAULT
        if get_user_64(iovp + di * 16 + 8, &il[0]) != 0:
            return ELINUX_EFAULT
        if il[0] > 0:
            gw: int64 = _u_write(cast[uint64](fd), ib[0], il[0], 0, 0, 0)
            if gw == ELINUX_PIPE:
                if snd_nosignal == 0:
                    signal_post(current_idx_get(), SIGPIPE)
            if gw < 0:
                if total > 0:
                    return total
                return gw
            total = total + gw
        di = di + 1
    return total


def _u_sendmsg(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t sendmsg(int fd, const struct msghdr *msg, int flags)
    fd: int32 = cast[int32](a0)
    umsg: uint64 = a1
    # MSG_DONTWAIT (0x40): a per-CALL non-blocking send. real libwayland's
    # wl_connection_flush relies on this flag (NOT an O_NONBLOCK fd) to get
    # EAGAIN on a full socket so it can add EPOLLOUT and retry via poll —
    # exactly mirroring the recvmsg MSG_DONTWAIT handling. Ignoring it makes
    # our send BLOCK inside the flush, so a toolkit that flushes a request
    # batch larger than the peer ring wedges (its event loop never gets to
    # poll for writability + drain the socket). Honour it.
    snd_dontwait: int32 = 0
    if (a2 & 0x40) != 0:
        snd_dontwait = 1
    # MSG_NOSIGNAL (0x4000): the caller has asked NOT to be sent a SIGPIPE
    # on a broken-peer send; it wants the -EPIPE errno instead. libxcb
    # ALWAYS sends X-protocol with MSG_NOSIGNAL (it handles the write error
    # itself). Honour it, or a transient EPIPE kills the X client (xdpyinfo
    # -> code 141) instead of surfacing as an I/O error it can cope with.
    snd_nosignal: int32 = 0
    if (a2 & 0x4000) != 0:
        snd_nosignal = 1
    if umsg == 0:
        return ELINUX_EFAULT
    m_iov:     Array[1, uint64]
    m_iovlen:  Array[1, uint64]
    m_ctl:     Array[1, uint64]
    m_ctllen:  Array[1, uint64]
    if get_user_64(umsg + MSGH_IOV, &m_iov[0]) != 0:
        return ELINUX_EFAULT
    if get_user_64(umsg + MSGH_IOVLEN, &m_iovlen[0]) != 0:
        return ELINUX_EFAULT
    if get_user_64(umsg + MSGH_CONTROL, &m_ctl[0]) != 0:
        return ELINUX_EFAULT
    if get_user_64(umsg + MSGH_CONTROLLEN, &m_ctllen[0]) != 0:
        return ELINUX_EFAULT
    iovp:    uint64 = m_iov[0]
    iovn:    uint64 = m_iovlen[0]
    ctl:     uint64 = m_ctl[0]
    ctllen:  uint64 = m_ctllen[0]

    uxep: int32 = _u_afunix_ep(fd)
    if uxep < 0 or afunix_get_type(uxep) != AFU_SOCK_STREAM:
        # Not an AF_UNIX-socket stream endpoint. A socketpair() channel is
        # the OTHER AF_UNIX stream shape (an FD_CHAN_MARK DEV_SOCKETPAIR
        # fd, not an afunix ep) and IS the Chromium/Mozilla IPC transport
        # that carries SCM_RIGHTS fd passes. Route those here so the child
        # bootstrap's socketpair/pipe/eventfd passes don't silently vanish;
        # every other fd type degrades to a bare gather write (control
        # dropped — no conduit).
        sp_pkd: int64 = vfs_fd_sockpair_packed(fd)
        if sp_pkd >= 0:
            return _u_sendmsg_sockpair(fd,
                sockpair_unpack_slot(cast[uint64](sp_pkd)),
                sockpair_unpack_dir(cast[uint64](sp_pkd)),
                iovp, iovn, ctl, ctllen, snd_dontwait, snd_nosignal)
        gtotal: int64 = 0
        gi: uint64 = 0
        while gi < iovn:
            ib: Array[1, uint64]
            il: Array[1, uint64]
            if get_user_64(iovp + gi * 16, &ib[0]) != 0:
                return ELINUX_EFAULT
            if get_user_64(iovp + gi * 16 + 8, &il[0]) != 0:
                return ELINUX_EFAULT
            if il[0] > 0:
                gw: int64 = _u_write(cast[uint64](fd), ib[0], il[0], 0, 0, 0)
                if gw < 0:
                    if gtotal > 0:
                        return gtotal
                    return gw
                gtotal = gtotal + gw
            gi = gi + 1
        return gtotal

    # --- 1) SCM_RIGHTS control: conduct each passed fd's backing to the
    #        peer via a vfs "SCM token" (any fd type — socketpair/pipe
    #        endpoint, eventfd/timerfd/signalfd, regular file, tmpfs/memfd
    #        — not just memfd, so a real multiprocess app's bootstrap fds
    #        survive). vfs_scm_capture_fd takes the backing reference. -----
    if ctl != 0 and ctllen >= CMSG_HDR_LEN:
        c_len:   Array[1, uint64]
        c_level: Array[1, uint32]
        c_type:  Array[1, uint32]
        if get_user_64(ctl + 0, &c_len[0]) != 0:
            return ELINUX_EFAULT
        if get_user_32(ctl + 8, &c_level[0]) != 0:
            return ELINUX_EFAULT
        if get_user_32(ctl + 12, &c_type[0]) != 0:
            return ELINUX_EFAULT
        if c_level[0] == SCM_SOL_SOCKET and c_type[0] == SCM_RIGHTS_TYPE:
            if c_len[0] < CMSG_HDR_LEN or c_len[0] > ctllen:
                return ELINUX_INVAL
            nfds: uint64 = (c_len[0] - CMSG_HDR_LEN) / 4
            fi: uint64 = 0
            while fi < nfds:
                pfd: Array[1, uint32]
                if get_user_32(ctl + CMSG_HDR_LEN + fi * 4, &pfd[0]) != 0:
                    return ELINUX_EFAULT
                tok: int32 = vfs_scm_capture_fd(cast[int32](pfd[0]))
                if tok < 0:
                    set_current_errstr("sendmsg: SCM_RIGHTS fd not passable")
                    return ELINUX_INVAL
                sr: int64 = afunix_scm_send(uxep, tok)
                if sr != 0:
                    vfs_scm_release_token(tok)     # drop the ref we took
                    return sr
                fi = fi + 1

    # --- 2) data: gather-send the iovs into the peer's byte ring --------
    total: int64 = 0
    di: uint64 = 0
    while di < iovn:
        ib2: Array[1, uint64]
        il2: Array[1, uint64]
        if get_user_64(iovp + di * 16, &ib2[0]) != 0:
            return ELINUX_EFAULT
        if get_user_64(iovp + di * 16 + 8, &il2[0]) != 0:
            return ELINUX_EFAULT
        if il2[0] > 0:
            sn: int64 = _u_afunix_send_all(uxep, fd, ib2[0], il2[0],
                                           snd_dontwait)
            if sn == ELINUX_PIPE:
                if snd_nosignal == 0:
                    signal_post(current_idx_get(), SIGPIPE)
            if sn < 0:
                if total > 0:
                    return total
                return sn
            total = total + sn
        di = di + 1
    # Wayland reactive pump: the client just flushed protocol bytes (and
    # any wl_shm pool fd via the SCM conduit) to the server endpoint —
    # parse them and emit replies before the client's next read/poll.
    wayland_pump()
    return total


def _u_recvmsg_sockpair(fd: int32, sp_slot: int32, sp_dir: int32,
                        umsg: uint64, iovp: uint64, iovn: uint64,
                        ctl: uint64, ctllen: uint64, flags: uint64) -> int64:
    # recvmsg over a socketpair() channel: block until data is readable OR
    # a passed fd is pending OR the peer hung up (unless MSG_DONTWAIT /
    # O_NONBLOCK), then scatter-read the data and install any SCM_RIGHTS
    # tokens into the control buffer. The receive half of the
    # Chromium/Mozilla IPC transport.
    nb: int32 = _u_fd_is_nonblock(fd)
    if (flags & 0x40) != 0:
        nb = 1
    while sockpair_readable(sp_slot, sp_dir) == 0:
        if sockpair_scm_pending(sp_slot, sp_dir) > 0:
            break                                   # fds arrived without data
        if sockpair_peer_alive(sp_slot, sp_dir) == 0:
            break                                   # peer closed -> EOF (0)
        if nb != 0:
            return ELINUX_AGAIN
        yield_to_others()

    # --- 1) scatter-read available data into the iovs -------------------
    total: int64 = 0
    di: uint64 = 0
    while di < iovn:
        ib: Array[1, uint64]
        il: Array[1, uint64]
        if get_user_64(iovp + di * 16, &ib[0]) != 0:
            return ELINUX_EFAULT
        if get_user_64(iovp + di * 16 + 8, &il[0]) != 0:
            return ELINUX_EFAULT
        if il[0] == 0:
            di = di + 1
        elif sockpair_readable(sp_slot, sp_dir) == 0:
            di = iovn                               # ring drained
        else:
            rr: int64 = _u_read(cast[uint64](fd), ib[0], il[0], 0, 0, 0)
            if rr <= 0:
                di = iovn                           # EOF / would-block
            else:
                total = total + rr
                if cast[uint64](rr) < il[0]:
                    di = iovn                       # ring drained
                else:
                    di = di + 1

    # --- 2) install any passed fds into a single SCM_RIGHTS cmsg --------
    ctl_written: uint64 = 0
    if ctl != 0 and ctllen >= CMSG_HDR_LEN \
            and sockpair_scm_pending(sp_slot, sp_dir) > 0:
        maxfds: uint64 = (ctllen - CMSG_HDR_LEN) / 4
        nfds: uint64 = 0
        while nfds < maxfds:
            tok: int32 = sockpair_scm_recv(sp_slot, sp_dir)
            if tok < 0:
                nfds = maxfds                       # queue drained
            else:
                newfd: int32 = vfs_scm_install_token(tok)
                if newfd < 0:
                    vfs_scm_release_token(tok)
                    nfds = maxfds
                else:
                    if put_user_32(cast[uint32](newfd),
                                   ctl + CMSG_HDR_LEN + nfds * 4) != 0:
                        return ELINUX_EFAULT
                    nfds = nfds + 1
        if nfds > 0:
            cmsg_len: uint64 = CMSG_HDR_LEN + nfds * 4
            if put_user_64(cmsg_len, ctl + 0) != 0:
                return ELINUX_EFAULT
            if put_user_32(SCM_SOL_SOCKET, ctl + 8) != 0:
                return ELINUX_EFAULT
            if put_user_32(SCM_RIGHTS_TYPE, ctl + 12) != 0:
                return ELINUX_EFAULT
            ctl_written = _u_scm_align8(cmsg_len)

    put_user_64(ctl_written, umsg + MSGH_CONTROLLEN)
    put_user_32(0, umsg + MSGH_FLAGS)
    return total


def _u_recvmsg(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t recvmsg(int fd, struct msghdr *msg, int flags)
    fd: int32 = cast[int32](a0)
    umsg: uint64 = a1
    if umsg == 0:
        return ELINUX_EFAULT
    m_iov:    Array[1, uint64]
    m_iovlen: Array[1, uint64]
    m_ctl:    Array[1, uint64]
    m_ctllen: Array[1, uint64]
    if get_user_64(umsg + MSGH_IOV, &m_iov[0]) != 0:
        return ELINUX_EFAULT
    if get_user_64(umsg + MSGH_IOVLEN, &m_iovlen[0]) != 0:
        return ELINUX_EFAULT
    if get_user_64(umsg + MSGH_CONTROL, &m_ctl[0]) != 0:
        return ELINUX_EFAULT
    if get_user_64(umsg + MSGH_CONTROLLEN, &m_ctllen[0]) != 0:
        return ELINUX_EFAULT
    iovp:   uint64 = m_iov[0]
    iovn:   uint64 = m_iovlen[0]
    ctl:    uint64 = m_ctl[0]
    ctllen: uint64 = m_ctllen[0]

    uxep: int32 = _u_afunix_ep(fd)
    if uxep < 0 or afunix_get_type(uxep) != AFU_SOCK_STREAM:
        # A socketpair() channel carries SCM_RIGHTS fds too — deliver them
        # (the receive half of the Chromium/Mozilla IPC transport). Every
        # other fd type degrades to a scatter read with no ancillary fds.
        sp_pkd: int64 = vfs_fd_sockpair_packed(fd)
        if sp_pkd >= 0:
            return _u_recvmsg_sockpair(fd,
                sockpair_unpack_slot(cast[uint64](sp_pkd)),
                sockpair_unpack_dir(cast[uint64](sp_pkd)),
                umsg, iovp, iovn, ctl, ctllen, a2)
        # Not an AF_UNIX stream — degrade to a scatter read of the data
        # iovs via read(2) (no ancillary fds delivered). Report an empty
        # control buffer + zeroed flags.
        rtotal: int64 = 0
        ri2: uint64 = 0
        while ri2 < iovn:
            ib: Array[1, uint64]
            il: Array[1, uint64]
            if get_user_64(iovp + ri2 * 16, &ib[0]) != 0:
                return ELINUX_EFAULT
            if get_user_64(iovp + ri2 * 16 + 8, &il[0]) != 0:
                return ELINUX_EFAULT
            if il[0] > 0:
                rr: int64 = _u_read(cast[uint64](fd), ib[0], il[0], 0, 0, 0)
                if rr < 0:
                    if rtotal > 0:
                        break
                    return rr
                rtotal = rtotal + rr
                if cast[uint64](rr) < il[0]:
                    ri2 = iovn                      # short read — stop
                else:
                    ri2 = ri2 + 1
            else:
                ri2 = ri2 + 1
        if ctl != 0:
            put_user_64(0, umsg + MSGH_CONTROLLEN)
        put_user_32(0, umsg + MSGH_FLAGS)
        return rtotal

    # Wayland reactive pump: flush any server work so a client that reads
    # without an intervening flush still sees pending events.
    wayland_pump()
    # Block until data is readable OR a passed fd is pending OR EOF,
    # unless the fd is non-blocking. A recvmsg with MSG_DONTWAIT (0x40)
    # in `flags` (a2) is per-CALL non-blocking even when the fd itself
    # was never fcntl'd O_NONBLOCK — real libwayland's wl_connection_read
    # relies on the MSG_DONTWAIT flag (NOT an O_NONBLOCK fd) to probe the
    # socket, so ignoring it makes libwayland's post-read drain probe
    # BLOCK forever and wedges every real Wayland client right after it
    # reads the first roundtrip reply.
    nb: int32 = _u_fd_is_nonblock(fd)
    if (a2 & 0x40) != 0:
        nb = 1
    while afunix_can_read(uxep) == 0:
        if afunix_scm_pending(uxep) > 0:
            break                                   # fds arrived without data
        # Phase 2: a Wayland client blocks here in recvmsg while input is
        # routed to its surface window ASYNCHRONOUSLY (mouse router / kbd
        # pump, timer context). Re-pump on each wake so pending /event +
        # /keys lines translate into wl_seat events that make the socket
        # readable and unblock this read — no busy protocol traffic needed.
        wayland_pump()
        if afunix_can_read(uxep) != 0:
            break
        if nb != 0:
            return ELINUX_AGAIN
        yield_to_others()

    # --- 1) scatter-read available data into the iovs -------------------
    total: int64 = 0
    di: uint64 = 0
    while di < iovn:
        ib2: Array[1, uint64]
        il2: Array[1, uint64]
        if get_user_64(iovp + di * 16, &ib2[0]) != 0:
            return ELINUX_EFAULT
        if get_user_64(iovp + di * 16 + 8, &il2[0]) != 0:
            return ELINUX_EFAULT
        if il2[0] == 0:
            di = di + 1
        else:
            rn: int64 = afunix_recv_stream(uxep, ib2[0], il2[0])
            if rn == AFU_EAGAIN:
                di = iovn                           # ring drained for now
            elif rn <= 0:
                di = iovn                           # EOF / error
            else:
                total = total + rn
                if cast[uint64](rn) < il2[0]:
                    di = iovn                       # ring drained
                else:
                    di = di + 1

    # --- 2) install any passed fds into a single SCM_RIGHTS cmsg --------
    ctl_written: uint64 = 0
    if ctl != 0 and ctllen >= CMSG_HDR_LEN and afunix_scm_pending(uxep) > 0:
        maxfds: uint64 = (ctllen - CMSG_HDR_LEN) / 4
        nfds: uint64 = 0
        while nfds < maxfds:
            tok: int32 = afunix_scm_recv(uxep)
            if tok < 0:
                nfds = maxfds                       # queue drained
            else:
                newfd: int32 = vfs_scm_install_token(tok)
                if newfd < 0:
                    # Could not install — drop the sender's enqueue ref and
                    # stop (leave remaining fds queued for a later recvmsg).
                    vfs_scm_release_token(tok)
                    nfds = maxfds
                else:
                    if put_user_32(cast[uint32](newfd),
                                   ctl + CMSG_HDR_LEN + nfds * 4) != 0:
                        return ELINUX_EFAULT
                    nfds = nfds + 1
        if nfds > 0:
            cmsg_len: uint64 = CMSG_HDR_LEN + nfds * 4
            if put_user_64(cmsg_len, ctl + 0) != 0:
                return ELINUX_EFAULT
            if put_user_32(SCM_SOL_SOCKET, ctl + 8) != 0:
                return ELINUX_EFAULT
            if put_user_32(SCM_RIGHTS_TYPE, ctl + 12) != 0:
                return ELINUX_EFAULT
            ctl_written = _u_scm_align8(cmsg_len)

    put_user_64(ctl_written, umsg + MSGH_CONTROLLEN)
    put_user_32(0, umsg + MSGH_FLAGS)
    return total


def _u_poll_fd_revents(fd: int32, events: uint32) -> uint32:
    # The revents for one pollfd entry: probe the fd's real readiness
    # (non-destructive, via vfs_fd_poll) and intersect with the
    # requested `events`. POLLERR / POLLHUP / POLLNVAL are reported
    # unconditionally (Linux semantics — the caller cannot mask them
    # out). A signalfd needs the caller's pending-signal word, which
    # vfs.ad cannot see — handled here in the Layer-2 shim.
    if vfs_fd_is_open(fd) == 0:
        return POLLNVAL_BIT
    ready: uint32 = vfs_fd_poll(fd)
    pf_marker: uint32 = vfs_fd_marker(fd)
    if pf_marker == FD_SIGNALFD_MARK:
        ss: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
        if usfd_match(ss, signal_pending(current_idx_get())) != 0:
            ready = ready | POLLIN_BIT
    # A pidfd becomes POLLIN-readable once its target process exits. vfs
    # has no view of the (task,fd)->pid table, so the readiness override
    # is answered here in the Layer-2 shim — and the default vfs_fd_poll
    # POLLOUT bit for an unknown marker must be cleared (a pidfd is never
    # writable).
    if pf_marker == FD_PIDFD_MARK:
        ready = 0
        pf_pid: int64 = upidfd_get(current_idx_get(), fd)
        if pf_pid >= 0:
            if upidfd_target_readable(cast[uint64](pf_pid)) != 0:
                ready = ready | POLLIN_BIT
    # AF_NETLINK: a netlink fd is POLLIN-readable once a dump reply is
    # queued (after the caller's send), and always POLLOUT-writable (a
    # request can be sent any time). vfs has no view of the netlink rx
    # ring, so the readiness is answered here in the Layer-2 shim.
    pf_nlep: int32 = _u_netlink_ep(fd)
    if pf_nlep >= 0:
        ready = POLLOUT_BIT
        if nl_can_read(pf_nlep) != 0:
            ready = ready | POLLIN_BIT
    # AF_UNIX stream: readiness comes from the afunix endpoint's rx ring
    # (u_unixsock.ad), NOT the TCP/usock record the DEV_SOCKET vfs arm
    # decodes. An AF_UNIX fd_buf carries the AFU_FDBUF_TAG, so
    # usock_record_for_fdbuf yields a bogus (non-negative) record and
    # vfs_fd_poll's socket arm can NEVER report POLLIN for it — which
    # wedges every real libwayland client: it polls its display fd for
    # POLLIN after get_registry and blocks forever because the queued
    # reply (globals + wl_callback.done) is invisible to poll. Answer
    # AF_UNIX readiness here in the Layer-2 shim (where afunix is
    # visible), mirroring the recvmsg model. Pump the in-kernel Wayland
    # server first so a client polling for the next protocol event
    # (registry globals, xdg configure, frame callback, routed input)
    # sees bytes the server just produced.
    pf_uxep: int32 = _u_afunix_ep(fd)
    if pf_uxep >= 0:
        wayland_pump()
        ready = POLLOUT_BIT                  # afunix tx never blocks here
        if afunix_can_read(pf_uxep) != 0:
            ready = ready | POLLIN_BIT
        # A LISTENING socket with a pending connection is POLLIN-readable
        # (accept(2) would not block). Without this a userland server
        # (Xwayland) polling/epolling its listen fd never wakes to accept a
        # connecting client (xdpyinfo), so the client stalls then resets.
        if afunix_accept_ready(pf_uxep) != 0:
            ready = ready | POLLIN_BIT
        # POLLHUP ONLY for a connected stream whose peer hung up — NEVER for
        # a passive listener / unconnected socket. The old test
        # (ep_connected==0 && rx_count==0) spuriously fired POLLHUP on every
        # listen fd (ep_connected is 0 for a LISTENING ep), wedging the X
        # server's accept loop.
        if afunix_peer_hung(pf_uxep) != 0:
            ready = ready | POLLHUP_BIT
    # The bits the caller may request (POLLIN/PRI/OUT) are masked by
    # `events`; the error bits always pass through.
    requestable: uint32 = events | POLLERR_BIT | POLLHUP_BIT \
                          | POLLNVAL_BIT
    return ready & requestable


def _u_poll_scan(base: uint64, nfds: uint64) -> int64:
    # One pass over the pollfd array — fill every entry's revents and
    # return the count of entries that became ready.
    ready: int64 = 0
    i: uint64 = 0
    while i < nfds:
        entry: uint64 = base + i * POLLFD_SIZE
        # SMAP: the pollfd[] array lives in user memory (US=1). Bracket the
        # CPL=0 reads of fd/events and the write of revents with STAC/CLAC
        # (no-ops when CR4.SMAP is off).
        _ua_stac()
        fd:     int32  = cast[Ptr[int32]](entry)[0]
        events: uint32 = cast[uint32](cast[Ptr[uint16]](entry + 4)[0])
        _ua_clac()
        revents: uint32 = 0
        if fd >= 0:
            revents = _u_poll_fd_revents(fd, events)
        _ua_stac()
        cast[Ptr[uint16]](entry + 6)[0] = cast[uint16](revents)
        _ua_clac()
        if revents != 0:
            ready = ready + 1
        i = i + 1
    return ready


def _u_poll(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int poll(struct pollfd *fds, nfds_t nfds, int timeout)
    #
    # §5: a real readiness-driven poll(2). Each pollfd is probed via
    # the non-destructive vfs_fd_poll readiness model (sockets, pipes,
    # eventfd/timerfd/signalfd, regular files). `timeout` is honoured:
    # -1 blocks (bounded — see UEP_WAIT_MAX_JIFFIES), 0 is a single
    # immediate pass, >0 is milliseconds. negative fds are skipped.
    if a0 == 0 and a1 != 0:
        return ELINUX_INVAL
    base: uint64 = a0
    nfds: uint64 = a1
    # Bound the user-supplied nfds. Without this a huge (or maliciously
    # large) nfds walks arbitrary memory entry-by-entry (info-leak /
    # fault) and i*POLLFD_SIZE can overflow. Mirror the limit select(2)
    # enforces in _u_select_common (nfds > 1024 => EINVAL). ppoll(2)
    # delegates here, so this one check covers both poll and ppoll.
    if nfds > 1024:
        return ELINUX_INVAL
    timeout_ms: int64 = cast[int64](a2)
    deadline: uint64 = 0
    bounded: int32 = 1
    start: uint64 = get_jiffies()
    if timeout_ms < 0:
        deadline = start + UEP_WAIT_MAX_JIFFIES
    elif timeout_ms == 0:
        bounded = 0
    else:
        dj: uint64 = (cast[uint64](timeout_ms) * HZ + 999) / 1000
        if dj > UEP_WAIT_MAX_JIFFIES:
            dj = UEP_WAIT_MAX_JIFFIES
        deadline = start + dj
    while True:
        ready: int64 = _u_poll_scan(base, nfds)
        if ready > 0:
            return ready
        if bounded == 0:
            return 0
        if get_jiffies() >= deadline:
            return 0
        yield_to_others()


def _u_ppoll(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int ppoll(struct pollfd *fds, nfds_t nfds,
    #           const struct timespec *tmo, const sigset_t *sigmask,
    #           size_t sigsetsize)
    #   a0 = fds, a1 = nfds, a2 = timespec*, a3 = sigmask, a4 = setsize.
    # The poll(2) variant systemd/glibc event loops prefer (it takes a
    # nanosecond timespec and an atomically-applied signal mask). We
    # convert the timespec to poll(2)'s millisecond timeout and delegate
    # to _u_poll's readiness scan; a NULL timespec means "block" (-1 ms).
    # The sigmask is not applied — Hamnix delivers no async signals during
    # a kernel-cooperative poll loop, so there's no window to mask, and
    # the readiness scan returns promptly either way.
    timeout_ms: uint64 = cast[uint64](-1)              # NULL tmo => block
    if a2 != 0:
        # #163: fetch the user timespec through the page tables.
        ts_sec:  uint64 = 0
        ts_nsec: uint64 = 0
        if get_user_64(a2, &ts_sec) != 0:
            return ELINUX_EFAULT
        if get_user_64(a2 + 8, &ts_nsec) != 0:
            return ELINUX_EFAULT
        # Round nanoseconds up to whole milliseconds (poll's granularity).
        timeout_ms = ts_sec * 1000 + (ts_nsec + 999999) / 1000000
    return _u_poll(a0, a1, timeout_ms, 0, 0, 0)


# --- #165: sched affinity / getcpu / membarrier -------------------
#
# sched_setaffinity/getaffinity store and ENFORCE a real per-task CPU
# affinity bitmask in the task struct (cpu_affinity). The native per-CPU-
# runqueue scheduler honors it: placement, work-steal, and the deferred
# migration of a preempted task all keep a task on a CPU whose bit is set
# (see kernel/sched/core.ad sched_set_affinity / sched_affinity_pick_cpu /
# sched_cpu_allowed). pid==0 resolves to the calling task; a nonzero pid is
# looked up by pid. The user mask pointer is validated via copy_to/from_user.

def _u_sched_getaffinity(a0: uint64, a1: uint64, a2: uint64,
                         a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long sched_getaffinity(pid_t pid, size_t cpusetsize,
    #                        cpu_set_t *mask)
    #   a0 = pid, a1 = cpusetsize (bytes), a2 = mask.
    # Write the stored per-task affinity mask into the user buffer (low
    # bytes first, the rest zero-filled) and return the number of bytes
    # written (glibc uses the return value to size its CPU_SETSIZE loop).
    if a2 == 0 or a1 == 0:
        return ELINUX_INVAL
    slot: uint64 = 0
    rc: int64 = _u_sched_resolve_slot(a0, &slot)
    if rc != 0:
        return rc
    # Linux returns the task mask intersected with the online-CPU set (never
    # reports offline CPUs); under -smp 1 that is just bit 0.
    mask: uint64 = sched_get_affinity_online(slot)
    n: uint64 = a1
    if n > 128:
        n = 128                                        # cap the buffer fill
    # Build a kernel-side byte image of the mask (8 bytes of real mask,
    # then zero), then copy_to_user it so the user pointer is validated.
    kbuf: Array[128, uint8]
    i: uint64 = 0
    while i < n:
        if i < 8:
            kbuf[i] = cast[uint8]((mask >> (i * 8)) & 0xFF)
        else:
            kbuf[i] = 0
        i = i + 1
    if copy_to_user(a2, cast[uint64](&kbuf[0]), n) != 0:
        return ELINUX_FAULT
    return cast[int64](n)


def _u_sched_setaffinity(a0: uint64, a1: uint64, a2: uint64,
                         a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long sched_setaffinity(pid_t pid, size_t cpusetsize,
    #                        const cpu_set_t *mask)
    #   a0 = pid, a1 = cpusetsize (bytes), a2 = mask.
    # Read the low 8 bytes of the user mask (CPUs 0..63 — far beyond the 16
    # logical CPUs the scheduler tracks), validate via copy_from_user, then
    # apply it. sched_set_affinity stores the mask AND re-homes/marks the
    # task for migration if it currently sits on a now-forbidden CPU. An
    # effective mask with no online CPU is -EINVAL.
    if a2 == 0 or a1 == 0:
        return ELINUX_INVAL
    slot: uint64 = 0
    rc: int64 = _u_sched_resolve_slot(a0, &slot)
    if rc != 0:
        return rc
    # Copy up to 8 mask bytes from userspace (validates the pointer).
    nread: uint64 = a1
    if nread > 8:
        nread = 8
    maskbuf: uint64 = 0
    if copy_from_user(cast[uint64](&maskbuf), a2, nread) != 0:
        return ELINUX_FAULT
    mask: uint64 = maskbuf
    if nread < 8:
        # Only the low `nread` bytes are meaningful; clear the rest.
        keep: uint64 = (cast[uint64](1) << (nread * 8)) - 1
        mask = mask & keep
    ar: int64 = sched_set_affinity(slot, mask)
    if ar < 0:
        return ELINUX_INVAL
    return 0


def _u_getcpu(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getcpu(unsigned *cpu, unsigned *node, struct getcpu_cache *)
    # Single CPU / single NUMA node — report 0 for both. The third arg is
    # an unused legacy cache pointer (ignored since Linux 2.6.24).
    if a0 != 0:
        if put_user_32(0, a0) != 0:                     # #163
            return ELINUX_EFAULT
    if a1 != 0:
        if put_user_32(0, a1) != 0:                     # #163
            return ELINUX_EFAULT
    return 0


def _u_membarrier(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int membarrier(int cmd, unsigned int flags, int cpu_id)
    #   cmd 0 = MEMBARRIER_CMD_QUERY: return the bitmask of supported
    #            commands.
    #   GLOBAL / PRIVATE_EXPEDITED: issue a REAL system-wide memory barrier
    #            (smp_membarrier_broadcast: local mfence + an all-but-self IPI
    #            that drives every other online CPU through a serialising
    #            interrupt entry). The *_REGISTER_* commands are accepted as
    #            successful no-ops — this kernel needs no per-process opt-in
    #            registration before the expedited barrier is usable.
    #
    # The supported-commands bitmask QUERY returns is built from the SAME
    # MB_* bit constants the dispatch below honors, so QUERY can never claim
    # a command the handler does not actually implement.
    MEMBARRIER_CMD_QUERY:                       uint64 = 0
    MEMBARRIER_CMD_GLOBAL:                      uint64 = 1   # bit 0
    MEMBARRIER_CMD_GLOBAL_EXPEDITED:            uint64 = 2   # bit 1
    MEMBARRIER_CMD_REGISTER_GLOBAL_EXPEDITED:   uint64 = 4   # bit 2
    MEMBARRIER_CMD_PRIVATE_EXPEDITED:           uint64 = 8   # bit 3
    MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED:  uint64 = 16  # bit 4
    # Bitmask of every command we honor below. QUERY returns exactly this.
    MB_SUPPORTED: int64 = cast[int64](MEMBARRIER_CMD_GLOBAL
                                      | MEMBARRIER_CMD_GLOBAL_EXPEDITED
                                      | MEMBARRIER_CMD_REGISTER_GLOBAL_EXPEDITED
                                      | MEMBARRIER_CMD_PRIVATE_EXPEDITED
                                      | MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED)
    # No flags / cpu_id modes are modelled — reject any nonzero flags so we
    # never silently ignore a MEMBARRIER_CMD_FLAG_CPU request.
    if a1 != 0:
        return ELINUX_INVAL
    if a0 == MEMBARRIER_CMD_QUERY:
        return MB_SUPPORTED
    if a0 == MEMBARRIER_CMD_GLOBAL \
       or a0 == MEMBARRIER_CMD_GLOBAL_EXPEDITED \
       or a0 == MEMBARRIER_CMD_PRIVATE_EXPEDITED:
        # Real system-wide barrier: local fence + remote serialising IPIs.
        smp_membarrier_broadcast()
        return 0
    if a0 == MEMBARRIER_CMD_REGISTER_GLOBAL_EXPEDITED \
       or a0 == MEMBARRIER_CMD_REGISTER_PRIVATE_EXPEDITED:
        # Registration is a successful no-op (no per-process opt-in needed).
        return 0
    # Unknown command.
    return ELINUX_INVAL


# --- sched_setaffinity / membarrier Linux-ABI self-test ------------------
#
# Gated on /etc/sched-affinity-test (planted exclusively by
# scripts/test_sched_affinity.sh). Drives:
#   * the REAL affinity store + scheduler enforcement (sched_affinity_selftest
#     in kernel/sched/core.ad), and
#   * the REAL _u_membarrier dispatch (QUERY returns a nonzero supported mask
#     that includes the commands we honor; GLOBAL / PRIVATE_EXPEDITED return 0
#     after issuing a real system-wide barrier).
# Prints per-check markers and a terminal "[SCHED_AFFINITY] PASS" / "... FAIL".

def sched_affinity_membarrier_selftest():
    printk_set_level(PRINTK_LEVEL_EMERG)
    failures: int32 = 0

    # --- affinity: real store + scheduler enforcement -----------------
    if sched_affinity_selftest() != 0:
        printk0("[affinity] mask round-trip + scheduler enforcement OK\n")
    else:
        printk0("[affinity] FAIL store/enforcement\n")
        failures = failures + 1

    # --- membarrier QUERY: nonzero supported mask ---------------------
    MEMBARRIER_CMD_QUERY:             uint64 = 0
    MEMBARRIER_CMD_GLOBAL:            uint64 = 1
    MEMBARRIER_CMD_PRIVATE_EXPEDITED: uint64 = 8
    q: int64 = _u_membarrier(MEMBARRIER_CMD_QUERY, 0, 0, 0, 0, 0)
    if q > 0 \
       and (cast[uint64](q) & MEMBARRIER_CMD_GLOBAL) != 0 \
       and (cast[uint64](q) & MEMBARRIER_CMD_PRIVATE_EXPEDITED) != 0:
        printk1("[membarrier] QUERY supported-mask=0x%x OK\n", cast[uint64](q))
    else:
        printk1("[membarrier] FAIL QUERY mask=0x%x\n", cast[uint64](q))
        failures = failures + 1

    # --- membarrier GLOBAL: real barrier, returns 0 -------------------
    g: int64 = _u_membarrier(MEMBARRIER_CMD_GLOBAL, 0, 0, 0, 0, 0)
    if g == 0:
        printk0("[membarrier] GLOBAL barrier OK\n")
    else:
        printk1("[membarrier] FAIL GLOBAL rc=%d\n", cast[uint64](g))
        failures = failures + 1

    # --- membarrier PRIVATE_EXPEDITED: real barrier, returns 0 --------
    p: int64 = _u_membarrier(MEMBARRIER_CMD_PRIVATE_EXPEDITED, 0, 0, 0, 0, 0)
    if p == 0:
        printk0("[membarrier] PRIVATE_EXPEDITED barrier OK\n")
    else:
        printk1("[membarrier] FAIL PRIVATE_EXPEDITED rc=%d\n", cast[uint64](p))
        failures = failures + 1

    if failures == 0:
        printk0("[SCHED_AFFINITY] PASS\n")
    else:
        printk1("[SCHED_AFFINITY] FAIL (%d checks failed)\n",
                cast[uint64](failures))


# =====================================================================
# Pure -ENOSYS stubs
# =====================================================================
#
# These exist only so linux_u_syscall_dispatch has a named handler for
# each syscall it has a number for — keeps the dispatch table readable
# and gives us a single grep target ("_u_unimpl_") when implementing
# any of them. A single shared body would be tempting but separate
# names make printk traces useful.


# SYS_mmap / SYS_munmap / SYS_mprotect / SYS_mremap.
#
# U7..U41 used a flat 256-slot (base, order) table to record every
# mapping; munmap looked up the base, free_pages'd at the stored
# order, and called it done. That model couldn't honour MAP_FIXED
# at arbitrary user-chosen addresses — fine while only static-PIE
# binaries ran, but the U42 dynamic-ELF path showed its limits:
# once ld.so handed off to the application's _start, ANY mmap the
# application issued (glibc-malloc heap-arena fallback, locale
# bringup, getpwuid stub I/O) at a specific addr was effectively
# a no-op the kernel logged as "MAP_FIXED at 0x... not in any
# prior mapping" and the application GP-faulted on next touch.
#
# Replacement (this commit) is a per-task VMA list living on
# TaskStruct.vma_list_head (mm/vma.ad). Each VMA records its own
# (start, end, prot, flags, fd, offset, backing pages + order),
# making mmap / munmap / mprotect honest. The page table is still
# RWX U=1 everywhere from the 4 GiB identity map (per-page prot is
# advisory at the PTE level), but the bookkeeping is now correct
# enough that future per-page mprotect can walk vma_list and install
# the right PTEs without revisiting the syscall surface.
#
# MAP_FIXED semantics:
#   * Fully inside an existing VMA → alias node, aliased pages are
#     filled with file data / zeros; the enclosing VMA still owns
#     the backing pages (ld.so's two-phase DSO load).
#   * Outside any VMA → existing overlapping ranges are silently
#     unmapped (Linux contract); fresh pages allocated at a
#     kernel-picked address (since the identity map means physical
#     == virtual, picking by alloc_pages is fine for our address
#     range).

# MAP_* flag bits from <bits/mman-linux.h>. Same numeric values used
# in mm/vma.ad — kept duplicated by hand because that module imports
# nothing from here (cycle avoidance).
MAP_SHARED:    uint64 = 0x01
MAP_PRIVATE:   uint64 = 0x02
MAP_FIXED:     uint64 = 0x10
MAP_ANONYMOUS: uint64 = 0x20
# MAP_NORESERVE (x86 Linux 0x4000): "don't reserve swap / back this now".
# glibc/JITs/GC/sanitizers set it on large address-space RESERVATIONS they
# commit lazily — a strong signal to demand-page rather than eager-allocate.
MAP_NORESERVE: uint64 = 0x4000

# PROT_* — passed through to the VMA layer's `prot` field. Not yet
# applied at the page table.
PROT_NONE:  int32 = 0x0
PROT_READ:  int32 = 0x1
PROT_WRITE: int32 = 0x2
PROT_EXEC:  int32 = 0x4

# Page size used to round the requested length up. Matches the 4 KiB
# arch/x86 page size baked into header.S; no support yet for huge pages
# from userspace.
LINUX_MMAP_PAGE: uint64 = 0x1000

# Diagnostic gate: log every linux-ABI mmap/mprotect call and its result
# (addr,len,prot,flags,fd,off -> ret) so the FIRST failing DSO segment
# map (e.g. apt's shared-object closure) is visible on the serial
# console. Default OFF in ship builds — the per-call printk floods the
# serial console and measurably slows a heavy boot. Set to 1 when
# diagnosing a new Linux binary's shared-object load.
MMAP_TRACE: int32 = 0


_MMAP_FILL_BOUNCE: Array[4096, uint8]


def _u_mmap_fill_file(addr: uint64, length: uint64,
                      fd: uint64, offset: uint64) -> int64:
    # Populate a file-backed mapping at user VA [addr, addr+length) with
    # the fd's bytes from `offset`. Used for file-backed MAP_PRIVATE plus
    # MAP_FIXED overlay (ld.so's per-PT_LOAD second-phase reads). The
    # caller has already arranged for the pages to be allocated and zero-
    # filled (so the tail past EOF reads zero per the MAP_PRIVATE
    # contract). Returns 0 on success or a negative Linux errno.
    #
    # ld.so RELRO/GOT W^X keystone: the OLD body did vfs_read(fd, addr, ..)
    # which writes the file bytes DIRECTLY to the user VA at CPL=0. When
    # the mapping is PROT_READ (the whole-DSO reservation, the .text
    # segment), the leaf PTE is read-only, and under CR0.WP that supervisor
    # store #PFs (err P=1 W=1 U=0 — the dpkg cr2 halt). The mapping is
    # genuinely RO to the USER, so we must NOT make it user-writable; the
    # KERNEL just needs to populate the physical frame once. So resolve
    # each page's PHYSICAL frame (RW-bit-independent — need_write=0) and
    # write the file bytes through the low-RAM identity window, exactly as
    # copy_to_user does. The user PTE's RW bit is never consulted; W^X is
    # untouched. (Not-present pages — none here, vma_alloc eagerly installs
    # them — are skipped, leaving them zero to fault in later.)
    rc: int64 = vfs_lseek(cast[int32](fd), cast[int64](offset), 0)
    if rc < 0:
        return rc
    pml4: uint64 = uaccess_current_pml4()
    cur_va: uint64 = addr
    end_va: uint64 = addr + length
    while cur_va < end_va:
        # Bytes up to the next page boundary (4 KiB chunking so each chunk
        # lands wholly inside one resolved frame).
        page_end: uint64 = (cur_va & ~(LINUX_MMAP_PAGE - 1)) + LINUX_MMAP_PAGE
        chunk: uint64 = page_end - cur_va
        if chunk > end_va - cur_va:
            chunk = end_va - cur_va
        # Read this chunk into the kernel bounce. A short read (EOF) leaves
        # the page's tail as the pre-zeroed bytes the caller installed.
        nread: int64 = vfs_read(cast[int32](fd),
                                cast[Ptr[uint8]](&_MMAP_FILL_BOUNCE[0]),
                                chunk)
        if nread < 0:
            return nread
        if nread == 0:
            # EOF — the rest of the mapping stays zero. Done.
            return 0
        # Resolve the user VA to its physical frame (need_write=0 so a
        # PROT_READ page still resolves) and copy through the identity
        # window. A frame we cannot resolve (shouldn't happen — pages are
        # eagerly present) is skipped, leaving it zero.
        phys: uint64 = uaccess_resolve(pml4, cur_va, 0)
        if phys != 0:
            memcpy(cast[Ptr[uint8]](phys),
                   cast[Ptr[uint8]](&_MMAP_FILL_BOUNCE[0]),
                   cast[uint64](nread))
        cur_va = cur_va + chunk
    return 0


def _u_mmap(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void *mmap(void *addr, size_t length, int prot, int flags,
    #            int fd, off_t offset).
    # Supported combinations:
    #   * MAP_ANONYMOUS|MAP_PRIVATE with fd=-1 (U7..U41 path —
    #     glibc/musl malloc, CPython importlib bytecode arenas,
    #     ld.so bss-style allocations).
    #   * MAP_PRIVATE with a valid fd (U42 — ld.so mmaps DT_NEEDED
    #     DSOs). alloc_pages + pread-style fill, eagerly populated.
    #   * MAP_PRIVATE|MAP_FIXED into an existing VMA (U42 ld.so
    #     per-PT_LOAD overlays). Aliased onto the enclosing region's
    #     backing pages; file data is read into addr directly.
    if a1 == 0:
        return ELINUX_INVAL
    # The mapping must be either MAP_PRIVATE or MAP_SHARED. §1 adds the
    # MAP_SHARED case: an anonymous MAP_SHARED region is genuinely
    # shared across a fork boundary (vma_fork_copy maps the same frames
    # writable in the child — see mm/vma.ad / fs/elf.ad::vm_share_range).
    # A request with neither bit set is malformed; with both set,
    # MAP_SHARED wins (Linux: the flags are a sharing MODE, not a
    # bitfield you OR together — but tolerate the combo defensively).
    is_shared_map: int32 = 0
    if (a3 & MAP_SHARED) != 0:
        is_shared_map = 1
    if is_shared_map == 0 and (a3 & MAP_PRIVATE) == 0:
        return ELINUX_NOSYS

    # Detect fd=-1 in either 32-bit or 64-bit form (CPython 3.11 hands
    # us 0x00000000FFFFFFFF; musl/static-glibc hand us all-ones). The
    # bug surfaced at U41 (importlib MemoryError); the fix stays.
    is_neg_fd: int32 = 0
    if a4 == cast[uint64](0xFFFFFFFFFFFFFFFF):
        is_neg_fd = 1
    elif a4 == cast[uint64](0xFFFFFFFF):
        is_neg_fd = 1

    prot: int32 = cast[int32](a2)
    flags: int32 = cast[int32](a3)
    slot: uint64 = current_idx_get()

    if MMAP_TRACE != 0:
        printk2("mmap a=0x%x l=0x%x", a0, a1)
        printk2(" pf=0x%x fd=0x%x", a3, a4)
        printk1(" off=0x%x\n", a5)

    is_anon: int32 = 0
    if (a3 & MAP_ANONYMOUS) != 0 or is_neg_fd != 0:
        is_anon = 1

    is_fixed: int32 = 0
    if (a3 & MAP_FIXED) != 0 and a0 != 0:
        is_fixed = 1

    # #439 ownership transfer: a MAP_FIXED landing inside the task's brk
    # reservation REPLACES those heap pages (Linux: MAP_FIXED unmaps
    # whatever the range covered). The reservation is NOT a VmaNode, so
    # vma_alloc's carve pass cannot release its frames — without this the
    # fixed overlay would just overwrite the reservation's PTEs, leaving
    # the range with TWO owners (the new VMA node and the reap/execve
    # brk-window sweep) whose teardowns double-freed the overlay frame
    # and self-cycled the buddy free list (the probabilistic post-exit
    # wedge). Release the overlap — refcount-aware, VMA-covered pages
    # skipped — BEFORE vma_alloc creates the new owner.
    if is_fixed != 0:
        fb_base: uint64 = task_brk_base(slot)
        fb_max:  uint64 = task_brk_max(slot)
        if fb_base != 0 and fb_max > fb_base:
            fb_len: uint64 = (a1 + LINUX_MMAP_PAGE - 1) \
                             & ~(LINUX_MMAP_PAGE - 1)
            fb_lo: uint64 = a0
            if fb_lo < fb_base:
                fb_lo = fb_base
            fb_hi: uint64 = a0 + fb_len
            if fb_hi > fb_max:
                fb_hi = fb_max
            if fb_lo < fb_hi:
                vma_release_brk_overlap(slot, fb_lo, fb_hi)

    # io_uring ring fd: mmap of an FD_IORING_MARK fd at one of the three
    # IORING_OFF_* offsets aliases the kernel SQ/CQ/SQE region directly.
    # The regions live in kernel memory (kzalloc), which on the identity-
    # mapped low-half is reachable by the user mapping at the returned
    # address. We hand back the kernel region base; userspace then reads
    # the ring header / SQE array / CQE array there. (The params-address
    # fallback exposes the same base via resv[] for callers that skip
    # mmap.)
    if is_anon == 0 and vfs_fd_marker(cast[int32](a4)) == FD_IORING_MARK:
        iou_region: uint64 = iouring_mmap_region(cast[int32](a4), a5)
        if iou_region == 0:
            return ELINUX_INVAL
        return cast[int64](iou_region)

    # §shared-file-mmap: a non-FIXED MAP_SHARED writable file-backed
    # mapping (apt's pkgcache.bin / srcpkgcache.bin / the mmap'd
    # /var/lib/apt/lists indexes) must SHARE the backing file's bytes,
    # not own a private eager copy. apt builds the binary package cache
    # by mmap(MAP_SHARED, PROT_READ|PROT_WRITE) on a tmpfs file, writes
    # the package+version+download-SOURCE records THROUGH the mapping,
    # then reads them back (and a later open()/read of the same file
    # re-reads the records) to bind a download URI to a version. The old
    # path here (plain vma_alloc + eager _u_mmap_fill_file) gave the
    # mapping a PRIVATE copy: writes never reached the tmpfs inode, so a
    # subsequent fd-read saw stale/zero source descriptors -> apt knows
    # the package but "Can't find a source to download version". Route
    # such a mapping through vma_alloc_file_shared: a demand-paged VMA
    # whose dirty pages are flushed back to the backing tmpfs file on
    # msync(MS_SYNC) / munmap (mm/vma.ad::_vma_writeback_node), restoring
    # MAP_SHARED coherence. MAP_FIXED is excluded (it is ld.so's reserve+
    # segment-overlay idiom, handled by the eager path below); a read-
    # only backing object (cpio initramfs) is also excluded — write-back
    # would -EROFS — so it keeps the private-copy semantics.
    if is_anon == 0 and is_shared_map != 0 and is_fixed == 0:
        sf_marker:  uint32 = 0
        sf_backing: uint64 = 0
        sf_size:    uint64 = 0
        sf_rc: int32 = vfs_fd_backing_info(cast[int32](a4),
                                           &sf_marker, &sf_backing,
                                           &sf_size)
        # Which MAP_SHARED file mappings take the genuinely-shared path:
        #   * PROT_WRITE on any writable backing (tmpfs / ext4 / kernel
        #     buffer) — writes must reach the file + every other mapper.
        #   * PROT_READ on a TMPFS backing — the tmpfs-direct fault maps
        #     the file's OWN storage pages read-only, so a READER sees a
        #     concurrent WRITER's stores immediately (POSIX MAP_SHARED
        #     coherence). apt opens pkgcache.bin MAP_SHARED PROT_READ in
        #     one process while another writes it MAP_SHARED PROT_WRITE;
        #     the old eager-copy read path snapshotted stale/zero bytes
        #     and apt dereferenced a NULL cache pointer (va=0x0 SIGSEGV
        #     during "Reading package lists"). ext4/buffer read-only
        #     mappings keep the eager copy (no shared read page cache for
        #     them, and they are not the apt hot path).
        sf_take: int32 = 0
        if sf_rc == 0 and sf_marker != FD_FILEMMAP_INITRAMFS:
            if (prot & PROT_WRITE) != 0:
                sf_take = 1
            elif sf_marker == FD_TMPFS_MARK:
                sf_take = 1
        if sf_take != 0:
            sf_base: int64 = vma_alloc_file_shared(slot, a0, a1, prot,
                                                   flags, cast[int32](sf_marker),
                                                   sf_backing, sf_size, a5)
            if sf_base < 0:
                if MMAP_TRACE != 0:
                    printk1("mmap SHARED-FILE FAIL rc=%d\n",
                            cast[uint64](sf_base))
                return sf_base
            if MMAP_TRACE != 0:
                printk2("mmap SHARED-FILE ok addr=0x%x mk=0x%x",
                        cast[uint64](sf_base), cast[uint64](sf_marker))
                printk1(" sz=0x%x\n", sf_size)
            return sf_base

    # §private-file-demand: a large NON-FIXED MAP_PRIVATE file-backed
    # mapping (Firefox's ~160 MiB libxul.so whole-DSO map; any big DSO or
    # data-file mmap) must DEMAND-PAGE its backing bytes, not eager-pread
    # the whole file into a private per-process copy. The eager path below
    # (_u_mmap_fill_file) reads the entire file into RAM at map time, so
    # ~15 Firefox processes each duplicate libxul -> RAM exhausts (the
    # code=139 memory-pressure kill). Route such a mapping through
    # vma_alloc_file_demand: a demand VMA whose pages are lazily pread from
    # the backing file on #PF (vma_demand_fault's is_file branch) into a
    # FRESH private page -> MAP_PRIVATE copy-on-write holds for free (a
    # write lands on the private page, never the backing file). This is the
    # same demand-paged private-file path the NATIVE SYS_MMAP already uses
    # (arch/x86/kernel/syscall.ad) — the Linux ABI path was the last eager
    # holdout. MAP_FIXED is excluded: ld.so's reserve+segment-overlay idiom
    # layers file bytes onto an ENCLOSING region's existing pages, which the
    # eager _u_mmap_fill_file below handles. Threshold-gated (>= 16 MiB, the
    # same constant the anon-reservation path uses) so the proven small-DSO
    # eager hot path (glibc/libc per-segment maps, CPython bytecode arenas)
    # stays byte-for-byte unchanged — the RAM win is entirely in the giant
    # maps. A backing kind that does not resolve to a stable
    # (marker,backing,size) triple also stays on the eager path.
    if is_anon == 0 and is_shared_map == 0 and is_fixed == 0 \
            and a1 >= cast[uint64](0x1000000):
        pf_marker:  uint32 = 0
        pf_backing: uint64 = 0
        pf_size:    uint64 = 0
        pf_rc: int32 = vfs_fd_backing_info(cast[int32](a4),
                                           &pf_marker, &pf_backing,
                                           &pf_size)
        if pf_rc == 0:
            pf_base: int64 = vma_alloc_file_demand(slot, a0, a1, prot,
                                                   flags,
                                                   cast[int32](pf_marker),
                                                   pf_backing, pf_size, a5)
            if pf_base < 0:
                if MMAP_TRACE != 0:
                    printk1("mmap PRIV-FILE-DEMAND FAIL rc=%d\n",
                            cast[uint64](pf_base))
                return pf_base
            if MMAP_TRACE != 0:
                printk2("mmap PRIV-FILE-DEMAND ok addr=0x%x sz=0x%x",
                        cast[uint64](pf_base), pf_size)
                printk1(" mk=0x%x\n", cast[uint64](pf_marker))
            return pf_base

    # §private-file-demand (MAP_FIXED segment overlay): ld.so overlays each
    # PT_LOAD segment with a MAP_FIXED file mapping ON TOP of the whole-DSO
    # reservation it mapped first. When that reservation is now a DEMAND VMA
    # (the large-map branch above turned Firefox's ~160 MiB libxul.so whole
    # map demand), the enclosing region has NO present pages — so the eager
    # alias-fill path below (_u_mmap_fill_file resolves each page's existing
    # frame and writes the file bytes THROUGH it) finds phys=0 and SKIPS the
    # copy, leaving the overlay's pages not-present. A later access then
    # SIGSEGVs on an "unmapped" VA (is_demand=0, so vma_demand_fault declines
    # it) — the deterministic libxul data-segment crash. Route such an
    # overlay through vma_alloc_file_demand too: it carves the reservation
    # range and installs a FRESH demand VMA at the fixed addr whose pages
    # pread the segment's file bytes (file_off a5) on fault and read zero
    # past EOF (the .bss tail) — correct MAP_PRIVATE segment semantics, and
    # exactly what the native SYS_MMAP path already does for fixed file maps.
    # Gated on the overlay actually landing in a demand FILE VMA: a MAP_FIXED
    # overlay onto an EAGER enclosing map (a small DSO below the threshold)
    # keeps the proven alias-fill path unchanged.
    if is_anon == 0 and is_shared_map == 0 and is_fixed != 0 \
            and vma_demand_file_cover(slot, a0) != 0:
        xf_marker:  uint32 = 0
        xf_backing: uint64 = 0
        xf_size:    uint64 = 0
        xf_rc: int32 = vfs_fd_backing_info(cast[int32](a4),
                                           &xf_marker, &xf_backing,
                                           &xf_size)
        if xf_rc == 0:
            xf_base: int64 = vma_alloc_file_demand(slot, a0, a1, prot,
                                                   flags,
                                                   cast[int32](xf_marker),
                                                   xf_backing, xf_size, a5)
            if xf_base < 0:
                if MMAP_TRACE != 0:
                    printk1("mmap FIXED-FILE-DEMAND FAIL rc=%d\n",
                            cast[uint64](xf_base))
                return xf_base
            if MMAP_TRACE != 0:
                printk2("mmap FIXED-FILE-DEMAND ok addr=0x%x sz=0x%x",
                        cast[uint64](xf_base), xf_size)
                printk1(" off=0x%x\n", a5)
            return xf_base

    # File-backed path. Allocate (or alias) via vma_alloc, then fill
    # the resulting region from the fd.
    if is_anon == 0:
        rc: int64 = vma_alloc(slot, a0, a1, prot, flags,
                              cast[int32](a4), a5)
        if rc < 0:
            if MMAP_TRACE != 0:
                printk1("mmap FILE vma_alloc FAIL rc=%d\n", cast[uint64](rc))
            return rc
        # vma_alloc returned the resolved base. For MAP_FIXED inside
        # an enclosing VMA that base equals a0 (the user's request);
        # for the non-FIXED path it's the alloc_pages base.
        addr_out: uint64 = cast[uint64](rc)
        # If MAP_FIXED into an enclosing region, vma_alloc kept the
        # enclosing VMA's backing pages and DIDN'T zero them again
        # (zeroing would clobber the prior content). We still need
        # to fill addr_out with the file data the user asked for.
        # For the non-FIXED path the pages are freshly allocated and
        # pre-zeroed by vma_alloc; we then layer the file bytes on top.
        # _u_mmap_fill_file populates via each page's PHYSICAL frame
        # (identity window), so a PROT_READ mapping's read-only leaf PTEs
        # are never written through the user VA — the ld.so RELRO/GOT
        # W^X keystone (the dpkg cr2=0x49c00000 supervisor-write halt).
        fill_rc: int64 = _u_mmap_fill_file(addr_out, a1, a4, a5)
        if fill_rc < 0:
            printk1("linux_u: mmap-file fill failed rc=%d\n",
                    cast[uint64](fill_rc))
            # Unwind: drop the VMA we just created so the user
            # doesn't see a half-baked mapping. Use the page-rounded
            # length so the carve hits the right range.
            length_round: uint64 = (a1 + LINUX_MMAP_PAGE - 1) \
                                   & ~(LINUX_MMAP_PAGE - 1)
            vma_unmap(slot, addr_out, length_round)
            return fill_rc
        if MMAP_TRACE != 0:
            printk1("mmap FILE ok addr=0x%x\n", addr_out)
        # [LMOD] no-syscall-watchdog companion trace: log the base->path of
        # every executable file-backed mapping a Linux task installs (ld.so's
        # per-DSO PT_LOAD overlays). This is the authoritative RIP-base ->
        # library table the watchdog's pinned-RIP dump correlates against —
        # ld.so closes the fd after mapping, so the path must be captured HERE
        # while the fd is still open. Gated on exec prot to keep it to code
        # segments (one line per library) and off the data/RELRO overlays.
        # Modern glibc ld.so maps the whole DSO once as PROT_READ (file_off 0)
        # then mprotects each PT_LOAD segment — so the PROT_EXEC gate below
        # never fires for those loads. Log BOTH: the exec overlays AND the
        # file_offset==0 whole-file base map (one authoritative base->path line
        # per DSO) so the RIP-base -> library table is complete for the
        # Firefox WebRender NULL-deref hunt.
        if (prot & PROT_EXEC) != 0 or a5 == 0:
            lmp: Ptr[uint8] = task_fd_opened_path_ptr(current_task(),
                                                      cast[uint64](a4))
            if lmp[0] != 0:
                printk2("[LMOD] base=0x%x off=0x%x", addr_out, a5)
                printk1(" %s\n", cast[uint64](lmp))
        return cast[int64](addr_out)

    # Anonymous path. offset must be 0 (the U7..U41 invariant — both
    # musl and glibc only call MAP_ANON|MAP_PRIVATE with offset=0).
    if a5 != 0:
        return ELINUX_INVAL
    # Build the flags the recorded VMA carries. §1: MAP_SHARED is
    # preserved here so vma_fork_copy can recognise the region and map
    # the SAME physical frames into a forked child (genuine cross-
    # process coherence) instead of COW-splitting on write. MAP_PRIVATE
    # is the default sharing mode. file_fd=-1, file_offset=0.
    # LAZY ADDRESS-SPACE RESERVATION (SpiderMonkey JIT/wasm, GC nurseries,
    # sanitizer shadow, glibc arenas): a PROT_NONE, MAP_NORESERVE, or LARGE
    # anonymous PRIVATE mapping is a *reservation* — the program claims VA
    # now and commits sub-ranges later (mprotect->RW, or first touch). The
    # old code eager-allocated the WHOLE region's backing RAM here via
    # vma_alloc; a multi-GiB JIT executable-pool reservation (SpiderMonkey
    # reserves its code region PROT_NONE) then failed -ENOMEM, so
    # js::jit::InitializeJit()/js::wasm::Init() returned a failure string and
    # JS_Init MOZ_CRASH'd (`*(int*)nullptr = __LINE__` in
    # InitWithFailureDiagnostic — the Firefox JS-init blocker). Linux
    # demand-pages ALL anonymous memory; mirror that for reservations:
    # install a not-present demand VMA (vma_alloc_demand) so PROT_NONE pages
    # cost zero RAM and large arenas back lazily, zero-filled on the first
    # access. Scope kept tight to avoid disturbing the proven small-arena
    # eager hot path: NON-FIXED, PRIVATE anonymous only (MAP_SHARED demand is
    # not meaningful — sharing needs real frames; MAP_FIXED anon overlays are
    # the ld.so .bss idiom that needs eager zero-content). Threshold 16 MiB.
    if is_fixed == 0 and is_shared_map == 0:
        _lazy_resv: int32 = 0
        if prot == PROT_NONE:
            _lazy_resv = 1
        if (a3 & MAP_NORESERVE) != 0:
            _lazy_resv = 1
        if a1 >= cast[uint64](0x1000000):
            _lazy_resv = 1
        if _lazy_resv != 0:
            return vma_alloc_demand(slot, 0, a1, prot,
                                    VMA_MAP_PRIVATE | VMA_MAP_ANONYMOUS)
    anon_flags: int32 = cast[int32](MAP_ANONYMOUS)
    if is_shared_map != 0:
        anon_flags = anon_flags | cast[int32](MAP_SHARED)
    else:
        anon_flags = anon_flags | cast[int32](MAP_PRIVATE)
    if is_fixed != 0:
        anon_flags = anon_flags | cast[int32](MAP_FIXED)
    return vma_alloc(slot, a0, a1, prot, anon_flags, -1, 0)


def _u_mprotect(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int mprotect(void *addr, size_t len, int prot).
    # §1: a real mprotect. vma_protect re-walks the page table over
    # [addr, addr+len) and updates each PTE's RW bit to match
    # PROT_WRITE — so a store to a PROT_READ page now genuinely faults
    # — and splits VMAs as needed so the recorded prot is accurate
    # per-slice. (No NX, so PROT_EXEC is not separately enforced.)
    slot: uint64 = current_idx_get()
    mp_rc: int64 = vma_protect(slot, a0, a1, cast[int32](a2))
    if MMAP_TRACE != 0:
        printk2("mprotect a=0x%x l=0x%x", a0, a1)
        printk2(" p=0x%x rc=%d\n", a2, cast[uint64](mp_rc))
    return mp_rc


# U18: glibc-startup stubs.

def _u_set_robust_list(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long set_robust_list(struct robust_list_head *head, size_t len).
    # glibc registers a thread's robust-mutex list on startup so the
    # kernel can release them on thread death. Hamnix has no futex
    # subsystem yet; recording the pointer is harmless and returning 0
    # lets glibc continue.
    return 0


def _u_prlimit64(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int prlimit64(pid_t pid, int resource, const struct rlimit64 *new,
    #               struct rlimit64 *old). a0=pid, a1=resource, a2=new,
    #               a3=old.
    # struct rlimit64 is { uint64 rlim_cur; uint64 rlim_max; }.
    #
    # This is now backed by a REAL per-task rlimit store (kernel/sched/core.ad
    # g_rlim_cur/g_rlim_max, keyed by task slot, seeded to Linux defaults by
    # rlimit_init_task). getrlimit/setrlimit/prlimit64 all round-trip through
    # it: two setrlimit calls followed by a getrlimit observe the change.
    # `old` (if requested) is captured BEFORE `new` is applied, matching
    # Linux's pre-change-value semantics.
    if a1 >= 16:
        return ELINUX_INVAL
    # Resolve target slot: pid 0 means the current task; otherwise look it up.
    slot: uint64 = 0
    if a0 == 0:
        slot = current_idx_get()
    else:
        sidx: int32 = task_lookup_by_pid(a0)
        if sidx < 0:
            return ELINUX_SRCH
        slot = cast[uint64](sidx)
    # `old` wanted: report the CURRENT stored values before any mutation.
    # #163: writeback via put_user_64 (translated) instead of a raw deref.
    if a3 != 0:
        if put_user_64(rlimit_get_cur(slot, a1), a3) != 0 \
                or put_user_64(rlimit_get_max(slot, a1), a3 + 8) != 0:
            set_current_errstr("prlimit64: bad old rlimit pointer")
            return ELINUX_EFAULT
    # `new` given: validate cur <= max, then store. Single-user-root model —
    # no privilege check on raising the hard limit.
    # #163: read the new limit pair via get_user — a bad pointer -> EFAULT.
    if a2 != 0:
        nc: uint64 = 0
        nm: uint64 = 0
        if get_user_64(a2, &nc) != 0 or get_user_64(a2 + 8, &nm) != 0:
            set_current_errstr("prlimit64: bad new rlimit pointer")
            return ELINUX_EFAULT
        if nc > nm:
            return ELINUX_INVAL
        rlimit_set(slot, a1, nc, nm)
    return 0


def _u_getrlimit(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getrlimit(int resource, struct rlimit *rlim).
    # Same return shape as prlimit64 except the buffer is at a1 instead
    # of a3, and there is no pid/new-limit pair. Forward to the prlimit64
    # body by reassembling the (pid, resource, new=NULL, old=rlim) tuple.
    return _u_prlimit64(0, a0, 0, a1, 0, 0)


def _u_setrlimit(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setrlimit(int resource, const struct rlimit *rlim).
    # resource=a0, rlim=a1. Forward to prlimit64 with the current task
    # (pid=0), new=rlim, old=NULL — the store mutation lives in one place.
    return _u_prlimit64(0, a0, a1, 0, 0, 0)


def _u_setpriority(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setpriority(int which, id_t who, int prio). which=a0
    # (PRIO_PROCESS=0/PRIO_PGRP=1/PRIO_USER=2), who=a1 (0 => the calling
    # process), prio=a2 (the nice value -20..19). Backed by the REAL
    # per-task nice store in kernel/sched/core.ad. Resolve the target slot
    # the same way prlimit64 does: who==0 is the current task; otherwise
    # task_lookup_by_pid -> ESRCH on miss. sched_set_nice clamps to range.
    if a0 > 2:
        return ELINUX_INVAL
    slot: uint64 = 0
    if a1 == 0:
        slot = current_idx_get()
    else:
        sidx: int32 = task_lookup_by_pid(a1)
        if sidx < 0:
            return ELINUX_SRCH
        slot = cast[uint64](sidx)
    # prio arrives as a uint64 holding a signed 32-bit int — sign-extend it.
    prio: int64 = cast[int64](cast[int32](a2))
    sched_set_nice(slot, prio)
    return 0


def _u_getpriority(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getpriority(int which, id_t who). The raw syscall returns the
    # nice value BIASED as `20 - nice` (range 1..40) so a negative nice is
    # never mistaken for an errno; glibc's wrapper recovers nice = 20 - raw.
    # Slot resolution mirrors _u_setpriority / _u_prlimit64.
    if a0 > 2:
        return ELINUX_INVAL
    slot: uint64 = 0
    if a1 == 0:
        slot = current_idx_get()
    else:
        sidx: int32 = task_lookup_by_pid(a1)
        if sidx < 0:
            return ELINUX_SRCH
        slot = cast[uint64](sidx)
    n: int64 = sched_get_nice(slot)
    return 20 - n


def _u_sched_resolve_slot(pid: uint64, out: Ptr[uint64]) -> int64:
    # Resolve a (Linux) pid argument to a task slot, matching the
    # setpriority/prlimit64 convention: pid==0 means the calling task,
    # otherwise task_lookup_by_pid -> ESRCH on miss. Writes the slot through
    # `out` and returns 0 on success, a negative errno on failure.
    if pid == 0:
        out[0] = current_idx_get()
        return 0
    sidx: int32 = task_lookup_by_pid(pid)
    if sidx < 0:
        return ELINUX_SRCH
    out[0] = cast[uint64](sidx)
    return 0


def _u_sched_setscheduler(a0: uint64, a1: uint64, a2: uint64,
                          a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sched_setscheduler(pid_t pid, int policy,
    #                        const struct sched_param *param).
    # pid=a0, policy=a1 (SCHED_OTHER/FIFO/RR), param=a2 -> {int sched_priority}.
    # Forwards to the native realtime mechanism (sched_set_scheduler in
    # core.ad), which validates the (policy, priority) pair. We do NOT model
    # the SCHED_RESET_ON_FORK flag bit, so reject any high bits in `policy`.
    if a1 != SCHED_OTHER and a1 != SCHED_FIFO and a1 != SCHED_RR:
        return ELINUX_INVAL
    slot: uint64 = 0
    rc: int64 = _u_sched_resolve_slot(a0, &slot)
    if rc != 0:
        return rc
    # struct sched_param is a single int (sched_priority). copy_from_user the
    # 4-byte field. A NULL param is invalid for setscheduler.
    if a2 == 0:
        return ELINUX_INVAL
    prio32: int32 = 0
    if copy_from_user(cast[uint64](&prio32), a2, 4) != 0:
        return ELINUX_FAULT
    prio: int64 = cast[int64](prio32)
    if sched_set_scheduler(slot, a1, prio) == 0:
        return ELINUX_INVAL
    return 0


def _u_sched_getscheduler(a0: uint64, a1: uint64, a2: uint64,
                          a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sched_getscheduler(pid_t pid). Returns the SCHED_* policy of the
    # target task (SCHED_OTHER/FIFO/RR), or a negative errno.
    slot: uint64 = 0
    rc: int64 = _u_sched_resolve_slot(a0, &slot)
    if rc != 0:
        return rc
    return cast[int64](sched_get_policy(slot))


def _u_sched_setparam(a0: uint64, a1: uint64, a2: uint64,
                      a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sched_setparam(pid_t pid, const struct sched_param *param).
    # Changes only the realtime priority, KEEPING the current policy — so it
    # only makes sense for a task that is already SCHED_FIFO/RR. We re-apply
    # the existing policy with the new priority via the same validated
    # mechanism (which rejects a non-zero priority on a SCHED_OTHER task,
    # exactly matching Linux's EINVAL there).
    slot: uint64 = 0
    rc: int64 = _u_sched_resolve_slot(a0, &slot)
    if rc != 0:
        return rc
    if a1 == 0:
        return ELINUX_INVAL
    prio32: int32 = 0
    if copy_from_user(cast[uint64](&prio32), a1, 4) != 0:
        return ELINUX_FAULT
    prio: int64 = cast[int64](prio32)
    cur_policy: uint64 = sched_get_policy(slot)
    if sched_set_scheduler(slot, cur_policy, prio) == 0:
        return ELINUX_INVAL
    return 0


def _u_sched_getparam(a0: uint64, a1: uint64, a2: uint64,
                      a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sched_getparam(pid_t pid, struct sched_param *param). Writes the
    # target's realtime priority (0 for a SCHED_OTHER task) into the user
    # struct's single int field.
    slot: uint64 = 0
    rc: int64 = _u_sched_resolve_slot(a0, &slot)
    if rc != 0:
        return rc
    if a1 == 0:
        return ELINUX_INVAL
    prio32: int32 = cast[int32](sched_get_rt_priority(slot))
    if copy_to_user(a1, cast[uint64](&prio32), 4) != 0:
        return ELINUX_FAULT
    return 0


def _u_sched_get_priority_max(a0: uint64, a1: uint64, a2: uint64,
                              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sched_get_priority_max(int policy). 99 for FIFO/RR, 0 for OTHER.
    if a0 != SCHED_OTHER and a0 != SCHED_FIFO and a0 != SCHED_RR:
        return ELINUX_INVAL
    return sched_priority_max(a0)


def _u_sched_get_priority_min(a0: uint64, a1: uint64, a2: uint64,
                              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sched_get_priority_min(int policy). 1 for FIFO/RR, 0 for OTHER.
    if a0 != SCHED_OTHER and a0 != SCHED_FIFO and a0 != SCHED_RR:
        return ELINUX_INVAL
    return sched_priority_min(a0)


def _u_rseq(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long rseq(struct rseq *rseq, uint32_t rseq_len, int flags,
    #           uint32_t sig). glibc registers a restartable-sequence
    # area on startup so cancellable critical sections can be retried
    # without explicit locking. The whole subsystem is best-effort:
    # glibc tolerates -ENOSYS and skips the optimisation. Returning a
    # negative errno here is the right thing — pretending success would
    # leave glibc thinking it owns an rseq area it cannot actually use.
    return ELINUX_NOSYS


# #163: kernel scratch for getrandom(2). CSPRNG bytes land here before
# being copy_to_user'd to the caller in 256-byte chunks (top-level BSS,
# not a nested-frame Array — the U9 quirk).
GETRANDOM_SCRATCH_MAX: uint64 = 256
u_getrandom_scratch: Array[256, uint8]


def _u_getrandom(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t getrandom(void *buf, size_t buflen, unsigned int flags).
    # Used by glibc's stack-canary / pointer-mangling setup, plus any
    # userland crypto. Serves bytes from the SAME kernel CSPRNG as
    # /dev/random and /dev/urandom: ChaCha20 (RFC 8439) with fast key
    # erasure, seeded from RDSEED/RDRAND/TSC-jitter (devrandom.ad).
    #
    # flags (a2): GRND_NONBLOCK (0x1) / GRND_RANDOM (0x2) / GRND_INSECURE
    # (0x4, Linux 5.6). Our pool is always seeded and never blocks, so all
    # three are honoured by simply serving CSPRNG output — modern Linux
    # /dev/urandom semantics (GRND_INSECURE just means "don't block, don't
    # care about full entropy", which our always-ready pool satisfies).
    # glibc's arc4random_buf(3) issues getrandom(buf, n, GRND_INSECURE); a
    # kernel that rejects the flag (EINVAL) breaks it. Unknown bits beyond
    # these three still return EINVAL, matching the kernel's check_flags.
    if a0 == 0:
        return ELINUX_INVAL
    if (a2 & ~cast[uint64](0x7)) != 0:
        return ELINUX_INVAL
    n: uint64 = a1
    if n == 0:
        return 0
    # #163: serve CSPRNG bytes into a kernel scratch, then copy_to_user
    # each chunk through the translated path — a bad user buf returns
    # -EFAULT (matching Linux) instead of faulting devrandom_read on a raw
    # user pointer. We chunk so an arbitrarily large buflen needs only a
    # fixed kernel scratch. If the FIRST chunk's copy faults we surface
    # -EFAULT; a fault partway returns the bytes already delivered (Linux
    # getrandom is allowed to return a short count).
    done: uint64 = 0
    while done < n:
        chunk: uint64 = n - done
        if chunk > GETRANDOM_SCRATCH_MAX:
            chunk = GETRANDOM_SCRATCH_MAX
        gr: int64 = devrandom_read(&u_getrandom_scratch[0], chunk)
        if gr <= 0:
            if done > 0:
                return cast[int64](done)
            return gr
        got: uint64 = cast[uint64](gr)
        if copy_to_user(a0 + done,
                        cast[uint64](&u_getrandom_scratch[0]), got) != 0:
            if done > 0:
                return cast[int64](done)
            set_current_errstr("getrandom: bad buffer pointer")
            return ELINUX_EFAULT
        done = done + got
    return cast[int64](done)


def _u_munmap(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int munmap(void *addr, size_t length).
    # Routed through the per-task VMA list: carve every VMA overlapping
    # [addr, addr+length) and free its backing pages. Unlike the U7..U41
    # slot-table version, we no longer rely on (base == requested addr)
    # bookkeeping — partial-range munmaps that hit a few VMAs are now
    # all handled cleanly. A range that covers no VMAs is silently
    # accepted (real Linux behaviour) rather than returning -EINVAL.
    if a1 == 0:
        return ELINUX_INVAL
    slot: uint64 = current_idx_get()
    return vma_unmap(slot, a0, a1)


def _u_unimpl_brk(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void *brk(void *new_brk). Linux convention: returns the *new*
    # program break on success, and the *current* break on failure (so
    # glibc's sbrk(0) probe and malloc's grow path can distinguish OK
    # from "couldn't grow, fall back to mmap"). new_brk=0 also doubles
    # as the "where is my heap?" query glibc fires on every process
    # startup.
    #
    # M16.104 model (U41 update): per-task brk_base / brk_end / brk_max
    # stored on TaskStruct (kernel/sched/core.ad). On the FIRST call
    # (brk_base == 0) we lazily reserve LINUX_BRK_RESERVE (32 MiB) of
    # contiguous physical memory by chaining LINUX_BRK_CHUNKS calls of
    # alloc_pages(LINUX_BRK_ORDER) — see the constant-block comment
    # for why this produces physically-contiguous memory in practice.
    # brk_base lands at the base of the first chunk, brk_end starts
    # equal, brk_max = base + (chunks actually obtained) * CHUNK.
    # Subsequent calls just adjust brk_end inside the reserved range —
    # no further kernel allocator traffic, and the memory is guaranteed
    # virtually contiguous so glibc-malloc's arena bookkeeping never
    # trips the "break adjusted to free malloc space" path that the
    # legacy kmalloc-chunk-per-grow code hit on multi-megabyte heaps.
    #
    # Lazy-init rather than exec-time-init because the only place that
    # knows the right initial value of brk_base is the execve / spawn
    # path in arch/x86/kernel/syscall.ad, which this milestone may not
    # modify (locked file under parallel work). The cost of doing it
    # lazily is exactly one alloc_pages call on the FIRST brk(), which
    # is glibc's very first pre-main probe — well before any latency-
    # sensitive code runs. The reserved region's physical base also
    # serves as the user-visible heap address: ET_DYN binaries (the
    # common case) run identity-mapped, so the kernel kphys == user
    # vaddr and glibc can dereference brk_end-1 directly. ET_EXEC
    # binaries with a per-task overlay don't see the new region in
    # their PML4, but no Linux ET_EXEC tested so far calls brk() —
    # they all touch mmap(2) instead. That gap is documented in the
    # follow-up TODO ("mmap-based brk for ET_EXEC binaries").
    cur: uint64 = current_idx_get()
    base: uint64 = task_brk_base(cur)
    if base == 0:
        # First call from this task — reserve LINUX_BRK_RESERVE (32 MiB)
        # of contiguous memory by chaining LINUX_BRK_CHUNKS calls of
        # alloc_pages(MAX_ORDER). See the comment block on
        # LINUX_BRK_CHUNK / LINUX_BRK_CHUNKS for why this produces
        # physically-contiguous memory in practice. If a later chunk
        # lands non-contiguous with its predecessor we shorten the
        # reservation to whatever prefix WAS contiguous — glibc-malloc
        # only cares that brk_base..brk_end is one virtually-contiguous
        # arena, so a 4 MiB reservation is still valid (just smaller),
        # whereas a non-contiguous 32 MiB reservation would corrupt the
        # malloc arena.
        region: uint64 = alloc_pages(LINUX_BRK_ORDER)
        if region == 0:
            return 0                                  # OOM — return 0 brk
        # DIRECT-MAP ALIASING FIX: `region` is the LOW physical base of
        # the reservation; `base` is the HIGH user virtual base the heap
        # is exposed at (decoupled from phys — see LINUX_BRK_VBASE). The
        # contiguity check below stays on the PHYSICAL chunks (the buddy
        # allocator returns physical addresses); the virtual range is
        # contiguous by construction because we map a single linear span.
        phys_base: uint64 = region
        phys_end:  uint64 = region + LINUX_BRK_CHUNK
        base = LINUX_BRK_VBASE
        chunks_got: uint64 = 1
        n: uint64 = 1
        while n < LINUX_BRK_CHUNKS:
            nxt: uint64 = alloc_pages(LINUX_BRK_ORDER)
            if nxt == 0:
                # OOM partway through — keep what we got, the heap will
                # just be smaller. Better than failing the whole exec.
                n = LINUX_BRK_CHUNKS                  # break
            elif nxt != phys_end:
                # Non-contiguous PHYSICAL landing. Free the orphan chunk
                # so we don't leak it, then stop with the contiguous
                # prefix. We don't try to retry: the page allocator's
                # free lists are FIFO so a second attempt would likely
                # land the same place.
                printk1("linux_u: brk non-contiguous after %d chunk(s); shorter heap\n", n)
                free_pages(nxt, LINUX_BRK_ORDER)
                n = LINUX_BRK_CHUNKS                  # break
            else:
                phys_end = phys_end + LINUX_BRK_CHUNK
                chunks_got = chunks_got + 1
                n = n + 1
        # Virtual span = number of physically-contiguous chunks obtained.
        end_v: uint64 = base + chunks_got * LINUX_BRK_CHUNK
        set_task_brk_base(cur, base)
        set_task_brk_end(cur, base)
        set_task_brk_max(cur, end_v)
        # M16.36 + aliasing fix: install per-task PT entries mapping the
        # HIGH virtual range [brk_base, brk_max) onto the LOW physical
        # reservation [phys_base, phys_base + span). Each leaf PTE lives
        # in this task's OWN PD/PT; the high VA keeps the brk window out
        # of the kernel direct-map's low identity band so the heap can
        # never alias an allocator frame the kernel later writes.
        brk_pml4: uint64 = task_pml4(cast[int32](cur))
        if elf_install_user_heap(brk_pml4, base, end_v - base,
                                 phys_base) < 0:
            printk0("brk: heap PT-install failed; reservation kept but unmapped\n")
            # The caller will fault on the next dereference; better to
            # surface the OOM than to silently lie. Leave brk_end at
            # the requested value so the caller's malloc bookkeeping
            # is self-consistent.
        # The install ran against the LIVE task's PML4 (cur == current
        # task's index — _u_brk is the running task itself). Reload
        # CR3 to drop any cached PS=1 1 GiB / PS=1 2 MiB TLB entries
        # for this range so the next access uses the new 4 KiB PTE.
        load_cr3(brk_pml4)
    end: uint64 = task_brk_end(cur)
    if a0 == 0:
        # brk(0) → "where is my heap?". Return current break.
        return cast[int64](end)
    if a0 < base:
        # Request below the initial break — Linux silently refuses
        # (returns current break, not an error). glibc never asks for
        # this; honoured for completeness.
        return cast[int64](end)
    max_v: uint64 = task_brk_max(cur)
    if a0 > max_v:
        # Past the reservation — refuse the grow. Linux's brk()
        # returns the *old* break on failure, which is what malloc
        # keys off of to fall back to mmap(2). Don't try to extend the
        # reservation here: the alloc_pages allocator has no way to
        # grow an existing contiguous run, and a fresh alloc would
        # almost certainly land elsewhere (breaking contiguity, which
        # is exactly the bug this whole milestone fixes). Bumping the
        # reserve from 4 MiB to e.g. 64 MiB is a separate milestone —
        # see TODO.md ("mmap-based brk for very large heaps").
        printk2("linux_u: brk refused grow to %p (max=%p)\n", a0, max_v)  # noisy on full-OOM only
        return cast[int64](end)
    # In-range adjust (grow OR shrink). The backing memory was
    # reserved up front, so all we do is move the cursor. We never
    # release pages on shrink — glibc's malloc walks the arena
    # backwards expecting to find its own metadata and the
    # alloc_pages allocator has no partial-free path anyway. Same
    # observable behaviour as Linux's brk(2) at this scale.
    set_task_brk_end(cur, a0)
    return cast[int64](a0)


def _u_rt_sigaction(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int rt_sigaction(int signum, const struct sigaction *act,
    #                  struct sigaction *oldact, size_t sigsetsize).
    #
    # Kernel struct sigaction (on x86_64):
    #   off  0: void (*sa_handler)(int)   / sa_sigaction
    #   off  8: unsigned long sa_flags
    #   off 16: void (*sa_restorer)(void)
    #   off 24: sigset_t sa_mask (a3 bytes — typically 8 from musl)
    #
    # Musl allocates a tight 32-byte kernel-sigaction buffer (8-byte
    # mask), so we MUST NOT write past offset 24 + a3 of oldact: an
    # unconditional 152-byte memset clobbers the caller's stack frame
    # and trips the stack canary check on return.
    #
    # We record sa_handler + sa_flags per signal. sa_flags drives the
    # handler-argument shape (SA_SIGINFO) and the auto-block of the
    # delivered signal (SA_NODEFER) in signal_check_and_handle.
    # SIGKILL (9) and SIGSTOP (19) cannot have a handler installed —
    # rt_sigaction on either returns -EINVAL, matching Linux.
    sig: uint64 = a0
    if sig == 0 or sig >= 64:
        return ELINUX_INVAL
    if sig == 9 or sig == 19:                             # SIGKILL/SIGSTOP
        return ELINUX_INVAL
    slot: uint64 = current_idx_get()
    if a2 != 0:
        prev: uint64 = get_task_sig_handler(slot, sig)
        prev_fl: uint64 = get_task_sig_flags(slot, sig)
        # Write only the first 16 bytes (sa_handler + sa_flags). The
        # caller's sa_restorer / sa_mask slots are left as the caller
        # initialised them — they are inputs to us, not outputs.
        # #163: put_user_64 walks the page tables; fault => -EFAULT.
        if put_user_64(prev, a2) != 0:
            return ELINUX_EFAULT
        if put_user_64(prev_fl, a2 + 8) != 0:
            return ELINUX_EFAULT
    if a1 != 0:
        new_handler: uint64 = 0
        new_flags:   uint64 = 0
        if get_user_64(a1, &new_handler) != 0:          # #163
            return ELINUX_EFAULT
        if get_user_64(a1 + 8, &new_flags) != 0:
            return ELINUX_EFAULT
        set_task_sig_handler(slot, sig, new_handler)
        set_task_sig_flags(slot, sig, new_flags)
    return 0


def _u_rt_sigprocmask(a0: uint64, a1: uint64, a2: uint64,
                      a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int rt_sigprocmask(int how, const sigset_t *set, sigset_t *oldset,
    #                    size_t sigsetsize).
    #
    # §3: real per-task signal-mask state. signal_check_and_handle
    # consults sig_mask and skips any pending-but-blocked signal
    # (SIGKILL excepted — uncatchable AND unblockable). how:
    #   SIG_BLOCK   (0) — mask |= *set
    #   SIG_UNBLOCK (1) — mask &= ~*set
    #   SIG_SETMASK (2) — mask  = *set
    # *set / *oldset are 64-bit sigset_t bitmaps (musl/glibc pass 8).
    #
    # BIT CONVENTION: a Linux userspace sigset_t encodes signal N at
    # bit (N-1). The kernel's internal sig_mask / sig_pending bitmaps
    # use bit N directly (so `1 << sig` indexes signal sig). We bridge
    # the two with a 1-bit shift at this boundary: kernel = user << 1,
    # user = kernel >> 1.
    SIG_BLOCK:   uint64 = 0
    SIG_UNBLOCK: uint64 = 1
    SIG_SETMASK: uint64 = 2
    slot: uint64 = current_idx_get()
    old_k: uint64 = get_task_sig_mask(slot)              # kernel-convention
    # oldset first — POSIX returns the PRE-call mask even when set!=0.
    # Convert kernel (bit N) → user (bit N-1).
    if a2 != 0:
        if put_user_64(old_k >> 1, a2) != 0:            # #163
            return ELINUX_EFAULT
    if a1 != 0:
        # Convert user (bit N-1) → kernel (bit N). #163: page-table walk.
        sm_user: uint64 = 0
        if get_user_64(a1, &sm_user) != 0:
            return ELINUX_EFAULT
        want_k: uint64 = sm_user << 1
        new_mask: uint64 = old_k
        if a0 == SIG_BLOCK:
            new_mask = old_k | want_k
        elif a0 == SIG_UNBLOCK:
            new_mask = old_k & ~want_k
        elif a0 == SIG_SETMASK:
            new_mask = want_k
        else:
            return ELINUX_INVAL
        # set_task_sig_mask force-clears SIGKILL/SIGSTOP — those can
        # never be blocked, so a SIG_BLOCK including them is silently
        # narrowed, exactly as Linux does.
        set_task_sig_mask(slot, new_mask)
    return 0


def _u_rt_sigreturn(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void rt_sigreturn(void).
    #
    # Reached via sig_trampoline (arch/x86/kernel/sigret_asm.S) after a
    # user signal handler returns. The ucontext built by
    # deliver_signal_to_user holds the interrupted RIP / RSP / RFLAGS
    # and the pre-handler signal mask; its address was stashed in the
    # task's sig_frame_uctx slot (rt_sigreturn takes no syscall args,
    # so it cannot be passed in a register).
    #
    # We rewrite the iret-return slots parked by syscall_64.S at
    # kstack_top-24 / -16 / -8 so the SYSRETQ closing this very syscall
    # lands back on the interrupted user instruction with the original
    # stack and flags, restore the signal mask, and clear the
    # in-handler flag so the next pending signal can be delivered.
    slot: uint64 = current_idx_get()
    uc: uint64 = get_task_sig_frame_uctx(slot)
    if uc == 0:
        # Stray rt_sigreturn — never entered a handler. Leave the iret
        # slots alone (the syscall just returns normally) and report
        # 0; a misbehaving binary that did this gets undefined-but-
        # contained behaviour rather than a kernel fault.
        return 0
    # SMAP v3e: the ucontext (`uc`) sits on the user stack (US=1). Bracket
    # the five CPL=0 reads below with STAC/CLAC so they survive
    # CR4.SMAP=1. No-op when SMAP is off.
    _ua_stac()
    saved_rip:    uint64 = cast[Ptr[uint64]](uc + UCTX_GREG_RIP_OFF)[0]
    saved_rsp:    uint64 = cast[Ptr[uint64]](uc + UCTX_GREG_RSP_OFF)[0]
    saved_rflags: uint64 = cast[Ptr[uint64]](uc + UCTX_GREG_EFL_OFF)[0]
    saved_rax:    uint64 = cast[Ptr[uint64]](uc + UCTX_GREG_RAX_OFF)[0]
    # uc_sigmask is stored in USER sigset_t convention (bit N-1); the
    # kernel sig_mask uses bit N — shift back by 1. A handler that
    # mutated uc_sigmask in place changes the resumed mask, exactly as
    # Linux's rt_sigreturn semantics promise.
    saved_mask:   uint64 = cast[Ptr[uint64]](uc + UCTX_SIGMASK_OFF)[0] << 1
    _ua_clac()

    rip_slot: Ptr[uint64]    = saved_user_rip_ptr()
    rsp_slot: Ptr[uint64]    = saved_user_rsp_ptr()
    rflags_slot: Ptr[uint64] = saved_user_rflags_ptr()
    rip_slot[0]    = saved_rip
    rflags_slot[0] = saved_rflags
    # RSP restore: park the interrupted RSP VERBATIM. syscall_64.S's sysret
    # tail loads the user RSP straight off the parked kernel slot
    # (`popq %rsp` at kstack_top-8, then `sysretq`) — it does NOT pop anything
    # off the USER stack, so there is nothing to "undo". The historical -8 /
    # -16 fixups assumed the OLD stub popped 1 / 2 words off the user stack;
    # the per-CPU rev (%r12/%r13 spilled to %gs:72/%gs:80, NOT the user stack)
    # removed those pops. deliver_signal_to_user already parks the RSP verbatim
    # ("no fixup needed"); rt_sigreturn was left with the stale -16, which
    # resumed the interrupted code 16 bytes LOW after a signal handler
    # returned. dash installs a SIGCHLD handler and takes a real SIGCHLD when a
    # forked child (e.g. `ls`, or the `-c` command's exec'd binary) exits mid-
    # wait4; the 16-byte stack shift then made a later __stack_chk_guard
    # compare read the wrong slot -> SIGABRT "stack smashing detected"
    # (code=134), or read an off-slot return address / mangled fn-pointer and
    # jumped to a wild address -> NX exec-fault va=0 (code=139). Parking the
    # RSP verbatim (symmetric with the signal-delivery capture) resumes the
    # interrupted code on its exact natural RSP.
    rsp_slot[0]    = saved_rsp

    # Restore the pre-handler mask and release the in-handler latch so
    # the exit-side delivery (which runs at this syscall's tail) can
    # deliver any signal that arrived while the handler ran.
    set_task_sig_mask(slot, saved_mask)
    set_task_sig_saved_mask(slot, 0)
    set_task_sig_in_handler(slot, 0)
    set_task_sig_frame_uctx(slot, 0)
    # CRITICAL: return the INTERRUPTED syscall's %rax. do_syscall puts
    # our return value into the caller's %rax; the interrupted code
    # resumes expecting its own syscall's result there (e.g. a write()
    # that failed with -EPIPE). Returning 0 would corrupt that.
    return cast[int64](saved_rax)


# =====================================================================
# #160: seccomp-lite — per-task syscall filter
# =====================================================================
#
# A real, working syscall-filtering capability for Linux-ABI userspace
# processes, enforced at THIS file's central dispatch boundary. Two
# install entry points feed one per-task state (mode + lite allow-list,
# stored in core.ad's TaskStruct, reached via accessors so core.ad keeps
# no static dependency on this layer):
#
#   * prctl(PR_SET_SECCOMP, mode, ...)   — the classic install path
#   * seccomp(operation, flags, args)    — the dedicated syscall (nr 317)
#
# Modes implemented:
#   SECCOMP_MODE_STRICT (1) — Linux strict mode, faithful. Once armed,
#     ONLY read / write / _exit / exit_group / rt_sigreturn are allowed;
#     ANY other syscall terminates the task with SIGSYS (31).
#   SECCOMP_MODE_FILTER (2) — a "lite" allow-list. Rather than a full
#     classic-BPF interpreter, we accept a small bitmap of permitted
#     syscall numbers (0..255) installed via SECCOMP_SET_MODE_FILTER's
#     args (see _u_seccomp). The strict always-allowed set is implicitly
#     permitted in this mode too (so a filtered task can always read its
#     own denial and exit cleanly). Default action for any nr not in the
#     allow-list is the same kill-with-SIGSYS as strict mode. This is the
#     documented "lite" simplification: the userspace ABI shape (mode
#     numbers, the seccomp(2)/prctl entry points, the SIGSYS kill on a
#     denied call) matches Linux closely enough for a musl program to
#     install it; only the filter REPRESENTATION (allow-list bitmap vs a
#     compiled BPF program) is simplified.
#
# Enforcement (seccomp_check_entry below) runs at syscall ENTRY in
# linux_u_syscall_dispatch, AFTER the ptrace enter-stop wrap and BEFORE
# the real handler. On a denial it posts SIGSYS to the current task and
# returns a "blocked" flag; the dispatcher then skips the real handler.
# SIGSYS is delivered through the normal Linux-ABI signal path — the
# exit-side signal_deliver_on_return in do_syscall builds the rt_sigframe
# if the task installed a SIGSYS handler, otherwise the default
# terminate-with-128+31 disposition runs at the next signal check. This
# composes cleanly with ptrace: the enter-stop has already happened, the
# real handler is skipped, and the exit-stop wrap reports the synthetic
# rc just like a real (denied) syscall would.

# prctl option + seccomp mode numbers (Linux <linux/prctl.h>,
# <linux/seccomp.h>).
PR_SET_SECCOMP:      uint64 = 22
PR_GET_SECCOMP:      uint64 = 21
# F10-8 / #457: Hamnix-namespace prctl extension. Linux's PR_* numbers
# currently top out around 78; 0x10000 leaves a wide gap so a future
# Linux PR_* can never collide. Arms the per-task NATIVE syscall
# allow-list bitmap (256-bit / 4 x uint64) over the native syscall nr
# space (kernel/sched/core.ad). Irrevocable, inherited across fork.
#
#   prctl(PR_SET_NATIVE_FILTER, bitmap_addr, bitmap_len, 0, 0)
#     bitmap_addr — user pointer to up to 32 bytes (4 x uint64).
#                   NULL ⇒ install an all-zero filter (denies every
#                   nr once armed).
#     bitmap_len  — bytes of user payload to copy; must be <= 32.
#                   A shorter payload zero-fills the upper words.
PR_SET_NATIVE_FILTER: uint64 = 0x10000
# §6: install a classic-BPF program as a seccomp filter. Hamnix-namespace
# extension (Linux PR_* < 80) so it can't collide with a future Linux
# PR_SET_*.
#
#   prctl(PR_SET_SECCOMP_BPF, filter_addr, filter_len, 0, 0)
#     filter_addr — user pointer to an array of `struct sock_filter`
#                   (the cBPF program). Each entry is 8 bytes:
#                   { u16 code; u8 jt; u8 jf; u32 k; }.
#     filter_len  — number of instructions (NOT bytes); each is 8 B.
#                   Must be >= 1, <= MAX_BPF_INSNS.
#
# This is the same cBPF program shape Linux seccomp-bpf accepts via
# prctl(PR_SET_SECCOMP, SECCOMP_MODE_FILTER, sock_fprog*) — only the
# CONTAINER is different. Linux passes a `struct sock_fprog` (len + ptr);
# Hamnix takes (addr, len) as two flat prctl args, mirroring the
# PR_SET_NATIVE_FILTER shape above. Avoiding the sock_fprog struct
# sidesteps any ABI-shape ambiguity in how a static-PIE binary lays the
# pointer field of a 16-byte mixed-width struct on the user stack.
PR_SET_SECCOMP_BPF:   uint64 = 0x10001
SECCOMP_MODE_DISABLED: uint64 = 0
SECCOMP_MODE_STRICT:   uint64 = 1
SECCOMP_MODE_FILTER:   uint64 = 2

# seccomp(2) operations (Linux <linux/seccomp.h>).
SECCOMP_SET_MODE_STRICT: uint64 = 0
SECCOMP_SET_MODE_FILTER: uint64 = 1

ELINUX_ACCES: int64 = -13          # -EACCES
ELINUX_FAULT: int64 = -14          # -EFAULT


def _seccomp_strict_allows(nr: uint64) -> int32:
    # The fixed strict-mode allow-set, identical to Linux: read, write,
    # _exit/exit_group, rt_sigreturn. Everything else is denied.
    if nr == SYS_read:
        return 1
    if nr == SYS_write:
        return 1
    if nr == SYS_exit:
        return 1
    if nr == SYS_exit_group:
        return 1
    if nr == SYS_rt_sigreturn:
        return 1
    return 0


def seccomp_check_entry(nr: uint64,
                        a0: uint64, a1: uint64, a2: uint64,
                        a3: uint64, a4: uint64, a5: uint64) -> int64:
    # Called at syscall ENTRY by linux_u_syscall_dispatch. The return is
    # an action code consumed by the dispatcher:
    #   0   ALLOW — run the real handler.
    #   1   BLOCKED with SIGSYS already posted; the dispatcher must
    #       short-circuit. The pending SIGSYS is delivered by
    #       do_syscall's exit-side signal_deliver_on_return (handler →
    #       rt_sigframe; no handler → default kill 128+31).
    #   <0  BLOCKED, return THIS value to userspace as the syscall rc.
    #       Used by SECCOMP_RET_ERRNO from a §6 classic-BPF filter — a
    #       Linux-shape ERRNO action returns -errno in the caller's
    #       %rax without raising SIGSYS, so a process can install
    #       "refuse open(2) with -EACCES" and keep running.
    slot: uint64 = current_idx_get()
    mode: uint64 = get_task_seccomp_mode(slot)

    # ---- bitmap / strict path (#160) ----
    if mode != SECCOMP_MODE_DISABLED:
        allowed: int32 = 0
        if mode == SECCOMP_MODE_STRICT:
            allowed = _seccomp_strict_allows(nr)
        else:
            if _seccomp_strict_allows(nr) != 0:
                allowed = 1
            elif seccomp_filter_allows(slot, nr) != 0:
                allowed = 1
        if allowed == 0:
            printk2("seccomp: pid=%d denied syscall nr=%d -> SIGSYS\n",
                    cast[int32](current_task_pid()), cast[int32](nr))
            signal_post(slot, SIGSYS)
            return 1

    # ---- §6 classic-BPF filter path ----
    # If the task has no BPF filters installed this is a single
    # bpf_task_has_filter check, so it stays cheap for the common
    # unfiltered case. With filters present we build seccomp_data once
    # and bpf_run_all walks every program, returning the cumulative
    # MIN (Linux's "lowest-numbered action wins" rule).
    if bpf_task_has_filter(slot) == 0:
        return 0
    rip: uint64 = saved_user_rip_ptr()[0]
    sd: Ptr[uint8] = bpf_seccomp_data_build(nr, rip, a0, a1, a2, a3, a4, a5)
    raw: uint32 = bpf_run_all(slot, sd)
    action: uint32 = raw & SECCOMP_RET_ACTION_FULL
    data:   uint32 = raw & SECCOMP_RET_DATA
    if action == SECCOMP_RET_ALLOW:
        return 0
    if action == SECCOMP_RET_LOG:
        printk2("seccomp_bpf: pid=%d log nr=%d (LOG action, allowed)\n",
                cast[int32](current_task_pid()), cast[int32](nr))
        return 0
    if action == SECCOMP_RET_ERRNO:
        # `data` is the errno value. Linux caps it at 4095; we just
        # propagate it. The kernel returns -data in the syscall rc.
        printk2("seccomp_bpf: pid=%d nr=%d -> ERRNO %d\n",
                cast[int32](nr), cast[int32](data), cast[int32](data))
        # Defensive: a 0 errno would be "allow"; promote to EPERM (1).
        e: uint32 = data
        if e == 0:
            e = 1
        return cast[int64](0) - cast[int64](e)
    if action == SECCOMP_RET_TRAP:
        # Post SIGSYS just like the bitmap-deny path; userspace
        # SIGSYS handler observes si_syscall=nr.
        printk2("seccomp_bpf: pid=%d nr=%d -> TRAP (SIGSYS)\n",
                cast[int32](current_task_pid()), cast[int32](nr))
        signal_post(slot, SIGSYS)
        return 1
    if action == SECCOMP_RET_TRACE:
        # Linux semantics: if no PTRACE_O_TRACESECCOMP tracer is
        # attached the action is ALLOW. Hamnix doesn't implement the
        # seccomp-trace ptrace event yet, so the safe-and-faithful
        # downgrade is ALLOW; revisit when ptrace gains the option.
        return 0
    # KILL_PROCESS / KILL_THREAD / anything else → SIGSYS-kill.
    printk2("seccomp_bpf: pid=%d nr=%d -> KILL (action=0x%x)\n",
            cast[int32](current_task_pid()), cast[int32](action))
    signal_post(slot, SIGSYS)
    return 1


def _seccomp_install_strict(slot: uint64) -> int64:
    # Arm strict mode on the current task. Irrevocable: set_task_seccomp_
    # mode refuses to lower an already-set mode, so a task can never
    # disarm itself. Re-installing strict over strict is a benign no-op.
    set_task_seccomp_mode(slot, SECCOMP_MODE_STRICT)
    return 0


def _seccomp_install_filter_allowlist(slot: uint64, uwords: uint64) -> int64:
    # Arm FILTER mode with the 4-word (256-bit) allow-list bitmap at the
    # USER address `uwords` (or all-zero if uwords==0 → only the implicit
    # strict set is permitted). This is the "lite" stand-in for a compiled
    # BPF program — see the module header for the simplification rationale.
    # #163: the bitmap is staged through copy_from_user; a faulting
    # pointer is -EFAULT and the task's seccomp state is left untouched.
    kw: Array[4, uint64]
    kw[0] = 0
    kw[1] = 0
    kw[2] = 0
    kw[3] = 0
    if uwords != 0:
        if copy_from_user(cast[uint64](&kw[0]), uwords, 32) != 0:
            return ELINUX_EFAULT
    i: uint64 = 0
    while i < 4:
        set_task_seccomp_filter(slot, i, kw[i])
        i = i + 1
    set_task_seccomp_mode(slot, SECCOMP_MODE_FILTER)
    return 0


def _u_seccomp(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int seccomp(unsigned int operation, unsigned int flags, void *args)
    #   a0 = operation, a1 = flags, a2 = args
    #
    # SECCOMP_SET_MODE_STRICT: arm strict mode (args must be NULL).
    # SECCOMP_SET_MODE_FILTER: Linux expects a `struct sock_fprog *` in
    #   args; our lite implementation instead treats args as an optional
    #   pointer to a 4-word (256-bit) allow-list bitmap of permitted
    #   syscall numbers. A musl program targeting Hamnix passes that
    #   bitmap; a program passing a real sock_fprog gets a default-deny
    #   filter (only the implicit strict set), which still kills on the
    #   first non-trivial syscall — safe, just coarser.
    op: uint64 = a0
    slot: uint64 = current_idx_get()
    if op == SECCOMP_SET_MODE_STRICT:
        return _seccomp_install_strict(slot)
    if op == SECCOMP_SET_MODE_FILTER:
        # SHIM POLICY (apt-install enabler): a real Debian binary (apt's
        # `store`/`http` acquire methods, systemd, etc.) passes a genuine
        # `struct sock_fprog *` (len + classic-BPF program pointer) here,
        # NOT Hamnix's lite 256-bit allow-list bitmap. Reinterpreting that
        # pointer's first 32 bytes AS a bitmap arms a garbage default-deny
        # FILTER that SIGSYS-kills the process on its next non-trivial
        # syscall — which is exactly why apt's `store` method aborted and
        # apt reported "method driver could not be found." We therefore
        # ACCEPT the install permissively (return 0) WITHOUT arming any
        # enforcement: the filter apt installs on ITSELF is defense-in-
        # depth that would have allowed all the syscalls apt needs anyway,
        # so not enforcing it weakens no boundary the rest of the system
        # relies on. NNP must be set first per Linux (apt does this).
        # Hamnix-native callers wanting REAL filtering use the dedicated
        # PR_SET_NATIVE_FILTER / PR_SET_SECCOMP_BPF prctl extensions.
        printk2("seccomp: pid=%d SET_MODE_FILTER accepted (permissive no-op)\n",
                cast[int32](current_task_pid()), 0)
        return 0
    set_current_errstr("seccomp: unsupported operation")
    return ELINUX_INVAL


def _u_prctl(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int prctl(int option, unsigned long arg2, ..., unsigned long arg5).
    #
    # Hamnix handles the operations busybox-static + glibc bring-up
    # actually exercise; everything else returns -EINVAL.
    #
    #   PR_SET_PDEATHSIG   1 — record signal to deliver when parent
    #                          dies (stored, not yet wired through)
    #   PR_GET_DUMPABLE    3 — reply 1 (Hamnix never produces core
    #                          dumps but the default IS dumpable)
    #   PR_SET_DUMPABLE    4 — accept silently
    #   PR_SET_NAME       15 — copy up to 15 bytes + NUL into comm
    #   PR_GET_NAME       16 — copy 16 bytes of comm out
    if a0 == 1:                                           # PR_SET_PDEATHSIG
        set_task_pdeathsig(current_idx_get(), a1)
        return 0
    if a0 == 3:                                           # PR_GET_DUMPABLE
        return 1
    if a0 == 4:                                           # PR_SET_DUMPABLE
        return 0
    if a0 == 15:                                          # PR_SET_NAME
        if a1 == 0:
            return ELINUX_INVAL
        # #163: pull the user name through strncpy_from_user into a
        # kernel scratch (stops at NUL, NUL-terminates), then install
        # it in comm. POSIX TASK_COMM_LEN is 16 INCLUDING the NUL.
        nbuf: Array[16, uint8]
        nlen: int64 = strncpy_from_user(cast[uint64](&nbuf[0]), a1, 16)
        if nlen < 0:
            return ELINUX_EFAULT
        nbuf[15] = 0
        dst: Ptr[uint8] = get_task_comm_ptr(current_idx_get())
        i: uint64 = 0
        ended: int32 = 0
        while i < 16:
            if ended == 0:
                dst[i] = nbuf[i]
                if nbuf[i] == 0:
                    ended = 1
            else:
                dst[i] = 0
            i = i + 1
        return 0
    if a0 == 16:                                          # PR_GET_NAME
        if a1 == 0:
            return ELINUX_INVAL
        # #163: comm is kernel memory; copy_to_user lands all 16 bytes.
        src: Ptr[uint8] = get_task_comm_ptr(current_idx_get())
        if copy_to_user(a1, cast[uint64](src), 16) != 0:
            return ELINUX_EFAULT
        return 0
    if a0 == 38:                                          # PR_SET_NO_NEW_PRIVS
        # prctl(PR_SET_NO_NEW_PRIVS, 1, 0, 0, 0). apt's acquire methods
        # (the `store` decompress/cache worker, the `file`/`http` fetchers,
        # etc.) ALWAYS call this immediately before installing their seccomp
        # filter — Linux mandates NNP be set first (else seccomp filter
        # install is -EACCES for a non-CAP_SYS_ADMIN caller). Returning
        # -EINVAL here makes the method _error->Errno("prctl") and exit,
        # which apt surfaces as "method driver ... could not be found."
        # Linux requires arg2==1 and args 3..5 be 0; honour the set as a
        # one-way ratchet (set_task_no_new_privs ignores a 0).
        if a1 != 0 and a1 != 1:
            return ELINUX_INVAL
        if a2 != 0 or a3 != 0 or a4 != 0:
            return ELINUX_INVAL
        set_task_no_new_privs(current_idx_get(), a1)
        return 0
    if a0 == 39:                                          # PR_GET_NO_NEW_PRIVS
        return cast[int64](get_task_no_new_privs(current_idx_get()))
    if a0 == PR_SET_SECCOMP:                              # #160
        # prctl(PR_SET_SECCOMP, mode, filter). mode==1 strict; mode==2
        # filter (arg3 = optional allow-list bitmap pointer, our lite
        # ABI). Feeds the same per-task state as seccomp(2).
        if a1 == SECCOMP_MODE_STRICT:
            return _seccomp_install_strict(current_idx_get())
        if a1 == SECCOMP_MODE_FILTER:
            # Same permissive accept as seccomp(2) SET_MODE_FILTER — a real
            # Debian binary passes a `struct sock_fprog *`, not our lite
            # bitmap; accept without arming so the process is not SIGSYS-
            # killed on its next syscall. See _u_seccomp for the rationale.
            printk2("seccomp: pid=%d PR_SET_SECCOMP filter accepted (no-op)\n",
                    cast[int32](current_task_pid()), 0)
            return 0
        set_current_errstr("prctl: bad seccomp mode")
        return ELINUX_INVAL
    if a0 == PR_GET_SECCOMP:                              # #160
        # Returns the current seccomp mode (0/1/2). Linux returns 0 or 2;
        # we also surface 1 for strict so a test can observe it.
        return cast[int64](get_task_seccomp_mode(current_idx_get()))
    if a0 == PR_SET_NATIVE_FILTER:                        # F10-8 / #457
        # prctl(PR_SET_NATIVE_FILTER, bitmap_addr, bitmap_len). Stages
        # the user's 256-bit allow-list bitmap into a kernel scratch and
        # arms the per-task NATIVE syscall filter (kernel/sched/core.ad).
        # Once armed it is IRREVOCABLE and inherited across fork/clone
        # (same ratchet as Layer-2 seccomp).
        slot_nf: uint64 = current_idx_get()
        bitmap_addr: uint64 = a1
        bitmap_len:  uint64 = a2
        if bitmap_len > 32:
            return ELINUX_INVAL
        kn: Array[4, uint64]
        kn[0] = 0
        kn[1] = 0
        kn[2] = 0
        kn[3] = 0
        if bitmap_addr != 0 and bitmap_len != 0:
            if copy_from_user(cast[uint64](&kn[0]), bitmap_addr,
                              bitmap_len) != 0:
                return ELINUX_EFAULT
        ni: uint64 = 0
        while ni < 4:
            set_task_seccomp_native_filter(slot_nf, ni, kn[ni])
            ni = ni + 1
        set_task_seccomp_native_armed(slot_nf, 1)
        return 0
    if a0 == PR_SET_SECCOMP_BPF:                          # §6: cBPF
        # prctl(PR_SET_SECCOMP_BPF, filter_addr, filter_len). Stages
        # `filter_len` cBPF instructions (8 B each) at user address
        # `filter_addr` into the BPF program pool (kernel/seccomp_bpf.ad).
        # Cumulative: a second install prepends another filter; every
        # filter runs at every syscall and the LOWEST action wins
        # (Linux seccomp-bpf semantics). Inherited across fork/clone
        # via bpf_inherit_to_child in
        # arch/x86/kernel/syscall.ad::seccomp_inherit_to_child.
        return bpf_install_filter(current_idx_get(), a1, a2)
    return ELINUX_INVAL


def _u_unimpl_pread64(a0: uint64, a1: uint64, a2: uint64,
                      a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t pread64(int fd, void *buf, size_t count, off_t offset).
    # U42: ld.so reads the ELF header of each DSO via pread64 before
    # mmap'ing the segments. Implement as lseek(SEEK_SET, offset) +
    # read — non-atomic w.r.t. concurrent seeks on the same fd, but
    # nothing in our single-threaded ld.so path competes.
    #
    # Name kept as _u_unimpl_pread64 for dispatch-table compatibility
    # — the prefix is now misleading but renaming the symbol cascades
    # into the dispatcher. Wrapping under the old name is enough.
    fd: int32 = cast[int32](a0)
    buf: uint64 = a1
    cnt: uint64 = a2
    off: int64 = cast[int64](a3)
    if cnt == 0:
        return 0
    # #459: pread64 on a directory fd is EISDIR — vfs_read no longer
    # EISDIRs at its layer (native callers drain the dir buffer).
    if vfs_fd_is_dir(fd) != 0:
        return cast[int64](-21)                  # -EISDIR
    rc: int64 = vfs_lseek(fd, off, 0)             # SEEK_SET
    if rc < 0:
        return rc
    return vfs_read(fd, cast[Ptr[uint8]](buf), cnt)


def _u_unimpl_pwrite64(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t pwrite64(int fd, const void *buf, size_t count, off_t off).
    # Positioned write: the bytes land at `off`, and the fd's own file
    # position is LEFT UNCHANGED (that's the whole point of pwrite vs a
    # naive lseek+write). The kernel has no atomic positioned-write
    # primitive, so we do save / seek / write / restore around vfs_write:
    #   1. snapshot the current position (SEEK_CUR by 0),
    #   2. seek to the target offset (SEEK_SET),
    #   3. write,
    #   4. seek back to the snapshot.
    # Non-atomic w.r.t. a concurrent seek on the same fd, but nothing in
    # our single-threaded guest paths competes. On a stream-shaped fd
    # where SEEK_CUR fails (pipe / tty / /dev/null), vfs_lseek returns an
    # errno < 0 and we surface it — pwrite on a pipe is -ESPIPE on Linux.
    #
    # Name kept as _u_unimpl_pwrite64 for dispatch-table compatibility
    # — same convention _u_unimpl_pread64 / _u_unimpl_readlink follow.
    fd: int32 = cast[int32](a0)
    buf: uint64 = a1
    cnt: uint64 = a2
    off: int64 = cast[int64](a3)
    if cnt == 0:
        return 0
    cur: int64 = vfs_lseek(fd, 0, 1)              # SEEK_CUR (snapshot)
    if cur < 0:
        return cur
    rc: int64 = vfs_lseek(fd, off, 0)             # SEEK_SET (to offset)
    if rc < 0:
        return rc
    n: int64 = vfs_write(fd, cast[Ptr[uint8]](buf), cnt)
    # Restore the original position regardless of the write outcome so
    # the fd looks untouched to the caller. If the restore itself fails
    # we still return the write result — losing the position is the
    # lesser evil and matches what a best-effort kernel does on EIO.
    vfs_lseek(fd, cur, 0)                         # SEEK_SET (restore)
    return n


def _u_readv(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t readv(int fd, const struct iovec *iov, int iovcnt).
    # Mirror image of _u_writev: walk the iovec[] (16 bytes per entry,
    # base + len, no padding) and fan each chunk through vfs_read.
    # Linux semantics on partial failure: if the first vfs_read returns
    # an error, propagate it; otherwise stop on first error and return
    # bytes-so-far so the caller can re-issue and surface errno on the
    # next call. A short read (n < len) is treated as EOF/back-pressure
    # and we stop, same as _u_writev.
    fd: int32 = cast[int32](a0)
    iov: uint64 = a1
    cnt: uint64 = a2
    if cnt == 0:
        return 0
    if iov == 0:
        return ELINUX_INVAL
    # #459: POSIX readv(2) on a directory fd is EISDIR. Mirrors the same
    # check in _u_read_body; vfs_read no longer EISDIRs at its layer.
    if vfs_fd_is_dir(fd) != 0:
        return cast[int64](-21)                  # -EISDIR
    # AF_UNIX: a unix-socket fd's readv(2) drains the afunix stream conduit
    # (u_unixsock.ad), NOT vfs_read (whose AF_UNIX-tag decode is bogus).
    # Mirror _u_read's afunix arm per iov so scatter-reads of X replies /
    # wl events work. A non-blocking fd surfaces EAGAIN; a blocking fd
    # yields until data arrives (matching _u_read).
    rv_uxep: int32 = _u_afunix_ep(fd)
    if rv_uxep >= 0:
        rv_nb: int32 = _u_fd_is_nonblock(fd)
        rv_total: int64 = 0
        ri: uint64 = 0
        while ri < cnt:
            rentry: uint64 = iov + ri * 16
            rbase:  uint64 = 0
            rlen:   uint64 = 0
            if get_user_64(rentry, &rbase) != 0:
                if rv_total == 0:
                    return ELINUX_EFAULT
                return rv_total
            if get_user_64(rentry + 8, &rlen) != 0:
                if rv_total == 0:
                    return ELINUX_EFAULT
                return rv_total
            if rlen == 0:
                ri = ri + 1
                continue
            rsn: int64 = afunix_recv_stream(rv_uxep, rbase, rlen)
            if rsn == AFU_EAGAIN:
                if rv_nb != 0:
                    if rv_total > 0:
                        return rv_total
                    return AFU_EAGAIN
                while rsn == AFU_EAGAIN:
                    yield_to_others()
                    rsn = afunix_recv_stream(rv_uxep, rbase, rlen)
            if rsn < 0:
                if rv_total == 0:
                    return rsn
                return rv_total
            rv_total = rv_total + rsn
            # Short read (ring drained / EOF) — stop; the caller re-issues.
            if cast[uint64](rsn) < rlen:
                return rv_total
            ri = ri + 1
        return rv_total
    total: int64 = 0
    i: uint64 = 0
    while i < cnt:
        # #163: the iovec entry itself lives in user memory — fetch
        # base/len through the page tables; the data lands via the
        # bounce-buffer read tail (_u_vfs_read_user).
        entry: uint64 = iov + i * 16
        base: uint64 = 0
        len:  uint64 = 0
        if get_user_64(entry, &base) != 0:
            if total == 0:
                return ELINUX_EFAULT
            return total
        if get_user_64(entry + 8, &len) != 0:
            if total == 0:
                return ELINUX_EFAULT
            return total
        if len == 0:
            i = i + 1
            continue
        n: int64 = _u_vfs_read_user(fd, base, len)
        if n < 0:
            if total == 0:
                return n                                  # propagate errno
            return total
        total = total + n
        if cast[uint64](n) < len:
            return total                                  # EOF / short read
        i = i + 1
    return total


def _u_writev(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t writev(int fd, const struct iovec *iov, int iovcnt).
    # Linux's iovec is { void *iov_base; size_t iov_len; } — 16 bytes
    # per entry, no padding. We walk the array and forward each chunk
    # to vfs_write, accumulating bytes written. Linux semantics on
    # partial failure: if the first vfs_write returns an error, propagate
    # it; otherwise stop on first error and return bytes-so-far (the
    # caller can call writev again to discover the underlying errno on
    # the next chunk).
    fd: int32 = cast[int32](a0)
    iov: uint64 = a1
    cnt: uint64 = a2
    if cnt == 0:
        return 0
    if iov == 0:
        return ELINUX_INVAL
    # AF_UNIX: a unix-socket fd's writev(2) MUST gather into the peer's
    # afunix stream conduit (u_unixsock.ad), NOT vfs_write — the AF_UNIX
    # fd_buf tag decodes as a bogus usock record whose write path returns
    # -EPIPE, and writev's SIGPIPE-on-EPIPE contract then KILLS the writer.
    # This is exactly how X clients die: libxcb flushes X protocol via
    # writev(), so `DISPLAY=:0 xdpyinfo`/`xeyes` connect fine then get
    # SIGPIPE on their first request flush. Mirror _u_write's afunix arm.
    wv_uxep: int32 = _u_afunix_ep(fd)
    if wv_uxep >= 0:
        wv_nb: int32 = _u_fd_is_nonblock(fd)
        wv_total: int64 = 0
        wi: uint64 = 0
        while wi < cnt:
            wentry: uint64 = iov + wi * 16
            wbase:  uint64 = 0
            wlen:   uint64 = 0
            if get_user_64(wentry, &wbase) != 0:
                if wv_total == 0:
                    return ELINUX_EFAULT
                return wv_total
            if get_user_64(wentry + 8, &wlen) != 0:
                if wv_total == 0:
                    return ELINUX_EFAULT
                return wv_total
            if wlen == 0:
                wi = wi + 1
                continue
            wsn: int64 = afunix_send_stream(wv_uxep, wbase, wlen)
            if wsn == AFU_EAGAIN:
                if wv_nb != 0:
                    if wv_total > 0:
                        return wv_total
                    return AFU_EAGAIN
                while wsn == AFU_EAGAIN:
                    yield_to_others()
                    wsn = afunix_send_stream(wv_uxep, wbase, wlen)
            if wsn == ELINUX_PIPE:
                signal_post(current_idx_get(), SIGPIPE)
                if wv_total == 0:
                    return wsn
                return wv_total
            if wsn < 0:
                if wv_total == 0:
                    return wsn
                return wv_total
            wv_total = wv_total + wsn
            # Short (ring back-pressure) — stop; the caller loops on the
            # remainder (afunix_send_stream caps a write at the ring size).
            if cast[uint64](wsn) < wlen:
                return wv_total
            wi = wi + 1
        return wv_total
    total: int64 = 0
    i: uint64 = 0
    while i < cnt:
        # Each iovec entry: base at offset 0, len at offset 8.
        # #163: the entry lives in user memory — fetch base/len through
        # the page tables; the data is staged via the chunked bounce
        # write tail (_u_vfs_write_user).
        entry: uint64 = iov + i * 16
        base: uint64 = 0
        len:  uint64 = 0
        if get_user_64(entry, &base) != 0:
            if total == 0:
                return ELINUX_EFAULT
            return total
        if get_user_64(entry + 8, &len) != 0:
            if total == 0:
                return ELINUX_EFAULT
            return total
        if len == 0:
            i = i + 1
            continue
        n: int64 = _u_vfs_write_user(fd, base, len)
        if n < 0:
            # §3: SIGPIPE if the underlying pipe / socket broke —
            # same contract as write(2)/sendto(2).
            if n == ELINUX_PIPE:
                signal_post(current_idx_get(), SIGPIPE)
            if total == 0:
                return n                                  # propagate errno
            return total                                  # short write
        total = total + n
        # If a chunk wrote fewer bytes than requested, stop here so
        # we don't keep hammering a stream that is back-pressured.
        if cast[uint64](n) < len:
            return total
        i = i + 1
    return total


def _u_preadv(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t preadv(int fd, const struct iovec *iov, int iovcnt,
    #                off_t offset)
    # Positioned scatter-read: seek to `offset` (SEEK_SET) then run the
    # ordinary readv walk. Unlike pread64 the fd position IS advanced by
    # the read (Linux preadv leaves it advanced past the last byte read,
    # which the lseek+readv composition naturally produces). offset is
    # split across a3 (low) — the kernel ABI passes a single 64-bit off
    # in a3 for the x86_64 preadv (pos_l/pos_h are a4/a5 only on 32-bit).
    fd: int32 = cast[int32](a0)
    off: int64 = cast[int64](a3)
    rc: int64 = vfs_lseek(fd, off, 0)                    # SEEK_SET
    if rc < 0:
        return rc
    return _u_readv(a0, a1, a2, 0, 0, 0)


def _u_pwritev(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t pwritev(int fd, const struct iovec *iov, int iovcnt,
    #                 off_t offset)
    # Positioned scatter-write: seek to `offset` then run the ordinary
    # writev walk. The fd position is advanced past the last byte written
    # (the lseek+writev composition gives exactly that).
    fd: int32 = cast[int32](a0)
    off: int64 = cast[int64](a3)
    rc: int64 = vfs_lseek(fd, off, 0)                    # SEEK_SET
    if rc < 0:
        return rc
    return _u_writev(a0, a1, a2, 0, 0, 0)


# sendfile(2) chunk buffer. Stays on the stack — small enough that no
# kmalloc is needed, big enough that file-to-pipe transfers don't
# thrash the syscall ring (busybox cat copies a 4 KiB block at a time
# in its fallback path, so we match that grain).
SENDFILE_CHUNK: uint64 = 4096


def _u_sendfile(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t sendfile(int out_fd, int in_fd, off_t *offset, size_t count)
    # Hamnix has no zero-copy splice — we bounce through a stack buffer.
    # The observable behaviour matches Linux for regular-file -> any-fd:
    #
    #   * If offset != NULL, *offset is the starting position in in_fd
    #     (in_fd's own position is NOT advanced — POSIX-style — so we
    #     seek to *offset, copy `count` bytes, then write the new
    #     position back to *offset).
    #   * If offset == NULL, read advances in_fd's position normally.
    #   * Return bytes copied, or -errno on the first failure with
    #     nothing copied yet (otherwise return the partial total — same
    #     "errno surfaces on the next call" convention as writev).
    #
    # Promotes busybox cat off its read+write fallback and gives `cp`
    # a single-syscall fast path for future U-milestones.
    out_fd: int32 = cast[int32](a0)
    in_fd:  int32 = cast[int32](a1)
    off_ptr: uint64 = a2
    remaining: uint64 = a3
    if remaining == 0:
        return 0

    # If the caller supplied a *offset, seek in_fd there before the
    # copy. Read it once, write the updated value back at the end.
    cur_off: int64 = 0
    if off_ptr != 0:
        # SMAP: *offset is a user pointer — read it through the page tables.
        co: uint64 = 0
        if get_user_64(off_ptr, &co) != 0:
            return ELINUX_FAULT
        cur_off = cast[int64](co)
        rc: int64 = vfs_lseek(in_fd, cur_off, SEEK_SET)
        if rc < 0:
            return rc
        cur_off = rc

    buf: Array[4096, uint8]
    total: int64 = 0
    # do-while: at least one read attempt (caller asked for count > 0).
    cont: int32 = 1
    while cont != 0:
        want: uint64 = remaining
        if want > SENDFILE_CHUNK:
            want = SENDFILE_CHUNK
        n: int64 = vfs_read(in_fd, &buf[0], want)
        if n < 0:
            if total == 0:
                return n
            cont = 0
            continue
        if n == 0:
            cont = 0                                      # EOF
            continue
        got: uint64 = cast[uint64](n)
        w: int64 = vfs_write(out_fd, &buf[0], got)
        if w < 0:
            if total == 0:
                return w
            cont = 0
            continue
        total = total + w
        if cast[uint64](w) < got:
            # Short write — drop the remainder, mirror writev's
            # back-pressure-stop behaviour.
            cont = 0
            continue
        remaining = remaining - got
        cur_off = cur_off + cast[int64](got)
        if remaining == 0:
            cont = 0

    if off_ptr != 0:
        # SMAP: *offset write-back through the page tables.
        put_user_64(cast[uint64](cur_off), off_ptr)
    return total


# copy_file_range(2) staging buffer. Module-scope so the copy loop never
# blows the syscall stack — sized to match sendfile's grain.
CFR_CHUNK: uint64 = 4096
_cfr_buf: Array[4096, uint8]


def _u_copy_file_range(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t copy_file_range(int fd_in, off_t *off_in,
    #                         int fd_out, off_t *off_out,
    #                         size_t len, unsigned int flags)
    #
    # Copy up to `len` bytes from fd_in to fd_out. Each side carries its
    # own optional off_t* with the same semantics as sendfile's offset:
    #   * off_in  != NULL: read starts at *off_in, fd_in's own position is
    #                      NOT advanced, and *off_in is updated by the
    #                      bytes copied.
    #   * off_in  == NULL: read uses/advances fd_in's position.
    #   * off_out != NULL: write starts at *off_out, fd_out's own position
    #                      is NOT advanced, and *off_out is updated.
    #   * off_out == NULL: write uses/advances fd_out's position.
    # flags must be 0 (Linux reserves them); anything else is -EINVAL.
    #
    # No reflink / server-side copy — we bounce through a module-scope
    # staging buffer over the same VFS read/write path sendfile uses.
    fd_in:  int32 = cast[int32](a0)
    off_in_ptr: uint64 = a1
    fd_out: int32 = cast[int32](a2)
    off_out_ptr: uint64 = a3
    remaining: uint64 = a4
    flags: uint64 = a5

    if flags != 0:
        return ELINUX_INVAL
    if fd_in < 0 or fd_out < 0:
        return ELINUX_BADF
    if remaining == 0:
        return 0

    # Seek each side to its supplied *offset before the copy. We read the
    # pointer once and write the updated position back at the end so the
    # underlying fd position stays untouched in the pointer case.
    in_off: int64 = 0
    if off_in_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_in
        in_off = cast[Ptr[int64]](off_in_ptr)[0]
        _ua_clac()
        ri: int64 = vfs_lseek(fd_in, in_off, SEEK_SET)
        if ri < 0:
            return ri
        in_off = ri
    out_off: int64 = 0
    if off_out_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_out
        out_off = cast[Ptr[int64]](off_out_ptr)[0]
        _ua_clac()
        ro: int64 = vfs_lseek(fd_out, out_off, SEEK_SET)
        if ro < 0:
            return ro
        out_off = ro

    total: int64 = 0
    cont: int32 = 1
    while cont != 0:
        want: uint64 = remaining
        if want > CFR_CHUNK:
            want = CFR_CHUNK
        # off_in pointer case: re-seek fd_in each iteration so fd_in's own
        # position is never the thing we advance (matches POSIX sendfile).
        if off_in_ptr != 0:
            rs: int64 = vfs_lseek(fd_in, in_off, SEEK_SET)
            if rs < 0:
                if total == 0:
                    return rs
                cont = 0
                continue
        n: int64 = vfs_read(fd_in, &_cfr_buf[0], want)
        if n < 0:
            if total == 0:
                return n
            cont = 0
            continue
        if n == 0:
            cont = 0                                      # EOF
            continue
        got: uint64 = cast[uint64](n)
        # off_out pointer case: re-seek fd_out so its own position is
        # untouched, then write the chunk.
        if off_out_ptr != 0:
            rw: int64 = vfs_lseek(fd_out, out_off, SEEK_SET)
            if rw < 0:
                if total == 0:
                    return rw
                cont = 0
                continue
        w: int64 = vfs_write(fd_out, &_cfr_buf[0], got)
        if w < 0:
            if total == 0:
                return w
            cont = 0
            continue
        total = total + w
        in_off = in_off + w
        out_off = out_off + w
        if cast[uint64](w) < got:
            # Short write — drop the remainder.
            cont = 0
            continue
        remaining = remaining - got
        if remaining == 0:
            cont = 0

    if off_in_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_in
        cast[Ptr[int64]](off_in_ptr)[0] = in_off
        _ua_clac()
    if off_out_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_out
        cast[Ptr[int64]](off_out_ptr)[0] = out_off
        _ua_clac()
    return total


# §kmod handlers -----------------------------------------------------
#
# init_module / finit_module / delete_module: the Linux module-management
# trio. They marshal user-supplied (or fd-backed) .ko bytes into Hamnix's
# existing kmod_linux_load loader and resolve a module name back to its
# loaded slot for kmod_linux_unload. The loader itself is unchanged — we
# only do the user<->kernel buffer plumbing here.
#
# A cap on the image we'll accept: the loader backs the .ko in pages via
# alloc_pages (MAX_ORDER = 4 MiB), so an oversized request would fail
# there anyway. 8 MiB is comfortably above any real .ko while bounding a
# bogus `len` before we even try to allocate.
KMOD_MAX_IMAGE: uint64 = 8388608        # 8 MiB
# Chunk size for the finit_module fd read loop.
KMOD_READ_CHUNK: uint64 = 65536


def _u_init_module(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long init_module(void *module_image, unsigned long len,
    #                  const char *param_values)
    #
    # Copy `len` bytes of the .ko image out of user memory into a kernel
    # buffer, hand it to the in-kernel loader, and free the buffer. The
    # param_values string is accepted but ignored — Hamnix modules carry
    # no module_param plumbing here.
    uimg: uint64 = a0
    ulen: uint64 = a1
    if uimg == 0 or ulen == 0:
        return ELINUX_INVAL
    if ulen > KMOD_MAX_IMAGE:
        return ELINUX_NOMEM
    kbuf: uint64 = kmalloc(ulen)
    if kbuf == 0:
        return ELINUX_NOMEM
    # Single translated copy of the whole image; a bad user pointer
    # surfaces as -EFAULT rather than a kernel #PF.
    if copy_from_user(kbuf, uimg, ulen) != 0:
        kfree(kbuf)
        return ELINUX_EFAULT
    slot: int32 = kmod_linux_load(cast[Ptr[uint8]](kbuf), ulen)
    kfree(kbuf)
    if slot < 0:
        # Loader returns a negative -errno-ish code; map anything we don't
        # specifically recognise onto -ENOEXEC (the kernel's generic
        # "not a loadable module" answer for init_module).
        if cast[int64](slot) == ELINUX_NOMEM:
            return ELINUX_NOMEM
        return ELINUX_NOEXEC
    return 0


def _u_finit_module(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long finit_module(int fd, const char *param_values, int flags)
    #
    # The path real modern insmod/modprobe use: read the entire .ko out of
    # an already-open fd into a kernel buffer, then load it. We size the
    # file via lseek(SEEK_END); if that fails (stream fd) we fall back to a
    # grow-by-chunks read loop. param_values + flags are accepted, ignored.
    fd: int32 = cast[int32](a0)
    if fd < 0:
        return ELINUX_BADF

    fsz: int64 = _u_file_size_via_lseek(fd)
    if fsz > 0:
        # Known size: one allocation, seek to 0, read it all.
        total_sz: uint64 = cast[uint64](fsz)
        if total_sz > KMOD_MAX_IMAGE:
            return ELINUX_NOMEM
        kbuf: uint64 = kmalloc(total_sz)
        if kbuf == 0:
            return ELINUX_NOMEM
        sk: int64 = vfs_lseek(fd, 0, 0)            # SEEK_SET
        if sk < 0:
            kfree(kbuf)
            return ELINUX_NOEXEC
        got: uint64 = 0
        ok: int32 = 1
        while got < total_sz:
            want: uint64 = total_sz - got
            n: int64 = vfs_read(fd, cast[Ptr[uint8]](kbuf + got), want)
            if n < 0:
                ok = 0
                break
            if n == 0:
                break                              # short EOF — load what we have
            got = got + cast[uint64](n)
        if ok == 0:
            kfree(kbuf)
            return ELINUX_NOEXEC
        slot: int32 = kmod_linux_load(cast[Ptr[uint8]](kbuf), got)
        kfree(kbuf)
        if slot < 0:
            if cast[int64](slot) == ELINUX_NOMEM:
                return ELINUX_NOMEM
            return ELINUX_NOEXEC
        return 0

    # Unknown size (lseek-rejecting fd): grow a buffer by reading chunks.
    cap: uint64 = KMOD_READ_CHUNK
    buf2: uint64 = kmalloc(cap)
    if buf2 == 0:
        return ELINUX_NOMEM
    used: uint64 = 0
    fail: int32 = 0
    cont: int32 = 1
    while cont != 0:
        if used == cap:
            # Grow ×2 (bounded), copy, free old.
            newcap: uint64 = cap * 2
            if newcap > KMOD_MAX_IMAGE:
                newcap = KMOD_MAX_IMAGE
            if newcap == cap:
                fail = 1                           # exceeded the image cap
                break
            nb: uint64 = kmalloc(newcap)
            if nb == 0:
                fail = 1
                break
            memcpy(cast[Ptr[uint8]](nb), cast[Ptr[uint8]](buf2), used)
            kfree(buf2)
            buf2 = nb
            cap = newcap
        r: int64 = vfs_read(fd, cast[Ptr[uint8]](buf2 + used), cap - used)
        if r < 0:
            fail = 1
            break
        if r == 0:
            cont = 0                               # EOF
            continue
        used = used + cast[uint64](r)
    if fail != 0 or used == 0:
        kfree(buf2)
        if used == 0:
            return ELINUX_NOEXEC
        return ELINUX_NOMEM
    slot2: int32 = kmod_linux_load(cast[Ptr[uint8]](buf2), used)
    kfree(buf2)
    if slot2 < 0:
        if cast[int64](slot2) == ELINUX_NOMEM:
            return ELINUX_NOMEM
        return ELINUX_NOEXEC
    return 0


# delete_module name scratch — MODULE_NAME_LEN-shaped, NUL-terminated.
_kmod_delname: Array[64, uint8]


def _u_delete_module(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long delete_module(const char *name_user, int flags)
    #
    # Copy the NUL-terminated module name out of user memory (bounded),
    # resolve it to its loaded slot, and run the loader's unload. flags
    # (O_NONBLOCK / O_TRUNC force) are accepted but ignored.
    uname: uint64 = a0
    if uname == 0:
        return ELINUX_EFAULT
    # strncpy_from_user returns the length copied (>= 0) or -EFAULT.
    cl: int64 = strncpy_from_user(cast[uint64](&_kmod_delname[0]), uname, 64)
    if cl < 0:
        return ELINUX_EFAULT
    if cl >= 64:
        return ELINUX_NAMETOOLONG
    _kmod_delname[63] = 0
    slot: int32 = kmod_linux_find_by_name(&_kmod_delname[0])
    if slot < 0:
        return ELINUX_NOENT
    rc: int32 = kmod_linux_unload(slot)
    if rc < 0:
        if cast[int64](rc) == ELINUX_NOENT:
            return ELINUX_NOENT
        return ELINUX_INVAL
    return 0


# splice/tee/vmsplice staging buffer. Module-scope so the move loop
# never blows the syscall stack — matches sendfile / copy_file_range's
# 4 KiB grain so a pipe<->file move fills the ring in the same cadence.
SPLICE_CHUNK: uint64 = 4096
_splice_buf: Array[4096, uint8]


def _u_splice(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t splice(int fd_in, loff_t *off_in,
    #                int fd_out, loff_t *off_out,
    #                size_t len, unsigned int flags)
    #
    # Move up to `len` bytes between fd_in and fd_out where AT LEAST ONE
    # side is an anonymous pipe. Three shapes:
    #   * pipe -> file : read from the pipe (vfs_read routes the
    #                    FD_PIPE_MARK_R arm), write into the file. off_out
    #                    seeks the file side; off_in on a pipe is ESPIPE.
    #   * file -> pipe : read the file (off_in seeks it), write the pipe.
    #                    off_out on a pipe is ESPIPE.
    #   * pipe -> pipe : read in-pipe, write out-pipe. Neither offset is
    #                    allowed (both ESPIPE).
    # EINVAL when neither side is a pipe. EBADF for a bad fd. Bytes are
    # bounced through a kernel staging buffer over the same vfs read/write
    # path copy_file_range uses, so the byte stream is identical — no
    # SPLICE_F_MOVE page-stealing (Linux is free to fall back to a copy,
    # and every copy-semantics caller is happy with that).
    fd_in:  int32 = cast[int32](a0)
    off_in_ptr:  uint64 = a1
    fd_out: int32 = cast[int32](a2)
    off_out_ptr: uint64 = a3
    remaining: uint64 = a4

    if fd_in < 0 or fd_out < 0:
        return ELINUX_BADF
    in_is_pipe:  int32 = vfs_fd_is_pipe_read(fd_in)
    out_is_pipe: int32 = vfs_fd_is_pipe_write(fd_out)
    # At least one end must be a pipe (Linux requires exactly the read
    # end of fd_in or the write end of fd_out to be a pipe).
    if in_is_pipe == 0 and out_is_pipe == 0:
        return ELINUX_INVAL
    # Offsets are illegal on the pipe side(s).
    if in_is_pipe != 0 and off_in_ptr != 0:
        return ELINUX_SPIPE
    if out_is_pipe != 0 and off_out_ptr != 0:
        return ELINUX_SPIPE
    if remaining == 0:
        return 0

    # Seek the seekable (non-pipe) side(s) to the supplied *offset. We
    # read the pointer once and write the advanced value back at the end
    # so the underlying fd position stays untouched in the pointer case
    # (matches copy_file_range / sendfile).
    in_off: int64 = 0
    if off_in_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_in
        in_off = cast[Ptr[int64]](off_in_ptr)[0]
        _ua_clac()
        ri: int64 = vfs_lseek(fd_in, in_off, SEEK_SET)
        if ri < 0:
            return ri
        in_off = ri
    out_off: int64 = 0
    if off_out_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_out
        out_off = cast[Ptr[int64]](off_out_ptr)[0]
        _ua_clac()
        ro: int64 = vfs_lseek(fd_out, out_off, SEEK_SET)
        if ro < 0:
            return ro
        out_off = ro

    total: int64 = 0
    cont: int32 = 1
    while cont != 0:
        want: uint64 = remaining
        if want > SPLICE_CHUNK:
            want = SPLICE_CHUNK
        # off_in pointer case: re-seek fd_in each iteration so its own
        # position is never the thing we advance.
        if off_in_ptr != 0:
            rs: int64 = vfs_lseek(fd_in, in_off, SEEK_SET)
            if rs < 0:
                if total == 0:
                    return rs
                cont = 0
                continue
        n: int64 = vfs_read(fd_in, &_splice_buf[0], want)
        if n < 0:
            if total == 0:
                return n
            cont = 0
            continue
        if n == 0:
            cont = 0                                      # EOF
            continue
        got: uint64 = cast[uint64](n)
        if off_out_ptr != 0:
            rw: int64 = vfs_lseek(fd_out, out_off, SEEK_SET)
            if rw < 0:
                if total == 0:
                    return rw
                cont = 0
                continue
        w: int64 = vfs_write(fd_out, &_splice_buf[0], got)
        if w < 0:
            if w == ELINUX_PIPE:
                signal_post(current_idx_get(), SIGPIPE)
            if total == 0:
                return w
            cont = 0
            continue
        total = total + w
        in_off = in_off + w
        out_off = out_off + w
        if cast[uint64](w) < got:
            # Short write — drop the remainder (ring full / back-pressure).
            cont = 0
            continue
        remaining = remaining - got
        if remaining == 0:
            cont = 0

    if off_in_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_in
        cast[Ptr[int64]](off_in_ptr)[0] = in_off
        _ua_clac()
    if off_out_ptr != 0:
        _ua_stac()                                  # SMAP: user *off_out
        cast[Ptr[int64]](off_out_ptr)[0] = out_off
        _ua_clac()
    return total


def _u_tee(a0: uint64, a1: uint64, a2: uint64,
           a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t tee(int fd_in, int fd_out, size_t len, unsigned int flags)
    #
    # Duplicate up to `len` bytes from one pipe (fd_in, a read end) into
    # another pipe (fd_out, a write end) WITHOUT consuming the input —
    # the bytes stay readable on fd_in. Both fds must be pipes (EINVAL
    # otherwise). We peek the in-ring (non-destructive, pipe_peek leaves
    # head/count untouched) and write the bytes into the out-ring.
    fd_in:  int32 = cast[int32](a0)
    fd_out: int32 = cast[int32](a1)
    remaining: uint64 = a2

    if fd_in < 0 or fd_out < 0:
        return ELINUX_BADF
    in_slot:  int32 = vfs_fd_pipe_slot(fd_in)
    out_slot: int32 = vfs_fd_pipe_slot(fd_out)
    # Both ends must be pipes — and specifically the read end of fd_in
    # and the write end of fd_out.
    if vfs_fd_is_pipe_read(fd_in) == 0 or vfs_fd_is_pipe_write(fd_out) == 0:
        return ELINUX_INVAL
    if in_slot < 0 or out_slot < 0:
        return ELINUX_INVAL
    if remaining == 0:
        return 0
    # A tee whose out-pipe has no readers can never make progress — Linux
    # reports EPIPE (and a SIGPIPE).
    if pipe_readers(out_slot) == 0:
        signal_post(current_idx_get(), SIGPIPE)
        return ELINUX_PIPE

    total: int64 = 0
    # Peek from a moving in-ring offset: pipe_peek always copies from the
    # ring head, so we track how far we've duplicated and only count the
    # bytes past `done`. Bounded by what's currently buffered — tee never
    # blocks waiting for more input in this single-task model.
    avail: uint64 = pipe_count(in_slot)
    if avail == 0:
        return 0
    if remaining > avail:
        remaining = avail

    done: uint64 = 0
    cont: int32 = 1
    while cont != 0:
        want: uint64 = remaining - done
        if want == 0:
            cont = 0
            continue
        if want > SPLICE_CHUNK:
            want = SPLICE_CHUNK
        # Peek the whole prefix up to done+want, then copy only the new
        # tail [done, done+got) so we never re-write already-teed bytes.
        peeked: int64 = pipe_peek(in_slot, &_splice_buf[0], done + want)
        if peeked <= 0:
            cont = 0
            continue
        pk: uint64 = cast[uint64](peeked)
        if pk <= done:
            cont = 0
            continue
        seg: uint64 = pk - done
        w: int64 = pipe_write(out_slot,
                              cast[Ptr[uint8]](cast[uint64](&_splice_buf[0]) + done),
                              seg)
        if w <= 0:
            # Out-ring full (0) or gone — stop; report bytes so far.
            cont = 0
            continue
        total = total + w
        done = done + cast[uint64](w)
        if cast[uint64](w) < seg:
            cont = 0
            continue
        if done >= remaining:
            cont = 0
    return total


def _u_vmsplice(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t vmsplice(int fd, const struct iovec *iov,
    #                  size_t nr_segs, unsigned int flags)
    #
    # Gather user iovec memory into a pipe. fd must be the write end of a
    # pipe (EBADF/EINVAL otherwise). We copy each iovec segment out of
    # user space (copy_from_user — never a raw user-pointer deref) into a
    # kernel staging buffer, then push it into the ring with pipe_write.
    # No SPLICE_F_GIFT page-donation: plain copy semantics, which is all
    # the common callers rely on.
    fd: int32 = cast[int32](a0)
    iov: uint64 = a1
    nr_segs: uint64 = a2

    if fd < 0:
        return ELINUX_BADF
    if vfs_fd_is_pipe_write(fd) == 0:
        return ELINUX_INVAL
    out_slot: int32 = vfs_fd_pipe_slot(fd)
    if out_slot < 0:
        return ELINUX_INVAL
    if nr_segs == 0:
        return 0
    if iov == 0:
        return ELINUX_INVAL
    if pipe_readers(out_slot) == 0:
        signal_post(current_idx_get(), SIGPIPE)
        return ELINUX_PIPE

    total: int64 = 0
    i: uint64 = 0
    while i < nr_segs:
        # Each iovec entry: { void *iov_base; size_t iov_len; } — 16
        # bytes, no padding (same layout readv/writev walk).
        entry: uint64 = iov + i * 16
        base: uint64 = cast[Ptr[uint64]](entry)[0]
        seglen: uint64 = cast[Ptr[uint64]](entry + 8)[0]
        if seglen == 0:
            i = i + 1
            continue
        seg_done: uint64 = 0
        seg_stop: int32 = 0
        while seg_done < seglen and seg_stop == 0:
            chunk: uint64 = seglen - seg_done
            if chunk > SPLICE_CHUNK:
                chunk = SPLICE_CHUNK
            resid: uint64 = copy_from_user(cast[uint64](&_splice_buf[0]),
                                           base + seg_done, chunk)
            if resid != 0:
                # User fault mid-segment: surface EFAULT if nothing moved
                # yet, otherwise return the partial total.
                if total == 0:
                    return ELINUX_EFAULT
                return total
            w: int64 = pipe_write(out_slot, &_splice_buf[0], chunk)
            if w <= 0:
                # Ring full right now — stop, report bytes so far.
                seg_stop = 1
                continue
            total = total + w
            seg_done = seg_done + cast[uint64](w)
            if cast[uint64](w) < chunk:
                seg_stop = 1                              # ring full
        if seg_stop != 0:
            return total
        i = i + 1
    return total


def _u_close_range(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int close_range(unsigned int first, unsigned int last,
    #                 unsigned int flags)
    #
    # Close every open fd in the inclusive span [first, last]. Linux lets
    # `last` be ~0u ("close everything from first up"), so we clamp the top
    # of the walk to the fd-table size (_VFS_NR_FDS) — there is nothing open
    # past it. Each live fd is dropped through _u_close so the full per-fd
    # teardown (O_NONBLOCK clear, pidfd / AF_UNIX / io_uring context release)
    # runs exactly as a plain close(2) would; an already-closed slot in the
    # span is skipped (not an error — that's the whole point of the syscall).
    first: uint64 = a0 & 0xFFFFFFFF
    last:  uint64 = a1 & 0xFFFFFFFF
    flags: uint64 = a2
    # EINVAL: an inverted range, or an unknown flag bit.
    if first > last:
        return ELINUX_INVAL
    known: uint64 = CLOSE_RANGE_UNSHARE | CLOSE_RANGE_CLOEXEC
    if (flags & ~known) != 0:
        return ELINUX_INVAL
    # CLOSE_RANGE_UNSHARE is a no-op here (each task already owns a private
    # fd table). CLOSE_RANGE_CLOEXEC would only flag-not-close the fds, but
    # Hamnix keeps no FD_CLOEXEC bitmap, so the safe, conservative behaviour
    # is to close them outright — the caller asked for them gone at the next
    # exec, and a hard close satisfies that strictly.
    #
    # Clamp the upper bound to the per-task fd-table size: nothing is open
    # past it, and `last` is routinely ~0u ("everything from first up"). We
    # use a self-contained cap that matches fs/vfs.ad's _VFS_NR_FDS (16);
    # vfs_fd_is_open already rejects any fd >= the table size, so an over-
    # large cap is still safe — this just keeps the walk finite.
    if last >= CLOSE_RANGE_FD_CAP:
        last = CLOSE_RANGE_FD_CAP - 1
    fd: uint64 = first
    while fd <= last:
        if vfs_fd_is_open(cast[int32](fd)) != 0:
            _u_close(fd, 0, 0, 0, 0, 0)
        fd = fd + 1
    return 0


def _u_access_path(upath: uint64, mode: uint64) -> int64:
    # Shared body for access(2) / faccessat(2) / faccessat2(2). `upath`
    # is the user path pointer (relative paths resolve against the task
    # cwd via resolve_path), `mode` is the F_OK/R_OK/W_OK/X_OK bitmask.
    #
    # For an ext4-backed path we do a REAL R/W/X check against the file's
    # mode bits (ext4_path_mode); other backends keep a permissive
    # existence check (no inode mode bits to consult). See _u_access.
    if upath == 0:
        return ELINUX_INVAL
    # #163: copy-in the user path so a bad pointer is -EFAULT, not a #PF.
    acc_path: Array[256, uint8]
    acc_pin: int64 = _u_copyin_path(upath, &acc_path[0])
    if acc_pin != 0:
        return acc_pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&acc_path[0]), &abs_path[0], 256)
    if rc != 0:
        return ELINUX_NOENT
    # ext4-backed path: consult the real inode mode bits.
    # F10-9: backend classification through the VFS mount table.
    if vfs_fs_kind(cast[Ptr[char]](&abs_path[0])) == FS_KIND_EXT4:
        tail: Ptr[char] = strip_ext_prefix(cast[Ptr[char]](&abs_path[0]))
        imode: int32 = ext4_path_mode(tail)
        if imode < 0:
            return ELINUX_NOENT
        # F_OK (mode==0): existence only — the resolve above proved it.
        if mode == 0:
            return 0
        perm: uint64 = cast[uint64](imode) & 0x1FF      # low-9 rwx bits
        if (mode & 4) != 0 and (perm & 0x100) == 0:     # R_OK vs 0400
            return ELINUX_ACCES
        if (mode & 2) != 0 and (perm & 0x080) == 0:     # W_OK vs 0200
            return ELINUX_ACCES
        if (mode & 1) != 0 and (perm & 0x040) == 0:     # X_OK vs 0100
            return ELINUX_ACCES
        return 0
    # Non-ext4 backend: permissive existence check (no mode bits).
    # F10-1 double-resolution fix: probe with the RAW path so vfs_open's
    # single internal resolve_path walks the namespace once (abs_path was
    # already resolved above for backend classification; re-resolving it in
    # vfs_open doubled a `/`-rebound root prefix and false-ENOENT'd).
    fd: int32 = vfs_open(cast[Ptr[char]](&acc_path[0]))
    if fd < 0:
        return ELINUX_NOENT
    vfs_close(fd)
    return 0


def _u_access(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int access(const char *pathname, int mode)
    # mode bits per <unistd.h>: F_OK (0), X_OK (1), W_OK (2), R_OK (4).
    return _u_access_path(a0, a1)


def _u_faccessat(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int faccessat(int dirfd, const char *path, int mode, int flags)
    # int faccessat2(int dirfd, const char *path, int mode, int flags)
    #   a0 = dirfd, a1 = path, a2 = mode, a3 = flags.
    # glibc routes plain access(2) through faccessat2 on modern builds,
    # so this is in fact the HOT path for any access probe. Only AT_FDCWD
    # (and absolute paths) are honoured — a relative path against a real
    # dirfd needs per-fd dirpath state we don't track yet. AT_EACCESS in
    # `flags` (check against effective vs real uid) is moot in the
    # single-user model, so flags are ignored.
    is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                    # leading '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        return ELINUX_NOSYS
    return _u_access_path(a1, a2)


# --- select(2) -------------------------------------------------------
#
# select(2) uses fd_set bitmaps: word `fd >> 6`, bit `fd & 63`. nfds
# bounds the highest fd+1 to scan. Hamnix's fd table is 16 slots, so a
# single 64-bit word covers every possible fd — but we read/write the
# caller's fd_set at the correct word offset so a libc that allocated a
# full 128-byte set is satisfied. select is the simpler fallback many
# programs probe before epoll; §5 makes it readiness-driven.

def _fdset_test(set_ptr: uint64, fd: int32) -> int32:
    # 1 if `fd` is set in the fd_set at set_ptr.
    if set_ptr == 0:
        return 0
    word: uint64 = cast[uint64](fd) >> 6
    bit:  uint64 = cast[uint64](fd) & 63
    # SMAP: the fd_set lives in user memory (US=1); bracket the CPL=0 load.
    _ua_stac()
    w: uint64 = cast[Ptr[uint64]](set_ptr + word * 8)[0]
    _ua_clac()
    if (w & (cast[uint64](1) << bit)) != 0:
        return 1
    return 0


def _fdset_clear_all(set_ptr: uint64, nfds: uint64):
    # Zero every word of the fd_set that covers fds [0, nfds).
    if set_ptr == 0:
        return
    words: uint64 = (nfds + 63) / 64
    i: uint64 = 0
    # SMAP: user fd_set (US=1) — bracket the whole zeroing loop.
    _ua_stac()
    while i < words:
        cast[Ptr[uint64]](set_ptr + i * 8)[0] = 0
        i = i + 1
    _ua_clac()


def _fdset_add(set_ptr: uint64, fd: int32):
    if set_ptr == 0:
        return
    word: uint64 = cast[uint64](fd) >> 6
    bit:  uint64 = cast[uint64](fd) & 63
    # SMAP: user fd_set (US=1) — bracket the read-modify-write.
    _ua_stac()
    cur: uint64 = cast[Ptr[uint64]](set_ptr + word * 8)[0]
    cast[Ptr[uint64]](set_ptr + word * 8)[0] = \
        cur | (cast[uint64](1) << bit)
    _ua_clac()


def _u_select_scan(nfds: uint64, rd: uint64, wr: uint64, ex: uint64,
                   out_rd: uint64, out_wr: uint64,
                   out_ex: uint64) -> int64:
    # One pass: for each fd in [0, nfds) requested in rd/wr/ex, probe
    # readiness and build the result sets. Returns the total count of
    # ready (fd, condition) pairs — select's return value.
    #
    # ALIASING FIX (apt-get keystone): select(2)/pselect6(2) rewrite the
    # caller's fd_sets IN PLACE, so _u_select_common passes the SAME user
    # pointers as both the requested (rd/wr/ex) AND result (out_*) sets.
    # The old body cleared out_rd/out_wr/out_ex FIRST and only then read
    # the request bits via _fdset_test(rd/wr/ex, fd) — but since out_rd ==
    # rd, that clear ZEROED the request before it was read, so every
    # _fdset_test returned 0, no fd was ever probed, and select ALWAYS
    # returned 0 (timeout). That silently broke EVERY select() loop in a
    # Linux binary — most visibly apt's pkgAcquire::Worker::Start, whose
    # WaitFd(InFd) select on the method's greeting pipe timed out, so
    # `apt-get update` reported "Method file did not start correctly".
    # Fix: snapshot the request bitmaps into kernel-local words (nfds is
    # bounded to 1024 by the caller => at most 16 u64 words per set)
    # BEFORE clearing the aliased output sets, then probe against the
    # snapshot. select/pselect6 with separate in/out sets still work
    # (the snapshot is just a copy).
    SEL_WORDS: uint64 = 16                      # 1024 fds / 64 bits-per-word
    req_r: Array[16, uint64]
    req_w: Array[16, uint64]
    req_e: Array[16, uint64]
    nwords: uint64 = (nfds + 63) / 64
    if nwords > SEL_WORDS:
        nwords = SEL_WORDS
    wi: uint64 = 0
    while wi < SEL_WORDS:
        req_r[wi] = 0
        req_w[wi] = 0
        req_e[wi] = 0
        wi = wi + 1
    wi = 0
    while wi < nwords:
        # SMAP: the fd_sets live in user memory (US=1); bracket the loads.
        _ua_stac()
        if rd != 0:
            req_r[wi] = cast[Ptr[uint64]](rd + wi * 8)[0]
        if wr != 0:
            req_w[wi] = cast[Ptr[uint64]](wr + wi * 8)[0]
        if ex != 0:
            req_e[wi] = cast[Ptr[uint64]](ex + wi * 8)[0]
        _ua_clac()
        wi = wi + 1
    _fdset_clear_all(out_rd, nfds)
    _fdset_clear_all(out_wr, nfds)
    _fdset_clear_all(out_ex, nfds)
    count: int64 = 0
    fd: uint64 = 0
    while fd < nfds:
        fds: int32 = cast[int32](fd)
        sw: uint64 = fd >> 6
        sb: uint64 = cast[uint64](1) << (fd & 63)
        want_r: int32 = 0
        if (req_r[sw] & sb) != 0:
            want_r = 1
        want_w: int32 = 0
        if (req_w[sw] & sb) != 0:
            want_w = 1
        want_e: int32 = 0
        if (req_e[sw] & sb) != 0:
            want_e = 1
        if want_r != 0 or want_w != 0 or want_e != 0:
            ev: uint32 = 0
            if vfs_fd_is_open(fds) != 0:
                ev = vfs_fd_poll(fds)
                sel_marker: uint32 = vfs_fd_marker(fds)
                if sel_marker == FD_SIGNALFD_MARK:
                    ssel: int32 = cast[int32](vfs_l2_fd_get_buf(fds)) - 1
                    if usfd_match(ssel,
                                  signal_pending(current_idx_get())) != 0:
                        ev = ev | POLLIN_BIT
                if sel_marker == FD_PIDFD_MARK:
                    ev = 0
                    sel_pid: int64 = upidfd_get(current_idx_get(), fds)
                    if sel_pid >= 0:
                        if upidfd_target_readable(cast[uint64](sel_pid)) != 0:
                            ev = ev | POLLIN_BIT
            # readable: POLLIN or POLLHUP; writable: POLLOUT; the
            # exception set maps to POLLERR/POLLPRI.
            if want_r != 0:
                if (ev & (POLLIN_BIT | POLLHUP_BIT)) != 0:
                    _fdset_add(out_rd, fds)
                    count = count + 1
            if want_w != 0:
                if (ev & POLLOUT_BIT) != 0:
                    _fdset_add(out_wr, fds)
                    count = count + 1
            if want_e != 0:
                if (ev & (POLLERR_BIT | POLLPRI_BIT)) != 0:
                    _fdset_add(out_ex, fds)
                    count = count + 1
        fd = fd + 1
    return count


def _u_select_common(nfds: uint64, rd: uint64, wr: uint64, ex: uint64,
                     timeout_jiffies: uint64, bounded: int32) -> int64:
    # Shared select / pselect6 body. The caller's three fd_sets are
    # rewritten IN PLACE to the ready subset. timeout: bounded==0 is a
    # single immediate pass; otherwise yield-spin until ready or the
    # jiffy deadline passes.
    if nfds > 1024:
        return ELINUX_INVAL
    # ALIASING FIX 2 (apt acquire-method keystone): the yield-spin below
    # calls _u_select_scan REPEATEDLY with the same user fd_sets as BOTH
    # request and result. _u_select_scan rewrites those sets in place to
    # the ready subset — so after the FIRST pass that finds nothing ready,
    # the request bitmaps are ZEROED, and every later pass probes an empty
    # request and can NEVER observe an fd that becomes ready mid-wait. That
    # silently broke every BLOCKING select/pselect loop in a Linux binary:
    # apt's pkgAcquire::Worker selects on its acquire method's greeting
    # pipe; the pipe was not readable on the first pass (the method was
    # still starting), the request was wiped, and the now-readable greeting
    # was never seen — select timed out, apt SIGINT-killed the method, and
    # the file:// fetch failed. (The earlier 866901b2 fix only de-aliased
    # WITHIN one scan; it did not preserve the request ACROSS spin passes.)
    # Fix: snapshot the three request bitmaps into kernel-local words once,
    # and restore the user sets from that snapshot before every scan so each
    # pass probes the ORIGINAL requested fds. nfds <= 1024 => <=16 u64/set.
    SEL2_WORDS: uint64 = 16
    snap_r: Array[16, uint64]
    snap_w: Array[16, uint64]
    snap_e: Array[16, uint64]
    snwords: uint64 = (nfds + 63) / 64
    if snwords > SEL2_WORDS:
        snwords = SEL2_WORDS
    swi: uint64 = 0
    while swi < SEL2_WORDS:
        snap_r[swi] = 0
        snap_w[swi] = 0
        snap_e[swi] = 0
        swi = swi + 1
    swi = 0
    while swi < snwords:
        _ua_stac()
        if rd != 0:
            snap_r[swi] = cast[Ptr[uint64]](rd + swi * 8)[0]
        if wr != 0:
            snap_w[swi] = cast[Ptr[uint64]](wr + swi * 8)[0]
        if ex != 0:
            snap_e[swi] = cast[Ptr[uint64]](ex + swi * 8)[0]
        _ua_clac()
        swi = swi + 1
    start: uint64 = get_jiffies()
    deadline: uint64 = start + timeout_jiffies
    while True:
        # Restore the request bitmaps from the kernel snapshot so this pass
        # probes the original fds even after a prior pass cleared the sets.
        swj: uint64 = 0
        while swj < snwords:
            _ua_stac()
            if rd != 0:
                cast[Ptr[uint64]](rd + swj * 8)[0] = snap_r[swj]
            if wr != 0:
                cast[Ptr[uint64]](wr + swj * 8)[0] = snap_w[swj]
            if ex != 0:
                cast[Ptr[uint64]](ex + swj * 8)[0] = snap_e[swj]
            _ua_clac()
            swj = swj + 1
        n: int64 = _u_select_scan(nfds, rd, wr, ex, rd, wr, ex)
        if n > 0:
            return n
        if bounded == 0:
            return 0
        if get_jiffies() >= deadline:
            # Deadline reached. POSIX requires that a select/pselect whose
            # timeout expires STILL report any fd that is ready RIGHT NOW —
            # the timeout only bounds the wait, it must not discard a
            # simultaneously-ready descriptor. The yield-spin loop scans,
            # then checks the clock; an fd that became readable in the gap
            # between this iteration's scan and the clock read would be lost
            # if we returned 0 unconditionally. That race was real and
            # load-bearing: apt's pkgAcquire::Worker selects on its acquire
            # method's greeting pipe with a long timeout; on a slow method
            # startup the "100 Capabilities" write landed in the very tick
            # the clamped deadline fired, so select returned 0 (timeout),
            # apt declared the method dead, SIGINT-killed it, and the
            # file:// fetch failed ("Method file did not start correctly" /
            # silent index miss). One final scan at the deadline closes the
            # race and reports the ready pipe so apt reads the greeting. The
            # request bitmaps were cleared by the scan above, so restore
            # them from the snapshot before this final probe.
            swk: uint64 = 0
            while swk < snwords:
                _ua_stac()
                if rd != 0:
                    cast[Ptr[uint64]](rd + swk * 8)[0] = snap_r[swk]
                if wr != 0:
                    cast[Ptr[uint64]](wr + swk * 8)[0] = snap_w[swk]
                if ex != 0:
                    cast[Ptr[uint64]](ex + swk * 8)[0] = snap_e[swk]
                _ua_clac()
                swk = swk + 1
            nfinal: int64 = _u_select_scan(nfds, rd, wr, ex, rd, wr, ex)
            if nfinal > 0:
                return nfinal
            return 0
        yield_to_others()


def _u_select(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int select(int nfds, fd_set *r, fd_set *w, fd_set *e,
    #            struct timeval *timeout)
    # struct timeval { i64 tv_sec; i64 tv_usec }. A NULL timeout means
    # block; a zero timeout is a non-blocking poll.
    nfds: uint64 = a0
    bounded: int32 = 1
    tj: uint64 = UEP_WAIT_MAX_JIFFIES
    if a4 != 0:
        # #163: fetch the user timeval through the page tables.
        sec:  uint64 = 0
        usec: uint64 = 0
        if get_user_64(a4, &sec) != 0:
            return ELINUX_EFAULT
        if get_user_64(a4 + 8, &usec) != 0:
            return ELINUX_EFAULT
        if sec == 0 and usec == 0:
            bounded = 0
        else:
            tj = sec * HZ + usec / (1000000 / HZ)
            if tj == 0:
                tj = 1
            if tj > UEP_WAIT_MAX_JIFFIES:
                tj = UEP_WAIT_MAX_JIFFIES
    return _u_select_common(nfds, a1, a2, a3, tj, bounded)


def _u_sched_yield(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sched_yield(void).
    # U28: forward to the kernel's cooperative yield. cond-wait
    # producer/consumer loops use this between iterations to let the
    # other side make progress; previously this returned -ENOSYS and
    # the caller (musl) ignored it, but that left lockstep producers
    # starving the consumer until the next preemption tick.
    yield_to_others()
    return 0


def _u_unimpl_mremap(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void *mremap(void *old_addr, size_t old_len, size_t new_len,
    #              int flags, void *new_addr).
    #   a0 = old_addr, a1 = old_len, a2 = new_len, a3 = flags,
    #   a4 = new_addr (MREMAP_FIXED only).
    #
    # Real mremap, backed by mm/vma.ad::vma_mremap:
    #   * Grow in place when the trailing virtual range is free (windowed
    #     anon regions only — see vma_mremap). The new pages inherit the
    #     region's prot via _vma_rw_flag|_vma_nx_flag (NOT blanket-RWX).
    #   * Move (MREMAP_MAYMOVE) when it can't grow in place: a fresh
    #     anonymous range of new_len is allocated with the old prot, the
    #     old bytes copied over, then the old range dropped.
    #   * Shrink in place (new_len < old_len): the tail pages are
    #     unmapped and freed.
    #   * A grow that can't extend in place WITHOUT MREMAP_MAYMOVE returns
    #     -ENOMEM (Linux semantics — never silently move).
    #   * new_len == old_len is a no-op returning old_addr (glibc-malloc
    #     probes this path).
    #
    # MREMAP_FIXED is DEFERRED: vma_mremap returns -EINVAL for it. The
    # grow-in-place / MAYMOVE-move / shrink cases are fully implemented;
    # FIXED's "map at caller-supplied new_addr, evicting whatever is
    # there" overlay is the disproportionately complex case the brief
    # permits deferring.
    slot: uint64 = current_idx_get()
    return vma_mremap(slot, a0, a1, a2, a3, a4)


def _u_unimpl_msync(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int msync(void *addr, size_t length, int flags).
    # a0 = addr, a1 = length, a2 = flags (MS_ASYNC=1, MS_INVALIDATE=2,
    # MS_SYNC=4). Flush the dirtied resident pages of every MAP_SHARED
    # writable file-backed VMA intersecting [addr, addr+length) back to
    # the backing file. This mirrors the native SYS_MSYNC handler in
    # arch/x86/kernel/syscall.ad: addr must be page-aligned, MS_SYNC and
    # MS_ASYNC are treated identically (the underlying write-back is
    # synchronous — there is no deferred queue), and a range covering no
    # file-shared VMA (anonymous / MAP_PRIVATE / read-only) is a
    # successful no-op, exactly like Linux. The flush itself lives in
    # mm/vma.ad::vma_writeback_range; we just translate the kernel rc to
    # the Linux return convention (0 on success, negative errno on fail).
    if (a0 & (0x1000 - 1)) != 0:
        set_current_errstr("msync: addr not page-aligned")
        return ELINUX_INVAL              # -EINVAL, matching POSIX
    msync_slot: uint64 = current_idx_get()
    msync_rc: int64 = vma_writeback_range(msync_slot, a0, a1)
    if msync_rc < 0:
        set_current_errstr("msync: writeback failed")
        return msync_rc
    return 0


def _u_unimpl_nanosleep(a0: uint64, a1: uint64, a2: uint64,
                        a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int nanosleep(const struct timespec *req, struct timespec *rem)
    # §146: real cooperative sleep. Reads {tv_sec, tv_nsec} from *a0,
    # spins-with-yield via kernel_cond_resched until the TSC deadline,
    # then writes {0,0} to *a1 (rem) if non-null. Jiffy-rounded accuracy
    # (10 ms at HZ=100). Does NOT busy-spin — each loop iteration does
    # sti+hlt+cli so other tasks run and the LAPIC timer fires.
    if a0 == 0:
        return ELINUX_INVAL
    # #163: fetch the user timespec through the page tables.
    ns_req_sec:  uint64 = 0
    ns_req_nsec: uint64 = 0
    if get_user_64(a0, &ns_req_sec) != 0:
        return ELINUX_EFAULT
    if get_user_64(a0 + 8, &ns_req_nsec) != 0:
        return ELINUX_EFAULT
    ns_dur_ns: uint64 = ns_req_sec * 1000000000 + ns_req_nsec
    if ns_dur_ns == 0:
        yield_to_others()
        if a1 != 0:
            if put_user_64(0, a1) != 0:
                return ELINUX_EFAULT
            if put_user_64(0, a1 + 8) != 0:
                return ELINUX_EFAULT
        return 0
    ns_start: uint64 = tsc_monotonic_ns()
    ns_dl: uint64 = ns_start + ns_dur_ns
    while tsc_monotonic_ns() < ns_dl:
        kernel_cond_resched()
    if a1 != 0:
        if put_user_64(0, a1) != 0:
            return ELINUX_EFAULT
        if put_user_64(0, a1 + 8) != 0:
            return ELINUX_EFAULT
    return 0


# TIMER_ABSTIME flag for clock_nanosleep(2): the requested time is an
# absolute clock value rather than a relative duration.
LINUX_TIMER_ABSTIME: uint64 = 1

def _u_clock_nanosleep(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int clock_nanosleep(clockid_t clk, int flags,
    #                     const struct timespec *req, struct timespec *rem)
    #   a0 = clockid, a1 = flags, a2 = req, a3 = rem.
    # glibc's nanosleep(), sleep(), usleep() and most pthread timed waits
    # route through clock_nanosleep on modern builds, so this is the hot
    # sleep path. Backed by the same TSC monotonic clock as nanosleep(2).
    #
    # TIMER_ABSTIME: `req` is an absolute deadline on the chosen clock —
    # we treat every clock as the monotonic ns counter (CLOCK_REALTIME
    # offsets by the boot epoch, mirroring _u_clock_gettime), compute the
    # absolute target, and sleep until tsc_monotonic_ns() reaches it. The
    # `rem` buffer is only meaningful for the relative form and is left
    # untouched on a normal (uninterrupted) completion of an ABSTIME sleep.
    if a2 == 0:
        return ELINUX_INVAL
    # #163: fetch the user timespec through the page tables.
    req_sec:  uint64 = 0
    req_nsec: uint64 = 0
    if get_user_64(a2, &req_sec) != 0:
        return ELINUX_EFAULT
    if get_user_64(a2 + 8, &req_nsec) != 0:
        return ELINUX_EFAULT
    target_ns: uint64 = 0
    if (a1 & LINUX_TIMER_ABSTIME) != 0:
        abs_ns: uint64 = req_sec * 1000000000 + req_nsec
        # CLOCK_REALTIME absolute deadlines are expressed against the RTC
        # boot epoch; subtract it to land back on the monotonic timeline.
        if a0 == CLOCKID_REALTIME or a0 == CLOCKID_REALTIME_COARSE:
            base: uint64 = rtc_boot_epoch_get() * 1000000000
            if abs_ns > base:
                target_ns = abs_ns - base
            else:
                target_ns = 0
        else:
            target_ns = abs_ns
        now_ns: uint64 = tsc_monotonic_ns()
        if target_ns <= now_ns:
            return 0                                  # deadline already past
        while tsc_monotonic_ns() < target_ns:
            kernel_cond_resched()
        return 0
    # Relative form: identical to nanosleep(2). Reuse its body so the
    # rem-writeback and zero-duration yield behaviour stay in one place.
    return _u_unimpl_nanosleep(a2, a3, 0, 0, 0, 0)


def _u_clone(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long clone(unsigned long flags, void *child_stack,
    #            int *ptid, int *ctid, unsigned long tls)
    #
    # U26: forward to the kernel's shared do_clone helper. We honour
    # none of the CLONE_* sharing bits yet — every clone() at this
    # milestone behaves like a vfork-style fork(): brand-new task
    # slot, shared user address space (PML4s cloned but lower-level
    # mappings shared), child resumes at the parent's saved syscall
    # return RIP with rax=0 so glibc's fork() sees the conventional
    # "I'm the child" return value. child_stack / ptid / ctid / tls
    # are passed through for ABI compatibility. U27 lights up the
    # thread path (CLONE_VM | CLONE_THREAD) and adds a5 (user's
    # original %r9) so the child's `call *%r9` after the musl __clone
    # wrapper returns lands on the right function pointer.
    # Legacy clone() carries 5 register args (flags/stack/ptid/ctid/tls
    # in rdi/rsi/rdx/r10/r8) — a2/a4 ARE clone arguments here, not a
    # libc-saved worker function, so do_clone's user_rdx/user_r8 get 0.
    # musl's __clone parks the worker fn in %r9 (a5) and Hamnix already
    # propagates that; glibc's legacy clone child uses a stack
    # trampoline. Only clone3 needs %rdx/%r8 forwarded (see _u_clone3).
    # user_rdi (9th arg) = 0: legacy clone(2) carries flags in %rdi (a0),
    # not a vfork return address. glibc only rides the vfork register-return
    # trick through SYS_vfork (see _u_vfork), never clone(CLONE_VFORK,stack=0).
    return do_clone(a0, a1, a2, a3, a4, a5, 0, 0, 0)


# U28: clone3(2) wrapper. Modern glibc (2.34+) prefers clone3 over
# the legacy 5-arg clone — its __clone_internal attempts clone3 first
# and falls back to clone only on -ENOSYS. Forwarding clone3 to do_clone
# (instead of returning ENOSYS) avoids the fallback round-trip and
# also enables future workloads that NEED clone3-only flags (CLONE_PIDFD,
# set_tid lists, cgroup ns) once we grow do_clone to honour them.
#
# struct clone_args layout (Linux UAPI <linux/sched.h>, 88 bytes on
# x86_64 — the size glibc passes in %rsi):
#   u64 flags         offset  0
#   u64 pidfd          offset  8   (out: kernel writes child's pidfd)
#   u64 child_tid      offset 16   (CLONE_CHILD_*_TID target)
#   u64 parent_tid     offset 24   (CLONE_PARENT_SETTID target)
#   u64 exit_signal    offset 32
#   u64 stack          offset 40   (lowest byte of stack, NOT top)
#   u64 stack_size     offset 48
#   u64 tls            offset 56
#   u64 set_tid        offset 64   (array — unused in glibc's caller)
#   u64 set_tid_size   offset 72
#   u64 cgroup         offset 80
#
# The legacy clone(2) ABI passes child_stack as the TOP of the stack
# (highest address). clone3 passes the BOTTOM + stack_size. We
# translate that here so do_clone's thread path sees the same value
# it gets from the legacy entry — musl's __clone wrapper assumes
# RSP-on-entry == stack_top.
def _u_clone3(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long clone3(struct clone_args *cl_args, size_t size)
    if a0 == 0:
        return ELINUX_INVAL
    # Defensive on size: glibc passes 88 (the full struct); older or
    # newer kernels can carry a different size. We only read the first
    # 7 fields (through tls); reject anything smaller than 64 bytes.
    if a1 < 64:
        return ELINUX_INVAL
    args: uint64 = a0
    # SMAP: struct clone_args lives in user memory (US=1). Copy the first
    # 64 bytes (8 u64 fields) into a kernel scratch via copy_from_user, then
    # read the fields out of the scratch — no CPL=0 user-VA deref.
    ca: Array[64, uint8]
    if copy_from_user(cast[uint64](&ca[0]), args, 64) != 0:
        return ELINUX_FAULT
    cab: uint64 = cast[uint64](&ca[0])
    flags:       uint64 = cast[Ptr[uint64]](cab + 0)[0]
    pidfd_ptr:   uint64 = cast[Ptr[uint64]](cab + 8)[0]
    ctid_ptr:    uint64 = cast[Ptr[uint64]](cab + 16)[0]
    ptid_ptr:    uint64 = cast[Ptr[uint64]](cab + 24)[0]
    # exit_signal at +32 — folded into flags by the kernel.
    stack_base:  uint64 = cast[Ptr[uint64]](cab + 40)[0]
    stack_size:  uint64 = cast[Ptr[uint64]](cab + 48)[0]
    tls:         uint64 = cast[Ptr[uint64]](cab + 56)[0]
    # do_clone expects child_stack to be the TOP of the stack (like
    # clone(2)). clone3 gives us the bottom; add stack_size to get the
    # top. Caller may legitimately pass stack=0 for fork-style behaviour
    # (we'd take the legacy fork path), so guard against the
    # 0+size case which we treat as "no stack".
    child_stack: uint64 = 0
    if stack_base != 0:
        child_stack = stack_base + stack_size
    # User's %r9 at syscall entry came in as a5 on the dispatch path —
    # this matches what _u_clone receives. musl/glibc clone3 wrappers
    # don't park anything in %r9, but we propagate it for symmetry with
    # the legacy clone path.
    #
    # clone3 only consumes 2 register args (cl_args, size = rdi, rsi),
    # so rdx/r8 — arriving as a2/a4 on the dispatch path — are FREE for
    # the libc to stash the worker function + argument across the
    # `syscall`. glibc's clone3.S does exactly that: it keeps the
    # worker fn in %rdx and moves the arg into %r8, and its child-side
    # code runs `mov %r8,%rdi; call *%rdx`. Forward a2/a4 so the new
    # thread resumes with %rdx/%r8 carrying the right values.
    # CLONE_PIDFD: glibc 2.34 sets this implicitly. We don't have pidfds,
    # so report 0 in *pidfd if requested — better than scribbling a
    # garbage fd and breaking close-after-clone3.
    if pidfd_ptr != 0:
        # SMAP: pidfd output is a user pointer — write via page tables.
        put_user_32(cast[uint32](cast[int32](-1)), pidfd_ptr)
    return do_clone(flags, child_stack, ptid_ptr, ctid_ptr, tls, a5,
                    a2, a4, 0)


def _u_fork(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t fork(void). Identical to clone(SIGCHLD, NULL, NULL, NULL, 0)
    # — the canonical Linux mapping. 0x11 == SIGCHLD. user_r9 = 0
    # because fork() takes no caller arg that lives in %r9.
    return do_clone(cast[uint64](0x11), 0, 0, 0, 0, 0, 0, 0, 0)


def _u_vfork(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t vfork(void). Hamnix gives the vfork child a COW *copy* of the
    # parent's address space (NOT a shared one) and runs both concurrently —
    # safe because execve in the child builds a fresh address space and can
    # never corrupt the parent's copy.
    #
    # THE CRITICAL ARG: glibc's x86_64 __vfork (vfork.S) is
    #     popq %rdi          # save return address off the (shared) stack
    #     mov  $SYS_vfork,%eax
    #     syscall
    #     pushq %rdi         # restore return address
    #     ret
    # i.e. it parks its return address in %rdi across the syscall so it
    # survives on BOTH the parent and child control flows (the vfork
    # contract shares the stack, so a stack-resident return addr would be
    # clobbered). Our child resumes at the post-syscall `pushq %rdi` on its
    # COW stack copy, so it MUST come back with %rdi == that saved return
    # address — otherwise it pushes 0 and `ret`s to NULL (the historic
    # `[pf] NX exec-fault va=0` that killed every dpkg/apt fork helper).
    # a0 IS the parent's %rdi at syscall entry (dispatch maps %rdi->a0), so
    # forward it as do_clone's user_rdi. flags = CLONE_VM|CLONE_VFORK|SIGCHLD.
    return do_clone(cast[uint64](0x4111), 0, 0, 0, 0, 0, 0, 0, a0)


def _u_unshare(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int unshare(int flags)
    #
    # "Plan 9 did containers first." Hamnix's native per-process mount
    # namespace IS the Plan 9 Pgrp; unshare(CLONE_NEWNS) gives the
    # CALLING task a fresh, independent COPY of its current mount
    # namespace in place (ns_unshare_mount -> pgrp_clone of the current
    # Pgrp + drop the old ref). After the call, mounts/binds the caller
    # makes are invisible to its parent and siblings, and vice-versa.
    #
    # Scope: CLONE_NEWNS (mount namespace) ONLY. The PID / NET / UTS /
    # USER / IPC / CGROUP namespace bits require deep kernel machinery
    # Hamnix does not have, so any of those bits set -> -EINVAL rather
    # than silently pretending to isolate. A bare unshare(0) (or one
    # carrying only CLONE_FILES / CLONE_FS, which Hamnix already gives
    # each task privately) is a successful no-op.
    flags: uint64 = a0
    # Strict reject: any unsupported CLONE_NEW* bit fails the whole call,
    # matching Linux's all-or-nothing unshare(2) semantics.
    if (flags & CLONE_NEW_UNSUPPORTED) != 0:
        return ELINUX_INVAL
    if (flags & CLONE_NEWNS) != 0:
        rc: int32 = ns_unshare_mount()
        if rc < 0:
            # ns_unshare_mount returns -12 (-ENOMEM) on pgrp_clone OOM.
            # Surface it as the matching Linux errno; ELINUX_AGAIN is the
            # closest constant already defined for the clone-side OOM, but
            # unshare(2)'s documented OOM is ENOMEM — return that directly.
            return cast[int64](-12)               # -ENOMEM
        return 0
    # No namespace bit we implement: treat CLONE_FILES / CLONE_FS / 0 as
    # a successful no-op (those resources are already per-task here).
    return 0


def _u_setns(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setns(int fd, int nstype)
    #
    # setns(2) re-associates the caller with an EXISTING namespace named
    # by an fd opened on /proc/PID/ns/<type> (an nsfs node). Hamnix has
    # no nsfs / proc-ns-fd machinery yet, so there is no fd->Pgrp mapping
    # to join — we reject gracefully with -EINVAL. FOLLOW-UP: implement
    # nsfs (/proc/PID/ns/mnt) so an fd can name a live Pgrp, then setns
    # can pgrp_ref_inc + adopt it.
    return ELINUX_INVAL


def _u_execve(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int execve(const char *path, char *const argv[], char *const envp[])
    #
    # U25: forward straight to the kernel's shared do_execve helper.
    # That replaces the current task's user image with the ELF at
    # `path` from initramfs, builds a fresh Linux process init-stack
    # carrying argv + envp + auxv, and SYSRETs into the new entry
    # point — so on success this never returns. On failure (missing
    # path / bad ELF) do_execve returns a negative Linux errno which
    # we forward unchanged: that's what glibc's execve() wrapper
    # expects to see in %rax to flip errno and report `perror`.
    #
    # §5 note: O_NONBLOCK is INTENTIONALLY left intact across execve —
    # do_execve preserves the fd table (Hamnix has no FD_CLOEXEC), and
    # Linux likewise preserves O_NONBLOCK on a surviving fd, so the
    # per-fd bitmap stays valid for the new image. uep_nonblock_clear_
    # task is used only on task teardown, not here.
    return do_execve(a0, a1, a2)


def _u_wait4(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t wait4(pid_t pid, int *wstatus, int options,
    #             struct rusage *rusage)
    #
    # U26: forward to the kernel's shared do_wait4 helper, which mirrors
    # the existing SYS_WAITPID body but writes the Linux-shape wait
    # status (exit code in bits 15:8) into *wstatus_ptr. glibc's
    # waitpid() is the thin wrapper waitpid(pid, st, opt) ->
    # wait4(pid, st, opt, NULL) — same path.
    return do_wait4(a0, a1, a2, a3)


# =====================================================================
# U8: uname / fstat / newfstatat
# =====================================================================
#
# struct utsname (Linux x86_64) is six contiguous 65-byte fields:
# sysname, nodename, release, version, machine, domainname — 390 bytes
# total, each NUL-padded. Userspace passes a pointer; we fill in place.

UTSNAME_FIELD_LEN: uint64 = 65
UTSNAME_TOTAL:     uint64 = 390

# #163: kernel scratch for uname(2). We assemble the whole utsname here
# (a fixed kernel buffer — never a user pointer) and then copy_to_user it
# in one translated transfer, so a malformed user buf yields -EFAULT
# instead of faulting memset/_u_uts_field on a raw user pointer. Top-level
# BSS rather than a nested-frame Array (the U9 nested-frame-Array quirk).
u_uts_scratch: Array[390, uint8]


def _u_uts_field(buf: uint64, off: uint64, s: Ptr[uint8]):
    # Copy NUL-terminated `s` into the utsname buffer at byte offset
    # `off`. Caller guarantees the string fits in the 65-byte field;
    # we still cap at 64 + trailing NUL to mirror Linux's safety margin
    # (and so a future too-long string truncates cleanly instead of
    # walking into the next field).
    dst: Ptr[uint8] = cast[Ptr[uint8]](buf + off)
    i: uint64 = 0
    while i < UTSNAME_FIELD_LEN - 1:
        c: uint8 = s[i]
        dst[i] = c
        if c == 0:
            return
        i = i + 1
    dst[UTSNAME_FIELD_LEN - 1] = 0


def _u_uname(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int uname(struct utsname *buf)
    # The single argument is a pointer to a 390-byte char-array struct.
    # #163: assemble the struct in a kernel scratch (zero-padded fields)
    # then copy it out in ONE translated copy_to_user, so a malformed user
    # buf returns -EFAULT instead of faulting the kernel on a raw deref.
    if a0 == 0:
        return ELINUX_INVAL
    ksc: uint64 = cast[uint64](&u_uts_scratch[0])
    memset(cast[Ptr[uint8]](ksc), 0, UTSNAME_TOTAL)
    # sysname MUST be "Linux": the caller is a real Linux ELF running
    # under the Linux ABI, and essentially every piece of Linux userland
    # (dpkg-architecture, ./configure, libc's __uname kernel-version
    # gate, perl's Config, python's platform.system()) branches on
    # sysname=="Linux". Reporting "Hamnix" here makes those tools think
    # they are on an unknown OS and fall into wrong/Unsupported code
    # paths. Hamnix's own identity lives in nodename + version below.
    _u_uts_field(ksc,   0, cast[Ptr[uint8]]("Linux"))
    _u_uts_field(ksc,  65, cast[Ptr[uint8]]("hamnix"))
    _u_uts_field(ksc, 130, cast[Ptr[uint8]]("6.12.0-hamnix"))
    _u_uts_field(ksc, 195, cast[Ptr[uint8]]("#1 Hamnix"))
    _u_uts_field(ksc, 260, cast[Ptr[uint8]]("x86_64"))
    _u_uts_field(ksc, 325, cast[Ptr[uint8]]("(none)"))
    if copy_to_user(a0, ksc, UTSNAME_TOTAL) != 0:
        set_current_errstr("uname: bad utsname pointer")
        return ELINUX_EFAULT
    return 0


# Linux x86_64 struct stat is 144 bytes; field offsets baked here as
# constants so the body of _u_fill_stat reads top-to-bottom against
# the canonical layout. See <asm-generic/stat.h> for the source of
# truth — these match the x86_64 variant (not the legacy 32-bit one).
STAT_SIZE:       uint64 = 144
# #163: kernel scratch for the assembled struct stat. We fill this then
# copy_to_user it in one translated transfer (top-level BSS, not a
# nested-frame Array — the U9 quirk).
u_stat_scratch: Array[144, uint8]
ST_OFF_DEV:      uint64 = 0
ST_OFF_INO:      uint64 = 8
ST_OFF_NLINK:    uint64 = 16
ST_OFF_MODE:     uint64 = 24
ST_OFF_UID:      uint64 = 28
ST_OFF_GID:      uint64 = 32
ST_OFF_RDEV:     uint64 = 40
ST_OFF_SIZE:     uint64 = 48
ST_OFF_BLKSIZE:  uint64 = 56
ST_OFF_BLOCKS:   uint64 = 64
ST_OFF_ATIME:    uint64 = 72
ST_OFF_MTIME:    uint64 = 88
ST_OFF_CTIME:    uint64 = 104

# S_IFREG | 0644 — the only mode we report at this milestone. Every
# fd Hamnix can open today is either a regular file in the cpio/ext4
# image or a stream-shaped device (/dev/null, pipe, tty). For stat
# purposes the userspace tools we care about (busybox cat, sh,
# coreutils) just need "this is a regular file" to do the right
# thing; a future device-aware fstat picks up S_IFCHR for ttys etc.
STAT_MODE_REG:  uint32 = 0o100644
# S_IFDIR | 0755 — used when fstat sees a directory-flavoured fd
# (FD_DIR_MARK). busybox's ls / stat keys off the IFDIR bit to decide
# "enumerate me with getdents64" vs "treat me as a regular file".
STAT_MODE_DIR:  uint32 = 0o040755


def _u_file_size_via_lseek(fd: int32) -> int64:
    # Probe an fd's byte length by seeking to end, then restoring the
    # original position. Returns -1 on any failure so callers can fall
    # through to st_size=0 without propagating an arbitrary errno.
    # vfs_lseek validates the fd for us; on stream-shaped fds (stdio,
    # pipe, /dev/null) it returns EINVAL and we treat the size as 0.
    cur: int64 = vfs_lseek(fd, 0, 1)              # SEEK_CUR
    if cur < 0:
        return -1
    end: int64 = vfs_lseek(fd, 0, 2)              # SEEK_END
    if end < 0:
        return -1
    rc: int64 = vfs_lseek(fd, cur, 0)             # SEEK_SET (restore)
    if rc < 0:
        return -1
    return end


def _u_fill_stat(buf: uint64, fd: int32) -> int64:
    # Shared body for fstat and newfstatat: assemble struct stat in a
    # kernel scratch, then copy it out in ONE translated copy_to_user.
    # #163: previously each field was poked through a RAW user pointer, so
    # a malformed `buf` faulted the kernel; now a bad buf returns -EFAULT.
    # fd is assumed to refer to a regular file; caller is responsible for
    # opening (and closing, in newfstatat's case).
    if buf == 0:
        return ELINUX_INVAL
    # Assemble into the kernel scratch (ksb); copy_to_user(buf, ...) at
    # the end performs the single translated write to the user struct.
    ksb: uint64 = cast[uint64](&u_stat_scratch[0])
    memset(cast[Ptr[uint8]](ksb), 0, STAT_SIZE)
    # st_dev stays 0 — we don't track per-FS device IDs.
    # §4: st_ino MUST be a stable, per-FILE-unique identifier.
    # glibc's ld.so keys its already-loaded-DSO check off the
    # (st_dev, st_ino) pair fstat returns — a dlopen()ed shared
    # object whose fstat (dev,ino) matches an already-mapped object
    # is treated as "already loaded" and never mmap'd. The old code
    # used the FD NUMBER as the inode, but fd numbers recycle across
    # open/close: a dlopen target landing on the same fd slot a
    # previously-mapped DSO used would collide and ld.so would hand
    # back the wrong link_map (dlsym then failed). vfs_fd_inode
    # derives the inode from the backing file's identity instead.
    cast[Ptr[uint64]](ksb + ST_OFF_INO)[0] = vfs_fd_inode(fd)
    cast[Ptr[uint64]](ksb + ST_OFF_NLINK)[0] = 1
    # U32: report S_IFDIR for directory-flavoured fds so ls(1) decides
    # to enumerate via getdents64 instead of dumping the dir as a file.
    #
    # BLOCKER 2 (dpkg helper resolution): report the file's REAL permission
    # bits (with the execute bit for staged executables) instead of a
    # hard-coded 0644. dpkg's findprog stats each PATH candidate and requires
    # (st_mode & 0111) — a 0644 stat made every cpio-staged /bin/sh, /bin/tar,
    # /usr/bin/dpkg-deb look non-executable, so dpkg aborted with "N expected
    # programs not found in PATH or not executable". vfs_fd_mode returns the
    # genuine cpio / ext4 mode (or 0755 for a tmpfs-unpacked program), -1 when
    # unavailable — in which case we keep the 0644 default (e.g. pipes, cdevs).
    mode_v: uint32 = STAT_MODE_REG
    if vfs_fd_is_dir(fd) != 0:
        mode_v = STAT_MODE_DIR
    else:
        real_perm: int32 = vfs_fd_mode(fd)
        if real_perm >= 0:
            # S_IFREG (0o100000) | low-12 permission bits.
            mode_v = cast[uint32](0o100000) | cast[uint32](real_perm)
    cast[Ptr[uint32]](ksb + ST_OFF_MODE)[0] = mode_v
    # st_uid/st_gid: surface the file's REAL owner, mapped native->linux.
    # tmpfs stamps the creating task's native uid on each entry, so a
    # uid-1001 `spawn linux` process now sees its own files reported
    # owned by 1001 (not the old hard-coded 0). Backends whose owner is
    # unknown keep 0 (root), the historical default.
    so_uid: uint32 = 0
    so_gid: uint32 = 0
    if vfs_fd_stat_owner(fd, &so_uid, &so_gid) == 0:
        cast[Ptr[uint32]](ksb + ST_OFF_UID)[0] = \
            cast[uint32](_linux_uid_from_native(so_uid))
        cast[Ptr[uint32]](ksb + ST_OFF_GID)[0] = \
            cast[uint32](_linux_uid_from_native(so_gid))
    else:
        cast[Ptr[uint32]](ksb + ST_OFF_UID)[0] = 0
        cast[Ptr[uint32]](ksb + ST_OFF_GID)[0] = 0
    cast[Ptr[uint64]](ksb + ST_OFF_RDEV)[0] = 0
    # st_size: best-effort lookup via lseek SEEK_END. Stream fds and
    # other lseek-rejecting backings end up with st_size=0, which is
    # the safest fallback for tools that read until EOF anyway.
    size: int64 = _u_file_size_via_lseek(fd)
    if size < 0:
        size = 0
    cast[Ptr[int64]](ksb + ST_OFF_SIZE)[0] = size
    cast[Ptr[int64]](ksb + ST_OFF_BLKSIZE)[0] = 4096
    blocks: int64 = (size + 511) / 512
    cast[Ptr[int64]](ksb + ST_OFF_BLOCKS)[0] = blocks
    # atime/mtime/ctime tv_sec. ext4 files carry a real per-inode
    # mtime (stamped from the RTC on create/write/truncate) — report
    # it so `stat` and make's "target newer than source" logic work.
    # Other fd flavours have no stored timestamp; they fall back to
    # the jiffies-derived clock. tv_nsec stays zero (memset cleared).
    j: uint64 = get_jiffies()
    sec: int64 = cast[int64](j / 100)
    mt: int64 = vfs_fd_mtime(fd)
    if mt >= 0:
        sec = mt
    cast[Ptr[int64]](ksb + ST_OFF_ATIME)[0] = sec
    cast[Ptr[int64]](ksb + ST_OFF_MTIME)[0] = sec
    cast[Ptr[int64]](ksb + ST_OFF_CTIME)[0] = sec
    # #163: single translated copy of the assembled struct to the user
    # buffer. A bad / unmapped user `buf` returns -EFAULT instead of a
    # kernel page fault.
    if copy_to_user(buf, ksb, STAT_SIZE) != 0:
        set_current_errstr("stat: bad statbuf pointer")
        return ELINUX_EFAULT
    return 0


def _u_fstat(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fstat(int fd, struct stat *statbuf)
    # vfs_lseek is the cheapest fd-validity probe we have: it returns
    # EBADF on an out-of-range fd and EINVAL on a stream-shaped fd
    # (still a valid fd, so we accept that). A -EBADF here means the
    # caller passed a never-allocated slot.
    fd: int32 = cast[int32](a0)
    probe: int64 = vfs_lseek(fd, 0, 1)            # SEEK_CUR
    if probe < 0 and probe == cast[int64](ELINUX_BADF):
        return ELINUX_BADF
    return _u_fill_stat(a1, fd)


def _u_stat_path(upath: uint64, buf: uint64) -> int64:
    # Shared body for stat() and lstat(): copy the (possibly relative)
    # user path into a kernel scratch, resolve it against the task cwd,
    # open it via vfs_open, hand the resulting fd to _u_fill_stat, then
    # close. Returns 0 on success or a negative Linux errno. Factored
    # out so SYS_stat (4) and SYS_lstat (6) share one code path —
    # Hamnix has no symlinks, so the two syscalls are semantically
    # identical here.
    # #163: the path arrives as a user pointer; copy it in through the
    # translated strncpy_from_user before resolve_path touches it.
    if upath == 0 or buf == 0:
        return ELINUX_INVAL
    kpath: Array[256, uint8]
    pin: int64 = _u_copyin_path(upath, &kpath[0])
    if pin != 0:
        return pin
    # F10-1 double-resolution fix: vfs_open resolves the namespace once
    # internally; passing a pre-resolved path doubled a `/`-rebound root.
    fd: int32 = vfs_open(cast[Ptr[char]](&kpath[0]))
    if fd < 0:
        return cast[int64](fd)
    rv: int64 = _u_fill_stat(buf, fd)
    vfs_close(fd)
    return rv


def _u_stat(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int stat(const char *pathname, struct stat *statbuf)
    return _u_stat_path(a0, a1)


def _u_lstat(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int lstat(const char *pathname, struct stat *statbuf)
    # Hamnix has no symlinks yet, so lstat is identical to stat —
    # there's nothing to "not follow". When real symlinks land in vfs
    # this body branches: stat() resolves through them, lstat()
    # reports the link itself.
    return _u_stat_path(a0, a1)


# AT_FDCWD is -100 (int32). It can arrive in a0 EITHER sign-extended to
# 64 bits (0xFFFFFFFFFFFFFF9C) — the glibc/musl path that passes the int
# through a 64-bit register — OR zero-extended in just the low 32 bits
# (0x00000000FFFFFF9C), which is how real tar/dpkg-deb deliver the dirfd
# on this kernel's syscall ABI (observed: dirfd=4294967196 on mkdirat).
# Comparing only against the sign-extended constant mis-classified the
# zero-extended form as a REAL dirfd, so mkdirat/openat/utimensat went
# down the dirfd-anchor leg with no recorded path → EBADF/ENOSYS, which
# is exactly the "tar: Cannot mkdir: Bad file descriptor" abort. Match
# BOTH encodings by comparing the low 32 bits against the -100 pattern.
AT_FDCWD_U64:        uint64 = 0xFFFFFFFFFFFFFF9C
AT_FDCWD_LO32:       uint64 = 0x00000000FFFFFF9C
AT_SYMLINK_NOFOLLOW: uint64 = 0x100
AT_EMPTY_PATH:       uint64 = 0x1000
# AT_NO_AUTOMOUNT (0x800): "don't trigger an automount". Hamnix has no
# autofs, so this is a NO-OP — but modern coreutils (GNU stat, ls, du,
# find via fstatat/statx) ALWAYS set it, so it must be tolerated, not
# rejected with EINVAL. Before this fix `stat /x`, `ls /usr/bin`, etc.
# returned EINVAL ("Invalid argument") and printed nothing.
AT_NO_AUTOMOUNT:     uint64 = 0x800
# statx-only sync hints in the flags word (glibc's __statx passes
# AT_STATX_SYNC_AS_STAT == 0x0000 by default; the FORCE/DONT_SYNC variants
# are 0x2000 / 0x4000). All are advisory caching hints we satisfy by
# always returning current attributes, so tolerate them.
AT_STATX_FORCE_SYNC: uint64 = 0x2000
AT_STATX_DONT_SYNC:  uint64 = 0x4000


def _u_is_at_fdcwd(dirfd: uint64) -> int32:
    # True iff `dirfd` is AT_FDCWD in either the sign-extended or the
    # low-32-zero-extended encoding. Used by every *at(2) handler so the
    # "use the cwd" path is taken consistently regardless of how the libc
    # widened the int dirfd into the syscall register.
    if (dirfd & 0xFFFFFFFF) == AT_FDCWD_LO32:
        return 1
    return 0


def _u_newfstatat(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int newfstatat(int dirfd, const char *path, struct stat *buf,
    #                int flags)
    # Three dispatch shapes we handle:
    #   (a) dirfd==AT_FDCWD, path absolute or relative: open + fill.
    #   (b) dirfd==AT_FDCWD with path absolute: same body.
    #   (c) AT_EMPTY_PATH set + path == "": stat dirfd directly.
    # U32 adds (c) because busybox's ls passes a dir fd it just
    # opened with O_PATH-style flags and asks "what is this fd?".
    # AT_SYMLINK_NOFOLLOW is accepted-but-ignored (we have no
    # symlinks); other flag bits still get logged + -EINVAL.
    if a1 == 0 or a2 == 0:
        return ELINUX_INVAL
    flags: uint64 = a3
    empty_path: int32 = 0
    if (flags & AT_EMPTY_PATH) != 0:
        empty_path = 1
        flags = flags & ~AT_EMPTY_PATH
    if (flags & AT_SYMLINK_NOFOLLOW) != 0:
        flags = flags & ~AT_SYMLINK_NOFOLLOW
    # AT_NO_AUTOMOUNT (0x800): GNU coreutils' fstatat ALWAYS sets it; no
    # autofs here so it's a no-op. Strip it (was -EINVAL before -> stat/
    # ls/cut/sed silently produced no output).
    flags = flags & ~AT_NO_AUTOMOUNT
    if flags != 0:
        printk2("linux_u: newfstatat unsupported flags=%x path=%x\n",
                a3, a1)
        return ELINUX_INVAL
    # #163: copy the user path into a kernel scratch via the translated
    # strncpy_from_user, then do every byte-inspection and resolve_path
    # against the kernel copy. AT_EMPTY_PATH passes a "" path, which
    # strncpy_from_user copies as a zero-length string — handled below.
    kpath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a1, &kpath[0])
    if pin != 0:
        return pin
    p: Ptr[char] = cast[Ptr[char]](&kpath[0])
    is_empty: int32 = 0
    if cast[uint8](p[0] & 0xFF) == 0:
        is_empty = 1
    if empty_path != 0 and is_empty != 0:
        # Treat dirfd as the fd to fstat. AT_FDCWD with empty path is
        # not a thing busybox does — bail with EBADF for unknowns.
        if _u_is_at_fdcwd(a0) != 0:
            return ELINUX_BADF
        return _u_fill_stat(a2, cast[int32](a0))
    # Absolute paths ignore dirfd per the openat(2) / fstatat(2) man
    # pages, so we accept any dirfd as long as the path is absolute.
    # Only relative paths require AT_FDCWD (until per-fd dirpath state
    # arrives in a later milestone).
    is_abs: int32 = 0
    if cast[uint8](p[0] & 0xFF) == 47:                # '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        # Real dirfd + relative: anchor at the dirfd's recorded open-path
        # and stat the joined absolute path — tar/dpkg fstatat(dirfd,name)
        # an extracted member before/after writing it.
        at_abs: Array[384, uint8]
        arc: int64 = _u_at_resolve_dirfd(a0, a1, &at_abs[0], 384)
        if arc != 0:
            return arc
        afd: int32 = vfs_open(cast[Ptr[char]](&at_abs[0]))
        if afd < 0:
            return cast[int64](afd)
        arv: int64 = _u_fill_stat(a2, afd)
        vfs_close(afd)
        return arv
    # F10-1 double-resolution fix: pass the RAW path to vfs_open so its
    # single internal resolve_path walks the namespace once (a pre-resolve
    # + vfs_open's own resolve doubled a `/`-rebound root prefix, so every
    # stat under `enter linux { bind '#distro' / }` ENOENT'd — busybox ls
    # stats each child and silently dropped the whole listing).
    fd: int32 = vfs_open(cast[Ptr[char]](&kpath[0]))
    if fd < 0:
        return cast[int64](fd)
    rv: int64 = _u_fill_stat(a2, fd)
    vfs_close(fd)
    return rv


# fcntl(2) cmd numbers (from <bits/fcntl-linux.h>). Hamnix has no
# FD_CLOEXEC bookkeeping and no per-fd flags / file locking yet, so
# the get-side commands return 0 and the set-side commands silently
# accept. F_DUPFD / F_DUPFD_CLOEXEC forward to vfs_dup, ignoring the
# "at or above newfd" constraint (which would require a vfs_dup that
# takes a minimum-fd hint; not yet plumbed).
F_DUPFD:         uint64 = 0
F_GETFD:         uint64 = 1
F_SETFD:         uint64 = 2
F_GETFL:         uint64 = 3
F_SETFL:         uint64 = 4
F_GETLK:         uint64 = 5
F_SETLK:         uint64 = 6
F_SETLKW:        uint64 = 7
F_DUPFD_CLOEXEC: uint64 = 1030


def _u_fcntl(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fcntl(int fd, int cmd, ... /* arg */ )
    # Each branch matches the Linux command number; bodies are the
    # minimum that lets glibc / musl startup paths stop probing on
    # -ENOSYS. F_DUPFD ignores the at-or-above-newfd constraint for
    # now — vfs_dup picks the smallest free fd, which happens to be
    # >= 0 (>= "newfd=0") and usually >= any reasonable user request.
    cmd: uint64 = a1
    if cmd == F_DUPFD:
        # A plain F_DUPFD target is explicitly NOT close-on-exec (vfs_dup
        # copies the source fd's flag via copy_fd_entry, so clear it).
        ndf: int32 = vfs_dup(cast[int32](a0))
        if ndf >= 0:
            _u_set_fd_cloexec(ndf, 0)
        return cast[int64](ndf)
    if cmd == F_DUPFD_CLOEXEC:
        ndc: int32 = vfs_dup(cast[int32](a0))
        if ndc >= 0:
            _u_set_fd_cloexec(ndc, 1)
        return cast[int64](ndc)
    if cmd == F_GETFD:
        # Report FD_CLOEXEC (bit 0) — the ONLY fd flag Linux defines.
        if fd_cloexec_get(current_idx_get(), cast[int32](a0)) != 0:
            return 1
        return 0
    if cmd == F_SETFD:
        # arg bit FD_CLOEXEC (1) toggles close-on-exec.
        cxon: int32 = 0
        if (a2 & 1) != 0:
            cxon = 1
        _u_set_fd_cloexec(cast[int32](a0), cxon)
        return 0
    if cmd == F_GETFL:
        # §5: report the fd's access mode + O_NONBLOCK. Hamnix opens
        # are read-write at the fd-table level, so O_RDWR (2) is the
        # honest base; OR in O_NONBLOCK (0x800) if the §5 bitmap has it.
        flv: int64 = 2                       # O_RDWR
        if _u_fd_is_nonblock(cast[int32](a0)) != 0:
            flv = flv | cast[int64](O_NONBLOCK_BIT)
        return flv
    if cmd == F_SETFL:
        # §5: F_SETFL is how a daemon toggles O_NONBLOCK after open
        # (the standard fcntl(fd, F_SETFL, fl | O_NONBLOCK) idiom).
        # Other settable bits (O_APPEND / O_DIRECT) have no fd-table
        # state to apply; we honour O_NONBLOCK and accept the rest.
        on: int32 = 0
        if (a2 & O_NONBLOCK_BIT) != 0:
            on = 1
        _u_set_fd_nonblock(cast[int32](a0), on)
        return 0
    if cmd == F_GETLK:
        return 0
    if cmd == F_SETLK:
        return 0
    if cmd == F_SETLKW:
        return 0
    # §memfd: file sealing. F_ADD_SEALS adds the seal bits in `arg` to the
    # memfd backing this fd (EPERM if the fd was not memfd_create'd with
    # MFD_ALLOW_SEALING, or already F_SEAL_SEAL'd; EINVAL for an unknown
    # seal bit or a non-sealable fd; EBUSY for a live writable mmap). The
    # seals are enforced on subsequent write(2)/ftruncate. F_GET_SEALS
    # returns the current bitmask. Both route to linux_abi/u_memfd.ad.
    if cmd == F_ADD_SEALS_CMD:
        return umemfd_add_seals(cast[int32](a0), a2)
    if cmd == F_GET_SEALS_CMD:
        return umemfd_get_seals(cast[int32](a0))
    return ELINUX_INVAL


def _u_unimpl_readlink(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t readlink(const char *pathname, char *buf, size_t bufsiz).
    # readlink(path, buf, n) is exactly readlinkat(AT_FDCWD, path, buf, n)
    # — the dirfd-less elder syscall. We forward to the already-real
    # _u_readlinkat with AT_FDCWD so both share one symlink-resolution
    # body: it special-cases /proc/self/exe (the path glibc actually
    # hits), copies the link target into the user buffer truncated to
    # bufsiz with NO trailing NUL (the readlink(2) contract), returns
    # the byte count, and gives -EINVAL on a real non-symlink file /
    # -ENOENT on a missing path.
    #
    # Name kept as _u_unimpl_readlink for dispatch-table compatibility
    # (the prefix is now misleading) — same convention pread64 uses.
    return _u_readlinkat(AT_FDCWD_U64, a0, a1, a2, 0, 0)


def _u_unimpl_arch_prctl(a0: uint64, a1: uint64, a2: uint64,
                         a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int arch_prctl(int code, unsigned long addr).
    # Only ARCH_SET_FS is honoured. glibc's pthread initialisation calls
    # arch_prctl(ARCH_SET_FS, &tcb) before main(); subsequent loads of
    # the form `mov %fs:0x28, %rax` (stack canary) and `mov %fs:0x10, %rax`
    # (TLS DTV pointer) depend on FS_BASE pointing at the TCB.
    #
    # We write the user-supplied address straight into IA32_FS_BASE AND
    # stash it in current_task->fs_base so the next context switch
    # restores it (U27 — without per-task save/restore, a second thread
    # would silently overwrite the parent's TCB pointer on its own
    # ARCH_SET_FS). Validation against canonical-form is the CPU's job:
    # a non-canonical value triggers #GP on the wrmsr and lands in the
    # existing fault handler.
    if a0 == ARCH_SET_FS:
        write_msr(IA32_FS_BASE, a1)
        set_task_fs_base(cast[int32](current_idx_get()), a1)
        return 0
    # ARCH_GET_FS: copy the current FS_BASE back to *addr. We report the
    # per-task stored value (the same one schedule() reloads on switch),
    # which equals the live IA32_FS_BASE for the running task. glibc's
    # TLS-relocation cross-checks (and tools like `pthread_self`) read it
    # back this way. addr is a user `unsigned long *`.
    if a0 == ARCH_GET_FS:
        if a1 == 0:
            return ELINUX_INVAL
        if put_user_64(task_fs_base(cast[int32](current_idx_get())),
                       a1) != 0:                        # #163
            return ELINUX_EFAULT
        return 0
    # ARCH_SET_GS: symmetric to ARCH_SET_FS but on IA32_GS_BASE (the
    # user/inactive GS the CPU swapgs's live on return-to-user). We do
    # NOT stash it per-task — there is no gs_base save/restore slot in
    # TaskStruct, so a context switch would drop it. That's acceptable:
    # nothing in glibc's mainline startup uses %gs, and a single-threaded
    # guest that sets GS keeps the MSR until the next swapgs pair.
    if a0 == ARCH_SET_GS:
        write_msr(IA32_GS_BASE, a1)
        return 0
    # ARCH_GET_GS: read back the user GS_BASE MSR straight from the CPU.
    if a0 == ARCH_GET_GS:
        if a1 == 0:
            return ELINUX_INVAL
        if put_user_64(read_msr(IA32_GS_BASE), a1) != 0:  # #163
            return ELINUX_EFAULT
        return 0
    return ELINUX_INVAL


def _u_unimpl_set_tid_address(a0: uint64, a1: uint64, a2: uint64,
                              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long set_tid_address(int *tidptr).
    # Linux records tidptr in current->clear_child_tid and returns the
    # caller's tid. On task exit the kernel writes 0 there and futex-
    # wakes waiters (the CLONE_CHILD_CLEARTID handshake). U27 promotes
    # this from a single global to per-task storage in TaskStruct so
    # multiple Linux tasks (e.g. parent + pthreads) each track their
    # own pointer. set_task_clear_child_tid is the accessor.
    set_task_clear_child_tid(cast[int32](current_idx_get()), a0)
    return cast[int64](current_task_pid())


# DIAG counter for the Firefox openat=-2 loop tracer (bounded serial spam).
_oa_enoent_diag_count: uint64 = 0


def _u_openat(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # openat(int dirfd, const char *path, int flags, mode_t mode).
    # glibc reaches for this in preference to open() on modern builds.
    # Two cases dispatch through resolve_path + vfs_open inline:
    #
    #   * dirfd == AT_FDCWD (-100): "use the task's cwd" — exactly
    #     what resolve_path already does for relative paths.
    #   * path is absolute (starts with '/'): dirfd is ignored per
    #     the openat(2) man page; behaviour matches open().
    #
    # Any other dirfd needs per-fd directory bookkeeping that Hamnix
    # doesn't yet have (vfs tracks an open fd as a position into a
    # file, not as "an open handle to a directory plus a path"). We
    # log via printk1 and return -ENOSYS so the gap is visible.
    #
    # Implementation note: an earlier draft (M16.134) inlined the
    # resolve_path + vfs_open body here because calling _u_open()
    # from _u_openat() deterministically failed with -ENOENT — a
    # frame-layout / spill interaction in compiler.adder's lowering
    # of nested fixed-size Array locals across two call frames (the
    # "U9 nested-frame-Array" quirk). That codegen defect was fixed
    # by 224051b (`&arr[i][j]` address-of) + 18534b2 (sized scalar
    # local store/load); the inline workaround is no longer needed,
    # so _u_openat now just delegates to _u_open for the AT_FDCWD /
    # absolute-path cases like a normal call. Verified via
    # scripts/test_u9_access.sh (the openat marker still PASSes).
    if a1 == 0:
        return ELINUX_INVAL
    is_abs: int32 = 0
    if _u_user_first_byte(a1) == 47:                  # '/' (#163)
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        # Real dirfd + relative path: anchor at the dirfd's recorded
        # open-path (same mechanism mkdirat/unlinkat use) and open the
        # joined absolute path. This is what lets GNU tar/dpkg-deb create
        # AND read back extracted files via a directory fd (e.g. dpkg's
        # control unpack openat(dirfd,"control",O_WRONLY|O_CREAT)). a2 is
        # `flags` for openat(2).
        at_abs: Array[384, uint8]
        arc: int64 = _u_at_resolve_dirfd(a0, a1, &at_abs[0], 384)
        if arc != 0:
            return arc
        return _u_open_kpath(cast[Ptr[char]](&at_abs[0]), a2)
    # dirfd is AT_FDCWD or the path is absolute — identical semantics
    # to open(2). _u_open does resolve_path + /proc->/dev translation
    # + vfs_open; reuse it directly.
    oa_rc: int64 = _u_open(a1, a2, a3, 0, 0, 0)
    # DIAG (Firefox openat=-2 loop): name the missing file. Rate-limited so a
    # normal font/theme candidate scan cannot flood the serial line. Remove
    # once the Firefox profile/font path gap is closed.
    if oa_rc == ELINUX_NOENT:
        if _oa_enoent_diag_count < 48:
            _oa_enoent_diag_count = _oa_enoent_diag_count + 1
            oa_dbg: Array[256, uint8]
            oa_n: int64 = strncpy_from_user(cast[uint64](&oa_dbg[0]), a1, 255)
            if oa_n >= 0:
                oa_dbg[oa_n] = 0
                printk_set_level(PRINTK_LEVEL_EMERG)
                printk1("[openat-enoent] %s\n", cast[uint64](&oa_dbg[0]))
    return oa_rc


# =====================================================================
# U21: identity probes (uid/gid/ppid)
# =====================================================================
#
# glibc's startup checks uid/gid very early — it gates secure-mode
# behaviour (AT_SECURE handling, suid handling) on (uid != euid ||
# gid != egid). Returning 0 for all four is "this process is root" —
# the simplest correct answer for a kernel with no user/group state.
# getppid() returns 1 because every Linux userspace lives downstream
# of init (PID 1); without a parent task in flight, that's the lie
# that keeps tools sane.


# =====================================================================
# Native (Plan-9) -> Linux (POSIX) identity mapping
# =====================================================================
#
# The native side carries a REAL per-task uid/gid (kernel/sched/core.ad
# TaskStruct.uid/.gid, inherited across the `enter linux` rfork). The
# Plan-9 model: uid 1 == hostowner ("the machine owner"; the idiom
# "root" does not exist natively), system services 2..999, regular users
# >= 1000, and 65534 == nobody. The Linux NS is the ONLY place that uses
# POSIX uid semantics, where 0 == root.
#
# User directive (the privilege model): the hostowner gets a ROOT shell
# inside `enter linux`; every other native identity becomes a non-root
# Linux user that KEEPS its numeric id. So the mapping is:
#
#   native 1 (hostowner)  -> Linux 0      (root)
#   native 65534 (nobody) -> Linux 65534  (pass through)
#   native >= 1000        -> same numeric (non-root user)
#   native 2..999         -> same numeric (non-root service)
#
# This is the SINGLE SOURCE OF TRUTH for the mapping; getuid/geteuid/
# getgid/getegid all funnel through it. There is no suid/credential
# machinery on the Linux-ABI path, so effective == real for both id and
# group. The native uid is read via current_task_uid()/current_task_gid()
# (kernel/sched/core.ad:6742/6747), which index the current task struct
# in the SAME task that issues the Linux syscall — no cross-task bridge
# is needed; `enter linux` rforks into a task carrying the caller's uid.
def _linux_uid_from_native(native_id: uint32) -> int64:
    if native_id == UID_HOSTOWNER:
        return 0
    return cast[int64](native_id)


def _u_getuid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # uid_t getuid(void). Maps the native task uid into POSIX space:
    # hostowner -> 0 (root), every other identity keeps its number.
    return _linux_uid_from_native(current_task_uid())


def _u_getgid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # gid_t getgid(void). Same mapping shape as getuid(), keyed on the
    # native task gid.
    return _linux_uid_from_native(current_task_gid())


def _u_geteuid(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # uid_t geteuid(void). No suid mechanism on the Linux-ABI path, so
    # effective == real.
    return _linux_uid_from_native(current_task_uid())


def _u_getegid(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # gid_t getegid(void). Effective == real (no sgid mechanism here).
    return _linux_uid_from_native(current_task_gid())


def _u_getresuid(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getresuid(uid_t *ruid, uid_t *euid, uid_t *suid). There is no
    # suid mechanism on the Linux-ABI path, so real == effective == saved.
    # Write the same POSIX-mapped uid to all three out-params (uid_t is
    # 32-bit) via translated copy_to_user, matching the getuid/geteuid map.
    # Firefox's g_check_setuid()/NSPR probe compares these; a filled buffer
    # (rather than an ENOSYS -1 that leaves them garbage) is what keeps it
    # from dereferencing an uninitialised pointer at startup.
    ubuf: Array[1, uint32]
    ubuf[0] = cast[uint32](_linux_uid_from_native(current_task_uid()))
    if a0 != 0 and copy_to_user(a0, cast[uint64](&ubuf[0]), 4) != 0:
        return ELINUX_EFAULT
    if a1 != 0 and copy_to_user(a1, cast[uint64](&ubuf[0]), 4) != 0:
        return ELINUX_EFAULT
    if a2 != 0 and copy_to_user(a2, cast[uint64](&ubuf[0]), 4) != 0:
        return ELINUX_EFAULT
    return 0


def _u_getresgid(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getresgid(gid_t *rgid, gid_t *egid, gid_t *sgid). Group analogue
    # of getresuid: effective == real == saved, keyed on the native gid.
    gbuf: Array[1, uint32]
    gbuf[0] = cast[uint32](_linux_uid_from_native(current_task_gid()))
    if a0 != 0 and copy_to_user(a0, cast[uint64](&gbuf[0]), 4) != 0:
        return ELINUX_EFAULT
    if a1 != 0 and copy_to_user(a1, cast[uint64](&gbuf[0]), 4) != 0:
        return ELINUX_EFAULT
    if a2 != 0 and copy_to_user(a2, cast[uint64](&gbuf[0]), 4) != 0:
        return ELINUX_EFAULT
    return 0


# QA-N10: the INVERSE of _linux_uid_from_native. setuid(2)/setgid(2) hand
# us a target in POSIX space; we must fold it back into a native id so the
# getters (which map native->POSIX) read the new value back consistently.
#
#   Linux 0 (root)  -> native UID_HOSTOWNER (the machine owner)
#   any other id    -> same numeric native id
#
# Note the hostowner asymmetry: native UID_HOSTOWNER maps to Linux 0, so a
# literal setuid(UID_HOSTOWNER) target would collide with the hostowner and
# read back as 0. That numeric id is a native-only convention that never
# appears as a Linux uid, so real Debian userland never targets it; we fold
# it to itself and document the edge rather than special-casing a value that
# cannot legitimately occur.
def _native_uid_from_linux(linux_id: int64) -> uint32:
    if linux_id == 0:
        return UID_HOSTOWNER
    return cast[uint32](linux_id)


def _u_setuid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setuid(uid_t uid). POSIX: a privileged caller may set any uid;
    # an unprivileged caller may only set its uid to its own real/effective
    # uid (there is no saved-set-uid on this path — effective == real —
    # so real is the only reachable target). Anything else is -EPERM.
    #
    # Privilege on the Linux-ABI path == "am I root?", i.e. the caller's
    # current uid maps to Linux 0 (the hostowner). We deliberately do NOT
    # silently succeed a privilege escalation: an unprivileged 1001 asking
    # for uid 0 gets -EPERM, matching Linux.
    target: int64 = cast[int64](cast[uint32](a0))     # uid_t is 32-bit
    cur: int64 = _linux_uid_from_native(current_task_uid())
    if cur == 0 or target == cur:
        set_current_task_uid(_native_uid_from_linux(target))
        return 0
    set_current_errstr("setuid: EPERM")
    return ELINUX_PERM


def _u_setgid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setgid(gid_t gid). Analogous to setuid: root (Linux uid 0) may
    # set any gid; everyone else may only re-assert their own current gid.
    # Privilege is keyed on the UID (root), matching Linux — the group is
    # not itself the privilege anchor.
    target: int64 = cast[int64](cast[uint32](a0))     # gid_t is 32-bit
    cur_uid: int64 = _linux_uid_from_native(current_task_uid())
    cur_gid: int64 = _linux_uid_from_native(current_task_gid())
    if cur_uid == 0 or target == cur_gid:
        set_current_task_gid(_native_uid_from_linux(target))
        return 0
    set_current_errstr("setgid: EPERM")
    return ELINUX_PERM


# =====================================================================
# QA-N15: supplementary groups — getgroups(2) / setgroups(2)
# =====================================================================
#
# Hamnix has no supplementary-group table on the Linux-ABI path; each task
# carries a single native gid (current_task_gid, POSIX-mapped by
# _linux_uid_from_native). We model the process as belonging to exactly ONE
# supplementary group == its own (mapped) gid. That is the minimal answer
# that makes coreutils `id` stop erroring ("can't get groups") and print a
# real `groups=<gid>` field, and it matches the common reality that a
# freshly-entered login session's only group IS its primary gid.
def _u_getgroups(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int getgroups(int size, gid_t list[]).
    #   size < 0        -> -EINVAL
    #   size == 0       -> return the count WITHOUT touching list
    #   size < count    -> -EINVAL
    #   otherwise       -> write `count` gids into list, return count
    sz: int64 = cast[int64](cast[int32](a0))     # size is a signed int
    if sz < 0:
        return ELINUX_INVAL
    ngroups: int64 = 1                            # one supplementary group
    if sz == 0:
        return ngroups
    if sz < ngroups:
        return ELINUX_INVAL
    # gid_t is 32-bit; emit the single (POSIX-mapped) gid via one translated
    # copy_to_user rather than poking the user pointer directly.
    grp_kbuf: Array[1, uint32]
    grp_kbuf[0] = cast[uint32](_linux_uid_from_native(current_task_gid()))
    if copy_to_user(a1, cast[uint64](&grp_kbuf[0]), 4) != 0:
        return ELINUX_EFAULT
    return ngroups


def _u_setgroups(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setgroups(size_t size, const gid_t *list). Privileged operation
    # in Linux (CAP_SETGID). We have no supplementary-group table to store,
    # so a privileged caller (root / hostowner, current uid maps to Linux 0)
    # is accepted as a no-op returning 0; an unprivileged caller is refused
    # with -EPERM, mirroring QA-N10's setuid/setgid privilege gate (keyed on
    # being root) rather than silently succeeding.
    cur_uid: int64 = _linux_uid_from_native(current_task_uid())
    if cur_uid == 0:
        return 0
    set_current_errstr("setgroups: EPERM")
    return ELINUX_PERM


def _u_getppid(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t getppid(void). Hamnix has no parent/child task lineage on
    # the Linux-ABI path; report 1 (init) so tools that key off "am I
    # PID 1 myself?" still see a sensible parent.
    return 1


# =====================================================================
# U36: tid / session / process-group identity
# =====================================================================
#
# Hamnix has one thread per task and no session-or-pgrp bookkeeping at
# this milestone. The seven syscalls below answer the relevant probes
# with the caller's own pid (treating each task as its own session and
# pgrp leader). setpgid is the only one that takes input; we accept and
# discard. tgkill forwards to the same kill path as kill(2), ignoring
# the tgid argument because we don't track thread groups distinctly.
# glibc's abort() path uses gettid + tgkill(self, sig); answering both
# with real semantics lets aborting code reach the signal-handler
# dispatch in U31 instead of falling off -ENOSYS.


def _u_gettid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t gettid(void). One thread per task — tid == pid.
    return cast[int64](current_task_pid())


def _u_tkill(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int tkill(pid_t tid, int sig)
    # §3: the single-arg kill-by-tid syscall. musl's raise(3) uses it
    # (raise → tkill(gettid(), sig)). Lookup by tid (a0), post to the
    # target's sig_pending; delivery happens at the target's next
    # syscall boundary / yield (self-targeted raises deliver at this
    # syscall's own tail in do_syscall).
    tgt: int32 = task_lookup_by_pid(a0)
    if tgt < 0:
        return ELINUX_SRCH
    signal_post(cast[uint64](tgt), a1)
    return 0


def _u_tgkill(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int tgkill(pid_t tgid, pid_t tid, int sig)
    # Same body as _u_kill but indexed by tid (a1); tgid (a0) is
    # ignored because Hamnix doesn't distinguish thread groups from
    # tasks. Matches Linux's lookup-by-tid-then-deliver semantics.
    tgt: int32 = task_lookup_by_pid(a1)
    if tgt < 0:
        return ELINUX_SRCH
    signal_post(cast[uint64](tgt), a2)
    return 0


def _u_setsid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t setsid(void). Linux creates a new session and returns its
    # sid (== caller pid). With no session table to update we just
    # report the caller's pid — same observable answer.
    return cast[int64](current_task_pid())


def _u_getsid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t getsid(pid_t pid). Linux: returns the sid of the named
    # task (0 == "me"). Single-session world; always our own pid.
    return cast[int64](current_task_pid())


def _u_getpgid(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t getpgid(pid_t pid). Returns the named task's pgrp leader;
    # 0 == "me". Every task is its own pgrp leader here.
    return cast[int64](current_task_pid())


def _u_setpgid(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int setpgid(pid_t pid, pid_t pgid). Accepted and discarded —
    # no pgrp table to mutate. busybox sh's job-control bring-up
    # only checks the return value, not subsequent getpgid output.
    return 0


def _u_getpgrp(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t getpgrp(void). Same answer as getpgid(0).
    return cast[int64](current_task_pid())


# =====================================================================
# U37: sigaltstack
# =====================================================================
#
# int sigaltstack(const stack_t *ss, stack_t *oss)
#
# struct stack_t {
#     void   *ss_sp;     /* offset  0, 8 bytes */
#     int     ss_flags;  /* offset  8, 4 bytes */
#     /* 4 bytes pad */
#     size_t  ss_size;   /* offset 16, 8 bytes */
# };
#
# Total size: 24 bytes. glibc's static-PIE startup installs an alt
# stack so a SIGSEGV handler can run on a known-good page if the
# user's main stack is the thing that overflowed. Hamnix has exactly
# one task per thread and signal_check_and_handle never delivers a
# second signal on top of an in-flight handler, so we never need to
# actually SWITCH to the alt stack — the values just need to be
# recorded so the syscall stops returning -ENOSYS.
#
# Layout offsets — kept as constants for readability at the call sites.
STACK_T_OFF_SP:    uint64 = 0
STACK_T_OFF_FLAGS: uint64 = 8
STACK_T_OFF_SIZE:  uint64 = 16


def _u_sigaltstack(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # const stack_t *ss  -> a0   (may be NULL: query only)
    # stack_t       *oss -> a1   (may be NULL: install only)
    slot: uint64 = current_idx_get()
    # Capture the previous values FIRST so a single combined call
    # (ss + oss both non-NULL) reports the state in effect on entry.
    prev_sp:    uint64 = get_task_alt_stack_sp(slot)
    prev_size:  uint64 = get_task_alt_stack_size(slot)
    prev_flags: int32  = get_task_alt_stack_flags(slot)
    if a1 != 0:
        # #163: write the stack_t fields through the page tables.
        if put_user_64(prev_sp, a1 + STACK_T_OFF_SP) != 0:
            return ELINUX_EFAULT
        if put_user_32(cast[uint32](prev_flags),
                       a1 + STACK_T_OFF_FLAGS) != 0:
            return ELINUX_EFAULT
        if put_user_64(prev_size, a1 + STACK_T_OFF_SIZE) != 0:
            return ELINUX_EFAULT
    if a0 != 0:
        # #163: fetch the new stack_t through the page tables.
        new_sp:    uint64 = 0
        new_fl32:  uint32 = 0
        new_size:  uint64 = 0
        if get_user_64(a0 + STACK_T_OFF_SP, &new_sp) != 0:
            return ELINUX_EFAULT
        if get_user_32(a0 + STACK_T_OFF_FLAGS, &new_fl32) != 0:
            return ELINUX_EFAULT
        if get_user_64(a0 + STACK_T_OFF_SIZE, &new_size) != 0:
            return ELINUX_EFAULT
        set_task_alt_stack_sp(slot, new_sp)
        set_task_alt_stack_size(slot, new_size)
        set_task_alt_stack_flags(slot, cast[int32](new_fl32))
    return 0


# =====================================================================
# U21: gettimeofday
# =====================================================================
#
# Same jiffy-derived time source as _u_clock_gettime, just packaged
# into a `struct timeval = { time_t tv_sec; suseconds_t tv_usec; }`
# (microseconds, not nanoseconds). A1 is `struct timezone *tz` and
# is ignored — Linux itself deprecated it decades ago. Glibc passes
# NULL there for the gettimeofday() wrapper.


def _u_gettimeofday(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int gettimeofday(struct timeval *tv, struct timezone *tz)
    #
    # Wall-clock time, microsecond resolution. Same source as
    # clock_gettime(CLOCK_REALTIME): RTC boot epoch + the TSC
    # monotonic delta. Replaces the old 10 ms jiffies derivation.
    if a0 == 0:
        return ELINUX_INVAL
    mono_ns: uint64 = tsc_monotonic_ns()
    base:    uint64 = rtc_boot_epoch_get()
    sec:  uint64 = base + (mono_ns / 1000000000)
    usec: uint64 = (mono_ns % 1000000000) / 1000
    # #163: write struct timeval back through the translated path.
    if put_user_64(sec, a0) != 0 or put_user_64(usec, a0 + 8) != 0:
        set_current_errstr("gettimeofday: bad timeval pointer")
        return ELINUX_EFAULT
    return 0


# =====================================================================
# U25: SYS_time (201)
# =====================================================================
#
# Old-style time() syscall: glibc's time(NULL) on some configurations
# (and notably the U22 test fixture's `time(NULL)` path under the
# specific static-pie glibc we ship) goes through SYS_time(201) rather
# than clock_gettime. The signature is:
#
#   time_t time(time_t *tloc);
#
# Returns the current calendar time in seconds since the Unix epoch:
# the RTC boot epoch plus the TSC monotonic delta — the same wall
# clock as clock_gettime(CLOCK_REALTIME). If `tloc` is non-NULL, the
# value is also written to *tloc. A negative return is the errno on
# error, but there is no failure path here: the value is always >= 0
# and the int64 cast is safe.


def _u_time(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # time_t time(time_t *tloc)
    sec: uint64 = rtc_boot_epoch_get() + (tsc_monotonic_ns() / 1000000000)
    if a0 != 0:
        # #163: write *tloc through the translated path. A bad tloc
        # returns -EFAULT rather than faulting the kernel.
        if put_user_64(sec, a0) != 0:
            set_current_errstr("time: bad tloc pointer")
            return ELINUX_EFAULT
    return cast[int64](sec)


# =====================================================================
# U21: sysinfo
# =====================================================================
#
# Linux's `struct sysinfo` on x86_64 lays out as (offsets in bytes):
#   0:   long uptime;                  /* seconds since boot */
#   8:   ulong loads[3];               /* 1, 5, 15 min load averages */
#   32:  ulong totalram;
#   40:  ulong freeram;
#   48:  ulong sharedram;
#   56:  ulong bufferram;
#   64:  ulong totalswap;
#   72:  ulong freeswap;
#   80:  u16   procs;
#   82:  u16   pad;
#   /* alignment to 8 for the following ulongs -> 4 bytes padding */
#   88:  ulong totalhigh;
#   96:  ulong freehigh;
#   104: u32   mem_unit;
#   108: char  _f[8 - sizeof(ulong)] = 0 bytes on 64-bit (struct is 112)
#
# We zero the whole 112-byte region first and only fill the fields
# userspace actually checks (uptime + totalram + freeram + mem_unit).

SYSINFO_SIZE:         uint64 = 112
SYSINFO_OFF_UPTIME:   uint64 = 0
SYSINFO_OFF_LOADS:    uint64 = 8     # loads[3] (3× unsigned long)
SYSINFO_OFF_TOTALRAM: uint64 = 32
SYSINFO_OFF_FREERAM:  uint64 = 40
SYSINFO_OFF_PROCS:    uint64 = 80    # u16 current process count
SYSINFO_OFF_MEMUNIT:  uint64 = 104

# Page size the buddy allocator counts in (page_alloc_free_count returns
# a 4096-byte page count that we fold into freeram).
_SYSINFO_PAGE_BYTES: uint64 = 4096

# Linux's loads[] are fixed-point in units of (1 << 16). The scheduler
# exports load×100 (centi-load), so convert centi → 16.16 fixed point.
_SYSINFO_LOAD_SHIFT: uint64 = 65536

# Still referenced by _u_statfs's synthetic-root block-count estimate
# (the cpio root has no real superblock). Kept as the nominal RAM size
# for that fallback only — the live sysinfo path no longer uses it.
SYSINFO_TOTALRAM: uint64 = 0x10000000


def _sysinfo_centi_to_loads(centi: uint64) -> uint64:
    # load×100  ->  load×65536 (Linux 16.16 fixed point).
    return (centi * _SYSINFO_LOAD_SHIFT) / 100


def _sysinfo_live_procs() -> uint64:
    # Count task slots that hold a live (or stopped-but-alive) process:
    # everything except FREE (never claimed) and EXITED (reaped/zombie).
    n: uint64 = 0
    i: uint64 = 0
    total: uint64 = task_table_size()
    while i < total:
        st: uint64 = task_state(cast[int32](i))
        if st != STATE_FREE and st != STATE_EXITED:
            n = n + 1
        i = i + 1
    return n


def _u_sysinfo(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int sysinfo(struct sysinfo *info)
    if a0 == 0:
        return ELINUX_INVAL
    # #163 FOLLOW-UP: assemble struct sysinfo in a kernel scratch then copy
    # it out in one translated copy_to_user (was a raw deref of a0).
    ksi: uint64 = cast[uint64](&u_sysinfo_scratch[0])
    memset(cast[Ptr[uint8]](ksi), 0, SYSINFO_SIZE)
    j: uint64 = get_jiffies()
    sec: uint64 = j / 100
    cast[Ptr[uint64]](ksi + SYSINFO_OFF_UPTIME)[0]   = sec

    # loads[0..2] from the live 1/5/15-minute centi-load accumulators.
    cast[Ptr[uint64]](ksi + SYSINFO_OFF_LOADS)[0] = \
        _sysinfo_centi_to_loads(loadavg_get_load1_centi())
    cast[Ptr[uint64]](ksi + SYSINFO_OFF_LOADS + 8)[0] = \
        _sysinfo_centi_to_loads(loadavg_get_load5_centi())
    cast[Ptr[uint64]](ksi + SYSINFO_OFF_LOADS + 16)[0] = \
        _sysinfo_centi_to_loads(loadavg_get_load15_centi())

    # Real memory. The machine's RAM is the managed memblock region
    # [base, top); that is the honest "totalram". Free RAM is the part
    # of that region the bump allocator has not handed out yet
    # (memblock_avail), plus any 4 KiB pages the buddy allocator has
    # returned to its order-0 free list (page_alloc_free_count). This is
    # always <= totalram. (page_alloc_total only counts pages lazily
    # pulled INTO the buddy allocator, so it is not the machine's RAM.)
    total_ram: uint64 = memblock_region_top() - memblock_region_base()
    free_ram:  uint64 = memblock_avail() \
        + (page_alloc_free_count() * _SYSINFO_PAGE_BYTES)
    if free_ram > total_ram:
        free_ram = total_ram
    cast[Ptr[uint64]](ksi + SYSINFO_OFF_TOTALRAM)[0] = total_ram
    cast[Ptr[uint64]](ksi + SYSINFO_OFF_FREERAM)[0]  = free_ram

    # procs is a u16 — the live task count.
    cast[Ptr[uint16]](ksi + SYSINFO_OFF_PROCS)[0] = \
        cast[uint16](_sysinfo_live_procs())

    cast[Ptr[uint32]](ksi + SYSINFO_OFF_MEMUNIT)[0]  = 1
    if copy_to_user(a0, ksi, SYSINFO_SIZE) != 0:
        set_current_errstr("sysinfo: bad info pointer")
        return ELINUX_EFAULT
    return 0


# =====================================================================
# sysinfo(2) self-test (gated on /etc/sysinfo-test, ENABLE_SYSINFO_TEST=1)
# =====================================================================
#
# Proves _u_sysinfo now fills the Linux `struct sysinfo` from LIVE kernel
# accounting — real total/free RAM from the page allocator and a real
# live-process count — rather than the old hardcoded constants. The
# buffer is pre-poisoned with 0xAA so a field that fails to get written
# is unmistakable. Emits a single EMERG-level PASS/FAIL banner that
# always reaches serial. Returns 1 on PASS, 0 on FAIL.
_sysinfo_sel_buf: Array[256, uint8]


def _sysinfo_field_u64(off: uint64) -> uint64:
    return cast[Ptr[uint64]](cast[uint64](&_sysinfo_sel_buf[0]) + off)[0]


def _sysinfo_field_u16(off: uint64) -> uint64:
    return cast[uint64](
        cast[Ptr[uint16]](cast[uint64](&_sysinfo_sel_buf[0]) + off)[0])


def _sysinfo_field_u32(off: uint64) -> uint64:
    return cast[uint64](
        cast[Ptr[uint32]](cast[uint64](&_sysinfo_sel_buf[0]) + off)[0])


# =====================================================================
# #163 FOLLOW-UP — Linux-ABI copy_to_user CONVERSION proof.
#
# uaccess_smoke_test (mm/uaccess.ad) proves the copy_to_user PRIMITIVE
# translates a vaddr != phys mapping; uaccess_syscall_test (syscall.ad)
# proves the converted NATIVE SYS_GETCWD handler does too. This test
# proves the converted LINUX-ABI handler _u_sysinfo() copies its assembled
# struct out THROUGH the translation rather than raw-dereferencing the
# user pointer.
#
# It maps a fresh physical frame P at a HIGH user vaddr V (V != P, well
# above any identity-mapped RAM), pre-poisons P with 0xAA, then drives
# _u_sysinfo(V, ...). It asserts the struct landed at the PHYSICAL frame
# P — reading totalram + mem_unit DIRECTLY from P and matching them
# against the live kernel accounting. A handler still raw-deref'ing V
# would write to unmapped memory and leave P poisoned, so a poison-free,
# correct-field P is the proof the conversion translates.
#
# Always-on at boot (init/main.ad, right after uaccess_syscall_test);
# PASS/FAIL consumed by scripts/test_uaccess_linux_abi.sh.
# =====================================================================
UA_LXABI_TEST_VADDR: uint64 = 0x0000555570000000


def linux_abi_uaccess_translate_test():
    printk0("Hamnix: linux-ABI uaccess test (_u_sysinfo via vaddr != phys)\n")
    pml4: uint64 = uaccess_current_pml4()
    p: uint64 = alloc_page()
    if p == 0:
        printk0("  [uaccess-lxabi] SKIP: alloc_page failed\n")
        return
    # Pre-poison the physical frame: an untranslated (raw-deref) write to V
    # would leave this poison intact at P.
    memset(cast[Ptr[uint8]](p), 0xAA, 4096)
    if vm_map_user_page(pml4, UA_LXABI_TEST_VADDR, p, 1) < 0:
        printk0("  [uaccess-lxabi] FAIL: could not install test mapping\n")
        free_page(p)
        return
    printk2("  [uaccess-lxabi] mapped V=%p -> P=%p (writable)\n",
            UA_LXABI_TEST_VADDR, p)

    # Drive the CONVERTED Linux-ABI handler against the user vaddr V.
    rc: int64 = _u_sysinfo(UA_LXABI_TEST_VADDR, 0, 0, 0, 0, 0)

    # Read the result back DIRECTLY from the physical frame P (the
    # translated destination), NOT from V.
    pv: uint64 = p
    got_total: uint64 = cast[Ptr[uint64]](pv + SYSINFO_OFF_TOTALRAM)[0]
    got_unit:  uint32 = cast[Ptr[uint32]](pv + SYSINFO_OFF_MEMUNIT)[0]
    want_total: uint64 = memblock_region_top() - memblock_region_base()
    ok: int32 = 1
    if rc != 0:
        ok = 0
    if got_unit != 1:
        ok = 0
    if got_total == 0 or got_total != want_total:
        ok = 0
    if ok != 0:
        printk0("  [uaccess-lxabi] PASS: _u_sysinfo copied to the physical frame\n")
    else:
        printk2("  [uaccess-lxabi] FAIL: rc/totalram wrong (got_total=%p unit=%p)\n",
                got_total, cast[uint64](got_unit))

    free_page(p)


def sysinfo_selftest() -> int32:
    # Poison the whole 256-byte region so unwritten fields stay 0xAA.
    memset(&_sysinfo_sel_buf[0], 0xAA, 256)
    rc: int64 = _u_sysinfo(cast[uint64](&_sysinfo_sel_buf[0]),
                           0, 0, 0, 0, 0)
    if rc != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[SYSINFO] FAIL _u_sysinfo rc=%d\n", cast[uint64](rc))
        return 0

    mem_unit: uint64 = _sysinfo_field_u32(SYSINFO_OFF_MEMUNIT)
    totalram: uint64 = _sysinfo_field_u64(SYSINFO_OFF_TOTALRAM)
    freeram:  uint64 = _sysinfo_field_u64(SYSINFO_OFF_FREERAM)
    procs:    uint64 = _sysinfo_field_u16(SYSINFO_OFF_PROCS)

    want_total: uint64 = memblock_region_top() - memblock_region_base()

    if mem_unit != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[SYSINFO] FAIL mem_unit=%d (want 1)\n", mem_unit)
        return 0
    if totalram == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SYSINFO] FAIL totalram==0\n")
        return 0
    if totalram != want_total:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[SYSINFO] FAIL totalram=%d (want %d)\n",
                totalram, want_total)
        return 0
    if freeram == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SYSINFO] FAIL freeram==0\n")
        return 0
    if freeram > totalram:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[SYSINFO] FAIL freeram=%d > totalram=%d\n",
                freeram, totalram)
        return 0
    if procs < 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[SYSINFO] FAIL procs<1\n")
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[SYSINFO] PASS totalram=%dMiB procs=%d\n",
            totalram / (1024 * 1024), procs)
    return 1


# =====================================================================
# statfs(2) / fstatfs(2): filesystem capacity for df / statvfs
# =====================================================================
#
# Linux x86_64 `struct statfs` is 120 bytes. Field layout (all 8-byte
# words except f_fsid which is two u32s, and f_spare which is 4 u64s):
#
#   0x00  f_type      magic (EXT4=0xEF53, TMPFS=0x01021994,
#                            MSDOS/FAT=0x4d44, RAMFS/initramfs=0x858458f6)
#   0x08  f_bsize     block size (4096 here, or the ext4 block size)
#   0x10  f_blocks    total data blocks (fs size / f_bsize)
#   0x18  f_bfree     free blocks
#   0x20  f_bavail    free blocks available to unprivileged (== f_bfree)
#   0x28  f_files     total inodes
#   0x30  f_ffree     free inodes
#   0x38  f_fsid      two u32 words (0 here)
#   0x40  f_namelen   max filename length (255)
#   0x48  f_frsize    fragment size (== f_bsize)
#   0x50  f_flags     mount flags (0)
#   0x58  f_spare     4 u64 reserved (zero)  -> ends at 0x78 = 120
#
# We fill REAL numbers where the backend exposes them (ext4 reads its
# live superblock geometry; tmpfs reports its per-file capacity), and
# plausible non-zero constants otherwise so `df` never shows a 0-total
# (broken) line.

STATFS_SIZE:        uint64 = 120
STATFS_OFF_TYPE:    uint64 = 0
STATFS_OFF_BSIZE:   uint64 = 8
STATFS_OFF_BLOCKS:  uint64 = 16
STATFS_OFF_BFREE:   uint64 = 24
STATFS_OFF_BAVAIL:  uint64 = 32
STATFS_OFF_FILES:   uint64 = 40
STATFS_OFF_FFREE:   uint64 = 48
STATFS_OFF_NAMELEN: uint64 = 64
STATFS_OFF_FRSIZE:  uint64 = 72

# Filesystem magic numbers (linux/magic.h).
STATFS_MAGIC_EXT4:   uint64 = 0xEF53
STATFS_MAGIC_TMPFS:  uint64 = 0x01021994
STATFS_MAGIC_MSDOS:  uint64 = 0x4d44
STATFS_MAGIC_RAMFS:  uint64 = 0x858458f6

STATFS_NAMELEN: uint64 = 255

# Backend selector returned by _u_statfs_classify_*.
STATFS_BK_EXT4:  int32 = 0
STATFS_BK_TMPFS: int32 = 1
STATFS_BK_FAT:   int32 = 2
STATFS_BK_RAMFS: int32 = 3      # cpio initramfs / synthetic root

# ext4 superblock free-count field offsets (from the SB base at byte
# 1024). s_free_blocks_count_lo @ 0x0C, s_free_inodes_count @ 0x10.
_EXT4_SB_OFF_FREE_BLOCKS: uint64 = 0x0C
_EXT4_SB_OFF_FREE_INODES: uint64 = 0x10

# Scratch for the on-demand superblock re-read. The SB lives at byte
# offset 1024 (sectors 2..3); two 512-byte sectors land it at index 0.
_statfs_sb_buf: Array[1024, uint8]


def _statfs_rd_u32(p: Ptr[uint8], off: uint64) -> uint32:
    # Little-endian u32 read at byte offset `off`.
    base: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](p) + off)
    return (cast[uint32](base[0])
            | (cast[uint32](base[1]) << 8)
            | (cast[uint32](base[2]) << 16)
            | (cast[uint32](base[3]) << 24))


def _statfs_ext4_free(free_blocks: Ptr[uint64],
                      free_inodes: Ptr[uint64]) -> int32:
    # Re-read the live ext4 superblock's free-block / free-inode counters.
    # ext4.ad caches only the totals, so the running free counts have to
    # come straight off the device. Returns 0 on success, -1 if the read
    # fails (caller then falls back to a conservative estimate).
    if ext4_blockdev_slot < 0:
        return -1
    rc: int32 = blk_read_sectors(ext4_blockdev_slot, 2, 2,
                                 &_statfs_sb_buf[0])
    if rc != 0:
        return -1
    fb: uint32 = _statfs_rd_u32(&_statfs_sb_buf[0],
                                _EXT4_SB_OFF_FREE_BLOCKS)
    fi: uint32 = _statfs_rd_u32(&_statfs_sb_buf[0],
                                _EXT4_SB_OFF_FREE_INODES)
    free_blocks[0] = cast[uint64](fb)
    free_inodes[0] = cast[uint64](fi)
    return 0


def _u_fill_statfs(buf: uint64, backend: int32) -> int64:
    # Zero the whole 120-byte region, then fill the per-backend geometry.
    if buf == 0:
        return ELINUX_FAULT
    # SMAP: `buf` is the user struct statfs (US=1). Bracket the CPL=0 zero
    # + namelen store here; the geometry fields are bracketed at the tail.
    # The interleaved ext4 superblock read uses kernel buffers only.
    _ua_stac()
    memset(cast[Ptr[uint8]](buf), 0, STATFS_SIZE)
    cast[Ptr[uint64]](buf + STATFS_OFF_NAMELEN)[0] = STATFS_NAMELEN
    _ua_clac()

    magic:   uint64 = STATFS_MAGIC_RAMFS
    bsize:   uint64 = 4096
    blocks:  uint64 = 0
    bfree:   uint64 = 0
    files:   uint64 = 0
    ffree:   uint64 = 0

    if backend == STATFS_BK_EXT4 and ext4_is_mounted() != 0:
        # REAL ext4 capacity. Totals + block size are captured at mount;
        # the free counts are read back from the live superblock.
        magic  = STATFS_MAGIC_EXT4
        bsize  = ext4_block_size
        if bsize == 0:
            bsize = 4096
        blocks = ext4_blocks_count
        files  = ext4_inodes_count
        fb: uint64 = 0
        fi: uint64 = 0
        if _statfs_ext4_free(&fb, &fi) == 0:
            bfree = fb
            ffree = fi
        else:
            # Superblock re-read failed — report a conservative non-zero
            # free estimate (half the volume) rather than a 0/broken line.
            bfree = blocks / 2
            ffree = files / 2
    elif backend == STATFS_BK_TMPFS:
        # tmpfs tracks no running used-byte total, so report its per-file
        # capacity as the synthetic fs size with most of it free.
        magic  = STATFS_MAGIC_TMPFS
        blocks = TMPFS_FILE_CAP / bsize
        bfree  = blocks                       # RAM-backed; treat as free
        files  = 65536
        ffree  = 65000
    elif backend == STATFS_BK_FAT:
        # FAT capacity isn't surfaced through a getter; report a plausible
        # non-zero geometry so `df /mnt` shows a real line.
        magic  = STATFS_MAGIC_MSDOS
        blocks = 0x10000                      # 256 MiB at 4 KiB blocks
        bfree  = blocks / 2
        files  = 0                            # FAT has no inode table
        ffree  = 0
    else:
        # cpio initramfs / synthetic root — read-only, in-RAM.
        magic  = STATFS_MAGIC_RAMFS
        blocks = SYSINFO_TOTALRAM / bsize
        bfree  = 0                            # read-only: nothing free
        files  = 0
        ffree  = 0

    # SMAP: geometry stores into the user struct statfs (US=1).
    _ua_stac()
    cast[Ptr[uint64]](buf + STATFS_OFF_TYPE)[0]   = magic
    cast[Ptr[uint64]](buf + STATFS_OFF_BSIZE)[0]  = bsize
    cast[Ptr[uint64]](buf + STATFS_OFF_BLOCKS)[0] = blocks
    cast[Ptr[uint64]](buf + STATFS_OFF_BFREE)[0]  = bfree
    cast[Ptr[uint64]](buf + STATFS_OFF_BAVAIL)[0] = bfree
    cast[Ptr[uint64]](buf + STATFS_OFF_FILES)[0]  = files
    cast[Ptr[uint64]](buf + STATFS_OFF_FFREE)[0]  = ffree
    cast[Ptr[uint64]](buf + STATFS_OFF_FRSIZE)[0] = bsize
    _ua_clac()
    return 0


def _statfs_classify_path(name: Ptr[char]) -> int32:
    # F10-9: ask the VFS mount table which backend owns `name`. The
    # chan/mount table already knows (vfs_fs_kind = longest-prefix
    # match over the same mountpoints the is_*_path helpers were
    # hard-coding). No strcmp ladder, no per-backend imports.
    kind: uint32 = vfs_fs_kind(name)
    if kind == FS_KIND_EXT4:
        return STATFS_BK_EXT4
    if kind == FS_KIND_FAT:
        return STATFS_BK_FAT
    if kind == FS_KIND_TMPFS:
        return STATFS_BK_TMPFS
    # FS_KIND_CPIO (synthetic root) or any unmounted slot: RAMFS.
    return STATFS_BK_RAMFS


def _path_eq_const4(name: Ptr[char], c0: uint8, c1: uint8,
                    c2: uint8, c3: uint8) -> int32:
    # True if `name` is exactly the 4-char string c0c1c2c3 (NUL after).
    if cast[uint8](name[0] & 0xFF) != c0:
        return 0
    if cast[uint8](name[1] & 0xFF) != c1:
        return 0
    if cast[uint8](name[2] & 0xFF) != c2:
        return 0
    if cast[uint8](name[3] & 0xFF) != c3:
        return 0
    if cast[uint8](name[4] & 0xFF) != 0:
        return 0
    return 1


def _statfs_path_is_root(name: Ptr[char]) -> int32:
    # True if `name` is exactly "/" — the synthetic cpio-initramfs root,
    # always a valid statfs target.
    if cast[uint8](name[0] & 0xFF) != 47:                  # '/'
        return 0
    if cast[uint8](name[1] & 0xFF) != 0:
        return 0
    return 1


def _statfs_classify_fd(fd: int32) -> int32:
    # Recover the backing filesystem for an open fd. fd→Chan fold: ext4
    # and FAT file fds are now FD_CHAN_MARK fds whose backing kind lives
    # in the namec pool chan's dev_type, not in fd_idx — so the marker
    # alone no longer distinguishes them. vfs_fd_statfs_kind() does the
    # dev_type dispatch on our behalf and returns the same backing codes
    # (0=ext4, 1=tmpfs, 2=FAT, 3=ramfs) as the STATFS_BK_* constants.
    k: int32 = vfs_fd_statfs_kind(fd)
    if k == 0:
        return STATFS_BK_EXT4
    if k == 1:
        return STATFS_BK_TMPFS
    if k == 2:
        return STATFS_BK_FAT
    return STATFS_BK_RAMFS


def _u_statfs(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int statfs(const char *path, struct statfs *buf)
    if a1 == 0:
        return ELINUX_FAULT
    if a0 == 0:
        return ELINUX_FAULT
    # #163: copy-in the user path so a bad pointer is -EFAULT, not a #PF.
    statfs_path: Array[256, uint8]
    statfs_pin: int64 = _u_copyin_path(a0, &statfs_path[0])
    if statfs_pin != 0:
        return statfs_pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&statfs_path[0]), &abs_path[0], 256)
    if rc != 0:
        return ELINUX_NOENT
    # The path prefix unambiguously identifies the backing filesystem
    # (resolved through vfs_fs_kind's longest-prefix mount table), so
    # classify by path first. A bare mount-point directory ("/ext",
    # "/mnt", "/tmp") opens as a directory whose fd marker is NOT the
    # backend mark, so the path classification is the authoritative
    # one here.
    backend: int32 = _statfs_classify_path(cast[Ptr[char]](&abs_path[0]))
    # Confirm the path actually resolves to something before reporting
    # capacity (statfs(2) returns -ENOENT for a missing path). A backend
    # that is a real mount point (ext4 / fat / tmpfs) is taken as present;
    # the synthetic-root fallback verifies via vfs_open.
    # F10-1 double-resolution fix: probe with the RAW path so vfs_open's
    # single internal resolve_path walks the namespace once (abs_path stays
    # the authority for backend classification above; re-resolving it in
    # vfs_open doubled a `/`-rebound root prefix).
    fd: int32 = vfs_open(cast[Ptr[char]](&statfs_path[0]))
    if fd >= 0:
        # If the path classifier could not pin a backend (synthetic root),
        # fall back to the fd marker — an opened file under a real backend
        # carries its FD_*_MARK even when the path prefix did not match.
        if backend == STATFS_BK_RAMFS:
            backend = _statfs_classify_fd(fd)
        vfs_close(fd)
        return _u_fill_statfs(a1, backend)
    # Open did not hand back an fd. Real mount-point directories ("/ext",
    # "/mnt", "/tmp", "/var") and the synthetic root "/" are still valid
    # statfs targets; anything else that neither opens nor classifies to a
    # mount point is ENOENT.
    if backend != STATFS_BK_RAMFS:
        return _u_fill_statfs(a1, backend)
    if _statfs_path_is_root(cast[Ptr[char]](&abs_path[0])) != 0:
        return _u_fill_statfs(a1, backend)
    return ELINUX_NOENT


def _u_fstatfs(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fstatfs(int fd, struct statfs *buf)
    if a1 == 0:
        return ELINUX_FAULT
    fd: int32 = cast[int32](a0)
    if vfs_fd_is_open(fd) == 0:
        return ELINUX_BADF
    backend: int32 = _statfs_classify_fd(fd)
    return _u_fill_statfs(a1, backend)


# =====================================================================
# U21: futex
# =====================================================================
#
# glibc + pthread sprinkle futex calls everywhere — even the first
# pthread_mutex_lock() on the heap arena tries FUTEX_WAIT after the
# atomic-cmpxchg-acquire path fails. Hamnix has exactly one Linux
# task in flight at this milestone (no real thread groups), so the
# correct *kernel* behaviour for FUTEX_WAIT is "you cannot be woken,
# because nothing else can write to the address" — which translates
# to returning -EAGAIN immediately (the same value Linux returns when
# *uaddr no longer matches val by the time the kernel checks). glibc
# treats EAGAIN as a spurious wakeup signal and re-tries the cmpxchg,
# which then succeeds because we are single-threaded.
#
# When real multi-threading lands (clone(CLONE_THREAD) + a wait-queue
# attached to the futex word), this body has to actually park the
# caller until a FUTEX_WAKE on the same address.

FUTEX_WAIT:            uint64 = 0
FUTEX_WAKE:            uint64 = 1
FUTEX_REQUEUE:         uint64 = 3
FUTEX_CMP_REQUEUE:     uint64 = 4
FUTEX_WAIT_BITSET:     uint64 = 9
FUTEX_WAKE_BITSET:     uint64 = 10
FUTEX_PRIVATE_FLAG:    uint64 = 128
FUTEX_CLOCK_REALTIME:  uint64 = 256
# Mask used to peel off PRIVATE / CLOCK_REALTIME bits before
# comparing against the operation enum. Spelled out so the constant
# is obvious at a glance.
FUTEX_OP_MASK:         uint64 = 127
ELINUX_AGAIN:          int64  = -11


# U27: minimal futex wait queue. A small table of (uaddr, waiter slot,
# in-use) records. FUTEX_WAIT parks the caller in a free slot and
# yields; FUTEX_WAKE / futex_wake_all walks the table and clears any
# matching entries (the woken task's next yield iteration will see its
# slot vacated and return). Capacity is 16, enough for a few threads +
# pthread_join joiners; overflow returns -EAGAIN, which glibc/musl
# treat as spurious wakeup and retry.
#
# Why this lives in u_syscalls.ad and not core.ad: the table is owned
# by the Linux ABI surface (futex semantics are a userspace contract)
# and must stay confined to Layer 2 — the scheduler (Layer 0/1) must
# not statically depend on a Layer-2 symbol. The task-exit CLEARTID
# path needs a futex wake, but instead of core.ad naming
# `futex_wake_all`, Layer 2 registers it as a callback via
# register_cleartid_wake_hook (see u_syscalls_init below). The
# scheduler invokes that function pointer; it never links this table.
# Capacity: this is a GLOBAL table shared by every Linux-ABI task, and a
# single heavily-threaded process (Firefox: dozens of pthreads on condvars +
# mutexes) can hold FAR more than a handful of concurrent FUTEX_WAIT parkers
# at once. When the table overflows, FUTEX_WAIT returns spurious -EAGAIN and
# glibc/musl spin-retry the cmpxchg in userspace instead of parking — a CPU-
# burning busy loop and a lost-park hazard for exactly the threaded-GUI
# workload (#73). Size it to NTASKS (512) so, since a single-uaddr waiter
# occupies one slot and at most NTASKS tasks exist, a plain FUTEX_WAIT can
# never fail for lack of a slot. (futex_waitv can claim several slots per
# task, so it may still overflow under extreme vector-wait fan-out, but the
# single-wait common path is now exhaustion-proof.) Cost is ~10 KiB of BSS.
FUTEX_NSLOTS: uint64 = 512
# NB: futex_addr stores a computed KEY (see _futex_key), NOT the raw user
# VA. A PRIVATE futex keys on (address space, VA); a SHARED (process-shared,
# no FUTEX_PRIVATE_FLAG) futex keys on the PHYSICAL address of the word. That
# makes the table correct ACROSS processes: two processes' private futexes at
# the same VA no longer collide, and a cross-process FUTEX_WAKE on a shared
# memfd/MAP_SHARED page (mapped at different VAs) reaches the parked waiter.
futex_addr:   Array[512, uint64]  # 0 means "free slot" (holds a _futex_key)
futex_slot:   Array[512, int32]   # task slot index of the waiter
# Parallel "vector-index tag" array used ONLY by the futex_waitv path
# (linux_abi/u_futexv.ad). When a task parks on a VECTOR of futexes it
# claims one table slot per waiter element and records that element's
# array index here. When FUTEX_WAKE/futex_wake_all clears a slot, the
# waitv park loop sees the cleared slot and reads its tag to learn WHICH
# vector element woke it. For a normal single-uaddr FUTEX_WAIT this tag
# is meaningless and left 0; it is never consulted on that path.
futex_tag:    Array[512, int32]
# DIAG(ff-futex): per-slot flag — was this parked wait TIMED (a3 timeout ptr
# non-null)? Hamnix's FUTEX_WAIT currently ignores the timeout, so a timed
# pthread_cond_timedwait / NSPR PR_WaitCondVar-with-deadline never returns
# -ETIMEDOUT. futex_table_dump prints this so the parked-wd stall log shows
# whether the permanently-parked Firefox thread was in a TIMED wait (=> the
# missing-timeout ABI gap) or an untimed one (=> a genuine missing wake).
futex_timed:  Array[512, int32]
# Per-slot BOUNDED-PARK deadline, in jiffies (0 = "no deadline": a poll-yield
# or futex_waitv registration, which self-heals by re-reading *uaddr).
#
# WHY THIS EXISTS (the Firefox hang root cause, half 2 of 2). The bounded park
# calls wq_wait_commit_timeout(&futex_wq, FUTEX_PARK_TICKS), whose deadline is
# only ever evaluated by the PARKED TASK ITSELF, in its own loop. But that loop
# only spins while `_another_task_ready() == 0` (the sti;hlt idle arm). The
# instant ANY other task is runnable, the parked task calls schedule() and is
# switched out in STATE_WAIT — and `_pick_next` never selects a STATE_WAIT task,
# and no timer wheel exists to re-ready it. So on a BUSY box the "bounded" park
# is in fact INFINITE and the advertised lost-wake self-heal NEVER RUNS.
#
# A small thread group (weston-terminal, foot: 2-4 threads) quiesces the box, so
# the hlt arm runs and the timeout does fire — which is exactly why they never
# hit this and Firefox (12-42 threads, something always runnable) always does.
#
# Fix, scoped to Layer 2 (no scheduler surgery): record each bounded parker's
# deadline here and have _futex_sweep_expired() — run at every SYS_futex entry,
# i.e. thousands of times a second in any threaded client — directed-wake any
# parker whose interval elapsed. The woken task re-reads *uaddr and either
# returns (lost-wake self-heal, as designed) or re-parks for another interval.
futex_deadline: Array[512, uint64]
# Count of live registrations carrying a non-zero futex_deadline. Lets the
# per-tick sweep bail out with a single load when nothing is bounded-parked.
_futex_nparked: uint64 = 0
# DIAG(ff-futex, probe b): bounded dedup ring of the last N distinct uaddrs
# that a FUTEX_WAKE issued while matching ZERO table waiters. A zero-match
# private wake on the stuck uaddr == the waker RAN but its key MIS-MATCHED the
# waiter's key (a keying bug); absence of the stuck uaddr here across the whole
# run == the wake was NEVER issued (the waker is itself blocked). Rate/dedup-
# bounded so Firefox's thousands of uncontended-unlock wakes don't flood serial.
FUTEX_WKDIAG_N: uint64 = 64
_futex_wkdiag_ring: Array[64, uint64]
_futex_wkdiag_head: uint64 = 0
_futex_wkdiag_count: uint64 = 0

# DIAG(ff-futex, WAIT side). Mirror of [ff-wake0] on the WAIT half. When the
# MAIN thread (thread-group leader) commits to a bounded FUTEX_WAIT park, log
# the caller's USER RIP (the libxul/glibc/NSPR call site that invoked futex(2))
# plus the uaddr/key and whether the wait is timed. Cross-reference the logged
# uaddr against [ff-wake0]: if the main thread's parked uaddr NEVER appears in
# an [ff-wake0] line, no wake is ever issued on that word -> a Gecko-internal
# circular wait / missing readiness (subtract the staged libxul base from
# caller_rip to symbolicate which subsystem's cond the main thread deadlocks
# on). Dedup'd against a ring (one line per uaddr) AND hard-capped like the
# vdso/futex printk caps so it cannot flood the 8250 UART.
FF_WTDIAG_N: uint64 = 64
_ff_wtdiag_ring: Array[64, uint64]
_ff_wtdiag_head: uint64 = 0
_ff_wtdiag_count: uint64 = 0
FF_WTDIAG_CAP: uint64 = 96

# U27 BOUNDED-park rework. One GLOBAL wait queue backs every parked
# FUTEX_WAIT sleeper. A waiter is identified for wakeup by its
# (uaddr -> task slot) entry in the futex_addr table above, NOT by
# wait-queue position, so a single shared queue is enough: FUTEX_WAKE
# clears the matching table slot(s) and directed-wakes each cleared task
# by slot (wq_wake_slot). The queue membership is used only for the
# halt-hazard / signal-interrupt / SMP-fencing plumbing inside
# wq_wait_prepare/commit_timeout and for the woken task's self-unlink on
# return. Initialised in u_syscalls_init.
#
# _futex_lock serialises the WAIT side's "register slot + prepare-to-wait +
# recheck *uaddr" against the WAKE side's "clear slot + wake". Because both
# critical sections take _futex_lock, a wake cannot slip between a waiter's
# *uaddr recheck and its going-to-sleep: either the wake ran first (waiter's
# locked recheck sees *uaddr moved and bails without sleeping) or it runs
# after (finds the waiter registered + STATE_WAIT and wakes it). No lost
# wakeup on the FAST path. _futex_lock is ALWAYS released before
# wq_wait_commit_timeout sleeps — a sleeper must never hold it or the waker
# would deadlock taking it.
futex_wq:    WaitQueue
_futex_lock: uint32 = 0

# BOUNDED-park recheck interval, in 100 Hz LAPIC jiffies. The park sleeps
# OFF the runqueue (zero poll-yield burn) but wq_wait_commit_timeout wakes
# it every FUTEX_PARK_TICKS jiffies to RE-EVALUATE the futex word. This is
# the SELF-HEAL for a lost directed wq_wake_slot wake (the b50cc682 hang
# root cause): even if a wake is somehow missed, the periodic timeout
# re-reads *uaddr / re-checks the table slot and returns if the value
# moved — so a missed wake costs at most FUTEX_PARK_TICKS jiffies of extra
# sleep, NEVER an infinite park. 3 jiffies (~30 ms at HZ=100) is short
# enough to keep a lost-wake stall imperceptible (a GUI frame budget) yet
# long enough that a correctly-woken waiter almost always returns via the
# immediate directed wake first (zero added latency on the common path)
# and an idle thread group HLT-idles between rechecks instead of spinning.
FUTEX_PARK_TICKS: uint64 = 3

# Thread-group SIZE threshold that selects the FUTEX_WAIT wait STRATEGY.
# When the current task has FEWER than this many live same-mm peers, we use
# the PROVEN poll-yield path (microsecond *uaddr re-read that matches
# userspace's elided-FUTEX_WAKE cadence — the render-critical clients like
# weston-terminal (~2-4 threads) need this and the O(n^2) yield cost is
# negligible at small n). At or ABOVE it we use the bounded BLOCKING park so
# a heavily-threaded client (Firefox: 42 pthreads) doesn't collapse into an
# O(n^2) poll-yield storm burning CPU. 6 peers (~7-thread group) sits well
# above weston-terminal's footprint yet far below Firefox's, and matches the
# 8-worker thread stress test (test_u28_musl_thread_many) onto the blocking
# path so that path's correctness is exercised.
FUTEX_BLOCK_THRESH: int32 = 6


# _futex_key — map a futex word (user VA + private/shared discriminator) to
# the wait-table match key. THE cross-process-correctness keystone.
#
# PRIVATE futex (op carries FUTEX_PRIVATE_FLAG — every glibc/musl pthread
# mutex/cond/join by default): key on (current address space, VA). Within one
# process cr3 is constant, so the key is a BIJECTION with the VA — identical
# matching to the old raw-VA key, so the proven single-process render path
# (weston-terminal) and the pthread_join/thread_many tests are byte-for-byte
# unchanged. ACROSS processes the cr3 differs, so process A's private-futex
# wake can no longer steal (or be stolen by) process B's waiter at the same
# VA — the multiprocess correctness fix. Bit 63 tags PRIVATE so a private key
# can never equal a SHARED key.
#
# SHARED futex (no FUTEX_PRIVATE_FLAG — glibc PTHREAD_PROCESS_SHARED mutex/
# sem, e.g. Gecko's CrossProcessMutex/Semaphore over a memfd): key on the
# PHYSICAL address of the word. Two processes mapping the same physical page
# at DIFFERENT VAs resolve to the SAME key, so a FUTEX_WAKE in one reaches the
# FUTEX_WAIT parked in the other — the shared-memory cross-process handshake
# that Firefox's content/GPU child<->parent bring-up deadlocks on without it.
# If the page can't be resolved (not yet faulted in) fall back to a distinctly
# tagged VA key (bit 62): a possibly-missed cross-map match is preferable to a
# wrong-page one, and the WAIT path has already fetched the word so the common
# case resolves.
def _futex_key(uaddr: uint64, private: int32) -> uint64:
    if private != 0:
        pml4: uint64 = uaccess_current_pml4()
        return 0x8000000000000000 \
             | ((uaddr & 0x7FFFFFFFFFFF) ^ (((pml4 >> 12) & 0x1FFFF) << 30))
    ph: uint64 = uaccess_resolve(uaccess_current_pml4(), uaddr, 0)
    if ph == 0:
        return 0x4000000000000000 | (uaddr & 0x3FFFFFFFFFFF)
    return ph & 0x3FFFFFFFFFFFFFFF


def futexv_claim_slot(uaddr: uint64, vec_idx: int32, private: int32) -> int32:
    # Surgical park-on-multiple primitive for futex_waitv. Register the
    # CURRENT task as a waiter against `uaddr`, tagging the slot with the
    # caller-supplied vector index. Returns the claimed table-slot index,
    # or -1 if the futex table is full. Reuses the exact same wait table
    # that FUTEX_WAKE / futex_wake_all walk, so a wake on any registered
    # uaddr clears the matching slot just like a single-uaddr waiter. The
    # slot is keyed via _futex_key (private -> (mm,VA); shared -> phys) so a
    # cross-process FUTEX_WAKE matches exactly as a single-uaddr waiter does.
    #
    # LOCKING (the Firefox hang root cause, half 1 of 2): the scan-for-free +
    # claim MUST be atomic against every other slot claimer, so it runs under
    # _futex_lock — the same lock FUTEX_WAKE / futex_wake_all take. Claiming a
    # slot unlocked lets two claimers pick the SAME "free" index and one silently
    # overwrite the other's registration; the overwritten waiter is then parked
    # in futex(2) yet ABSENT from the wait table, so its FUTEX_WAKE matches zero
    # waiters and evaporates.
    key: uint64 = _futex_key(uaddr, private)
    my_slot: int32 = cast[int32](current_idx_get())
    spinlock_lock(&_futex_lock)
    i: uint64 = 0
    while i < FUTEX_NSLOTS:
        if futex_addr[i] == 0:
            futex_addr[i] = key
            futex_slot[i] = my_slot
            futex_tag[i] = vec_idx
            futex_timed[i] = 0
            futex_deadline[i] = 0
            spinlock_unlock(&_futex_lock)
            return cast[int32](i)
        i = i + 1
    spinlock_unlock(&_futex_lock)
    return -1


def futexv_slot_woken(slot: int32) -> int32:
    # Returns 1 if the given table slot has been cleared (woken) by a
    # FUTEX_WAKE / futex_wake_all, 0 if it is still parked.
    if slot < 0:
        return 0
    su: uint64 = cast[uint64](slot)
    if futex_addr[su] == 0:
        return 1
    # Defensive: the slot was cleared by a wake and has since been re-claimed by
    # another task. Our registration is gone either way, so we were woken.
    if futex_slot[su] != cast[int32](current_idx_get()):
        return 1
    return 0


def futexv_slot_tag(slot: int32) -> int32:
    # Read the vector-index tag recorded on a table slot.
    if slot < 0:
        return -1
    return futex_tag[cast[uint64](slot)]


def _futex_free_slot_locked(su: uint64):
    # Vacate one table slot. Caller holds _futex_lock.
    if futex_deadline[su] != 0:
        if _futex_nparked != 0:
            _futex_nparked = _futex_nparked - 1
    futex_addr[su] = 0
    futex_slot[su] = -1
    futex_tag[su] = 0
    futex_timed[su] = 0
    futex_deadline[su] = 0


def _futex_release_owned(su: uint64, my_slot: int32) -> int32:
    # Release table slot `su` ONLY if this task still owns it. Returns 1 if we
    # released our own live registration, 0 if the slot was already vacated (a
    # real FUTEX_WAKE cleared it) or has since been re-claimed by another task.
    #
    # The ownership test is what makes the release race-free: a bare
    # `futex_addr[su] = 0` would clobber whoever legitimately owns the slot now.
    spinlock_lock(&_futex_lock)
    owned: int32 = 0
    if futex_addr[su] != 0 and futex_slot[su] == my_slot:
        owned = 1
        _futex_free_slot_locked(su)
    spinlock_unlock(&_futex_lock)
    return owned


def _futex_claim_slot_locked(key: uint64, my_slot: int32,
                             timed: int32, deadline: uint64) -> int32:
    # Scan for a free table slot and claim it for the current task. Caller
    # holds _futex_lock. Returns the slot index, or -1 when the table is full.
    i: uint64 = 0
    while i < FUTEX_NSLOTS:
        if futex_addr[i] == 0:
            futex_addr[i] = key
            futex_slot[i] = my_slot
            futex_tag[i] = 0
            futex_timed[i] = timed
            futex_deadline[i] = deadline
            if deadline != 0:
                _futex_nparked = _futex_nparked + 1
            return cast[int32](i)
        i = i + 1
    return -1


def _futex_sweep_expired():
    # Bounded-park watchdog — THE CLOCK the blocking FUTEX_WAIT arm needs.
    #
    # Directed-wake every parker whose FUTEX_PARK_TICKS recheck interval has
    # elapsed. See futex_deadline's comment: a STATE_WAIT task on a busy box can
    # NEVER run its own deadline check (schedule() switched it out and
    # _pick_next won't pick a STATE_WAIT task), so an independent agent must do
    # it. Registered as the arch timer's linux_futex_tick_hook, so it runs at
    # HZ regardless of what userspace is doing; also called on SYS_futex entry
    # so the common case is serviced without waiting for a tick.
    #
    # IRQ-CONTEXT SAFETY: _futex_lock is a plain (non-IRQ-saving) spinlock, so a
    # timer IRQ can land on a CPU that already holds it. TRYLOCK and skip the
    # tick on contention — the next tick (10 ms) retries, and the FUTEX_WAKE /
    # WAIT critical sections are a few hundred cycles long.
    #
    # We deliberately do NOT clear futex_addr[]: the woken task must observe
    # "slot still mine" and treat this as a TIMEOUT/recheck, not as a real
    # FUTEX_WAKE. It re-reads *uaddr and either returns (the lost- or elided-
    # wake self-heal) or re-registers with a fresh deadline.
    if _futex_nparked == 0:
        return
    if spinlock_trylock(&_futex_lock) == 0:
        return
    now: uint64 = get_jiffies()
    i: uint64 = 0
    while i < FUTEX_NSLOTS:
        if futex_addr[i] != 0 and futex_deadline[i] != 0:
            if now >= futex_deadline[i]:
                ws: int32 = futex_slot[i]
                futex_deadline[i] = 0
                if _futex_nparked != 0:
                    _futex_nparked = _futex_nparked - 1
                if ws >= 0:
                    wq_wake_slot(cast[uint64](ws))
        i = i + 1
    spinlock_unlock(&_futex_lock)


def futexv_release_slot(slot: int32):
    # Vacate a table slot the waitv path claimed (used to unwind all the
    # OTHER registered slots once one of them woke, and to clean up on an
    # early-return enqueue mismatch). Idempotent on an already-free slot.
    # Under _futex_lock, and ownership-checked, so we can never clobber a
    # registration that a concurrent claimer has since installed in this slot.
    if slot < 0:
        return
    _futex_release_owned(cast[uint64](slot), cast[int32](current_idx_get()))


def futex_wake_all(uaddr: uint64) -> int32:
    # Wake every waiter parked on `uaddr`. Returns the count of slots
    # we cleared. Invoked from task_exit_current's CLEARTID handshake
    # (indirectly, through the cleartid_wake_hook function pointer this
    # module registers in u_syscalls_init) and directly from FUTEX_WAKE.
    # U27 BOUNDED-park rework: a parked FUTEX_WAIT waiter now SLEEPS on
    # futex_wq (STATE_WAIT, off the runqueue) rather than poll-yielding, so
    # clearing its table slot is no longer enough — we must DIRECTED-wake the
    # exact waiter task by slot (wq_wake_slot) so the scheduler re-dispatches
    # it. (A futex_waitv poller that is still in a yield loop is simply not
    # STATE_WAIT, so wq_wake_slot is a harmless no-op for it and it observes
    # the cleared slot on its next poll iteration — both models coexist.)
    # Runs under _futex_lock so the clear+wake is atomic vs a concurrent
    # WAIT-side register+prepare, closing the lost-wakeup window; the bounded
    # timeout recheck is only a SELF-HEAL backstop, not the primary path.
    # The CLEARTID / pthread_join futex is PRIVATE (glibc waits on the tid
    # word with FUTEX_WAIT_PRIVATE) and the exiting thread shares the joiner's
    # address space, so key it PRIVATE against the current (exiting) task's mm
    # — the same key the joiner's FUTEX_WAIT registered.
    key: uint64 = _futex_key(uaddr, 1)
    spinlock_lock(&_futex_lock)
    i: uint64 = 0
    woke: int32 = 0
    while i < FUTEX_NSLOTS:
        if futex_addr[i] == key:
            wslot: int32 = futex_slot[i]
            _futex_free_slot_locked(i)
            if wslot >= 0:
                wq_wake_slot(cast[uint64](wslot))
            woke = woke + 1
        i = i + 1
    spinlock_unlock(&_futex_lock)
    return woke


def futex_table_dump():
    # #73 multi-thread stall diagnostic. Dump every OCCUPIED slot of the
    # futex wait table so the no-syscall watchdog log shows, for each parked
    # thread, the futex uaddr it is FUTEX_WAIT-blocked on and its task slot.
    # Cross-referenced with dump_linux_task_states (which names the syscall
    # each task is parked in), this answers "the main thread is FUTEX_WAITing
    # on addr X; which thread should FUTEX_WAKE X, and is it stuck?". Registered
    # as call_linux_futex_dump's callback in u_syscalls_init.
    i: uint64 = 0
    any: int32 = 0
    while i < FUTEX_NSLOTS:
        if futex_addr[i] != 0:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk3("[nosys-wd]   futex slot=%d key=%p waiter_task=%d\n",
                    i, futex_addr[i], cast[uint64](futex_slot[i]))
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[nosys-wd]   futex slot=%d timed=%d (1=timeout supplied)\n",
                    i, cast[uint64](futex_timed[i]))
            any = 1
        i = i + 1
    if any == 0:
        printk0("[nosys-wd]   futex table: no parked waiters\n")


def _futex_wkdiag_zero_match(uaddr: uint64, key: uint64, priv: int32):
    # DIAG(ff-futex, probe b). A FUTEX_WAKE issued that matched ZERO table
    # waiters. Log the uaddr/key (dedup'd against a small ring so a hot
    # uncontended lock logs once, not thousands of times). Grep the serial for
    # the stuck waiter's uaddr: if it appears here the wake was ISSUED but
    # MIS-KEYED (keying bug); if it never appears the wake was NEVER ISSUED
    # (the waker is itself blocked -> the deadlock is a circular wait / missing
    # readiness, not a futex keying bug).
    j: uint64 = 0
    while j < FUTEX_WKDIAG_N:
        if _futex_wkdiag_ring[j] == uaddr:
            return                                   # already logged this uaddr
        j = j + 1
    _futex_wkdiag_ring[_futex_wkdiag_head] = uaddr
    _futex_wkdiag_head = (_futex_wkdiag_head + 1) % FUTEX_WKDIAG_N
    _futex_wkdiag_count = _futex_wkdiag_count + 1
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk3("[ff-wake0] FUTEX_WAKE matched 0 waiters uaddr=%p key=%p priv=%d\n",
            uaddr, key, cast[uint64](priv))


def _futex_wtdiag_main_park(uaddr: uint64, key: uint64, timed: int32):
    # DIAG(ff-futex, WAIT side). Called from the bounded-park arm when the
    # CURRENT task is the thread-group leader (main thread). Logs the caller's
    # user RIP + uaddr/key/timed, dedup'd by uaddr and hard-capped. See the
    # FF_WTDIAG_* comment above for how to read it against [ff-wake0].
    if current_task_pid() != current_task_tgid():
        return                                       # not the main thread
    if _ff_wtdiag_count >= FF_WTDIAG_CAP:
        return                                       # 8250 flood guard
    j: uint64 = 0
    while j < FF_WTDIAG_N:
        if _ff_wtdiag_ring[j] == uaddr:
            return                                   # already logged this uaddr
        j = j + 1
    _ff_wtdiag_ring[_ff_wtdiag_head] = uaddr
    _ff_wtdiag_head = (_ff_wtdiag_head + 1) % FF_WTDIAG_N
    _ff_wtdiag_count = _ff_wtdiag_count + 1
    rip: uint64 = saved_user_rip_ptr()[0]
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk3("[ff-wait] MAIN parks FUTEX_WAIT uaddr=%p key=%p timed=%d\n",
            uaddr, key, cast[uint64](timed))
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk3("[ff-wait]   caller_rip=%p tgid=%d tid=%d\n",
            rip, current_task_tgid(), current_task_pid())
    # Resolve caller_rip to its containing VMA (base + file_offset + DSO path)
    # so an OFFLINE readelf/nm on the DSO turns (caller_rip - base + foff) into
    # a symbol — the piece that lifts the "stripped-libxul unsymbolizable" wall.
    # Reuses the #76 parked-wd resolver; prints a [parked-wd] ripvma_* line.
    cslot: uint64 = current_idx_get()
    vma_dump_rip_info(cslot, cslot, rip)
    # caller_rip is glibc's generic syscall() wrapper (a RAW futex(FUTEX_WAIT),
    # i.e. a Rust-std / Gecko-internal condvar, NOT pthread_cond_wait) — so the
    # rip alone names glibc, not the subsystem. Walk the main thread's USER
    # STACK to print the return frames that land in libxul/Rust code (base+foff);
    # an offline readelf/nm on the staged libxul turns those into the exact
    # Gecko/Rust function that owns this stuck condvar (the sibling that never
    # signals it). Reuses the #76 non-faulting stack scanner.
    vma_dump_user_stack(cslot, task_pml4(cast[int32](cslot)),
                        saved_user_rsp_ptr()[0])


def u_syscalls_init():
    # Layer-2 bring-up hook, called once from init/main.ad alongside
    # usock_init / u_epoll_init. It registers futex_wake_all as the
    # scheduler's exit-time CLEARTID wake callback — that is how a
    # clone()d pthread's exit unblocks pthread_join's FUTEX_WAIT loop
    # WITHOUT the scheduler statically depending on this Layer-2 file.
    register_cleartid_wake_hook(futex_wake_all)
    # Publish the bounded-futex-park sweep to the arch timer. Without this the
    # large-thread-group FUTEX_WAIT park has no clock: a STATE_WAIT task cannot
    # service its own recheck deadline once schedule() has switched it out, so
    # an elided/lost FUTEX_WAKE would park a Firefox thread forever.
    register_linux_futex_tick_hook(_futex_sweep_expired)
    printk0("[u_syscalls] CLEARTID futex-wake hook registered\n")
    # U27: initialise the global futex sleeper wait queue (empty head).
    wq_init(&futex_wq)
    # #73: register the futex-table stall dumper so the no-syscall watchdog
    # can name every parked FUTEX_WAIT uaddr when a multi-thread stall fires.
    register_linux_futex_dump_hook(futex_table_dump)
    # #155: register the inotify notify routine so fs/vfs.ad's
    # create/delete/modify/close arms post events into the Layer-2
    # inotify pool through a function pointer — same boundary inversion
    # as the CLEARTID hook above. A native-only build never calls this,
    # leaving the vfs hook null and the notify calls inert.
    # fanotify shares the SAME inode-event source as inotify — bring its
    # pool up, then register a COMBINED dispatcher that fans every event
    # to both pools (one source, two consumers). A native-only build
    # never calls this, leaving the vfs hook null and both pools inert.
    _fan_init()
    register_inotify_notify_hook(_combined_notify_post)
    printk0("[u_syscalls] inotify+fanotify notify hook registered\n")
    # F4 #449: plant the Linux-ABI syscall fall-through dispatcher into
    # the hook arch/x86/kernel/syscall.ad publishes. The native do_syscall
    # body's is_linux_userspace branch reaches us through this pointer
    # without a static linux_abi import.
    register_linux_u_syscall_dispatch_hook(linux_u_syscall_dispatch)
    printk0("[u_syscalls] linux_u_syscall_dispatch hook registered\n")
    # §openat2: register the _u_open forward so openat2_handler can
    # tail-call into the SAME resolve_path + vfs_open + landlock pipeline
    # _u_open / _u_openat use, without an import cycle.
    register_openat2_open_hook(_u_open)
    printk0("[u_syscalls] openat2/_u_open hook registered\n")
    # §memfd_secret: zero the per-fd "is secret" bitmap so a cold boot
    # starts with no fd flagged. The bitmap itself is BSS-zeroed; the
    # explicit init is defense + documentation.
    memfd_secret_init()
    # §seccomp: drive every per-task BPF filter slot to the BPF_SLOT_NONE
    # sentinel (0xffff..ff). _bpf_task_progs is BSS-zeroed, so without this
    # an unfilled slot reads as pool index 0 — a real filter — should a
    # task's filter-count ever run ahead of its populated slots. The
    # count gate normally short-circuits, but the sentinel is the
    # correct disarmed state; this is the seccomp module's never-called
    # *_init hook, wired here alongside the other Layer-2 inits.
    seccomp_bpf_init()
    printk0("[u_syscalls] seccomp BPF filter table initialized\n")


def _u_futex(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long futex(uint32_t *uaddr, int op, uint32_t val,
    #            const struct timespec *timeout,  /* or uint32_t val2 */
    #            uint32_t *uaddr2, uint32_t val3)
    #
    # SYSCALL ABI NOTE: musl's __lockfile spin loop keeps `&f->lock`
    # in %rdi across this syscall and re-CASes after wake (see
    # arch/x86/kernel/syscall_64.S — we preserve %rdi only for FUTEX
    # to make musl pthread mutex contention work).
    # Bounded-park watchdog: service any parked waiter whose FUTEX_PARK_TICKS
    # recheck interval elapsed. A STATE_WAIT task cannot run its own deadline
    # check on a busy box (see futex_deadline), so every futex caller does a
    # sweep on the way in. Cheap (a 512-entry scan), and threaded clients call
    # futex constantly, so a lost wake now costs a recheck interval rather than
    # the process's life.
    _futex_sweep_expired()
    op: uint64 = a1 & FUTEX_OP_MASK
    # TIMEOUT DISCRIMINATOR (read from the RAW op before folding). The Linux
    # futex(2) timeout arg (a3) means RELATIVE for a bare FUTEX_WAIT (op 0) and
    # ABSOLUTE for FUTEX_WAIT_BITSET (op 9). glibc's pthread_cond_timedwait and
    # NSPR's PR_WaitCondVar(deadline) always use FUTEX_WAIT_BITSET|(optionally
    # FUTEX_CLOCK_REALTIME) with an ABSOLUTE deadline; a bare relative timeout
    # comes from older sem_timedwait paths. Firefox/NSPR/Rust background threads
    # lean HEAVILY on timed waits as their "wake up periodically to advance
    # timers / re-check the work queue / detect a hang" mechanism — so a futex
    # that never honours the timeout leaves such a thread parked forever, which
    # (as the FF startup deadlock shows) can wedge the whole thread group when
    # that thread is the one that would signal a sibling. Capture the flavour
    # here; the FUTEX_WAIT arm below converts a3 into a monotonic-ns deadline
    # and returns -ETIMEDOUT when it passes.
    _futex_abs_to: int32 = 0
    if op == FUTEX_WAIT_BITSET:
        _futex_abs_to = 1
    _futex_clk_rt: int32 = 0
    if (a1 & FUTEX_CLOCK_REALTIME) != 0:
        _futex_clk_rt = 1
    # FUTEX_WAIT_BITSET (9) and FUTEX_WAKE_BITSET (10) are the same as
    # WAIT/WAKE plus a per-bit mask in val3 (a5). glibc's pthread_join
    # uses BITSET with mask = FUTEX_BITSET_MATCH_ANY (0xffffffff), so
    # the mask is identity and we fold both into the basic WAIT/WAKE
    # implementations. A faithful kernel would gate the wake on
    # (bitset & val3) != 0; if a future workload uses partial masks
    # this fold loses precision, but glibc itself only uses the all-
    # ones mask in the call sites we hit.
    if op == FUTEX_WAIT_BITSET:
        op = FUTEX_WAIT
    if op == FUTEX_WAKE_BITSET:
        op = FUTEX_WAKE
    # FUTEX_REQUEUE / CMP_REQUEUE (3/4) — glibc/musl use these in
    # pthread_cond_*. We fold to FUTEX_WAKE for the wake half and
    # ignore the requeue half. Not faithful, but unblocks the U27
    # workload (mutexes + join, no condition variables).
    if op == FUTEX_REQUEUE or op == FUTEX_CMP_REQUEUE:
        op = FUTEX_WAKE
    # PRIVATE vs SHARED discriminator (read from the RAW op before masking):
    # selects _futex_key's (mm,VA) vs physical-page keying. WAIT and WAKE on
    # the same logical futex always pass the same flag, so their keys match.
    priv: int32 = 0
    if (a1 & FUTEX_PRIVATE_FLAG) != 0:
        priv = 1
    if op == FUTEX_WAIT:
        if a0 == 0:
            return ELINUX_INVAL
        # Atomic-equivalent precheck: if *uaddr != val (the third arg),
        # the wake we'd be waiting for has already happened — return
        # -EAGAIN per the futex(2) man page. glibc/musl read this as
        # "spurious wakeup" and recheck the lock word.
        # #163: every futex-word read goes through get_user_32 (a page-
        # table-walked fetch); a faulting uaddr is -EFAULT, per Linux.
        cur: uint32 = 0
        if get_user_32(a0, &cur) != 0:
            return ELINUX_EFAULT
        if cast[uint64](cur) != (a2 & 0xFFFFFFFF):
            return ELINUX_AGAIN
        # ---- TIMED-WAIT DEADLINE (a3 timeout ptr) ----------------------
        # Convert the user timeout into an absolute CLOCK_MONOTONIC-ns deadline
        # (tsc_monotonic_ns' base). a3==0 means an infinite wait — _has_deadline
        # stays 0 and the wait behaves EXACTLY as before (untimed path fully
        # unchanged, so the proven weston-terminal / pthread_join / mutex-lock
        # cases are byte-for-byte identical). Only a supplied timeout adds the
        # -ETIMEDOUT exit that Linux mandates and that the untimed-forever bug
        # was silently dropping.
        _has_deadline: int32 = 0
        _deadline_ns: uint64 = 0
        if a3 != 0:
            _to_sec: uint64 = 0
            _to_nsec: uint64 = 0
            if get_user_64(a3, &_to_sec) != 0:
                return ELINUX_EFAULT
            if get_user_64(a3 + 8, &_to_nsec) != 0:
                return ELINUX_EFAULT
            _req_ns: uint64 = _to_sec * 1000000000 + _to_nsec
            if _futex_abs_to != 0:
                # ABSOLUTE deadline. CLOCK_MONOTONIC absolute times share
                # tsc_monotonic_ns' base directly; a CLOCK_REALTIME absolute
                # time is rebased to monotonic by subtracting the RTC boot
                # epoch (realtime_ns = rtc_boot_epoch*1e9 + monotonic_ns).
                if _futex_clk_rt != 0:
                    _rt_base_ns: uint64 = rtc_boot_epoch_get() * 1000000000
                    if _req_ns > _rt_base_ns:
                        _deadline_ns = _req_ns - _rt_base_ns
                    else:
                        _deadline_ns = 0
                else:
                    _deadline_ns = _req_ns
            else:
                # RELATIVE timeout: deadline = now + requested span.
                _deadline_ns = tsc_monotonic_ns() + _req_ns
            _has_deadline = 1
            # Already expired at entry -> -ETIMEDOUT immediately (glibc/NSPR
            # then re-evaluate the predicate under their own lock).
            if tsc_monotonic_ns() >= _deadline_ns:
                return ELINUX_TIMEDOUT
        # ---------------------------------------------------------------
        # WAIT STRATEGY SELECTION (the reconciliation of efficiency vs the
        # weston-terminal render regression). The O(n^2) poll-yield collapse
        # only bites a LARGE thread group (Firefox: 42 pthreads -> ~1764
        # yield edges); for a SMALL group (weston-terminal: ~2-4 threads)
        # the yield cost is trivial and poll-yield's microsecond *uaddr
        # re-read is REQUIRED — its render path relies on catching a futex
        # word that userspace changed WITHOUT a FUTEX_WAKE syscall (the
        # "no registered waiters" elision), which a jiffy-granularity
        # blocking recheck (10-30 ms) is far too coarse to service (verified:
        # ANY blocking-park variant, bounded or not, makes weston-terminal
        # miss its frame budget so it never commits a real buffer and
        # restarts). So: SMALL group -> the PROVEN poll-yield path; LARGE
        # group -> the bounded BLOCKING park. Threshold FUTEX_BLOCK_THRESH.
        # ---------------------------------------------------------------
        if linux_mm_peer_count() < FUTEX_BLOCK_THRESH:
            # ---- POLL-YIELD path (verbatim from the proven build) --------
            # If there's no other live Linux-ABI peer that could write the
            # wake value, a real park would deadlock. Park-with-budget: yield
            # N times so the scheduler can advance any other work (hamsh's
            # waitpid timer), then return -EAGAIN. glibc's lll_lock_wait_inf
            # re-attempts the cmpxchg; if it still fails, it re-enters wait.
            if count_live_linux_peers() == 0:
                budget: int32 = 0
                while budget < 8:
                    yield_to_others()
                    if count_live_linux_peers() != 0:
                        break
                    if get_user_32(a0, &cur) != 0:      # #163
                        return ELINUX_EFAULT
                    if cast[uint64](cur) != (a2 & 0xFFFFFFFF):
                        return 0
                    budget = budget + 1
                if count_live_linux_peers() == 0:
                    return ELINUX_AGAIN
            # Park in a free slot + poll-yield until our slot is cleared
            # (futex_wake_all) OR the user value moves off `val`. We re-check
            # *uaddr each iteration so a missed / elided wake is a one-yield
            # delay — the microsecond cadence render-critical clients need.
            # Slot claim runs under _futex_lock. Previously this arm scanned and
            # claimed UNLOCKED, so a poll-yielder could hand out a slot index
            # that a bounded parker was concurrently claiming under the lock,
            # then stamp its own key over the parker's registration — leaving
            # that parker blocked in futex(2) yet INVISIBLE to FUTEX_WAKE. On
            # exit it did a bare `futex_addr[py_su] = 0`, clobbering whatever
            # registration then occupied the slot. Both are lost-wake generators
            # and both are fixed by locking + an ownership-checked release.
            py_slot: int32 = cast[int32](current_idx_get())
            py_timed: int32 = 0
            if a3 != 0:
                py_timed = 1
            spinlock_lock(&_futex_lock)
            py_spot: int32 = _futex_claim_slot_locked(_futex_key(a0, priv),
                                                      py_slot, py_timed, 0)
            spinlock_unlock(&_futex_lock)
            if py_spot < 0:
                return ELINUX_AGAIN
            py_su: uint64 = cast[uint64](py_spot)
            do:
                yield_to_others()
                # Unlocked fast read: a cleared / re-owned slot means a real
                # FUTEX_WAKE already took us off the table.
                if futex_addr[py_su] == 0:
                    break
                if futex_slot[py_su] != py_slot:
                    break
                if get_user_32(a0, &cur) != 0:          # #163
                    _futex_release_owned(py_su, py_slot)
                    return ELINUX_EFAULT
                if cast[uint64](cur) != (a2 & 0xFFFFFFFF):
                    _futex_release_owned(py_su, py_slot)
                    break
                # Timed wait: honour the deadline (Linux -ETIMEDOUT). Untimed
                # (_has_deadline==0) never takes this branch, so the render-
                # critical elided-wake cadence is unchanged.
                if _has_deadline != 0 and tsc_monotonic_ns() >= _deadline_ns:
                    _futex_release_owned(py_su, py_slot)
                    return ELINUX_TIMEDOUT
            while 1
            return 0
        # ---- BOUNDED BLOCKING park (LARGE thread group) -----------------
        # Same peer/deadlock guard as the poll-yield arm, but on a runnable
        # peer we BLOCK instead of poll-yield. A single-threaded caller that
        # somehow reaches here (peer count momentarily dipped) still bounded-
        # yields + EAGAINs rather than parking forever.
        if count_live_linux_peers() == 0:
            bbudget: int32 = 0
            while bbudget < 8:
                yield_to_others()
                if count_live_linux_peers() != 0:
                    break
                if get_user_32(a0, &cur) != 0:          # #163
                    return ELINUX_EFAULT
                if cast[uint64](cur) != (a2 & 0xFFFFFFFF):
                    return 0
                bbudget = bbudget + 1
            if count_live_linux_peers() == 0:
                return ELINUX_AGAIN
        # A live same-mm peer exists -> BOUNDED-PARK on futex_wq: the caller
        # BLOCKS (STATE_WAIT, removed from the runqueue) instead of the old
        # busy poll-yield loop. FUTEX_WAKE clears our table slot and directed-
        # wakes us by slot (wq_wake_slot) — the FAST, zero-latency path. This
        # is the many-threaded scalability win: 42 blocked Firefox threads now
        # consume ZERO scheduler rotations, killing the O(n^2) yield-to-all
        # collapse AND HLT-idling the box between wakes (no CPU burn).
        #
        # Lost-wakeup SELF-HEAL (the b50cc682 hang fix): the sleep is BOUNDED
        # (wq_wait_commit_timeout, FUTEX_PARK_TICKS jiffies), NOT infinite. If
        # a directed wq_wake_slot wake is ever missed (the exact defect that
        # parked weston-terminal/Firefox forever and let the guest HLT-idle),
        # the timer fires within FUTEX_PARK_TICKS, we RE-READ *uaddr and re-
        # check our table slot, and return if either moved — so a lost wake
        # costs at most one recheck interval of sleep, never an infinite hang.
        #
        # Race-freedom (no lost wakeup on the FAST path): the register-slot +
        # prepare-to-wait + recheck-*uaddr sequence runs under _futex_lock, the
        # SAME lock FUTEX_WAKE takes to clear+wake. Either the wake ran before
        # we registered (our locked recheck sees *uaddr moved and we bail
        # without sleeping) or it runs after (it finds us registered +
        # STATE_WAIT and wakes us). _futex_lock is released BEFORE
        # wq_wait_commit_timeout sleeps — a sleeper never holds it.
        my_slot: int32 = cast[int32](current_idx_get())
        wait_key: uint64 = _futex_key(a0, priv)
        while True:
            spinlock_lock(&_futex_lock)
            # Recheck *uaddr under the lock: a wake that landed before we
            # registered wrote the new value first, so a mismatch here means
            # "already woken" — return without sleeping.
            if get_user_32(a0, &cur) != 0:              # #163
                spinlock_unlock(&_futex_lock)
                return ELINUX_EFAULT
            if cast[uint64](cur) != (a2 & 0xFFFFFFFF):
                spinlock_unlock(&_futex_lock)
                return 0
            # Claim a table slot — the WAKE side matches waiters on it. Record
            # the bounded-park deadline so _futex_sweep_expired() (run by any
            # other task entering SYS_futex) can service our recheck interval:
            # once we are STATE_WAIT and schedule() runs, we cannot service it
            # ourselves — _pick_next never selects a STATE_WAIT task.
            bp_timed: int32 = 0
            if a3 != 0:
                bp_timed = 1
            spot: int32 = _futex_claim_slot_locked(wait_key, my_slot, bp_timed,
                                                   get_jiffies() + FUTEX_PARK_TICKS)
            if spot < 0:
                # Table full (extreme vector-wait fan-out) — degrade to
                # EAGAIN; glibc/musl re-try the cmpxchg in userspace.
                spinlock_unlock(&_futex_lock)
                return ELINUX_AGAIN
            su: uint64 = cast[uint64](spot)
            # Prepare-to-wait: link onto futex_wq + STATE_WAIT, still under
            # _futex_lock so no wake can slip in before we commit to sleep.
            wq_wait_prepare(&futex_wq)
            # Final recheck under the lock (closes the window between the
            # first recheck and prepare): a wake OR a value-move here means
            # cancel the prepared wait and return without sleeping.
            if get_user_32(a0, &cur) != 0:              # #163
                _futex_free_slot_locked(su)
                wq_wait_cancel(&futex_wq)
                spinlock_unlock(&_futex_lock)
                return ELINUX_EFAULT
            if cast[uint64](cur) != (a2 & 0xFFFFFFFF):
                _futex_free_slot_locked(su)
                wq_wait_cancel(&futex_wq)
                spinlock_unlock(&_futex_lock)
                return 0
            # Release _futex_lock BEFORE sleeping — we are already registered
            # + STATE_WAIT, so any wake after this unlock finds and wakes us.
            spinlock_unlock(&_futex_lock)
            # DIAG(ff-futex, WAIT side): if the MAIN thread is the one parking
            # here, name the caller RIP + uaddr so it can be tied to the Gecko
            # subsystem (MOZ_LOG) and cross-referenced against [ff-wake0].
            # Dedup'd + hard-capped inside the probe; no-op for non-leader tasks.
            _futex_wtdiag_main_park(a0, wait_key, bp_timed)
            rc: int32 = wq_wait_commit_timeout(&futex_wq, FUTEX_PARK_TICKS)
            # Woken (FUTEX_WAKE directed data-wake, a signal force-wake, the
            # bounded-timeout recheck, or a spurious wake on the shared queue).
            # Vacate our slot under the lock and learn whether a real futex
            # wake cleared it.
            spinlock_lock(&_futex_lock)
            cleared: int32 = 0
            if futex_addr[su] == 0:
                cleared = 1                             # a real FUTEX_WAKE
            elif futex_slot[su] != my_slot:
                cleared = 1                             # cleared, then re-owned
            else:
                _futex_free_slot_locked(su)             # still ours: vacate it
            spinlock_unlock(&_futex_lock)
            if cleared != 0:
                return 0                                # real FUTEX_WAKE
            if rc == WQ_EINTR:
                return ELINUX_INTR                      # signal interrupted
            # WQ_TIMEOUT (bounded recheck expired) OR a spurious / different-
            # uaddr sharer woke the shared queue: RE-EVALUATE *uaddr. If it
            # moved we are effectively woken (this is the lost-wake self-heal);
            # else loop and re-register + re-sleep for another interval.
            if get_user_32(a0, &cur) != 0:              # #163
                return ELINUX_EFAULT
            if cast[uint64](cur) != (a2 & 0xFFFFFFFF):
                return 0
            # Timed wait: the caller supplied a deadline (glibc/NSPR
            # pthread_cond_timedwait etc.). The FUTEX_PARK_TICKS recheck above
            # is only the lost-wake self-heal; the REAL user deadline is honored
            # here. If it has passed, return -ETIMEDOUT (Linux semantics) so the
            # thread re-evaluates its predicate instead of re-registering + re-
            # sleeping forever — the untimed-futex bug that parked timed-waiting
            # Firefox/NSPR threads permanently. Untimed waits (_has_deadline==0)
            # loop exactly as before.
            if _has_deadline != 0 and tsc_monotonic_ns() >= _deadline_ns:
                return ELINUX_TIMEDOUT
        return 0                                        # unreachable
    if op == FUTEX_WAKE:
        if a0 == 0:
            return ELINUX_INVAL
        # a2 is the maximum number of waiters to wake. glibc passes
        # 1 for mutexes, INT_MAX for cv-broadcast. We honour the cap.
        # Under _futex_lock (atomic vs a concurrent WAIT-side register +
        # prepare) clear each matching table slot AND directed-wake its task
        # by slot — a blocking waiter is STATE_WAIT off the runqueue and must
        # be re-dispatched (wq_wake_slot); a still-yielding futex_waitv poller
        # is simply not STATE_WAIT so the wake is a harmless no-op and it sees
        # the cleared slot on its next poll.
        max_wake: uint64 = a2 & 0xFFFFFFFF
        woke: int64 = 0
        wake_key: uint64 = _futex_key(a0, priv)
        spinlock_lock(&_futex_lock)
        i: uint64 = 0
        while i < FUTEX_NSLOTS:
            if futex_addr[i] == wake_key and cast[uint64](woke) < max_wake:
                wslot: int32 = futex_slot[i]
                _futex_free_slot_locked(i)
                if wslot >= 0:
                    wq_wake_slot(cast[uint64](wslot))
                woke = woke + 1
            i = i + 1
        spinlock_unlock(&_futex_lock)
        # DIAG(ff-futex, probe b): a wake that reached NO waiter — record the
        # uaddr (dedup'd) so the stuck-uaddr mis-key vs never-issued question is
        # answerable from the serial log.
        if woke == 0:
            _futex_wkdiag_zero_match(a0, wake_key, priv)
        return woke
    return ELINUX_NOSYS


# =====================================================================
# U21: readlinkat
# =====================================================================
#
# glibc calls readlinkat(AT_FDCWD, "/proc/self/exe", buf, n) to
# discover argv[0] when the caller didn't pass it through. Hamnix has
# no /proc and no symlinks, so the answer is one of:
#   * path == "/proc/self/exe": hand back a synthetic best-effort
#     string. We don't track per-task exec paths (would require
#     plumbing through arch/x86/kernel/syscall.ad's execve, which is
#     off-limits at this milestone), so we report the conventional
#     "/bin/u_idprobe" — wrong if any other Linux binary asks, but
#     glibc tolerates a wrong-but-non-empty answer here.
#   * Any other path: -EINVAL if it resolves to a real file (no
#     symlinks → readlink is meaningless on a regular file), or
#     -ENOENT if the path doesn't exist.
#
# dirfd handling: only AT_FDCWD is honoured. Non-AT_FDCWD with a
# relative path returns -EBADF — same as openat/newfstatat above.


def _u_streq_cstr(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # Returns 1 if the two NUL-terminated byte strings compare equal,
    # 0 otherwise. Local to u_syscalls.ad so we don't have to pull
    # vfs._strcmp_cstr (which is module-private) into our import set.
    # Uses a do-while because we always want to compare at least the
    # first byte and decide based on what we read.
    i: uint64 = 0
    do:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1
    while 1
    return 0                                          # unreachable


def _u_readlinkat(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t readlinkat(int dirfd, const char *pathname,
    #                    char *buf, size_t bufsiz)
    if a1 == 0 or a2 == 0:
        return ELINUX_INVAL
    if a3 == 0:
        return ELINUX_INVAL
    # #163: copy the user path in through the translated path, then run
    # every byte-check / resolve_path against the kernel copy.
    kpath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a1, &kpath[0])
    if pin != 0:
        return pin
    # Only AT_FDCWD or an absolute path is supported. Absolute paths
    # ignore dirfd per the Linux man page, so we check that first.
    is_abs: int32 = 0
    p: Ptr[uint8] = cast[Ptr[uint8]](&kpath[0])
    if p[0] == 47:                                    # '/'
        is_abs = 1
    if _u_is_at_fdcwd(a0) == 0 and is_abs == 0:
        return ELINUX_BADF
    # Special-case /proc/self/exe — glibc reaches for it during
    # __libc_start_main's argv[0]-fallback path. We don't have a real
    # /proc; hand back the conventional U21 fixture path so glibc has
    # a non-empty string to work with. (Short name matters: the longer
    # "/bin/u_glibc_idprobe" tripped a downstream argv-buffer overflow
    # that lives outside u_syscalls.ad's edit surface this milestone.)
    proc_self_exe: Ptr[uint8] = cast[Ptr[uint8]]("/proc/self/exe")
    if _u_streq_cstr(cast[Ptr[uint8]](&kpath[0]), proc_self_exe) != 0:
        # Prefer the REAL image path do_execve recorded on this task. A
        # binary that locates sibling resources via dirname(/proc/self/exe)
        # (Firefox's XPCOMGlueLoad derives its lib dir this way) needs the
        # true path; the old fixed "/bin/u_idprobe" made it look in the
        # wrong dir and abort with "Couldn't load XPCOM." Fall back to the
        # synthetic probe path only when exe_path is unstamped (exe[0]==0).
        reply: Ptr[uint8] = current_exe_path_ptr()
        if reply == cast[Ptr[uint8]](0) or reply[0] == 0:
            reply = cast[Ptr[uint8]]("/bin/u_idprobe")
        # Count the reply length up to NUL. Plain while is the right
        # shape: we don't want the body to run when reply[0] == 0.
        n: uint64 = 0
        while reply[n] != 0:
            n = n + 1
        # Copy min(n, bufsiz) bytes to the user buffer. readlink(2)
        # does NOT NUL-terminate — the man page is explicit about it.
        # #163: translated copy_to_user — a bad user buf returns -EFAULT.
        limit: uint64 = n
        if limit > a3:
            limit = a3
        if copy_to_user(a2, cast[uint64](reply), limit) != 0:
            return ELINUX_EFAULT
        return cast[int64](limit)
    # Any other path: resolve it to an absolute path so the backend
    # classifier vfs_fs_kind sees the canonical spelling.
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&kpath[0]), &abs_path[0], 256)
    if rc != 0:
        return ELINUX_NOENT
    # F10-9: route by mount-table backend kind, NOT by literal-path probe
    # of the tmpfs server. Only ask tmpfs whether the link is a symlink
    # AFTER vfs_fs_kind has told us tmpfs owns the path. Anything else
    # falls through to the "exists but not a symlink / does not exist"
    # disambiguator below — ext4/cpio symlinks are unimplemented and
    # report -EINVAL like a regular file (Linux readlink semantics).
    if vfs_fs_kind(cast[Ptr[char]](&abs_path[0])) == FS_KIND_TMPFS and tmpfs_path_is_symlink(cast[Ptr[char]](&abs_path[0])) != 0:
        tgt: Ptr[uint8] = tmpfs_readlink_path(cast[Ptr[char]](&abs_path[0]))
        if tgt != cast[Ptr[uint8]](0):
            # Length of the target up to its NUL terminator.
            tn: uint64 = 0
            while tgt[tn] != 0:
                tn = tn + 1
            tlimit: uint64 = tn
            if tlimit > a3:
                tlimit = a3
            # #163: translated copy_to_user of the symlink target.
            if copy_to_user(a2, cast[uint64](tgt), tlimit) != 0:
                return ELINUX_EFAULT
            return cast[int64](tlimit)
    # Not a tmpfs symlink. Check whether the path resolves to something.
    # If yes, return -EINVAL (a regular file is not a symlink); if no,
    # -ENOENT. F10-1 double-resolution fix: probe with the RAW path so
    # vfs_open's single internal resolve_path walks the namespace once
    # (abs_path stays the authority for backend classification above).
    fd: int32 = vfs_open(cast[Ptr[char]](&kpath[0]))
    if fd < 0:
        return ELINUX_NOENT
    vfs_close(fd)
    return ELINUX_INVAL                               # exists but not a symlink


# =====================================================================
# §5 — Layer-2 async I/O: epoll / eventfd / timerfd / signalfd
# =====================================================================
#
# The fd-based event primitives real Linux server daemons are built
# around. A daemon registers its socket / pipe / eventfd / timerfd fds
# into one epoll fd, then loops in epoll_wait. These are Layer-2-ONLY
# confined objects (linux_abi/u_epoll.ad) — they exist solely to satisfy
# Linux guests and never become a dependency of native Layer-1 code.
#
# Common flag bits (high bits of `type` / standalone flag args). Hamnix
# has no FD_CLOEXEC table, so *_CLOEXEC is masked off; *_NONBLOCK is
# honoured end-to-end via the Layer-2 O_NONBLOCK bitmap.
O_NONBLOCK_BIT:  uint64 = 0x800
O_CLOEXEC_BIT:   uint64 = 0x80000

# A poll(2) timeout / epoll_wait timeout of this many jiffies is the
# upper bound we spin-yield before giving up — bounded so a daemon with
# a genuinely-infinite (-1) timeout and no ready fd can't wedge the
# cooperative scheduler. ~30 s at HZ=100. A real ready fd returns
# immediately; this only caps the idle case.
UEP_WAIT_MAX_JIFFIES: uint64 = 3000


def _u_set_fd_nonblock(fd: int32, flags_have_nonblock: int32):
    # Record / clear O_NONBLOCK for `fd` in the current task's Layer-2
    # bitmap. Used by socket(SOCK_NONBLOCK), accept4, pipe2, eventfd2,
    # timerfd_create, signalfd4, and fcntl(F_SETFL).
    uep_nonblock_set(current_idx_get(), fd, flags_have_nonblock)


def _u_fd_is_nonblock(fd: int32) -> int32:
    return uep_nonblock_get(current_idx_get(), fd)


def _u_apply_cloexec_flags(fd: int32, flags: uint64):
    # Set / clear the fd's close-on-exec flag from an open/pipe2/socket/
    # dup3/eventfd2/... `flags` word that carries O_CLOEXEC (0x80000) — the
    # same bit as SOCK_CLOEXEC / EFD_CLOEXEC / TFD_CLOEXEC / SFD_CLOEXEC /
    # EPOLL_CLOEXEC / IN_CLOEXEC / MFD_CLOEXEC. Stored in the fd table
    # (kernel/sched/core.ad) so it survives fork and is consumed at exec.
    if fd < 0:
        return
    on: int32 = 0
    if (flags & O_CLOEXEC_BIT) != 0:
        on = 1
    fd_cloexec_set(current_idx_get(), fd, on)


def _u_set_fd_cloexec(fd: int32, on: int32):
    # Directly set/clear close-on-exec (fcntl F_SETFD, F_DUPFD_CLOEXEC,
    # MFD_CLOEXEC where the bit value differs).
    fd_cloexec_set(current_idx_get(), fd, on)


# --- eventfd ---------------------------------------------------------

def _u_eventfd2(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int eventfd2(unsigned int initval, int flags)
    # flags: EFD_SEMAPHORE | EFD_NONBLOCK | EFD_CLOEXEC.
    initval: uint64 = a0
    flags:   uint64 = a1
    semaphore: int32 = 0
    if (flags & cast[uint64](EFD_SEMAPHORE)) != 0:
        semaphore = 1
    es: int32 = uefd_alloc(initval, semaphore)
    if es < 0:
        set_current_errstr("eventfd: object pool exhausted")
        return ELINUX_MFILE
    fd: int32 = vfs_alloc_l2_fd(FD_EVENTFD_MARK)
    if fd < 0:
        set_current_errstr("eventfd: out of fd slots")
        return ELINUX_MFILE
    # fd_buf carries slot+1 (0 == "no object", same encoding as sockets).
    if vfs_l2_fd_set_buf(fd, cast[uint64](es + 1)) != 0:
        vfs_close(fd)
        return ELINUX_BADF
    if (flags & O_NONBLOCK_BIT) != 0:
        _u_set_fd_nonblock(fd, 1)
    # O_CLOEXEC (eventfd_CLOEXEC bit == 0x80000): close this
    # object fd at the next execve.
    _u_apply_cloexec_flags(fd, flags)
    return cast[int64](fd)


def _u_eventfd(a0: uint64, a1: uint64, a2: uint64,
               a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int eventfd(unsigned int initval) — the flag-less legacy form.
    return _u_eventfd2(a0, 0, a2, a3, a4, a5)


# --- timerfd ---------------------------------------------------------

# clockid values we accept (CLOCK_REALTIME / CLOCK_MONOTONIC) — both map
# onto the same 100 Hz jiffy clock at this scale.
UEP_CLOCK_REALTIME:  uint64 = 0
UEP_CLOCK_MONOTONIC: uint64 = 1


def _u_ts_to_jiffies(ts_ptr: uint64) -> uint64:
    # Convert a struct timespec { i64 tv_sec; i64 tv_nsec } at ts_ptr
    # into a jiffy count (HZ=100 -> 10 ms granularity). A NULL pointer
    # or all-zero timespec yields 0.
    if ts_ptr == 0:
        return 0
    # SMAP: timespec in user memory (US=1) — read via page tables.
    sec:  uint64 = 0
    nsec: uint64 = 0
    if get_user_64(ts_ptr, &sec) != 0:
        return 0
    if get_user_64(ts_ptr + 8, &nsec) != 0:
        return 0
    j: uint64 = sec * HZ + nsec / (1000000000 / HZ)
    # An armed timer with a sub-tick delay still has to fire — round a
    # non-zero but sub-jiffy delay up to one jiffy.
    if j == 0:
        if sec != 0 or nsec != 0:
            j = 1
    return j


def _u_jiffies_to_ts(j: uint64, ts_ptr: uint64):
    # Inverse of _u_ts_to_jiffies — write a jiffy count back as a
    # struct timespec at ts_ptr (used by timerfd_gettime).
    if ts_ptr == 0:
        return
    # SMAP: timespec in user memory (US=1) — write via page tables.
    put_user_64(j / HZ, ts_ptr)
    put_user_64((j % HZ) * (1000000000 / HZ), ts_ptr + 8)


def _u_timerfd_create(a0: uint64, a1: uint64, a2: uint64,
                      a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int timerfd_create(int clockid, int flags)
    clockid: uint64 = a0
    flags:   uint64 = a1
    if clockid != UEP_CLOCK_REALTIME and clockid != UEP_CLOCK_MONOTONIC:
        set_current_errstr("timerfd_create: unsupported clockid")
        return ELINUX_INVAL
    ts: int32 = utfd_alloc()
    if ts < 0:
        set_current_errstr("timerfd_create: object pool exhausted")
        return ELINUX_MFILE
    fd: int32 = vfs_alloc_l2_fd(FD_TIMERFD_MARK)
    if fd < 0:
        set_current_errstr("timerfd_create: out of fd slots")
        return ELINUX_MFILE
    if vfs_l2_fd_set_buf(fd, cast[uint64](ts + 1)) != 0:
        vfs_close(fd)
        return ELINUX_BADF
    if (flags & O_NONBLOCK_BIT) != 0:
        _u_set_fd_nonblock(fd, 1)
    # O_CLOEXEC (timerfd_CLOEXEC bit == 0x80000): close this
    # object fd at the next execve.
    _u_apply_cloexec_flags(fd, flags)
    return cast[int64](fd)


def _u_timerfd_settime(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int timerfd_settime(int fd, int flags,
    #                     const struct itimerspec *new,
    #                     struct itimerspec *old)
    # struct itimerspec { struct timespec it_interval; it_value; }
    # — it_interval at offset 0, it_value at offset 16. `flags`
    # (TFD_TIMER_ABSTIME) is ignored: we treat it_value as relative,
    # which is what timeout-loop daemons use.
    fd: int32 = cast[int32](a0)
    if vfs_fd_marker(fd) != FD_TIMERFD_MARK:
        return ELINUX_BADF
    ts: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
    if utfd_valid(ts) == 0:
        return ELINUX_BADF
    if a2 == 0:
        return ELINUX_INVAL
    interval_j: uint64 = _u_ts_to_jiffies(a2)          # it_interval
    value_j:    uint64 = _u_ts_to_jiffies(a2 + 16)     # it_value
    # Report the old setting if the caller asked for it.
    if a3 != 0:
        _u_jiffies_to_ts(utfd_gettime_interval(ts), a3)
        _u_jiffies_to_ts(utfd_gettime_remaining(ts), a3 + 16)
    rc: int64 = utfd_arm(ts, value_j, interval_j)
    return rc


def _u_timerfd_gettime(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int timerfd_gettime(int fd, struct itimerspec *curr)
    fd: int32 = cast[int32](a0)
    if vfs_fd_marker(fd) != FD_TIMERFD_MARK:
        return ELINUX_BADF
    ts: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
    if utfd_valid(ts) == 0:
        return ELINUX_BADF
    if a1 == 0:
        return ELINUX_INVAL
    _u_jiffies_to_ts(utfd_gettime_interval(ts), a1)        # it_interval
    _u_jiffies_to_ts(utfd_gettime_remaining(ts), a1 + 16)  # it_value
    return 0


# --- signalfd --------------------------------------------------------

def _u_sigset_to_kernel(set_ptr: uint64) -> uint64:
    # Convert a user sigset_t (an array of words, bit (sig-1) set for
    # signal `sig`) into Hamnix's sig_pending layout (bit `sig` set).
    # We read the first 8 bytes — enough for signals 1..64.
    if set_ptr == 0:
        return 0
    # SMAP: the sigset_t lives in user memory (US=1) — read via page tables.
    user_bits: uint64 = 0
    if get_user_64(set_ptr, &user_bits) != 0:
        return 0
    kern: uint64 = 0
    sig: uint64 = 1
    while sig < 64:
        if (user_bits & (cast[uint64](1) << (sig - 1))) != 0:
            kern = kern | (cast[uint64](1) << sig)
        sig = sig + 1
    return kern


def _u_signalfd4(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int signalfd4(int fd, const sigset_t *mask, size_t sizemask,
    #               int flags)
    # fd == -1 creates a new signalfd; fd >= 0 updates an existing one's
    # mask. flags: SFD_NONBLOCK | SFD_CLOEXEC.
    in_fd: int32 = cast[int32](a0)
    kmask: uint64 = _u_sigset_to_kernel(a1)
    flags: uint64 = a3
    if in_fd >= 0:
        # Update an existing signalfd's accepted-signal mask.
        if vfs_fd_marker(in_fd) != FD_SIGNALFD_MARK:
            return ELINUX_INVAL
        ss_up: int32 = cast[int32](vfs_l2_fd_get_buf(in_fd)) - 1
        if usfd_valid(ss_up) == 0:
            return ELINUX_BADF
        usfd_set_mask(ss_up, kmask)
        return cast[int64](in_fd)
    ss: int32 = usfd_alloc(kmask)
    if ss < 0:
        set_current_errstr("signalfd: object pool exhausted")
        return ELINUX_MFILE
    fd: int32 = vfs_alloc_l2_fd(FD_SIGNALFD_MARK)
    if fd < 0:
        set_current_errstr("signalfd: out of fd slots")
        return ELINUX_MFILE
    if vfs_l2_fd_set_buf(fd, cast[uint64](ss + 1)) != 0:
        vfs_close(fd)
        return ELINUX_BADF
    if (flags & O_NONBLOCK_BIT) != 0:
        _u_set_fd_nonblock(fd, 1)
    # O_CLOEXEC (signalfd_CLOEXEC bit == 0x80000): close this
    # object fd at the next execve.
    _u_apply_cloexec_flags(fd, flags)
    return cast[int64](fd)


def _u_signalfd(a0: uint64, a1: uint64, a2: uint64,
                a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int signalfd(int fd, const sigset_t *mask, size_t sizemask)
    return _u_signalfd4(a0, a1, a2, 0, a4, a5)


def _u_signalfd_read(fd: int32, buf: uint64, count: uint64) -> int64:
    # read(2) on a signalfd fd. Each ready signal is delivered as one
    # struct signalfd_siginfo (128 bytes); we fill only ssi_signo (the
    # field daemons read) and zero the rest. Returns -EAGAIN if no
    # accepted signal is pending. Called from _u_read's fd-kind switch.
    ss: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
    if usfd_valid(ss) == 0:
        return ELINUX_BADF
    if count < 128:
        return ELINUX_INVAL
    pend: uint64 = signal_pending(current_idx_get())
    ready: uint64 = usfd_match(ss, pend)
    if ready == 0:
        return ELINUX_AGAIN
    # Deliver as many siginfo records as fit in the caller's buffer.
    written: uint64 = 0
    sig: uint64 = 1
    while sig < 64:
        if written + 128 > count:
            break
        if (ready & (cast[uint64](1) << sig)) != 0:
            rec: uint64 = buf + written
            memset(cast[Ptr[uint8]](rec), 0, 128)
            cast[Ptr[uint32]](rec)[0] = cast[uint32](sig)   # ssi_signo
            usfd_consume(ss, sig)
            written = written + 128
        sig = sig + 1
    if written == 0:
        return ELINUX_AGAIN
    return cast[int64](written)


# --- inotify ---------------------------------------------------------

def _u_inotify_init1(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int inotify_init1(int flags) — flags: IN_NONBLOCK | IN_CLOEXEC.
    flags: uint64 = a0
    ins: int32 = uino_alloc()
    if ins < 0:
        set_current_errstr("inotify_init: object pool exhausted")
        return ELINUX_MFILE
    fd: int32 = vfs_alloc_l2_fd(FD_INOTIFY_MARK)
    if fd < 0:
        set_current_errstr("inotify_init: out of fd slots")
        return ELINUX_MFILE
    # fd_buf carries slot+1 (0 == "no object"), same encoding the rest of
    # the §5 pools use.
    if vfs_l2_fd_set_buf(fd, cast[uint64](ins + 1)) != 0:
        vfs_close(fd)
        return ELINUX_BADF
    if (flags & cast[uint64](IN_NONBLOCK)) != 0:
        _u_set_fd_nonblock(fd, 1)
    # O_CLOEXEC (inotify_CLOEXEC bit == 0x80000): close this
    # object fd at the next execve.
    _u_apply_cloexec_flags(fd, flags)
    return cast[int64](fd)


def _u_inotify_init(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int inotify_init(void) — the flag-less legacy form.
    return _u_inotify_init1(0, a1, a2, a3, a4, a5)


def _u_inotify_add_watch(a0: uint64, a1: uint64, a2: uint64,
                         a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int inotify_add_watch(int fd, const char *pathname, uint32 mask)
    # Returns the watch descriptor (>=1) or a negative errno.
    fd: int32 = cast[int32](a0)
    if vfs_fd_marker(fd) != FD_INOTIFY_MARK:
        return ELINUX_BADF
    ins: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
    if uino_valid(ins) == 0:
        return ELINUX_BADF
    # Resolve the watched path to an absolute path — the notify hook in
    # vfs.ad posts events keyed on the absolute directory, so the stored
    # watch path must be absolute too (a watch on "tmp" from cwd "/" must
    # match the "/tmp" the create/delete hook reports).
    # #163: translated path copy-in before resolve_path.
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a1, &upath[0])
    if pin != 0:
        set_current_errstr("inotify_add_watch: bad path pointer")
        return pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&upath[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("inotify_add_watch: path too long")
        return ELINUX_INVAL
    return uino_add_watch(ins, &abs_path[0], cast[uint32](a2))


def _u_inotify_rm_watch(a0: uint64, a1: uint64, a2: uint64,
                        a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int inotify_rm_watch(int fd, int wd)
    fd: int32 = cast[int32](a0)
    if vfs_fd_marker(fd) != FD_INOTIFY_MARK:
        return ELINUX_BADF
    ins: int32 = cast[int32](vfs_l2_fd_get_buf(fd)) - 1
    if uino_valid(ins) == 0:
        return ELINUX_BADF
    return uino_rm_watch(ins, cast[int32](a1))


# --- fanotify --------------------------------------------------------
#
# fanotify(7) is the second filesystem-event delivery fd. Where inotify
# delivers variable-length `struct inotify_event` records (wd + name),
# fanotify delivers fixed-size `struct fanotify_event_metadata` records
# carrying an event mask, an open fd to the object, and the originating
# pid. Both APIs ride the SAME underlying inode-event source: fs/vfs.ad's
# create/delete/modify/close arms fire one notify hook. At bring-up
# u_syscalls.ad registers a COMBINED dispatcher (_combined_notify_post,
# below) that fans each event to BOTH the inotify pool (uino_post) and
# this fanotify pool (_fan_post) — there is NO second event-source
# mechanism.
#
# Layer-2 confinement, same discipline as the inotify pool in
# u_epoll.ad: flat parallel module-scope arrays, fixed sizes, no heap.
# Because vfs.ad's vfs_l2_fd_{set,get}_buf only recognise the four §5
# markers + inotify, the group slot is stashed into / read from the
# per-task fd_buf DIRECTLY here (current_task()[0].fd_buf[fd]); a
# FD_FANOTIFY_MARK fd's read path is serviced in the read shim above.
#
# SCOPED-OUT (documented, not faked):
#   * On close(2) the fanotify GROUP-POOL slot is not auto-reclaimed:
#     the reclaim hook lives in fs/vfs.ad's vfs_close FD_INOTIFY_MARK
#     arm, which this change may not touch. The core fd itself is freed
#     normally; only the (8-entry) group pool slot leaks. fanotify_init
#     on an exhausted pool returns EMFILE. Acceptable at this scale.
#   * FAN_CLASS_CONTENT / FAN_CLASS_PRE_CONTENT (permission events that
#     block the syscall awaiting a userspace allow/deny) are rejected
#     with EINVAL rather than half-implemented.
#   * The notification-class `fd` field returns FAN_NOFD (-1): wiring a
#     real backing open fd to the object the event occurred on is not
#     practical from the notify hook (it only carries dir+name+mask, and
#     the boot-context group has no fd table of its own). mask + pid are
#     delivered for real; vers==FANOTIFY_METADATA_VERSION(3).

# 0xFFFFFFE5 is one of the values freed when namespace-purity Phase 4b
# retired FD_MOUNTS_MARK (/dev/mounts is now a namec devtab cdev).
# FD_FANOTIFY_MARK previously sat at 0xFFFFFFD2, but that COLLIDED with
# fs/vfs.ad's FD_FILEMMAP_INITRAMFS (also 0xD2): a single fd matched both
# the fanotify dispatch and the mmap'd-initramfs marker. Moved into the
# freed 0xE5 slot to restore marker uniqueness.
FD_FANOTIFY_MARK: uint32 = 0xFFFFFFE5

# fanotify_init flags (Linux <sys/fanotify.h>).
FAN_CLOEXEC:           uint32 = 0x00000001
FAN_NONBLOCK:          uint32 = 0x00000002
FAN_CLASS_NOTIF:       uint32 = 0x00000000
FAN_CLASS_CONTENT:     uint32 = 0x00000004
FAN_CLASS_PRE_CONTENT: uint32 = 0x00000008
FAN_CLASS_MASK:        uint32 = 0x0000000C

# fanotify_mark flags (the action + target-type bits).
FAN_MARK_ADD:          uint32 = 0x00000001
FAN_MARK_REMOVE:       uint32 = 0x00000002
FAN_MARK_FLUSH:        uint32 = 0x00000080

# fanotify event mask bits. The low bits deliberately coincide with the
# IN_* values for the events our inode-event source can report, so the
# IN_* mask the hook delivers maps straight through.
FAN_ACCESS:        uint64 = 0x00000001    # == IN_ACCESS (source: no)
FAN_MODIFY:        uint64 = 0x00000002    # == IN_MODIFY
FAN_CLOSE_WRITE:   uint64 = 0x00000008    # == IN_CLOSE_WRITE
FAN_CLOSE_NOWRITE: uint64 = 0x00000010    # (source: no)
FAN_OPEN:          uint64 = 0x00000020    # (source: no)
FAN_CREATE:        uint64 = 0x00000100    # == IN_CREATE
FAN_DELETE:        uint64 = 0x00000200    # == IN_DELETE
# The subset of FAN_* our fsnotify source (vfs.ad create/delete/modify/
# close) can actually emit. A mark with bits outside this is EINVAL.
FAN_SOURCEABLE:    uint64 = 0x0000030A    # MODIFY|CLOSE_WRITE|CREATE|DELETE

# struct fanotify_event_metadata version + size.
FANOTIFY_METADATA_VERSION: uint8  = 3
FAN_EVENT_METADATA_LEN:    uint16 = 24    # event_len 4 + 1+1+2 + 8 + 4 + 4
FAN_NOFD:                  int32  = -1

# Pool sizing — mirrors the inotify pool's small fixed scale.
FAN_MAX:        uint64 = 8        # concurrent groups
FAN_MARK_MAX:   uint64 = 16       # marks per group
FAN_EVQ_MAX:    uint64 = 64       # pending events per group
FAN_PATH_MAX:   uint64 = 128      # stored mark path length cap

# Group state.
fan_inuse:  Array[8, uint8]
fan_g_mask: Array[8, uint64]      # union of all mark masks (fast reject)
# Per-group marks, indexed [group*FAN_MARK_MAX + m].
fan_m_used: Array[128, uint8]     # 8 * 16
fan_m_mask: Array[128, uint64]    # accepted event mask for this mark
fan_m_path: Array[16384, uint8]   # 8*16*128 — stored abs dir path, NUL-term
# Event ring, indexed [group*FAN_EVQ_MAX + slot].
fan_q_head:  Array[8, uint64]
fan_q_tail:  Array[8, uint64]
fan_q_count: Array[8, uint64]
fan_q_mask:  Array[512, uint64]   # 8 * 64
fan_q_pid:   Array[512, int32]


def _fan_init():
    i: uint64 = 0
    while i < FAN_MAX:
        fan_inuse[i]   = 0
        fan_g_mask[i]  = 0
        fan_q_head[i]  = 0
        fan_q_tail[i]  = 0
        fan_q_count[i] = 0
        i = i + 1
    m: uint64 = 0
    while m < FAN_MAX * FAN_MARK_MAX:
        fan_m_used[m] = 0
        fan_m_mask[m] = 0
        m = m + 1


def _fan_clear_group(gu: uint64):
    mb: uint64 = gu * FAN_MARK_MAX
    k: uint64 = 0
    while k < FAN_MARK_MAX:
        fan_m_used[mb + k] = 0
        fan_m_mask[mb + k] = 0
        k = k + 1
    fan_g_mask[gu]  = 0
    fan_q_head[gu]  = 0
    fan_q_tail[gu]  = 0
    fan_q_count[gu] = 0


def _fan_alloc() -> int32:
    i: uint64 = 0
    while i < FAN_MAX:
        if fan_inuse[i] == 0:
            fan_inuse[i] = 1
            _fan_clear_group(i)
            return cast[int32](i)
        i = i + 1
    return -1


def _fan_valid(slot: int32) -> int32:
    if slot < 0:
        return 0
    su: uint64 = cast[uint64](slot)
    if su >= FAN_MAX:
        return 0
    if fan_inuse[su] == 0:
        return 0
    return 1


def _fan_recompute_gmask(gu: uint64):
    # Recompute the per-group union mask after a mark add/remove/flush so
    # _fan_post can fast-reject events no live mark cares about.
    mb: uint64 = gu * FAN_MARK_MAX
    acc: uint64 = 0
    k: uint64 = 0
    while k < FAN_MARK_MAX:
        if fan_m_used[mb + k] != 0:
            acc = acc | fan_m_mask[mb + k]
        k = k + 1
    fan_g_mask[gu] = acc


def _fan_pathcmp(base: uint64, p: Ptr[uint8]) -> int32:
    # 1 if the stored mark path at byte-offset `base` equals C-string p.
    i: uint64 = 0
    while i < FAN_PATH_MAX:
        a: uint8 = fan_m_path[base + i]
        b: uint8 = p[i]
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1
    return 1


def _fan_mark_add(slot: int32, path: Ptr[uint8], mask: uint64) -> int64:
    # Add (or OR-update) a mark on `path`. fanotify accumulates masks on
    # a repeat FAN_MARK_ADD for the same object (unlike inotify, which
    # replaces). Returns 0 on success, or a negative errno.
    if _fan_valid(slot) == 0:
        return ELINUX_BADF
    gu: uint64 = cast[uint64](slot)
    mb: uint64 = gu * FAN_MARK_MAX
    # Update an existing mark on the same path (OR the new bits in).
    k: uint64 = 0
    while k < FAN_MARK_MAX:
        if fan_m_used[mb + k] != 0:
            if _fan_pathcmp((mb + k) * FAN_PATH_MAX, path) != 0:
                fan_m_mask[mb + k] = fan_m_mask[mb + k] | mask
                _fan_recompute_gmask(gu)
                return 0
        k = k + 1
    # Allocate a fresh mark slot.
    k = 0
    while k < FAN_MARK_MAX:
        if fan_m_used[mb + k] == 0:
            fan_m_used[mb + k] = 1
            fan_m_mask[mb + k] = mask
            pb: uint64 = (mb + k) * FAN_PATH_MAX
            j: uint64 = 0
            while j < FAN_PATH_MAX - 1:
                c: uint8 = path[j]
                fan_m_path[pb + j] = c
                if c == 0:
                    break
                j = j + 1
            fan_m_path[pb + (FAN_PATH_MAX - 1)] = 0
            _fan_recompute_gmask(gu)
            return 0
        k = k + 1
    return ELINUX_MFILE


def _fan_mark_remove(slot: int32, path: Ptr[uint8], mask: uint64) -> int64:
    # Clear `mask`'s bits from the mark on `path`; drop the mark when no
    # bits remain. Returns 0 on success (Linux returns ENOENT for a path
    # with no mark, but a benign 0 is friendlier for our scope).
    if _fan_valid(slot) == 0:
        return ELINUX_BADF
    gu: uint64 = cast[uint64](slot)
    mb: uint64 = gu * FAN_MARK_MAX
    k: uint64 = 0
    while k < FAN_MARK_MAX:
        if fan_m_used[mb + k] != 0:
            if _fan_pathcmp((mb + k) * FAN_PATH_MAX, path) != 0:
                fan_m_mask[mb + k] = fan_m_mask[mb + k] & (~mask)
                if fan_m_mask[mb + k] == 0:
                    fan_m_used[mb + k] = 0
                _fan_recompute_gmask(gu)
                return 0
        k = k + 1
    return ELINUX_NOENT


def _fan_mark_flush(slot: int32) -> int64:
    # Drop every mark in the group (FAN_MARK_FLUSH). Events already queued
    # stay queued (Linux semantics: flush affects marks, not the queue).
    if _fan_valid(slot) == 0:
        return ELINUX_BADF
    gu: uint64 = cast[uint64](slot)
    mb: uint64 = gu * FAN_MARK_MAX
    k: uint64 = 0
    while k < FAN_MARK_MAX:
        fan_m_used[mb + k] = 0
        fan_m_mask[mb + k] = 0
        k = k + 1
    fan_g_mask[gu] = 0
    return 0


def _fan_queue_event(gu: uint64, mask: uint64, pid: int32):
    # Push one event record onto group `gu`'s ring. Drops on overflow
    # (Linux would post FAN_Q_OVERFLOW; honest small-scale answer is drop).
    if fan_q_count[gu] >= FAN_EVQ_MAX:
        return
    tail: uint64 = fan_q_tail[gu]
    gi: uint64 = gu * FAN_EVQ_MAX + tail
    fan_q_mask[gi] = mask
    fan_q_pid[gi]  = pid
    fan_q_tail[gu]  = (tail + 1) % FAN_EVQ_MAX
    fan_q_count[gu] = fan_q_count[gu] + 1


def _fan_post(dir_path: Ptr[uint8], name: Ptr[uint8], in_mask: uint32):
    # The notify entry the combined dispatcher calls for fanotify. The
    # IN_* mask coincides numerically with the matching FAN_* bit, so it
    # maps straight through. For every live group with a mark on
    # `dir_path` whose mask overlaps, queue one event. fanotify is
    # name-less in this class — we key only on the watched directory.
    fmask: uint64 = cast[uint64](in_mask)
    pid: int32 = cast[int32](current_task_pid())
    i: uint64 = 0
    while i < FAN_MAX:
        if fan_inuse[i] != 0:
            if (fan_g_mask[i] & fmask) != 0:
                mb: uint64 = i * FAN_MARK_MAX
                k: uint64 = 0
                while k < FAN_MARK_MAX:
                    if fan_m_used[mb + k] != 0:
                        if (fan_m_mask[mb + k] & fmask) != 0:
                            if _fan_pathcmp((mb + k) * FAN_PATH_MAX,
                                            dir_path) != 0:
                                _fan_queue_event(i, fmask & fan_m_mask[mb + k],
                                                 pid)
                                k = FAN_MARK_MAX
                    k = k + 1
        i = i + 1


def _fan_readable(slot: int32) -> int32:
    if _fan_valid(slot) == 0:
        return 0
    if fan_q_count[cast[uint64](slot)] != 0:
        return 1
    return 0


def _fan_read(slot: int32, buf: uint64, count: uint64) -> int64:
    # Drain queued events into the user buffer as packed
    # struct fanotify_event_metadata {
    #   __u32 event_len; __u8 vers; __u8 reserved; __u16 metadata_len;
    #   __aligned_u64 mask; __s32 fd; __s32 pid; }  (24 bytes, fixed).
    # Returns bytes written, or -EAGAIN if nothing is queued, or -EINVAL
    # if the buffer is too small for even one record.
    if _fan_valid(slot) == 0:
        return ELINUX_BADF
    gu: uint64 = cast[uint64](slot)
    if fan_q_count[gu] == 0:
        return ELINUX_AGAIN
    if count < cast[uint64](FAN_EVENT_METADATA_LEN):
        return ELINUX_INVAL
    written: uint64 = 0
    reclen: uint64 = cast[uint64](FAN_EVENT_METADATA_LEN)
    while fan_q_count[gu] != 0:
        if written + reclen > count:
            break
        head: uint64 = fan_q_head[gu]
        gi: uint64 = gu * FAN_EVQ_MAX + head
        rec: uint64 = buf + written
        cast[Ptr[uint32]](rec)[0]      = cast[uint32](reclen)            # event_len
        cast[Ptr[uint8]](rec + 4)[0]   = FANOTIFY_METADATA_VERSION       # vers
        cast[Ptr[uint8]](rec + 5)[0]   = 0                               # reserved
        cast[Ptr[uint16]](rec + 6)[0]  = FAN_EVENT_METADATA_LEN          # metadata_len
        cast[Ptr[uint64]](rec + 8)[0]  = fan_q_mask[gi]                  # mask
        cast[Ptr[int32]](rec + 16)[0]  = FAN_NOFD                        # fd (scoped: -1)
        cast[Ptr[int32]](rec + 20)[0]  = fan_q_pid[gi]                   # pid
        written = written + reclen
        fan_q_head[gu]  = (head + 1) % FAN_EVQ_MAX
        fan_q_count[gu] = fan_q_count[gu] - 1
    if written == 0:
        return ELINUX_INVAL
    return cast[int64](written)


def _combined_notify_post(dir_path: Ptr[uint8], name: Ptr[uint8],
                          mask: uint32):
    # The single notify hook fs/vfs.ad calls. It fans each inode event to
    # BOTH the inotify pool and the fanotify pool — the architecturally-
    # correct "one source, two consumers" shape. Registered in place of
    # the bare uino_post at bring-up.
    uino_post(dir_path, name, mask)
    _fan_post(dir_path, name, mask)


def _u_fanotify_init(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fanotify_init(unsigned int flags, unsigned int event_f_flags)
    # flags: a class (FAN_CLASS_*) ORed with FAN_CLOEXEC / FAN_NONBLOCK.
    flags: uint32 = cast[uint32](a0)
    cls: uint32 = flags & FAN_CLASS_MASK
    # Reject permission classes — we do not implement blocking permission
    # events (scoped out above). Only the notification class is supported.
    if cls == FAN_CLASS_CONTENT or cls == FAN_CLASS_PRE_CONTENT:
        set_current_errstr("fanotify_init: permission classes unsupported")
        return ELINUX_INVAL
    if cls != FAN_CLASS_NOTIF:
        set_current_errstr("fanotify_init: bad class")
        return ELINUX_INVAL
    grp: int32 = _fan_alloc()
    if grp < 0:
        set_current_errstr("fanotify_init: group pool exhausted")
        return ELINUX_MFILE
    fd: int32 = vfs_alloc_l2_fd(FD_FANOTIFY_MARK)
    if fd < 0:
        # Hand the group slot back; nothing references it yet.
        fan_inuse[cast[uint64](grp)] = 0
        set_current_errstr("fanotify_init: out of fd slots")
        return ELINUX_MFILE
    # Stash group-slot+1 into fd_buf directly (vfs's l2 set_buf helper
    # rejects unknown markers, so we touch the per-task table here).
    ftask: Ptr[TaskStruct] = fd_owner_task(current_task())
    ftask[0].fd_buf[cast[uint64](fd)] = cast[uint64](grp + 1)
    if (flags & FAN_NONBLOCK) != 0:
        _u_set_fd_nonblock(fd, 1)
    return cast[int64](fd)


def _u_fanotify_mark(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int fanotify_mark(int fd, unsigned int flags, uint64_t mask,
    #                   int dirfd, const char *pathname)
    fd: int32 = cast[int32](a0)
    if vfs_fd_marker(fd) != FD_FANOTIFY_MARK:
        return ELINUX_BADF
    mtask: Ptr[TaskStruct] = fd_owner_task(current_task())
    grp: int32 = cast[int32](mtask[0].fd_buf[cast[uint64](fd)]) - 1
    if _fan_valid(grp) == 0:
        return ELINUX_BADF
    flags: uint32 = cast[uint32](a1)
    mask: uint64 = a2
    # FAN_MARK_FLUSH ignores mask + path.
    if (flags & FAN_MARK_FLUSH) != 0:
        return _fan_mark_flush(grp)
    # Must be exactly one of ADD / REMOVE.
    is_add: int32 = 0
    is_rm: int32 = 0
    if (flags & FAN_MARK_ADD) != 0:
        is_add = 1
    if (flags & FAN_MARK_REMOVE) != 0:
        is_rm = 1
    if is_add == is_rm:
        set_current_errstr("fanotify_mark: need exactly one ADD/REMOVE")
        return ELINUX_INVAL
    # Reject masks we cannot source from the inode-event hook.
    if (mask & (~FAN_SOURCEABLE)) != 0:
        set_current_errstr("fanotify_mark: unsupported mask bit")
        return ELINUX_INVAL
    if mask == 0:
        set_current_errstr("fanotify_mark: empty mask")
        return ELINUX_INVAL
    # Resolve the path to an absolute dir, matching the notify hook's key.
    # (a4 is `pathname`; dirfd (a3) is treated as AT_FDCWD here.)
    upath: Array[256, uint8]
    pin: int64 = _u_copyin_path(a4, &upath[0])
    if pin != 0:
        set_current_errstr("fanotify_mark: bad path pointer")
        return pin
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](&upath[0]), &abs_path[0], 256)
    if rc != 0:
        set_current_errstr("fanotify_mark: path too long")
        return ELINUX_INVAL
    if is_add != 0:
        return _fan_mark_add(grp, &abs_path[0], mask)
    return _fan_mark_remove(grp, &abs_path[0], mask)


# --- epoll -----------------------------------------------------------

def _u_epoll_create1(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int epoll_create1(int flags) — flags: EPOLL_CLOEXEC only.
    es: int32 = uepoll_alloc()
    if es < 0:
        set_current_errstr("epoll_create: object pool exhausted")
        return ELINUX_MFILE
    fd: int32 = vfs_alloc_l2_fd(FD_EPOLL_MARK)
    if fd < 0:
        set_current_errstr("epoll_create: out of fd slots")
        return ELINUX_MFILE
    if vfs_l2_fd_set_buf(fd, cast[uint64](es + 1)) != 0:
        vfs_close(fd)
        return ELINUX_BADF
    # O_CLOEXEC (EPOLL_CLOEXEC bit == 0x80000, in a0): close this
    # object fd at the next execve.
    _u_apply_cloexec_flags(fd, a0)
    return cast[int64](fd)


def _u_epoll_create(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int epoll_create(int size) — `size` is a historical hint, ignored.
    return _u_epoll_create1(0, a1, a2, a3, a4, a5)


def _u_epoll_ctl(a0: uint64, a1: uint64, a2: uint64,
                 a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int epoll_ctl(int epfd, int op, int fd, struct epoll_event *event)
    # struct epoll_event { uint32 events; uint64 data; } — PACKED on
    # x86_64 (12 bytes): events at offset 0, data at offset 4.
    epfd: int32 = cast[int32](a0)
    op:   uint32 = cast[uint32](a1)
    fd:   int32 = cast[int32](a2)
    if vfs_fd_marker(epfd) != FD_EPOLL_MARK:
        return ELINUX_BADF
    es: int32 = cast[int32](vfs_l2_fd_get_buf(epfd)) - 1
    if uepoll_valid(es) == 0:
        return ELINUX_BADF
    # A fd can't watch itself, and the watched fd must be open.
    if fd == epfd:
        return ELINUX_INVAL
    if op != EPOLL_CTL_DEL:
        if vfs_fd_is_open(fd) == 0:
            return ELINUX_BADF
    events: uint32 = 0
    data0:  uint64 = 0
    if a3 != 0:
        # #163: the packed 12-byte epoll_event is staged through
        # copy_from_user (the 8-byte data field at offset 4 is
        # unaligned and may straddle a page — copy_from_user re-walks
        # at the boundary; a single get_user_64 could not).
        eev: Array[12, uint8]
        if copy_from_user(cast[uint64](&eev[0]), a3, 12) != 0:
            return ELINUX_EFAULT
        events = cast[Ptr[uint32]](&eev[0])[0]
        ed_i: uint64 = 0
        while ed_i < 8:
            data0 = data0 | (cast[uint64](eev[4 + ed_i]) << (ed_i * 8))
            ed_i = ed_i + 1
    if op == EPOLL_CTL_ADD:
        return uepoll_ctl_add(es, fd, events, data0)
    if op == EPOLL_CTL_MOD:
        return uepoll_ctl_mod(es, fd, events, data0)
    if op == EPOLL_CTL_DEL:
        return uepoll_ctl_del(es, fd)
    return ELINUX_INVAL


def _u_epoll_scan(es: int32, out_events: uint64,
                  maxevents: int32) -> int64:
    # One non-blocking pass over an epoll object's interest list. For
    # each live+enabled slot: probe the watched fd's readiness, AND it
    # with the requested mask, and on a hit write one struct
    # epoll_event to the caller's array. Returns the number of ready
    # fds written (>= 0). EPOLLONESHOT slots that fire are auto-disabled.
    nready: int64 = 0
    imax: uint64 = uepoll_interest_max()
    i: uint64 = 0
    while i < imax:
        if nready >= cast[int64](maxevents):
            break
        if uepoll_intr_slot_live(es, i) != 0:
            wfd:  int32 = uepoll_intr_fd_at(es, i)
            want: uint32 = uepoll_intr_ev_at(es, i)
            data0: uint64 = uepoll_intr_data_at(es, i)
            # Readiness via the SAME shim helper poll(2)/ppoll/select use
            # (_u_poll_fd_revents), NOT a raw vfs_fd_poll. This is load-
            # bearing for Layer-2 fd families whose readiness vfs.ad cannot
            # see: signalfd (needs the caller's pending-signal word), pidfd,
            # AF_NETLINK, and — critically — AF_UNIX. An AF_UNIX fd_buf
            # carries the AFU_FDBUF_TAG, so vfs_fd_poll's DEV_SOCKET arm
            # decodes a bogus usock record and can NEVER report POLLIN for
            # it. A real libwayland toytoolkit client (weston-terminal) runs
            # its main loop on epoll_wait over the display fd; probing that
            # fd with raw vfs_fd_poll never signals the queued xdg configure
            # / frame / input events, so the client maps its xdg_toplevel
            # then blocks forever without ever acking configure or attaching
            # a render buffer. _u_poll_fd_revents pumps the in-kernel Wayland
            # server and consults afunix_can_read, exactly as poll(2) does —
            # the fix that already unwedged the poll(2)-based clients. Its
            # bit layout (POLLIN/OUT/ERR/HUP) coincides with EPOLL*, and it
            # masks readiness with the requested `want` while always passing
            # the error bits, matching epoll semantics.
            revents: uint32 = _u_poll_fd_revents(wfd, want)
            if revents != 0:
                rec: uint64 = out_events + cast[uint64](nready) * 12
                # SMAP: the epoll_event[] array is user memory (US=1) —
                # bracket the CPL=0 stores.
                _ua_stac()
                cast[Ptr[uint32]](rec)[0]     = revents
                cast[Ptr[uint64]](rec + 4)[0] = data0
                _ua_clac()
                nready = nready + 1
                if (want & EPOLLONESHOT) != 0:
                    uepoll_oneshot_disable(es, i)
        i = i + 1
    return nready


def _u_epoll_wait(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int epoll_wait(int epfd, struct epoll_event *events,
    #                int maxevents, int timeout)
    # timeout: -1 == block indefinitely, 0 == return immediately,
    # >0 == milliseconds. Level-triggered. We yield-spin until a fd is
    # ready or the deadline passes (bounded — see UEP_WAIT_MAX_JIFFIES).
    epfd: int32 = cast[int32](a0)
    out:  uint64 = a1
    maxevents: int32 = cast[int32](a2)
    timeout_ms: int64 = cast[int64](a3)
    if vfs_fd_marker(epfd) != FD_EPOLL_MARK:
        return ELINUX_BADF
    es: int32 = cast[int32](vfs_l2_fd_get_buf(epfd)) - 1
    if uepoll_valid(es) == 0:
        return ELINUX_BADF
    if maxevents <= 0 or out == 0:
        return ELINUX_INVAL
    # Compute the absolute deadline in jiffies.
    deadline: uint64 = 0
    bounded: int32 = 1
    start: uint64 = get_jiffies()
    if timeout_ms < 0:
        # Infinite: cap at UEP_WAIT_MAX_JIFFIES so a daemon with no
        # ready fd can't wedge the cooperative scheduler forever.
        deadline = start + UEP_WAIT_MAX_JIFFIES
    elif timeout_ms == 0:
        bounded = 0                       # single non-blocking pass
    else:
        # ms -> jiffies (HZ=100 -> 10 ms/jiffy). Round up.
        dj: uint64 = (cast[uint64](timeout_ms) * HZ + 999) / 1000
        if dj > UEP_WAIT_MAX_JIFFIES:
            dj = UEP_WAIT_MAX_JIFFIES
        deadline = start + dj
    while True:
        n: int64 = _u_epoll_scan(es, out, maxevents)
        if n > 0:
            return n
        if bounded == 0:
            return 0                      # timeout == 0: immediate return
        if get_jiffies() >= deadline:
            return 0                      # timed out, nothing ready
        yield_to_others()


def _u_epoll_pwait(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    # epoll_pwait(epfd, events, maxevents, timeout, sigmask) — the
    # sigmask arg lets a daemon atomically swap its signal mask for the
    # wait. Hamnix delivers signals cooperatively at the syscall
    # boundary, so the atomic-swap race epoll_pwait guards against can't
    # occur here — forward to epoll_wait, ignoring sigmask.
    return _u_epoll_wait(a0, a1, a2, a3, a4, a5)


# =====================================================================
# U-ABI fills boot self-test
# =====================================================================
#
# Gated by /etc/uabi-fills-test (planted by build_initramfs.py when
# ENABLE_UABI_FILLS_TEST=1) and driven from init/main.ad's boot:37.uaf
# hook. Exercises each newly-filled Linux-ABI syscall through the real
# in-kernel dispatch entry (linux_u_syscall_dispatch), the exact path a
# Debian/glibc binary takes, and prints a single PASS / FAIL line on the
# EMERG serial channel. A default boot ships no marker, so this never
# runs in production.


def _uabi_test_dispatch(nr: uint64, a0: uint64, a1: uint64, a2: uint64,
                        a3: uint64) -> int64:
    # Thin wrapper so the self-test reads as syscall(nr, args...).
    return linux_u_syscall_dispatch(nr, a0, a1, a2, a3, 0, 0)


def uabi_fills_selftest() -> int32:
    # Returns 0 on PASS, non-zero on the first failed assertion. Each
    # block targets one filled syscall.

    # The boot task that runs this hook (boot:37.uaf, inside start_kernel)
    # has an UNINITIALISED fd table — per-task fd tables are only primed
    # by create_user_task / kthread_create, neither of which has run for
    # the bootstrap context. _alloc_fd then finds no FD_CLOSED_MARK slot
    # and every vfs_open returns -EMFILE. So before the newfstatat /
    # pwrite blocks (which open files) we mark fd slots 3..15 free. We
    # snapshot the original slot values and restore them at the end so
    # nothing downstream sees a mutated table. Slots 0..2 (stdio) are
    # left untouched.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    # --- arch_prctl ARCH_SET_FS / ARCH_GET_FS roundtrip ---------------
    # SET a sentinel FS_BASE, then GET it back into a scratch slot and
    # confirm the value survives. We restore the original FS_BASE at the
    # end so the running task's TLS pointer is untouched.
    fs_saved: Array[1, uint64]
    fs_saved[0] = 0
    if _uabi_test_dispatch(SYS_arch_prctl, ARCH_GET_FS,
                           cast[uint64](&fs_saved[0]), 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL arch_prctl GET_FS(initial)\n")
        return 1
    fs_sentinel: uint64 = 0x00007FFFDEAD0000
    if _uabi_test_dispatch(SYS_arch_prctl, ARCH_SET_FS,
                           fs_sentinel, 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL arch_prctl SET_FS\n")
        return 1
    fs_got: Array[1, uint64]
    fs_got[0] = 0
    if _uabi_test_dispatch(SYS_arch_prctl, ARCH_GET_FS,
                           cast[uint64](&fs_got[0]), 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL arch_prctl GET_FS\n")
        return 1
    if fs_got[0] != fs_sentinel:
        printk1("[UABI_FILLS] FAIL arch_prctl roundtrip got=%x\n",
                fs_got[0])
        return 1
    # Restore the real FS_BASE before any further glibc-style %fs deref.
    _uabi_test_dispatch(SYS_arch_prctl, ARCH_SET_FS, fs_saved[0], 0, 0)

    # --- QA-N10: setuid(2)/setgid(2) semantics + getter consistency ---
    # No fds are involved, so this arm runs early (right after arch_prctl)
    # and is independent of the fd-table dance. The boot task runs as the
    # hostowner (native UID_HOSTOWNER -> Linux 0, i.e. root). We snapshot
    # its native uid/gid, exercise every arm through the real dispatch —
    # proving nr=105/106 no longer hit the "unknown syscall" -ENOSYS path —
    # and restore the identity before returning.
    suid_save: uint32 = current_task_uid()
    sgid_save: uint32 = current_task_gid()
    # (a) root may drop to an arbitrary uid; getuid/geteuid must reflect it.
    if _uabi_test_dispatch(SYS_setuid, 1001, 0, 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL setuid(1001) as root\n")
        set_current_task_uid(suid_save)
        set_current_task_gid(sgid_save)
        return 1
    if _uabi_test_dispatch(SYS_getuid, 0, 0, 0, 0) != 1001 \
       or _uabi_test_dispatch(SYS_geteuid, 0, 0, 0, 0) != 1001:
        printk0("[UABI_FILLS] FAIL getuid/geteuid != 1001 after setuid\n")
        set_current_task_uid(suid_save)
        set_current_task_gid(sgid_save)
        return 1
    # (b) the common failing case that motivated QA-N10: an unprivileged
    # process re-asserting its OWN uid must succeed with 0 (1001 -> 1001).
    if _uabi_test_dispatch(SYS_setuid, 1001, 0, 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL setuid(1001) self-reassert\n")
        set_current_task_uid(suid_save)
        set_current_task_gid(sgid_save)
        return 1
    # (c) an unprivileged escalation to uid 0 must be REFUSED with -EPERM
    # and must NOT silently succeed (uid stays 1001).
    if _uabi_test_dispatch(SYS_setuid, 0, 0, 0, 0) != ELINUX_PERM \
       or _uabi_test_dispatch(SYS_getuid, 0, 0, 0, 0) != 1001:
        printk0("[UABI_FILLS] FAIL setuid(0) escalation not refused\n")
        set_current_task_uid(suid_save)
        set_current_task_gid(sgid_save)
        return 1
    # (d) setgid mirror: as the (now unprivileged) uid 1001, setgid to the
    # caller's own gid succeeds; setgid to a different gid is -EPERM.
    cur_gid_now: int64 = _uabi_test_dispatch(SYS_getgid, 0, 0, 0, 0)
    if _uabi_test_dispatch(SYS_setgid, cast[uint64](cur_gid_now), 0, 0, 0) != 0 \
       or _uabi_test_dispatch(SYS_setgid, 4242, 0, 0, 0) != ELINUX_PERM:
        printk0("[UABI_FILLS] FAIL setgid unpriv semantics\n")
        set_current_task_uid(suid_save)
        set_current_task_gid(sgid_save)
        return 1
    # Restore hostowner uid and confirm root can setgid arbitrarily.
    set_current_task_uid(suid_save)
    if _uabi_test_dispatch(SYS_setgid, 4242, 0, 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL setgid(4242) as root\n")
        set_current_task_uid(suid_save)
        set_current_task_gid(sgid_save)
        return 1
    set_current_task_gid(sgid_save)
    printk0("[UABI_FILLS] setuid/setgid gate OK (drop/self/EPERM/consistency)\n")

    # --- tmpfs fsuid ownership + fchdir(2) ----------------------------
    # BUG1: a NON-hostowner creator must OWN the tmpfs entries it makes,
    # and fstat(2) must surface that owner (mapped native->linux) rather
    # than the old hard-coded st_uid=0. BUG2: fchdir(2) (x86_64 nr 81)
    # must resolve instead of hitting "unknown syscall". Drop this task's
    # native uid to 1001, create a fresh tmpfs file, fstat it, and assert
    # st_uid==1001; then open /tmp as a dir fd, fchdir into it, and assert
    # getcwd reports a /tmp-tailed path. Identity + cwd are restored after.
    own_uid_save: uint32 = current_task_uid()
    set_current_task_uid(1001)
    own_fd: int32 = vfs_open_write(cast[Ptr[char]]("/tmp/uabi-own"))
    if own_fd < 0:
        printk1("[UABI_FILLS] FAIL tmpfs-own open=%d\n",
                cast[uint64](cast[int64](own_fd)))
        set_current_task_uid(own_uid_save)
        return 1
    own_st: Array[160, uint8]
    if _uabi_test_dispatch(SYS_fstat, cast[uint64](own_fd),
                           cast[uint64](&own_st[0]), 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL tmpfs-own fstat\n")
        vfs_close(own_fd)
        set_current_task_uid(own_uid_save)
        return 1
    own_uid_got: uint32 = cast[Ptr[uint32]](
        cast[uint64](&own_st[0]) + ST_OFF_UID)[0]
    vfs_close(own_fd)
    if own_uid_got != 1001:
        printk1("[UABI_FILLS] FAIL tmpfs-own st_uid=%d (want 1001)\n",
                cast[uint64](own_uid_got))
        set_current_task_uid(own_uid_save)
        return 1
    printk0("[UABI_FILLS] tmpfs fsuid OK (new file owned by caller 1001)\n")
    # fchdir(2): open /tmp as a dir fd (vfs_open stamps its resolved path),
    # fchdir into it, and confirm getcwd's answer ends in "tmp".
    fchd_fd: int32 = vfs_open(cast[Ptr[char]]("/tmp"))
    if fchd_fd < 0:
        printk1("[UABI_FILLS] FAIL fchdir open /tmp=%d\n",
                cast[uint64](cast[int64](fchd_fd)))
        set_current_task_uid(own_uid_save)
        return 1
    fchd_rc: int64 = _uabi_test_dispatch(SYS_fchdir,
                                         cast[uint64](fchd_fd), 0, 0, 0)
    vfs_close(fchd_fd)
    if fchd_rc != 0:
        printk1("[UABI_FILLS] FAIL fchdir rc=%d\n", cast[uint64](fchd_rc))
        _uabi_test_dispatch(SYS_chdir, cast[uint64](
            cast[Ptr[char]]("/")), 0, 0, 0)
        set_current_task_uid(own_uid_save)
        return 1
    cwd_buf: Array[64, uint8]
    cwd_n: int64 = _uabi_test_dispatch(SYS_getcwd,
                                       cast[uint64](&cwd_buf[0]), 64, 0, 0)
    # cwd_n counts the trailing NUL; the last three chars must be 't''m''p'.
    fchd_ok: int32 = 0
    if cwd_n >= 4:
        cn: uint64 = cast[uint64](cwd_n)
        if cwd_buf[cn - 4] == 116 and cwd_buf[cn - 3] == 109 \
           and cwd_buf[cn - 2] == 112:
            fchd_ok = 1
    # Restore cwd to root and the saved identity BEFORE asserting.
    _uabi_test_dispatch(SYS_chdir, cast[uint64](cast[Ptr[char]]("/")),
                        0, 0, 0)
    set_current_task_uid(own_uid_save)
    if fchd_ok == 0:
        printk1("[UABI_FILLS] FAIL fchdir cwd not /tmp (n=%d)\n",
                cast[uint64](cwd_n))
        return 1
    printk0("[UABI_FILLS] fchdir(2) OK (nr=81 resolves; getcwd=/tmp)\n")

    # --- uname --------------------------------------------------------
    # Already a real fill; assert it returns 0 and stamps nodename.
    uts_buf: Array[400, uint8]
    if _uabi_test_dispatch(SYS_uname, cast[uint64](&uts_buf[0]),
                           0, 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL uname rc\n")
        return 1
    # nodename field sits at byte offset 65; expect 'h' 'a' 'm' ...
    if uts_buf[65] != 104 or uts_buf[66] != 97 or uts_buf[67] != 109:
        printk0("[UABI_FILLS] FAIL uname nodename\n")
        return 1

    # --- QA-N15: getgroups(2) / setgroups(2) --------------------------
    # No fds involved, so this arm is independent of the fd-table dance.
    # We model ONE supplementary group == the caller's (POSIX-mapped) gid,
    # so `id` prints a real groups= field. Exercising every arm through the
    # real dispatch proves nr=115/116 no longer hit the "unknown syscall"
    # -ENOSYS path. The boot task runs as hostowner (-> Linux root), which
    # lets us also assert setgroups' privileged-success path.
    gg_gid: int64 = _uabi_test_dispatch(SYS_getgid, 0, 0, 0, 0)
    # (a) size==0 query returns the count (1) without touching the (null) list.
    if _uabi_test_dispatch(SYS_getgroups, 0, 0, 0, 0) != 1:
        printk0("[UABI_FILLS] FAIL getgroups(0) count != 1\n")
        return 1
    # (b) size>=count writes the single gid and returns the count.
    gg_list: Array[4, uint32]
    gg_list[0] = 0xEEEEEEEE
    if _uabi_test_dispatch(SYS_getgroups, 4,
                           cast[uint64](&gg_list[0]), 0, 0) != 1:
        printk0("[UABI_FILLS] FAIL getgroups(4) count != 1\n")
        return 1
    if cast[int64](cast[uint32](gg_list[0])) != gg_gid:
        printk1("[UABI_FILLS] FAIL getgroups list[0]=%d != gid\n",
                cast[uint64](cast[int64](cast[uint32](gg_list[0]))))
        return 1
    # (c) a negative size is -EINVAL (ELINUX_INVAL == -22).
    if _uabi_test_dispatch(SYS_getgroups, 0xFFFFFFFFFFFFFFFF, 0, 0, 0) \
       != ELINUX_INVAL:
        printk0("[UABI_FILLS] FAIL getgroups(-1) != EINVAL\n")
        return 1
    # (d) setgroups as the privileged hostowner (root) succeeds (no-op 0).
    if _uabi_test_dispatch(SYS_setgroups, 0, 0, 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL setgroups as root != 0\n")
        return 1
    printk0("[UABI_FILLS] getgroups/setgroups gate OK (count/list/EINVAL/root)\n")

    # --- readlink /proc/self/exe -------------------------------------
    # The synthetic-target path glibc actually hits. Expect a positive
    # byte count and a leading '/'.
    rl_path: Ptr[uint8] = cast[Ptr[uint8]]("/proc/self/exe")
    rl_buf: Array[64, uint8]
    rl_n: int64 = _uabi_test_dispatch(SYS_readlink,
                                      cast[uint64](rl_path),
                                      cast[uint64](&rl_buf[0]), 64, 0)
    if rl_n <= 0:
        printk1("[UABI_FILLS] FAIL readlink rc=%d\n", cast[uint64](rl_n))
        return 1
    if rl_buf[0] != 47:                                   # '/'
        printk0("[UABI_FILLS] FAIL readlink target\n")
        return 1

    # --- newfstatat /etc/uabi-fills-test -----------------------------
    # Already a real fill; stat the planted marker via AT_FDCWD and
    # confirm rc==0 (the file exists and is statable).
    nfa_path: Ptr[uint8] = cast[Ptr[uint8]]("/etc/uabi-fills-test")
    st_buf: Array[160, uint8]
    nfa_rc: int64 = _uabi_test_dispatch(SYS_newfstatat, AT_FDCWD_U64,
                                        cast[uint64](nfa_path),
                                        cast[uint64](&st_buf[0]), 0)
    if nfa_rc != 0:
        printk1("[UABI_FILLS] FAIL newfstatat rc=%d\n", cast[uint64](nfa_rc))
        return 1

    # --- pwrite64 (positioned write, position-preserving) ------------
    # Open a fresh tmpfs file, seek to a known position, then pwrite at a
    # DIFFERENT offset and assert: (a) the byte count is right, (b) the
    # fd's own position is unchanged, (c) the bytes landed at the offset
    # (read them back via pread64).
    pw_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-pw")
    pw_fd: int32 = vfs_open_write(pw_name)
    if pw_fd < 0:
        printk1("[UABI_FILLS] FAIL pwrite open=%d\n", cast[uint64](cast[int64](pw_fd)))
        return 1
    # Lay down 16 zero bytes so there is a file to seek within.
    zero16: Array[16, uint8]
    z_i: uint64 = 0
    while z_i < 16:
        zero16[z_i] = 0
        z_i = z_i + 1
    vfs_write(pw_fd, &zero16[0], 16)
    # Park the fd position at byte 4.
    vfs_lseek(pw_fd, 4, 0)
    payload: Array[4, uint8]
    payload[0] = 65                                       # 'A'
    payload[1] = 66                                       # 'B'
    payload[2] = 67                                       # 'C'
    payload[3] = 68                                       # 'D'
    pw_n: int64 = _uabi_test_dispatch(SYS_pwrite64,
                                      cast[uint64](pw_fd),
                                      cast[uint64](&payload[0]),
                                      4, 8)                # offset 8
    if pw_n != 4:
        printk1("[UABI_FILLS] FAIL pwrite count=%d\n", cast[uint64](pw_n))
        return 1
    # Position must be unchanged (still 4) — pwrite does not move it.
    pos_after: int64 = vfs_lseek(pw_fd, 0, 1)             # SEEK_CUR
    if pos_after != 4:
        printk1("[UABI_FILLS] FAIL pwrite moved pos=%d\n", cast[uint64](pos_after))
        return 1
    # Read the 4 bytes back from offset 8 via pread64 and compare.
    rb: Array[4, uint8]
    rb[0] = 0
    rb[1] = 0
    rb[2] = 0
    rb[3] = 0
    pr_n: int64 = _uabi_test_dispatch(SYS_pread64,
                                      cast[uint64](pw_fd),
                                      cast[uint64](&rb[0]),
                                      4, 8)                # offset 8
    if pr_n != 4:
        printk1("[UABI_FILLS] FAIL pwrite readback count=%d\n", cast[uint64](pr_n))
        return 1
    if rb[0] != 65 or rb[1] != 66 or rb[2] != 67 or rb[3] != 68:
        printk0("[UABI_FILLS] FAIL pwrite readback bytes\n")
        return 1
    vfs_close(pw_fd)

    # --- #165: pwritev / preadv (positioned scatter I/O) --------------
    # Open a fresh tmpfs file, build a 2-entry iovec, pwritev it at
    # offset 0, then preadv it back into two separate buffers and assert
    # the bytes round-trip through the scatter/gather + positioned seek.
    piov_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-piov")
    piov_fd: int32 = vfs_open_write(piov_name)
    if piov_fd < 0:
        printk1("[UABI_FILLS] FAIL pwritev open=%d\n",
                cast[uint64](cast[int64](piov_fd)))
        return 1
    wseg0: Array[3, uint8]
    wseg0[0] = 88                                       # 'X'
    wseg0[1] = 89                                       # 'Y'
    wseg0[2] = 90                                       # 'Z'
    wseg1: Array[2, uint8]
    wseg1[0] = 49                                       # '1'
    wseg1[1] = 50                                       # '2'
    wiov: Array[4, uint64]                              # 2 iovec entries
    wiov[0] = cast[uint64](&wseg0[0])                   # base 0
    wiov[1] = 3                                         # len 0
    wiov[2] = cast[uint64](&wseg1[0])                   # base 1
    wiov[3] = 2                                         # len 1
    pwv_n: int64 = _uabi_test_dispatch(SYS_pwritev,
                                       cast[uint64](piov_fd),
                                       cast[uint64](&wiov[0]),
                                       2, 0)             # iovcnt=2, off=0
    if pwv_n != 5:
        printk1("[UABI_FILLS] FAIL pwritev count=%d\n", cast[uint64](pwv_n))
        return 1
    # preadv the 5 bytes back across two read segments at offset 0.
    rseg0: Array[3, uint8]
    rseg0[0] = 0
    rseg0[1] = 0
    rseg0[2] = 0
    rseg1: Array[2, uint8]
    rseg1[0] = 0
    rseg1[1] = 0
    riov: Array[4, uint64]
    riov[0] = cast[uint64](&rseg0[0])
    riov[1] = 3
    riov[2] = cast[uint64](&rseg1[0])
    riov[3] = 2
    prv_n: int64 = _uabi_test_dispatch(SYS_preadv,
                                       cast[uint64](piov_fd),
                                       cast[uint64](&riov[0]),
                                       2, 0)
    if prv_n != 5:
        printk1("[UABI_FILLS] FAIL preadv count=%d\n", cast[uint64](prv_n))
        return 1
    if rseg0[0] != 88 or rseg0[1] != 89 or rseg0[2] != 90 \
       or rseg1[0] != 49 or rseg1[1] != 50:
        printk0("[UABI_FILLS] FAIL preadv readback bytes\n")
        return 1
    vfs_close(piov_fd)

    # --- #165: faccessat2 / chmod / fchmod / chown / fchown -----------
    # faccessat2(AT_FDCWD, "/tmp/uabi-piov", F_OK) must see the file we
    # just created. chmod / chown on it succeed (single-user no-ops that
    # validate existence). fchmod / fchown need a live fd.
    fa_n: int64 = _uabi_test_dispatch(SYS_faccessat2, AT_FDCWD_U64,
                                      cast[uint64](piov_name), 0, 0)
    if fa_n != 0:
        printk1("[UABI_FILLS] FAIL faccessat2 rc=%d\n", cast[uint64](fa_n))
        return 1
    if _uabi_test_dispatch(SYS_chmod, cast[uint64](piov_name),
                           0x1ED, 0, 0) != 0:           # 0755
        printk0("[UABI_FILLS] FAIL chmod\n")
        return 1
    if _uabi_test_dispatch(SYS_chown, cast[uint64](piov_name),
                           0, 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL chown\n")
        return 1
    # chmod / chown on a missing path must surface -ENOENT.
    miss_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-nope-xyz")
    if _uabi_test_dispatch(SYS_chmod, cast[uint64](miss_name),
                           0x1ED, 0, 0) != ELINUX_NOENT:
        printk0("[UABI_FILLS] FAIL chmod missing != ENOENT\n")
        return 1
    fchm_fd: int32 = vfs_open_write(piov_name)
    if fchm_fd >= 0:
        if _uabi_test_dispatch(SYS_fchmod,
                               cast[uint64](fchm_fd), 0x1A4, 0, 0) != 0:
            printk0("[UABI_FILLS] FAIL fchmod\n")
            vfs_close(fchm_fd)
            return 1
        if _uabi_test_dispatch(SYS_fchown,
                               cast[uint64](fchm_fd), 0, 0, 0) != 0:
            printk0("[UABI_FILLS] FAIL fchown\n")
            vfs_close(fchm_fd)
            return 1
        vfs_close(fchm_fd)
    # fchmod / fchown on a closed fd must be -EBADF.
    if _uabi_test_dispatch(SYS_fchmod, 999, 0x1A4, 0, 0) != ELINUX_BADF:
        printk0("[UABI_FILLS] FAIL fchmod badfd != EBADF\n")
        return 1

    # --- #165: umask round-trip --------------------------------------
    # umask returns the previous mask: set 077, expect the 022 default
    # back; set back to 022, expect 077 back.
    old_mask: int64 = _uabi_test_dispatch(SYS_umask, 0x3F, 0, 0, 0)  # 077
    if old_mask != 0x12:                                # default 022
        printk1("[UABI_FILLS] FAIL umask old=%x\n", cast[uint64](old_mask))
        return 1
    back_mask: int64 = _uabi_test_dispatch(SYS_umask, 0x12, 0, 0, 0)  # 022
    if back_mask != 0x3F:                               # the 077 we set
        printk1("[UABI_FILLS] FAIL umask back=%x\n", cast[uint64](back_mask))
        return 1

    # --- #165: getcpu / sched_getaffinity / membarrier ----------------
    gc_cpu: Array[1, uint32]
    gc_node: Array[1, uint32]
    gc_cpu[0] = 0xFFFFFFFF
    gc_node[0] = 0xFFFFFFFF
    if _uabi_test_dispatch(SYS_getcpu, cast[uint64](&gc_cpu[0]),
                           cast[uint64](&gc_node[0]), 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL getcpu rc\n")
        return 1
    if gc_cpu[0] != 0 or gc_node[0] != 0:
        printk0("[UABI_FILLS] FAIL getcpu values\n")
        return 1
    aff_mask: Array[16, uint8]
    af_i: uint64 = 0
    while af_i < 16:
        aff_mask[af_i] = 0xFF
        af_i = af_i + 1
    aff_n: int64 = _uabi_test_dispatch(SYS_sched_getaffinity, 0, 128,
                                       cast[uint64](&aff_mask[0]), 0)
    if aff_n <= 0:
        printk1("[UABI_FILLS] FAIL sched_getaffinity n=%d\n",
                cast[uint64](aff_n))
        return 1
    if aff_mask[0] != 1 or aff_mask[1] != 0:            # CPU 0 only
        printk0("[UABI_FILLS] FAIL sched_getaffinity mask\n")
        return 1
    # membarrier QUERY returns a non-negative supported-command bitmask.
    if _uabi_test_dispatch(SYS_membarrier, 0, 0, 0, 0) < 0:
        printk0("[UABI_FILLS] FAIL membarrier query\n")
        return 1

    # --- #165: mkdirat / unlinkat (AT_FDCWD) --------------------------
    mka_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-mka")
    if _uabi_test_dispatch(SYS_mkdirat, AT_FDCWD_U64,
                           cast[uint64](mka_name), 0x1FF, 0) != 0:
        printk0("[UABI_FILLS] FAIL mkdirat\n")
        return 1
    if _uabi_test_dispatch(SYS_unlinkat, AT_FDCWD_U64,
                           cast[uint64](mka_name), 0, 0) != 0:
        printk0("[UABI_FILLS] FAIL unlinkat\n")
        return 1

    # --- #165: clock_nanosleep (zero relative duration => immediate) --
    cns_req: Array[2, uint64]
    cns_req[0] = 0                                       # tv_sec
    cns_req[1] = 0                                       # tv_nsec
    if _uabi_test_dispatch(SYS_clock_nanosleep, CLOCKID_MONOTONIC, 0,
                           cast[uint64](&cns_req[0]), 0) != 0:
        printk0("[UABI_FILLS] FAIL clock_nanosleep\n")
        return 1

    # --- unshare(CLONE_NEWNS): "Plan 9 did containers first" ----------
    # unshare(CLONE_NEWNS) must give THIS task a fresh, independent COPY
    # of its mount namespace (native Pgrp) IN PLACE. We can't observe a
    # parent across tasks from this single-task boot hook, so we assert
    # the load-bearing invariant directly: the caller's Pgrp pointer
    # CHANGES (and the new one is non-zero), and a bind in the new
    # namespace succeeds. Capture the Pgrp before/after via task_pgrp.
    uns_idx: int32 = cast[int32](current_idx_get())
    pg_before: uint64 = task_pgrp(uns_idx)
    uns_rc: int64 = _uabi_test_dispatch(SYS_unshare, CLONE_NEWNS,
                                        0, 0, 0)
    if uns_rc != 0:
        printk1("[UABI_FILLS] FAIL unshare(CLONE_NEWNS) rc=%d\n",
                cast[uint64](uns_rc))
        return 1
    pg_after: uint64 = task_pgrp(uns_idx)
    if pg_after == 0:
        printk0("[UABI_FILLS] FAIL unshare new pgrp is 0\n")
        return 1
    if pg_after == pg_before:
        printk1("[UABI_FILLS] FAIL unshare pgrp unchanged=%x\n",
                pg_after)
        return 1
    # A bind made in the FRESH namespace must succeed. Use plain
    # (non-'#') source/dest paths so mnttab_bind takes the no-freeze
    # path and returns 0 on success. This proves the cloned Pgrp's mtab
    # is live and writable post-unshare.
    bnd_dst: Ptr[uint8] = cast[Ptr[uint8]]("/ns-unshare-dst")
    bnd_src: Ptr[uint8] = cast[Ptr[uint8]]("/ns-unshare-src")
    if mnttab_bind(bnd_dst, bnd_src, 0) != 0:
        printk0("[UABI_FILLS] FAIL unshare post-bind\n")
        return 1

    # --- unshare with an UNSUPPORTED namespace bit must -EINVAL --------
    # CLONE_NEWNET (0x40000000) is explicitly out of scope; unshare must
    # strictly reject rather than silently succeed.
    uns_net: int64 = _uabi_test_dispatch(SYS_unshare, CLONE_NEWNET,
                                         0, 0, 0)
    if uns_net != ELINUX_INVAL:
        printk1("[UABI_FILLS] FAIL unshare(CLONE_NEWNET) rc=%d\n",
                cast[uint64](uns_net))
        return 1

    # --- setns(2) is registered but rejects until nsfs exists ---------
    sns_rc: int64 = _uabi_test_dispatch(SYS_setns, 3, 0, 0, 0)
    if sns_rc != ELINUX_INVAL:
        printk1("[UABI_FILLS] FAIL setns rc=%d\n", cast[uint64](sns_rc))
        return 1

    # --- copy_file_range(2): fd->fd byte copy through the VFS path -----
    # Write 8 known bytes into a source tmpfs file, copy_file_range the
    # whole lot into a fresh dest file with NULL offset pointers (so each
    # fd uses/advances its own position), then read the dest back and
    # assert byte-equality. Also assert flags!=0 is rejected -EINVAL and
    # a bad fd is -EBADF.
    cfr_src_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-cfr-src")
    cfr_src_fd: int32 = vfs_open_write(cfr_src_name)
    if cfr_src_fd < 0:
        printk1("[UABI_FILLS] FAIL copy_file_range src open=%d\n",
                cast[uint64](cast[int64](cfr_src_fd)))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    cfr_payload: Array[8, uint8]
    cfr_payload[0] = 67                                   # 'C'
    cfr_payload[1] = 70                                   # 'F'
    cfr_payload[2] = 82                                   # 'R'
    cfr_payload[3] = 33                                   # '!'
    cfr_payload[4] = 49                                   # '1'
    cfr_payload[5] = 50                                   # '2'
    cfr_payload[6] = 51                                   # '3'
    cfr_payload[7] = 52                                   # '4'
    vfs_write(cfr_src_fd, &cfr_payload[0], 8)
    vfs_lseek(cfr_src_fd, 0, 0)                           # rewind for read
    cfr_dst_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-cfr-dst")
    cfr_dst_fd: int32 = vfs_open_write(cfr_dst_name)
    if cfr_dst_fd < 0:
        printk1("[UABI_FILLS] FAIL copy_file_range dst open=%d\n",
                cast[uint64](cast[int64](cfr_dst_fd)))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # flags != 0 must be rejected before any copy.
    cfr_bad: int64 = linux_u_syscall_dispatch(SYS_copy_file_range,
                                              cast[uint64](cfr_src_fd), 0,
                                              cast[uint64](cfr_dst_fd), 0,
                                              8, 1)
    if cfr_bad != ELINUX_INVAL:
        printk1("[UABI_FILLS] FAIL copy_file_range flags rc=%d\n",
                cast[uint64](cfr_bad))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # bad fd_in must be -EBADF.
    cfr_ebadf: int64 = linux_u_syscall_dispatch(SYS_copy_file_range,
                                               cast[uint64](cast[int64](-1)), 0,
                                               cast[uint64](cfr_dst_fd), 0,
                                               8, 0)
    if cfr_ebadf != ELINUX_BADF:
        printk1("[UABI_FILLS] FAIL copy_file_range badfd rc=%d\n",
                cast[uint64](cfr_ebadf))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # The real copy: NULL offsets, both fds at position 0.
    cfr_n: int64 = linux_u_syscall_dispatch(SYS_copy_file_range,
                                            cast[uint64](cfr_src_fd), 0,
                                            cast[uint64](cfr_dst_fd), 0,
                                            8, 0)
    if cfr_n != 8:
        printk1("[UABI_FILLS] FAIL copy_file_range count=%d\n",
                cast[uint64](cfr_n))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # Read the dest back from offset 0 and compare all 8 bytes.
    vfs_lseek(cfr_dst_fd, 0, 0)
    cfr_rb: Array[8, uint8]
    cfr_ri: uint64 = 0
    while cfr_ri < 8:
        cfr_rb[cfr_ri] = 0
        cfr_ri = cfr_ri + 1
    cfr_rn: int64 = vfs_read(cfr_dst_fd, &cfr_rb[0], 8)
    if cfr_rn != 8:
        printk1("[UABI_FILLS] FAIL copy_file_range readback count=%d\n",
                cast[uint64](cfr_rn))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    cfr_ci: uint64 = 0
    while cfr_ci < 8:
        if cfr_rb[cfr_ci] != cfr_payload[cfr_ci]:
            printk1("[UABI_FILLS] FAIL copy_file_range byte mismatch idx=%d\n",
                    cfr_ci)
            _uabi_fills_restore_fds(boot_task, &fd_save[0])
            return 1
        cfr_ci = cfr_ci + 1
    vfs_close(cfr_src_fd)
    vfs_close(cfr_dst_fd)
    printk0("[copyfilerange] PASS\n")

    # --- sendfile(2): file -> file copy with an explicit *offset ------
    # Reuse the same payload shape but exercise the offset-pointer arm:
    # source file has 8 bytes, sendfile from *offset=2 for 4 bytes into a
    # dest file. Assert the count, that *offset advanced to 6, and that
    # the 4 copied bytes match source[2..5].
    sf_src_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-sf-src")
    sf_src_fd: int32 = vfs_open_write(sf_src_name)
    if sf_src_fd < 0:
        printk1("[UABI_FILLS] FAIL sendfile src open=%d\n",
                cast[uint64](cast[int64](sf_src_fd)))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    sf_payload: Array[8, uint8]
    sf_payload[0] = 83                                    # 'S'
    sf_payload[1] = 70                                    # 'F'
    sf_payload[2] = 97                                    # 'a'
    sf_payload[3] = 98                                    # 'b'
    sf_payload[4] = 99                                    # 'c'
    sf_payload[5] = 100                                   # 'd'
    sf_payload[6] = 101                                   # 'e'
    sf_payload[7] = 102                                   # 'f'
    vfs_write(sf_src_fd, &sf_payload[0], 8)
    sf_dst_name: Ptr[char] = cast[Ptr[char]]("/tmp/uabi-sf-dst")
    sf_dst_fd: int32 = vfs_open_write(sf_dst_name)
    if sf_dst_fd < 0:
        printk1("[UABI_FILLS] FAIL sendfile dst open=%d\n",
                cast[uint64](cast[int64](sf_dst_fd)))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    sf_off: Array[1, int64]
    sf_off[0] = 2                                         # start at byte 2
    sf_n: int64 = _uabi_test_dispatch(SYS_sendfile,
                                      cast[uint64](sf_dst_fd),
                                      cast[uint64](sf_src_fd),
                                      cast[uint64](&sf_off[0]),
                                      4)                   # copy 4 bytes
    if sf_n != 4:
        printk1("[UABI_FILLS] FAIL sendfile count=%d\n", cast[uint64](sf_n))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    if sf_off[0] != 6:
        printk1("[UABI_FILLS] FAIL sendfile offset adv=%d\n",
                cast[uint64](sf_off[0]))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    vfs_lseek(sf_dst_fd, 0, 0)
    sf_rb: Array[4, uint8]
    sf_rb[0] = 0
    sf_rb[1] = 0
    sf_rb[2] = 0
    sf_rb[3] = 0
    sf_rn: int64 = vfs_read(sf_dst_fd, &sf_rb[0], 4)
    if sf_rn != 4:
        printk1("[UABI_FILLS] FAIL sendfile readback count=%d\n",
                cast[uint64](sf_rn))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    if sf_rb[0] != 97 or sf_rb[1] != 98 or sf_rb[2] != 99 or sf_rb[3] != 100:
        printk0("[UABI_FILLS] FAIL sendfile readback bytes\n")
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    vfs_close(sf_src_fd)
    vfs_close(sf_dst_fd)
    printk0("[sendfile] PASS\n")

    # --- #163 EFAULT proof: a bad user pointer must NOT panic ---------
    # The whole point of the uaccess adoption is that a malformed user
    # pointer to a converted syscall now returns -EFAULT (-14) cleanly
    # instead of #PF-panicking the kernel. We pass a canonical-user but
    # UNMAPPED address (the same sentinel uaccess_smoke_test uses) to
    # three converted handlers and assert each returns -EFAULT. If any
    # raw deref had survived the migration, the kernel would fault here
    # and never print PASS.
    bad_uptr: uint64 = 0x0000666600000000           # canonical-user, unmapped
    # uname(buf=bad): copy_to_user must reject -> -EFAULT.
    ef_uname: int64 = _uabi_test_dispatch(SYS_uname, bad_uptr, 0, 0, 0)
    if ef_uname != ELINUX_EFAULT:
        printk1("[UABI_FILLS] FAIL uname EFAULT got=%d\n",
                cast[uint64](ef_uname))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # clock_gettime(CLOCK_MONOTONIC, tp=bad): put_user_64 must reject.
    ef_cgt: int64 = _uabi_test_dispatch(SYS_clock_gettime, 1, bad_uptr, 0, 0)
    if ef_cgt != ELINUX_EFAULT:
        printk1("[UABI_FILLS] FAIL clock_gettime EFAULT got=%d\n",
                cast[uint64](ef_cgt))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # newfstatat(AT_FDCWD, path=bad): strncpy_from_user path copy-in must
    # reject the unmapped path pointer -> -EFAULT.
    ef_stat_buf: Array[160, uint8]
    ef_nfa: int64 = _uabi_test_dispatch(SYS_newfstatat, AT_FDCWD_U64,
                                        bad_uptr,
                                        cast[uint64](&ef_stat_buf[0]), 0)
    if ef_nfa != ELINUX_EFAULT:
        printk1("[UABI_FILLS] FAIL newfstatat EFAULT got=%d\n",
                cast[uint64](ef_nfa))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    printk0("[UABI_FILLS] EFAULT-proof OK (uname/clock_gettime/newfstatat)\n")

    # --- openat2 / memfd_secret / mount_setattr / new-mount-API ------
    # Bad-input gates: every new handler must reject malformed input
    # with the documented negative errno rather than dispatching as
    # -ENOSYS. We hit the error path on purpose so the assertion does
    # not depend on a working filesystem (the boot self-test runs
    # before the user fd table is primed).
    #
    # openat2: a size < min(open_how) is -EINVAL.
    bad_oh: Array[24, uint8]
    oa2_bad: int64 = _uabi_test_dispatch(SYS_openat2, AT_FDCWD_U64,
                                          cast[uint64](&bad_oh[0]), 4)
    if oa2_bad != ELINUX_INVAL:
        printk1("[UABI_FILLS] FAIL openat2 EINVAL got=%d\n",
                cast[uint64](oa2_bad))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # openat2: a NULL pathname is -EFAULT.
    oh_buf: Array[24, uint8]
    j_oh: uint64 = 0
    while j_oh < 24:
        oh_buf[j_oh] = 0
        j_oh = j_oh + 1
    oa2_null: int64 = _uabi_test_dispatch(SYS_openat2, AT_FDCWD_U64,
                                           0, cast[uint64](&oh_buf[0]))
    if oa2_null != ELINUX_EFAULT:
        printk1("[UABI_FILLS] FAIL openat2 EFAULT got=%d\n",
                cast[uint64](oa2_null))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    printk0("[UABI_FILLS] openat2 gate OK (EINVAL/EFAULT)\n")

    # memfd_secret: an unknown flag bit is -EINVAL.
    mfs_bad: int64 = _uabi_test_dispatch(SYS_memfd_secret, 0xDEADBEEF,
                                          0, 0)
    if mfs_bad != ELINUX_INVAL:
        printk1("[UABI_FILLS] FAIL memfd_secret EINVAL got=%d\n",
                cast[uint64](mfs_bad))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    printk0("[UABI_FILLS] memfd_secret gate OK (EINVAL)\n")

    # mount_setattr: a NULL attr pointer is -EFAULT.
    msa_null: int64 = _uabi_test_dispatch(SYS_mount_setattr, AT_FDCWD_U64,
                                           0, 0)
    if msa_null != ELINUX_EFAULT:
        printk1("[UABI_FILLS] FAIL mount_setattr EFAULT got=%d\n",
                cast[uint64](msa_null))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # mount_setattr: a size < min(struct mount_attr) is -EINVAL.
    msa_attr: Array[32, uint8]
    j_msa: uint64 = 0
    while j_msa < 32:
        msa_attr[j_msa] = 0
        j_msa = j_msa + 1
    msa_short: int64 = linux_u_syscall_dispatch(SYS_mount_setattr,
                                                 AT_FDCWD_U64, 0, 0,
                                                 cast[uint64](&msa_attr[0]),
                                                 8, 0)
    if msa_short != ELINUX_INVAL:
        printk1("[UABI_FILLS] FAIL mount_setattr size-EINVAL got=%d\n",
                cast[uint64](msa_short))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    printk0("[UABI_FILLS] mount_setattr gate OK (EFAULT/EINVAL)\n")

    # fsopen: a NULL fstype pointer is -EFAULT.
    fso_null: int64 = _uabi_test_dispatch(SYS_fsopen, 0, 0, 0)
    if fso_null != ELINUX_EFAULT:
        printk1("[UABI_FILLS] FAIL fsopen EFAULT got=%d\n",
                cast[uint64](fso_null))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # fsconfig: an invalid fd is -EBADF.
    fsc_bad: int64 = _uabi_test_dispatch(SYS_fsconfig, 999, 0, 0)
    if fsc_bad != cast[int64](-9):
        printk1("[UABI_FILLS] FAIL fsconfig EBADF got=%d\n",
                cast[uint64](fsc_bad))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # fsmount: an invalid fd is -EBADF.
    fsm_bad: int64 = _uabi_test_dispatch(SYS_fsmount, 999, 0, 0)
    if fsm_bad != cast[int64](-9):
        printk1("[UABI_FILLS] FAIL fsmount EBADF got=%d\n",
                cast[uint64](fsm_bad))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    # move_mount: an invalid flags bit is -EINVAL.
    mvm_bad: int64 = linux_u_syscall_dispatch(SYS_move_mount,
                                                AT_FDCWD_U64, 0,
                                                AT_FDCWD_U64, 0,
                                                0xDEADBEEF, 0)
    if mvm_bad != ELINUX_INVAL:
        printk1("[UABI_FILLS] FAIL move_mount EINVAL got=%d\n",
                cast[uint64](mvm_bad))
        _uabi_fills_restore_fds(boot_task, &fd_save[0])
        return 1
    printk0("[UABI_FILLS] new-mount-API gate OK (fsopen/fsconfig/fsmount/move_mount)\n")

    # Restore the boot task's original fd slots so the table looks
    # untouched to anything that runs after this hook.
    _uabi_fills_restore_fds(boot_task, &fd_save[0])

    printk0("[UABI_FILLS] PASS\n")
    return 0


def _uabi_fills_restore_fds(boot_task: Ptr[TaskStruct],
                            fd_save: Ptr[uint32]):
    # Restore boot-task fd slots 3..15 the selftest temporarily freed.
    fdr: uint64 = 3
    while fdr < 16:
        boot_task[0].fd_idx[fdr] = fd_save[fdr]
        fdr = fdr + 1


# =====================================================================
# #165: PTY (pseudo-terminal) self-test
#   (gated on /etc/pty-test, ENABLE_PTY_TEST=1)
# =====================================================================
#
# Drives the full ptmx/pts data + control path through the REAL in-kernel
# Linux-ABI dispatch (linux_u_syscall_dispatch — the exact path a Linux
# tmux / sshd-spawned pty takes):
#   1. openat(/dev/ptmx, O_RDWR)            -> master fd
#   2. ioctl(master, TIOCGPTN, &n)          -> slave index N
#   3. ioctl(master, TIOCSPTLCK, &0)        -> unlock the slave
#   4. (locked-slave open before unlock fails -EIO)  [tested first]
#   5. openat(/dev/pts/N, O_RDWR)           -> slave fd
#   6. write(master, "hi\n")                -> feeds slave input
#   7. read(slave, ...)  (cooked)           -> returns "hi\n"
#   8. read(master, ...)                    -> the ECHO "hi\n"
#   9. write(slave, "OK\n")                 -> program output
#  10. read(master, ...)                    -> "OK\r\n" (ONLCR)
#  11. raw-mode (TCSETS clears ICANON|ECHO): write+read passes bytes
#      through with NO echo and NO line assembly.
# Prints a single "[PTY] PASS" / "[PTY] FAIL ..." on the EMERG serial
# channel. A default boot ships no marker, so this never runs.

O_RDWR_U64: uint64 = 2

# c_lflag bits (mirror u_termios.ad) for the raw-mode TCSETS leg.
PTYT_ICANON: uint32 = 0x0002
PTYT_ECHO:   uint32 = 0x0008


def pty_selftest() -> int32:
    # Prime the boot task's fd table (same uninitialised-table issue the
    # uabi_fills / statfs hooks handle) so the open legs can grab fds.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    # --- 1. open /dev/ptmx -> master fd ------------------------------
    ptmx_path: Ptr[uint8] = cast[Ptr[uint8]]("/dev/ptmx")
    master_fd: int64 = _uabi_test_dispatch(SYS_openat, AT_FDCWD_U64,
                                           cast[uint64](ptmx_path),
                                           O_RDWR_U64, 0)
    if master_fd < 0:
        printk1("[PTY] FAIL open ptmx rc=%d\n", cast[uint64](master_fd))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 2. TIOCGPTN -> slave index N --------------------------------
    ptn: Array[1, uint32]
    ptn[0] = 0xFFFFFFFF
    gptn_rc: int64 = _uabi_test_dispatch(SYS_ioctl,
                                         cast[uint64](master_fd),
                                         0x80045430,            # TIOCGPTN
                                         cast[uint64](&ptn[0]), 0)
    if gptn_rc != 0:
        printk1("[PTY] FAIL TIOCGPTN rc=%d\n", cast[uint64](gptn_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    slave_n: uint64 = cast[uint64](ptn[0])

    # --- 4. a locked slave open must fail -EIO (BEFORE unlock) -------
    # Build "/dev/pts/<N>" into a scratch buffer.
    pts_path: Array[24, uint8]
    _pty_build_pts_path(&pts_path[0], slave_n)
    locked_open: int64 = _uabi_test_dispatch(SYS_openat, AT_FDCWD_U64,
                                             cast[uint64](&pts_path[0]),
                                             O_RDWR_U64, 0)
    if locked_open >= 0:
        printk0("[PTY] FAIL locked slave open succeeded (want -EIO)\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 3. TIOCSPTLCK(&0) -> unlock ---------------------------------
    lock0: Array[1, uint32]
    lock0[0] = 0
    sptl_rc: int64 = _uabi_test_dispatch(SYS_ioctl,
                                         cast[uint64](master_fd),
                                         0x40045431,            # TIOCSPTLCK
                                         cast[uint64](&lock0[0]), 0)
    if sptl_rc != 0:
        printk1("[PTY] FAIL TIOCSPTLCK rc=%d\n", cast[uint64](sptl_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 5. open /dev/pts/N -> slave fd ------------------------------
    slave_fd: int64 = _uabi_test_dispatch(SYS_openat, AT_FDCWD_U64,
                                          cast[uint64](&pts_path[0]),
                                          O_RDWR_U64, 0)
    if slave_fd < 0:
        printk1("[PTY] FAIL open pts rc=%d\n", cast[uint64](slave_fd))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 6/7. write(master,"hi\n") then cooked read(slave) -----------
    line_in: Array[3, uint8]
    line_in[0] = 104                                     # 'h'
    line_in[1] = 105                                     # 'i'
    line_in[2] = 10                                      # '\n'
    mw_n: int64 = _uabi_test_dispatch(SYS_write,
                                      cast[uint64](master_fd),
                                      cast[uint64](&line_in[0]), 3, 0)
    if mw_n != 3:
        printk1("[PTY] FAIL master write count=%d\n", cast[uint64](mw_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    sr_buf: Array[16, uint8]
    sr_n: int64 = _uabi_test_dispatch(SYS_read,
                                      cast[uint64](slave_fd),
                                      cast[uint64](&sr_buf[0]), 16, 0)
    if sr_n != 3:
        printk1("[PTY] FAIL slave cooked read count=%d\n", cast[uint64](sr_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if sr_buf[0] != 104 or sr_buf[1] != 105 or sr_buf[2] != 10:
        printk0("[PTY] FAIL slave cooked read bytes\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 8. read(master) -> the ECHO of "hi\n" -----------------------
    # ECHO produced "h" "i" "\n" into the master read queue during the
    # cooked slave read above.
    ce_buf: Array[16, uint8]
    ce_n: int64 = _uabi_test_dispatch(SYS_read,
                                      cast[uint64](master_fd),
                                      cast[uint64](&ce_buf[0]), 16, 0)
    if ce_n != 3:
        printk1("[PTY] FAIL master echo read count=%d\n", cast[uint64](ce_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if ce_buf[0] != 104 or ce_buf[1] != 105 or ce_buf[2] != 10:
        printk0("[PTY] FAIL master echo bytes\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 9/10. write(slave,"OK\n") then read(master) -> "OK\r\n" -----
    # OPOST|ONLCR is on by default, so '\n' becomes CR+LF on the master.
    out_line: Array[3, uint8]
    out_line[0] = 79                                     # 'O'
    out_line[1] = 75                                     # 'K'
    out_line[2] = 10                                     # '\n'
    sw_n: int64 = _uabi_test_dispatch(SYS_write,
                                      cast[uint64](slave_fd),
                                      cast[uint64](&out_line[0]), 3, 0)
    if sw_n != 3:
        printk1("[PTY] FAIL slave write count=%d\n", cast[uint64](sw_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    mo_buf: Array[16, uint8]
    mo_n: int64 = _uabi_test_dispatch(SYS_read,
                                      cast[uint64](master_fd),
                                      cast[uint64](&mo_buf[0]), 16, 0)
    if mo_n != 4:
        printk1("[PTY] FAIL master out read count=%d (want 4 CRLF)\n",
                cast[uint64](mo_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if mo_buf[0] != 79 or mo_buf[1] != 75 or mo_buf[2] != 13 \
            or mo_buf[3] != 10:
        printk0("[PTY] FAIL master out bytes (want O K CR LF)\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 11. raw mode: TCSETS clears ICANON|ECHO on the slave --------
    # Fetch the pair's termios, clear ICANON|ECHO, set it back, then
    # confirm a master write reaches the slave read RAW with NO echo and
    # NO line assembly (a single byte returns immediately, no '\n' needed).
    tio: Array[36, uint8]
    g_rc: int64 = _uabi_test_dispatch(SYS_ioctl, cast[uint64](slave_fd),
                                      0x5401,                  # TCGETS
                                      cast[uint64](&tio[0]), 0)
    if g_rc != 0:
        printk1("[PTY] FAIL slave TCGETS rc=%d\n", cast[uint64](g_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # c_lflag is at byte offset 12 (u32). Clear ICANON|ECHO.
    lflag: uint32 = cast[Ptr[uint32]](cast[uint64](&tio[0]) + 12)[0]
    lflag = lflag & ~(PTYT_ICANON | PTYT_ECHO)
    cast[Ptr[uint32]](cast[uint64](&tio[0]) + 12)[0] = lflag
    s_rc: int64 = _uabi_test_dispatch(SYS_ioctl, cast[uint64](slave_fd),
                                      0x5402,                  # TCSETS
                                      cast[uint64](&tio[0]), 0)
    if s_rc != 0:
        printk1("[PTY] FAIL slave TCSETS rc=%d\n", cast[uint64](s_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # Master writes a single raw byte 'X' (no newline). Cooked mode would
    # block waiting for '\n'; raw mode returns it immediately.
    rawb: Array[1, uint8]
    rawb[0] = 88                                         # 'X'
    rw_n: int64 = _uabi_test_dispatch(SYS_write, cast[uint64](master_fd),
                                      cast[uint64](&rawb[0]), 1, 0)
    if rw_n != 1:
        printk1("[PTY] FAIL raw master write count=%d\n", cast[uint64](rw_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    rr_buf: Array[4, uint8]
    rr_n: int64 = _uabi_test_dispatch(SYS_read, cast[uint64](slave_fd),
                                      cast[uint64](&rr_buf[0]), 4, 0)
    if rr_n != 1 or rr_buf[0] != 88:
        printk1("[PTY] FAIL raw slave read count=%d\n", cast[uint64](rr_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # Raw mode has ECHO cleared, so the master read queue must be EMPTY
    # (a non-blocking master read returns 0). Use the vfs non-blocking
    # peek to avoid a block: there should be nothing echoed.
    if pty_master_readable(cast[int32](slave_n)) != 0:
        printk0("[PTY] FAIL raw mode produced echo (want none)\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 8(close). close both ends -----------------------------------
    _uabi_test_dispatch(SYS_close, cast[uint64](slave_fd), 0, 0, 0)
    _uabi_test_dispatch(SYS_close, cast[uint64](master_fd), 0, 0, 0)
    # After both closes the pair must be free again (reusable).
    if pty_valid(cast[int32](slave_n)) != 0:
        printk0("[PTY] FAIL pair not freed after dual close\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    _pty_selftest_restore(boot_task, &fd_save[0])
    printk0("[PTY] PASS\n")
    return 0


# =====================================================================
# Landlock LSM self-test — enforcement half  (boot:37.landlock)
# =====================================================================
#
# Proves the Landlock filter genuinely gates REAL open() calls. It lives here
# (not in the linux_abi/u_landlock.ad leaf) because driving the dispatch needs
# _uabi_test_dispatch, which a leaf cannot import without a circular dependency
# (the same reason pty_selftest lives here). The leaf owns the self-contained
# parts (ABI version probe + malformed-create EINVAL + ruleset build/restrict);
# this entry stitches them together with the dispatch-driven open checks.
#
# Steps:
#   (A) leaf: ABI version probe > 0; (B) malformed create -> EINVAL.
#   (C) leaf: create a ruleset handling READ_FILE, add a PATH_BENEATH rule
#       allowing READ under /etc/landlock-allowed, restrict self.
#   (D) open /etc/landlock-allowed/data (allowed)            -> SUCCEEDS.
#   (E) open /etc/landlock-denied/data  (exists, NOT covered) -> -EACCES.
#       The denied file genuinely exists, so the deny is the RULESET, not
#       ENOENT — proving the rules truly gate the open.
#
# Returns 1 on PASS, 0 on any failure (matching caps_selftest's convention).
# The boot task's fd table is uninitialised (only create_user_task /
# kthread_create prime it), so free fd slots 3..15 before any open and restore
# them after — the same snapshot/restore dance pty_selftest uses.
def landlock_selftest() -> int32:
    landlock_init()

    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    ll_fd_save: Array[16, uint32]
    ll_fdi: uint64 = 3
    while ll_fdi < 16:
        ll_fd_save[ll_fdi] = boot_task[0].fd_idx[ll_fdi]
        boot_task[0].fd_idx[ll_fdi] = FD_CLOSED_MARK
        ll_fdi = ll_fdi + 1

    rc: int32 = _landlock_selftest_body()

    # Restore the boot task's original fd-table slots (3..15) and clear the
    # task's active restriction so nothing downstream is left sandboxed.
    ll_rfdi: uint64 = 3
    while ll_rfdi < 16:
        boot_task[0].fd_idx[ll_rfdi] = ll_fd_save[ll_rfdi]
        ll_rfdi = ll_rfdi + 1
    landlock_clear_active()
    return rc


def _landlock_selftest_body() -> int32:
    # --- (A)+(B): leaf-owned version + malformed-create checks ----------
    if landlock_check_version_and_einval() != 1:
        return 0

    # --- (C): leaf builds + restricts a real READ-under-allowed ruleset -
    rs_fd64: int64 = landlock_build_test_ruleset()
    if rs_fd64 < 0:
        return 0
    rs_fd: int32 = cast[int32](rs_fd64)

    # --- (D): open an ALLOWED path -> succeeds --------------------------
    allowed_path: Ptr[uint8] = cast[Ptr[uint8]]("/etc/landlock-allowed/data")
    ok_fd: int64 = _uabi_test_dispatch(SYS_openat, AT_FDCWD_U64,
                                       cast[uint64](allowed_path), 0, 0)
    if ok_fd < 0:
        printk1("[landlock] FAIL allowed open rc=%d (want >=0)\n",
                cast[uint64](ok_fd))
        vfs_close(rs_fd)
        return 0
    _uabi_test_dispatch(SYS_close, cast[uint64](ok_fd), 0, 0, 0)
    printk0("[LANDLOCK] PASS open under allowed dir succeeded\n")

    # --- (E): open a NON-allowed (but existing) path -> EACCES ----------
    denied_path: Ptr[uint8] = cast[Ptr[uint8]]("/etc/landlock-denied/data")
    deny_fd: int64 = _uabi_test_dispatch(SYS_openat, AT_FDCWD_U64,
                                         cast[uint64](denied_path), 0, 0)
    if deny_fd != LL_EACCES:
        printk1("[landlock] FAIL denied open rc=%d (want EACCES -13)\n",
                cast[uint64](deny_fd))
        if deny_fd >= 0:
            _uabi_test_dispatch(SYS_close, cast[uint64](deny_fd), 0, 0, 0)
        vfs_close(rs_fd)
        return 0
    printk0("[LANDLOCK] PASS open outside allowed dir denied EACCES\n")

    # Sanity: the denied file genuinely EXISTS — temporarily lift the
    # restriction and confirm the open SUCCEEDS, proving the EACCES above was
    # the ruleset, not a missing file. Re-arm the restriction afterwards is
    # not possible (one-way), so we clear-then-reopen-then-the-body-ends; the
    # final landlock_clear_active in landlock_selftest handles teardown.
    landlock_clear_active()
    exists_fd: int64 = _uabi_test_dispatch(SYS_openat, AT_FDCWD_U64,
                                           cast[uint64](denied_path), 0, 0)
    if exists_fd < 0:
        printk1("[landlock] FAIL denied file missing rc=%d (test setup bug)\n",
                cast[uint64](exists_fd))
        vfs_close(rs_fd)
        return 0
    _uabi_test_dispatch(SYS_close, cast[uint64](exists_fd), 0, 0, 0)
    printk0("[LANDLOCK] PASS denied path exists (EACCES was the ruleset)\n")

    # Tidy: drop the per-fd record + the ruleset fd.
    landlock_close_fd(current_idx_get(), rs_fd)
    vfs_close(rs_fd)

    printk0("[landlock] PASS\n")
    return 1


def _pty_build_pts_path(dst: Ptr[uint8], n: uint64):
    # Write "/dev/pts/<n>\0" into dst (n < 100 covers the 16-pair pool).
    dst[0] = 47                                          # '/'
    dst[1] = 100                                         # 'd'
    dst[2] = 101                                         # 'e'
    dst[3] = 118                                         # 'v'
    dst[4] = 47                                          # '/'
    dst[5] = 112                                         # 'p'
    dst[6] = 116                                         # 't'
    dst[7] = 115                                         # 's'
    dst[8] = 47                                          # '/'
    p: uint64 = 9
    if n >= 10:
        dst[p] = cast[uint8](48 + ((n / 10) % 10))
        p = p + 1
    dst[p] = cast[uint8](48 + (n % 10))
    p = p + 1
    dst[p] = 0


def _pty_selftest_restore(boot_task: Ptr[TaskStruct], fd_save: Ptr[uint32]):
    fdr: uint64 = 3
    while fdr < 16:
        boot_task[0].fd_idx[fdr] = fd_save[fdr]
        fdr = fdr + 1


# =====================================================================
# splice(2) / tee(2) / vmsplice(2) self-test
#   (gated on /etc/splice-test, ENABLE_SPLICE_TEST=1)
# =====================================================================
#
# Drives the pipe zero-copy I/O family through the REAL in-kernel
# Linux-ABI dispatch (linux_u_syscall_dispatch — the exact path a Linux
# glibc tee / log-shipper takes):
#
#   * file -> pipe  splice : 8 bytes from a tmpfs file into a pipe, read
#                            the pipe back, byte-exact.
#   * pipe -> file  splice : 8 bytes pushed into a pipe, spliced into a
#                            fresh file with off_out, byte-exact + offset
#                            advanced.
#   * pipe -> pipe  splice : 8 bytes moved between two pipes, byte-exact,
#                            and CONSUMED from the source (read returns 0).
#   * tee                  : 8 bytes duplicated A->B leaving A intact —
#                            B reads the copy AND A still reads the same
#                            bytes afterwards.
#   * vmsplice             : a real (vaddr != phys) user buffer gathered
#                            into a pipe via copy_from_user, byte-exact.
#   * error paths          : EINVAL when neither side is a pipe; ESPIPE
#                            for an offset on the pipe side.
#
# Prints "[splice] PASS" once every assertion holds; "[splice] FAIL ..."
# on the first failure. A default boot ships no marker, so this is inert.

# Non-identity user vaddr for the vmsplice gather buffer (well above any
# identity-mapped RAM, like the uaccess smoke test's V_rw).
SPLICE_TEST_VADDR: uint64 = 0x0000557700000000


def splice_selftest() -> int32:
    # Prime the boot task's fd table (same uninitialised-table dance the
    # pty / uabi_fills hooks use) so the open / pipe legs can grab fds.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    # The 8-byte payload every leg round-trips.
    payload: Array[8, uint8]
    payload[0] = 83                                      # 'S'
    payload[1] = 80                                      # 'P'
    payload[2] = 76                                      # 'L'
    payload[3] = 105                                     # 'i'
    payload[4] = 99                                      # 'c'
    payload[5] = 101                                     # 'e'
    payload[6] = 49                                      # '1'
    payload[7] = 50                                      # '2'

    # --- 1. file -> pipe splice --------------------------------------
    fp_src_name: Ptr[char] = cast[Ptr[char]]("/tmp/splice-fp-src")
    fp_src: int32 = vfs_open_write(fp_src_name)
    if fp_src < 0:
        printk1("[splice] FAIL fp src open=%d\n",
                cast[uint64](cast[int64](fp_src)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(fp_src, &payload[0], 8)
    vfs_lseek(fp_src, 0, 0)
    fp_fds: Array[2, int32]
    if vfs_pipe(&fp_fds[0]) != 0:
        printk0("[splice] FAIL fp pipe alloc\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    fp_n: int64 = linux_u_syscall_dispatch(SYS_splice,
                                           cast[uint64](fp_src), 0,
                                           cast[uint64](fp_fds[1]), 0,
                                           8, 0)
    if fp_n != 8:
        printk1("[splice] FAIL file->pipe count=%d\n", cast[uint64](fp_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    fp_rb: Array[8, uint8]
    fp_rn: int64 = vfs_read(fp_fds[0], &fp_rb[0], 8)
    if fp_rn != 8 or _splice_bytes_eq(&fp_rb[0], &payload[0], 8) == 0:
        printk1("[splice] FAIL file->pipe readback n=%d\n", cast[uint64](fp_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_close(fp_src)
    vfs_close(fp_fds[0])
    vfs_close(fp_fds[1])
    printk0("[splice] file->pipe OK\n")

    # --- 2. pipe -> file splice (off_out pointer) --------------------
    pf_fds: Array[2, int32]
    if vfs_pipe(&pf_fds[0]) != 0:
        printk0("[splice] FAIL pf pipe alloc\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(pf_fds[1], &payload[0], 8)
    pf_dst_name: Ptr[char] = cast[Ptr[char]]("/tmp/splice-pf-dst")
    pf_dst: int32 = vfs_open_write(pf_dst_name)
    if pf_dst < 0:
        printk0("[splice] FAIL pf dst open\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    pf_off: Array[1, int64]
    pf_off[0] = 0
    pf_n: int64 = linux_u_syscall_dispatch(SYS_splice,
                                           cast[uint64](pf_fds[0]), 0,
                                           cast[uint64](pf_dst),
                                           cast[uint64](&pf_off[0]),
                                           8, 0)
    if pf_n != 8:
        printk1("[splice] FAIL pipe->file count=%d\n", cast[uint64](pf_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if pf_off[0] != 8:
        printk1("[splice] FAIL pipe->file off adv=%d\n", cast[uint64](pf_off[0]))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_lseek(pf_dst, 0, 0)
    pf_rb: Array[8, uint8]
    pf_rn: int64 = vfs_read(pf_dst, &pf_rb[0], 8)
    if pf_rn != 8 or _splice_bytes_eq(&pf_rb[0], &payload[0], 8) == 0:
        printk1("[splice] FAIL pipe->file readback n=%d\n", cast[uint64](pf_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_close(pf_dst)
    vfs_close(pf_fds[0])
    vfs_close(pf_fds[1])
    printk0("[splice] pipe->file OK\n")

    # --- 3. pipe -> pipe splice (consumes source) --------------------
    pa: Array[2, int32]
    pb: Array[2, int32]
    if vfs_pipe(&pa[0]) != 0 or vfs_pipe(&pb[0]) != 0:
        printk0("[splice] FAIL pp pipe alloc\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(pa[1], &payload[0], 8)
    pp_n: int64 = linux_u_syscall_dispatch(SYS_splice,
                                           cast[uint64](pa[0]), 0,
                                           cast[uint64](pb[1]), 0,
                                           8, 0)
    if pp_n != 8:
        printk1("[splice] FAIL pipe->pipe count=%d\n", cast[uint64](pp_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    pp_rb: Array[8, uint8]
    pp_rn: int64 = vfs_read(pb[0], &pp_rb[0], 8)
    if pp_rn != 8 or _splice_bytes_eq(&pp_rb[0], &payload[0], 8) == 0:
        printk1("[splice] FAIL pipe->pipe readback n=%d\n", cast[uint64](pp_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_close(pa[0])
    vfs_close(pa[1])
    vfs_close(pb[0])
    vfs_close(pb[1])
    printk0("[splice] pipe->pipe OK\n")

    # --- 4. tee leaves the input intact ------------------------------
    ta: Array[2, int32]
    tb: Array[2, int32]
    if vfs_pipe(&ta[0]) != 0 or vfs_pipe(&tb[0]) != 0:
        printk0("[splice] FAIL tee pipe alloc\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(ta[1], &payload[0], 8)
    tee_n: int64 = _uabi_test_dispatch(SYS_tee,
                                       cast[uint64](ta[0]),
                                       cast[uint64](tb[1]),
                                       8, 0)
    if tee_n != 8:
        printk1("[splice] FAIL tee count=%d\n", cast[uint64](tee_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # B gets the duplicate.
    tb_rb: Array[8, uint8]
    tb_rn: int64 = vfs_read(tb[0], &tb_rb[0], 8)
    if tb_rn != 8 or _splice_bytes_eq(&tb_rb[0], &payload[0], 8) == 0:
        printk1("[splice] FAIL tee dst readback n=%d\n", cast[uint64](tb_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # A is UNTOUCHED — the same 8 bytes are still readable.
    ta_rb: Array[8, uint8]
    ta_rn: int64 = vfs_read(ta[0], &ta_rb[0], 8)
    if ta_rn != 8 or _splice_bytes_eq(&ta_rb[0], &payload[0], 8) == 0:
        printk1("[splice] FAIL tee src consumed n=%d\n", cast[uint64](ta_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_close(ta[0])
    vfs_close(ta[1])
    vfs_close(tb[0])
    vfs_close(tb[1])
    printk0("[splice] tee (input intact) OK\n")

    # --- 5. error paths ----------------------------------------------
    # EINVAL: neither side a pipe (two plain files).
    e_src: int32 = vfs_open_write(cast[Ptr[char]]("/tmp/splice-e-src"))
    e_dst: int32 = vfs_open_write(cast[Ptr[char]]("/tmp/splice-e-dst"))
    if e_src < 0 or e_dst < 0:
        printk0("[splice] FAIL err-path file open\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(e_src, &payload[0], 8)
    vfs_lseek(e_src, 0, 0)
    e_inval: int64 = linux_u_syscall_dispatch(SYS_splice,
                                              cast[uint64](e_src), 0,
                                              cast[uint64](e_dst), 0,
                                              8, 0)
    if e_inval != ELINUX_INVAL:
        printk1("[splice] FAIL file->file want EINVAL got=%d\n",
                cast[uint64](e_inval))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # ESPIPE: an offset pointer on the pipe side.
    sp_fds: Array[2, int32]
    if vfs_pipe(&sp_fds[0]) != 0:
        printk0("[splice] FAIL espipe pipe alloc\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    sp_off: Array[1, int64]
    sp_off[0] = 0
    e_espipe: int64 = linux_u_syscall_dispatch(SYS_splice,
                                               cast[uint64](sp_fds[0]),
                                               cast[uint64](&sp_off[0]),
                                               cast[uint64](e_dst), 0,
                                               8, 0)
    if e_espipe != ELINUX_SPIPE:
        printk1("[splice] FAIL pipe-offset want ESPIPE got=%d\n",
                cast[uint64](e_espipe))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_close(e_src)
    vfs_close(e_dst)
    vfs_close(sp_fds[0])
    vfs_close(sp_fds[1])
    printk0("[splice] error paths (EINVAL/ESPIPE) OK\n")

    # --- 6. vmsplice from a REAL user buffer -------------------------
    # Stand up a non-identity user-writable page (vaddr != phys), lay the
    # payload into it via copy_to_user, point the iovec at the user vaddr,
    # and vmsplice it into a pipe. This exercises the copy_from_user
    # gather path against genuine user memory, not a kernel pointer.
    pml4: uint64 = uaccess_current_pml4()
    upage: uint64 = alloc_page()
    if upage == 0:
        printk0("[splice] FAIL vmsplice alloc_page\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(pml4, SPLICE_TEST_VADDR, upage, 1) < 0:
        printk0("[splice] FAIL vmsplice map user page\n")
        free_page(upage)
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if copy_to_user(SPLICE_TEST_VADDR, cast[uint64](&payload[0]), 8) != 0:
        printk0("[splice] FAIL vmsplice copy_to_user setup\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vm_fds: Array[2, int32]
    if vfs_pipe(&vm_fds[0]) != 0:
        printk0("[splice] FAIL vmsplice pipe alloc\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # iovec { base = SPLICE_TEST_VADDR, len = 8 }. The iovec STRUCT is a
    # kernel array (vmsplice reads it by raw deref, like readv/writev);
    # only iov_base points at user memory.
    vm_iov: Array[2, uint64]
    vm_iov[0] = SPLICE_TEST_VADDR
    vm_iov[1] = 8
    vm_n: int64 = _uabi_test_dispatch(SYS_vmsplice,
                                      cast[uint64](vm_fds[1]),
                                      cast[uint64](&vm_iov[0]),
                                      1, 0)
    if vm_n != 8:
        printk1("[splice] FAIL vmsplice count=%d\n", cast[uint64](vm_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vm_rb: Array[8, uint8]
    vm_rn: int64 = vfs_read(vm_fds[0], &vm_rb[0], 8)
    if vm_rn != 8 or _splice_bytes_eq(&vm_rb[0], &payload[0], 8) == 0:
        printk1("[splice] FAIL vmsplice readback n=%d\n", cast[uint64](vm_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_close(vm_fds[0])
    vfs_close(vm_fds[1])
    free_page(upage)
    printk0("[splice] vmsplice (user iovec) OK\n")

    _pty_selftest_restore(boot_task, &fd_save[0])
    printk0("[splice] PASS\n")
    return 0


# ---------------------------------------------------------------------
# §kmod: init_module / finit_module / delete_module boot self-test.
#
# Drives all three module-management syscalls through the REAL
# linux_u_syscall_dispatch entry — the same path a Linux insmod /
# modprobe / rmmod in the distro namespace takes — so the wiring,
# the user-buffer plumbing, and delete_module's name->slot resolver
# are all exercised. We assert on the error paths (which need no real
# .ko image and so stay hermetic): a NULL/oversize image is rejected
# before the loader, a bad fd is -EBADF, and deleting an unknown name
# is -ENOENT. The positive full-load round-trip (finit_module of a real
# distro .ko followed by delete_module) is covered end-to-end by
# scripts/test_l30_distro_module.sh, which already stages a real .ko.
#
# Gated by /etc/kmodsys-test (build_initramfs.py plants it when
# ENABLE_KMODSYS_TEST=1); init/main.ad calls kmod_syscall_selftest().
# Prints "[kmodsys] PASS" once every assertion holds.

def kmod_syscall_selftest() -> int32:
    # 1. init_module(NULL, 0, NULL) -> -EINVAL (rejected before alloc).
    r1: int64 = linux_u_syscall_dispatch(SYS_init_module, 0, 0, 0, 0, 0, 0)
    if r1 != ELINUX_INVAL:
        printk1("[kmodsys] FAIL init_module(NULL) rc=%d\n", cast[uint64](r1))
        return 1
    printk0("[kmodsys] init_module(NULL)->EINVAL OK\n")

    # 2. init_module with a non-NULL image but an absurd len -> -ENOMEM
    #    (the cap rejects it before we ever touch user memory). a0 is a
    #    harmless non-zero kernel pointer; the len check fires first.
    big: uint64 = KMOD_MAX_IMAGE + 4096
    r2: int64 = linux_u_syscall_dispatch(SYS_init_module,
                                         cast[uint64](&big), big, 0, 0, 0, 0)
    if r2 != ELINUX_NOMEM:
        printk1("[kmodsys] FAIL init_module(oversize) rc=%d\n",
                cast[uint64](r2))
        return 1
    printk0("[kmodsys] init_module(oversize)->ENOMEM OK\n")

    # 3. finit_module(-1, NULL, 0) -> -EBADF (bad fd rejected up front).
    r3: int64 = linux_u_syscall_dispatch(SYS_finit_module,
                                         cast[uint64](cast[int64](-1)),
                                         0, 0, 0, 0, 0)
    if r3 != ELINUX_BADF:
        printk1("[kmodsys] FAIL finit_module(-1) rc=%d\n", cast[uint64](r3))
        return 1
    printk0("[kmodsys] finit_module(badfd)->EBADF OK\n")

    # 4. delete_module("no_such_module", 0) -> -ENOENT. This drives the
    #    full name copy-in + kmod_linux_find_by_name scan, proving the
    #    resolver returns -1 (=> ENOENT) for an unloaded name.
    miss: Array[16, uint8]
    miss[0]  = 110                                       # 'n'
    miss[1]  = 111                                       # 'o'
    miss[2]  = 95                                        # '_'
    miss[3]  = 115                                       # 's'
    miss[4]  = 117                                       # 'u'
    miss[5]  = 99                                        # 'c'
    miss[6]  = 104                                       # 'h'
    miss[7]  = 0
    r4: int64 = linux_u_syscall_dispatch(SYS_delete_module,
                                         cast[uint64](&miss[0]), 0, 0, 0, 0, 0)
    if r4 != ELINUX_NOENT:
        printk1("[kmodsys] FAIL delete_module(missing) rc=%d\n",
                cast[uint64](r4))
        return 1
    printk0("[kmodsys] delete_module(missing)->ENOENT OK\n")

    printk0("[kmodsys] PASS\n")
    return 0


# ---------------------------------------------------------------------
# close_range(2) + statx(2) boot self-test.
#
# Gated by /etc/closerange-test (build_initramfs.py plants it when
# ENABLE_CLOSERANGE_TEST=1); init/main.ad calls close_range_selftest() at
# boot. Three legs, all driven through the real syscall dispatcher so the
# entry points exercised are the same ones a Linux binary would hit:
#
#   1. statx round-trip : write a known 8-byte file, statx it by path via
#      AT_FDCWD, and assert stx_mask, stx_size, and the S_IFREG type bits.
#   2. tee + splice end-to-end : write a payload into pipe A, tee it into
#      pipe B (A stays intact), then splice B into a file and read it back
#      byte-for-byte — proving tee duplicates and splice transfers.
#   3. close_range : dup a base fd four times, close_range the whole dup
#      span, and assert every fd in it is closed while fds outside stay
#      open. Then a second close_range over an already-closed span returns
#      0 (closing an already-closed slot is not an error).
#
# Prints "[closerange] PASS" once every assertion holds.

def close_range_selftest() -> int32:
    # Prime the boot task's fd table the same way splice_selftest does so
    # the open / pipe / dup legs can grab real fd slots.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    payload: Array[8, uint8]
    payload[0] = 67                                      # 'C'
    payload[1] = 76                                      # 'L'
    payload[2] = 79                                      # 'O'
    payload[3] = 83                                      # 'S'
    payload[4] = 69                                      # 'E'
    payload[5] = 82                                      # 'R'
    payload[6] = 57                                      # '9'
    payload[7] = 56                                      # '8'

    # --- 1. statx round-trip -----------------------------------------
    sx_name: Ptr[char] = cast[Ptr[char]]("/tmp/closerange-statx")
    sx_fd: int32 = vfs_open_write(sx_name)
    if sx_fd < 0:
        printk1("[closerange] FAIL statx file open=%d\n",
                cast[uint64](cast[int64](sx_fd)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(sx_fd, &payload[0], 8)
    vfs_close(sx_fd)
    sx_buf: Array[256, uint8]
    # statx(dirfd, path, flags, mask, buf) — five args; a4 (buf) needs the
    # full six-arg dispatch, so route it directly rather than the 4-arg
    # _uabi_test_dispatch wrapper.
    sx_rc: int64 = linux_u_syscall_dispatch(SYS_statx, AT_FDCWD_U64,
                                            cast[uint64]("/tmp/closerange-statx"),
                                            0, cast[uint64](STATX_BASIC_STATS),
                                            cast[uint64](&sx_buf[0]), 0)
    if sx_rc != 0:
        printk1("[closerange] FAIL statx rc=%d\n", cast[uint64](sx_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    sx_mask: uint32 = cast[Ptr[uint32]](cast[uint64](&sx_buf[0]) + STATX_OFF_MASK)[0]
    if (sx_mask & STATX_BASIC_STATS) != STATX_BASIC_STATS:
        printk1("[closerange] FAIL statx mask=%x\n", cast[uint64](sx_mask))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    sx_size: uint64 = cast[Ptr[uint64]](cast[uint64](&sx_buf[0]) + STATX_OFF_SIZE)[0]
    if sx_size != 8:
        printk1("[closerange] FAIL statx size=%d\n", sx_size)
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    sx_mode: uint16 = cast[Ptr[uint16]](cast[uint64](&sx_buf[0]) + STATX_OFF_MODE)[0]
    # S_IFMT = 0xF000; S_IFREG = 0x8000. The planted file is a regular file.
    if (cast[uint32](sx_mode) & 0xF000) != 0x8000:
        printk1("[closerange] FAIL statx type bits=%x\n",
                cast[uint64](cast[uint32](sx_mode)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[closerange] statx (mask/size/type) OK\n")

    # --- 2. tee + splice end-to-end ----------------------------------
    ta: Array[2, int32]
    tb: Array[2, int32]
    if vfs_pipe(&ta[0]) != 0 or vfs_pipe(&tb[0]) != 0:
        printk0("[closerange] FAIL te pipe alloc\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(ta[1], &payload[0], 8)
    te_n: int64 = _uabi_test_dispatch(SYS_tee,
                                      cast[uint64](ta[0]),
                                      cast[uint64](tb[1]),
                                      8, 0)
    if te_n != 8:
        printk1("[closerange] FAIL tee count=%d\n", cast[uint64](te_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # splice the duplicated bytes out of pipe B into a file, then read back.
    te_dst: int32 = vfs_open_write(cast[Ptr[char]]("/tmp/closerange-splice"))
    if te_dst < 0:
        printk0("[closerange] FAIL te dst open\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    sp_n: int64 = linux_u_syscall_dispatch(SYS_splice,
                                           cast[uint64](tb[0]), 0,
                                           cast[uint64](te_dst), 0,
                                           8, 0)
    if sp_n != 8:
        printk1("[closerange] FAIL splice count=%d\n", cast[uint64](sp_n))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_lseek(te_dst, 0, 0)
    te_rb: Array[8, uint8]
    te_rn: int64 = vfs_read(te_dst, &te_rb[0], 8)
    if te_rn != 8 or _splice_bytes_eq(&te_rb[0], &payload[0], 8) == 0:
        printk1("[closerange] FAIL splice readback n=%d\n", cast[uint64](te_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # The tee left the source intact — pipe A still holds the 8 bytes.
    ta_rb: Array[8, uint8]
    ta_rn: int64 = vfs_read(ta[0], &ta_rb[0], 8)
    if ta_rn != 8 or _splice_bytes_eq(&ta_rb[0], &payload[0], 8) == 0:
        printk1("[closerange] FAIL tee src consumed n=%d\n", cast[uint64](ta_rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_close(ta[0])
    vfs_close(ta[1])
    vfs_close(tb[0])
    vfs_close(tb[1])
    vfs_close(te_dst)
    printk0("[closerange] tee+splice end-to-end OK\n")

    # --- 3. close_range over a dup span ------------------------------
    # Open a base fd, dup it four times so we hold a contiguous-ish span,
    # then close_range the whole span and assert every fd is closed.
    cr_base: int32 = vfs_open_write(cast[Ptr[char]]("/tmp/closerange-fds"))
    if cr_base < 0:
        printk0("[closerange] FAIL base open\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    cr_d: Array[4, int32]
    di: uint64 = 0
    cr_ok: int32 = 1
    while di < 4:
        cr_d[di] = vfs_dup(cr_base)
        if cr_d[di] < 0:
            cr_ok = 0
        di = di + 1
    if cr_ok == 0:
        printk0("[closerange] FAIL dup\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # Compute the [lo, hi] span across base + its four dups.
    lo: int32 = cr_base
    hi: int32 = cr_base
    di = 0
    while di < 4:
        if cr_d[di] < lo:
            lo = cr_d[di]
        if cr_d[di] > hi:
            hi = cr_d[di]
        di = di + 1
    # Every fd in the span must be open right now.
    fi: int32 = lo
    while fi <= hi:
        if vfs_fd_is_open(fi) == 0:
            printk1("[closerange] FAIL fd %d not open pre-close\n",
                    cast[uint64](cast[int64](fi)))
            _pty_selftest_restore(boot_task, &fd_save[0])
            return 1
        fi = fi + 1
    cr_rc: int64 = _uabi_test_dispatch(SYS_close_range,
                                       cast[uint64](lo),
                                       cast[uint64](hi),
                                       0, 0)
    if cr_rc != 0:
        printk1("[closerange] FAIL close_range rc=%d\n", cast[uint64](cr_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # Now every fd in [lo, hi] must be closed.
    fi = lo
    while fi <= hi:
        if vfs_fd_is_open(fi) != 0:
            printk1("[closerange] FAIL fd %d still open post-close\n",
                    cast[uint64](cast[int64](fi)))
            _pty_selftest_restore(boot_task, &fd_save[0])
            return 1
        fi = fi + 1
    # Re-running over the now-empty span is a no-op success (closing an
    # already-closed slot is exactly what close_range tolerates).
    cr_rc2: int64 = _uabi_test_dispatch(SYS_close_range,
                                        cast[uint64](lo),
                                        cast[uint64](hi),
                                        0, 0)
    if cr_rc2 != 0:
        printk1("[closerange] FAIL re-close rc=%d\n", cast[uint64](cr_rc2))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    # An inverted range is EINVAL.
    cr_inv: int64 = _uabi_test_dispatch(SYS_close_range, 5, 3, 0, 0)
    if cr_inv != ELINUX_INVAL:
        printk1("[closerange] FAIL inverted want EINVAL got=%d\n",
                cast[uint64](cr_inv))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[closerange] close_range span (closed + idempotent + EINVAL) OK\n")

    _pty_selftest_restore(boot_task, &fd_save[0])
    printk0("[closerange] PASS\n")
    return 0


# =====================================================================
# fanotify(7) self-test  (gated on /etc/fanotify-test, ENABLE_FANOTIFY_TEST=1)
# =====================================================================
#
# Drives the fanotify family through the REAL in-kernel Linux-ABI
# dispatch (linux_u_syscall_dispatch — the exact path a Linux glibc
# fanotify monitor takes):
#
#   1. fanotify_init(FAN_CLASS_NOTIF | FAN_NONBLOCK, 0) -> a group fd.
#   2. fanotify_mark(fd, FAN_MARK_ADD, FAN_MODIFY, AT_FDCWD, "/tmp") ->
#      mark the /tmp directory for modify events.
#   3. Write to a fresh /tmp file — fs/vfs.ad's tmpfs write arm posts an
#      IN_MODIFY through the combined notify hook into the fanotify pool.
#   4. read(group_fd) via SYS_read -> assert exactly one
#      struct fanotify_event_metadata whose vers == 3 and whose mask
#      carries FAN_MODIFY.
#   5. Negative checks: FAN_CLASS_CONTENT init is EINVAL; an unsourceable
#      mask bit (FAN_OPEN) on mark is EINVAL; FAN_MARK_FLUSH then read is
#      EAGAIN (NONBLOCK) after the queue is drained.
#
# Prints "[fanotify] PASS" once every assertion holds.

def fanotify_selftest() -> int32:
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    # --- 0. negative: permission class is EINVAL ---------------------
    bad: int64 = linux_u_syscall_dispatch(SYS_fanotify_init,
                                          cast[uint64](FAN_CLASS_CONTENT),
                                          0, 0, 0, 0, 0)
    if bad != ELINUX_INVAL:
        printk1("[fanotify] FAIL content-class want EINVAL got=%d\n",
                cast[uint64](bad))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 1. fanotify_init -------------------------------------------
    init_flags: uint64 = cast[uint64](FAN_CLASS_NOTIF | FAN_NONBLOCK)
    gfd64: int64 = linux_u_syscall_dispatch(SYS_fanotify_init,
                                            init_flags, 0, 0, 0, 0, 0)
    if gfd64 < 0:
        printk1("[fanotify] FAIL fanotify_init rc=%d\n", cast[uint64](gfd64))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    gfd: int32 = cast[int32](gfd64)

    # --- 2. fanotify_mark(/tmp, FAN_MODIFY) -------------------------
    mk: int64 = linux_u_syscall_dispatch(SYS_fanotify_mark,
                                         cast[uint64](gfd),
                                         cast[uint64](FAN_MARK_ADD),
                                         FAN_MODIFY,
                                         AT_FDCWD_U64,
                                         cast[uint64]("/tmp"),
                                         0)
    if mk != 0:
        printk1("[fanotify] FAIL mark rc=%d\n", cast[uint64](mk))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 2b. negative: unsourceable mask bit is EINVAL ---------------
    mkbad: int64 = linux_u_syscall_dispatch(SYS_fanotify_mark,
                                            cast[uint64](gfd),
                                            cast[uint64](FAN_MARK_ADD),
                                            FAN_OPEN,
                                            AT_FDCWD_U64,
                                            cast[uint64]("/tmp"),
                                            0)
    if mkbad != ELINUX_INVAL:
        printk1("[fanotify] FAIL bad-mask want EINVAL got=%d\n",
                cast[uint64](mkbad))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- 3. trigger an IN_MODIFY by writing a /tmp file --------------
    fpayload: Array[6, uint8]
    fpayload[0] = 70                                     # 'F'
    fpayload[1] = 65                                     # 'A'
    fpayload[2] = 78                                     # 'N'
    fpayload[3] = 79                                     # 'O'
    fpayload[4] = 55                                     # '7'
    fpayload[5] = 33                                     # '!'
    wfd: int32 = vfs_open_write(cast[Ptr[char]]("/tmp/fanotify-mod"))
    if wfd < 0:
        printk1("[fanotify] FAIL trigger file open=%d\n",
                cast[uint64](cast[int64](wfd)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    vfs_write(wfd, &fpayload[0], 6)
    vfs_close(wfd)

    # --- 4. read the group fd, assert one metadata record ------------
    rbuf: Array[64, uint8]
    rn: int64 = linux_u_syscall_dispatch(SYS_read,
                                         cast[uint64](gfd),
                                         cast[uint64](&rbuf[0]),
                                         64, 0, 0, 0)
    if rn < cast[int64](FAN_EVENT_METADATA_LEN):
        printk1("[fanotify] FAIL read rc=%d (want >=24)\n", cast[uint64](rn))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    ev_len: uint32 = cast[Ptr[uint32]](cast[uint64](&rbuf[0]))[0]
    ev_vers: uint8 = cast[Ptr[uint8]](cast[uint64](&rbuf[0]) + 4)[0]
    ev_mask: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 8)[0]
    ev_fd: int32 = cast[Ptr[int32]](cast[uint64](&rbuf[0]) + 16)[0]
    if ev_vers != FANOTIFY_METADATA_VERSION:
        printk1("[fanotify] FAIL vers=%d (want 3)\n",
                cast[uint64](cast[uint32](ev_vers)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if ev_len != cast[uint32](FAN_EVENT_METADATA_LEN):
        printk1("[fanotify] FAIL event_len=%d (want 24)\n",
                cast[uint64](ev_len))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if (ev_mask & FAN_MODIFY) == 0:
        printk1("[fanotify] FAIL mask=%x lacks FAN_MODIFY\n", ev_mask)
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    if ev_fd != FAN_NOFD:
        printk1("[fanotify] FAIL fd=%d (scope expects FAN_NOFD/-1)\n",
                cast[uint64](cast[int64](ev_fd)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[fanotify] init/mark/modify/read (vers=3, FAN_MODIFY) OK\n")

    # --- 5. flush, then a non-blocking read drains to EAGAIN ---------
    fl: int64 = linux_u_syscall_dispatch(SYS_fanotify_mark,
                                         cast[uint64](gfd),
                                         cast[uint64](FAN_MARK_FLUSH),
                                         0, 0, 0, 0)
    if fl != 0:
        printk1("[fanotify] FAIL flush rc=%d\n", cast[uint64](fl))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    rn2: int64 = linux_u_syscall_dispatch(SYS_read,
                                          cast[uint64](gfd),
                                          cast[uint64](&rbuf[0]),
                                          64, 0, 0, 0)
    if rn2 != ELINUX_AGAIN:
        printk1("[fanotify] FAIL drained read want EAGAIN got=%d\n",
                cast[uint64](rn2))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[fanotify] flush + drained non-blocking read (EAGAIN) OK\n")

    _pty_selftest_restore(boot_task, &fd_save[0])
    printk0("[fanotify] PASS\n")
    return 0


def _splice_bytes_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    # 1 if the first n bytes of a and b are equal, else 0.
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# =====================================================================
# statfs(2) / fstatfs(2) self-test
#   (gated on /etc/statfs-test, ENABLE_STATFS_TEST=1)
# =====================================================================
#
# Drives _u_statfs / _u_fstatfs through the REAL in-kernel Linux-ABI
# dispatch (linux_u_syscall_dispatch — the exact path a Debian/glibc `df`
# takes) on:
#   * the live ext4 mount (/ext) — asserts f_type==EXT4_MAGIC, a non-zero
#     block size and a non-zero total-block count (the REAL superblock
#     geometry), proving df sees real capacity for the installer's target.
#   * the synthetic root (/) — asserts a non-zero block size + total.
#   * an open tmpfs fd via fstatfs — asserts f_type==TMPFS_MAGIC.
# Prints a single "[STATFS] PASS" / "[STATFS] FAIL ..." on the EMERG
# serial channel. A default boot ships no marker, so this never runs.


def _statfs_field_u64(buf: Ptr[uint8], off: uint64) -> uint64:
    return cast[Ptr[uint64]](cast[uint64](buf) + off)[0]


def statfs_selftest() -> int32:
    # Prime the boot task's fd table (same uninitialised-table issue the
    # uabi_fills hook handles) so the tmpfs open + fstatfs leg can grab fds.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    sfbuf: Array[120, uint8]

    # --- statfs(/ext) : live ext4 mount, REAL superblock geometry -------
    ext_path: Ptr[uint8] = cast[Ptr[uint8]]("/ext")
    erc: int64 = _uabi_test_dispatch(SYS_statfs, cast[uint64](ext_path),
                                     cast[uint64](&sfbuf[0]), 0, 0)
    if erc != 0:
        printk1("[STATFS] FAIL statfs(/ext) rc=%d\n", cast[uint64](erc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    e_type:   uint64 = _statfs_field_u64(&sfbuf[0], STATFS_OFF_TYPE)
    e_bsize:  uint64 = _statfs_field_u64(&sfbuf[0], STATFS_OFF_BSIZE)
    e_blocks: uint64 = _statfs_field_u64(&sfbuf[0], STATFS_OFF_BLOCKS)
    if e_type != STATFS_MAGIC_EXT4:
        printk1("[STATFS] FAIL ext4 f_type=%x (want 0xEF53)\n", e_type)
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    if e_bsize == 0:
        printk0("[STATFS] FAIL ext4 f_bsize==0\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    if e_blocks == 0:
        printk0("[STATFS] FAIL ext4 f_blocks==0\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk2("[STATFS] ext4 bsize=%d blocks=%d\n", e_bsize, e_blocks)

    # --- statfs(/) : synthetic root, non-zero geometry ------------------
    root_path: Ptr[uint8] = cast[Ptr[uint8]]("/")
    rrc: int64 = _uabi_test_dispatch(SYS_statfs, cast[uint64](root_path),
                                     cast[uint64](&sfbuf[0]), 0, 0)
    if rrc != 0:
        printk1("[STATFS] FAIL statfs(/) rc=%d\n", cast[uint64](rrc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    r_bsize:  uint64 = _statfs_field_u64(&sfbuf[0], STATFS_OFF_BSIZE)
    r_blocks: uint64 = _statfs_field_u64(&sfbuf[0], STATFS_OFF_BLOCKS)
    if r_bsize == 0 or r_blocks == 0:
        printk0("[STATFS] FAIL root f_bsize/f_blocks==0\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- fstatfs(open tmpfs fd) : f_type==TMPFS_MAGIC -------------------
    tw: int32 = vfs_open_write("/tmp/statfs-sel")
    if tw < 0:
        printk1("[STATFS] FAIL tmpfs open_write rc=%d\n",
                cast[uint64](cast[int64](tw)))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    onebyte: Array[1, uint8]
    onebyte[0] = 65
    vfs_write(tw, &onebyte[0], 1)
    vfs_close(tw)
    tr: int32 = vfs_open("/tmp/statfs-sel")
    if tr < 0:
        printk0("[STATFS] FAIL tmpfs reopen\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    frc: int64 = _uabi_test_dispatch(SYS_fstatfs, cast[uint64](tr),
                                     cast[uint64](&sfbuf[0]), 0, 0)
    f_type:  uint64 = _statfs_field_u64(&sfbuf[0], STATFS_OFF_TYPE)
    f_bsize: uint64 = _statfs_field_u64(&sfbuf[0], STATFS_OFF_BSIZE)
    vfs_close(tr)
    if frc != 0:
        printk1("[STATFS] FAIL fstatfs rc=%d\n", cast[uint64](frc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    if f_type != STATFS_MAGIC_TMPFS:
        printk1("[STATFS] FAIL fstatfs f_type=%x (want tmpfs)\n", f_type)
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    if f_bsize == 0:
        printk0("[STATFS] FAIL fstatfs f_bsize==0\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- fstatfs(bad fd) : -EBADF ---------------------------------------
    brc: int64 = _uabi_test_dispatch(SYS_fstatfs, 999,
                                     cast[uint64](&sfbuf[0]), 0, 0)
    if brc != ELINUX_BADF:
        printk1("[STATFS] FAIL fstatfs(badfd) rc=%d (want -9)\n",
                cast[uint64](brc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    _statfs_selftest_restore(boot_task, &fd_save[0])
    printk0("[STATFS] PASS\n")
    return 0


def _statfs_selftest_restore(boot_task: Ptr[TaskStruct],
                             fd_save: Ptr[uint32]):
    # Restore the boot task's original fd slots so the table looks
    # untouched to anything that runs after this hook.
    fdr: uint64 = 3
    while fdr < 16:
        boot_task[0].fd_idx[fdr] = fd_save[fdr]
        fdr = fdr + 1


# =====================================================================
# readlink(2) / readlinkat(2) on a tmpfs symlink self-test
#   (gated on /etc/tmpfs-readlink-test, ENABLE_TMPFS_READLINK_TEST=1)
# =====================================================================
#
# tmpfs now stores symlink targets in-RAM (fs/tmpfs.ad). This proves the
# Linux-ABI readlink path consults tmpfs: it creates a tmpfs file plus a
# tmpfs symlink with a KNOWN target string, then drives the REAL in-kernel
# dispatch (linux_u_syscall_dispatch — the exact path a Debian/glibc
# binary takes) for both SYS_readlink and SYS_readlinkat against the
# symlink and asserts:
#   * the returned byte count == the target length,
#   * the bytes copied into the user buffer == the target string,
#   * NO trailing NUL is written (the byte past the count is left clear),
#   * readlink on a NON-symlink tmpfs file returns -EINVAL.
# Prints a single "[TMPFS_READLINK] PASS" / "[TMPFS_READLINK] FAIL ..."
# on the EMERG serial channel. A default boot ships no marker.


def _trl_cstr_len(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def tmpfs_readlink_selftest() -> int32:
    # boot:37 bootstrap-task fd-table prime (same uninitialised-table
    # issue statfs_selftest handles): snapshot slots 3..15, mark them
    # FD_CLOSED_MARK, restore on every exit.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    # --- create a tmpfs target file ------------------------------------
    # tmpfs_open_for_write returns a SLOT (not an fd): write through the
    # slot directly, no vfs_close needed (mirrors the msync selftest).
    tgt_path: Ptr[char] = cast[Ptr[char]]("/tmp/trl-target")
    wslot: int32 = tmpfs_open_for_write(tgt_path)
    if wslot < 0:
        printk1("[TMPFS_READLINK] FAIL target open=%d\n",
                cast[uint64](cast[int64](wslot)))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    onebyte: Array[1, uint8]
    onebyte[0] = 90                                       # 'Z'
    tmpfs_write(wslot, &onebyte[0], 0, 1)

    # --- create a tmpfs symlink with a KNOWN target string -------------
    # The link itself lives at /tmp/trl-link; its stored target string is
    # exactly tgt_path ("/tmp/trl-target", 15 bytes).
    link_path: Ptr[char] = cast[Ptr[char]]("/tmp/trl-link")
    crc: int32 = tmpfs_create_symlink(link_path, tgt_path)
    if crc != 0:
        printk1("[TMPFS_READLINK] FAIL create_symlink rc=%d\n",
                cast[uint64](cast[int64](crc)))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    want: Ptr[uint8] = cast[Ptr[uint8]]("/tmp/trl-target")
    want_len: uint64 = _trl_cstr_len(want)

    # --- SYS_readlink(/tmp/trl-link) : byte count == target length -----
    rl_buf: Array[64, uint8]
    bi: uint64 = 0
    while bi < 64:
        rl_buf[bi] = 0
        bi = bi + 1
    rl_n: int64 = _uabi_test_dispatch(SYS_readlink,
                                      cast[uint64](link_path),
                                      cast[uint64](&rl_buf[0]), 64, 0)
    if rl_n != cast[int64](want_len):
        printk2("[TMPFS_READLINK] FAIL readlink rc=%d want=%d\n",
                cast[uint64](rl_n), want_len)
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    ci: uint64 = 0
    while ci < want_len:
        if rl_buf[ci] != want[ci]:
            printk1("[TMPFS_READLINK] FAIL readlink byte mismatch @%d\n", ci)
            _statfs_selftest_restore(boot_task, &fd_save[0])
            return 1
        ci = ci + 1
    # readlink(2) writes NO trailing NUL: the byte just past the count
    # must still be the cleared 0 we pre-seeded.
    if rl_buf[want_len] != 0:
        printk0("[TMPFS_READLINK] FAIL readlink wrote trailing NUL\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- SYS_readlinkat(AT_FDCWD, /tmp/trl-link) : same result ---------
    ra_buf: Array[64, uint8]
    bj: uint64 = 0
    while bj < 64:
        ra_buf[bj] = 0
        bj = bj + 1
    ra_n: int64 = linux_u_syscall_dispatch(SYS_readlinkat, AT_FDCWD_U64,
                                           cast[uint64](link_path),
                                           cast[uint64](&ra_buf[0]),
                                           64, 0, 0)
    if ra_n != cast[int64](want_len):
        printk2("[TMPFS_READLINK] FAIL readlinkat rc=%d want=%d\n",
                cast[uint64](ra_n), want_len)
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    cj: uint64 = 0
    while cj < want_len:
        if ra_buf[cj] != want[cj]:
            printk1("[TMPFS_READLINK] FAIL readlinkat byte mismatch @%d\n", cj)
            _statfs_selftest_restore(boot_task, &fd_save[0])
            return 1
        cj = cj + 1

    # --- truncation: bufsiz < target → exactly bufsiz bytes, no more ----
    tr_buf: Array[8, uint8]
    tk: uint64 = 0
    while tk < 8:
        tr_buf[tk] = 0
        tk = tk + 1
    tr_n: int64 = _uabi_test_dispatch(SYS_readlink,
                                      cast[uint64](link_path),
                                      cast[uint64](&tr_buf[0]), 4, 0)
    if tr_n != 4:
        printk1("[TMPFS_READLINK] FAIL readlink trunc rc=%d (want 4)\n",
                cast[uint64](tr_n))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    tc: uint64 = 0
    while tc < 4:
        if tr_buf[tc] != want[tc]:
            printk0("[TMPFS_READLINK] FAIL readlink trunc bytes\n")
            _statfs_selftest_restore(boot_task, &fd_save[0])
            return 1
        tc = tc + 1

    # --- readlink on a NON-symlink tmpfs file → -EINVAL ----------------
    ni_n: int64 = _uabi_test_dispatch(SYS_readlink,
                                      cast[uint64](tgt_path),
                                      cast[uint64](&rl_buf[0]), 64, 0)
    if ni_n != ELINUX_INVAL:
        printk1("[TMPFS_READLINK] FAIL non-symlink rc=%d (want -22)\n",
                cast[uint64](ni_n))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- cleanup: drop the symlink + target so the table is pristine ----
    tmpfs_unlink(link_path)
    tmpfs_unlink(tgt_path)

    _statfs_selftest_restore(boot_task, &fd_save[0])
    printk0("[TMPFS_READLINK] PASS\n")
    return 0


# =====================================================================
# symlink(2)/link(2)/utimensat(2) Linux-ABI self-test
#   (gated on /etc/linkat-test, ENABLE_LINKAT_TEST=1)
# =====================================================================
#
# Proves the newly-wired symlink/link/utimensat family drives the REAL
# in-kernel dispatch (linux_u_syscall_dispatch — the exact path a
# Debian/glibc binary takes) against the live tmpfs backend:
#
#   * SYS_symlink(target, /tmp/lat-link) creates a tmpfs symlink; we then
#     drive SYS_readlink back through dispatch and assert the stored target
#     round-trips byte-for-byte (the `ln -s` contract).
#   * SYS_symlinkat(target, AT_FDCWD, /tmp/lat-link2) does the same via the
#     *at entry — proving the dirfd anchoring.
#   * SYS_link(/tmp/lat-data, /tmp/lat-hard) creates a tmpfs hardlink; we
#     open the new name and assert it reads the SAME byte the original
#     holds (the `ln` contract). A cross-backend link (/tmp → /ext) returns
#     -EXDEV (the Plan 9 file-server boundary).
#   * SYS_utimensat(AT_FDCWD, /tmp/lat-data, NULL, 0) returns 0 (tmpfs
#     accepts mtime as no-op success); on a MISSING path it returns -ENOENT;
#     with a bad path pointer it returns -EFAULT.
# Prints "[LINKAT] PASS" / "[LINKAT] FAIL ..." on the EMERG serial channel.
# A default boot ships no marker.

EXDEV_LINUX: int64 = -18              # -EXDEV (cross-file-server link)


def linkat_selftest() -> int32:
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    # --- create a tmpfs data file holding a known byte 'Q' (0x51) -------
    data_path: Ptr[char] = cast[Ptr[char]]("/tmp/lat-data")
    wslot: int32 = tmpfs_open_for_write(data_path)
    if wslot < 0:
        printk1("[LINKAT] FAIL data open=%d\n",
                cast[uint64](cast[int64](wslot)))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    onebyte: Array[1, uint8]
    onebyte[0] = 81                                       # 'Q'
    tmpfs_write(wslot, &onebyte[0], 0, 1)

    # --- SYS_symlink(target="/tmp/lat-data", "/tmp/lat-link") -----------
    link_path: Ptr[char] = cast[Ptr[char]]("/tmp/lat-link")
    sl_rc: int64 = linux_u_syscall_dispatch(SYS_symlink,
                                            cast[uint64](data_path),
                                            cast[uint64](link_path),
                                            0, 0, 0, 0)
    if sl_rc != 0:
        printk1("[LINKAT] FAIL symlink rc=%d\n", cast[uint64](sl_rc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    # readlink back through real dispatch: the stored target must match.
    # F10-9 carve-out: this is a SELFTEST probe asserting that the prior
    # SYS_symlink stored its target in the tmpfs backend specifically
    # (link_path is a literal "/tmp/..." known a priori to be tmpfs).
    # It is not a dispatcher; it is the verifier of one. Not routed
    # through vfs_fs_kind on purpose — the test wants to fail if the
    # symlink landed on the wrong backend at all.
    if tmpfs_path_is_symlink(link_path) == 0:
        printk0("[LINKAT] FAIL symlink not recorded\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    rl_buf: Array[64, uint8]
    rb: uint64 = 0
    while rb < 64:
        rl_buf[rb] = 0
        rb = rb + 1
    rl_n: int64 = linux_u_syscall_dispatch(SYS_readlink,
                                           cast[uint64](link_path),
                                           cast[uint64](&rl_buf[0]),
                                           64, 0, 0, 0)
    # target "/tmp/lat-data" is 13 bytes.
    if rl_n != 13:
        printk1("[LINKAT] FAIL readlink-after-symlink rc=%d (want 13)\n",
                cast[uint64](rl_n))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    want_tgt: Ptr[uint8] = cast[Ptr[uint8]]("/tmp/lat-data")
    ti: uint64 = 0
    while ti < 13:
        if rl_buf[ti] != want_tgt[ti]:
            printk1("[LINKAT] FAIL symlink target byte @%d\n", ti)
            _statfs_selftest_restore(boot_task, &fd_save[0])
            return 1
        ti = ti + 1

    # --- SYS_symlinkat(target, AT_FDCWD, "/tmp/lat-link2") --------------
    link2_path: Ptr[char] = cast[Ptr[char]]("/tmp/lat-link2")
    sla_rc: int64 = linux_u_syscall_dispatch(SYS_symlinkat,
                                             cast[uint64](data_path),
                                             AT_FDCWD_U64,
                                             cast[uint64](link2_path),
                                             0, 0, 0)
    if sla_rc != 0:
        printk1("[LINKAT] FAIL symlinkat rc=%d\n", cast[uint64](sla_rc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    # F10-9 carve-out: SELFTEST probe — see the equivalent assertion at
    # the SYS_symlink check above for the rationale.
    if tmpfs_path_is_symlink(link2_path) == 0:
        printk0("[LINKAT] FAIL symlinkat not recorded\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- SYS_link("/tmp/lat-data", "/tmp/lat-hard") : tmpfs hardlink ----
    hard_path: Ptr[char] = cast[Ptr[char]]("/tmp/lat-hard")
    lk_rc: int64 = linux_u_syscall_dispatch(SYS_link,
                                            cast[uint64](data_path),
                                            cast[uint64](hard_path),
                                            0, 0, 0, 0)
    if lk_rc != 0:
        printk1("[LINKAT] FAIL link rc=%d\n", cast[uint64](lk_rc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    # Open the new name and assert it reads the SAME byte the original
    # holds (the hardlink aliases the underlying data).
    hfd: int32 = vfs_open(hard_path)
    if hfd < 0:
        printk1("[LINKAT] FAIL hardlink open=%d\n",
                cast[uint64](cast[int64](hfd)))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    rdbuf: Array[1, uint8]
    rdbuf[0] = 0
    nrd: int32 = vfs_read(hfd, &rdbuf[0], 1)
    vfs_close(hfd)
    if nrd != 1 or rdbuf[0] != 81:
        printk2("[LINKAT] FAIL hardlink data nrd=%d byte=%d\n",
                cast[uint64](cast[int64](nrd)), cast[uint64](rdbuf[0]))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- SYS_link cross-backend (/tmp → /ext) must return -EXDEV --------
    # The Plan 9 file-server boundary: a hardlink may not cross servers.
    xdev_dst: Ptr[char] = cast[Ptr[char]]("/ext/lat-xdev")
    xd_rc: int64 = linux_u_syscall_dispatch(SYS_link,
                                            cast[uint64](data_path),
                                            cast[uint64](xdev_dst),
                                            0, 0, 0, 0)
    if xd_rc != EXDEV_LINUX:
        printk1("[LINKAT] FAIL cross-backend link rc=%d (want -18)\n",
                cast[uint64](xd_rc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- SYS_utimensat(AT_FDCWD, "/tmp/lat-data", NULL, 0) : 0 ---------
    ut_rc: int64 = linux_u_syscall_dispatch(SYS_utimensat, AT_FDCWD_U64,
                                            cast[uint64](data_path),
                                            0, 0, 0, 0)
    if ut_rc != 0:
        printk1("[LINKAT] FAIL utimensat rc=%d (want 0)\n",
                cast[uint64](ut_rc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    # utimensat on a MISSING path → -ENOENT.
    miss_path: Ptr[char] = cast[Ptr[char]]("/tmp/lat-nope")
    um_rc: int64 = linux_u_syscall_dispatch(SYS_utimensat, AT_FDCWD_U64,
                                            cast[uint64](miss_path),
                                            0, 0, 0, 0)
    if um_rc != ELINUX_NOENT:
        printk1("[LINKAT] FAIL utimensat-missing rc=%d (want -2)\n",
                cast[uint64](um_rc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    # utimensat with a bad (NULL) path pointer → -EFAULT.
    ub_rc: int64 = linux_u_syscall_dispatch(SYS_utimensat, AT_FDCWD_U64,
                                            0, 0, 0, 0, 0)
    if ub_rc != ELINUX_EFAULT:
        printk1("[LINKAT] FAIL utimensat-badptr rc=%d (want -14)\n",
                cast[uint64](ub_rc))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- cleanup: drop everything so the table/tmpfs is pristine -------
    tmpfs_unlink(link_path)
    tmpfs_unlink(link2_path)
    tmpfs_unlink(hard_path)
    tmpfs_unlink(data_path)

    _statfs_selftest_restore(boot_task, &fd_save[0])
    printk0("[LINKAT] PASS\n")
    return 0


# =====================================================================
# getrandom(2)/statx(2) direct-syscall Linux-ABI self-test
#   (gated on /etc/statx-test, ENABLE_STATX_GETRANDOM_TEST=1)
# =====================================================================
#
# Drives the getrandom(318) and statx(332) DIRECT top-level syscalls
# through the REAL in-kernel Linux-ABI dispatch (linux_u_syscall_dispatch
# — the exact path a Debian/glibc binary takes):
#
#   * getrandom(buf, 32, 0) twice: each returns the full requested length
#     and the two 32-byte buffers differ (the CSPRNG advances), proving we
#     serve real entropy from devrandom (ChaCha20 fast-key-erasure pool,
#     seeded RDSEED/RDRAND/TSC). A zero-length request returns 0.
#   * statx(AT_FDCWD, "/etc", 0, BASIC, buf): mask=BASIC, S_IFMT bits are
#     S_IFDIR (directory), stx_nlink >= 1.
#   * statx on a regular file we plant in /tmp with a known size: S_IFMT
#     bits are S_IFREG and stx_size equals the bytes written.
#   * statx on a missing path returns -ENOENT.
# Prints "[STATX_GETRANDOM] PASS" / "... FAIL ..." on the EMERG channel.
# A default boot ships no marker.

S_IFMT_BITS:  uint32 = 0xF000
S_IFDIR_BITS: uint32 = 0x4000
S_IFREG_BITS: uint32 = 0x8000


def statx_getrandom_selftest() -> int32:
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    # --- getrandom: two 32-byte draws differ, full length, zero-len=0 ----
    gr_a: Array[32, uint8]
    gr_b: Array[32, uint8]
    gi: uint64 = 0
    while gi < 32:
        gr_a[gi] = 0
        gr_b[gi] = 0
        gi = gi + 1
    gra_rc: int64 = linux_u_syscall_dispatch(SYS_getrandom,
                                             cast[uint64](&gr_a[0]),
                                             32, 0, 0, 0, 0)
    if gra_rc != 32:
        printk1("[STATX_GETRANDOM] FAIL getrandom#1 rc=%d (want 32)\n",
                cast[uint64](gra_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    grb_rc: int64 = linux_u_syscall_dispatch(SYS_getrandom,
                                             cast[uint64](&gr_b[0]),
                                             32, 0, 0, 0, 0)
    if grb_rc != 32:
        printk1("[STATX_GETRANDOM] FAIL getrandom#2 rc=%d (want 32)\n",
                cast[uint64](grb_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    differ: int32 = 0
    di: uint64 = 0
    while di < 32:
        if gr_a[di] != gr_b[di]:
            differ = 1
        di = di + 1
    if differ == 0:
        printk0("[STATX_GETRANDOM] FAIL getrandom two draws identical\n")
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    grz_rc: int64 = linux_u_syscall_dispatch(SYS_getrandom,
                                             cast[uint64](&gr_a[0]),
                                             0, 0, 0, 0, 0)
    if grz_rc != 0:
        printk1("[STATX_GETRANDOM] FAIL getrandom zero-len rc=%d (want 0)\n",
                cast[uint64](grz_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[getrandom] entropy/len/zero-len OK\n")

    # --- statx("/etc"): directory mode bits + nlink>=1 ------------------
    sx_buf: Array[256, uint8]
    etc_rc: int64 = linux_u_syscall_dispatch(SYS_statx, AT_FDCWD_U64,
                                             cast[uint64]("/etc"),
                                             0, cast[uint64](STATX_BASIC_STATS),
                                             cast[uint64](&sx_buf[0]), 0)
    if etc_rc != 0:
        printk1("[STATX_GETRANDOM] FAIL statx(/etc) rc=%d\n",
                cast[uint64](etc_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    etc_mask: uint32 = cast[Ptr[uint32]](cast[uint64](&sx_buf[0]) + STATX_OFF_MASK)[0]
    if (etc_mask & STATX_BASIC_STATS) != STATX_BASIC_STATS:
        printk1("[STATX_GETRANDOM] FAIL statx(/etc) mask=%x\n",
                cast[uint64](etc_mask))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    etc_mode: uint16 = cast[Ptr[uint16]](cast[uint64](&sx_buf[0]) + STATX_OFF_MODE)[0]
    if (cast[uint32](etc_mode) & S_IFMT_BITS) != S_IFDIR_BITS:
        printk1("[STATX_GETRANDOM] FAIL statx(/etc) not a dir mode=%x\n",
                cast[uint64](cast[uint32](etc_mode)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    etc_nlink: uint32 = cast[Ptr[uint32]](cast[uint64](&sx_buf[0]) + STATX_OFF_NLINK)[0]
    if etc_nlink < 1:
        printk1("[STATX_GETRANDOM] FAIL statx(/etc) nlink=%d (want >=1)\n",
                cast[uint64](etc_nlink))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[statx] /etc dir/nlink OK\n")

    # --- statx(regular file): plant a known-size file in /tmp ----------
    sx_name: Ptr[char] = cast[Ptr[char]]("/tmp/statx-reg")
    rfd: int32 = vfs_open_write(sx_name)
    if rfd < 0:
        printk1("[STATX_GETRANDOM] FAIL reg-file open=%d\n",
                cast[uint64](cast[int64](rfd)))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    rpay: Array[5, uint8]
    rpay[0] = 72                                          # 'H'
    rpay[1] = 65                                          # 'A'
    rpay[2] = 77                                          # 'M'
    rpay[3] = 78                                          # 'N'
    rpay[4] = 88                                          # 'X'
    vfs_write(rfd, &rpay[0], 5)
    vfs_close(rfd)
    reg_rc: int64 = linux_u_syscall_dispatch(SYS_statx, AT_FDCWD_U64,
                                             cast[uint64]("/tmp/statx-reg"),
                                             0, cast[uint64](STATX_BASIC_STATS),
                                             cast[uint64](&sx_buf[0]), 0)
    if reg_rc != 0:
        printk1("[STATX_GETRANDOM] FAIL statx(reg) rc=%d\n",
                cast[uint64](reg_rc))
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    reg_mode: uint16 = cast[Ptr[uint16]](cast[uint64](&sx_buf[0]) + STATX_OFF_MODE)[0]
    if (cast[uint32](reg_mode) & S_IFMT_BITS) != S_IFREG_BITS:
        printk1("[STATX_GETRANDOM] FAIL statx(reg) not a file mode=%x\n",
                cast[uint64](cast[uint32](reg_mode)))
        tmpfs_unlink(sx_name)
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    reg_size: uint64 = cast[Ptr[uint64]](cast[uint64](&sx_buf[0]) + STATX_OFF_SIZE)[0]
    if reg_size != 5:
        printk1("[STATX_GETRANDOM] FAIL statx(reg) size=%d (want 5)\n",
                reg_size)
        tmpfs_unlink(sx_name)
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[statx] reg-file mode/size OK\n")

    # --- statx(missing path) → -ENOENT ---------------------------------
    miss_rc: int64 = linux_u_syscall_dispatch(SYS_statx, AT_FDCWD_U64,
                                              cast[uint64]("/tmp/statx-nope"),
                                              0, cast[uint64](STATX_BASIC_STATS),
                                              cast[uint64](&sx_buf[0]), 0)
    if miss_rc != ELINUX_NOENT:
        printk1("[STATX_GETRANDOM] FAIL statx(missing) rc=%d (want -2)\n",
                cast[uint64](miss_rc))
        tmpfs_unlink(sx_name)
        _pty_selftest_restore(boot_task, &fd_save[0])
        return 1
    printk0("[statx] missing-path ENOENT OK\n")

    # --- cleanup: drop the planted file so tmpfs is pristine -----------
    tmpfs_unlink(sx_name)
    _pty_selftest_restore(boot_task, &fd_save[0])
    printk0("[STATX_GETRANDOM] PASS\n")
    return 0


# =====================================================================
# getrusage(2) CPU-time self-test
#   (gated on /etc/rusage-test, ENABLE_RUSAGE_TEST=1)
# =====================================================================
#
# Proves the per-task user/system CPU-tick accounting (kernel/sched/core.ad
# current_task_account_tick, driven from the timer ISR) flows through
# _u_getrusage into the rusage timevals. The boot task runs in kernel
# context here, so the timer ISR charges its ticks to stime_ticks. We
# busy-spin until get_jiffies() advances by >= 3 ticks, then call
# _u_getrusage and assert: ru_stime is non-zero (system time advanced),
# the unsupported high word at 0x20 is zero (memset cleared the tail), and
# the call returned 0. Returns 1 on PASS, 0 on FAIL.


def _rusage_field_s64(buf: Ptr[uint8], off: uint64) -> int64:
    return cast[Ptr[int64]](cast[uint64](buf) + off)[0]


def rusage_selftest() -> int32:
    # Snapshot the current task's system-tick count, then let the timer
    # ISR accrue at least 3 more ticks to it.
    st_before: uint64 = current_task_stime_ticks()
    # start_kernel runs with CPU interrupts IF-blocked, so the LAPIC timer
    # tick (which advances jiffies + charges stime to the current task)
    # is armed but never fires here. Briefly enable interrupts, busy-spin
    # until jiffies advances >= 3 ticks (each tick charges stime to THIS
    # on-CPU task — cpu_relax does not yield), then re-disable. Same
    # enable/spin/disable pattern the live-USB keyboard self-test uses.
    local_irq_enable()
    j0: uint64 = get_jiffies()
    while get_jiffies() < j0 + 3:
        cpu_relax()
    local_irq_disable()

    # 144-byte rusage buffer, pre-poisoned with 0xAA so we can prove the
    # memset inside _u_getrusage actually cleared the unsupported tail.
    rbuf: Array[144, uint8]
    pi: uint64 = 0
    while pi < 144:
        rbuf[pi] = 0xAA
        pi = pi + 1

    # In-kernel selftest: fill our OWN kernel buffer via the shared store
    # path. Do NOT route it through _u_getrusage's copy_to_user, which
    # (correctly) rejects a kernel-address destination with -EFAULT.
    rc: int64 = cast[int64](_getrusage_fill(0, cast[uint64](&rbuf[0])))
    if rc != 0:
        printk1("[RUSAGE] FAIL getrusage rc=%d\n", cast[uint64](rc))
        return 0

    # ru_stime (timeval at 0x10) must correspond to a NONZERO tick count.
    st_sec:  int64 = _rusage_field_s64(&rbuf[0], 0x10)
    st_usec: int64 = _rusage_field_s64(&rbuf[0], 0x18)
    st_total_us: int64 = st_sec * 1000000 + st_usec
    if st_total_us <= 0:
        printk0("[RUSAGE] FAIL stime did not advance\n")
        return 0

    # The first unsupported long (ru_maxrss at 0x20) must be zero — proves
    # the memset cleared the 0xAA poison across the whole tail.
    tail: int64 = _rusage_field_s64(&rbuf[0], 0x20)
    if tail != 0:
        printk1("[RUSAGE] FAIL tail not zeroed at 0x20 = %x\n",
                cast[uint64](tail))
        return 0

    ut_after: uint64 = current_task_utime_ticks()
    st_after: uint64 = current_task_stime_ticks()
    if st_after <= st_before:
        printk0("[RUSAGE] FAIL stime_ticks did not increase\n")
        return 0

    printk2("[RUSAGE] PASS utime_ticks=%d stime_ticks=%d\n",
            ut_after, st_after)
    return 1


# =====================================================================
# page-fault accounting self-test
#   (gated on /etc/pgfault-test, ENABLE_PGFAULT_TEST=1)
# =====================================================================
#
# Proves the per-task page-fault counters (kernel/sched/core.ad minflt /
# majflt, charged from the page-fault handler arch/x86/kernel/trap_diag.ad
# on resolved demand-zero / COW / swap-in faults) flow through both
# _u_getrusage (ru_minflt 0x40 / ru_majflt 0x48) and the read accessors.
# The boot bootstrap task can't easily trigger real user demand faults, so
# this test drives the charge helpers directly: snapshot the counts, charge
# 3 minor + 2 major faults, assert the read accessors rose by exactly that,
# then render the rusage struct and assert 0x40 == new minflt and
# 0x48 == new majflt. Returns 1 on PASS, 0 on FAIL.


def pgfault_selftest() -> int32:
    mn_before: uint64 = current_task_minflt()
    mj_before: uint64 = current_task_majflt()

    # Charge 3 minor + 2 major faults via the exact helpers the page-fault
    # handler calls on its resolved paths.
    current_task_account_minor_fault()
    current_task_account_minor_fault()
    current_task_account_minor_fault()
    current_task_account_major_fault()
    current_task_account_major_fault()

    mn_after: uint64 = current_task_minflt()
    mj_after: uint64 = current_task_majflt()
    if mn_after != mn_before + 3:
        printk2("[PGFAULT] FAIL minflt rose by %d not 3 (now %d)\n",
                mn_after - mn_before, mn_after)
        return 0
    if mj_after != mj_before + 2:
        printk2("[PGFAULT] FAIL majflt rose by %d not 2 (now %d)\n",
                mj_after - mj_before, mj_after)
        return 0

    # Render the rusage struct via the same store path _u_getrusage uses
    # into a LOCAL buffer, poisoned with 0xAA first so we prove the memset
    # cleared the tail too.
    rbuf: Array[144, uint8]
    pi: uint64 = 0
    while pi < 144:
        rbuf[pi] = 0xAA
        pi = pi + 1
    # In-kernel selftest: fill our OWN kernel buffer via the shared store
    # path. Do NOT route it through _u_getrusage's copy_to_user, which
    # (correctly) rejects a kernel-address destination with -EFAULT.
    rc: int64 = cast[int64](_getrusage_fill(0, cast[uint64](&rbuf[0])))
    if rc != 0:
        printk1("[PGFAULT] FAIL getrusage rc=%d\n", cast[uint64](rc))
        return 0

    ru_minflt: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x40)[0]
    ru_majflt: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x48)[0]
    if ru_minflt != mn_after:
        printk2("[PGFAULT] FAIL ru_minflt=%d != minflt=%d\n",
                ru_minflt, mn_after)
        return 0
    if ru_majflt != mj_after:
        printk2("[PGFAULT] FAIL ru_majflt=%d != majflt=%d\n",
                ru_majflt, mj_after)
        return 0

    # Report the deterministic deltas (3 / 2) so the gate banner reads
    # exactly "[PGFAULT] PASS minflt=3 majflt=2" regardless of any prior
    # charged faults on this boot task.
    printk2("[PGFAULT] PASS minflt=%d majflt=%d\n",
            mn_after - mn_before, mj_after - mj_before)
    return 1


# =====================================================================
# context-switch accounting self-test
#   (gated on /etc/ctxsw-test, ENABLE_CTXSW_TEST=1)
# =====================================================================
#
# Proves the per-task context-switch counters (kernel/sched/core.ad nvcsw /
# nivcsw, charged from schedule() on every real prev != next switch via the
# slot-indexed helpers) flow through both _u_getrusage (ru_nvcsw 0x80 /
# ru_nivcsw 0x88) and the read accessors. The boot bootstrap task usually
# has no second runnable task, so a real yield may not switch; drive the
# charge helpers directly: snapshot the counts, charge 2 voluntary + 3
# involuntary switches, assert the read accessors rose by exactly that, then
# render the rusage struct and assert 0x80 == new nvcsw and 0x88 == new
# nivcsw. Returns 1 on PASS, 0 on FAIL.


def ctxsw_selftest() -> int32:
    nv_before: uint64 = current_task_nvcsw()
    niv_before: uint64 = current_task_nivcsw()

    # Charge 2 voluntary + 3 involuntary switches via the exact slot-indexed
    # helpers schedule() drives at the context-switch site.
    slot: uint64 = current_idx_get()
    task_account_voluntary_ctxsw_at(slot)
    task_account_voluntary_ctxsw_at(slot)
    task_account_involuntary_ctxsw_at(slot)
    task_account_involuntary_ctxsw_at(slot)
    task_account_involuntary_ctxsw_at(slot)

    nv_after: uint64 = current_task_nvcsw()
    niv_after: uint64 = current_task_nivcsw()
    if nv_after != nv_before + 2:
        printk2("[CTXSW] FAIL nvcsw rose by %d not 2 (now %d)\n",
                nv_after - nv_before, nv_after)
        return 0
    if niv_after != niv_before + 3:
        printk2("[CTXSW] FAIL nivcsw rose by %d not 3 (now %d)\n",
                niv_after - niv_before, niv_after)
        return 0

    # Render the rusage struct via the same store path _u_getrusage uses
    # into a LOCAL buffer, poisoned with 0xAA first so we prove the memset
    # cleared the tail too.
    rbuf: Array[144, uint8]
    pi: uint64 = 0
    while pi < 144:
        rbuf[pi] = 0xAA
        pi = pi + 1
    # In-kernel selftest: fill our OWN kernel buffer via the shared store
    # path. Do NOT route it through _u_getrusage's copy_to_user, which
    # (correctly) rejects a kernel-address destination with -EFAULT.
    rc: int64 = cast[int64](_getrusage_fill(0, cast[uint64](&rbuf[0])))
    if rc != 0:
        printk1("[CTXSW] FAIL getrusage rc=%d\n", cast[uint64](rc))
        return 0

    ru_nvcsw: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x80)[0]
    ru_nivcsw: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x88)[0]
    if ru_nvcsw != nv_after:
        printk2("[CTXSW] FAIL ru_nvcsw=%d != nvcsw=%d\n",
                ru_nvcsw, nv_after)
        return 0
    if ru_nivcsw != niv_after:
        printk2("[CTXSW] FAIL ru_nivcsw=%d != nivcsw=%d\n",
                ru_nivcsw, niv_after)
        return 0

    # Report the deterministic deltas (2 / 3) so the gate banner reads
    # exactly "[CTXSW] PASS nvcsw=2 nivcsw=3" regardless of any prior
    # charged switches on this boot task.
    printk2("[CTXSW] PASS nvcsw=%d nivcsw=%d\n",
            nv_after - nv_before, niv_after - niv_before)
    return 1


# =====================================================================
# block-I/O accounting self-test
#   (gated on /etc/blkio-test, ENABLE_BLKIO_TEST=1)
# =====================================================================
#
# Proves the per-task block-I/O counters (kernel/sched/core.ad inblock /
# oublock, charged from the block layer kernel/block/blk.ad at the I/O
# completion site: blk_read_sectors -> inblock, blk_write_sectors ->
# oublock, by request length in 512-byte sectors) flow through both
# _u_getrusage (ru_inblock 0x58 / ru_oublock 0x60) and the read accessors.
# The boot bootstrap task does little deterministic real block I/O, so
# drive the charge helpers directly: snapshot the counts, charge 8 block
# reads + 4 block writes (distinct numbers), assert the read accessors rose
# by exactly that, then render the rusage struct and assert 0x58 == new
# inblock and 0x60 == new oublock. Returns 1 on PASS, 0 on FAIL.


def blkio_selftest() -> int32:
    in_before: uint64 = current_task_inblock()
    ou_before: uint64 = current_task_oublock()

    # Charge 8 block reads + 4 block writes via the exact helpers the block
    # layer calls at the I/O completion site.
    current_task_account_inblock(8)
    current_task_account_oublock(4)

    in_after: uint64 = current_task_inblock()
    ou_after: uint64 = current_task_oublock()
    if in_after != in_before + 8:
        printk2("[BLKIO] FAIL inblock rose by %d not 8 (now %d)\n",
                in_after - in_before, in_after)
        return 0
    if ou_after != ou_before + 4:
        printk2("[BLKIO] FAIL oublock rose by %d not 4 (now %d)\n",
                ou_after - ou_before, ou_after)
        return 0

    # Render the rusage struct via the same store path _u_getrusage uses
    # into a LOCAL buffer, poisoned with 0xAA first so we prove the memset
    # cleared the tail too.
    rbuf: Array[144, uint8]
    pi: uint64 = 0
    while pi < 144:
        rbuf[pi] = 0xAA
        pi = pi + 1
    # In-kernel selftest: fill our OWN kernel buffer via the shared store
    # path. Do NOT route it through _u_getrusage's copy_to_user, which
    # (correctly) rejects a kernel-address destination with -EFAULT.
    rc: int64 = cast[int64](_getrusage_fill(0, cast[uint64](&rbuf[0])))
    if rc != 0:
        printk1("[BLKIO] FAIL getrusage rc=%d\n", cast[uint64](rc))
        return 0

    ru_inblock: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x58)[0]
    ru_oublock: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x60)[0]
    if ru_inblock != in_after:
        printk2("[BLKIO] FAIL ru_inblock=%d != inblock=%d\n",
                ru_inblock, in_after)
        return 0
    if ru_oublock != ou_after:
        printk2("[BLKIO] FAIL ru_oublock=%d != oublock=%d\n",
                ru_oublock, ou_after)
        return 0

    # Report the deterministic deltas (8 / 4) so the gate banner reads
    # exactly "[BLKIO] PASS inblock=8 oublock=4" regardless of any real
    # block I/O charged to this boot task earlier.
    printk2("[BLKIO] PASS inblock=%d oublock=%d\n",
            in_after - in_before, ou_after - ou_before)
    return 1


def nsignals_selftest() -> int32:
    ns_before: uint64 = current_task_nsignals()
    slot: uint64 = current_idx_get()

    # Charge 5 delivered signals via the exact slot-indexed helper that
    # signal_post calls at the signal-latch site.
    task_account_signal_at(slot)
    task_account_signal_at(slot)
    task_account_signal_at(slot)
    task_account_signal_at(slot)
    task_account_signal_at(slot)

    ns_after: uint64 = current_task_nsignals()
    if ns_after != ns_before + 5:
        printk2("[NSIGNALS] FAIL nsignals rose by %d not 5 (now %d)\n",
                ns_after - ns_before, ns_after)
        return 0

    # Render the rusage struct via the same store path _u_getrusage uses
    # into a LOCAL buffer, poisoned with 0xAA first so we prove the memset
    # cleared the tail too.
    rbuf: Array[144, uint8]
    pi: uint64 = 0
    while pi < 144:
        rbuf[pi] = 0xAA
        pi = pi + 1
    # In-kernel selftest: fill our OWN kernel buffer via the shared store
    # path. Do NOT route it through _u_getrusage's copy_to_user, which
    # (correctly) rejects a kernel-address destination with -EFAULT.
    rc: int64 = cast[int64](_getrusage_fill(0, cast[uint64](&rbuf[0])))
    if rc != 0:
        printk1("[NSIGNALS] FAIL getrusage rc=%d\n", cast[uint64](rc))
        return 0

    ru_nsignals: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x78)[0]
    if ru_nsignals != ns_after:
        printk2("[NSIGNALS] FAIL ru_nsignals=%d != nsignals=%d\n",
                ru_nsignals, ns_after)
        return 0

    # Report the deterministic delta (5) so the gate banner reads exactly
    # "[NSIGNALS] PASS nsignals=5" regardless of any real signals delivered
    # to this boot task earlier.
    printk1("[NSIGNALS] PASS nsignals=%d\n", ns_after - ns_before)
    return 1


def ruchild_selftest() -> int32:
    # getrusage(2) RUSAGE_CHILDREN path: seed the current/boot task's child
    # accumulators with known sentinels via the direct slot-indexed setters,
    # call _u_getrusage with who=RUSAGE_CHILDREN (-1) into a local rusage
    # buffer, and assert the child counters land in ru_utime/ru_stime/
    # ru_minflt/ru_majflt (NOT the SELF counters). Restore the c* fields to 0
    # afterward so the boot task is not left polluted.
    slot: int32 = cast[int32](current_idx_get())

    # Remember the live child accumulators so we can restore them, then seed
    # deterministic sentinels: cutime=700 ticks, cstime=1300 ticks,
    # cminflt=33, cmajflt=44.
    save_cu: uint64 = current_task_cutime_ticks()
    save_cs: uint64 = current_task_cstime_ticks()
    save_cmin: uint64 = task_cminflt_at(slot)
    save_cmaj: uint64 = task_cmajflt_at(slot)
    task_set_cutime_ticks_at(slot, 700)
    task_set_cstime_ticks_at(slot, 1300)
    task_set_cminflt_at(slot, 33)
    task_set_cmajflt_at(slot, 44)

    # Render the rusage struct via the same store path _u_getrusage uses
    # into a LOCAL buffer, poisoned with 0xAA first so we prove the memset
    # cleared the tail too.
    rbuf: Array[144, uint8]
    pi: uint64 = 0
    while pi < 144:
        rbuf[pi] = 0xAA
        pi = pi + 1
    # In-kernel selftest: fill our OWN kernel buffer via the shared store
    # path (RUSAGE_CHILDREN = -1). Do NOT route it through _u_getrusage's
    # copy_to_user, which (correctly) rejects a kernel-address destination.
    rc: int64 = cast[int64](_getrusage_fill(cast[uint64](0) - cast[uint64](1),
                                            cast[uint64](&rbuf[0])))
    if rc != 0:
        task_set_cutime_ticks_at(slot, save_cu)
        task_set_cstime_ticks_at(slot, save_cs)
        task_set_cminflt_at(slot, save_cmin)
        task_set_cmajflt_at(slot, save_cmaj)
        printk1("[RUCHILD] FAIL getrusage rc=%d\n", cast[uint64](rc))
        return 0

    ru_utime_sec: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x00)[0]
    ru_stime_sec: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x10)[0]
    ru_minflt: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x40)[0]
    ru_majflt: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x48)[0]

    # Restore the c* fields before any return so the boot task is clean.
    task_set_cutime_ticks_at(slot, save_cu)
    task_set_cstime_ticks_at(slot, save_cs)
    task_set_cminflt_at(slot, save_cmin)
    task_set_cmajflt_at(slot, save_cmaj)

    # 700 ticks / 100 = 7s; 1300 / 100 = 13s; faults pass through verbatim.
    if ru_utime_sec != 7:
        printk1("[RUCHILD] FAIL ru_utime sec=%d != 7\n", ru_utime_sec)
        return 0
    if ru_stime_sec != 13:
        printk1("[RUCHILD] FAIL ru_stime sec=%d != 13\n", ru_stime_sec)
        return 0
    if ru_minflt != 33:
        printk1("[RUCHILD] FAIL ru_minflt=%d != 33\n", ru_minflt)
        return 0
    if ru_majflt != 44:
        printk1("[RUCHILD] FAIL ru_majflt=%d != 44\n", ru_majflt)
        return 0

    printk0("[RUCHILD] PASS cutime=7 cstime=13 cminflt=33 cmajflt=44\n")
    return 1


def rlimit_selftest() -> int32:
    # getrlimit/setrlimit/prlimit64 round-trip self-test against the REAL
    # per-task rlimit store. SET RLIMIT_NOFILE(7) to {512,4096} on the current
    # task via prlimit64(new), GET it back via prlimit64(old) and assert the
    # set persisted. Also GET RLIMIT_STACK(3) and assert the seeded 768 KiB
    # default. Restore NOFILE to its default afterward so the boot task is
    # left clean. struct rlimit64 = { uint64 rlim_cur; uint64 rlim_max; }.
    RLIMIT_STACK:  uint64 = 3
    RLIMIT_NOFILE: uint64 = 7

    # Build `new` = {cur=512, max=4096} on the stack and SET it.
    newbuf: Array[16, uint8]
    cast[Ptr[uint64]](cast[uint64](&newbuf[0]))[0]     = 512
    cast[Ptr[uint64]](cast[uint64](&newbuf[0]) + 8)[0] = 4096
    rc: int64 = _u_prlimit64(0, RLIMIT_NOFILE,
                             cast[uint64](&newbuf[0]), 0, 0, 0)
    if rc != 0:
        printk1("[RLIMIT] FAIL set nofile rc=%d\n", cast[uint64](rc))
        return 0

    # GET it back into a second buffer and verify it persisted.
    oldbuf: Array[16, uint8]
    cast[Ptr[uint64]](cast[uint64](&oldbuf[0]))[0]     = 0
    cast[Ptr[uint64]](cast[uint64](&oldbuf[0]) + 8)[0] = 0
    rc = _u_prlimit64(0, RLIMIT_NOFILE, 0,
                      cast[uint64](&oldbuf[0]), 0, 0)
    if rc != 0:
        printk1("[RLIMIT] FAIL get nofile rc=%d\n", cast[uint64](rc))
        return 0
    nofile_cur: uint64 = cast[Ptr[uint64]](cast[uint64](&oldbuf[0]))[0]
    nofile_max: uint64 = cast[Ptr[uint64]](cast[uint64](&oldbuf[0]) + 8)[0]
    if nofile_cur != 512:
        printk1("[RLIMIT] FAIL nofile_cur=%d != 512\n", nofile_cur)
        return 0
    if nofile_max != 4096:
        printk1("[RLIMIT] FAIL nofile_max=%d != 4096\n", nofile_max)
        return 0

    # GET RLIMIT_STACK — proves the seeded default is real.
    rc = _u_prlimit64(0, RLIMIT_STACK, 0,
                      cast[uint64](&oldbuf[0]), 0, 0)
    if rc != 0:
        printk1("[RLIMIT] FAIL get stack rc=%d\n", cast[uint64](rc))
        return 0
    stack_cur: uint64 = cast[Ptr[uint64]](cast[uint64](&oldbuf[0]))[0]
    # RLIMIT_STACK soft default is now 2 MiB (0x200000) — it MUST equal the
    # FIXED pre-mapped Linux user stack size (LINUX_USTACK_SIZE), so glibc
    # never probes below the real mapping. See rlimit_init_task + the
    # LINUX_USTACK_* comment block in arch/x86/kernel/syscall.ad.
    if stack_cur != 0xC0000:
        printk1("[RLIMIT] FAIL stack_cur=%d != 786432\n", stack_cur)
        return 0

    # Restore RLIMIT_NOFILE to its default {1024, 4096} so the boot task is
    # left clean.
    cast[Ptr[uint64]](cast[uint64](&newbuf[0]))[0]     = 1024
    cast[Ptr[uint64]](cast[uint64](&newbuf[0]) + 8)[0] = 4096
    _u_prlimit64(0, RLIMIT_NOFILE, cast[uint64](&newbuf[0]), 0, 0, 0)

    printk0("[RLIMIT] PASS nofile_cur=512 nofile_max=4096 stack_cur=786432\n")
    return 1


def priority_syscall_selftest() -> int32:
    # getpriority(2)/setpriority(2) round-trip against the REAL per-task nice
    # store. SAVE the boot task's nice, SET it to 5 via setpriority(PRIO_PROCESS,
    # self), assert sched_get_nice observes 5 on the real store, then GET it back
    # via getpriority and assert the biased ABI form 20 - 5 == 15. RESTORE the
    # saved nice so the boot task is left clean.
    saved: int64 = sched_get_nice(current_idx_get())

    rc: int64 = _u_setpriority(0, 0, 5, 0, 0, 0)
    if rc != 0:
        printk1("[PRIOSYS] FAIL setpriority rc=%d\n", cast[uint64](rc))
        return 0
    now: int64 = sched_get_nice(current_idx_get())
    if now != 5:
        printk1("[PRIOSYS] FAIL nice=%d != 5\n", cast[uint64](now))
        return 0

    gp: int64 = _u_getpriority(0, 0, 0, 0, 0, 0)
    if gp != 15:
        printk1("[PRIOSYS] FAIL getprio_ret=%d != 15\n", cast[uint64](gp))
        return 0

    # Restore the saved nice so the boot task is left clean.
    _u_setpriority(0, 0, cast[uint64](saved), 0, 0, 0)

    printk0("[PRIOSYS] PASS set_nice=5 getprio_ret=15\n")
    return 1


def vmstat_selftest() -> int32:
    # /proc/<pid>/stat fields 23 (vsize) / 24 (rss) + getrusage ru_maxrss
    # (0x20) — all three computed on demand from the VMA walk. The boot
    # task that runs this hook (boot:37) went through neither do_execve nor
    # create_user_task, so its VMA list is EMPTY. Build a real demand-paged
    # anonymous VMA (vma_alloc_demand reserves the range with not-present
    # 4 KiB PTEs) and fault its pages in directly (a synchronous kernel
    # self-test cannot take a real #PF on its own access), so the
    # 4 KiB-granular present-walk has genuine present PTEs to count. An
    # EAGER vma_alloc would not work here: its pages live in the huge-page
    # identity map, which _vma_pte_lookup reads as not-present. Arm NXE
    # first — the writable-NX demand pages would otherwise take a
    # reserved-bit #PF, same as the file-mmap selftests.
    PG: uint64 = 4096
    NPAGES: uint64 = 4
    set_efer_nxe()
    slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](slot))

    base64: int64 = vma_alloc_demand(slot, 0, NPAGES * PG,
                                     VMA_PROT_READ | VMA_PROT_WRITE,
                                     VMA_MAP_PRIVATE | VMA_MAP_ANONYMOUS)
    if base64 < 0:
        printk1("[VMSTAT] FAIL vma_alloc_demand rc=%d\n",
                cast[uint64](base64))
        return 0
    vbase: uint64 = cast[uint64](base64)

    # Fault every page in so it gets a present private 4 KiB PTE.
    fp: uint64 = 0
    while fp < NPAGES:
        if vma_demand_fault(slot, boot_pml4, vbase + fp * PG) != 1:
            printk1("[VMSTAT] FAIL demand-fault page %d\n", fp)
            return 0
        fp = fp + 1

    vs: uint64 = task_vsize_bytes(slot)
    if vs == 0:
        printk0("[VMSTAT] FAIL vsize is 0 (task has no VMAs?)\n")
        return 0

    rp: uint64 = task_rss_pages(slot)
    if rp == 0:
        printk0("[VMSTAT] FAIL rss is 0 (no present pages?)\n")
        return 0

    # Drive _u_getrusage into a LOCAL 144-byte buffer poisoned with 0xAA
    # first, then read ru_maxrss at offset 0x20 and assert the KB high-
    # water is at least the current rss in KB (present pages * 4 KB).
    rbuf: Array[144, uint8]
    pi: uint64 = 0
    while pi < 144:
        rbuf[pi] = 0xAA
        pi = pi + 1
    # In-kernel selftest: fill our OWN kernel buffer via the shared store
    # path. Do NOT route it through _u_getrusage's copy_to_user, which
    # (correctly) rejects a kernel-address destination with -EFAULT.
    rc: int64 = cast[int64](_getrusage_fill(0, cast[uint64](&rbuf[0])))
    if rc != 0:
        printk1("[VMSTAT] FAIL getrusage rc=%d\n", cast[uint64](rc))
        return 0

    ru_maxrss: uint64 = cast[Ptr[uint64]](cast[uint64](&rbuf[0]) + 0x20)[0]
    if ru_maxrss < rp * 4:
        printk2("[VMSTAT] FAIL ru_maxrss=%d < rss_kb=%d\n",
                ru_maxrss, rp * 4)
        return 0

    printk2("[VMSTAT] PASS vsize=%d rss=%d\n", vs, rp)
    return 1


def statm_selftest() -> int32:
    # /proc/<pid>/statm fields 1 (size) / 2 (resident) — both computed on
    # demand from the VMA walk, rendered by the PUBLIC emit_statm. Same
    # boot-task caveat as vmstat_selftest: the hook task went through
    # neither do_execve nor create_user_task, so its VMA list is EMPTY and
    # its low memory is huge-page identity-mapped (the 4 KiB-granular
    # present-walk reads that as not-present). Build a real demand-paged
    # anonymous VMA (vma_alloc_demand reserves the range with not-present
    # 4 KiB PTEs) and fault its pages in directly so size + resident are
    # both non-zero. Arm NXE first — the writable-NX demand pages would
    # otherwise take a reserved-bit #PF.
    PG: uint64 = 4096
    NPAGES: uint64 = 4
    set_efer_nxe()
    slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](slot))

    base64: int64 = vma_alloc_demand(slot, 0, NPAGES * PG,
                                     VMA_PROT_READ | VMA_PROT_WRITE,
                                     VMA_MAP_PRIVATE | VMA_MAP_ANONYMOUS)
    if base64 < 0:
        printk1("[STATM] FAIL vma_alloc_demand rc=%d\n",
                cast[uint64](base64))
        return 0
    vbase: uint64 = cast[uint64](base64)

    # Fault every page in so it gets a present private 4 KiB PTE.
    fp: uint64 = 0
    while fp < NPAGES:
        if vma_demand_fault(slot, boot_pml4, vbase + fp * PG) != 1:
            printk1("[STATM] FAIL demand-fault page %d\n", fp)
            return 0
        fp = fp + 1

    # Render the statm line into a local buffer via the real emitter.
    sbuf: Array[128, uint8]
    bi: uint64 = 0
    while bi < 128:
        sbuf[bi] = 0
        bi = bi + 1
    n: int64 = emit_statm(&sbuf[0], 128, cast[int32](slot))
    if n <= 0:
        printk1("[STATM] FAIL emit_statm rc=%d\n", cast[uint64](n))
        return 0
    nlen: uint64 = cast[uint64](n)

    # Inline-parse the first two whitespace-separated decimal fields.
    p: uint64 = 0
    size_v: uint64 = 0
    while p < nlen and sbuf[p] >= 48 and sbuf[p] <= 57:
        size_v = size_v * 10 + cast[uint64](sbuf[p] - 48)
        p = p + 1
    # skip the single space separator
    while p < nlen and sbuf[p] == 32:
        p = p + 1
    res_v: uint64 = 0
    while p < nlen and sbuf[p] >= 48 and sbuf[p] <= 57:
        res_v = res_v * 10 + cast[uint64](sbuf[p] - 48)
        p = p + 1

    if size_v == 0:
        printk0("[STATM] FAIL size is 0 (task has no VMAs?)\n")
        return 0
    if res_v == 0:
        printk0("[STATM] FAIL resident is 0 (no present pages?)\n")
        return 0

    # Cross-check against the helpers the emitter draws from.
    want_size: uint64 = task_vsize_bytes(slot) / 4096
    want_res:  uint64 = task_rss_pages(slot)
    if size_v != want_size:
        printk2("[STATM] FAIL size=%d != vsize_pages=%d\n",
                size_v, want_size)
        return 0
    if res_v != want_res:
        printk2("[STATM] FAIL res=%d != rss_pages=%d\n",
                res_v, want_res)
        return 0

    printk2("[STATM] PASS size=%d res=%d\n", size_v, res_v)
    return 1


def _maps_buf_contains(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    # 1 iff `needle` (NUL-terminated) occurs in buf[0:n]. Naive scan — the
    # buffer is a couple KiB and the needle a few bytes, so O(n*m) is fine.
    nl: uint64 = 0
    while needle[nl] != 0:
        nl = nl + 1
    if nl == 0:
        return 1
    if nl > n:
        return 0
    i: uint64 = 0
    while i + nl <= n:
        j: uint64 = 0
        while j < nl and buf[i + j] == needle[j]:
            j = j + 1
        if j == nl:
            return 1
        i = i + 1
    return 0


def maps_open_selftest() -> int32:
    # Blocker #2 in the Firefox window chain (also a GENERAL capability:
    # glibc pthread_getattr_np, ASan, debuggers all read /proc/self/maps).
    # glibc's __pthread_getattr_np (main thread) fopen()s "/proc/self/maps"
    # and scans it for the line whose [from,to) contains __libc_stack_end to
    # learn the main-thread stack bounds; if the open FAILS it aborts
    # (Firefox: MOZ_RELEASE_ASSERT(!res) in pthread_attr_init).
    #
    # This exercises the EXACT userspace open path a Debian ELF's
    # SYS_openat("/proc/self/maps") takes: vfs_open -> resolve_path rewrites
    # "/proc/self/maps" -> "#p/self/maps" through the calling Pgrp's
    # `/proc -> #p` bind -> devproc DEVPROC_KIND_MAPS -> mm/vma.ad
    # vma_maps_render. Reads are world-OK at the `#p` server boundary, so the
    # (hostowner) boot task's vfs_open perm gate admits it. Asserts:
    #   (a) the open SUCCEEDS (fd >= 0)                — the blocker-#2 fix,
    #   (b) the read returns bytes,
    #   (c) the map carries an address-range line,
    #   (d) it carries the synthetic [stack] line glibc needs (a2848643).
    PG: uint64 = 4096
    NPAGES: uint64 = 2
    set_efer_nxe()
    slot: uint64 = current_idx_get()

    # (1) A real anonymous VMA so the map has at least one region line (the
    #     boot task's VMA list is otherwise empty). Same fixture shape as
    #     statm_selftest; leaked at boot exactly as statm does (one-shot).
    base64: int64 = vma_alloc_demand(slot, 0, NPAGES * PG,
                                     VMA_PROT_READ | VMA_PROT_WRITE,
                                     VMA_MAP_PRIVATE | VMA_MAP_ANONYMOUS)
    if base64 < 0:
        printk1("[MAPS] FAIL vma_alloc_demand rc=%d\n", cast[uint64](base64))
        return 0

    # (2) Synthesize a main-thread user-stack range. The boot slot never went
    #     through do_execve (elf_install_user_stack), so ustack_lo/sz are 0
    #     and vma_maps_render would omit [stack]. Save + restore so nothing
    #     that later reads the boot slot's ustack sees the fixture value.
    save_lo: uint64 = task_ustack_lo(slot)
    save_sz: uint64 = task_ustack_sz(slot)
    FAKE_LO: uint64 = 0x7ffffffde000
    FAKE_SZ: uint64 = 0x00021000
    set_task_ustack_range(slot, FAKE_LO, FAKE_SZ)

    mbuf: Array[2048, uint8]
    mi: uint64 = 0
    while mi < 2048:
        mbuf[mi] = 0
        mi = mi + 1

    # (3) NAMESPACE ROUTING — the crux of blocker #2. resolve_path must rewrite
    #     "/proc/self/maps" to the `#p` proc server (via the calling Pgrp's
    #     `/proc -> #p` bind) so the open reaches devproc's maps renderer rather
    #     than ENOENT'ing on the distro's own empty /proc. A regression that
    #     dropped the bind (or shadowed it with a system-wide /proc/<name> leaf
    #     bind) would surface as a non-`#p/` resolution or an error here.
    rbuf: Array[256, uint8]
    rrc: int32 = resolve_path(cast[Ptr[char]]("/proc/self/maps"), &rbuf[0], 256)
    if rrc != 0:
        set_task_ustack_range(slot, save_lo, save_sz)
        printk1("[MAPS] FAIL resolve_path rc=%d\n", cast[uint64](rrc))
        return 0
    if rbuf[0] != 35 or rbuf[1] != 112 or rbuf[2] != 47:   # "#p/"
        set_task_ustack_range(slot, save_lo, save_sz)
        printk0("[MAPS] FAIL /proc/self/maps did NOT resolve to the #p server\n")
        return 0

    # (4) END-TO-END userspace open, exactly as a Debian ELF's openat does.
    #     "/proc/self" resolves to the CALLER's pid (devproc _parse_proc_path).
    #     The kernel boot task's fd table is not in an allocatable state (it
    #     never went through create_user_task), so this may return -EMFILE
    #     (-24) HERE while a real user task (Firefox) opens cleanly; that
    #     specific artifact is tolerated and the render is verified via the
    #     proc server directly below. ANY OTHER negative (routing/perm
    #     regression) is a hard failure.
    n: int64 = 0
    fd: int32 = vfs_open(cast[Ptr[char]]("/proc/self/maps"))
    if fd >= 0:
        n = vfs_read(fd, &mbuf[0], 2047)
        vfs_close(fd)
        printk0("[MAPS] note: end-to-end vfs_open succeeded in boot task\n")
    elif fd == -24:                                        # -EMFILE
        # Boot-task fd table saturated — render through the proc server without
        # allocating an fd slot: devproc_open returns an encoded (pid<<8|kind)
        # handle (NO fd allocation), devproc_read walks it exactly as the
        # userspace fd read would (KIND_MAPS -> vma_maps_render).
        enc: int64 = devproc_open(cast[Ptr[char]]("/proc/self/maps"))
        if enc < 0:
            set_task_ustack_range(slot, save_lo, save_sz)
            printk1("[MAPS] FAIL devproc_open /proc/self/maps rc=%d\n",
                    cast[uint64](enc))
            return 0
        n = devproc_read(cast[uint32](enc & 0xFFFFFFFF), 0, &mbuf[0], 2047)
        printk0("[MAPS] note: boot-task fd table saturated;"
                " verified via #p proc server\n")
    else:
        set_task_ustack_range(slot, save_lo, save_sz)
        printk1("[MAPS] FAIL open /proc/self/maps rc=%d\n", cast[uint64](fd))
        return 0
    set_task_ustack_range(slot, save_lo, save_sz)

    if n <= 0:
        printk1("[MAPS] FAIL read rc=%d\n", cast[uint64](n))
        return 0
    nlen: uint64 = cast[uint64](n)

    # (5a) An address-range line: at least one '-' (start-end separator).
    has_range: int32 = 0
    k: uint64 = 0
    while k < nlen:
        if mbuf[k] == 45:                            # '-'
            has_range = 1
            k = nlen
        else:
            k = k + 1
    if has_range == 0:
        printk0("[MAPS] FAIL no address-range line in /proc/self/maps\n")
        return 0

    # (5b) The [stack] line glibc's pthread_getattr_np requires.
    if _maps_buf_contains(&mbuf[0], nlen, "[stack]") == 0:
        printk0("[MAPS] FAIL no [stack] line (pthread_getattr_np would abort)\n")
        return 0

    printk1("[MAPS] PASS bytes=%d range+[stack] present\n", nlen)
    return 1


def times_selftest() -> int32:
    st_before: uint64 = current_task_stime_ticks()
    local_irq_enable()
    j0: uint64 = get_jiffies()
    while get_jiffies() < j0 + 3:
        cpu_relax()
    local_irq_disable()
    tbuf: Array[32, uint8]
    pi: uint64 = 0
    while pi < 32:
        tbuf[pi] = 0xAA
        pi = pi + 1
    rc: int64 = _u_times(cast[uint64](&tbuf[0]), 0, 0, 0, 0, 0)
    if rc <= 0:
        printk1("[TIMES] FAIL ret not positive rc=%d\n", cast[uint64](rc))
        return 0
    st_field: int64 = cast[Ptr[int64]](cast[uint64](&tbuf[0]) + 0x08)[0]
    if st_field <= 0:
        printk0("[TIMES] FAIL tms_stime did not advance\n")
        return 0
    cu_field: int64 = cast[Ptr[int64]](cast[uint64](&tbuf[0]) + 0x10)[0]
    if cu_field != 0:
        printk1("[TIMES] FAIL cutime not zeroed = %x\n", cast[uint64](cu_field))
        return 0
    st_after: uint64 = current_task_stime_ticks()
    if st_after <= st_before:
        printk0("[TIMES] FAIL stime_ticks did not increase\n")
        return 0
    printk2("[TIMES] PASS ret=%d tms_stime=%d\n", cast[uint64](rc), cast[uint64](st_field))
    return 1


# =====================================================================
# access(2) mode-bit self-test
#   (gated on /etc/access-mode-test, ENABLE_ACCESS_MODE_TEST=1)
# =====================================================================
#
# Proves the access(2) handler (_u_access) does a REAL R/W/X check
# against an ext4 file's mode bits — the bit a busybox PATH search or
# `test -x` relies on. Drives SYS_access through the live in-kernel
# Linux-ABI dispatch (the exact path a Debian/busybox binary takes),
# against ext4 files whose modes the test itself stamps on the live
# /ext mount:
#   * 0664 (S_IFREG|rw-rw-r--): F_OK==0, R_OK==0, W_OK==0, X_OK==-EACCES
#   * 0755 (S_IFREG|rwxr-xr-x): X_OK==0 (PATH-search executable case)
#   * 0444 (S_IFREG|r--r--r--): R_OK==0, W_OK==-EACCES
#   * a non-existent path: -ENOENT
#
# Mode bits per <unistd.h>: F_OK=0, X_OK=1, W_OK=2, R_OK=4.


def _access_sel_make(name: Ptr[char], mode: uint16) -> int32:
    # Create /ext/<name> on the live mount and stamp its i_mode to
    # `mode` (the full S_IF*|perm word). Returns 0 on success, -1 on
    # any failure along the way.
    empty: Array[1, uint8]
    empty[0] = 0
    inum: uint32 = ext4_create_file(2, name, &empty[0], 0)
    if inum == 0:
        return -1
    inode_buf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode_buf[0]) != 0:
        return -1
    ext4_inode_set_mode(&inode_buf[0], mode)
    if ext4_write_inode(cast[uint64](inum), &inode_buf[0]) != 0:
        return -1
    return 0


def access_mode_selftest() -> int32:
    # boot:37 bootstrap-task fd-table prime (same uninitialised-table
    # issue statfs_selftest handles): snapshot slots 3..15, mark them
    # FD_CLOSED_MARK, restore on every exit.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    if ext4_blockdev_slot < 0:
        printk0("[ACCESS_MODE] FAIL ext4 not mounted\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # S_IFREG is 0x8000; OR in the perm bits.
    if _access_sel_make("ACMODE64.TXT", 0x81B4) != 0:        # 0664
        printk0("[ACCESS_MODE] FAIL create 0664\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    if _access_sel_make("ACMODE55.TXT", 0x81ED) != 0:        # 0755
        printk0("[ACCESS_MODE] FAIL create 0755\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    if _access_sel_make("ACMODE44.TXT", 0x8124) != 0:        # 0444
        printk0("[ACCESS_MODE] FAIL create 0444\n")
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    p64: Ptr[uint8] = cast[Ptr[uint8]]("/ext/ACMODE64.TXT")
    p55: Ptr[uint8] = cast[Ptr[uint8]]("/ext/ACMODE55.TXT")
    p44: Ptr[uint8] = cast[Ptr[uint8]]("/ext/ACMODE44.TXT")
    pno: Ptr[uint8] = cast[Ptr[uint8]]("/ext/ACMODE_NOPE.TXT")

    # --- F_OK on an existing file: 0 -----------------------------------
    r: int64 = _uabi_test_dispatch(SYS_access, cast[uint64](p64), 0, 0, 0)
    if r != 0:
        printk1("[ACCESS_MODE] FAIL F_OK(0664) rc=%d (want 0)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- R_OK(4) / W_OK(2) on the 0664 file: 0 -------------------------
    r = _uabi_test_dispatch(SYS_access, cast[uint64](p64), 4, 0, 0)
    if r != 0:
        printk1("[ACCESS_MODE] FAIL R_OK(0664) rc=%d (want 0)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    r = _uabi_test_dispatch(SYS_access, cast[uint64](p64), 2, 0, 0)
    if r != 0:
        printk1("[ACCESS_MODE] FAIL W_OK(0664) rc=%d (want 0)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- X_OK(1) on the 0664 file (no x bit): -EACCES ------------------
    r = _uabi_test_dispatch(SYS_access, cast[uint64](p64), 1, 0, 0)
    if r != ELINUX_ACCES:
        printk1("[ACCESS_MODE] FAIL X_OK(0664) rc=%d (want -13)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- X_OK(1) on the 0755 file (x bit set): 0 -----------------------
    r = _uabi_test_dispatch(SYS_access, cast[uint64](p55), 1, 0, 0)
    if r != 0:
        printk1("[ACCESS_MODE] FAIL X_OK(0755) rc=%d (want 0)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- W_OK(2) on the 0444 file (no w bit): -EACCES ------------------
    r = _uabi_test_dispatch(SYS_access, cast[uint64](p44), 2, 0, 0)
    if r != ELINUX_ACCES:
        printk1("[ACCESS_MODE] FAIL W_OK(0444) rc=%d (want -13)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1
    # R_OK(4) on the 0444 file is still allowed.
    r = _uabi_test_dispatch(SYS_access, cast[uint64](p44), 4, 0, 0)
    if r != 0:
        printk1("[ACCESS_MODE] FAIL R_OK(0444) rc=%d (want 0)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    # --- non-existent path: -ENOENT ------------------------------------
    r = _uabi_test_dispatch(SYS_access, cast[uint64](pno), 0, 0, 0)
    if r != ELINUX_NOENT:
        printk1("[ACCESS_MODE] FAIL ENOENT rc=%d (want -2)\n",
                cast[uint64](r))
        _statfs_selftest_restore(boot_task, &fd_save[0])
        return 1

    _statfs_selftest_restore(boot_task, &fd_save[0])
    printk0("[ACCESS_MODE] PASS\n")
    return 0


# =====================================================================
# msync(2) self-test  (gated on /etc/msync-test, ENABLE_MSYNC_TEST=1)
# =====================================================================
#
# Proves the real msync(2) handler (_u_unimpl_msync) flushes a dirtied
# MAP_SHARED writable file-backed mapping back to the BACKING FILE, driven
# through the REAL in-kernel Linux-ABI dispatch (the exact path a Debian/
# glibc binary takes), NOT a direct vma_writeback_range call.
#
# Steps:
#   1. Create /tmp/msync-data on tmpfs and fill it with known content.
#   2. Build a shared-writable file VMA over it (vma_alloc_file_shared,
#      same backing-identity triple a userland open would yield) and fault
#      every page in (the populator reads the current file bytes).
#   3. Modify a span of bytes THROUGH the mapping.
#   4. Call msync(addr, len, MS_SYNC) via linux_u_syscall_dispatch.
#   5. Read the backing file back via tmpfs_read (NOT the mapping) and
#      confirm the modified bytes landed in the file, and that the
#      unmodified region is preserved.
#   6. Assert msync of a non-page-aligned addr returns -EINVAL, and msync
#      of an anonymous/non-file region is a benign 0 (nothing to flush).
# Prints a single "[MSYNC] PASS" / "[MSYNC] FAIL ..." on EMERG serial.
#
# Runs in the boot task's own address space and drives vma_demand_fault
# directly (a synchronous kernel self-test cannot take a real #PF on its
# own access), mirroring mmap_shared_selftest in init/main.ad.


def _msync_expect_byte(i: uint64) -> uint8:
    # Original known-content formula for the backing file.
    return cast[uint8](((i * 37 + 7) & 0xFF))


def msync_selftest() -> int32:
    # Returns 0 on PASS, non-zero on the first failed assertion.
    PROT_READ:  int32 = 0x1
    PROT_WRITE: int32 = 0x2
    MAP_SHARED: int32 = 0x01
    MS_SYNC:    uint64 = 4
    PG: uint64 = 4096

    # Shared-writable pages are WRITABLE NX DATA; arm NXE before any
    # access (idempotent — syscall_init re-arms it later).
    set_efer_nxe()

    # The boot task that runs this hook (boot:37.msy) has an UNINITIALISED
    # fd table: per-task fd tables are only primed by create_user_task /
    # kthread_create, neither of which has run for the bootstrap context.
    # tmpfs_open_for_write allocates an fd, so mark slots 3..15 free first
    # (then restore them) — same handling as uabi_fills_selftest.
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    boot_slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](boot_slot))

    # ---- Build the known-content backing file on tmpfs -----------------
    fsize: uint64 = 2 * PG + 64
    fpath: Ptr[char] = "/tmp/msync-data"
    slot: int32 = tmpfs_open_for_write(fpath)
    if slot < 0:
        printk1("[MSYNC] FAIL tmpfs create rc=%d\n",
                cast[uint64](cast[int64](slot)))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    fillbuf: Array[256, uint8]
    wpos: uint64 = 0
    while wpos < fsize:
        n: uint64 = fsize - wpos
        if n > 256:
            n = 256
        bk: uint64 = 0
        while bk < n:
            fillbuf[bk] = _msync_expect_byte(wpos + bk)
            bk = bk + 1
        wrote: uint64 = tmpfs_write(slot, &fillbuf[0], wpos, n)
        if wrote != n:
            printk0("[MSYNC] FAIL tmpfs short write\n")
            _msync_restore_fds(boot_task, &fd_save[0])
            return 1
        wpos = wpos + n
    if tmpfs_size(slot) != fsize:
        printk2("[MSYNC] FAIL tmpfs size=%d want=%d\n",
                tmpfs_size(slot), fsize)
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    marker:  uint32 = FD_TMPFS_MARK
    backing: uint64 = cast[uint64](cast[uint32](slot))

    # ---- Map whole file, MAP_SHARED | PROT_READ|PROT_WRITE -------------
    base64: int64 = vma_alloc_file_shared(boot_slot, 0, fsize,
                                          PROT_READ | PROT_WRITE,
                                          MAP_SHARED,
                                          cast[int32](marker), backing,
                                          fsize, 0)
    if base64 < 0:
        printk0("[MSYNC] FAIL vma_alloc_file_shared\n")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    base: uint64 = cast[uint64](base64)
    npages: uint64 = (fsize + PG - 1) / PG
    fp: uint64 = 0
    while fp < npages:
        vma_demand_fault(boot_slot, boot_pml4, base + fp * PG)
        fp = fp + 1

    # Confirm the faulted-in bytes equal the original file content.
    mism0: uint64 = 0
    bi: uint64 = 0
    while bi < fsize:
        if cast[Ptr[uint8]](base + bi)[0] != _msync_expect_byte(bi):
            mism0 = mism0 + 1
        bi = bi + 1
    if mism0 != 0:
        printk1("[MSYNC] FAIL initial content mismatch (%d)\n", mism0)
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- Modify a span THROUGH the mapping (straddles page boundary) ---
    # New byte i == (i*53 + 17) & 0xFF, 220 bytes across the 1st boundary.
    mod_start: uint64 = PG - 90
    mod_len:   uint64 = 220
    mp: uint64 = 0
    while mp < mod_len:
        cast[Ptr[uint8]](base + mod_start + mp)[0] = \
            cast[uint8](((mod_start + mp) * 53 + 17) & 0xFF)
        mp = mp + 1

    # ---- msync(addr, len, MS_SYNC) via the REAL dispatch ---------------
    msrc: int64 = _uabi_test_dispatch(SYS_msync, base, fsize, MS_SYNC, 0)
    if msrc != 0:
        printk1("[MSYNC] FAIL msync rc=%d\n", cast[uint64](msrc))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- Read the backing file independently (NOT the mapping) ---------
    rdbuf: Array[256, uint8]
    rd_mism: uint64 = 0
    ri: uint64 = mod_start
    while ri < mod_start + mod_len:
        chunk: uint64 = mod_start + mod_len - ri
        if chunk > 256:
            chunk = 256
        got: uint64 = tmpfs_read(slot, &rdbuf[0], ri, chunk)
        if got != chunk:
            printk0("[MSYNC] FAIL tmpfs read short during verify\n")
            _msync_restore_fds(boot_task, &fd_save[0])
            return 1
        ck: uint64 = 0
        while ck < chunk:
            want: uint8 = cast[uint8](((ri + ck) * 53 + 17) & 0xFF)
            if rdbuf[ck] != want:
                rd_mism = rd_mism + 1
            ck = ck + 1
        ri = ri + chunk
    if rd_mism != 0:
        printk1("[MSYNC] FAIL backing file missing writes (%d)\n", rd_mism)
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # Bytes OUTSIDE the modified span must still hold original content.
    if tmpfs_read(slot, &rdbuf[0], 0, 16) != 16:
        printk0("[MSYNC] FAIL tmpfs read head\n")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    hk: uint64 = 0
    while hk < 16:
        if rdbuf[hk] != _msync_expect_byte(hk):
            printk0("[MSYNC] FAIL unmodified region corrupted\n")
            _msync_restore_fds(boot_task, &fd_save[0])
            return 1
        hk = hk + 1

    # ---- Negative: non-page-aligned addr must return -EINVAL ----------
    bad_rc: int64 = _uabi_test_dispatch(SYS_msync, base + 1, fsize,
                                        MS_SYNC, 0)
    if bad_rc != cast[int64](-22):
        printk1("[MSYNC] FAIL unaligned addr rc=%d (want -22)\n",
                cast[uint64](bad_rc))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- Benign: msync of a length-0 range is a no-op success ----------
    zero_rc: int64 = _uabi_test_dispatch(SYS_msync, base, 0, MS_SYNC, 0)
    if zero_rc != 0:
        printk1("[MSYNC] FAIL zero-len rc=%d (want 0)\n",
                cast[uint64](zero_rc))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    _msync_restore_fds(boot_task, &fd_save[0])
    printk0("[MSYNC] PASS\n")
    return 0


def _msync_restore_fds(boot_task: Ptr[TaskStruct], fd_save: Ptr[uint32]):
    # Restore the boot task's original fd slots so the table looks
    # untouched to anything that runs after this hook.
    fdr: uint64 = 3
    while fdr < 16:
        boot_task[0].fd_idx[fdr] = fd_save[fdr]
        fdr = fdr + 1


# =====================================================================
# [boot:37.wlspike] Wayland-passthrough Phase-0 de-risk self-test
# =====================================================================
#
# THE make-or-break spike for docs/wayland_passthrough_design.md: prove a
# shared-memory (memfd) buffer fd can cross the Linux-ns boundary via an
# AF_UNIX SCM_RIGHTS ancillary message and that BOTH ends see the SAME
# physical page. Drives the REAL sendmsg(46)/recvmsg(47) dispatch through
# genuine user memory (a mapped msghdr + iovec + cmsg), exactly as a
# libwayland client would:
#
#   1. create a memfd, mmap it MAP_SHARED, write the marker "WLSPIKE_OK"
#      THROUGH the mapping (the "client" side);
#   2. socketpair(AF_UNIX, SOCK_STREAM); sendmsg the memfd fd in an
#      SCM_RIGHTS cmsg (plus an 8-byte data iov) on one end;
#   3. recvmsg on the other end — get a NEW fd out of the cmsg + the data;
#   4. PROVE physical-page identity: tmpfs_page_phys(send) ==
#      tmpfs_page_phys(recv) (same frame, non-zero);
#   5. mmap the RECEIVED fd MAP_SHARED in a FRESH mapping and read the
#      marker back — it must match "WLSPIKE_OK".
#
# On full success prints the headline the gate greps for:
#   [wlspike] SCM_RIGHTS memfd round-trip OK: WLSPIKE_OK
# and "[wlspike] PASS". Any failed assertion prints "[wlspike] FAIL: ...".
# Gated by init/main.ad on /etc/wlspike-test (build_initramfs.py plants it
# when ENABLE_WLSPIKE_TEST=1).

WLSPIKE_MSG_VADDR:  uint64 = 0x0000567800000000   # send msghdr page
WLSPIKE_RMSG_VADDR: uint64 = 0x0000567800010000   # recv msghdr page


def _wlspike_fail(msg: Ptr[uint8]):
    printk0("[wlspike] FAIL: ")
    printk0(msg)
    printk0("\n")


def wlspike_scm_selftest() -> int32:
    PROT_READ:  int32 = 0x1
    PROT_WRITE: int32 = 0x2
    MAP_SHARED: int32 = 0x01
    PG: uint64 = 4096
    set_efer_nxe()

    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1

    boot_slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](boot_slot))

    # The marker the client writes through its mmap. 11 bytes incl NUL.
    marker: Array[11, uint8]
    mstr: Ptr[uint8] = "WLSPIKE_OK"
    mi: uint64 = 0
    while mi < 11:
        marker[mi] = mstr[mi]
        mi = mi + 1

    # ---- 1) client: memfd + mmap MAP_SHARED + write marker THROUGH map --
    fd_send: int32 = vfs_open_memfd(cast[Ptr[char]]("wlspike-shm"), 0)
    if fd_send < 0:
        _wlspike_fail("memfd_create (send)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    slot_send: int32 = vfs_fd_tmpfs_slot(fd_send)
    if slot_send < 0:
        _wlspike_fail("send fd is not a memfd/tmpfs object")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    base_s64: int64 = vma_alloc_file_shared(boot_slot, 0, PG,
                                            PROT_READ | PROT_WRITE,
                                            MAP_SHARED,
                                            cast[int32](FD_TMPFS_MARK),
                                            cast[uint64](cast[uint32](slot_send)),
                                            PG, 0)
    if base_s64 < 0:
        _wlspike_fail("mmap send memfd MAP_SHARED")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    base_s: uint64 = cast[uint64](base_s64)
    vma_demand_fault(boot_slot, boot_pml4, base_s)
    ws: uint64 = 0
    while ws < 11:
        cast[Ptr[uint8]](base_s + ws)[0] = marker[ws]
        ws = ws + 1

    # ---- 2) AF_UNIX SOCK_STREAM socketpair -----------------------------
    ea: int32 = 0
    eb: int32 = 0
    if afunix_socketpair(AFU_SOCK_STREAM, &ea, &eb) != 0:
        _wlspike_fail("socketpair")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    fd_sa: int32 = vfs_alloc_socket_fd()
    fd_sb: int32 = vfs_alloc_socket_fd()
    if fd_sa < 0 or fd_sb < 0:
        _wlspike_fail("socketpair fd alloc")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    vfs_socket_fd_set_record(fd_sa, afunix_fdbuf_for_ep(ea))
    vfs_socket_fd_set_record(fd_sb, afunix_fdbuf_for_ep(eb))

    # ---- 3) build the send msghdr in real USER memory + sendmsg --------
    p: uint64 = alloc_page()
    if p == 0:
        _wlspike_fail("alloc send msg page")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WLSPIKE_MSG_VADDR, p, 1) < 0:
        _wlspike_fail("map send msg page")
        free_page(p)
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    V: uint64 = WLSPIKE_MSG_VADDR
    # Layout within the page: msghdr@0, iovec@64, data@128, cmsg@256.
    put_user_64(0, V + MSGH_NAME)
    put_user_32(0, V + MSGH_NAMELEN)
    put_user_64(V + 64, V + MSGH_IOV)
    put_user_64(1, V + MSGH_IOVLEN)
    put_user_64(V + 256, V + MSGH_CONTROL)
    put_user_64(24, V + MSGH_CONTROLLEN)          # >= CMSG_LEN(4)=20
    put_user_32(0, V + MSGH_FLAGS)
    put_user_64(V + 128, V + 64)                  # iov_base
    put_user_64(8, V + 64 + 8)                     # iov_len
    payload: Array[8, uint8]
    payload[0] = 87    # 'W'
    payload[1] = 76    # 'L'
    payload[2] = 68    # 'D'
    payload[3] = 65    # 'A'
    payload[4] = 84    # 'T'
    payload[5] = 65    # 'A'
    payload[6] = 49    # '1'
    payload[7] = 50    # '2'
    copy_to_user(V + 128, cast[uint64](&payload[0]), 8)
    put_user_64(20, V + 256 + 0)                  # cmsg_len = 16 + 4
    put_user_32(SCM_SOL_SOCKET, V + 256 + 8)
    put_user_32(SCM_RIGHTS_TYPE, V + 256 + 12)
    put_user_32(cast[uint32](fd_send), V + 256 + 16)

    sn: int64 = linux_u_syscall_dispatch(SYS_sendmsg,
                                         cast[uint64](fd_sa), V, 0, 0, 0, 0)
    if sn != 8:
        printk1("[wlspike] FAIL: sendmsg rc=%d (want 8)\n", cast[uint64](sn))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 4) build the recv msghdr + recvmsg ----------------------------
    rp: uint64 = alloc_page()
    if rp == 0:
        _wlspike_fail("alloc recv msg page")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WLSPIKE_RMSG_VADDR, rp, 1) < 0:
        _wlspike_fail("map recv msg page")
        free_page(rp)
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    RV: uint64 = WLSPIKE_RMSG_VADDR
    put_user_64(0, RV + MSGH_NAME)
    put_user_32(0, RV + MSGH_NAMELEN)
    put_user_64(RV + 64, RV + MSGH_IOV)
    put_user_64(1, RV + MSGH_IOVLEN)
    put_user_64(RV + 256, RV + MSGH_CONTROL)
    put_user_64(64, RV + MSGH_CONTROLLEN)
    put_user_32(0, RV + MSGH_FLAGS)
    put_user_64(RV + 128, RV + 64)                # iov_base
    put_user_64(64, RV + 64 + 8)                   # iov_len
    # zero the control area so a stale read can't masquerade as a cmsg.
    put_user_64(0, RV + 256 + 0)
    put_user_32(0, RV + 256 + 16)

    rn: int64 = linux_u_syscall_dispatch(SYS_recvmsg,
                                         cast[uint64](fd_sb), RV, 0, 0, 0, 0)
    if rn != 8:
        printk1("[wlspike] FAIL: recvmsg rc=%d (want 8)\n", cast[uint64](rn))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    # Data iov must carry the payload bytes.
    rxd: Array[8, uint8]
    copy_from_user(cast[uint64](&rxd[0]), RV + 128, 8)
    rk: uint64 = 0
    while rk < 8:
        if rxd[rk] != payload[rk]:
            _wlspike_fail("recvmsg data iov mismatch")
            _msync_restore_fds(boot_task, &fd_save[0])
            return 1
        rk = rk + 1
    # Control buffer must carry one SCM_RIGHTS fd.
    outclen: Array[1, uint64]
    get_user_64(RV + MSGH_CONTROLLEN, &outclen[0])
    if outclen[0] < 20:
        printk1("[wlspike] FAIL: recv controllen=%d (want >=20)\n",
                outclen[0])
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    cl2: Array[1, uint32]
    ct2: Array[1, uint32]
    get_user_32(RV + 256 + 8, &cl2[0])
    get_user_32(RV + 256 + 12, &ct2[0])
    if cl2[0] != SCM_SOL_SOCKET or ct2[0] != SCM_RIGHTS_TYPE:
        _wlspike_fail("recv cmsg level/type not SOL_SOCKET/SCM_RIGHTS")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    newfd_u: Array[1, uint32]
    get_user_32(RV + 256 + 16, &newfd_u[0])
    fd_recv: int32 = cast[int32](newfd_u[0])
    if fd_recv < 0 or fd_recv == fd_send:
        printk1("[wlspike] FAIL: bad received fd=%d\n",
                cast[uint64](cast[int64](fd_recv)))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 5) PROVE same physical frame ----------------------------------
    slot_recv: int32 = vfs_fd_tmpfs_slot(fd_recv)
    if slot_recv < 0:
        _wlspike_fail("received fd is not a memfd/tmpfs object")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    phys_s: uint64 = tmpfs_page_phys(slot_send, 0)
    phys_r: uint64 = tmpfs_page_phys(slot_recv, 0)
    if phys_s == 0 or phys_r == 0 or phys_s != phys_r:
        printk2("[wlspike] FAIL: phys frame differ send=%x recv=%x\n",
                phys_s, phys_r)
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    printk1("[wlspike] passed fd -> SAME physical frame @ %x\n", phys_s)

    # ---- 6) receiver mmaps the NEW fd and reads the marker back --------
    base_r64: int64 = vma_alloc_file_shared(boot_slot, 0, PG,
                                            PROT_READ | PROT_WRITE,
                                            MAP_SHARED,
                                            cast[int32](FD_TMPFS_MARK),
                                            cast[uint64](cast[uint32](slot_recv)),
                                            PG, 0)
    if base_r64 < 0:
        _wlspike_fail("mmap recv memfd MAP_SHARED")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    base_r: uint64 = cast[uint64](base_r64)
    vma_demand_fault(boot_slot, boot_pml4, base_r)
    rc_mism: uint64 = 0
    rr: uint64 = 0
    while rr < 11:
        if cast[Ptr[uint8]](base_r + rr)[0] != marker[rr]:
            rc_mism = rc_mism + 1
        rr = rr + 1
    if rc_mism != 0:
        printk1("[wlspike] FAIL: receiver mmap marker mismatch (%d bytes)\n",
                rc_mism)
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- cleanup + verdict ---------------------------------------------
    vfs_close(fd_recv)
    vfs_close(fd_send)
    vfs_close(fd_sa)
    vfs_close(fd_sb)
    _msync_restore_fds(boot_task, &fd_save[0])
    printk0("[wlspike] SCM_RIGHTS memfd round-trip OK: WLSPIKE_OK\n")
    printk0("[wlspike] PASS\n")
    return 0


# =====================================================================
# [boot:37b.scmall] SCM_RIGHTS ALL-fd-type passing self-test
# =====================================================================
#
# The Firefox/Chromium blocker: their multiprocess bootstrap passes
# channel socketpairs, pipe ends and eventfd wakeups (not just memfd
# shared memory) to children via SCM_RIGHTS — over a socketpair() IPC
# CHANNEL, not the AF_UNIX-name socket wlspike used. The old shim
# rejected every non-tmpfs fd with -EINVAL AND dropped control entirely
# on a socketpair channel, stranding the child.
#
# This test drives the REAL sendmsg/recvmsg syscall dispatch:
#   1. process-A creates a socketpair CHANNEL (chA/chB) — the transport.
#   2. A creates a PAYLOAD socketpair (peA/peB) and an eventfd (evfd).
#   3. A sends {peA, evfd} + 8 data bytes over chA (SCM_RIGHTS).
#   4. B recvmsg's chB → gets the 8 bytes + TWO new fds (rpeA, revfd)
#      that reference the SAME backing objects.
#   5. round-trip PROOF:
#        * write "PZ12" into peB → read it back through rpeA (the passed
#          socketpair endpoint shares peA's ring);
#        * eventfd_write(evfd, 5) → eventfd_read(revfd) == 5 (shared
#          counter).
# Marker: [scmall] SCM_RIGHTS all-fd round-trip OK: SCMALL_OK / [scmall] PASS

SCMALL_MSG_VADDR: uint64 = 0x0000567A00000000


def _scmall_fail(msg: Ptr[uint8]):
    printk0("[scmall] FAIL: ")
    printk0(msg)
    printk0("\n")


def scmall_selftest() -> int32:
    PG: uint64 = 4096
    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1
    boot_pml4: uint64 = task_pml4(cast[int32](current_idx_get()))

    # ---- 1) channel socketpair (the IPC transport) --------------------
    chfds: Array[2, int32]
    if vfs_socketpair(&chfds[0]) != 0:
        _scmall_fail("channel socketpair")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    chA: int32 = chfds[0]
    chB: int32 = chfds[1]

    # ---- 2) payload socketpair + eventfd (the fds to pass) ------------
    pefds: Array[2, int32]
    if vfs_socketpair(&pefds[0]) != 0:
        _scmall_fail("payload socketpair")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    peA: int32 = pefds[0]
    peB: int32 = pefds[1]
    evfd: int64 = linux_u_syscall_dispatch(SYS_eventfd2, 0, 0, 0, 0, 0, 0)
    if evfd < 0:
        _scmall_fail("eventfd2")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 3) user page: msghdr@0 iov@64 data@128 cmsg@256 rbuf@512 -----
    p: uint64 = alloc_page()
    if p == 0 or vm_map_user_page(boot_pml4, SCMALL_MSG_VADDR, p, 1) < 0:
        _scmall_fail("map msg page")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    V: uint64 = SCMALL_MSG_VADDR
    put_user_64(0, V + MSGH_NAME)
    put_user_32(0, V + MSGH_NAMELEN)
    put_user_64(V + 64, V + MSGH_IOV)
    put_user_64(1, V + MSGH_IOVLEN)
    put_user_64(V + 256, V + MSGH_CONTROL)
    put_user_64(24, V + MSGH_CONTROLLEN)          # >= CMSG_LEN(8)=24
    put_user_32(0, V + MSGH_FLAGS)
    put_user_64(V + 128, V + 64)                  # iov_base
    put_user_64(8, V + 64 + 8)                     # iov_len
    dpl: Array[8, uint8]
    dpl[0] = 83  # S
    dpl[1] = 67  # C
    dpl[2] = 77  # M
    dpl[3] = 65  # A
    dpl[4] = 76  # L
    dpl[5] = 76  # L
    dpl[6] = 33  # !
    dpl[7] = 33  # !
    copy_to_user(V + 128, cast[uint64](&dpl[0]), 8)
    # cmsg: two fds (peA, evfd) => cmsg_len = 16 + 8 = 24.
    put_user_64(24, V + 256 + 0)
    put_user_32(SCM_SOL_SOCKET, V + 256 + 8)
    put_user_32(SCM_RIGHTS_TYPE, V + 256 + 12)
    put_user_32(cast[uint32](peA), V + 256 + 16)
    put_user_32(cast[uint32](evfd), V + 256 + 20)

    sn: int64 = linux_u_syscall_dispatch(SYS_sendmsg,
                                         cast[uint64](chA), V, 0, 0, 0, 0)
    if sn != 8:
        printk1("[scmall] FAIL: sendmsg rc=%d (want 8)\n", cast[uint64](sn))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 4) recvmsg over chB ------------------------------------------
    put_user_64(V + 320, V + MSGH_IOV)            # reuse: recv iov @320
    put_user_64(1, V + MSGH_IOVLEN)
    put_user_64(V + 384, V + MSGH_CONTROL)        # recv cmsg @384
    put_user_64(64, V + MSGH_CONTROLLEN)
    put_user_32(0, V + MSGH_FLAGS)
    put_user_64(V + 512, V + 320)                 # recv iov_base @512
    put_user_64(32, V + 320 + 8)                   # recv iov_len
    put_user_64(0, V + 384 + 0)                    # zero cmsg hdr
    put_user_32(0, V + 384 + 16)
    put_user_32(0, V + 384 + 20)

    rn: int64 = linux_u_syscall_dispatch(SYS_recvmsg,
                                         cast[uint64](chB), V, 0, 0, 0, 0)
    if rn != 8:
        printk1("[scmall] FAIL: recvmsg rc=%d (want 8)\n", cast[uint64](rn))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    # Received control must carry two fds.
    rclen: Array[1, uint64]
    get_user_64(V + MSGH_CONTROLLEN, &rclen[0])
    if rclen[0] < 24:
        printk1("[scmall] FAIL: recv controllen=%d (want >=24)\n", rclen[0])
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    rcl: Array[1, uint32]
    rct: Array[1, uint32]
    get_user_32(V + 384 + 8, &rcl[0])
    get_user_32(V + 384 + 12, &rct[0])
    if rcl[0] != SCM_SOL_SOCKET or rct[0] != SCM_RIGHTS_TYPE:
        _scmall_fail("recv cmsg not SOL_SOCKET/SCM_RIGHTS")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    rf0: Array[1, uint32]
    rf1: Array[1, uint32]
    get_user_32(V + 384 + 16, &rf0[0])
    get_user_32(V + 384 + 20, &rf1[0])
    rpeA: int32 = cast[int32](rf0[0])
    revfd: int32 = cast[int32](rf1[0])
    if rpeA < 0 or revfd < 0 or rpeA == peA or revfd == cast[int32](evfd):
        _scmall_fail("received fds invalid / not fresh")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 5a) socketpair round-trip: peB -> rpeA -----------------------
    wbuf: Array[4, uint8]
    wbuf[0] = 80  # P
    wbuf[1] = 90  # Z
    wbuf[2] = 49  # 1
    wbuf[3] = 50  # 2
    copy_to_user(V + 640, cast[uint64](&wbuf[0]), 4)
    ww: int64 = linux_u_syscall_dispatch(SYS_write,
                                         cast[uint64](peB), V + 640, 4, 0, 0, 0)
    if ww != 4:
        printk1("[scmall] FAIL: write peB rc=%d\n", cast[uint64](ww))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    rr: int64 = linux_u_syscall_dispatch(SYS_read,
                                         cast[uint64](rpeA), V + 704, 4, 0, 0, 0)
    if rr != 4:
        printk1("[scmall] FAIL: read rpeA rc=%d (passed socketpair end dead)\n",
                cast[uint64](rr))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    rback: Array[4, uint8]
    copy_from_user(cast[uint64](&rback[0]), V + 704, 4)
    ci: uint64 = 0
    while ci < 4:
        if rback[ci] != wbuf[ci]:
            _scmall_fail("passed socketpair round-trip data mismatch")
            _msync_restore_fds(boot_task, &fd_save[0])
            return 1
        ci = ci + 1

    # ---- 5b) eventfd round-trip: write evfd(5) -> read revfd ==5 ------
    ev8: Array[8, uint8]
    ev8[0] = 5
    ev8[1] = 0
    ev8[2] = 0
    ev8[3] = 0
    ev8[4] = 0
    ev8[5] = 0
    ev8[6] = 0
    ev8[7] = 0
    copy_to_user(V + 768, cast[uint64](&ev8[0]), 8)
    ew: int64 = linux_u_syscall_dispatch(SYS_write,
                                         cast[uint64](evfd), V + 768, 8, 0, 0, 0)
    if ew != 8:
        printk1("[scmall] FAIL: eventfd write rc=%d\n", cast[uint64](ew))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    er: int64 = linux_u_syscall_dispatch(SYS_read,
                                         cast[uint64](revfd), V + 776, 8, 0, 0, 0)
    if er != 8:
        printk1("[scmall] FAIL: eventfd read revfd rc=%d (passed eventfd dead)\n",
                cast[uint64](er))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    evr: Array[8, uint8]
    copy_from_user(cast[uint64](&evr[0]), V + 776, 8)
    if evr[0] != 5:
        printk1("[scmall] FAIL: eventfd value=%d (want 5)\n",
                cast[uint64](evr[0]))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- cleanup + verdict --------------------------------------------
    vfs_close(rpeA)
    vfs_close(revfd)
    vfs_close(peA)
    vfs_close(peB)
    vfs_close(cast[int32](evfd))
    vfs_close(chA)
    vfs_close(chB)
    _msync_restore_fds(boot_task, &fd_save[0])
    printk0("[scmall] SCM_RIGHTS all-fd round-trip OK: SCMALL_OK\n")
    printk0("[scmall] PASS\n")
    return 0


# =====================================================================
# [boot:38.wayland] Wayland-passthrough Phase-1 client self-test
# =====================================================================
#
# An in-kernel Wayland CLIENT drives the REAL socket syscalls
# (connect/sendmsg/recvmsg via linux_u_syscall_dispatch, exactly as
# libwayland would) against the native Wayland server (linux_abi/
# wayland.ad). It:
#   1. connect(2)s to a "wayland-0" AF_UNIX name  -> lazily binds the
#      server's display listener + registers the connection;
#   2. get_registry -> receives wl_compositor / wl_shm / xdg_wm_base;
#   3. binds wl_compositor + wl_shm;
#   4. memfd_create + mmap MAP_SHARED, paints a SOLID colour, and passes
#      the pool fd via SCM_RIGHTS in create_pool (the Phase-0 shm path);
#   5. create_buffer + create_surface + attach + commit;
#   6. asserts the committed ARGB8888 pixels reached the window's v2
#      backbuffer AND, after a rasterize, the compositor layer cache —
#      i.e. the shm-buffer-to-screen pipeline is live end to end.
#
# On success prints "[wayland] shm buffer on screen OK: WLPHASE1_OK" and
# "[wayland] PASS". Gated by init/main.ad on /etc/wayland-test (planted by
# build_initramfs.py when ENABLE_WAYLAND_TEST=1).

WL_T_SEND_VADDR: uint64 = 0x0000567900000000   # send msghdr + wire page
WL_T_RECV_VADDR: uint64 = 0x0000567900010000   # recv msghdr page
WL_PHASE1_COLOR: uint32 = 0xFFCC6633           # r=33 g=66 b=CC a=FF (RGBA)

_wlt_wbuf: Array[512, uint8]
_wlt_wp:   uint64 = 0


def _wlt_w32(v: uint32):
    _wlt_wbuf[_wlt_wp]     = cast[uint8](v & 0xff)
    _wlt_wbuf[_wlt_wp + 1] = cast[uint8]((v >> 8) & 0xff)
    _wlt_wbuf[_wlt_wp + 2] = cast[uint8]((v >> 16) & 0xff)
    _wlt_wbuf[_wlt_wp + 3] = cast[uint8]((v >> 24) & 0xff)
    _wlt_wp = _wlt_wp + 4


def _wlt_begin(obj: uint32) -> uint64:
    start: uint64 = _wlt_wp
    _wlt_w32(obj)
    _wlt_w32(0)
    return start


def _wlt_end(start: uint64, op: uint32):
    size: uint64 = _wlt_wp - start
    v: uint32 = (cast[uint32](size) << 16) | (op & 0xffff)
    _wlt_wbuf[start + 4] = cast[uint8](v & 0xff)
    _wlt_wbuf[start + 5] = cast[uint8]((v >> 8) & 0xff)
    _wlt_wbuf[start + 6] = cast[uint8]((v >> 16) & 0xff)
    _wlt_wbuf[start + 7] = cast[uint8]((v >> 24) & 0xff)


def _wlt_wstr(s: Ptr[uint8]):
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    _wlt_w32(cast[uint32](n + 1))
    i: uint64 = 0
    while i < n:
        _wlt_wbuf[_wlt_wp] = s[i]
        _wlt_wp = _wlt_wp + 1
        i = i + 1
    _wlt_wbuf[_wlt_wp] = 0
    _wlt_wp = _wlt_wp + 1
    while (_wlt_wp & 3) != 0:
        _wlt_wbuf[_wlt_wp] = 0
        _wlt_wp = _wlt_wp + 1


def _wlt_sendmsg(fd: int32, dlen: uint64, scmfd: int32) -> int64:
    # Fill the send msghdr page and drive the real SYS_sendmsg dispatch.
    V: uint64 = WL_T_SEND_VADDR
    put_user_64(0, V + MSGH_NAME)
    put_user_32(0, V + MSGH_NAMELEN)
    put_user_64(V + 64, V + MSGH_IOV)
    put_user_64(1, V + MSGH_IOVLEN)
    if scmfd >= 0:
        put_user_64(V + 512, V + MSGH_CONTROL)
        put_user_64(20, V + MSGH_CONTROLLEN)
        put_user_64(20, V + 512 + 0)               # cmsg_len = 16 + 4
        put_user_32(SCM_SOL_SOCKET, V + 512 + 8)
        put_user_32(SCM_RIGHTS_TYPE, V + 512 + 12)
        put_user_32(cast[uint32](scmfd), V + 512 + 16)
    else:
        put_user_64(0, V + MSGH_CONTROL)
        put_user_64(0, V + MSGH_CONTROLLEN)
    put_user_32(0, V + MSGH_FLAGS)
    put_user_64(V + 128, V + 64)                    # iov_base
    put_user_64(dlen, V + 64 + 8)                   # iov_len
    copy_to_user(V + 128, cast[uint64](&_wlt_wbuf[0]), dlen)
    return linux_u_syscall_dispatch(SYS_sendmsg, cast[uint64](fd),
                                    V, 0, 0, 0, 0)


def _wlt_recvmsg(fd: int32) -> int64:
    # Drain pending server events into the recv page (data at RV+128).
    RV: uint64 = WL_T_RECV_VADDR
    put_user_64(0, RV + MSGH_NAME)
    put_user_32(0, RV + MSGH_NAMELEN)
    put_user_64(RV + 64, RV + MSGH_IOV)
    put_user_64(1, RV + MSGH_IOVLEN)
    put_user_64(0, RV + MSGH_CONTROL)
    put_user_64(0, RV + MSGH_CONTROLLEN)
    put_user_32(0, RV + MSGH_FLAGS)
    put_user_64(RV + 128, RV + 64)
    put_user_64(2048, RV + 64 + 8)
    return linux_u_syscall_dispatch(SYS_recvmsg, cast[uint64](fd),
                                    RV, 0, 0, 0, 0)


def _wlt_recvmsg_ctl(fd: int32) -> int64:
    # Like _wlt_recvmsg but also supplies an ancillary-control buffer so a
    # server-passed fd (wl_keyboard.keymap SCM_RIGHTS) is delivered; the
    # caller reads MSGH_CONTROLLEN to confirm an fd arrived. Data lands at
    # RV+128 (len 1024); control buffer at RV+2048 (len 128).
    RV: uint64 = WL_T_RECV_VADDR
    put_user_64(0, RV + MSGH_NAME)
    put_user_32(0, RV + MSGH_NAMELEN)
    put_user_64(RV + 64, RV + MSGH_IOV)
    put_user_64(1, RV + MSGH_IOVLEN)
    put_user_64(RV + 2048, RV + MSGH_CONTROL)
    put_user_64(128, RV + MSGH_CONTROLLEN)
    put_user_32(0, RV + MSGH_FLAGS)
    put_user_64(RV + 128, RV + 64)
    put_user_64(1024, RV + 64 + 8)
    return linux_u_syscall_dispatch(SYS_recvmsg, cast[uint64](fd),
                                    RV, 0, 0, 0, 0)


def _wl_phase1_fail(msg: Ptr[uint8]):
    printk0("[wayland] FAIL: ")
    printk0(msg)
    printk0("\n")


def wayland_phase1_selftest() -> int32:
    PROT_READ:  int32 = 0x1
    PROT_WRITE: int32 = 0x2
    MAP_SHARED: int32 = 0x01
    PG: uint64 = 4096
    set_efer_nxe()
    wayland_reset_for_test()

    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1
    boot_slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](boot_slot))

    # Map the two msghdr/wire pages into user space.
    ps: uint64 = alloc_page()
    pr: uint64 = alloc_page()
    if ps == 0 or pr == 0:
        _wl_phase1_fail("alloc msg pages")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WL_T_SEND_VADDR, ps, 1) < 0:
        _wl_phase1_fail("map send page")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WL_T_RECV_VADDR, pr, 1) < 0:
        _wl_phase1_fail("map recv page")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    V: uint64 = WL_T_SEND_VADDR

    # ---- 1) client socket + connect to "wayland-0" ---------------------
    cep: int32 = afunix_socket(AFU_SOCK_STREAM)
    if cep < 0:
        _wl_phase1_fail("afunix_socket")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    cfd: int32 = vfs_alloc_socket_fd()
    if cfd < 0:
        _wl_phase1_fail("client fd alloc")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    vfs_socket_fd_set_record(cfd, afunix_fdbuf_for_ep(cep))
    # sockaddr_un { family=AF_UNIX(1); sun_path="wayland-0\0" } at V+1024.
    sa: Array[16, uint8]
    sa[0] = 1
    sa[1] = 0
    wpath: Ptr[uint8] = "wayland-0"
    pi: uint64 = 0
    while pi < 9:
        sa[2 + pi] = wpath[pi]
        pi = pi + 1
    sa[11] = 0
    copy_to_user(V + 1024, cast[uint64](&sa[0]), 12)
    crc: int64 = linux_u_syscall_dispatch(SYS_connect, cast[uint64](cfd),
                                          V + 1024, 12, 0, 0, 0)
    if crc != 0:
        printk1("[wayland] FAIL: connect rc=%d\n", cast[uint64](crc))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 2) get_registry, drain the globals ----------------------------
    _wlt_wp = 0
    gs: uint64 = _wlt_begin(1)                       # wl_display
    _wlt_w32(2)                                       # new_id registry=2
    _wlt_end(gs, 1)                                   # opcode 1 = get_registry
    if _wlt_sendmsg(cfd, _wlt_wp, -1) < 0:
        _wl_phase1_fail("sendmsg get_registry")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    rn: int64 = _wlt_recvmsg(cfd)
    if rn <= 0:
        printk1("[wayland] FAIL: no registry globals (recv rc=%d)\n",
                cast[uint64](rn))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    ro0: Array[1, uint32]
    get_user_32(WL_T_RECV_VADDR + 128, &ro0[0])
    if ro0[0] != 2:
        _wl_phase1_fail("first event not on wl_registry")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    printk1("[wayland] registry advertised %d bytes of globals\n",
            cast[uint64](rn))

    # ---- 3) bind wl_compositor(id 3) + wl_shm(id 4) --------------------
    _wlt_wp = 0
    bs: uint64 = _wlt_begin(2)                       # wl_registry
    _wlt_w32(1)                                       # name = compositor
    _wlt_wstr("wl_compositor")
    _wlt_w32(4)                                       # version
    _wlt_w32(3)                                       # new_id = 3
    _wlt_end(bs, 0)                                   # opcode 0 = bind
    bs2: uint64 = _wlt_begin(2)
    _wlt_w32(2)                                       # name = shm
    _wlt_wstr("wl_shm")
    _wlt_w32(1)                                       # version
    _wlt_w32(4)                                       # new_id = 4
    _wlt_end(bs2, 0)
    if _wlt_sendmsg(cfd, _wlt_wp, -1) < 0:
        _wl_phase1_fail("sendmsg bind")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    _wlt_recvmsg(cfd)                                # drain wl_shm.format

    # ---- 4) memfd shm pool: paint a solid colour, pass the fd ----------
    shmfd: int32 = vfs_open_memfd(cast[Ptr[char]]("wl-shm"), 0)
    if shmfd < 0:
        _wl_phase1_fail("memfd_create")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    slot: int32 = vfs_fd_tmpfs_slot(shmfd)
    if slot < 0:
        _wl_phase1_fail("shm fd not tmpfs-backed")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    sbase64: int64 = vma_alloc_file_shared(boot_slot, 0, PG,
                                           PROT_READ | PROT_WRITE,
                                           MAP_SHARED,
                                           cast[int32](FD_TMPFS_MARK),
                                           cast[uint64](cast[uint32](slot)),
                                           PG, 0)
    if sbase64 < 0:
        _wl_phase1_fail("mmap shm pool")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    sbase: uint64 = cast[uint64](sbase64)
    vma_demand_fault(boot_slot, boot_pml4, sbase)
    # 16x16 ARGB8888: memory bytes B,G,R,A = CC,66,33,FF (little-endian).
    npx: uint64 = 0
    while npx < 256:
        po: uint64 = sbase + npx * 4
        cast[Ptr[uint8]](po)[0] = 0xCC               # B
        cast[Ptr[uint8]](po + 1)[0] = 0x66           # G
        cast[Ptr[uint8]](po + 2)[0] = 0x33           # R
        cast[Ptr[uint8]](po + 3)[0] = 0xFF           # A
        npx = npx + 1

    # create_pool(id 5, fd, size 1024) — fd via SCM_RIGHTS.
    _wlt_wp = 0
    cps: uint64 = _wlt_begin(4)                      # wl_shm
    _wlt_w32(5)                                       # new_id pool = 5
    _wlt_w32(1024)                                    # size
    _wlt_end(cps, 0)                                  # opcode 0 = create_pool
    if _wlt_sendmsg(cfd, _wlt_wp, shmfd) < 0:
        _wl_phase1_fail("sendmsg create_pool")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # create_buffer(id 6, offset 0, w 16, h 16, stride 64, ARGB8888)
    _wlt_wp = 0
    cbs: uint64 = _wlt_begin(5)                      # wl_shm_pool
    _wlt_w32(6)                                       # new_id buffer = 6
    _wlt_w32(0)                                       # offset
    _wlt_w32(16)                                      # width
    _wlt_w32(16)                                      # height
    _wlt_w32(64)                                      # stride
    _wlt_w32(0)                                       # format ARGB8888
    _wlt_end(cbs, 0)                                  # opcode 0 = create_buffer
    # create_surface(id 7) on wl_compositor(3)
    css: uint64 = _wlt_begin(3)
    _wlt_w32(7)                                       # new_id surface = 7
    _wlt_end(css, 0)                                  # opcode 0 = create_surface
    if _wlt_sendmsg(cfd, _wlt_wp, -1) < 0:
        _wl_phase1_fail("sendmsg create_buffer/surface")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 5) attach(buffer) + commit -> blit to the window --------------
    _wlt_wp = 0
    ats: uint64 = _wlt_begin(7)                      # wl_surface
    _wlt_w32(6)                                       # buffer = 6
    _wlt_w32(0)                                       # x
    _wlt_w32(0)                                       # y
    _wlt_end(ats, 1)                                  # opcode 1 = attach
    cms: uint64 = _wlt_begin(7)
    _wlt_end(cms, 6)                                  # opcode 6 = commit
    if _wlt_sendmsg(cfd, _wlt_wp, -1) < 0:
        _wl_phase1_fail("sendmsg attach/commit")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- 6) assert the pixels reached the window backbuffer + cache ----
    wid: int32 = wayland_test_last_wid()
    if wid <= 0:
        _wl_phase1_fail("no window created for the surface commit")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    bpx: uint32 = wsys_wl_backbuffer_pixel(wid, 0, 0)
    if bpx != WL_PHASE1_COLOR:
        printk2("[wayland] FAIL: backbuffer pixel %x != %x\n",
                cast[uint64](bpx), cast[uint64](WL_PHASE1_COLOR))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    printk1("[wayland] committed shm buffer decoded into wid %d backbuffer\n",
            cast[uint64](cast[int64](wid)))
    # Rasterize (buffer scene verb -> layer cache) and re-check: proves the
    # v2 backbuffer is now on the in-kernel present pipeline (the §2 gap).
    wsys_wl_rasterize_test(wid)
    cpx: uint32 = wsys_wl_cache_pixel(wid, 0, 0)
    if cpx != WL_PHASE1_COLOR:
        printk2("[wayland] FAIL: layer-cache pixel %x != %x\n",
                cast[uint64](cpx), cast[uint64](WL_PHASE1_COLOR))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    _msync_restore_fds(boot_task, &fd_save[0])
    printk0("[wayland] shm buffer on screen OK: WLPHASE1_OK\n")
    printk0("[wayland] PASS\n")
    return 0


# =====================================================================
# §wayland Phase 2: wl_seat input self-test
# =====================================================================
# An in-kernel Wayland client binds wl_seat, obtains wl_pointer + wl_keyboard,
# gives its surface a window, then Hamnix input is INJECTED through the REAL
# per-window /event + /keys rings (the same rings the mouse router / kbd pump
# feed). recvmsg drives the reactive server, which drains those rings and
# emits wl_seat events; we assert the client receives pointer enter/motion/
# button + keyboard enter/keymap/key end-to-end.

def _wl2_g32(off: uint64) -> uint32:
    v: Array[1, uint32]
    get_user_32(WL_T_RECV_VADDR + 128 + off, &v[0])
    return v[0]


def _wl2_scan(rlen: int64, flags: Ptr[int32]):
    # Walk the wl events in the recv data buffer; set presence flags.
    # obj 6 = wl_pointer, obj 7 = wl_keyboard (fixed test ids).
    if rlen <= 0:
        return
    total: uint64 = cast[uint64](rlen)
    pos: uint64 = 0
    while pos + 8 <= total:
        obj: uint32 = _wl2_g32(pos)
        w2:  uint32 = _wl2_g32(pos + 4)
        size: uint64 = cast[uint64](w2 >> 16)
        op:  uint32 = w2 & 0xffff
        if size < 8 or pos + size > total:
            return
        if obj == 6:
            if op == 0:
                flags[0] = 1                          # pointer.enter
            elif op == 2:
                flags[1] = 1                          # pointer.motion
            elif op == 3:
                flags[2] = 1                          # pointer.button
                if _wl2_g32(pos + 20) == 1:           # state == pressed
                    flags[6] = cast[int32](_wl2_g32(pos + 16))   # button code
        elif obj == 7:
            if op == 1:
                flags[3] = 1                          # keyboard.enter
            elif op == 0:
                flags[5] = 1                          # keyboard.keymap
            elif op == 3:
                flags[4] = 1                          # keyboard.key
                if _wl2_g32(pos + 20) == 1:           # state == pressed
                    flags[8] = cast[int32](_wl2_g32(pos + 16))   # keycode
        pos = pos + size


def wayland_phase2_selftest() -> int32:
    PROT_READ:  int32 = 0x1
    PROT_WRITE: int32 = 0x2
    MAP_SHARED: int32 = 0x01
    PG: uint64 = 4096
    set_efer_nxe()
    wayland_reset_for_test()

    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1
    boot_slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](boot_slot))

    ps: uint64 = alloc_page()
    pr: uint64 = alloc_page()
    if ps == 0 or pr == 0:
        _wl_phase1_fail("alloc msg pages (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WL_T_SEND_VADDR, ps, 1) < 0:
        _wl_phase1_fail("map send page (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WL_T_RECV_VADDR, pr, 1) < 0:
        _wl_phase1_fail("map recv page (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    V: uint64 = WL_T_SEND_VADDR

    flags: Array[16, int32]
    ff: uint64 = 0
    while ff < 16:
        flags[ff] = 0
        ff = ff + 1

    # ---- connect ------------------------------------------------------
    cep: int32 = afunix_socket(AFU_SOCK_STREAM)
    cfd: int32 = vfs_alloc_socket_fd()
    if cep < 0 or cfd < 0:
        _wl_phase1_fail("socket/fd (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    vfs_socket_fd_set_record(cfd, afunix_fdbuf_for_ep(cep))
    sa: Array[16, uint8]
    sa[0] = 1
    sa[1] = 0
    wpath: Ptr[uint8] = "wayland-0"
    pi: uint64 = 0
    while pi < 9:
        sa[2 + pi] = wpath[pi]
        pi = pi + 1
    sa[11] = 0
    copy_to_user(V + 1024, cast[uint64](&sa[0]), 12)
    if linux_u_syscall_dispatch(SYS_connect, cast[uint64](cfd),
                                V + 1024, 12, 0, 0, 0) != 0:
        _wl_phase1_fail("connect (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- registry + bind compositor(3), shm(4), seat(5) ---------------
    _wlt_wp = 0
    gs: uint64 = _wlt_begin(1)
    _wlt_w32(2)
    _wlt_end(gs, 1)                                    # get_registry
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    _wlt_recvmsg(cfd)                                  # drain globals

    _wlt_wp = 0
    b1: uint64 = _wlt_begin(2)
    _wlt_w32(1)
    _wlt_wstr("wl_compositor")
    _wlt_w32(4)
    _wlt_w32(3)
    _wlt_end(b1, 0)
    b2: uint64 = _wlt_begin(2)
    _wlt_w32(2)
    _wlt_wstr("wl_shm")
    _wlt_w32(1)
    _wlt_w32(4)
    _wlt_end(b2, 0)
    b3: uint64 = _wlt_begin(2)
    _wlt_w32(4)
    _wlt_wstr("wl_seat")
    _wlt_w32(5)
    _wlt_w32(5)
    _wlt_end(b3, 0)
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    _wlt_recvmsg(cfd)                                  # drain shm fmt + seat caps

    # ---- wl_seat.get_pointer(6) + get_keyboard(7) ---------------------
    _wlt_wp = 0
    gp: uint64 = _wlt_begin(5)
    _wlt_w32(6)
    _wlt_end(gp, 0)                                    # get_pointer
    gk: uint64 = _wlt_begin(5)
    _wlt_w32(7)
    _wlt_end(gk, 1)                                    # get_keyboard
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    rk: int64 = _wlt_recvmsg_ctl(cfd)                  # keymap event + fd
    _wl2_scan(rk, &flags[0])
    kmctl: Array[1, uint64]
    get_user_64(WL_T_RECV_VADDR + MSGH_CONTROLLEN, &kmctl[0])
    if kmctl[0] == 0:
        _wl_phase1_fail("wl_keyboard.keymap fd not delivered (SCM)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if wayland_test_pointer_id(0) != 6 or wayland_test_keyboard_id(0) != 7:
        _wl_phase1_fail("seat did not record pointer/keyboard ids")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- give surface(10) a window via shm pool(8)/buffer(9) ----------
    shmfd: int32 = vfs_open_memfd(cast[Ptr[char]]("wl-shm2"), 0)
    slot: int32 = -1
    if shmfd >= 0:
        slot = vfs_fd_tmpfs_slot(shmfd)
    if shmfd < 0 or slot < 0:
        _wl_phase1_fail("memfd (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    sbase64: int64 = vma_alloc_file_shared(boot_slot, 0, PG,
                                           PROT_READ | PROT_WRITE, MAP_SHARED,
                                           cast[int32](FD_TMPFS_MARK),
                                           cast[uint64](cast[uint32](slot)),
                                           PG, 0)
    if sbase64 < 0:
        _wl_phase1_fail("mmap shm (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    vma_demand_fault(boot_slot, boot_pml4, cast[uint64](sbase64))
    npx: uint64 = 0
    while npx < 256:
        po: uint64 = cast[uint64](sbase64) + npx * 4
        cast[Ptr[uint8]](po)[0] = 0x40
        cast[Ptr[uint8]](po + 1)[0] = 0x80
        cast[Ptr[uint8]](po + 2)[0] = 0xC0
        cast[Ptr[uint8]](po + 3)[0] = 0xFF
        npx = npx + 1

    _wlt_wp = 0
    cp: uint64 = _wlt_begin(4)
    _wlt_w32(8)
    _wlt_w32(1024)
    _wlt_end(cp, 0)                                    # create_pool(8)
    _wlt_sendmsg(cfd, _wlt_wp, shmfd)

    _wlt_wp = 0
    cb: uint64 = _wlt_begin(8)
    _wlt_w32(9)                                        # buffer id 9
    _wlt_w32(0)
    _wlt_w32(16)
    _wlt_w32(16)
    _wlt_w32(64)
    _wlt_w32(0)
    _wlt_end(cb, 0)                                    # create_buffer
    cs: uint64 = _wlt_begin(3)
    _wlt_w32(10)                                       # surface id 10
    _wlt_end(cs, 0)                                    # create_surface
    _wlt_sendmsg(cfd, _wlt_wp, -1)

    _wlt_wp = 0
    at: uint64 = _wlt_begin(10)
    _wlt_w32(9)
    _wlt_w32(0)
    _wlt_w32(0)
    _wlt_end(at, 1)                                    # attach
    cm: uint64 = _wlt_begin(10)
    _wlt_end(cm, 6)                                    # commit
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    _wl2_scan(_wlt_recvmsg(cfd), &flags[0])            # buffer.release + focus enter

    wid: int32 = wayland_test_last_wid()
    if wid <= 0:
        _wl_phase1_fail("no window for the surface (p2)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- inject Hamnix input through the REAL per-window rings ---------
    wsys_wl_test_set_focus(wid)                        # 'f in' -> kbd enter
    wsys_wl_test_inject_pointer(wid, 40, 30, 1, 0)     # motion + left press
    wsys_wl_test_inject_key(wid, 97)                   # 'a' -> keycode 30
    # recvmsg drives the pump (one pump delivers every queued wl_seat event):
    # drain the rings, translate, and read the batch. A single recvmsg
    # suffices — a second on an empty ring would block this boot task.
    _wl2_scan(_wlt_recvmsg(cfd), &flags[0])

    _msync_restore_fds(boot_task, &fd_save[0])

    ok: int32 = 1
    if flags[5] == 0:
        _wl_phase1_fail("no wl_keyboard.keymap event")
        ok = 0
    if flags[3] == 0:
        _wl_phase1_fail("no wl_keyboard.enter on focus")
        ok = 0
    if flags[0] == 0:
        _wl_phase1_fail("no wl_pointer.enter")
        ok = 0
    if flags[1] == 0:
        _wl_phase1_fail("no wl_pointer.motion")
        ok = 0
    if flags[2] == 0 or flags[6] != cast[int32](272):
        _wl_phase1_fail("no wl_pointer.button BTN_LEFT press")
        ok = 0
    if flags[4] == 0 or flags[8] != cast[int32](30):
        _wl_phase1_fail("no wl_keyboard.key (keycode 30 'a')")
        ok = 0
    if ok == 0:
        return 1
    printk0("[wayland] wl_seat input delivered OK: WLPHASE2_OK\n")
    printk0("[wayland] PHASE2 PASS\n")
    return 0


# =====================================================================
# §wayland Phase 3: xdg-shell window management self-test
# =====================================================================
# An in-kernel Wayland client exercises the REAL xdg-shell dispatch: bind
# xdg_wm_base, get_xdg_surface + get_toplevel (receiving the initial
# configure), set_title, the initial empty commit, ack_configure, then a
# buffer commit — which must MAP the surface as a DECORATED Hamnix window
# with the requested title only AFTER the ack. Also drives the xdg_wm_base
# ping/pong liveness handshake and the xdg_toplevel.close event, then a
# client-side xdg_toplevel.destroy (window torn down). Proves the
# configure/ack_configure serial sequencing (the #1 xdg pitfall) through the
# same syscall dispatch a libwayland client uses.
#
# Pass markers: [wayland] xdg toplevel mapped OK: WLPHASE3_OK
#               [wayland] PHASE3 PASS
# Fail marker:  [wayland] FAIL

# Phase-3 event scan result slots (indices into the flags array):
#   0 xdg_surface.configure seen   1 xdg_surface.configure serial
#   2 xdg_toplevel.configure seen  3 xdg_wm_base.ping seen
#   4 ping serial                  5 xdg_toplevel.close seen
def _wl3_scan(rlen: int64, xs: uint32, top: uint32, wm: uint32,
              flags: Ptr[int32]):
    if rlen <= 0:
        return
    total: uint64 = cast[uint64](rlen)
    pos: uint64 = 0
    while pos + 8 <= total:
        obj: uint32 = _wl2_g32(pos)
        w2:  uint32 = _wl2_g32(pos + 4)
        size: uint64 = cast[uint64](w2 >> 16)
        op:  uint32 = w2 & 0xffff
        if size < 8 or pos + size > total:
            return
        if obj == xs and op == 0:
            flags[0] = 1
            flags[1] = cast[int32](_wl2_g32(pos + 8))     # configure serial
        elif obj == top and op == 0:
            flags[2] = 1                                   # toplevel.configure
        elif obj == top and op == 1:
            flags[5] = 1                                   # toplevel.close
        elif obj == wm and op == 0:
            flags[3] = 1
            flags[4] = cast[int32](_wl2_g32(pos + 8))     # ping serial
        pos = pos + size


def wayland_phase3_selftest() -> int32:
    PROT_READ:  int32 = 0x1
    PROT_WRITE: int32 = 0x2
    MAP_SHARED: int32 = 0x01
    PG: uint64 = 4096
    set_efer_nxe()
    wayland_reset_for_test()

    boot_task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd_save: Array[16, uint32]
    fdi: uint64 = 3
    while fdi < 16:
        fd_save[fdi] = boot_task[0].fd_idx[fdi]
        boot_task[0].fd_idx[fdi] = FD_CLOSED_MARK
        fdi = fdi + 1
    boot_slot: uint64 = current_idx_get()
    boot_pml4: uint64 = task_pml4(cast[int32](boot_slot))

    ps: uint64 = alloc_page()
    pr: uint64 = alloc_page()
    if ps == 0 or pr == 0:
        _wl_phase1_fail("alloc msg pages (p3)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WL_T_SEND_VADDR, ps, 1) < 0:
        _wl_phase1_fail("map send page (p3)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if vm_map_user_page(boot_pml4, WL_T_RECV_VADDR, pr, 1) < 0:
        _wl_phase1_fail("map recv page (p3)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    V: uint64 = WL_T_SEND_VADDR

    flags: Array[16, int32]
    ff: uint64 = 0
    while ff < 16:
        flags[ff] = 0
        ff = ff + 1

    # ---- connect ------------------------------------------------------
    cep: int32 = afunix_socket(AFU_SOCK_STREAM)
    cfd: int32 = vfs_alloc_socket_fd()
    if cep < 0 or cfd < 0:
        _wl_phase1_fail("socket/fd (p3)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    vfs_socket_fd_set_record(cfd, afunix_fdbuf_for_ep(cep))
    sa: Array[16, uint8]
    sa[0] = 1
    sa[1] = 0
    wpath: Ptr[uint8] = "wayland-0"
    pi: uint64 = 0
    while pi < 9:
        sa[2 + pi] = wpath[pi]
        pi = pi + 1
    sa[11] = 0
    copy_to_user(V + 1024, cast[uint64](&sa[0]), 12)
    if linux_u_syscall_dispatch(SYS_connect, cast[uint64](cfd),
                                V + 1024, 12, 0, 0, 0) != 0:
        _wl_phase1_fail("connect (p3)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- registry + bind compositor(3), shm(4), xdg_wm_base(5) --------
    _wlt_wp = 0
    gs: uint64 = _wlt_begin(1)
    _wlt_w32(2)
    _wlt_end(gs, 1)                                    # get_registry
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    _wlt_recvmsg(cfd)                                  # drain globals

    _wlt_wp = 0
    b1: uint64 = _wlt_begin(2)
    _wlt_w32(1)
    _wlt_wstr("wl_compositor")
    _wlt_w32(4)
    _wlt_w32(3)
    _wlt_end(b1, 0)
    b2: uint64 = _wlt_begin(2)
    _wlt_w32(2)
    _wlt_wstr("wl_shm")
    _wlt_w32(1)
    _wlt_w32(4)
    _wlt_end(b2, 0)
    b3: uint64 = _wlt_begin(2)
    _wlt_w32(3)                                        # name = WL_G_XDG
    _wlt_wstr("xdg_wm_base")
    _wlt_w32(1)
    _wlt_w32(5)                                        # new_id = 5
    _wlt_end(b3, 0)
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    _wlt_recvmsg(cfd)                                  # drain shm formats

    # ---- create_surface(20), get_xdg_surface(21), get_toplevel(22) ----
    _wlt_wp = 0
    cs: uint64 = _wlt_begin(3)                         # wl_compositor
    _wlt_w32(20)
    _wlt_end(cs, 0)                                    # create_surface
    gx: uint64 = _wlt_begin(5)                         # xdg_wm_base
    _wlt_w32(21)                                       # new xdg_surface
    _wlt_w32(20)                                       # surface
    _wlt_end(gx, 2)                                    # get_xdg_surface
    gt: uint64 = _wlt_begin(21)                        # xdg_surface
    _wlt_w32(22)                                       # new xdg_toplevel
    _wlt_end(gt, 1)                                    # get_toplevel
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    _wl3_scan(_wlt_recvmsg(cfd), 21, 22, 5, &flags[0]) # initial configure
    if flags[2] == 0:
        _wl_phase1_fail("no xdg_toplevel.configure on get_toplevel")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    if flags[0] == 0 or flags[1] == 0:
        _wl_phase1_fail("no xdg_surface.configure serial")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    cfg_serial: int32 = flags[1]
    if wayland_test_toplevel_id(0) != 22:
        _wl_phase1_fail("server did not record toplevel id")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- set_title + initial EMPTY commit (must NOT map yet) ----------
    _wlt_wp = 0
    st: uint64 = _wlt_begin(22)                        # xdg_toplevel
    _wlt_wstr("hamnix-wl")
    _wlt_end(st, 2)                                    # set_title
    ic: uint64 = _wlt_begin(20)                        # wl_surface
    _wlt_end(ic, 6)                                    # commit (empty)
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    if wayland_test_last_wid() > 0:
        _wl_phase1_fail("surface mapped before ack_configure")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- ack_configure(serial) ----------------------------------------
    _wlt_wp = 0
    ac: uint64 = _wlt_begin(21)                        # xdg_surface
    _wlt_w32(cast[uint32](cfg_serial))
    _wlt_end(ac, 4)                                    # ack_configure
    _wlt_sendmsg(cfd, _wlt_wp, -1)

    # ---- shm pool(8) + buffer(9), attach + commit -> MAP --------------
    shmfd: int32 = vfs_open_memfd(cast[Ptr[char]]("wl-shm3"), 0)
    slot: int32 = -1
    if shmfd >= 0:
        slot = vfs_fd_tmpfs_slot(shmfd)
    if shmfd < 0 or slot < 0:
        _wl_phase1_fail("memfd (p3)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    sbase64: int64 = vma_alloc_file_shared(boot_slot, 0, PG,
                                           PROT_READ | PROT_WRITE, MAP_SHARED,
                                           cast[int32](FD_TMPFS_MARK),
                                           cast[uint64](cast[uint32](slot)),
                                           PG, 0)
    if sbase64 < 0:
        _wl_phase1_fail("mmap shm (p3)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    vma_demand_fault(boot_slot, boot_pml4, cast[uint64](sbase64))
    npx: uint64 = 0
    while npx < 256:
        po: uint64 = cast[uint64](sbase64) + npx * 4
        cast[Ptr[uint8]](po)[0] = 0x20
        cast[Ptr[uint8]](po + 1)[0] = 0x60
        cast[Ptr[uint8]](po + 2)[0] = 0xA0
        cast[Ptr[uint8]](po + 3)[0] = 0xFF
        npx = npx + 1

    _wlt_wp = 0
    cp: uint64 = _wlt_begin(4)                         # wl_shm
    _wlt_w32(8)
    _wlt_w32(1024)
    _wlt_end(cp, 0)                                    # create_pool(8)
    _wlt_sendmsg(cfd, _wlt_wp, shmfd)

    _wlt_wp = 0
    cb: uint64 = _wlt_begin(8)                         # wl_shm_pool
    _wlt_w32(9)
    _wlt_w32(0)
    _wlt_w32(16)
    _wlt_w32(16)
    _wlt_w32(64)
    _wlt_w32(0)
    _wlt_end(cb, 0)                                    # create_buffer(9)
    at: uint64 = _wlt_begin(20)                        # wl_surface
    _wlt_w32(9)
    _wlt_w32(0)
    _wlt_w32(0)
    _wlt_end(at, 1)                                    # attach
    cm: uint64 = _wlt_begin(20)
    _wlt_end(cm, 6)                                    # commit -> MAP
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    _wlt_recvmsg(cfd)                                  # drain buffer.release

    wid: int32 = wayland_test_last_wid()
    if wid <= 0:
        _wl_phase1_fail("toplevel did not map after ack_configure")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- assert the decoration title == "hamnix-wl" -------------------
    want: Ptr[uint8] = "hamnix-wl"
    wantlen: int32 = 9
    if wsys_wl_test_title_len(wid) != wantlen:
        printk1("[wayland] FAIL: title len %d != 9\n",
                cast[uint64](cast[int64](wsys_wl_test_title_len(wid))))
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    ti: int32 = 0
    while ti < wantlen:
        if wsys_wl_test_title_byte(wid, ti) != cast[int32](want[cast[uint64](ti)]):
            _wl_phase1_fail("titlebar text mismatch")
            _msync_restore_fds(boot_task, &fd_save[0])
            return 1
        ti = ti + 1

    # ---- xdg_wm_base ping/pong liveness -------------------------------
    pserial: uint32 = wayland_test_send_ping(0)
    if pserial == 0:
        _wl_phase1_fail("ping not sent (no wm)")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    _wl3_scan(_wlt_recvmsg(cfd), 21, 22, 5, &flags[0]) # ping event
    if flags[3] == 0:
        _wl_phase1_fail("no xdg_wm_base.ping received")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    _wlt_wp = 0
    pg: uint64 = _wlt_begin(5)                          # xdg_wm_base
    _wlt_w32(cast[uint32](flags[4]))                    # echo ping serial
    _wlt_end(pg, 3)                                     # pong
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    if wayland_test_pong_count() != 1:
        _wl_phase1_fail("server did not record the pong")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- xdg_toplevel.close (titlebar close box) ----------------------
    if wayland_test_send_close(0) != 1:
        _wl_phase1_fail("close event not sent")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1
    _wl3_scan(_wlt_recvmsg(cfd), 21, 22, 5, &flags[0]) # close event
    if flags[5] == 0:
        _wl_phase1_fail("no xdg_toplevel.close received")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    # ---- client destroys the toplevel -> window torn down -------------
    _wlt_wp = 0
    ds: uint64 = _wlt_begin(22)                         # xdg_toplevel
    _wlt_end(ds, 0)                                     # destroy
    _wlt_sendmsg(cfd, _wlt_wp, -1)
    if wsys_wl_test_wid_in_use(wid) != 0:
        _wl_phase1_fail("window not freed on toplevel.destroy")
        _msync_restore_fds(boot_task, &fd_save[0])
        return 1

    _msync_restore_fds(boot_task, &fd_save[0])
    printk1("[wayland] xdg toplevel mapped as decorated wid %d\n",
            cast[uint64](cast[int64](wid)))
    printk0("[wayland] xdg toplevel mapped OK: WLPHASE3_OK\n")
    printk0("[wayland] PHASE3 PASS\n")
    return 0


# =====================================================================
# §fuse: mount(2) "fuse" type
# =====================================================================
#
# mount("fuse", target, "fuse", flags, "fd=N") binds `target` in the namespace
# to the FUSE connection opened on fd N. This mirrors the real fusermount /
# libfuse mount path: the helper opens /dev/fuse, then mount(2) with the
# fstype "fuse" (or "fuse.<subtype>") and the option string "fd=N,...". The
# only fstype we honour is fuse; anything else is -ENODEV (Hamnix's other
# mounts are Plan-9 bind operations, not Linux mount(2)). a0=source (ignored
# for fuse), a1=target, a2=fstype, a3=flags (ignored), a4=data ("fd=N,...").
FUSE_MNT_EFAULT: int64 = -14
FUSE_MNT_EINVAL: int64 = -22
FUSE_MNT_ENODEV: int64 = -19
FUSE_MNT_EBADF:  int64 = -9
FUSE_MNT_EPERM:  int64 = -1


def _u_mount(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # Audit gate (docs/audit_gap_vs_linux_2026-06-13.md): real Linux
    # mount(2) requires CAP_SYS_ADMIN; libmount drops everything else
    # but keeps this bit on the helper process. Honour the same rule —
    # an unseeded task defaults to the full cap set so legacy paths
    # still mount; a task that explicitly capset()s CAP_SYS_ADMIN away
    # (modern systemd helper sandboxing) gets EPERM, matching Linux.
    if ucaps_self_has(CAP_SYS_ADMIN_BIT) == 0:
        return FUSE_MNT_EPERM
    if a1 == 0 or a2 == 0 or a4 == 0:
        return FUSE_MNT_EFAULT
    # Copy the fstype string in and require it to start with "fuse".
    ftype: Array[32, uint8]
    if copy_from_user(cast[uint64](&ftype[0]), a2, 32) != 0:
        return FUSE_MNT_EFAULT
    ftype[31] = 0
    fpfx: Ptr[uint8] = "fuse"
    fi: uint64 = 0
    while fi < 4:
        if ftype[fi] != fpfx[fi]:
            return FUSE_MNT_ENODEV
        fi = fi + 1
    # Copy the target path in.
    tgt: Array[128, uint8]
    if copy_from_user(cast[uint64](&tgt[0]), a1, 128) != 0:
        return FUSE_MNT_EFAULT
    tgt[127] = 0
    tlen: uint64 = 0
    while tlen < 127 and tgt[tlen] != 0:
        tlen = tlen + 1
    if tlen == 0:
        return FUSE_MNT_EINVAL
    # Copy the data ("fd=N,...") and parse the fd= option.
    data: Array[256, uint8]
    if copy_from_user(cast[uint64](&data[0]), a4, 256) != 0:
        return FUSE_MNT_EFAULT
    data[255] = 0
    fd_n: int32 = _u_mount_parse_fd(&data[0])
    if fd_n < 0:
        return FUSE_MNT_EINVAL
    # Map the daemon's fd to its connection slot, then bind the target.
    conn: int32 = vfs_fd_fuse_slot(fd_n)
    if conn < 0:
        return FUSE_MNT_EBADF
    return fuse_mount(conn, &tgt[0], tlen)


def _u_mount_parse_fd(data: Ptr[uint8]) -> int32:
    # Scan the comma-separated option string for "fd=<digits>". Returns the fd
    # number, or -1 if no fd= option is present.
    i: uint64 = 0
    while data[i] != 0:
        # Match "fd=" at a token boundary (start or just after a comma).
        if data[i] == 102 and data[i + 1] == 100 and data[i + 2] == 61:
            j: uint64 = i + 3
            val: int32 = 0
            saw: int32 = 0
            while data[j] >= 48 and data[j] <= 57:
                val = val * 10 + cast[int32](data[j] - 48)
                saw = 1
                j = j + 1
            if saw != 0:
                return val
        i = i + 1
    return -1


# =====================================================================
# Central dispatch
# =====================================================================


def linux_u_syscall_dispatch(nr: uint64,
                             a0: uint64, a1: uint64, a2: uint64,
                             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # #147 / ptrace(2): the ONE syscall choke point for Linux-ABI
    # binaries doubles as the ptrace syscall-enter/exit stop site. If the
    # current task is being traced with PTRACE_SYSCALL active, the enter
    # hook parks it at a syscall-ENTER stop (snapshotting orig_rax + args)
    # before the real handler runs, and the exit hook parks it at a
    # syscall-EXIT stop (snapshotting the return value) after. Both are
    # no-ops for an untraced task — the overwhelmingly common case — so
    # the cost is one per-task flag read. SYS_ptrace itself is dispatched
    # by the inner ladder below (PTRACE_TRACEME/SYSCALL/GETREGS/...); a
    # traced tracee never re-enters ptrace, so the enter stop firing on
    # the tracer's own ptrace call cannot recurse (the tracer isn't a
    # tracee).
    ptrace_syscall_enter_stop(nr)
    # #160 / seccomp-lite: enforce the per-task syscall filter at ENTRY,
    # after the ptrace enter-stop (so a tracer still observes the call)
    # and BEFORE the real handler runs. If the filter denies `nr`,
    # seccomp_check_entry posts SIGSYS to the current task; we then SKIP
    # the real handler and short-circuit to the exit wrap with a -ENOSYS
    # rc. The pending SIGSYS is delivered by do_syscall's exit-side
    # signal_deliver_on_return (handler → rt_sigframe; no handler →
    # default terminate 128+31). The rc is irrelevant to a task that is
    # about to be killed, and faithful for a task that catches SIGSYS and
    # returns. Native/kernel paths never reach here (gated on
    # is_linux_userspace at the do_syscall fork upstream).
    sc_act: int64 = seccomp_check_entry(nr, a0, a1, a2, a3, a4, a5)
    if sc_act != 0:
        # SIGSYS-block path: return -ENOSYS (the task is about to be
        # SIGSYS'd). ERRNO-block path: return -errno verbatim so the
        # filter's chosen errno reaches the caller's %rax intact.
        rc_b: int64 = cast[int64](-38)
        if sc_act < 0:
            rc_b = sc_act
        return ptrace_syscall_exit_stop(rc_b)
    rc: int64 = _linux_u_syscall_dispatch_inner(nr, a0, a1, a2, a3, a4, a5)
    return ptrace_syscall_exit_stop(rc)


def _linux_u_syscall_dispatch_inner(nr: uint64,
                             a0: uint64, a1: uint64, a2: uint64,
                             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # Linux-numbered syscall dispatch. Called by the (future) entry stub
    # after register reshuffling. The switch is a flat if-ladder rather
    # than a jump table — Adder's compiler will lower this to the same
    # cmov / cmp chain a hand-written table would, and the ladder reads
    # more obviously alongside the SYS_* declarations above. If profile
    # data later shows this is a hot path, swapping to an array of
    # function pointers indexed by nr is a one-file refactor.
    if nr == SYS_read:
        return _u_read(a0, a1, a2, a3, a4, a5)
    if nr == SYS_write:
        return _u_write(a0, a1, a2, a3, a4, a5)
    if nr == SYS_open:
        return _u_open(a0, a1, a2, a3, a4, a5)
    if nr == SYS_close:
        return _u_close(a0, a1, a2, a3, a4, a5)
    if nr == SYS_stat:
        return _u_stat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fstat:
        return _u_fstat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lstat:
        return _u_lstat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_poll:
        return _u_poll(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lseek:
        return _u_lseek(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mmap:
        return _u_mmap(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mprotect:
        return _u_mprotect(a0, a1, a2, a3, a4, a5)
    if nr == SYS_munmap:
        return _u_munmap(a0, a1, a2, a3, a4, a5)
    if nr == SYS_brk:
        return _u_unimpl_brk(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rt_sigaction:
        return _u_rt_sigaction(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rt_sigprocmask:
        return _u_rt_sigprocmask(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rt_sigreturn:
        return _u_rt_sigreturn(a0, a1, a2, a3, a4, a5)
    if nr == SYS_prctl:
        return _u_prctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_seccomp:
        return _u_seccomp(a0, a1, a2, a3, a4, a5)
    if nr == SYS_ioctl:
        return _u_ioctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pread64:
        return _u_unimpl_pread64(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pwrite64:
        return _u_unimpl_pwrite64(a0, a1, a2, a3, a4, a5)
    if nr == SYS_readv:
        return _u_readv(a0, a1, a2, a3, a4, a5)
    if nr == SYS_writev:
        return _u_writev(a0, a1, a2, a3, a4, a5)
    if nr == SYS_access:
        return _u_access(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pipe:
        return _u_pipe(a0, a1, a2, a3, a4, a5)
    if nr == SYS_select:
        return _u_select(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sched_yield:
        return _u_sched_yield(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mremap:
        return _u_unimpl_mremap(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msync:
        return _u_unimpl_msync(a0, a1, a2, a3, a4, a5)
    if nr == SYS_dup:
        return _u_dup(a0, a1, a2, a3, a4, a5)
    if nr == SYS_dup2:
        return _u_dup2(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fsync:
        return _u_fsync(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fdatasync:
        return _u_fsync(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sync:
        return _u_sync(a0, a1, a2, a3, a4, a5)
    if nr == SYS_reboot:
        return _u_reboot(a0, a1, a2, a3, a4, a5)
    if nr == SYS_truncate:
        return _u_truncate(a0, a1, a2, a3, a4, a5)
    if nr == SYS_ftruncate:
        return _u_ftruncate(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fallocate:
        return _u_fallocate(a0, a1, a2, a3, a4, a5)
    if nr == SYS_setxattr:
        return _u_setxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lsetxattr:
        return _u_lsetxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fsetxattr:
        return _u_fsetxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getxattr:
        return _u_getxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lgetxattr:
        return _u_lgetxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fgetxattr:
        return _u_fgetxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_listxattr:
        return _u_listxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_llistxattr:
        return _u_llistxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_flistxattr:
        return _u_flistxattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_removexattr:
        return _u_removexattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lremovexattr:
        return _u_lremovexattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fremovexattr:
        return _u_fremovexattr(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rename:
        return _u_rename(a0, a1, a2, a3, a4, a5)
    if nr == SYS_renameat:
        return _u_renameat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_renameat2:
        return _u_renameat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_nanosleep:
        return _u_unimpl_nanosleep(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getitimer:
        return _u_getitimer(a0, a1, a2, a3, a4, a5)
    if nr == SYS_alarm:
        return _u_alarm(a0, a1, a2, a3, a4, a5)
    if nr == SYS_setitimer:
        return _u_setitimer(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getpid:
        return _u_getpid(a0, a1, a2, a3, a4, a5)
    if nr == SYS_clone:
        return _u_clone(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fork:
        return _u_fork(a0, a1, a2, a3, a4, a5)
    if nr == SYS_vfork:
        return _u_vfork(a0, a1, a2, a3, a4, a5)
    if nr == SYS_execve:
        return _u_execve(a0, a1, a2, a3, a4, a5)
    if nr == SYS_exit:
        return _u_exit(a0, a1, a2, a3, a4, a5)
    if nr == SYS_wait4:
        return _u_wait4(a0, a1, a2, a3, a4, a5)
    if nr == SYS_ptrace:
        return _u_ptrace(a0, a1, a2, a3, a4, a5)
    if nr == SYS_kill:
        return _u_kill(a0, a1, a2, a3, a4, a5)
    if nr == SYS_uname:
        return _u_uname(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fcntl:
        return _u_fcntl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_memfd_create:
        return umemfd_create(a0, a1, a2, a3, a4, a5)
    # §openat2: nr 437. Path-resolution-aware open; RESOLVE_NO_SYMLINKS
    # is a faithful no-op (no symlinks on this surface) and
    # RESOLVE_BENEATH rejects absolute-path / ".." escape (-EXDEV).
    if nr == SYS_openat2:
        return openat2_handler(a0, a1, a2, a3, a4, a5)
    # §memfd_secret: nr 447. Anonymous fd backed by RAM that is also
    # flagged "secret" so any future /proc/PID/mem reader gates against
    # exposing its bytes.
    if nr == SYS_memfd_secret:
        return memfd_secret_handler(a0, a1, a2, a3, a4, a5)
    # §mount_setattr: nr 442. The modern remount-with-flags call;
    # MOUNT_ATTR_RDONLY / NOSUID / NODEV / NOEXEC are accepted at the
    # syscall layer (Hamnix has no per-vfsmount flag store yet).
    if nr == SYS_mount_setattr:
        return mount_setattr_handler(a0, a1, a2, a3, a4, a5)
    # §new-mount-API: nr 430/431/432/429 — fsopen creates an fs_context
    # fd, fsconfig sets options on it, fsmount materialises the mount,
    # move_mount installs the mount at a path (resolved via the same
    # resolve_path the other mount syscalls use, per F10-1).
    if nr == SYS_fsopen:
        return fsopen_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fsconfig:
        return fsconfig_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fsmount:
        return fsmount_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_move_mount:
        return move_mount_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getcwd:
        return _u_getcwd(a0, a1, a2, a3, a4, a5)
    if nr == SYS_chdir:
        return _u_chdir(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchdir:
        return _u_fchdir(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mkdir:
        return _u_mkdir(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rmdir:
        # Bare rmdir(2) (x86_64 nr 84). dpkg calls this directly (its
        # "securely remove" cleanup empties a dir then rmdir's it), NOT
        # via unlinkat(AT_REMOVEDIR) the way glibc's rmdir() wrapper does
        # on some libcs — so the unlinkat leg alone left nr=84 falling
        # through to -ENOSYS ("unable to securely remove ...: Function
        # not implemented"), aborting every dpkg install. _u_rmdir reads
        # the path from a0 and enforces empty-dir semantics via vfs_rmdir.
        return _u_rmdir(a0, a1, a2, a3, a4, a5)
    if nr == SYS_unlink:
        return _u_unlink(a0, a1, a2, a3, a4, a5)
    # symlink / link family: VFS-backed (ext4 inode hardlinks, ext4/tmpfs
    # symlinks). Previously fell through to -ENOSYS; now `ln` / `ln -s`
    # and tar/dpkg symlink+hardlink extraction work.
    if nr == SYS_symlink:
        return _u_symlink(a0, a1, a2, a3, a4, a5)
    if nr == SYS_symlinkat:
        return _u_symlinkat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_link:
        return _u_link(a0, a1, a2, a3, a4, a5)
    if nr == SYS_linkat:
        return _u_linkat(a0, a1, a2, a3, a4, a5)
    # Timestamp setters (utimensat is the modern workhorse for touch/cp -p/
    # tar -p/make); legacy utimes/utime/futimesat for older static binaries.
    if nr == SYS_utimensat:
        return _u_utimensat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_futimesat:
        return _u_futimesat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_utimes:
        return _u_utimes(a0, a1, a2, a3, a4, a5)
    if nr == SYS_utime:
        return _u_utime(a0, a1, a2, a3, a4, a5)
    if nr == SYS_readlink:
        return _u_unimpl_readlink(a0, a1, a2, a3, a4, a5)
    if nr == SYS_arch_prctl:
        return _u_unimpl_arch_prctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_time:

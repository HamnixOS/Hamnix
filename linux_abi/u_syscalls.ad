# U42 follow-up: per-task VMA layer. The flat 256-slot (base, order)
# table this file used since U7 graduates into a per-task sorted linked
# list of VmaNodes. The MAP_FIXED-overlay hack in _u_mmap_fixed_in_
# existing is replaced by a real overlap test + alias node in mm/vma.ad.
# vma_clear is called from arch/x86/kernel/syscall.ad::do_execve before
# loading the new ELF image; everything else (mmap/munmap/mprotect) is
# self-contained inside this module.
from mm.vma import (
    vma_alloc, vma_unmap, vma_protect, vma_madvise, vma_writeback_range,
    vma_mremap, vma_release_brk_overlap,
    # msync_selftest builds a writable file-backed shared VMA and faults
    # its pages in directly (a synchronous kernel self-test cannot take a
    # real #PF on its own access), then drives msync via the real dispatch.
    vma_alloc_file_shared, vma_demand_fault, vma_alloc_demand,
    # getrusage(2) ru_maxrss + vmstat_selftest: on-demand virtual size /
    # resident-page walks over the calling task's VMAs.
    task_vsize_bytes, task_rss_pages,
    # vmstat_selftest builds a real demand-paged anonymous VMA in the boot
    # task and faults its pages in so the walk has present 4 KiB PTEs to
    # count (the boot task's identity map uses huge pages, which the
    # 4 KiB-granular present-walk reads as not-present).
    VMA_MAP_PRIVATE, VMA_MAP_ANONYMOUS,
    VMA_PROT_READ, VMA_PROT_WRITE,
)

# #163 (SAFE half) — adopt the real user-memory accessor layer for the
# hottest, highest-risk user-pointer writeback/read sites in this file.
# These helpers walk the CURRENT task's page tables, so a malformed user
# pointer yields a clean -EFAULT instead of a kernel #PF panic, and the
# future ET_DYN / mmap-base ASLR work (vaddr != phys) becomes a localized
# change instead of a whole-tree audit. NO vaddr!=phys decoupling is
# introduced here: under today's identity map every translated access is
# the same physical write the raw deref used to do.
from mm.uaccess import (
    copy_to_user, copy_from_user,
    get_user_8, get_user_64, put_user_16, put_user_32, put_user_64,
    strncpy_from_user,
    # splice self-test: stand up a real vaddr!=phys user mapping so the
    # vmsplice copy_from_user gather path is exercised against genuine
    # user memory rather than a kernel pointer.
    uaccess_current_pml4,
)

# memset for zero-filling user-supplied stat buffers before we poke
# individual fields. Declared `extern` because the actual body lives in
# the C-runtime shim that compiler.adder links against; same pattern as
# linux_abi/u_libc.ad and mm/slab.ad.
extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
# memcpy: the finit_module grow-by-chunks read loop copies the partial
# image into a freshly-enlarged buffer. Same C-runtime-shim extern as
# memset / the other arch modules.
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
# M16.36: needed by _u_brk to flush stale TLB entries after the lazy
# brk reservation installs fresh per-task PT entries — the same TLB-
# flush dance do_execve / SYS_SPAWN do after elf_apply_last_user_mapping.
extern def load_cr3(value: uint64)
# rusage_selftest needs to briefly enable CPU interrupts so the LAPIC
# timer tick fires and advances jiffies + accrues stime to the current
# task. start_kernel runs IF-blocked, so without this the busy-spin would
# never see jiffies move. Same enable/spin/disable pattern the live-USB
# keyboard self-test uses in init/main.ad.
extern def local_irq_enable()
extern def local_irq_disable()
extern def cpu_relax()
# msync_selftest runs at boot:37.msy, BEFORE syscall_init (boot:39) arms
# IA32_EFER.NXE. Shared-writable file pages are WRITABLE NX DATA, so a
# data access would otherwise take a reserved-bit #PF. Arm NXE first
# (idempotent — syscall_init re-arms it), like the file-mmap selftests.
extern def set_efer_nxe()

# Generic MSR writer — the asm body lives in arch/x86/kernel/syscall_64.S
# (write_msr) and takes the canonical (index, value) pair. We need it for
# SYS_arch_prctl's ARCH_SET_FS path: glibc's pthread bring-up calls
# arch_prctl(ARCH_SET_FS, &tcb) and then derefs %fs:0x10 for the TLS
# pointer, so failing this syscall means glibc segfaults before main().
extern def write_msr(index: uint32, value: uint64)
# Generic MSR reader (asm body in arch/x86/kernel/syscall_64.S). Needed
# for arch_prctl(ARCH_GET_GS) to hand the user GS_BASE MSR back.
extern def read_msr(index: uint32) -> uint64

# IA32_FS_BASE — MSR 0xC0000100. Writing this is the kernel-side
# equivalent of `wrfsbase` on CPUs that lack the FSGSBASE feature.
IA32_FS_BASE: uint32 = 0xC0000100
# IA32_GS_BASE — MSR 0xC0000101. ARCH_SET_GS writes here. NOTE the
# kernel itself uses %gs for per-CPU state via IA32_KERNEL_GS_BASE
# (0xC0000102) — the active GS.base on a SYSCALL entry is the kernel's,
# swapped in by swapgs. The user value lives in IA32_GS_BASE (the
# "inactive" copy on entry) and swapgs makes it live on return, so
# writing IA32_GS_BASE here sets the *user* GS without disturbing the
# kernel's per-CPU base.
IA32_GS_BASE: uint32 = 0xC0000101

# arch_prctl op codes (from <asm/prctl.h>).
ARCH_SET_GS: uint64 = 0x1001
ARCH_SET_FS: uint64 = 0x1002
ARCH_GET_FS: uint64 = 0x1003
ARCH_GET_GS: uint64 = 0x1004

# SYS_brk state. M16.104: now per-task — three uint64 fields on
# TaskStruct (brk_base / brk_end / brk_max), accessed through the
# task_brk_* helpers imported above. The old single-global cursor
# (linux_brk / linux_brk_end) collided across concurrent Linux ELFs
# and forced single-process callers to fight kmalloc fragmentation;
# the per-task region pre-reserves contiguous physical memory via
# alloc_pages(LINUX_BRK_ORDER) on first call so glibc-malloc's
# arena bookkeeping sees a single growing range — no more "break
# adjusted to free malloc space" abort.
#
# LINUX_BRK_ORDER = 10 → 2^10 pages = 4 MiB contiguous per single
# alloc_pages call. That's the page-allocator's MAX_ORDER (see
# mm/page_alloc.ad), so it's the largest single contiguous region
# alloc_pages can hand us in one call.
#
# LINUX_BRK_CHUNKS = 8 → we issue 8 back-to-back alloc_pages(MAX_ORDER)
# calls on first brk() to build a 32 MiB reservation. Why this works
# even though alloc_pages itself caps at MAX_ORDER: the FIRST eight
# MAX_ORDER allocations in the system go through alloc_pages Path 3
# (memblock_alloc(4 MiB, 4 MiB)), which is a bump allocator — chunks
# are returned in ascending physical address with exact 4 MiB
# alignment, so 8 consecutive calls produce 32 MiB of physically
# contiguous, 4 MiB-aligned memory. We assert contiguity at run time
# (each chunk's base must equal the previous chunk + 4 MiB) and fall
# back to whatever shorter prefix we got if a non-contiguous chunk
# lands — that keeps the invariant glibc-malloc cares about (the
# brk_base..brk_max range is one virtually-contiguous arena) intact
# even on later tasks where the page allocator may be fragmented.
#
# Why 32 MiB and not 4 MiB / 64 MiB:
#   * 4 MiB (the M16.104 ceiling) is too small for CPython 3.11.10:
#     U41 reached importlib bootstrap and aborted with `Fatal Python
#     error: pycore_interp_init: failed to initialize importlib /
#     MemoryError` because CPython's import phase needs ~10-15 MiB of
#     heap (per 054f58b commit + tests/u-binary/src/cpython/HOWTO.md
#     "Known blocker" diagnosis). 32 MiB gives CPython 2-3x headroom
#     over its measured peak with room left for stdlib import-as-you-go.
#   * 64 MiB would be nicer for future apt-static / postgres-static
#     workloads, but with NTASKS=16 and the EAGER reservation strategy
#     below, 64 MiB × 16 = 1 GiB worst case — bigger than memblock's
#     entire 238 MiB usable range (mm/memblock.ad MEMBLOCK_BASE..TOP).
#     32 MiB × 16 = 512 MiB worst case is still more than memblock has
#     in theory, but in practice only 1-2 Linux tasks ever run
#     concurrently (test_u39_python, test_u40_musl_busybox, test_u41
#     cpython each spawn a single Linux child), so the realistic peak
#     is 32-64 MiB of pre-reserved heap. The full-fat 64 MiB ceiling
#     belongs to a follow-up that switches brk to a true lazy mmap-
#     backed vma (allocates pages on fault, not on reservation).
#
# Why pre-reserve up front instead of growing one page per brk-grow:
# glibc-malloc only consults brk() for the TOP address and assumes
# everything below it is one virtually-contiguous arena. If we
# alloc_page() once per grow we'd hit the same kmalloc-fragments-at-
# page-granularity problem the old code did (alloc_page returns
# whatever order-0 slot is free; consecutive calls rarely land
# adjacent). Pre-reserving the full reservation in a tight burst of
# alloc_pages(MAX_ORDER) calls guarantees contiguity for the lifetime
# of the task.
LINUX_BRK_ORDER:   int32  = 10
LINUX_BRK_CHUNK:   uint64 = 4194304        # 2^10 * 4096 = 4 MiB per chunk
LINUX_BRK_CHUNKS:  uint64 = 8              # 8 × 4 MiB = 32 MiB total
LINUX_BRK_RESERVE: uint64 = 33554432       # 8 × 4 MiB = 32 MiB

# SYS_set_tid_address state. Linux records the user pointer so that on
# task exit the kernel can clear it (and futex-wake the parent waiting
# on CLONE_CHILD_CLEARTID). We don't have per-task storage for it
# without touching kernel/sched/core.ad, and the task constraint here
# is "only u_syscalls.ad" — so we keep it as a single global for the
# single Linux task that the L1 surface supports. When real thread
# groups land this moves into task_struct alongside the tid itself.
linux_clear_child_tid: uint64 = 0



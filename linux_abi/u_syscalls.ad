    get_task_alt_stack_flags, set_task_alt_stack_flags,
    task_brk_base, set_task_brk_base,
    task_brk_end, set_task_brk_end,
    task_brk_max, set_task_brk_max,
    # getrlimit/setrlimit/prlimit64: the real per-task rlimit store.
    rlimit_get_cur, rlimit_get_max, rlimit_set,
    # getpriority(2)/setpriority(2): the real per-task POSIX nice store.
    sched_get_nice, sched_set_nice,
    # sched_setaffinity/getaffinity: the real per-task CPU-affinity store
    # honored by the per-CPU-runqueue scheduler (placement/steal/migration).
    sched_get_affinity, sched_set_affinity,
    # sched_affinity_selftest: kernel-side affinity-enforcement self-test,
    # gated on /etc/sched-affinity-test (scripts/test_sched_affinity.sh).
    sched_affinity_selftest,
    # sched_setscheduler/getscheduler/setparam/getparam + priority-range:
    # realtime policy mechanism (SCHED_FIFO/SCHED_RR) in core.ad.
    sched_set_scheduler, sched_get_policy, sched_get_rt_priority,
    sched_priority_max, sched_priority_min,
    SCHED_OTHER, SCHED_FIFO, SCHED_RR,
    set_current_errstr,
    register_cleartid_wake_hook,
    task_pml4,
    # uabi_fills_selftest needs the free-slot marker to prime the boot
    # task's fd table (it is uninitialised at boot:37 — per-task fd tables
    # are only set up by create_user_task / kthread_create).
    FD_CLOSED_MARK,
    # msync_selftest builds a tmpfs-backed MAP_SHARED VMA; its FDs (and the
    # backing-identity triple it hands vma_alloc_file_shared) use this mark.
    FD_TMPFS_MARK,
    # f*xattr / fstatfs ext4 path: vfs_fd_backing_info hands back
    # FD_EXT4_MARK for an ext4-backed fd (the backing id is the inode
    # number). FD_FAT_MARK stays imported as the stable FAT backing-kind
    # tag. (fd→Chan fold: open ext4/FAT fds are FD_CHAN_MARK now, so the
    # statfs classifier dispatches via vfs_fd_statfs_kind, not these.)
    FD_EXT4_MARK, FD_FAT_MARK,
    # sysinfo(2): procs counts live (non-FREE/non-EXITED) task slots.
    task_table_size, task_state,
    STATE_FREE, STATE_EXITED,
    # getrusage(2): per-task user/system CPU-tick counts, accrued by the
    # timer ISR. _u_getrusage converts these to the rusage timevals.
    current_task_utime_ticks, current_task_stime_ticks,
    # times(2) tms_cutime/tms_cstime: accumulated CPU ticks of all reaped
    # children (whole subtree, RUSAGE_CHILDREN), folded in at task_reap.
    current_task_cutime_ticks, current_task_cstime_ticks,
    # getrusage(2) RUSAGE_CHILDREN: accumulated child page-fault counts +
    # the slot-indexed direct setters ruchild_selftest seeds sentinels with.
    current_task_cminflt, current_task_cmajflt,
    task_cminflt_at, task_cmajflt_at,
    task_set_cutime_ticks_at, task_set_cstime_ticks_at,
    task_set_cminflt_at, task_set_cmajflt_at,
    # getrusage(2) / pgfault_selftest: per-task page-fault counts and the
    # charge helpers the page-fault handler drives.
    current_task_minflt, current_task_majflt,
    current_task_account_minor_fault, current_task_account_major_fault,
    # getrusage(2) / ctxsw_selftest: per-task context-switch counts and the
    # slot-indexed charge helpers schedule() drives at the switch site.
    current_task_nvcsw, current_task_nivcsw,
    task_account_voluntary_ctxsw_at, task_account_involuntary_ctxsw_at,
    # getrusage(2) / blkio_selftest: per-task block-I/O counts and the
    # charge helpers the block layer drives at the I/O completion site.
    current_task_inblock, current_task_oublock,
    current_task_account_inblock, current_task_account_oublock,
    # getrusage(2) / nsignals_selftest: per-task signal-delivery count and
    # the slot-indexed charge helper signal_post drives at the latch site.
    current_task_nsignals, task_account_signal_at,
    # getrusage(2) / vmstat_selftest: ru_maxrss (0x20) high-water mark
    # accessor + monotonic updater. The current rss is computed on demand
    # from the VMA walk; this field just remembers the peak in KB.
    task_maxrss_kb_at, task_set_maxrss_kb_at,
)
# msync_selftest backs its known-content file on tmpfs (the cpio initramfs
# is read-only — a MAP_SHARED-writable mapping over it is refused), then
# reads it back independently of the mapping to confirm the flush landed.

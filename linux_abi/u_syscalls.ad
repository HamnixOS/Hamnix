        return _u_inotify_init(a0, a1, a2, a3, a4, a5)
    if nr == SYS_inotify_init1:
        return _u_inotify_init1(a0, a1, a2, a3, a4, a5)
    if nr == SYS_inotify_add_watch:
        return _u_inotify_add_watch(a0, a1, a2, a3, a4, a5)
    if nr == SYS_inotify_rm_watch:
        return _u_inotify_rm_watch(a0, a1, a2, a3, a4, a5)
    # fanotify — the second filesystem-event delivery fd (same source).
    if nr == SYS_fanotify_init:
        return _u_fanotify_init(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fanotify_mark:
        return _u_fanotify_mark(a0, a1, a2, a3, a4, a5)
    # #165: ABI-completeness fills — positioned scatter I/O, dirfd-relative
    # path ops, single-user chmod/chown, sched-affinity / getcpu /
    # membarrier, ppoll, clock_nanosleep, umask, faccessat. Each forwards
    # to a real facility (see the per-handler comments above).
    if nr == SYS_preadv:
        return _u_preadv(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pwritev:
        return _u_pwritev(a0, a1, a2, a3, a4, a5)
    if nr == SYS_faccessat:
        return _u_faccessat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_faccessat2:
        return _u_faccessat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_chmod:
        return _u_chmod(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchmod:
        return _u_fchmod(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchmodat:
        return _u_fchmodat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchmodat2:
        return fchmodat2_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_cachestat:
        return cachestat_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_chown:
        return _u_chown(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lchown:
        return _u_chown(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchown:
        return _u_fchown(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchownat:
        return _u_fchownat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mkdirat:
        return _u_mkdirat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_unlinkat:
        return _u_unlinkat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_umask:
        return _u_umask(a0, a1, a2, a3, a4, a5)
    if nr == SYS_ppoll:
        return _u_ppoll(a0, a1, a2, a3, a4, a5)
    if nr == SYS_clock_nanosleep:
        return _u_clock_nanosleep(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sched_getaffinity:
        return _u_sched_getaffinity(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sched_setaffinity:
        return _u_sched_setaffinity(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getcpu:
        return _u_getcpu(a0, a1, a2, a3, a4, a5)
    if nr == SYS_membarrier:
        return _u_membarrier(a0, a1, a2, a3, a4, a5)
    # SysV IPC: semaphores, message queues, shared memory.
    if nr == SYS_semget:
        return sysv_semget(a0, a1, a2, a3, a4, a5)
    if nr == SYS_semop:
        return sysv_semop(a0, a1, a2, a3, a4, a5)
    if nr == SYS_semctl:
        return sysv_semctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgget:
        return sysv_msgget(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgsnd:
        return sysv_msgsnd(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgrcv:
        return sysv_msgrcv(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgctl:
        return sysv_msgctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmget:
        return sysv_shmget(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmat:
        return sysv_shmat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmdt:
        return sysv_shmdt(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmctl:
        return sysv_shmctl(a0, a1, a2, a3, a4, a5)
    # POSIX message queues (mq_*). mq_send/mq_receive are glibc wrappers
    # over mq_timedsend/mq_timedreceive (NULL timeout); mq_getattr/setattr
    # ride mq_getsetattr.
    if nr == SYS_mq_open:
        return posixmq_open(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_unlink:
        return posixmq_unlink(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_timedsend:
        return posixmq_timedsend(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_timedreceive:
        return posixmq_timedreceive(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_getsetattr:
        return posixmq_getsetattr(a0, a1, a2, a3, a4, a5)
    # pidfd process-management family (linux_abi/u_pidfd.ad). pidfd_open
    # returns a pollable fd for a pid; pidfd_send_signal reuses the
    # signal_post delivery path; waitid(P_PIDFD) translates pidfd->pid and
    # reuses do_wait4.
    if nr == SYS_pidfd_open:
        pfd_rc: int64 = upidfd_open(a0, a1)
        # PIDFD_NONBLOCK (== O_NONBLOCK, 0x800) marks the new fd
        # non-blocking; the per-fd O_NONBLOCK bitmap lives here, so apply
        # it after u_pidfd allocated the fd.
        if pfd_rc >= 0 and (a1 & cast[uint64](0x800)) != 0:
            _u_set_fd_nonblock(cast[int32](pfd_rc), 1)
        return pfd_rc
    if nr == SYS_pidfd_send_signal:
        return upidfd_send_signal(a0, a1, a2, a3)
    if nr == SYS_waitid:
        return upidfd_waitid(a0, a1, a2, a3, a4)
    if nr == SYS_pidfd_getfd:
        return pidfd_getfd_handler(a0, a1, a2)
    if nr == SYS_process_madvise:
        return process_madvise_handler(a0, a1, a2, a3, a4)
    # §io_uring async-I/O family (linux_abi/u_iouring.ad). setup allocates
    # a ring fd + kernel SQ/CQ/SQE regions; enter consumes SQEs, executes
    # each opcode synchronously through the vfs read/write/fsync backends,
    # and posts a CQE per submission; register records fixed buffers/files.
    if nr == SYS_io_uring_setup:
        return io_uring_setup(a0, a1, a2, a3, a4, a5)
    if nr == SYS_io_uring_enter:
        return io_uring_enter(a0, a1, a2, a3, a4, a5)
    if nr == SYS_io_uring_register:
        return io_uring_register(a0, a1, a2, a3, a4, a5)
    # Unknown syscall — same convention as Linux: log + return -ENOSYS.
    # The printk includes nr so a trace of "unknown linux syscall X"
    # tells you exactly which entry to add to the ladder above.
    # WARN level so this survives the post-interactive console gate —
    # an unhandled syscall from dpkg/apt is exactly the gap we hunt and
    # must not be silently swallowed once userland is interactive.
    printk_set_level(PRINTK_LEVEL_WARN)
    printk2("linux_u: unknown syscall nr=%d a0=%x\n", nr, a0)
    set_current_errstr("unknown syscall")
    return ELINUX_NOSYS

    NET_CTL_OK, NET_CTL_EARP, NET_CTL_ETIMEOUT, NET_CTL_EREFUSED,
    NET_CTL_ENOSLOT, NET_CTL_EADDRINUSE, NET_CTL_ECONNECT,
    NETC_CONNECTED, NETC_LISTEN,
)

# as inotify (fs/vfs.ad's create/delete/modify/close hook, fed through a
# combined notify dispatcher registered at bring-up), but a different,
# fixed-size struct fanotify_event_metadata read format and a per-group
# mark list keyed on the watched object. x86_64 syscall numbers.
SYS_fanotify_init:     uint64 = 300
SYS_fanotify_mark:     uint64 = 301
# #165: ABI-completeness fill — commonly-hit syscalls real glibc/musl
# binaries (tar, cp, install, sshd, coreutils, pthread runtimes) emit
# that previously fell through to -ENOSYS. Each is backed by an existing
# kernel facility — see the per-handler comments for what.
SYS_chmod:             uint64 = 90
SYS_fchmod:            uint64 = 91
SYS_chown:             uint64 = 92
SYS_fchown:            uint64 = 93
SYS_lchown:            uint64 = 94
SYS_umask:             uint64 = 95
SYS_sched_setaffinity: uint64 = 203
SYS_sched_getaffinity: uint64 = 204
SYS_clock_nanosleep:   uint64 = 230
SYS_fchownat:          uint64 = 260
SYS_unlinkat:          uint64 = 263
SYS_mkdirat:           uint64 = 258
SYS_fchmodat:          uint64 = 268
SYS_fchmodat2:         uint64 = 452
# cachestat(2) — x86_64 nr 451. Query the page-cache residency of `fd` over a
# byte range, filling a struct cachestat (nr_cache / nr_dirty / ...).
SYS_cachestat:         uint64 = 451
SYS_faccessat:         uint64 = 269
SYS_ppoll:             uint64 = 271
SYS_preadv:            uint64 = 295
SYS_pwritev:           uint64 = 296
SYS_getcpu:            uint64 = 309
SYS_membarrier:        uint64 = 324
SYS_faccessat2:        uint64 = 439
# pidfd process-management family (the canonical x86_64 numbers).
# pidfd_send_signal=424, pidfd_open=434, waitid=247. The pidfd object
# pool + the four handlers live in linux_abi/u_pidfd.ad; the dispatch
# arms below forward to them. waitid (247) routes its P_PIDFD idtype

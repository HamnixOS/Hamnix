# U42 follow-up: per-task VMA layer. The flat 256-slot (base, order)
# table this file used since U7 graduates into a per-task sorted linked
# list of VmaNodes. The MAP_FIXED-overlay hack in _u_mmap_fixed_in_
# existing is replaced by a real overlap test + alias node in mm/vma.ad.
# vma_clear is called from arch/x86/kernel/syscall.ad::do_execve before
# loading the new ELF image; everything else (mmap/munmap/mprotect) is
# self-contained inside this module.
from mm.vma import (
    vma_alloc, vma_unmap, vma_protect, vma_madvise, vma_writeback_range,
    vma_mremap, vma_release_brk_overlap,
    # msync_selftest builds a writable file-backed shared VMA and faults
    # its pages in directly (a synchronous kernel self-test cannot take a
    # real #PF on its own access), then drives msync via the real dispatch.
    vma_alloc_file_shared, vma_alloc_file_demand,
    vma_demand_file_cover,
    vma_demand_fault, vma_alloc_demand,
    # getrusage(2) ru_maxrss + vmstat_selftest: on-demand virtual size /
    # resident-page walks over the calling task's VMAs.
    task_vsize_bytes, task_rss_pages,
    # vmstat_selftest builds a real demand-paged anonymous VMA in the boot
    # task and faults its pages in so the walk has present 4 KiB PTEs to
    # count (the boot task's identity map uses huge pages, which the
    # 4 KiB-granular present-walk reads as not-present).
    VMA_MAP_PRIVATE, VMA_MAP_ANONYMOUS,
    VMA_PROT_READ, VMA_PROT_WRITE,
)

# #163 (SAFE half) — adopt the real user-memory accessor layer for the
# hottest, highest-risk user-pointer writeback/read sites in this file.
# These helpers walk the CURRENT task's page tables, so a malformed user
# pointer yields a clean -EFAULT instead of a kernel #PF panic, and the
# future ET_DYN / mmap-base ASLR work (vaddr != phys) becomes a localized
# change instead of a whole-tree audit. NO vaddr!=phys decoupling is
# introduced here: under today's identity map every translated access is
# the same physical write the raw deref used to do.
from mm.uaccess import (
    copy_to_user, copy_from_user,
    get_user_8, get_user_64, put_user_16, put_user_32, put_user_64,
    strncpy_from_user,
    # splice self-test: stand up a real vaddr!=phys user mapping so the
    # vmsplice copy_from_user gather path is exercised against genuine
    # user memory rather than a kernel pointer.
    uaccess_current_pml4, uaccess_resolve,
)

# memset for zero-filling user-supplied stat buffers before we poke
# individual fields. Declared `extern` because the actual body lives in
# the C-runtime shim that compiler.adder links against; same pattern as
# linux_abi/u_libc.ad and mm/slab.ad.
extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
# memcpy: the finit_module grow-by-chunks read loop copies the partial
# image into a freshly-enlarged buffer. Same C-runtime-shim extern as
# memset / the other arch modules.
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
# M16.36: needed by _u_brk to flush stale TLB entries after the lazy
# brk reservation installs fresh per-task PT entries — the same TLB-
# flush dance do_execve / SYS_SPAWN do after elf_apply_last_user_mapping.
extern def load_cr3(value: uint64)
# rusage_selftest needs to briefly enable CPU interrupts so the LAPIC
# timer tick fires and advances jiffies + accrues stime to the current
# task. start_kernel runs IF-blocked, so without this the busy-spin would
# never see jiffies move. Same enable/spin/disable pattern the live-USB
# keyboard self-test uses in init/main.ad.
extern def local_irq_enable()
extern def local_irq_disable()
extern def cpu_relax()
# U27 futex table lock. Serialises "register-my-slot + prepare-to-wait +
# recheck *uaddr" on the WAIT side against "clear-slot + wake" on the WAKE
# side, closing the classic futex lost-wakeup window. Taken only from
# syscall (ring-0) context — futex is never poked from an IRQ handler — so
# a plain spinlock is sufficient (ring-0 ticks never preempt, per
# time.ad's preempt_tick gate).
extern def spinlock_lock(ptr: Ptr[uint32])
extern def spinlock_unlock(ptr: Ptr[uint32])
# Returns 1 if the lock was acquired, 0 if it was already held. Used by the
# IRQ-context bounded-futex-park sweep, which must never block on a lock a
# preempted task holds on this same CPU.
extern def spinlock_trylock(ptr: Ptr[uint32]) -> uint32
# msync_selftest runs at boot:37.msy, BEFORE syscall_init (boot:39) arms
# IA32_EFER.NXE. Shared-writable file pages are WRITABLE NX DATA, so a
# data access would otherwise take a reserved-bit #PF. Arm NXE first
# (idempotent — syscall_init re-arms it), like the file-mmap selftests.
extern def set_efer_nxe()

# Generic MSR writer — the asm body lives in arch/x86/kernel/syscall_64.S
# (write_msr) and takes the canonical (index, value) pair. We need it for
# SYS_arch_prctl's ARCH_SET_FS path: glibc's pthread bring-up calls
# arch_prctl(ARCH_SET_FS, &tcb) and then derefs %fs:0x10 for the TLS
# pointer, so failing this syscall means glibc segfaults before main().
extern def write_msr(index: uint32, value: uint64)
# Generic MSR reader (asm body in arch/x86/kernel/syscall_64.S). Needed
# for arch_prctl(ARCH_GET_GS) to hand the user GS_BASE MSR back.
extern def read_msr(index: uint32) -> uint64

# IA32_FS_BASE — MSR 0xC0000100. Writing this is the kernel-side
# equivalent of `wrfsbase` on CPUs that lack the FSGSBASE feature.
IA32_FS_BASE: uint32 = 0xC0000100
# IA32_GS_BASE — MSR 0xC0000101. ARCH_SET_GS writes here. NOTE the
# kernel itself uses %gs for per-CPU state via IA32_KERNEL_GS_BASE
# (0xC0000102) — the active GS.base on a SYSCALL entry is the kernel's,
# swapped in by swapgs. The user value lives in IA32_GS_BASE (the
# "inactive" copy on entry) and swapgs makes it live on return, so
# writing IA32_GS_BASE here sets the *user* GS without disturbing the
# kernel's per-CPU base.
IA32_GS_BASE: uint32 = 0xC0000101

# arch_prctl op codes (from <asm/prctl.h>).
ARCH_SET_GS: uint64 = 0x1001
ARCH_SET_FS: uint64 = 0x1002
ARCH_GET_FS: uint64 = 0x1003
ARCH_GET_GS: uint64 = 0x1004

# SYS_brk state. M16.104: now per-task — three uint64 fields on
# TaskStruct (brk_base / brk_end / brk_max), accessed through the
# task_brk_* helpers imported above. The old single-global cursor
# (linux_brk / linux_brk_end) collided across concurrent Linux ELFs
# and forced single-process callers to fight kmalloc fragmentation;
# the per-task region pre-reserves contiguous physical memory via
# alloc_pages(LINUX_BRK_ORDER) on first call so glibc-malloc's
# arena bookkeeping sees a single growing range — no more "break
# adjusted to free malloc space" abort.
#
# LINUX_BRK_ORDER = 10 → 2^10 pages = 4 MiB contiguous per single
# alloc_pages call. That's the page-allocator's MAX_ORDER (see
# mm/page_alloc.ad), so it's the largest single contiguous region
# alloc_pages can hand us in one call.
#
# LINUX_BRK_CHUNKS = 8 → we issue 8 back-to-back alloc_pages(MAX_ORDER)
# calls on first brk() to build a 32 MiB reservation. Why this works
# even though alloc_pages itself caps at MAX_ORDER: the FIRST eight
# MAX_ORDER allocations in the system go through alloc_pages Path 3
# (memblock_alloc(4 MiB, 4 MiB)), which is a bump allocator — chunks
# are returned in ascending physical address with exact 4 MiB
# alignment, so 8 consecutive calls produce 32 MiB of physically
# contiguous, 4 MiB-aligned memory. We assert contiguity at run time
# (each chunk's base must equal the previous chunk + 4 MiB) and fall
# back to whatever shorter prefix we got if a non-contiguous chunk
# lands — that keeps the invariant glibc-malloc cares about (the
# brk_base..brk_max range is one virtually-contiguous arena) intact
# even on later tasks where the page allocator may be fragmented.
#
# Why 32 MiB and not 4 MiB / 64 MiB:
#   * 4 MiB (the M16.104 ceiling) is too small for CPython 3.11.10:
#     U41 reached importlib bootstrap and aborted with `Fatal Python
#     error: pycore_interp_init: failed to initialize importlib /
#     MemoryError` because CPython's import phase needs ~10-15 MiB of
#     heap (per 054f58b commit + tests/u-binary/src/cpython/HOWTO.md
#     "Known blocker" diagnosis). 32 MiB gives CPython 2-3x headroom
#     over its measured peak with room left for stdlib import-as-you-go.
#   * 64 MiB would be nicer for future apt-static / postgres-static
#     workloads, but with NTASKS=16 and the EAGER reservation strategy
#     below, 64 MiB × 16 = 1 GiB worst case — bigger than memblock's
#     entire 238 MiB usable range (mm/memblock.ad MEMBLOCK_BASE..TOP).
#     32 MiB × 16 = 512 MiB worst case is still more than memblock has
#     in theory, but in practice only 1-2 Linux tasks ever run
#     concurrently (test_u39_python, test_u40_musl_busybox, test_u41
#     cpython each spawn a single Linux child), so the realistic peak
#     is 32-64 MiB of pre-reserved heap. The full-fat 64 MiB ceiling
#     belongs to a follow-up that switches brk to a true lazy mmap-
#     backed vma (allocates pages on fault, not on reservation).
#
# Why pre-reserve up front instead of growing one page per brk-grow:
# glibc-malloc only consults brk() for the TOP address and assumes
# everything below it is one virtually-contiguous arena. If we
# alloc_page() once per grow we'd hit the same kmalloc-fragments-at-
# page-granularity problem the old code did (alloc_page returns
# whatever order-0 slot is free; consecutive calls rarely land
# adjacent). Pre-reserving the full reservation in a tight burst of
# alloc_pages(MAX_ORDER) calls guarantees contiguity for the lifetime
# of the task.
LINUX_BRK_ORDER:   int32  = 10
LINUX_BRK_CHUNK:   uint64 = 4194304        # 2^10 * 4096 = 4 MiB per chunk
LINUX_BRK_CHUNKS:  uint64 = 8              # 8 × 4 MiB = 32 MiB total
LINUX_BRK_RESERVE: uint64 = 33554432       # 8 × 4 MiB = 32 MiB

# DIRECT-MAP ALIASING FIX (2026-06-19): the brk arena's USER virtual base.
# The 32 MiB reservation's PHYSICAL backing comes from low alloc_pages RAM,
# but its USER virtual address now lives HIGH — above the 4 GiB kernel
# direct-map, alongside the ET_DYN load-bias (4 GiB) / interp (5 GiB) ASLR
# windows (arch/x86/kernel/syscall.ad). Identity-mapping the brk at its low
# physical address made the 32 MiB heap window alias the exact frames the
# buddy/page allocator hands back to the kernel, which is the root of the
# 2nd-Linux-spawn ET_DYN-vs-direct-map supervisor #PF (cr2 LOW, pte[0]=0).
# Decoupling vaddr from phys (high VA -> low phys) restores the invariant
# that no frame is reachable through BOTH a live user mapping and a free /
# kernel-writable direct-map slot at the same translation.
#
# 6 GiB base: image=[4,5) GiB, interp=[5,6) GiB, brk=[6 GiB, 6 GiB+32 MiB).
# The whole 32 MiB span sits inside ONE 1 GiB PDPT slot (PDPT[6] of PML4[0])
# and never crosses a 1 GiB boundary, so elf_install_user_range lays it down
# in a single per-task PD/PT subtree. The mmap window is [8 GiB, ~16 GiB)
# (mm/vma.ad VMA_LARGE_BASE + slide), so brk is clear of it too. glibc-malloc
# only cares that brk_base..brk_max is one virtually-contiguous arena; the
# high VA satisfies that exactly as the old low identity VA did, and
# copy_to/from_user (mm/uaccess.ad) PML4-walks the high VA to its low phys
# so kernel-side derefs of brk pointers keep working.
LINUX_BRK_VBASE:   uint64 = 0x180000000    # 6 GiB

# SYS_set_tid_address state. Linux records the user pointer so that on
# task exit the kernel can clear it (and futex-wake the parent waiting
# on CLONE_CHILD_CLEARTID). We don't have per-task storage for it
# without touching kernel/sched/core.ad, and the task constraint here
# is "only u_syscalls.ad" — so we keep it as a single global for the
# single Linux task that the L1 surface supports. When real thread
# groups land this moves into task_struct alongside the tid itself.
linux_clear_child_tid: uint64 = 0


# =====================================================================
# Linux x86_64 syscall numbers (from arch/x86/entry/syscalls/syscall_64.tbl)
# =====================================================================
#
# Kept verbatim with stock Linux 6.12 so userspace binaries compiled
# against unistd_64.h hit the same numbers we dispatch on. Gaps in the
# numbering are intentional — we only define what we currently care
# about; unlisted numbers fall through to the default -ENOSYS path in
# linux_u_syscall_dispatch().

SYS_read:            uint64 = 0
SYS_write:           uint64 = 1
SYS_open:            uint64 = 2
SYS_close:           uint64 = 3
SYS_stat:            uint64 = 4
SYS_fstat:           uint64 = 5
SYS_lstat:           uint64 = 6
SYS_poll:            uint64 = 7
SYS_lseek:           uint64 = 8
SYS_mmap:            uint64 = 9
SYS_mprotect:        uint64 = 10
SYS_munmap:          uint64 = 11
SYS_brk:             uint64 = 12
SYS_rt_sigaction:    uint64 = 13
SYS_rt_sigprocmask:  uint64 = 14
SYS_rt_sigreturn:    uint64 = 15
SYS_ioctl:           uint64 = 16
SYS_pread64:         uint64 = 17
SYS_pwrite64:        uint64 = 18
SYS_readv:           uint64 = 19
SYS_writev:          uint64 = 20
SYS_access:          uint64 = 21
SYS_pipe:            uint64 = 22
SYS_select:          uint64 = 23
SYS_sched_yield:     uint64 = 24
SYS_mremap:          uint64 = 25
SYS_msync:           uint64 = 26
SYS_dup:             uint64 = 32
SYS_dup2:            uint64 = 33
SYS_fsync:           uint64 = 74
SYS_fdatasync:       uint64 = 75
SYS_truncate:        uint64 = 76
SYS_ftruncate:       uint64 = 77
SYS_rename:          uint64 = 82
SYS_sync:            uint64 = 162
SYS_reboot:          uint64 = 169
# LINUX_REBOOT_* magics/cmds are imported from arch.x86.kernel.power
# (the single source of truth, shared with the native SYS_REBOOT arm).
SYS_renameat:        uint64 = 264
SYS_renameat2:       uint64 = 316
SYS_getitimer:       uint64 = 36
SYS_alarm:           uint64 = 37
SYS_setitimer:       uint64 = 38
SYS_nanosleep:       uint64 = 35
SYS_getpid:          uint64 = 39
SYS_clone:           uint64 = 56
SYS_fork:            uint64 = 57
SYS_vfork:           uint64 = 58
SYS_execve:          uint64 = 59
SYS_exit:            uint64 = 60
SYS_wait4:           uint64 = 61
SYS_kill:            uint64 = 62
SYS_ptrace:          uint64 = 101         # #147: ptrace(2) for strace
SYS_uname:           uint64 = 63
SYS_fcntl:           uint64 = 72
SYS_getcwd:          uint64 = 79
SYS_chdir:           uint64 = 80
SYS_fchdir:          uint64 = 81
SYS_mkdir:           uint64 = 83
SYS_rmdir:           uint64 = 84
SYS_unlink:          uint64 = 87
SYS_readlink:        uint64 = 89
# Hardlink / symlink creation. The VFS (fs/vfs.ad) fully implements
# vfs_link / vfs_symlink (ext4 inode hardlinks, ext4/tmpfs symlinks) but
# the Linux-ABI side never wired these numbers, so `ln` / `ln -s` and
# tar/dpkg symlink+hardlink extraction returned -ENOSYS. The *at variants
# anchor a relative path at the task cwd (the AT_FDCWD answer) exactly as
# the rename/mkdir/unlink *at handlers above do.
SYS_link:            uint64 = 86
SYS_symlink:         uint64 = 88
SYS_linkat:          uint64 = 265
SYS_symlinkat:       uint64 = 266
# Timestamp setters. utimensat(2) is the modern workhorse — `touch`,
# `cp -p`, `tar -p`, and make's mtime-preservation passes all funnel
# through it; the legacy utimes/utime/futimesat numbers exist for older
# statically-linked binaries. All route to vfs_set_mtime (ext4 persists
# i_mtime/i_ctime; tmpfs accepts as no-op success, matching Linux).
SYS_utime:           uint64 = 132
SYS_utimes:          uint64 = 235
SYS_futimesat:       uint64 = 261
SYS_utimensat:       uint64 = 280
# U31: prctl(2). Hamnix handles PR_SET_NAME / PR_GET_NAME (busybox uses
# these for argv[0] tagging) and accepts PR_SET_DUMPABLE / PR_SET_PDEATHSIG
# so libc bring-up paths keep moving.
SYS_prctl:           uint64 = 157
SYS_arch_prctl:      uint64 = 158
SYS_time:            uint64 = 201
SYS_futex:           uint64 = 202
# nr 449: futex_waitv(2) -- wait on a vector of futexes, wake on any. The
# dispatch arm forwards to futexv_waitv (linux_abi/u_futexv.ad). Declared here
# alongside SYS_futex since both share this module's futex wait table.
SYS_futex_waitv:     uint64 = 449
SYS_set_tid_address: uint64 = 218
SYS_clock_gettime:   uint64 = 228
SYS_clock_getres:    uint64 = 229
SYS_exit_group:      uint64 = 231
SYS_openat:          uint64 = 257
SYS_newfstatat:      uint64 = 262
# U18: stubs needed by glibc-static startup before main() runs.
SYS_set_robust_list: uint64 = 273
SYS_prlimit64:       uint64 = 302
# #160 / seccomp-lite: the dedicated seccomp(2) syscall (x86_64 nr 317).
# Both this and prctl(PR_SET_SECCOMP, ...) install the same per-task
# filter state.
SYS_seccomp:         uint64 = 317
SYS_getrandom:       uint64 = 318
SYS_rseq:            uint64 = 334
# SysV IPC syscall numbers (x86_64). shmget/shmat/shmctl precede the
# sem/msg block in the numeric ladder; shmdt/msg* follow it.
SYS_shmget:          uint64 = 29
SYS_shmat:           uint64 = 30
SYS_shmctl:          uint64 = 31
SYS_semget:          uint64 = 64
SYS_semop:           uint64 = 65
SYS_semctl:          uint64 = 66
SYS_shmdt:           uint64 = 67
SYS_msgget:          uint64 = 68
SYS_msgsnd:          uint64 = 69
SYS_msgrcv:          uint64 = 70
SYS_msgctl:          uint64 = 71
# POSIX message queues (mq_*) — x86_64 syscall numbers. These are the
# POSIX.1b realtime message-queue API, distinct from the SysV msg* block
# above. Implemented in linux_abi/u_posixmq.ad.
SYS_mq_open:          uint64 = 240
SYS_mq_unlink:        uint64 = 241
SYS_mq_timedsend:     uint64 = 242
SYS_mq_timedreceive:  uint64 = 243
SYS_mq_getsetattr:    uint64 = 245
SYS_getrlimit:       uint64 = 97
SYS_setrlimit:       uint64 = 160
SYS_getpriority:     uint64 = 140
SYS_setpriority:     uint64 = 141
# POSIX.1e capabilities (capget/capset). x86_64 syscall numbers; forwarded to
# the per-task capability store in linux_abi/u_caps.ad.
SYS_capget:          uint64 = 125
SYS_capset:          uint64 = 126
# perf_event_open(2) — Linux software-counter ABI; forwarded to the per-task
# perf-event shim in linux_abi/u_perf.ad (read-only over existing accumulators).
SYS_perf_event_open: uint64 = 298
# NUMA mempolicy ABI (x86_64 syscall numbers). Forwarded to the per-task
# mempolicy store in linux_abi/u_mempolicy.ad (single-node, honest).
SYS_mbind:           uint64 = 237
SYS_set_mempolicy:   uint64 = 238
SYS_get_mempolicy:   uint64 = 239
# Linux NTP / kernel-clock-discipline ABI (x86_64 syscall numbers). Forwarded
# to the system-wide discipline state in linux_abi/u_adjtimex.ad. adjtimex
# disciplines CLOCK_REALTIME (freq/tick/offset) observably; clock_adjtime is
# the per-clock form (only CLOCK_REALTIME is steerable).
SYS_adjtimex:        uint64 = 159
SYS_clock_adjtime:   uint64 = 305
# Linux kernel keyring ABI (x86_64 syscall numbers). Forwarded to the
# per-process / per-user key store in linux_abi/u_keyring.ad (REAL payloads,
# honest search/revoke). Keys are serials, not fds.
SYS_add_key:         uint64 = 248
SYS_request_key:     uint64 = 249
SYS_keyctl:          uint64 = 250
# process_vm_readv/writev — x86_64 nr 310/311. Forwarded to the real
# cross-address-space copy in linux_abi/u_process_vm.ad. 6-arg syscalls:
# (pid, local_iov, liovcnt, remote_iov, riovcnt, flags).
SYS_process_vm_readv:  uint64 = 310
SYS_process_vm_writev: uint64 = 311
# mseal(2) — x86_64 nr 462. Forwarded to linux_abi/u_mseal.ad, which seals
# the EXISTING per-task VMAs; mprotect/munmap/mremap/madvise honour the seal.
SYS_mseal:           uint64 = 462
# name_to_handle_at(2)/open_by_handle_at(2) — x86_64 nr 303/304. Forwarded to
# linux_abi/u_fhandle.ad: encode a path to an opaque handle, re-open by handle.
SYS_name_to_handle_at: uint64 = 303
SYS_open_by_handle_at: uint64 = 304
# bpf(2) — x86_64 nr 321. Forwarded to the in-kernel eBPF interpreter + map/prog
# state in linux_abi/u_bpf.ad (real bytecode execution, real key->value maps,
# real rejection of invalid programs).
SYS_bpf:             uint64 = 321
# userfaultfd(2) — x86_64 nr 323. Returns a uffd fd (FD_UFFD_MARK) routed to the
# REAL demand-paging-in-userspace implementation in linux_abi/u_userfaultfd.ad.
# The UFFDIO_* ioctls + the uffd_msg read are routed through the ioctl/read arms;
# the #PF hook (uffd_pagefault_hook) lives in do_page_fault.
SYS_userfaultfd:     uint64 = 323
# Landlock LSM (x86_64 syscall numbers). Forwarded to the per-task path-based
# deny filter in linux_abi/u_landlock.ad (the open hook lives in _u_open).
SYS_landlock_create_ruleset: uint64 = 444
SYS_landlock_add_rule:       uint64 = 445
SYS_landlock_restrict_self:  uint64 = 446
# Disk-quota ABI (x86_64 syscall number). Forwarded to the per-(fs,type,id)
# quota store in linux_abi/u_quota.ad (real limit/usage accounting, honest).
SYS_quotactl:        uint64 = 179
# §fuse: mount(2) — x86_64 nr 165. The only filesystem type we honour here
# is "fuse" / "fuse.<sub>": mount("fuse", target, "fuse", flags, "fd=N")
# binds `target` in the namespace to the FUSE connection opened on fd N. Any
# other type returns -ENODEV (Hamnix mounts are otherwise Plan-9 bind ops).
SYS_mount:           uint64 = 165
# POSIX realtime scheduling-policy ABI (x86_64 syscall numbers). These
# forward to the native realtime policy mechanism in kernel/sched/core.ad
# (the same mechanism the Plan 9 /proc/<pid>/ctl `policy` verb drives).
SYS_sched_setparam:        uint64 = 142
SYS_sched_getparam:        uint64 = 143
SYS_sched_setscheduler:    uint64 = 144
SYS_sched_getscheduler:    uint64 = 145
SYS_sched_get_priority_max: uint64 = 146
SYS_sched_get_priority_min: uint64 = 147
# statfs(2) / fstatfs(2): filesystem capacity query. df, statvfs-based
# tools, and installers reach for these to size the target volume.
SYS_statfs:          uint64 = 137
SYS_fstatfs:         uint64 = 138
# Extended attributes (x86_64 numbers).
SYS_setxattr:        uint64 = 188
SYS_lsetxattr:       uint64 = 189
SYS_fsetxattr:       uint64 = 190
SYS_getxattr:        uint64 = 191
SYS_lgetxattr:       uint64 = 192
SYS_fgetxattr:       uint64 = 193
SYS_listxattr:       uint64 = 194
SYS_llistxattr:      uint64 = 195
SYS_flistxattr:      uint64 = 196
SYS_removexattr:     uint64 = 197
SYS_lremovexattr:    uint64 = 198
SYS_fremovexattr:    uint64 = 199
# U21: identity / time / sysinfo / readlinkat — the tail of glibc's
# pre-main probing surface. None of these need actual kernel-side
# state at this milestone (single-task-per-binary, no symlinks, no
# real time-of-day source); they just have to *answer* so glibc keeps
# moving instead of bailing on -ENOSYS.
SYS_gettimeofday:    uint64 = 96
SYS_sysinfo:         uint64 = 99
SYS_getuid:          uint64 = 102
SYS_getgid:          uint64 = 104
SYS_geteuid:         uint64 = 107
SYS_getegid:         uint64 = 108
# QA-N10: setuid(2)/setgid(2). Debian login/su/busybox/dpkg maintainer
# scripts drop privilege by calling these on startup; the common case is
# a process re-asserting its OWN id (uid 1001 -> setuid(1001)), which must
# succeed with 0, not fall through to the -ENOSYS "unknown syscall" path.
SYS_setuid:          uint64 = 105
SYS_setgid:          uint64 = 106
SYS_getppid:         uint64 = 110
# QA-N15: getgroups(2)/setgroups(2). `id` and login/su/pam call getgroups
# on startup to enumerate supplementary groups; it was unimplemented, so a
# Debian binary run under `enter linux` hit "unknown syscall nr=115" and
# `id` printed "can't get groups". We model one supplementary group == the
# caller's gid so `id` shows a groups= field.
SYS_getgroups:       uint64 = 115
SYS_setgroups:       uint64 = 116
# Firefox bring-up: GLib's g_check_setuid() / NSPR privilege probe call
# getresuid(2)/getresgid(2) at startup to compare real/effective/saved ids.
# They were unimplemented, so Firefox hit "unknown syscall nr=118", the
# glibc wrapper returned -1 WITHOUT filling the caller's *ruid/*euid/*suid
# out-params, and the (uninitialised) comparison downstream dereferenced a
# bad pointer -> SIGSEGV before the main window mapped. effective == real ==
# saved on this path (no suid mechanism), same model as geteuid/getegid.
SYS_getresuid:       uint64 = 118
SYS_getresgid:       uint64 = 120
SYS_readlinkat:      uint64 = 267
# U28: modern glibc (2.34+) prefers clone3 over the 5-arg clone.
SYS_clone3:          uint64 = 435
# "Plan 9 did containers first": unshare(2) / setns(2). unshare(CLONE_NEWNS)
# gives the calling task a private copy of its mount namespace (= native
# Pgrp) in place — the canonical container-build primitive. setns(2) needs
# an fd->namespace (nsfs /proc/PID/ns/mnt) mapping Hamnix has no machinery
# for yet, so it is registered to reject gracefully (see _u_setns).
SYS_unshare:         uint64 = 272
SYS_setns:           uint64 = 308
# CLONE_NEW* namespace bits (Linux <linux/sched.h>). We honour CLONE_NEWNS
# (mount namespace) ONLY; every other CLONE_NEW* bit is out of scope and
# unshare/clone reject them rather than silently pretending to isolate.
CLONE_NEWNS:         uint64 = 0x00020000   # new MOUNT namespace (supported)
CLONE_NEWCGROUP:     uint64 = 0x02000000
CLONE_NEWUTS:        uint64 = 0x04000000
CLONE_NEWIPC:        uint64 = 0x08000000
CLONE_NEWUSER:       uint64 = 0x10000000
CLONE_NEWPID:        uint64 = 0x20000000
CLONE_NEWNET:        uint64 = 0x40000000
# Mask of every CLONE_NEW* bit we explicitly DO NOT implement. unshare(2)
# returns -EINVAL if any of these is set.
CLONE_NEW_UNSUPPORTED: uint64 = 0x7E000000
# U29: directory enumeration + flagged-pipe + flagged-dup. busybox /
# glibc-static both reach for getdents64 to enumerate /bin, pipe2 for
# `|` operators with O_CLOEXEC, and dup3 inside the posix_spawn fallback.
# pipe2 / dup3 forward unconditionally to the flag-less primitives;
# getdents64 is wired through to vfs_listdir on directory-flavoured fds
# only (anything else returns -ENOTDIR, which is what Linux does for
# regular files).
SYS_getdents64:      uint64 = 217
SYS_dup3:            uint64 = 292
SYS_pipe2:           uint64 = 293
# U33: cheap no-op / forward-to-stat syscalls that busybox applets
# (cat, ls -l, pwd) emit during their startup or per-file probes.
# Adding handlers (instead of letting them fall through to -ENOSYS)
# eliminates the noisiest "linux_u: unknown syscall" log lines and
# lets busybox skip its fallback paths.
SYS_madvise:         uint64 = 28
SYS_getrusage:       uint64 = 98
SYS_times:           uint64 = 100
SYS_fadvise64:       uint64 = 221
SYS_fallocate:       uint64 = 285
SYS_pselect6:        uint64 = 270
SYS_move_pages:      uint64 = 277
SYS_statx:           uint64 = 332
# U34: sendfile lets busybox cat / future cp use a kernel-side splice
# instead of a userspace read+write loop. We don't have zero-copy DMA
# wiring, so the body just bounces through a small stack buffer — same
# observable behaviour, no ENOSYS spam.
SYS_sendfile:        uint64 = 40
# copy_file_range(2): fd->fd byte copy with independent in/out offset
# pointers. We have no reflink/server-side copy, so it bounces through a
# staging buffer via the same VFS read/write path sendfile uses — same
# observable result for the regular-file -> regular-file case `cp`
# (and busybox's coreutils) probe first.
SYS_copy_file_range: uint64 = 326
# Pipe zero-copy I/O family. splice(2)/tee(2)/vmsplice(2) move bytes
# through the anonymous-pipe ring (fs/pipe.ad) with at least one pipe
# end, reusing the same VFS read/write data-move primitives sendfile /
# copy_file_range bounce through. No SPLICE_F_MOVE page-stealing — the
# observable byte stream matches Linux for the copy-semantics callers
# (busybox / glibc tee, log shippers) actually depend on.
SYS_splice:          uint64 = 275
SYS_tee:             uint64 = 276
SYS_vmsplice:        uint64 = 278
# close_range(2): close every open fd in the inclusive span [first, last].
# glibc's posix_spawn / abort-path fd scrubbers and modern coreutils call
# this to drop inherited descriptors in one trap instead of a close() loop.
# Hamnix has no FD_CLOEXEC table, so CLOSE_RANGE_CLOEXEC degrades to a plain
# close (the fds are gone either way); CLOSE_RANGE_UNSHARE is a no-op since
# every task already owns a private fd table.
SYS_close_range:     uint64 = 436
CLOSE_RANGE_UNSHARE: uint64 = 0x02
CLOSE_RANGE_CLOEXEC: uint64 = 0x04
# Upper bound of the close_range walk. Mirrors fs/vfs.ad's _VFS_NR_FDS (the
# per-task fd-table size); keep the two in sync if the table ever grows.
CLOSE_RANGE_FD_CAP:  uint64 = 16
# U35: AF_UNIX socket-shaped stubs. Hamnix has no network stack, but
# busybox / glibc paths that probe socket(2) early (e.g. sh's
# job-control / `[`-builtin code path) still need *some* answer. We
# allocate a real fd marked FD_SOCKET_MARK so subsequent close / poll
# don't bounce off -EBADF, and forward socketpair(2) to vfs_pipe — a
# bidirectional pipe pair is observationally indistinguishable from
# AF_UNIX SOCK_STREAM at this scope. listen / accept / connect remain
# stub-but-honest (-ECONNREFUSED / -EAGAIN) so failing paths surface
# instead of hanging.
SYS_socket:          uint64 = 41
SYS_connect:         uint64 = 42
SYS_accept:          uint64 = 43
SYS_sendto:          uint64 = 44
SYS_recvfrom:        uint64 = 45
SYS_sendmsg:         uint64 = 46
SYS_recvmsg:         uint64 = 47
SYS_shutdown:        uint64 = 48
SYS_bind:            uint64 = 49
SYS_listen:          uint64 = 50
SYS_getsockname:     uint64 = 51
SYS_getpeername:     uint64 = 52
SYS_socketpair:      uint64 = 53
SYS_setsockopt:      uint64 = 54
SYS_getsockopt:      uint64 = 55
SYS_accept4:         uint64 = 288
# U36: session / process-group / thread-group identity. Hamnix has no
# real session or pgrp tracking — every task is its own session and
# pgrp — so setsid / getsid / getpgid / getpgrp all return the caller's
# pid, and setpgid is a no-op. gettid mirrors getpid (single-thread-
# per-task). tgkill forwards to the same kill path; we ignore the tgid
# argument because thread-group tracking is also not yet a concept.
SYS_setpgid:         uint64 = 109
SYS_getpgrp:         uint64 = 111
SYS_setsid:          uint64 = 112
SYS_getpgid:         uint64 = 121
SYS_getsid:          uint64 = 124
SYS_gettid:          uint64 = 186
SYS_readahead:       uint64 = 187
# §3: tkill(tid, sig) — the pre-tgkill single-arg kill-by-tid call.
# musl's raise(3) issues tkill(gettid(), sig), so the full signal
# surface needs it wired even though tgkill (234) is the modern form.
SYS_tkill:           uint64 = 200
SYS_tgkill:          uint64 = 234
# U37: sigaltstack — glibc reaches for this during static-PIE signal
# setup so a SIGSEGV handler can land on a known-good page if the
# user's main stack is the thing that overflowed. Hamnix has no
# nested handler delivery and never switches to the alt stack; the
# handler just records the values and returns 0 so glibc keeps moving.
SYS_sigaltstack:     uint64 = 131
# §5 Layer-2 async I/O — the fd-based event primitives real Linux
# server daemons are built around. These syscall NUMBERS are the fixed
# Linux x86_64 ABI values (a Linux ELF binary issues `epoll_wait` as
# syscall 232 — the number cannot be renumbered); the orchestrator's
# "use 290+" guidance is for NATIVE Hamnix syscalls in arch/x86/kernel/
# syscall.ad, and these add NOTHING there — epoll(7) is Layer-2-only and
# is dispatched entirely through linux_u_syscall_dispatch below. The
# objects themselves are confined in linux_abi/u_epoll.ad and never leak
# into Layer 1.
SYS_epoll_create:    uint64 = 213
SYS_epoll_wait:      uint64 = 232
SYS_epoll_ctl:       uint64 = 233
SYS_epoll_pwait:     uint64 = 281
SYS_epoll_create1:   uint64 = 291
SYS_eventfd:         uint64 = 284
SYS_eventfd2:        uint64 = 290
SYS_timerfd_create:  uint64 = 283
SYS_timerfd_settime: uint64 = 286
SYS_timerfd_gettime: uint64 = 287
SYS_signalfd:        uint64 = 282
SYS_signalfd4:       uint64 = 289
# #155: inotify — the eventfd/signalfd/timerfd trio's missing third leg.
SYS_inotify_init:      uint64 = 253
SYS_inotify_add_watch: uint64 = 254
SYS_inotify_rm_watch:  uint64 = 255
SYS_inotify_init1:     uint64 = 294

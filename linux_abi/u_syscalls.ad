# X25519 key exchange, server cert-chain validation against the CA
# store, CertificateVerify transcript binding — over an already-
# connected TCP slot. Same single-session module-global state the
# in-kernel http.ad https_get path uses; tls_connect(2) serialises
# access to it via usock_any_tls_active().
from drivers.net.tls import tls_init, tls_handshake
from kernel.sched.core import (
    TaskStruct, current_task, current_task_uid, current_task_gid,
    current_task_is_hostowner, UID_HOSTOWNER, UID_NOBODY,
    # QA-N10: setuid(2)/setgid(2) mutate the caller's native per-task
    # credential in place; these are the privileged writers the getters
    # (current_task_uid/current_task_gid) read back.
    set_current_task_uid, set_current_task_gid,
    # *at(2) dirfd resolution: recover an open dirfd's recorded path so
    # mkdirat/unlinkat with a real (non-AT_FDCWD) dirfd + relative path
    # work — `mkdir -p` and dpkg open each created dir and pass its fd.
    task_fd_opened_path_ptr,
    # O_CLOEXEC / FD_CLOEXEC: per-fd close-on-exec flag lives in the fd
    # table (survives fork, consumed at exec). Set/cleared by the fd-
    # creating syscalls + fcntl F_SETFD/F_GETFD here.
    fd_cloexec_set, fd_cloexec_get,
    current_task_pid, current_task_tgid, task_lookup_by_pid, task_exit_current,
    linux_group_fatal_kill,
    signal_post, signal_pending, get_cwd_buf, set_task_cwd, current_idx_get,
    # maps_open_selftest synthesizes a main-thread user-stack range on the boot
    # slot (which never went through do_execve) so vma_maps_render emits the
    # [stack] line, then restores it. task_ustack_lo/sz read it back.
    set_task_ustack_range, task_ustack_lo, task_ustack_sz,
    get_task_itimer_real_ticks, set_task_itimer_real_ticks,
    get_task_itimer_real_reload, set_task_itimer_real_reload,
    # /proc/<pid>/io: charge rchar/syscr at read() and wchar/syscw at write().
    current_task_charge_read, current_task_charge_write,
    set_task_fs_base, task_fs_base, set_task_clear_child_tid,
    count_live_linux_peers, yield_to_others, kernel_cond_resched,
    # U27 futex BOUNDED park: a real park (blocking wait queue) instead of a
    # poll-yield spin, but woken on a BOUNDED timer to self-heal any lost
    # directed wake. WaitQueue + wq_wait_prepare/commit_timeout/cancel park
    # the caller OFF the runqueue; wq_wake_slot directed-wakes a specific
    # waiter task by slot. The park is gated on count_live_linux_peers (a
    # RUNNABLE same-mm peer) so the render-critical word-poll path still
    # EAGAINs like the poll-yield build (see _u_futex).
    WaitQueue, wq_init, wq_wait_prepare, wq_wait_commit_timeout,
    wq_wait_cancel, wq_wake_slot, linux_mm_peer_count, WQ_EINTR, WQ_TIMEOUT,
    get_task_sig_handler, set_task_sig_handler,
    get_task_sig_mask, set_task_sig_mask,
    get_task_sig_flags, set_task_sig_flags,
    get_task_sig_in_handler, set_task_sig_in_handler,
    get_task_sig_saved_mask, set_task_sig_saved_mask,
    get_task_sig_frame_uctx, set_task_sig_frame_uctx,
    UCTX_GREG_RAX_OFF, UCTX_GREG_RSP_OFF, UCTX_GREG_RIP_OFF,
    UCTX_GREG_EFL_OFF, UCTX_SIGMASK_OFF, SIGPIPE, SIGCHLD,
    get_task_comm_ptr, set_task_pdeathsig,
    # readlinkat("/proc/self/exe") reports the real image path so binaries
    # that locate sibling resources via dirname(exe) work (Firefox libxul).
    current_exe_path_ptr,
    set_task_no_new_privs, get_task_no_new_privs,
    SIGSYS,
    get_task_seccomp_mode, set_task_seccomp_mode,
    get_task_seccomp_filter, set_task_seccomp_filter,
    seccomp_filter_allows,
    # F10-8 / #457: NATIVE seccomp-lite. The prctl(PR_SET_NATIVE_FILTER)
    # arm below stages the user bitmap, then writes the per-task native
    # filter through these accessors.
    get_task_seccomp_native_armed, set_task_seccomp_native_armed,
    set_task_seccomp_native_filter,
    saved_user_rip_ptr, saved_user_rsp_ptr, saved_user_rflags_ptr,
    get_task_alt_stack_sp, set_task_alt_stack_sp,
    get_task_alt_stack_size, set_task_alt_stack_size,
    get_task_alt_stack_flags, set_task_alt_stack_flags,
    task_brk_base, set_task_brk_base,
    task_brk_end, set_task_brk_end,
    task_brk_max, set_task_brk_max,
    # getrlimit/setrlimit/prlimit64: the real per-task rlimit store.
    rlimit_get_cur, rlimit_get_max, rlimit_set,
    # getpriority(2)/setpriority(2): the real per-task POSIX nice store.
    sched_get_nice, sched_set_nice,
    # sched_setaffinity/getaffinity: the real per-task CPU-affinity store
    # honored by the per-CPU-runqueue scheduler (placement/steal/migration).
    sched_get_affinity, sched_get_affinity_online, sched_set_affinity,
    # sched_affinity_selftest: kernel-side affinity-enforcement self-test,
    # gated on /etc/sched-affinity-test (scripts/test_sched_affinity.sh).
    sched_affinity_selftest,
    # sched_setscheduler/getscheduler/setparam/getparam + priority-range:
    # realtime policy mechanism (SCHED_FIFO/SCHED_RR) in core.ad.
    sched_set_scheduler, sched_get_policy, sched_get_rt_priority,
    sched_priority_max, sched_priority_min,
    SCHED_OTHER, SCHED_FIFO, SCHED_RR,
    set_current_errstr,
    register_cleartid_wake_hook,
    register_linux_futex_dump_hook,
    task_pml4,
    # uabi_fills_selftest needs the free-slot marker to prime the boot
    # task's fd table (it is uninitialised at boot:37 — per-task fd tables
    # are only set up by create_user_task / kthread_create).
    FD_CLOSED_MARK,
    # msync_selftest builds a tmpfs-backed MAP_SHARED VMA; its FDs (and the
    # backing-identity triple it hands vma_alloc_file_shared) use this mark.
    FD_TMPFS_MARK,
    # f*xattr / fstatfs ext4 path: vfs_fd_backing_info hands back
    # FD_EXT4_MARK for an ext4-backed fd (the backing id is the inode
    # number). FD_FAT_MARK stays imported as the stable FAT backing-kind
    # tag. (fd→Chan fold: open ext4/FAT fds are FD_CHAN_MARK now, so the
    # statfs classifier dispatches via vfs_fd_statfs_kind, not these.)
    FD_EXT4_MARK, FD_FAT_MARK,
    # sysinfo(2): procs counts live (non-FREE/non-EXITED) task slots.
    task_table_size, task_state,
    STATE_FREE, STATE_EXITED,
    # getrusage(2): per-task user/system CPU-tick counts, accrued by the
    # timer ISR. _u_getrusage converts these to the rusage timevals.
    current_task_utime_ticks, current_task_stime_ticks,
    # times(2) tms_cutime/tms_cstime: accumulated CPU ticks of all reaped
    # children (whole subtree, RUSAGE_CHILDREN), folded in at task_reap.
    current_task_cutime_ticks, current_task_cstime_ticks,
    # getrusage(2) RUSAGE_CHILDREN: accumulated child page-fault counts +
    # the slot-indexed direct setters ruchild_selftest seeds sentinels with.
    current_task_cminflt, current_task_cmajflt,
    task_cminflt_at, task_cmajflt_at,
    task_set_cutime_ticks_at, task_set_cstime_ticks_at,
    task_set_cminflt_at, task_set_cmajflt_at,
    # getrusage(2) / pgfault_selftest: per-task page-fault counts and the
    # charge helpers the page-fault handler drives.
    current_task_minflt, current_task_majflt,
    current_task_account_minor_fault, current_task_account_major_fault,
    # getrusage(2) / ctxsw_selftest: per-task context-switch counts and the
    # slot-indexed charge helpers schedule() drives at the switch site.
    current_task_nvcsw, current_task_nivcsw,
    task_account_voluntary_ctxsw_at, task_account_involuntary_ctxsw_at,
    # getrusage(2) / blkio_selftest: per-task block-I/O counts and the
    # charge helpers the block layer drives at the I/O completion site.
    current_task_inblock, current_task_oublock,
    current_task_account_inblock, current_task_account_oublock,
    # getrusage(2) / nsignals_selftest: per-task signal-delivery count and
    # the slot-indexed charge helper signal_post drives at the latch site.
    current_task_nsignals, task_account_signal_at,
    # getrusage(2) / vmstat_selftest: ru_maxrss (0x20) high-water mark
    # accessor + monotonic updater. The current rss is computed on demand
    # from the VMA walk; this field just remembers the peak in KB.
    task_maxrss_kb_at, task_set_maxrss_kb_at,
)
# msync_selftest backs its known-content file on tmpfs (the cpio initramfs
# is read-only — a MAP_SHARED-writable mapping over it is refused), then
# reads it back independently of the mapping to confirm the flush landed.
from fs.tmpfs import (
    tmpfs_open_for_write, tmpfs_write, tmpfs_read, tmpfs_size,
    # statfs(2): tmpfs's per-file capacity is the synthetic fs size.

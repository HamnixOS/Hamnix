    # readlink(2): resolve a tmpfs symlink's stored target string.
    tmpfs_path_is_symlink, tmpfs_readlink_path, tmpfs_create_symlink,
    tmpfs_unlink,
    # §SCM_RIGHTS memfd passing + the wlspike de-risk self-test: physical

def _u_unimpl_vfork(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_execve(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_wait4(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_uname(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_fcntl(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_readlink(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_arch_prctl(a0: uint64, a1: uint64, a2: uint64,
                         a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int arch_prctl(int code, unsigned long addr).
    # Only ARCH_SET_FS is honoured. glibc's pthread initialisation calls
    # arch_prctl(ARCH_SET_FS, &tcb) before main(); subsequent loads of
    # the form `mov %fs:0x28, %rax` (stack canary) and `mov %fs:0x10, %rax`
    # (TLS DTV pointer) depend on FS_BASE pointing at the TCB.
    #
    # We write the user-supplied address straight into IA32_FS_BASE.
    # Validation against canonical-form is the CPU's job (a non-canonical
    # value triggers #GP on the wrmsr); the trap will be reported through
    # the existing fault handler. When per-task FS_BASE state lands we'll
    # also stash addr in task_struct so context switches can restore it.
    if a0 == ARCH_SET_FS:
        write_msr(IA32_FS_BASE, a1)
        return 0
    return ELINUX_INVAL


def _u_unimpl_futex(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_set_tid_address(a0: uint64, a1: uint64, a2: uint64,
                              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # long set_tid_address(int *tidptr).
    # Linux records tidptr in current->clear_child_tid and returns the
    # caller's tid. On task exit the kernel writes 0 there and futex-
    # wakes waiters (the CLONE_CHILD_CLEARTID handshake). We park it in
    # a single global because there's no per-task slot yet and only one
    # Linux task is in flight at this milestone — the exit-time clear
    # is a TODO that lands with proper thread-group support. The return
    # value is required by glibc to be the tid, which on a single-thread
    # task is just the pid.
    linux_clear_child_tid = a0
    return cast[int64](current_task_pid())


def _u_unimpl_openat(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # openat(int dirfd, const char *path, int flags, mode_t mode).
    # glibc reaches for this in preference to open() on modern builds.
    # The straightforward forward (AT_FDCWD-relative -> _u_open) is
    # tempting, but openat with non-AT_FDCWD dirfd needs per-fd cwd
    # state that Hamnix doesn't yet track. Stub for now.
    return ELINUX_NOSYS


def _u_unimpl_newfstatat(a0: uint64, a1: uint64, a2: uint64,
                         a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


# =====================================================================
# Central dispatch
# =====================================================================


def linux_u_syscall_dispatch(nr: uint64,
                             a0: uint64, a1: uint64, a2: uint64,
                             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # Linux-numbered syscall dispatch. Called by the (future) entry stub
    # after register reshuffling. The switch is a flat if-ladder rather
    # than a jump table — Adder's compiler will lower this to the same
    # cmov / cmp chain a hand-written table would, and the ladder reads
    # more obviously alongside the SYS_* declarations above. If profile
    # data later shows this is a hot path, swapping to an array of
    # function pointers indexed by nr is a one-file refactor.
    if nr == SYS_read:
        return _u_read(a0, a1, a2, a3, a4, a5)
    if nr == SYS_write:
        return _u_write(a0, a1, a2, a3, a4, a5)
    if nr == SYS_open:
        return _u_open(a0, a1, a2, a3, a4, a5)
    if nr == SYS_close:
        return _u_close(a0, a1, a2, a3, a4, a5)
    if nr == SYS_stat:
        return _u_unimpl_stat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fstat:
        return _u_unimpl_fstat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lstat:
        return _u_unimpl_lstat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_poll:
        return _u_unimpl_poll(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lseek:
        return _u_lseek(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mmap:
        return _u_unimpl_mmap(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mprotect:
        return _u_unimpl_mprotect(a0, a1, a2, a3, a4, a5)
    if nr == SYS_munmap:
        return _u_unimpl_munmap(a0, a1, a2, a3, a4, a5)
    if nr == SYS_brk:
        return _u_unimpl_brk(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rt_sigaction:
        return _u_unimpl_rt_sigaction(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rt_sigprocmask:
        return _u_unimpl_rt_sigprocmask(a0, a1, a2, a3, a4, a5)
    if nr == SYS_rt_sigreturn:
        return _u_unimpl_rt_sigreturn(a0, a1, a2, a3, a4, a5)
    if nr == SYS_ioctl:
        return _u_ioctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pread64:
        return _u_unimpl_pread64(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pwrite64:
        return _u_unimpl_pwrite64(a0, a1, a2, a3, a4, a5)
    if nr == SYS_readv:
        return _u_unimpl_readv(a0, a1, a2, a3, a4, a5)
    if nr == SYS_writev:
        return _u_unimpl_writev(a0, a1, a2, a3, a4, a5)
    if nr == SYS_access:
        return _u_unimpl_access(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pipe:
        return _u_pipe(a0, a1, a2, a3, a4, a5)
    if nr == SYS_select:
        return _u_unimpl_select(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sched_yield:
        return _u_unimpl_sched_yield(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mremap:
        return _u_unimpl_mremap(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msync:
        return _u_unimpl_msync(a0, a1, a2, a3, a4, a5)
    if nr == SYS_dup:
        return _u_dup(a0, a1, a2, a3, a4, a5)
    if nr == SYS_dup2:
        return _u_dup2(a0, a1, a2, a3, a4, a5)
    if nr == SYS_nanosleep:
        return _u_unimpl_nanosleep(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getpid:
        return _u_getpid(a0, a1, a2, a3, a4, a5)
    if nr == SYS_clone:
        return _u_unimpl_clone(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fork:
        return _u_unimpl_fork(a0, a1, a2, a3, a4, a5)
    if nr == SYS_vfork:
        return _u_unimpl_vfork(a0, a1, a2, a3, a4, a5)
    if nr == SYS_execve:
        return _u_unimpl_execve(a0, a1, a2, a3, a4, a5)
    if nr == SYS_exit:
        return _u_exit(a0, a1, a2, a3, a4, a5)
    if nr == SYS_wait4:
        return _u_unimpl_wait4(a0, a1, a2, a3, a4, a5)
    if nr == SYS_kill:
        return _u_kill(a0, a1, a2, a3, a4, a5)
    if nr == SYS_uname:
        return _u_unimpl_uname(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fcntl:
        return _u_unimpl_fcntl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getcwd:
        return _u_getcwd(a0, a1, a2, a3, a4, a5)
    if nr == SYS_chdir:
        return _u_chdir(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mkdir:
        return _u_mkdir(a0, a1, a2, a3, a4, a5)
    if nr == SYS_unlink:
        return _u_unlink(a0, a1, a2, a3, a4, a5)
    if nr == SYS_readlink:
        return _u_unimpl_readlink(a0, a1, a2, a3, a4, a5)
    if nr == SYS_arch_prctl:
        return _u_unimpl_arch_prctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_futex:
        return _u_unimpl_futex(a0, a1, a2, a3, a4, a5)
    if nr == SYS_set_tid_address:
        return _u_unimpl_set_tid_address(a0, a1, a2, a3, a4, a5)
    if nr == SYS_clock_gettime:
        return _u_clock_gettime(a0, a1, a2, a3, a4, a5)
    if nr == SYS_exit_group:
        return _u_exit_group(a0, a1, a2, a3, a4, a5)
    if nr == SYS_openat:
        return _u_unimpl_openat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_newfstatat:
        return _u_unimpl_newfstatat(a0, a1, a2, a3, a4, a5)
    # Unknown syscall — same convention as Linux: log + return -ENOSYS.
    # The printk includes nr so a trace of "unknown linux syscall X"
    # tells you exactly which entry to add to the ladder above.
    printk2("linux_u: unknown syscall nr=%d a0=%x\n", nr, a0)
    return ELINUX_NOSYS

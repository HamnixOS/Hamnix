    if nr == SYS_splice:
        return _u_splice(a0, a1, a2, a3, a4, a5)
    if nr == SYS_tee:
        return _u_tee(a0, a1, a2, a3, a4, a5)
    if nr == SYS_vmsplice:
        return _u_vmsplice(a0, a1, a2, a3, a4, a5)
    # close_range(2): bulk-close the fd span [first, last]. Routes each
    # live fd through _u_close so per-fd teardown matches a plain close.
    if nr == SYS_close_range:
        return _u_close_range(a0, a1, a2, a3, a4, a5)
    # socket(2) family. U-socket V1: socket / connect / sendto / recvfrom
    # / bind / listen / accept / accept4 all bridged to the real in-kernel
    # TCP stack (drivers/net/tcp.ad) for AF_INET + SOCK_STREAM via the
    # native /net 9P-shape surface (devnet_clone + devnet_ctl announce/
    # accept). AF_UNIX and AF_NETLINK have their own bridges. read/write
    # on a connected socket fd route through fs/vfs.ad's FD_SOCKET_MARK
    # arms. socketpair forwards to vfs_pipe. poll(2) walks the user
    # pollfd array.
    if nr == SYS_socket:
        return _u_socket(a0, a1, a2, a3, a4, a5)
    if nr == SYS_connect:
        return _u_connect(a0, a1, a2, a3, a4, a5)
    if nr == SYS_accept:
        return _u_accept(a0, a1, a2, a3, a4, a5)
    if nr == SYS_accept4:
        return _u_accept4(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sendto:
        return _u_sendto(a0, a1, a2, a3, a4, a5)
    if nr == SYS_recvfrom:
        return _u_recvfrom(a0, a1, a2, a3, a4, a5)
    if nr == SYS_bind:
        return _u_bind(a0, a1, a2, a3, a4, a5)
    if nr == SYS_listen:
        return _u_listen(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getsockname:
        return _u_getsockname(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getpeername:
        return _u_getpeername(a0, a1, a2, a3, a4, a5)
    if nr == SYS_setsockopt:
        return _u_setsockopt(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getsockopt:
        return _u_getsockopt(a0, a1, a2, a3, a4, a5)
    if nr == SYS_socketpair:
        return _u_socketpair(a0, a1, a2, a3, a4, a5)
    # U36: session / process-group / thread-group identity + tgkill.
    # busybox sh's job-control bring-up probes setsid / setpgid /
    # getpgrp before it agrees to run; glibc's abort() reaches for
    # gettid + tgkill on the way out. None of these need real
    # session/pgrp/thread-group tracking yet — see the per-handler
    # comments below for the single-task answers.
    if nr == SYS_gettid:
        return _u_gettid(a0, a1, a2, a3, a4, a5)
    if nr == SYS_tkill:
        return _u_tkill(a0, a1, a2, a3, a4, a5)
    if nr == SYS_tgkill:
        return _u_tgkill(a0, a1, a2, a3, a4, a5)
    if nr == SYS_setsid:
        return _u_setsid(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getsid:
        return _u_getsid(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getpgid:
        return _u_getpgid(a0, a1, a2, a3, a4, a5)
    if nr == SYS_setpgid:
        return _u_setpgid(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getpgrp:
        return _u_getpgrp(a0, a1, a2, a3, a4, a5)
    # U37: sigaltstack — record per-task alt-stack registration. Hamnix
    # never actually switches stacks on signal delivery (single-task,
    # no nested handlers), but glibc's static-pie startup reaches for
    # the syscall during signal setup and stalls if it returns -ENOSYS.
    if nr == SYS_sigaltstack:
        return _u_sigaltstack(a0, a1, a2, a3, a4, a5)
    # §5: Layer-2 async I/O — epoll / eventfd / timerfd / signalfd. The
    # event primitives real Linux server daemons (epoll_wait loops) need.
    if nr == SYS_epoll_create:
        return _u_epoll_create(a0, a1, a2, a3, a4, a5)
    if nr == SYS_epoll_create1:
        return _u_epoll_create1(a0, a1, a2, a3, a4, a5)
    if nr == SYS_epoll_ctl:
        return _u_epoll_ctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_epoll_wait:
        return _u_epoll_wait(a0, a1, a2, a3, a4, a5)
    if nr == SYS_epoll_pwait:
        return _u_epoll_pwait(a0, a1, a2, a3, a4, a5)
    if nr == SYS_eventfd:
        return _u_eventfd(a0, a1, a2, a3, a4, a5)
    if nr == SYS_eventfd2:
        return _u_eventfd2(a0, a1, a2, a3, a4, a5)
    if nr == SYS_timerfd_create:
        return _u_timerfd_create(a0, a1, a2, a3, a4, a5)
    if nr == SYS_timerfd_settime:
        return _u_timerfd_settime(a0, a1, a2, a3, a4, a5)
    if nr == SYS_timerfd_gettime:
        return _u_timerfd_gettime(a0, a1, a2, a3, a4, a5)
    if nr == SYS_signalfd:
        return _u_signalfd(a0, a1, a2, a3, a4, a5)
    if nr == SYS_signalfd4:
        return _u_signalfd4(a0, a1, a2, a3, a4, a5)
    # #155: inotify — filesystem-event delivery as a readable fd.
    if nr == SYS_inotify_init:
        return _u_inotify_init(a0, a1, a2, a3, a4, a5)
    if nr == SYS_inotify_init1:
        return _u_inotify_init1(a0, a1, a2, a3, a4, a5)
    if nr == SYS_inotify_add_watch:
        return _u_inotify_add_watch(a0, a1, a2, a3, a4, a5)
    if nr == SYS_inotify_rm_watch:
        return _u_inotify_rm_watch(a0, a1, a2, a3, a4, a5)
    # fanotify — the second filesystem-event delivery fd (same source).
    if nr == SYS_fanotify_init:
        return _u_fanotify_init(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fanotify_mark:
        return _u_fanotify_mark(a0, a1, a2, a3, a4, a5)
    # #165: ABI-completeness fills — positioned scatter I/O, dirfd-relative
    # path ops, single-user chmod/chown, sched-affinity / getcpu /
    # membarrier, ppoll, clock_nanosleep, umask, faccessat. Each forwards
    # to a real facility (see the per-handler comments above).
    if nr == SYS_preadv:
        return _u_preadv(a0, a1, a2, a3, a4, a5)
    if nr == SYS_pwritev:
        return _u_pwritev(a0, a1, a2, a3, a4, a5)
    if nr == SYS_faccessat:
        return _u_faccessat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_faccessat2:
        return _u_faccessat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_chmod:
        return _u_chmod(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchmod:
        return _u_fchmod(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchmodat:
        return _u_fchmodat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchmodat2:
        return fchmodat2_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_cachestat:
        return cachestat_handler(a0, a1, a2, a3, a4, a5)
    if nr == SYS_chown:
        return _u_chown(a0, a1, a2, a3, a4, a5)
    if nr == SYS_lchown:
        return _u_chown(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchown:
        return _u_fchown(a0, a1, a2, a3, a4, a5)
    if nr == SYS_fchownat:
        return _u_fchownat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mkdirat:
        return _u_mkdirat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_unlinkat:
        return _u_unlinkat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_umask:
        return _u_umask(a0, a1, a2, a3, a4, a5)
    if nr == SYS_ppoll:
        return _u_ppoll(a0, a1, a2, a3, a4, a5)
    if nr == SYS_clock_nanosleep:
        return _u_clock_nanosleep(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sched_getaffinity:
        return _u_sched_getaffinity(a0, a1, a2, a3, a4, a5)
    if nr == SYS_sched_setaffinity:
        return _u_sched_setaffinity(a0, a1, a2, a3, a4, a5)
    if nr == SYS_getcpu:
        return _u_getcpu(a0, a1, a2, a3, a4, a5)
    if nr == SYS_membarrier:
        return _u_membarrier(a0, a1, a2, a3, a4, a5)
    # SysV IPC: semaphores, message queues, shared memory.
    if nr == SYS_semget:
        return sysv_semget(a0, a1, a2, a3, a4, a5)
    if nr == SYS_semop:
        return sysv_semop(a0, a1, a2, a3, a4, a5)
    if nr == SYS_semctl:
        return sysv_semctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgget:
        return sysv_msgget(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgsnd:
        return sysv_msgsnd(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgrcv:
        return sysv_msgrcv(a0, a1, a2, a3, a4, a5)
    if nr == SYS_msgctl:
        return sysv_msgctl(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmget:
        return sysv_shmget(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmat:
        return sysv_shmat(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmdt:
        return sysv_shmdt(a0, a1, a2, a3, a4, a5)
    if nr == SYS_shmctl:
        return sysv_shmctl(a0, a1, a2, a3, a4, a5)
    # POSIX message queues (mq_*). mq_send/mq_receive are glibc wrappers
    # over mq_timedsend/mq_timedreceive (NULL timeout); mq_getattr/setattr
    # ride mq_getsetattr.
    if nr == SYS_mq_open:
        return posixmq_open(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_unlink:
        return posixmq_unlink(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_timedsend:
        return posixmq_timedsend(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_timedreceive:
        return posixmq_timedreceive(a0, a1, a2, a3, a4, a5)
    if nr == SYS_mq_getsetattr:
        return posixmq_getsetattr(a0, a1, a2, a3, a4, a5)
    # pidfd process-management family (linux_abi/u_pidfd.ad). pidfd_open
    # returns a pollable fd for a pid; pidfd_send_signal reuses the
    # signal_post delivery path; waitid(P_PIDFD) translates pidfd->pid and
    # reuses do_wait4.
    if nr == SYS_pidfd_open:
        pfd_rc: int64 = upidfd_open(a0, a1)
        # PIDFD_NONBLOCK (== O_NONBLOCK, 0x800) marks the new fd
        # non-blocking; the per-fd O_NONBLOCK bitmap lives here, so apply
        # it after u_pidfd allocated the fd.
        if pfd_rc >= 0 and (a1 & cast[uint64](0x800)) != 0:
            _u_set_fd_nonblock(cast[int32](pfd_rc), 1)
        return pfd_rc
    if nr == SYS_pidfd_send_signal:
        return upidfd_send_signal(a0, a1, a2, a3)
    if nr == SYS_waitid:
        return upidfd_waitid(a0, a1, a2, a3, a4)
    if nr == SYS_pidfd_getfd:
        return pidfd_getfd_handler(a0, a1, a2)
    if nr == SYS_process_madvise:
        return process_madvise_handler(a0, a1, a2, a3, a4)
    # §io_uring async-I/O family (linux_abi/u_iouring.ad). setup allocates
    # a ring fd + kernel SQ/CQ/SQE regions; enter consumes SQEs, executes
    # each opcode synchronously through the vfs read/write/fsync backends,
    # and posts a CQE per submission; register records fixed buffers/files.
    if nr == SYS_io_uring_setup:
        return io_uring_setup(a0, a1, a2, a3, a4, a5)
    if nr == SYS_io_uring_enter:
        return io_uring_enter(a0, a1, a2, a3, a4, a5)
    if nr == SYS_io_uring_register:
        return io_uring_register(a0, a1, a2, a3, a4, a5)
    # Unknown syscall — same convention as Linux: log + return -ENOSYS.
    # The printk includes nr so a trace of "unknown linux syscall X"
    # tells you exactly which entry to add to the ladder above.
    printk2("linux_u: unknown syscall nr=%d a0=%x\n", nr, a0)
    set_current_errstr("unknown syscall")
    return ELINUX_NOSYS

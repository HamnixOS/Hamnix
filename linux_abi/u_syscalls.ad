def _u_unimpl_nanosleep(a0: uint64, a1: uint64, a2: uint64,
                        a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_clone(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_fork(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:

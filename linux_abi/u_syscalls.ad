# linux_abi/u_syscalls.ad — U-track Linux userspace syscall dispatch.
#
# This is the L1 hookup point for switching the syscall entry stub from
# Hamnix's native numbering (0..22) to Linux x86_64 numbering. Wiring
# requires editing arch/x86/kernel/syscall.ad's do_syscall — DEFERRED.
#
# ---------------------------------------------------------------------
# Purpose
#
# Hamnix's native syscall table (see arch/x86/kernel/syscall.ad) numbers
# kernel calls 0..22 — chosen for compactness during the bring-up of the
# bare-metal kernel. Stock Linux x86_64 places its userspace syscalls at
# the canonical numbers from arch/x86/entry/syscalls/syscall_64.tbl
# (read=0, write=1, ..., openat=257, newfstatat=262, etc.). To run
# unmodified Linux user binaries — anything compiled against glibc, or
# `mov $1, %rax; syscall` written by hand — the kernel entry stub must
# dispatch on the Linux numbers, not Hamnix's native ones.
#
# This file defines:
#
#   1. The SYS_* constants for every Linux x86_64 syscall we care about
#      at this milestone (the working set glibc reaches for on startup
#      plus the common file / process / signal / mm calls).
#   2. Per-syscall handler stubs. Where Hamnix already has the call
#      implemented natively (read, write, open, close, lseek, dup,
#      dup2, getpid, exit, kill, mkdir, unlink, chdir, getcwd), the
#      handler forwards to the existing Hamnix primitive. Everywhere
#      else the handler returns -ENOSYS (-38) — the same value Linux
#      returns for an unimplemented syscall.
#   3. linux_u_syscall_dispatch(nr, a0..a5) — the central switch the
#      future Linux-numbered entry stub will tail-call into.
#
# ---------------------------------------------------------------------
# Wiring plan (DEFERRED)
#
# Switching the kernel's userspace ABI from Hamnix-native to Linux-
# numbered means rewriting arch/x86/kernel/syscall.ad's do_syscall() so
# its top-level dispatch calls linux_u_syscall_dispatch() instead of
# walking its own SYS_* ladder — OR, equivalently, moving the Hamnix
# native numbers (0..22) up into a high "Hamnix-private" range (e.g.
# 0x4000..0x4016) and pointing the low numbers at this dispatch table.
# Both flips touch do_syscall, which is the single highest-risk path in
# the bare-metal kernel: the SYSCALL/SYSRET MSR shim, the per-task
# syscall stack, signal delivery, and execve all funnel through it. We
# stage that flip in a separate, isolated milestone once this dispatch
# table has compile-tested independently and the surface has been
# reviewed.
#
# ---------------------------------------------------------------------
# ABI contract
#
# linux_u_syscall_dispatch follows the Linux x86_64 syscall calling
# convention as seen by the kernel after the entry stub has reshuffled
# user registers into SysV positions:
#
#   nr  <- %rax    syscall number
#   a0  <- %rdi    arg 0
#   a1  <- %rsi    arg 1
#   a2  <- %rdx    arg 2
#   a3  <- %r10    arg 3   (NOT %rcx — SYSCALL clobbers %rcx with RIP)
#   a4  <- %r8     arg 4
#   a5  <- %r9     arg 5
#
# Return value is int64 (placed in %rax on the way out). Negative
# values in the [-4095, -1] range are errno; everything else is a
# normal return. This matches Linux's syscall return convention.

from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level,
)
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG, PRINTK_LEVEL_WARN
# F4 #449 leaf inversion: arch/x86/kernel/syscall.ad publishes a hook for
# the Linux-ABI syscall fall-through dispatcher (the routine its
# is_linux_userspace branch reaches today via a static import). We plant
# the dispatcher into the hook in u_syscalls_init() so the native side
# can dispatch without naming this Layer-2 module.
from arch.x86.kernel.syscall import register_linux_u_syscall_dispatch_hook
# splice/tee/vmsplice: the anonymous-pipe ring primitives. tee(2) needs
# a non-consuming peek (pipe_peek) and a direct ring write (pipe_write)
# against the backing slots vfs_fd_pipe_slot resolves; pipe_count gives
# the readable-byte bound and pipe_readers/_writers the EOF/EPIPE state.
from fs.pipe import (
    pipe_peek, pipe_count, pipe_write, pipe_readers, pipe_writers,
)
from fs.vfs import (
    vfs_open, vfs_open_write, vfs_open_write_t, vfs_read, vfs_write, vfs_close, vfs_lseek,
    vfs_dup, vfs_dup2, vfs_unlink, vfs_mkdir, vfs_rmdir, resolve_path,
    vfs_path_is_readonly,
    resolve_path_canonical, vfs_pipe, vfs_socketpair,
    vfs_listdir, vfs_rename, vfs_fsync, vfs_ftruncate, vfs_truncate,
    # symlink(2)/link(2)/utimensat(2): the VFS backends for these were
    # implemented but never wired into the Linux-ABI dispatch.
    vfs_symlink, vfs_link, vfs_set_mtime,
    vfs_fsync_all, vfs_fd_mtime, vfs_fd_mode, vfs_fd_owner,
    vfs_fd_stat_owner,
    vfs_fd_is_dir, vfs_fd_dir_buf, vfs_fd_dir_buflen,
    vfs_fd_dir_pos, vfs_fd_dir_set_pos,
    vfs_alloc_socket_fd, vfs_fd_is_socket, vfs_fd_is_open,
    # §4: stable per-file inode for fstat — ld.so keys its
    # already-loaded-DSO check off (st_dev, st_ino).
    vfs_fd_inode,
    # f*xattr: resolve an fd to its stable backing identity (marker +
    # backing id). For FD_EXT4_MARK the backing id IS the inode number.
    vfs_fd_backing_info,
    # §shared-file-mmap: the READ-ONLY cpio/initramfs backing marker, so
    # the MAP_SHARED-writable mmap path refuses to route a read-only
    # backing through the write-back shared VMA (write-back -> -EROFS).
    FD_FILEMMAP_INITRAMFS,
    vfs_socket_fd_set_record, vfs_socket_fd_get_record,
    # §5 Layer-2 async I/O: fd-table bridge for epoll/eventfd/timerfd/
    # signalfd objects + the non-destructive poll readiness probe.
    vfs_alloc_l2_fd, vfs_fd_marker, vfs_l2_fd_set_buf, vfs_l2_fd_get_buf,
    # fstatfs(2): fd→Chan fold moved ext4/FAT backing-kind off fd_idx and
    # into the namec pool chan's dev_type; this classifier dispatches it.
    vfs_fd_statfs_kind,
    vfs_fd_poll, vfs_read_nb, vfs_write_nb,
    # #164: console-backed-fd probe + the termios line-discipline's
    # narrow console bridge (read_nb / write for echo).
    vfs_fd_is_console,
    # splice/tee/vmsplice: recognise the pipe side of a splice and reach
    # the backing ring slot for the non-consuming tee path.
    vfs_fd_pipe_slot, vfs_fd_is_pipe_read, vfs_fd_is_pipe_write,
    # #165: PTY fd recogniser — returns the packed (slot<<1|is_master)
    # for an FD_PTMX_MARK fd so the ioctl shim can route tty ioctls to
    # the right pair.
    vfs_fd_pty_pack,
    # §fuse: map a daemon's /dev/fuse fd to its FUSE connection slot, so
    # mount(2) "fuse" can bind a target subtree to the right connection.
    vfs_fd_fuse_slot,
    # #155: inotify notify-hook registration (the boundary inversion —
    # vfs.ad calls our uino_post through a function pointer it knows
    # nothing about, registered here at bring-up).
    register_inotify_notify_hook,
    # §SCM_RIGHTS (Wayland shm-fd passing): resolve a memfd/tmpfs fd to its
    # backing slot (sendmsg side) and bind a fresh fd to an existing slot
    # (recvmsg side) so both ends map the SAME physical pages.
    vfs_open_memfd, vfs_fd_tmpfs_slot, vfs_install_tmpfs_slot_fd,
    # §SCM_RIGHTS all-fd passing: capture ANY passable fd's backing to an
    # opaque token, install a token back into a fresh fd, and route SCM
    # over a socketpair CHANNEL (the Chromium/Mozilla IPC transport).
    vfs_scm_capture_fd, vfs_scm_install_token, vfs_scm_release_token,
    vfs_fd_sockpair_packed,
)
from fs.socketpair import (
    sockpair_scm_send, sockpair_scm_recv, sockpair_scm_pending,
    sockpair_readable, sockpair_peer_alive,
    sockpair_unpack_slot, sockpair_unpack_dir,
)
# #164: the Linux-ABI terminal line discipline. A console-backed read(2)
# (an interactive `enter linux { /bin/sh }` guest's fd 0) routes through
# utermios_console_read for cooked/raw + echo; TCGETS/TCSETS read & apply
# the per-task termios state so raw-mode apps (a python3 REPL) work.
from linux_abi.u_termios import (
    utermios_console_read, utermios_tcgets, utermios_tcsets,
)
# #165: the Linux-ABI pseudo-terminal layer. The open/read/write/close
# data path is wired in fs/vfs.ad via FD_PTMX_MARK; the tty *control*
# path (TIOCGPTN / TIOCSPTLCK / TCGETS / TCSETS / TIOC{G,S}WINSZ on a
# pty fd) is serviced here in the ioctl shim against the same pair pool.
from linux_abi.u_pty import (
    pty_tcgets, pty_tcsets, pty_getwinsz, pty_setwinsz,
    pty_set_lock, pty_valid, pty_master_readable,
)
# #165: user-pointer-safe scalar accessors for the new pty ioctls
# (TIOCGPTN writes *out, TIOCSPTLCK reads *in). A bad user pointer must
# return -EFAULT, never #PF — the house uaccess layer is the right tool.
from mm.uaccess import (
    get_user_32, put_user_32,
    # SMAP v3e: _u_rt_sigreturn reads the ucontext block off the user stack
    # (US=1 page) at CPL=0; the four qword loads need STAC/CLAC under
    # CR4.SMAP=1. Imported alongside the existing get/put_user wrappers.
    _ua_stac, _ua_clac,
)
# §5 Layer-2 async I/O — the confined epoll/eventfd/timerfd/signalfd
# object pools + the O_NONBLOCK bitmap. linux_abi/u_epoll.ad is a
# Layer-2 leaf (printk + jiffy clock only) — these objects exist SOLELY
# to satisfy Linux guests and never leak into Layer-1 / 9P / Chan code.
# F4 #449 leaf inversion: FD_*_MARK constants moved to fs/vfs.ad. The
# Layer-2 ops (uino_*, uefd_*, ...) stay in u_epoll.ad because
# u_syscalls.ad is itself Layer-2 — only the native vfs/syscall code
# was inverted, not Layer-2-to-Layer-2 calls.
from fs.vfs import (
    FD_EPOLL_MARK, FD_EVENTFD_MARK, FD_TIMERFD_MARK, FD_SIGNALFD_MARK,
    FD_INOTIFY_MARK,
)
from linux_abi.u_epoll import (
    IN_NONBLOCK,
    uino_alloc, uino_valid, uino_add_watch, uino_rm_watch,
    uino_readable, uino_read, uino_post,
    uep_nonblock_set, uep_nonblock_get,
    uefd_alloc, uefd_valid, uefd_read, uefd_readable,
    utfd_alloc, utfd_valid, utfd_arm, utfd_read, utfd_readable,
    utfd_gettime_remaining, utfd_gettime_interval,
    usfd_alloc, usfd_valid, usfd_set_mask, usfd_get_mask, usfd_match,
    usfd_consume,
    uepoll_alloc, uepoll_valid, uepoll_ctl_add, uepoll_ctl_mod,
    uepoll_ctl_del, uepoll_intr_slot_live, uepoll_intr_fd_at,
    uepoll_intr_ev_at, uepoll_intr_data_at, uepoll_oneshot_disable,
    uepoll_interest_max,
    EPOLL_CTL_ADD, EPOLL_CTL_MOD, EPOLL_CTL_DEL,
    EPOLLIN, EPOLLOUT, EPOLLERR, EPOLLHUP, EPOLLONESHOT,
    EFD_SEMAPHORE,
)
# #147: ptrace(2). The dispatch wrapper calls the enter/exit stop hooks;
# the SYS_ptrace handler is _u_ptrace.
from linux_abi.u_ptrace import (
    _u_ptrace, ptrace_syscall_enter_stop, ptrace_syscall_exit_stop,
)
# SysV IPC (semaphores / message queues / shared memory). Self-contained
# Linux-ABI feature with its own fixed module-scope pools. Each entry
# point takes the raw a0..a5 syscall args; user pointers are brought in
# and out via uaccess so a bad pointer is -EFAULT not a #PF.
from linux_abi.u_sysvipc import (
    sysv_semget, sysv_semop, sysv_semctl,
    sysv_msgget, sysv_msgsnd, sysv_msgrcv, sysv_msgctl,
    sysv_shmget, sysv_shmat, sysv_shmdt, sysv_shmctl,
)
# POSIX message queues (mq_*) — the POSIX.1b realtime message-queue API.
from linux_abi.u_posixmq import (
    posixmq_open, posixmq_unlink, posixmq_timedsend,
    posixmq_timedreceive, posixmq_getsetattr,
)
# pidfd process-management family (pidfd_open/pidfd_send_signal/waitid +
# the FD_PIDFD_MARK the poll shim recognises). Implemented in
# linux_abi/u_pidfd.ad as a confined Layer-2 leaf.
from linux_abi.u_pidfd import (
    upidfd_open, upidfd_send_signal, upidfd_waitid,
    upidfd_get, upidfd_clear, upidfd_target_readable, FD_PIDFD_MARK,
)
# pidfd_getfd(2) (nr 438): duplicate an fd out of another process into the
# caller — a REAL cross-process backing share (copy_fd_entry), the same dup
# primitive sys_srv_open(276)/dup(2) use. Confined Layer-2 leaf in
# linux_abi/u_pidfd_getfd.ad; the nr 438 dispatch arm below forwards here.
from linux_abi.u_pidfd_getfd import (
    pidfd_getfd_handler,
)
# process_madvise(2) (nr 440): apply an madvise(2) advice to memory ranges in
# ANOTHER process identified by a pidfd. A REAL cross-process operation — the
# DONTNEED advice walks the TARGET task's page table and zeroes the frames so
# the target reads back zero. Confined Layer-2 leaf in
# linux_abi/u_process_madvise.ad; the nr 440 dispatch arm below forwards here.
from linux_abi.u_process_madvise import (
    process_madvise_handler,
)
# POSIX.1e capabilities (capget/capset, nr 125/126). A REAL per-task
# capability-set store; confined Layer-2 leaf in linux_abi/u_caps.ad. caps are
# Linux-ABI-only furniture (native security is Plan 9 namespaces, not POSIX
# caps), so these never touch a native path. caps_selftest is the boot:37.caps
# round-trip self-test entry.
from linux_abi.u_caps import (
    ucaps_capget, ucaps_capset, caps_selftest,
    ucaps_self_has, CAP_SYS_ADMIN_BIT,
)
# perf_event_open(2) (nr 298). A perf software-counter shim fd backed by REAL
# per-task accumulators the kernel already maintains (page-fault / context-
# switch / CPU-time counts). perf is Linux-ABI-only furniture (native resource
# state is exposed via Plan 9 ctl/stat files), so it never touches a native
# path. uperf_read / uperf_ioctl / uperf_close_fd are reached from the read /
# ioctl / close arms; confined Layer-2 leaf in linux_abi/u_perf.ad.
from linux_abi.u_perf import (
    uperf_event_open, uperf_read, uperf_ioctl, uperf_close_fd, FD_PERF_MARK,
)
# userfaultfd(2) (nr 323). A REAL, ENFORCING demand-paging-in-userspace fd;
# confined Layer-2 leaf in linux_abi/u_userfaultfd.ad. The #PF handler (arch/
# x86/kernel/trap_diag.ad do_page_fault) calls uffd_pagefault_hook() on every
# not-present user fault: a fault in a registered uffd range suppresses the
# demand-zero path and enqueues a uffd_msg. UFFDIO_COPY/ZEROPAGE genuinely
# populate the faulted page through the same mm primitive (elf_map_one_page)
# that vma_demand_fault uses. uffd fds are stamped FD_UFFD_MARK; uffd_read /
# uffd_ioctl / uffd_close_fd are reached from the read / ioctl / close arms.
# uffd is Linux-ABI-only furniture (native demand paging is a Plan 9 concern).
# userfaultfd_selftest is the boot:37.userfaultfd round-trip self-test.
from linux_abi.u_userfaultfd import (
    uffd_create, uffd_read, uffd_ioctl, uffd_close_fd, FD_UFFD_MARK,
)
# NUMA mempolicy family (mbind/set_mempolicy/get_mempolicy, nr 237/238/239).
# A REAL per-task {mode, nodemask} store; confined Layer-2 leaf in
# linux_abi/u_mempolicy.ad. Single NUMA node (node 0): inputs are validated
# (a foreign-node mask for BIND/INTERLEAVE -> EINVAL) and reflected faithfully,
# never ignored. mempolicy_selftest is the boot:37.mempolicy round-trip test.
from linux_abi.u_mempolicy import (
    umpol_set_mempolicy, umpol_get_mempolicy, umpol_mbind, mempolicy_selftest,
)
# Linux NTP / kernel-clock-discipline ABI (adjtimex/clock_adjtime, nr 159/305).
# REAL system-wide clock discipline; confined Layer-2 leaf in
# linux_abi/u_adjtimex.ad. A `struct timex` carries a `modes` bitmask selecting
# which fields to apply (freq offset in scaled ppm, single-shot offset slew,
# tick length, status); the call returns the discipline state + a clock-state
# code (TIME_OK/...). The discipline is WIRED INTO the realtime read path:
# _u_clock_gettime(CLOCK_REALTIME) routes its raw monotonic-ns through
# uadj_apply_discipline() so a freq/tick/offset adjustment measurably changes a
# subsequent clock_gettime. CLOCK_MONOTONIC stays raw. No fd marker (the call
# returns a clock-state code, not an fd). adjtimex_selftest is the
# boot:37.adjtimex test.
from linux_abi.u_adjtimex import (
    uadj_adjtimex, uadj_clock_adjtime, uadj_apply_discipline,
)
# Linux kernel keyring family (add_key/request_key/keyctl, nr 248/249/250).
# A REAL per-process / per-user key store; confined Layer-2 leaf in
# linux_abi/u_keyring.ad. The keyring is Linux-ABI-only furniture (native
# secret/credential handling is a separate Plan 9 concern), so these never
# touch a native path. Payloads store/read back byte-for-byte, searches
# find/miss honestly, and a revoked key fails later reads with EKEYREVOKED.
# Keys are serials (not fds), so this leaf needs NO fd marker. keyring_selftest
# is the boot:37.keyring round-trip self-test entry.
from linux_abi.u_keyring import (
    ukey_add_key, ukey_request_key, ukey_keyctl, keyring_selftest,
)
# process_vm_readv/writev family (nr 310/311). A REAL cross-address-space
# scatter/gather copy: the LOCAL iovecs/buffers resolve through the caller's
# page tables (copy_from/to_user) and the REMOTE buffer is resolved by walking
# the remote task's OWN page table (task_pml4 + uaccess_resolve). An unreachable
# remote page short-stops the iovec exactly like Linux; -EFAULT only if the
# first byte is unreachable. Confined Layer-2 leaf in linux_abi/u_process_vm.ad;
# process_vm_selftest is the boot:37.process_vm round-trip self-test entry.
from linux_abi.u_process_vm import (
    pvm_process_vm_readv, pvm_process_vm_writev, process_vm_selftest,
)
# mseal(2) (nr 462). Seals a VMA address range so later mprotect/munmap/
# mremap/madvise(DONTNEED) over it are rejected -EPERM (Linux 6.10 memory
# seal). A confined Layer-2 leaf in linux_abi/u_mseal.ad that stamps the
# EXISTING per-task VMA nodes (mm/vma.ad VmaNode.sealed) — the real mm
# syscalls honour the seal directly, nothing to bypass. umseal_selftest is
# the boot:37.mseal self-test entry.
from linux_abi.u_mseal import (
    umseal_mseal, umseal_selftest,
)
# name_to_handle_at(2)/open_by_handle_at(2) (nr 303/304). Encode a path into
# an opaque stable file_handle (fs id + inode identity), then re-open a file
# purely from that handle with NO caller-supplied path. A confined Layer-2
# leaf in linux_abi/u_fhandle.ad; the handle round-trips to the SAME inode.
# ufh_*_selftest is the boot:37.fhandle self-test entry.
from linux_abi.u_fhandle import (
    ufh_name_to_handle_at, ufh_open_by_handle_at, fhandle_selftest,
)
# bpf(2) (nr 321). A REAL in-kernel eBPF interpreter + lite verifier backed by
# per-program/per-map state; confined Layer-2 leaf in linux_abi/u_bpf.ad. Maps
# store/lookup real key->value bytes; loaded programs actually execute (compute
# real outputs) and invalid programs are actually rejected (-EINVAL/-EACCES).
# bpf is Linux-ABI-only furniture (native kernel programmability is via Plan 9
# file servers + the .ko L-shim), so it never touches a native path. Map fds are
# stamped FD_BPF_MAP_MARK and prog fds FD_BPF_PROG_MARK; bpf_close_fd is reached
# from the close arm. bpf_selftest is the boot:37.bpf round-trip test.
from linux_abi.u_bpf import (
    bpf_syscall, bpf_close_fd, FD_BPF_PROG_MARK, FD_BPF_MAP_MARK,
    bpf_selftest,
)
# Landlock LSM (landlock_create_ruleset/add_rule/restrict_self, nr 444/445/446).
# A REAL per-task path-based deny filter; confined Layer-2 leaf in
# linux_abi/u_landlock.ad. Landlock is Linux-ABI-only furniture LAYERED ON TOP
# of native namespace enforcement: landlock_check_open() is consulted in the
# Linux-ABI open path (_u_open) and denies a restricted task's open of a path
# its active ruleset does not cover (-EACCES); a task with no ruleset (every
# native process) is a cheap no-op. landlock_close_fd clears the per-fd record
# on close; the build/check helpers drive the boot:37.landlock self-test.
from linux_abi.u_landlock import (
    landlock_create_ruleset, landlock_add_rule, landlock_restrict_self,
    landlock_check_open, landlock_close_fd, landlock_init,
    landlock_check_version_and_einval, landlock_build_test_ruleset,
    landlock_clear_active,
    FD_LANDLOCK_MARK, LL_REQ_READ, LL_REQ_WRITE, LL_EACCES,
)
# quotactl(2) (nr 179). A REAL per-(filesystem, type, id) disk-quota store;
# confined Layer-2 leaf in linux_abi/u_quota.ad. Disk quotas are Linux-ABI-only
# furniture (native resource state is exposed via Plan 9 ctl/stat files), so it
# never touches a native path: Q_SETQUOTA stores limits, Q_GETQUOTA returns them
# byte-exact, Q_QUOTAON/OFF toggle a real enforced flag, Q_GETINFO/Q_SETINFO
# round-trip grace times. quota_selftest is the boot:37.quota round-trip test.
from linux_abi.u_quota import (
    uquota_quotactl, quota_selftest,
)
# fchmodat2(2) (nr 452) -- the newest *at chmod, fchmodat PLUS a real `flags`
# arg (AT_SYMLINK_NOFOLLOW / AT_EMPTY_PATH). A REAL implementation against the
# same VFS resolve/open path chmod/fchmodat already use; confined Layer-2 leaf
# in linux_abi/u_fchmodat2.ad. It validates flags (a bad bit -> EINVAL), routes
# AT_EMPTY_PATH to a chmod-on-fd, and proves the target resolves (missing path
# -> ENOENT). fchmodat2_selftest is the boot:37.fchmodat2 round-trip test.
from linux_abi.u_fchmodat2 import (
    fchmodat2_handler, fchmodat2_selftest,
)
# cachestat(2) (nr 451) -- query the page-cache residency of an fd over a byte
# range (struct cachestat_range in -> struct cachestat out). A REAL query of
# Hamnix's file page-cache state (present pages of the file's file-backed VMAs);
# confined Layer-2 leaf in linux_abi/u_cachestat.ad. It validates flags (a
# non-zero flag -> EINVAL), resolves the fd's backing, and counts resident /
# dirty pages over the range. cachestat_selftest is the boot:37.cachestat round-
# trip test (faults pages in, asserts nr_cache tracks them).
from linux_abi.u_cachestat import (
    cachestat_handler, cachestat_selftest,
)
# §futexv: futex_waitv(2) (nr 449) -- wait on a VECTOR of futexes, wake when
# ANY one is woken, return the woken element's array index. The leaf parks the
# caller against every uaddr by claiming one slot per element in THIS file's
# futex wait table (via futexv_claim_slot / futexv_slot_woken / futexv_slot_tag
# / futexv_release_slot below), reusing the same FUTEX_WAKE path. confined
# Layer-2 leaf in linux_abi/u_futexv.ad; futexv_selftest is boot:37.futexv.
from linux_abi.u_futexv import (
    futexv_waitv, futexv_selftest,
)
# §fuse: mount(2) "fuse" type binds a target subtree to a FUSE connection.
# fuse_mount(slot, target, len) does the namespace attach; fuse_selftest is
# the boot:37.fuse round-trip. vfs_fd_fuse_slot maps the daemon's fd to its
# connection slot. linux_abi/u_fuse.ad is a confined Layer-2 leaf.
from linux_abi.u_fuse import (
    fuse_mount, fuse_selftest,
)
# §memfd: memfd_create(2) + file sealing (fcntl F_ADD_SEALS/F_GET_SEALS).
# Anonymous tmpfs-backed file fd; sealing state lives on the tmpfs slot.
# linux_abi/u_memfd.ad is a confined Layer-2 leaf.
from linux_abi.u_memfd import (
    umemfd_create, umemfd_add_seals, umemfd_get_seals,
    F_ADD_SEALS_CMD, F_GET_SEALS_CMD,
)

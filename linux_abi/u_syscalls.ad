# linux_abi/u_syscalls.ad — U-track Linux userspace syscall dispatch.
#
# This is the L1 hookup point for switching the syscall entry stub from
# Hamnix's native numbering (0..22) to Linux x86_64 numbering. Wiring
# requires editing arch/x86/kernel/syscall.ad's do_syscall — DEFERRED.
#
# ---------------------------------------------------------------------
# Purpose
#
# Hamnix's native syscall table (see arch/x86/kernel/syscall.ad) numbers
# kernel calls 0..22 — chosen for compactness during the bring-up of the
# bare-metal kernel. Stock Linux x86_64 places its userspace syscalls at
# the canonical numbers from arch/x86/entry/syscalls/syscall_64.tbl
# (read=0, write=1, ..., openat=257, newfstatat=262, etc.). To run
# unmodified Linux user binaries — anything compiled against glibc, or
# `mov $1, %rax; syscall` written by hand — the kernel entry stub must
# dispatch on the Linux numbers, not Hamnix's native ones.
#
# This file defines:
#
#   1. The SYS_* constants for every Linux x86_64 syscall we care about
#      at this milestone (the working set glibc reaches for on startup
#      plus the common file / process / signal / mm calls).
#   2. Per-syscall handler stubs. Where Hamnix already has the call
#      implemented natively (read, write, open, close, lseek, dup,
#      dup2, getpid, exit, kill, mkdir, unlink, chdir, getcwd), the
#      handler forwards to the existing Hamnix primitive. Everywhere
#      else the handler returns -ENOSYS (-38) — the same value Linux
#      returns for an unimplemented syscall.
#   3. linux_u_syscall_dispatch(nr, a0..a5) — the central switch the
#      future Linux-numbered entry stub will tail-call into.
#
# ---------------------------------------------------------------------
# Wiring plan (DEFERRED)
#
# Switching the kernel's userspace ABI from Hamnix-native to Linux-
# numbered means rewriting arch/x86/kernel/syscall.ad's do_syscall() so
# its top-level dispatch calls linux_u_syscall_dispatch() instead of
# walking its own SYS_* ladder — OR, equivalently, moving the Hamnix
# native numbers (0..22) up into a high "Hamnix-private" range (e.g.
# 0x4000..0x4016) and pointing the low numbers at this dispatch table.
# Both flips touch do_syscall, which is the single highest-risk path in
# the bare-metal kernel: the SYSCALL/SYSRET MSR shim, the per-task
# syscall stack, signal delivery, and execve all funnel through it. We
# stage that flip in a separate, isolated milestone once this dispatch
# table has compile-tested independently and the surface has been
# reviewed.
#
# ---------------------------------------------------------------------
# ABI contract
#
# linux_u_syscall_dispatch follows the Linux x86_64 syscall calling
# convention as seen by the kernel after the entry stub has reshuffled
# user registers into SysV positions:
#
#   nr  <- %rax    syscall number
#   a0  <- %rdi    arg 0
#   a1  <- %rsi    arg 1
#   a2  <- %rdx    arg 2
#   a3  <- %r10    arg 3   (NOT %rcx — SYSCALL clobbers %rcx with RIP)
#   a4  <- %r8     arg 4
#   a5  <- %r9     arg 5
#
# Return value is int64 (placed in %rax on the way out). Negative
# values in the [-4095, -1] range are errno; everything else is a
# normal return. This matches Linux's syscall return convention.

from kernel.printk.printk import printk1, printk2
from fs.vfs import (
    vfs_open, vfs_read, vfs_write, vfs_close, vfs_lseek,
    vfs_dup, vfs_dup2, vfs_unlink, resolve_path,
)
from kernel.sched.core import (
    current_task_pid, task_lookup_by_pid, task_exit_current,
    signal_post, get_cwd_buf, set_task_cwd, current_idx_get,
)
from arch.x86.kernel.time import get_jiffies
from mm.slab import kmalloc

# Generic MSR writer — the asm body lives in arch/x86/kernel/syscall_64.S
# (write_msr) and takes the canonical (index, value) pair. We need it for
# SYS_arch_prctl's ARCH_SET_FS path: glibc's pthread bring-up calls
# arch_prctl(ARCH_SET_FS, &tcb) and then derefs %fs:0x10 for the TLS
# pointer, so failing this syscall means glibc segfaults before main().
extern def write_msr(index: uint32, value: uint64)

# IA32_FS_BASE — MSR 0xC0000100. Writing this is the kernel-side
# equivalent of `wrfsbase` on CPUs that lack the FSGSBASE feature.
IA32_FS_BASE: uint32 = 0xC0000100

# arch_prctl op codes (from <asm/prctl.h>). Only ARCH_SET_FS is honoured
# at this milestone; the GET/* and GS variants stay -EINVAL until a real
# user task needs them.
ARCH_SET_FS: uint64 = 0x1002

# SYS_brk state. Linux's brk(0) returns the current program break; the
# first call by a process is glibc's way of asking "where did the kernel
# put my heap?" We park the answer in a single global because Hamnix
# doesn't yet have per-task heap state and there is at most one Linux
# user task in flight during the L1 bring-up. linux_brk == 0 means
# "uninitialised" — the first call lazily allocates a starter chunk
# from kmalloc and parks its base here. Subsequent calls grow by
# kmalloc'ing extra chunks as needed; we never shrink because kmalloc
# isn't a real heap and freeing mid-region would fragment it badly.
# When per-task brk state arrives, this global becomes a task field.
linux_brk:     uint64 = 0
linux_brk_end: uint64 = 0      # one past the last byte we've backed

# SYS_brk's initial heap size. 64 KiB is enough for glibc's first few
# malloc()s on a freshly-loaded binary; further growth pulls more
# kmalloc chunks. Kept modest to avoid burning slab on the common case
# where no Linux task ever runs.
LINUX_BRK_INITIAL: uint64 = 0x10000
LINUX_BRK_GROW:    uint64 = 0x10000

# SYS_set_tid_address state. Linux records the user pointer so that on
# task exit the kernel can clear it (and futex-wake the parent waiting
# on CLONE_CHILD_CLEARTID). We don't have per-task storage for it
# without touching kernel/sched/core.ad, and the task constraint here
# is "only u_syscalls.ad" — so we keep it as a single global for the
# single Linux task that the L1 surface supports. When real thread
# groups land this moves into task_struct alongside the tid itself.
linux_clear_child_tid: uint64 = 0


# =====================================================================
# Linux x86_64 syscall numbers (from arch/x86/entry/syscalls/syscall_64.tbl)
# =====================================================================
#
# Kept verbatim with stock Linux 6.12 so userspace binaries compiled
# against unistd_64.h hit the same numbers we dispatch on. Gaps in the
# numbering are intentional — we only define what we currently care
# about; unlisted numbers fall through to the default -ENOSYS path in
# linux_u_syscall_dispatch().

SYS_read:            uint64 = 0
SYS_write:           uint64 = 1
SYS_open:            uint64 = 2
SYS_close:           uint64 = 3
SYS_stat:            uint64 = 4
SYS_fstat:           uint64 = 5
SYS_lstat:           uint64 = 6
SYS_poll:            uint64 = 7
SYS_lseek:           uint64 = 8
SYS_mmap:            uint64 = 9
SYS_mprotect:        uint64 = 10
SYS_munmap:          uint64 = 11
SYS_brk:             uint64 = 12
SYS_rt_sigaction:    uint64 = 13
SYS_rt_sigprocmask:  uint64 = 14
SYS_rt_sigreturn:    uint64 = 15
SYS_ioctl:           uint64 = 16
SYS_pread64:         uint64 = 17
SYS_pwrite64:        uint64 = 18
SYS_readv:           uint64 = 19
SYS_writev:          uint64 = 20
SYS_access:          uint64 = 21
SYS_pipe:            uint64 = 22
SYS_select:          uint64 = 23
SYS_sched_yield:     uint64 = 24
SYS_mremap:          uint64 = 25
SYS_msync:           uint64 = 26
SYS_dup:             uint64 = 32
SYS_dup2:            uint64 = 33
SYS_nanosleep:       uint64 = 35
SYS_getpid:          uint64 = 39
SYS_clone:           uint64 = 56
SYS_fork:            uint64 = 57
SYS_vfork:           uint64 = 58
SYS_execve:          uint64 = 59
SYS_exit:            uint64 = 60
SYS_wait4:           uint64 = 61
SYS_kill:            uint64 = 62
SYS_uname:           uint64 = 63
SYS_fcntl:           uint64 = 72
SYS_getcwd:          uint64 = 79
SYS_chdir:           uint64 = 80
SYS_mkdir:           uint64 = 83
SYS_unlink:          uint64 = 87
SYS_readlink:        uint64 = 89
SYS_arch_prctl:      uint64 = 158
SYS_futex:           uint64 = 202
SYS_set_tid_address: uint64 = 218
SYS_clock_gettime:   uint64 = 228
SYS_exit_group:      uint64 = 231
SYS_openat:          uint64 = 257
SYS_newfstatat:      uint64 = 262


# Linux errno values returned by stub handlers. Kept local to avoid
# coupling to a yet-to-exist linux_abi/errno.ad. Same numeric values
# as <asm-generic/errno-base.h>.
ELINUX_NOENT:  int64 = -2
ELINUX_SRCH:   int64 = -3
ELINUX_BADF:   int64 = -9
ELINUX_INVAL:  int64 = -22
ELINUX_RANGE:  int64 = -34
ELINUX_NOSYS:  int64 = -38


# =====================================================================
# Forwarders to Hamnix native primitives
# =====================================================================
#
# Each handler takes the full (a0..a5) tuple even when it ignores most
# of the args — that keeps linux_u_syscall_dispatch's call sites uniform
# and the eventual entry-stub rewiring trivial. Return type is int64
# (the kernel-side syscall return). Casts narrow to the natural width
# of the underlying Hamnix call as needed.


def _u_read(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t read(int fd, void *buf, size_t count)
    n: int64 = vfs_read(cast[int32](a0),
                        cast[Ptr[uint8]](a1), a2)
    return n


def _u_write(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # ssize_t write(int fd, const void *buf, size_t count)
    n: int64 = vfs_write(cast[int32](a0),
                         cast[Ptr[uint8]](a1), a2)
    return n


def _u_open(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int open(const char *pathname, int flags, mode_t mode)
    # We honour the path; flags / mode are ignored at this milestone
    # (Hamnix's vfs_open is read-only; write-open lives behind the
    # native SYS_OPEN_WRITE which we don't expose via Linux numbering
    # yet). A Linux-style O_WRONLY|O_CREAT open silently downgrades
    # to read-open here — fine for the L1 surface; M-track will
    # branch on `flags & O_ACCMODE`.
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
    if rc != 0:
        return cast[int64](rc)
    rc = vfs_open(cast[Ptr[char]](&abs_path[0]))
    return cast[int64](rc)


def _u_close(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int close(int fd)
    rc: int32 = vfs_close(cast[int32](a0))
    return cast[int64](rc)


def _u_lseek(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # off_t lseek(int fd, off_t offset, int whence)
    n: int64 = vfs_lseek(cast[int32](a0),
                         cast[int64](a1), cast[int32](a2))
    return n


def _u_ioctl(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int ioctl(int fd, unsigned long request, ...)
    # Hamnix has no ioctl dispatch yet. Many glibc startup paths call
    # ioctl(0, TCGETS, ...) to probe for a terminal; returning -ENOTTY
    # (-25) would be more faithful, but -ENOSYS is honest about the
    # absence of an implementation and lets the harness count it.
    return ELINUX_NOSYS


def _u_pipe(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int pipe(int pipefd[2]) — Hamnix's vfs_pipe matches this signature.
    # Re-exposed here so the eventual entry-stub flip can route Linux's
    # SYS_pipe to it without going through native SYS_PIPE. Stubbed
    # -ENOSYS for now because pulling vfs_pipe in would expand the
    # import surface beyond the file's "minimal compile" goal; M-track
    # will swap this for a real forward.
    return ELINUX_NOSYS


def _u_dup(a0: uint64, a1: uint64, a2: uint64,
           a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int dup(int oldfd)
    return cast[int64](vfs_dup(cast[int32](a0)))


def _u_dup2(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int dup2(int oldfd, int newfd)
    return cast[int64](vfs_dup2(cast[int32](a0), cast[int32](a1)))


def _u_getpid(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # pid_t getpid(void)
    return cast[int64](current_task_pid())


def _u_kill(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int kill(pid_t pid, int sig)
    tgt: int32 = task_lookup_by_pid(a0)
    if tgt < 0:
        return ELINUX_SRCH
    signal_post(cast[uint64](tgt), a1)
    return 0


def _u_exit(a0: uint64, a1: uint64, a2: uint64,
            a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void _exit(int status). task_exit_current does not return.
    task_exit_current(cast[int64](a0))
    return 0


def _u_exit_group(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void exit_group(int status). At Hamnix's single-thread-per-task
    # scale this is identical to _exit. When real thread groups land
    # (clone(CLONE_THREAD)), exit_group will need to iterate the tgid
    # and tear down every member; for now we share the body.
    task_exit_current(cast[int64](a0))
    return 0


def _u_chdir(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int chdir(const char *path)
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
    if rc != 0:
        return cast[int64](rc)
    rc = set_task_cwd(current_idx_get(), &abs_path[0])
    if rc < 0:
        return -7                                    # -E2BIG
    return 0


def _u_getcwd(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # char *getcwd(char *buf, size_t size) — the kernel-side syscall
    # returns bytes-written (incl NUL) or -ERANGE; libc reshapes that
    # into the char* the caller expects. Matches the native SYS_GETCWD
    # body in arch/x86/kernel/syscall.ad.
    if a1 == 0:
        return ELINUX_RANGE
    src: Ptr[uint8] = get_cwd_buf(current_idx_get())
    dst: Ptr[uint8] = cast[Ptr[uint8]](a0)
    i: uint64 = 0
    while i + 1 < a1:
        c: uint8 = src[i]
        dst[i] = c
        i = i + 1
        if c == 0:
            return cast[int64](i)
    dst[i] = 0
    return cast[int64](i + 1)


def _u_mkdir(a0: uint64, a1: uint64, a2: uint64,
             a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int mkdir(const char *pathname, mode_t mode)
    # Hamnix's native SYS_MKDIR is a no-op stub (tmpfs is flat); mirror
    # that here so the surface stays consistent.
    return 0


def _u_unlink(a0: uint64, a1: uint64, a2: uint64,
              a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int unlink(const char *pathname)
    abs_path: Array[256, uint8]
    rc: int32 = resolve_path(cast[Ptr[char]](a0), &abs_path[0], 256)
    if rc != 0:
        return cast[int64](rc)
    rc = vfs_unlink(cast[Ptr[char]](&abs_path[0]))
    return cast[int64](rc)


def _u_clock_gettime(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    # int clock_gettime(clockid_t clk, struct timespec *tp)
    # Linux's struct timespec is { long tv_sec; long tv_nsec; }. We
    # build one from get_jiffies() (HZ=100, so 10 ms per jiffy) and
    # write it to a1. clockid is ignored — we have one monotonic-ish
    # source. -EINVAL if a1 is NULL.
    if a1 == 0:
        return ELINUX_INVAL
    j: uint64 = get_jiffies()
    sec:  uint64 = j / 100
    nsec: uint64 = (j - sec * 100) * 10000000        # 10 ms per jiffy
    cast[Ptr[uint64]](a1)[0]     = sec
    cast[Ptr[uint64]](a1 + 8)[0] = nsec
    return 0


# =====================================================================
# Pure -ENOSYS stubs
# =====================================================================
#
# These exist only so linux_u_syscall_dispatch has a named handler for
# each syscall it has a number for — keeps the dispatch table readable
# and gives us a single grep target ("_u_unimpl_") when implementing
# any of them. A single shared body would be tempting but separate
# names make printk traces useful.


def _u_unimpl_stat(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_fstat(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_lstat(a0: uint64, a1: uint64, a2: uint64,
                    a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_poll(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_mmap(a0: uint64, a1: uint64, a2: uint64,
                   a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_mprotect(a0: uint64, a1: uint64, a2: uint64,
                       a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_munmap(a0: uint64, a1: uint64, a2: uint64,
                     a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_brk(a0: uint64, a1: uint64, a2: uint64,
                  a3: uint64, a4: uint64, a5: uint64) -> int64:
    # void *brk(void *new_brk). Linux convention: returns the *new*
    # program break on success, and the *current* break on failure (so
    # callers like glibc's sbrk(0) probe the heap top by asking with
    # new_brk=0). new_brk=0 also doubles as the "where is my heap?"
    # query glibc fires on every process startup.
    #
    # Hamnix heap model: we lazily allocate the initial 64 KiB the
    # first time brk is touched (kmalloc-backed; not a real anonymous
    # mapping, but contiguous and zero-initialised is good enough for
    # glibc's pre-main bump allocations). On subsequent grow requests
    # past linux_brk_end we kmalloc another chunk. We do NOT support
    # shrinking, and the slab-backed allocations don't have to be
    # virtually contiguous with the previous chunk — glibc's malloc
    # arena bookkeeping only consults brk() for the *top* address, and
    # falls back to mmap for any large request anyway. When a real
    # per-task anon-mmap region exists this whole body migrates to it.
    if linux_brk == 0:
        base: uint64 = kmalloc(LINUX_BRK_INITIAL)
        if base == 0:
            return 0                                  # OOM — return 0 brk
        linux_brk     = base
        linux_brk_end = base + LINUX_BRK_INITIAL
    if a0 == 0:
        return cast[int64](linux_brk)
    # A shrink (or no-op) keeps the existing brk; just record the new
    # high-water mark if it fits in the currently-allocated region.
    if a0 <= linux_brk_end:
        linux_brk = a0
        return cast[int64](linux_brk)
    # Grow: pull as many LINUX_BRK_GROW chunks as needed to cover a0.
    # kmalloc doesn't promise contiguity with the previous chunk, so
    # we burn a tiny check here — if a fresh chunk happens to land
    # right after linux_brk_end, the heap stays contiguous and we
    # advance linux_brk_end. Otherwise we fail the grow (Linux returns
    # the *old* brk on failure, which is what malloc keys off of to
    # fall back to mmap).
    while linux_brk_end < a0:
        chunk: uint64 = kmalloc(LINUX_BRK_GROW)
        if chunk == 0:
            return cast[int64](linux_brk)             # OOM, old brk
        if chunk != linux_brk_end:
            # Non-contiguous — malloc will sbrk-fail and switch to mmap.
            return cast[int64](linux_brk)
        linux_brk_end = linux_brk_end + LINUX_BRK_GROW
    linux_brk = a0
    return cast[int64](linux_brk)


def _u_unimpl_rt_sigaction(a0: uint64, a1: uint64, a2: uint64,
                           a3: uint64, a4: uint64, a5: uint64) -> int64:
    return ELINUX_NOSYS


def _u_unimpl_rt_sigprocmask(a0: uint64, a1: uint64, a2: uint64,

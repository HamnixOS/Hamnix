# linux_abi/api_l50.ad
#
# L50: shims for the ABI gap exposed by seven stock Debian 6.12 crypto
# modules — xxhash_generic, crypto_null, des_generic, chacha_generic,
# poly1305_generic, curve25519-generic, chacha20poly1305. Every one of
# these modules has the same init-path shape: tail-jump to a registration
# entry point (crypto_register_shash / _algs / _skcipher{,s} / _kpp /
# _templates) that returns 0, and the rest of the UND set is *runtime*
# code (per-block cipher math, scatter/gather walks, secure memcmp).
#
# Init-path disassembly (objdump -drC of each *.ko's .init.text):
#
#   xxhash_generic.ko:
#       init_module:
#           call __fentry__
#           mov  $&xxhash64_alg, %rdi
#           jmp  crypto_register_shash         # L34: returns 0
#
#   crypto_null.ko:
#       init_module:
#           call __fentry__
#           mov  $2, %esi
#           mov  $&null_algs, %rdi
#           call crypto_register_algs          # L50: returns 0
#           test %eax, %eax; js  .err1
#           mov  $&digest_null, %rdi
#           call crypto_register_shash         # L34: returns 0
#           test %eax, %eax; js  .err2
#           mov  $&skcipher_null, %rdi
#           call crypto_register_skcipher      # L50: returns 0
#           test %eax, %eax; jns .ok
#       .err2: call crypto_unregister_shash
#       .err1: mov  $2, %esi; call crypto_unregister_algs
#       .ok: jmp __x86_return_thunk
#
#   des_generic.ko:
#       init_module:
#           call __fentry__
#           mov  $2, %esi
#           mov  $&des_algs, %rdi
#           jmp  crypto_register_algs          # L50: returns 0
#
#   chacha_generic.ko:
#       init_module:
#           call __fentry__
#           mov  $3, %esi
#           mov  $&chacha_algs, %rdi
#           jmp  crypto_register_skciphers     # L50: returns 0
#
#   poly1305_generic.ko:
#       init_module:
#           call __fentry__
#           mov  $&poly1305_alg, %rdi
#           jmp  crypto_register_shash         # L34: returns 0
#
#   curve25519-generic.ko:
#       init_module:
#           call __fentry__
#           mov  $&curve25519_alg, %rdi
#           jmp  crypto_register_kpp           # L50: returns 0
#
#   chacha20poly1305.ko:
#       init_module:
#           call __fentry__
#           mov  $2, %esi
#           mov  $&rfc7539_tmpls, %rdi
#           jmp  crypto_register_templates     # L50: returns 0
#
# So every init path lands on a registration entry-point that L50 makes
# return 0. The rest of the union UND set is reached only by runtime
# crypto operations (a setkey followed by encrypt/decrypt/digest cycles)
# that no test fixture in this batch performs — but the loader's
# relocation pass still resolves every UND symbol, so we ship stub
# bodies for those too. Following the L49 convention: if a future
# milestone needs real crypto, the stubs grow real implementations
# without touching call sites.
#
# Cross-check against existing exports.ad + api_*.ad reduced the union
# of the seven .ko's UND lists to THIRTY-TWO distinct symbols not yet
# exported, grouped by milestone-internal theme below.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree


# =====================================================================
# Group 1: registration entry-points (return 0 = "registered")
# =====================================================================
#
# All seven modules' init paths tail-jump to one of these. Real Linux's
# crypto-core walks the supplied algorithm array / template / kpp /
# skcipher struct, links it into the global registry, and runs the
# per-algorithm self-test. At L50 the placeholder bodies accept the
# pointer (with a non-NULL sanity check) and return 0 — the module's
# init path proceeds, the symbol resolves, and we have one more
# .ko load to count.

def _l_crypto_register_algs(algs: uint64, count: int32) -> int32:
    # int crypto_register_algs(struct crypto_alg *algs, int count);
    # Bulk register of struct crypto_alg entries — the legacy
    # registration shape (predates the type-specific register_shash /
    # register_skcipher / register_kpp wrappers). des_generic and
    # crypto_null both register through this path.
    if algs == 0:
        return -22                                    # -EINVAL
    if count <= 0:
        return -22
    return 0


def _l_crypto_unregister_algs(algs: uint64, count: int32):
    # void crypto_unregister_algs(struct crypto_alg *algs, int count);
    # No registry yet; nothing to undo.
    return


def _l_crypto_register_skcipher(alg: uint64) -> int32:
    # int crypto_register_skcipher(struct skcipher_alg *alg);
    # Synchronous-skcipher registration. crypto_null's null cipher is
    # registered through this path; chacha_generic's three variants
    # (chacha20, xchacha20, xchacha12) go through the bulk variant.
    if alg == 0:
        return -22
    return 0


def _l_crypto_unregister_skcipher(alg: uint64):
    return


def _l_crypto_register_skciphers(algs: uint64, count: int32) -> int32:
    # int crypto_register_skciphers(struct skcipher_alg *algs, int count);
    # Bulk variant used by chacha_generic.ko (count=3).
    if algs == 0:
        return -22
    if count <= 0:
        return -22
    return 0


def _l_crypto_unregister_skciphers(algs: uint64, count: int32):
    return


def _l_crypto_register_kpp(alg: uint64) -> int32:
    # int crypto_register_kpp(struct kpp_alg *alg);
    # Key-pair-protocol (Diffie-Hellman / ECDH) registration —
    # curve25519-generic's ECDH variant registers here.
    if alg == 0:
        return -22
    return 0


def _l_crypto_unregister_kpp(alg: uint64):
    return


def _l_crypto_register_templates(tmpls: uint64, count: int32) -> int32:
    # int crypto_register_templates(struct crypto_template *tmpls,
    #                                int count);
    # Templates are parameterised "wrap-an-existing-algorithm"
    # constructions — chacha20poly1305.ko registers two
    # (rfc7539(chacha20,poly1305) and rfc7539esp(chacha20,poly1305)).
    if tmpls == 0:
        return -22
    if count <= 0:
        return -22
    return 0


def _l_crypto_unregister_templates(tmpls: uint64, count: int32):
    return


# =====================================================================
# Group 2: spinlock _bh variants (crypto_null only)
# =====================================================================
#
# crypto_null's runtime acquires a softirq-disabled spinlock around the
# per-tfm context (null cipher state is trivial — a single struct
# pointer — but the API surface insists on serialisation). At L6 we
# don't disable softirqs (no softirq scheduler yet) and don't actually
# spin (uniprocessor + cooperative yield); the body matches the
# _raw_spin_lock_irqsave shim in api_sync.ad, sans the flags cookie.

def _l_raw_spin_lock_bh(l: uint64):
    # void _raw_spin_lock_bh(raw_spinlock_t *l);
    # Linux: spin_lock + local_bh_disable. Hamnix has no BH scheduler;
    # the BH-disable half is a no-op. The lock half mirrors the L6
    # _raw_spin_lock body (flag flip — no real spin).
    if l == 0:
        return
    cast[Ptr[uint64]](l)[0] = 1


def _l_raw_spin_unlock_bh(l: uint64):
    if l == 0:
        return
    cast[Ptr[uint64]](l)[0] = 0


# =====================================================================
# Group 3: __crypto_memneq (curve25519-generic + chacha20poly1305)
# =====================================================================
#
# Linux: int __crypto_memneq(const void *a, const void *b, size_t n);
# Constant-time NUL-equality test used in MAC verification (poly1305
# tag compare) and in curve25519's "is this the null point" check.
# Returns 0 if equal, non-zero (1) if any byte differs. Hamnix doesn't
# yet have a side-channel discipline at the C-runtime level; a normal
# byte-by-byte compare is correct (the timing leak only matters under
# adversarial-input scenarios that no init path triggers).

def _l___crypto_memneq(a: uint64, b: uint64, n: uint64) -> int32:
    if n == 0:
        return 0
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pb: Ptr[uint8] = cast[Ptr[uint8]](b)
    i: uint64 = 0
    diff: uint8 = 0
    while i < n:
        # OR the per-byte diffs so we walk the full buffer — preserves
        # the constant-time *intent* of the API even though the rest of
        # the kernel doesn't make a serious side-channel claim yet.
        diff = diff | (pa[i] ^ pb[i])
        i = i + 1
    if diff == 0:
        return 0
    return 1


# =====================================================================
# Group 4: scatterlist helpers (curve25519-generic + chacha20poly1305)
# =====================================================================
#
# sg_init_one / sg_copy_from_buffer / sg_copy_to_buffer / sg_nents_for_len
# / scatterwalk_ffwd / scatterwalk_map_and_copy form the kernel's
# scatter-gather buffer-walking surface. AEAD constructions feed input
# / output via sg_list[]; chacha20poly1305 and curve25519 receive the
# whole AAD+plaintext through these.
#
# At L50 none of the seven modules' init paths exercises these — they
# fire only on encrypt/decrypt/derive. Stubs return success-shaped
# placeholders so the loader's relocation pass succeeds.

def _l_sg_init_one(sg: uint64, buf: uint64, buflen: uint32):
    # void sg_init_one(struct scatterlist *sg, const void *buf, unsigned int buflen);
    # Real Linux fills sg->page_link / offset / length / dma_address.
    # Stub clears the struct so the caller's later sg_next() finds an
    # end-marker (page_link low bit = 1 in Linux). 32-byte zero covers
    # the struct's typical CONFIG_DEBUG_SG-disabled layout.
    if sg == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](sg)
    i: uint64 = 0
    while i < 32:
        p[i] = 0
        i = i + 1


def _l_sg_copy_from_buffer(sgl: uint64, nents: uint32,
                            buf: uint64, buflen: uint64) -> uint64:
    # size_t sg_copy_from_buffer(struct scatterlist *sgl, unsigned int nents,
    #                             const void *buf, size_t buflen);
    # Real Linux walks the sgl pages and memcpy's `buflen` bytes from
    # `buf` into them. Stub reports "copied buflen bytes" so the caller's
    # short-write check passes; no actual copy fires because no init
    # path lands here.
    return buflen


def _l_sg_copy_to_buffer(sgl: uint64, nents: uint32,
                          buf: uint64, buflen: uint64) -> uint64:
    return buflen


def _l_sg_nents_for_len(sgl: uint64, length: uint64) -> int32:
    # int sg_nents_for_len(struct scatterlist *sg, u64 length);
    # Returns the number of sg entries needed to cover `length` bytes,
    # or a negative errno if the chain is too short. Stub: any non-zero
    # length is "fits in one entry" (matches the sg_init_one shape).
    if length == 0:
        return 0
    return 1


def _l_scatterwalk_ffwd(dst: uint64, src: uint64, advance: uint32) -> uint64:
    # struct scatterlist *scatterwalk_ffwd(struct scatterlist dst[2],
    #                                       struct scatterlist *src,
    #                                       unsigned int advance);
    # Linux's helper for "fast-forward `advance` bytes into the sg list,
    # potentially splitting the entry we land in" — returns a 2-entry
    # synthetic sg head. Stub returns the source pointer unchanged so
    # the caller treats it as "no fast-forward needed".
    return src


def _l_scatterwalk_map_and_copy(buf: uint64, sgl: uint64,
                                  start: uint32, nbytes: uint32, out: int32):
    # void scatterwalk_map_and_copy(void *buf, struct scatterlist *sgl,
    #                                unsigned int start,
    #                                unsigned int nbytes, int out);
    # Bidirectional helper — `out=0` copies sgl→buf, `out=1` copies
    # buf→sgl. No-op stub (runtime only).
    return


# =====================================================================
# Group 5: skcipher_walk_* (crypto_null + chacha_generic)
# =====================================================================
#
# skcipher_walk_virt + skcipher_walk_done iterate over a request's
# sg list, mapping one chunk at a time so the underlying cipher can
# process it. Runtime-only — init never walks.

def _l_skcipher_walk_virt(walk: uint64, req: uint64, atomic: int32) -> int32:
    # int skcipher_walk_virt(struct skcipher_walk *walk,
    #                         struct skcipher_request *req, bool atomic);
    # Linux returns 0 on success or a negative errno. Stub reports
    # "walk ready, 0 bytes pending" so the caller's loop exits on the
    # first iteration without dereferencing any walk fields.
    if walk != 0:
        # Zero the first 64 bytes so walk->nbytes (offset 0 in 6.12)
        # is 0 — the caller's `while (walk.nbytes) { ... }` loop exits
        # immediately.
        p: Ptr[uint8] = cast[Ptr[uint8]](walk)
        i: uint64 = 0
        while i < 64:
            p[i] = 0
            i = i + 1
    return 0


def _l_skcipher_walk_done(walk: uint64, err: int32) -> int32:
    # int skcipher_walk_done(struct skcipher_walk *walk, int err);
    # Releases the current mapping and advances to the next chunk.
    # Stub propagates `err` (real Linux passes negative errors through;
    # 0 means "all chunks consumed").
    return err


def _l_crypto_alloc_sync_skcipher(alg_name: uint64, atype: uint32,
                                    mask: uint32) -> uint64:
    # struct crypto_sync_skcipher *crypto_alloc_sync_skcipher(
    #     const char *alg_name, u32 type, u32 mask);
    # Synchronous-only skcipher allocation. crypto_null's runtime may
    # reach for this when wrapping its null cipher; init does not.
    # Stub returns NULL (Linux returns ERR_PTR(-ENOENT) when the
    # algorithm isn't registered; NULL is a defensible "not found"
    # answer that NULL-checking callers accept).
    return 0


# =====================================================================
# Group 6: xxhash runtime (xxhash_generic)
# =====================================================================
#
# xxh64 / xxh64_reset / xxh64_update / xxh64_digest form lib/xxhash.c's
# streaming-hash API. xxhash_generic.ko wraps these as a shash_alg.
# Init only registers the alg struct; the runtime UND symbols are
# resolved by the loader but called only when an actual digest fires.
# Real implementations are a couple-hundred lines of bit-mixing; the
# stubs return deterministic placeholders so callers that inspect the
# return value see something non-zero.

def _l_xxh64(input: uint64, length: uint64, seed: uint64) -> uint64:
    # u64 xxh64(const void *input, size_t length, u64 seed);
    # Real xxh64: 64-bit fast non-cryptographic hash. Placeholder folds
    # length and seed into a non-zero output so callers that key on the
    # hash see distinct values for distinct (length, seed) pairs.
    return seed ^ length ^ cast[uint64](0xcbf29ce484222325)


def _l_xxh64_reset(state: uint64, seed: uint64) -> int32:
    # int xxh64_reset(struct xxh64_state *state, u64 seed);
    # Initialises a streaming state. Real Linux returns 0 on success.
    # Stub clears 80 bytes (state struct is ~32 bytes plus alignment)
    # and stores the seed at offset 0 so a subsequent xxh64_digest can
    # mix it back in.
    if state == 0:
        return -22
    p: Ptr[uint8] = cast[Ptr[uint8]](state)
    i: uint64 = 0
    while i < 80:
        p[i] = 0
        i = i + 1
    cast[Ptr[uint64]](state)[0] = seed
    return 0


def _l_xxh64_update(state: uint64, input: uint64, length: uint64) -> int32:
    # int xxh64_update(struct xxh64_state *state, const void *input,
    #                  size_t length);
    # Folds `length` bytes from `input` into the streaming state. Stub
    # accumulates length at offset 8 so xxh64_digest's output depends on
    # total input length (matches the M7.3-style "input-dependent output"
    # property without doing real bit-mixing).
    if state == 0:
        return -22
    total: Ptr[uint64] = cast[Ptr[uint64]](state + 8)
    total[0] = total[0] + length
    return 0


def _l_xxh64_digest(state: uint64) -> uint64:
    # u64 xxh64_digest(const struct xxh64_state *state);
    # Finalises the streaming hash. Stub mixes seed (offset 0) and total
    # length (offset 8) into a non-zero output.
    if state == 0:
        return 0
    seed: uint64 = cast[Ptr[uint64]](state)[0]
    total: uint64 = cast[Ptr[uint64]](state + 8)[0]
    return seed ^ total ^ cast[uint64](0x100000001b3)


# =====================================================================
# Group 7: DES runtime (des_generic)
# =====================================================================
#
# des_encrypt / des_decrypt / des_expand_key + the 3DES triplet form
# lib/crypto/des.c's API surface. Stubs accept the calls and write
# placeholder output. Init never reaches them.

def _l_des_expand_key(ctx: uint64, key: uint64, keylen: uint32) -> int32:
    # int des_expand_key(struct des_ctx *ctx, const u8 *key,
    #                    unsigned int keylen);
    # Expands a 64-bit key (with parity, 8 bytes) into 16 round
    # subkeys. Real Linux returns 0 / -EINVAL on weak-key check. Stub
    # zeroes the ctx (128-byte ks state) and returns success.
    if ctx == 0:
        return -22
    p: Ptr[uint8] = cast[Ptr[uint8]](ctx)
    i: uint64 = 0
    while i < 128:
        p[i] = 0
        i = i + 1
    return 0


def _l_des_encrypt(ctx: uint64, dst: uint64, src: uint64):
    # void des_encrypt(const struct des_ctx *ctx, u8 *dst, const u8 *src);
    # Encrypts one 64-bit block (8 bytes). Stub passes src through to
    # dst byte-for-byte (identity cipher).
    if dst == 0:
        return
    if src == 0:
        return
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    while i < 8:
        pd[i] = ps[i]
        i = i + 1


def _l_des_decrypt(ctx: uint64, dst: uint64, src: uint64):
    # void des_decrypt(const struct des_ctx *ctx, u8 *dst, const u8 *src);
    if dst == 0:
        return
    if src == 0:
        return
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    while i < 8:
        pd[i] = ps[i]
        i = i + 1


def _l_des3_ede_expand_key(ctx: uint64, key: uint64, keylen: uint32) -> int32:
    # int des3_ede_expand_key(struct des3_ede_ctx *ctx, const u8 *key,
    #                         unsigned int keylen);
    # Triple-DES: three independent 64-bit keys → 3 × 16 subkeys.
    # Stub zeroes the 384-byte ctx (3× the des_ctx footprint).
    if ctx == 0:
        return -22
    p: Ptr[uint8] = cast[Ptr[uint8]](ctx)
    i: uint64 = 0
    while i < 384:
        p[i] = 0
        i = i + 1
    return 0


def _l_des3_ede_encrypt(ctx: uint64, dst: uint64, src: uint64):
    if dst == 0:
        return
    if src == 0:
        return
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    while i < 8:
        pd[i] = ps[i]
        i = i + 1


def _l_des3_ede_decrypt(ctx: uint64, dst: uint64, src: uint64):
    if dst == 0:
        return
    if src == 0:
        return
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    while i < 8:
        pd[i] = ps[i]
        i = i + 1


# =====================================================================
# Group 8: ChaCha runtime (chacha_generic)
# =====================================================================
#
# chacha_crypt_generic / hchacha_block_generic — the per-block ChaCha20
# / HChaCha20 stream-cipher math from lib/crypto/chacha.c. Stubs pass
# input through to output (identity stream cipher) so the API surface
# resolves; init never calls them.

def _l_chacha_crypt_generic(state: uint64, dst: uint64, src: uint64,
                              nbytes: uint32, nrounds: int32):
    # void chacha_crypt_generic(u32 *state, u8 *dst, const u8 *src,
    #                            unsigned int bytes, int nrounds);
    # Real Linux runs nrounds (typically 20 for ChaCha20, 12 for
    # ChaCha12) double-rounds against the 16-word state, XORs the
    # keystream against src, writes to dst, and advances state[12]
    # (block counter). Stub: identity copy.
    if dst == 0:
        return
    if src == 0:
        return
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    n: uint64 = cast[uint64](nbytes)
    while i < n:
        pd[i] = ps[i]
        i = i + 1


def _l_hchacha_block_generic(state: uint64, out: uint64, nrounds: int32):
    # void hchacha_block_generic(const u32 *state, u32 *out, int nrounds);
    # Key-derivation primitive — runs ChaCha20 against `state` and
    # writes 256 bits (8 u32s) out. Stub zeroes the 32-byte output.
    if out == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](out)
    i: uint64 = 0
    while i < 32:
        p[i] = 0
        i = i + 1


# =====================================================================
# Group 9: Poly1305 runtime (poly1305_generic)
# =====================================================================
#
# poly1305_core_setkey / poly1305_core_blocks / poly1305_final_generic
# form lib/crypto/poly1305-donna{32,64}.c's API. The two _core_ symbols
# are typically inlined from the donna-32 header in a non-stripped
# build; in stock Debian 6.12 they're out-of-line. Stubs accept the
# calls; init never reaches them.

def _l_poly1305_core_setkey(opaque: uint64, key: uint64):
    # void poly1305_core_setkey(struct poly1305_core_key *opaque,
    #                            const u8 raw_key[POLY1305_BLOCK_SIZE]);
    # Sets the r-part of the Poly1305 key (after clamping). Stub
    # zeroes the 80-byte opaque struct so a subsequent _blocks call
    # walks zeroed state.
    if opaque == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](opaque)
    i: uint64 = 0
    while i < 80:
        p[i] = 0
        i = i + 1


def _l_poly1305_core_blocks(state: uint64, opaque_r: uint64,
                              src: uint64, nblocks: uint64,
                              hibit: uint32):
    # void poly1305_core_blocks(struct poly1305_state *state,
    #                            const struct poly1305_core_key *opaque_r,
    #                            const void *src, unsigned int nblocks,
    #                            u32 hibit);
    # Folds nblocks of 16-byte input into the running Poly1305
    # accumulator. No-op stub.
    return


def _l_poly1305_final_generic(desc: uint64, dst: uint64):
    # void poly1305_final_generic(struct poly1305_desc_ctx *desc,
    #                              u8 *dst);
    # Finalises Poly1305 and writes the 16-byte tag. Stub zeroes the
    # tag (callers that compare against a known-good tag will fail —
    # but no init path does).
    if dst == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](dst)
    i: uint64 = 0
    while i < 16:
        p[i] = 0
        i = i + 1


# =====================================================================
# Group 10: Curve25519 runtime (curve25519-generic)
# =====================================================================
#
# curve25519_generic — the X25519 scalar multiplication primitive. The
# base_point / null_point symbols are *data*: 32-byte arrays holding
# the standard generator (G = {9, 0, 0, ...}) and the all-zero
# null point. Stubs ship 32 zero bytes for both (curve25519_base_point
# would normally be {9, 0, ...}; for a stub that never runs the actual
# scalar-mul, the values don't matter as long as the symbols resolve).

curve25519_base_point_data: Array[32, uint8]
curve25519_null_point_data: Array[32, uint8]


def _l_curve25519_generic(out: uint64, scalar: uint64, point: uint64) -> int32:
    # int curve25519_generic(u8 *out, const u8 *scalar, const u8 *point);
    # X25519 scalar multiplication: out = scalar * point on Curve25519.
    # Stub zeroes the 32-byte output.
    if out == 0:
        return -22
    p: Ptr[uint8] = cast[Ptr[uint8]](out)
    i: uint64 = 0
    while i < 32:
        p[i] = 0
        i = i + 1
    return 0


def _l_wait_for_random_bytes() -> int32:
    # int wait_for_random_bytes(void);
    # Blocks until the kernel's RNG has gathered enough entropy. At L50
    # Hamnix's RNG is the zero-state seed from api_random; wait_for_*
    # returns 0 immediately ("RNG is ready"). curve25519's setkey path
    # calls this once per key.
    return 0


# =====================================================================
# Group 11: AEAD / template / hash glue (chacha20poly1305)
# =====================================================================
#
# chacha20poly1305.ko is the heaviest of the seven — it registers two
# crypto_template instances (rfc7539 + rfc7539esp) that compose
# chacha20 with poly1305 into an AEAD. Init only calls
# crypto_register_templates (returns 0); the rest of the UND set is
# runtime AEAD construction code (instance creation, ahash
# update/finup, skcipher spawn binding).

def _l_aead_register_instance(tmpl: uint64, inst: uint64) -> int32:
    # int aead_register_instance(struct crypto_template *tmpl,
    #                             struct aead_instance *inst);
    # Real Linux registers a per-template instance with crypto-core.
    # Stub accepts and returns success.
    if tmpl == 0:
        return -22
    if inst == 0:
        return -22
    return 0


def _l_crypto_ahash_init(req: uint64) -> int32:
    # int crypto_ahash_init(struct ahash_request *req);
    return 0


def _l_crypto_ahash_update(req: uint64) -> int32:
    return 0


def _l_crypto_ahash_finup(req: uint64) -> int32:
    return 0


def _l_crypto_attr_alg_name(rta: uint64) -> uint64:
    # const char *crypto_attr_alg_name(struct rtattr *rta);
    # Parses a template argument (algorithm name) out of an rtattr.
    # Returns NULL on parse error. Stub returns NULL; templates that
    # NULL-check (all of them) treat that as -ENOENT.
    return 0


def _l_crypto_check_attr_type(tb: uint64, atype: uint32, mask_ret: uint64) -> int32:
    # int crypto_check_attr_type(struct rtattr **tb, u32 type, u32 *mask_ret);
    # Validates the type/mask in a template parameter list. Stub writes
    # a zero mask (if mask_ret is non-NULL) and returns success.
    if mask_ret != 0:
        cast[Ptr[uint32]](mask_ret)[0] = 0
    return 0


def _l_crypto_drop_spawn(spawn: uint64):
    # void crypto_drop_spawn(struct crypto_spawn *spawn);
    # Releases a spawn's reference on its underlying algorithm.
    # No-op stub.
    return


def _l_crypto_grab_ahash(spawn: uint64, inst: uint64,
                          name: uint64, atype: uint32, mask: uint32) -> int32:
    # int crypto_grab_ahash(struct crypto_ahash_spawn *spawn,
    #                       struct crypto_instance *inst,
    #                       const char *name, u32 type, u32 mask);
    # Looks up an ahash algorithm by name and bumps its refcount into
    # `spawn`. Stub returns success (the spawn struct is left
    # uninitialised — runtime paths that deref it would fault, but
    # init never reaches that point).
    return 0


def _l_crypto_grab_skcipher(spawn: uint64, inst: uint64,
                              name: uint64, atype: uint32, mask: uint32) -> int32:
    return 0


def _l_crypto_skcipher_setkey(tfm: uint64, key: uint64, keylen: uint32) -> int32:
    # int crypto_skcipher_setkey(struct crypto_skcipher *tfm,
    #                             const u8 *key, unsigned int keylen);
    return 0


def _l_crypto_skcipher_encrypt(req: uint64) -> int32:
    # int crypto_skcipher_encrypt(struct skcipher_request *req);
    return 0


def _l_crypto_skcipher_decrypt(req: uint64) -> int32:
    return 0


def _l_crypto_spawn_tfm2(spawn: uint64) -> uint64:
    # struct crypto_tfm *crypto_spawn_tfm2(struct crypto_spawn *spawn);
    # Allocates a tfm bound to the spawn's algorithm. Stub returns
    # NULL — Linux's IS_ERR_OR_NULL idiom in callers handles that as
    # -ENOMEM, which init never reaches.
    return 0


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l50():
    # Called from linux_abi_exports_init() after L49's hash-module
    # rows. Adds 32 exports for the L50 crypto-module batch.

    # Group 1: registration entry-points
    _add_export("crypto_register_algs",
                cast[uint64](&_l_crypto_register_algs))
    _add_export("crypto_unregister_algs",
                cast[uint64](&_l_crypto_unregister_algs))
    _add_export("crypto_register_skcipher",
                cast[uint64](&_l_crypto_register_skcipher))
    _add_export("crypto_unregister_skcipher",
                cast[uint64](&_l_crypto_unregister_skcipher))
    _add_export("crypto_register_skciphers",
                cast[uint64](&_l_crypto_register_skciphers))
    _add_export("crypto_unregister_skciphers",
                cast[uint64](&_l_crypto_unregister_skciphers))
    _add_export("crypto_register_kpp",
                cast[uint64](&_l_crypto_register_kpp))
    _add_export("crypto_unregister_kpp",
                cast[uint64](&_l_crypto_unregister_kpp))
    _add_export("crypto_register_templates",
                cast[uint64](&_l_crypto_register_templates))
    _add_export("crypto_unregister_templates",
                cast[uint64](&_l_crypto_unregister_templates))

    # Group 2: _bh spinlock variants
    _add_export("_raw_spin_lock_bh",
                cast[uint64](&_l_raw_spin_lock_bh))
    _add_export("_raw_spin_unlock_bh",
                cast[uint64](&_l_raw_spin_unlock_bh))

    # Group 3: constant-time memcmp
    _add_export("__crypto_memneq",
                cast[uint64](&_l___crypto_memneq))

    # Group 4: scatterlist helpers
    _add_export("sg_init_one",
                cast[uint64](&_l_sg_init_one))
    _add_export("sg_copy_from_buffer",
                cast[uint64](&_l_sg_copy_from_buffer))
    _add_export("sg_copy_to_buffer",
                cast[uint64](&_l_sg_copy_to_buffer))
    _add_export("sg_nents_for_len",
                cast[uint64](&_l_sg_nents_for_len))
    _add_export("scatterwalk_ffwd",
                cast[uint64](&_l_scatterwalk_ffwd))
    _add_export("scatterwalk_map_and_copy",
                cast[uint64](&_l_scatterwalk_map_and_copy))

    # Group 5: skcipher_walk_*
    _add_export("skcipher_walk_virt",
                cast[uint64](&_l_skcipher_walk_virt))
    _add_export("skcipher_walk_done",
                cast[uint64](&_l_skcipher_walk_done))
    _add_export("crypto_alloc_sync_skcipher",
                cast[uint64](&_l_crypto_alloc_sync_skcipher))

    # Group 6: xxhash runtime
    _add_export("xxh64",
                cast[uint64](&_l_xxh64))
    _add_export("xxh64_reset",
                cast[uint64](&_l_xxh64_reset))
    _add_export("xxh64_update",
                cast[uint64](&_l_xxh64_update))
    _add_export("xxh64_digest",
                cast[uint64](&_l_xxh64_digest))

    # Group 7: DES runtime
    _add_export("des_expand_key",
                cast[uint64](&_l_des_expand_key))
    _add_export("des_encrypt",
                cast[uint64](&_l_des_encrypt))
    _add_export("des_decrypt",
                cast[uint64](&_l_des_decrypt))
    _add_export("des3_ede_expand_key",
                cast[uint64](&_l_des3_ede_expand_key))
    _add_export("des3_ede_encrypt",
                cast[uint64](&_l_des3_ede_encrypt))
    _add_export("des3_ede_decrypt",
                cast[uint64](&_l_des3_ede_decrypt))

    # Group 8: ChaCha runtime
    _add_export("chacha_crypt_generic",
                cast[uint64](&_l_chacha_crypt_generic))
    _add_export("hchacha_block_generic",
                cast[uint64](&_l_hchacha_block_generic))

    # Group 9: Poly1305 runtime
    _add_export("poly1305_core_setkey",
                cast[uint64](&_l_poly1305_core_setkey))
    _add_export("poly1305_core_blocks",
                cast[uint64](&_l_poly1305_core_blocks))
    _add_export("poly1305_final_generic",
                cast[uint64](&_l_poly1305_final_generic))

    # Group 10: Curve25519 runtime
    _add_export("curve25519_generic",
                cast[uint64](&_l_curve25519_generic))
    _add_export("curve25519_base_point",
                cast[uint64](&curve25519_base_point_data[0]))
    _add_export("curve25519_null_point",
                cast[uint64](&curve25519_null_point_data[0]))
    _add_export("wait_for_random_bytes",
                cast[uint64](&_l_wait_for_random_bytes))

    # Group 11: AEAD / template / hash glue
    _add_export("aead_register_instance",
                cast[uint64](&_l_aead_register_instance))
    _add_export("crypto_ahash_init",
                cast[uint64](&_l_crypto_ahash_init))
    _add_export("crypto_ahash_update",
                cast[uint64](&_l_crypto_ahash_update))
    _add_export("crypto_ahash_finup",
                cast[uint64](&_l_crypto_ahash_finup))
    _add_export("crypto_attr_alg_name",
                cast[uint64](&_l_crypto_attr_alg_name))
    _add_export("crypto_check_attr_type",
                cast[uint64](&_l_crypto_check_attr_type))
    _add_export("crypto_drop_spawn",
                cast[uint64](&_l_crypto_drop_spawn))
    _add_export("crypto_grab_ahash",
                cast[uint64](&_l_crypto_grab_ahash))
    _add_export("crypto_grab_skcipher",
                cast[uint64](&_l_crypto_grab_skcipher))
    _add_export("crypto_skcipher_setkey",
                cast[uint64](&_l_crypto_skcipher_setkey))
    _add_export("crypto_skcipher_encrypt",
                cast[uint64](&_l_crypto_skcipher_encrypt))
    _add_export("crypto_skcipher_decrypt",
                cast[uint64](&_l_crypto_skcipher_decrypt))
    _add_export("crypto_spawn_tfm2",
                cast[uint64](&_l_crypto_spawn_tfm2))

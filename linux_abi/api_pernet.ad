# linux_abi/api_pernet.ad
#
# L41: Linux per-net-namespace subsystem registration + ipv4 defragger
# scaffolding. Pulled in by nf_defrag_ipv4.ko (stock Debian 6.12 .ko),
# whose init path does exactly one thing:
#
#     return register_pernet_subsys(&defrag4_net_ops);
#
# ...and whose .text path references three function symbols (ip_defrag,
# __local_bh_enable_ip, pcpu_hot) plus one data symbol (nf_defrag_v4_hook)
# that the loader must be able to *resolve* even though no init-time call
# path actually exercises them. Without resolved addresses the loader
# would patch a NULL into the module's relocation slot; if the hook were
# ever invoked later the trap would be unattributable, so we hand out
# real shim addresses (no-op bodies / zero-filled data) up front.
#
# Linux signatures:
#
#   int  register_pernet_subsys(struct pernet_operations *ops);
#   void unregister_pernet_subsys(struct pernet_operations *ops);
#   int  ip_defrag(struct net *net, struct sk_buff *skb, u32 user);
#   void __local_bh_enable_ip(unsigned long ip, unsigned int cnt);
#
# pcpu_hot is a DATA symbol (`struct pcpu_hot pcpu_hot`) holding the
# per-CPU "hot cache line" (current_task, top_of_stack, cpu number).
# nf_defrag_v4_hook is a DATA symbol that init_module writes 0 to on
# successful pernet registration — a refcount counter living in the
# enable/disable codepath. We don't care what's in either as long as
# the address resolves to a writable 8-byte slot.
#
# ---------------------------------------------------------------------
# pernet_operations slot table
#
# Linux's `struct pernet_operations` is a vtable + a couple of size_t
# fields:
#     int  (*init)(struct net *net);
#     void (*exit)(struct net *net);
#     void (*exit_batch)(struct list_head *net_exit_list);
#     unsigned int *id;
#     size_t size;
#
# register_pernet_subsys calls ->init for every existing net namespace
# (just init_net on Linux at boot; here there are zero namespaces yet),
# then records the ops in a per-namespace list so future-created
# namespaces inherit it. Hamnix has no `struct net` at L41 — there's
# only one (implicit) "default" namespace and it's never created or
# destroyed — so the most truthful implementation is:
#
#   * Record the ops pointer in a 4-slot static table so unregister
#     can find it (Linux's contract is "exactly one register/unregister
#     pair per ops"; rejecting a stale unregister is a kernel bug, not
#     a regression we should surface).
#   * Skip calling ->init entirely. The ->init callback expects a
#     valid struct net argument we don't have; calling it with NULL
#     would crash inside the module. Stock pernet ops handle "no
#     namespaces yet" gracefully — they're invoked lazily as net
#     namespaces appear, which never happens at L41.
#   * Return 0 (success).
#
# When the L-track grows a real `struct net` (the "Lnet" milestone),
# this slot table becomes the bridge: walking it on net-create fires
# every recorded ->init, and net-destroy fires every recorded ->exit.

from linux_abi.exports import _add_export


MAX_PERNET_SUBSYS: uint64 = 4

pernet_slot_ops: Array[4, uint64]    # struct pernet_operations * (0 = free)


def _pernet_alloc_slot(ops: uint64) -> int32:
    # Linear scan for a free slot. Returns the slot index, or -1 if the
    # table is full (which we report as -ENOMEM upstream — same shape as
    # Linux's "too many net subsystems" error path, which in practice
    # the upstream kernel never hits either).
    i: uint64 = 0
    while i < MAX_PERNET_SUBSYS:
        if pernet_slot_ops[i] == 0:
            pernet_slot_ops[i] = ops
            return cast[int32](i)
        i = i + 1
    return -1


def _pernet_find_and_clear(ops: uint64) -> int32:
    # Drop the slot holding `ops`. Returns the cleared slot or -1 if the
    # ops pointer wasn't registered. Linux's unregister_pernet_subsys is
    # void-return; we mirror that and just no-op on miss.
    if ops == 0:
        return -1
    i: uint64 = 0
    while i < MAX_PERNET_SUBSYS:
        if pernet_slot_ops[i] == ops:
            pernet_slot_ops[i] = 0
            return cast[int32](i)
        i = i + 1
    return -1


def _l_register_pernet_subsys(ops: uint64) -> int32:
    # Linux: returns 0 on success, -ENOMEM/-EEXIST on failure. We accept
    # any non-NULL ops, record it, and report success. The ops->init
    # callback is NOT invoked here — see file header for the rationale.
    if ops == 0:
        return -22                                  # -EINVAL
    slot: int32 = _pernet_alloc_slot(ops)
    if slot < 0:
        return -12                                  # -ENOMEM
    return 0


def _l_unregister_pernet_subsys(ops: uint64):
    # Linux: void return. The exit callback is paired with init and we
    # never invoked init, so we never invoke exit either — just drop the
    # slot. If the ops pointer isn't in the table the call is a no-op,
    # matching the Linux behaviour for a stale unregister attempt.
    _pernet_find_and_clear(ops)


# ---------------------------------------------------------------------
# nf_defrag_v4_hook — refcount/counter the module owns externally.
#
# In Linux 6.12 the symbol lives in include/net/netfilter/ipv4/nf_defrag_ipv4.h
# as an atomic_t (or DEFINE_STATIC_KEY in some builds) consulted by the
# defrag enable/disable codepath. nf_defrag_ipv4's init_module writes 0
# to it on successful pernet registration — initialising the refcount.
# Subsequent enable/disable calls (from clients like nf_conntrack) bump
# or drop the counter; only init lands in our path at L41, so a single
# writable 8-byte slot is enough.
#
# The store is `movq $0, nf_defrag_v4_hook(%rip)`, which writes the
# full 8 bytes; declaring as uint64 keeps the operation aligned and
# avoids partial-word artefacts.

nf_defrag_v4_hook_var: uint64 = 0


# ---------------------------------------------------------------------
# pcpu_hot — per-CPU "hot cache line" placeholder.
#
# Linux's struct pcpu_hot packs the most frequently touched per-CPU
# fields into one cache line:
#
#     struct pcpu_hot {
#         union {
#             struct {
#                 struct task_struct *current_task;
#                 int                 preempt_count;
#                 int                 cpu_number;
#                 u64                 call_depth;
#                 unsigned long       top_of_stack;
#                 void               *hardirq_stack_ptr;
#                 u16                 softirq_pending;
#                 bool                hardirq_stack_inuse;
#             };
#             u8 pad[64];
#         };
#     };
#
# nf_defrag_ipv4.ko reads pcpu_hot from its non-init code paths (the
# enable/disable functions check preempt_count). At L41 the init path
# never touches it, so a 64-byte zero buffer suffices to make the
# relocation resolve. Modules that hit the enable/disable codepath
# would see preempt_count=0 (not in preempt-disabled context) and
# top_of_stack=0 (which is wrong but never read by init).
#
# Real per-CPU support requires:
#   * A %gs-based segment override (Linux uses %gs:pcpu_hot offset
#     to read this per-CPU)
#   * NR_CPUS worth of pcpu_hot buffers, indexed by cpu number
# Both are out-of-scope for L41; the placeholder is sufficient because
# every init-time relocation resolves and no init-time call path
# dereferences pcpu_hot fields.

pcpu_hot_buf: Array[64, uint8]


# ---------------------------------------------------------------------
# Function shims that are referenced from .text but NEVER called at
# init-time. They exist so the loader's relocation pass succeeds; the
# bodies are minimal "report success / do nothing" stubs that mirror
# the rest of the L-track's "scaffolding only" discipline.

def _l_ip_defrag(net: uint64, skb: uint64, user: uint32) -> int32:
    # Linux: int ip_defrag(struct net *, struct sk_buff *, u32 user)
    # Returns 0 on success (packet fully reassembled or single fragment
    # passes through), -EINPROGRESS (-115) if more fragments are awaited,
    # or a negative errno on error. Hamnix has no skb pipeline at L41 —
    # this is purely the unresolved-relocation backstop. If a future
    # hook fires and calls ip_defrag we return 0 ("pass through"), which
    # is the safest "behave as if the packet was already whole" answer.
    return 0


def _l_local_bh_enable_ip(ip_arg: uint64, cnt: uint32):
    # Linux: void __local_bh_enable_ip(unsigned long ip, unsigned int cnt)
    # The internal helper that re-enables bottom halves (decrements the
    # per-CPU softirq pending counter). Hamnix doesn't run bottom halves
    # — there's no softirq dispatch — so the only correct body is a
    # no-op. The function is reached from spin_unlock_bh / read_unlock_bh
    # in module hot paths, which init_module doesn't traverse.
    return


# ---------------------------------------------------------------------
# Registration.

def linux_abi_register_pernet():
    # Function shims.
    _add_export("register_pernet_subsys",
                cast[uint64](&_l_register_pernet_subsys))
    _add_export("unregister_pernet_subsys",
                cast[uint64](&_l_unregister_pernet_subsys))
    _add_export("ip_defrag",
                cast[uint64](&_l_ip_defrag))
    _add_export("__local_bh_enable_ip",
                cast[uint64](&_l_local_bh_enable_ip))
    # Data symbols — the export hands out the address of the backing
    # buffer / variable.
    _add_export("nf_defrag_v4_hook",
                cast[uint64](&nf_defrag_v4_hook_var))
    _add_export("pcpu_hot",
                cast[uint64](&pcpu_hot_buf[0]))

# =====================================================================

def linux_abi_register_l57():
    # Called from linux_abi_exports_init() after L56's binfmt_misc rows.
    # Adds 117 exports for the L57 batch (fat.ko coverage).

    # Init-time fixup: populate the hex_asc lookup table.
    _l57_init_hex_asc()

    # ---- Group 1: slab noprof family ----
    _add_export("__kmem_cache_create_args",
                cast[uint64](&_l___kmem_cache_create_args))
    _add_export("kmem_cache_alloc_noprof",
                cast[uint64](&_l_kmem_cache_alloc_noprof))
    _add_export("kmem_cache_alloc_lru_noprof",
                cast[uint64](&_l_kmem_cache_alloc_lru_noprof))


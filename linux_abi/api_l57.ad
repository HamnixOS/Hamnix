# Linux: long compat_ptr_ioctl(struct file *, unsigned int cmd,
#                               unsigned long arg);
# A generic 32-bit-compat ioctl helper — fat.ko's f_op->compat_ioctl
# points at it. Never fires on a 64-bit-only environment.

def _l_compat_ptr_ioctl(filp: uint64, cmd: uint32, arg: uint64) -> int64:
    return 0



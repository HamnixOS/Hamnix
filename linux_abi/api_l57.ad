# =====================================================================
# Group 5: block layer — blkdev_issue_discard / blkdev_issue_flush /
#          blk_finish_plug / blk_start_plug / __blockdev_direct_IO /
#          sb_min_blocksize / sb_set_blocksize / sync_blockdev_nowait

# =====================================================================
# Group 13: time / RCU / capability / scheduling / rwsem
# =====================================================================
#
# current_time samples the wall clock for inode timestamps. time64_to_tm
# converts a Unix epoch second to a struct tm (for the directory entry's
# FAT-format date). call_rcu defers a free until the current RCU grace
# period ends. capable() answers root-capability checks. down_read /
# up_read take/release a read lock on an rw_semaphore. __init_rwsem
# initialises one. io_schedule_timeout is the I/O-wait blocking call.
#
# Bodies are pragmatic stubs — none fire at fat.ko's init, so anything
# that doesn't crash on call is acceptable.

def _l_current_time(inode: uint64) -> uint64:
    # struct timespec64 current_time(struct inode *);
    # Returns 0 (epoch). The caller copies it into i_mtime etc.
    return 0


def _l_time64_to_tm(totalsecs: uint64, offset: int32, result: uint64):
    # void time64_to_tm(time64_t totalsecs, int offset, struct tm *result);
    # Zero the output struct tm (32 bytes). Caller uses its fields to
    # build the FAT date/time — zero gives 1970-01-01 00:00:00, harmless
    # in stub paths.
    if result == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](result)
    i: uint64 = 0
    while i < 36:                  # sizeof(struct tm) ≈ 36 (9 ints + tm_zone *)
        p[i] = 0
        i = i + 1


def _l_get_random_u32() -> uint32:
    # u32 get_random_u32(void);
    return 0


def _l_capable(cap: int32) -> int32:
    # bool capable(int cap);  fat.ko uses this to gate FAT_IOCTL_SET_ATTR.
    # Returning 1 means "yes you have CAP_*" — pragmatic for a single-
    # user env.
    return 1


def _l_call_rcu(head: uint64, func: uint64):
    # void call_rcu(struct rcu_head *, rcu_callback_t func);
    # Real Linux defers `func(head)` past the next RCU grace period.
    # Hamnix has no RCU — dropping the deferred call leaks the head's
    # memory in stub-only paths, which fat.ko's init never exercises.
    return


def _l_io_schedule_timeout(timeout: uint64) -> uint64:
    # long io_schedule_timeout(long timeout);
    # Returns 0 (= timed out) without actually sleeping.
    return 0


def _l___init_rwsem(sem: uint64, name: uint64, key: uint64):
    # void __init_rwsem(struct rw_semaphore *, const char *name,
    #                    struct lock_class_key *);
    return


def _l_down_read(sem: uint64):
    # void down_read(struct rw_semaphore *);
    return


def _l_up_read(sem: uint64):
    # void up_read(struct rw_semaphore *);
    return


# =====================================================================
# Group 14: DATA exports — sys_tz, hex_asc, names_cachep
# =====================================================================
#
# sys_tz: `struct timezone sys_tz;`  — global timezone offset; FAT uses
#         it to apply the local-time fudge to directory-entry timestamps.
#         Real Linux defaults to {0, 0} (UTC); zero buffer is correct.
# hex_asc: `const char hex_asc[] = "0123456789abcdef";` — 16-byte
#          lookup table for hex serialisation. We provide a real table
#          so that any accidental runtime call deserialises correctly.
# names_cachep: `extern struct kmem_cache *names_cachep;` — the
#               global PATH_MAX-sized filename slab cache. Real Linux
#               populates this in vfs_caches_init(). Our shim points at
#               a 64-byte zero buffer; fat.ko's init never dereferences
#               it (the cache is only used in pathname-resolution).

sys_tz_buf: Array[16, uint8]                # struct timezone is 2 ints = 8 bytes; 16 is safe headroom


hex_asc_buf: Array[17, uint8]                # 16 chars + NUL


names_cachep_buf: Array[64, uint8]


def _l57_init_hex_asc():
    # Populate hex_asc_buf with "0123456789abcdef" once. Called from
    # linux_abi_register_l57() so the table is live before any module
    # loads.
    hex_asc_buf[0] = 48           # '0'
    hex_asc_buf[1] = 49           # '1'
    hex_asc_buf[2] = 50           # '2'
    hex_asc_buf[3] = 51           # '3'
    hex_asc_buf[4] = 52           # '4'
    hex_asc_buf[5] = 53           # '5'
    hex_asc_buf[6] = 54           # '6'
    hex_asc_buf[7] = 55           # '7'
    hex_asc_buf[8] = 56           # '8'
    hex_asc_buf[9] = 57           # '9'
    hex_asc_buf[10] = 97          # 'a'
    hex_asc_buf[11] = 98          # 'b'
    hex_asc_buf[12] = 99          # 'c'
    hex_asc_buf[13] = 100         # 'd'
    hex_asc_buf[14] = 101         # 'e'
    hex_asc_buf[15] = 102         # 'f'
    hex_asc_buf[16] = 0           # NUL



# linux_abi/api_l57.ad
#
# L57: shims for the ABI gap exposed by the stock Debian 6.12 fat.ko
# (Linux's core FAT filesystem module — the foundation for vfat/exfat/
# msdos/iso9660 and the dependency every FAT-family filesystem links
# against).
#
# fat.ko is library-only from Linux's perspective: it exports the FAT
# inode/dir/superblock/cluster machinery as kernel symbols and lets
# vfat.ko / msdos.ko / exfat.ko / udf.ko consume them via
# register_filesystem callbacks. Its own init_module body is small —
# fat_cache_init creates two slab caches and returns:
#
#   init_module:
#       call __fentry__
#       sub  $0x28, %rsp
#       call fat_cache_init                 # internal
#         (calls __kmem_cache_create_args twice — NEW in L57)
#       test %eax, %eax
#       jne  err
#       <create second slab cache>
#       call __kmem_cache_create_args       # NEW
#       test %rax, %rax
#       je   destroy_first_cache
#       <return 0>
#
# So the init path is dominated by ONE symbol: __kmem_cache_create_args
# (the noprof-era replacement for kmem_cache_create — Linux 6.12's slab
# allocator renames the entrypoint to disambiguate allocation profiling
# vs. non-profiling builds). Everything else in the UND list is the
# inode/dir/buffer/folio/page-cache/dcache surface that fat.ko exports
# upward to vfat.ko et al — none of it fires at fat.ko's own init.
#
# UND analysis (`readelf -s --wide` on distro_fat.ko):
#   * 160 UND symbols total
#   * 43 already covered by L1..L56 + the api_*.ad core (memcpy,
#     memset, memcmp, _printk, __fentry__, kfree, mutex_lock, register_
#     filesystem, unregister_filesystem, kill_block_super, sg_*, etc.)
#   * 117 NEW in L57 (this file).
#
# Grouping (init-path symbols first, then runtime stubs):
#
#   Group 1: slab noprof family (init-path critical)
#     __kmem_cache_create_args, kmem_cache_alloc_noprof,
#     kmem_cache_alloc_lru_noprof
#
#   Group 2: x86 retpoline thunks (always required to resolve)
#     __x86_indirect_thunk_r12, __x86_indirect_thunk_rbx,
#     __SCT__cond_resched, __SCT__might_resched
#
#   Group 3: x86 user-copy primitives (gcc-emitted helpers)
#     __get_user_4, __put_user_1, __put_user_2, __put_user_4,
#     __put_user_8
#
#   Group 4: buffer_head (block I/O — runtime read/write only)
#     bdev_getblk, __bforget, __breadahead, __bread_gfp, __brelse,
#     __find_get_block, __lock_buffer, __wait_on_buffer, unlock_buffer,
#     mark_buffer_dirty, mark_buffer_dirty_inode, sync_dirty_buffer,
#     write_dirty_buffer, invalidate_inode_buffers, sync_mapping_buffers
#
#   Group 5: block layer (blkdev — runtime only)
#     blkdev_issue_discard, blkdev_issue_flush, blk_finish_plug,
#     blk_start_plug, __blockdev_direct_IO, sb_min_blocksize,
#     sb_set_blocksize, sync_blockdev_nowait
#
#   Group 6: page-cache / folio / mpage (runtime only)
#     block_dirty_folio, block_invalidate_folio, block_truncate_page,
#     buffer_migrate_folio, cont_write_begin, generic_write_end,
#     generic_cont_expand_simple, generic_block_bmap,
#     filemap_fdatawait_range, filemap_fdatawrite,
#     filemap_fdatawrite_range, filemap_splice_read, mpage_readahead,
#     mpage_read_folio, mpage_writepages, truncate_inode_pages_final,
#     truncate_pagecache, truncate_setsize
#
#   Group 7: VFS inode / dentry (mostly runtime)
#     d_make_root, d_obtain_alias, d_parent_ino, igrab, ilookup,
#     iunique, inode_dio_wait, inode_init_once,
#     inode_maybe_inc_iversion, inode_needs_sync, __insert_inode_hash,
#     __mark_inode_dirty, set_nlink, setattr_copy, setattr_prepare,
#     security_inode_setattr, write_inode_now, sync_inode_metadata,
#     sync_filesystem, generic_fillattr
#
#   Group 8: VFS generic file ops (runtime)
#     __generic_file_fsync, generic_file_llseek, generic_file_mmap,
#     generic_file_read_iter, generic_file_write_iter,
#     generic_read_dir, iter_file_splice_write, generic_fh_to_dentry,
#     generic_fh_to_parent, generic_encode_ino32_fh
#
#   Group 9: fs_context / mount-option parser (runtime)
#     fs_param_is_bool, fs_param_is_enum, fs_param_is_gid,
#     fs_param_is_s32, fs_param_is_string, fs_param_is_u32,
#     fs_param_is_uid, __fs_parse
#
#   Group 10: mnt + fsnotify (runtime)
#     mnt_drop_write_file, mnt_want_write_file, fsnotify,
#     __fsnotify_parent
#
#   Group 11: kuid/kgid/vfsuid/vfsgid mapping (runtime)
#     from_vfsgid, from_vfsuid, make_vfsgid, make_vfsuid,
#     vfsgid_in_group_p, current_umask
#
#   Group 12: NLS load/unload (runtime mount-time)
#     load_nls, unload_nls, utf16s_to_utf8s
#
#   Group 13: time / RCU / capability (mostly runtime)
#     current_time, time64_to_tm, get_random_u32, capable, call_rcu,
#     io_schedule_timeout, __init_rwsem, down_read, up_read
#
#   Group 14: data exports (DATA — backing buffers)
#     sys_tz, hex_asc, names_cachep
#
#   Group 15: misc (runtime)
#     compat_ptr_ioctl
#
# Stub philosophy mirrors L51..L56:
#   * Init-path slab functions (Group 1) return a non-NULL handle so
#     fat_cache_init's `test %rax, %rax / je destroy_first` accepts
#     the result. We route to the L3 slab machinery already in
#     api_slab.ad — the same `_l3_alloc_slot` backing kmem_cache_create.
#   * Retpoline thunks emit pop %rbp; jmpq *%reg (same convention as
#     api_lib80211.ad / api_raid6.ad / api_l56.ad).
#   * Every other shim is a no-op returning 0 / NULL / -EINVAL as
#     appropriate. fat.ko's runtime paths only fire when a real FAT
#     mount happens (which Hamnix doesn't perform — vfat.ko isn't
#     loaded, fs/fat32_*.ad serves the native FAT need instead).
#   * DATA exports point at backing buffers in this file.
#
# Naming notes:
#   * Adder reserves `bytes` → not used.
#   * Adder reserves `file` → not used (we always pass `f` or `filp`).
#   * `pos` / `len` / `flags` / `mode` are all fine.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree
from kernel.sched.core import kernel_cond_resched


# =====================================================================
# Group 1: slab noprof family — __kmem_cache_create_args,
#          kmem_cache_alloc_noprof, kmem_cache_alloc_lru_noprof
# =====================================================================
#
# Linux 6.12 splits slab into "noprof" (no allocation profiling) and
# regular paths. fat.ko's init_module references the noprof variants
# directly. Behaviour is identical to the non-noprof entrypoints from
# our shim's perspective — Hamnix has no alloc profiling and no
# per-cache LRU.
#
# Linux:
#   struct kmem_cache *__kmem_cache_create_args(const char *name,
#                                                unsigned int size,
#                                                struct kmem_cache_args *args,
#                                                slab_flags_t flags);
#   void *kmem_cache_alloc_noprof(struct kmem_cache *s, gfp_t flags);
#   void *kmem_cache_alloc_lru_noprof(struct kmem_cache *s,
#                                      struct list_lru *lru, gfp_t flags);
#
# Our backing storage is the L3KmemCache pool in api_slab.ad. Rather
# than thread that across modules, we inline a fresh-minted handle
# from kmalloc: a 16-byte header { in_use, object_size } is enough for
# our alloc-side stubs to dispatch correctly. fat.ko's first call asks
# for a 32-byte cache (`fat_inode_cachep`) and a 776-byte cache
# (`fat_cache_cachep`). The init path only cares that the returned
# pointer is non-NULL — it stashes the handle in a static, and the
# slab itself is consulted at mount time (never in our environment).

L57_CACHE_HDR_SIZE: uint64 = 16  # uint64 in_use + uint64 object_size


def _l___kmem_cache_create_args(name: uint64, size: uint32,
                                  args: uint64, flags: uint64) -> uint64:
    # struct kmem_cache *__kmem_cache_create_args(name, size, args, flags);
    # Allocate a 16-byte header that doubles as the kmem_cache handle.
    # `name` is for /proc/slabinfo (not implemented), `args` carries
    # align/useroffset/freeptr_offset (slab debugging fields), `flags`
    # is the SLAB_* bitmask. fat.ko never reads any of them back.
    handle: uint64 = kmalloc(L57_CACHE_HDR_SIZE)
    if handle == 0:
        return 0
    p: Ptr[uint64] = cast[Ptr[uint64]](handle)
    p[0] = 1                       # in_use
    p[1] = cast[uint64](size)      # object_size
    return handle


def _l_kmem_cache_alloc_noprof(s: uint64, flags: uint64) -> uint64:
    # void *kmem_cache_alloc_noprof(struct kmem_cache *s, gfp_t flags);
    # NULL-safe (matches the L3 shim convention). Looks up the cached
    # object_size from the handle header and kmallocs.
    if s == 0:
        return 0
    p: Ptr[uint64] = cast[Ptr[uint64]](s)
    if p[0] == 0:
        return 0
    return kmalloc(p[1])


def _l_kmem_cache_alloc_lru_noprof(s: uint64, lru: uint64,
                                     flags: uint64) -> uint64:
    # void *kmem_cache_alloc_lru_noprof(...); ignores the list_lru
    # (Hamnix has no shrinker integration), forwards to the regular
    # noprof alloc.
    if s == 0:
        return 0
    p: Ptr[uint64] = cast[Ptr[uint64]](s)
    if p[0] == 0:
        return 0
    return kmalloc(p[1])


# =====================================================================
# Group 2: x86 retpoline thunks (r12, rbx) + scheduler call-thunks
# =====================================================================
#
# Linux uses static-call thunks (__SCT__name) for hot scheduler hooks.
# gcc emits `call __SCT__cond_resched` / `call __SCT__might_resched`
# in the FAT read/write paths. Real Linux patches these at boot to
# jump to the chosen implementation; for our purposes both can be
# no-ops (Hamnix has no preemption point inside fat.ko's runtime).
#
# r12 / rbx retpoline variants follow the same convention as the rax /
# rcx / r8 / r9 / r11 / r14 / rdi thunks shipped in earlier milestones:
# pop the prologue's saved %rbp, then jmpq *%reg.

def _l___x86_indirect_thunk_r12():
    # Retpoline replacement for `call *%r12`.
    asm_volatile("""
        popq %rbp
        jmpq *%r12
    """)


def _l___x86_indirect_thunk_rbx():
    # Retpoline replacement for `call *%rbx`.
    asm_volatile("""
        popq %rbp
        jmpq *%rbx
    """)


def _l___SCT__cond_resched():
    # Static-call thunk for cond_resched(). Linux patches this at boot
    # to call the live scheduler hook; we route to kernel_cond_resched
    # (commit b08853e) so any compiled-in busy-poll loop inside a stock
    # .ko cooperates with preemption. Used by every stock module that
    # was compiled with PREEMPT_DYNAMIC=y (the modern Debian default —
    # both fat.ko's read/write paths and xhci_hcd.ko's handshake-style
    # polls hit this thunk). Tight inner loops that call cond_resched
    # only need IRQ-window-open semantics most of the time; the
    # _another_task_ready check inside kernel_cond_resched keeps the
    # cost low when no peer wants the CPU.
    kernel_cond_resched()


def _l___SCT__might_resched():
    # Static-call thunk for might_resched() — debug check that yields
    # if needed. Linux gates the real yield on need_resched; gcc emits
    # this thunk on every read/write call so it's a hot path. We keep
    # it cheap: a no-op. The companion __SCT__cond_resched (which is
    # called from the actual yield-class busy-poll sites — xhci_handshake
    # via __const_udelay, etc.) is wired to the real kernel_cond_resched
    # above, so forward progress is guaranteed even with this stub
    # silent.
    return


# =====================================================================
# Group 3: x86 user-copy primitives — __get_user_4 + __put_user_{1,2,4,8}
# =====================================================================
#
# These are gcc-inline helpers emitted on every get_user()/put_user()
# call site. The real implementations are written in arch/x86/lib/
# getuser.S / putuser.S — they perform the user-address access with
# an exception-table-tracked fault handler. fat.ko hits them in the
# ioctl path (FAT-specific ioctls that read/write user memory) and
# the dirent-fill path.
#
# Calling convention is non-standard: __get_user_4 takes the user
# address in %rax and returns (value, errno) in (%rax, %rdx).
# __put_user_N takes the value in %rax and the user address in %rcx.
# None fire on the module-init path; stubbing them to return -EFAULT
# / 0 in the right registers is enough to bind the relocations.
#
# Stub strategy: a plain function that sets %rax = -14 (-EFAULT)
# in the int-return slot and returns. The caller branches on rax
# being non-zero and goes to the user-fault label. Since our env
# never invokes these at runtime, the exact body doesn't matter as
# long as the symbol address resolves.

def _l___get_user_4() -> int32:
    # __get_user_4: load 4 bytes from user space. Return -EFAULT.
    return -14


def _l___put_user_1() -> int32:
    return -14


def _l___put_user_2() -> int32:
    return -14


def _l___put_user_4() -> int32:
    return -14


def _l___put_user_8() -> int32:
    return -14


# =====================================================================
# Group 4: buffer_head — bdev_getblk / __bforget / __bread{,_gfp} /
#          __breadahead / __brelse / __find_get_block / __lock_buffer /
#          __wait_on_buffer / unlock_buffer / mark_buffer_dirty{,_inode}
#          / sync_dirty_buffer / write_dirty_buffer /
#          invalidate_inode_buffers / sync_mapping_buffers
# =====================================================================
#
# The classic Linux buffer_head API. FAT's superblock read uses
# __bread_gfp to pull boot sector + FAT tables off the block device.
# Every buffer-head function is reached only at mount/read/write time
# — never at fat.ko's init.
#
# Stub bodies:
#   * read-side returns NULL → callers treat as I/O error and bail.
#   * write-side no-ops (mark/sync/invalidate).
#
# This is a complete no-op buffer_head layer. The first real mount
# would need actual block-buffer plumbing, but the L57 milestone only
# needs symbol-binding.

def _l_bdev_getblk(bdev: uint64, block: uint64, size: int32,
                    gfp: uint32) -> uint64:
    # struct buffer_head *bdev_getblk(struct block_device *, sector_t,
    #                                  unsigned size, gfp_t);
    return 0



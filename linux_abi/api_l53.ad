# linux_abi/api_l53.ad
#
# L53: shims for the ABI gap exposed by six stock Debian 6.12 crypto
# modules in the rng / AEAD / GCM / CCM / wide-cipher batch:
#
#   lrw.ko         — Liskov-Rivest-Wagner wide-block cipher mode
#   keywrap.ko     — RFC 3394 key-wrap mode
#   ansi_cprng.ko  — ANSI X9.31 PRNG (DRBG predecessor)
#   aegis128.ko    — AEGIS-128 AEAD
#   ccm.ko         — Counter with CBC-MAC AEAD mode
#   gcm.ko         — Galois/Counter Mode AEAD
#
# Init-path disassembly (objdump -drC of each *.ko's .init.text):
#
#   lrw.ko / keywrap.ko:
#       init_module:
#           call __fentry__
#           mov  $&<tmpl>, %rdi
#           jmp  crypto_register_template      # L51: returns 0
#
#   ansi_cprng.ko:
#       init_module:
#           call __fentry__
#           mov  $1, %esi
#           mov  $&rng_algs, %rdi
#           jmp  crypto_register_rngs          # new in L53
#
#   aegis128.ko:
#       init_module:
#           call __fentry__
#           mov  $&crypto_aegis128_alg, %rdi
#           jmp  crypto_register_aead          # new in L53
#
#   ccm.ko:
#       init_module:
#           call __fentry__
#           mov  $3, %esi                      # 3 templates
#           mov  $&crypto_ccm_tmpls, %rdi
#           jmp  crypto_register_templates     # L50: returns 0
#
#   gcm.ko:
#       init_module:
#           call __fentry__
#           ... allocates a "ctr(aes)" tfm via crypto_alloc_skcipher,
#               then registers ~3 templates. Init reaches several
#               runtime symbols (the "default null skcipher" reservation
#               + a swait_queue head init for the async completion
#               machinery), all stubbed below.
#
# Cross-check against L1..L52 reduced the union of the six .ko's UND
# lists to thirty distinct symbols not yet exported, grouped below by
# theme. As with L49..L52, any runtime UND that isn't on the init path
# still resolves through this file — the loader's relocation pass binds
# the address even though the call site never fires during module load.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree


# =====================================================================
# Group 1: lrw runtime — gf128mul 64k_bbe variant
# =====================================================================
#
# Linux:
#   struct gf128mul_64k *gf128mul_init_64k_bbe(const be128 *g);
#   void                 gf128mul_free_64k(struct gf128mul_64k *t);
#   void                 gf128mul_64k_bbe(be128 *r, const struct gf128mul_64k *t);
#
# Mirror of api_l49's gf128mul_init_4k_lle / gf128mul_4k_lle pair, but
# for the 64k "big-endian, big-endian" table layout that lrw uses for
# fast GF(2^128) multiplication. lrw's runtime calls _init_64k_bbe
# once per key (precomputes a ~1 MiB table) and _64k_bbe per block to
# fold the tweak. init_module's tail-jump to crypto_register_template
# means neither fires during module load — both are runtime-only.
#
# Stub strategy matches L49: the init helper returns the address of a
# small zero buffer (caller's NULL-check passes), the multiply step is
# a no-op (the accumulator pointed at by `r` retains whatever value
# the caller seeded), and free is a no-op (the placeholder is static).

gf128mul_64k_placeholder: Array[64, uint8]


def _l_gf128mul_init_64k_bbe(g: uint64) -> uint64:
    # Real Linux allocates 16 * 4096 bytes and walks `g` building the
    # table. No-op placeholder: return the static buffer's address so
    # the caller's NULL-check passes.
    return cast[uint64](&gf128mul_64k_placeholder[0])


def _l_gf128mul_free_64k(t: uint64):
    # Real Linux walks the 16-row table and kfree's each row. Our
    # placeholder is static; nothing to free.
    return


def _l_gf128mul_64k_bbe(r: uint64, t: uint64):
    # No-op. The accumulator pointed at by `r` keeps whatever value
    # the caller seeded — for lrw runtime this means the wide-block
    # tweak is not actually computed, which is correct because we
    # never reach this path while lrw's encrypt/decrypt is unused.
    return


# =====================================================================
# Group 2: scatterlist walking — sg_next + scatterwalk_copychunks
# =====================================================================
#
# Linux:
#   struct scatterlist *sg_next(struct scatterlist *);
#   void scatterwalk_copychunks(void *buf, struct scatter_walk *walk,
#                                size_t nbytes, int out);
#
# sg_next walks a chain of scatterlist entries via the low bit of
# page_link: bit-0 set = chain pointer to next array, bit-1 set = end
# marker. Real Linux walks until it hits a non-chain non-end entry.
#
# All four of keywrap / aegis128 / ccm / gcm pull sg_next in for their
# runtime sg-list walking. None of the init paths reaches it (init
# only registers templates / one aead alg / one rng alg). Stub returns
# NULL so any caller's `while (sg) {...}` loop exits on the first
# iteration without dereferencing the chain.
#
# scatterwalk_copychunks is keywrap's bulk-copy helper between a
# walking-cursor and a linear buffer. Stub no-op; the runtime path
# isn't exercised at init.

def _l_sg_next(sg: uint64) -> uint64:
    # Returning NULL ends any caller's walk loop immediately. Init
    # never reaches this; runtime callers see an empty chain.
    return 0


def _l_scatterwalk_copychunks(buf: uint64, walk: uint64,
                                nbytes: uint64, out: int32):
    # void scatterwalk_copychunks(void *buf, struct scatter_walk *walk,
    #                              size_t nbytes, int out);
    # Bidirectional helper between a scatter-walk cursor and a linear
    # buffer. Stub no-op — keywrap's runtime never fires during load.
    return


# =====================================================================
# Group 3: ansi_cprng runtime — rng registration + diagnostics
# =====================================================================
#
# Linux:
#   int  crypto_register_rngs(struct rng_alg *algs, int count);
#   void crypto_unregister_rngs(struct rng_alg *algs, int count);
#   struct crypto_tfm *crypto_alloc_base(const char *alg_name,
#                                          u32 type, u32 mask);
#   void panic(const char *fmt, ...) __noreturn;
#   void print_hex_dump(const char *level, const char *prefix_str,
#                        int prefix_type, int rowsize, int groupsize,
#                        const void *buf, size_t len, bool ascii);
#
# ansi_cprng's init tail-jumps to crypto_register_rngs (returns 0 on
# success, walking the rng_algs array onto Linux's crypto-core PRNG
# registry). The base allocator + panic + print_hex_dump are all
# runtime-only: panic is the diagnostic when the PRNG state has been
# corrupted; print_hex_dump dumps key material during debug; crypto_
# alloc_base is the generic tfm allocator that ansi_cprng's reseed
# path calls into to get a "ctr(des)" or similar cipher.
#
# Stub strategy: rng_register/unregister mirrors L50's crypto_register_
# skciphers shape; crypto_alloc_base returns NULL (caller treats as
# -ENOMEM); panic logs + spins; print_hex_dump no-ops.

def _l_crypto_register_rngs(algs: uint64, count: int32) -> int32:
    # Real Linux: walks `algs[0..count)` onto the rng registry, runs
    # per-rng self-test if CRYPTO_ALG_TESTED is unset. Stub: validate
    # pointer and count, return 0.
    if algs == 0:
        return -22                                       # -EINVAL
    if count <= 0:
        return -22
    return 0


def _l_crypto_unregister_rngs(algs: uint64, count: int32):
    # void crypto_unregister_rngs(struct rng_alg *algs, int count);
    # Real Linux: removes each from the registry, decrements refcount.
    return


def _l_crypto_alloc_base(alg_name: uint64, atype: uint32,
                          mask: uint32) -> uint64:
    # struct crypto_tfm *crypto_alloc_base(const char *alg_name,
    #                                       u32 type, u32 mask);
    # Generic tfm allocator. Real Linux looks up `alg_name` in the
    # crypto-core registry, allocates and initialises a tfm. Stub
    # returns NULL — caller's IS_ERR_OR_NULL idiom treats as -ENOMEM.
    # No init path in this batch lands here.
    return 0


def _l_panic(fmt: uint64):
    # void panic(const char *fmt, ...) __noreturn;
    # Linux funnels through a controlled shutdown (panic_print, sysrq,
    # etc.). Hamnix has no panic infrastructure beyond printk0 + halt
    # loop; mirror the _linux_stack_chk_fail pattern from exports.ad.
    # `fmt` is the format string (variadic tail is dropped, fine for
    # the init-path use that never fires here).
    printk0("PANIC: ")
    if fmt != 0:
        printk0(cast[Ptr[char]](fmt))
    printk0("\n")
    while True:
        pass
    return


def _l_print_hex_dump(level: uint64, prefix_str: uint64,
                       prefix_type: int32, rowsize: int32,
                       groupsize: int32, buf: uint64,
                       len: uint64, ascii_flag: int32):
    # void print_hex_dump(const char *level, const char *prefix_str,
    #                      int prefix_type, int rowsize, int groupsize,
    #                      const void *buf, size_t len, bool ascii);
    # Debug-only formatter. Hamnix has no hex-dump helper yet — just
    # log the prefix so the trace shows the call site fired.
    if prefix_str != 0:
        printk0(cast[Ptr[char]](prefix_str))
    printk0("\n")
    return


# =====================================================================
# Group 4: AEAD core — register/unregister + grab + ops
# =====================================================================
#
# Linux signatures (include/crypto/aead.h, include/crypto/internal/aead.h):
#   int  crypto_register_aead(struct aead_alg *alg);
#   void crypto_unregister_aead(struct aead_alg *alg);
#   int  crypto_grab_aead(struct crypto_aead_spawn *spawn,
#                          struct crypto_instance *inst,
#                          const char *name, u32 type, u32 mask);
#   int  crypto_aead_setkey(struct crypto_aead *tfm,
#                            const u8 *key, unsigned int keylen);
#   int  crypto_aead_setauthsize(struct crypto_aead *tfm, unsigned int authsize);
#   int  crypto_aead_encrypt(struct aead_request *req);
#   int  crypto_aead_decrypt(struct aead_request *req);
#
# aegis128 / ccm / gcm all funnel through this surface. aegis128's init
# tail-jumps to crypto_register_aead with a single struct aead_alg;
# ccm's init registers three templates via crypto_register_templates
# (L50) but the templates' create() path calls crypto_grab_aead +
# inherits setkey/encrypt/decrypt pointers; gcm's init likewise.
#
# Stub strategy mirrors L51's crypto_register_alg singular pair and
# L50's crypto_register_aeads (if it existed): validate the pointer,
# return 0 on register, void on unregister, ops as success-shaped
# no-ops so the runtime relocations resolve.

def _l_crypto_register_aead(alg: uint64) -> int32:
    # Real Linux: pushes alg onto the AEAD registry, runs the per-aead
    # self-test if CRYPTO_ALG_TESTED is unset.
    if alg == 0:
        return -22
    return 0


def _l_crypto_unregister_aead(alg: uint64):
    # Real Linux: drops the aead from the registry, decrements refcount.
    return


def _l_crypto_grab_aead(spawn: uint64, inst: uint64,
                         name: uint64, atype: uint32, mask: uint32) -> int32:
    # int crypto_grab_aead(struct crypto_aead_spawn *spawn,
    #                      struct crypto_instance *inst,
    #                      const char *name, u32 type, u32 mask);
    # Look up an AEAD by name, bump its refcount into the spawn.
    # Mirror of L51's crypto_grab_spawn. Stub returns success (spawn
    # is left uninitialised — runtime paths that deref would fault,
    # but init never reaches them).
    return 0


def _l_crypto_aead_setkey(tfm: uint64, key: uint64, keylen: uint32) -> int32:
    # int crypto_aead_setkey(struct crypto_aead *tfm,
    #                         const u8 *key, unsigned int keylen);
    if tfm == 0:
        return -22
    if key == 0:
        return -22
    return 0


def _l_crypto_aead_setauthsize(tfm: uint64, authsize: uint32) -> int32:
    # int crypto_aead_setauthsize(struct crypto_aead *tfm,
    #                              unsigned int authsize);
    if tfm == 0:
        return -22
    return 0


def _l_crypto_aead_encrypt(req: uint64) -> int32:
    # int crypto_aead_encrypt(struct aead_request *req);
    # Stub returns 0 ("encryption complete"). Init never lands here.
    return 0


def _l_crypto_aead_decrypt(req: uint64) -> int32:
    # int crypto_aead_decrypt(struct aead_request *req);
    return 0


# =====================================================================
# Group 5: AEAD-adjacent — ahash setkey + skcipher_walk_aead variants
# =====================================================================
#
# Linux:
#   int crypto_ahash_setkey(struct crypto_ahash *tfm,
#                            const u8 *key, unsigned int keylen);
#   int skcipher_walk_aead_encrypt(struct skcipher_walk *walk,
#                                    struct aead_request *req, bool atomic);
#   int skcipher_walk_aead_decrypt(struct skcipher_walk *walk,
#                                    struct aead_request *req, bool atomic);
#
# ccm + gcm pull crypto_ahash_setkey for the ahash-keyed MAC half (CBC-
# MAC in ccm; GHASH in gcm). aegis128 + ccm use skcipher_walk_aead_*
# to iterate over the AEAD request's AAD+plaintext sg lists. All
# runtime; init in this batch never lands here.
#
# skcipher_walk_aead_* mirrors L50's skcipher_walk_virt shape — zero
# the first 64 bytes of the walk struct so the caller's `while (walk.
# nbytes)` loop exits immediately.

def _l_crypto_ahash_setkey(tfm: uint64, key: uint64, keylen: uint32) -> int32:
    # int crypto_ahash_setkey(struct crypto_ahash *tfm,
    #                          const u8 *key, unsigned int keylen);
    if tfm == 0:
        return -22
    if key == 0:
        return -22
    return 0


def _l_skcipher_walk_aead_encrypt(walk: uint64, req: uint64,
                                    atomic: int32) -> int32:
    # int skcipher_walk_aead_encrypt(struct skcipher_walk *walk,
    #                                 struct aead_request *req, bool atomic);
    # Zero the head of `walk` so the caller's nbytes-driven loop exits
    # immediately. Mirror of L50's skcipher_walk_virt stub.
    if walk != 0:
        p: Ptr[uint8] = cast[Ptr[uint8]](walk)
        i: uint64 = 0
        while i < 64:
            p[i] = 0
            i = i + 1
    return 0


def _l_skcipher_walk_aead_decrypt(walk: uint64, req: uint64,
                                    atomic: int32) -> int32:
    # int skcipher_walk_aead_decrypt(struct skcipher_walk *walk,
    #                                 struct aead_request *req, bool atomic);
    if walk != 0:
        p: Ptr[uint8] = cast[Ptr[uint8]](walk)
        i: uint64 = 0
        while i < 64:
            p[i] = 0
            i = i + 1
    return 0


# =====================================================================
# Group 6: scatterlist init + AES T-table data
# =====================================================================
#
# Linux:
#   void sg_init_table(struct scatterlist *sgl, unsigned int nents);
#   extern const u32 crypto_ft_tab[4][256];   # exported by aes_generic.ko
#
# sg_init_table walks a fresh sgl array zeroing entries and setting
# the chain-or-end marker. ccm + gcm + aegis128 all use it to set up
# their internal AAD/plaintext sg lists. Stub: zero `nents` * 32 bytes
# at `sgl` (32 is the typical scatterlist size on x86_64 with
# CONFIG_DEBUG_SG disabled; aligns with the L50 sg_init_one shim).
#
# crypto_ft_tab is aes_generic.ko's forward-T-table (a 4 * 256 array
# of u32 = 4 KiB). aegis128.ko's runtime AES core EXPORT_SYMBOL_GPL
# references it for the table-lookup S-box step. Hamnix has no inter-
# module ksymtab lookup yet (aes_generic.ko itself is a candidate for
# a later L-track milestone), so the table ships here as a 4096-byte
# zero-filled buffer. Init-path callers only take the address (`lea
# crypto_ft_tab(%rip), %reg`); the runtime AES round dereferences each
# entry per encrypted byte, which init never performs.

def _l_sg_init_table(sgl: uint64, nents: uint32):
    # void sg_init_table(struct scatterlist *sgl, unsigned int nents);
    # Real Linux zeroes the entries and sets sg_mark_end(&sgl[nents-1]).
    # Stub clears `nents * 32` bytes — caller's later sg_next() finds
    # an end marker (well, finds a zero, which our _l_sg_next reports
    # as NULL — same effect).
    if sgl == 0:
        return
    if nents == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](sgl)
    total: uint64 = cast[uint64](nents) * 32
    i: uint64 = 0
    do:
        p[i] = 0
        i = i + 1
    while i < total


crypto_ft_tab_buf: Array[4096, uint8]


# =====================================================================
# Group 7: kernel virt<->phys conversion bases (DATA symbols)
# =====================================================================
#
# Linux: extern unsigned long page_offset_base;
#        extern unsigned long phys_base;
#        extern unsigned long vmemmap_base;
#
# These are the three global address bases used by Linux's __pa() /
# __va() / pfn_to_page() macros. With KASLR enabled, arch/x86/mm/init_
# 64.c sets them once at boot and modules read them at runtime through
# the macro expansions.
#
# aegis128 / ccm / gcm reference them via kmap_local_page() and
# sg_virt() expansions inside the runtime sg-walk path. Init never
# reads them (init in this batch only registers algs/templates).
#
# Export strategy: a uint64 DATA slot each. Module relocations against
# the symbol patch in the *address* of the global, which the loader's
# linux_abi_lookup handles uniformly. The value is 0 — anything that
# tries to dereference through the resulting "physical address 0"
# would fault, but no init path in this batch does.

page_offset_base_data: uint64 = 0
phys_base_data:        uint64 = 0
vmemmap_base_data:     uint64 = 0


# =====================================================================
# Group 8: gcm-specific — default null skcipher + req_done + swait + alloc
# =====================================================================
#
# Linux:
#   struct crypto_sync_skcipher *crypto_get_default_null_skcipher(void);
#   void                          crypto_put_default_null_skcipher(void);
#   void crypto_req_done(void *req, int err);
#   void __init_swait_queue_head(struct swait_queue_head *q, const char *name,
#                                 struct lock_class_key *key);
#   void *__kmalloc_noprof(size_t size, gfp_t flags);
#
# gcm.ko reserves a singleton "null" skcipher (ECB-NULL) at module init
# for its IV-zero-fill path, sets up a swait_queue_head for async-
# completion synchronisation, and uses __kmalloc_noprof (size class
# beyond the 25 inline-cache buckets — see api_lib80211's
# __kmalloc_cache_noprof note) for any large allocations.
#
# Stub strategy:
#   * get_default_null_skcipher returns a static placeholder pointer so
#     the caller's NULL-check passes. put is a no-op.
#   * crypto_req_done is the standard async-completion callback —
#     usually `complete(req->base.data)`. No-op stub.
#   * __init_swait_queue_head zeroes the queue head (typical struct
#     swait_queue_head is 24 bytes on x86_64: list_head + raw_spinlock).
#   * __kmalloc_noprof is the non-inline-cache slab path; forward to
#     mm.slab.kmalloc, ignore the gfp_t (matches the _linux_kmalloc_
#     shim convention).

null_skcipher_placeholder: Array[64, uint8]


def _l_crypto_get_default_null_skcipher() -> uint64:
    # struct crypto_sync_skcipher *crypto_get_default_null_skcipher(void);
    # Real Linux maintains a refcounted singleton allocated lazily on
    # first call. Stub returns a static buffer's address so callers'
    # IS_ERR_OR_NULL check passes; subsequent dereferences (encrypt /
    # setkey through the null tfm) are unreachable from init.
    return cast[uint64](&null_skcipher_placeholder[0])


def _l_crypto_put_default_null_skcipher():
    # void crypto_put_default_null_skcipher(void);
    # Drops the singleton's refcount. Our singleton is static; no-op.
    return


def _l_crypto_req_done(req: uint64, err: int32):
    # void crypto_req_done(void *req, int err);
    # Default async-completion callback — typically signals a
    # completion attached to req->base.data. No-op stub.
    return


def _l___init_swait_queue_head(q: uint64, name: uint64, key: uint64):
    # void __init_swait_queue_head(struct swait_queue_head *q,
    #                               const char *name,
    #                               struct lock_class_key *key);
    # Initialises a simple-wait queue head. struct swait_queue_head on
    # 6.12 x86_64 is `raw_spinlock_t lock; struct list_head task_list;`
    # = 24 bytes. Stub zero-fills 32 bytes (slight slack covers any
    # CONFIG_DEBUG-driven layout change).
    if q == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](q)
    i: uint64 = 0
    while i < 32:
        p[i] = 0
        i = i + 1


def _l___kmalloc_noprof(size: uint64, flags: uint64) -> uint64:
    # void *__kmalloc_noprof(size_t size, gfp_t flags);
    # Non-inline-cache slab path. Forward to mm.slab.kmalloc; gfp_t is
    # ignored (matches the _linux_kmalloc_shim in exports.ad).
    return kmalloc(size)


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l53():
    # Called from linux_abi_exports_init() after L52's rows.
    # Adds 30 exports for the L53 batch:
    #   3 gf128mul 64k_bbe (lrw)
    #   2 scatterlist walking (keywrap + shared)
    #   5 ansi_cprng runtime + diagnostics
    #   7 AEAD core (register/unregister/grab/ops × 2 + setauthsize)
    #   3 AEAD-adjacent (ahash setkey + 2 skcipher_walk_aead variants)
    #   2 scatterlist init + AES T-table data
    #   3 kernel virt<->phys data slots
    #   5 gcm-specific (null skcipher + req_done + swait + __kmalloc_noprof)

    # Group 1: lrw runtime (gf128mul 64k_bbe)
    _add_export("gf128mul_init_64k_bbe",
                cast[uint64](&_l_gf128mul_init_64k_bbe))
    _add_export("gf128mul_free_64k",
                cast[uint64](&_l_gf128mul_free_64k))
    _add_export("gf128mul_64k_bbe",
                cast[uint64](&_l_gf128mul_64k_bbe))

    # Group 2: scatterlist walking
    _add_export("sg_next",
                cast[uint64](&_l_sg_next))
    _add_export("scatterwalk_copychunks",
                cast[uint64](&_l_scatterwalk_copychunks))

    # Group 3: ansi_cprng runtime + diagnostics
    _add_export("crypto_register_rngs",
                cast[uint64](&_l_crypto_register_rngs))
    _add_export("crypto_unregister_rngs",
                cast[uint64](&_l_crypto_unregister_rngs))
    _add_export("crypto_alloc_base",
                cast[uint64](&_l_crypto_alloc_base))
    _add_export("panic",
                cast[uint64](&_l_panic))
    _add_export("print_hex_dump",
                cast[uint64](&_l_print_hex_dump))

    # Group 4: AEAD core
    _add_export("crypto_register_aead",
                cast[uint64](&_l_crypto_register_aead))
    _add_export("crypto_unregister_aead",
                cast[uint64](&_l_crypto_unregister_aead))
    _add_export("crypto_grab_aead",
                cast[uint64](&_l_crypto_grab_aead))
    _add_export("crypto_aead_setkey",
                cast[uint64](&_l_crypto_aead_setkey))
    _add_export("crypto_aead_setauthsize",
                cast[uint64](&_l_crypto_aead_setauthsize))
    _add_export("crypto_aead_encrypt",
                cast[uint64](&_l_crypto_aead_encrypt))
    _add_export("crypto_aead_decrypt",
                cast[uint64](&_l_crypto_aead_decrypt))

    # Group 5: AEAD-adjacent (ahash setkey + skcipher_walk_aead)
    _add_export("crypto_ahash_setkey",
                cast[uint64](&_l_crypto_ahash_setkey))
    _add_export("skcipher_walk_aead_encrypt",
                cast[uint64](&_l_skcipher_walk_aead_encrypt))
    _add_export("skcipher_walk_aead_decrypt",
                cast[uint64](&_l_skcipher_walk_aead_decrypt))

    # Group 6: scatterlist init + AES T-table data
    _add_export("sg_init_table",
                cast[uint64](&_l_sg_init_table))
    _add_export("crypto_ft_tab",
                cast[uint64](&crypto_ft_tab_buf[0]))

    # Group 7: kernel virt<->phys bases (DATA)
    _add_export("page_offset_base",
                cast[uint64](&page_offset_base_data))
    _add_export("phys_base",
                cast[uint64](&phys_base_data))
    _add_export("vmemmap_base",
                cast[uint64](&vmemmap_base_data))


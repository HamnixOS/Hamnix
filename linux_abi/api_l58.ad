# linux_abi/api_l58.ad
#
# L58: shims for the ABI gap exposed by the Debian 6.12 FAT-family +
# isofs modules — vfat.ko, msdos.ko, exfat.ko, and isofs.ko.
#
# All four modules land on top of L57's fat.ko / __kmem_cache_create_args
# foundation. Their init paths are tiny:
#
#   vfat.ko::init_module      -> register_filesystem(&vfat_fs_type)
#   msdos.ko::init_module     -> register_filesystem(&msdos_fs_type)
#   exfat.ko::init_module     -> exfat_cache_init           # local
#                                  __kmem_cache_create_args  (L57)
#                                register_filesystem(&exfat_fs_type)
#   isofs.ko::init_module     -> __kmem_cache_create_args   (L57)
#                                zisofs_init                # local
#                                  zlib_inflate_workspacesize -> int
#                                  vmalloc_noprof(size)     (L54)
#                                register_filesystem(&isofs_fs_type)
#
# The vast majority of the UND symbols are reached only at mount /
# read / write time and exist purely so the .text and the static
# function-pointer tables in .data / .rodata can be relocated. The
# only init-path symbol that must do real work is
# `zlib_inflate_workspacesize` — zisofs_init checks the result is
# non-zero before vmalloc, so we hand back a small positive constant.
#
# UND analysis (`readelf -s --wide`, missing-after-L57):
#   vfat.ko    36 missing
#   msdos.ko   31 missing
#   exfat.ko   46 missing
#   isofs.ko   32 missing
#   union      100 unique
#
# Groups (init-critical first, then runtime-only filler):
#
#   Group 1: zlib runtime (isofs init-critical)
#     zlib_inflate_workspacesize, zlib_inflateInit2,
#     zlib_inflate, zlib_inflateEnd
#
#   Group 2: x86 retpoline thunks (always required to bind)
#     __x86_indirect_thunk_r10, __x86_indirect_thunk_r15
#
#   Group 3: x86 user-copy / arith helpers
#     __sw_hweight64
#
#   Group 4: fat.ko exported surface (vfat / msdos / exfat consume)
#     fat_add_entries, fat_alloc_new_dir, fat_attach, fat_build_inode,
#     fat_detach, fat_dir_empty, fat_fill_super, fat_flush_inodes,
#     fat_free_clusters, fat_free_fc, __fat_fs_error, fat_getattr,
#     fat_get_dotdot_entry, fat_init_fs_context, fat_param_spec (DATA),
#     fat_parse_param, fat_reconfigure, fat_remove_entries, fat_scan,
#     fat_search_long, fat_setattr, fat_sync_inode, fat_time_unix2fat,
#     fat_truncate_time, fat_update_time
#
#   Group 5: VFS super_block teardown / mount glue
#     kill_block_super, get_tree_bdev
#
#   Group 6: dentry helpers
#     d_drop, d_find_alias, d_move, d_rehash, d_splice_alias,
#     full_name_hash
#
#   Group 7: inode link-count helpers
#     clear_nlink, inc_nlink, drop_nlink, set_nlink (already L57),
#     init_special_inode, iget5_locked, iget_failed,
#     inode_set_ctime_current, inode_query_iversion, inode_newsize_ok,
#     inode_nohighmem, simple_rename_timestamp
#
#   Group 8: page-cache / folio helpers (runtime read/write)
#     pagecache_get_page, unlock_page, __folio_put, folio_end_read,
#     folio_zero_new_buffers, truncate_inode_pages,
#     filemap_fault, filemap_map_pages, filemap_page_mkwrite,
#     generic_ro_fops (DATA — generic read-only file_operations),
#     page_symlink_inode_operations (DATA)
#
#   Group 9: buffer_head + block runtime
#     __bh_read, __bh_read_batch, bh_uptodate_or_lock,
#     __sync_dirty_buffer, sync_blockdev, sync_blockdev_range,
#     bdev_freeze, bdev_thaw, block_write_begin,
#     __generic_file_write_iter, generic_write_checks,
#     vfs_fsync_range, balance_dirty_pages_ratelimited
#
#   Group 10: iov_iter / kvmalloc / page allocator
#     iov_iter_alignment, iov_iter_revert, iov_iter_zero,
#     __kvmalloc_node_noprof, kvfree, alloc_pages_noprof, __free_pages,
#     hugetlb_optimize_vmemmap_key (DATA — static_key),
#     devmap_managed_key (DATA — static_key),
#     __put_devmap_managed_folio_refs
#
#   Group 11: strings / utf / hex
#     kstrdup, memchr, memchr_inv, strncasecmp, hex2bin,
#     utf8s_to_utf16s, utf8_to_utf32, mktime64
#
#   Group 12: sync / cred / misc
#     down_write_trylock, touch_atime, cdrom_multisession,
#     cdrom_read_tocentry, make_kgid, make_kuid,
#     wrap_directory_iterator
#
# Stub philosophy (mirrors L57):
#   * Init-critical: zlib_inflate_workspacesize returns 4096 (any
#     positive int is enough — zisofs_init then vmalloc(4096) which
#     routes to kmalloc which our slab serves).
#   * Retpoline thunks: pop %rbp; jmpq *%reg (same as earlier L*).
#   * Every other shim is a no-op returning 0 / NULL / -EINVAL as
#     appropriate. None fire on the init path.
#   * DATA exports point at zero-buffers; readers of the data only
#     fire on mount/read/write (never in our env).
#
# Naming notes:
#   * Adder reserves `bytes` -> use `nbytes`.
#   * Adder reserves `file` -> use `filp` / `f`.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree


# =====================================================================
# Group 1: zlib runtime — isofs init-critical
# =====================================================================
#
# isofs's init_module calls zisofs_init, which does:
#
#   size = zlib_inflate_workspacesize();
#   ws = vmalloc(size);
#   if (!ws) return -ENOMEM;
#   ...
#
# The workspace pointer is stashed in a static and is only consulted
# at decompression time (zisofs mount). Return a small positive
# constant so vmalloc(size) doesn't degenerate to a zero-byte alloc.
#
# zlib_inflateInit2 / zlib_inflate / zlib_inflateEnd are reached only
# during actual decompression — stubs returning Z_OK / Z_STREAM_END
# (0 / 1) suffice for symbol binding.

L58_ZISOFS_WS_SIZE: uint64 = 4096


def _l_zlib_inflate_workspacesize() -> int32:
    # int zlib_inflate_workspacesize(void);
    # Real zlib returns sizeof(struct inflate_state) plus alignment,
    # roughly 9 KiB. Any positive value works — zisofs_init only checks
    # vmalloc() returned non-NULL afterwards.
    return cast[int32](L58_ZISOFS_WS_SIZE)


def _l_zlib_inflateInit2(strm: uint64, windowBits: int32) -> int32:
    # int zlib_inflateInit2(z_streamp strm, int windowBits);
    # Returns Z_OK = 0. Never fires in our env (no zisofs mount).
    return 0


def _l_zlib_inflate(strm: uint64, flush: int32) -> int32:
    # int zlib_inflate(z_streamp strm, int flush);
    # Returns Z_STREAM_END = 1 — the "done, no more input needed"
    # marker. Caller treats anything >= 0 as success.
    return 1


def _l_zlib_inflateEnd(strm: uint64) -> int32:
    # int zlib_inflateEnd(z_streamp strm);
    return 0


# =====================================================================
# Group 2: x86 retpoline thunks (r10, r15)
# =====================================================================

def _l___x86_indirect_thunk_r10():
    # Retpoline replacement for `call *%r10`.
    asm_volatile("""
        popq %rbp
        jmpq *%r10
    """)


def _l___x86_indirect_thunk_r15():
    # Retpoline replacement for `call *%r15`.
    asm_volatile("""
        popq %rbp
        jmpq *%r15
    """)


# =====================================================================
# Group 3: __sw_hweight64 — software popcount
# =====================================================================
#
# gcc emits __sw_hweight64 for `__builtin_popcountll` on builds that
# can't assume CONFIG_X86_FEATURE_POPCNT. exfat's allocation bitmap
# code uses it. Real implementation: 6-step parallel-reduction. We
# stub it to a real popcount via Adder-level shifts; init never
# touches the bitmap so 0 would also work, but a correct body is
# cheap to write.

def _l___sw_hweight64(w: uint64) -> uint64:
    # unsigned int __sw_hweight64(__u64 w);
    # Bit-twiddling popcount. Correct for any 64-bit input.
    w = w - ((w >> 1) & 0x5555555555555555)
    w = (w & 0x3333333333333333) + ((w >> 2) & 0x3333333333333333)
    w = (w + (w >> 4)) & 0x0f0f0f0f0f0f0f0f
    w = w + (w >> 8)
    w = w + (w >> 16)
    w = w + (w >> 32)
    return w & 0x7f


# =====================================================================
# Group 4: fat.ko's exported surface
# =====================================================================
#
# fat.ko in stock Linux exports ~40 functions; vfat/msdos/exfat consume
# the subset they call directly. In Hamnix, fat.ko was loaded as
# library-only (L57): its init returned 0 without registering any of
# these as kernel symbols. So vfat/msdos's relocations against the
# fat_* names hit linux_abi_lookup, and we stub each here.
#
# All entries below are reached only on a real FAT mount (which Hamnix
# never performs — fs/fat32_*.ad is the native driver). The function-
# pointer slots in struct file_system_type / fs_context_operations /
# fat_*_inode_operations carry these addresses without ever invoking
# them. Stub bodies returning 0 / NULL bind cleanly.

def _l_fat_add_entries(dir: uint64, slots: uint64, nr_slots: int32,
                        sinfo: uint64) -> int32:
    # int fat_add_entries(struct inode *dir, void *slots, int nr_slots,
    #                      struct fat_slot_info *sinfo);
    return 0


def _l_fat_alloc_new_dir(dir: uint64, ts: uint64) -> int32:

    return kmalloc(size)


def _l_kvfree(addr: uint64):
    # void kvfree(const void *addr);
    if addr == 0:
        return
    kfree(addr)


def _l_alloc_pages_noprof(gfp_mask: uint32, order: uint32) -> uint64:
    # struct page *alloc_pages_noprof(gfp_t gfp_mask, unsigned int order);
    # Forward to kmalloc with order-shifted size. Stub paths never deref
    # the result as a struct page.
    size: uint64 = cast[uint64](4096) << cast[uint64](order)
    return kmalloc(size)


def _l___free_pages(page: uint64, order: uint32):
    # void __free_pages(struct page *page, unsigned int order);
    if page == 0:
        return
    kfree(page)



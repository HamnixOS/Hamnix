def linux_abi_register_l58():
    # Called from linux_abi_exports_init() after the L57 fat.ko rows.
    # Adds 100 new exports for the FAT-family + isofs batch.

    # ---- Group 1: zlib runtime (isofs init-critical) ----
    _add_export("zlib_inflate_workspacesize",
                cast[uint64](&_l_zlib_inflate_workspacesize))

# DATA exports — static_key structs, 16 bytes each in Linux. Real
# Linux defines them with DEFINE_STATIC_KEY_FALSE; the load-time test
# expands to `if (static_branch_unlikely(&key))` which jumps over the
# slow path. With a zero key the branch is taken to "false" — exactly
# what we want for stub-only paths.
hugetlb_optimize_vmemmap_key_buf: Array[16, uint8]
devmap_managed_key_buf:           Array[16, uint8]


# =====================================================================
# Group 11: strings / utf / hex / time conversion
# =====================================================================

def _l_kstrdup(s: uint64, gfp: uint32) -> uint64:
    # char *kstrdup(const char *s, gfp_t gfp);
    # Stub: never called on init path. Return NULL — well-defined per
    # Linux semantics for NULL input. The runtime callers must handle
    # NULL returns from kstrdup.
    return 0


def _l_memchr(s: uint64, c: int32, n: uint64) -> uint64:
    # void *memchr(const void *s, int c, size_t n);
    if s == 0 or n == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    needle: uint8 = cast[uint8](c & 0xff)
    i: uint64 = 0
    while i < n:
        if p[i] == needle:
            return s + i
        i = i + 1
    return 0


def _l_memchr_inv(s: uint64, c: int32, n: uint64) -> uint64:
    # void *memchr_inv(const void *s, int c, size_t n);
    # Find the first byte that is NOT `c`, or NULL if all bytes match.
    if s == 0 or n == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    target: uint8 = cast[uint8](c & 0xff)
    i: uint64 = 0
    while i < n:
        if p[i] != target:
            return s + i
        i = i + 1
    return 0


def _l_strncasecmp(s1: uint64, s2: uint64, n: uint64) -> int32:
    # int strncasecmp(const char *s1, const char *s2, size_t n);
    # ASCII-only fold. Sufficient for isofs's UDF-vs-ISO format detect
    # comparisons against compile-time constants like "CD001".
    if n == 0:
        return 0
    a: Ptr[uint8] = cast[Ptr[uint8]](s1)
    b: Ptr[uint8] = cast[Ptr[uint8]](s2)
    i: uint64 = 0
    while i < n:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        # Lowercase fold: 'A'..'Z' -> +32
        if ca >= 65 and ca <= 90:
            ca = ca + 32
        if cb >= 65 and cb <= 90:
            cb = cb + 32
        if ca != cb:
            return cast[int32](ca) - cast[int32](cb)
        if ca == 0:
            return 0
        i = i + 1
    return 0


def _l_hex2bin(dst: uint64, src: uint64, count: uint64) -> int32:
    # int hex2bin(u8 *dst, const char *src, size_t count);
    return 0


def _l_utf8s_to_utf16s(s: uint64, inlen: int32, endian: int32,
                        pwcs: uint64, maxout: int32) -> int32:
    # int utf8s_to_utf16s(const u8 *s, int inlen, enum utf16_endian,
    #                      wchar_t *pwcs, int maxout);
    return 0


def _l_utf8_to_utf32(s: uint64, inlen: int32, pu: uint64) -> int32:
    # int utf8_to_utf32(const u8 *s, int inlen, unicode_t *pu);
    return 0


def _l_mktime64(year: uint32, mon: uint32, day: uint32,
                 hour: uint32, min: uint32, sec: uint32) -> uint64:

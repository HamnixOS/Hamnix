# linux_abi/api_tg3.ad
#
# Multi-NIC scale-out (round 2), Broadcom NetXtreme (tg3.ko) leg —
# ubiquitous on Dell/HP servers and workstations. The stock Debian
# tg3.ko has 199 UND symbols; 173 are already exported by L1..L68 +
# api_e1000e + api_r8169 + api_igb + api_alx + api_atlantic +
# api_sky2. This file closes the remaining 26-symbol gap.
#
# Categories:
#   * 6 PHY library — phy_connect, phy_ethtool_ksettings_{get,set},
#                      phy_mii_ioctl, phy_validate_pause,
#                      phy_get_pause (handled by api_r8169 already)
#   * 5 MDIO bus    — mdiobus_alloc_size, mdiobus_free,
#                      __mdiobus_register, mdiobus_unregister,
#                      (mdiobus_read/write already by api_r8169)
#   * 3 sk_buff     — build_skb, slab_build_skb, __napi_alloc_frag_align
#   * 2 hwmon       — hwmon_device_register_with_groups,
#                      hwmon_device_unregister
#   * 4 PCI         — pci_dev_present, pci_get_slot,
#                      pcie_capability_clear_and_set_word_unlocked,
#                      (pci_ioremap_bar already by api_alx)
#   * 3 PCI VPD     — pci_vpd_alloc, pci_vpd_check_csum,
#                      pci_vpd_find_ro_info_keyword
#   * 1 PTP         — ptp_schedule_worker
#   * 1 bitmap      — __bitmap_equal
#   * 1 netdev      — netif_get_num_default_rss_queues
#   * 1 netdev MAC  — device_get_mac_address
#   * 1 page-frag   — page_frag_free
#   * 1 netdev_pk   — netdev_notice
#
# Stub philosophy: every shim is init-cold. tg3's probe runs
# alloc_etherdev + register_netdev + mdiobus_alloc/register +
# phy_connect + hwmon_device_register. Anything beyond probe (TX/RX,
# PTP, real PHY link-up, ethtool) is gated behind a packet path that
# doesn't fire at insmod in our env.
#
# Prefix: "_tg3_".

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree, kzalloc

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


# =====================================================================
# DATA buffers
# =====================================================================

# hwmon device stub — same shape as the atlantic hwmon shim.
tg3_hwmon_dev_stub: Array[64, uint8]


# =====================================================================
# Group 1: PHY library extensions
# =====================================================================
#
# tg3 wires its internal/external PHY through libphy. api_r8169 ships
# most of the PHY surface already (phy_start/stop/init_hw/...) — this
# batch adds the half-dozen tg3 references not covered there.

def _tg3_phy_connect(dev: uint64, bus_id: Ptr[char], handler: uint64,
                      interface: int32) -> uint64:
    # struct phy_device *phy_connect(struct net_device *, const char
    #                                  *bus_id, void (*handler)(struct
    #                                  net_device *), phy_interface_t);
    # Higher-level wrapper around phy_attach_direct + phy_connect_direct.
    # We have no real PHY; return NULL so the caller's IS_ERR_OR_NULL
    # check trips and tg3 falls into its non-phylib internal-PHY arm.
    return 0


def _tg3_phy_ethtool_ksettings_get(phydev: uint64, cmd: uint64) -> int32:
    # int phy_ethtool_ksettings_get(struct phy_device *,
    #                                 struct ethtool_link_ksettings *);
    # ethtool `-s` getter. Init-cold. (Note: api_r8169 ships
    # `phy_ethtool_get_link_ksettings` with a slightly different name —
    # the _ksettings_ infix variant is what tg3 + many newer drivers
    # link against.)
    return -524                                       # -ENOTSUPP


def _tg3_phy_ethtool_ksettings_set(phydev: uint64, cmd: uint64) -> int32:
    # int phy_ethtool_ksettings_set(...);
    return -524


def _tg3_phy_mii_ioctl(phydev: uint64, mii_data: uint64, cmd: int32) -> int32:
    # int phy_mii_ioctl(struct phy_device *, struct ifreq *, int cmd);
    # Forwards a SIOC{G,S}MII* ioctl to the PHY. Init-cold.
    return 0


def _tg3_phy_validate_pause(phydev: uint64, pp: uint64) -> int32:
    # int phy_validate_pause(struct phy_device *,
    #                          struct ethtool_pauseparam *);
    # Sanity-checks the pause parameters against the PHY's supported
    # set. No PHY; pass-through success.
    return 0


# =====================================================================
# Group 2: MDIO bus allocation / register
# =====================================================================
#
# api_r8169 ships mdiobus_read/write + __devm_mdiobus_register +
# devm_mdiobus_alloc_size. tg3 calls the non-devm flavour
# (mdiobus_alloc_size + __mdiobus_register + mdiobus_unregister +
# mdiobus_free) and the bare alloc_size. Same backing alloc as the
# devm variant.

def _tg3_mdiobus_alloc_size(sz: uint64) -> uint64:
    # struct mii_bus *mdiobus_alloc_size(size_t sizeof_priv);
    # Allocates struct mii_bus + `sz` trailing priv bytes. The real
    # struct mii_bus is ~512 bytes; we hand back kzalloc(1 KiB + sz)
    # mirroring the devm shim in api_r8169.
    total: uint64 = 1024
    total = total + sz
    return kzalloc(total)


def _tg3_mdiobus_free(bus: uint64):
    # void mdiobus_free(struct mii_bus *);
    if bus != 0:
        kfree(bus)


def _tg3___mdiobus_register(bus: uint64, owner: uint64) -> int32:
    # int __mdiobus_register(struct mii_bus *, struct module *);
    # Same contract as __devm_mdiobus_register in api_r8169 — registers
    # the bus + triggers PHY scan. No bus to talk to; success.
    return 0


def _tg3_mdiobus_unregister(bus: uint64):
    # void mdiobus_unregister(struct mii_bus *);
    return


# =====================================================================
# Group 3: sk_buff additions
# =====================================================================

def _tg3_build_skb(data: uint64, frag_size: uint32) -> uint64:
    # struct sk_buff *build_skb(void *data, unsigned int frag_size);
    # Wraps a caller-supplied data buffer in an sk_buff. The real
    # implementation kmem_cache_allocates the skb head and fills in
    # head/data/end pointers to the supplied buffer. We approximate
    # with a kzalloc'd skb header that points at `data`.
    if data == 0:
        return 0
    SKB_HEADER: uint64 = 512
    skb: uint64 = kzalloc(SKB_HEADER)
    if skb == 0:
        return 0
    # skb->head, skb->data — match the e1000e layout convention used
    # in api_e1000e's __netdev_alloc_skb (head/data at +0xc8/+0xd0).
    p: Ptr[uint64] = cast[Ptr[uint64]](skb + 0xc8)
    p[0] = data
    p2: Ptr[uint64] = cast[Ptr[uint64]](skb + 0xd0)
    p2[0] = data
    return skb


def _tg3_slab_build_skb(data: uint64) -> uint64:
    # struct sk_buff *slab_build_skb(void *data);
    # Like build_skb but knows `data` came from the slab (so it skips
    # the frag-truesize bookkeeping). Same backing alloc.
    return _tg3_build_skb(data, 0)


def _tg3_napi_alloc_frag_align(napi: uint64, fragsz: uint32,
                                 align_mask: uint64) -> uint64:
    # void *__napi_alloc_frag_align(unsigned int fragsz, unsigned int
    #                                 align_mask);
    # Allocates `fragsz` bytes of NAPI-rx-cached memory, aligned. We
    # don't run the page-frag cache; just kzalloc.
    return kzalloc(cast[uint64](fragsz))


# =====================================================================
# Group 4: hwmon (non-devm variants)
# =====================================================================
#
# api_igb ships devm_hwmon_device_register_with_groups (the devm
# variant); tg3 uses the plain non-devm form. Same backing stub.

def _tg3_hwmon_device_register_with_groups(dev: uint64,
                                             name: Ptr[char],
                                             drvdata: uint64,
                                             groups: uint64) -> uint64:
    # struct device *hwmon_device_register_with_groups(struct device *,
    #                                                    const char *name,
    #                                                    void *drvdata,
    #                                                    const struct
    #                                                    attribute_group
    #                                                    **groups);
    return cast[uint64](&tg3_hwmon_dev_stub[0])


def _tg3_hwmon_device_unregister(dev: uint64):
    # void hwmon_device_unregister(struct device *);
    return


# =====================================================================
# Group 5: PCI extensions
# =====================================================================

def _tg3_pci_dev_present(ids: uint64) -> int32:
    # int pci_dev_present(const struct pci_device_id *ids);
    # Walks the global pci_dev list looking for a match against `ids`.
    # tg3 calls this from its quirk-bypass path; returning false (the
    # specific quirky device isn't present) keeps the driver on the
    # standard path.
    return 0


def _tg3_pci_get_slot(bus: uint64, devfn: uint32) -> uint64:
    # struct pci_dev *pci_get_slot(struct pci_bus *, unsigned int devfn);
    # Returns a refcounted pci_dev * (caller must put_device). Returns
    # NULL == "no device at that slot". tg3 uses this to peek at a
    # parent bridge's quirks; NULL drops the quirk path.
    return 0


def _tg3_pcie_cap_clear_and_set_word_unlocked(pdev: uint64, pos: int32,
                                                clear: uint16,
                                                set_bits: uint16) -> int32:
    # int pcie_capability_clear_and_set_word_unlocked(struct pci_dev *,
    #                                                   int pos, u16 clear,
    #                                                   u16 set);
    # Unlocked variant of pcie_capability_clear_and_set_word (the
    # locked form is shipped by api_e1000e). Same shim — return 0
    # (no PCIe config access; assume the bits were "applied").
    return 0


# =====================================================================
# Group 6: PCI VPD allocator family
# =====================================================================
#
# api_sky2 ships pci_read_vpd_any / pci_write_vpd_any (the byte-level
# accessors). tg3 uses the higher-level allocator + checksum + RO-info
# helpers, which sit on top of the byte accessors. With no VPD region
# in our env, all three return "no VPD" outcomes.

def _tg3_pci_vpd_alloc(pdev: uint64, sizep: uint64) -> uint64:
    # void *pci_vpd_alloc(struct pci_dev *, unsigned int *size);
    # Allocates + reads the entire VPD region into a buffer. We have
    # no VPD; return an ERR_PTR(-ENODEV) cookie (one of the predefined
    # MAX_ERRNO values — 0xfffffffffffffff5 == -ENODEV cast to ptr).
    # tg3 IS_ERR()-checks the result and falls back to no-VPD probe.
    if sizep != 0:
        sp: Ptr[uint32] = cast[Ptr[uint32]](sizep)
        sp[0] = 0
    return 0xffffffffffffffed                          # -ENODEV ERR_PTR


def _tg3_pci_vpd_check_csum(buf: uint64, size: uint64) -> int32:
    # int pci_vpd_check_csum(const void *vpd, size_t size);
    # Validates the VPD region's checksum byte. We never returned a
    # valid VPD pointer; this won't be called on the success path,
    # but the relocation must resolve. -EINVAL for "no valid VPD".
    return -22                                         # -EINVAL


def _tg3_pci_vpd_find_ro_info_keyword(buf: uint64, len: uint64,
                                        kw: Ptr[char],
                                        size: uint64) -> int32:
    # int pci_vpd_find_ro_info_keyword(const void *buf, unsigned int
    #                                    len, const char *kw, unsigned
    #                                    int *size);
    # Locates the offset of a 2-byte VPD keyword (e.g. "MN", "PN") in
    # the buffer's RO area. Returns -ENOENT == keyword not found.
    return -2                                          # -ENOENT


# =====================================================================
# Group 7: PTP worker scheduler
# =====================================================================

def _tg3_ptp_schedule_worker(ptp: uint64, delay: uint64) -> int32:
    # int ptp_schedule_worker(struct ptp_clock *, unsigned long delay);
    # Schedules the PTP aux work item. No PTP active in our env;
    # success (== "queued").
    return 0


# =====================================================================
# Group 8: misc
# =====================================================================

def _tg3_bitmap_equal(bitmap1: uint64, bitmap2: uint64, nbits: uint32) -> int32:
    # int __bitmap_equal(const unsigned long *bitmap1, const unsigned
    #                      long *bitmap2, unsigned int nbits);
    # Word-by-word equality (with a partial-word mask on the tail).
    # tg3 uses it for per-port queue-mask comparisons. We're called
    # with sane pointers (driver-owned local stacks).
    if bitmap1 == 0 or bitmap2 == 0:
        return 0
    if bitmap1 == bitmap2:
        return 1
    # Word-by-word compare. nbits is the bit count; round up to 64.
    nwords: uint32 = (nbits + 63) >> 6
    p1: Ptr[uint64] = cast[Ptr[uint64]](bitmap1)
    p2: Ptr[uint64] = cast[Ptr[uint64]](bitmap2)
    i: uint64 = 0
    while i < cast[uint64](nwords):
        if p1[i] != p2[i]:
            return 0
        i = i + 1
    return 1


def _tg3_netif_get_num_default_rss_queues() -> uint32:
    # unsigned int netif_get_num_default_rss_queues(void);
    # Returns the kernel's RSS-queue default. Single-CPU env -> 1.
    return 1


def _tg3_device_get_mac_address(dev: uint64, mac: uint64) -> int32:
    # int device_get_mac_address(struct device *dev, char *mac);
    # Reads a MAC address from device tree / EFI variables / ACPI
    # _DSM. Not wired; -ENODEV makes tg3 fall back to its EEPROM-read
    # path.
    return -19                                         # -ENODEV


def _tg3_page_frag_free(addr: uint64):
    # void page_frag_free(void *addr);
    # Frees a buffer obtained from __page_frag_cache_drain /
    # napi_alloc_frag. We back fragments with kzalloc; mirror that
    # with kfree. NULL-safe.
    if addr == 0:
        return
    kfree(addr)


def _tg3_netdev_notice(dev: uint64, fmt: Ptr[char]) -> int32:
    # int netdev_notice(const struct net_device *, const char *fmt, ...);
    # Same convention as netdev_err / netdev_printk in the e1000e +
    # r8169 batches.
    printk0("[netdev_notice] ")
    printk0(fmt)
    printk0("\n")
    return 0


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_tg3():
    # 26 new exports beyond api_e1000e + api_r8169 + api_igb + api_alx
    # + api_atlantic + api_sky2.

    # ---- Group 1: PHY library extensions ----
    _add_export("phy_connect",
                cast[uint64](&_tg3_phy_connect))
    _add_export("phy_ethtool_ksettings_get",
                cast[uint64](&_tg3_phy_ethtool_ksettings_get))
    _add_export("phy_ethtool_ksettings_set",
                cast[uint64](&_tg3_phy_ethtool_ksettings_set))
    _add_export("phy_mii_ioctl",
                cast[uint64](&_tg3_phy_mii_ioctl))
    _add_export("phy_validate_pause",
                cast[uint64](&_tg3_phy_validate_pause))

    # ---- Group 2: MDIO bus (non-devm) ----
    _add_export("mdiobus_alloc_size",
                cast[uint64](&_tg3_mdiobus_alloc_size))
    _add_export("mdiobus_free",
                cast[uint64](&_tg3_mdiobus_free))
    _add_export("__mdiobus_register",
                cast[uint64](&_tg3___mdiobus_register))
    _add_export("mdiobus_unregister",
                cast[uint64](&_tg3_mdiobus_unregister))

    # ---- Group 3: sk_buff ----
    _add_export("build_skb",
                cast[uint64](&_tg3_build_skb))
    _add_export("slab_build_skb",
                cast[uint64](&_tg3_slab_build_skb))
    _add_export("__napi_alloc_frag_align",
                cast[uint64](&_tg3_napi_alloc_frag_align))

    # ---- Group 4: hwmon (non-devm) ----
    _add_export("hwmon_device_register_with_groups",
                cast[uint64](&_tg3_hwmon_device_register_with_groups))
    _add_export("hwmon_device_unregister",
                cast[uint64](&_tg3_hwmon_device_unregister))

    # ---- Group 5: PCI extensions ----
    _add_export("pci_dev_present",
                cast[uint64](&_tg3_pci_dev_present))
    _add_export("pci_get_slot",
                cast[uint64](&_tg3_pci_get_slot))
    _add_export("pcie_capability_clear_and_set_word_unlocked",
                cast[uint64](&_tg3_pcie_cap_clear_and_set_word_unlocked))

    # ---- Group 6: PCI VPD ----
    _add_export("pci_vpd_alloc",
                cast[uint64](&_tg3_pci_vpd_alloc))
    _add_export("pci_vpd_check_csum",
                cast[uint64](&_tg3_pci_vpd_check_csum))
    _add_export("pci_vpd_find_ro_info_keyword",
                cast[uint64](&_tg3_pci_vpd_find_ro_info_keyword))

    # ---- Group 7: PTP ----
    _add_export("ptp_schedule_worker",
                cast[uint64](&_tg3_ptp_schedule_worker))

    # ---- Group 8: misc ----
    _add_export("__bitmap_equal",
                cast[uint64](&_tg3_bitmap_equal))
    _add_export("netif_get_num_default_rss_queues",
                cast[uint64](&_tg3_netif_get_num_default_rss_queues))
    _add_export("device_get_mac_address",
                cast[uint64](&_tg3_device_get_mac_address))
    _add_export("page_frag_free",
                cast[uint64](&_tg3_page_frag_free))
    _add_export("netdev_notice",
                cast[uint64](&_tg3_netdev_notice))

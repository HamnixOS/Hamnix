# linux_abi/api_strings.ad
#
# Linux-ABI string-and-memory shims. These are the bread-and-butter
# helpers that virtually every stock .ko module references via UND
# symbols — sprintf, snprintf, strlen, strcmp, strncmp, strncpy,
# strncat, strchr, strrchr, strstr, memmove, memset, memcmp.
#
# In a real Linux build most of these resolve to lib/string.c (or
# arch-specific asm) and are EXPORT_SYMBOL'd. Without this module our
# l_track_status scan flags them as unresolved against any L-track
# fixture whose .c source touches a printf-family format string or
# does any kind of string comparison. That's almost every fixture.
#
# Implementation strategy:
#
# - The "mem*" family wraps the existing C-runtime memcpy/memset
#   externs (the same ones api_random.ad and loader.ad pull in).
#   memmove gets a small overlap-safe loop; memcmp is a byte-wise
#   compare. We deliberately don't shell out to the C-runtime
#   memmove/memcmp because some Hamnix toolchain configurations
#   don't link them, and a hand-rolled loop is fast enough for
#   the modest buffers these L-track fixtures push (<4 KiB).
#
# - The "str*" family is implemented in-place (no extern calls) so
#   they remain self-contained — every L-track .ko picks them up
#   without dragging in additional unresolved symbols.
#
# - sprintf / snprintf are deliberately minimal: only %s, %d, %u,
#   %x, %p, and %c are honored, with at most ONE arg substitution.
#   The Linux kernel itself uses vsnprintf with a full formatter,
#   but the .ko fixtures in this repo only feed simple banners like
#   "module %s loaded" or "got %d bytes". A future milestone can
#   replace this with a real vsnprintf if a fixture demands it.
#   '%%' (literal percent) is also supported.
#
# - Return values match Linux contract:
#     sprintf  -> total bytes written, NOT including the trailing NUL
#     snprintf -> bytes that WOULD HAVE been written (Linux >=2.0.6),
#                 capped at size-1; trailing NUL always planted if
#                 size > 0.
#     strlen   -> length without NUL
#     strcmp   -> <0, 0, >0
#     strncmp  -> <0, 0, >0
#     strncpy  -> dst (pads with NULs up to n; Linux semantics)
#     strncat  -> dst (appends at most n bytes, always NUL-terminates)
#     strchr   -> pointer to first occurrence, or NULL
#     strrchr  -> pointer to last occurrence, or NULL
#     strstr   -> pointer to first occurrence of needle, or NULL
#     memmove  -> dst
#     memset   -> dst
#     memcmp   -> <0, 0, >0
#
# All return-by-pointer shims return uint64 (the loader treats all
# return values as 8-byte slots; modules cast back to char* / void*).

from linux_abi.exports import _add_export


# ---------------------------------------------------------------------
# strlen / strcmp / strncmp
# ---------------------------------------------------------------------

def _l_strlen(s: uint64) -> uint64:
    # size_t strlen(const char *s);
    # NULL-safe: strlen(NULL) returns 0 (Linux's strlen segfaults on
    # NULL but a defensive zero here makes accidental misuse from a
    # buggy module fail safe rather than crash the kernel).
    if s == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    n: uint64 = 0
    while p[n] != 0:
        n = n + 1
    return n


def _l_strcmp(a: uint64, b: uint64) -> int32:
    # int strcmp(const char *a, const char *b);
    # Same-pointer fast path; NULL handling mirrors strlen above.
    if a == b:
        return 0
    if a == 0:
        return -1
    if b == 0:
        return 1
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pb: Ptr[uint8] = cast[Ptr[uint8]](b)
    i: uint64 = 0
    while True:
        ca: uint8 = pa[i]
        cb: uint8 = pb[i]
        if ca != cb:
            if ca < cb:
                return -1
            return 1
        if ca == 0:
            return 0
        i = i + 1
    return 0


def _l_strncmp(a: uint64, b: uint64, n: uint64) -> int32:
    # int strncmp(const char *a, const char *b, size_t n);
    if n == 0:
        return 0
    if a == b:
        return 0
    if a == 0:
        return -1
    if b == 0:
        return 1
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pb: Ptr[uint8] = cast[Ptr[uint8]](b)
    i: uint64 = 0
    while i < n:
        ca: uint8 = pa[i]
        cb: uint8 = pb[i]
        if ca != cb:
            if ca < cb:
                return -1
            return 1
        if ca == 0:
            return 0
        i = i + 1
    return 0


# ---------------------------------------------------------------------
# strncpy / strncat
# ---------------------------------------------------------------------

def _l_strncpy(dst: uint64, src: uint64, n: uint64) -> uint64:
    # char *strncpy(char *dst, const char *src, size_t n);
    # Linux semantics: copies up to n bytes; if src is shorter than n,
    # the remaining bytes of dst are zero-filled. If src is longer
    # than n, dst is NOT NUL-terminated.
    if dst == 0 or n == 0:
        return dst
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    if src == 0:
        # NULL src — zero-fill dst to n bytes, matching the "src
        # exhausted" branch of the loop.
        i: uint64 = 0
        while i < n:
            pd[i] = 0
            i = i + 1
        return dst
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    i: uint64 = 0
    src_done: int32 = 0
    while i < n:
        if src_done == 0:
            c: uint8 = ps[i]
            pd[i] = c
            if c == 0:
                src_done = 1
        else:
            pd[i] = 0
        i = i + 1
    return dst


def _l_strncat(dst: uint64, src: uint64, n: uint64) -> uint64:
    # char *strncat(char *dst, const char *src, size_t n);
    # Append at most n bytes from src; always NUL-terminate. Differs
    # from strncpy in that the trailing NUL is unconditional.
    if dst == 0 or src == 0 or n == 0:
        return dst
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    # Walk to end of dst.
    dlen: uint64 = 0
    while pd[dlen] != 0:
        dlen = dlen + 1
    # Copy up to n bytes or until src NUL.
    i: uint64 = 0
    while i < n:
        c: uint8 = ps[i]
        if c == 0:
            pd[dlen + i] = 0
            return dst
        pd[dlen + i] = c
        i = i + 1
    # n exhausted without hitting src's NUL; plant our own.
    pd[dlen + n] = 0
    return dst


# ---------------------------------------------------------------------
# strchr / strrchr / strstr
# ---------------------------------------------------------------------

def _l_strchr(s: uint64, c: int32) -> uint64:
    # char *strchr(const char *s, int c);
    # Returns pointer to first occurrence of (char)c, or NULL. Per
    # standard, if c == '\0' the returned pointer is to the trailing
    # NUL itself (used as a "string end" trick).
    if s == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    target: uint8 = cast[uint8](c & 0xFF)
    i: uint64 = 0
    while True:
        cur: uint8 = p[i]
        if cur == target:
            return s + i
        if cur == 0:
            return 0
        i = i + 1
    return 0


def _l_strrchr(s: uint64, c: int32) -> uint64:
    # char *strrchr(const char *s, int c);
    # Returns pointer to last occurrence of (char)c, or NULL. Single
    # forward pass; remember the most-recent hit.
    if s == 0:
        return 0
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    target: uint8 = cast[uint8](c & 0xFF)
    last: uint64 = 0
    i: uint64 = 0
    while True:
        cur: uint8 = p[i]
        if cur == target:
            last = s + i
        if cur == 0:
            return last
        i = i + 1
    return last


def _l_strstr(hay: uint64, needle: uint64) -> uint64:
    # char *strstr(const char *haystack, const char *needle);
    # Empty needle returns haystack (POSIX). NULL inputs return NULL.
    if hay == 0 or needle == 0:
        return 0
    ph: Ptr[uint8] = cast[Ptr[uint8]](hay)
    pn: Ptr[uint8] = cast[Ptr[uint8]](needle)
    if pn[0] == 0:
        return hay
    i: uint64 = 0
    while ph[i] != 0:
        # Try to match needle starting at ph + i.
        j: uint64 = 0
        while True:
            nc: uint8 = pn[j]
            if nc == 0:
                return hay + i      # Full needle matched.
            hc: uint8 = ph[i + j]
            if hc == 0:
                return 0            # Hit haystack end mid-needle.
            if hc != nc:
                # break out of inner loop
                j = 0xFFFFFFFFFFFFFFFF
                # use a sentinel to mark "no match"; checked below
            if j == 0xFFFFFFFFFFFFFFFF:
                # restart at next haystack position
                # break inner
                # ad doesn't have `break`-out-of-nested labels here,
                # so we rely on the sentinel + outer i increment.
                # Force inner loop exit by setting j to a value the
                # while-true never returns from above (no NUL on nc).
                # Cleanest: exit inner via a conditional.
                # We mimic break by setting nc to NUL via the next
                # iteration's read. Simpler: explicit second test.
                j = 1
                # actually, just fall through and let outer advance:
                # we restructure below to avoid sentinel.
                pass
            j = j + 1
            # Bound: if j grows past haystack remainder we'll catch
            # it via the hc == 0 branch above.
        i = i + 1
    return 0


# The strstr above relies on a sentinel that's awkward; provide a
# cleaner secondary implementation and route the export to this one
# instead. Keeping the first as documentation of the naive approach.

def _l_strstr2(hay: uint64, needle: uint64) -> uint64:
    if hay == 0 or needle == 0:
        return 0
    ph: Ptr[uint8] = cast[Ptr[uint8]](hay)
    pn: Ptr[uint8] = cast[Ptr[uint8]](needle)
    if pn[0] == 0:
        return hay
    i: uint64 = 0
    while ph[i] != 0:
        j: uint64 = 0
        matched: int32 = 1
        while matched == 1:
            nc: uint8 = pn[j]
            if nc == 0:
                return hay + i
            hc: uint8 = ph[i + j]
            if hc == 0:
                return 0
            if hc != nc:
                matched = 0
            else:
                j = j + 1
        i = i + 1
    return 0


# ---------------------------------------------------------------------
# memmove / memset / memcmp
# ---------------------------------------------------------------------

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


def _l_memset(dst: uint64, val: int32, n: uint64) -> uint64:
    # void *memset(void *dst, int c, size_t n);
    if dst == 0 or n == 0:
        return dst
    memset(cast[Ptr[uint8]](dst), val, n)
    return dst


def _l_memmove(dst: uint64, src: uint64, n: uint64) -> uint64:
    # void *memmove(void *dst, const void *src, size_t n);
    # Overlap-safe: if dst > src and ranges overlap, copy backwards.
    if dst == 0 or src == 0 or n == 0:
        return dst
    if dst == src:
        return dst
    pd: Ptr[uint8] = cast[Ptr[uint8]](dst)
    ps: Ptr[uint8] = cast[Ptr[uint8]](src)
    if dst < src:
        # Forward copy is safe; delegate to memcpy.
        memcpy(pd, ps, n)
    else:
        # Backward copy.
        i: uint64 = n
        while i > 0:
            i = i - 1
            pd[i] = ps[i]
    return dst


def _l_memcmp(a: uint64, b: uint64, n: uint64) -> int32:
    # int memcmp(const void *a, const void *b, size_t n);
    if n == 0:
        return 0
    if a == b:
        return 0
    if a == 0:
        return -1
    if b == 0:
        return 1
    pa: Ptr[uint8] = cast[Ptr[uint8]](a)
    pb: Ptr[uint8] = cast[Ptr[uint8]](b)
    i: uint64 = 0
    while i < n:
        ca: uint8 = pa[i]
        cb: uint8 = pb[i]
        if ca != cb:
            if ca < cb:
                return -1
            return 1
        i = i + 1
    return 0


# ---------------------------------------------------------------------
# sprintf / snprintf (minimal)
# ---------------------------------------------------------------------
#
# These handle the common L-track fixture patterns:
#   "module %s loaded"
#   "got %d bytes"
#   "addr=%p"
#   "value=0x%x"
#
# Only ONE substitution is consumed from the variadic tail. The first
# variadic arg lands in %rsi (Linux x86_64 ABI) which our shim picks
# up as a uint64 named `arg1`. Subsequent %-conversions in the format
# string copy the literal characters as-is (so a two-arg printf will
# render the first arg and the second as text fallback). This is
# adequate for the L-track fixtures; a future milestone with real
# multi-arg fixtures will need full vsnprintf.
#
# A "writer" abstraction lets us share the inner loop between sprintf
# (unbounded) and snprintf (bounded). The writer is just a tiny state
# struct passed as four uint64s by reference: dst, size, pos, plus a
# return-count for snprintf's "would-have-been-written" semantics.

# Writer state offsets within a 32-byte stack-allocated descriptor.
WR_OFF_DST:   uint64 = 0     # uint64 dst pointer (0 = no write, count only)
WR_OFF_SIZE:  uint64 = 8     # uint64 size cap; 0xFFFFFFFFFFFFFFFF = unbounded
WR_OFF_POS:   uint64 = 16    # uint64 bytes written to dst so far (capped)
WR_OFF_TOTAL: uint64 = 24    # uint64 total bytes that WOULD have been written


def _wr_putc(wr: uint64, c: uint8):
    # Push one byte through the writer. Always increments TOTAL; only
    # writes to dst (and increments POS) if dst != 0 AND there's still
    # room under SIZE - 1 (we reserve the last byte for NUL).
    if wr == 0:
        return
    dst:   uint64 = cast[Ptr[uint64]](wr + WR_OFF_DST)[0]
    size:  uint64 = cast[Ptr[uint64]](wr + WR_OFF_SIZE)[0]
    pos:   uint64 = cast[Ptr[uint64]](wr + WR_OFF_POS)[0]
    total: uint64 = cast[Ptr[uint64]](wr + WR_OFF_TOTAL)[0]
    cast[Ptr[uint64]](wr + WR_OFF_TOTAL)[0] = total + 1
    if dst == 0:
        return
    # Reserve one byte for the trailing NUL (so cap is size - 1 unless
    # size is "unbounded" via 0xFFFFFFFFFFFFFFFF).
    if size != 0xFFFFFFFFFFFFFFFF:
        if pos + 1 >= size:
            return
    cast[Ptr[uint8]](dst + pos)[0] = c
    cast[Ptr[uint64]](wr + WR_OFF_POS)[0] = pos + 1


def _wr_puts(wr: uint64, s: uint64):
    # Write a NUL-terminated string to the writer. NULL becomes the
    # literal "(null)" — same convention printk uses.
    if s == 0:
        _wr_putc(wr, cast[uint8](40))      # '('
        _wr_putc(wr, cast[uint8](110))     # 'n'
        _wr_putc(wr, cast[uint8](117))     # 'u'
        _wr_putc(wr, cast[uint8](108))     # 'l'
        _wr_putc(wr, cast[uint8](108))     # 'l'
        _wr_putc(wr, cast[uint8](41))      # ')'
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](s)
    i: uint64 = 0
    while p[i] != 0:
        _wr_putc(wr, p[i])
        i = i + 1


def _wr_putu(wr: uint64, v: uint64):
    # Decimal-format an unsigned 64-bit value into the writer. We
    # build digits backwards in a 24-byte stack buffer (uint64 max is
    # 20 decimal digits) then flush forwards.
    buf: Array[24, uint8]
    n: uint64 = v
    idx: uint64 = 0
    if n == 0:
        _wr_putc(wr, cast[uint8](48))      # '0'
        return
    while n > 0:
        d: uint64 = n % 10
        buf[idx] = cast[uint8](48 + d)     # ASCII '0' + digit
        idx = idx + 1
        n = n / 10
    while idx > 0:
        idx = idx - 1
        _wr_putc(wr, buf[idx])


def _wr_putd(wr: uint64, v: int64):
    # Decimal-format a signed 64-bit value. Negative numbers get a
    # leading '-'. INT64_MIN edge case: negating it overflows in
    # two's complement, but reinterpreting as uint64 gives the
    # correct magnitude bit pattern for the digit extraction loop
    # (the LCG/printk style).
    n: int64 = v
    if n < 0:
        _wr_putc(wr, cast[uint8](45))      # '-'
        # Negate to get positive magnitude; cast through uint64
        # handles the INT64_MIN edge case correctly (the bit pattern
        # of -INT64_MIN is the same as 0x8000000000000000, whose
        # uint64 interpretation is the correct magnitude).
        _wr_putu(wr, cast[uint64](0 - n))
    else:
        _wr_putu(wr, cast[uint64](n))


def _wr_putx(wr: uint64, v: uint64):
    # Hex-format an unsigned 64-bit value (lowercase, no leading 0x).
    buf: Array[24, uint8]
    n: uint64 = v
    idx: uint64 = 0
    if n == 0:
        _wr_putc(wr, cast[uint8](48))      # '0'
        return
    while n > 0:
        d: uint64 = n & 0xF
        if d < 10:
            buf[idx] = cast[uint8](48 + d)        # '0'..'9'
        else:
            buf[idx] = cast[uint8](87 + d)        # 'a'..'f' (87 = 'a' - 10)
        idx = idx + 1
        n = n >> 4
    while idx > 0:
        idx = idx - 1
        _wr_putc(wr, buf[idx])


def _do_format(wr: uint64, fmt: uint64, arg1: uint64):
    # Walk the format string. On '%' look at the next char and
    # consume arg1 if needed. Only the FIRST %-conversion pulls from
    # arg1; subsequent ones get '?' as a placeholder (warning that a
    # multi-arg printf wasn't fully wired).
    if fmt == 0:
        return
    pf: Ptr[uint8] = cast[Ptr[uint8]](fmt)
    i: uint64 = 0
    arg_used: int32 = 0
    while pf[i] != 0:
        c: uint8 = pf[i]
        if c != cast[uint8](37):                   # not '%'
            _wr_putc(wr, c)
            i = i + 1
        else:
            spec: uint8 = pf[i + 1]
            if spec == 0:
                # Trailing lone '%' — emit literal and stop.
                _wr_putc(wr, c)
                return
            if spec == cast[uint8](37):            # '%%'
                _wr_putc(wr, cast[uint8](37))
            else:
                if arg_used == 0:
                    arg_used = 1
                    if spec == cast[uint8](115):   # 's'
                        _wr_puts(wr, arg1)
                    else:
                        if spec == cast[uint8](100):  # 'd'
                            _wr_putd(wr, cast[int64](arg1))
                        else:
                            if spec == cast[uint8](117):  # 'u'
                                _wr_putu(wr, arg1)
                            else:
                                if spec == cast[uint8](120):  # 'x'
                                    _wr_putx(wr, arg1)
                                else:
                                    if spec == cast[uint8](112):  # 'p'
                                        _wr_putc(wr, cast[uint8](48))   # '0'
                                        _wr_putc(wr, cast[uint8](120))  # 'x'
                                        _wr_putx(wr, arg1)
                                    else:
                                        if spec == cast[uint8](99):  # 'c'
                                            _wr_putc(wr, cast[uint8](arg1 & 0xFF))
                                        else:
                                            # Unknown spec: emit
                                            # literally as "%X".
                                            _wr_putc(wr, cast[uint8](37))
                                            _wr_putc(wr, spec)
                else:
                    # Second+ argument: placeholder '?'. A future
                    # fixture-driven milestone will extend this to
                    # carry arg2/arg3 (Linux ABI: %rdx, %rcx) and a
                    # vararg-walking pointer for the rest.
                    _wr_putc(wr, cast[uint8](63))   # '?'
            i = i + 2


def _l_sprintf(buf: uint64, fmt: uint64, arg1: uint64) -> int32:
    # int sprintf(char *buf, const char *fmt, ...);
    # Returns number of bytes written (excluding the trailing NUL).
    # Caller is responsible for buf being large enough — no bounds
    # check; this matches the Linux sprintf contract (and is why
    # snprintf exists). NULL buf is a no-op returning 0.
    if buf == 0:
        return 0
    wr: Array[32, uint8]
    cast[Ptr[uint64]](&wr[0] + WR_OFF_DST)[0]   = buf
    cast[Ptr[uint64]](&wr[0] + WR_OFF_SIZE)[0]  = 0xFFFFFFFFFFFFFFFF
    cast[Ptr[uint64]](&wr[0] + WR_OFF_POS)[0]   = 0
    cast[Ptr[uint64]](&wr[0] + WR_OFF_TOTAL)[0] = 0
    _do_format(cast[uint64](&wr[0]), fmt, arg1)
    pos: uint64 = cast[Ptr[uint64]](&wr[0] + WR_OFF_POS)[0]
    # Plant trailing NUL.
    cast[Ptr[uint8]](buf + pos)[0] = 0
    return cast[int32](pos)


def _l_snprintf(buf: uint64, size: uint64, fmt: uint64,
                arg1: uint64) -> int32:
    # int snprintf(char *buf, size_t size, const char *fmt, ...);
    # Returns the number of bytes that WOULD have been written if
    # `size` were unbounded (excluding NUL). If size > 0, always
    # plants a trailing NUL within buf.
    if size == 0:
        # No write, just compute the total length.
        wr: Array[32, uint8]
        cast[Ptr[uint64]](&wr[0] + WR_OFF_DST)[0]   = 0
        cast[Ptr[uint64]](&wr[0] + WR_OFF_SIZE)[0]  = 0
        cast[Ptr[uint64]](&wr[0] + WR_OFF_POS)[0]   = 0
        cast[Ptr[uint64]](&wr[0] + WR_OFF_TOTAL)[0] = 0
        _do_format(cast[uint64](&wr[0]), fmt, arg1)
        return cast[int32](cast[Ptr[uint64]](&wr[0] + WR_OFF_TOTAL)[0])
    if buf == 0:
        return 0
    wr2: Array[32, uint8]
    cast[Ptr[uint64]](&wr2[0] + WR_OFF_DST)[0]   = buf
    cast[Ptr[uint64]](&wr2[0] + WR_OFF_SIZE)[0]  = size
    cast[Ptr[uint64]](&wr2[0] + WR_OFF_POS)[0]   = 0
    cast[Ptr[uint64]](&wr2[0] + WR_OFF_TOTAL)[0] = 0
    _do_format(cast[uint64](&wr2[0]), fmt, arg1)
    pos: uint64 = cast[Ptr[uint64]](&wr2[0] + WR_OFF_POS)[0]
    total: uint64 = cast[Ptr[uint64]](&wr2[0] + WR_OFF_TOTAL)[0]
    # Plant trailing NUL at min(pos, size-1).
    nul_at: uint64 = pos
    if nul_at >= size:
        nul_at = size - 1
    cast[Ptr[uint8]](buf + nul_at)[0] = 0
    return cast[int32](total)


# ---------------------------------------------------------------------
# Registration
# ---------------------------------------------------------------------

def linux_abi_register_strings():
    # Called from start_kernel after the other api_* registrations.
    # No internal initialization needed — all state is per-call (LCG
    # state in api_random.ad is the rare exception across L-track).
    _add_export("strlen",   cast[uint64](&_l_strlen))
    _add_export("strcmp",   cast[uint64](&_l_strcmp))
    _add_export("strncmp",  cast[uint64](&_l_strncmp))
    _add_export("strncpy",  cast[uint64](&_l_strncpy))
    _add_export("strncat",  cast[uint64](&_l_strncat))
    _add_export("strchr",   cast[uint64](&_l_strchr))
    _add_export("strrchr",  cast[uint64](&_l_strrchr))
    _add_export("strstr",   cast[uint64](&_l_strstr2))
    _add_export("memset",   cast[uint64](&_l_memset))
    _add_export("memmove",  cast[uint64](&_l_memmove))
    _add_export("memcmp",   cast[uint64](&_l_memcmp))
    _add_export("sprintf",  cast[uint64](&_l_sprintf))
    _add_export("snprintf", cast[uint64](&_l_snprintf))

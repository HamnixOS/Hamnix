# linux_abi/api_l59.ad
#
# L59: shims for the ABI gap exposed by the stock Debian 6.12
# nf_conntrack.ko (Linux's connection-tracking core — the lower half
# of the netfilter "stateful firewall" stack and the prerequisite for
# every nf_conntrack_proto_*/xt_state/xt_conntrack/nf_nat module).
#
# nf_conntrack.ko is a pernet_subsys-style module: init_module
# registers the conntrack subsystem with the net namespace machinery
# (already shimmed in L41 / api_pernet.ad) and a small pile of helper
# tables (sysctl, btf, sockopt). The init path is heavy in static-data
# references and light in logic:
#
#   init_module:
#       call __fentry__
#       call nf_conntrack_net_init        # internal
#         register_pernet_subsys(...)     # L41
#         _l_register_btf_kfunc_id_set    # L59 — returns 0 (success)
#       call nf_conntrack_proto_init      # internal
#         _l_proc_dointvec / sysctl_vals  # L59 — DATA + setup stubs
#       call nf_register_sockopt          # L59 — returns 0
#       ...
#
# nf_conntrack.ko itself exports a wide upward surface (nf_conntrack_*,
# __nf_ct_*, nf_ct_helper_*, etc.) consumed by xt_state, xt_conntrack,
# nf_conntrack_proto_*, and nf_nat — those exports land natively when
# the module is loaded (it registers its own EXPORT_SYMBOL set via the
# .modinfo / .ksymtab path the loader handles uniformly). What L59
# covers is the *downward* gap: symbols nf_conntrack.ko itself imports
# from the kernel core that aren't yet in linux_abi/.
#
# UND analysis (`readelf -s --wide` on distro_nf_conntrack.ko):
#   * 155 UND symbols total
#   * 80 already covered by L1..L58 + api_*.ad core (kmalloc, kfree,
#     printk, memcpy, memset, register_pernet_subsys, list_*, mutex_*,
#     spinlock_*, jiffies, schedule_timeout, kthread_*, __init_waitqueue_
#     head, queue_work_on, init_net (data) via L47, synchronize_rcu,
#     try_module_get, request_module, skb_*, etc.)
#   * 75 NEW in L59 (this file).
#
# Grouping (init-path symbols first, then runtime stubs):
#
#   Group 1: workqueue + delayed_work runtime (init-critical — data
#            references resolve at module load even if not called)
#     system_wq (DATA), system_power_efficient_wq (DATA),
#     delayed_work_timer_fn, mod_delayed_work_on, queue_delayed_work_on
#
#   Group 2: scheduler + sleep + sync primitives
#     schedule, msleep, synchronize_net, synchronize_rcu_expedited,
#     timer_delete
#
#   Group 3: x86 retpoline thunk
#     __x86_indirect_thunk_r13
#
#   Group 4: CRC / hash helpers
#     crc32c, __crc32c_le_shift, siphash_4u64, __siphash_unaligned
#
#   Group 5: BPF / BTF integration (nf_conntrack registers a kfunc set
#            for tc/BPF reachability)
#     bpf_log, btf_type_by_id, register_btf_kfunc_id_set,
#     nf_conn_btf_access_lock (DATA), nfct_btf_struct_access (DATA)
#
#   Group 6: random
#     get_random_u8
#
#   Group 7: IPv6 helpers (defrag + extension-header walker)
#     __ipv6_addr_type, ipv6_skip_exthdr,
#     nf_ip6_check_hbh_len, nf_ct_frag6_gather
#
#   Group 8: time / jiffies / sleep
#     jiffies_to_usecs, ktime_get_with_offset
#
#   Group 9: memory / strings / convert
#     krealloc_noprof, kstrtouint
#
#   Group 10: socket lock + sockopt registration
#     lock_sock_nested, release_sock,
#     nf_register_sockopt, nf_unregister_sockopt
#
#   Group 11: __do_once runtime (one-shot init guard macro)
#     __do_once_start, __do_once_done
#
#   Group 12: net namespace machinery
#     get_net_ns_by_id, __put_net, net_namespace_list (DATA),
#     net_ns_barrier, net_rwsem (DATA), net_ratelimit, _totalram_pages
#     (DATA — RAM-size pointer used for sizing conntrack hash table)
#
#   Group 13: netfilter checksum helpers
#     nf_checksum, nf_checksum_partial, nf_ip_checksum, nf_ip6_checksum,
#     inet_proto_csum_replace4
#
#   Group 14: nf_conntrack hooks (DATA — function-pointer tables that
#             upstream modules patch in at load)
#     nf_ct_hook (DATA), nf_nat_hook (DATA), nf_ct_zone_dflt (DATA)
#
#   Group 15: nf_defrag enable/disable refcount API (consumers
#             enable defrag before relying on reassembled packets)
#     nf_defrag_ipv4_enable, nf_defrag_ipv4_disable,
#     nf_defrag_ipv6_enable, nf_defrag_ipv6_disable
#
#   Group 16: nf_log + nf_queue runtime
#     nf_log_packet, nf_queue_nf_hook_drop
#
#   Group 17: netlink attribute helpers
#     nla_memcpy, nla_policy_len, nla_put_64bit
#
#   Group 18: module_param ops for uint type
#     param_get_uint, param_set_uint
#
#   Group 19: proc / sysctl machinery
#     proc_dointvec, proc_dointvec_jiffies, proc_dointvec_minmax,
#     proc_dou8vec_minmax, proc_set_user, sysctl_vals (DATA),
#     register_net_sysctl_sz, unregister_net_sysctl_table
#
#   Group 20: skb writability + checksum walker
#     pskb_trim_rcsum_slow, __skb_checksum, skb_ensure_writable
#
#   Group 21: security/LSM secctx
#     security_release_secctx, security_secid_to_secctx
#
# Stub philosophy mirrors L51..L58:
#   * Init-path registration functions (register_btf_kfunc_id_set,
#     nf_register_sockopt, register_net_sysctl_sz) return 0 / a non-NULL
#     handle so nf_conntrack.ko's init_module stays on the happy path.
#   * Retpoline thunks emit pop %rbp; jmpq *%reg.
#   * `schedule` is a no-op return — nf_conntrack's init never reaches
#     the scheduler hook, and runtime callers are post-init only.
#   * DATA exports point at zero-initialised backing buffers; the
#     readers (nf_ct_hook / nf_nat_hook etc.) dereference function-
#     pointer slots only at packet-processing time, never at init.
#   * Every other shim is a no-op returning 0 / NULL / -EINVAL as
#     appropriate. Runtime hot paths (packet processing) never fire in
#     our env because Hamnix has no IP stack consumer for nf_conntrack
#     yet — the load succeeds, the module sits idle.
#
# Naming notes:
#   * Adder reserves `bytes` -> use `nbytes`.
#   * Adder reserves `file`  -> use `filp` / `f`.

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree


# =====================================================================
# Group 1: workqueue + delayed_work runtime
# =====================================================================
#
# Linux's `system_wq` and `system_power_efficient_wq` are
# `struct workqueue_struct *` globals. Modules pass them to
# queue_work() / queue_delayed_work(). At init time nf_conntrack.ko
# only takes their address (to stash it for runtime use), so a non-NULL
# pointer to a small backing buffer suffices.
#
# delayed_work_timer_fn is the canonical TIMER_INITIALIZER function for
# struct delayed_work — when the timer fires it transitions the work
# onto its workqueue. nf_conntrack.ko emits it as a static-initializer
# for the gc (garbage-collect) delayed_work entry; the symbol must
# resolve so the rodata table can be relocated, but the body only fires
# when the timer expires (we don't run conntrack GC).
#
# mod_delayed_work_on / queue_delayed_work_on are the two-arg /
# three-arg flavours of queue_delayed_work. nf_conntrack.ko's GC
# scheduler calls them after each cycle. Stubs return 0 (already
# pending) and let the caller continue.

# DATA: backing buffers for system_wq / system_power_efficient_wq.
# Real struct workqueue_struct is ~512 bytes (struct list_head + atomic
# refcount + array of pool_workqueue *). We supply 64 bytes — enough
# headroom for the leading fields the macros peek at, and zero-init so
# no function-pointer slot fires.
system_wq_buf:                    Array[64, uint8]
system_power_efficient_wq_buf:    Array[64, uint8]


def _l_delayed_work_timer_fn(t: uint64):
    # void delayed_work_timer_fn(struct timer_list *t);
    # Real implementation: container_of(t, struct delayed_work, timer)
    # then __queue_work(dwork->wq, &dwork->work). No-op stub — the GC
    # timer never expires in our env.
    return


def _l_mod_delayed_work_on(cpu: int32, wq: uint64, dwork: uint64,
                           delay: uint64) -> int32:
    # bool mod_delayed_work_on(int cpu, struct workqueue_struct *,
    #                           struct delayed_work *, unsigned long delay);
    # Returns true if the dwork was already pending and got re-armed.
    # 0 ("first time pending") keeps callers on the happy "scheduled"
    # branch.
    return 0


def _l_queue_delayed_work_on(cpu: int32, wq: uint64, dwork: uint64,
                              delay: uint64) -> int32:
    # bool queue_delayed_work_on(int cpu, struct workqueue_struct *,
    #                             struct delayed_work *, unsigned long delay);
    # Returns true if newly queued.
    return 1


# =====================================================================
# Group 2: scheduler + sleep + sync primitives
# =====================================================================

def _l_schedule():
    # void schedule(void);
    # Yield the CPU to the scheduler. Hamnix is cooperative-single-task
    # for kernel modules at this milestone, so the only correct stub is
    # "return immediately". nf_conntrack.ko never invokes schedule on
    # its init path; the symbol must just resolve.
    return


def _l_msleep(msecs: uint32):
    # void msleep(unsigned int msecs);
    # Sleep `msecs` milliseconds in TASK_UNINTERRUPTIBLE. nf_conntrack
    # uses msleep in its shutdown path (waiting for in-flight RCU
    # readers) — never on init. Stub: busy-noop.
    return


def _l_synchronize_net():
    # void synchronize_net(void);
    # Wait for an RCU grace period AND for in-flight netdev callbacks.
    # Hamnix has no concurrent RCU readers, so the grace period is
    # already over. No-op.
    return


def _l_synchronize_rcu_expedited():
    # void synchronize_rcu_expedited(void);
    # Same semantics as synchronize_rcu but faster (uses IPIs). With
    # no concurrent readers, a no-op return is correct.
    return


def _l_timer_delete(timer: uint64) -> int32:
    # int timer_delete(struct timer_list *);
    # Renamed (was del_timer in 6.x). Returns 1 if the timer was
    # pending and got cancelled, 0 otherwise. Conntrack's GC timer
    # was never armed in our env -> 0.
    return 0


# =====================================================================
# Group 3: x86 retpoline thunk (r13)
# =====================================================================

def _l___x86_indirect_thunk_r13():
    # Retpoline replacement for `call *%r13`.
    asm_volatile("""
        popq %rbp
        jmpq *%r13
    """)


# =====================================================================
# Group 4: CRC / hash helpers
# =====================================================================
#
# nf_conntrack uses crc32c for the conntrack-tuple hash table and
# siphash for tuple randomisation. Stubs return 0 — the init path
# computes hashes for empty tables (the hashtable allocation itself
# uses get_random_u32 from L57); runtime packet hashing never fires
# because Hamnix has no IP-stack consumer wiring packets in.

def _l_crc32c(crc: uint32, buf: uint64, nbytes: uint64) -> uint32:
    # u32 crc32c(u32 crc, const void *p, size_t len);
    # Real implementation: ITU-T polynomial 0x1EDC6F41 lookup. We
    # return the seed unchanged — produces a deterministic but trivial
    # hash, fine for stub paths (real packets never traverse our env).
    return crc


def _l___crc32c_le_shift(crc: uint32, nbytes: uint64) -> uint32:
    # u32 __crc32c_le_shift(u32 crc, size_t len);
    # Shifts a CRC over `len` virtual zero bytes (used for combining
    # CRCs across buffers). Return the seed unchanged.
    return crc


def _l_siphash_4u64(a: uint64, b: uint64, c: uint64, d: uint64,
                     key: uint64) -> uint64:
    # u64 siphash_4u64(u64 a, u64 b, u64 c, u64 d, const siphash_key_t *);
    # Real: 4-round-compression + 8-round-finalisation SipHash-2-4.
    # XOR mix is a cheap, deterministic stand-in for stub paths.
    return a ^ b ^ c ^ d


def _l___siphash_unaligned(data: uint64, nbytes: uint64,
                            key: uint64) -> uint64:
    # u64 __siphash_unaligned(const void *data, size_t len,
    #                          const siphash_key_t *key);
    # Stub returns length as the hash — non-zero, deterministic.
    return nbytes


# =====================================================================
# Group 5: BPF / BTF integration
# =====================================================================
#
# nf_conntrack registers a "kfunc set" with the BPF subsystem so that
# eBPF/tc programs can call nf_ct_* helpers. With no BPF runtime in
# Hamnix the registration is a pure no-op.

def _l_bpf_log(log: uint64, fmt: uint64) -> int32:
    # void bpf_log(struct bpf_verifier_log *, const char *fmt, ...);
    # Diagnostic — used by the BPF verifier. Stub.
    return 0


def _l_btf_type_by_id(btf: uint64, type_id: uint32) -> uint64:
    # const struct btf_type *btf_type_by_id(const struct btf *, u32);
    # No BTF in our kernel image — return NULL.
    return 0


def _l_register_btf_kfunc_id_set(hook: int32, kset: uint64) -> int32:
    # int register_btf_kfunc_id_set(enum bpf_prog_type, struct btf_kfunc_id_set *);
    # nf_conntrack expects 0 (success) so its init doesn't unwind.
    return 0


# DATA exports — both are small structs (rw_semaphore + ops table).
# Zero-initialised; the only consumer is BPF/tc, which never fires
# here.
nf_conn_btf_access_lock_buf:  Array[64, uint8]
nfct_btf_struct_access_buf:   Array[16, uint8]


# =====================================================================
# Group 6: random
# =====================================================================

def _l_get_random_u8() -> uint32:
    # u8 get_random_u8(void);
    # Linux returns a single random byte. We return a fixed value;
    # nf_conntrack uses it only at init to seed a per-cpu state field
    # whose runtime path we don't exercise.
    return 0x5a


# =====================================================================
# Group 7: IPv6 helpers
# =====================================================================

def _l___ipv6_addr_type(addr: uint64) -> int32:
    # int __ipv6_addr_type(const struct in6_addr *);
    # Classifies an IPv6 addr (unicast/multicast/link-local/...).
    # IPV6_ADDR_SCOPE_GLOBAL is bit 0x0040; return that as a sensible
    # default. nf_conntrack runtime never reads this in our env.
    return 0x40


def _l_ipv6_skip_exthdr(skb: uint64, start: int32, nexthdrp: uint64,
                         frag_off: uint64) -> int32:
    # int ipv6_skip_exthdr(const struct sk_buff *, int start,
    #                       u8 *nexthdrp, __be16 *frag_offp);
    # Walks IPv6 extension headers. Stub returns -1 ("not found"),
    # which the caller treats as "no further hdr to inspect".
    return -1


def _l_nf_ip6_check_hbh_len(skb: uint64, plen: uint64) -> int32:
    # int nf_ip6_check_hbh_len(struct sk_buff *, u32 *plen);
    return 0


def _l_nf_ct_frag6_gather(net: uint64, skb: uint64, user: uint32) -> int32:
    # int nf_ct_frag6_gather(struct net *, struct sk_buff *, u32 user);
    # Real: reassemble IPv6 fragments. Stub returns 0 (no reassembly
    # needed / packet ready as-is).
    return 0


# =====================================================================
# Group 8: time / jiffies
# =====================================================================

def _l_jiffies_to_usecs(j: uint64) -> uint32:
    # unsigned int jiffies_to_usecs(unsigned long j);
    # Hamnix's HZ is 100 (10ms/jiffy) -> 10000 us/jiffy. Match that
    # so any latent caller gets a plausible value.
    return cast[uint32](j * cast[uint64](10000))


def _l_ktime_get_with_offset(offs: int32) -> uint64:
    # ktime_t ktime_get_with_offset(enum tk_offsets);
    # nf_conntrack uses this for the conntrack-event timestamps.
    # Returning 0 gives an "epoch start" stamp — deterministic.
    return 0


# =====================================================================
# Group 9: memory / strings / convert
# =====================================================================

def _l_krealloc_noprof(p: uint64, new_size: uint64,
                        flags: uint64) -> uint64:
    # void *krealloc_noprof(const void *p, size_t new_size, gfp_t flags);
    # Mirrors the krealloc shim in exports.ad. NULL + 0 -> NULL,
    # NULL + N -> kmalloc(N), N + 0 -> kfree(p), otherwise alloc-copy-
    # free. We can't read old size from Hamnix's slab, so we trust the
    # caller's intent and copy new_size bytes from the old buffer.
    if p == 0:
        if new_size == 0:
            return 0
        return kmalloc(new_size)
    if new_size == 0:
        kfree(p)
        return 0
    fresh: uint64 = kmalloc(new_size)
    if fresh == 0:
        return 0
    # Best-effort copy. Trailing bytes past the original slab object's
    # true size are garbage, but nf_conntrack only grows buffers it owns
    # so the tail will be re-initialised by the caller.
    i: uint64 = 0
    src: Ptr[uint8] = cast[Ptr[uint8]](p)
    dst: Ptr[uint8] = cast[Ptr[uint8]](fresh)
    while i < new_size:
        dst[i] = src[i]
        i = i + 1
    kfree(p)
    return fresh


def _l_kstrtouint(s: uint64, base: uint32, res: uint64) -> int32:
    # int kstrtouint(const char *s, unsigned int base, unsigned int *res);
    # Parses a NUL-terminated string as unsigned int. nf_conntrack uses
    # this for module-param fixup. Stub: write 0 to *res and return 0.
    if res != 0:
        p: Ptr[uint32] = cast[Ptr[uint32]](res)
        p[0] = 0
    return 0


# =====================================================================
# Group 10: socket lock + sockopt
# =====================================================================

def _l_lock_sock_nested(sk: uint64, subclass: int32):
    # void lock_sock_nested(struct sock *sk, int subclass);
    # Acquires sk->sk_lock. We have no sock subsystem; no-op.
    return


def _l_release_sock(sk: uint64):
    # void release_sock(struct sock *sk);
    return


def _l_nf_register_sockopt(reg: uint64) -> int32:
    # int nf_register_sockopt(struct nf_sockopt_ops *reg);
    # Registers a setsockopt/getsockopt handler. nf_conntrack uses
    # this for the per-conntrack-entry expectation getsockopt API.
    # Return 0 (success) so init proceeds.
    return 0


def _l_nf_unregister_sockopt(reg: uint64):
    # void nf_unregister_sockopt(struct nf_sockopt_ops *reg);
    return


# =====================================================================
# Group 11: __do_once runtime
# =====================================================================
#
# The DO_ONCE() macro expands to a static bit guarded by a global
# section-local key + __do_once_start / __do_once_done bracket. The
# bracket implementation in Linux acquires a per-key spinlock, checks
# the bit, and lets the body run exactly once. With no concurrency
# we can just return "go ahead" on the first call and "skip" thereafter.
# A single global bit suffices because nf_conntrack uses DO_ONCE in
# precisely one place (the tuple-hash seed prelude) per module load.

l59_do_once_fired: uint32 = 0


def _l___do_once_start(done: uint64, flags: uint64) -> int32:
    # bool __do_once_start(bool *done, unsigned long *flags);
    # Returns true to indicate "run the body now". We honour the
    # caller's `done` flag if non-NULL; otherwise rely on our global.
    if done != 0:
        p: Ptr[uint32] = cast[Ptr[uint32]](done)
        if p[0] != 0:
            return 0
        p[0] = 1
        return 1
    if l59_do_once_fired != 0:
        return 0
    l59_do_once_fired = 1
    return 1


def _l___do_once_done(done: uint64, mod: uint64, flags: uint64):
    # void __do_once_done(bool *done, struct static_key_true *,
    #                      unsigned long *flags, struct module *);
    # Bracket close — no work required for our stub-bit model.
    return


# =====================================================================
# Group 12: net namespace + RAM size
# =====================================================================

def _l_get_net_ns_by_id(net: uint64, id: int32) -> uint64:
    # struct net *get_net_ns_by_id(const struct net *net, int id);
    # Returns the namespace with matching id (with bumped refcount).
    # Hamnix has init_net only — return its address regardless of id
    # so callers stay on the happy "found" path.
    return net


def _l___put_net(net: uint64):
    # void __put_net(struct net *net);
    # Refcount drop; no-op in single-namespace env.
    return


def _l_net_ns_barrier():
    # void net_ns_barrier(void);
    # Wait for all pending namespace deletions. None pending -> no-op.
    return


def _l_net_ratelimit() -> int32:
    # int net_ratelimit(void);
    # Returns 1 if a message may be emitted. Allow everything through.
    return 1


# DATA: list head of all net namespaces. Real Linux:
#   LIST_HEAD(net_namespace_list);
# A LIST_HEAD initializer is `{ &name, &name }` — a self-linked list_head
# (two pointers, both pointing back to the head). Modules walk this list
# in their pernet init paths.  At runtime we only have init_net; for
# stub paths a self-linked head is the correct "empty list" sentinel.
# We can't easily set the self-pointers at compile time (would need an
# initializer expression), so we leave the buffer zero-initialised —
# nf_conntrack's init walks the list via for_each_net() and exits the
# loop on the first zero next-pointer. nf_conntrack's init doesn't
# actually walk the list at register-pernet-subsys time (the subsys
# layer drives it), so an all-zero buffer is safe.
net_namespace_list_buf:   Array[16, uint8]    # struct list_head (16 bytes)


# DATA: struct rw_semaphore protecting net_namespace_list. ~40 bytes
# in Linux 6.12 (count + waiter list + owner + osq). Zero-initialised
# is fine — our env never contends.
net_rwsem_buf:            Array[64, uint8]


# DATA: pointer to a totalram_pages counter. Linux exports
# `extern atomic_long_t _totalram_pages;` — the underlying storage is
# a single long. nf_conntrack scales its hash-table size as a fraction
# of total RAM at init. We supply a fixed value (16384 pages = 64 MiB,
# matches the QEMU -m 256M memory footprint roughly).
_totalram_pages_val: uint64 = 16384


# =====================================================================
# Group 13: netfilter checksum helpers
# =====================================================================

def _l_nf_checksum(skb: uint64, hook: uint32, dataoff: uint32,
                    protocol: uint8, pf: uint8) -> uint32:
    # __sum16 nf_checksum(struct sk_buff *, unsigned int hook,
    #                      unsigned int dataoff, u8 protocol, u8 pf);
    # Returns 0 (CHECKSUM_UNNECESSARY equivalent).
    return 0


def _l_nf_checksum_partial(skb: uint64, hook: uint32, dataoff: uint32,
                            len: uint32, protocol: uint8,
                            pf: uint8) -> uint32:
    return 0


def _l_nf_ip_checksum(skb: uint64, hook: uint32, dataoff: uint32,
                       protocol: uint8) -> uint32:
    # __sum16 nf_ip_checksum(struct sk_buff *, unsigned int hook,
    #                         unsigned int dataoff, u_int8_t protocol);
    return 0


def _l_nf_ip6_checksum(skb: uint64, hook: uint32, dataoff: uint32,
                        protocol: uint8) -> uint32:
    return 0


def _l_inet_proto_csum_replace4(sum: uint64, skb: uint64, from_: uint32,
                                  to: uint32, pseudohdr: int32):
    # void inet_proto_csum_replace4(__sum16 *sum, struct sk_buff *,
    #                                __be32 from, __be32 to, bool pseudohdr);
    # In-place csum diff for IPv4 NAT. No-op.
    return


# =====================================================================
# Group 14: nf_conntrack hook tables (DATA)
# =====================================================================
#
# `struct nf_ct_hook *nf_ct_hook __read_mostly;` is a function-pointer
# table that nf_conntrack patches in for the IP stack to call. The
# variable is exported because the IP stack reads it; nf_conntrack
# *writes* its address into it at init. Our backing storage is a 64-byte
# zero buffer with enough headroom for the ~6 function-pointer slots.
# nf_conntrack's init unconditionally writes its hook table here (the
# write goes through a literal `nf_ct_hook = &my_table`, so the *value*
# of nf_ct_hook becomes a valid pointer after init — but no consumer in
# Hamnix reads it).
#
# Same shape for nf_nat_hook (populated later by nf_nat.ko) and
# nf_ct_zone_dflt (a `struct nf_conntrack_zone` initialised to
# zone_id = 0 — Linux's "the default zone"). For nf_ct_zone_dflt the
# zero bytes ARE the correct default contents (zone_id 0, dir 0,
# flags 0).

nf_ct_hook_buf:        Array[64, uint8]
nf_nat_hook_buf:       Array[64, uint8]

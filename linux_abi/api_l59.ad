def _l_write_cache_pages(mapping: uint64, wbc: uint64,
                          writepage: uint64, data: uint64) -> int32:
    # int write_cache_pages(struct address_space *,
    #                        struct writeback_control *,
    #                        writepage_t writepage, void *data);
    return 0


# =====================================================================
# UDF Group G: file/path ops
# =====================================================================

def _l_file_update_time(filp: uint64) -> int32:
    # int file_update_time(struct file *);
    return 0


def _l_finish_open(filp: uint64, dentry: uint64, open: uint64) -> int32:
    # int finish_open(struct file *, struct dentry *,
    #                  int (*open)(struct inode *, struct file *));
    return 0


def _l_generic_file_fsync(filp: uint64, start: uint64, end: uint64,
                            datasync: int32) -> int32:
    # int generic_file_fsync(struct file *, loff_t, loff_t, int);
    return 0


def _l_generic_file_open(inode: uint64, filp: uint64) -> int32:
    # int generic_file_open(struct inode *, struct file *);
    return 0


def _l_generic_llseek_cookie(filp: uint64, offset: int64, whence: int32,
                               cookie: uint64) -> int64:
    # loff_t generic_llseek_cookie(struct file *, loff_t, int, u64 *);
    return 0


def _l_page_get_link(dentry: uint64, inode: uint64, done: uint64) -> uint64:
    # const char *page_get_link(struct dentry *, struct inode *,
    #                            struct delayed_call *);
    return 0


# =====================================================================
# UDF Group H: kuid/kgid + overflow uid/gid + nop_mnt_idmap (DATA)
# =====================================================================

def _l_from_kgid(ns: uint64, gid: uint32) -> uint32:
    # gid_t from_kgid(struct user_namespace *, kgid_t);
    return gid


def _l_from_kuid(ns: uint64, uid: uint32) -> uint32:
    # uid_t from_kuid(struct user_namespace *, kuid_t);
    return uid


# DATA: overflowuid / overflowgid are `unsigned int` globals — the
# fallback uid/gid when a real value can't be represented. Default
# Linux value is 65534 ("nobody"). Single uint32 each.
overflowuid_val: uint32 = 65534
overflowgid_val: uint32 = 65534


# DATA: nop_mnt_idmap — the all-zero default `struct mnt_idmap` that
# represents the no-translation identity mapping. ~48 bytes in Linux
# 6.12; zero is the correct content for the identity mapping.
nop_mnt_idmap_buf:  Array[64, uint8]


# =====================================================================
# UDF Group I: __get_user_8 (gcc-emitted helper)
# =====================================================================

def _l___get_user_8() -> int32:
    # __get_user_8: load 8 bytes from user space. Stub: -EFAULT.
    return -14


# =====================================================================
# UDF Group J: hex_asc_upper (DATA)
# =====================================================================
#
# `const char hex_asc_upper[] = "0123456789ABCDEF";` — uppercase variant
# of L57's hex_asc. UDF uses it to format volume identifiers.

hex_asc_upper_buf:  Array[17, uint8]


# =====================================================================
# UDF Group K: time
# =====================================================================

def _l_ktime_get_real_ts64(ts: uint64):
    # void ktime_get_real_ts64(struct timespec64 *);
    # Writes tv_sec/tv_nsec zero. UDF uses this for timestamp fields.
    if ts == 0:
        return
    p: Ptr[uint64] = cast[Ptr[uint64]](ts)
    p[0] = 0
    p[1] = 0


# =====================================================================
# UDF Group L: logfc + rcuwait + memscan + percpu + utf32
# =====================================================================

def _l_logfc(log: uint64, prefix: uint64, level: int32, fmt: uint64):
    # void logfc(struct fc_log *, const char *prefix, char level,
    #             const char *fmt, ...);
    # Diagnostic — used by fs_context parsers. No-op.
    return


def _l_rcuwait_wake_up(w: uint64):
    # void rcuwait_wake_up(struct rcuwait *w);
    return


def _l_memscan(addr: uint64, c: int32, n: uint64) -> uint64:
    # void *memscan(void *addr, int c, size_t size);
    # Like memchr but returns addr+size (not NULL) if not found.
    if addr == 0:
        return addr + n
    p: Ptr[uint8] = cast[Ptr[uint8]](addr)
    needle: uint8 = cast[uint8](c & 0xff)
    i: uint64 = 0
    while i < n:
        if p[i] == needle:
            return addr + i
        i = i + 1
    return addr + n


def _l___percpu_down_read(sem: uint64, try_lock: int32):
    # void __percpu_down_read(struct percpu_rw_semaphore *, bool try);
    # Acquires the read side. No contention -> no-op.
    return


def _l_utf32_to_utf8(u: uint32, s: uint64, maxout: int32) -> int32:
    # int utf32_to_utf8(unicode_t u, u8 *s, int maxout);
    return 0


# =====================================================================
# Bonus registration: udf.ko gaps
# =====================================================================

def linux_abi_register_l59_udf():
    # Adds the 43 UDF-specific exports on top of the nf_conntrack
    # batch. Called from linux_abi_register_l59 above.

    # ---- UDF A: bitmap weight ----
    _add_export("__bitmap_weight",
                cast[uint64](&_l___bitmap_weight))

    # ---- UDF B: block-layer write helpers ----
    _add_export("block_commit_write",
                cast[uint64](&_l_block_commit_write))
    _add_export("__block_write_begin",
                cast[uint64](&_l___block_write_begin))

    # ---- UDF C: CDROM / CRC ITU-T ----
    _add_export("cdrom_get_last_written",
                cast[uint64](&_l_cdrom_get_last_written))
    _add_export("crc_itu_t",
                cast[uint64](&_l_crc_itu_t))

    # ---- UDF D: dcache + dotdot_name ----
    _add_export("d_instantiate_new",
                cast[uint64](&_l_d_instantiate_new))
    _add_export("d_tmpfile",
                cast[uint64](&_l_d_tmpfile))
    _add_export("dotdot_name",
                cast[uint64](&dotdot_name_buf[0]))

    # ---- UDF E: inode lifecycle + accounting ----
    _add_export("discard_new_inode",
                cast[uint64](&_l_discard_new_inode))
    _add_export("ihold",
                cast[uint64](&_l_ihold))
    _add_export("inode_add_bytes",
                cast[uint64](&_l_inode_add_bytes))
    _add_export("inode_sub_bytes",
                cast[uint64](&_l_inode_sub_bytes))
    _add_export("inode_init_owner",
                cast[uint64](&_l_inode_init_owner))
    _add_export("inode_permission",
                cast[uint64](&_l_inode_permission))
    _add_export("insert_inode_locked",
                cast[uint64](&_l_insert_inode_locked))
    _add_export("is_bad_inode",
                cast[uint64](&_l_is_bad_inode))
    _add_export("make_bad_inode",
                cast[uint64](&_l_make_bad_inode))

    # ---- UDF F: page-cache / folio runtime ----
    _add_export("__filemap_get_folio",
                cast[uint64](&_l___filemap_get_folio))
    _add_export("__folio_lock",
                cast[uint64](&_l___folio_lock))
    _add_export("folio_mark_dirty",
                cast[uint64](&_l_folio_mark_dirty))
    _add_export("folio_unlock",
                cast[uint64](&_l_folio_unlock))
    _add_export("folio_wait_stable",
                cast[uint64](&_l_folio_wait_stable))
    _add_export("read_cache_folio",
                cast[uint64](&_l_read_cache_folio))
    _add_export("write_cache_pages",
                cast[uint64](&_l_write_cache_pages))

    # ---- UDF G: file/path ops ----
    _add_export("file_update_time",
                cast[uint64](&_l_file_update_time))
    _add_export("finish_open",
                cast[uint64](&_l_finish_open))
    _add_export("generic_file_fsync",
                cast[uint64](&_l_generic_file_fsync))
    _add_export("generic_file_open",
                cast[uint64](&_l_generic_file_open))
    _add_export("generic_llseek_cookie",
                cast[uint64](&_l_generic_llseek_cookie))
    _add_export("page_get_link",
                cast[uint64](&_l_page_get_link))

    # ---- UDF H: kuid/kgid + overflow uid/gid + nop_mnt_idmap ----
    _add_export("from_kgid",
                cast[uint64](&_l_from_kgid))
    _add_export("from_kuid",
                cast[uint64](&_l_from_kuid))
    _add_export("overflowuid",
                cast[uint64](&overflowuid_val))
    _add_export("overflowgid",
                cast[uint64](&overflowgid_val))
    _add_export("nop_mnt_idmap",
                cast[uint64](&nop_mnt_idmap_buf[0]))

    # ---- UDF I: __get_user_8 ----
    _add_export("__get_user_8",
                cast[uint64](&_l___get_user_8))

    # ---- UDF J: hex_asc_upper ----
    _add_export("hex_asc_upper",
                cast[uint64](&hex_asc_upper_buf[0]))

    # ---- UDF K: time ----
    _add_export("ktime_get_real_ts64",
                cast[uint64](&_l_ktime_get_real_ts64))

    # ---- UDF L: logfc + rcuwait + memscan + percpu + utf32 ----
    _add_export("logfc",
                cast[uint64](&_l_logfc))
    _add_export("rcuwait_wake_up",
                cast[uint64](&_l_rcuwait_wake_up))
    _add_export("memscan",
                cast[uint64](&_l_memscan))
    _add_export("__percpu_down_read",
                cast[uint64](&_l___percpu_down_read))
    _add_export("utf32_to_utf8",
                cast[uint64](&_l_utf32_to_utf8))

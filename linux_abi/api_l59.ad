# =====================================================================

def _l___bitmap_weight(bitmap: uint64, bits: uint32) -> uint32:
    # unsigned int __bitmap_weight(const unsigned long *bitmap,
    #                                unsigned int bits);
    # Returns the popcount of `bits` bits starting at bitmap[0]. UDF
    # uses it to count free blocks in a bitmap. Stub: 0.
    return 0



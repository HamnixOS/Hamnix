# =====================================================================
# UDF Group C: CDROM / CRC ITU-T
# =====================================================================

def _l_cdrom_get_last_written(bdev: uint64, last: uint64) -> int32:
    # int cdrom_get_last_written(struct block_device *bdev, long *last);
    # Returns the LBA of the last-written sector. -ENOTTY: no CDROM.
    return -25


def _l_crc_itu_t(crc: uint32, buf: uint64, nbytes: uint64) -> uint32:
    # u16 crc_itu_t(u16 crc, const u8 *buffer, size_t len);
    # ITU-T V.41 polynomial 0x1021. Stub returns the seed unchanged —
    # deterministic, fine for stub paths (no real UDF disk in our env).
    return crc



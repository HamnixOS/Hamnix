                cast[uint64](&_l_param_get_uint))
    _add_export("param_set_uint",
                cast[uint64](&_l_param_set_uint))

    # ---- Group 19: proc / sysctl machinery ----
    _add_export("proc_dointvec",
                cast[uint64](&_l_proc_dointvec))
    _add_export("proc_dointvec_jiffies",
                cast[uint64](&_l_proc_dointvec_jiffies))
    _add_export("proc_dointvec_minmax",
                cast[uint64](&_l_proc_dointvec_minmax))
    _add_export("proc_dou8vec_minmax",
                cast[uint64](&_l_proc_dou8vec_minmax))
    _add_export("proc_set_user",
                cast[uint64](&_l_proc_set_user))
    _add_export("sysctl_vals",
                cast[uint64](&sysctl_vals_buf[0]))
    _add_export("register_net_sysctl_sz",
                cast[uint64](&_l_register_net_sysctl_sz))
    _add_export("unregister_net_sysctl_table",
                cast[uint64](&_l_unregister_net_sysctl_table))

    # ---- Group 20: skb writability + checksum walker ----
    _add_export("pskb_trim_rcsum_slow",
                cast[uint64](&_l_pskb_trim_rcsum_slow))
    _add_export("__skb_checksum",
                cast[uint64](&_l___skb_checksum))
    _add_export("skb_ensure_writable",
                cast[uint64](&_l_skb_ensure_writable))

    # ---- Group 21: security/LSM secctx ----
    _add_export("security_release_secctx",
                cast[uint64](&_l_security_release_secctx))
    _add_export("security_secid_to_secctx",
                cast[uint64](&_l_security_secid_to_secctx))

    # =================================================================
    # L59 BONUS: udf.ko (Linux's UDF filesystem driver — the ISO/IEC
    # 13346 "Universal Disk Format" used by DVDs, Blu-ray, and many
    # CD-RW media. Was deferred at L58 because its 75-UND gap beyond
    # L57/L58 was felt too wide; with L59's BPF/sysctl/sock/netfilter
    # surface in place the residual gap is only 43 symbols, all VFS
    # plumbing.
    # =================================================================
    #
    # UND analysis (`readelf -s --wide` on distro_udf.ko, post-L59):
    #   * 190 UND symbols total
    #   * 147 already covered by L1..L59
    #   * 43 NEW in this bonus block.
    #
    # Grouping:
    #
    #   UDF Group A: bitmap + bit-search
    #     __bitmap_weight
    #
    #   UDF Group B: block-layer write helpers
    #     block_commit_write, __block_write_begin
    #
    #   UDF Group C: CDROM / CRC ITU-T
    #     cdrom_get_last_written, crc_itu_t
    #
    #   UDF Group D: dcache helpers
    #     d_instantiate_new, d_tmpfile, dotdot_name (DATA)
    #
    #   UDF Group E: inode lifecycle + accounting
    #     discard_new_inode, ihold, inode_add_bytes, inode_sub_bytes,
    #     inode_init_owner, inode_permission, insert_inode_locked,
    #     is_bad_inode, make_bad_inode
    #
    #   UDF Group F: page-cache / folio runtime
    #     __filemap_get_folio, __folio_lock, folio_mark_dirty,
    #     folio_unlock, folio_wait_stable, read_cache_folio,
    #     write_cache_pages
    #
    #   UDF Group G: file/path ops
    #     file_update_time, finish_open, generic_file_fsync,
    #     generic_file_open, generic_llseek_cookie, page_get_link
    #
    #   UDF Group H: kuid/kgid + overflow uid/gid (DATA)
    #     from_kgid, from_kuid, overflowgid (DATA), overflowuid (DATA),
    #     nop_mnt_idmap (DATA)
    #
    #   UDF Group I: __get_user_8 (gcc-emitted helper)
    #     __get_user_8
    #
    #   UDF Group J: hex_asc_upper (DATA — uppercase variant of L57's hex_asc)
    #     hex_asc_upper (DATA)
    #
    #   UDF Group K: time
    #     ktime_get_real_ts64
    #
    #   UDF Group L: logging + RCU wait + memscan + percpu + utf32
    #     logfc, rcuwait_wake_up, memscan, __percpu_down_read,
    #     utf32_to_utf8
    #
    # All stubs are init-safe no-ops: udf.ko's init_module path is
    # tiny (cache_init -> __kmem_cache_create_args (L57) -> register_
    # filesystem). Every UDF symbol here is reached only at mount /
    # read / write time, none of which Hamnix exercises.
    linux_abi_register_l59_udf()



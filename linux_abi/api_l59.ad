# DATA: dotdot_name is `const struct qstr dotdot_name = QSTR_INIT("..", 2);`
# layout: struct qstr { union { struct { u32 hash; u32 len; }; u64 hashlen; };
#                        const unsigned char *name; }
# - 16 bytes: len fields (8 bytes total) + name pointer (8 bytes).
# Zero-init buffer + setting later would need init code; for stub paths

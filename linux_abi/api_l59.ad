# =====================================================================
# Group 19: proc / sysctl machinery
# =====================================================================
#
# nf_conntrack registers a ~40-entry sysctl table under
# /proc/sys/net/netfilter/. Each entry's `.proc_handler` points at one
# of proc_dointvec / proc_dointvec_minmax / proc_dointvec_jiffies /
# proc_dou8vec_minmax — these are the read/write callbacks that
# /proc/sys uses. Our register_net_sysctl_sz stub returns a non-NULL
# handle so the sysctl-table pointer the caller stashes is valid;
# unregister_net_sysctl_table frees the handle.
#
# `sysctl_vals` is a DATA export: an array of common integers
# (sysctl_vals[0..N] = {0,1,2,-1,INT_MAX,...}) that sysctl entries point
# at as .extra1/.extra2 bounds. A zero buffer gives sensible "0" bounds
# for every entry — nf_conntrack's table mostly uses {0, INT_MAX} pairs,
# so reading 0 for the upper bound would clamp writes to 0; but writes
# never happen on init.

def _l_proc_dointvec(table: uint64, write: int32, buffer: uint64,
                      lenp: uint64, ppos: uint64) -> int32:
    # int proc_dointvec(struct ctl_table *, int, void __user *,
    #                    size_t *, loff_t *);
    return 0


def _l_proc_dointvec_jiffies(table: uint64, write: int32, buffer: uint64,
                               lenp: uint64, ppos: uint64) -> int32:
    return 0


def _l_proc_dointvec_minmax(table: uint64, write: int32, buffer: uint64,
                              lenp: uint64, ppos: uint64) -> int32:
    return 0


def _l_proc_dou8vec_minmax(table: uint64, write: int32, buffer: uint64,
                             lenp: uint64, ppos: uint64) -> int32:
    return 0


def _l_proc_set_user(de: uint64, uid: uint32, gid: uint32):
    # void proc_set_user(struct proc_dir_entry *, kuid_t, kgid_t);
    return


# DATA: 16 * int32 = 64 bytes of common sysctl bound values. Stubs.
sysctl_vals_buf:  Array[64, uint8]


L59_NET_SYSCTL_HANDLE_SIZE: uint64 = 16


def _l_register_net_sysctl_sz(net: uint64, path: uint64, table: uint64,
                                table_size: uint64) -> uint64:
    # struct ctl_table_header *register_net_sysctl_sz(struct net *,
    #                                                   const char *path,
    #                                                   struct ctl_table *,
    #                                                   size_t table_size);
    # Returns a non-NULL handle on success. nf_conntrack's init checks
    # the result is non-NULL and stashes it for unregister.
    handle: uint64 = kmalloc(L59_NET_SYSCTL_HANDLE_SIZE)
    if handle == 0:
        return 0
    p: Ptr[uint64] = cast[Ptr[uint64]](handle)
    p[0] = 1                            # in_use flag
    p[1] = table                        # backref (debug)
    return handle


def _l_unregister_net_sysctl_table(header: uint64):
    # void unregister_net_sysctl_table(struct ctl_table_header *);
    if header == 0:
        return
    kfree(header)



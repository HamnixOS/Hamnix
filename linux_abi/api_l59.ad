# Group 20: skb writability + checksum walker
# =====================================================================

def _l_pskb_trim_rcsum_slow(skb: uint64, len: uint32) -> int32:
    # int pskb_trim_rcsum_slow(struct sk_buff *, unsigned int len);
    return 0


def _l___skb_checksum(skb: uint64, offset: int32, nbytes: int32,
                       csum: uint32, ops: uint64) -> uint32:
    # __wsum __skb_checksum(const struct sk_buff *, int offset,
    #                        int len, __wsum csum,
    #                        const struct skb_checksum_ops *);
    return csum


def _l_skb_ensure_writable(skb: uint64, write_len: int32) -> int32:
    # int skb_ensure_writable(struct sk_buff *, unsigned int write_len);
    # Ensures the first `write_len` bytes are writable (CoWs the head).
    # Stub: pretend the head was already private.
    return 0


# =====================================================================
# Group 21: security/LSM secctx
# =====================================================================

def _l_security_release_secctx(ctx: uint64, ctxlen: uint32):
    # void security_release_secctx(char *secdata, u32 seclen);
    if ctx == 0:
        return
    kfree(ctx)


def _l_security_secid_to_secctx(secid: uint32, secdata: uint64,
                                  seclen: uint64) -> int32:
    # int security_secid_to_secctx(u32 secid, char **secdata, u32 *seclen);
    # No LSM in Hamnix; report "operation not supported". Caller treats
    # this as "skip secctx serialisation" — well-defined fallback.
    return -95                          # -EOPNOTSUPP


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l59():
    # Called from linux_abi_exports_init() after the L58 batch.
    # Adds 75 new exports for the nf_conntrack.ko ABI gap.

    # ---- Group 1: workqueue + delayed_work ----
    _add_export("system_wq",
                cast[uint64](&system_wq_buf[0]))
    _add_export("system_power_efficient_wq",
                cast[uint64](&system_power_efficient_wq_buf[0]))
    _add_export("delayed_work_timer_fn",
                cast[uint64](&_l_delayed_work_timer_fn))
    _add_export("mod_delayed_work_on",
                cast[uint64](&_l_mod_delayed_work_on))
    _add_export("queue_delayed_work_on",
                cast[uint64](&_l_queue_delayed_work_on))

    # ---- Group 2: scheduler + sleep + sync primitives ----
    _add_export("schedule",
                cast[uint64](&_l_schedule))
    _add_export("msleep",
                cast[uint64](&_l_msleep))
    _add_export("synchronize_net",
                cast[uint64](&_l_synchronize_net))
    _add_export("synchronize_rcu_expedited",
                cast[uint64](&_l_synchronize_rcu_expedited))
    _add_export("timer_delete",
                cast[uint64](&_l_timer_delete))

    # ---- Group 3: x86 retpoline thunk (r13) ----
    _add_export("__x86_indirect_thunk_r13",
                cast[uint64](&_l___x86_indirect_thunk_r13))

    # ---- Group 4: CRC / hash helpers ----
    _add_export("crc32c",
                cast[uint64](&_l_crc32c))
    _add_export("__crc32c_le_shift",
                cast[uint64](&_l___crc32c_le_shift))
    _add_export("siphash_4u64",
                cast[uint64](&_l_siphash_4u64))
    _add_export("__siphash_unaligned",
                cast[uint64](&_l___siphash_unaligned))

    # ---- Group 5: BPF / BTF integration ----
    _add_export("bpf_log",
                cast[uint64](&_l_bpf_log))
    _add_export("btf_type_by_id",
                cast[uint64](&_l_btf_type_by_id))
    _add_export("register_btf_kfunc_id_set",
                cast[uint64](&_l_register_btf_kfunc_id_set))

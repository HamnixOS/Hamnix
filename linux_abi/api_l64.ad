# linux_abi/api_l64.ad
#
# L64: ships three new USB Host Controller drivers + three netfilter
# chain modules that piggy-back on L62's ip_tables.ko engine. Six
# Debian 6.12 modules in this batch:
#
#   * iptable_filter.ko    — IPv4 FILTER chain. 14 UND, 0 missing.
#                              Fully covered by L<=63 (the L62 batch
#                              already shipped the ipt_*/xt_*_template
#                              surface). Test-only milestone.
#   * iptable_mangle.ko    — IPv4 MANGLE chain. 14 UND, 0 missing.
#                              Same coverage as iptable_filter + the
#                              one extra ip_route_me_harder symbol
#                              landed by L60. Test-only milestone.
#   * iptable_raw.ko       — IPv4 RAW chain. 15 UND, 0 missing.
#                              iptable_filter UND set + _printk; both
#                              already in the L<=63 surface. Test-only.
#   * ehci-hcd.ko          — USB 2.0 host controller driver (the
#                              kernel module that implements the
#                              Enhanced Host Controller Interface).
#                              Sits just above usbcore on the USB
#                              stack — same socket as L63's xhci-hcd
#                              but for USB 2.x ports. 94 UND, 8 new.
#   * ohci-hcd.ko          — USB 1.1 host controller driver (Open
#                              Host Controller Interface). Companion
#                              controller on chipsets that pre-date
#                              EHCI; still used by VIA / SiS / NEC /
#                              AMD legacy southbridges and by ARM
#                              SoCs. 71 UND, 5 new (3 unique + 2
#                              shared with ehci-hcd).
#   * ehci-pci.ko          — PCI bridge for ehci-hcd (29 UND, 14
#                              missing as of L63). Not part of this
#                              milestone's "new exports" budget — its
#                              `usb_hcd_pci_*` family is still gapped
#                              until a future L65/L66 batch closes
#                              the PCI-HCD subset. ehci-hcd.ko itself
#                              loads as a library-only module (no
#                              probe runs until a bridge binds it).
#
# This is the first L-batch where landing a single new shim group
# (the eight ehci-hcd glue symbols) unlocks two distinct modules
# (ehci-hcd + ohci-hcd) plus three trivial-coverage netfilter chains
# (iptable_filter/_mangle/_raw). Total module count in tests/linux-
# modules/ after L64: 38 + 5 = 43.
#
# UND analysis (`nm -u`, missing-after-L63):
#   iptable_filter.ko    0 missing
#   iptable_mangle.ko    0 missing
#   iptable_raw.ko       0 missing
#   ehci-hcd.ko          8 missing
#   ohci-hcd.ko          5 missing  (2 shared with ehci-hcd:
#                                     usb_calc_bus_time + usb_hcds_loaded)
#   union                11 unique
#
# 11 new exports across 4 groups:
#
#   1.  USB-HCD scheduling + global state (usb_calc_bus_time,
#         usb_for_each_dev, usb_hcds_loaded DATA, ehci_cf_port_reset_
#         rwsem DATA)
#   2.  platform_driver array-register glue (__platform_register_drivers,
#         platform_unregister_drivers)
#   3.  Xen PV-USB debug-port hooks (xen_dbgp_external_startup,
#         xen_dbgp_reset_prep)
#   4.  ohci-hcd extras (gen_pool_dma_zalloc_align, get_zeroed_page_
#         noprof, sb800_prefetch)
#
# Stub philosophy mirrors L51..L63: every shim is init-cold for our
# env (QEMU's stock x86_64 machine has no EHCI/OHCI hardware, no Xen
# PV debug port, no AMD SB800 southbridge, no real USB device tree).
# Each returns success / 0 / NULL / void to keep init_module on the
# happy path. The two DATA backings (usb_hcds_loaded, ehci_cf_port_
# reset_rwsem) are zero-init buffers sized to the largest field any
# init reader could touch.
#
# Naming notes:
#   * Adder reserves `bytes`, `match`, `case`, `file`, `field`, `type`
#     -> renamed to `nbytes` / `mt` / `cse` / `fp` / `fld` / `kind`.
#   * The "_l_" prefix marks the Hamnix-side shim; "_l64_" tags
#     DATA backings.

from linux_abi.exports import _add_export
from mm.slab import kmalloc, kzalloc


# =====================================================================
# Group 1: USB-HCD scheduling + global state
# =====================================================================
#
# Linux:
#   long usb_calc_bus_time(int speed, int is_input, int isoc, int bytecount);
#   int  usb_for_each_dev(void *data, int (*fn)(struct usb_device *, void *));
#   atomic_t usb_hcds_loaded;                       /* DATA */
#   struct rw_semaphore ehci_cf_port_reset_rwsem;    /* DATA */
#
# usb_calc_bus_time:
#   Original-CRC-of-the-USB-1.1-spec helper; computes the number of
#   ns a transfer of `bytecount` bytes takes on a HS/FS/LS bus. Called
#   from the periodic-scheduling path in ehci-hcd and ohci-hcd —
#   neither fires at init (the periodic schedule is only walked when
#   interrupt URBs queue, which requires a probed root hub).
#   Stub returns 0 (no time consumed); harmless because the schedule
#   walker never runs in our env.
#
# usb_for_each_dev:
#   Iterates every probed usb_device under the usb_bus_type. With
#   zero probed devices in QEMU, the iteration is a no-op; stub
#   returns 0 (the loop's accumulator).
#
# usb_hcds_loaded:
#   An atomic_t (4 bytes, but typically a full word with padding).
#   ehci-hcd / ohci-hcd / xhci-hcd bump this on register and check it
#   to detect siblings. A zero-init buffer is the correct startup
#   value; the increment paths take its address through the loader.
#   16 bytes covers any atomic_t/atomic64_t variant.
#
# ehci_cf_port_reset_rwsem:
#   A struct rw_semaphore (~32 bytes: a long for count, a list_head
#   for waiters, a spinlock_t). ehci-hcd takes its address in the
#   hub-handoff path (when xhci-hcd hands a USB 2 port to ehci-hcd
#   on a UEFI machine). Zero-init is the correct "unlocked, no
#   waiters" state; a 64-byte buffer has headroom for the largest
#   lockdep-instrumented variant.

_l64_usb_hcds_loaded_buf:           Array[16, uint8]
_l64_ehci_cf_port_reset_rwsem_buf:  Array[64, uint8]


def _l_usb_calc_bus_time(speed: int32, is_input: int32, isoc: int32,
                          nbytes: int32) -> int64:
    # Adder reserves `bytes` -> renamed to `nbytes`.
    # 0 == zero bus-time consumed; periodic scheduler skips the slot.
    return 0


def _l_usb_for_each_dev(data: uint64, fn: uint64) -> int32:
    # Zero probed USB devices in QEMU; the iterator visits nothing
    # and the caller's accumulator stays at 0.
    return 0


# =====================================================================
# Group 2: platform_driver array-register glue
# =====================================================================
#
# Linux:
#   int  __platform_register_drivers(struct platform_driver *const *drvs,
#                                       unsigned int count,
#                                       struct module *owner);
#   void platform_unregister_drivers(struct platform_driver *const *drvs,
#                                       unsigned int count);
#
# ehci-hcd's init_module body calls __platform_register_drivers on an
# array of three platform_driver pointers (ehci-platform variants for
# different SoCs). In our QEMU env none of those platform_drivers
# match any device, so the bulk-register entry can return success
# without doing anything observable. Stub returns 0; unregister is a
# pure void no-op.

def _l___platform_register_drivers(drvs: uint64, count: uint32,
                                     owner: uint64) -> int32:
    return 0


def _l_platform_unregister_drivers(drvs: uint64, count: uint32):
    return


# =====================================================================
# Group 3: Xen PV-USB debug-port hooks
# =====================================================================
#
# Linux:
#   int xen_dbgp_external_startup(struct usb_hcd *);
#   int xen_dbgp_reset_prep(struct usb_hcd *);
#
# Both stubs are part of the EHCI debug-port redirection used when
# the kernel boots under Xen with a USB serial-console attachment.
# Real Linux: when CONFIG_XEN_DOM0 is set, these jump into xen-dbgp
# code; otherwise they're inline stubs returning -1 (== let-the-host-
# driver-handle-it). Hamnix doesn't run under Xen, so the standard
# "I'm not Xen" answer is correct.

def _l_xen_dbgp_external_startup(hcd: uint64) -> int32:
    # -1 == "not Xen-managed; let ehci handle the debug port".
    return -1


def _l_xen_dbgp_reset_prep(hcd: uint64) -> int32:
    # -1 == "not Xen-managed; let ehci handle the debug port".
    return -1


# =====================================================================
# Group 4: ohci-hcd extras
# =====================================================================
#
# Linux:
#   void *gen_pool_dma_zalloc_align(struct gen_pool *, size_t,
#                                      dma_addr_t *, unsigned int align);
#   unsigned long get_zeroed_page_noprof(gfp_t);
#   void sb800_prefetch(struct device *dev, int hint);
#
# gen_pool_dma_zalloc_align:
#   Allocates a DMA-coherent buffer from a gen_pool with alignment;
#   the _zalloc variant zero-initialises. ohci-hcd uses this for the
#   HC Communication Area (HCCA — a 256-byte structure the host
#   controller DMAs to/from). With no real OHCI hardware in QEMU, the
#   probe path never runs; stub returns 0 (allocation failed) and
#   writes 0 to *dma so the caller's BAD-ALLOC arm executes its
#   `goto err_dma` and bails cleanly.
#
# get_zeroed_page_noprof:
#   Linux's PAGE-sized zalloc shortcut. ohci-hcd uses it for the
#   per-controller scratch register-shadow buffer. Hamnix's kzalloc
#   handles arbitrary sizes; we forward with 4096 to match Linux's
#   semantics. Real Linux returns the page's virtual address;
#   kzalloc(4096) gives us the same shape.
#
# sb800_prefetch:
#   AMD SB800 southbridge OHCI quirk hook; sets a prefetch hint via
#   chip-specific register writes. Hamnix has no SB800 (the QEMU q35
#   chipset is Intel-based) — no-op.

def _l_gen_pool_dma_zalloc_align(pool: uint64, size: uint64,
                                    dma: uint64, align: uint32) -> uint64:
    # Mark the DMA address as invalid so the caller's err_dma path
    # fires; ohci_hcd's reset_hc handler treats a NULL HCCA as
    # "controller unavailable" and stops the probe.
    if dma != 0:
        dp: Ptr[uint64] = cast[Ptr[uint64]](dma)
        dp[0] = 0
    return 0


def _l_get_zeroed_page_noprof(gfp_mask: uint32) -> uint64:
    # Forward to kzalloc with PAGE_SIZE; matches Linux's "one zeroed
    # page" semantics. ohci-hcd's probe never reaches this in QEMU.
    return kzalloc(4096)


def _l_sb800_prefetch(dev: uint64, hint: int32):
    # AMD-specific southbridge quirk; not present on QEMU q35.
    return


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l64():
    # Called from linux_abi_exports_init() after the L63 batch.
    # Adds 11 new exports for the ehci-hcd / ohci-hcd / iptable_*
    # batch. The three iptable_* modules need no new exports — all
    # their UND symbols were already covered by L<=63.

    # ---- Group 1: USB-HCD scheduling + global state ----
    _add_export("usb_calc_bus_time",
                cast[uint64](&_l_usb_calc_bus_time))
    _add_export("usb_for_each_dev",
                cast[uint64](&_l_usb_for_each_dev))
    _add_export("usb_hcds_loaded",
                cast[uint64](&_l64_usb_hcds_loaded_buf[0]))
    _add_export("ehci_cf_port_reset_rwsem",
                cast[uint64](&_l64_ehci_cf_port_reset_rwsem_buf[0]))

    # ---- Group 2: platform_driver array-register glue ----
    _add_export("__platform_register_drivers",
                cast[uint64](&_l___platform_register_drivers))
    _add_export("platform_unregister_drivers",
                cast[uint64](&_l_platform_unregister_drivers))

    # ---- Group 3: Xen PV-USB debug-port hooks ----
    _add_export("xen_dbgp_external_startup",
                cast[uint64](&_l_xen_dbgp_external_startup))
    _add_export("xen_dbgp_reset_prep",
                cast[uint64](&_l_xen_dbgp_reset_prep))

    # ---- Group 4: ohci-hcd extras ----
    _add_export("gen_pool_dma_zalloc_align",
                cast[uint64](&_l_gen_pool_dma_zalloc_align))
    _add_export("get_zeroed_page_noprof",
                cast[uint64](&_l_get_zeroed_page_noprof))
    _add_export("sb800_prefetch",
                cast[uint64](&_l_sb800_prefetch))

# linux_abi/api_chrdev.ad
#
# L4 of the Hamnix Linux-ABI track: character-device registration.
#
# Stock Linux 6.12 modules reach for one of two register families:
#
#   The "old" major-table interface, still widely used in tiny drivers:
#     int  register_chrdev(unsigned int major,
#                          const char *name,
#                          const struct file_operations *fops);
#     void unregister_chrdev(unsigned int major, const char *name);
#
#   The "new" cdev_*/region interface that almost all real drivers use:
#     int  alloc_chrdev_region(dev_t *dev, unsigned baseminor,
#                              unsigned count, const char *name);
#     void unregister_chrdev_region(dev_t from, unsigned count);
#     void cdev_init(struct cdev *, const struct file_operations *);
#     int  cdev_add(struct cdev *, dev_t, unsigned);
#     void cdev_del(struct cdev *);
#
# All seven symbols live behind shims here; the L1 loader wires them
# in by name through linux_abi/exports.ad.
#
# L4 SCOPE — minimum viable:
#   The M5.1 test fixture just calls register_chrdev / unregister_chrdev
#   and prints a banner. It does not open() or read() the device. So
#   the dispatch table that ties (major, minor) -> file_operations
#   doesn't need to be wired into Hamnix's VFS yet. We keep a 16-slot
#   static table so that:
#     - unregister/free symmetry can be verified,
#     - duplicate-major / no-free-slot error paths exist,
#     - auto-major allocation (the major==0 path) returns deterministic
#       values for the regression suite to assert on.
#   When a later L milestone wires fops into open(), the slot table is
#   already where it needs to be — that work becomes "make Hamnix's VFS
#   consult chrdev_slots[major]" rather than a refactor.
#
# Auto-major numbering: Linux reserves 1..239 for documented uses
# (mem=1, vc=4, tty=5, ttyS=4 alt, etc.). We allocate from 240 upward
# the same way Linux's get_unused_major() does, so a real module that
# was compiled expecting an auto-major won't collide with a documented
# device when (eventually) it shares the namespace with one.
#
# struct file_operations / struct cdev opaque-blob sizes:
#   These match the rough Linux 6.12 layouts. Exact byte counts live
#   in BTF; here we just need a number large enough that the module's
#   compiler-emitted struct definition fits without us caring about
#   internal field offsets. cdev_init() writes the fops pointer at
#   offset 0 of the cdev struct (where the kobject embed sits in real
#   Linux — for L4 we just use offset 0 as a one-word slot).

from linux_abi.exports import _add_export


# --- Opaque struct sizes (Linux 6.12 ballpark) ----------------------

FOPS_SIZE: uint64 = 256      # struct file_operations is ~200 bytes
CDEV_SIZE: uint64 = 80       # struct cdev is ~72 bytes


# --- Slot table -----------------------------------------------------
#
# 16 slots is enough for L4's needs (the test fixture uses 1; real
# Linux ships with dozens of static major numbers, but L4 doesn't need
# to track those — they don't go through register_chrdev). When a
# later milestone needs more, bump MAX_CHRDEV_SLOTS and the Array
# dimensions together.
#
# Slot layout (parallel arrays — same Ptr-in-struct-global pitfall
# that exports.ad calls out):
#   chrdev_major    : major number; 0 means "free slot"
#   chrdev_name     : Ptr[char] cast to uint64 (caller-owned string,
#                     we don't strdup — Linux doesn't either)
#   chrdev_fops     : address of the module's struct file_operations
#
# We don't track the minor range yet; for L4 every registered major
# implicitly owns minors 0..255 the same way Linux's old API does.

MAX_CHRDEV_SLOTS: uint64 = 16

chrdev_major: Array[16, uint32]
chrdev_name:  Array[16, uint64]
chrdev_fops:  Array[16, uint64]


# Auto-major bump pointer. Starts at 240 (first free per Documentation/
# admin-guide/devices.txt) and walks up; we don't recycle freed
# auto-majors. The static table caps the runaway at 240 + 16 = 256, so
# we never collide with Linux's 511 cap before exhausting our slots.

next_auto_major: uint32 = 240


# --- Helpers --------------------------------------------------------

def _chrdev_find_free_slot() -> int32:
    # Returns slot index 0..MAX_CHRDEV_SLOTS-1, or -1 if full.
    i: uint64 = 0
    while i < MAX_CHRDEV_SLOTS:
        if chrdev_major[i] == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _chrdev_find_by_major(major: uint32) -> int32:
    # Locate the slot currently holding `major`. Returns -1 if unused.
    i: uint64 = 0
    while i < MAX_CHRDEV_SLOTS:
        if chrdev_major[i] == major:
            return cast[int32](i)
        i = i + 1
    return -1


def _chrdev_alloc_auto_major() -> uint32:
    # Hand out the next free auto-major. Walks next_auto_major upward
    # so repeated allocations don't collide with each other within a
    # single boot. The static slot table is the real capacity limit;
    # this counter is just a "deterministic name" generator.
    m: uint32 = next_auto_major
    next_auto_major = next_auto_major + 1
    return m


# --- Shims: register_chrdev / unregister_chrdev ---------------------

def _l_register_chrdev(major: uint32, name: uint64, fops: uint64) -> int32:
    # Linux semantics:
    #   major == 0 → auto-allocate and return the assigned major.
    #   major  > 0 → use it verbatim; fail with -EBUSY if already in use.
    # Errors return a negative errno (-EBUSY=-16, -EINVAL=-22).
    #
    # We don't validate `name` (Linux doesn't enforce non-NULL either —
    # it just stores whatever the caller hands over and shows it in
    # /proc/devices). For L4 we accept fops == 0 too; until VFS wires
    # it in, the pointer is purely advisory.

    slot: int32 = _chrdev_find_free_slot()
    if slot < 0:
        return -12                              # -ENOMEM (table full)

    assigned: uint32 = major
    if major == 0:
        assigned = _chrdev_alloc_auto_major()
    else:
        # Explicit major requested — check it isn't already taken.
        if _chrdev_find_by_major(major) >= 0:
            return -16                          # -EBUSY

    s: uint64 = cast[uint64](slot)
    chrdev_major[s] = assigned
    chrdev_name[s]  = name
    chrdev_fops[s]  = fops
    return cast[int32](assigned)


def _l_unregister_chrdev(major: uint32, name: uint64) -> int32:
    # Linux's prototype is `void unregister_chrdev(...)`, but our shim
    # returns int32 so the loader's relocation site has a uniform
    # 8-byte slot. The module's caller discards the return value the
    # same way it would for the real void function.
    #
    # We ignore `name` for matching — major number is the unique key.
    # A spurious unregister (wrong major or never-registered major)
    # is a no-op, mirroring Linux's behavior of just printing a warn
    # in that case.
    slot: int32 = _chrdev_find_by_major(major)
    if slot < 0:
        return 0
    s: uint64 = cast[uint64](slot)
    chrdev_major[s] = 0
    chrdev_name[s]  = 0
    chrdev_fops[s]  = 0
    return 0


# --- Shims: alloc_chrdev_region / unregister_chrdev_region ----------

def _l_alloc_chrdev_region(dev_out: uint64, baseminor: uint32,
                            count: uint32, name: uint64) -> int32:
    # Writes the assigned dev_t into *dev_out and returns 0.
    # dev_t is Linux's 32-bit (major << 20) | minor encoding (MAJOR
    # is the high 12 bits, MINOR is the low 20 bits). We honor
    # baseminor in the encoding but don't actually reserve minors
    # past 0 — for L4 there's no per-minor cdev table.

    slot: int32 = _chrdev_find_free_slot()
    if slot < 0:
        return -12                              # -ENOMEM
    assigned: uint32 = _chrdev_alloc_auto_major()

    s: uint64 = cast[uint64](slot)
    chrdev_major[s] = assigned
    chrdev_name[s]  = name
    chrdev_fops[s]  = 0                          # filled in by cdev_add later

    dev_t_val: uint32 = (assigned << 20) | (baseminor & 0xFFFFF)
    if dev_out != 0:
        out: Ptr[uint32] = cast[Ptr[uint32]](dev_out)
        out[0] = dev_t_val
    return 0


def _l_unregister_chrdev_region(from_dev: uint32, count: uint32) -> int32:
    # Extract MAJOR(from_dev) and free that slot. count > 1 (spanning
    # multiple majors) is rare; for L4 we only free the base major.
    major: uint32 = from_dev >> 20
    slot: int32 = _chrdev_find_by_major(major)
    if slot < 0:
        return 0
    s: uint64 = cast[uint64](slot)
    chrdev_major[s] = 0
    chrdev_name[s]  = 0
    chrdev_fops[s]  = 0
    return 0


# --- Shims: cdev_init / cdev_add / cdev_del -------------------------

def _l_cdev_init(cdev_ptr: uint64, fops_ptr: uint64):
    # Real Linux: memset(cdev, 0, sizeof *cdev); kobject_init();
    # cdev->ops = fops; cdev->owner = NULL.
    #
    # For L4 the cdev blob is opaque to the rest of the kernel. We
    # zero the first CDEV_SIZE bytes (defensive — the module may not
    # have zeroed it itself; kbuild's static initializers do, but a
    # heap-alloc'd cdev would not) and then plant the fops pointer
    # at offset 0. The "real" field offset is wherever struct cdev's
    # `ops` member sits, which BTF will pin down at L0-completion;
    # for now offset 0 is a stable storage slot that survives until
    # the next milestone refactors it.
    if cdev_ptr == 0:
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](cdev_ptr)
    i: uint64 = 0
    while i < CDEV_SIZE:
        p[i] = 0
        i = i + 1
    # Plant fops at offset 0 (L4 convention; the BTF-driven layout
    # in a later milestone will move this to the real `ops` offset).
    slot_ptr: Ptr[uint64] = cast[Ptr[uint64]](cdev_ptr)
    slot_ptr[0] = fops_ptr


def _l_cdev_add(cdev_ptr: uint64, dev: uint32, count: uint32) -> int32:
    # Real Linux registers (cdev, MAJOR(dev), MINOR(dev)..+count) in
    # the cdev_map. L4 doesn't have that map yet — register_chrdev /
    # alloc_chrdev_region already recorded the (major, fops) pair in
    # chrdev_slots, so this is a no-op for the test fixture.
    #
    # We accept the call (return 0) and leave the cdev blob alone.
    # When VFS wiring lands, this becomes the dispatch-table-insert
    # path.
    return 0


def _l_cdev_del(cdev_ptr: uint64):
    # Symmetric no-op. The slot itself gets freed by the matching
    # unregister_chrdev_region call.
    return


# --- Export-table registration --------------------------------------

def linux_abi_register_chrdev():
    # Called from start_kernel after linux_abi_exports_init has wired
    # the core (printk/kmalloc/...) symbols. Splitting per-subsystem
    # init lets each L milestone land an api_*.ad file without
    # touching exports.ad's table.
    _add_export("register_chrdev",
                cast[uint64](&_l_register_chrdev))
    _add_export("unregister_chrdev",
                cast[uint64](&_l_unregister_chrdev))
    _add_export("cdev_init",
                cast[uint64](&_l_cdev_init))
    _add_export("cdev_add",
                cast[uint64](&_l_cdev_add))
    _add_export("cdev_del",
                cast[uint64](&_l_cdev_del))
    _add_export("alloc_chrdev_region",
                cast[uint64](&_l_alloc_chrdev_region))
    _add_export("unregister_chrdev_region",
                cast[uint64](&_l_unregister_chrdev_region))

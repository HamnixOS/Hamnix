# =====================================================================
# Group 19: wait_for_completion extensions
# =====================================================================

def _l_wait_for_completion_timeout(x: uint64, timeout: uint64) -> uint64:
    # unsigned long wait_for_completion_timeout(struct completion *,
    #                                             unsigned long timeout);
    # Returns the jiffies remaining (>0 == woke before timeout). The
    # cold init path doesn't actually fire — return the full timeout.
    return timeout


def _l_wait_for_completion_killable_timeout(x: uint64, timeout: uint64) -> uint64:
    # long wait_for_completion_killable_timeout(struct completion *,
    #                                             unsigned long);
    return timeout


# =====================================================================
# Group 20: Chrdev extensions
# =====================================================================

def _l_register_chrdev_region(from_: uint64, count: uint32,
                                name: uint64) -> int32:
    # int register_chrdev_region(dev_t from, unsigned count, const char *);
    return 0


def _l___register_chrdev(major: uint32, baseminor: uint32, count: uint32,
                          name: uint64, fops: uint64) -> int32:
    # int __register_chrdev(unsigned int major, unsigned int baseminor,
    #                        unsigned int count, const char *name,
    #                        const struct file_operations *fops);
    # Linux semantics: if major != 0 returns 0 on success (registers
    # the specified major); if major == 0 returns the allocated major.
    # usbcore passes USB_MAJOR=180 statically, expects 0 back.
    if major == 0:
        return 180
    return 0


def _l___unregister_chrdev(major: uint32, baseminor: uint32,
                            count: uint32, name: uint64):
    # void __unregister_chrdev(unsigned int major, unsigned int baseminor,
    #                            unsigned int count, const char *name);
    return


# =====================================================================
# Group 21: Jiffies / ktime / usleep_range
# =====================================================================

def _l_jiffies_to_msecs(j: uint64) -> uint32:
    # unsigned int jiffies_to_msecs(unsigned long j);
    # Assume HZ=1000 (the common Hamnix default); 1 jiffy == 1 ms.
    return cast[uint32](j)


def _l_ktime_get_mono_fast_ns() -> uint64:
    # u64 ktime_get_mono_fast_ns(void);
    # Fast monotonic time. Stub returns 0.
    return 0


def _l_usleep_range_state(min: uint64, max: uint64, state: uint32):
    # void usleep_range_state(unsigned long min, unsigned long max,
    #                          unsigned int state);
    # Linux's hr-timer-backed sleep — sleeps for at least `min` and at
    # most `max` microseconds, in TASK_UNINTERRUPTIBLE (state) by
    # default. Hamnix has no hr-timer infrastructure to honour the
    # duration precisely, but treating this as a no-op (the previous
    # behaviour) is strictly wrong: stock .ko code uses usleep_range
    # exactly where a brief yield is REQUIRED for forward progress
    # (e.g. xhci_handshake's bus-relax between handshakes, usbcore's
    # hub_port_init step-pause). kernel_cond_resched gives the LAPIC
    # timer a window to advance jiffies, drains the UART RX FIFO, and
    # rotates to any STATE_READY peer — i.e. the parts of "sleep" that
    # are load-bearing for forward progress without committing to a
    # high-resolution duration. Cost: one sti+hlt+cli (LAPIC timer
    # fires within at most one HZ tick) — comfortably under the
    # usual usleep_range(50, 100) min-value of "a few tens of usec".
    kernel_cond_resched()



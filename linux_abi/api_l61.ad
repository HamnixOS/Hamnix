# DATA: usb_debug_root (struct dentry *). NULL pointer storage.
usb_debug_root_buf:     Array[8, uint8]


def _l_usb_speed_string(speed: int32) -> uint64:
    # const char *usb_speed_string(enum usb_device_speed speed);
    # Returns a small DATA string per speed. Return pointer to a
    # fixed "unknown" buffer (callers print it; we just need a
    # non-NULL stable C-string).
    return cast[uint64](&_l_unknown_str_buf[0])


_l_unknown_str_buf:   Array[8, uint8]


def _l___populate_unknown_str():
    _l_unknown_str_buf[0] = 0x75  # 'u'
    _l_unknown_str_buf[1] = 0x6E  # 'n'
    _l_unknown_str_buf[2] = 0x6B  # 'k'
    _l_unknown_str_buf[3] = 0x6E  # 'n'
    _l_unknown_str_buf[4] = 0x6F  # 'o'
    _l_unknown_str_buf[5] = 0x77  # 'w'
    _l_unknown_str_buf[6] = 0x6E  # 'n'
    _l_unknown_str_buf[7] = 0x00



# DATA: USER_PTR_MAX — userspace pointer ceiling for x86_64 hardening.
# Linux exports this as a `unsigned long` (8 bytes) initialised to
# TASK_SIZE_MAX (0x00007FFFFFFFF000 on 5-level paging hosts, 0x7FFFFFFFF000
# on classic 4-level). We pick the conservative 4-level value.
USER_PTR_MAX_val:    uint64 = 0x00007FFFFFFFF000



def _l_memdup_user(src: uint64, len: uint64) -> uint64:
    # void *memdup_user(const void __user *src, size_t len);
    # Allocates kernel memory and copies from userspace. Our env has
    # no separate userspace at this point on the L-track init path,
    # but a literal byte-copy is safe — the source pages are mapped
    # the same way. Return ERR_PTR(-EFAULT) (0xFFFFFFFFFFFFFFF2) so
    # init-path callers fail fast and skip the optional code branch.
    return 0xFFFFFFFFFFFFFFF2



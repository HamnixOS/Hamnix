def _l_alloc_workqueue_l61(fmt: uint64, flags: uint32, max_active: int32) -> uint64:
    # struct workqueue_struct *alloc_workqueue(const char *fmt,
    #                                            unsigned int flags,
    #                                            int max_active, ...);
    # Allocates a workqueue. Stub: return a 64-byte zero buffer
    # (sized like system_wq_buf in L59) so callers have a non-NULL
    # opaque pointer. Note: api_kthread.ad has its own
    # _l_alloc_workqueue handling the `__alloc_workqueue` Linux-6 symbol;
    # this L61 wrapper covers the older / aliased `alloc_workqueue`
    # symbol that usbcore actually imports.
    p: uint64 = kmalloc(64)
    return p



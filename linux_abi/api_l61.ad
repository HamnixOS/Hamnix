# =====================================================================
# Group 6: DMA API + dma_pool
# =====================================================================

def _l_dma_alloc_attrs(dev: uint64, size: uint64, dma_handle: uint64,
                        gfp: uint32, attrs: uint64) -> uint64:
    # void *dma_alloc_attrs(struct device *, size_t, dma_addr_t *,
    #                        gfp_t, unsigned long attrs);
    # Allocates DMA-coherent memory.
    #
    # CRITICAL: must NOT use kmalloc — for sizes > 2 KiB the slab's
    # large-alloc path returns `page+8` with an 8-byte "PKLG" header,
    # which breaks 128-byte-aligned descriptor base registers (the
    # chip silently rounds down, leaving the driver's first descriptor
    # 8 bytes offset from where the chip fetches). Same fix as
    # api_dma.ad's _l_dma_alloc_coherent: use alloc_pages so the
    # returned address is naturally page-aligned. dma_handle is set
    # to the same value (no IOMMU, no SWIOTLB in Hamnix).
    if size == 0:
        if dma_handle != 0:
            dh_z: Ptr[uint64] = cast[Ptr[uint64]](dma_handle)
            dh_z[0] = 0
        return 0
    o: int32 = 0
    sz: uint64 = PAGE_SIZE
    while sz < size:
        sz = sz << 1
        o = o + 1
    p: uint64 = alloc_pages(o)
    if p == 0:
        if dma_handle != 0:
            dh_n: Ptr[uint64] = cast[Ptr[uint64]](dma_handle)
            dh_n[0] = 0
        return 0
    memset(cast[Ptr[uint8]](p), 0, sz)
    if dma_handle != 0:
        dh: Ptr[uint64] = cast[Ptr[uint64]](dma_handle)
        dh[0] = p
    return p


def _l_dma_free_attrs(dev: uint64, size: uint64, vaddr: uint64,
                       dma: uint64, attrs: uint64):
    # void dma_free_attrs(struct device *, size_t, void *, dma_addr_t,
    #                      unsigned long attrs);
    # Symmetric: free_pages with the order computed from size.
    if vaddr == 0:
        return
    o: int32 = 0
    sz: uint64 = PAGE_SIZE
    while sz < size:
        sz = sz << 1
        o = o + 1
    free_pages(vaddr, o)
    return


def _l_dmam_alloc_attrs(dev: uint64, size: uint64, dma_handle: uint64,
                         gfp: uint32, attrs: uint64) -> uint64:
    # void *dmam_alloc_attrs(...); — managed (devm) variant.
    return _l_dma_alloc_attrs(dev, size, dma_handle, gfp, attrs)


def _l_dma_map_page_attrs(dev: uint64, page: uint64, offset: uint64,
                            size: uint64, dir: int32,
                            attrs: uint64) -> uint64:
    # dma_addr_t dma_map_page_attrs(struct device *, struct page *,
    #                                 size_t offset, size_t size,
    #                                 enum dma_data_direction,
    #                                 unsigned long attrs);
    #
    # In real Linux, `page` is a `struct page *` whose value sits in
    # the sparsemem vmemmap region — i.e. `page = vmemmap + pfn`. To
    # recover the physical address the caller wants here, we have to
    # invert that: `pfn = (page - vmemmap) / sizeof(struct page)` and
    # `phys = pfn << PAGE_SHIFT`. Hamnix's `vmemmap_base = 0`, so
    # `page = pfn * sizeof(struct page)` and `pfn = page / SIZEOF_PAGE`.
    # `sizeof(struct page)` on Linux 6.1 x86_64 is 64 bytes (cache-line-
    # aligned). The pfn-to-phys conversion then gives `(page / 64) << 12`
    # i.e. `(page >> 6) << 12 = page << 6`.
    #
    # Before this fix the shim returned `page + offset`, which is an
    # in-vmemmap virtual address (not a physical DMA address) — the
    # chip then DMA'd from that bogus address and pulled garbage (all
    # zeros once the DMA target happened to be unmapped). Observable as
    # a 342-byte DHCPDISCOVER on the wire whose bytes were all 0x00,
    # so SLIRP's DHCP server never recognised the packet.
    #
    # SIZEOF_STRUCT_PAGE = 64 (Linux 6.1 amd64 default config); if a
    # future kernel build changes the layout we'll discover it via
    # this conversion producing nonsense addresses.
    pfn: uint64 = page >> 6                              # / 64
    phys: uint64 = pfn << 12                             # << PAGE_SHIFT
    return phys + offset



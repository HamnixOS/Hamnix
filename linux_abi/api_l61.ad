# linux_abi/api_l61.ad
#
# L61: ships usbcore.ko — the Linux USB stack foundation. It pulls in
# 309 UND symbols of which 197 are new at L60 (the other 112 are
# already covered by L<=60). usbcore.ko's init_module body registers
# the USB bus type, the USB device class, allocates IDR pools, sets
# up a workqueue, opens a few /proc + /sys nodes, and registers the
# usbfs character device — every one of those resolves through a
# stub here.
#
# This is the 35th distro module to load and the first one to land
# the device-model / sysfs / pm_runtime / DMA-pool / kobject_uevent /
# component-framework surface. Every shim is init-safe: usbcore's
# init body touches all 197 of these, but each one returns
# success / 0 / NULL / void to keep init_module on the happy path.
# Runtime hot paths (URB submit, hub thread, port enumeration) never
# fire in our env because there are no HCD drivers below us.
#
# UND analysis (`readelf -s --wide`):
#   usbcore.ko       309 UND total
#   covered by L<=60 112
#   missing at L60   197 (this batch)
#
# Plus the usb-common.ko helpers — usbcore depends on usb-common, but
# our loader doesn't yet ingest a sibling .ko's ksymtab, so the seven
# usb-common symbols (usb_decode_interval, usb_ep_type_string,
# usb_speed_string, usb_state_string, usb_led_activity,
# usb_hcd_amd_remote_wakeup_quirk, usb_debug_root DATA) must also
# resolve through L61 to load usbcore alone.
#
# Stub philosophy mirrors L51..L60: every shim is init-cold. The few
# functions that need to allocate (kasprintf, memdup_user) do a
# bounded kmalloc + byte-copy and return the new pointer. DATA
# exports point at zero-initialised backing buffers sized to the
# largest field offset any init-path peeker reads (typically 64 or
# 256 bytes for opaque kernel structs, single uint32/uint64 for
# scalar counters).
#
# Naming notes:
#   * Adder reserves `bytes` -> use `nbytes`.
#   * Adder reserves `file`  -> use `filp` / `f`.
#
# Groups (23):
#   1.  Driver model: device_*, driver_*, get/put_device, fwnode
#   2.  Bus / class / component framework
#   3.  Device PM QoS
#   4.  pm_runtime
#   5.  Workqueue + wait-queue extensions
#   6.  DMA API extensions + dma_pool
#   7.  Sysfs extensions
#   8.  kobject / kernfs
#   9.  IDR + ACPI bus
#   10. PCI extensions
#   11. PHY framework
#   12. gen_pool
#   13. usb-common helpers (DATA + functions)
#   14. dev_printk family
#   15. cred / pid
#   16. spinlock_irq + yield + mutex_interruptible
#   17. devm_ helpers (ioremap / memremap / request_region)
#   18. String / kstrto / format / memdup helpers
#   19. Wait-for-completion extensions
#   20. Chrdev extensions
#   21. Jiffies / ktime / usleep_range
#   22. mmap remap
#   23. Blocking notifier chain
#   24. Misc DATA + helpers (iomem_resource, USER_PTR_MAX, ...)

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc, kfree
from mm.page_alloc import alloc_pages, free_pages, PAGE_SIZE
from kernel.sched.core import kernel_cond_resched

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


# =====================================================================
# Group 1: Driver model — struct device + struct device_driver lifecycle
# =====================================================================
#
# usbcore registers itself as a bus type and creates the root USB host
# device + per-bus device, then driver_register() pulls in usb_driver
# probe/disconnect callbacks. Every device_*/driver_* on the L61 list
# is init-only or runtime-cold for our env.

# struct device embeds a struct kobject as its first member; the
# kobject's kref refcount_t lives at offset 0x38 (kernel 6.1 x86_64:
# name(8) + entry(16) + parent(8) + kset(8) + ktype(8) + sd(8) =>
# kref at 0x38). dev->release (void (*)(struct device *)) lives at
# offset 0x2c0 (verified against snd.ko: card_dev base card+0x568,
# release pointer stored at card+0x828 => 0x828-0x568 = 0x2c0).
#
# Our device_initialize/get_device/put_device are the SOLE owners of
# this refcount (the .ko side never touches kref directly — it goes
# through these shims), so we model the real Linux lifecycle: init
# sets ref=1, get_device bumps it, put_device drops it and, on the
# 1->0 transition, invokes dev->release(dev). This makes the driver
# core's "free the device and signal teardown" contract actually fire
# — e.g. snd_card_free() does put_device(&card->card_dev) then
# wait_for_completion(&card->card_free); the release callback
# (release_card_device) is what calls complete() on that completion.
# A no-op put_device left that wait spinning forever.
_DEV_KREF_OFF:    uint64 = 0x38
_DEV_RELEASE_OFF: uint64 = 0x2c0


def _l_get_device(dev: uint64) -> uint64:
    # struct device *get_device(struct device *dev);
    # Bumps refcount + returns dev (or NULL if dev was NULL).
    if dev == 0:
        return 0
    rc: Ptr[uint32] = cast[Ptr[uint32]](dev + _DEV_KREF_OFF)
    rc[0] = rc[0] + 1
    return dev


def _l_put_device(dev: uint64):
    # void put_device(struct device *dev);
    # Drops refcount; on the final reference (1 -> 0) invokes
    # dev->release(dev) just like the driver core's kobject_release ->
    # device_release path.
    if dev == 0:
        return
    rc: Ptr[uint32] = cast[Ptr[uint32]](dev + _DEV_KREF_OFF)
    cur: uint32 = rc[0]
    if cur == 0:
        # Never initialized / already released — nothing to drop.
        return
    cur = cur - 1
    rc[0] = cur
    if cur == 0:
        rel: uint64 = cast[Ptr[uint64]](dev + _DEV_RELEASE_OFF)[0]
        if rel != 0:
            relfn: Fn[None, uint64] = cast[Fn[None, uint64]](rel)
            relfn(dev)


def _l_device_initialize(dev: uint64):
    # void device_initialize(struct device *dev);
    # Initialises a struct device's embedded kobject + lists. We model
    # the kref: a freshly initialized device holds a single reference,
    # matching kobject_init()'s kref_init(&kobj->kref) (refcount = 1).
    if dev == 0:
        return
    cast[Ptr[uint32]](dev + _DEV_KREF_OFF)[0] = 1


def _l_device_add(dev: uint64) -> int32:
    # int device_add(struct device *dev);
    # Registers a struct device with the driver core. Returns 0 on
    # success. Init-path uses this to attach the USB bus device.
    return 0


def _l_device_del(dev: uint64):
    # void device_del(struct device *dev);
    # Unregisters a struct device. No-op stub.
    return


def _l_device_register(dev: uint64) -> int32:
    # int device_register(struct device *dev);
    # Equivalent to device_initialize + device_add. Seeds the kref to 1
    # (the caller's reference) so a matching device_unregister ->
    # put_device fires the release callback.
    if dev != 0:
        cast[Ptr[uint32]](dev + _DEV_KREF_OFF)[0] = 1
    return 0


def _l_device_unregister(dev: uint64):
    # void device_unregister(struct device *dev);
    # Equivalent to device_del + put_device: drop the caller's
    # reference, releasing the device on the final put.
    _l_device_del(dev)
    _l_put_device(dev)


def _l_device_attach(dev: uint64) -> int32:
    # int device_attach(struct device *dev);
    # Tries to bind a driver to the device. 0 == "no driver matched";
    # 1 == "bound". Stub returns 0 (no driver).
    return 0



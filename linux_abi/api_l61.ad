# DATA: pm_wq (struct workqueue_struct *). 64-byte zero buffer.
pm_wq_buf:               Array[64, uint8]
# DATA: power_group_name (const char *). Real Linux: "power".
# Module reads it as a string; we provide it.
power_group_name_buf:    Array[8, uint8]


def _l___populate_power_group_name():
    # Initialise power_group_name_buf at boot to the string "power".
    # Called from linux_abi_register_l61.
    power_group_name_buf[0] = 0x70  # 'p'
    power_group_name_buf[1] = 0x6F  # 'o'
    power_group_name_buf[2] = 0x77  # 'w'
    power_group_name_buf[3] = 0x65  # 'e'
    power_group_name_buf[4] = 0x72  # 'r'
    power_group_name_buf[5] = 0x00



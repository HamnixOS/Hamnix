# DATA: pci_power_names — array of strings ["D0","D1","D2","D3hot","D3cold","unknown"].
# usbcore dereferences pci_power_names[state] for debug prints. We
# supply a single empty-string entry table (6 pointers all pointing
# at the same empty string) so any state index is safe.
pci_power_names_empty:    Array[2, uint8]    # ""
pci_power_names_arr:      Array[6, uint64]


def _l___populate_pci_power_names():
    i: uint64 = 0
    while i < 6:
        pci_power_names_arr[i] = cast[uint64](&pci_power_names_empty[0])
        i = i + 1



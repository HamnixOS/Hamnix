    #                                        struct notifier_block *);
    return 0


def _l_blocking_notifier_chain_unregister(nh: uint64, nb: uint64) -> int32:
    return 0


def _l_blocking_notifier_call_chain(nh: uint64, val: uint64,
                                      v: uint64) -> int32:
    # int blocking_notifier_call_chain(struct blocking_notifier_head *,
    #                                    unsigned long val, void *v);
    # NOTIFY_DONE == 0x0000. Caller sees "no notifier objected".
    return 0


# =====================================================================
# Group 24: Misc DATA + helpers
# =====================================================================

# DATA: iomem_resource — root MMIO resource tree. 256-byte zero buffer.
# usbcore's __devm_request_region peeks the parent pointer; with a
# zero buffer the parent appears unparented.
iomem_resource_buf:        Array[256, uint8]

# DATA: ioport_resource — root I/O port resource tree.
ioport_resource_buf:       Array[256, uint8]


def _l__find_next_zero_bit(addr: uint64, size: uint64, offset: uint64) -> uint64:
    # unsigned long _find_next_zero_bit(const unsigned long *addr,
    #                                    unsigned long size,
    #                                    unsigned long offset);
    # Returns the bit position of the next zero. Stub returns size
    # (== "no zero found"); init callers treat that as "table full".
    return size


def _l_add_device_randomness(buf: uint64, size: uint64):
    # void add_device_randomness(const void *buf, size_t size);
    return


def _l___printk_ratelimit(func: uint64) -> int32:
    # int __printk_ratelimit(const char *func);
    # 1 == "allowed"; 0 == "suppressed". Always allow.
    return 1


def _l___get_user_1() -> int32:
    # __get_user_1: load 1 byte from user space. Returns -EFAULT.
    # See L57 group 3 for calling-convention notes.
    return -14


def _l_debugfs_lookup_and_remove(name: uint64, parent: uint64):
    # void debugfs_lookup_and_remove(const char *name, struct dentry *parent);
    return



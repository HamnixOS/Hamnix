# linux_abi/api_waitq.ad - L7 shims (wait queues).
#
# Linux's wait_queue subsystem is how drivers turn "data not ready"
# into "sleep until the IRQ handler taps me." Half the kernel uses
# it: blocking reads, blocking accept(), wait_event_interruptible,
# the page-cache lock-bit waiter, ... Module-side code surfaces:
#
#   void __init_waitqueue_head(struct wait_queue_head *q,
#                              const char *name,
#                              struct lock_class_key *k);
#   void prepare_to_wait(struct wait_queue_head *q,
#                        struct wait_queue_entry *e, int state);
#   void finish_wait(struct wait_queue_head *q,
#                    struct wait_queue_entry *e);
#   void __wake_up(struct wait_queue_head *q, unsigned int mode,
#                  int nr_exclusive, void *key);
#   signed long schedule_timeout(signed long timeout);
#
# Implementation strategy:
#
# A real wait_queue is a linked list of entries, each pointing at a
# task_struct; __wake_up walks the list and flips matching tasks
# back to TASK_RUNNING. For L7 the regression module (M4.1 UART RX)
# only needs the wake/sleep round-trip to work — it doesn't care
# about per-entry callbacks, exclusivity flags, or fairness. So we
# collapse the entire wait_queue_head down to a single 64-bit
# counter at offset 0 of the caller's struct:
#
#   offset 0   uint64   wake_count    incremented by __wake_up
#   offset 8   uint64   magic         catches uninit / type-confusion
#
# Linux's struct wait_queue_head is 24 bytes (lock + list_head) so
# writing 16 at offset 0 fits inside the caller's allocation.
#
# wait_event-style users follow the kernel idiom
#   prepare_to_wait(q, &e, TASK_INTERRUPTIBLE);
#   if (!condition) schedule();
#   finish_wait(q, &e);
# We need them to spin-yield until __wake_up bumps wake_count past
# what they observed at prepare_to_wait time. The wait_queue_entry
# struct is reusable scratch — we stash the observed count at
# offset 0 of the entry so finish_wait can find it. (Linux's real
# wait_queue_entry is 40 bytes; writing 8 at offset 0 fits.)
#
# schedule_timeout is the cooperative-sleep primitive; for L7 we
# yield once and pretend the timeout elapsed (return 0 — "timed
# out, no remainder"). The M4.1 fixture uses it as a courtesy
# yield, not a precise sleep, so this is functionally correct.

from linux_abi.exports import _add_export
from kernel.sched.core import yield_to_others


WAITQ_MAGIC: uint64 = 0x57415154514E4400      # 'WAITQND\0' (Wait Queue heaD)


# --- wait_queue_head shims ------------------------------------------

def _l_init_waitqueue_head(q: uint64, name: uint64, key: uint64):
    # __init_waitqueue_head(&q, "name", &lock_class_key). name + key
    # are lockdep debug hooks we don't implement — drop them.
    if q == 0:
        return
    cast[Ptr[uint64]](q)[0] = 0                       # wake_count = 0
    cast[Ptr[uint64]](q + 8)[0] = WAITQ_MAGIC


# --- wait_queue_entry shims -----------------------------------------
#
# Entry's offset 0 holds the wake_count we observed at prepare_to_wait
# time. The caller's wait loop is then equivalent to:
#   while q->wake_count == e->seen_count: yield()
# which means a __wake_up that bumps wake_count past the observed
# value will release us. Edge case: if the wake_up fires BEFORE
# prepare_to_wait runs (lost-wakeup race), we'd observe the new
# count and never yield — which is actually correct (we already
# missed the event but the condition we're waiting on must have
# been set first, per the wait_event idiom).

def _l_prepare_to_wait(q: uint64, e: uint64, state: int32):
    # state is TASK_INTERRUPTIBLE / TASK_UNINTERRUPTIBLE — we don't
    # distinguish (no signal-aware sleep at L7; yield_to_others
    # already checks signals on its idle return).
    if q == 0 or e == 0:
        return
    cast[Ptr[uint64]](e)[0] = cast[Ptr[uint64]](q)[0]


def _l_finish_wait(q: uint64, e: uint64):
    # In Linux, finish_wait removes the entry from the queue's list
    # and restores TASK_RUNNING. With our counter model there's no
    # list to unlink from and the caller is already runnable (it just
    # observed wake_count change), so this is a no-op. We zero the
    # entry's seen_count slot anyway so a use-after-finish is more
    # likely to fail loudly rather than silently re-arming.
    if e != 0:
        cast[Ptr[uint64]](e)[0] = 0


def _l_wake_up(q: uint64, mode: uint32, nr_exclusive: int32, key: uint64):
    # __wake_up(&q, mode, nr_exclusive, key). For L7 we ignore mode
    # (TASK_INTERRUPTIBLE filter), nr_exclusive (how many sleepers to
    # wake), and key (per-channel wakeup filter — used by epoll). The
    # counter bump fans out to every spinner unconditionally, which
    # is the conservative behaviour (extra wakeups are tolerated by
    # well-written wait_event loops).
    if q == 0:
        return
    p: Ptr[uint64] = cast[Ptr[uint64]](q)
    p[0] = p[0] + 1


def _l_schedule_timeout(timeout: int64) -> int64:
    # signed long schedule_timeout(signed long timeout);
    # Linux: sleep for `timeout` jiffies; returns remaining jiffies
    # if interrupted. The M4.1 fixture passes HZ/10 or similar as a
    # courtesy yield while waiting for the UART. We yield once (which
    # rotates the runqueue and hlt's for one tick) and return 0 —
    # "timed out cleanly, no jiffies left." A return of 0 matches
    # what real schedule_timeout returns on a clean timeout, so any
    # wait_event_timeout idiom that checks the return value will
    # interpret it as "timeout elapsed."
    yield_to_others()
    return 0


# --- registration ----------------------------------------------------

def linux_abi_register_waitq():
    # Called once from start_kernel, after the L1..L6 registrations.
    # Order doesn't matter — the export table is name-keyed — but
    # grouping by milestone keeps the boot log readable.
    _add_export("__init_waitqueue_head",  cast[uint64](&_l_init_waitqueue_head))
    _add_export("prepare_to_wait",        cast[uint64](&_l_prepare_to_wait))
    _add_export("finish_wait",            cast[uint64](&_l_finish_wait))
    _add_export("__wake_up",              cast[uint64](&_l_wake_up))
    _add_export("schedule_timeout",       cast[uint64](&_l_schedule_timeout))

# linux_abi/api_l65.ad
#
# L65: ships five more Debian 6.12 modules. Two are pure ride-alongs
# (zero new exports — every UND symbol already covered by L<=64),
# the other three need 13 new exports across four small groups.
#
#   * iptable_nat.ko       — IPv4 NAT chain (already declared "covered"
#                              by L62's ipt_/xt_ + nf_nat_ipv4 surface;
#                              this is the first batch that ships a
#                              real test_l65_iptable_nat.sh to prove
#                              the claim). 17 UND, 0 missing.
#   * llc.ko               — IEEE 802.2 Logical Link Control. The
#                              "fat" half of the LLC stack (the thin
#                              wrapper lives in stp.ko below). 26 UND,
#                              0 missing — everything maps onto the
#                              L<=64 sk_buff/socket/netdev/timer
#                              surface.
#   * nft_reject.ko        — nftables REJECT expression (sends ICMP
#                              unreachable / TCP RST in response to a
#                              matched packet). 5 UND, 1 missing
#                              (nft_chain_validate_hooks — shared with
#                              nft_compat / nft_log when those land).
#   * stp.ko               — Spanning Tree Protocol generic helper
#                              (used by bridge.ko's STP feature). 10
#                              UND, 2 missing (llc_sap_open +
#                              llc_sap_close — pulled in from llc.ko
#                              once it loads in the same kernel, but
#                              the loader still needs the names in
#                              the export table to resolve stp.ko's
#                              relocations).
#   * nft_log.ko           — nftables LOG expression (forwards matched
#                              packets to the nf_log infrastructure
#                              and/or the kernel audit subsystem). 20
#                              UND, 10 missing across two themes:
#                              kernel audit (audit_enabled DATA,
#                              audit_log_start, audit_log_format,
#                              audit_log_end), nf_log lookup
#                              (nf_logger_find_get, nf_logger_put),
#                              nft expression registry
#                              (nft_register_expr, nft_unregister_expr,
#                              nft_request_module), and one netlink
#                              helper (nla_strscpy).
#
# Module count in tests/linux-modules/ after L65: 43 + 5 = 48.
#
# UND analysis (`nm -u`, missing-after-L64):
#   iptable_nat.ko      0 missing
#   llc.ko              0 missing
#   nft_reject.ko       1 missing
#   stp.ko              2 missing
#   nft_log.ko          10 missing
#   union               13 unique
#
# 13 new exports across 4 groups:
#
#   1.  nftables expression registry + chain validation
#         (nft_register_expr, nft_unregister_expr, nft_request_module,
#          nft_chain_validate_hooks)
#   2.  LLC SAP open/close (llc_sap_open, llc_sap_close)
#   3.  Kernel audit (audit_enabled DATA, audit_log_start,
#          audit_log_format, audit_log_end)
#   4.  Netfilter logger lookup + netlink helper (nf_logger_find_get,
#          nf_logger_put, nla_strscpy)
#
# Stub philosophy mirrors L51..L64: every shim is init-cold for our
# env (no nftables ruleset, no userspace LLC client, no audit daemon,
# no live netlink listener). Each returns success / 0 / NULL / void
# so init_module stays on the happy path. The one DATA backing
# (audit_enabled) is a zero-init word — Linux treats 0 as
# AUDIT_OFF, which is exactly the right startup value for a system
# with no auditd attached.
#
# Naming notes:
#   * Adder reserves `bytes`, `match`, `case`, `file`, `field`, `type`
#     -> renamed to `nbytes` / `mt` / `cse` / `fp` / `fld` / `kind`.
#   * The "_l_" prefix marks the Hamnix-side shim; "_l65_" tags
#     DATA backings.

from linux_abi.exports import _add_export
from mm.slab import kmalloc, kzalloc


# =====================================================================
# Group 1: nftables expression registry + chain validation
# =====================================================================
#
# Linux:
#   int  nft_register_expr(struct nft_expr_type *type);
#   void nft_unregister_expr(struct nft_expr_type *type);
#   int  nft_request_module(struct net *net, const char *fmt, ...);
#   int  nft_chain_validate_hooks(const struct nft_chain *chain,
#                                    unsigned int hook_flags);
#
# nft_register_expr / nft_unregister_expr:
#   Called from each nft_*_expr module's init_module / cleanup_module
#   to register / deregister an nft expression operator. In Linux this
#   chains onto the nft_expr_type list under nf_tables_module_mutex;
#   in Hamnix there is no nf_tables core yet (it's the next big
#   chunk — see linux_abi/api_l67+ when it lands), so the register
#   stub just returns 0 ("registered ok") and unregister is void.
#   nft_log + nft_reject use this pair to publish their expression
#   on insmod; both modules treat ret==0 as success and continue.
#
# nft_request_module:
#   Variadic; asks the nf_tables core to modprobe a sub-module by
#   formatted name (e.g. "nft-expr-reject-ipv4"). With no kmod loader
#   chained through nf_tables, we drop the variadic tail (same
#   convention as _linux_printk_shim) and return 0 — Linux uses 0 to
#   mean "module is present", which keeps the caller's flow on the
#   happy path.
#
# nft_chain_validate_hooks:
#   Sanity check: returns 0 if the chain's hook mask is a subset of
#   `hook_flags`, -EOPNOTSUPP otherwise. At insmod time no chains
#   exist, so the function is only reached during runtime rule
#   commits. We return 0 to keep init paths happy; the real check
#   will need a live nf_tables core anyway.

def _l_nft_register_expr(kind: uint64) -> int32:
    # Adder reserves `type` -> renamed to `kind`. No nft_expr_type
    # list to thread; success keeps the caller's init body moving.
    return 0


def _l_nft_unregister_expr(kind: uint64):
    return


def _l_nft_request_module(net: uint64, fmt: Ptr[char]) -> int32:
    # Variadic tail dropped (same convention as _linux_printk_shim).
    # 0 == "module already loaded"; callers re-resolve the expression
    # type after this returns.
    return 0


def _l_nft_chain_validate_hooks(chain: uint64, hook_flags: uint32) -> int32:
    # No live chain table in Hamnix's nf_tables shim; the hook-mask
    # check trivially passes. 0 == "valid".
    return 0


# =====================================================================
# Group 2: LLC SAP open/close
# =====================================================================
#
# Linux:
#   struct llc_sap *llc_sap_open(unsigned char lsap,
#                                  int (*func)(struct sk_buff *, ...));
#   void            llc_sap_close(struct llc_sap *sap);
#
# An LLC Service Access Point is the demux entry for an 802.2 LSAP
# byte. stp.ko opens SAP 0x42 (the BPDU LSAP) to receive Spanning
# Tree Protocol frames; bridge.ko / appletalk / etc. open their own
# SAPs. In Hamnix the LLC core (llc.ko) is purely library-loaded —
# its init_module body sets up an empty hash table; no packets ever
# arrive. llc_sap_open's caller stores the returned pointer and uses
# it only as an opaque handle, so returning a small zero-init buffer
# is the correct "yes, registered" answer.
#
# llc_sap_close is called from cleanup_module on rmmod (never in our
# env — modules don't unload at runtime) and from open()'s error
# paths; void in any case.

_l65_llc_sap_buf:  Array[128, uint8]


def _l_llc_sap_open(lsap: uint8, func: uint64) -> uint64:
    # Return the address of a zero-init "fake" llc_sap. The caller
    # treats the pointer as opaque (sap->dev, sap->ind_skb_q etc. are
    # only touched when a packet arrives). 128 bytes is more than
    # enough for stp / bridge / appletalk; struct llc_sap is ~96 B.
    return cast[uint64](&_l65_llc_sap_buf[0])


def _l_llc_sap_close(sap: uint64):
    # No teardown; the buffer lives until cleanup_module (never).
    return


# =====================================================================
# Group 3: Kernel audit
# =====================================================================
#
# Linux:
#   u32 audit_enabled;                                /* DATA */
#   struct audit_buffer *audit_log_start(struct audit_context *,
#                                          gfp_t, int type);
#   void audit_log_format(struct audit_buffer *, const char *fmt, ...);
#   void audit_log_end(struct audit_buffer *);
#
# nft_log.ko queries audit_enabled at module-load time to decide
# whether to register an audit hook. Hamnix has no auditd; the
# correct startup value is AUDIT_OFF (== 0), which is what a
# zero-init word gives us — readers see 0 and skip the audit path.
#
# audit_log_start returns the audit_buffer that audit_log_format
# fills and audit_log_end submits to netlink. Since audit_enabled is
# always 0 the start/format/end trio should never fire at insmod;
# we still need symbols (the .rela.text entries point at them
# regardless of whether the callsites execute). Start returns NULL
# (== "audit unavailable", caller skips the format/end calls);
# format / end are pure void no-ops.

_l65_audit_enabled_buf:  Array[8, uint8]


def _l_audit_log_start(ctx: uint64, gfp_mask: uint32,
                         kind: int32) -> uint64:
    # Adder reserves `type` -> renamed to `kind`. NULL == "no audit
    # buffer available"; nft_log's caller treats NULL as "skip the
    # audit emit and fall through to plain logging".
    return 0


def _l_audit_log_format(ab: uint64, fmt: Ptr[char]):
    # Variadic tail dropped. Never reached in practice (ab is always
    # NULL from audit_log_start above), but the relocation needs an
    # address.
    return


def _l_audit_log_end(ab: uint64):
    # Same story as audit_log_format; relocation-only target.
    return


# =====================================================================
# Group 4: Netfilter logger lookup + netlink helper
# =====================================================================
#
# Linux:
#   int  nf_logger_find_get(int pf, enum nf_log_type type);
#   void nf_logger_put(int pf, enum nf_log_type type);
#   ssize_t nla_strscpy(char *dst, const struct nlattr *nla, size_t dstsize);
#
# nf_logger_find_get walks the per-family nf_log table and bumps the
# refcount of the matching logger. nft_log calls it at expression-
# init time to bind a logger to the expression. With no loggers
# registered in Hamnix (the nf_log infrastructure landed as
# api_nf_log.ad but only as a stub), the lookup returns -ENOENT.
# Real Linux treats this as "no logger available; emission silently
# drops" — which is exactly the right behaviour for our env.
#
# nf_logger_put is the matched-pair release; void.
#
# nla_strscpy copies a NUL-terminated string out of a netlink
# attribute into a fixed-size buffer. Called from nft_log's expression
# parse path when a userspace tool sets a string attribute on the
# rule. At insmod the netlink table is empty; the function is
# relocation-only. We return 0 (== "0 bytes copied") and leave the
# dst buffer untouched — safe even if the loader ever does fire a
# callsite at runtime, because the dst is always pre-zeroed by
# nft_log's parse helper.

def _l_nf_logger_find_get(pf: int32, kind: int32) -> int32:
    # Adder reserves `type` -> renamed to `kind`. -ENOENT == "no
    # logger registered for this protocol family".
    return -2  # -ENOENT


def _l_nf_logger_put(pf: int32, kind: int32):
    return


def _l_nla_strscpy(dst: uint64, nla: uint64, dstsize: uint64) -> int64:
    # 0 bytes copied; dst left at its caller-supplied initial value
    # (nft_log pre-zeroes its name buffer before this call).
    return 0


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l65():
    # Called from linux_abi_exports_init() after the L64 batch.
    # Adds 13 new exports for the iptable_nat / llc / nft_reject /
    # stp / nft_log batch. iptable_nat.ko + llc.ko need no new
    # exports — every UND already covered by L<=64.

    # ---- Group 1: nftables expression registry + chain validation ----
    _add_export("nft_register_expr",
                cast[uint64](&_l_nft_register_expr))
    _add_export("nft_unregister_expr",
                cast[uint64](&_l_nft_unregister_expr))
    _add_export("nft_request_module",
                cast[uint64](&_l_nft_request_module))
    _add_export("nft_chain_validate_hooks",
                cast[uint64](&_l_nft_chain_validate_hooks))

    # ---- Group 2: LLC SAP open/close ----
    _add_export("llc_sap_open",
                cast[uint64](&_l_llc_sap_open))
    _add_export("llc_sap_close",
                cast[uint64](&_l_llc_sap_close))

    # ---- Group 3: Kernel audit ----
    _add_export("audit_enabled",
                cast[uint64](&_l65_audit_enabled_buf[0]))
    _add_export("audit_log_start",
                cast[uint64](&_l_audit_log_start))
    _add_export("audit_log_format",
                cast[uint64](&_l_audit_log_format))
    _add_export("audit_log_end",
                cast[uint64](&_l_audit_log_end))

    # ---- Group 4: Netfilter logger lookup + netlink helper ----
    _add_export("nf_logger_find_get",
                cast[uint64](&_l_nf_logger_find_get))
    _add_export("nf_logger_put",
                cast[uint64](&_l_nf_logger_put))
    _add_export("nla_strscpy",
                cast[uint64](&_l_nla_strscpy))

# linux_abi/api_l49.ad
#
# L49: shims for the ABI gap exposed by five stock Debian 6.12 hash
# modules — crc32_generic.ko (covered for free), md4.ko, rmd160.ko,
# blake2b_generic.ko, and ghash-generic.ko. All five register one or
# more `struct shash_alg` entries at init time via crypto_register_shash
# / crypto_register_shashes (already shipped in L34), then tail-return
# — none of the init paths exercises the runtime-dispatch UND symbols
# this file shims. The shims must exist only so the loader's relocation
# pass succeeds; if a future milestone wires the hash dispatch table,
# the bodies grow real implementations without touching call sites.
#
# Cross-check against linux_abi/exports.ad reduced the union of the
# four .ko's UND lists (md4 + rmd160 + blake2b_generic + ghash-generic;
# crc32_generic was already zero-gap) to FIVE distinct symbols not yet
# exported:
#
#     memcpy                  C-runtime byte copy (md4 / rmd160 /
#                              blake2b_generic). Already linked into
#                              the kernel ELF — this file just exposes
#                              it under the Linux module-ABI name.
#     __warn_printk           printk wrapper called from the WARN()
#                              expansion macros. Runtime-only; init
#                              never trips a WARN.
#     gf128mul_init_4k_lle    GF(2^128) multiplication table init
#                              (ghash-generic runtime). Returns a
#                              non-NULL placeholder pointer.
#     gf128mul_4k_lle         GF(2^128) multiplication step
#                              (ghash-generic runtime). No-op.
#     kfree_sensitive         kfree variant that zeroes the buffer
#                              before freeing (ghash-generic tfm
#                              teardown). Forwards through kfree
#                              after a memset(0).
#
# Init paths (objdump -drC of each *.ko's .init.text):
#
#   md4.ko / rmd160.ko:
#       init_module:
#           call __fentry__
#           mov  $&md4_alg, %rdi
#           jmp  crypto_register_shash        # → L34 returns 0
#
#   blake2b_generic.ko:
#       init_module:
#           call __fentry__
#           mov  $4, %esi                     # count = 4 blake2b sizes
#           mov  $&blake2b_algs, %rdi
#           jmp  crypto_register_shashes      # → L34 returns 0
#
#   ghash-generic.ko:
#       init_module:
#           call __fentry__
#           mov  $&ghash_alg, %rdi
#           jmp  crypto_register_shash        # → L34 returns 0
#
#   crc32_generic.ko (zero-gap, no shim):
#       init_module:
#           call __fentry__
#           mov  $&crc32_algs, %rdi
#           jmp  crypto_register_shashes      # → L34 returns 0
#
# So all five tail-call existing L34 shims at init. memcpy is reached
# by md4/rmd160/blake2b's *runtime* shash update path when an actual
# digest is computed; __warn_printk fires only from a WARN_ON_ONCE
# path that init never trips; the gf128mul pair runs inside ghash's
# per-key tfm setup which we never invoke; kfree_sensitive runs in
# the cleanup_module path or under a per-tfm free callback, neither
# of which is on the init-path.
#
# Design notes:
#
# * memcpy: the kernel ELF already links a C-runtime memcpy (used by
#   loader.ad, api_random.ad, api_strings.ad, etc.). Real Linux's
#   memcpy has the same `void *(void *dst, const void *src, size_t n)`
#   signature, so the Hamnix-internal memcpy serves the Linux ABI
#   unchanged. We export its address directly — no wrapper needed.
#
# * __warn_printk: Linux's WARN() macros expand to
#       if (cond) __warn_printk(fmt, ...);
#   which logs the formatted message and increments a per-warning
#   counter. Hamnix has no WARN counter or BugFrame infrastructure
#   yet; the truthful body is "log the format string via printk0 and
#   return". Variadic arguments are dropped — same pattern as the
#   _linux_printk_shim in exports.ad. Init never trips a WARN in any
#   of the L49 modules.
#
# * gf128mul_init_4k_lle: Linux signature
#       struct gf128mul_4k *gf128mul_init_4k_lle(const be128 *g);
#   builds a 64 KiB lookup table for fast GF(2^128) multiplication
#   in little-endian byte order. ghash-generic's setkey calls it to
#   amortise per-block multiply cost. Hamnix has no GF(2^128) backend;
#   we return the address of a small zero-filled placeholder buffer
#   so the caller's NULL-check passes. Any field deref into it would
#   page-fault (the placeholder isn't a real gf128mul_4k struct), but
#   ghash's runtime path treats the pointer as an opaque cookie — it
#   only flows back into gf128mul_4k_lle, which is itself a no-op.
#
# * gf128mul_4k_lle: Linux signature
#       void gf128mul_4k_lle(be128 *r, const struct gf128mul_4k *t);
#   computes r = r * t in the GF(2^128) field. ghash runtime only;
#   no-op body. If a future milestone needs real ghash, this grows
#   the table-driven multiply (Karatsuba-friendly 4-bit decomposition);
#   the signature stays the same.
#
# * kfree_sensitive: Linux signature
#       void kfree_sensitive(const void *p);
#   wraps kfree with a `memzero_explicit` over the buffer first, so
#   key material doesn't linger in the freed slab. We don't know the
#   object size from the pointer alone (Hamnix's slab doesn't expose
#   object-size lookup yet — same blocker as krealloc), so the
#   "secure-zero" half is best-effort: a fixed 64-byte zero across
#   the head of the buffer covers typical hash-tfm contexts (struct
#   shash_desc + small inline state). Then forward to kfree. NULL
#   is a no-op (matches Linux's contract).

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kfree


# ---------------------------------------------------------------------
# memcpy: expose the existing C-runtime symbol under the Linux ABI
# name. The kernel already links memcpy (every other api_*.ad pulls it
# in via `extern def memcpy`). Adder's address-of operator returns the
# linker symbol's address, which is exactly what module relocations
# patch into the call sites of `call memcpy`.

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# ---------------------------------------------------------------------
# __warn_printk
#
# Linux: void __warn_printk(const char *fmt, ...);
#
# WARN() expansion lands here when a sanity check trips. Hamnix has no
# BugFrame infrastructure; we forward the format string through printk0
# (same convention as the _linux_printk_shim in exports.ad — variadic
# tail is dropped, fine for the L-track since module init never WARNs).
# Return path mirrors the rest of the printk family: caller treats the
# void return as "nothing happened", continues execution.

def _l_warn_printk(fmt: Ptr[char]):
    printk0("WARN: ")
    printk0(fmt)
    printk0("\n")
    return


# ---------------------------------------------------------------------
# gf128mul_init_4k_lle + gf128mul_4k_lle
#
# ghash-generic's runtime calls gf128mul_init_4k_lle(g) once per key
# (inside ghash_setkey) to build a precomputed multiplication table,
# then gf128mul_4k_lle(r, t) per data block to fold the accumulator
# against the table. The init-time symbol-resolution must succeed even
# though neither call ever fires during module load.
#
# The init helper returns a struct gf128mul_4k *; we hand out the
# address of a small zero buffer. The 4k name refers to the table size
# in Linux (4096-entry × 16 bytes ≈ 64 KiB); since the multiply step
# (below) is a no-op, the table contents don't matter — only the
# pointer's non-NULL-ness is checked.

gf128mul_4k_placeholder: Array[64, uint8]


def _l_gf128mul_init_4k_lle(g: uint64) -> uint64:
    # Real Linux allocates 64 KiB and walks `g` building the table.
    # No-op placeholder: return the static buffer's address so the
    # caller's NULL-check passes.
    return cast[uint64](&gf128mul_4k_placeholder[0])


def _l_gf128mul_4k_lle(r: uint64, t: uint64):
    # No-op. The accumulator pointed at by `r` keeps whatever value
    # the caller seeded — for ghash runtime this means the digest is
    # not actually computed, which is correct because we never reach
    # this path while ghash's runtime is disabled.
    return


# ---------------------------------------------------------------------
# kfree_sensitive
#
# Linux: void kfree_sensitive(const void *p);
#
# Zeroes the buffer before freeing so secret material doesn't survive
# in the slab freelist. Hamnix's slab doesn't expose object-size
# lookup (same blocker the krealloc shim in exports.ad documents), so
# we can't memzero the full allocation. Best-effort: zero a fixed
# 64-byte window at the head of the buffer (covers typical hash-tfm
# state — struct shash_desc plus small inline state), then forward to
# kfree. NULL is a no-op, matching Linux's documented contract.

def _l_kfree_sensitive(p: uint64):
    if p == 0:
        return
    # Best-effort secure-zero. 64 bytes is enough for a shash_desc
    # header + small inline state, which is what ghash-generic frees
    # through this path. A future slab improvement (object-size from
    # pointer) lets the body zero the full allocation.
    buf: Ptr[uint8] = cast[Ptr[uint8]](p)
    i: uint64 = 0
    while i < 64:
        buf[i] = 0
        i = i + 1
    kfree(p)


# ---------------------------------------------------------------------
# Registration

def linux_abi_register_l49():
    # Called from linux_abi_exports_init() after L48's netlink rows.
    # Adds 5 exports for the L49 hash-module set.
    _add_export("memcpy",
                cast[uint64](&memcpy))
    _add_export("__warn_printk",
                cast[uint64](&_l_warn_printk))
    _add_export("gf128mul_init_4k_lle",
                cast[uint64](&_l_gf128mul_init_4k_lle))
    _add_export("gf128mul_4k_lle",
                cast[uint64](&_l_gf128mul_4k_lle))
    _add_export("kfree_sensitive",
                cast[uint64](&_l_kfree_sensitive))

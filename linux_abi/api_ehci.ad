# linux_abi/api_ehci.ad
#
# USB 2.0 scale-out, ehci-pci + ehci-hcd leg. ehci-pci.ko is the PCI
# attachment shim above ehci-hcd.ko (the actual USB-2 host controller
# driver). On a real box, modprobe loads usbcore -> ehci-hcd ->
# ehci-pci, then the kernel's PCI bus walk dispatches the bound
# pci_driver's probe against any EHCI class-code-0x0C0320 device. On
# Hamnix the auto-loader matches that class code through modules.alias
# and lands ehci_pci.ko, which UND-references symbols defined by both
# usbcore.ko and ehci-hcd.ko.
#
# UND analysis (`nm --undefined` of Debian 6.1.0-32 ehci-pci.ko):
#   ehci-pci.ko       29 UND total
#   covered by L<=68 + usbcore + xhci batches    22 (the L61
#                                                    device-model /
#                                                    PCI / printk /
#                                                    slab surface +
#                                                    api_usbcore's
#                                                    HCD-side glue +
#                                                    api_xhci's PCI
#                                                    extensions like
#                                                    pci_match_id /
#                                                    pci_set_mwi)
#   missing          7 (this batch — split between ehci-hcd-defined
#                          symbols and a few stragglers)
#
# 7 new exports across 3 groups:
#
#   1.  ehci-hcd cross-module surface — ehci_init_driver, ehci_setup,
#         ehci_suspend, ehci_resume. ehci_hcd.ko EXPORT_SYMBOL's
#         these and ehci_pci references them at .text emit time, so
#         our shim table must resolve them (option (a) from the
#         agent brief — load order is not modules.dep-sequenced).
#
#   2.  ehci-pci-specific PCI extensions — pci_clear_mwi,
#         pci_find_capability. xhci's PCI extensions covered
#         pci_match_id / pci_set_mwi already; ehci-pci's tail
#         adds two more.
#
#   3.  AMD-specific quirk — usb_amd_hang_symptom_quirk. Like the
#         pll_check sibling in api_xhci.ad, this is the AMD-platform-
#         only hang workaround. Hamnix on QEMU is Intel-flavoured so
#         it always returns "no quirk needed".
#
# Stub philosophy mirrors api_xhci.ad: every shim is init-cold for
# our QEMU env. ehci-pci's init_module body calls __pci_register_driver
# (Hamnix shim, returns 0) and registers the four ehci_*_driver-derived
# hc_driver overrides; nothing in that path touches real USB hardware.
# Live probe runs only when QEMU's `-device usb-ehci` is plumbed
# through and even then the actual transfer-engine work is the
# follow-up (URB submission, schedules) deferred per the agent brief.
#
# The "_eh_" prefix marks the Hamnix-side shim for ehci-defined or
# ehci-pci-private symbols ("eh" = ehci-core).

from linux_abi.exports import _add_export


# =====================================================================
# Group 1: ehci-hcd cross-module surface
# =====================================================================
#
# Linux:
#   void ehci_init_driver(struct hc_driver *drv,
#                            const struct ehci_driver_overrides *over);
#   int  ehci_setup(struct usb_hcd *);
#   int  ehci_suspend(struct usb_hcd *, bool do_wakeup);
#   int  ehci_resume(struct usb_hcd *, bool force_reset);
#
# ehci_init_driver:
#   Mirrors xhci_init_driver from api_xhci.ad. Populates a struct
#   hc_driver from ehci-hcd's defaults + caller overrides. Void
#   return; populated table is only invoked from a real probe path
#   that doesn't fire on QEMU emulated ehci without a deeper
#   follow-up. Stub returns immediately.
#
# ehci_setup:
#   Stage-0 of the ehci controller bringup: read HC capability
#   registers, allocate device context, configure interrupters.
#   No real silicon in our env; return 0.
#
# ehci_suspend / ehci_resume:
#   PM transitions on the controller. No PM in V0; return 0.

def _eh_ehci_init_driver(drv: uint64, over: uint64):
    return


def _eh_ehci_setup(hcd: uint64) -> int32:
    return 0


def _eh_ehci_suspend(hcd: uint64, do_wakeup: int32) -> int32:
    return 0


def _eh_ehci_resume(hcd: uint64, force_reset: int32) -> int32:
    return 0


# =====================================================================
# Group 2: ehci-pci PCI extensions
# =====================================================================
#
# Linux:
#   void pci_clear_mwi(struct pci_dev *);
#   int  pci_find_capability(struct pci_dev *, int cap);
#
# pci_clear_mwi:
#   Disables Memory-Write-Invalidate on the device. The lazy peer
#   of api_xhci's pci_set_mwi. No-op in V0.
#
# pci_find_capability:
#   Returns the byte offset of the requested PCI capability ID in
#   the device's config space (PCIE Cap, MSI Cap, PM Cap, ...). 0
#   means "not found"; ehci-pci's caller treats 0 as "no such cap"
#   and skips the capability-specific arm. Hamnix's pci.ad already
#   exports a capability walker through L21; we keep this shim
#   separate (returns 0 == "not present") so ehci-pci's probe doesn't
#   try to use a capability that isn't actually wired through the
#   underlying QEMU device. The L21 walker is the right answer when
#   the URB-path agent extends it; for V0 "no caps" is safest.

def _eh_pci_clear_mwi(dev: uint64):
    return


def _eh_pci_find_capability(dev: uint64, cap: int32) -> int32:
    # 0 == "capability not present"; caller skips the cap-specific
    # arm. Safe default for V0 when we don't yet route capability
    # walks through the real QEMU usb-ehci config space.
    return 0


# =====================================================================
# Group 3: AMD-specific quirk
# =====================================================================
#
# Linux:
#   bool usb_amd_hang_symptom_quirk(void);
#
# AMD-specific EHCI controller hang workaround. Returns true if the
# AMD platform needs the workaround. Hamnix on QEMU emulates an Intel
# chipset; this always returns 0 (no quirk).

def _eh_usb_amd_hang_symptom_quirk() -> int32:
    return 0


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_ehci():
    # Called from linux_abi_exports_init() after the xhci batch.
    # Adds the 7 new shims so ehci-pci.ko + ehci-hcd.ko both load
    # (ehci-hcd UND covered by L64; ehci-pci closes the rest here).

    # ---- Group 1: ehci-hcd cross-module surface ----
    _add_export("ehci_init_driver",
                cast[uint64](&_eh_ehci_init_driver))
    _add_export("ehci_setup",
                cast[uint64](&_eh_ehci_setup))
    _add_export("ehci_suspend",
                cast[uint64](&_eh_ehci_suspend))
    _add_export("ehci_resume",
                cast[uint64](&_eh_ehci_resume))

    # ---- Group 2: ehci-pci PCI extensions ----
    _add_export("pci_clear_mwi",
                cast[uint64](&_eh_pci_clear_mwi))
    _add_export("pci_find_capability",
                cast[uint64](&_eh_pci_find_capability))

    # ---- Group 3: AMD-specific quirk ----
    _add_export("usb_amd_hang_symptom_quirk",
                cast[uint64](&_eh_usb_amd_hang_symptom_quirk))

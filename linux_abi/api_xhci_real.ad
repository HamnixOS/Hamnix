# linux_abi/api_xhci_real.ad
#
# REAL Linux .ko xHCI bring-up — the "Linux driver actually drives the
# controller" path, as opposed to the api_usb_hcd.ad bridge which (for
# the legacy /etc/xhci-ko marker) returns 0 from usb_hcd_pci_probe and
# bridges all real MMIO work back into the hand-rolled
# drivers/usb/xhci.ad::xhci_init().
#
# This module is gated behind a SEPARATE opt-in marker /etc/xhci-ko-real
# (planted by scripts/build_initramfs.py when ENABLE_XHCI_KO_REAL=1). It
# does NOT change the default boot path and does NOT touch the existing
# /etc/xhci-ko legacy bridge. Native USB-MSC (the root-on-USB boot path)
# is wholly unaffected.
#
# What "real" means here: instead of stubbing xhci_gen_setup / xhci_run
# / xhci_init_driver, we resolve the ACTUAL functions the loaded
# xhci_hcd.ko EXPORT_SYMBOL'd (via ksymtab_lookup) and CALL THEM so the
# stock Linux driver's own code reads and writes the controller MMIO.
# QEMU's `-trace usb_xhci_*` then records the controller activity the
# Linux driver — not Hamnix native code — produced.
#
# Layout facts (from objdump -dr kernel-modules/xhci_hcd/xhci_hcd.ko):
#
#   xhci_init_driver(struct hc_driver *drv, const struct
#                    xhci_driver_overrides *over):
#       - `rep stos` zeroes 0x2e qwords (0x170 bytes) of *drv, then
#         writes ~40 function pointers. Relevant ones:
#           drv+0x10 = hcd_priv_size = 0x1c60   (size of xhci_hcd tail)
#           drv+0x18 = xhci_irq                  (.irq)
#           drv+0x20 = 0x147 = flags (HCD_MEMORY|HCD_USB3|HCD_SHARED|..)
#           drv+0x28 = over->reset               (.reset, from overrides)
#           drv+0x30 = over->start ?: xhci_run   (.start)
#       - BUGs (ud2) if over == NULL, so we must pass a non-NULL
#         overrides table. xhci_pci.ko's own xhci_pci_overrides lives
#         in its .data; we synthesize a minimal overrides struct with
#         reset = xhci_gen_setup-wrapper so .reset is the real .ko
#         controller setup.
#
#   xhci_gen_setup(struct usb_hcd *hcd, get_quirks_fn):
#       reads hcd->regs at hcd+0x160 (cap_regs base), then
#       `mov (%rax),%edx` reads CAPLENGTH — a REAL MMIO read of the
#       controller capability registers. Continues into xhci_mem_init
#       (DMA ring allocation). This is the first point at which the
#       Linux driver touches the silicon.
#
# Staging:
#   Stage 1 (always, safe): resolve + call xhci_init_driver to populate
#     a real hc_driver; assert the .ko wrote real (.ko-resident) fn
#     pointers into .irq/.start. No MMIO, no unmapped derefs — safe.
#   Stage 2 (opt-in via /etc/xhci-ko-real-mmio): set hcd->regs = BAR0 and
#     read CAPLENGTH/HCSPARAMS DIRECTLY through the Linux driver's own
#     register-base convention to prove the controller's MMIO window the
#     .ko will use is live, then attempt the real .ko xhci_gen_setup.
#     gen_setup walks deep into xhci_mem_init (hundreds of struct fields);
#     a layout mismatch faults with no recovery, so this stays opt-in and
#     reports the precise furthest milestone.

from linux_abi.exports import _add_export
from linux_abi.loader import ksymtab_lookup
from kernel.printk.printk import printk0, printk1, printk2
from mm.slab import kzalloc
from drivers.pci.pci import pci_read_bar, pci_bdf_bus, pci_bdf_dev, \
    pci_bdf_fn, pci_config_read_dword, pci_config_write_dword, pci_pack_bdf
from fs.cpio import cpio_init
from kernel.modprobe import _find_initramfs_entry
from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, blk_scan_partitions,
    blk_register_partitions, SECTOR_SIZE,
)


# hc_driver field offsets (Linux 6.1 / 6.12, x86_64), confirmed from
# the xhci_init_driver disassembly.
HCDRV_HCD_PRIV_SIZE_OFF: uint64 = 0x10
HCDRV_IRQ_OFF:           uint64 = 0x18
HCDRV_FLAGS_OFF:         uint64 = 0x20
HCDRV_RESET_OFF:         uint64 = 0x28
HCDRV_START_OFF:         uint64 = 0x30

# struct usb_hcd field offsets (Linux 6.1 / 6.12, x86_64). hcd->regs is
# the ioremap'd capability-register base the .ko's xhci_gen_setup reads
# at hcd+0x160 (`mov 0x160(%rbp),%rax`).
USB_HCD_REGS_OFF:        uint64 = 0x160

# We need a hc_driver buffer large enough for xhci_init_driver's
# `rep stos` of 0x2e qwords + the trailing field writes (largest write
# is around offset 0x150). 0x400 bytes is generous.
HCDRV_BUF_SIZE:          uint64 = 0x400


# Synthetic xhci_driver_overrides table. Real struct:
#   struct xhci_driver_overrides {
#       size_t extra_priv_size;          // +0x00
#       int  (*reset)(struct usb_hcd *); // +0x08
#       int  (*start)(struct usb_hcd *); // +0x10
#       int  (*add_endpoint)(...);       // +0x18
#       ... more, all optional (NULL-tolerant in xhci_init_driver) ...
#   }
# xhci_init_driver reads over->extra_priv_size (+0x00), over->reset
# (+0x08), over->start (+0x10), over->add_endpoint (+0x18) and patches
# them in if non-NULL. We zero everything except reset, which we point
# at the real .ko xhci_gen_setup wrapper resolved below so the .reset
# the controller bring-up calls is the genuine Linux function.
_xr_overrides_buf:       Array[64, uint8]

# The resolved real .ko hc_driver after stage 1.
_xr_hc_driver:           uint64 = 0
_xr_hcd:                 uint64 = 0
_xr_xhci_run_addr:       uint64 = 0
_xr_xhci_irq_addr:       uint64 = 0
_xr_xhci_gen_setup_addr: uint64 = 0


def _xr_marker(path: Ptr[uint8], plen: uint64) -> int32:
    cpio_init()
    idx: int64 = _find_initramfs_entry(path, plen)
    if idx < 0:
        return 0
    return 1


def xhci_ko_real_marker_found() -> int32:
    # /etc/xhci-ko-real present?  (ENABLE_XHCI_KO_REAL=1)
    return _xr_marker("/etc/xhci-ko-real", 17)


def xhci_ko_real_mmio_marker_found() -> int32:
    # /etc/xhci-ko-real-mmio present?  (ENABLE_XHCI_KO_REAL_MMIO=1) —
    # the deep, fault-prone stage-2 attempt at the real .ko gen_setup.
    return _xr_marker("/etc/xhci-ko-real-mmio", 22)


def _xr_find_xhci_controller() -> uint32:
    # Walk bus 0 for a USB-HC class device (base 0x0C / sub 0x03 /
    # progif 0x30 == xHCI). Returns the bdf, or 0xFFFFFFFF if none.
    dev: uint32 = 0
    while dev < 32:
        ident: uint32 = pci_config_read_dword(0, dev, 0, 0x00)
        vendor: uint32 = ident & 0xFFFF
        if vendor != 0xFFFF:
            cls_raw: uint32 = pci_config_read_dword(0, dev, 0, 0x08)
            base_class: uint32 = (cls_raw >> 24) & 0xFF
            subclass:   uint32 = (cls_raw >> 16) & 0xFF
            progif:     uint32 = (cls_raw >> 8) & 0xFF
            if base_class == 0x0C and subclass == 0x03 and progif == 0x30:
                return pci_pack_bdf(0, dev, 0)
        dev = dev + 1
    return 0xFFFFFFFF


def _xr_bar0(bdf: uint32) -> uint64:
    low:  uint32 = pci_read_bar(bdf, 0)
    high: uint32 = pci_read_bar(bdf, 1)
    base: uint64 = cast[uint64](low & 0xFFFFFFF0) \
                 | (cast[uint64](high) << 32)
    return base


def _xr_enable_bus_master(bdf: uint32):
    # Set PCI COMMAND.MEM (bit1) + COMMAND.MASTER (bit2) so the
    # controller can be MMIO-accessed and can DMA. The Linux driver's
    # pci_enable_device path normally does this; in the real-.ko path
    # we do it here so the controller's register window responds.
    bus: uint32 = pci_bdf_bus(bdf)
    dev: uint32 = pci_bdf_dev(bdf)
    fn:  uint32 = pci_bdf_fn(bdf)
    cmd: uint32 = pci_config_read_dword(bus, dev, fn, 0x04)
    cmd = cmd | 0x6
    pci_config_write_dword(bus, dev, fn, 0x04, cmd)


def _xr_r32(addr: uint64) -> uint32:
    return cast[Ptr[uint32]](addr)[0]


def _xr_w32(addr: uint64, val: uint32):
    cast[Ptr[uint32]](addr)[0] = val


def _xr_r64(addr: uint64) -> uint64:
    return cast[Ptr[uint64]](addr)[0]


def _xr_w64(addr: uint64, val: uint64):
    cast[Ptr[uint64]](addr)[0] = val


# =====================================================================
# Stage 1: populate a real hc_driver via the loaded .ko's
# xhci_init_driver.
# =====================================================================

def xhci_real_stage1_init_driver() -> int32:
    # Resolve the three real .ko entry points from the EXPORT_SYMBOL
    # ksymtab populated when xhci_hcd.ko loaded.
    init_driver_addr: uint64 = ksymtab_lookup("xhci_init_driver")
    _xr_xhci_run_addr       = ksymtab_lookup("xhci_run")
    _xr_xhci_gen_setup_addr = ksymtab_lookup("xhci_gen_setup")

    printk2("[xhci-real] ksymtab xhci_init_driver=%p xhci_run=%p\n",
            init_driver_addr, _xr_xhci_run_addr)
    printk1("[xhci-real] ksymtab xhci_gen_setup=%p\n",
            _xr_xhci_gen_setup_addr)

    if init_driver_addr == 0 or _xr_xhci_run_addr == 0 \
            or _xr_xhci_gen_setup_addr == 0:
        printk0("[xhci-real] FAIL stage1: a real .ko export did not resolve\n")
        return -1

    # Allocate a real hc_driver and an overrides table whose .reset is
    # the real .ko xhci_gen_setup. xhci_init_driver BUGs on NULL over,
    # so we must hand it a non-NULL pointer.
    drv: uint64 = kzalloc(HCDRV_BUF_SIZE)
    if drv == 0:
        printk0("[xhci-real] FAIL stage1: kzalloc(hc_driver) failed\n")
        return -1

    # Overrides: extra_priv_size=0, reset=xhci_gen_setup, start=NULL
    # (so xhci_init_driver keeps its default .start = xhci_run).
    over: uint64 = cast[uint64](&_xr_overrides_buf[0])
    reset_slot: Ptr[uint64] = cast[Ptr[uint64]](over + 0x08)
    reset_slot[0] = _xr_xhci_gen_setup_addr

    # Call the REAL .ko xhci_init_driver(drv, over). No MMIO, no
    # unmapped deref — it memsets drv and writes function pointers.
    init_fn: Fn[None, uint64, uint64] = \
        cast[Fn[None, uint64, uint64]](init_driver_addr)
    init_fn(drv, over)
    _xr_hc_driver = drv

    # Verify the .ko populated the struct with its own resident fn
    # pointers: .irq (+0x18) and .start (+0x30) must equal the real
    # xhci_irq / xhci_run addresses (the .ko wrote them via its own
    # relocated .text references).
    irq_slot:   Ptr[uint64] = cast[Ptr[uint64]](drv + HCDRV_IRQ_OFF)
    start_slot: Ptr[uint64] = cast[Ptr[uint64]](drv + HCDRV_START_OFF)
    reset_field: Ptr[uint64] = cast[Ptr[uint64]](drv + HCDRV_RESET_OFF)
    priv_slot:  Ptr[uint64] = cast[Ptr[uint64]](drv + HCDRV_HCD_PRIV_SIZE_OFF)
    _xr_xhci_irq_addr = irq_slot[0]

    printk2("[xhci-real] hc_driver.irq=%p .start=%p\n",
            irq_slot[0], start_slot[0])
    printk2("[xhci-real] hc_driver.reset=%p .hcd_priv_size=%p\n",
            reset_field[0], priv_slot[0])

    # The .ko's .start MUST be xhci_run (resolved above). Proves the
    # Linux driver's own xhci_init_driver code ran and wrote real
    # function pointers, not our stub.
    if start_slot[0] != _xr_xhci_run_addr:
        printk0("[xhci-real] FAIL stage1: .start != real xhci_run\n")
        return -1
    if reset_field[0] != _xr_xhci_gen_setup_addr:
        printk0("[xhci-real] FAIL stage1: .reset override not applied\n")
        return -1
    if irq_slot[0] == 0:
        printk0("[xhci-real] FAIL stage1: .irq is NULL\n")
        return -1

    printk0("[xhci-real] PASS stage1: real .ko hc_driver populated (xhci_init_driver ran; .irq/.start/.reset are real .ko code)\n")
    return 0


# =====================================================================
# Stage 2: real .ko controller register bring-up.
# =====================================================================

def xhci_real_stage2_mmio() -> int32:
    # Find the controller, enable bus-master/MMIO, read CAPLENGTH and
    # HCSPARAMS1 through the SAME register base the Linux driver will
    # use (BAR0 == hcd->regs). This proves the controller MMIO window
    # the .ko relies on is live in THIS boot mode (native disabled).
    bdf: uint32 = _xr_find_xhci_controller()
    if bdf == 0xFFFFFFFF:
        printk0("[xhci-real] FAIL stage2: no xHCI controller on bus 0\n")
        return -1
    printk1("[xhci-real] stage2 controller bdf=%x\n", cast[uint64](bdf))
    _xr_enable_bus_master(bdf)
    bar0: uint64 = _xr_bar0(bdf)
    if bar0 == 0:
        printk0("[xhci-real] FAIL stage2: BAR0 == 0\n")
        return -1
    _xr_bar0_g = bar0
    printk1("[xhci-real] stage2 BAR0=%p\n", bar0)

    # CAPLENGTH is the low byte of the first cap dword; HCIVERSION the
    # high 16 bits. This is the exact `mov (%rax),%edx` the .ko's
    # xhci_gen_setup does after loading hcd->regs.
    cap0: uint32 = _xr_r32(bar0 + 0x00)
    caplength: uint32 = cap0 & 0xFF
    hciversion: uint32 = (cap0 >> 16) & 0xFFFF
    hcsparams1: uint32 = _xr_r32(bar0 + 0x04)
    printk2("[xhci-real] stage2 CAPLENGTH=%x HCIVERSION=%x\n",
            cast[uint64](caplength), cast[uint64](hciversion))
    printk1("[xhci-real] stage2 HCSPARAMS1=%p\n", cast[uint64](hcsparams1))
    max_ports: uint32 = (hcsparams1 >> 24) & 0xFF
    max_slots: uint32 = hcsparams1 & 0xFF
    printk2("[xhci-real] stage2 maxports=%d maxslots=%d (controller reachable)\n",
            cast[uint64](max_ports), cast[uint64](max_slots))
    if caplength < 0x20 or caplength > 0x80:
        printk0("[xhci-real] FAIL stage2: CAPLENGTH implausible — BAR not mapped\n")
        return -1

    # The controller's register window is live and the Linux driver's
    # cap-register read convention works against it. This is the
    # ground-truth equivalent of `usb_xhci_cap_read` in QEMU's trace.
    printk0("[xhci-real] PASS stage2: controller cap-registers read through Linux-driver BAR convention\n")

    # Stage 3 (deep, fault-prone): attempt the REAL .ko xhci_gen_setup.
    # It walks into xhci_mem_init (hundreds of struct fields at exact
    # offsets); a layout mismatch faults with no recovery. Gate it so
    # stage1+stage2 stay safe and committable; only the explicit deep
    # marker arms it.
    if xhci_ko_real_mmio_marker_found() == 1:
        return _xr_stage3_gen_setup(bar0)
    printk0("[xhci-real] stage3 (real xhci_gen_setup) NOT armed (set ENABLE_XHCI_KO_REAL_MMIO=1)\n")
    return 0


# A real (non-NULL) get_quirks callback for xhci_gen_setup. The .ko
# does `mov %rsi,%r14` (the 2nd arg) then later `cs call
# *__x86_indirect_thunk_r14` — i.e. it invokes get_quirks(dev, xhci)
# through the retpoline. If we pass 0 the thunk does `jmpq *%r14`
# with r14==0, faulting #UD at rip=0x3. We MUST pass real code here.
# Signature: void (*get_quirks)(struct device *dev, struct xhci_hcd
# *xhci). qemu-xhci needs no platform quirks, so a no-op is correct.
def _xr_get_quirks(dev: uint64, xhci: uint64):
    return


# struct xhci_hcd is INLINE in the usb_hcd hcd_priv tail at hcd+0x260
# (confirmed: xhci_gen_setup/xhci_init do `lea 0x260(%rbx),%r12`
# where rbx==hcd for the primary hcd). hcd_priv_size==0x1c60, so the
# usb_hcd allocation must be at least 0x260 + 0x1c60 == 0x1ec0 bytes.
USB_HCD_PRIV_OFF:        uint64 = 0x260
USB_HCD_ALLOC_SIZE:      uint64 = 0x4000     # generous (> 0x1ec0)

# struct usb_hcd field offsets we must seed before xhci_gen_setup:
#   +0x08  self.controller (struct device *) — passed to dma_*/iommu
#          shims (all of which ignore it in Hamnix), but the .ko also
#          dereferences hcd->self.controller in a couple of dbg paths,
#          so point it at a small zeroed device buffer for safety.
USB_HCD_CONTROLLER_OFF:  uint64 = 0x08

# xhci_hcd field offsets (relative to xhci == hcd+0x260), confirmed
# from xhci_gen_setup's / xhci_mem_init's stores:
#   xhci+0x10  cap_regs        (= hcd->regs == BAR0)
#   xhci+0x18  op_regs         (= cap_regs + CAPLENGTH)
#   xhci+0x20  run_regs        (= cap_regs + RTSOFF)
#   xhci+0x88  dcbaa (virt)    (xhci_mem_init dma_alloc_attrs result)
XHCI_CAP_REGS_OFF:       uint64 = 0x10
XHCI_OP_REGS_OFF:        uint64 = 0x18
XHCI_RUN_REGS_OFF:       uint64 = 0x20
XHCI_DCBAA_OFF:          uint64 = 0x88

_xr_dev_buf:             Array[256, uint8]

# stage6/7 DMA buffers are kzalloc'd at call time (identity-mapped low
# memory, virt==phys), NOT static BSS — BSS lives at the high-half
# kernel mapping which the controller's DMA engine cannot address.


extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]
extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


def _xr_align64(p: uint64) -> uint64:
    return (p + 63) & ~cast[uint64](63)


def _xr_stage3_gen_setup(bar0: uint64) -> int32:
    # Allocate a real usb_hcd, set hcd->regs = BAR0, seed
    # hcd->self.controller, and call the real .ko xhci_gen_setup with a
    # REAL get_quirks callback. This is the moment the stock Linux
    # driver reads/writes the controller and allocates its DMA rings
    # (xhci_mem_init) for real.
    if _xr_hc_driver == 0:
        printk0("[xhci-real] FAIL stage3: stage1 hc_driver missing\n")
        return -1
    hcd: uint64 = kzalloc(USB_HCD_ALLOC_SIZE)
    if hcd == 0:
        printk0("[xhci-real] FAIL stage3: kzalloc(usb_hcd) failed\n")
        return -1
    _xr_hcd = hcd
    # hcd->regs (cap base) and hcd->self.controller (device pointer).
    regs_slot: Ptr[uint64] = cast[Ptr[uint64]](hcd + USB_HCD_REGS_OFF)
    regs_slot[0] = bar0
    ctrl_slot: Ptr[uint64] = cast[Ptr[uint64]](hcd + USB_HCD_CONTROLLER_OFF)
    ctrl_slot[0] = cast[uint64](&_xr_dev_buf[0])

    gq: uint64 = cast[uint64](&_xr_get_quirks)
    printk2("[xhci-real] stage3 calling REAL xhci_gen_setup(hcd=%p regs=%p)\n",
            hcd, bar0)
    printk1("[xhci-real] stage3 get_quirks=%p (real no-op callback)\n", gq)
    gs_fn: Fn[int32, uint64, uint64] = \
        cast[Fn[int32, uint64, uint64]](_xr_xhci_gen_setup_addr)
    rc: int32 = gs_fn(hcd, gq)
    printk1("[xhci-real] stage3 xhci_gen_setup returned rc=%d\n",
            cast[uint64](rc))
    if rc != 0:
        printk0("[xhci-real] stage3: gen_setup non-zero (controller setup rejected)\n")
        return -1

    # gen_setup completed: the .ko ran xhci_halt/xhci_reset and
    # xhci_init -> xhci_mem_init, allocating its DMA rings. Read back
    # the register bases + DCBAA the .ko stored in the xhci_hcd priv
    # tail to prove the allocation is real (.ko-driven, not our code).
    xhci: uint64 = hcd + USB_HCD_PRIV_OFF
    cap_slot:   Ptr[uint64] = cast[Ptr[uint64]](xhci + XHCI_CAP_REGS_OFF)
    op_slot:    Ptr[uint64] = cast[Ptr[uint64]](xhci + XHCI_OP_REGS_OFF)
    run_slot:   Ptr[uint64] = cast[Ptr[uint64]](xhci + XHCI_RUN_REGS_OFF)
    dcbaa_slot: Ptr[uint64] = cast[Ptr[uint64]](xhci + XHCI_DCBAA_OFF)
    printk0("[xhci-real] PASS stage3: real .ko xhci_gen_setup completed (halt+reset+mem_init OK)\n")
    printk2("[xhci-real] stage3 .ko regs: cap=%p op=%p\n",
            cap_slot[0], op_slot[0])
    printk2("[xhci-real] stage3 .ko regs: run=%p dcbaa(virt)=%p\n",
            run_slot[0], dcbaa_slot[0])
    return _xr_stage4_run_and_enum(hcd, xhci, bar0)


# op-register offsets (relative to op_regs base == xhci->op_regs).
_XR_OP_USBCMD:  uint64 = 0x00     # u32
_XR_OP_USBSTS:  uint64 = 0x04     # u32
_XR_OP_CRCR:    uint64 = 0x18     # u64 Command Ring Control
_XR_OP_DCBAAP:  uint64 = 0x30     # u64 Device Context Base Array Ptr
_XR_OP_CONFIG:  uint64 = 0x38     # u32 Max Device Slots Enabled

_XR_CMD_RS:     uint32 = 0x01     # Run/Stop
_XR_STS_HCH:    uint32 = 0x01     # Host Controller Halted

# xHCI extended-capability IDs / USB Legacy Support bit layout.
_XR_ECP_LEGACY:    uint32 = 0x01           # cap id 1 = USB Legacy Support
_XR_LEGSUP_BIOS:   uint32 = 0x00010000     # HC BIOS Owned Semaphore (bit16)
_XR_LEGSUP_OS:     uint32 = 0x01000000     # HC OS Owned Semaphore   (bit24)


def _xr_bios_handoff(bar0: uint64) -> int32:
    # xHCI BIOS->OS ownership handoff (xHCI spec 4.22.1 / 7.1.1). The
    # NUC's UEFI firmware enumerated this controller at boot, so SMM may
    # still own it. Asserting USBCMD.R/S while the HC is BIOS-owned traps
    # into SMM on real Intel silicon and wedges the CPU — the exact hang
    # observed at "stage4 USBSTS before run". QEMU exposes no legacy cap
    # (xECP=0 or no id-1 entry), so this is a no-op there.
    #
    # xECP lives in HCCPARAMS1[31:16] as a dword offset from the cap base.
    hccparams1: uint32 = _xr_r32(bar0 + 0x10)
    xecp: uint32 = (hccparams1 >> 16) & 0xFFFF
    if xecp == 0:
        printk0("[xhci-real] handoff: no extended caps (xECP=0) — QEMU/no-legacy, skip\n")
        return 0
    capptr: uint64 = bar0 + cast[uint64](xecp) * 4
    guard: uint32 = 0
    while guard < 256:
        guard = guard + 1
        dw: uint32 = _xr_r32(capptr)
        capid: uint32 = dw & 0xFF
        if capid == _XR_ECP_LEGACY:
            printk2("[xhci-real] handoff: USBLEGSUP@%p = %p\n",
                    capptr, cast[uint64](dw))
            if (dw & _XR_LEGSUP_BIOS) == 0:
                printk0("[xhci-real] handoff: already OS-owned (BIOS bit clear)\n")
            # Claim OS ownership and wait (bounded) for BIOS to release.
            _xr_w32(capptr, dw | _XR_LEGSUP_OS)
            spin: uint32 = 0
            cur: uint32 = _xr_r32(capptr)
            while (cur & _XR_LEGSUP_BIOS) != 0 and spin < 1000000:
                cur = _xr_r32(capptr)
                spin = spin + 1
            if (cur & _XR_LEGSUP_BIOS) != 0:
                printk1("[xhci-real] handoff: WARN BIOS still owns after wait (USBLEGSUP=%p)\n",
                        cast[uint64](cur))
            else:
                printk0("[xhci-real] handoff: OS ownership acquired (BIOS released)\n")
            # Disable all legacy SMI sources and clear RW1C SMI status in
            # USBLEGCTLSTS (USBLEGSUP+4) so the running HC can't fire an
            # SMI the firmware never set us up to service.
            _xr_w32(capptr + 4, 0xE0000000)
            printk0("[xhci-real] handoff: legacy SMIs disabled in USBLEGCTLSTS\n")
            return 0
        nxt: uint32 = (dw >> 8) & 0xFF
        if nxt == 0:
            break
        capptr = capptr + cast[uint64](nxt) * 4
    printk0("[xhci-real] handoff: no USB Legacy Support cap (id=1) in xECP chain — skip\n")
    return 0


def _xr_stage4_run_and_enum(hcd: uint64, xhci: uint64, bar0: uint64) -> int32:
    # The real .ko's xhci_mem_init programmed the controller's ring
    # pointers (DCBAAP, CRCR) and slot count (CONFIG) into op-MMIO.
    # Read them back DIRECTLY from the controller to prove the .ko wrote
    # live silicon — these registers were 0 after reset and are now
    # populated with the phys addrs of the .ko's own DMA allocations.
    op_slot:    Ptr[uint64] = cast[Ptr[uint64]](xhci + XHCI_OP_REGS_OFF)
    dcbaa_slot: Ptr[uint64] = cast[Ptr[uint64]](xhci + XHCI_DCBAA_OFF)
    op: uint64 = op_slot[0]
    if op == 0:
        printk0("[xhci-real] FAIL stage4: .ko op_regs base is 0\n")
        return -1
    # Stash op base so the MSC event-scan loop can poke USBSTS to drive
    # QEMU's async USB backend forward while waiting on bulk completions.
    _xr_op_base = op

    dcbaap:  uint64 = _xr_r64(op + _XR_OP_DCBAAP)
    crcr:    uint64 = _xr_r64(op + _XR_OP_CRCR)
    config:  uint32 = _xr_r32(op + _XR_OP_CONFIG)
    dcbaa_v: uint64 = dcbaa_slot[0]
    printk2("[xhci-real] stage4 .ko-programmed MMIO: DCBAAP=%p (dcbaa virt=%p)\n",
            dcbaap, dcbaa_v)
    printk2("[xhci-real] stage4 .ko-programmed MMIO: CRCR=%p CONFIG.MaxSlots=%d\n",
            crcr, cast[uint64](config & 0xFF))

    # DCBAAP must equal the .ko's dcbaa phys (identity-mapped, so virt
    # == phys in Hamnix low memory). DCBAAP (op+0x30) is fully readable,
    # so a non-zero read-back proves the .ko wrote live silicon.
    #
    # Do NOT gate on CRCR: per xHCI spec 5.4.5 the Command Ring Pointer
    # field (bits 63:6) and RCS (bit0) are write-only and ALWAYS read as
    # 0. So CRCR=0 read-back is spec-correct, not a programming failure.
    # QEMU's model non-spec-ly returns the written value, which is why a
    # crcr==0 gate passed in the VM but false-failed on real Intel
    # silicon (NUC Sunrise Point-H: DCBAAP=0x102455000 OK, CRCR reads 0).
    if dcbaap == 0:
        printk0("[xhci-real] FAIL stage4: DCBAAP still 0 (.ko did not program MMIO)\n")
        return -1
    if (dcbaap & ~cast[uint64](0x3F)) != (dcbaa_v & ~cast[uint64](0x3F)):
        printk2("[xhci-real] WARN stage4: DCBAAP %p != dcbaa virt %p (non-identity map?)\n",
                dcbaap, dcbaa_v)
    printk0("[xhci-real] PASS stage4: real .ko xhci_mem_init programmed DCBAAP+CRCR into live controller MMIO\n")

    # Start the controller off the .ko's configuration: set USBCMD.R/S
    # and poll USBSTS until HCHalted clears. A controller that goes
    # !halted is running on the ring layout the .ko built — the
    # strongest .ko-attributable "the Linux driver brought the silicon
    # up" assertion short of a full transfer.
    sts0: uint32 = _xr_r32(op + _XR_OP_USBSTS)
    printk1("[xhci-real] stage4 USBSTS before run=%p (HCH expected set)\n",
            cast[uint64](sts0))

    # CRITICAL on real silicon: take HC ownership from BIOS/SMM BEFORE
    # touching USBCMD.R/S. Without this the R/S write traps into SMM on
    # the NUC and wedges (QEMU has no legacy cap → no-op). See
    # _xr_bios_handoff.
    _xr_bios_handoff(bar0)

    # Bracket each operational-register access with a marker so that if a
    # wedge survives the handoff the next capture shows EXACTLY which MMIO
    # access hangs (read-USBCMD vs R/S-write vs first poll read).
    printk0("[xhci-real] stage4 run: reading USBCMD\n")
    cmd: uint32 = _xr_r32(op + _XR_OP_USBCMD)
    printk1("[xhci-real] stage4 run: USBCMD=%p, writing R/S\n", cast[uint64](cmd))
    _xr_w32(op + _XR_OP_USBCMD, cmd | _XR_CMD_RS)
    printk0("[xhci-real] stage4 run: R/S written, polling USBSTS for HCH clear\n")

    spin: uint64 = 0
    sts: uint32 = _xr_r32(op + _XR_OP_USBSTS)
    while (sts & _XR_STS_HCH) != 0 and spin < 1000000:
        sts = _xr_r32(op + _XR_OP_USBSTS)
        spin = spin + 1
    if (sts & _XR_STS_HCH) != 0:
        printk1("[xhci-real] FAIL stage4: controller stayed HALTED after R/S (USBSTS=%p)\n",
                cast[uint64](sts))
        return -1
    printk1("[xhci-real] PASS stage4: controller RUNNING off .ko ring config (USBSTS=%p, HCHalted cleared)\n",
            cast[uint64](sts))
    return _xr_stage5_enumerate(hcd, xhci, bar0, op)


# struct xhci_ring offsets (confirmed from xhci_ring_alloc disassembly
# at 0x881d: `mov (%rbx),%rax; mov (%rax),%rdx;
#  mov %rax,0x18(seg); mov %rax,0x28(seg);
#  mov %rdx,0x10(trbs); mov %rdx,0x20(trbs)`):
#   ring+0x00  first_seg     (struct xhci_segment*)
#   ring+0x10  enqueue       (virt ptr to next TRB to write == first_seg->trbs)
#   ring+0x18  enq_seg       (struct xhci_segment*) — NOT the TRB ptr
#   ring+0x20  dequeue       (virt ptr)
#   ring+0x28  deq_seg
#   ring+0x40  cycle_state   (u32; producer cycle bit)
XHCI_RING_ENQUEUE_OFF:  uint64 = 0x10
XHCI_RING_CYCLE_OFF:    uint64 = 0x40
XHCI_CMD_RING_OFF:      uint64 = 0x98   # xhci->cmd_ring (struct xhci_ring*)

# =====================================================================
# .ko-transfer-path struct offsets (Linux 6.1.0-32-amd64 x86_64),
# ALL derived from disassembling kernel-modules/xhci_hcd/xhci_hcd.ko.
# These let us drive the BOT DATA/CBW/CSW phases through the .ko's own
# xhci_urb_enqueue (and thus xhci_queue_bulk_tx) so the on-the-wire TRBs
# are byte-identical to mainline Linux — killing the VM-vs-metal
# divergence in OUR hand-rolled _xr_queue_bulk_dir TRB builder.
#
#  struct hc_driver .urb_enqueue offset:
#    From xhci_init_driver's template: the store at drv+0x60 receives
#    `.text+0x66c0`, and `nm` shows xhci_urb_enqueue == 0x66c0. So the
#    function pointer slot for .urb_enqueue is at hc_driver + 0x60.
#    (Cross-checks: drv+0x48=xhci_stop(.text+0x4060), drv+0x50=xhci_shutdown,
#     drv+0x58=xhci_get_frame(.text+0x150), drv+0x68=xhci_urb_dequeue
#     (.text+0x2070).)
HCDRV_URB_ENQUEUE_OFF:  uint64 = 0x60
#
#  struct xhci_hcd ->devs[] (array of struct xhci_virt_device*):
#    xhci_get_virt_ep / xhci_urb_enqueue / xhci_check_args / xhci_alloc_dev
#    all index it as *(hcd + slot_id*8 + 0x3c8). hcd_priv (== xhci) is at
#    hcd+0x260, so relative to xhci the array base is 0x3c8-0x260 = 0x168.
XHCI_DEVS_OFF:          uint64 = 0x168
#    xhci->xhc_state (checked by xhci_check_args as `0xbf0(hcd) & 2`):
#    relative to xhci == 0xbf0-0x260 = 0x990. Must be 0 (not HALTED/DYING).
XHCI_XHC_STATE_OFF:     uint64 = 0x990
#
#  struct usb_hcd ->flags: xhci_urb_enqueue does `testb $1,0x148(hcd)`
#    (HCD_FLAG_HW_ACCESSIBLE); if clear it returns -EPIPE. Set bit0.
USB_HCD_FLAGS_OFF:      uint64 = 0x148
#
#  struct usb_hcd ->primary_hcd: hcd_to_xhci() for a NON-primary (shared /
#    USB3 SuperSpeed) hcd resolves xhci from primary_hcd->hcd_priv, NOT the
#    shared hcd's own priv. xhci_check_args's usb_hcd_is_primary_hcd() does
#    `mov 0x228(%rbx),%rax; cmp %rbx,%rax` and follows it when not equal.
#    A SuperSpeed device's virt_dev therefore lives in the PRIMARY xhci's
#    devs[], so we must install into primary_hcd's priv, not the shared one.
USB_HCD_PRIMARY_HCD_OFF: uint64 = 0x228
#
#  struct xhci_virt_device:
#    +0x00  slot_id (u32). prepare_transfer() reads it back out of the
#           installed virt_dev (`mov esi,[r15]` at prepare_transfer+0x2d)
#           and feeds it to xhci_get_virt_ep as the slot index. If left 0
#           the .ko computes (0-1)=0xFFFFFFFF, fails the `<=0xfe` range
#           check, and dev_err's "Invalid slot_id 0" — even though
#           urb->dev->slot_id and devs[slot] are all correct. (Proven on
#           the NUC via the dev_printk vararg instrumentation: the .ko's
#           own message rendered "Invalid slot_id 0".) queue_bulk_tx's
#           OWN get_virt_ep masks this because it reads slot_id fresh from
#           urb->dev->slot_id@0x530; prepare_transfer is the path that
#           trusts virt_dev->slot_id, so this field MUST be populated.
#    +0x08  udev (struct usb_device*) — xhci_check_args verifies
#           devs[slot]->udev == urb->dev.
#    +0x20  eps[] base; each struct xhci_virt_ep is 0x98 bytes (the
#           ep_index*0x98 stride seen in xhci_get_virt_ep:
#           lea 0x20(virt_dev, ep_index*19, 8) == virt_dev+0x20+ep_index*0x98).
#    +0x12a0 a flags word; bit0 (VDEV_PORT_ERROR) checked in urb_enqueue,
#           must be clear.
XHCI_VDEV_SLOT_ID_OFF:  uint64 = 0x00
XHCI_VDEV_UDEV_OFF:     uint64 = 0x08
#    +0x10  out_ctx (struct xhci_container_ctx*) — the Output Device
#           Context. prepare_transfer reads it (`mov rsi,0x10(r15)`) and
#           passes it to xhci_get_ep_ctx to derive the ep_ctx whose state
#           it then derefs (`mov edx,[r14]`). Must point at a container
#           whose ->bytes is the live DCBAA[slot] output context.
XHCI_VDEV_OUT_CTX_OFF:  uint64 = 0x10
XHCI_VDEV_EPS_OFF:      uint64 = 0x20
XHCI_VDEV_EP_STRIDE:    uint64 = 0x98
XHCI_VDEV_FLAGS_OFF:    uint64 = 0x12a0
#
#  struct xhci_container_ctx (this .ko): type@0x00 (1=DEVICE, 2=INPUT),
#  bytes@0x08 (Ptr to raw device-context memory). xhci_get_ep_ctx returns
#  bytes + (ep_index+1)*CTX_SIZE.
XHCI_CTX_TYPE_OFF:      uint64 = 0x00
XHCI_CTX_BYTES_OFF:     uint64 = 0x08
XHCI_CTX_TYPE_DEVICE:   uint32 = 1
#
#  struct xhci_virt_ep (relative to &eps[i]):
#    +0x10  ring (struct xhci_ring*) — read on the no-streams path
#           (`mov 0x10(ep),rax` at xhci_queue_bulk_tx+0x7f8).
#    +0x2c  ep_state — `testb $0x10,0x2c(ep)` (EP_HAS_STREAMS) must be 0
#           so the no-streams ring is used.
XHCI_VEP_RING_OFF:      uint64 = 0x10
XHCI_VEP_STATE_OFF:     uint64 = 0x2c
#
#  struct usb_device fields the .ko reads:
#    +0x1c  speed (USB_SPEED_SUPER==5)
#    +0x48  parent (struct usb_device*) — xhci_check_args returns 0
#           ("called for root hub") when this is NULL, and
#           xhci_urb_enqueue treats a <=0 check_args result as -EINVAL.
#           Verified from `cmpq $0x0,0x48(%rsi); je <ret 0>` in the .ko
#           disassembly of xhci_check_args. Must be NON-NULL; the .ko
#           only tests it for zero on the bulk path (never derefs it).
#    +0x530 slot_id
USB_DEV_SPEED_OFF:      uint64 = 0x1c
USB_DEV_PARENT_OFF:     uint64 = 0x48
USB_DEV_SLOT_ID_OFF:    uint64 = 0x530
_XR_USB_SPEED_SUPER:    uint32 = 5
#
#  struct urb fields the .ko reads/writes:
#    +0x08 hcpriv (urb_priv; .ko kmallocs + stores here — init 0)
#    +0x40 dev (struct usb_device*)
#    +0x48 ep  (struct usb_host_endpoint*)
#    +0x50 pipe; +0x54 stream_id (0); +0x5c transfer_flags (0)
#    +0x60 transfer_buffer; +0x68 transfer_dma
#    +0x7c num_sgs (0); +0x80 transfer_buffer_length
URB_HCPRIV_OFF:         uint64 = 0x08
URB_DEV_OFF:            uint64 = 0x40
URB_EP_OFF:             uint64 = 0x48
URB_PIPE_OFF:           uint64 = 0x50
URB_STREAM_ID_OFF:      uint64 = 0x54
URB_TRANSFER_FLAGS_OFF: uint64 = 0x5c
URB_TRANSFER_BUF_OFF:   uint64 = 0x60
URB_TRANSFER_DMA_OFF:   uint64 = 0x68
URB_NUM_SGS_OFF:        uint64 = 0x7c
URB_TRANSFER_LEN_OFF:   uint64 = 0x80
#
#  struct usb_host_endpoint: ->desc at +0, usb_endpoint_descriptor =
#    { bLength(0), bDescriptorType(1), bEndpointAddress(2), bmAttributes(3),
#      wMaxPacketSize(4..5) }. The .ko reads bEndpointAddress(+2) and
#    bmAttributes(+3) (and wMaxPacketSize for burst calc).
EPDESC_BENDPOINTADDRESS_OFF: uint64 = 0x02
EPDESC_BMATTRIBUTES_OFF:     uint64 = 0x03
EPDESC_WMAXPACKETSIZE_OFF:   uint64 = 0x04
USB_HOST_EP_HCPRIV_OFF:      uint64 = 0x60   # ep->hcpriv (not read by bulk path)
#
#  struct xhci_ring (matches existing XHCI_RING_*_OFF; here named for the
#  .ko fabrication): +0x00 first_seg, +0x10 enqueue, +0x18 enq_seg,
#  +0x20 dequeue, +0x28 deq_seg, +0x40 cycle_state, +0x48 num_trbs,
#  +0x4c num_trbs_free, +0x58 type. (queue_trb/prepare_ring disasm.)
XR_RING_FIRST_SEG_OFF:  uint64 = 0x00
XR_RING_ENQUEUE_OFF:    uint64 = 0x10
XR_RING_ENQ_SEG_OFF:    uint64 = 0x18
XR_RING_DEQUEUE_OFF:    uint64 = 0x20
XR_RING_DEQ_SEG_OFF:    uint64 = 0x28
XR_RING_CYCLE_OFF:      uint64 = 0x40
XR_RING_NUM_TRBS_OFF:   uint64 = 0x48
XR_RING_NUM_FREE_OFF:   uint64 = 0x4c
XR_RING_TYPE_OFF:       uint64 = 0x58
#  struct xhci_segment: +0x00 trbs (virt ptr), +0x08 next (struct
#  xhci_segment*), +0x10 dma. (queue_trb seg traversal.)
XR_SEG_TRBS_OFF:        uint64 = 0x00
XR_SEG_NEXT_OFF:        uint64 = 0x08
XR_SEG_DMA_OFF:         uint64 = 0x10
#  TRB_TYPE_BULK ring type value used by prepare_ring's room check.
XR_RING_TYPE_BULK:      uint32 = 3

# Master toggle: 1 == issue BOT transfer phases through the loaded
# xhci_hcd.ko's xhci_urb_enqueue (the user-chosen architecture). 0 ==
# fall back to OUR hand-rolled _xr_queue_bulk_dir Normal-TRB builder
# (the A/B comparison path). Default ON.
_xr_use_ko_transfers: int32 = 1

# State for the .ko transfer path, built once in _xr_ko_xfer_setup():
#   _xr_ko_urb_enqueue  = resolved hc_driver.urb_enqueue fn pointer
#   _xr_ko_virt_dev     = fabricated struct xhci_virt_device installed
#                         into xhci->devs[slot]
#   _xr_ko_udev         = fabricated struct usb_device (slot_id, speed)
#   _xr_ko_urb          = reusable fabricated struct urb scratch
#   _xr_ko_ep_in/out    = fabricated struct usb_host_endpoint per dir
#   _xr_ko_ring_in/out  = fabricated struct xhci_ring + xhci_segment per
#                         dir, whose enqueue/segment point at OUR existing
#                         _xr_bulk_in_ring / _xr_bulk_out_ring TRB memory.
#   _xr_ko_ready        = 1 once the above are wired and installed.
_xr_ko_urb_enqueue: uint64 = 0
_xr_ko_virt_dev:    uint64 = 0
_xr_ko_udev:        uint64 = 0
_xr_ko_urb:         uint64 = 0
_xr_ko_ep_in:       uint64 = 0
_xr_ko_ep_out:      uint64 = 0
_xr_ko_ring_in:     uint64 = 0
_xr_ko_ring_out:    uint64 = 0
_xr_ko_seg_in:      uint64 = 0
_xr_ko_seg_out:     uint64 = 0
_xr_ko_xhci:        uint64 = 0
_xr_ko_hcd:         uint64 = 0
_xr_ko_ready:       int32  = 0

# One-shot value-rendered slot_id diagnostic + BOT-EINVAL failure latch.
# The .ko's own "Invalid slot_id %u" print does NOT substitute the value
# (it scrolls a literal %u), so we render the actual slot_id chain ONCE the
# first time a CBW enqueue is about to run. Once a CBW enqueue returns
# -EINVAL we latch _xr_ko_bot_dead=1 so the block-read layer's hundreds of
# retries bail immediately instead of burying the log in identical spam.
_xr_ko_slotdiag_done: int32 = 0
_xr_ko_epstate_done:  int32 = 0
_xr_ko_bot_dead:      int32 = 0

# Latched diagnostics for the .ko transfer path, re-emitted in the late
# halt frame by xhci_real_blk_diag_report().
_xr_dbg_urbq_addr:  uint64 = 0   # resolved hc_driver.urb_enqueue address
_xr_dbg_virtdev:    uint64 = 0   # installed xhci->devs[slot] pointer
_xr_dbg_urbq_rc:    int32  = 0xDEAD   # last urb_enqueue return code
_xr_dbg_data_cc:    int32  = -2  # last DATA-IN transfer-event completion code
_xr_dbg_ko_setup_rc: int32 = -2  # _xr_ko_xfer_setup() outcome
_xr_dbg_last_dir_in: int32 = -1  # dir of last .ko-issued phase
_xr_dbg_eff_hcd:    uint64 = 0   # primary-resolved hcd used for devs[] install
_xr_dbg_prim_hcd:   uint64 = 0   # raw hcd->primary_hcd (0 == we are primary)
_xr_dbg_devs_slotv: uint64 = 0   # readback of devs[slot] after install
_xr_dbg_vdev_udev:  uint64 = 0   # readback of virt_dev->udev
_xr_dbg_udev_parent: uint64 = 0  # readback of udev->parent
_xr_dbg_ko_out_ctx: uint64 = 0   # ko_out_ctx (the container we set at virt_dev->out_ctx@0x10)
_xr_dbg_ko_dev_ctx: uint64 = 0   # ko_dev_ctx (the synth bytes buffer ko_out_ctx->bytes@0x08 points at)

# cap-register offsets for the doorbell + runtime register windows.
_XR_CAP_DBOFF:   uint64 = 0x14
_XR_CAP_RTSOFF:  uint64 = 0x18
# interrupter #0 runtime block = rt_base + 0x20; ERDP at +0x18.
_XR_IR0_OFF:     uint64 = 0x20
_XR_IR_ERDP:     uint64 = 0x18

# TRB type field.
_XR_TRB_TYPE_SHIFT:      uint32 = 10
_XR_TRB_CYCLE:          uint32 = 0x01
_XR_TRB_TYPE_ENABLE_SLOT: uint32 = 9
_XR_TRB_TYPE_DISABLE_SLOT: uint32 = 10
_XR_TRB_TYPE_CMD_COMPLETION: uint32 = 33

# Multi-port enumeration state. The bring-up iterates the root-hub ports,
# addressing each connected device and binding the FIRST that exposes an
# MSC BOT interface. _xr_cur_port/_xr_cur_speed are the port the current
# attempt is addressing (set by the loop, read by stage6). _xr_msc_bound
# is set to 1 inside stage8 the instant both bulk endpoints are found, so
# the loop knows to STOP (stage9 itself returns 0 even on success — the
# real success signal is sd0 registration, not a return value).
_xr_cur_port:   uint32 = 0
_xr_cur_speed:  uint32 = 0
_xr_msc_bound:  uint32 = 0


# Post a single Enable-Slot at the RUNNING command-ring cursor
# (_xr_cmd_next/_xr_cmd_cyc) and return the controller-assigned slot id, or
# 0 on failure. Unlike stage5's FIRST Enable-Slot this does NOT re-arm CRCR:
# the command ring is already running (CRR=1) so a fresh command is simply
# written at the live enqueue and the doorbell rung. Used by the multi-port
# bring-up loop to obtain a fresh slot for the next connected device after
# the previous (non-MSC) device's slot was disabled.
def _xr_enable_slot_once(op: uint64, bar0: uint64, db_base: uint64) -> uint32:
    cmd_at: uint64 = _xr_cmd_next
    ct: Ptr[uint32] = cast[Ptr[uint32]](cmd_at)
    ct[0] = 0
    ct[1] = 0
    ct[2] = 0
    ct[3] = (_XR_TRB_TYPE_ENABLE_SLOT << _XR_TRB_TYPE_SHIFT) | _xr_cmd_cyc
    _xr_w32(db_base + 0x00, 0)
    cc: int32 = _xr_scan_event(_XR_TRB_TYPE_CMD_COMPLETION, cmd_at)
    _xr_cmd_next = cmd_at + 0x10
    if cc != 1:
        printk1("[xhci-real] enable-slot-once completion-code=%d (not SUCCESS)\n",
                cast[uint64](cast[uint32](cc)))
        return 0
    return _xr_cc_slot


# Release a slot we addressed but rejected (non-MSC device on this port).
# Posts a Disable-Slot command at the running command-ring cursor so the
# controller frees the slot's resources before we Enable a fresh one for
# the next port.
def _xr_disable_slot(db_base: uint64, slot: uint32):
    cmd_at: uint64 = _xr_cmd_next
    ct: Ptr[uint32] = cast[Ptr[uint32]](cmd_at)
    ct[0] = 0
    ct[1] = 0
    ct[2] = 0
    ct[3] = (_XR_TRB_TYPE_DISABLE_SLOT << _XR_TRB_TYPE_SHIFT) | (slot << 24) | _xr_cmd_cyc
    _xr_w32(db_base + 0x00, 0)
    _xr_scan_event(_XR_TRB_TYPE_CMD_COMPLETION, cmd_at)
    _xr_cmd_next = cmd_at + 0x10
    printk1("[xhci-real] disabled non-MSC slot %d\n", cast[uint64](slot))


def _xr_stage5_enumerate(hcd: uint64, xhci: uint64, bar0: uint64,
                          op: uint64) -> int32:
    # Post a real Enable-Slot command on the .ko's OWN command ring
    # (xhci->cmd_ring, allocated by xhci_mem_init) and poll the .ko's
    # event ring for the controller's Command-Completion event. This
    # exercises the .ko-built ring through a genuine controller round
    # trip — the controller DMA-reads the command TRB from the .ko's
    # ring and DMA-writes a completion TRB to the .ko's event ring.
    cap: uint64 = bar0
    dboff:  uint32 = _xr_r32(cap + _XR_CAP_DBOFF) & 0xFFFFFFFC
    rtsoff: uint32 = _xr_r32(cap + _XR_CAP_RTSOFF) & 0xFFFFFFE0
    db_base: uint64 = bar0 + cast[uint64](dboff)
    rt_base: uint64 = bar0 + cast[uint64](rtsoff)
    ir0: uint64 = rt_base + _XR_IR0_OFF

    # Discover the event-ring segment (base + size in TRBs) from the
    # interrupter-0 ERST so the block-device read path can WRAP the event
    # ring correctly across hundreds of BOT events. ERSTBA (ir0+0x10)
    # points at the Event Ring Segment Table; entry 0 is { ring-base
    # (8 bytes), size-in-TRBs (low 16 bits of the next dword) }. Stash
    # the segment base/size + the ERDP register address into globals.
    erstba: uint64 = _xr_r64(ir0 + 0x10) & ~cast[uint64](0x3F)
    if erstba != 0:
        seg_base: uint64 = _xr_r64(erstba + 0x00) & ~cast[uint64](0x3F)
        seg_size: uint32 = _xr_r32(erstba + 0x08) & 0xFFFF
        _xr_ev_base = seg_base
        _xr_ev_nslots = cast[uint64](seg_size)
        _xr_ev_erdp_reg = ir0 + _XR_IR_ERDP
        printk2("[xhci-real] stage5 event-ring seg base=%p size(TRBs)=%d\n",
                seg_base, cast[uint64](seg_size))

    cmd_ring: uint64 = cast[Ptr[uint64]](xhci + XHCI_CMD_RING_OFF)[0]
    if cmd_ring == 0:
        printk0("[xhci-real] FAIL stage5: xhci->cmd_ring is NULL\n")
        return -1
    first_seg: uint64 = cast[Ptr[uint64]](cmd_ring + 0x00)[0]
    enq: uint64 = cast[Ptr[uint64]](cmd_ring + XHCI_RING_ENQUEUE_OFF)[0]
    printk2("[xhci-real] stage5 cmd_ring=%p first_seg=%p\n", cmd_ring, first_seg)
    printk2("[xhci-real] stage5 cmd_ring->enqueue=%p\n", enq, enq)

    # GROUND TRUTH for where to post the command: the command ring's FIRST
    # SEGMENT TRB BASE (first_seg->trbs), NOT cmd_ring->enqueue.
    #
    # Why not enqueue? Two metal findings (NUC boots 11-45/11-54):
    #  (1) cmd_ring->enqueue lands at a 32-byte (odd-TRB) offset
    #      (...4220, & 0x3F == 0x20). The CRCR Command-Ring-Pointer is bits
    #      63:6 (xHCI §5.4.5) — the low 6 bits are RCS/reserved — so writing
    #      CRCR=enqueue truncates the pointer to a 64-byte boundary
    #      (...4200), 0x20 BEFORE our TRB. The controller then dequeues a
    #      stale/zero TRB, sees a cycle mismatch, and never runs the command
    #      (it kept posting Port-Status-Change events but zero Cmd-Completes).
    #  (2) enqueue at a non-base offset means the ring is NOT fresh-at-base,
    #      so it is not a safe place to re-point a stopped controller.
    # The segment TRB base is allocated 64-byte (page) aligned per spec and
    # is exactly where a stopped controller's command-ring dequeue belongs.
    # We take over the ring: post our Enable-Slot at the base with the .ko's
    # producer cycle and re-arm CRCR to the aligned base (legal while CRR=0).
    seg_trbs: uint64 = cast[Ptr[uint64]](first_seg + 0x00)[0]
    cmd_cycle: uint32 = cast[Ptr[uint32]](cmd_ring + XHCI_RING_CYCLE_OFF)[0] & 0x1
    # FORCE 64-byte alignment. NUC boots 11-54/12-04 proved both
    # cmd_ring->enqueue AND first_seg->trbs land at a 32-byte (0x20) offset
    # on this hardware — tolerated by QEMU, but the xHCI CRCR pointer is bits
    # 63:6 so real Intel silicon TRUNCATES the low 6 bits and dequeues from a
    # DIFFERENT 64-byte slot than where we wrote, so the command is never
    # run. We take over the command ring entirely (the .ko is not using it
    # and the controller is stopped, CRR=0): pick a 64-byte-aligned address,
    # write our Enable-Slot TRB THERE, and re-arm CRCR to the SAME address.
    # Post-address == CRCR-pointer (both aligned) is the invariant that makes
    # the controller fetch exactly the TRB we wrote. Round DOWN; the slot is
    # in our DMA-coherent region either way and we own the whole ring now.
    deq: uint64 = seg_trbs & ~cast[uint64](0x3F)
    rcs: uint32 = cmd_cycle
    # CRCR readback kept for diagnostics ONLY (reads 0 on real silicon).
    crcr_raw: uint64 = _xr_r64(op + _XR_OP_CRCR)
    printk2("[xhci-real] stage5 first_seg->trbs=%p -> 64B-aligned deq=%p\n",
            seg_trbs, deq)
    printk2("[xhci-real] stage5 post-at deq=%p align&0x3F=%p\n",
            deq, deq & cast[uint64](0x3F))
    printk1("[xhci-real] stage5 CRCR readback (diag, 0 on metal)=%p\n", crcr_raw)
    printk2("[xhci-real] stage5 db_base=%p ir0(runtime)=%p\n", db_base, ir0)

    # Initialise the SHARED event-ring walker (_xr_scan_event) before
    # posting any command. The walker maintains a live dequeue cursor +
    # consumer cycle and skips intervening events. This is REQUIRED on real
    # hardware: the instant R/S started the controller, every root-hub port
    # that already has a device attached posts a Port-Status-Change event
    # (type 34) into the event ring AHEAD of our Command-Completion. The old
    # "inspect the single TRB at ERDP and wait for a cycle flip" logic spun
    # forever on that PSC event (the fresh ring's producer cycle is already
    # 1, so there is no flip to see). QEMU posted the completion first so it
    # never tripped on this. A fresh event ring's producer cycle is 1.
    erdp_before: uint64 = _xr_r64(ir0 + _XR_IR_ERDP) & ~cast[uint64](0xF)
    _xr_ev_cursor = erdp_before
    _xr_ev_cyc = 1
    _xr_op_base = op
    printk1("[xhci-real] stage5 event-ring ERDP(before)=%p\n", erdp_before)

    # Build the Enable-Slot command TRB at the .ko's command-ring enqueue
    # (deq, computed from cmd_ring->enqueue above): dword0/1 = parameter (0),
    # dword2 = status (0), dword3 = (type<<10) | cycle. Write the cycle bit
    # LAST so the controller never sees a half-written TRB.
    trb: Ptr[uint32] = cast[Ptr[uint32]](deq)
    trb[0] = 0
    trb[1] = 0
    trb[2] = 0
    trb[3] = (_XR_TRB_TYPE_ENABLE_SLOT << _XR_TRB_TYPE_SHIFT) | rcs

    # EXPLICITLY RE-ARM the Command Ring on metal. DIAG dump (NUC boot
    # 11-45-04) proved the controller is RUNNING and posting Port-Status-
    # Change events to the event ring, our Enable-Slot TRB is intact
    # (dword3=0x2401), yet NO Command-Completion is ever posted — i.e. the
    # controller never DEQUEUES the command ring. The controller's internal
    # Command Ring Dequeue Pointer was set by the .ko's xhci_mem_init CRCR
    # write; since CRCR is write-only (reads 0 on real silicon) we cannot
    # see where it actually points, and on metal it evidently does NOT point
    # at cmd_ring->enqueue. Per xHCI spec §5.4.5 the CRCR pointer is only
    # latched while the ring is STOPPED (CRR=0) — true here (fresh ring, no
    # command yet processed) — so we authoritatively point the controller at
    # OUR TRB: write CRCR = (deq physical | RCS). deq is identity-mapped
    # (virt==phys, confirmed via DCBAA), so deq is the correct bus address.
    _xr_w64(op + _XR_OP_CRCR, deq | cast[uint64](rcs))
    printk2("[xhci-real] stage5 re-armed CRCR=%p|RCS=%d (authoritative cmd-ring deq)\n",
            deq, cast[uint64](rcs))

    # Ring command doorbell 0 (DB target 0 == host controller command).
    _xr_w32(db_base + 0x00, 0)
    printk0("[xhci-real] stage5 Enable-Slot posted at controller dequeue; doorbell 0 rung\n")

    # Walk the event ring for the Command-Completion (type 33) referencing
    # our Enable-Slot TRB at `deq`, skipping the Port-Status-Change events.
    cc_i: int32 = _xr_scan_event(_XR_TRB_TYPE_CMD_COMPLETION, deq)
    if cc_i < 0:
        printk0("[xhci-real] stage5: no Cmd-Completion for our Enable-Slot found while walking the event ring\n")
        # DECISIVE METAL DIAGNOSTIC: dump controller state + the raw command
        # TRB we wrote + the raw first 8 event-ring TRBs, so we can see what
        # (if anything) the controller actually DMA-posted. completion code
        # !=1, a TRB_ERROR, a cref mismatch, or an all-zero ring each point
        # at a different root cause that the type-matched scan hides.
        dsts:  uint32 = _xr_r32(op + _XR_OP_USBSTS)
        dcmd:  uint32 = _xr_r32(op + _XR_OP_USBCMD)
        printk2("[xhci-real] stage5 DIAG USBSTS=%p USBCMD=%p\n",
                cast[uint64](dsts), cast[uint64](dcmd))
        ctrb: Ptr[uint32] = cast[Ptr[uint32]](deq)
        printk2("[xhci-real] stage5 DIAG cmd-TRB@%p readback dword3=%p\n",
                deq, cast[uint64](ctrb[3]))
        printk2("[xhci-real] stage5 DIAG ev_base=%p nslots=%d\n",
                _xr_ev_base, _xr_ev_nslots)
        di: uint64 = 0
        while di < 8:
            esl: Ptr[uint32] = cast[Ptr[uint32]](_xr_ev_base + di * 0x10)
            elo: uint64 = (cast[uint64](esl[1]) << 32) | cast[uint64](esl[0])
            printk2("[xhci-real] stage5 DIAG ev[%d] ptr=%p\n", di, elo)
            printk2("[xhci-real] stage5 DIAG ev    sts=%p ctl=%p\n",
                    cast[uint64](esl[2]), cast[uint64](esl[3]))
            di = di + 1
        printk0("[xhci-real] FURTHEST: controller running off .ko rings; command posted to .ko cmd-ring but no attributable completion in the event ring (see usb_xhci_fetch_trb)\n")
        return 0
    cc: uint32 = cast[uint32](cc_i)
    slot: uint32 = _xr_cc_slot
    printk2("[xhci-real] stage5 xr-rev=7 Cmd-Completion: completion-code=%d slot-id=%d\n",
            cast[uint64](cc), cast[uint64](slot))
    if slot == 0:
        printk0("[xhci-real] stage5: completion carried slot-id 0 (Enable-Slot did not assign a slot)\n")
        return 0
    printk0("[xhci-real] PASS stage5: real .ko command ring round-tripped a controller Enable-Slot end-to-end\n")
    printk0("[xhci-real] FURTHEST: controller DMA-consumed an Enable-Slot from the .ko-built cmd ring and DMA-posted a Command-Completion to the .ko-built event ring\n")

    # Multi-port enumeration. We have a slot; now iterate the connected
    # root-hub ports and bind the FIRST device that enumerates as MSC BOT
    # (two bulk endpoints). On QEMU the stick is the only device (port 1),
    # so the first attempt binds it and the loop exits immediately. On real
    # NUC silicon several internal USB devices (an internal hub — config
    # wTotalLength=25, one interrupt EP — plus BT/camera) sit on lower root
    # ports and address fine but expose NO bulk endpoints; we must skip
    # them, release each slot, and keep advancing until we reach the
    # mass-storage stick on its own root port. This is exactly what a real
    # USB bus driver does: enumerate every port, bind by interface class.
    #
    # We track the command-ring cursor ourselves (CRCR reports the ring
    # BASE / reads 0 on real silicon): the next command TRB goes at deq+0x10
    # (same cycle, no wrap within a 256-TRB segment for the <=24 commands a
    # bring-up emits). The event-ring cursor is the SHARED walker state.
    _xr_cmd_next = deq + 0x10
    _xr_cmd_cyc = rcs
    hcs2: uint32 = _xr_r32(bar0 + 0x04)
    max_ports2: uint32 = (hcs2 >> 24) & 0xFF
    # Two-pass port enumeration. Pass 1 prefers SuperSpeed ports (PORTSC
    # speed=4): a SuperSpeed MSC stick auto-enables on its SS root port, and
    # binding it there is the ONLY way SET_CONFIGURATION succeeds — its USB2
    # companion port mis-trains (e.g. FullSpeed) and, although it enumerates
    # far enough to look like MSC, the device operates at SuperSpeed so the
    # config request on the companion slot fails. Pass 2 (pref_speed=0) is the
    # legacy "any connected port" scan that resets USB2 ports; QEMU's single
    # non-SS stick is found here. Each pass walks ports independently.
    cur_slot: uint32 = slot
    attempts: uint32 = 0
    pass_no: uint32 = 0
    while pass_no < 2 and attempts < 24:
        pref: uint32 = 0
        if pass_no == 0:
            pref = 4                              # SuperSpeed-first pass
        port_cursor: uint32 = 1
        while attempts < 24:
            pp: uint32 = _xr_find_connected_port(op, bar0, port_cursor, pref)
            if pp == 0:
                break                            # this pass exhausted
            _xr_cur_port = (pp >> 8) & 0xFF
            _xr_cur_speed = pp & 0xF
            printk2("[xhci-real] bring-up attempt: slot=%d addressing port=%d\n",
                    cast[uint64](cur_slot), cast[uint64](_xr_cur_port))
            _xr_msc_bound = 0
            r: int32 = _xr_stage6_address_device(xhci, op, bar0, db_base, ir0,
                                                 0, 0, _xr_cmd_next, _xr_cmd_cyc,
                                                 cur_slot)
            if _xr_msc_bound != 0:
                # stage8 found bulk IN/OUT on this device — it IS the MSC
                # stick. Stop iterating regardless of stage9's return (sd0
                # registration is the real success signal, emitted in stage9).
                return r
            # Non-MSC device (or this port failed to enumerate). Release the
            # slot and advance to the next connected port with a fresh slot.
            port_cursor = _xr_cur_port + 1
            attempts = attempts + 1
            if port_cursor > max_ports2:
                break
            _xr_disable_slot(db_base, cur_slot)
            cur_slot = _xr_enable_slot_once(op, bar0, db_base)
            if cur_slot == 0:
                printk0("[xhci-real] bring-up: Enable-Slot for next port failed\n")
                return 0
        pass_no = pass_no + 1
    printk0("[xhci-real] FURTHEST: enumerated all connected ports; none exposed an MSC BOT interface (no sd0)\n")
    return 0


# --- stage6: Address Device + GET_DESCRIPTOR -------------------------
#
# With slot 1 enabled (stage5) and root-hub port 1 already connected +
# enabled (PORTSC.CCS=1/PED=1, observed in the QEMU trace), drive the
# next two real controller round trips:
#   (a) Address Device — build an Input Context (Input Control Context
#       adds A0|A1; Slot Context: root-hub port + speed + 1 ctx entry;
#       EP0 Context: control, MPS, the EP0 transfer-ring deq ptr+DCS),
#       install an Output Device Context into DCBAA[slot], post the
#       Address-Device command on the .ko cmd ring, ring DB0.
#   (b) GET_DESCRIPTOR(device) — queue Setup/Data/Status TRBs on the
#       EP0 transfer ring, ring the slot's EP0 doorbell (target 1), and
#       read the 18-byte device descriptor the controller DMA-writes
#       into the kzalloc'd desc buffer. bLength==0x12 /
#       bDescriptorType==0x01 is the unambiguous proof of a
#       Linux-.ko-driven enumeration step (SeaBIOS uses wLength=0x08, so
#       our wLength=0x12 control transfer cannot be a BIOS transaction).

_XR_TRB_TYPE_ADDRESS_DEVICE: uint32 = 11
_XR_TRB_TYPE_CONFIGURE_ENDPOINT: uint32 = 12
_XR_TRB_TYPE_NORMAL:         uint32 = 1
_XR_TRB_TYPE_SETUP:          uint32 = 2
_XR_TRB_TYPE_DATA:           uint32 = 3
_XR_TRB_TYPE_STATUS:         uint32 = 4
_XR_TRB_IDT:                 uint32 = 0x40   # Immediate-Data (Setup TRB)
_XR_TRB_IOC:                 uint32 = 0x20   # Interrupt-On-Completion


# Wait for a Command-Completion (type 33) at the event-ring cursor
# `ev` whose cycle differs from `ev_cyc_before` AND that references the
# command TRB we posted at `want_cmd` (rejects BIOS-ring false
# positives). Returns the completion code, or -1 if none / mismatched.
def _xr_wait_cmd_complete(ev: Ptr[uint32], ev_cyc_before: uint32,
                           want_cmd: uint64) -> int32:
    spin: uint64 = 0
    ctl: uint32 = ev[3]
    t: uint32 = (ctl >> _XR_TRB_TYPE_SHIFT) & 0x3F
    c: uint32 = ctl & 0x1
    while (t != _XR_TRB_TYPE_CMD_COMPLETION or c == ev_cyc_before) and spin < 4000000:
        ctl = ev[3]
        t = (ctl >> _XR_TRB_TYPE_SHIFT) & 0x3F
        c = ctl & 0x1
        spin = spin + 1
    if t != _XR_TRB_TYPE_CMD_COMPLETION:
        return -1
    ref: uint64 = (cast[uint64](ev[1]) << 32) | cast[uint64](ev[0])
    if ref != want_cmd:
        printk2("[xhci-real] cmd-completion references %p, not our TRB %p (BIOS-ring event)\n",
                ref, want_cmd)
        return -1
    return cast[int32]((ev[2] >> 24) & 0xFF)   # completion code


# Scan the root-hub ports for a connected device and (for USB2 ports that
# are not auto-enabled) drive a hot reset to train the link speed. On QEMU
# the device sits on port 1 and is already PED=1, so this returns
# immediately; on real Intel silicon the stick lands on some other port and
# its USB2 companion needs an explicit Port-Reset (PORTSC.PR) before the
# port enables and reports a trained speed. Returns (port_number << 8) |
# speed (speed = PORTSC bits 10..13), or 0 if no connected+enabled port.
#
# PORTSC write hygiene: the change bits (CSC/PEC/PRC) are RW1C and PED is
# write-1-to-disable, so we build a "neutral" write that preserves PP (bit
# 9) + PLS (bits 5..8) and zeroes everything else before OR-ing in PR —
# this avoids accidentally disabling the port or clearing status we still
# need. (Mirrors Linux xhci_port_state_to_neutral.)
def _xr_find_connected_port(op: uint64, bar0: uint64, start: uint32,
                             pref_speed: uint32) -> uint32:
    # pref_speed != 0 => only accept a connected+enabled port already trained
    # to that PORTSC speed (bits 10..13), and never drive a Port-Reset. A
    # SuperSpeed device auto-enables (PED=1) on its SuperSpeed root port, so a
    # SuperSpeed-first pass (pref_speed=4) can pick it WITHOUT touching the
    # USB2 companion ports. pref_speed == 0 => legacy "any port" behaviour:
    # reset USB2 ports (PED==0) to train them, then accept the first enabled
    # port. The NUC MSC stick is SuperSpeed: it lands enabled on its SS root
    # port (PORTSC speed=4) while ALSO presenting a USB2 companion that
    # mis-trains to FullSpeed; binding the companion enumerates as MSC but
    # SET_CONFIGURATION fails because the device actually operates at
    # SuperSpeed. Preferring the SS port fixes the metal bring-up.
    hcs: uint32 = _xr_r32(bar0 + 0x04)
    max_ports: uint32 = (hcs >> 24) & 0xFF
    p: uint32 = start
    if p < 1:
        p = 1
    while p <= max_ports:
        pa: uint64 = op + 0x400 + cast[uint64](p - 1) * 0x10
        v: uint32 = _xr_r32(pa)
        if (v & 0x1) != 0:                       # CCS: device connected
            if pref_speed != 0:
                # Speed-filtered, reset-free pass: only consider ports already
                # enabled and trained to the requested speed.
                if (v & 0x2) != 0:               # PED == 1: speed is valid
                    spd: uint32 = (v >> 10) & 0xF
                    if spd == pref_speed:
                        printk2("[xhci-real] port%d connected (pref-speed) PORTSC=%p\n",
                                cast[uint64](p), cast[uint64](v))
                        return (p << 8) | spd
                p = p + 1
                continue
            if (v & 0x2) == 0:                   # PED == 0: needs a reset
                _xr_w32(pa, (v & 0x3E0) | 0x10)  # preserve PP/PLS, set PR
                spin: uint64 = 0
                v = _xr_r32(pa)
                while (v & 0x10) != 0 and spin < 8000000:   # wait PR clear
                    v = _xr_r32(pa)
                    spin = spin + 1
                _xr_w32(pa, (v & 0x3E0) | (1 << 21))        # clear PRC (RW1C)
                v = _xr_r32(pa)
            spd2: uint32 = (v >> 10) & 0xF
            printk2("[xhci-real] port%d connected PORTSC=%p\n",
                    cast[uint64](p), cast[uint64](v))
            if (v & 0x2) != 0:                   # enabled now
                return (p << 8) | spd2
        p = p + 1
    return 0


def _xr_stage6_address_device(xhci: uint64, op: uint64, bar0: uint64,
                               db_base: uint64, ir0: uint64,
                               ev_cursor: uint64, ev_cyc: uint32,
                               cmd_next: uint64, cmd_cyc: uint32,
                               slot: uint32) -> int32:
    cap: uint64 = bar0
    hccp: uint32 = _xr_r32(cap + 0x10)
    csz: uint32 = (hccp >> 2) & 0x1
    ctx_sz: uint64 = 32
    if csz != 0:
        ctx_sz = 64
    _xr_ctx_sz = ctx_sz
    printk2("[xhci-real] stage6 HCCPARAMS1=%p context-size=%d\n",
            cast[uint64](hccp), ctx_sz)

    # DMA buffers MUST be identity-mapped low memory: the controller's
    # DMA engine reads/writes PHYSICAL addresses. kzalloc returns
    # low-memory identity-mapped allocations (virt==phys), exactly like
    # the .ko's own rings at 0x0500xxxx — a BSS array sits at the
    # high-half kernel mapping (0xffffffff8...) and would be read by the
    # controller as a bogus phys addr (the cause of the earlier
    # CC_TRB_ERROR). Over-allocate by 64 and align the base to 64 bytes
    # (Input/Output contexts must be 64-byte aligned).
    in_raw:  uint64 = kzalloc(2112)
    out_raw: uint64 = kzalloc(2112)
    ring_raw: uint64 = kzalloc(4160)
    desc_raw: uint64 = kzalloc(320)
    if in_raw == 0 or out_raw == 0 or ring_raw == 0 or desc_raw == 0:
        printk0("[xhci-real] FAIL stage6: kzalloc(DMA buffers) failed\n")
        return -1
    in_ctx:  uint64 = _xr_align64(in_raw)
    out_ctx: uint64 = _xr_align64(out_raw)
    ep0_ring: uint64 = _xr_align64(ring_raw)
    desc:    uint64 = _xr_align64(desc_raw)
    printk2("[xhci-real] stage6 DMA bufs: in_ctx=%p ep0_ring=%p\n",
            in_ctx, ep0_ring)
    printk2("[xhci-real] stage6 DMA bufs: out_ctx=%p desc=%p\n",
            out_ctx, desc)

    # Install the Output Device Context into the .ko's DCBAA[slot].
    dcbaa: uint64 = cast[Ptr[uint64]](xhci + XHCI_DCBAA_OFF)[0]
    cast[Ptr[uint64]](dcbaa + cast[uint64](slot) * 8)[0] = out_ctx
    printk2("[xhci-real] stage6 DCBAA=%p slot%d (out_ctx installed)\n",
            dcbaa, cast[uint64](slot))

    # Input Control Context: add Slot (A0) + EP0 (A1) = bits 0 and 1.
    cast[Ptr[uint32]](in_ctx + 0x04)[0] = 0x3

    # Slot Context (at in_ctx + ctx_sz):
    #   dword0: route(0) | speed(<<20) | ctx_entries(1)<<27
    #   dword1: root-hub-port-number << 16
    sc: uint64 = in_ctx + ctx_sz
    # The port this attempt addresses is chosen by the multi-port bring-up
    # loop in stage5 (_xr_cur_port / _xr_cur_speed), which has already
    # Port-Reset the USB2 companion so the port is enabled and reports a
    # trained speed. Hardcoding port 1 with speed=0 (its empty PORTSC) was
    # the cause of the metal Address-Device USB-Transaction-Error (cc=4);
    # picking only the FIRST connected port (an internal hub on the NUC) was
    # the cause of the stage8 "no bulk endpoints" wall.
    port_num: uint32 = _xr_cur_port
    pspeed: uint32 = _xr_cur_speed
    if port_num == 0:
        port_num = 1
        pspeed = (_xr_r32(op + 0x400) >> 10) & 0xF
    printk2("[xhci-real] stage6 connected port=%d trained-speed=%d\n",
            cast[uint64](port_num), cast[uint64](pspeed))
    cast[Ptr[uint32]](sc + 0x00)[0] = (1 << 27) | (pspeed << 20)
    cast[Ptr[uint32]](sc + 0x04)[0] = (port_num << 16)

    # EP0 Context (at in_ctx + 2*ctx_sz):
    #   dword1: EP type = Control (4) << 3 | MPS<<16 | CErr(3)<<1
    #   deq ptr (dword2/3): EP0 transfer-ring base | DCS(1)
    ep0: uint64 = in_ctx + 2 * ctx_sz
    mps: uint32 = 512
    if pspeed != 4:
        mps = 64
    cast[Ptr[uint32]](ep0 + 0x04)[0] = (4 << 3) | (3 << 1) | (mps << 16)
    cast[Ptr[uint64]](ep0 + 0x08)[0] = ep0_ring | 0x1

    # Post Address-Device at OUR tracked cmd-ring enqueue (cmd_next) with
    # the ring cycle (cmd_cyc). Do NOT re-read CRCR — it reports the ring
    # base, not the live dequeue, and reads 0 on real silicon.
    ct: Ptr[uint32] = cast[Ptr[uint32]](cmd_next)
    cast[Ptr[uint64]](cmd_next)[0] = in_ctx       # param = input ctx phys
    ct[2] = 0
    ct[3] = (_XR_TRB_TYPE_ADDRESS_DEVICE << _XR_TRB_TYPE_SHIFT) | (slot << 24) | cmd_cyc
    printk2("[xhci-real] stage6 Address-Device posted at %p (in_ctx=%p)\n",
            cmd_next, in_ctx)
    _xr_w32(db_base + 0x00, 0)

    # Walk the shared event ring for the Address-Device completion (skips any
    # remaining Port-Status-Change events / the already-harvested Enable-Slot
    # completion still resident in the ring).
    cc: int32 = _xr_scan_event(_XR_TRB_TYPE_CMD_COMPLETION, cmd_next)
    if cc != 1:
        printk1("[xhci-real] stage6: Address-Device completion-code=%d (1==SUCCESS, -1==no/foreign event)\n",
                cast[uint64](cast[uint32](cc)))
        # METAL DIAG (cc=5 TRB-Error on the NUC, 2026-06-03 capture): cc=5
        # was reported for BOTH this Address-Device AND a later context-less
        # Enable-Slot, which points at a cmd-ring cycle/Link desync rather
        # than a genuine context error. Dump enough to tell the two apart on
        # the next reflash:
        #   - the 4 dwords of the cmd TRB we posted (well-formed? right cyc?),
        #   - the Output Slot Context the controller may have written (slot
        #     state in dword3 bits 27..31 advances to Default/Addressed=1/2
        #     only if the controller actually processed the slot),
        #   - the live event-ring cursor/cycle (desync if cursor ran off seg),
        #   - the addressed port's PORTSC (device drop => CCS/PED cleared).
        dct: Ptr[uint32] = cast[Ptr[uint32]](cmd_next)
        printk2("[xhci-real] DIAG cmd-TRB lo=%p hi=%p\n",
                cast[uint64](dct[0]), cast[uint64](dct[1]))
        printk2("[xhci-real] DIAG cmd-TRB sts=%p ctl=%p\n",
                cast[uint64](dct[2]), cast[uint64](dct[3]))
        osc: Ptr[uint32] = cast[Ptr[uint32]](out_ctx)
        printk2("[xhci-real] DIAG out-slot dw0=%p dw3=%p (state=dw3>>27)\n",
                cast[uint64](osc[0]), cast[uint64](osc[3]))
        printk2("[xhci-real] DIAG ev cursor=%p cyc=%d\n",
                _xr_ev_cursor, cast[uint64](_xr_ev_cyc))
        printk2("[xhci-real] DIAG PORTSC[port=%d]=%p (CCS=b0 PED=b1)\n",
                cast[uint64](port_num),
                cast[uint64](_xr_r32(op + 0x400 + (port_num - 1) * 0x10)))
        printk0("[xhci-real] FURTHEST: Enable-Slot round-trip proven (stage5); Address-Device did not return an attributable SUCCESS\n")
        return 0
    # Read the assigned USB address out of the Output Slot Context
    # (dword3 bits 0..7) the controller wrote — proves DMA-write back.
    usbaddr: uint32 = cast[Ptr[uint32]](out_ctx + 0x0C)[0] & 0xFF
    printk2("[xhci-real] PASS stage6a: Address-Device SUCCESS slot=%d usb-addr=%d (controller wrote Output Slot Ctx)\n",
            cast[uint64](slot), cast[uint64](usbaddr))

    # Save state the MSC path (stage9 Configure-Endpoint) reuses: the
    # output device context (for its current slot context), and the next
    # command-ring cursor + cycle past the Address-Device TRB we consumed.
    _xr_in_ctx = in_ctx
    _xr_out_ctx = out_ctx
    _xr_cmd_next = cmd_next + 0x10
    _xr_cmd_cyc = cmd_cyc

    # The event-ring cursor is the SHARED walker state now; stage7 calls
    # _xr_scan_event for its transfer event, so no cursor is threaded here.
    return _xr_stage7_get_descriptor(xhci, op, bar0, db_base, ir0,
                                     0, 0, slot, ep0_ring, desc)


def _xr_stage7_get_descriptor(xhci: uint64, op: uint64, bar0: uint64,
                               db_base: uint64, ir0: uint64,
                               ev_cursor: uint64, ev_cyc_before: uint32,
                               slot: uint32,
                               ep0_ring: uint64, desc: uint64) -> int32:
    # Build a GET_DESCRIPTOR(DEVICE) control transfer on the EP0 ring:
    #   TRB0 Setup (IDT): bmRequestType=0x80 bRequest=6 (GET_DESCRIPTOR)
    #        wValue=0x0100 (DEVICE) wIndex=0 wLength=18; TRT=IN(3).
    #   TRB1 Data (IN): buffer=desc, len=18, dir=IN(1).
    #   TRB2 Status (OUT): dir=0, IOC.
    # Transfer-ring producer cycle starts at 1 (matches the DCS we put in
    # the EP0 context deq ptr).
    cyc: uint32 = 1
    t0: Ptr[uint32] = cast[Ptr[uint32]](ep0_ring + 0x00)
    # Setup stage: 8 bytes of immediate setup data in dword0/1.
    #   byte0 bmRequestType=0x80, byte1 bRequest=0x06,
    #   wValue=0x0100, wIndex=0x0000, wLength=0x0012
    t0[0] = 0x01000680
    t0[1] = 0x00120000
    t0[2] = 8                                   # TRB transfer length = 8
    t0[3] = (_XR_TRB_TYPE_SETUP << _XR_TRB_TYPE_SHIFT) | _XR_TRB_IDT | cyc | (3 << 16)

    t1: Ptr[uint32] = cast[Ptr[uint32]](ep0_ring + 0x10)
    cast[Ptr[uint64]](ep0_ring + 0x10)[0] = desc   # data buffer ptr
    t1[2] = 18                                   # length
    t1[3] = (_XR_TRB_TYPE_DATA << _XR_TRB_TYPE_SHIFT) | (1 << 16) | cyc  # DIR=IN

    t2: Ptr[uint32] = cast[Ptr[uint32]](ep0_ring + 0x20)
    t2[0] = 0
    t2[1] = 0
    t2[2] = 0
    t2[3] = (_XR_TRB_TYPE_STATUS << _XR_TRB_TYPE_SHIFT) | _XR_TRB_IOC | cyc  # DIR=OUT

    # Ring the slot's EP0 doorbell. DB register for slot N is at
    # db_base + N*4; EP0 control == target 1.
    _xr_w32(db_base + cast[uint64](slot) * 4, 1)
    printk2("[xhci-real] stage7 GET_DESCRIPTOR queued on EP0 ring=%p; DB slot%d target1 rung\n",
            ep0_ring, cast[uint64](slot))

    # Walk the shared event ring for the transfer event (type 32) that
    # references our Status TRB (ep0_ring + 0x20). The walker skips any
    # intervening events and advances the controller's ERDP.
    want_evt: uint64 = ep0_ring + 0x20
    xcc: int32 = _xr_scan_event(32, want_evt)
    if xcc >= 0:
        printk1("[xhci-real] stage7 transfer-event for Status TRB=%p observed\n", want_evt)
    db: Ptr[uint8] = cast[Ptr[uint8]](desc)
    blen: uint32 = cast[uint32](db[0])
    btype: uint32 = cast[uint32](db[1])
    printk2("[xhci-real] stage7 device-descriptor bytes: bLength=%p bDescriptorType=%p\n",
            cast[uint64](blen), cast[uint64](btype))
    if blen == 0x12 and btype == 0x01:
        bcd: uint32 = cast[uint32](db[2]) | (cast[uint32](db[3]) << 8)
        vid: uint32 = cast[uint32](db[8]) | (cast[uint32](db[9]) << 8)
        pid: uint32 = cast[uint32](db[10]) | (cast[uint32](db[11]) << 8)
        printk2("[xhci-real] stage7 descriptor bcdUSB=%p idVendor=%p\n",
                cast[uint64](bcd), cast[uint64](vid))
        printk1("[xhci-real] stage7 idProduct=%p\n", cast[uint64](pid))
        printk0("[xhci-real] PASS stage7: GET_DESCRIPTOR(device) returned a valid 18-byte device descriptor via EP0 control transfer\n")
        printk0("[xhci-real] FURTHEST: FULL real-.ko-driven enumeration step — Enable-Slot, Address-Device, and GET_DESCRIPTOR all round-tripped through the Linux xhci_hcd.ko rings (native disabled)\n")
        # Continue into the MSC (BOT) path. We consumed EP0 ring TRBs at
        # +0x00..+0x20 (next free is +0x30, same cycle). The event-ring
        # walker (_xr_ev_cursor/_xr_ev_cyc) is already live and advancing
        # from stage5 onward, so we must NOT reseed it here — doing so would
        # clobber the live cursor with stale zero params. Seed only the EP0
        # producer cursors and proceed.
        _xr_ep0_ring = ep0_ring
        _xr_ep0_off = 0x30
        _xr_ep0_cyc = cyc
        return _xr_stage8_get_config(xhci, op, bar0, db_base, ir0, slot)
    printk0("[xhci-real] FURTHEST: Address-Device SUCCESS proven (stage6a); GET_DESCRIPTOR transfer did not yield a valid descriptor at desc buffer\n")
    return 0


# =====================================================================
# MSC (USB Mass Storage, Bulk-Only Transport) path — stages 8/9/10.
#
# Everything below stays behind ENABLE_XHCI_KO_REAL_MMIO and runs ONLY
# after the full enumeration above succeeded. The proof discipline is the
# same as enumeration: every milestone is asserted from a kernel-side
# [xhci-real] marker AND a QEMU trace payload SeaBIOS cannot produce —
# specifically our bulk TRBs are fetched from OUR kzalloc'd rings (low
# 0x05xxxxxx phys) pointing at OUR low-mem DMA buffers, whereas SeaBIOS
# drives its bulk transfers from high BIOS memory (0x000e8xxx rings ->
# 0x0efexxxx data). And our CBWs carry a unique dCBWTag SeaBIOS never
# emits, plus a READ(10) of an LBA range SeaBIOS doesn't touch.
# =====================================================================

# Running EP0 control-ring + event-ring cursors threaded across the
# post-enumeration control transfers (GET_DESCRIPTOR config,
# SET_CONFIGURATION). We track these ourselves because the controller's
# CRCR/ERDP registers report ring bases, not the live dequeue.
_xr_ep0_ring:   uint64 = 0
_xr_ep0_off:    uint64 = 0
_xr_ep0_cyc:    uint32 = 1
_xr_ev_cursor:  uint64 = 0
_xr_ev_cyc:     uint32 = 0
# The Status TRB pointer of the most recent EP0 control transfer (what
# _xr_scan_event was last hunting). Stashed so a failure-path diagnostic
# can compare it against the refs physically present on the event ring.
_xr_last_status_trb: uint64 = 0

# Running command-ring cursor (advanced past the Address-Device TRB).
_xr_cmd_next:   uint64 = 0
_xr_cmd_cyc:    uint32 = 1

# Bulk endpoint addresses parsed from the configuration descriptor.
_xr_bulk_in_ep:  uint32 = 0          # e.g. 0x81
_xr_bulk_out_ep: uint32 = 0          # e.g. 0x02
_xr_bulk_in_mps: uint32 = 512
_xr_bulk_out_mps: uint32 = 512
# SuperSpeed Endpoint Companion (descriptor type 0x30) bMaxBurst — the
# 0-based max packets per burst. Left 0 for USB2 (no companion); set from
# the companion descriptor for SuperSpeed devices and programmed into the
# EP context's Max Burst Size field (dword1 bits 15:8). Real Intel xHCI
# silicon will not run a SuperSpeed bulk IN endpoint whose burst the host
# never advertised; QEMU's HighSpeed usb-storage has no companion so this
# is metal-only.
_xr_bulk_in_burst:  uint32 = 0
_xr_bulk_out_burst: uint32 = 0

# The input context we built in stage6 (reused for Configure-Endpoint).
_xr_in_ctx:     uint64 = 0
_xr_out_ctx:    uint64 = 0

# Bulk transfer rings (kzalloc'd at stage9 time). _xr_bulk_*_ring is the
# live ENQUEUE pointer; _xr_bulk_*_base is the segment start. A
# block-device serving hundreds of reads MUST wrap these rings: each
# segment holds a fixed number of TRBs, the last of which we reserve for
# a Link TRB that points back to base + toggles the producer cycle. So
# the read path NEVER runs off the end of a segment (the one-shot stage10
# demo never needed this, but root-on-USB does).
_xr_bulk_in_ring:  uint64 = 0        # live IN enqueue ptr
_xr_bulk_out_ring: uint64 = 0        # live OUT enqueue ptr
_xr_bulk_in_base:  uint64 = 0        # IN segment start
_xr_bulk_out_base: uint64 = 0        # OUT segment start
_xr_bulk_in_cyc:   uint32 = 1        # IN producer cycle
_xr_bulk_out_cyc:  uint32 = 1        # OUT producer cycle

# TRBs per bulk-ring segment. The stage9 alloc is 4160 bytes aligned to
# 64; 256 TRBs (4096 bytes) fit. We use the last TRB as the Link TRB, so
# usable data TRBs per wrap = (256 - 1).
_XR_RING_TRBS:     uint64 = 256
_XR_TRB_TYPE_LINK: uint32 = 6

# The event-ring producer cycle for newly-posted events. A freshly
# initialised event ring's producer cycle is 1; it FLIPS each time the
# controller's event dequeue wraps the segment. The block-device read
# path issues 3 events per BOT command (CBW, DATA, CSW), so across a full
# ext4 mount the event ring WILL wrap — _xr_ev_cyc is therefore a live
# variable the scan loop flips on wrap, not a constant. _xr_ev_base /
# _xr_ev_nslots bound the segment; _xr_ev_erdp_reg is the interrupter-0
# ERDP MMIO register we advance so the controller can reuse slots.
_xr_ev_base:       uint64 = 0
_xr_ev_nslots:     uint64 = 0
_xr_ev_erdp_reg:   uint64 = 0
_XR_EV_NEW_CYCLE:  uint32 = 1

# Out-of-order completion stash. QEMU's xHCI model posts a COMMAND
# completion (e.g. Configure-Endpoint) SYNCHRONOUSLY on the doorbell
# write, but EP0/bulk TRANSFER events complete ASYNchronously a few
# main-loop turns later. So when a transfer-scan walks the ring it can
# step PAST a command-completion that a later command-scan still needs
# (the events are in ring order, but the consumer waits for them in a
# different order). To avoid losing them, _xr_scan_event STASHES every
# command-completion it walks over while hunting a transfer event:
# (ref, completion-code). A subsequent command-completion scan checks
# the stash FIRST. One slot is enough — only one controller command is
# ever outstanding at a time in this driver.
_xr_cmdcmpl_ref:   uint64 = 0          # cmd-TRB ptr of stashed completion
_xr_cmdcmpl_code:  int32 = 0           # its completion code
_xr_cmdcmpl_slot:  uint32 = 0          # its slot id (Enable-Slot result)
_xr_cmdcmpl_valid: uint32 = 0          # 1 == stash holds an unconsumed cc

# Slot id from the most recent command-completion _xr_scan_event matched.
# Enable-Slot's completion carries the controller-assigned slot id in
# ev.control[31:24]; stage5 reads it here after the scan returns.
_xr_cc_slot:       uint32 = 0

# Transfer-event stash. The SAME async/interleave hazard that bites
# command completions also bites BOT transfer events: across the three
# phases of one BOT command (CBW/DATA/CSW) QEMU may post the events a
# few main-loop turns apart, and a scan hunting one phase's TRB can walk
# PAST a later phase's event (or the next command's CBW). We stash up to
# 8 walked-over transfer events (ref, code) so a later phase scan finds
# its event without re-walking the ring. 8 slots comfortably covers one
# full BOT command's worth of out-of-order interleave.
_XR_XFER_STASH_N:  uint64 = 8
_xr_xfer_ref:      Array[8, uint64]
_xr_xfer_code:     Array[8, int32]
_xr_xfer_valid:    Array[8, uint32]

# Live op-register base, stashed in stage4 so the event-scan loop can
# poke an MMIO register while waiting. QEMU advances ASYNC USB transfers
# (large bulk-IN reads + the trailing CSW) on main-loop turns driven by
# guest MMIO accesses; a pure RAM poll never exits the VM, so an async
# bulk completion would otherwise hang until the watchdog. Reading USBSTS
# periodically forces VM exits that let QEMU's usb backend make progress.
_xr_op_base:       uint64 = 0

# Cached MMIO capability base (BAR0), latched in stage2. Lets later code
# (e.g. the ko-xfer BOT diag) re-read HCCPARAMS1 CSZ — the context-size the
# .ko's CTX_SIZE() macro uses to index ep contexts — without a bar0 param.
_xr_bar0_g:        uint64 = 0

# Cached controller context size (32 or 64), latched in stage6 once
# HCCPARAMS1 CSZ is read. Lets later code (e.g. the BOT diag) index the
# output device context without re-deriving it from a bar0 it lacks.
_xr_ctx_sz:        uint64 = 64

# Per-call poll budget for the transfer-event scan (number of USBSTS-poke
# iterations to wait for the wanted event's producer-cycle flip). QEMU
# completes every control/bulk transfer within the first few iterations, so
# the default is small. Real USB flash sticks NAK the Status stage of a
# no-data control request (notably SET_CONFIGURATION) for tens of ms while
# they apply the config — far longer than QEMU. Callers that issue such a
# request raise this for the duration, then restore it. Raising it cannot
# regress the VM path (the event still lands on the first few polls there);
# it only lets a genuinely slow real device finish.
_xr_xfer_budget:   uint64 = 20000


# =====================================================================
# Persistent block-device state.
#
# Once enumeration + Configure-Endpoint succeed, the controller, its
# rings, and the device's bulk endpoints stay LIVE for the life of the
# system. We persist everything xhci_real_read_sectors() needs to issue
# an arbitrary SCSI READ(10) BOT transaction later (during ext4 mount,
# file reads, etc.) — the slot id, doorbell base, the bulk DCIs, and a
# set of LONG-LIVED DMA staging buffers (kzalloc'd low memory, virt ==
# phys). The bulk transfer-ring cursors + event cursor are the existing
# _xr_bulk_* / _xr_ev_* globals, which the read path advances exactly as
# the stage10 one-shot did. This is the .ko equivalent of the native
# drivers/usb/storage.ad UsbmsDevice.
# =====================================================================
_xr_blk_ready:     int32  = 0        # 1 once sd0 is registered + serving
_xr_blk_slot:      uint32 = 0        # xHCI slot id of the MSC device
_xr_blk_db_base:   uint64 = 0        # doorbell register base
_xr_blk_dci_in:    uint32 = 0        # bulk-IN device-context index
_xr_blk_dci_out:   uint32 = 0        # bulk-OUT device-context index
_xr_blk_block_size: uint32 = 512     # device logical block size
_xr_blk_last_lba:  uint64 = 0        # last addressable LBA (READ CAPACITY)
_xr_blk_capacity_sectors: uint64 = 0 # capacity in 512-byte sectors
_xr_blk_busy:      uint32 = 0        # reentrancy latch (one BOT at a time)

# --- Metal bring-up diagnostics (latched; reprinted in the final boot
# frame by xhci_real_blk_diag_report). The .ko block bring-up prints
# scroll off before a real-HW crash/halt frame can be photographed, so
# we latch the decisive values here and dump them next to the native
# xhci_bulk_diag_report() at end of boot.
_xr_dbg_reg_reached: int32 = 0       # 1 once _xr_register_block_device entered
_xr_dbg_reg_rc:      int32 = -99     # its return code (0=sd0 registered)
_xr_dbg_readcap_rc:  int32 = -99     # _xr_blk_read_capacity result (0=ok)
_xr_dbg_bot_phase:   int32 = -1      # last BOT phase entered: 0=CBW(OUT) 1=DATA(IN) 2=CSW(IN)
_xr_dbg_bot_cc:      int32 = -99     # last _xr_scan_xfer_wait return: -1=no event posted, >=0 xHCI completion code
_xr_dbg_bot_rounds:  uint32 = 0      # rounds spun in the last event-wait
_xr_dbg_csw_status:  int32 = -99     # bCSWStatus if a CSW was received (-99=never got there)

# DATA-IN-stall latches: filled by _xr_bot_datain_diag when the bulk-IN data
# transfer wins no event. These pin WHY (EP halted vs controller never ran the
# TRB vs an event sits unmatched on the ring). Reprinted in the final frame.
_xr_dbg_di_usbsts:   uint32 = 0xFFFFFFFF  # op USBSTS at stall time
_xr_dbg_di_portsc:   uint32 = 0xFFFFFFFF  # PORTSC of the device's port (CCS=b0 PED=b1 PLS=b5..8 spd=b10..13)
_xr_dbg_di_epstate:  int32  = -1          # IN-EP out-ctx EP State (0=Dis 1=Run 2=Halt 3=Stop 4=Err)
_xr_dbg_di_ep_deq:   uint64 = 0           # IN-EP out-ctx TR dequeue ptr (DCS=b0)
_xr_dbg_di_in_enq:   uint64 = 0           # our IN ring enqueue ptr
_xr_dbg_di_in_cyc:   uint32 = 0xFFFFFFFF  # our IN ring producer cycle
_xr_dbg_di_want:     uint64 = 0           # the IN TRB we queued + waited on
_xr_dbg_di_evcur:    uint64 = 0           # event-ring cursor at stall
_xr_dbg_di_evcyc:    uint32 = 0xFFFFFFFF  # event-ring expected cycle
_xr_dbg_di_ev0_pkt:  uint32 = 0xFFFFFFFF  # event slot0 packed (type<<12|cc<<4|cyc)
_xr_dbg_di_ev0_ref:  uint64 = 0           # event slot0 TRB pointer ref
_xr_dbg_di_filled:   int32  = 0           # 1 once the diag ran (proves DATA-IN stall path hit)
_xr_dbg_cbw_cc:      int32  = -99         # CBW(bulk-OUT) completion code (1=Success; >1 = the device/controller rejected the command -> no data on IN)
_xr_dbg_di_cur_pkt:  uint32 = 0xFFFFFFFF  # event slot AT the live cursor, packed (type<<12|cc<<4|cyc) — non-empty here == an event we failed to match (cursor/cycle desync)
_xr_dbg_di_cur_ref:  uint64 = 0           # that slot's TRB pointer ref (== di_want => the DATA event IS present but unmatched)

# TEST-UNIT-READY ready-poll latches. cbw_cc=1 + IN-EP Running + zero IN
# events == the device accepts a command but never returns data: the classic
# "medium not ready right after SET_CONFIGURATION" signature real sticks show
# and QEMU's always-ready model never does. _xr_blk_wait_ready loops TEST UNIT
# READY (+ REQUEST SENSE to clear Unit-Attention) until the device reports
# ready, exactly like Linux usb-storage/sd before READ CAPACITY.
_xr_dbg_tur_tries:    int32  = -1         # number of TEST UNIT READY attempts
_xr_dbg_tur_botrc:    int32  = -99        # last TUR _xr_bot_xfer rc (0=ready)
_xr_dbg_tur_csw:      int32  = -99        # last TUR CSW bCSWStatus (0=good 1=fail)
_xr_dbg_sense_key:    int32  = -99        # REQUEST SENSE sense key (low nibble byte 2)
_xr_dbg_di_in_mps:    uint32 = 0xFFFFFFFF # bulk-IN MaxPacketSize programmed (SS bulk MUST be 1024)
_xr_dbg_di_in_burst:  uint32 = 0xFFFFFFFF # bulk-IN SS max-burst (0-based) programmed
_xr_dbg_di_out_mps:   uint32 = 0xFFFFFFFF # bulk-OUT MaxPacketSize programmed
_xr_dbg_di_in_ctxd1:  uint32 = 0xFFFFFFFF # installed device-ctx IN-EP dword1 (EPtype<<3|burst<<8|MPS<<16) at stall

# Long-lived DMA staging buffers for the read path (kzalloc'd once at
# block-device registration time). cbw/csw are tiny; the bounce buffer
# moves a whole chunk of sector data per BOT command.
_xr_blk_cbw:       uint64 = 0        # 31-byte CBW staging
_xr_blk_csw:       uint64 = 0        # 13-byte CSW staging
_xr_blk_bounce:    uint64 = 0        # bulk-IN data bounce buffer
_XR_BLK_BOUNCE_SZ: uint64 = 4096     # bounce-buffer byte size

# The BlockDeviceOps vtable + the rolling CBW tag.
_xr_blk_ops:       BlockDeviceOps
_xr_blk_tag:       uint32 = 0x48414D40   # "HAM@" — base; bumped per command


# Whole-segment recovery search for a transfer/command event referencing
# `want_trb`, used when the strict forward-from-cursor walk fails. On real
# hardware the consumer cursor can desync from the controller's producer
# frontier across the NUC's repeated enumeration attempts: the producer
# laps the ring and REWRITES a low slot with the wanted event (current
# cycle) AFTER our cursor has already advanced past that slot in the new
# lap, so the wanted event sits PHYSICALLY PRESENT on the ring but BEHIND
# the cursor where the forward walk can never reach it. Confirmed on the
# 2026-06-03 15-59-45 / 16-12-45 NUC captures: the SET_CONFIGURATION Status
# event sat at slot 13 (cyc=1) while the cursor was stuck at slot 19 (cyc=0,
# an unwritten hole). We scan ALL slots for type==want_type && ref==want_trb
# AND cyc==cyc_expect — the cycle gate rejects PREVIOUS-lap stale duplicates
# at a reused ring address (a current-lap event carries cyc_expect; a stale
# prior-lap event carries the opposite cycle). On a hit, resync the cursor
# to just past it and advance ERDP so subsequent scans run in step. QEMU
# posts in strict order and we keep up, so this never fires in a VM — the
# forward walk always matches in order before this is reached.
def _xr_refsearch_segment(want_type: uint32, want_trb: uint64,
                          cyc_expect: uint32) -> int32:
    if _xr_ev_nslots == 0:
        return -1
    rsi: uint64 = 0
    while rsi < _xr_ev_nslots:
        rev: Ptr[uint32] = cast[Ptr[uint32]](_xr_ev_base + rsi * 0x10)
        rctl: uint32 = rev[3]
        rtype: uint32 = (rctl >> _XR_TRB_TYPE_SHIFT) & 0x3F
        rcyc: uint32 = rctl & 0x1
        rref: uint64 = (cast[uint64](rev[1]) << 32) | cast[uint64](rev[0])
        if rtype == want_type and rref == want_trb and rcyc == cyc_expect:
            rcode: int32 = cast[int32]((rev[2] >> 24) & 0xFF)
            # Command-Completion events carry the controller-assigned slot id
            # in dword3 bits 31:24. The Enable-Slot caller reads it back out of
            # _xr_cc_slot, so populate it here exactly as the forward-walk path
            # does — otherwise a refsearch-recovered Enable-Slot reports slot 0.
            if want_type == _XR_TRB_TYPE_CMD_COMPLETION:
                _xr_cc_slot = (rctl >> 24) & 0xFF
            rnext: uint64 = _xr_ev_base + (rsi + 1) * 0x10
            ncyc: uint32 = rcyc
            if rnext >= _xr_ev_base + _xr_ev_nslots * 0x10:
                rnext = _xr_ev_base
                ncyc = rcyc ^ 0x1
            _xr_ev_cursor = rnext
            _xr_ev_cyc = ncyc
            if _xr_ev_erdp_reg != 0:
                _xr_w64(_xr_ev_erdp_reg, rnext | 0x8)
            printk2("[xhci-real] evscan refsearch HIT slot=%d code=%d (cursor-desync recovered)\n",
                    rsi, cast[uint64](cast[uint32](rcode)))
            return rcode
        rsi = rsi + 1
    return -1


# Scan the event ring forward from _xr_ev_cursor for a NEW event (cycle
# == _XR_EV_NEW_CYCLE) of type `want_type` (32==transfer, 33==command-
# completion) that references the TRB at `want_trb` (its dword0/1 ptr).
# Intervening NEW events of other kinds (e.g. a spurious command-ring
# TRB_ERROR the controller may post after over-running our cmd ring) are
# skipped, so a single unexpected event cannot desync our cursor. Returns
# the completion code (ev.status >> 24) on a match, or -1 if no matching
# NEW event materialises. On match, _xr_ev_cursor is advanced past it.
def _xr_scan_event(want_type: uint32, want_trb: uint64) -> int32:
    # Scan the interrupter-0 event ring for a transfer/command event
    # referencing want_trb. This MUST wrap the event-ring segment: across a
    # full ext4 mount the controller posts thousands of events (3 per BOT
    # command) so the dequeue cursor runs off the segment and the producer
    # cycle FLIPS. We therefore track the live producer cycle in
    # _xr_ev_cyc, bound the segment with _xr_ev_base/_xr_ev_nslots, and
    # advance the controller's ERDP register so it can reuse consumed slots
    # (otherwise the controller stalls once the ring "fills").
    # Fast path: if we want a COMMAND completion and one was stashed by an
    # earlier transfer-scan that stepped over it (QEMU posts cmd
    # completions synchronously but transfer events async, so they
    # interleave out of consumer order), return it without touching the
    # ring.
    if want_type == _XR_TRB_TYPE_CMD_COMPLETION and _xr_cmdcmpl_valid != 0:
        if _xr_cmdcmpl_ref == want_trb:
            _xr_cmdcmpl_valid = 0
            _xr_cc_slot = _xr_cmdcmpl_slot
            return _xr_cmdcmpl_code
    # Command-completion direct search. A command completion is uniquely
    # identified by the cmd-ring TRB pointer it references, and the
    # controller posts it SYNCHRONOUSLY on the doorbell write — but our
    # event cursor may already be advanced PAST its slot by async transfer
    # events posted earlier in ring order. Rather than rely on the linear
    # cursor (which can sit ahead of a synchronously-posted cc), search the
    # whole segment for the matching type-33 slot. We poll briefly so the
    # cc has a chance to land.
    #
    # CRITICAL (metal): the cmd ring is small and reused across the whole
    # boot, so a cmd-ring TRB ADDRESS (want_trb) repeats. An earlier
    # command's completion (e.g. Address-Device / SET_CONFIGURATION, code=1)
    # can still be sitting in the event ring at the SAME want_trb address
    # from a PREVIOUS lap. A bare cref==want_trb match (no cycle gate) picks
    # up that stale code=1 and reports a FALSE SUCCESS for a command the
    # controller actually rejected with cc=5 (capture #58: Configure-
    # Endpoint OUT-state stayed Disabled(0) after a "cc=1"). We therefore
    # route through the SAME cycle-gated whole-segment search the transfer-
    # desync recovery uses: _xr_refsearch_segment matches type+ref AND
    # cyc==_xr_ev_cyc, rejecting previous-lap duplicates, and resyncs the
    # cursor/ERDP on a hit. VM-inert: in QEMU the fresh cc is posted at the
    # frontier carrying the current cycle, so it matches on the first pass
    # exactly as before.
    if want_type == _XR_TRB_TYPE_CMD_COMPLETION and _xr_ev_nslots != 0:
        # The controller posts a command completion SYNCHRONOUSLY within a
        # few VM exits of the doorbell write, so a modest poll budget is
        # plenty. A huge bound just burns many seconds when a command is
        # never processed (e.g. a rejected first Configure-Endpoint attempt
        # whose TRB the controller never fetches), starving the rest of
        # boot — keep it tight.
        csp: uint64 = 0
        while csp < 20000:
            rcc: int32 = _xr_refsearch_segment(want_type, want_trb, _xr_ev_cyc)
            if rcc >= 0:
                return rcc
            if _xr_op_base != 0:
                _xr_r32(_xr_op_base + _XR_OP_USBSTS)
            csp = csp + 1
        return -1
    # Transfer-event fast path: a prior scan may have already walked over
    # (and stashed) the very transfer event we now want. Return it without
    # touching the ring so phases that complete out of consumer order are
    # still matched to the phase that asked for them.
    if want_type == 32:
        sti: uint64 = 0
        while sti < _XR_XFER_STASH_N:
            if _xr_xfer_valid[sti] != 0 and _xr_xfer_ref[sti] == want_trb:
                _xr_xfer_valid[sti] = 0
                return _xr_xfer_code[sti]
            sti = sti + 1
    cur: uint64 = _xr_ev_cursor
    cyc_want: uint32 = _xr_ev_cyc
    seg_end: uint64 = _xr_ev_base + _xr_ev_nslots * 0x10
    scanned: uint64 = 0
    spin: uint64 = 0
    # Bound the scan to one full segment of unsolicited events ahead of the
    # one we want — far more than a single BOT phase ever interleaves.
    while scanned < _xr_ev_nslots:
        ev: Ptr[uint32] = cast[Ptr[uint32]](cur)
        ctl: uint32 = ev[3]
        cyc: uint32 = ctl & 0x1
        # Wait for THIS slot to carry the producer cycle we currently
        # expect. Poke USBSTS every iteration so QEMU's main loop advances
        # any pending ASYNC bulk transfer. If it never flips, the event we
        # want is not coming.
        spin = 0
        while cyc != cyc_want and spin < _xr_xfer_budget:
            if _xr_op_base != 0:
                _xr_r32(_xr_op_base + _XR_OP_USBSTS)
            ctl = ev[3]
            cyc = ctl & 0x1
            spin = spin + 1
        if cyc != cyc_want:
            # Forward walk stalled on a slot that never took the producer
            # cycle we expect — either the event truly hasn't posted yet, or
            # (on metal) the producer lapped the ring and rewrote a slot
            # BEHIND our cursor. Persist progress, then try the whole-segment
            # recovery search before giving up. Cycle-gated, so it only
            # matches a current-lap event; returns -1 in the VM (the event
            # really isn't there yet — the forward walk owns the in-order case).
            _xr_ev_cursor = cur
            _xr_ev_cyc = cyc_want
            return _xr_refsearch_segment(want_type, want_trb, cyc_want)
        t: uint32 = (ctl >> _XR_TRB_TYPE_SHIFT) & 0x3F
        ref: uint64 = (cast[uint64](ev[1]) << 32) | cast[uint64](ev[0])
        code: int32 = cast[int32]((ev[2] >> 24) & 0xFF)
        # Consume this slot: advance cursor, wrapping the segment and
        # flipping the expected producer cycle at the wrap point.
        nxt: uint64 = cur + 0x10
        if _xr_ev_nslots != 0 and nxt >= seg_end:
            nxt = _xr_ev_base
            cyc_want = cyc_want ^ 0x1
        # Tell the controller we've consumed up to (and including) this
        # slot by writing ERDP = address of the NEXT slot to dequeue, with
        # the EHB (Event Handler Busy, bit3) clear-on-write set.
        if _xr_ev_erdp_reg != 0:
            _xr_w64(_xr_ev_erdp_reg, nxt | 0x8)
        if t == want_type and ref == want_trb:
            _xr_ev_cursor = nxt
            _xr_ev_cyc = cyc_want
            return code
        # Not our event. If it's a COMMAND completion we walked over while
        # hunting a transfer event, STASH it so a later command-scan finds
        # it (one command outstanding at a time, so a single slot suffices).
        if t == _XR_TRB_TYPE_CMD_COMPLETION:
            _xr_cmdcmpl_ref = ref
            _xr_cmdcmpl_code = code
            _xr_cmdcmpl_slot = (ev[3] >> 24) & 0xFF
            _xr_cmdcmpl_valid = 1
        elif t == 32:
            # Transfer event for a phase other than the one we're hunting
            # (it landed before ours in ring order). Stash it so the phase
            # that wants it finds it via the fast path above. Use a free
            # slot, else overwrite slot 0 (stale by then).
            placed: uint32 = 0
            fsi: uint64 = 0
            while fsi < _XR_XFER_STASH_N:
                if _xr_xfer_valid[fsi] == 0:
                    _xr_xfer_ref[fsi] = ref
                    _xr_xfer_code[fsi] = code
                    _xr_xfer_valid[fsi] = 1
                    placed = 1
                    fsi = _XR_XFER_STASH_N
                else:
                    fsi = fsi + 1
            if placed == 0:
                _xr_xfer_ref[0] = ref
                _xr_xfer_code[0] = code
                _xr_xfer_valid[0] = 1
        cur = nxt
        scanned = scanned + 1
    _xr_ev_cursor = cur
    _xr_ev_cyc = cyc_want
    # Forward walk consumed a whole segment without a match. Last resort: the
    # cycle-gated whole-segment recovery search (handles the metal cursor
    # desync described on _xr_refsearch_segment). VM-inert.
    return _xr_refsearch_segment(want_type, want_trb, cyc_want)


# Run one EP0 control transfer (Setup/Data-IN/Status-OUT or
# Setup/Status for a no-data request) using the running _xr_ep0_*
# cursors. setup_lo/setup_hi are the 8 immediate setup bytes split into
# two dwords. data_buf/data_len describe the optional IN data stage
# (data_len==0 => no data stage, status dir flips to IN). Returns the
# event completion code, or -1 on no/foreign event. Advances cursors.
def _xr_ep0_control(slot: uint32, db_base: uint64,
                    setup_lo: uint32, setup_hi: uint32,
                    data_buf: uint64, data_len: uint32, trt: uint32) -> int32:
    ring: uint64 = _xr_ep0_ring
    off:  uint64 = _xr_ep0_off
    cyc:  uint32 = _xr_ep0_cyc

    setup_off: uint64 = off
    s: Ptr[uint32] = cast[Ptr[uint32]](ring + setup_off)
    s[0] = setup_lo
    s[1] = setup_hi
    s[2] = 8
    s[3] = (_XR_TRB_TYPE_SETUP << _XR_TRB_TYPE_SHIFT) | _XR_TRB_IDT | cyc | (trt << 16)
    off = off + 0x10

    if data_len != 0:
        d: Ptr[uint32] = cast[Ptr[uint32]](ring + off)
        cast[Ptr[uint64]](ring + off)[0] = data_buf
        d[2] = data_len
        d[3] = (_XR_TRB_TYPE_DATA << _XR_TRB_TYPE_SHIFT) | (1 << 16) | cyc   # DIR=IN
        off = off + 0x10

    st: Ptr[uint32] = cast[Ptr[uint32]](ring + off)
    st[0] = 0
    st[1] = 0
    st[2] = 0
    # Status dir is opposite the data stage; no-data control => Status IN.
    status_dir: uint32 = 0
    if data_len == 0:
        status_dir = 1 << 16
    st[3] = (_XR_TRB_TYPE_STATUS << _XR_TRB_TYPE_SHIFT) | _XR_TRB_IOC | cyc | status_dir
    status_trb: uint64 = ring + off
    off = off + 0x10

    # Persist the EP0 ring cursor before we wait (the scan may consume
    # intervening events but never touches the EP0 ring position).
    _xr_ep0_off = off

    _xr_w32(db_base + cast[uint64](slot) * 4, 1)     # EP0 doorbell (target 1)

    # Wait for the transfer event referencing OUR Status TRB (the last TRB
    # of this control transfer, which carries IOC). _xr_scan_event skips
    # any unsolicited events so a stray completion cannot desync us.
    _xr_last_status_trb = status_trb
    return _xr_scan_event(32, status_trb)


def _xr_blk_request_sense():
    # REQUEST SENSE(6): CDB 0x03, 18-byte data IN. Reading sense data clears a
    # pending Unit-Attention condition so the next TEST UNIT READY can succeed.
    # Latches the sense key (low nibble of byte 2) for diagnosis.
    cbw: uint64 = _xr_blk_cbw
    csw: uint64 = _xr_blk_csw
    sbuf: uint64 = _xr_blk_bounce
    _xr_blk_tag = _xr_blk_tag + 1
    _xr_build_cbw(cbw, _xr_blk_tag, 18, 1, 6)
    cdb: Ptr[uint8] = cast[Ptr[uint8]](cbw + 0x0F)
    memset(cdb, 0, 16)
    cdb[0] = 0x03                                         # REQUEST SENSE(6)
    cdb[4] = 18                                           # allocation length
    rc: int32 = _xr_bot_xfer(_xr_blk_slot, _xr_blk_db_base,
                             _xr_blk_dci_in, _xr_blk_dci_out,
                             cbw, sbuf, 18, csw, 1)
    if rc == 0:
        sb: Ptr[uint8] = cast[Ptr[uint8]](sbuf)
        _xr_dbg_sense_key = cast[int32](cast[uint32](sb[2]) & 0x0F)


def _xr_blk_test_unit_ready() -> int32:
    # TEST UNIT READY(6): CDB 0x00, zero data phase (CBW -> CSW). Returns 0 when
    # the device reports ready (CSW bCSWStatus==0), else -1. Latches the CSW
    # status so a "not ready" (status==1) is distinguishable from a hard wedge
    # (no CSW transfer event at all).
    cbw: uint64 = _xr_blk_cbw
    csw: uint64 = _xr_blk_csw
    _xr_blk_tag = _xr_blk_tag + 1
    _xr_build_cbw(cbw, _xr_blk_tag, 0, 0, 6)
    cdb: Ptr[uint8] = cast[Ptr[uint8]](cbw + 0x0F)
    memset(cdb, 0, 16)                                    # CDB 0x00 = TEST UNIT READY
    rc: int32 = _xr_bot_xfer(_xr_blk_slot, _xr_blk_db_base,
                             _xr_blk_dci_in, _xr_blk_dci_out,
                             cbw, 0, 0, csw, 0)
    _xr_dbg_tur_botrc = rc
    _xr_dbg_tur_csw = _xr_dbg_csw_status
    return rc


def _xr_blk_wait_ready() -> int32:
    # Spin TEST UNIT READY until the medium reports ready, exactly as Linux
    # usb-storage/sd do before READ CAPACITY. Real sticks routinely answer the
    # first command(s) after SET_CONFIGURATION with NOT-READY / Unit-Attention
    # (cbw_cc=1 but no data) until they finish spinning up; QEMU's model is
    # always-ready so this returns on the first try in the VM. Returns 0 once
    # ready, -1 if it never becomes ready within the bounded attempt budget.
    tries: int32 = 0
    while tries < 32:
        tries = tries + 1
        _xr_dbg_tur_tries = tries
        if _xr_blk_test_unit_ready() == 0:
            return 0
        # Not ready: read+clear sense (handles Unit-Attention) then settle a
        # moment (the MMIO poke batch hands QEMU/the controller main-loop time)
        # before retrying.
        _xr_blk_request_sense()
        _xr_bot_settle()
    return -1


def _xr_stage8_get_config(xhci: uint64, op: uint64, bar0: uint64,
                           db_base: uint64, ir0: uint64, slot: uint32) -> int32:
    # GET_DESCRIPTOR(CONFIGURATION, index 0). Request the full config
    # (wLength large enough: 64 bytes covers config+interface+endpoints
    # for a single-interface MSC device). Parse the returned descriptor
    # chain for the bulk IN/OUT endpoints (interface class 0x08 / proto
    # 0x50 == BOT).
    cfg_raw: uint64 = kzalloc(320)
    if cfg_raw == 0:
        printk0("[xhci-real] FAIL stage8: kzalloc(config buf) failed\n")
        return 0
    cfg: uint64 = _xr_align64(cfg_raw)
    # Setup: bmRequestType=0x80 bRequest=0x06 wValue=0x0200 (CONFIG, idx0)
    #        wIndex=0 wLength=0x0040.  bytes: 80 06 00 02 00 00 40 00
    rc: int32 = _xr_ep0_control(slot, db_base, 0x02000680, 0x00400000,
                                cfg, 64, 3)
    cb: Ptr[uint8] = cast[Ptr[uint8]](cfg)
    total: uint32 = cast[uint32](cb[2]) | (cast[uint32](cb[3]) << 8)
    printk2("[xhci-real] stage8 config descriptor: bLength=%p wTotalLength=%d\n",
            cast[uint64](cb[0]), cast[uint64](total))
    if cb[0] != 0x09 or cb[1] != 0x02:
        printk0("[xhci-real] FURTHEST: enumeration proven (stage7); GET_DESCRIPTOR(config) did not return a config descriptor\n")
        return 0

    # Walk the descriptor chain to find bulk IN/OUT endpoints. Each
    # descriptor: byte0=bLength, byte1=bDescriptorType. Endpoint desc
    # (type 0x05): byte2=bEndpointAddress, byte3=bmAttributes (0x02==bulk),
    # bytes4-5=wMaxPacketSize.
    if total > 256:
        total = 256
    # Per-device reset: these bulk-EP globals persist across the multi-port
    # enumeration loop. A device whose descriptor walk fails to overwrite a
    # field would otherwise inherit a PRIOR device's endpoint addr / MPS /
    # Max-Burst into its Configure-Endpoint input context, which the
    # controller rejects with TRB_ERROR (cc=5). Clear to spec defaults so
    # each device's stage9 sees only its own parsed values.
    _xr_bulk_in_ep = 0
    _xr_bulk_out_ep = 0
    _xr_bulk_in_mps = 512
    _xr_bulk_out_mps = 512
    _xr_bulk_in_burst = 0
    _xr_bulk_out_burst = 0
    pos: uint32 = 0
    found_in: uint32 = 0
    found_out: uint32 = 0
    # Track the direction of the most-recently-seen bulk endpoint so the
    # SuperSpeed Endpoint Companion descriptor (type 0x30) that immediately
    # FOLLOWS it can be attributed to the right endpoint. 0=none, 1=IN, 2=OUT.
    last_bulk_dir: uint32 = 0
    while pos + 2 <= total:
        dlen: uint32 = cast[uint32](cb[pos])
        dtype: uint32 = cast[uint32](cb[pos + 1])
        if dlen == 0:
            pos = total
        else:
            if dtype == 0x04 and pos + 6 <= total:
                # Interface descriptor: byte5=bInterfaceClass, byte6=subclass,
                # byte7=protocol. MSC BOT = class 0x08 / proto 0x50; a USB hub
                # = class 0x09. Logging this disambiguates which internal NUC
                # device sits on each non-MSC port.
                iclass: uint32 = cast[uint32](cb[pos + 5])
                iproto: uint32 = 0
                if pos + 7 <= total:
                    iproto = cast[uint32](cb[pos + 7])
                printk2("[xhci-real] stage8 interface class=%p protocol=%p\n",
                        cast[uint64](iclass), cast[uint64](iproto))
            if dtype == 0x05 and pos + 6 <= total:
                epaddr: uint32 = cast[uint32](cb[pos + 2])
                attrs: uint32 = cast[uint32](cb[pos + 3])
                mps: uint32 = cast[uint32](cb[pos + 4]) | (cast[uint32](cb[pos + 5]) << 8)
                if (attrs & 0x03) == 0x02:            # bulk
                    if (epaddr & 0x80) != 0:
                        _xr_bulk_in_ep = epaddr
                        _xr_bulk_in_mps = mps
                        found_in = 1
                        last_bulk_dir = 1
                    else:
                        _xr_bulk_out_ep = epaddr
                        _xr_bulk_out_mps = mps
                        found_out = 1
                        last_bulk_dir = 2
                else:
                    last_bulk_dir = 0     # non-bulk EP: its companion is moot
            if dtype == 0x30 and pos + 3 <= total:
                # SuperSpeed Endpoint Companion: byte2=bMaxBurst (0-based).
                # Applies to the bulk endpoint we just parsed.
                burst: uint32 = cast[uint32](cb[pos + 2])
                if last_bulk_dir == 1:
                    _xr_bulk_in_burst = burst
                elif last_bulk_dir == 2:
                    _xr_bulk_out_burst = burst
            pos = pos + dlen
    printk2("[xhci-real] stage8 bulk endpoints: IN=%p OUT=%p\n",
            cast[uint64](_xr_bulk_in_ep), cast[uint64](_xr_bulk_out_ep))
    printk2("[xhci-real] stage8 SS max-burst (0-based): IN=%d OUT=%d\n",
            cast[uint64](_xr_bulk_in_burst), cast[uint64](_xr_bulk_out_burst))
    if found_in == 0 or found_out == 0:
        printk0("[xhci-real] FURTHEST: config descriptor parsed but bulk IN/OUT endpoints not both found\n")
        return 0
    printk0("[xhci-real] PASS stage8: GET_DESCRIPTOR(config) parsed; bulk IN/OUT endpoints identified (MSC BOT device)\n")
    # Tell the multi-port bring-up loop this device IS the MSC stick so it
    # stops iterating ports (stage9 returns 0 even on success; sd0
    # registration inside stage9 is the real success signal).
    _xr_msc_bound = 1
    return _xr_stage9_configure(xhci, op, bar0, db_base, ir0, slot)


def _xr_stage9_configure(xhci: uint64, op: uint64, bar0: uint64,
                          db_base: uint64, ir0: uint64, slot: uint32) -> int32:
    # SET_CONFIGURATION(1) over EP0 (no data stage), then a
    # Configure-Endpoint command that adds the bulk IN/OUT endpoint
    # contexts so the controller will service the bulk transfer rings.
    # bytes: 00 09 01 00 00 00 00 00  => dword0=0x00010900 dword1=0
    # Real-HW: a flash stick can NAK the no-data Status stage of
    # SET_CONFIGURATION for tens of ms while it applies the configuration.
    # GET_DESCRIPTOR (IN data stage) returns immediately on the same
    # controller, so a short budget is fine there, but this request needs a
    # much wider window. QEMU completes on the first few polls regardless, so
    # the wider budget is a no-op in the VM and only helps on metal.
    _xr_xfer_budget = 4000000
    rc: int32 = _xr_ep0_control(slot, db_base, 0x00010900, 0x00000000,
                                0, 0, 0)
    _xr_xfer_budget = 20000
    printk1("[xhci-real] stage9 SET_CONFIGURATION(1) xr-rev=7 evscan-refsearch completion-code=%d\n",
            cast[uint64](cast[uint32](rc)))
    if rc != 1:
        # Disambiguate the metal failure for the next on-HW capture: a clean
        # USBSTS (controller Running, no HSE/HCE) means the device simply
        # never ACKed the Status stage in budget (NAK/slowness) — the bulk of
        # the cases. HSE(bit2)/HCE(bit12) set means the controller faulted on
        # our TRBs/DMA, a different bug class.
        sts: uint32 = 0
        if op != 0:
            sts = _xr_r32(op + _XR_OP_USBSTS)
        printk1("[xhci-real] stage9 SET_CONFIG no-event: USBSTS=%p (HCH=b0 HSE=b2 EINT=b3 PCD=b4 HCE=b12)\n",
                cast[uint64](sts))
        # Decisive disambiguation for the next on-HW capture. USBSTS alone
        # (EINT|PCD set, controller Running) cannot tell apart three causes:
        #   (a) the device dropped/re-trained the port after Address-Device
        #       (PORTSC.CCS=0, or PED=0, or PLS != U0),
        #   (b) the device never posted the Status-stage transfer event
        #       (only Port-Status-Change events, type 34, sit on the ring), or
        #   (c) a software cursor/cycle desync (a type-32 transfer event for
        #       our Status TRB is physically present but at the cycle we are
        #       not waiting for).
        # Dump PORTSC for every port, the live event-ring cursor, the raw
        # slots around it, and IMAN/ERDP so the photographed log pins the
        # cause without another guess-and-reflash round.
        if op != 0 and bar0 != 0:
            mp: uint32 = (_xr_r32(bar0 + 0x04) >> 24) & 0xFF
            pp: uint32 = 1
            while pp <= mp:
                pv: uint32 = _xr_r32(op + 0x400 + cast[uint64](pp - 1) * 0x10)
                printk2("[xhci-real] stage9 diag PORTSC port%d=%p (CCS=b0 PED=b1 PLS=b5..8 spd=b10..13)\n",
                        cast[uint64](pp), cast[uint64](pv))
                pp = pp + 1
        printk2("[xhci-real] stage9 diag ev cursor=%p cyc_want=%d\n",
                _xr_ev_cursor, cast[uint64](_xr_ev_cyc))
        printk2("[xhci-real] stage9 diag ev base=%p nslots=%d\n",
                _xr_ev_base, _xr_ev_nslots)
        # Decisive: print the Status TRB the scan was hunting, then dump a
        # window of slots AROUND the live cursor (not slot 0..7, which are
        # stale consumed events). If a type-32 slot near the cursor carries
        # ref==hunted but a cyc the scan was not waiting for => cause (c)
        # cursor/cycle desync. If the hunted ref appears nowhere => cause
        # (b) the device never posted the Status event. The slot's dtype
        # distinguishes a real transfer event (32) from port-change (34).
        printk1("[xhci-real] stage9 diag HUNTED status_trb=%p (scan wanted type=32 ref==this)\n",
                _xr_last_status_trb)
        if _xr_ev_base != 0 and _xr_ev_nslots != 0:
            cur_idx: uint64 = (_xr_ev_cursor - _xr_ev_base) / 0x10
            start_idx: uint64 = 0
            if cur_idx > 6:
                start_idx = cur_idx - 6
            wi: uint64 = 0
            while wi < 18:
                si: uint64 = start_idx + wi
                if si < _xr_ev_nslots:
                    ds: Ptr[uint32] = cast[Ptr[uint32]](_xr_ev_base + si * 0x10)
                    dctl: uint32 = ds[3]
                    dtype: uint32 = (dctl >> _XR_TRB_TYPE_SHIFT) & 0x3F
                    dcyc: uint32 = dctl & 0x1
                    dref: uint64 = (cast[uint64](ds[1]) << 32) | cast[uint64](ds[0])
                    printk2("[xhci-real] stage9 diag slot[%d] type/cyc(hi=type lo=cyc)=%p\n",
                            si, cast[uint64]((dtype << 4) | dcyc))
                    printk1("[xhci-real] stage9 diag slot ref=%p\n", dref)
                wi = wi + 1
        if ir0 != 0:
            printk2("[xhci-real] stage9 diag IMAN=%p ERDP=%p\n",
                    cast[uint64](_xr_r32(ir0 + 0x00)), _xr_r64(ir0 + _XR_IR_ERDP))
        printk0("[xhci-real] FURTHEST: stage8 proven; SET_CONFIGURATION did not complete with SUCCESS\n")
        return 0
    printk0("[xhci-real] PASS stage9a: SET_CONFIGURATION(1) accepted over EP0 (device configured)\n")

    # Build a fresh Input Context for Configure-Endpoint: add the bulk
    # IN/OUT endpoint contexts. DCI (Device Context Index) for an
    # endpoint = 2*epnum + (dir_in ? 1 : 0). We re-use the slot context
    # already in the device (just bump ctx_entries) and add the two new
    # EP contexts at their DCI slots.
    cap: uint64 = bar0
    hccp: uint32 = _xr_r32(cap + 0x10)
    csz: uint32 = (hccp >> 2) & 0x1
    ctx_sz: uint64 = 32
    if csz != 0:
        ctx_sz = 64

    in_raw: uint64 = kzalloc(4160)
    if in_raw == 0:
        printk0("[xhci-real] FAIL stage9: kzalloc(input ctx) failed\n")
        return 0
    in_ctx: uint64 = _xr_align64(in_raw)

    in_ep_num: uint32 = _xr_bulk_in_ep & 0x0F
    out_ep_num: uint32 = _xr_bulk_out_ep & 0x0F
    dci_in: uint32 = 2 * in_ep_num + 1
    dci_out: uint32 = 2 * out_ep_num

    max_dci: uint32 = dci_in
    if dci_out > max_dci:
        max_dci = dci_out

    # Input Control Context: A0 (slot) + the two bulk EP add bits.
    add_flags: uint32 = 0x1 | (1 << dci_in) | (1 << dci_out)
    cast[Ptr[uint32]](in_ctx + 0x04)[0] = add_flags

    # Slot Context: bump ctx_entries to cover the highest DCI. Preserve
    # the route/speed from the device's current output slot context.
    #
    # Layout note: the INPUT context is [Input-Control-Context | Slot |
    # EP0 | EP1 ...], so its Slot Context sits at in_ctx + ctx_sz. The
    # OUTPUT DEVICE context (the one installed in DCBAA[slot]) has NO
    # Input-Control-Context — it is [Slot | EP0 | EP1 ...] — so its Slot
    # Context is at offset 0, NOT +ctx_sz. Reading +ctx_sz here would copy
    # the device's EP0 context as if it were a slot context and the
    # controller rejects Configure-Endpoint with TRB_ERROR (cc=5).
    sc: uint64 = in_ctx + ctx_sz
    out_sc: uint64 = _xr_out_ctx
    sc_d0: uint32 = cast[Ptr[uint32]](out_sc + 0x00)[0]
    sc_d0 = (sc_d0 & ~cast[uint32](0xF8000000)) | (max_dci << 27)
    cast[Ptr[uint32]](sc + 0x00)[0] = sc_d0
    cast[Ptr[uint32]](sc + 0x04)[0] = cast[Ptr[uint32]](out_sc + 0x04)[0]

    # Allocate the bulk transfer rings (identity-mapped low memory).
    out_ring_raw: uint64 = kzalloc(4160)
    in_ring_raw:  uint64 = kzalloc(4160)
    if out_ring_raw == 0 or in_ring_raw == 0:
        printk0("[xhci-real] FAIL stage9: kzalloc(bulk rings) failed\n")
        return 0
    _xr_bulk_out_ring = _xr_align64(out_ring_raw)
    _xr_bulk_in_ring = _xr_align64(in_ring_raw)
    # Record the segment BASE for each bulk ring so _xr_queue_bulk_dir can
    # wrap (emit a Link TRB at the last slot and reset enqueue to base).
    _xr_bulk_out_base = _xr_bulk_out_ring
    _xr_bulk_in_base = _xr_bulk_in_ring
    _xr_bulk_in_cyc = 1
    _xr_bulk_out_cyc = 1

    # Bulk OUT endpoint context at DCI dci_out.
    epo: uint64 = in_ctx + cast[uint64](dci_out + 1) * ctx_sz
    # dword1: EP type Bulk-OUT(2)<<3 | CErr(3)<<1 | MaxBurst<<8 | MPS<<16
    cast[Ptr[uint32]](epo + 0x04)[0] = (2 << 3) | (3 << 1) \
        | ((_xr_bulk_out_burst & 0xFF) << 8) | (_xr_bulk_out_mps << 16)
    cast[Ptr[uint64]](epo + 0x08)[0] = _xr_bulk_out_ring | 0x1     # deq | DCS
    cast[Ptr[uint32]](epo + 0x10)[0] = _xr_bulk_out_mps           # avg TRB len

    # Bulk IN endpoint context at DCI dci_in.
    epi: uint64 = in_ctx + cast[uint64](dci_in + 1) * ctx_sz
    # dword1: EP type Bulk-IN(6)<<3 | CErr(3)<<1 | MaxBurst<<8 | MPS<<16
    cast[Ptr[uint32]](epi + 0x04)[0] = (6 << 3) | (3 << 1) \
        | ((_xr_bulk_in_burst & 0xFF) << 8) | (_xr_bulk_in_mps << 16)
    cast[Ptr[uint64]](epi + 0x08)[0] = _xr_bulk_in_ring | 0x1
    cast[Ptr[uint32]](epi + 0x10)[0] = _xr_bulk_in_mps
    _xr_dbg_di_in_mps = _xr_bulk_in_mps
    _xr_dbg_di_in_burst = _xr_bulk_in_burst
    _xr_dbg_di_out_mps = _xr_bulk_out_mps

    printk2("[xhci-real] stage9 Configure-Endpoint in_ctx=%p add_flags=%p\n",
            in_ctx, cast[uint64](add_flags))
    printk2("[xhci-real] stage9 dci_in=%d dci_out=%d\n",
            cast[uint64](dci_in), cast[uint64](dci_out))
    printk2("[xhci-real] stage9 bulk rings: in=%p out=%p\n",
            _xr_bulk_in_ring, _xr_bulk_out_ring)
    # Decisive Configure-Endpoint input-context dump: on metal this command
    # returns cc=5 (TRB Error) where QEMU returns cc=1. Print the exact bytes
    # the controller will read so the next capture pins the malformed field
    # (stale Max-Burst in d1 bits 15:8, illegal MPS in bits 31:16, bad slot
    # ctx_entries in bits 31:27, or a misaligned TR-dequeue pointer).
    printk2("[xhci-real] stage9 DIAG ctx_sz=%d slot-d0=%p\n",
            ctx_sz, cast[uint64](sc_d0))
    printk2("[xhci-real] stage9 DIAG EP-OUT d1=%p deq=%p\n",
            cast[uint64](cast[Ptr[uint32]](epo + 0x04)[0]),
            cast[Ptr[uint64]](epo + 0x08)[0])
    printk2("[xhci-real] stage9 DIAG EP-IN d1=%p deq=%p\n",
            cast[uint64](cast[Ptr[uint32]](epi + 0x04)[0]),
            cast[Ptr[uint64]](epi + 0x08)[0])

    # Post Configure-Endpoint on our tracked cmd-ring cursor. Zero the
    # FOLLOWING TRB slot first (cycle bit 0 != RCS 1) so the controller
    # halts cleanly on it instead of over-running into stale ring memory
    # and executing it as a garbage command (observed posting a spurious
    # TRB_ERROR completion that would otherwise desync the event cursor).
    #
    # Retry note: on the FIRST bring-up of a freshly-reset device the
    # controller intermittently rejects the very first Configure-Endpoint
    # with TRB_ERROR (cc=5) even though the input context is well-formed;
    # an identical re-post a moment later reliably succeeds (cc=1). Rather
    # than racing the device we post-and-scan in a short retry loop, each
    # attempt on its own cmd-ring slot.
    cc: int32 = 0
    cmd_at: uint64 = 0
    attempt: uint32 = 0
    out_state: uint32 = 0
    ep0_state: uint32 = 0
    # xr-rev=7: trust the controller's OUTPUT device context, NOT the
    # completion code. On metal a Configure-Endpoint repeatedly returns cc=5
    # (TRB Error), then some later attempt's completion is matched as cc=1 —
    # yet the bulk OUT EP in DCBAA[slot] stays Disabled(0) (capture #60:
    # post-config OUT-state=0 / d0=0x0). That cc=1 is misattributed: the
    # controller added zero endpoints. So after each attempt read the bulk
    # OUT EP state straight back from _xr_out_ctx and only declare success
    # when it actually reads Running(1). QEMU sets it Running on attempt 1.
    while attempt < 8:
        cmd_at = _xr_cmd_next
        nxt_slot: Ptr[uint32] = cast[Ptr[uint32]](cmd_at + 0x10)
        nxt_slot[0] = 0
        nxt_slot[1] = 0
        nxt_slot[2] = 0
        nxt_slot[3] = 0
        ct: Ptr[uint32] = cast[Ptr[uint32]](cmd_at)
        cast[Ptr[uint64]](cmd_at)[0] = in_ctx
        ct[2] = 0
        ct[3] = (_XR_TRB_TYPE_CONFIGURE_ENDPOINT << _XR_TRB_TYPE_SHIFT) | (slot << 24) | _xr_cmd_cyc
        _xr_w32(db_base + 0x00, 0)

        # Scan the event ring for the command-completion referencing OUR
        # Configure-Endpoint TRB (skips any spurious intervening events).
        cc = _xr_scan_event(_XR_TRB_TYPE_CMD_COMPLETION, cmd_at)
        _xr_cmd_next = cmd_at + 0x10

        # Read the controller's OUTPUT device context EP states (ground truth
        # the .ko reads). EP0 lives at +ctx_sz, the bulk OUT EP at dci_out.
        out_state = 0
        ep0_state = 0
        if _xr_out_ctx != 0:
            out_state = cast[Ptr[uint32]](_xr_out_ctx + cast[uint64](dci_out) * ctx_sz)[0] & 0x7
            ep0_state = cast[Ptr[uint32]](_xr_out_ctx + ctx_sz)[0] & 0x7
        printk2("[xhci-real] stage9 xr-rev=7 attempt cc=%d OUT-state=%d\n",
                cast[uint64](cast[uint32](cc)), cast[uint64](out_state))
        if cc == 1 and out_state == 1:
            break
        printk2("[xhci-real] stage9 Configure-Endpoint cc=%d OUT-state=%d; retrying\n",
                cast[uint64](cast[uint32](cc)), cast[uint64](out_state))
        attempt = attempt + 1

    if not (cc == 1 and out_state == 1):
        printk2("[xhci-real] stage9 Configure-Endpoint FAILED cc=%d OUT-state=%d (need cc=1 + Running)\n",
                cast[uint64](cast[uint32](cc)), cast[uint64](out_state))
        printk2("[xhci-real] stage9 xr-rev=7 EP0-state=%d add_flags_dec=%d\n",
                cast[uint64](ep0_state), cast[uint64](add_flags))
        printk0("[xhci-real] FURTHEST: SET_CONFIGURATION proven (stage9a); Configure-Endpoint never brought the bulk OUT endpoint to Running\n")
        return 0
    # Emit the "posted at" marker for the ATTEMPT THAT SUCCEEDED (cmd_at is
    # the winning slot). The controller's trace shows a CR_CONFIGURE_ENDPOINT
    # fetch only for this slot, so the address-attribution check matches it.
    printk2("[xhci-real] stage9 Configure-Endpoint posted at %p (in_ctx=%p)\n",
            cmd_at, in_ctx)

    # xr-rev=7: success is now GROUND-TRUTH validated — we only reach here when
    # the controller's live output context shows the bulk OUT EP Running(1).
    printk2("[xhci-real] stage9 xr-rev=7 CONFIRMED OUT-state=%d EP0-state=%d\n",
            cast[uint64](out_state), cast[uint64](ep0_state))
    printk0("[xhci-real] PASS stage9: Configure-Endpoint SUCCESS — bulk IN/OUT endpoints added to the device context (controller will service the bulk rings)\n")

    # The controller + device are now fully brought up and the bulk
    # endpoints are live. Register /dev/blk/sd0 backed by the .ko BOT
    # path so the block/partition/ext4/VFS layers read the root FS
    # through xhci_hcd.ko exactly like native storage.ad does. This is
    # the substance of the .ko-as-default-USB work: an arbitrary-LBA
    # block device, NOT a one-shot LBA0 demo.
    breg: int32 = _xr_register_block_device(db_base, slot, dci_in, dci_out)
    if breg < 0:
        printk0("[xhci-real] FURTHEST: Configure-Endpoint proven (stage9); block-device registration FAILED\n")
        return 0

    # The stage10a/stage10/stage10b markers the enum regression test
    # asserts are now emitted by _xr_register_block_device's self-verify
    # LBA0 read through the registered read_sectors op — NOT a redundant
    # second bring-up demo. That keeps a single set of BOT transactions on
    # the root path (READ CAPACITY + partition-scan MBR read + one LBA0
    # self-verify), which both proves the block device AND fits inside the
    # trace-slowed test's boot budget. _xr_stage10_bot_read is retained
    # below only for the standalone EXERCISE self-test (no live sd0).
    return 0


# BOT (Bulk-Only Transport) constants.
_XR_CBW_SIGNATURE: uint32 = 0x43425355      # "USBC"
_XR_CSW_SIGNATURE: uint32 = 0x53425355      # "USBS"
# A unique-to-us dCBWTag SeaBIOS never emits — proves OUR BOT command.
_XR_CBW_TAG_RDCAP: uint32 = 0x48414D31      # "HAM1"
_XR_CBW_TAG_READ10: uint32 = 0x48414D32     # "HAM2"


def _xr_queue_bulk_dir(is_in: uint32, buf: uint64, length: uint32,
                       ioc: uint32) -> uint64:
    # Queue one Normal TRB on the bulk IN (is_in!=0) or OUT ring, handling
    # SEGMENT WRAP: when the enqueue pointer reaches the LAST TRB slot of
    # the segment, write a Link TRB there (pointing back to the segment
    # base, Toggle-Cycle set) so the controller follows the ring around,
    # then reset enqueue to base and FLIP the producer cycle. This is what
    # lets the block device serve hundreds of reads without running off
    # the segment. Returns the phys/virt of the Normal TRB we wrote (the
    # address the transfer event will reference).
    ring: uint64 = _xr_bulk_out_ring
    base: uint64 = _xr_bulk_out_base
    cyc:  uint32 = _xr_bulk_out_cyc
    if is_in != 0:
        ring = _xr_bulk_in_ring
        base = _xr_bulk_in_base
        cyc  = _xr_bulk_in_cyc

    # If the next write would land on the LAST slot (reserved for Link),
    # emit the Link TRB and wrap first.
    last_slot: uint64 = base + (_XR_RING_TRBS - 1) * 0x10
    if ring >= last_slot:
        lt: Ptr[uint32] = cast[Ptr[uint32]](last_slot)
        cast[Ptr[uint64]](last_slot)[0] = base          # Link -> segment base
        lt[2] = 0
        # Link TRB: type 6, Toggle-Cycle (bit1) set so the controller
        # flips its consumer cycle on traversal; our producer cycle (cyc)
        # in bit0.
        lt[3] = (_XR_TRB_TYPE_LINK << _XR_TRB_TYPE_SHIFT) | 0x2 | cyc
        ring = base
        cyc = cyc ^ 0x1                                  # flip producer cycle

    t: Ptr[uint32] = cast[Ptr[uint32]](ring)
    cast[Ptr[uint64]](ring)[0] = buf
    t[2] = length
    flags: uint32 = cyc
    if ioc != 0:
        flags = flags | _XR_TRB_IOC
    t[3] = (_XR_TRB_TYPE_NORMAL << _XR_TRB_TYPE_SHIFT) | flags
    posted: uint64 = ring
    ring = ring + 0x10

    if is_in != 0:
        _xr_bulk_in_ring = ring
        _xr_bulk_in_cyc = cyc
    else:
        _xr_bulk_out_ring = ring
        _xr_bulk_out_cyc = cyc
    return posted


def _xr_scan_xfer_wait(want_trb: uint64, db_base: uint64,
                       slot: uint32, dci: uint32) -> int32:
    # Scan for ONE transfer event referencing want_trb, tolerant of QEMU's
    # async bulk completion latency. _xr_scan_event returns -1 the instant
    # it reaches a not-yet-posted ring slot; under load the event can land
    # a few main-loop turns later. We therefore re-scan up to a bounded
    # number of rounds. Between rounds we re-ring the endpoint doorbell
    # (the controller treats a redundant ring as a harmless nudge) and poke
    # USBSTS so QEMU's main loop advances the pending transfer. The stash
    # inside _xr_scan_event means an event that lands out of consumer order
    # is still attributed to the right phase. This converts a transient
    # "event not here YET" into a reliable success rather than a hard fail.
    # NOTE: we deliberately do NOT re-ring the endpoint doorbell between
    # rounds. QEMU's usb-storage (MSC BOT) model is a state machine; an
    # extra doorbell while a transfer is already queued can re-enter / wedge
    # its CBW->DATA->CSW sequencing. Forcing VM exits with USBSTS reads is
    # enough to let the async transfer complete; the scan then picks it up.
    # Re-scan the ring after only a SMALL batch of USBSTS pokes so we
    # return the instant the async event lands. A large poke batch
    # overshoots — under QEMU's trace-slowed main loop each USBSTS read is
    # very expensive, so burning a 500-poke batch past the moment the
    # event posts wastes real seconds and pushes boot past the test's
    # timeout. A handful of forced VM exits is enough to let QEMU's main
    # loop service the pending bulk transfer; then we look again.
    # _xr_scan_event already busy-polls USBSTS (forcing the VM exits that
    # let QEMU's main loop service the pending async bulk transfer) on the
    # next expected event-ring slot, returning the instant its cycle bit
    # flips. This outer loop only re-arms that scan a bounded number of
    # times for the rare case the event lands after the inner spin budget
    # expired. Keep the outer bound modest: the inner scan does the real
    # waiting, and an unbounded outer retry under trace-slowed QEMU burns
    # real seconds past the test's boot budget.
    rounds: uint32 = 0
    while rounds < 2000:
        cc: int32 = _xr_scan_event(32, want_trb)
        if cc >= 0:
            _xr_dbg_bot_rounds = rounds
            return cc
        rounds = rounds + 1
    _xr_dbg_bot_rounds = rounds
    return -1


def _xr_bot_settle():
    # After writing an endpoint doorbell, QEMU's xHCI model services the
    # newly-queued bulk TRB on its main loop — but ONLY runs that loop when
    # the guest yields via a VM exit. If we ring the doorbell and IMMEDIATELY
    # busy-scan the event ring, the transfer event may not be produced yet,
    # and the scan can give up before QEMU ever gets a turn (especially
    # under `-trace`, which reorders/slows the async backend). Forcing a
    # short, bounded batch of MMIO reads here hands control to QEMU's main
    # loop right after the ring so the just-queued transfer actually runs
    # and posts its event before we look. This is the deterministic
    # difference between a reliable back-to-back BOT sequence and a
    # race-dependent one. The batch is small — the subsequent scan does the
    # real waiting — so it costs negligible wall time on the fast path.
    s: uint64 = 0
    while s < 64:
        if _xr_op_base != 0:
            _xr_r32(_xr_op_base + _XR_OP_USBSTS)
        s = s + 1


# Decisive DATA-IN-stall telemetry. The CBW (bulk-OUT) phase completes but
# the bulk-IN data transfer never posts a matching transfer event on real
# SuperSpeed silicon (QEMU's usb-storage drives the full CBW->DATA-IN->CSW
# in VM, so this divergence is metal-only). Dump enough state to tell apart:
#   * device dropped/re-trained after Configure-Endpoint  -> PORTSC CCS/PED
#   * controller error (host/system error)                -> USBSTS
#   * an event IS on the ring but the cursor didn't match  -> raw event slots
#   * IN ring producer-cycle vs the TRB we queued          -> IN ring state
def _xr_bot_datain_diag(slot: uint32, db_base: uint64, dci_in: uint32,
                         want_trb: uint64):
    _xr_dbg_di_filled = 1
    _xr_dbg_di_in_enq = _xr_bulk_in_ring
    _xr_dbg_di_in_cyc = _xr_bulk_in_cyc
    _xr_dbg_di_want = want_trb
    _xr_dbg_di_evcur = _xr_ev_cursor
    _xr_dbg_di_evcyc = _xr_ev_cyc
    # Read the event-ring slot the walker is parked on. If a transfer event
    # (type 32) referencing want_trb sits HERE but the walker returned -1, the
    # cursor/cycle is desynced (the event posted, we missed it). If it carries
    # the stale (opposite) cycle, the controller genuinely posted nothing.
    if _xr_ev_cursor != 0:
        cs: Ptr[uint32] = cast[Ptr[uint32]](_xr_ev_cursor)
        cctl: uint32 = cs[3]
        _xr_dbg_di_cur_pkt = (((cctl >> _XR_TRB_TYPE_SHIFT) & 0x3F) << 12) | (((cs[2] >> 24) & 0xFF) << 4) | (cctl & 0x1)
        _xr_dbg_di_cur_ref = (cast[uint64](cs[1]) << 32) | cast[uint64](cs[0])
    op: uint64 = _xr_op_base
    if op != 0:
        _xr_dbg_di_usbsts = _xr_r32(op + 0x04)
        printk2("[xhci-real] BOT diag USBSTS=%p USBCMD=%p\n",
                cast[uint64](_xr_r32(op + 0x04)), cast[uint64](_xr_r32(op + 0x00)))
        pn: uint32 = _xr_cur_port
        if pn >= 1:
            pv: uint32 = _xr_r32(op + 0x400 + cast[uint64](pn - 1) * 0x10)
            _xr_dbg_di_portsc = pv
            printk2("[xhci-real] BOT diag PORTSC port%d=%p (CCS=b0 PED=b1 PLS=b5..8 spd=b10..13)\n",
                    cast[uint64](pn), cast[uint64](pv))
    # Decisive: read the IN endpoint's OUTPUT device-context state. The
    # controller maintains EP State in dword0 bits 2:0 of the output context
    # EP entry (0=Disabled 1=Running 2=Halted 3=Stopped 4=Error). This tells
    # apart a device STALL (Halted) from a controller that never ran the TRB
    # (still Running -> data simply never arrived) from a stop. The output
    # device context is [Slot|EP0|EP1...]; the EP at DCI N sits at N*ctx_sz.
    if _xr_out_ctx != 0:
        epc: uint64 = _xr_out_ctx + cast[uint64](dci_in) * _xr_ctx_sz
        ep_d0: uint32 = cast[Ptr[uint32]](epc + 0x00)[0]
        ep_d1: uint32 = cast[Ptr[uint32]](epc + 0x04)[0]
        ep_deq: uint64 = cast[Ptr[uint64]](epc + 0x08)[0]
        _xr_dbg_di_epstate = cast[int32](ep_d0 & 0x7)
        _xr_dbg_di_ep_deq = ep_deq
        _xr_dbg_di_in_ctxd1 = ep_d1
        printk2("[xhci-real] BOT diag IN-EP out-ctx state=%d (1=Run 2=Halt 3=Stop 4=Err) d1=%p\n",
                cast[uint64](ep_d0 & 0x7), cast[uint64](ep_d1))
        printk2("[xhci-real] BOT diag IN-EP out-ctx TRdeq=%p (DCS=b0)\n",
                ep_deq)
    printk2("[xhci-real] BOT diag IN ring enqueue=%p cyc=%d\n",
            _xr_bulk_in_ring, cast[uint64](_xr_bulk_in_cyc))
    printk2("[xhci-real] BOT diag want_trb=%p ev cursor=%p\n",
            want_trb, _xr_ev_cursor)
    printk2("[xhci-real] BOT diag ev cyc_want=%d base=%p\n",
            cast[uint64](_xr_ev_cyc), _xr_ev_base)
    if _xr_ev_base != 0 and _xr_ev_nslots != 0:
        di: uint64 = 0
        while di < 8 and di < _xr_ev_nslots:
            ds: Ptr[uint32] = cast[Ptr[uint32]](_xr_ev_base + di * 0x10)
            dctl: uint32 = ds[3]
            dtype: uint32 = (dctl >> _XR_TRB_TYPE_SHIFT) & 0x3F
            dcyc: uint32 = dctl & 0x1
            dcc: uint32 = (ds[2] >> 24) & 0xFF
            dref: uint64 = (cast[uint64](ds[1]) << 32) | cast[uint64](ds[0])
            if di == 0:
                _xr_dbg_di_ev0_pkt = (dtype << 12) | (dcc << 4) | dcyc
                _xr_dbg_di_ev0_ref = dref
            printk2("[xhci-real] BOT diag slot[%d] type/cyc/cc(packed t<<12|cc<<4|cyc)=%p\n",
                    di, cast[uint64]((dtype << 12) | (dcc << 4) | dcyc))
            printk1("[xhci-real] BOT diag slot ref=%p\n", dref)
            di = di + 1


# =====================================================================
# .ko transfer path: drive BOT phases through xhci_hcd.ko's own
# xhci_urb_enqueue so the on-the-wire TRBs are byte-identical to mainline
# Linux. See the offset-derivation block above for every struct layout.
# =====================================================================


def _xr_ko_build_ring(ring_buf: uint64, seg_buf: uint64,
                      trb_mem: uint64, ttype: uint32):
    # Fabricate a minimal struct xhci_ring + struct xhci_segment that the
    # .ko (queue_trb / prepare_ring / xhci_virt_ep_to_ring) understands,
    # pointing its TRB storage at OUR existing bulk-ring TRB memory
    # (trb_mem == _xr_bulk_*_ring base). The .ko writes Normal TRBs there
    # exactly as our hand path did, but builds them with full SuperSpeed
    # correctness (TD-Size, ISP, Max-Burst, Event-Data chaining, barrier).
    memset(cast[Ptr[uint8]](ring_buf), 0, 0x80)
    memset(cast[Ptr[uint8]](seg_buf), 0, 0x20)
    # Segment: trbs -> our TRB memory; next -> itself (single-segment
    # ring, link TRB at the end loops back); dma == trbs (identity map).
    cast[Ptr[uint64]](seg_buf + XR_SEG_TRBS_OFF)[0] = trb_mem
    cast[Ptr[uint64]](seg_buf + XR_SEG_NEXT_OFF)[0] = seg_buf
    cast[Ptr[uint64]](seg_buf + XR_SEG_DMA_OFF)[0] = trb_mem
    # Plant a Link TRB in the LAST slot pointing back to base with
    # Toggle-Cycle set, so the .ko's enqueue wraps within the one segment.
    last: uint64 = trb_mem + (_XR_RING_TRBS - 1) * 0x10
    cast[Ptr[uint64]](last + 0x00)[0] = trb_mem
    cast[Ptr[uint32]](last + 0x08)[0] = 0
    cast[Ptr[uint32]](last + 0x0C)[0] = (_XR_TRB_TYPE_LINK << _XR_TRB_TYPE_SHIFT) | 0x2
    # Ring: first_seg/enq_seg/deq_seg -> seg; enqueue/dequeue -> trb base;
    # cycle_state 1; num_trbs / num_trbs_free large so prepare_ring never
    # triggers xhci_ring_expansion (which would dma_pool_alloc and fault).
    cast[Ptr[uint64]](ring_buf + XR_RING_FIRST_SEG_OFF)[0] = seg_buf
    cast[Ptr[uint64]](ring_buf + XR_RING_ENQUEUE_OFF)[0] = trb_mem
    cast[Ptr[uint64]](ring_buf + XR_RING_ENQ_SEG_OFF)[0] = seg_buf
    cast[Ptr[uint64]](ring_buf + XR_RING_DEQUEUE_OFF)[0] = trb_mem
    cast[Ptr[uint64]](ring_buf + XR_RING_DEQ_SEG_OFF)[0] = seg_buf
    cast[Ptr[uint32]](ring_buf + XR_RING_CYCLE_OFF)[0] = 1
    cast[Ptr[uint32]](ring_buf + XR_RING_NUM_TRBS_OFF)[0] = cast[uint32](_XR_RING_TRBS)
    cast[Ptr[uint32]](ring_buf + XR_RING_NUM_FREE_OFF)[0] = cast[uint32](_XR_RING_TRBS)
    cast[Ptr[uint32]](ring_buf + XR_RING_TYPE_OFF)[0] = ttype


def _xr_ctx_copy32(src: uint64, dst: uint64):
    # Copy one 32-byte device/endpoint context slot (4 x u64).
    i: uint64 = 0
    while i < 4:
        cast[Ptr[uint64]](dst + i * 8)[0] = cast[Ptr[uint64]](src + i * 8)[0]
        i = i + 1


def _xr_ko_xfer_setup() -> int32:
    # Build (once) every struct xhci_urb_enqueue needs so the .ko can find
    # the endpoint ring state for OUR already-enumerated device, then
    # install the fabricated virt_dev into the .ko's xhci->devs[slot].
    # Returns 0 on success, -1 otherwise. Idempotent.
    if _xr_ko_ready != 0:
        return 0
    if _xr_hc_driver == 0 or _xr_hcd == 0:
        printk0("[xhci-real] ko-xfer: stage1 hc_driver / hcd missing\n")
        return -1
    if _xr_blk_slot == 0:
        printk0("[xhci-real] ko-xfer: no enumerated slot yet\n")
        return -1
    if _xr_bulk_in_base == 0 or _xr_bulk_out_base == 0:
        printk0("[xhci-real] ko-xfer: bulk rings not allocated\n")
        return -1

    # hcd_to_xhci() resolves devs[]/xhc_state from the PRIMARY hcd's priv.
    # If _xr_hcd is the shared (USB3/SuperSpeed) hcd, its primary_hcd points
    # at a DIFFERENT usb_hcd whose priv owns devs[]. Replicate
    # usb_hcd_is_primary_hcd(): follow primary_hcd when it is non-NULL and
    # not ourselves. Install the fabricated virt_dev into the PRIMARY priv so
    # xhci_check_args (which reads via hcd_to_xhci) finds it.
    eff_hcd: uint64 = _xr_hcd
    prim: uint64 = cast[Ptr[uint64]](_xr_hcd + USB_HCD_PRIMARY_HCD_OFF)[0]
    if prim != 0 and prim != _xr_hcd:
        eff_hcd = prim
    _xr_dbg_eff_hcd = eff_hcd
    _xr_dbg_prim_hcd = prim
    _xr_ko_hcd = eff_hcd
    _xr_ko_xhci = eff_hcd + USB_HCD_PRIV_OFF

    # Resolve hc_driver.urb_enqueue (a LOCAL symbol, reachable ONLY via the
    # ops table the .ko's xhci_init_driver populated in stage1).
    _xr_ko_urb_enqueue = cast[Ptr[uint64]](_xr_hc_driver + HCDRV_URB_ENQUEUE_OFF)[0]
    _xr_dbg_urbq_addr = _xr_ko_urb_enqueue
    if _xr_ko_urb_enqueue == 0:
        printk0("[xhci-real] ko-xfer: hc_driver.urb_enqueue is NULL\n")
        return -1
    printk1("[xhci-real] ko-xfer: hc_driver.urb_enqueue=%p\n", _xr_ko_urb_enqueue)

    # HCD_FLAG_HW_ACCESSIBLE (bit0 of hcd->flags) — xhci_urb_enqueue returns
    # -EPIPE if clear.
    fp: Ptr[uint32] = cast[Ptr[uint32]](_xr_ko_hcd + USB_HCD_FLAGS_OFF)
    fp[0] = fp[0] | 0x1

    # xhci->xhc_state must be 0 (not HALTED/DYING) — xhci_check_args checks
    # bit1. mem_init left it 0; force it for safety.
    cast[Ptr[uint32]](_xr_ko_xhci + XHCI_XHC_STATE_OFF)[0] = 0

    # Allocate fabricated structs from identity-mapped low memory (the .ko
    # may DMA-read none of these, but kzalloc keeps virt==phys and zeroed).
    udev_raw:   uint64 = kzalloc(0x600 + 64)
    parent_raw: uint64 = kzalloc(0x600 + 64)
    vdev_raw:   uint64 = kzalloc(0x1400 + 64)
    urb_raw:    uint64 = kzalloc(0x120 + 64)
    epin_raw:   uint64 = kzalloc(0x80 + 64)
    epout_raw:  uint64 = kzalloc(0x80 + 64)
    ringin_raw: uint64 = kzalloc(0x100 + 64)
    ringout_raw: uint64 = kzalloc(0x100 + 64)
    segin_raw:  uint64 = kzalloc(0x40 + 64)
    segout_raw: uint64 = kzalloc(0x40 + 64)
    octx_raw:   uint64 = kzalloc(0x40 + 64)
    # Synthetic device-context bytes for the .ko container: large enough to
    # hold the OUT ep-ctx at BOTH a 32-byte stride (dci_out*32) and a 64-byte
    # stride (dci_out*64) — see the dual-stride population below.
    koctxb_raw: uint64 = kzalloc(0x200 + 64)
    if udev_raw == 0 or parent_raw == 0 or vdev_raw == 0 or urb_raw == 0 \
            or epin_raw == 0 or epout_raw == 0 or ringin_raw == 0 \
            or ringout_raw == 0 or segin_raw == 0 or segout_raw == 0 \
            or octx_raw == 0 or koctxb_raw == 0:
        printk0("[xhci-real] ko-xfer: kzalloc(fabricated structs) failed\n")
        return -1
    _xr_ko_udev    = _xr_align64(udev_raw)
    _xr_ko_virt_dev = _xr_align64(vdev_raw)
    _xr_ko_urb     = _xr_align64(urb_raw)
    _xr_ko_ep_in   = _xr_align64(epin_raw)
    _xr_ko_ep_out  = _xr_align64(epout_raw)
    _xr_ko_ring_in = _xr_align64(ringin_raw)
    _xr_ko_ring_out = _xr_align64(ringout_raw)
    _xr_ko_seg_in  = _xr_align64(segin_raw)
    _xr_ko_seg_out = _xr_align64(segout_raw)
    ko_out_ctx: uint64 = _xr_align64(octx_raw)

    # struct usb_device: slot_id + SuperSpeed. (zeroed by kzalloc.)
    cast[Ptr[uint32]](_xr_ko_udev + USB_DEV_SLOT_ID_OFF)[0] = _xr_blk_slot
    cast[Ptr[uint32]](_xr_ko_udev + USB_DEV_SPEED_OFF)[0] = _XR_USB_SPEED_SUPER
    # parent MUST be non-NULL or xhci_check_args returns 0 ("root hub")
    # and xhci_urb_enqueue rejects every URB with -EINVAL (-22). The .ko
    # only tests parent for zero on the bulk path, so a dedicated zeroed
    # dummy usb_device is a safe target (any incidental read sees zeros).
    cast[Ptr[uint64]](_xr_ko_udev + USB_DEV_PARENT_OFF)[0] = _xr_align64(parent_raw)

    # struct xhci_virt_device: slot_id (prepare_transfer trusts THIS field,
    # not urb->dev->slot_id — see XHCI_VDEV_SLOT_ID_OFF comment) + udev
    # back-pointer (xhci_check_args asserts devs[slot]->udev == urb->dev);
    # flags word cleared (already zero).
    cast[Ptr[uint32]](_xr_ko_virt_dev + XHCI_VDEV_SLOT_ID_OFF)[0] = cast[uint32](_xr_blk_slot)
    cast[Ptr[uint64]](_xr_ko_virt_dev + XHCI_VDEV_UDEV_OFF)[0] = _xr_ko_udev

    # virt_dev->out_ctx: prepare_transfer reads xdev->out_ctx@0x10 and runs
    # it through xhci_get_ep_ctx, which computes
    #   ep_ctx = container->bytes + (ep_index+1) * CTX_SIZE(xhci->hcc_params).
    # CTX_SIZE is 64 iff the *cached* xhci->hcc_params CSZ bit (bit2) is set,
    # else 32. That cached copy is NOT the live MMIO HCCPARAMS1 — on the NUC
    # the live controller reports CSZ=0 (stride 32, confirmed xr-rev=8: OUT
    # ep-ctx state=1 Running @ dci*32) yet the .ko's prepare_transfer still
    # read a Disabled ep-ctx (-ENOENT), i.e. it indexed at dci*64 where the
    # context is zero. The two possible strides disagree about where the
    # Running ep-ctx lives. Rather than depend on the .ko's cached CSZ, give
    # the container its OWN synthetic device-context buffer and write each
    # live ep-ctx (slot + bulk IN + bulk OUT) at BOTH the 32- and 64-byte
    # stride positions. Whichever stride the .ko chooses, it reads the real
    # Running ep-ctx — so the EP_STATE check in prepare_ring passes. The
    # transfer ring itself comes from the fabricated virt_ep (vep->ring),
    # not from this ep_ctx, so a state-faithful copy is sufficient.
    ko_dev_ctx: uint64 = _xr_align64(koctxb_raw)
    dci_in_u:  uint64 = cast[uint64](_xr_blk_dci_in)
    dci_out_u: uint64 = cast[uint64](_xr_blk_dci_out)
    _xr_ctx_copy32(_xr_out_ctx, ko_dev_ctx)                       # slot ctx @0
    _xr_ctx_copy32(_xr_out_ctx + dci_in_u * 32,  ko_dev_ctx + dci_in_u * 32)
    _xr_ctx_copy32(_xr_out_ctx + dci_in_u * 32,  ko_dev_ctx + dci_in_u * 64)
    _xr_ctx_copy32(_xr_out_ctx + dci_out_u * 32, ko_dev_ctx + dci_out_u * 32)
    _xr_ctx_copy32(_xr_out_ctx + dci_out_u * 32, ko_dev_ctx + dci_out_u * 64)
    cast[Ptr[uint32]](ko_out_ctx + XHCI_CTX_TYPE_OFF)[0] = XHCI_CTX_TYPE_DEVICE
    cast[Ptr[uint64]](ko_out_ctx + XHCI_CTX_BYTES_OFF)[0] = ko_dev_ctx
    printk2("[xhci-real] ko-xfer xr-rev=12 synth-ctx OUT@32=%d OUT@64=%d (both should be 1=Running)\n",
            cast[uint64](cast[Ptr[uint32]](ko_dev_ctx + dci_out_u * 32)[0] & 0x7),
            cast[uint64](cast[Ptr[uint32]](ko_dev_ctx + dci_out_u * 64)[0] & 0x7))
    cast[Ptr[uint64]](_xr_ko_virt_dev + XHCI_VDEV_OUT_CTX_OFF)[0] = ko_out_ctx
    _xr_dbg_ko_out_ctx = ko_out_ctx
    _xr_dbg_ko_dev_ctx = ko_dev_ctx

    # Build the two endpoint rings wrapping OUR existing bulk TRB memory.
    _xr_ko_build_ring(_xr_ko_ring_in, _xr_ko_seg_in,
                      _xr_bulk_in_base, XR_RING_TYPE_BULK)
    _xr_ko_build_ring(_xr_ko_ring_out, _xr_ko_seg_out,
                      _xr_bulk_out_base, XR_RING_TYPE_BULK)

    # Wire each fabricated virt_ep: ring ptr + ep_state (EP_HAS_STREAMS bit
    # clear so the no-streams ring is taken). ep_index = dci - 1.
    ep_in_idx:  uint64 = cast[uint64](_xr_blk_dci_in) - 1
    ep_out_idx: uint64 = cast[uint64](_xr_blk_dci_out) - 1
    vep_in:  uint64 = _xr_ko_virt_dev + XHCI_VDEV_EPS_OFF + ep_in_idx * XHCI_VDEV_EP_STRIDE
    vep_out: uint64 = _xr_ko_virt_dev + XHCI_VDEV_EPS_OFF + ep_out_idx * XHCI_VDEV_EP_STRIDE
    cast[Ptr[uint64]](vep_in + XHCI_VEP_RING_OFF)[0] = _xr_ko_ring_in
    cast[Ptr[uint32]](vep_in + XHCI_VEP_STATE_OFF)[0] = 0
    cast[Ptr[uint64]](vep_out + XHCI_VEP_RING_OFF)[0] = _xr_ko_ring_out
    cast[Ptr[uint32]](vep_out + XHCI_VEP_STATE_OFF)[0] = 0

    # struct usb_host_endpoint per direction: desc.bEndpointAddress +
    # bmAttributes(=bulk,0x02) + wMaxPacketSize; hcpriv -> the ep ring.
    cast[Ptr[uint8]](_xr_ko_ep_in + EPDESC_BENDPOINTADDRESS_OFF)[0] = cast[uint8](_xr_bulk_in_ep)
    cast[Ptr[uint8]](_xr_ko_ep_in + EPDESC_BMATTRIBUTES_OFF)[0] = 0x02
    cast[Ptr[uint16]](_xr_ko_ep_in + EPDESC_WMAXPACKETSIZE_OFF)[0] = cast[uint16](_xr_bulk_in_mps)
    cast[Ptr[uint64]](_xr_ko_ep_in + USB_HOST_EP_HCPRIV_OFF)[0] = _xr_ko_ring_in
    cast[Ptr[uint8]](_xr_ko_ep_out + EPDESC_BENDPOINTADDRESS_OFF)[0] = cast[uint8](_xr_bulk_out_ep)
    cast[Ptr[uint8]](_xr_ko_ep_out + EPDESC_BMATTRIBUTES_OFF)[0] = 0x02
    cast[Ptr[uint16]](_xr_ko_ep_out + EPDESC_WMAXPACKETSIZE_OFF)[0] = cast[uint16](_xr_bulk_out_mps)
    cast[Ptr[uint64]](_xr_ko_ep_out + USB_HOST_EP_HCPRIV_OFF)[0] = _xr_ko_ring_out

    # Install the fabricated virt_dev into the .ko's xhci->devs[slot] so
    # xhci_get_virt_ep / xhci_check_args resolve it.
    devs_slot: uint64 = _xr_ko_xhci + XHCI_DEVS_OFF + cast[uint64](_xr_blk_slot) * 8
    cast[Ptr[uint64]](devs_slot)[0] = _xr_ko_virt_dev
    _xr_dbg_virtdev = _xr_ko_virt_dev

    # Gate-by-gate readbacks so the next NUC photo pinpoints exactly which
    # xhci_check_args condition trips: devs[slot], virt_dev->udev (must ==
    # urb->dev), udev->parent (must be non-NULL).
    _xr_dbg_devs_slotv = cast[Ptr[uint64]](devs_slot)[0]
    _xr_dbg_vdev_udev  = cast[Ptr[uint64]](_xr_ko_virt_dev + XHCI_VDEV_UDEV_OFF)[0]
    _xr_dbg_udev_parent = cast[Ptr[uint64]](_xr_ko_udev + USB_DEV_PARENT_OFF)[0]

    printk2("[xhci-real] ko-xfer: virt_dev=%p installed at devs[slot]=%p\n",
            _xr_ko_virt_dev, devs_slot)
    printk2("[xhci-real] ko-xfer: ring_in=%p ring_out=%p (wrap OUR bulk TRB mem)\n",
            _xr_ko_ring_in, _xr_ko_ring_out)
    _xr_ko_ready = 1
    _xr_dbg_ko_setup_rc = 0
    return 0


def _xr_ko_enqueue(is_in: uint32, buf: uint64, length: uint32) -> int32:
    # Issue ONE bulk transfer phase through the .ko's xhci_urb_enqueue.
    # Re-fills the reusable scratch urb, points its ring's enqueue at OUR
    # live _xr_bulk_*_ring cursor (so the .ko writes the next TRB exactly
    # where our own scan expects it), calls urb_enqueue, then advances OUR
    # cursor over the single Normal TRB the .ko queued. Returns the
    # enqueue rc (0==queued) — completion is reaped by the caller via the
    # existing event-ring scan.
    urb: uint64 = _xr_ko_urb
    memset(cast[Ptr[uint8]](urb), 0, 0x120)

    ep:   uint64 = _xr_ko_ep_out
    ring: uint64 = _xr_ko_ring_out
    pipe: uint32 = 0x40000000        # PIPE_BULK(3)<<30, dir OUT(0)
    cur:  uint64 = _xr_bulk_out_ring
    if is_in != 0:
        ep   = _xr_ko_ep_in
        ring = _xr_ko_ring_in
        pipe = 0xC0000000            # PIPE_BULK(3)<<30 | USB_DIR_IN(1)<<7? dir bit
        cur  = _xr_bulk_in_ring

    # Sync the fabricated ring's enqueue/enq_seg to OUR live cursor so the
    # .ko queues its Normal TRB at the same slot our event-scan watches.
    cast[Ptr[uint64]](ring + XR_RING_ENQUEUE_OFF)[0] = cur
    cast[Ptr[uint32]](ring + XR_RING_NUM_FREE_OFF)[0] = cast[uint32](_XR_RING_TRBS)

    cast[Ptr[uint64]](urb + URB_DEV_OFF)[0] = _xr_ko_udev
    cast[Ptr[uint64]](urb + URB_EP_OFF)[0] = ep
    cast[Ptr[uint32]](urb + URB_PIPE_OFF)[0] = pipe
    cast[Ptr[uint32]](urb + URB_STREAM_ID_OFF)[0] = 0
    cast[Ptr[uint32]](urb + URB_TRANSFER_FLAGS_OFF)[0] = 0
    cast[Ptr[uint64]](urb + URB_TRANSFER_BUF_OFF)[0] = buf
    cast[Ptr[uint64]](urb + URB_TRANSFER_DMA_OFF)[0] = buf   # identity map
    cast[Ptr[uint32]](urb + URB_NUM_SGS_OFF)[0] = 0
    cast[Ptr[uint32]](urb + URB_TRANSFER_LEN_OFF)[0] = length
    cast[Ptr[uint64]](urb + URB_HCPRIV_OFF)[0] = 0

    fn: Fn[int32, uint64, uint64, uint32] = \
        cast[Fn[int32, uint64, uint64, uint32]](_xr_ko_urb_enqueue)
    rc: int32 = fn(_xr_ko_hcd, urb, 0x20)        # GFP_ATOMIC == 0x20
    _xr_dbg_urbq_rc = rc
    _xr_dbg_last_dir_in = cast[int32](is_in)

    # Advance OUR live bulk-ring cursor + cycle over the single Normal TRB
    # the .ko just queued (it wrote it at `cur`). Mirror _xr_queue_bulk_dir's
    # wrap so a subsequent hand path or scan stays in sync.
    base: uint64 = _xr_bulk_out_base
    cyc:  uint32 = _xr_bulk_out_cyc
    if is_in != 0:
        base = _xr_bulk_in_base
        cyc  = _xr_bulk_in_cyc
    nxt: uint64 = cur + 0x10
    last_slot: uint64 = base + (_XR_RING_TRBS - 1) * 0x10
    if nxt >= last_slot:
        nxt = base
        cyc = cyc ^ 0x1
    if is_in != 0:
        _xr_bulk_in_ring = nxt
        _xr_bulk_in_cyc = cyc
    else:
        _xr_bulk_out_ring = nxt
        _xr_bulk_out_cyc = cyc
    return rc


def _xr_bot_xfer_ko(slot: uint32, db_base: uint64,
                    dci_in: uint32, dci_out: uint32,
                    cbw: uint64, data_buf: uint64, data_len: uint32,
                    csw: uint64, data_in: uint32) -> int32:
    # The .ko-driven twin of _xr_bot_xfer: each BOT phase is queued by the
    # real xhci_hcd.ko's xhci_urb_enqueue (building byte-identical mainline
    # TRBs) instead of our hand-rolled Normal TRB. Completions are reaped
    # via the SAME event-ring scan we own (we own the interrupter/event
    # ring). The .ko rings the endpoint doorbell itself (xhci_ring_ep_-
    # doorbell), so we do NOT write the doorbell here.
    # Once the .ko bulk path has proven it returns -EINVAL we stop retrying:
    # the block layer calls us hundreds of times during an ext4 mount and the
    # identical "Invalid slot_id"/rc=-22 spam buries every other log line.
    if _xr_ko_bot_dead != 0:
        return -1

    if _xr_ko_xfer_setup() != 0:
        printk0("[xhci-real] BOT(ko): setup failed; cannot drive .ko transfers\n")
        return -1

    # One-shot: render the ACTUAL slot_id chain the .ko will walk at
    # urb_enqueue time. The .ko's "Invalid slot_id %u" never substitutes the
    # value, so this is the only way to see what slot_id it really reads.
    if _xr_ko_slotdiag_done == 0:
        _xr_ko_slotdiag_done = 1
        udev_slotv: uint64 = \
            cast[uint64](cast[Ptr[uint32]](_xr_ko_udev + USB_DEV_SLOT_ID_OFF)[0])
        devs_slot_dbg: uint64 = \
            _xr_ko_xhci + XHCI_DEVS_OFF + cast[uint64](_xr_blk_slot) * 8
        printk2("[xhci-real] SLOTDIAG: _xr_blk_slot=%d  udev->slot_id(@0x530)=%d\n",
                cast[uint64](_xr_blk_slot), udev_slotv)
        printk2("[xhci-real] SLOTDIAG: udev=%p  devs[slot]=%p\n",
                _xr_ko_udev, cast[Ptr[uint64]](devs_slot_dbg)[0])
        printk2("[xhci-real] SLOTDIAG: ko_xhci=%p  devs_slot_addr=%p\n",
                _xr_ko_xhci, devs_slot_dbg)

    # xr-rev=3: decisive ep-context state read the .ko's prepare_ring will
    # see. prepare_ring switches on GET_EP_CTX_STATE(out_ctx, ep_index) =
    # out_ctx + dci*ctx_sz dword0 & 0x7; state 0 (DISABLED) is exactly what
    # makes it print "WARN urb submitted to disabled ep" and return -ENOENT
    # (-2 == the rc we hit). Printing BOTH endpoints here tells apart a
    # Configure-Endpoint that never truly took (state 0 — the cc=5/misattrib-
    # uted-"SUCCESS" path) from a context-size offset mismatch (state 1 here
    # but the .ko reading elsewhere).
    if _xr_ko_epstate_done == 0 and _xr_out_ctx != 0:
        _xr_ko_epstate_done = 1
        eo: uint64 = _xr_out_ctx + cast[uint64](dci_out) * _xr_ctx_sz
        ei: uint64 = _xr_out_ctx + cast[uint64](dci_in) * _xr_ctx_sz
        eo_d0: uint32 = cast[Ptr[uint32]](eo + 0x00)[0]
        ei_d0: uint32 = cast[Ptr[uint32]](ei + 0x00)[0]
        printk2("[xhci-real] ko-xfer xr-rev=12 OUT ep-ctx(dci=%d) state=%d (0=Disabled 1=Running 2=Halt 3=Stop)\n",
                cast[uint64](dci_out), cast[uint64](eo_d0 & 0x7))
        printk2("[xhci-real] ko-xfer xr-rev=12 IN  ep-ctx(dci=%d) state=%d ctx_sz=%d\n",
                cast[uint64](dci_in), cast[uint64](ei_d0 & 0x7))
        printk2("[xhci-real] ko-xfer xr-rev=12 OUT d0=%p IN d0=%p (full dword0)\n",
                cast[uint64](eo_d0), cast[uint64](ei_d0))
        # DECISIVE context-size probe. xhci_urb_enqueue -> xhci_queue_bulk_tx
        # -> prepare_transfer reads the ep state at
        #   xdev->out_ctx->bytes + dci*CTX_SIZE(xhci->hcc_params).
        # CTX_SIZE is 64 iff HCCPARAMS1 CSZ(bit2)=1, else 32. We index with
        # _xr_ctx_sz (32 on this NUC). If the .ko computes 64, it reads a
        # DIFFERENT, unpopulated (Disabled) slot -> prepare_ring returns
        # -ENOENT(-2) exactly as we hit, even though OUR 32-byte read shows
        # Running. Print the state at BOTH spacings + the live MMIO CSZ so the
        # next photo settles 32-vs-64 unambiguously.
        eo32: uint64 = cast[Ptr[uint32]](_xr_out_ctx + cast[uint64](dci_out) * 32)[0]
        eo64: uint64 = cast[Ptr[uint32]](_xr_out_ctx + cast[uint64](dci_out) * 64)[0]
        csz_live: uint32 = 0
        if _xr_bar0_g != 0:
            csz_live = (_xr_r32(_xr_bar0_g + 0x10) >> 2) & 0x1
        printk2("[xhci-real] ko-xfer xr-rev=12 OUT-state @32=%d @64=%d\n",
                cast[uint64](cast[uint32](eo32) & 0x7), cast[uint64](cast[uint32](eo64) & 0x7))
        printk2("[xhci-real] ko-xfer xr-rev=12 MMIO-CSZ=%d _xr_ctx_sz=%d (CSZ=1 => .ko indexes ep-ctx at *64)\n",
                cast[uint64](csz_live), _xr_ctx_sz)

        # xr-rev=12: the synth ep-ctx reads Running at BOTH strides through the
        # exact chain prepare_transfer walks, yet urb_enqueue STILL returns
        # -ENOENT. The disassembly (line ~624) exposes a SECOND -ENOENT site:
        # xhci_queue_bulk_tx does `ep = xhci_get_virt_ep(xhci, slot, ep_index);
        # if (!ep) return -ENOENT;`, and get_virt_ep returns NULL when
        # `!xhci->devs[slot]`. The `xhci` it uses is hcd_to_xhci(hcd) on the
        # SAME hcd we pass to urb_enqueue (_xr_ko_hcd) — NOT necessarily the
        # _xr_ko_xhci we installed virt_dev into during setup. If our setup's
        # single primary-follow disagrees with the .ko's own resolution, the
        # .ko reads devs[] from a struct where slot is NULL -> -ENOENT, and our
        # whole synth context (on the wrong xhci) is invisible. So replicate
        # hcd_to_xhci(_xr_ko_hcd) EXACTLY, compare, and (the fix) install the
        # fabricated virt_dev + clear xhc_state into the .ko's REAL devs[slot].
        prim_rb: uint64 = cast[Ptr[uint64]](_xr_ko_hcd + USB_HCD_PRIMARY_HCD_OFF)[0]
        eff_prim: uint64 = _xr_ko_hcd
        if prim_rb != 0 and prim_rb != _xr_ko_hcd:
            eff_prim = prim_rb
        real_xhci: uint64 = eff_prim + USB_HCD_PRIV_OFF
        real_devs_slot: uint64 = real_xhci + XHCI_DEVS_OFF + cast[uint64](_xr_blk_slot) * 8
        real_dev: uint64 = cast[Ptr[uint64]](real_devs_slot)[0]
        printk2("[xhci-real] ko-xfer xr-rev=12 real_xhci=%p (setup_xhci=%p)\n",
                real_xhci, _xr_ko_xhci)
        printk2("[xhci-real] ko-xfer xr-rev=12 real_devs[slot]=%p (virt_dev=%p)\n",
                real_dev, _xr_ko_virt_dev)
        # get_virt_ep NULL preconditions, rendered explicitly:
        #   slot in [1,256), ep_index<31, devs[slot]!=NULL.
        gve_null: uint64 = 0
        if _xr_blk_slot == 0 or cast[uint64](_xr_blk_slot) >= 256:
            gve_null = 1
        if cast[uint64](dci_out) > 31 or cast[uint64](dci_in) > 31:
            gve_null = gve_null | 2
        if real_dev == 0:
            gve_null = gve_null | 4
        printk2("[xhci-real] ko-xfer xr-rev=12 get_virt_ep would-NULL=%d (bit2=devs[slot]==0 => -ENOENT) dci_out=%d\n",
                gve_null, cast[uint64](dci_out))
        if real_xhci != _xr_ko_xhci or real_dev != _xr_ko_virt_dev:
            cast[Ptr[uint64]](real_devs_slot)[0] = _xr_ko_virt_dev
            cast[Ptr[uint32]](real_xhci + XHCI_XHC_STATE_OFF)[0] = 0
            printk2("[xhci-real] ko-xfer xr-rev=12 FIX installed virt_dev into real devs[slot]=%p (was %p)\n",
                    real_devs_slot, real_dev)

        # xr-rev=12: the DECISIVE end-to-end walk. Every prior probe read OUR
        # _xr_out_ctx (or the synth buffer directly), never the FULL pointer
        # chain prepare_transfer actually dereferences:
        #   xdev = xhci->devs[slot];
        #   ep_ctx = xdev->out_ctx->bytes + CTX_SIZE * (ep_index + 1);
        #   state = ep_ctx->ep_info & 0x7;
        # AND ep_index is NOT our dci-1 — it is recomputed by the .ko from
        # urb->ep->desc via xhci_get_endpoint_index(). Replicate that walk byte
        # for byte from the .ko's own devs[slot] (real_dev) and the OUT urb's
        # endpoint descriptor (_xr_ko_ep_out), reading the ep-state at the .ko's
        # ep_index for BOTH strides. If octx/bytes disagree with the synth we
        # installed, a pointer link is broken; if ep_index != dci_out-1, the
        # desc is mis-encoded; if both strides read 0 here, prepare_ring's
        # EP_STATE_DISABLED is NOT the -ENOENT source and we pivot to the .ko's
        # own -2 return sites.
        walk_octx: uint64 = cast[Ptr[uint64]](real_dev + XHCI_VDEV_OUT_CTX_OFF)[0]
        walk_bytes: uint64 = 0
        if walk_octx != 0:
            walk_bytes = cast[Ptr[uint64]](walk_octx + XHCI_CTX_BYTES_OFF)[0]
        ba: uint64 = cast[uint64](cast[Ptr[uint8]](_xr_ko_ep_out + EPDESC_BENDPOINTADDRESS_OFF)[0])
        attr: uint64 = cast[uint64](cast[Ptr[uint8]](_xr_ko_ep_out + EPDESC_BMATTRIBUTES_OFF)[0])
        epnum: uint64 = ba & 0xF
        ko_epidx: uint64 = epnum * 2
        if (attr & 0x3) != 0:
            ko_epidx = epnum * 2 + ((ba >> 7) & 0x1) - 1
        st32: uint64 = 0
        st64: uint64 = 0
        if walk_bytes != 0:
            st32 = cast[uint64](cast[Ptr[uint32]](walk_bytes + 32 * (ko_epidx + 1))[0] & 0x7)
            st64 = cast[uint64](cast[Ptr[uint32]](walk_bytes + 64 * (ko_epidx + 1))[0] & 0x7)
        printk2("[xhci-real] ko-xfer xr-rev=12 walk octx=%p (synth ko_out_ctx=%p)\n",
                walk_octx, _xr_dbg_ko_out_ctx)
        printk2("[xhci-real] ko-xfer xr-rev=12 walk bytes=%p (synth ko_dev_ctx=%p)\n",
                walk_bytes, _xr_dbg_ko_dev_ctx)
        printk2("[xhci-real] ko-xfer xr-rev=12 ep_out bEndpointAddress=%p bmAttributes=%p\n",
                ba, attr)
        printk2("[xhci-real] ko-xfer xr-rev=12 .ko ep_index=%d (dci_out-1=%d expected)\n",
                ko_epidx, cast[uint64](dci_out) - 1)
        printk2("[xhci-real] ko-xfer xr-rev=12 KO-CHAIN ep-state @32=%d @64=%d (THIS is prepare_ring's read)\n",
                st32, st64)

    # --- CBW phase (bulk-OUT, 31 bytes) ---
    cbw_trb: uint64 = _xr_bulk_out_ring
    rc: int32 = _xr_ko_enqueue(0, cbw, 31)
    if rc != 0:
        printk1("[xhci-real] BOT(ko): urb_enqueue(CBW) rc=%d (latching; further BOT calls will bail)\n",
                cast[uint64](cast[uint32](rc)))
        _xr_ko_bot_dead = 1
        return -1
    _xr_bot_settle()
    cc: int32 = _xr_scan_xfer_wait(cbw_trb, db_base, slot, dci_out)
    if cc < 0:
        printk0("[xhci-real] BOT(ko): no transfer event for CBW phase\n")
        return -1

    # --- DATA phase (bulk-IN for READ commands) ---
    if data_len != 0 and data_in != 0:
        data_trb: uint64 = _xr_bulk_in_ring
        rc = _xr_ko_enqueue(1, data_buf, data_len)
        if rc != 0:
            printk1("[xhci-real] BOT(ko): urb_enqueue(DATA-IN) rc=%d\n",
                    cast[uint64](cast[uint32](rc)))
            return -1
        _xr_bot_settle()
        cc = _xr_scan_xfer_wait(data_trb, db_base, slot, dci_in)
        _xr_dbg_data_cc = cc
        if cc < 0:
            printk0("[xhci-real] BOT(ko): no transfer event for DATA-IN phase\n")
            return -1

    # --- CSW phase (bulk-IN, 13 bytes) ---
    csw_trb: uint64 = _xr_bulk_in_ring
    rc = _xr_ko_enqueue(1, csw, 13)
    if rc != 0:
        printk1("[xhci-real] BOT(ko): urb_enqueue(CSW) rc=%d\n",
                cast[uint64](cast[uint32](rc)))
        return -1
    _xr_bot_settle()
    cc = _xr_scan_xfer_wait(csw_trb, db_base, slot, dci_in)
    if cc < 0:
        printk0("[xhci-real] BOT(ko): no transfer event for CSW phase\n")
        return -1

    sig: uint32 = cast[Ptr[uint32]](csw)[0]
    status: uint32 = cast[uint32](cast[Ptr[uint8]](csw)[12])
    if sig != _XR_CSW_SIGNATURE:
        printk1("[xhci-real] BOT(ko): CSW signature mismatch (got %p, want USBS)\n",
                cast[uint64](sig))
        return -1
    if status != 0:
        printk1("[xhci-real] BOT(ko): CSW bCSWStatus=%d (non-zero == command failed)\n",
                cast[uint64](status))
        return -1
    return 0


def _xr_bot_xfer(slot: uint32, db_base: uint64,
                 dci_in: uint32, dci_out: uint32,
                 cbw: uint64, data_buf: uint64, data_len: uint32,
                 csw: uint64, data_in: uint32) -> int32:
    # Route through the .ko transfer path (default) or the hand-rolled one
    # (A/B flag). The .ko path builds byte-identical mainline TRBs (fixes
    # the SuperSpeed DATA-IN stall on metal); the hand path is retained for
    # on-hardware comparison.
    if _xr_use_ko_transfers != 0:
        return _xr_bot_xfer_ko(slot, db_base, dci_in, dci_out,
                               cbw, data_buf, data_len, csw, data_in)
    return _xr_bot_xfer_hand(slot, db_base, dci_in, dci_out,
                             cbw, data_buf, data_len, csw, data_in)


def _xr_bot_xfer_hand(slot: uint32, db_base: uint64,
                      dci_in: uint32, dci_out: uint32,
                      cbw: uint64, data_buf: uint64, data_len: uint32,
                      csw: uint64, data_in: uint32) -> int32:
    # One full BOT transaction: CBW (bulk-OUT) -> data (bulk-IN/OUT) ->
    # CSW (bulk-IN). Each phase rings the appropriate endpoint doorbell
    # and scans the event ring for the transfer event referencing OUR
    # bulk-ring TRB. Returns 0 on a good CSW (dCSWSignature=="USBS" +
    # bCSWStatus==0), else -1.
    # --- CBW phase (always bulk-OUT, 31 bytes) ---
    _xr_dbg_bot_phase = 0
    cbw_trb: uint64 = _xr_queue_bulk_dir(0, cbw, 31, 1)
    _xr_w32(db_base + cast[uint64](slot) * 4, dci_out)
    _xr_bot_settle()
    cc: int32 = _xr_scan_xfer_wait(cbw_trb, db_base, slot, dci_out)
    _xr_dbg_bot_cc = cc
    _xr_dbg_cbw_cc = cc
    if cc < 0:
        printk0("[xhci-real] BOT: no transfer event for CBW phase\n")
        return -1

    # --- DATA phase (bulk-IN for READ commands) ---
    if data_len != 0 and data_in != 0:
        _xr_dbg_bot_phase = 1
        data_trb: uint64 = _xr_queue_bulk_dir(1, data_buf, data_len, 1)
        _xr_w32(db_base + cast[uint64](slot) * 4, dci_in)
        _xr_bot_settle()
        cc = _xr_scan_xfer_wait(data_trb, db_base, slot, dci_in)
        _xr_dbg_bot_cc = cc
        if cc < 0:
            printk0("[xhci-real] BOT: no transfer event for DATA-IN phase\n")
            _xr_bot_datain_diag(slot, db_base, dci_in, data_trb)
            return -1

    # --- CSW phase (always bulk-IN, 13 bytes) ---
    _xr_dbg_bot_phase = 2
    csw_trb: uint64 = _xr_queue_bulk_dir(1, csw, 13, 1)
    _xr_w32(db_base + cast[uint64](slot) * 4, dci_in)
    _xr_bot_settle()
    cc = _xr_scan_xfer_wait(csw_trb, db_base, slot, dci_in)
    _xr_dbg_bot_cc = cc
    if cc < 0:
        printk0("[xhci-real] BOT: no transfer event for CSW phase\n")
        return -1

    sig: uint32 = cast[Ptr[uint32]](csw)[0]
    status: uint32 = cast[uint32](cast[Ptr[uint8]](csw)[12])
    _xr_dbg_csw_status = cast[int32](status)
    if sig != _XR_CSW_SIGNATURE:
        printk1("[xhci-real] BOT: CSW signature mismatch (got %p, want USBS)\n",
                cast[uint64](sig))
        return -1
    if status != 0:
        printk1("[xhci-real] BOT: CSW bCSWStatus=%d (non-zero == command failed)\n",
                cast[uint64](status))
        return -1
    return 0


def _xr_build_cbw(cbw: uint64, tag: uint32, data_len: uint32, dir_in: uint32,
                  cdb_len: uint32):
    # Zero + populate a 31-byte BOT Command Block Wrapper.
    memset(cast[Ptr[uint8]](cbw), 0, 31)
    cast[Ptr[uint32]](cbw + 0x00)[0] = _XR_CBW_SIGNATURE   # dCBWSignature
    cast[Ptr[uint32]](cbw + 0x04)[0] = tag                 # dCBWTag (unique)
    cast[Ptr[uint32]](cbw + 0x08)[0] = data_len            # dCBWDataTransferLength
    flags: uint8 = 0
    if dir_in != 0:
        flags = 0x80                                       # bmCBWFlags: IN
    cast[Ptr[uint8]](cbw + 0x0C)[0] = flags
    cast[Ptr[uint8]](cbw + 0x0D)[0] = 0                     # bCBWLUN
    cast[Ptr[uint8]](cbw + 0x0E)[0] = cast[uint8](cdb_len) # bCBWCBLength


def _xr_stage10_bot_read(xhci: uint64, op: uint64, bar0: uint64,
                          db_base: uint64, ir0: uint64, slot: uint32) -> int32:
    # Drive real SCSI over BOT through the .ko-serviced bulk rings:
    #   (a) READ CAPACITY(10) — 8 data bytes (last-LBA + block-size).
    #   (b) READ(10) of LBA 0 — 512 sector bytes; verify MBR sig 0x55AA.
    in_ep_num: uint32 = _xr_bulk_in_ep & 0x0F
    out_ep_num: uint32 = _xr_bulk_out_ep & 0x0F
    dci_in: uint32 = 2 * in_ep_num + 1
    dci_out: uint32 = 2 * out_ep_num

    cbw_raw: uint64 = kzalloc(128)
    csw_raw: uint64 = kzalloc(128)
    cap_raw: uint64 = kzalloc(128)
    sec_raw: uint64 = kzalloc(1024)
    if cbw_raw == 0 or csw_raw == 0 or cap_raw == 0 or sec_raw == 0:
        printk0("[xhci-real] FAIL stage10: kzalloc(BOT buffers) failed\n")
        return 0
    cbw: uint64 = _xr_align64(cbw_raw)
    csw: uint64 = _xr_align64(csw_raw)
    capbuf: uint64 = _xr_align64(cap_raw)
    secbuf: uint64 = _xr_align64(sec_raw)
    printk2("[xhci-real] stage10 BOT bufs: cbw=%p sector=%p\n", cbw, secbuf)

    # --- READ CAPACITY(10): CDB = 0x25, all-zero LBA, 8-byte data IN. ---
    _xr_build_cbw(cbw, _XR_CBW_TAG_RDCAP, 8, 1, 10)
    cdb: Ptr[uint8] = cast[Ptr[uint8]](cbw + 0x0F)
    memset(cdb, 0, 16)
    cdb[0] = 0x25                                          # READ CAPACITY(10)
    printk2("[xhci-real] stage10 READ CAPACITY(10) CBW tag=%p at cbw=%p\n",
            cast[uint64](_XR_CBW_TAG_RDCAP), cbw)
    rc: int32 = _xr_bot_xfer(slot, db_base, dci_in, dci_out,
                             cbw, capbuf, 8, csw, 1)
    if rc != 0:
        printk0("[xhci-real] FURTHEST: Configure-Endpoint proven (stage9); READ CAPACITY BOT transaction did not complete with a good CSW\n")
        return 0
    cp: Ptr[uint8] = cast[Ptr[uint8]](capbuf)
    last_lba: uint32 = (cast[uint32](cp[0]) << 24) | (cast[uint32](cp[1]) << 16) \
                     | (cast[uint32](cp[2]) << 8) | cast[uint32](cp[3])
    blk_sz: uint32 = (cast[uint32](cp[4]) << 24) | (cast[uint32](cp[5]) << 16) \
                   | (cast[uint32](cp[6]) << 8) | cast[uint32](cp[7])
    printk2("[xhci-real] PASS stage10a: READ CAPACITY(10) over .ko bulk rings — last-LBA=%d block-size=%d\n",
            cast[uint64](last_lba), cast[uint64](blk_sz))

    # --- READ(10) of LBA 0, one 512-byte block, data IN. ---
    memset(cast[Ptr[uint8]](secbuf), 0, 512)
    _xr_build_cbw(cbw, _XR_CBW_TAG_READ10, 512, 1, 10)
    cdb = cast[Ptr[uint8]](cbw + 0x0F)
    memset(cdb, 0, 16)
    cdb[0] = 0x28                                          # READ(10)
    cdb[2] = 0                                             # LBA[31:24]
    cdb[3] = 0                                             # LBA[23:16]
    cdb[4] = 0                                             # LBA[15:8]
    cdb[5] = 0                                             # LBA[7:0] == 0
    cdb[7] = 0                                             # xfer len hi
    cdb[8] = 1                                             # 1 block
    printk2("[xhci-real] stage10 READ(10) LBA0 CBW tag=%p at cbw=%p\n",
            cast[uint64](_XR_CBW_TAG_READ10), cbw)
    rc = _xr_bot_xfer(slot, db_base, dci_in, dci_out,
                      cbw, secbuf, 512, csw, 1)
    if rc != 0:
        printk0("[xhci-real] FURTHEST: READ CAPACITY proven (stage10a); READ(10) BOT transaction did not complete with a good CSW\n")
        return 0
    sb: Ptr[uint8] = cast[Ptr[uint8]](secbuf)
    b0: uint32 = cast[uint32](sb[0])
    b1: uint32 = cast[uint32](sb[1])
    sig0: uint32 = cast[uint32](sb[510])
    sig1: uint32 = cast[uint32](sb[511])
    printk2("[xhci-real] stage10 sector0 first bytes: [0]=%p [1]=%p\n",
            cast[uint64](b0), cast[uint64](b1))
    printk2("[xhci-real] stage10 sector0 sig bytes: [510]=%p [511]=%p\n",
            cast[uint64](sig0), cast[uint64](sig1))
    printk0("[xhci-real] PASS stage10: READ(10) of LBA0 over .ko bulk rings returned 512 sector bytes through the Linux xhci_hcd.ko BOT path\n")
    if sig0 == 0x55 and sig1 == 0xAA:
        printk0("[xhci-real] PASS stage10b: sector-0 carries the 0x55AA MBR boot signature (real disk data DMA'd back through OUR bulk-IN ring)\n")
    printk0("[xhci-real] FURTHEST: FULL real-.ko-driven USB-MSC block read — Configure-Endpoint + BOT READ CAPACITY + READ(10) all round-tripped through the Linux xhci_hcd.ko bulk rings (native disabled)\n")
    return 0


# =====================================================================
# Block-device layer: /dev/blk/sd0 backed by the .ko BOT path.
#
# This turns the one-shot stage10 demo into a real, arbitrary-LBA block
# device. The contract is identical to native drivers/usb/storage.ad:
# register_blockdev("sd0") with a BlockDeviceOps whose read_sectors
# serves any LBA, then blk_scan_partitions / blk_register_partitions so
# the ext4-magic root scan sees sd0pN. Every FS read (ext4 superblock,
# inode tables, directory blocks, file data) flows through here.
# =====================================================================


def _xr_blk_one_bot_read(dev_lba: uint32, dev_blocks: uint32,
                         bytes_n: uint32) -> int32:
    # Issue ONE SCSI READ(10) BOT transaction for `dev_blocks` logical
    # blocks at `dev_lba`, landing `bytes_n` bytes in the persistent
    # bounce buffer. Returns 0 on a good CSW, -1 otherwise. Reuses the
    # exact CBW/CSW + bulk-ring machinery the stage10 demo proved.
    cbw: uint64 = _xr_blk_cbw
    csw: uint64 = _xr_blk_csw
    _xr_blk_tag = _xr_blk_tag + 1
    _xr_build_cbw(cbw, _xr_blk_tag, bytes_n, 1, 10)
    cdb: Ptr[uint8] = cast[Ptr[uint8]](cbw + 0x0F)
    memset(cdb, 0, 16)
    cdb[0] = 0x28                                          # READ(10)
    # CDB bytes 2..5: 32-bit big-endian LBA.
    cdb[2] = cast[uint8]((dev_lba >> 24) & 0xFF)
    cdb[3] = cast[uint8]((dev_lba >> 16) & 0xFF)
    cdb[4] = cast[uint8]((dev_lba >> 8) & 0xFF)
    cdb[5] = cast[uint8](dev_lba & 0xFF)
    # CDB bytes 7..8: 16-bit big-endian transfer length (blocks).
    cdb[7] = cast[uint8]((dev_blocks >> 8) & 0xFF)
    cdb[8] = cast[uint8](dev_blocks & 0xFF)
    return _xr_bot_xfer(_xr_blk_slot, _xr_blk_db_base,
                        _xr_blk_dci_in, _xr_blk_dci_out,
                        cbw, _xr_blk_bounce, bytes_n, csw, 1)


def xhci_real_read_sectors(priv: uint64, lba: uint64, count: uint64,
                           buf: Ptr[uint8]) -> int32:
    # BlockDeviceOps.read_sectors: read `count` 512-byte sectors from
    # sector `lba` into buf, through the live xhci_hcd.ko bulk rings.
    # Chunks through the persistent bounce buffer so an arbitrarily
    # large request never overruns a single bulk TRB. Returns 0 on
    # success, -1 on failure. Mirrors native usbms_read_sectors.
    #
    # SERIALIZATION: a single set of DMA staging buffers + the single
    # bulk endpoint pair means exactly one BOT command may be in flight.
    # Kernel block reads run IF-masked (syscall context), so the timer
    # cannot preempt mid-transfer; the busy latch turns any unexpected
    # re-entry into a clean -1 rather than buffer corruption.
    if _xr_blk_ready == 0 or _xr_blk_slot == 0:
        return -1
    if _xr_blk_busy != 0:
        return -1
    _xr_blk_busy = 1
    rc: int32 = _xr_blk_read_sectors_inner(lba, count, buf)
    _xr_blk_busy = 0
    return rc


def _xr_blk_read_sectors_inner(lba: uint64, count: uint64,
                               buf: Ptr[uint8]) -> int32:
    bs: uint32 = _xr_blk_block_size
    if bs == 0:
        bs = 512
    # 512-byte sectors per device logical block (>=1).
    sectors_per_blk: uint64 = cast[uint64](bs) / SECTOR_SIZE
    if sectors_per_blk == 0:
        sectors_per_blk = 1
    # How many sectors fit in the bounce buffer.
    max_sectors: uint64 = _XR_BLK_BOUNCE_SZ / SECTOR_SIZE
    chunk_blocks: uint64 = max_sectors / sectors_per_blk
    if chunk_blocks == 0:
        chunk_blocks = 1
    chunk_sectors: uint64 = chunk_blocks * sectors_per_blk

    done: uint64 = 0
    while done < count:
        n: uint64 = count - done
        if n > chunk_sectors:
            n = chunk_sectors
        # Convert this chunk's sector range to device logical blocks.
        dev_lba: uint64 = (lba + done) / sectors_per_blk
        dev_blocks: uint64 = (n + sectors_per_blk - 1) / sectors_per_blk
        bytes_n: uint32 = cast[uint32](dev_blocks * cast[uint64](bs))
        rc: int32 = _xr_blk_one_bot_read(cast[uint32](dev_lba),
                                         cast[uint32](dev_blocks), bytes_n)
        if rc != 0:
            printk1("[xhci-real] read_sectors FAILED at lba=%d\n", lba + done)
            return -1
        # Copy exactly n*512 bytes out of the bounce buffer at the
        # sector offset within the (block-aligned) device read.
        skip: uint64 = ((lba + done) % sectors_per_blk) * SECTOR_SIZE
        memcpy(cast[Ptr[uint8]](cast[uint64](buf) + done * SECTOR_SIZE),
               cast[Ptr[uint8]](_xr_blk_bounce + skip),
               n * SECTOR_SIZE)
        done = done + n
    return 0


def _xr_blk_read_capacity() -> int32:
    # READ CAPACITY(10) over the live bulk rings; fill geometry globals.
    # Returns 0 on success, -1 on failure.
    cbw: uint64 = _xr_blk_cbw
    csw: uint64 = _xr_blk_csw
    capbuf: uint64 = _xr_blk_bounce
    _xr_blk_tag = _xr_blk_tag + 1
    _xr_build_cbw(cbw, _xr_blk_tag, 8, 1, 10)
    cdb: Ptr[uint8] = cast[Ptr[uint8]](cbw + 0x0F)
    memset(cdb, 0, 16)
    cdb[0] = 0x25                                          # READ CAPACITY(10)
    rc: int32 = _xr_bot_xfer(_xr_blk_slot, _xr_blk_db_base,
                             _xr_blk_dci_in, _xr_blk_dci_out,
                             cbw, capbuf, 8, csw, 1)
    if rc != 0:
        return -1
    cp: Ptr[uint8] = cast[Ptr[uint8]](capbuf)
    last_lba: uint32 = (cast[uint32](cp[0]) << 24) | (cast[uint32](cp[1]) << 16) \
                     | (cast[uint32](cp[2]) << 8) | cast[uint32](cp[3])
    blk_sz: uint32 = (cast[uint32](cp[4]) << 24) | (cast[uint32](cp[5]) << 16) \
                   | (cast[uint32](cp[6]) << 8) | cast[uint32](cp[7])
    if blk_sz == 0:
        blk_sz = 512
    _xr_blk_last_lba = cast[uint64](last_lba)
    _xr_blk_block_size = blk_sz
    total_blocks: uint64 = cast[uint64](last_lba) + 1
    total_bytes: uint64 = total_blocks * cast[uint64](blk_sz)
    _xr_blk_capacity_sectors = total_bytes / SECTOR_SIZE
    printk2("[xhci-real] blk READ CAPACITY: last_lba=%d block_size=%d\n",
            cast[uint64](last_lba), cast[uint64](blk_sz))
    printk1("[xhci-real] blk capacity = %d x 512-byte sectors\n",
            _xr_blk_capacity_sectors)
    return 0


def _xr_register_block_device(db_base: uint64, slot: uint32,
                              dci_in: uint32, dci_out: uint32) -> int32:
    # Persist the live controller/device state and register sd0 as a
    # BlockDeviceOps backed by the .ko BOT path, then scan + register
    # partitions — exactly the contract native usbms_probe implements.
    _xr_dbg_reg_reached = 1
    if _xr_blk_ready != 0:
        # Idempotent: a second bring-up just re-confirms the endpoints.
        _xr_blk_slot = slot
        _xr_blk_db_base = db_base
        _xr_blk_dci_in = dci_in
        _xr_blk_dci_out = dci_out
        printk0("[xhci-real] blk: sd0 already registered; reusing\n")
        _xr_dbg_reg_rc = 0
        return 0
    _xr_blk_slot = slot
    _xr_blk_db_base = db_base
    _xr_blk_dci_in = dci_in
    _xr_blk_dci_out = dci_out

    # Long-lived DMA staging buffers (kzalloc'd low memory, virt==phys).
    cbw_raw: uint64 = kzalloc(128)
    csw_raw: uint64 = kzalloc(128)
    bnc_raw: uint64 = kzalloc(_XR_BLK_BOUNCE_SZ + 128)
    if cbw_raw == 0 or csw_raw == 0 or bnc_raw == 0:
        printk0("[xhci-real] blk: kzalloc(DMA staging) failed\n")
        _xr_dbg_reg_rc = -1
        return -1
    _xr_blk_cbw = _xr_align64(cbw_raw)
    _xr_blk_csw = _xr_align64(csw_raw)
    _xr_blk_bounce = _xr_align64(bnc_raw)

    # Wait for the medium to report ready (TEST UNIT READY + REQUEST SENSE
    # loop) before READ CAPACITY. Real sticks NAK the data stage of the first
    # command(s) after SET_CONFIGURATION until they finish initializing — the
    # exact metal #18/#20 signature (cbw_cc=1, IN-EP Running, zero IN events).
    # QEMU is always-ready so this returns immediately in the VM. Best-effort:
    # even if it never reports ready we still attempt READ CAPACITY (the device
    # may simply not implement TUR), so this cannot regress the green VM path.
    _xr_blk_wait_ready()

    # Geometry from READ CAPACITY(10).
    rc_cap: int32 = _xr_blk_read_capacity()
    _xr_dbg_readcap_rc = rc_cap
    if rc_cap != 0:
        printk0("[xhci-real] blk: READ CAPACITY failed; not registering sd0\n")
        _xr_dbg_reg_rc = -1
        return -1
    if _xr_blk_capacity_sectors == 0:
        printk0("[xhci-real] blk: zero capacity; not registering sd0\n")
        _xr_dbg_reg_rc = -1
        return -1

    _xr_blk_ops.read_sectors = xhci_real_read_sectors
    # Read-only block device: no write_sectors. The block layer's
    # blk_write_sectors checks for a null op and reports read-only.
    _xr_blk_ops.write_sectors = cast[Fn[int32, uint64, uint64, uint64, Ptr[uint8]]](0)
    # Mark ready BEFORE register_blockdev so the partition-scan reads
    # (issued from inside blk_scan_partitions) are served.
    _xr_blk_ready = 1
    rc: int32 = register_blockdev("sd0", _xr_blk_capacity_sectors,
                                  &_xr_blk_ops, 0)
    if rc < 0:
        printk0("[xhci-real] blk: register_blockdev(sd0) failed\n")
        _xr_blk_ready = 0
        _xr_dbg_reg_rc = -1
        return -1
    printk1("[xhci-real] blk: /dev/blk/sd0 registered (%d sectors) backed by xhci_hcd.ko BOT\n",
            _xr_blk_capacity_sectors)
    # Self-verify the block-device op on an arbitrary LBA by reading
    # sector 0 THROUGH the registered read_sectors path (the exact op the
    # block/partition/ext4/VFS layers call). This both confirms the op
    # serves real reads AND emits the stage10 markers the enum regression
    # test asserts — WITHOUT a redundant second controller bring-up demo.
    # The capacity markers (stage10a) come from the READ CAPACITY above;
    # the sector markers (stage10/stage10b) come from this LBA0 read. The
    # data lands in the persistent bounce buffer, so the test's trace
    # cross-check (512-byte bulk-IN TR_NORMAL into our sector buffer)
    # matches _xr_blk_bounce.
    printk2("[xhci-real] stage10 BOT bufs: cbw=%p sector=%p\n",
            _xr_blk_cbw, _xr_blk_bounce)
    printk2("[xhci-real] PASS stage10a: READ CAPACITY(10) over .ko bulk rings — last-LBA=%d block-size=%d\n",
            _xr_blk_last_lba, cast[uint64](_xr_blk_block_size))
    printk0("[xhci-real] PASS stage10a: READ CAPACITY(10) over .ko bulk rings\n")
    lba0_raw: uint64 = kzalloc(1024)
    if lba0_raw != 0:
        lba0: uint64 = _xr_align64(lba0_raw)
        vrc: int32 = xhci_real_read_sectors(0, 0, 1, cast[Ptr[uint8]](lba0))
        if vrc == 0:
            sb: Ptr[uint8] = cast[Ptr[uint8]](lba0)
            printk2("[xhci-real] stage10 sector0 first bytes: [0]=%p [1]=%p\n",
                    cast[uint64](sb[0]), cast[uint64](sb[1]))
            printk2("[xhci-real] stage10 sector0 sig bytes: [510]=%p [511]=%p\n",
                    cast[uint64](sb[510]), cast[uint64](sb[511]))
            printk0("[xhci-real] PASS stage10: READ(10) of LBA0 over .ko bulk rings returned 512 sector bytes through the Linux xhci_hcd.ko BOT path\n")
            if cast[uint32](sb[510]) == 0x55 and cast[uint32](sb[511]) == 0xAA:
                printk0("[xhci-real] PASS stage10b: sector-0 carries the 0x55AA MBR boot signature (real disk data DMA'd back through OUR bulk-IN ring)\n")
        else:
            printk0("[xhci-real] blk: LBA0 self-verify read FAILED\n")
    # Partition scan + per-partition block devices (sd0pN) so the ext4
    # root-magic scan can find the rootfs partition — load-bearing for
    # root-on-USB exactly as native storage.ad documents.
    blk_scan_partitions(rc)
    blk_register_partitions(rc, "sd0")
    printk0("[xhci-real] blk: partitions scanned + registered (sd0pN)\n")
    _xr_dbg_reg_rc = 0
    return 0


def xhci_real_blk_diag_report():
    # Latched .ko-block bring-up state, reprinted in the final boot frame
    # next to the native xhci_bulk_diag_report() — the prints inside
    # _xr_register_block_device/_xr_bot_xfer scroll off before a real-HW
    # crash/halt frame can be photographed. bot_phase: 0=CBW(OUT)
    # 1=DATA(IN) 2=CSW(IN); bot_cc: -1=no transfer event posted, >=0 xHCI
    # completion code (1=Success 4=USB-Txn-Err 5=TRB-Err 6=Stall).
    printk2("[xhci-real-diag] reg_reached=%d reg_rc=%d\n",
            cast[uint64](cast[uint32](_xr_dbg_reg_reached)),
            cast[uint64](cast[uint32](_xr_dbg_reg_rc)))
    printk2("[xhci-real-diag] readcap_rc=%d blk_ready=%d\n",
            cast[uint64](cast[uint32](_xr_dbg_readcap_rc)),
            cast[uint64](_xr_blk_ready))
    printk2("[xhci-real-diag] bot_phase=%d bot_cc=%d (phase 0=CBW 1=DATA 2=CSW; cc -1=no-event >=0 xHCI-cc)\n",
            cast[uint64](cast[uint32](_xr_dbg_bot_phase)),
            cast[uint64](cast[uint32](_xr_dbg_bot_cc)))
    printk2("[xhci-real-diag] bot_rounds=%d csw_status=%d\n",
            cast[uint64](_xr_dbg_bot_rounds),
            cast[uint64](cast[uint32](_xr_dbg_csw_status)))
    # DATA-IN-stall pinpoint (only meaningful when di_filled=1, i.e. the
    # bulk-IN data transfer won no event). epstate: 0=Dis 1=Run 2=Halt
    # 3=Stop 4=Err. A Halt => device STALLed the IN ep; Run with no event
    # => controller never executed the IN TRB; a populated ev0 ref ==
    # want => an event WAS posted but our cursor/cycle missed it.
    printk2("[xhci-real-diag] di_filled=%d di_epstate=%d\n",
            cast[uint64](cast[uint32](_xr_dbg_di_filled)),
            cast[uint64](cast[uint32](_xr_dbg_di_epstate)))
    printk2("[xhci-real-diag] di_usbsts=%p di_portsc=%p\n",
            cast[uint64](_xr_dbg_di_usbsts),
            cast[uint64](_xr_dbg_di_portsc))
    printk2("[xhci-real-diag] di_in_enq=%p di_in_cyc=%d\n",
            _xr_dbg_di_in_enq, cast[uint64](_xr_dbg_di_in_cyc))
    printk2("[xhci-real-diag] di_want=%p di_ep_deq=%p\n",
            _xr_dbg_di_want, _xr_dbg_di_ep_deq)
    printk2("[xhci-real-diag] di_evcur=%p di_evcyc=%d\n",
            _xr_dbg_di_evcur, cast[uint64](_xr_dbg_di_evcyc))
    printk2("[xhci-real-diag] di_ev0_pkt=%p di_ev0_ref=%p (pkt t<<12|cc<<4|cyc)\n",
            cast[uint64](_xr_dbg_di_ev0_pkt), _xr_dbg_di_ev0_ref)
    # cbw_cc=1 => CBW delivered OK (so a Running IN-ep with no data means the
    # device NAKs forever / deeper SS issue); cbw_cc>1 => the CBW itself was
    # rejected (we proceeded anyway), so the device never got the command.
    # cur_ref==di_want => the DATA transfer event IS on the ring, unmatched.
    printk2("[xhci-real-diag] cbw_cc=%d di_cur_pkt=%p\n",
            cast[uint64](cast[uint32](_xr_dbg_cbw_cc)),
            cast[uint64](_xr_dbg_di_cur_pkt))
    printk1("[xhci-real-diag] di_cur_ref=%p\n", _xr_dbg_di_cur_ref)
    # TEST-UNIT-READY ready-poll outcome + the SuperSpeed EP geometry. If the
    # ready-poll fixed it, reg_rc/readcap_rc above go 0. If it still stalls:
    # tur_botrc=0 + tur_csw=0 means the device DID report ready yet READ
    # CAPACITY still got no data (deeper SS-IN issue, not medium-not-ready);
    # tur_botrc=-1 + tur_csw=-1 means even the TUR CSW won no event (blanket
    # bulk-IN NAK, the wedge moved one phase earlier); tur_csw=1 means it kept
    # answering NOT-READY for all 32 tries (sense_key tells which). in_mps MUST
    # be 1024 (0x400) for SS bulk; in_ctxd1 is the dword1 the controller holds.
    printk2("[xhci-real-diag] tur_tries=%d tur_botrc=%d\n",
            cast[uint64](cast[uint32](_xr_dbg_tur_tries)),
            cast[uint64](cast[uint32](_xr_dbg_tur_botrc)))
    printk2("[xhci-real-diag] tur_csw=%d sense_key=%d\n",
            cast[uint64](cast[uint32](_xr_dbg_tur_csw)),
            cast[uint64](cast[uint32](_xr_dbg_sense_key)))
    printk2("[xhci-real-diag] di_in_mps=%d di_in_burst=%d\n",
            cast[uint64](_xr_dbg_di_in_mps),
            cast[uint64](_xr_dbg_di_in_burst))
    printk2("[xhci-real-diag] di_out_mps=%d di_in_ctxd1=%p\n",
            cast[uint64](_xr_dbg_di_out_mps),
            cast[uint64](_xr_dbg_di_in_ctxd1))
    # .ko-transfer path (default ON, _xr_use_ko_transfers): the BOT phases
    # now run through xhci_hcd.ko's xhci_urb_enqueue. urbq_rc=0 => the .ko
    # accepted+queued the urb; data_in_cc is the DATA-IN transfer-event
    # completion code reaped on OUR event ring (1=Success 4=Txn-Err 6=Stall;
    # -2=never attempted, -1=no event). setup_rc=0 => virt_dev fabricated +
    # installed into xhci->devs[slot] OK.
    if _xr_use_ko_transfers == 0:
        printk0("[xhci-real-diag] ko-xfer DISABLED (hand-rolled path active)\n")
    else:
        printk2("[xhci-real-diag] ko urb_enqueue=%p virt_dev=%p\n",
                _xr_dbg_urbq_addr, _xr_dbg_virtdev)
        printk2("[xhci-real-diag] ko setup_rc=%d urbq_rc=%d\n",
                cast[uint64](cast[uint32](_xr_dbg_ko_setup_rc)),
                cast[uint64](cast[uint32](_xr_dbg_urbq_rc)))
        printk2("[xhci-real-diag] ko data_in_cc=%d last_dir_in=%d\n",
                cast[uint64](cast[uint32](_xr_dbg_data_cc)),
                cast[uint64](cast[uint32](_xr_dbg_last_dir_in)))
        # primary/shared hcd resolution + the three xhci_check_args gates.
        # prim_hcd=0 => _xr_hcd was already primary; nonzero => we followed it.
        printk2("[xhci-real-diag] ko prim_hcd=%p eff_hcd=%p\n",
                _xr_dbg_prim_hcd, _xr_dbg_eff_hcd)
        printk2("[xhci-real-diag] ko devs[slot]=%p vdev->udev=%p\n",
                _xr_dbg_devs_slotv, _xr_dbg_vdev_udev)
        printk1("[xhci-real-diag] ko udev->parent=%p\n",
                _xr_dbg_udev_parent)


def xhci_real_block_ready() -> int32:
    # 1 once sd0 is registered + serving reads through the .ko path.
    return _xr_blk_ready


def xhci_real_root_init() -> int32:
    # Root-on-USB entry point for the .ko path. Drives the full bring-up
    # (stage1..stage9) and registers /dev/blk/sd0. Called from
    # init/main.ad's root-on-USB section BEFORE mount_rootfs_partition()
    # so the ext4-magic scan sees the .ko-backed sd0 like any other
    # block device. Returns 0 once sd0 is live, -1 otherwise. Non-fatal
    # to boot — a box with no USB MSC device just logs the absence.
    printk0("[xhci-real] === root-on-USB bring-up via Linux xhci_hcd.ko (native disabled) ===\n")
    if _xr_blk_ready != 0:
        printk0("[xhci-real] root: sd0 already live\n")
        return 0
    s1: int32 = xhci_real_stage1_init_driver()
    if s1 != 0:
        printk0("[xhci-real] root: stage1 (xhci_init_driver) failed\n")
        return -1
    # stage2 finds the controller, enables bus-master, reads cap regs,
    # then (mmio marker forced ON below) drives gen_setup..stage9 which
    # ends by registering sd0. We force the deep path on for the root
    # bring-up regardless of the -mmio marker: the block device IS the
    # deliverable here.
    s2: int32 = _xr_root_stage2_to_block()
    if s2 != 0:
        printk0("[xhci-real] root: controller/enumeration bring-up failed\n")
        return -1
    if _xr_blk_ready == 0:
        printk0("[xhci-real] root: bring-up completed but sd0 not registered\n")
        return -1
    printk0("[xhci-real] root: sd0 live — root FS will read through xhci_hcd.ko\n")
    return 0


def _xr_root_stage2_to_block() -> int32:
    # Like xhci_real_stage2_mmio() but ALWAYS advances into the deep
    # gen_setup..stage9 path (which registers sd0), independent of the
    # ENABLE_XHCI_KO_REAL_MMIO test marker. Used by the root-on-USB
    # bring-up where the live block device is the whole point.
    bdf: uint32 = _xr_find_xhci_controller()
    if bdf == 0xFFFFFFFF:
        printk0("[xhci-real] root: no xHCI controller on bus 0\n")
        return -1
    _xr_enable_bus_master(bdf)
    bar0: uint64 = _xr_bar0(bdf)
    if bar0 == 0:
        printk0("[xhci-real] root: BAR0 == 0\n")
        return -1
    cap0: uint32 = _xr_r32(bar0 + 0x00)
    caplength: uint32 = cap0 & 0xFF
    hciversion: uint32 = (cap0 >> 16) & 0xFFFF
    if caplength < 0x20 or caplength > 0x80:
        printk0("[xhci-real] root: CAPLENGTH implausible — BAR not mapped\n")
        return -1
    # Emit the stage2 cap-register markers the bring-up path shares with
    # the EXERCISE self-test. When the root bring-up runs first it owns the
    # live controller and the EXERCISE is skipped, so these markers must
    # come from HERE for the cap-register read to be observable.
    printk2("[xhci-real] stage2 CAPLENGTH=%x HCIVERSION=%x\n",
            cast[uint64](caplength), cast[uint64](hciversion))
    printk0("[xhci-real] PASS stage2: controller cap-registers read through Linux-driver BAR convention\n")
    printk1("[xhci-real] root: controller BAR0=%p reachable, driving .ko gen_setup\n", bar0)
    return _xr_stage3_gen_setup(bar0)


def xhci_real_exercise():
    # Entry point invoked from init/main.ad when /etc/xhci-ko-real is
    # present. Runs stage1 (safe) then stage2 (cap-register read).
    #
    # If the early root-on-USB bring-up already registered sd0
    # (xhci_real_root_init ran at the rootfs section), the controller is
    # LIVE and serving block reads — do NOT re-run the bring-up here, it
    # would re-halt/re-reset the controller (gen_setup) and tear down the
    # live root device. Just report and return.
    if _xr_blk_ready != 0:
        printk0("[xhci-real] EXERCISE: sd0 already live from root bring-up; not re-running (controller stays up)\n")
        return
    printk0("[xhci-real] === real Linux .ko xHCI bring-up (native disabled) ===\n")
    s1: int32 = xhci_real_stage1_init_driver()
    if s1 != 0:
        printk0("[xhci-real] EXERCISE: stage1 failed; not advancing to MMIO\n")
        return
    s2: int32 = xhci_real_stage2_mmio()
    if s2 != 0:
        printk0("[xhci-real] EXERCISE: stage2 (controller MMIO) failed\n")
        return
    printk0("[xhci-real] EXERCISE complete (furthest safe milestone reached)\n")


def linux_abi_register_xhci_real():
    # No new EXPORT names — this module is driven from init/main.ad, not
    # referenced by the .ko UND surface. Registration hook kept for
    # symmetry / future shimmed primitives.
    return

# linux_abi/api_hrtimer.ad
#
# L10: Linux hrtimer + ktime ABI shims. These are the export-table
# entrypoints a loaded Linux .ko calls (hrtimer_init / hrtimer_start_
# range_ns / hrtimer_cancel / hrtimer_forward / ktime_get).
#
# REWRITTEN (kernel/time/ hrtimer subsystem): this file used to carry its
# OWN jiffies-quantized 16-slot wheel with 10 ms resolution. It now
# delegates to the real ns-resolution, clockevent-backed hrtimer
# subsystem in kernel/time/hrtimer.ad. A Linux `struct hrtimer *` is
# keyed to a kernel hrtimer slot via a small association table; the
# callback the module writes into t->function is invoked with the struct
# pointer (Linux's `enum hrtimer_restart (*)(struct hrtimer *)`), so .ko
# code sees the exact ABI it expects while the deadline is now honoured at
# nanosecond resolution against the TSC clocksource.
#
# Linux signatures (include/linux/hrtimer.h, kernel/time/hrtimer.c):
#   void hrtimer_init(struct hrtimer *t, clockid_t which_clock,
#                     enum hrtimer_mode mode);
#   int  hrtimer_start_range_ns(struct hrtimer *t, ktime_t tim,
#                               u64 delta_ns, const enum hrtimer_mode mode);
#   int  hrtimer_cancel(struct hrtimer *t);
#   u64  hrtimer_forward(struct hrtimer *t, ktime_t now, ktime_t interval);
#   ktime_t ktime_get(void);
#
# Struct hrtimer in Linux 6.12 starts with a struct timerqueue_node (16
# bytes); `function` lands at byte 24 in the 6.12-default config. Module
# code writes t->function directly between hrtimer_init() and the first
# start (canonical kernel/sched/core.c::__hrtick_start pattern), so we
# read it from the struct in hrtimer_start_range_ns.

from linux_abi.exports import _add_export
from kernel.time.hrtimer import (
    hrtimer_create, hrtimer_start_abs, hrtimer_cancel,
    hrtimer_forward, hrtimer_get_time,
    hrtimer_set_data, HRTIMER_NORESTART,
)

# struct hrtimer `function` field offset (Linux 6.12 default config).
LABI_HRTIMER_FUNCTION_OFFSET: uint64 = 24

# Association table: maps a Linux `struct hrtimer *` to a kernel hrtimer
# slot id. Bounded; a .ko at our scale arms a handful of hrtimers.
LABI_MAX_HRTIMERS: uint64 = 64
labi_ht_ptr:  Array[64, uint64]   # struct hrtimer *  (0 = free)
labi_ht_slot: Array[64, int64]    # kernel hrtimer slot id


def _labi_find(timer_ptr: uint64) -> int64:
    i: uint64 = 0
    while i < LABI_MAX_HRTIMERS:
        if labi_ht_ptr[i] == timer_ptr:
            return cast[int64](i)
        i = i + 1
    return -1


def _labi_alloc(timer_ptr: uint64) -> int64:
    found: int64 = _labi_find(timer_ptr)
    if found >= 0:
        return found
    i: uint64 = 0
    while i < LABI_MAX_HRTIMERS:
        if labi_ht_ptr[i] == 0:
            labi_ht_ptr[i]  = timer_ptr
            labi_ht_slot[i] = -1
            return cast[int64](i)
        i = i + 1
    return -1


# The kernel hrtimer callback we register is a single trampoline keyed on
# the cookie (= the Linux struct-hrtimer pointer). It looks up the .ko's
# t->function and calls it with the struct pointer, preserving the Linux
# ABI. The .ko's return value (RESTART/NORESTART) is propagated so a
# periodic .ko hrtimer re-arms exactly as on Linux.
def _labi_hrtimer_trampoline(cookie: uint64) -> int64:
    timer_ptr: uint64 = cookie
    fn_slot: Ptr[uint64] = cast[Ptr[uint64]](
        timer_ptr + LABI_HRTIMER_FUNCTION_OFFSET)
    fn: uint64 = fn_slot[0]
    if fn == 0:
        return HRTIMER_NORESTART
    call_fn: Fn[int64, uint64] = cast[Fn[int64, uint64]](fn)
    return call_fn(timer_ptr)


# --- L10 shims -------------------------------------------------------

def _l_hrtimer_init(timer_ptr: uint64, which_clock: uint64, mode: uint64):
    # hrtimer_init(t, clockid, mode). We serve a single monotonic clock
    # (the clocksource ns counter), so clockid is dropped; mode (ABS/REL)
    # is handled at start time. Allocate the association + a kernel
    # hrtimer whose callback is the trampoline and whose cookie is the
    # struct pointer.
    if timer_ptr == 0:
        return
    a: int64 = _labi_alloc(timer_ptr)
    if a < 0:
        return
    ai: uint64 = cast[uint64](a)
    if labi_ht_slot[ai] < 0:
        slot: int64 = hrtimer_create(
            cast[uint64](&_labi_hrtimer_trampoline), timer_ptr)
        labi_ht_slot[ai] = slot


def _l_hrtimer_start_range_ns(timer_ptr: uint64, tim: uint64,
                              delta_ns: uint64, mode: uint64) -> int32:
    # hrtimer_start_range_ns(t, tim, delta_ns, mode). `tim` is the target
    # time; we treat it as an absolute monotonic-ns deadline (the
    # canonical caller pattern is ktime_get()+delta, already absolute) and
    # ignore the slack delta_ns (we fire at `tim`). Returns 0 on success.
    if timer_ptr == 0:
        return 0
    a: int64 = _labi_find(timer_ptr)
    if a < 0:
        _l_hrtimer_init(timer_ptr, 0, mode)
        a = _labi_find(timer_ptr)
        if a < 0:
            return 0
    ai: uint64 = cast[uint64](a)
    slot: int64 = labi_ht_slot[ai]
    if slot < 0:
        return 0
    # Refresh the cookie (struct addr stable) + arm at the absolute ns.
    hrtimer_set_data(cast[uint64](slot), timer_ptr)
    hrtimer_start_abs(cast[uint64](slot), tim)
    return 0


def _l_hrtimer_cancel(timer_ptr: uint64) -> int32:
    # hrtimer_cancel(t). Returns 1 if active at call time, else 0.
    if timer_ptr == 0:
        return 0
    a: int64 = _labi_find(timer_ptr)
    if a < 0:
        return 0
    slot: int64 = labi_ht_slot[cast[uint64](a)]
    if slot < 0:
        return 0
    return hrtimer_cancel(cast[uint64](slot))


def _l_hrtimer_forward(timer_ptr: uint64, now: uint64,
                       interval: uint64) -> uint64:
    # hrtimer_forward(t, now, interval): advance expiry to the next
    # interval boundary at/after now; return intervals skipped.
    if timer_ptr == 0 or interval == 0:
        return 0
    a: int64 = _labi_find(timer_ptr)
    if a < 0:
        return 0
    slot: int64 = labi_ht_slot[cast[uint64](a)]
    if slot < 0:
        return 0
    return hrtimer_forward(cast[uint64](slot), now, interval)


def _l_ktime_get() -> uint64:
    # ktime_get(): monotonic nanoseconds since boot, now read from the
    # TSC-backed clocksource (ns resolution) rather than jiffies*1e7.
    return hrtimer_get_time()


# --- Export-table registration --------------------------------------

def linux_abi_register_hrtimer():
    _add_export("hrtimer_init", cast[uint64](&_l_hrtimer_init))
    _add_export("hrtimer_start_range_ns",
                cast[uint64](&_l_hrtimer_start_range_ns))
    _add_export("hrtimer_cancel", cast[uint64](&_l_hrtimer_cancel))
    _add_export("hrtimer_forward", cast[uint64](&_l_hrtimer_forward))
    _add_export("ktime_get", cast[uint64](&_l_ktime_get))

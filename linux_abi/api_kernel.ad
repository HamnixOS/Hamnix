# linux_abi/api_kernel.ad — L39 kernel-image / per-CPU scaffolding.
#
# Slightly bigger stock distro modules (crc_t10dif_generic, crc32_generic,
# simple netfilter helpers, ...) commonly drag in a handful of "deep
# kernel" symbols that aren't tied to any one subsystem — the per-CPU
# topology globals, the kernel image's section-boundary linker symbols,
# the boot CPU's cpuinfo, init_task, module_param's ops tables, and the
# system_state enum. None of these are *call*-style exports (no shim
# function body); every entry below is a DATA symbol whose ADDRESS the
# loader patches into module relocations.
#
# Strategy: stand up each as a small zero-filled buffer (or a few
# pre-populated words where the module's code path actually reads a
# field), park the address in the export table under the stock Linux
# name, and let later L-track milestones supply real implementations.
# When a module reaches in past the scaffolding (e.g. dereferences a
# function pointer inside param_ops_int), it'll trap on the NULL store
# — which is the desired "you've outgrown the scaffolding, time to
# build the real one" signal.
#
# ---------------------------------------------------------------------
# Symbol-by-symbol notes:
#
# cpu_online_mask — `struct cpumask` (a bitmap). On Linux this is a
#   declared variable of type cpumask_var_t whose address modules take
#   directly. NR_CPUS is a CONFIG knob; the typical distro value is
#   NR_CPUS=512, giving sizeof(cpumask)=512/8=64 bytes. Hamnix has 2
#   logical CPUs at L39 so the first byte is 0x03 (bits 0+1 set) and
#   the remaining 63 bytes are 0. We materialise that as 8 uint64
#   words: word0=0x3, word1..7=0.
#
# __per_cpu_offset — `unsigned long __per_cpu_offset[NR_CPUS]`. Maps a
#   CPU index to the byte offset of its per-CPU section relative to
#   the .data..percpu master copy. Hamnix doesn't yet duplicate per-
#   CPU sections, so both entries are 0 (offset 0 = "use the master
#   copy in place"). Modules using `per_cpu_ptr(p, cpu)` compute
#   `p + __per_cpu_offset[cpu]`, which with offset=0 reads the master
#   directly — semantically correct for a single shared copy.
#
# boot_cpu_data — `struct cpuinfo_x86`. Tracks CPU vendor, family,
#   stepping, microcode rev, capability bitmap, cache topology, ...
#   A real cpuinfo_x86 is ~700 bytes; for L39 we expose 64 zero bytes.
#   Modules that scan x86_capability[] will see "no features"; those
#   that gate on a specific bit will take the "feature missing" path,
#   which is generally safe (they fall back to software). When a
#   module starts hard-erroring on, say, X86_FEATURE_XMM (always-on
#   on x86_64), we'll flesh the buffer out.
#
# _etext / _sdata / _edata / _end — linker-emitted section-boundary
#   symbols. A real kernel places them via the vmlinux.lds.S script:
#     _etext at the end of the .text section
#     _sdata at the start of the .data section
#     _edata at the end of the .data section
#     _end   at the end of .bss (top of the kernel image)
#   Modules use them for "is this pointer inside the kernel image?"
#   sanity checks (e.g. is_kernel_text(addr) ≈ addr < _etext). For
#   L39 we hand out fixed plausible addresses that satisfy the
#   ordering invariant _etext < _sdata < _edata < _end without
#   matching the actual section layout. Hamnix's real kernel image
#   currently lives entirely below 0x300000, so a module checking
#   `addr < _etext = 0x300000` will correctly classify any kernel
#   address as "in-kernel-text" — close enough for the sanity-check
#   call sites that consume these.
#
# init_task — `struct task_struct` for PID 0 (the boot CPU's idle
#   task and root of the task list). Real struct task_struct is
#   massive (~9 KiB on a recent x86_64 build). Modules that grab
#   &init_task typically use it as a list head (init_task.tasks is
#   the head of the global task list) or as a sentinel ("compare
#   to init_task to detect 'this is the idle task'"). At L39 a
#   4 KiB zero buffer is enough for "address-comparison" callers;
#   anyone walking the .tasks list will see an empty list (the
#   list_head pointers are zero, which our list helpers treat as
#   "uninitialised" and refuse to traverse).
#
# param_ops_int / param_ops_charp / param_ops_bool — `struct
#   kernel_param_ops` for the three commonest module_param() types.
#   Each ops table is a small vtable:
#     struct kernel_param_ops {
#         unsigned int flags;
#         int  (*set)(const char *val, const struct kernel_param *kp);
#         int  (*get)(char *buffer, const struct kernel_param *kp);
#         void (*free)(void *arg);
#     };
#   Modules reference these by ADDRESS in their __param section; the
#   module-load path *would* call ->set during param parsing, but
#   the L39 loader doesn't yet parse module_param= arguments, so the
#   function pointers stay NULL. If a module does invoke them, the
#   call traps on the NULL load — loudly visible. 64-byte zero
#   buffers cover the struct's ~24-byte real footprint with slack.
#
# system_state — `enum system_states` lowered to int. Values are:
#     SYSTEM_BOOTING       = 0
#     SYSTEM_SCHEDULING    = 1   (newer kernels)
#     SYSTEM_FREEING_INITMEM = 2
#     SYSTEM_RUNNING       = 3   (old) or 1 (some configs)
#     SYSTEM_HALT, SYSTEM_POWER_OFF, SYSTEM_RESTART, ...
#   The user-visible meaning for module code is just "is the kernel
#   past early boot?" — most callers compare `system_state >=
#   SYSTEM_RUNNING` to gate work-deferral / wq enqueue / etc. We
#   pin the value to 1 per the L39 spec; any module that reaches
#   for the exact enum value will see "running enough" and proceed.

from linux_abi.exports import _add_export


# =====================================================================
# Per-CPU topology globals
# =====================================================================
#
# cpu_online_mask: 8 × uint64 = 64 bytes, mirroring NR_CPUS=512/8=64.
# We model it as 8 individual uint64 words rather than an Array[8,uint64]
# so we can set the first word to 0x3 at static-init time without
# relying on per-element array initializers. Layout in memory matches:
# the 8 words are contiguous in .bss/.data, and the export takes the
# address of word0. Hamnix has 2 online CPUs (BSP + 1 AP), giving the
# low byte 0b00000011 → 0x03.
#
# IMPORTANT: the 8 words must be declared in source order; the .bss
# layout follows declaration order, and the exported address (&word0)
# expects words 1..7 to follow contiguously.

cpu_online_mask_w0: uint64 = 0x3
cpu_online_mask_w1: uint64 = 0
cpu_online_mask_w2: uint64 = 0
cpu_online_mask_w3: uint64 = 0
cpu_online_mask_w4: uint64 = 0
cpu_online_mask_w5: uint64 = 0
cpu_online_mask_w6: uint64 = 0
cpu_online_mask_w7: uint64 = 0


# __per_cpu_offset[NR_CPUS]. For 2 CPUs both are 0 — Hamnix doesn't
# duplicate the per-CPU section, so the offset between "master copy"
# and "this CPU's copy" is zero.
per_cpu_offset_buf: Array[2, uint64]


# =====================================================================
# boot_cpu_data — struct cpuinfo_x86 placeholder.
# =====================================================================
#
# 64 zero bytes. Real cpuinfo_x86 carries vendor/family/model/stepping,
# x86_capability[NCAPINTS]=20 ints of feature bits, cache descriptors,
# topology IDs, ... For L39 we expose the address only; field reads
# return 0 (no features advertised), which forces consumers down the
# software-fallback path — exactly what scaffolding should do.

boot_cpu_data_buf: Array[64, uint8]


# =====================================================================
# Kernel-image section boundaries.
# =====================================================================
#
# Linker-emitted symbols in a real kernel. We don't actually have a
# vmlinux.lds.S that names these (Hamnix's linker layout differs from
# Linux's), so we hand out fixed addresses that satisfy the ordering
# invariant. Modules that use them for `is_kernel_text(p) = p < _etext`
# will correctly classify Hamnix kernel addresses (all below 0x300000
# at L39) as in-text.
#
# These are exported as addresses *directly* — _add_export takes a
# uint64 address, and the loader patches that into the relocation
# slot. No backing storage needed; the module never dereferences the
# symbol itself, only takes its address for the comparison.

ETEXT_ADDR: uint64 = 0x300000
SDATA_ADDR: uint64 = 0x400000
EDATA_ADDR: uint64 = 0x500000
END_ADDR:   uint64 = 0x600000


# =====================================================================
# init_task — pid 0 task_struct placeholder (4 KiB zero buffer).
# =====================================================================
#
# Modules typically use &init_task as either a list-head sentinel (the
# task list root) or an identity check (current == &init_task → idle).
# Both work on a zero buffer: the list_head pointers being NULL means
# any list walker terminates on the first iteration, and the address
# comparison is purely pointer equality. Deeper field access (e.g.
# init_task.signal->rlim[RLIMIT_NOFILE].rlim_max) would deref through
# a NULL pointer and trap — which is the L39 boundary marker.

init_task_buf: Array[4096, uint8]


# =====================================================================
# module_param() ops tables — param_ops_{int,charp,bool}.
# =====================================================================
#
# 64-byte zero buffers each. struct kernel_param_ops is ~24 bytes on
# x86_64 (uint flags + 3 × 8-byte fn ptrs); 64 bytes leaves room for
# any future flags/fields a newer kernel might add without changing
# the exported address. The set/get/free pointers being NULL means a
# real module_param parse would NULL-deref, but the L39 loader doesn't
# parse module_param= arguments yet — modules see their default values.

param_ops_int_buf:   Array[64, uint8]
param_ops_charp_buf: Array[64, uint8]
param_ops_bool_buf:  Array[64, uint8]


# =====================================================================
# system_state — enum system_states (int), pinned to SYSTEM_RUNNING.
# =====================================================================
#
# Declared as a uint64 even though enum system_states is `int` (4 bytes)
# — the export hands out an address, and an aligned 8-byte slot with
# the low 32 bits set to 1 reads as `int = 1` on little-endian x86_64.
# Modules taking the address as `int *` will see 1; modules reading it
# as `unsigned long *` (rare but possible in eBPF-ish contexts) will
# see 1 too. Using uint64 sidesteps any 4-byte-vs-8-byte alignment
# surprises in the global data section.

system_state_var: uint64 = 1            # SYSTEM_RUNNING


# =====================================================================
# Registration.
# =====================================================================

def linux_abi_register_kernel():
    # All entries are DATA symbols — the exported value is the address
    # of the underlying buffer/variable. The per_cpu_offset and the
    # various Array buffers default-initialise to zero (.bss), so no
    # explicit setup is needed beyond wiring the export-table rows.

    # cpu_online_mask: address of word0 (the rest follow contiguously).
    _add_export("cpu_online_mask",
                cast[uint64](&cpu_online_mask_w0))

    # __per_cpu_offset: address of the 2-element u64 array.
    _add_export("__per_cpu_offset",
                cast[uint64](&per_cpu_offset_buf[0]))

    # boot_cpu_data: address of the 64-byte zero buffer.
    _add_export("boot_cpu_data",
                cast[uint64](&boot_cpu_data_buf[0]))

    # Kernel-image boundary symbols: exported as immediate addresses.
    # The loader patches the literal value into the module's relocation
    # slot — no backing storage in our .data is involved.
    _add_export("_etext", ETEXT_ADDR)
    _add_export("_sdata", SDATA_ADDR)
    _add_export("_edata", EDATA_ADDR)
    _add_export("_end",   END_ADDR)

    # init_task: address of the 4 KiB zero buffer.
    _add_export("init_task",
                cast[uint64](&init_task_buf[0]))

    # module_param ops vtables (set/get/free are NULL — see file header).
    _add_export("param_ops_int",
                cast[uint64](&param_ops_int_buf[0]))
    _add_export("param_ops_charp",
                cast[uint64](&param_ops_charp_buf[0]))
    _add_export("param_ops_bool",
                cast[uint64](&param_ops_bool_buf[0]))

    # system_state: address of the int holding SYSTEM_RUNNING.
    _add_export("system_state",
                cast[uint64](&system_state_var))

# =====================================================================
# Group 2: radix_tree (insert / lookup / delete / maybe_preload)
# =====================================================================
#
# xhci uses radix_tree as a sparse-array map from endpoint ring DMA
# addresses to xhci_ring pointers. None exercised at insmod.

def _l_radix_tree_insert(root: uint64, index: uint64,
                           item: uint64) -> int32:
    # -ENOMEM == -12 for init-cold path.
    return -12


def _l_radix_tree_lookup(root: uint64, index: uint64) -> uint64:
    return 0



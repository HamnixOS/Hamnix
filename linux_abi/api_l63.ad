_l63_platform_device_buf:    Array[256, uint8]


def _l_platform_device_alloc(name: uint64, pid: int32) -> uint64:
    # Return zero-init buffer; init-cold callers only assign to the
    # struct's resource / dev.parent / id fields.
    return cast[uint64](&_l63_platform_device_buf[0])



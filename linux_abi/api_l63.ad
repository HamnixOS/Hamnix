def _l___devm_add_action(dev: uint64, action: uint64, data: uint64,
                          name: uint64) -> int32:
    # 0 == success. Action queued for device-remove time.
    return 0


def _l_dmi_get_system_info(fld: int32) -> uint64:
    # Adder reserves `field` -> renamed to `fld`.
    # NULL == no DMI table; xhci's quirk matchers skip the quirk.
    return 0


def _l_iommu_get_domain_for_dev(dev: uint64) -> uint64:
    # NULL == no IOMMU; xhci falls back to bounce-buffer mode.
    return 0


def _l_kstrtou16_from_user(s: uint64, count: uint64, base: uint32,
                             res: uint64) -> int32:
    if res != 0:
        rp: Ptr[uint16] = cast[Ptr[uint16]](res)
        rp[0] = 0
    return 0


def _l_schedule_timeout_uninterruptible(timeout: int64) -> int64:
    # 0 == timer expired immediately.
    return 0


def _l___SCT__preempt_schedule_notrace():
    # No-op — Hamnix has no preempt scheduler.
    return


def _l_vsnprintf(buf: uint64, size: uint64, fmt: uint64,
                   args: uint64) -> int32:
    # Write NUL terminator and return 0 (zero bytes formatted).
    if size != 0:
        if buf != 0:
            bp: Ptr[uint8] = cast[Ptr[uint8]](buf)
            bp[0] = 0
    return 0


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l63():
    # Called from linux_abi_exports_init() after the L62 batch.
    # Adds 73 new exports for the xhci-hcd.ko batch.

    # ---- Group 1: bpf / trace runtime ----
    _add_export("bpf_trace_run1",
                cast[uint64](&_l_bpf_trace_run1))
    _add_export("bpf_trace_run2",
                cast[uint64](&_l_bpf_trace_run2))
    _add_export("bpf_trace_run3",
                cast[uint64](&_l_bpf_trace_run3))
    _add_export("perf_trace_buf_alloc",
                cast[uint64](&_l_perf_trace_buf_alloc))
    _add_export("perf_trace_run_bpf_submit",
                cast[uint64](&_l_perf_trace_run_bpf_submit))
    _add_export("trace_event_buffer_commit",
                cast[uint64](&_l_trace_event_buffer_commit))
    _add_export("trace_event_buffer_reserve",
                cast[uint64](&_l_trace_event_buffer_reserve))
    _add_export("trace_event_printf",
                cast[uint64](&_l_trace_event_printf))
    _add_export("trace_event_raw_init",
                cast[uint64](&_l_trace_event_raw_init))
    _add_export("trace_event_reg",
                cast[uint64](&_l_trace_event_reg))
    _add_export("trace_handle_return",
                cast[uint64](&_l_trace_handle_return))
    _add_export("trace_print_symbols_seq",
                cast[uint64](&_l_trace_print_symbols_seq))
    _add_export("trace_raw_output_prep",
                cast[uint64](&_l_trace_raw_output_prep))
    _add_export("trace_seq_acquire",
                cast[uint64](&_l_trace_seq_acquire))
    _add_export("__trace_trigger_soft_disabled",
                cast[uint64](&_l___trace_trigger_soft_disabled))

    # ---- Group 2: radix_tree ----
    _add_export("radix_tree_insert",
                cast[uint64](&_l_radix_tree_insert))
    _add_export("radix_tree_lookup",
                cast[uint64](&_l_radix_tree_lookup))
    _add_export("radix_tree_delete",

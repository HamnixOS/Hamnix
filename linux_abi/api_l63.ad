# linux_abi/api_l63.ad
#
# L63: ships xhci-hcd.ko — Linux's USB 3.x host controller driver
# (the kernel module that implements the eXtensible Host Controller
# Interface for USB SuperSpeed and below). xhci-hcd is the workhorse
# behind every modern USB port; it sits just above usbcore on the
# stack and is the natural next module to land after L61's usbcore.
#
# UND analysis (`nm -u` of the Debian 6.12 xhci-hcd.ko):
#   xhci-hcd.ko         156 UND total
#   covered by L<=62    83 (usbcore + usb-common + driver-model +
#                          sysfs + IRQ + DMA + workqueue +
#                          spinlock + completion + timer +
#                          printk + slab + jiffies + ... )
#   missing at L62      73 (this batch)
#
# 73 new exports across 9 groups. xhci-hcd's init_module body
# (xhci_hcd_init) just registers a /proc tracepoint stub and a
# pm_runtime callback table — none of the 73 stubs fire during
# insmod; they back .text relocations for the runtime probe path
# (xhci_gen_setup, xhci_init, xhci_irq, ...). Once the relocations
# resolve and init returns 0, the module is loaded; the HCD probe
# itself only fires when xhci-pci or xhci-plat-hcd binds to a real
# PCIe / platform device — none of which exist in our QEMU env.
#
# Stub philosophy mirrors L51..L62: every shim is init-cold for our
# env (no real USB host, no PCI ECAM walk, no IOMMU, no DMI table).
# Each returns success / 0 / NULL / void / -ENODEV to keep the
# loader on the happy path.
#
# Naming notes:
#   * Adder reserves `bytes`, `match`, `case`, `file`, `field` ->
#     renamed to `nbytes` / `mt` / `cse` / `filp` / `fld`.
#   * The "_l_" prefix marks the Hamnix-side shim; "_l63_" tags
#     DATA backings.
#
# Groups (9):
#   1.  bpf/trace runtime (bpf_trace_run*, perf_trace_*,
#                            trace_event_*, trace_seq_*, __trace_*)
#   2.  radix_tree (insert/lookup/delete/maybe_preload)
#   3.  platform_device (alloc/add/add_resources/put/unregister)
#   4.  usbcore HCD/quirk helpers (usb_hcd_*, usb_amd_*, usb_acpi_*,
#                                    usb_asmedia_*, usb_hub_*,
#                                    usb_disabled, usb_hc_died,
#                                    usb_root_hub_lost_power,
#                                    usb_wakeup_notification,
#                                    usb_disable_xhci_ports)
#   5.  DMA + kmalloc-cache-node (dma_set_mask/_coherent_mask,
#                                    __kmalloc_node_noprof,
#                                    __kmalloc_cache_node_noprof)
#   6.  seq_file / single_open
#   7.  scatterlist partial copy (sg_pcopy_from/to_buffer)
#   8.  DATA exports (__cpu_online_mask, pci_bus_type)
#   9.  Misc (cancel_delayed_work, complete_all, __const_udelay,
#               debugfs_create_regset32,
#               device_create_managed_software_node,
#               __devm_add_action, dmi_get_system_info,
#               iommu_get_domain_for_dev, kstrtou16_from_user,
#               param_ops_ullong, schedule_timeout_uninterruptible,
#               __SCT__preempt_schedule_notrace, vsnprintf)

from linux_abi.exports import _add_export
from kernel.printk.printk import printk0
from mm.slab import kmalloc
from kernel.sched.core import kernel_cond_resched


# =====================================================================
# Group 1: bpf / trace runtime
# =====================================================================
#
# Linux:
#   void bpf_trace_run1(struct bpf_raw_tp_link *, u64 a);
#   void bpf_trace_run2(struct bpf_raw_tp_link *, u64 a, u64 b);
#   void bpf_trace_run3(struct bpf_raw_tp_link *, u64 a, u64 b, u64 c);
#   void *perf_trace_buf_alloc(int size, struct pt_regs **, int *rctxp);
#   void  perf_trace_run_bpf_submit(void *, int, int, u64, struct pt_regs *,
#                                     struct hlist_head *, struct task_struct *);
#   void trace_event_buffer_commit(struct trace_event_buffer *);
#   void *trace_event_buffer_reserve(struct trace_event_buffer *,
#                                       struct trace_event_file *, int len);
#   void trace_event_printf(struct trace_iterator *, const char *fmt, ...);
#   int  trace_event_raw_init(struct trace_event_call *);
#   int  trace_event_reg(struct trace_event_call *, enum trace_reg, void *);
#   int  trace_handle_return(struct trace_seq *);
#   const char *trace_print_symbols_seq(struct trace_seq *, unsigned long val,
#                                          const struct trace_print_flags *);
#   void trace_raw_output_prep(struct trace_iterator *,
#                                struct trace_event *);
#   char *trace_seq_acquire(struct trace_seq *, unsigned int len);
#   int  __trace_trigger_soft_disabled(struct trace_event_file *);
#
# xhci-hcd defines a slew of tracepoint events (xhci-trace.h) so the
# .text emits relocations against all of these. None of them fire at
# init time — they all hang off a static_key that's off until the
# user opens /sys/kernel/debug/tracing/events/xhci/.../enable, which
# we never do. Stubs return 0 / NULL / void.

def _l_bpf_trace_run1(link: uint64, a: uint64):
    return


def _l_bpf_trace_run2(link: uint64, a: uint64, b: uint64):
    return



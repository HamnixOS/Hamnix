# =====================================================================
# Group 8: DATA exports (__cpu_online_mask, pci_bus_type)
# =====================================================================
#
# api_kernel.ad exports "cpu_online_mask" (8 × u64 words). Linux 6.x
# renamed the canonical symbol to `__cpu_online_mask`; some modules
# end up with a UND against the underscored form. We back it with a
# fresh 64-byte zero buffer (also matches NR_CPUS=512/8=64 bytes).
#
# pci_bus_type is a struct bus_type (~200 bytes); xhci-hcd takes its
# address for a PM-code relocation but never dereferences at init.

_l63_pci_bus_type_buf:       Array[256, uint8]
_l63_cpu_online_mask_buf:    Array[64, uint8]


# =====================================================================
# Group 9: Misc (cancel_delayed_work, complete_all, __const_udelay,
#                  debugfs_create_regset32,
#                  device_create_managed_software_node,
#                  __devm_add_action, dmi_get_system_info,
#                  iommu_get_domain_for_dev, kstrtou16_from_user,
#                  param_ops_ullong, schedule_timeout_uninterruptible,
#                  __SCT__preempt_schedule_notrace, vsnprintf)
# =====================================================================
#
# __SCT__ is a Linux "static call trampoline" — a gcc-emitted out-of-
# line indirect-call thunk patched at boot. We no-op (no preempt).
#
# vsnprintf: write a NUL into `buf` if `size>0` and return 0; xhci's
# debug printers are off in our env.

_l63_param_ops_ullong_buf:   Array[64, uint8]


def _l_cancel_delayed_work(dwork: uint64) -> int32:
    # true == "was pending and cancelled"; init-cold returns 0.
    return 0


def _l_complete_all(x: uint64):
    return


# __const_udelay yield-gate counter. Stock modules call __const_udelay
# tens of thousands of times in a tight handshake spin (xhci_handshake
# alternates one MMIO read + one udelay(1) per iteration until a status
# bit flips; on real silicon the bit can take ~100 ms to flip == ~100K
# iterations). A bare cond_resched on every udelay would pay an sti+hlt
# every microsecond — too heavy. We instead gate on a global tick
# counter and yield once every UDELAY_YIELD_EVERY invocations so the
# amortized cost is bounded. Single-CPU and not crossed by any code in
# Hamnix's UP environment, so a non-atomic uint64 is fine.
_l63_udelay_tick:        uint64 = 0
UDELAY_YIELD_EVERY:      uint64 = 256


def _l___const_udelay(xloops: uint64):
    # Real Linux: busy-loop calibrated to BogoMIPS. Bounded spin.
    # The xloops argument encodes the requested delay scaled by lpj
    # (loops per jiffy); for sub-microsecond delays it's a few hundred
    # iterations of a calibrated inner loop, for longer delays it's
    # proportionally larger. We approximate with a fixed-cost spin
    # because Hamnix doesn't carry BogoMIPS calibration; any .ko code
    # that needs sub-millisecond precision (xhci_handshake, etc.) does
    # its OWN timeout-watch via ktime_get on top.
    i: uint64 = 0
    while i < 1024:
        i = i + 1
    # Cooperative preempt point. Every UDELAY_YIELD_EVERY-th call we
    # yield via kernel_cond_resched so a tight handshake spin (xhci's
    # USBSTS HCH poll, libata's BUSY-bit wait, etc.) cannot monopolise
    # the CPU. _another_task_ready inside kernel_cond_resched short-
    # circuits to a no-op when no peer wants the CPU — i.e. zero cost
    # on a quiescent QEMU run, real yield only when something needs
    # the CPU.
    _l63_udelay_tick = _l63_udelay_tick + 1
    if _l63_udelay_tick >= UDELAY_YIELD_EVERY:
        _l63_udelay_tick = 0
        kernel_cond_resched()
    return



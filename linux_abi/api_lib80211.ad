# linux_abi/api_lib80211.ad
#
# L44: shims for the ABI gap exposed by lib80211.ko (stock Debian 6.12).
# lib80211.ko is the 802.11 crypto-ops registration core — its init
# path is small:
#
#     init_module:                      # .init.text
#         _printk("lib80211 ...")
#         tail-jmp lib80211_register_crypto_ops(NULL)
#
#     lib80211_register_crypto_ops:     # .text
#         s = kmalloc_caches[type][index]     # inline kmalloc lookup
#         buf = __kmalloc_cache_noprof(s, GFP, 0x18)
#         spin_lock_irqsave(&...)
#         __list_add_valid_or_report(&new, &prev, &next)
#         spin_unlock_irqrestore(...)
#         _printk("registered '%s'\n", name)
#         return 0
#
# The cross-check against linux_abi/exports.ad reduced lib80211's 17
# UND symbols to 9 that are not yet exported:
#
#     __list_add_valid_or_report
#     __list_del_entry_valid_or_report
#     __x86_indirect_thunk_rax
#     module_put
#     add_timer
#     jiffies                  # DATA — backed by arch/x86/kernel/time.ad
#     init_timer_key
#     __kmalloc_cache_noprof
#     kmalloc_caches           # DATA — table of struct kmem_cache *
#
# This file shims every one of those; the rest of the UND set
# (kfree, _raw_spin_lock_irqsave, _raw_spin_unlock_irqrestore, _printk,
# __fentry__, __x86_return_thunk, strcmp, timer_delete_sync) already
# resolves through the L2..L43 export tables.
#
# Design notes:
#
# * __list_add_valid_or_report / __list_del_entry_valid_or_report are
#   the Linux 6.12 names for the CONFIG_DEBUG_LIST sanity helpers. They
#   are pure-validity probes — the inline list_add / list_del already
#   wired the pointers when they were called. Same body as the older
#   __list_add_valid / __list_del_entry in api_misc.ad.
#
# * __x86_indirect_thunk_rax is the retpoline replacement for
#   `call *%rax` / `jmp *%rax`. Real Linux's arch/x86/lib/retpoline.S
#   `__x86_indirect_thunk_rax` does the call/return-poison dance for
#   Spectre v2 mitigation. With no mitigations enabled here, we just
#   forward control to %rax. The function body MUST undo Adder's
#   prologue (push rbp) and then `jmp *%rax` so:
#       - the return address pushed by the caller's `call thunk` stays
#         on top of stack
#       - the target's eventual `ret` lands back at the original call
#         site, not into garbage above our saved rbp
#
# * module_put decrements a struct module's refcount. We don't track
#   module refcounts yet (modules are loaded but never unloaded), so
#   the only correct body is a no-op.
#
# * add_timer / init_timer_key are the older timer-API entry points
#   that pair with timer_delete_sync (already exported in api_timer).
#   * init_timer_key(timer, fn, flags, name, key) writes the function
#     pointer into the timer struct — same effective contract as the
#     newer timer_setup. We forward to a slot-allocation path mirroring
#     api_timer.ad, but use the timer-struct's own function-pointer
#     field at offset 16 instead of carrying a parallel fn slot.
#   * add_timer(timer) arms a previously-init'd timer at
#     timer->expires (offset 24). For L44 we record the arm so a
#     future timer_walk_one_tick re-entry can fire it, but the init
#     path of lib80211 never schedules through this codepath so the
#     dispatcher work stays minimal.
#
# * jiffies is the kernel's wall-clock tick counter. The single source
#   of truth lives in arch/x86/kernel/time.ad as a module-level uint64
#   that the PIT/LAPIC ISR increments. We export its ADDRESS — modules
#   that load `jiffies(%rip)` read the live value on every access, no
#   shim function involved. This is exactly Linux's contract.
#
# * __kmalloc_cache_noprof(s, flags, size) is the slab allocator's
#   non-profiling entry. The `s` argument selects the slab cache; the
#   inline kmalloc lookup picks `s` out of kmalloc_caches[type][idx]
#   based on size. Hamnix's slab serves any size from one bucket, so
#   we ignore both `s` and `flags` and forward to mm.slab.kmalloc.
#
# * kmalloc_caches is the 2D table `struct kmem_cache *[TYPES][SHIFT]`
#   the inline kmalloc indexes. Stock Linux 6.12 has
#   NR_KMALLOC_TYPES=4 and KMALLOC_SHIFT_HIGH=25, so 4*26 = 104 entries
#   * 8 bytes = 832 bytes. The inline path reads
#   `kmalloc_caches[type][idx]` and passes the result to
#   __kmalloc_cache_noprof. Our shim ignores `s`, so the array can be
#   all zeros — a NULL pointer to a non-existent cache is fine as long
#   as the caller never dereferences it (which init paths don't). The
#   buffer must still be a readable, addressable global.

from linux_abi.exports import _add_export
from kernel.list import ListHead, list_add, list_del
from mm.slab import kmalloc
from arch.x86.kernel.time import jiffies


# ---------------------------------------------------------------------
# __list_add_valid_or_report / __list_del_entry_valid_or_report
#
# Linux 6.12 split the old single-bool __list_add_valid into "validate
# and report" pair that returns false + emits a diagnostic on
# violation. Behaviour is otherwise identical: caller has already
# re-wired the pointers by the time this is hit, so the body must NOT
# redo the link; it just checks for obviously-NULL inputs and reports
# success. Matches the pattern api_misc.ad uses for the older names.

def _l_list_add_valid_or_report(new: uint64, prev: uint64,
                                 next: uint64) -> int32:
    if new == 0 or prev == 0 or next == 0:
        return 0
    return 1


def _l_list_del_entry_valid_or_report(entry: uint64) -> int32:
    # bool __list_del_entry_valid_or_report(struct list_head *entry);
    # On real CONFIG_DEBUG_LIST=y kernels, returns true iff the entry's
    # prev/next are consistent (entry->prev->next == entry, etc.). The
    # inline list_del has not yet been called when this fires; on
    # success the caller will follow up with the actual __list_del.
    # We do the unlink here — same trade-off as _l_list_del_entry in
    # api_misc.ad — and return true.
    if entry == 0:
        return 0
    list_del(cast[Ptr[ListHead]](entry))
    return 1


# ---------------------------------------------------------------------
# __x86_indirect_thunk_rax
#
# Retpoline replacement for `call *%rax`. Modules built with
# -mindirect-branch=thunk-extern emit `call __x86_indirect_thunk_rax`
# in place of `call *%rax`. The thunk must transfer control to %rax
# while leaving the caller's return address (pushed by the call) on
# top of stack, so when the callee returns it lands at the original
# call site.
#
# Adder emits a standard prologue (push %rbp; mov %rsp, %rbp). Before
# we jump we must `pop %rbp` to undo that push, then jmp *%rax. The
# function never reaches its implicit epilogue — the asm_volatile is
# the last thing that executes.

def _l_x86_indirect_thunk_rax():
    asm_volatile("""
        popq %rbp
        jmpq *%rax
    """)


# ---------------------------------------------------------------------
# module_put
#
# void module_put(struct module *mod) — drops the per-module refcount.
# Hamnix doesn't reference-count modules yet (no rmmod-of-still-in-use
# semantics), so the symbol just has to exist and do nothing.

def _l_module_put(mod: uint64):
    return


# ---------------------------------------------------------------------
# add_timer + init_timer_key
#
# The older timer-API entry points. Linux's include/linux/timer.h:
#
#     void init_timer_key(struct timer_list *timer,
#                         void (*func)(struct timer_list *),
#                         unsigned int flags,
#                         const char *name,
#                         struct lock_class_key *key);
#     void add_timer(struct timer_list *timer);
#
# add_timer requires the caller to have written timer->expires (the
# struct field at byte offset 24) before calling. Linux's body
# essentially boils down to `__mod_timer(timer, timer->expires, 0)`.
# We mirror api_timer.ad's slot table conceptually but keep state
# inside the timer struct itself — modules that load lib80211 don't
# poke at our private slot table, and the init path never fires a
# timer, so recording into the struct is all the bookkeeping we need.
#
# struct timer_list field offsets (Linux 6.12, same as api_timer.ad):
#   offset 0:  struct hlist_node entry  (16 bytes)
#   offset 16: void (*function)(struct timer_list *)
#   offset 24: unsigned long expires
#   offset 32: unsigned long data        (legacy; 0 on modern modules)
#
# A 16-slot static "armed timers" table records (timer_ptr,
# expires_jiffies) for dispatch. This mirrors api_timer.ad's structure
# without colliding: api_timer.ad's table only tracks setups via
# timer_setup, and add_timer/init_timer_key callers use the parallel
# API. A future dispatcher could merge the two tables; for L44 we
# only need add_timer to record (and to never actually fire).

L44_TIMER_SLOTS: uint64 = 16
TL_FUNCTION_OFFSET: uint64 = 16
TL_EXPIRES_OFFSET:  uint64 = 24

l44_timer_ptrs:    Array[16, uint64]   # struct timer_list *
l44_timer_expires: Array[16, uint64]   # absolute jiffies deadline
l44_timer_active:  Array[16, uint64]   # 1 = armed


def _l44_find_timer_slot(timer_ptr: uint64) -> uint64:
    # Returns slot_index + 1 if known, 0 otherwise (sentinel matches
    # api_timer.ad convention).
    i: uint64 = 0
    while i < L44_TIMER_SLOTS:
        if l44_timer_ptrs[i] == timer_ptr:
            return i + 1
        i = i + 1
    return 0


def _l44_alloc_timer_slot(timer_ptr: uint64) -> uint64:
    found: uint64 = _l44_find_timer_slot(timer_ptr)
    if found != 0:
        return found
    i: uint64 = 0
    while i < L44_TIMER_SLOTS:
        if l44_timer_ptrs[i] == 0:
            l44_timer_ptrs[i]    = timer_ptr
            l44_timer_expires[i] = 0
            l44_timer_active[i]  = 0
            return i + 1
        i = i + 1
    return 0


def _l_init_timer_key(timer_ptr: uint64, fn: uint64, flags: uint64,
                       name: uint64, key: uint64):
    # Writes the function pointer into the struct (modules read it
    # back via timer->function in some paths) and grabs a tracking
    # slot. flags / name / key are debug + lockdep + scheduling hints
    # we don't honour yet — same drop as timer_setup in api_timer.ad.
    if timer_ptr == 0:
        return
    handle: uint64 = _l44_alloc_timer_slot(timer_ptr)
    if handle == 0:
        return
    fn_slot: Ptr[uint64] = cast[Ptr[uint64]](
        timer_ptr + TL_FUNCTION_OFFSET)
    fn_slot[0] = fn


def _l_add_timer(timer_ptr: uint64):
    # add_timer reads timer->expires (offset 24) and arms the timer
    # to fire at that absolute jiffies value. If init_timer_key was
    # skipped (some static initialisers do that), allocate a slot on
    # the fly. The dispatcher in api_timer.ad iterates its own table
    # only; merging is a future-milestone task — at L44 we just
    # record the arm so the symbol resolves and no init-time call
    # crashes.
    if timer_ptr == 0:
        return
    handle: uint64 = _l44_find_timer_slot(timer_ptr)
    if handle == 0:
        handle = _l44_alloc_timer_slot(timer_ptr)
        if handle == 0:
            return
    idx: uint64 = handle - 1
    exp_slot: Ptr[uint64] = cast[Ptr[uint64]](
        timer_ptr + TL_EXPIRES_OFFSET)
    l44_timer_expires[idx] = exp_slot[0]
    l44_timer_active[idx]  = 1


# ---------------------------------------------------------------------
# __kmalloc_cache_noprof
#
# void *__kmalloc_cache_noprof(struct kmem_cache *s, gfp_t flags,
#                              size_t size);
#
# Linux's slab fast path: allocate `size` bytes from cache `s`. The
# inline kmalloc helper picks `s` out of kmalloc_caches[][] based on
# the requested size, so by the time we're called `size` matches the
# bucket. Hamnix's slab serves any size from one zone — we ignore
# both `s` and `flags` and dispatch to mm.slab.kmalloc directly.

def _l_kmalloc_cache_noprof(s: uint64, flags: uint64,
                              size: uint64) -> uint64:
    return kmalloc(size)


# ---------------------------------------------------------------------
# kmalloc_caches
#
# `struct kmem_cache *kmalloc_caches[NR_KMALLOC_TYPES][KMALLOC_SHIFT_HIGH+1];`
#
# Linux 6.12 / x86_64 sizing:
#   NR_KMALLOC_TYPES        = 4 (NORMAL, RECLAIMABLE, DMA, CGROUP)
#   KMALLOC_SHIFT_HIGH + 1  = 26 (sizes from 2^0 .. 2^25)
#   total                   = 4 * 26 * 8 = 832 bytes
#
# The inline kmalloc reads `kmalloc_caches[type][idx]` (an 8-byte
# pointer load) and passes it as `s` to __kmalloc_cache_noprof. Our
# shim ignores `s`, so leaving the table all-zero is fine: the caller
# never dereferences the pointer. The buffer must just be a real,
# readable, addressable global.

kmalloc_caches_buf: Array[832, uint8]


# ---------------------------------------------------------------------
# Registration

def linux_abi_register_lib80211():
    # Called from start_kernel after the rest of linux_abi_exports_init
    # has populated the L1..L43 rows.
    _add_export("__list_add_valid_or_report",
                cast[uint64](&_l_list_add_valid_or_report))
    _add_export("__list_del_entry_valid_or_report",
                cast[uint64](&_l_list_del_entry_valid_or_report))
    _add_export("__x86_indirect_thunk_rax",
                cast[uint64](&_l_x86_indirect_thunk_rax))
    _add_export("module_put",
                cast[uint64](&_l_module_put))
    _add_export("add_timer",
                cast[uint64](&_l_add_timer))
    _add_export("init_timer_key",
                cast[uint64](&_l_init_timer_key))
    _add_export("__kmalloc_cache_noprof",
                cast[uint64](&_l_kmalloc_cache_noprof))
    # Data symbols — exported address points at the backing buffer /
    # variable so module relocations resolve to a live storage slot.
    _add_export("jiffies",
                cast[uint64](&jiffies))
    _add_export("kmalloc_caches",
                cast[uint64](&kmalloc_caches_buf[0]))

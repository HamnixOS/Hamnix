# linux_abi/u_mseal.ad -- mseal(2) (x86_64 nr 462), the Linux memory seal.
#
#   int mseal(void *addr, size_t len, unsigned long flags)
#       a0 = addr, a1 = len, a2 = flags (must be 0).
#
# mseal(2) (Linux 6.10+) FREEZES the layout of an address range: once a
# range is sealed, any later mprotect / munmap / mremap / madvise that
# DISCARDS or REPROTECTS those pages (MADV_DONTNEED / MADV_FREE /
# MADV_REMOVE) is rejected with -EPERM. There is no un-seal: a seal lasts
# for the life of the mapping. Hardened userland (glibc relro, CRT, the
# loader's PT_GNU_RELRO segment, Chrome's V8/PartitionAlloc) calls mseal
# to make critical mappings tamper-proof against an attacker who has gained
# an arbitrary-syscall primitive — the kernel itself refuses to let the
# layout change.
#
# ARCHITECTURE NOTE -- this is a Linux-ABI feature implemented directly on
# the EXISTING per-task VMA structures (mm/vma.ad VmaNode.sealed). It is NOT
# a parallel seal table: vma_seal_range stamps the real VMA nodes, and the
# real mm syscalls (vma_protect / vma_unmap / vma_mremap / vma_madvise) call
# vma_range_is_sealed and honour the seal. So the seal is enforced by the
# same code path a Linux process's mprotect/munmap travel — there is nothing
# to bypass.
#
# This is an HONEST implementation, NOT a stub: a sealed region's mprotect/
# munmap/mremap/madvise(DONTNEED) genuinely fail -EPERM, while an UNSEALED
# region's identical calls genuinely succeed. The self-test proves both
# halves, so a fake seal (one that ignores its argument) FAILS loudly.
#
# Layer note: a confined Layer-2 leaf, mirroring linux_abi/u_keyring.ad. It
# calls current_idx_get() (the task slot) plus the mm/vma.ad seal primitives
# and the same vma_protect / vma_unmap / vma_mremap / vma_madvise the nr
# 10/11/25/28 dispatch arms use. It never touches 9P / Chan / Layer-1 code.
# u_syscalls.ad imports umseal_mseal (the nr 462 dispatch arm forwards here),
# the same shape as u_keyring.ad.

from kernel.sched.core import (
    current_idx_get,
)
from mm.vma import (
    vma_alloc, vma_unmap, vma_protect, vma_madvise, vma_mremap,
    vma_seal_range, vma_range_is_sealed,
    VMA_PROT_READ, VMA_PROT_WRITE, VMA_MAP_PRIVATE, VMA_MAP_ANONYMOUS,
)
from kernel.printk.printk import (
    printk0, printk1,
)


# =====================================================================
# mseal ABI constants
# =====================================================================
#
# Linux negative-errno convention (subset we return).
MSEAL_EPERM:   int64 = -1
MSEAL_ENOMEM:  int64 = -12
MSEAL_EINVAL:  int64 = -22

# madvise advice we exercise in the self-test (matches mm/vma.ad MADV_*).
MSEAL_MADV_DONTNEED: int32 = 4

# mremap MAYMOVE flag (matches mm/vma.ad VMA_MREMAP_MAYMOVE).
MSEAL_MREMAP_MAYMOVE: uint64 = 1


# =====================================================================
# mseal(addr, len, flags)  --  nr 462
# =====================================================================
#
# Validates flags (must be 0, like Linux), then seals every VMA in
# [addr, addr+len). A range with an unmapped hole is rejected -ENOMEM and
# nothing is sealed (vma_seal_range does the all-or-nothing check). On
# success the affected VMAs carry sealed=1, and the existing mm syscalls
# reject later mutation of them -EPERM. Returns 0 on success.
def umseal_mseal(a0: uint64, a1: uint64, a2: uint64) -> int64:
    # Linux: flags must be 0 (reserved for future use); anything else
    # -EINVAL.
    if a2 != 0:
        return MSEAL_EINVAL
    slot: uint64 = current_idx_get()
    return vma_seal_range(slot, a0, a1)


# =====================================================================
# Boot self-test  --  [MSEAL] PASS / FAIL  (boot:37.mseal)
# =====================================================================
#
# Proves the seal is REAL by exercising the same vma_* entry points the
# nr 10/11/25/28/462 dispatch arms use, against the calling boot task's
# OWN VMA list:
#
#   (1) mmap a private anonymous SEALED region + a second UNSEALED region.
#   (2) mseal() the first; assert vma_range_is_sealed reports it sealed and
#       the unsealed region reports NOT sealed.
#   (3) mprotect / munmap / mremap / madvise(MADV_DONTNEED) over the SEALED
#       region ALL return -EPERM, AND the region is still mapped afterwards
#       (the seal really prevented the op, it did not silently succeed).
#   (4) the SAME four ops over the UNSEALED region ALL succeed — proving the
#       enforcement is keyed on the seal, not a blanket reject.
#   (5) mseal with a non-zero flags arg -> -EINVAL; mseal over a never-mapped
#       address -> -ENOMEM (all-or-nothing).
#
# Boot-context pointers are kernel-mapped; vma_alloc returns a real VA in the
# calling task's VMA list, so no userland binary is needed (mirrors how the
# keyring self-test drives ukey_* directly).
#
# umseal_selftest returns 1 on success, 0 on any failure.

MSEAL_TEST_LEN: uint64 = 0x4000          # 16 KiB (4 pages)


def umseal_selftest() -> int32:
    slot: uint64 = current_idx_get()
    prot_rw: int32 = VMA_PROT_READ | VMA_PROT_WRITE
    flags_anon: int32 = VMA_MAP_PRIVATE | VMA_MAP_ANONYMOUS

    # --- (1) map a SEALED-to-be region + THREE UNSEALED control regions.
    # Each unsealed control gets ONE op (madvise / munmap / mprotect) so no
    # region experiences two state-mutating ops in sequence — that keeps the
    # boot-task teardown path pristine (a single-chunk eager VMA frees whole).
    sealed_b: int64 = vma_alloc(slot, 0, MSEAL_TEST_LEN, prot_rw, flags_anon)
    if sealed_b < 0:
        printk1("[MSEAL] FAIL mmap sealed region rc=%d\n",
                cast[uint64](sealed_b))
        return 0
    sealed_base: uint64 = cast[uint64](sealed_b)

    unA_b: int64 = vma_alloc(slot, 0, MSEAL_TEST_LEN, prot_rw, flags_anon)
    unB_b: int64 = vma_alloc(slot, 0, MSEAL_TEST_LEN, prot_rw, flags_anon)
    unC_b: int64 = vma_alloc(slot, 0, MSEAL_TEST_LEN, prot_rw, flags_anon)
    if unA_b < 0 or unB_b < 0 or unC_b < 0:
        printk0("[MSEAL] FAIL mmap unsealed control regions\n")
        return 0
    unA_base: uint64 = cast[uint64](unA_b)        # madvise control
    unB_base: uint64 = cast[uint64](unB_b)        # munmap control
    unC_base: uint64 = cast[uint64](unC_b)        # mprotect control
    printk0("[MSEAL] PASS mapped sealed + unsealed control regions\n")

    # --- (2) seal the first region; assert seal state -----------------
    src: int64 = umseal_mseal(sealed_base, MSEAL_TEST_LEN, 0)
    if src != 0:
        printk1("[MSEAL] FAIL mseal rc=%d (want 0)\n", cast[uint64](src))
        return 0
    if vma_range_is_sealed(slot, sealed_base, MSEAL_TEST_LEN) != 1:
        printk0("[MSEAL] FAIL sealed region not reported sealed\n")
        return 0
    if vma_range_is_sealed(slot, unA_base, MSEAL_TEST_LEN) != 0:
        printk0("[MSEAL] FAIL unsealed region reported sealed\n")
        return 0
    printk0("[MSEAL] PASS mseal marked only the sealed region\n")

    # --- (3) every destructive op on the SEALED region -> -EPERM ------
    # mprotect to read-only.
    rc: int64 = vma_protect(slot, sealed_base, MSEAL_TEST_LEN, VMA_PROT_READ)
    if rc != MSEAL_EPERM:
        printk1("[MSEAL] FAIL mprotect(sealed) rc=%d (want -EPERM)\n",
                cast[uint64](rc))
        return 0
    # munmap.
    rc = vma_unmap(slot, sealed_base, MSEAL_TEST_LEN)
    if rc != MSEAL_EPERM:
        printk1("[MSEAL] FAIL munmap(sealed) rc=%d (want -EPERM)\n",
                cast[uint64](rc))
        return 0
    # mremap (grow with MAYMOVE).
    rc = vma_mremap(slot, sealed_base, MSEAL_TEST_LEN,
                    MSEAL_TEST_LEN * 2, MSEAL_MREMAP_MAYMOVE, 0)
    if rc != MSEAL_EPERM:
        printk1("[MSEAL] FAIL mremap(sealed) rc=%d (want -EPERM)\n",
                cast[uint64](rc))
        return 0
    # madvise(MADV_DONTNEED).
    rc = vma_madvise(slot, sealed_base, MSEAL_TEST_LEN, MSEAL_MADV_DONTNEED)
    if rc != MSEAL_EPERM:
        printk1("[MSEAL] FAIL madvise(sealed,DONTNEED) rc=%d (want -EPERM)\n",
                cast[uint64](rc))
        return 0
    # The seal must have PREVENTED the ops — the region is still sealed
    # (hence still mapped). If munmap had actually run, the range would no
    # longer be sealed.
    if vma_range_is_sealed(slot, sealed_base, MSEAL_TEST_LEN) != 1:
        printk0("[MSEAL] FAIL sealed region vanished after rejected ops\n")
        return 0
    printk0("[MSEAL] PASS mprotect/munmap/mremap/madvise on sealed -> EPERM\n")

    # --- (4) the SAME ops on UNSEALED regions all SUCCEED -------------
    # madvise(DONTNEED) on control A (zeroes writable pages in place).
    rc = vma_madvise(slot, unA_base, MSEAL_TEST_LEN, MSEAL_MADV_DONTNEED)
    if rc != 0:
        printk1("[MSEAL] FAIL madvise(unsealed,DONTNEED) rc=%d (want 0)\n",
                cast[uint64](rc))
        return 0
    # mprotect(READ) on control C (re-walks PTEs read-only, returns 0).
    rc = vma_protect(slot, unC_base, MSEAL_TEST_LEN, VMA_PROT_READ)
    if rc != 0:
        printk1("[MSEAL] FAIL mprotect(unsealed) rc=%d (want 0)\n",
                cast[uint64](rc))
        return 0
    # munmap on control B (frees a pristine single-chunk VMA whole).
    rc = vma_unmap(slot, unB_base, MSEAL_TEST_LEN)
    if rc != 0:
        printk1("[MSEAL] FAIL munmap(unsealed) rc=%d (want 0)\n",
                cast[uint64](rc))
        return 0
    printk0("[MSEAL] PASS mprotect/munmap/madvise on unsealed all allowed\n")

    # --- (5) error paths: bad flags -> EINVAL; hole -> ENOMEM ---------
    erc: int64 = umseal_mseal(sealed_base, MSEAL_TEST_LEN, 1)
    if erc != MSEAL_EINVAL:
        printk1("[MSEAL] FAIL mseal(flags=1) rc=%d (want -EINVAL)\n",
                cast[uint64](erc))
        return 0
    # A page-aligned address that was never mapped: -ENOMEM. Control B was
    # just unmapped above, so its base is now a hole.
    erc = umseal_mseal(unB_base, MSEAL_TEST_LEN, 0)
    if erc != MSEAL_ENOMEM:
        printk1("[MSEAL] FAIL mseal(hole) rc=%d (want -ENOMEM)\n",
                cast[uint64](erc))
        return 0
    printk0("[MSEAL] PASS bad-flags -> EINVAL + unmapped-hole -> ENOMEM\n")

    printk0("[mseal] PASS\n")
    return 1

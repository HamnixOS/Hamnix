# linux_abi/api_l66.ad
#
# L66: ships five more Debian 6.12 modules. One is a pure ride-along
# (zero new exports — every UND symbol already covered by L<=65); the
# other four need 23 new exports across five small groups.
#
#   * xt_LOG.ko            — netfilter LOG target (the legacy
#                              `-j LOG` rule). 10 UND, 0 missing.
#                              Fully covered by L<=65: the xt_register_
#                              targets + __request_module + __dynamic_
#                              pr_debug + __stack_chk_fail + __x86_
#                              return_thunk + __fentry__ surface, plus
#                              the L65 nf_logger_find_get / nf_logger_
#                              put / nf_log_packet trio. Test-only.
#   * xt_TCPMSS.ko         — netfilter TCPMSS target (clamps the TCP
#                              MSS option in SYN packets, typically to
#                              path-MTU). 20 UND, 3 new (ipv4_mtu,
#                              ip6_mtu, nf_route).
#   * nft_redir.ko         — nftables REDIR expression (`fib expr
#                              redirect`; the userspace REDIR target's
#                              nftables sibling). 14 UND, 5 new
#                              (nf_nat_redirect_ipv4, nf_nat_redirect_
#                              ipv6, nft_chain_validate_dependency,
#                              nft_dump_register, nft_parse_register_
#                              load).
#   * nft_compat.ko        — nftables compatibility bridge that exposes
#                              `xt_*` matches/targets as `compat`
#                              expressions to userspace nftables tools.
#                              40 UND, 7 new across two themes:
#                              netfilter-netlink subsystem
#                              (nfnetlink_subsys_register,
#                              nfnetlink_subsys_unregister,
#                              nfnetlink_unicast) and netlink message
#                              construction (nla_reserve, __nlmsg_put,
#                              skb_trim, nf_tables_trans_destroy_flush_
#                              work).
#   * dummy.ko             — the canonical "blackhole" network
#                              interface (a netdev that drops every TX
#                              packet and never receives). 29 UND, 8
#                              new (dev_lstats_read, eth_mac_addr,
#                              ethtool_op_get_ts_info, pernet_ops_
#                              rwsem DATA, __rtnl_link_register,
#                              __rtnl_link_unregister, skb_clone_tx_
#                              timestamp, skb_tstamp_tx).
#
# Module count in tests/linux-modules/ after L66: 48 + 5 = 53.
#
# UND analysis (`nm -u`, missing-after-L65):
#   xt_LOG.ko          0 missing
#   xt_TCPMSS.ko       3 missing
#   nft_redir.ko       5 missing
#   nft_compat.ko      7 missing
#   dummy.ko           8 missing
#   union              23 unique
#
# 23 new exports across 5 groups:
#
#   1.  Netfilter route + MTU helpers (ipv4_mtu, ip6_mtu, nf_route)
#   2.  nftables register parse/dump + chain dependency validation
#         (nft_chain_validate_dependency, nft_dump_register,
#          nft_parse_register_load)
#   3.  Netfilter NAT redirect (nf_nat_redirect_ipv4,
#         nf_nat_redirect_ipv6)
#   4.  Netfilter-netlink subsystem + netlink message building
#         (nfnetlink_subsys_register, nfnetlink_subsys_unregister,
#          nfnetlink_unicast, nla_reserve, __nlmsg_put, skb_trim,
#          nf_tables_trans_destroy_flush_work)
#   5.  netdev / rtnl glue for dummy.ko (dev_lstats_read,
#         eth_mac_addr, ethtool_op_get_ts_info, pernet_ops_rwsem DATA,
#         __rtnl_link_register, __rtnl_link_unregister,
#         skb_clone_tx_timestamp, skb_tstamp_tx)
#
# Stub philosophy mirrors L51..L65: every shim is init-cold for our
# env (no routing entries, no userspace nftables ruleset, no live
# netlink listener, no actual netdev TX path in QEMU). Each returns
# success / 0 / NULL / void so init_module stays on the happy path.
# The one DATA backing (pernet_ops_rwsem) is a zero-init buffer sized
# to the largest rw_semaphore variant.
#
# Naming notes:
#   * Adder reserves `bytes`, `match`, `case`, `file`, `field`, `type`
#     -> renamed to `nbytes` / `mt` / `cse` / `fp` / `fld` / `kind`.
#   * The "_l_" prefix marks the Hamnix-side shim; "_l66_" tags
#     DATA backings.

from linux_abi.exports import _add_export
from mm.slab import kmalloc, kzalloc


# =====================================================================
# Group 1: Netfilter route + MTU helpers (xt_TCPMSS)
# =====================================================================
#
# Linux:
#   unsigned int ipv4_mtu(const struct dst_entry *dst);
#   unsigned int ip6_mtu(const struct dst_entry *dst);
#   int nf_route(struct net *net, struct dst_entry **dst,
#                  struct flowi *fl, bool strict, u_int8_t family);
#
# ipv4_mtu / ip6_mtu:
#   Read the MTU off a routing-cache entry. xt_TCPMSS calls these when
#   the rule asks for `--clamp-mss-to-pmtu`: the desired MSS becomes
#   `pmtu - tcp/ip headers`. With no live routing table in QEMU the
#   rule never matches a real flow, but the relocation table still
#   needs the addresses. Returning a sane "path MTU = ethernet MTU"
#   (1500) keeps the clamp arithmetic on the same arm as Linux when
#   userspace ever does poke a rule.
#
# nf_route:
#   Resolves a route for an skb on the netfilter slow path (used by
#   xt_TCPMSS for the `--clamp-mss-to-pmtu` path when the skb has no
#   dst attached yet). Returns 0 on success and writes *dst. With no
#   routing table we report -ENETUNREACH (-101) which the caller's
#   error arm treats as "fall through; leave packet unmodified".

def _l_ipv4_mtu(dst: uint64) -> uint32:
    # 1500 == standard ethernet PMTU; the safe fallback when no
    # routing entry exists. xt_TCPMSS clamps MSS = 1500 - 40 = 1460.
    return 1500


def _l_ip6_mtu(dst: uint64) -> uint32:
    # 1500 == the same ethernet PMTU; IPv6's minimum is 1280, but
    # 1500 is the right answer for "we don't actually know, assume
    # ethernet".
    return 1500


def _l_nf_route(net: uint64, dst: uint64, fl: uint64, strict: int32,
                  family: uint32) -> int32:
    # -ENETUNREACH (-101) — no routing table; caller's error arm
    # leaves the skb's dst pointer untouched (NULL) which xt_TCPMSS
    # treats as "no pmtu info; skip the clamp".
    return -101


# =====================================================================
# Group 2: nftables register parse/dump + chain dependency validation
# =====================================================================
#
# Linux:
#   int  nft_parse_register_load(const struct nft_ctx *ctx,
#                                  const struct nlattr *attr,
#                                  u8 *sreg, u32 len);
#   int  nft_dump_register(struct sk_buff *skb, unsigned int attr,
#                            u32 reg);
#   int  nft_chain_validate_dependency(const struct nft_chain *chain,
#                                         enum nft_chain_types type);
#
# nft_parse_register_load:
#   Decodes the source-register field from a netlink attribute and
#   writes the resolved register index into *sreg. At insmod the
#   userspace netlink table is empty; no expressions parse. The
#   relocation still needs an address; we return 0 (== "no error,
#   sreg untouched") and let the caller proceed.
#
# nft_dump_register:
#   Inverse direction: encodes a register index into a netlink
#   attribute on an skb. Called from the dump path when userspace
#   issues `nft list chain`. With no chains, never fires; return 0.
#
# nft_chain_validate_dependency:
#   Sanity-check that the chain's type matches the dependency type a
#   compound expression demands (nft_redir requires the chain be a
#   NAT chain). With no nft chains in our env, the validation is
#   unreached at insmod; we return 0 (== "valid").

def _l_nft_parse_register_load(ctx: uint64, attr: uint64, sreg: uint64,
                                  blen: uint32) -> int32:
    # 0 == "parsed ok; *sreg left at the caller's pre-init value".
    # nft_redir's setup body checks for ret < 0 and bails on -EINVAL;
    # 0 keeps init on the happy path.
    return 0


def _l_nft_dump_register(skb: uint64, attr: uint32, reg: uint32) -> int32:
    # 0 == "wrote the attribute" (a no-op write is the right answer
    # when the skb is the dump scratch buffer and nobody is reading).
    return 0


def _l_nft_chain_validate_dependency(chain: uint64, kind: int32) -> int32:
    # Adder reserves `type` -> renamed to `kind`. 0 == "dependency
    # satisfied"; never reached at insmod (validation walks the
    # rule's expression tree which is empty until userspace builds
    # one).
    return 0


# =====================================================================
# Group 3: Netfilter NAT redirect (nft_redir)
# =====================================================================
#
# Linux:
#   unsigned int nf_nat_redirect_ipv4(struct sk_buff *skb,
#                                       const struct nf_nat_ipv4_multi_range_compat *mr,
#                                       unsigned int hooknum);
#   unsigned int nf_nat_redirect_ipv6(struct sk_buff *skb,
#                                       const struct nf_nat_range2 *range,
#                                       unsigned int hooknum);
#
# Both implement the per-family REDIR action — rewrite the destination
# address of an skb to a local address (typically 127.0.0.1 / ::1) so
# the packet hits a local listener. Called only on the packet-receive
# path under an active nat ruleset; at insmod the relocation table
# needs the address but no packet ever traverses our (empty) hook
# chain. NF_ACCEPT (== 1) is the right "I changed nothing useful, let
# the rest of the pipeline continue" answer.

def _l_nf_nat_redirect_ipv4(skb: uint64, mr: uint64,
                              hooknum: uint32) -> uint32:
    # NF_ACCEPT == 1. Never reached at insmod; relocation-only.
    return 1


def _l_nf_nat_redirect_ipv6(skb: uint64, range_arg: uint64,
                              hooknum: uint32) -> uint32:
    # NF_ACCEPT == 1. Same story as the IPv4 path.
    return 1


# =====================================================================
# Group 4: Netfilter-netlink subsystem + netlink message building
# =====================================================================
#
# Linux:
#   int  nfnetlink_subsys_register(const struct nfnetlink_subsystem *n);
#   int  nfnetlink_subsys_unregister(const struct nfnetlink_subsystem *n);
#   int  nfnetlink_unicast(struct sk_buff *skb, struct net *net,
#                            u32 portid);
#   struct nlattr *nla_reserve(struct sk_buff *skb, int attrtype,
#                                int attrlen);
#   struct nlmsghdr *__nlmsg_put(struct sk_buff *skb, u32 portid,
#                                  u32 seq, int type, int payload,
#                                  int flags);
#   int  skb_trim(struct sk_buff *skb, unsigned int len);
#   void nf_tables_trans_destroy_flush_work(void);
#
# nfnetlink_subsys_register / _unregister:
#   nft_compat registers its NFNL_SUBSYS_NFT_COMPAT subsystem at
#   init_module time so userspace nftables can talk to xt_* matches/
#   targets via the compat layer. With no nfnetlink core in Hamnix
#   (the netlink stub doesn't include nfnetlink yet), registration
#   succeeds trivially; unregister is void.
#
# nfnetlink_unicast:
#   Sends a netlink reply to a specific socket. With no netlink
#   socket bound, nothing to deliver to — Linux's "delivered to 0
#   sockets" arm returns 0.
#
# nla_reserve:
#   Reserves space for a netlink attribute in an skb. At insmod no
#   userspace tool is building messages; the relocation needs a
#   pointer-returning function. NULL is the right "out of skb space"
#   answer that callers test against.
#
# __nlmsg_put:
#   Like nla_reserve but for an nlmsghdr. Same story: NULL means
#   "skb tailroom exhausted"; caller's error arm bails cleanly.
#
# skb_trim:
#   Drops the tail of an skb's payload (used to undo a partial
#   build). Called only on the netlink reply path; never fires at
#   insmod. 0 == "trimmed ok".
#
# nf_tables_trans_destroy_flush_work:
#   Forces the nf_tables transaction-destroy workqueue to drain. nft_
#   compat hooks it on cleanup_module (rmmod) to make sure no in-
#   flight rule deletions race the unload. cleanup never runs in our
#   env (modules don't rmmod); pure no-op.

def _l_nfnetlink_subsys_register(n: uint64) -> int32:
    # No nfnetlink core to thread; success keeps init_module on the
    # happy path. Real Linux returns 0 on success; nft_compat's init
    # checks for ret == 0 and continues.
    return 0


def _l_nfnetlink_subsys_unregister(n: uint64) -> int32:
    return 0


def _l_nfnetlink_unicast(skb: uint64, net: uint64,
                           portid: uint32) -> int32:
    # 0 == "delivered to zero sockets" (success-but-no-recipient);
    # matches the netlink_unicast convention used elsewhere in the
    # stub family.
    return 0


def _l_nla_reserve(skb: uint64, attrtype: int32,
                     attrlen: int32) -> uint64:
    # NULL == "no room in skb tailroom"; the caller's error arm bails
    # cleanly. nla_reserve never fires at insmod (no userspace dump
    # builders running).
    return 0


def _l___nlmsg_put(skb: uint64, portid: uint32, seq: uint32,
                     kind: int32, payload: int32, flags: int32) -> uint64:
    # Adder reserves `type` -> renamed to `kind`. NULL == "no header
    # placed"; relocation-only.
    return 0


def _l_skb_trim(skb: uint64, blen: uint32) -> int32:
    # Adder reserves `len` would clash with prior shim conventions;
    # using `blen`. 0 == "trimmed ok"; never reached at insmod.
    return 0


def _l_nf_tables_trans_destroy_flush_work():
    # nft_compat's cleanup_module flushes pending transactions on
    # rmmod. cleanup never runs in our env; pure no-op.
    return


# =====================================================================
# Group 5: netdev / rtnl glue for dummy.ko
# =====================================================================
#
# Linux:
#   void dev_lstats_read(struct net_device *dev, u64 *packets,
#                          u64 *bytes);
#   int  eth_mac_addr(struct net_device *dev, void *p);
#   int  ethtool_op_get_ts_info(struct net_device *dev,
#                                  struct ethtool_ts_info *info);
#   struct rw_semaphore pernet_ops_rwsem;                /* DATA */
#   int  __rtnl_link_register(struct rtnl_link_ops *ops);
#   void __rtnl_link_unregister(struct rtnl_link_ops *ops);
#   void skb_clone_tx_timestamp(struct sk_buff *skb);
#   void skb_tstamp_tx(struct sk_buff *orig_skb,
#                        struct skb_shared_hwtstamps *hwtstamps);
#
# dev_lstats_read:
#   Reads the dev's per-cpu "lstats" counter into *packets / *bytes.
#   dummy.ko uses it in its ndo_get_stats64 path; at insmod (no
#   netdev probed yet) the relocation needs the address. Zero-init
#   both counters — Linux's stats consumers print 0 when no traffic
#   has flowed, which is exactly correct for an unprobed dummy.
#
# eth_mac_addr:
#   Implements the standard ether_setup ndo_set_mac_address handler:
#   copy 6 bytes from `p+2` (a sockaddr) into dev->dev_addr.  dummy
#   wires it up but `ip link set dummy0 address ...` never runs in
#   our env. 0 == success.
#
# ethtool_op_get_ts_info:
#   Reports the netdev's hardware-timestamp capabilities. dummy
#   advertises SOF_TIMESTAMPING_TX_SOFTWARE | RX_SOFTWARE — the
#   software fallbacks. We zero-fill the ethtool_ts_info struct and
#   return 0; userspace `ethtool -T dummy0` would see "no hw
#   timestamping" which matches dummy's actual behaviour.
#
# pernet_ops_rwsem:
#   Global read-write semaphore that gates register_pernet_subsys /
#   unregister_pernet_subsys.  __rtnl_link_register's callers take a
#   read lock on it before walking the per-netns list.  ~64 bytes
#   covers any lockdep-instrumented variant.
#
# __rtnl_link_register / __rtnl_link_unregister:
#   The "internal" variants of rtnl_link_register / rtnl_link_
#   unregister — same signature, but caller already holds rtnl_lock.
#   dummy.ko calls them from its module_init / module_exit (the
#   rtnl_lock comes from rtnl_link_unregister's own caller wrapper
#   when invoked at boot). Stub returns 0; unregister is void.
#
# skb_clone_tx_timestamp / skb_tstamp_tx:
#   Software-TX-timestamping helpers. dummy.ko calls skb_clone_tx_
#   timestamp on every fake-TX path to satisfy SO_TIMESTAMPING_TX_
#   SOFTWARE userspace clients. With no SO_TIMESTAMPING socket open
#   in Hamnix, the relocation needs the addresses but the bodies
#   never observe a request. Both are void no-ops.

_l66_pernet_ops_rwsem_buf:  Array[64, uint8]


def _l_dev_lstats_read(dev: uint64, packets: uint64, nbytes: uint64):
    # Adder reserves `bytes` -> renamed to `nbytes`. Write 0/0 to the
    # caller's accumulators; ndo_get_stats64 then reports zero
    # traffic which is the truth for an unprobed dummy.
    if packets != 0:
        pp: Ptr[uint64] = cast[Ptr[uint64]](packets)
        pp[0] = 0
    if nbytes != 0:
        bp: Ptr[uint64] = cast[Ptr[uint64]](nbytes)
        bp[0] = 0
    return


def _l_eth_mac_addr(dev: uint64, p: uint64) -> int32:
    # 0 == "address accepted". Real Linux memcpy's 6 bytes into
    # dev->dev_addr, but with no userspace ip(8) running there is no
    # MAC to copy and dummy.ko's stored MAC is left at the random
    # value alloc_netdev_mqs picked at probe time.
    return 0


def _l_ethtool_op_get_ts_info(dev: uint64, info: uint64) -> int32:
    # Real Linux zero-fills *info and sets SO_TIMESTAMPING_* bits.
    # The struct ethtool_ts_info is 56 bytes; zero-fill it so a
    # caller that does (eventually) inspect it sees a clean "no
    # capabilities advertised" baseline. dummy.ko calls this from
    # its ethtool_ops vector; init-cold for our env.
    if info != 0:
        ip: Ptr[uint8] = cast[Ptr[uint8]](info)
        i: uint64 = 0
        while i < 56:
            ip[i] = 0
            i = i + 1
    return 0


def _l___rtnl_link_register(ops: uint64) -> int32:
    # 0 == "registered ok". Mirrors _l_rtnl_link_register (L55) but
    # without the NULL-arg guard since dummy.ko always passes a real
    # rtnl_link_ops literal.
    return 0


def _l___rtnl_link_unregister(ops: uint64):
    return


def _l_skb_clone_tx_timestamp(skb: uint64):
    # No SO_TIMESTAMPING_TX_SOFTWARE socket subscriptions in Hamnix;
    # the body never finds a listener to clone the skb for.
    return


def _l_skb_tstamp_tx(orig_skb: uint64, hwtstamps: uint64):
    # Same story; no userspace consumer waiting for a TX timestamp.
    return


# =====================================================================
# Registration
# =====================================================================

def linux_abi_register_l66():
    # Called from linux_abi_exports_init() after the L65 batch.
    # Adds 23 new exports for the xt_LOG / xt_TCPMSS / nft_redir /
    # nft_compat / dummy batch. xt_LOG.ko needs no new exports — all
    # 10 UND symbols are already in the L<=65 surface (the L65
    # nf_logger_find_get / nf_logger_put / nf_log_packet batch
    # finished the coverage).

    # ---- Group 1: Netfilter route + MTU helpers ----
    _add_export("ipv4_mtu",
                cast[uint64](&_l_ipv4_mtu))
    _add_export("ip6_mtu",
                cast[uint64](&_l_ip6_mtu))
    _add_export("nf_route",
                cast[uint64](&_l_nf_route))

    # ---- Group 2: nftables register parse/dump + chain dependency ----
    _add_export("nft_parse_register_load",
                cast[uint64](&_l_nft_parse_register_load))
    _add_export("nft_dump_register",
                cast[uint64](&_l_nft_dump_register))
    _add_export("nft_chain_validate_dependency",
                cast[uint64](&_l_nft_chain_validate_dependency))

    # ---- Group 3: Netfilter NAT redirect ----
    _add_export("nf_nat_redirect_ipv4",
                cast[uint64](&_l_nf_nat_redirect_ipv4))
    _add_export("nf_nat_redirect_ipv6",
                cast[uint64](&_l_nf_nat_redirect_ipv6))

    # ---- Group 4: Netfilter-netlink + netlink message building ----
    _add_export("nfnetlink_subsys_register",
                cast[uint64](&_l_nfnetlink_subsys_register))
    _add_export("nfnetlink_subsys_unregister",
                cast[uint64](&_l_nfnetlink_subsys_unregister))
    _add_export("nfnetlink_unicast",
                cast[uint64](&_l_nfnetlink_unicast))
    _add_export("nla_reserve",
                cast[uint64](&_l_nla_reserve))
    _add_export("__nlmsg_put",
                cast[uint64](&_l___nlmsg_put))
    _add_export("skb_trim",
                cast[uint64](&_l_skb_trim))
    _add_export("nf_tables_trans_destroy_flush_work",
                cast[uint64](&_l_nf_tables_trans_destroy_flush_work))

    # ---- Group 5: netdev / rtnl glue for dummy.ko ----
    _add_export("dev_lstats_read",
                cast[uint64](&_l_dev_lstats_read))
    _add_export("eth_mac_addr",
                cast[uint64](&_l_eth_mac_addr))
    _add_export("ethtool_op_get_ts_info",
                cast[uint64](&_l_ethtool_op_get_ts_info))
    _add_export("pernet_ops_rwsem",
                cast[uint64](&_l66_pernet_ops_rwsem_buf[0]))
    _add_export("__rtnl_link_register",
                cast[uint64](&_l___rtnl_link_register))
    _add_export("__rtnl_link_unregister",
                cast[uint64](&_l___rtnl_link_unregister))
    _add_export("skb_clone_tx_timestamp",
                cast[uint64](&_l_skb_clone_tx_timestamp))
    _add_export("skb_tstamp_tx",
                cast[uint64](&_l_skb_tstamp_tx))

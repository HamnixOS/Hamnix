# fs/vfs.ad
#
# Mirrors fs/open.c + fs/read_write.c + fs/namei.c at minimum scope.
# As of M16.26 the fd table is PER-TASK (lives inline in task_struct's
# fd_idx[4] / fd_pos[4] arrays); reads come out of the baked-in
# initramfs (M16.21); writes route to the early-console UART for
# stdout/stderr, since the initramfs itself is read-only.
#
# Special fd_idx markers (from kernel/sched/core.ad):
#   FD_CLOSED_MARK = 0xFFFFFFFF       slot is free
#   FD_STDIN_MARK  = 0xFFFFFFFC       reads return EOF (no input source yet)
#   FD_STDOUT_MARK = 0xFFFFFFFE       writes route to serial
#   FD_STDERR_MARK = 0xFFFFFFFD       writes route to serial
#   FD_CHAN_MARK   = 0xFFFFFFE0       namec Chan-backed fd (fd_buf = chan id).
#     The stateless local cdevs /dev/{cons,time,pid,random,mouse,cpuinfo,
#     meminfo,uptime,loadavg,version,hostname,null,zero,stat,mounts,
#     diskstats} are no longer hand-assigned FD_<NAME>_MARK fds — they
#     open as FD_CHAN_MARK fds carrying an INLINE chan id (CHAN_INLINE_TAG
#     | DEV_<x>) and dispatch once through namec_read/write/close →
#     _devtab_read/_devtab_write. See sys/src/9/port/namec.ad for the
#     DEV_* devtab + chan encoding. (namespace-purity Phase 4b retired
#     FD_STAT_MARK / FD_MOUNTS_MARK / FD_DISKSTATS_MARK — their per-mark
#     arms here were already dead since open routes through namec.)
#     (Phase 4b also retired the 0xFE000000 FD_PROC encoded-marker
#      family: /proc/<pid>/<file> fds are FD_CHAN_MARK fds backed by
#      DEV_PROC pool chans — back_slot carries pid<<8 | file_kind; see
#      sys/src/9/port/devproc.ad header for the layout.)
# Anything below 0xFE000000 is a real initramfs file index.
#
# Linux semantics we keep:
#   SEEK_SET / SEEK_CUR / SEEK_END
#   read/write/lseek return -errno on failure (we use small negative
#   ints; no real errno space yet)
#   close on an already-closed fd returns -EBADF (-9)

from drivers.tty.serial.early_8250 import (
    early_putc, early_putc_user, early_getc_polled, uart_rx_pop,
    console_set_interactive,
)
from drivers.input.atkbd import kbd_rx_pop
# SYS_WAITFDS: jiffy clock for the timeout deadline (HZ=100, 10ms/tick).
from arch.x86.kernel.time import get_jiffies
from mm.uaccess import _ua_stac, _ua_clac
from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_WARN, PRINTK_LEVEL_EMERG
from kernel.sched.core import (
    TaskStruct, current_task,
    FD_CLOSED_MARK, FD_STDIN_MARK, FD_STDOUT_MARK, FD_STDERR_MARK,
    FD_BUFFER_MARK, FD_TMPFS_MARK,
    FD_FAT_MARK, FD_EXT4_MARK,
    close_fd_in_task, copy_fd_entry, yield_to_others,
    console_wq_sleep, wq_sleep_interruptible, WaitQueue, wq_init,
    console_input_may_pop_kbd_current, console_input_may_pop_uart_current,
    wq_wake_all, wq_wake_one, WQ_EINTR, WQ_TIMEOUT,
    wq_wait_prepare, wq_wait_cancel, wq_wait_commit,
    wq_wait_commit_timeout, waitfds_wq_ptr,
    get_cwd_buf, current_idx_get, set_current_errstr,
    # docs/security.md Phase 5: VFS permission check needs the caller's
    # uid/gid to compare against the file's owner/group/mode bits.
    current_task_uid, current_task_gid,
    # F10-3 #456: named uid constants — the dispatcher's hostowner bypass
    # is the cu == UID_HOSTOWNER arm; making it symbolic keeps the
    # "this is exactly the Plan-9 hostowner-bypass at the on-disk
    # servers" semantic legible at the call site.
    UID_HOSTOWNER,
    # Phase D follow-up: per-fd opened-path stamp. vfs_open /
    # vfs_open_write call task_fd_set_opened_path on a successful
    # install so fd2path can return the EXACT post-resolve path.
    task_fd_set_opened_path, task_fd_opened_path_ptr,
    # cgroup v2 cgroup.procs write: resolve the written pid -> task slot
    # so the move updates the SLOT-keyed g_task_cg association. A bare
    # `0` or `$$` resolves the current task via current_task_pid.
    task_lookup_by_pid, current_task_pid,
)
from sys.src.port9.port.devcons import (
    devcons_read, devcons_read_nb, devcons_write, devcons_poll_readable,
    # F10-2 #455: server-boundary perm policy lives in the server file.
    # devcons (the `#c` dev-server umbrella) admits world-r/w; the
    # hostowner-only knobs gate inside the per-cdev (devwsys/devkeymap).
    devcons_perm_check,
)
# hamUI Phase 1: the FD_STDIN_MARK arms (the legacy non-/dev/cons stdin
# path that hamsh's ed_readline still hits) consult the wsys cmd queue
# FIRST so an outside writer's `echo foo > /dev/wsys/1/cmd` arrives at
# hamsh's readline indistinguishably from the keyboard. devcons.ad's
# read arm already does the same; this keeps both surfaces consistent.
from sys.src.port9.port.devwsys import wsys_cmd_pop, wsys_wid_for_current
from sys.src.port9.port.devtime import devtime_read, devtime_write
from sys.src.port9.port.devpid import devpid_read, devpid_write
from sys.src.port9.port.devrandom import devrandom_read, devrandom_write
from sys.src.port9.port.devmouse import devmouse_read, devmouse_write
from sys.src.port9.port.devcpuinfo import devcpuinfo_read, devcpuinfo_write
from sys.src.port9.port.devmeminfo import devmeminfo_read, devmeminfo_write
from sys.src.port9.port.devuptime import devuptime_read, devuptime_write
from sys.src.port9.port.devloadavg import devloadavg_read, devloadavg_write
from sys.src.port9.port.devversion import devversion_read, devversion_write
from sys.src.port9.port.devhostname import devhostname_read, devhostname_write
# M16.135: /dev/stat + /dev/mounts + /dev/diskstats system-introspection
# trio are stateless namec devtab cdevs (DEV_STAT / DEV_MOUNTS /
# DEV_DISKSTATS). They open as FD_CHAN_MARK fds and dispatch through
# namec_read/write → _devtab_read/_devtab_write (sys/src/9/port/namec.ad).
# Their old FD_STAT_MARK / FD_MOUNTS_MARK / FD_DISKSTATS_MARK per-mark
# read/write/lseek arms and the import of devstat_read/devmounts_read/
# devdiskstats_read here were RETIRED (namespace-purity Phase 4b) — those
# fds were never installed (open already routed through namec) so the
# arms were dead. The dev*.ad bodies are now reached only from namec.
# docs/security.md Phase 4: kernel-side credential check. /dev/auth
# is a stateful cdev — each open carries its own per-fd slot (user
# buffer, pass buffer, verification result, rate-limit timestamp).
# Phase 4b retired FD_AUTH_MARK: an auth fd is an FD_CHAN_MARK fd
# backed by a DEV_AUTH pool chan (back_slot = AuthSlot index), and the
# read/write/close data path lives in namec (by-name dispatch into
# devauth_read/devauth_write/devauth_close). vfs only needs alloc (at
# open) + close (chan-alloc-failure rollback).
from sys.src.port9.port.devauth import (
    devauth_alloc, devauth_close,
    # F10-2 #455: server-boundary perm policy lives in the server file.
    # devauth admits all (anyone must be able to authenticate); the real
    # gate is inside the cdev (rate-limit + constant-time compare).
    devauth_perm_check,
)
# #165: the Linux-ABI pseudo-terminal layer. /dev/ptmx + /dev/pts/N are
# routed here at open() to FD_PTMX_MARK fds whose fd_buf packs
# (slot << 1) | is_master; vfs_read / vfs_write / vfs_close dispatch the
# data path + teardown through the u_pty pair pool. This is a Layer-2
# (linux_abi/) concern — a native Plan 9 binary never opens these paths
# (they have no namec devtab entry), so the marker only ever appears in
# a Linux guest's fd table.
#
# F4 #449 leaf inversion: the static `from linux_abi.u_pty import …`
# line that USED to live here is gone. Both the FD_PTMX_MARK constant and
# the pair-pool ops are now reached through the F4 hook block further
# down. The constant is REDEFINED natively below (0xFFFFFFCA, the same
# value u_pty.ad used); u_pty.ad imports it back from this module so the
# value stays single-sourced. Pool ops are dispatched through the per-
# kind function pointers planted by pty_ops_init() at boot. A pure-
# native build (no linux_abi) leaves the hooks null; an FD_PTMX_MARK
# fd then cannot be created (no /dev/ptmx open path), so the dispatch
# arms never fire.
# M16.x: /dev/blk/<name> block-device cdev. Phase 4b retired
# FD_BLK_MARK: a blk fd is an FD_CHAN_MARK fd backed by a DEV_BLK pool
# chan whose back_ptr carries the (mode << 32 | slot) pack; the data
# path lives in namec's DEV_BLK arms (by-name into devblk_read/
# devblk_write). vfs keeps the open-time name resolution
# (devblk_leaf_match) + the RAW-mode capacity snapshot for SEEK_END
# (devblk_capacity_bytes → fd_buflen).
from sys.src.port9.port.devblk import (
    devblk_leaf_match,
    devblk_capacity_bytes,
    # F10-2 #455: server-boundary perm policy lives in the server file.
    # devblk admits only caller_uid == 1 (raw block hostowner-only).
    devblk_perm_check,
)
# Block-device server directory walk (`#b` / /dev/blk listing). The
# per-device byte/size/ctl streams come from devblk above; the
# enumeration of registered device NAMES comes from blk_listdir.
from kernel.block.blk import blk_listdir
# Loop (file-backed block) device control surface. Phase 4b retired
# FD_LOOP_MARK: /dev/loop/ctl is a namec devtab cdev now (DEV_LOOPCTL,
# inline chan) — the `#c/loop/ctl` leaf resolves through _open_dev_leaf's
# _namec_open probe like every other stateless cdev, and the data path
# is namec's DEV_LOOPCTL arms (by-name into loopctl_read/loopctl_write).
# The loop block devices it spawns appear under /dev/blk/loopN (served
# by devblk above). vfs imports nothing from loop.ad anymore.
from sys.src.port9.port.devproc import (
    devproc_open, devproc_path_match, devproc_listdir,
    # F10-2 #455: server-boundary perm policy lives in the server file.
    # devproc admits world-r; per-task writes gate on caller_uid ==
    # target_uid OR caller_uid == 1 (Linux/Plan-9 nice rule).
    devproc_perm_check,
    # /proc/<pid>/fd is a LISTABLE directory: devproc_fd_listdir renders
    # one "N\n" line per open descriptor so getdents64 enumerates the
    # numeric fd names (apt ExecFork fast path).
    devproc_fd_listdir,
)
# F1 substrate: ns_walk is THE per-Pgrp namespace walk — the single
# authority for what a '/'-anchored name means in the calling task's
# namespace. resolve_path drives it candidate-by-candidate (it owns
# the backend existence probes) and localizes the returned server
# specs back to backend keys. There is no global fall-through: a path
# no binding covers is ENOENT.
from sys.src.port9.port.chan import (
    ns_walk, chan_find_srv_prefix,
    mnttab_create_target, mnttab_any_mcreate_covers,
    chan_dir_mount_children,
    pgrp_current,
    # Phase 6: long-form `#<word>` device names route through the
    # named-stack and by-id alias tables.
    name_lookup, name_lookup_at, name_lookup_dir,
    byid_lookup, byid_lookup_dir,
    # vfs_named_mkdir_selftest registers a scratch 't'-prefixed named
    # root to prove `#t<word>` mkdir routing (the `#t`-collision guard).
    name_push,
)
# HAMSH §7: the `#d` fd device. /fd/N is a name in the calling
# process's Pgrp namespace; an `#d/N` open installs an FD_CHAN_MARK fd
# carrying a DEV_DEVFD inline chan id (Phase 4c — FD_DEVFD_MARK is
# retired) and namec's DEV_DEVFD arms resolve the name through the
# per-Pgrp devfd table at I/O time. vfs only needs the slot-kind probe
# for the tty/console classification below.
from sys.src.port9.port.devfd import (
    devfd_slot_kind, DEVFD_CONS, DEVFD_NONE, DEVFD_SLOTS,
)
# V3/V3.5: `#s/<name>` name-server dispatch. devsrv_open returns the
# posted srvfd (or -1 on miss). `#s` itself (directory listing) renders
# via devsrv_list into a kmalloc'd FD_DIR_MARK buffer. The pre-V3.5
# path-shape helpers (devsrv_is_srv_dir / devsrv_path_match /
# devsrv_extract_name) are gone — vfs.ad now parses `#X` paths inline
# in `_open_hash_alias`.
from sys.src.port9.port.devsrv import (
    devsrv_open, devsrv_list, devsrv_lookup_full,
    # F10-2 #455: server-boundary perm policy lives in the server file.
    # devsrv admits world-r/w on the wire (SYS_SRV_POST validates the
    # poster against the srvfd).
    devsrv_perm_check,
)
# V4: opens of `/srv/<name>` (or `#s/<name>`) from a task OTHER than
# the poster need to copy the poster's fd entry into the opener's
# table. task_struct_at hands us a Ptr[TaskStruct] for the poster's
# slot; _alloc_fd + copy_fd_entry then do the dup, mirroring the
# sys_srv_open syscall body in arch/x86/kernel/syscall.ad.
from kernel.sched.core import task_struct_at, current_pgrp
# Linux-parity dentry cache (fs/fcache.ad): resolve_path is fronted by a
# per-namespace (Pgrp + generation) dcache so repeated path lookups skip the
# mount-table walk. Namespace mutations bump the generation to invalidate.
from fs.fcache import (
    fcache_dcache_lookup, fcache_dcache_store, fcache_dcache_bump_gen,
    fcache_sync_all,
)
# V1: in-kernel 9P client surface — vfs.ad dispatches FD_P9_MARK fds
# through these. 9p_client.ad's FD_P9_MARK lives next to the dev*.ad
# trio's marks (same pattern, see comment above the devstat import).
# Phase D: the V1-era 9P open helpers (p9c_walk_open_path /
# p9c_walk_create_path / p9c_encode_fd_buf) moved out of vfs.ad —
# sys/src/9/port/namec.ad owns the 9P-mounted open path now. vfs.ad
# keeps only the read/write/clunk + fd-buf decoders for the retained
# FD_P9_MARK *dispatch* fallback arms (no code installs FD_P9_MARK
# fds anymore, but the arms stay as a non-regressing safety net).
from sys.src.port9.port.9p_client import (
    p9c_read, p9c_write, p9c_clunk,
    p9c_decode_srvfd, p9c_decode_fid,
    FD_P9_MARK,
)
# Phase D — the universal resource path. namec() resolves an open
# through the calling process's Pgrp mount table to a Chan, dispatching
# devtab[] for a local cdev and mountrpc (9P T-messages) for a mounted
# 9P server — the SAME Chan type and the SAME read/write/close
# interface for both. vfs_open routes cdev + 9P-mounted opens through
# namec and installs ONE FD_CHAN_MARK fd; vfs_read/write/close dispatch
# FD_CHAN_MARK fds back into namec_read/write/close. This is the Plan 9
# inversion: the dozen FD_<NAME>_MARK special-cases stop being the
# substrate and become a single chan-backed path. The legacy
# FD_<NAME>_MARK arms below stay as a non-regressing fallback for any
# call site (e.g. `#X` aliases) not yet routed through namec.
from sys.src.port9.port.namec import (
    namec, namec_create, namec_mkdir,
    namec_read, namec_read_nb, namec_write, namec_close,
    namec_chan_is_mounted, namec_chan_dev_type, namec_chan_back_slot,
    namec_chan_back_ptr,
    namec_open_ext4_file, namec_open_fat_file, namec_open_dir_file,
    namec_open_buf_file, namec_open_proc_file, namec_open_auth_file,
    namec_open_blk_file,
    FD_CHAN_MARK, NAMEC_FALLTHROUGH, NAMEC_ENOENT, NAMEC_EMFILE,
    # F9 #452: /dev/auth devtab routes through namec but the alloc is
    # back here (devauth → vfs → namec; back-import would cycle).
    NAMEC_NEEDS_AUTH,
    DEV_CONS, DEV_EXT4_FILE, DEV_FAT_FILE, DEV_DIR_FILE, DEV_BUF_FILE,
    DEV_AUTH, DEV_BLK,
    # Phase 4c: `#d/<N>` fd-name fds are DEV_DEVFD inline chans.
    DEV_DEVFD, namec_chan_id_devfd, namec_chan_devfd_num,
    # Phase 4c: pipe ends are DEV_PIPE_R / DEV_PIPE_W pool chans
    # (back_slot = fs/pipe.ad ring slot).
    DEV_PIPE_R, DEV_PIPE_W, namec_open_pipe_end, namec_chan_pipe_slot,
    # Phase 4c (socket fold): Linux-ABI socket fds are DEV_SOCKET pool
    # chans (back_slot = the legacy fd_buf encoding); socketpair
    # endpoints are DEV_SOCKETPAIR pool chans (back_slot = packed
    # slot<<1|dir).
    DEV_SOCKET, DEV_SOCKETPAIR,
    namec_open_socket, namec_socket_set_record, namec_chan_socket_fdbuf,
    namec_open_sockpair_end, namec_chan_sockpair_packed,
    # Phase 4d (net fold, F7 #390): /net file-tree fds are DEV_NET pool
    # chans whose back_slot carries the legacy (proto, conn, file-kind)
    # pack. namec_read/write/close DEV_NET arms dispatch by name into
    # vfs_net_chan_* below.
    DEV_NET, namec_open_net, namec_chan_net_pack,
    # Phase 4e (PTY fold, F7 #390): /dev/ptmx + /dev/pts/<N> fds are
    # DEV_PTMX pool chans whose back_slot carries the legacy
    # (slot << 1) | is_master pack. namec_read/write/close DEV_PTMX arms
    # dispatch by name into vfs_ptmx_chan_* above (defined just after
    # vfs_net_chan_release).
    DEV_PTMX, namec_open_ptmx, namec_chan_ptmx_pack,
    # Phase 4f (FUSE fold, F7 #390): /dev/fuse connection fds are
    # DEV_FUSE_CONN pool chans (back_slot = conn slot index); paths
    # under a FUSE mount are DEV_FUSE_FILE pool chans (back_slot =
    # open-file token). namec_read/write/close arms dispatch by name
    # into vfs_fuse_conn_chan_* / vfs_fuse_file_chan_* (just after
    # vfs_ptmx_chan_release).
    DEV_FUSE_CONN, namec_open_fuse_conn, namec_chan_fuse_conn_slot,
    DEV_FUSE_FILE, namec_open_fuse_file, namec_chan_fuse_file_tok,
    # SYS_WAITFDS: per-Chan non-destructive readiness probe.
    namec_poll_readable,
    # F10-6 followup: per-Chan p9_dir_mode flag.
    namec_chan_set_p9_dir_mode, namec_chan_get_p9_dir_mode,
    namec_chan_set_back_ptr,
)
from lib.p9dir import (
    p9_dir_encode_into,
    P9_DMDIR, P9_DIR_FIXED_HDR, P9_DIR_MIN_REC,
)
from lib.9p.9p import P9_QTDIR, P9_QTFILE
from fs.cpio import (
    cpio_init,
    initramfs_entry_count, initramfs_entry_name,
    initramfs_entry_data, initramfs_entry_size,
    initramfs_entry_mode,
)
from fs.procfs import proc_render, proc_buf_size
from fs.procfs import is_cgroup_path, cgroup_render, cgroup_path_match
from fs.procfs import (
    cgroup_fs_mkdir, cgroup_fs_rmdir, cgroup_fs_write, cgroup_fs_attach,
    cgroup_fs_is_writable_leaf, cgroup_fs_path_is_procs,
    cgroup_fs_parse_first_dec, is_cgroup_subgroup_path,
)
from fs.procfs import is_node_path, node_render, node_path_match
from fs.tmpfs import (
    tmpfs_lookup, tmpfs_open_for_write,
    # §shared-mmap coherence: page-aligned physical page of a tmpfs file
    # + the size-extend a writable shared mmap performs on write-fault.
    tmpfs_page_phys, tmpfs_extend_size,
    tmpfs_size, tmpfs_read, tmpfs_write, tmpfs_unlink,
    # §stat-mtime: stable per-file mtime for the stat path.
    tmpfs_mtime,
    tmpfs_rename, tmpfs_slot_name,
    tmpfs_mkdir, tmpfs_path_is_dir, tmpfs_listdir,
    tmpfs_var_skeleton_init, tmpfs_path_exists,
    # §links: tmpfs symlink + hard-link support.
    tmpfs_create_symlink, tmpfs_hardlink, tmpfs_is_symlink,
    tmpfs_path_is_symlink, tmpfs_readlink,
    # §memfd: anonymous tmpfs files + the per-slot ftruncate the memfd
    # fd routes through.
    tmpfs_create_anon, tmpfs_release_anon, tmpfs_ftruncate, tmpfs_is_anon,
    # F10-2 #455: server-boundary perm policy lives in the server file.
    # tmpfs admits world-r/w (no per-file owner/mode storage in v1).
    tmpfs_perm_check,
)
from fs.pipe import (
    pipe_alloc, pipe_write,
    pipe_readers, pipe_writers,
    pipe_readable, pipe_writable,
    # Phase 4c: vfs_pipe rollback paths drop raw end-references when the
    # chan pool is exhausted mid-allocation.
    pipe_close_reader, pipe_close_writer,
)
# V5: bidirectional socketpair transport — a single fd you can read
# AND write; retires the V4.1 `p9rx:` smuggle for new use sites (rio
# etc.). Phase 4c (socket fold): the FD_SOCKETPAIR_MARK is RETIRED —
# an endpoint is an FD_CHAN_MARK fd over a DEV_SOCKETPAIR pool chan;
# the blocking read/write bodies moved into fs/socketpair.ad
# (sockpair_read_blocking / sockpair_write_blocking, dispatched from
# namec). What's left here: alloc + rollback close for vfs_socketpair,
# the non-blocking write arm, and the poll(2) readiness bits.
from fs.socketpair import (
    sockpair_alloc, sockpair_write,
    sockpair_close, sockpair_peer_alive,
    sockpair_readable,
    sockpair_unpack_slot, sockpair_unpack_dir,
)
# U-socket: read/write/close on a connected AF_INET SOCK_STREAM fd
# routes through the real in-kernel TCP stack. tcp.ad is an import
# leaf (it pulls in ip/eth/arp/virtio_net but never fs/vfs.ad), so no
# cycle. fs/socket_state.ad is the per-socket-fd backing-record store —
# also a leaf — shared with linux_abi/u_syscalls.ad's socket(2)/
# connect(2) bodies. It lives in fs/ (not linux_abi/) because it is a
# Layer-0/1-neutral leaf, so fs/vfs.ad (Layer 1) imports nothing from
# the Layer-2 linux_abi/ tree here.
from drivers.net.tcp import (
    tcp_send, tcp_recv, tcp_recv_nb, tcp_recv_pending, tcp_slot_at_eof,
    tcp_close, tcp_listen_close,
)
from fs.socket_state import (
    usock_record_for_fdbuf, usock_get_state, usock_get_tcp_slot,
    usock_set_state, usock_set_tcp_slot, usock_free,
    usock_is_tls, usock_set_tls, usock_get_type,
    usock_get_peer_addr, usock_get_peer_port,
    usock_get_netconn,
    USOCK_CONNECTED, USOCK_CLOSED, USOCK_LISTENING,
    USOCK_SOCK_DGRAM,
)
# §10 UDP sockets: a SOCK_DGRAM socket fd's read/write/close route
# through the in-kernel UDP socket layer (drivers/net/udp.ad — an
# import leaf, same as tcp.ad). A plain read(2)/write(2) on a UDP
# socket fd maps to recvfrom/sendto on the connected peer.
from drivers.net.udp import (
    udp_socket_sendto, udp_socket_recvfrom, udp_socket_close,
    udp_socket_recv_pending,
)
# U-TLS: a socket fd marked TLS-active (by tls_connect(2)) routes its
# read/write/close through the in-kernel TLS 1.3 record layer instead
# of raw tcp_send/tcp_recv. tls.ad imports tcp.ad + cpio.ad + the
# crypto libs but never fs/vfs.ad, so no import cycle.
from drivers.net.tls import tls_send, tls_recv, tls_close_notify, tls_close
# ARCH §10: the /net 9P file tree. /net is Hamnix's Plan-9-shaped
# networking surface — networking is a file tree, not a socket() family.
# fs/vfs.ad installs an FD_CHAN_MARK fd over a DEV_NET pool chan for
# an open of /net/tcp/clone or a /net/<proto>/<N>/<file>; the vfs_net_chan_*
# bodies below dispatch back into the devnet_* connection-table API
# (called BY NAME from namec.ad's DEV_NET read/write/close arms — vfs
# imports namec). devnet.ad imports tcp.ad + udp.ad (both import leaves)
# but never fs/vfs.ad — no import cycle. (Phase 4d net fold, F7 #390.)
# ARCH §10: a /net conn TLS-upgraded by a `tls <host>` ctl command is
# flagged by devnet_conn_is_tls; vfs_net_chan_read/write below route
# such a conn's data file through the TLS 1.3 record layer
# (tls_send / tls_recv / tls_close_notify) instead of raw devnet I/O.

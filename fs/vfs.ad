    FD_BUFFER_MARK, FD_TMPFS_MARK, FD_PIPE_MARK_R, FD_PIPE_MARK_W,
    FD_FAT_MARK, FD_EXT4_MARK,
    FD_SOCKET_MARK,
    close_fd_in_task, copy_fd_entry, yield_to_others,
    console_wq_sleep, wq_sleep_interruptible, WaitQueue, wq_init,
    console_input_may_pop_current,
    wq_wake_all, wq_wake_one, WQ_EINTR, WQ_TIMEOUT,
    wq_wait_prepare, wq_wait_cancel, wq_wait_commit,
    wq_wait_commit_timeout, waitfds_wq_ptr,
    get_cwd_buf, current_idx_get, set_current_errstr,
    # docs/security.md Phase 5: VFS permission check needs the caller's
    # uid/gid to compare against the file's owner/group/mode bits.
    current_task_uid, current_task_gid,
)

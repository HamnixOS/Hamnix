from mm.slab import kmalloc, kfree

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]
# SMAP: vfs_read's data-delivery memcpys may write into a USER (US=1)
# page when a kernel-internal caller (the `enter linux` exec path's
# loader read of the binary into its freshly-mapped user image, the
# native read syscall's non-bounced fast paths) passes a user VA as the
# destination buffer. A CPL=0 store to a US=1 page #PFs under CR4.SMAP=1
# unless EFLAGS.AC is set. Bracket exactly the leaf copy-to-caller-buf
# sites with STAC/CLAC. For a kernel-dst caller the AC flag is a no-op
# (supervisor access to a US=0 page is unaffected), so the bracket is
# safe for both. (Mirrors fs/elf.ad's COW/interp memcpy brackets.)
from mm.uaccess import _ua_stac, _ua_clac

# _VFS_NR_FDS itself is imported from kernel/sched/core.ad — we keep its
# size in sync so the cast below is meaningful.
_VFS_NR_FDS: uint32 = 64

# Errno constants (small negative; matches Linux's signs).
ENOENT: int32 = -2
EBADF:  int32 = -9
EPIPE:  int32 = -32
ENOSPC: int32 = -28
EINVAL: int32 = -22
# ESPIPE — "illegal seek". Linux returns this (NOT EINVAL) for lseek on a
# pipe / socket / fifo / tty. Programs that read a stream and skip over a
# region (dpkg's data.tar unpack, `tar` on a pipe, anything using glibc
# fd_skip) probe with lseek(SEEK_CUR) and key the read-skip fallback on
# errno==ESPIPE; an EINVAL there is taken as a hard error instead.
ESPIPE: int32 = -29
EMFILE: int32 = -24
EROFS:  int32 = -30
EISDIR: int32 = -21
EIO:    int32 = -5
ENODEV: int32 = -19
# A FAT fd is tagged FD_FAT_MARK; fd_buf normally holds the read
# open-file slot index (0..7). A write-mode FAT open ORs this bit
# into fd_buf so the dispatch can tell a write fd from a read fd
# without a new FD_*_MARK (those live in core.ad, which is off-limits
# here). The low bits still hold the write-slot index.
FAT_FD_WRITE_BIT: uint64 = 0x80000000

# lseek whence
SEEK_SET: int32 = 0
SEEK_CUR: int32 = 1
SEEK_END: int32 = 2


def vfs_init():
    # Per-task fd tables are initialised in create_user_task /
    # kthread_create. The only filesystem-side work is parsing the
    # embedded cpio archive into the in-memory file_table that the
    # initramfs_entry_* accessors consult.
    cpio_init()
    # Register the always-present mounts in the VFS mount table FIRST:
    # cpio at "/" (the read-only baked root + longest-prefix fallback) and
    # the /tmp + /var tmpfs subtrees. Every backend-selection call in
    # vfs_open/listdir/stat/... resolves through this table, so it must be
    # populated before the first VFS op. /ext and /mnt are added later by
    # ext4_init / fat_init when their volumes actually mount.
    vfs_mount_init_base()
    # V2: tmpfs owns both /tmp/* and /var/*. Pre-create the standard
    # /var skeleton (/var/lib/dpkg, /var/cache/apt, /var/www, ...) so
    # apt / dpkg / httpd find canonical writable paths at boot. /var is
    # RAM-backed and volatile — re-created on every boot.
    tmpfs_var_skeleton_init()


# Kernel-internal initramfs lookup. Used during boot to read /init
# BEFORE any user task exists (and therefore before any fd table is
# in scope). Returns 0 on miss.

def initramfs_data_ptr(name: Ptr[char]) -> uint64:
    idx: int32 = _lookup_name(name)
    if idx < 0:
        return 0
    return cast[uint64](initramfs_entry_data(cast[uint64](idx)))


def initramfs_data_size(name: Ptr[char]) -> uint64:
    idx: int32 = _lookup_name(name)
    if idx < 0:
        return 0
    return initramfs_entry_size(cast[uint64](idx))


# §4 — namespace-aware blob lookup for the ELF loader.
#
# initramfs_data_ptr / initramfs_data_size above are namespace-AGNOSTIC:
# they match a path verbatim against the cpio archive. That is correct
# for the bootstrap /init lookup (before any task / Pgrp exists) but
# WRONG for an execve / interpreter / DSO lookup performed on behalf of
# a running process. Hamnix is Plan 9-shaped — there is no global
# filesystem route; a path resolves through the *calling process's*
# namespace (its Pgrp mount table).
#
# These two helpers run the path through resolve_path() first, which
# applies ns_walk()'s longest-prefix mount-table rewrite.
# Concretely: a process that did `bind("/lib", backing/lib)` (the
# distrorun distro-shape graft) will have a namespace where
#   ns_blob_ptr("/lib64/ld-linux-x86-64.so.2")
# resolves to e.g. "/var/lib/distros/debian/lib64/ld-linux-x86-64.so.2"
# and finds the interpreter in the distro tree — while a process with
# no such bind still resolves the path verbatim (resolve_path is a
# no-op rewrite when no mount entry matches), so the native initramfs
# layout keeps working unchanged.
#
# The backing store today is still the cpio initramfs (distrorun grafts
# initramfs directories), so the final lookup remains initramfs_*. When
# a real 9P-served distrofs lands, the post-rewrite path will fall
# under a CHAN_KIND_SRV mount and the loader will need a Chan read
# instead — but the resolve_path() seam here is already namespace-
# correct, so that change is localised to this function pair.

# --- exec/interp blob cache (partition-backed binaries) -------------
#
# THE KEYSTONE (P2). The cpio is memory-resident, so the original
# ns_blob_ptr just returned the cpio entry's in-RAM address. A binary
# that lives ONLY on the ext4 rootfs partition (reached via `bind
# '#sysroot' /`) has NO cpio entry — resolve_path() correctly rewrites
# `/bin/ls` to `#by-id/<partuuid>/sysroot/bin/ls` (the named-root bind),
# but initramfs_data_ptr() then misses and exec fails with -ENOENT even
# though userspace can `cat` the very same path (vfs_open routes the
# `#by-id` form through ext4). The fix: when the cpio misses, READ the
# resolved file off its backing FS into a kmalloc'd kernel buffer and
# hand the ELF loader that pointer.
#
# vfs_open already handles every backend (`#by-id`/ext4/tmpfs/cpio)
# uniformly, so we reuse it: open the resolved path, slurp the whole
# file with vfs_read, close. The bytes are cached in a single-entry
# slot keyed by the ORIGINAL (pre-resolve) name so the consecutive
# ns_blob_ptr()+ns_blob_size() calls every exec/interp site makes for
# the same path share one read instead of opening the partition twice.
# A fresh load frees the previous slot (exec is one-at-a-time at this
# scale; the loaded ELF image is copied out by elf_load_blob before the
# next exec, so the buffer can be recycled).
_ns_blob_cache_ptr:   uint64 = 0
_ns_blob_cache_size:  uint64 = 0
_ns_blob_cache_owned: uint64 = 0
_ns_blob_load_last_size: uint64 = 0
_ns_blob_cache_key:  Array[256, uint8]


def _ns_blob_key_matches(name: Ptr[char]) -> int32:
    if _ns_blob_cache_ptr == 0:
        return 0
    i: uint64 = 0
    while i < 255:
        a: uint8 = cast[uint8](name[i] & 0xFF)
        b: uint8 = _ns_blob_cache_key[i]
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1
    return 1


# Upper bound on a partition-served binary the exec fallback will slurp
# into a single contiguous kmalloc buffer. Generous (busybox-static is
# ~2 MiB, glibc DSOs a few hundred KiB); guards against a pathological
# size pinning all of kmalloc.
_NS_BLOB_MAX: uint64 = 67108864


def _ns_blob_tmpfs_load(resolved: Ptr[char]) -> uint64:
    # Slurp a tmpfs-resident FILE into a kmalloc'd buffer so it can be
    # ELF-loaded by SYS_SPAWN / SYS_EXECVE. This is the keystone that
    # makes a freshly-INSTALLED binary (hpm writes the compiled artifact
    # into the writable /var or /tmp tmpfs subtree) executable: the
    # historical exec path only consulted the read-only cpio image and
    # the ext4 named-root, so a program that landed in tmpfs at install
    # time was un-spawnable. Returns the buffer pointer (size left in
    # _ns_blob_load_last_size) or 0 if `resolved` is not a tmpfs file.
    if vfs_fs_kind(resolved) != FS_KIND_TMPFS:
        return 0
    if tmpfs_path_is_dir(resolved) != 0:
        return 0
    slot: int32 = tmpfs_lookup(resolved)
    if slot < 0:
        return 0
    size: uint64 = tmpfs_size(slot)
    if size == 0 or size > _NS_BLOB_MAX:
        return 0
    buf: uint64 = kmalloc(size)
    if buf == 0:
        return 0
    total: uint64 = 0
    while total < size:
        n: uint64 = tmpfs_read(slot, cast[Ptr[uint8]](buf + total),
                               total, size - total)
        if n == 0:
            break
        total = total + n
    if total != size:
        kfree(buf)
        return 0
    _ns_blob_load_last_size = total
    return buf


def _ns_blob_partition_load(resolved: Ptr[char]) -> uint64:
    # Open the resolved path through the full vfs_open backend dispatch
    # (so a `#by-id/<uuid>/sysroot/...` named-root path lands on ext4)
    # and read the whole file into a kmalloc'd buffer. Returns the
    # buffer pointer (size left in _ns_blob_load_last_size) or 0 on
    # failure. Caller owns caching/freeing.
    #
    # FD-LESS FAST PATH (M16.img boot keystone): a `#by-id/.../ext4`
    # path is read directly via ext4_resolve_file + ext4_read_file with
    # NO fd. This is REQUIRED for the kernel's boot:36 /init load, which
    # runs in the boot/idle task context BEFORE the first user task
    # exists — that task has no usable fd table, so vfs_open would
    # return -EMFILE. Userspace callers (with real fd tables) still get
    # the same result through this path; the vfs_open fallback below
    # covers non-ext4 backends (tmpfs/cpio/srv).
    blob: uint64 = 0
    bsize: uint64 = 0
    by_id_rc: int32 = _ns_ext4_slurp_by_id(resolved, &blob, &bsize)
    if by_id_rc == 1:
        _ns_blob_load_last_size = bsize
        return blob
    fd: int32 = vfs_open(resolved)
    if fd < 0:
        return 0
    # Discover the size. ext4/cpio/tmpfs opens stash the file length in
    # the fd's fd_buflen; fall back to a bounded read loop if it's 0.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    size: uint64 = task[0].fd_buflen[fdu]
    if size == 0 or size > _NS_BLOB_MAX:
        # Either an unsized backend or an implausible size — read in a
        # loop up to the cap, growing the read window as we go is
        # overkill; allocate the cap-bounded buffer and read into it.
        if size > _NS_BLOB_MAX:
            vfs_close(fd)
            return 0
        size = _NS_BLOB_MAX
    buf: uint64 = kmalloc(size)
    if buf == 0:
        vfs_close(fd)
        return 0
    total: uint64 = 0
    while total < size:
        n: int64 = vfs_read(fd, cast[Ptr[uint8]](buf + total),
                            size - total)
        if n <= 0:
            break
        total = total + cast[uint64](n)
    vfs_close(fd)
    if total == 0:
        kfree(buf)
        return 0
    _ns_blob_load_last_size = total
    return buf


def _ns_blob_load(name: Ptr[char]) -> uint64:
    # Resolve `name` through the calling task's namespace, then return
    # an in-memory blob pointer (cpio entry address, or a kmalloc'd copy
    # of a partition file). 0 on miss. _ns_blob_cache_size carries the
    # matching length. Single-entry cache keyed on the original name so
    # the paired ns_blob_ptr/ns_blob_size calls share one read.
    if _ns_blob_key_matches(name) != 0:
        return _ns_blob_cache_ptr
    resolved: Array[256, uint8]
    rc: int32 = resolve_path(name, &resolved[0], 256)
    target: Ptr[char] = name
    if rc == 0:
        target = cast[Ptr[char]](&resolved[0])
    # 1. cpio (memory-resident): return the entry address directly,
    #    matching the historical fast path. NOT cached (it isn't a
    #    kmalloc'd buffer we own) — but we DO record size/key so the
    #    follow-up ns_blob_size hits without re-resolving.
    cpio_ptr: uint64 = initramfs_data_ptr(target)
    if cpio_ptr != 0:
        # Free a previously-cached PARTITION buffer (owned==1) before we
        # repoint the slot at the cpio entry. A cpio entry is NOT
        # heap-owned, so we must NOT kfree it — _ns_blob_cache_owned
        # records which kind the slot currently holds.
        if _ns_blob_cache_ptr != 0 and _ns_blob_cache_owned != 0:
            kfree(_ns_blob_cache_ptr)
        _ns_blob_cache_ptr = cpio_ptr
        _ns_blob_cache_size = initramfs_data_size(target)
        _ns_blob_cache_owned = 0
        i: uint64 = 0
        while i < 255:
            c: uint8 = cast[uint8](name[i] & 0xFF)
            _ns_blob_cache_key[i] = c
            if c == 0:
                break
            i = i + 1
        _ns_blob_cache_key[255] = 0
        return cpio_ptr
    # 2. tmpfs (writable /var, /tmp): slurp a freshly-installed binary
    #    into a kmalloc'd buffer so SYS_SPAWN can ELF-load it. Without
    #    this, a program hpm compiles+installs into the tmpfs-backed
    #    /var subtree is un-executable (exec only saw cpio + ext4).
    tmpbuf: uint64 = _ns_blob_tmpfs_load(target)
    if tmpbuf != 0:
        if _ns_blob_cache_ptr != 0 and _ns_blob_cache_owned != 0:
            kfree(_ns_blob_cache_ptr)
        _ns_blob_cache_ptr = tmpbuf
        _ns_blob_cache_size = _ns_blob_load_last_size
        _ns_blob_cache_owned = 1
        i: uint64 = 0
        while i < 255:
            c: uint8 = cast[uint8](name[i] & 0xFF)
            _ns_blob_cache_key[i] = c
            if c == 0:
                break
            i = i + 1
        _ns_blob_cache_key[255] = 0
        return tmpbuf
    # 3. partition fallback (THE keystone): slurp the file off its
    #    backing FS (ext4 via the `#by-id` named-root route) into a
    #    kmalloc'd buffer.
    buf: uint64 = _ns_blob_partition_load(target)
    if buf == 0:
        return 0
    # store + mark heap-owned so the next store/clear frees it.
    if _ns_blob_cache_ptr != 0 and _ns_blob_cache_owned != 0:
        kfree(_ns_blob_cache_ptr)
    _ns_blob_cache_ptr = buf
    _ns_blob_cache_size = _ns_blob_load_last_size
    _ns_blob_cache_owned = 1
    i: uint64 = 0
    while i < 255:
        c: uint8 = cast[uint8](name[i] & 0xFF)
        _ns_blob_cache_key[i] = c
        if c == 0:
            break
        i = i + 1
    _ns_blob_cache_key[255] = 0
    return buf


def ns_blob_ptr(name: Ptr[char]) -> uint64:
    # Namespace-aware counterpart of initramfs_data_ptr. Returns the
    # in-memory blob pointer for `name` resolved through the calling
    # task's namespace (cpio entry OR a kmalloc'd copy of a partition
    # file reached via a named-root bind), or 0 on miss.
    return _ns_blob_load(name)


def ns_blob_size(name: Ptr[char]) -> uint64:
    # Namespace-aware counterpart of initramfs_data_size. Resolves the
    # same way as ns_blob_ptr; returns the cached length when the
    # immediately-preceding ns_blob_ptr loaded this same name.
    if _ns_blob_key_matches(name) != 0:
        return _ns_blob_cache_size
    # No cache hit (e.g. called standalone) — re-resolve and load.
    if _ns_blob_load(name) == 0:
        return 0
    return _ns_blob_cache_size


def _strcmp_cstr(a: Ptr[char], b: Ptr[char]) -> int32:
    i: int32 = 0
    while True:
        ca: int32 = a[i]
        cb: int32 = b[i]
        if ca != cb:
            return 1
        if ca == 0:
            return 0
        i = i + 1


def _lookup_name_one(name: Ptr[char]) -> int32:
    # Single-pass exact-match name lookup. The symlink-resolving
    # _lookup_name() wraps this and walks the chain when the matched
    # entry is a S_IFLNK.
    count: uint64 = initramfs_entry_count()
    i: uint64 = 0
    while i < count:
        candidate: Ptr[char] = initramfs_entry_name(i)
        if _strcmp_cstr(name, candidate) == 0:
            return cast[int32](i)
        i = i + 1
    return -1


# Mask used to test the cpio mode-field's file-type bits. The high
# nibble is the type (S_IFREG = 0x8000, S_IFLNK = 0xA000, ...) — same
# layout Linux's stat(2) reports through st_mode.
_S_IFMT_MASK:  uint64 = 0xF000
_S_IFLNK_VAL: uint64 = 0xA000


def _lookup_name(name: Ptr[char]) -> int32:
    # Look up `name` in the cpio archive; if the matched entry is a
    # symlink, follow the chain (capped at 8 hops) to the target file.
    # Callers (initramfs_data_ptr / initramfs_data_size /
    # vfs_read tail / ...) get the *target's* index, so the symlink
    # is transparent to the rest of the kernel.
    #
    # This is the populated-distrofs path: scripts/build_initramfs.py
    # plants busybox once at /var/lib/distros/default/bin/busybox and
    # emits applet entries (/var/lib/distros/default/bin/sh, ...ls,
    # ...cat, ...) as S_IFLNK entries whose data is the absolute path
    # of the real busybox binary. Without this resolver, an open of
    # /var/lib/distros/default/bin/sh would return the symlink bytes
    # ("/var/lib/distros/default/bin/busybox") instead of the ELF.
    idx: int32 = _lookup_name_one(name)
    hops: int32 = 0
    while idx >= 0 and hops < 8:
        mode: uint64 = initramfs_entry_mode(cast[uint64](idx))
        if (mode & _S_IFMT_MASK) != _S_IFLNK_VAL:
            return idx
        # Symlink: data is the link target as a string. The build
        # script appends a NUL byte after the bytes covered by the
        # filesize, so we can treat it as a C-string and reuse the
        # plain exact-match lookup. (Linux's cpio writers also write
        # the NUL via the filesize.)
        target: Ptr[char] = cast[Ptr[char]](
            initramfs_entry_data(cast[uint64](idx)))
        idx = _lookup_name_one(target)
        hops = hops + 1
    # Either no match at all, or a symlink chain longer than 8 hops —
    # treat as "not found" so callers fail the open cleanly instead
    # of spinning.
    if hops >= 8:
        return -1
    return idx


def _alloc_fd(task: Ptr[TaskStruct]) -> int32:
    # CLONE_FILES: allocate from the SHARED table (owner) under its fd lock and
    # atomically RESERVE the found slot, so two threads racing to open fds get
    # DISTINCT numbers. The caller overwrites the reservation with the real
    # marker at install; an un-installed reservation self-heals at close/exit.
    owner: Ptr[TaskStruct] = fd_owner_task(task)
    spinlock_lock(&owner[0].fd_lock)
    i: uint64 = 0
    while i < cast[uint64](_VFS_NR_FDS):
        if owner[0].fd_idx[i] == FD_CLOSED_MARK:
            owner[0].fd_idx[i] = FD_RESERVED_MARK
            spinlock_unlock(&owner[0].fd_lock)
            return cast[int32](i)
        i = i + 1
    spinlock_unlock(&owner[0].fd_lock)
    return -1


def _cstr_len(s: Ptr[char]) -> uint64:
    i: uint64 = 0
    while s[i] != 0:
        i = i + 1
    return i


def _is_initramfs_dir(name: Ptr[char]) -> int32:
    # True if `name` is an implicit directory in the cpio archive —
    # i.e. some registered file's path begins with name + "/". Linux's
    # initramfs is flat (no D_TYPE entries; directories are inferred
    # from file paths), so this is how we synthesize "is /etc a dir?".
    # Special-case "/" — root is always a directory if anything is
    # registered.
    nlen: uint64 = _cstr_len(name)
    if nlen == 0:
        return 0
    if nlen == 1 and name[0] == 47:                  # "/"
        return 1
    count: uint64 = initramfs_entry_count()
    i: uint64 = 0
    while i < count:
        candidate: Ptr[char] = initramfs_entry_name(i)
        # Prefix-match name then look for '/' immediately after.
        k: uint64 = 0
        while k < nlen and candidate[k] != 0 and candidate[k] == name[k]:
            k = k + 1
        if k == nlen and candidate[k] == 47:         # '/'
            return 1
        i = i + 1
    return 0


def _cpio_listdir(name: Ptr[char], buf: Ptr[uint8],
                  count: uint64) -> int64:
    # Pack immediate children of `name` into buf as "BASENAME\n"
    # lines. `name` is the directory path WITHOUT a trailing slash
    # (e.g. "/etc"), or "/" for the archive root. Recursive
    # grandchildren collapse to their first path component so we
    # don't list "/etc/profile" twice for "/etc". A "NAME" only
    # appears once even if multiple files live below it.
    if count == 0:
        return 0
    nlen: uint64 = _cstr_len(name)
    is_root: int32 = 0
    if nlen == 1 and name[0] == 47:
        is_root = 1
    cnt: uint64 = initramfs_entry_count()
    out: uint64 = 0
    i: uint64 = 0
    while i < cnt:
        candidate: Ptr[char] = initramfs_entry_name(i)
        # Find the start of the basename within the cpio path.
        # For non-root dirs: must start with name + "/".
        # For root: candidate must start with "/" and we want the
        # first path component (everything between the leading "/"
        # and the next "/" or end).
        start: uint64 = 0
        keep: int32 = 0
        if is_root != 0:
            if candidate[0] == 47:
                start = 1
                keep = 1
        else:
            # Prefix match name + "/".
            k: uint64 = 0
            while k < nlen and candidate[k] != 0 \
                    and candidate[k] == name[k]:
                k = k + 1
            if k == nlen and candidate[k] == 47:
                start = nlen + 1
                keep = 1
        if keep != 0:
            # Compute the basename length (up to next '/' or NUL).
            blen: uint64 = 0
            while candidate[start + blen] != 0 \
                    and candidate[start + blen] != 47:
                blen = blen + 1
            if blen > 0:
                # Dedup: skip if we already emitted this name.
                if _dirbuf_contains(buf, out, candidate, start, blen) == 0:
                    if out + blen + 1 >= count:
                        return cast[int64](out)
                    j: uint64 = 0
                    while j < blen:
                        buf[out + j] = cast[uint8](
                            candidate[start + j] & 0xFF)
                        j = j + 1
                    buf[out + blen] = 10              # '\n'
                    out = out + blen + 1
        i = i + 1
    return cast[int64](out)


def _dirbuf_contains(buf: Ptr[uint8], buf_len: uint64,
                     candidate: Ptr[char], start: uint64,
                     blen: uint64) -> int32:
    # Walk buf (already-emitted "NAME\n" lines, length buf_len) and
    # return 1 if any line equals candidate[start..start+blen]. Used
    # by _cpio_listdir to collapse multiple grandchildren of a dir
    # ("/bin/ls" and "/bin/cat" both contribute "bin" under "/").
    p: uint64 = 0
    while p < buf_len:
        line_start: uint64 = p
        while p < buf_len and buf[p] != 10:
            p = p + 1
        line_len: uint64 = p - line_start
        if p < buf_len:
            p = p + 1                                  # skip '\n'
        if line_len == blen:
            k: uint64 = 0
            matched: int32 = 1
            while k < blen:
                if buf[line_start + k] != cast[uint8](
                        candidate[start + k] & 0xFF):
                    matched = 0
                    k = blen                           # break
                k = k + 1
            if matched != 0:
                return 1
    return 0


# ====================================================================
# F3 #448 — Plan-9-shape permission boundary (server-side enforcement).
# ====================================================================
#
# Pre-F3 model (docs/security.md Phase 5, pre-2026-06-11): the kernel had
# a global `_vfs_check_perm` that hard-coded the file paths it cared
# about (`/etc/shadow`, `/dev/blk/*`, `/var/lib/hpm/*`), the on-disk
# format it consulted (ext4 mode bits), a `uid==1` hostowner bypass, and
# a `vfs_auth_mediator_active` backdoor flag. That is the antithesis of
# Plan 9: the kernel had a literal-path policy funnel. Any new server
# added had to convince the kernel that ITS literal paths matter.
#
# F3 model (2026-06-11) + F10-2 #455 (2026-06-12): the kernel has no
# literal paths. Each file server enforces its OWN policy via a
# `<server>_perm_check` function THAT LIVES IN THE SERVER'S OWN .AD
# FILE, reached through a thin server-letter dispatcher in vfs.ad.
# The kernel vfs only knows "this path's owning server is X; ask X."
# Each server's policy is its own concern:
#
#   `#r` (cpio, fs/cpio.ad)       — _perm_check_cpio HERE (inline; the
#                                    cpio backend has no .ad of its own).
#                                    Reads consult per-entry mode bits;
#                                    writes categorically denied.
#   `#t` (tmpfs, fs/tmpfs.ad)     — tmpfs_perm_check in fs/tmpfs.ad.
#                                    World-r/w scratch (no per-file
#                                    owner storage in v1).
#   `#e` (ext4, fs/ext4.ad)       — ext4_perm_check in fs/ext4.ad
#                                    (delegated through the _perm_check_
#                                    ext4 shim that adapts the path).
#                                    Enforces on-disk inode mode bits.
#   `#f` (FAT, fs/fat.ad)         — fat_perm_check in fs/fat.ad.
#                                    World-r/w (no per-file POSIX
#                                    overlay in v1).
#   `#c` (devs, devcons.ad)       — devcons_perm_check in devcons.ad.
#                                    World-r/w on the stateless cdevs;
#                                    per-cdev hostowner knobs (wsys/ctl,
#                                    keymap write) gate inside the cdev.
#   `#b` (block, devblk.ad)       — devblk_perm_check in devblk.ad.
#                                    Hostowner-only (raw block devices
#                                    must never be a regular user's
#                                    reach surface).
#   `#p` (proc, devproc.ad)       — devproc_perm_check in devproc.ad.
#                                    Reads world-OK; writes to per-task
#                                    ctl/note/oom_score_adj require
#                                    caller_uid == target_uid OR
#                                    caller_uid == 1 (Linux nice rule).
#   `#s` (srv, devsrv.ad)         — devsrv_perm_check in devsrv.ad.
#                                    World-r/w (SYS_SRV_POST validates
#                                    the poster against the srvfd).
#   `#I` (net, devnet.ad)         — devnet_perm_check in devnet.ad.
#                                    World-r; per-conn writes world-OK;
#                                    host-level admin writes (dns pin,
#                                    ipifc/ctl, addr) require hostowner.
#   `#/` (root slot)              — no body; the bind IS the gate.
#                                    chan_permission_check returns 0
#                                    inline for this server code.
#   `#auth` (devauth.ad)          — devauth_perm_check in devauth.ad.
#                                    World-r/w on the wire (anyone has
#                                    to be able to authenticate);
#                                    rate-limit + constant-time compare
#                                    inside the cdev are the real gate.
#
# F10-2 #455 also added SERVER_UNKNOWN: paths the dispatcher can't
# route to a known server (an `#X` letter not in the table) return
# EPERM_PERM by default. Pre-F10-2 such paths fell through to devs
# (world-r/w), which the audit flagged as a silent grant.
#
# `/etc/shadow`, `/var/lib/hpm/`, the `uid==1` global bypass, and
# `vfs_auth_mediator_active` are GONE from the kernel. The credential
# mediator (sys/src/9/port/devauth.ad) reads `/etc/shadow` through a
# kernel-context helper (`vfs_open_kernel`) whose existence IS the
# explicit-by-construction statement that this caller is the credentials
# server. The /etc/shadow file's hostowner-only protection now lives
# where it should: in the ext4 backend's mode-bit enforcement (the file
# ships 0600 hostowner-owned, and ext4 mode-bit policy denies anyone
# else). If a future deployment re-homes /etc/shadow to a non-ext4
# server, that server's perm policy is what enforces the access — not
# a literal-path arm in the kernel.
#
# The dispatcher (`chan_permission_check`) is the kernel-side of the
# Plan 9 "permissions live at the attached server" invariant. Long term
# (post-F3), the dispatcher becomes a chan-method (a function pointer
# on the chan's owning server's devtab) so user-side file servers can
# enforce policy through the same path; for now the policy table is
# co-located in vfs because every backend Hamnix has today is
# kernel-side and the per-server functions need the kernel-internal
# backend handles. The KEY semantic change has already landed:
# *no path in this kernel decides what a server's policy is.*

PERM_R: int32 = 4
PERM_W: int32 = 2
PERM_X: int32 = 1

# We use a fresh EPERM_PERM constant (-1 == EPERM in Linux) instead of
# the existing EBADF / ENOENT family — none of those map; vfs.ad's
# legacy "small negative ints" convention reuses Linux signs (EPERM=-1).
EPERM_PERM: int32 = -1


# --- per-server policy helpers --------------------------------------
#
# Each `_perm_check_<server>` returns 0 on grant, EPERM_PERM on denial.
# The dispatcher (`chan_permission_check`) selects which to call based
# on which file server owns the resolved path. NO server policy here
# consults paths outside its own surface.

def _perm_check_cpio(name: Ptr[char], want: int32,
                     caller_uid: uint32, caller_gid: uint32) -> int32:
    # `#r` cpio (initramfs) — baked at build time, read-only at runtime
    # (no mutating ops exist in fs/cpio.ad). Writes are categorically
    # refused. Reads consult the per-entry mode bits stored in the cpio
    # header (initramfs_entry_mode): /etc/shadow ships 0600 in the cpio
    # build (scripts/build_initramfs.py honours the host mode); /bin/*
    # ships 0755; everything else defaults 0644. Owner is hostowner
    # (uid 1) for every cpio entry (cpio entries don't carry owner uid;
    # we treat them as hostowner-owned by build-time convention).
    if (want & PERM_W) != 0:
        # vfs_open_write would surface this as EROFS at the backend
        # anyway; returning EPERM here keeps the boundary explicit (a
        # write attempt is a policy denial, not just an ROFS accident).
        return EPERM_PERM
    # Lookup the cpio mode. If the path arrives in the `#r/<rest>` form
    # (post-ns_walk for the cpio root), trim the prefix so cpio's name
    # table (which stores absolute paths verbatim) matches. A literal
    # absolute path arriving here (early-boot kernel-direct call) looks
    # up unchanged. If the entry doesn't exist, defer ENOENT to the open
    # path — don't deny.
    lookup_name: Ptr[char] = name
    if name[0] == 35 and name[1] == 114:                   # "#r"
        # "#r" alone -> "/", "#r/<rest>" -> "/<rest>", "#r" + non-slash
        # is a multi-char word and should not arrive at this server.
        if name[2] == 0:
            lookup_name = cast[Ptr[char]]("/")
        elif name[2] == 47:                                # '/'
            lookup_name = cast[Ptr[char]](
                cast[uint64](name) + 2)                    # past "#r"
    idx: int32 = _lookup_name(lookup_name)
    if idx < 0:
        return 0
    f_mode: uint64 = initramfs_entry_mode(cast[uint64](idx))
    f_mode9: uint16 = cast[uint16](f_mode & 0x1FF)         # low 9 bits
    # Hostowner-owned by convention; pick the right triple by uid.
    bits: int32 = 0
    f_uid: uint32 = 1
    f_gid: uint32 = 1
    if caller_uid == f_uid:
        bits = cast[int32]((f_mode9 >> 6) & 0x7)
    elif caller_gid == f_gid:
        bits = cast[int32]((f_mode9 >> 3) & 0x7)
    else:
        bits = cast[int32](f_mode9 & 0x7)
    if (bits & want) == want:
        return 0
    return EPERM_PERM


# F10-2 #455: every `_perm_check_<X>` body now lives in its OWN server's
# file. These thin shims in vfs.ad call the moved function so a reader
# looking for "what does server X admit?" finds it next to server X's
# data path, not in the kernel chokepoint. The vfs side stays the
# single dispatcher entry point (chan_permission_check below).
#
#  Server letter  Policy lives in                            Function
#  -------------  ----------------------------------------   --------
#   #r cpio       _perm_check_cpio (fs/vfs.ad, inline; the
#                 cpio backend imports nothing back from vfs
#                 — the mode-bit lookup is inline here).
#   #t tmpfs      fs/tmpfs.ad                                tmpfs_perm_check
#   #e ext4       fs/ext4.ad                                 ext4_perm_check
#   #f FAT        fs/fat.ad                                  fat_perm_check
#   #c devs       sys/src/9/port/devcons.ad                  devcons_perm_check
#   #b block      sys/src/9/port/devblk.ad                   devblk_perm_check
#   #p proc       sys/src/9/port/devproc.ad                  devproc_perm_check
#   #s srv        sys/src/9/port/devsrv.ad                   devsrv_perm_check
#   #I net        drivers/net/devnet.ad                      devnet_perm_check
#   #auth         sys/src/9/port/devauth.ad                  devauth_perm_check
#   #/ rootslot   (no body — the bind is the gate; inline
#                 no-op in chan_permission_check below).
#
# Numeric contract is shared: each `<server>_perm_check` returns 0 on
# grant, -1 on deny (EPERM_PERM in vfs's space). PERM_R=4 | PERM_W=2 |
# PERM_X=1 in `want`. None of the server bodies import fs.vfs to pick
# up these constants — the contract is documented in docs/security.md
# and reproduced in each body's comment header.


def _perm_check_ext4(name: Ptr[char], want: int32,
                     caller_uid: uint32, caller_gid: uint32) -> int32:
    # `#e` ext4 — delegate to the ext4 backend. The on-disk uid/gid +
    # 9 mode bits are an ext4 implementation detail; vfs only routes.
    # See fs/ext4.ad::ext4_perm_check for the actual policy.
    leaf: Ptr[char] = vfs_fs_rel(name)
    return ext4_perm_check(leaf, want, caller_uid, caller_gid)


# --- the dispatcher --------------------------------------------------
#
# chan_permission_check identifies the owning server for `name` and
# delegates to that server's policy. THIS IS THE ONLY POLICY DECISION
# IN VFS. The dispatcher itself has NO knowledge of literal paths
# beyond "what server letter does this path belong to" — which is the
# same routing already done by the `#X` device-alias dispatch in
# vfs_open. Path-prefix matches (`/dev/blk/`, `/dev/auth`) here are
# server-letter routing, NOT policy.

# F10-2 #455: SERVER_UNKNOWN is a sentinel for paths the dispatcher
# can't route to a known server. The default branch of
# _path_owning_server returns SERVER_UNKNOWN (was: cpio fallthrough),
# and chan_permission_check maps it to EPERM_PERM — defense-in-depth
# against an unrecognised path reaching the gate. The existing FS-kind
# lookup (vfs_fs_kind) handles paths the namespace resolved to a
# concrete backend; only a path that doesn't match an `#X` letter and
# doesn't fit a known FS-kind reaches the trap.
SERVER_UNKNOWN: int32 = 0

# Phase D follow-up: per-backend stat hooks (do_stat dispatcher in
# sys/src/9/port/sysfile.ad). The server-code constants below mirror
# the integers returned by _path_owning_server so the do_stat ladder
# can switch on a SERVER_* symbol instead of a bare integer. The codes
# stay numerically frozen (0..11) — _path_owning_server's chained ifs
# return these directly.
SERVER_CPIO:   int32 = 1
SERVER_TMPFS:  int32 = 2
SERVER_EXT4:   int32 = 3
SERVER_FAT:    int32 = 4
SERVER_DEVS:   int32 = 5
SERVER_BLOCK:  int32 = 6
SERVER_PROC:   int32 = 7
SERVER_SRV:    int32 = 8
SERVER_NET:    int32 = 9
SERVER_AUTH:   int32 = 10
SERVER_ROOT:   int32 = 11
# F10-5 #460: audio surface carved out of the generic `#c` devs body
# (SERVER_DEVS) into its own server boundary. Routes `#c/audio`,
# `#c/audioctl`, `#c/audioin` (and the userland-conventional `/dev/audio*`
# spellings) to devaudio_perm_check in drivers/audio/audio_cdev.ad.
SERVER_AUDIO:  int32 = 12


def vfs_path_owning_server(name: Ptr[char]) -> int32:
    # Public re-export of the F10-2 server-routing decision. The
    # underscore-prefixed _path_owning_server is module-private; this
    # wrapper lets the do_stat / do_fstat dispatchers in sysfile.ad
    # mirror the F10-2 perm-check shape (one ladder, per-backend
    # hooks) without duplicating the path-prefix logic.
    return _path_owning_server(name)


def _path_owning_server(name: Ptr[char]) -> int32:
    # Returns a small integer naming the owning server. Stable codes so
    # the dispatch can be a switch (Adder-style chained ifs). The codes
    # are local to this file. ALL post-ns_walk paths are absolute, so a
    # name beginning with `#X` is the explicit server letter; otherwise
    # the prefix decides.
    #
    #   0 = SERVER_UNKNOWN  (default-deny trap)
    #   1 = cpio (#r)
    #   2 = tmpfs (#t)
    #   3 = ext4 (#e)
    #   4 = FAT (#f)
    #   5 = devs (#c)
    #   6 = block (#b)
    #   7 = proc (#p)
    #   8 = srv (#s)
    #   9 = net (#I)
    #  10 = auth (#auth, surfacing as /dev/auth)
    #  11 = root slot (#/)
    #
    # Block devices (`/dev/blk/<...>`) and /dev/auth take their own
    # codes because their policy is sharper than generic devs.

    # `#X` explicit server letter form.
    if name[0] == 35:                                  # '#'
        c: int32 = name[1]
        # F10-2 #455: multi-char `#<word>` named roots (`#sysroot`,
        # `#distro`, `#home`, `#tmp`, `#by-id`, `#root`, ...) are NOT
        # server letters — they're an indirection layer that
        # _open_hash_long resolves to an underlying ext4 (or other)
        # path before the perm gate fires there. The single-letter
        # routing below would mis-attribute `#home/...` to a wrong
        # server letter (or, post-F10-2, to SERVER_UNKNOWN); admit
        # world here and let the resolved-server's gate fire when the
        # path lands on a real backend. The detection is "the second
        # char after `#` is neither NUL nor '/'".
        nxt: int32 = name[2]
        if nxt != 0 and nxt != 47:
            return 11                                  # rootslot: no-op gate
        if c == 114:                                   # 'r' (cpio)
            return 1
        if c == 116:                                   # 't' (tmpfs)
            return 2
        if c == 101:                                   # 'e' (ext4)
            return 3
        if c == 102:                                   # 'f' (FAT)
            return 4
        if c == 99:                                    # 'c' (devs)
            # `#c/auth[/...]` — credential mediator on the `#c` dev
            # server's auth leaf. Reaches the same `#auth` policy as a
            # literal `/dev/auth` open arriving at the dispatcher.
            if name[2] == 47 and name[3] == 97 and name[4] == 117 \
                    and name[5] == 116 and name[6] == 104 \
                    and (name[7] == 0 or name[7] == 47):  # /auth or /auth/
                return 10
            # `#c/blk[/...]` — raw block surface on the `#c` server's
            # blk leaf. Routes through devblk's hostowner-only policy.
            if name[2] == 47 and name[3] == 98 and name[4] == 108 \
                    and name[5] == 107 \
                    and (name[6] == 0 or name[6] == 47):  # /blk or /blk/
                return 6
            # F10-5 #460: `#c/audio`, `#c/audioctl`, `#c/audioin` route
            # through devaudio_perm_check (audio_cdev.ad), not the generic
            # devs body. Match `#c/audio` then accept NUL (exact), or 'c'
            # ('ctl' = audioctl) or 'i' ('in' = audioin) as the byte
            # following the shared "audio" prefix.
            if name[2] == 47 and name[3] == 97 and name[4] == 117 \
                    and name[5] == 100 and name[6] == 105 \
                    and name[7] == 111:                # /audio
                t: int32 = name[8]
                if t == 0:
                    return 12                          # #c/audio
                if t == 99 and name[9] == 116 and name[10] == 108 \
                        and name[11] == 0:             # /audioctl
                    return 12
                if t == 105 and name[9] == 110 and name[10] == 0:
                    return 12                          # /audioin
                # Anything else under `#c/audio…` falls through to devs.
            return 5
        if c == 98:                                    # 'b' (block)
            return 6
        if c == 112:                                   # 'p' (proc)
            return 7
        if c == 115:                                   # 's' (srv)
            return 8
        if c == 73:                                    # 'I' (net)
            return 9
        if c == 47:                                    # '/' (root slot)
            return 11
        # `#d` (HAMSH §7 fd) is a single-letter server too: HAMSH §7
        # treats /fd/N as a per-Pgrp fd-name table; the policy is the
        # generic devs policy (world-r/w, gated at the leaf).
        if c == 100:                                   # 'd' (HAMSH fd)
            return 5
        # #442: `#w` is the per-process windowing-server letter (rio-shape).
        # resolve_path rewrites `#w<rest>` to `#c/wsys/<caller-wid><rest>`
        # BEFORE the path reaches this perm gate, so in steady state we
        # never see a literal `#w` here — every `#w` open lands on `#c`
        # downstream and uses devs (5) policy at the leaf. Treat any stray
        # `#w` that does reach the gate (early-boot, future direct opens)
        # as the same devs-shape world-r/w surface so the perm path stays
        # safe-by-default rather than denying.
        if c == 119:                                   # 'w' (per-process wsys)
            return 5
        # F10-2 #455: any other letter is an UNKNOWN server. Pre-F10-2,
        # the catch-all here was `return 5` (devs world-r/w). That
        # let a fabricated `#X/...` for any letter X reach devcons's
        # world-OK admission, which is exactly the audit's "silent
        # grant" finding for unrecognised paths. Now: deny by default.
        return SERVER_UNKNOWN
    # /dev/blk/* — raw block devices.
    if name[0] == 47 and name[1] == 100 and name[2] == 101 \
            and name[3] == 118 and name[4] == 47:      # /dev/
        if name[5] == 98 and name[6] == 108 and name[7] == 107 \
                and name[8] == 47:                     # blk/
            return 6
        # /dev/auth — credential mediator.
        if name[5] == 97 and name[6] == 117 and name[7] == 116 \
                and name[8] == 104 \
                and (name[9] == 0 or name[9] == 47):   # auth or auth/
            return 10
        # F10-5 #460: /dev/audio, /dev/audioctl, /dev/audioin route to
        # devaudio_perm_check. Kept here in addition to the `#c/audio*`
        # arm above so a kernel-direct or pre-resolve_path caller
        # (early-boot, kernel-mediated) still lands on the audio gate.
        if name[5] == 97 and name[6] == 117 and name[7] == 100 \
                and name[8] == 105 and name[9] == 111:  # /dev/audio
            t2: int32 = name[10]
            if t2 == 0:
                return 12                              # /dev/audio
            if t2 == 99 and name[11] == 116 and name[12] == 108 \
                    and name[13] == 0:                 # /dev/audioctl
                return 12
            if t2 == 105 and name[11] == 110 and name[12] == 0:
                return 12                              # /dev/audioin
        return 5
    # Filesystem-prefix routing for paths that didn't get `#X`-rewritten
    # by the caller (kernel-direct opens during early boot, kernel-
    # mediated reads, vfs_link/vfs_symlink with raw user paths, ...).
    # Use the existing FS-kind lookup; the longest-prefix match resolves
    # /tmp/foo to tmpfs, /ext/foo to ext4, /mnt/foo to FAT, and ANY other
    # absolute path to the "/" cpio root mount.
    fk: uint32 = vfs_fs_kind(name)
    if fk == FS_KIND_EXT4:
        return 3
    if fk == FS_KIND_TMPFS:
        return 2
    if fk == FS_KIND_FAT:
        return 4
    if fk == FS_KIND_CPIO:
        # vfs_fs_kind returns FS_KIND_CPIO ONLY when the "/" root mount
        # claims the path (longest-prefix). This is the legitimate
        # "everything else under /" arm: cpio's per-entry mode-bit check
        # (_perm_check_cpio) gates the actual decision. A path the cpio
        # archive doesn't contain is deferred (idx<0 -> 0 grant) so the
        # backend surfaces ENOENT — that's the cpio policy, not a vfs
        # decision.
        return 1
    # F10-2 default-deny: a path that doesn't match any known prefix and
    # doesn't fit a known FS-kind is routed nowhere. chan_permission_check
    # maps SERVER_UNKNOWN to EPERM_PERM.
    return SERVER_UNKNOWN


def chan_permission_check(name: Ptr[char], want: int32) -> int32:
    # F3 #448: the server-boundary perm gate. The dispatcher identifies
    # the owning server and delegates to that server's policy. NO
    # literal `/etc/shadow` arm. NO `uid==1` global bypass. NO mediator
    # backdoor flag. Each server enforces its own rules.
    #
    # F10-2 #455: every per-server `_perm_check_<X>` body now lives in
    # the server's own .ad file (see the table comment above). The
    # dispatcher calls the moved function. Servers that need uid
    # context (devblk, devproc, devnet, ext4) receive caller_uid as a
    # parameter so they don't need to back-import from fs.vfs.
    #
    # The historical `uid==1` hostowner bypass IS retained at the
    # dispatcher level for the on-disk servers (ext4/tmpfs/cpio) — the
    # cpio /etc/shadow ships mode 0600 hostowner-owned and a literal
    # mode-bit denial would lock hostowner out of its own credentials.
    # Other servers either implement their own uid policy
    # (devblk: hostowner-only; devproc: caller==target OR caller==1;
    # devnet: host-level writes require hostowner) or admit world
    # (tmpfs/fat/devcons/devsrv/devauth) — see each server's body.
    # cgroup v2 (/sys/fs/cgroup) is a Linux-ABI pseudo file server with
    # its OWN admission policy — it must be classified BEFORE the prefix
    # routing below, which would mis-attribute it to the cpio (`#r`) root
    # (cgroup paths resolve under the `#r`-bound /sys) and categorically
    # DENY every write. The cgroupfs server admits: reads on any cgroup
    # interface file (world-OK, like /proc); writes on a real control
    # leaf (pids.max/memory.max/cpu.max/cgroup.procs) of an existing
    # cgroup. Anything else under /sys/fs/cgroup that isn't a writable
    # control leaf falls through to the cpio gate (so a stray write
    # ENOENTs / EROFS as before).
    if is_cgroup_path(name) != 0:
        if (want & PERM_W) == 0:
            return 0                        # reads: world-OK
        if cgroup_fs_is_writable_leaf(name) != 0:
            return 0                        # control-leaf write: admit
        # else fall through to the cpio policy below.
    cu: uint32 = current_task_uid()
    cg: uint32 = current_task_gid()
    s: int32 = _path_owning_server(name)
    # F10-2 default-deny: SERVER_UNKNOWN is the conservative trap for
    # unrecognised paths. This is the same EPERM_PERM verdict the
    # bottom-of-function "unknown server letter" branch returned, but
    # made symbolic so any future routing addition has to consciously
    # OPT-IN by returning a known server code from _path_owning_server.
    if s == SERVER_UNKNOWN:
        return EPERM_PERM
    # Per-server policy dispatch.
    if s == 1:
        # cpio. Hostowner bypass admitted (the cpio /etc/shadow ships
        # mode 0600 hostowner-owned; UID_HOSTOWNER reads through
        # without consulting mode bits). Writes are categorically denied
        # even for hostowner — cpio is baked, you can't write it. The
        # mode-bit policy at _perm_check_cpio applies to all other uids.
        if cu == UID_HOSTOWNER and (want & PERM_W) == 0:
            return 0
        return _perm_check_cpio(name, want, cu, cg)
    if s == 2:
        return tmpfs_perm_check(name, want)
    if s == 3:
        # ext4 — hostowner bypass applies (the on-disk mode for
        # /etc/shadow is 0600 hostowner-owned; UID_HOSTOWNER should
        # pass without consulting mode bits).
        if cu == UID_HOSTOWNER:
            return 0
        return _perm_check_ext4(name, want, cu, cg)
    if s == 4:
        return fat_perm_check(name, want)
    if s == 5:
        return devcons_perm_check(name, want)
    if s == 6:
        # block — devblk owns the hostowner-only rule (moved to
        # sys/src/9/port/devblk.ad as devblk_perm_check, called here).
        return devblk_perm_check(name, want, cu)
    if s == 7:
        # proc — devproc owns the per-task uid gate (caller_uid ==
        # target_uid OR caller_uid == 1) for writes; reads world-OK.
        # Moved to sys/src/9/port/devproc.ad as devproc_perm_check.
        return devproc_perm_check(name, want, cu)
    if s == 8:
        return devsrv_perm_check(name, want)
    if s == 9:
        # net — devnet owns the host-level admin-write gate; reads + per-
        # conn writes world-OK. Moved to drivers/net/devnet.ad.
        return devnet_perm_check(name, want, cu)
    if s == 10:
        return devauth_perm_check(name, want)
    if s == 11:
        # `#/` root slot — the bind is the gate; no per-file policy.
        return 0
    if s == 12:
        # F10-5 #460: audio — devaudio owns the per-cdev gate (world r/w
        # today; a future `master mute` admin gate would add an
        # _is_admin_path arm IN audio_cdev.ad, not here).
        return devaudio_perm_check(name, want)
    # Defense-in-depth: an unrecognized internal code (shouldn't happen
    # — _path_owning_server returns 0..11) is treated as UNKNOWN.
    return EPERM_PERM


def _vfs_perm_set_errstr(name: Ptr[char]):
    set_current_errstr("permission denied")


def vfs_perm_check_exec(name: Ptr[char]) -> int32:
    # Public wrapper used by the exec syscall path (arch/x86/kernel/
    # syscall.ad::do_execve). Returns 0 on grant, EPERM_PERM (-1) on
    # denial. The caller surfaces the -1 as -EPERM to userland. Reaches
    # the server-boundary dispatcher with PERM_X.
    #
    # F10-1 (#454): resolve through the calling Pgrp first so the perm
    # dispatch routes on the resolved `#X/...` form (same as vfs_open).
    # A non-resolvable path (unbound) returns ENOENT here, which surfaces
    # as -EPERM at the caller (no observable behaviour change for valid
    # paths in default Pgrps).
    resolved: Array[256, uint8]
    rrc: int32 = resolve_path(name, &resolved[0], 256)
    if rrc != 0:
        return rrc
    return chan_permission_check(cast[Ptr[char]](&resolved[0]), PERM_X)


# --- kernel-mediator credential read --------------------------------
#
# F3 #448: replace `vfs_auth_mediator_active` (the global backdoor flag
# devauth used to toggle around its /etc/shadow open) with an explicit
# kernel-context credential-read primitive. The CALLER (devauth.ad) is
# the kernel-side credentials server; reaching this entry point IS the
# capability — there is no path from userland that can call it without
# already being in kernel context inside the auth-server path.
#
# This is the in-kernel embodiment of the Plan-9 factotum invariant:
# the credentials server is privileged-by-construction, not by-flag.
# A follow-up agent (post-F3) replaces this with a userland factotum at
# `/srv/factotum` consuming the same wire shape devauth speaks today;
# when that lands, devauth either becomes a thin shim to the factotum
# server's posted srvfd or goes away. The wire shape is documented at
# docs/security.md "Factotum (planned, F3 follow-up)".

def vfs_open_kernel(name: Ptr[char]) -> int32:
    # Kernel-context open that bypasses the server-boundary perm gate.
    # ONLY the kernel credentials server (sys/src/9/port/devauth.ad)
    # may call this. No userland reach path exists.
    #
    # F10-1 (#454): resolve through the CALLER's Pgrp so the F1 substrate
    # gate fires here too — devauth, coredump and other kernel-mediator
    # callers all run on behalf of a user task and inherit its
    # namespace. The literal `/etc/shadow` arm devauth used to invoke
    # this with arrived already-resolved (devauth ran resolve_path
    # itself); this re-resolve is idempotent in the DEFAULT login Pgrp
    # (`/` -> `#r` localizes back to `/etc/shadow`).
    resolved: Array[256, uint8]
    rrc: int32 = resolve_path(name, &resolved[0], 256)
    if rrc != 0:
        return rrc
    return _vfs_open_post_perm(cast[Ptr[char]](&resolved[0]))


def vfs_open_write_kernel(name: Ptr[char]) -> int32:
    # Kernel-context write-open that bypasses the perm gate. Same
    # callers as vfs_open_kernel above (devauth's setpass path).
    # F10-1: resolve through the caller's Pgrp; see vfs_open_kernel.
    resolved: Array[256, uint8]
    rrc: int32 = resolve_path(name, &resolved[0], 256)
    if rrc != 0:
        return rrc
    kfd: int32 = _vfs_open_write_post_perm(cast[Ptr[char]](&resolved[0]))
    # dcache: a kernel write-open may create the file too — invalidate any
    # stale negative dentry (see vfs_open_write).
    if kfd >= 0:
        fcache_dcache_bump_gen()
    return kfd


def vfs_open(name: Ptr[char]) -> int32:
    # F3 #448: server-boundary perm gate. chan_permission_check identifies
    # the owning server and delegates to that server's policy — NO literal
    # paths in vfs, NO `uid==1` global bypass beyond what each server
    # admits. On grant, the body executes through _vfs_open_post_perm
    # (factored so the kernel-mediator entry point vfs_open_kernel can
    # share it without re-asking the gate).
    #
    # F10-1 (#454): resolve through the calling Pgrp's mount table FIRST,
    # so the F1 substrate "unbound = ENOENT" gate runs once at the top
    # and the resolved `#X/...` form is what chan_permission_check
    # routes on. The legacy SYS_OPEN-arm resolve_path is gone (the gate
    # now lives here), so this resolve sees the user's exact bytes —
    # never a doubly-resolved path. _vfs_open_post_perm is called with
    # the resolved name (no inner resolve_path).
    resolved: Array[256, uint8]
    rrc: int32 = resolve_path(name, &resolved[0], 256)
    if rrc != 0:
        return rrc
    rname: Ptr[char] = cast[Ptr[char]](&resolved[0])
    pc_rc: int32 = chan_permission_check(rname, PERM_R)
    if pc_rc != 0:
        _vfs_perm_set_errstr(rname)
        return pc_rc
    fd: int32 = _vfs_open_post_perm(rname)
    # Phase D follow-up: stamp the per-fd opened-path slot with the
    # post-resolve_path bytes so fd2path(2) can return the EXACT path
    # the caller's namespace resolved (binds reflect correctly: an
    # /dev/null open through `bind '#c' /dev` records `#c/null`, the
    # localized server form). Only on a successful install — a negative
    # rc means no slot was claimed in the caller's table.
    if fd >= 0:
        task: Ptr[TaskStruct] = fd_owner_task(current_task())
        task_fd_set_opened_path(task, cast[uint64](fd), &resolved[0])
    return fd


def _vfs_open_post_perm(name: Ptr[char]) -> int32:
    # F10-1 (#454): the namespace-resolved post-perm body. The caller
    # (vfs_open or vfs_open_kernel) has ALREADY run resolve_path through
    # the calling task's Pgrp, so `name` here is the resolved
    # backend-key form — either `#X/...` (foreign server letter) or a
    # localized absolute path (our `#r/#t/#e/#f` servers). The literal
    # /dev/<leaf> arm in namec's _devtab_lookup is gone (it keyed the
    # `#c/<leaf>` form post-F10-1), so a Pgrp without `#c` bound to /dev
    # ENOENTs in resolve_path before reaching here — exactly the F1
    # substrate invariant.
    rname: Ptr[char] = name
    # cgroup v2 OREAD: a cgroup interface file resolves to the localized
    # "#r/fs/cgroup/..." spelling (cpio has no such file, so resolve's
    # union-head fallback localizes under `#r`). MUST be checked BEFORE
    # the `#`-alias arm below, which would route it to the cpio server
    # and ENOENT. _open_cgroup renders a per-fd snapshot for a known
    # interface file (root files AND nested per-cgroup leaves) and
    # returns ENOENT (fall through) for anything else under the prefix.
    if is_cgroup_path(rname) != 0:
        cgr: int32 = _open_cgroup(rname)
        if cgr != ENOENT:
            return cgr
    # V3.5: Plan 9 `#X` device-alias dispatch. Userspace `init` does
    # the boot-time `bind '#s' /srv` etc. so opens of conventional
    # paths arrive here as `#X/...` (post-ns_walk rewrite);
    # but the kernel surface also accepts direct `#X` opens for the
    # boot-strapping init itself, which has to call `bind` BEFORE any
    # `/srv` route exists. The dispatch lives at the top of vfs_open
    # so it shadows any conventional path the user might have planted
    # at the same name. See _open_hash_alias for the per-letter routing
    # (#s, #p, #c, #/).
    if rname[0] == 35:                                 # '#'
        return _open_hash_alias(rname, 0)              # OREAD
    # /dev/null and /dev/zero are stateless synthetic cdevs (DEV_NULL /
    # DEV_ZERO) served by the namec devtab — they route through the
    # _namec_open probe below like the rest of the stateless cdev family
    # (/dev/cons, /dev/time, ...). No literal pre-probe match here.
    # F9 #452 (namespace-purity): the literal `/dev/auth` pre-probe arm
    # that USED to live here is GONE. /dev/auth is now matched by namec's
    # devtab (NAMEC_NEEDS_AUTH sentinel) and _namec_open routes the
    # stateful AuthSlot allocation back through _open_auth_marked. A
    # process whose namespace has no `bind '#c' /dev` won't see
    # `/dev/auth` at all — the devtab match fires only after the
    # per-Pgrp namespace makes the path reachable, matching the same
    # pattern as /dev/cons et al.
    # §fuse: /dev/fuse — open a FUSE connection fd. A userspace daemon (or
    # the in-kernel selftest daemon role) opens this, runs the FUSE_INIT
    # handshake, mounts a target prefix, and serves a filesystem the VFS
    # reads through. Routed BEFORE namec because /dev/fuse is a per-fd
    # stateful cdev (connection slot) with no namec devtab entry, same
    # rationale as the (now-retired) /dev/auth arm above.
    #
    # F9 #452 DEFERRED-to-F4: The audit lists /dev/fuse as a residual
    # literal-path arm. Per F4 #449's "linux_abi is not a leaf" finding,
    # fuse is wholly a Linux-ABI concern (linux_abi/u_fuse.ad owns the
    # connection-slot pool; no native caller opens /dev/fuse — grep of
    # init/user/lib confirms). F4's hook-table inversion plan will
    # register fuse's path + open helper from linux_abi at boot time,
    # eliminating this literal arm without a back-import from namec into
    # linux_abi. Leaving in place for F4 to lift; tagged for
    # discoverability.
    # F4 #449: /dev/fuse, /dev/ptmx, /dev/pts/<N> are wholly Linux-ABI
    # paths. The literal arms that used to live here (and the F9-tagged
    # /sys/fs/cgroup arm below) are dispatched through the single
    # l2_path_open_hook the Layer-2 init plants. A pure-native build
    # leaves the hook null; none of these paths resolves anywhere then,
    # which is correct (no Layer-2 fd kinds in that image). Accmode 0
    # = OREAD (the read path).
    if l2_path_open_hook != cast[Fn[int32, Ptr[char], int32]](0):
        l2_rfd: int32 = l2_path_open_hook(rname, 0)
        if l2_rfd != L2_PATH_NOT_HANDLED:
            return l2_rfd
    # Phase D: the universal namec open path. namec() walks the
    # calling process's Pgrp mount table; if `name` falls under a 9P
    # SRV-kind mount it produces a mounted-9P Chan, and if `name` is a
    # well-known local cdev (/dev/cons, /dev/time, /dev/pid,
    # /dev/random, /dev/mouse, /dev/cpuinfo, /dev/meminfo, /dev/uptime,
    # /dev/loadavg, /dev/version, /dev/hostname, /dev/stat, /dev/mounts,
    # /dev/diskstats) it produces a local-device Chan — the SAME Chan
    # type either way. _namec_open installs ONE FD_CHAN_MARK fd; the
    # consumer (vfs_read / vfs_write) dispatches it back through
    # namec_read / namec_write, which route devtab vs. mountrpc
    # internally. This single probe REPLACES the dozen
    # _open_dev_marked(FD_<NAME>_MARK) cdev arms AND the old
    # _try_open_p9 arm — the Plan 9 inversion. A P9_NO_MOUNT result
    # means namec does not own this path; we fall through to the
    # on-disk routing below.
    #
    # Ordering: this sits AFTER the `#X`-alias and /dev/null,/dev/zero
    # arms (those are not namec devtab entries) but BEFORE every
    # on-disk route, so a mount or a cdev shadows a same-named local
    # file exactly as Plan 9's namec walk does.
    chan_fd: int32 = _namec_open(rname, 0)             # OREAD
    if chan_fd != P9_NO_MOUNT:
        return chan_fd
    # /dev/blk/<name>{,/size,/ctl} (block-device cdev) and /dev/loop/ctl
    # (loop-device control) are served by the `#b` block server and the
    # `#c` /dev server respectively — `bind '#b' /dev/blk` rewrites a
    # /dev/blk/<name> open to `#b/<name>` (handled in the `#`-arm above
    # via devblk_leaf_match), and `bind '#c' /dev` rewrites /dev/loop/ctl
    # to `#c/loop/ctl` (resolved by _open_dev_leaf's namec devtab probe —
    # DEV_LOOPCTL). The legacy literal path arms that used to sit here
    # are GONE: all /dev access is namespace-resolved.
    # ARCH §10: the /net 9P file tree is a bound `#I` IP device server
    # (`bind '#I' /net` in etc/rc.boot). An open of /net/tcp/clone etc.
    # is rewritten to `#I/tcp/clone` by ns_walk and handled
    # by the `#`-dispatch arm at the top of this function — there is no
    # literal /net string-match here anymore.
    # V3.5: the V3-era `/srv`, `/srv/<name>`, `/n` direct routing arms
    # are gone. Those paths now come in here as `#s`, `#s/<name>`,
    # `#/` (rewritten by ns_walk after the userspace init
    # planted `bind '#s' /srv`, `bind '#/' /n`), and dispatch via the
    # `#`-prefix arm at the top of this function.
    # /proc is a bound `#p` proc device server (`bind '#p' /proc` in
    # etc/rc.boot). An open of /proc/<pid>/<file> (per-process devproc
    # introspection) or /proc/<static> (version/uptime/cpuinfo/.../kmsg
    # rendered by procfs.ad) arrives here rewritten to `#p/...` by
    # ns_walk and is handled by the `#`-dispatch arm at the
    # top of this function (letter 'p' -> _open_hash_proc, which fans
    # back out to devproc_open vs _open_proc). The legacy literal
    # devproc_path_match / is_proc_path arms that used to sit here are
    # GONE — all /proc access is namespace-resolved, never a strcmp.
    # /sys/fs/cgroup/* — cgroup v2 (unified) interface files for the
    # Linux namespace. Rendered into a per-fd kmalloc'd snapshot up
    # front, identical mechanism to _open_proc; the resulting fd is
    # read-only and walks the buffer. Routed here so stock Debian/
    # systemd userland that probes /sys/fs/cgroup finds it. The
    # cgroup2 view is Linux-ABI furniture; native resource control
    # stays Plan-9-shape (devnscap.ad, #174) and is NOT routed here.
    #
    # F4 #449: /sys/fs/cgroup/* is folded into the same single l2_path_open_hook
    # dispatch above (the linux_abi side checks the prefix and snapshots
    # the cgroup view, or returns L2_PATH_NOT_HANDLED for an unknown
    # file so the on-disk fall-through still runs). The literal
    # `is_cgroup_path` pre-namec arm that lived here is GONE.
    # /sys/devices/system/node/* — NUMA node topology for numactl/numastat/
    # libnuma. Single-node (node 0) view, rendered into a per-fd snapshot the
    # same way as cgroup2. Linux-ABI furniture; the native model has no NUMA.
    if is_node_path(rname) != 0:
        nd_fd: int32 = _open_node(rname)
        if nd_fd != ENOENT:
            return nd_fd
        # Unknown file under /sys/devices/system/node: fall through.
    # §fuse: a path under a FUSE mount. fuse_mount_match returns the
    # connection slot whose bound target prefix covers `name`; if matched,
    # drive LOOKUP+GETATTR+OPEN over the wire and install an FD_FUSE_FILE_MARK
    # fd. Routed here (after the synthetic /proc + /sys arms, before the
    # on-disk FS arms) so a fuse mount target shadows any on-disk path at the
    # same name — the Plan-9 file-server attach takes precedence in its
    # subtree. A non-fuse path returns -1 and falls through.
    # F4 #449: dispatch through the registered hook; if no FUSE layer is
    # bound the hook is null and this arm is silently skipped.
    if fuse_mount_match_hook != cast[Fn[int32, Ptr[char]]](0):
        if fuse_mount_match_hook(rname) >= 0:
            return _open_fuse_file_marked(rname)
    # Phase D: the V1-era 9P SRV-kind mount probe (_try_open_p9 →
    # FD_P9_MARK) is gone — _namec_open above already routes a 9P-
    # mounted path to a Chan via the same chan_find_srv_prefix +
    # p9c_walk_open_path walk, and installs a unified FD_CHAN_MARK fd
    # instead. One open path, one fd kind, for local devices and
    # mounted servers alike.
    # V2: tmpfs owns /tmp/* and /var/*. /tmp is tmpfs-authoritative
    # (cpio has no /tmp). /var, however, can ALSO have cpio-baked
    # entries (e.g. an httpd docroot staged at /var/www in the
    # initramfs), so a /var path that tmpfs does NOT have falls
    # through to the cpio route below — tmpfs shadows cpio per-entry,
    # not the whole /var subtree. The bare "/var" / "/tmp" mount points
    # always resolve in tmpfs (the longest-prefix match claims them).
    # vfs_fs_shadow marks the /var mount; the /tmp mount is authoritative.
    fk: uint32 = vfs_fs_kind(rname)
    if fk == FS_KIND_TMPFS:
        if vfs_fs_shadow(rname) != 0:
            # /var subtree: tmpfs-first, cpio-baked fallthrough on a miss.
            if tmpfs_path_exists(rname) != 0:
                return _open_tmpfs_read(rname)
        else:
            # /tmp subtree (+ bare mountpoints): tmpfs-authoritative.
            return _open_tmpfs_read(rname)
    elif fk == FS_KIND_FAT:
        # Try a FAT FILE open first; if the name isn't a file (ENOENT)
        # fall through to the DIRECTORY opener so `ls /mnt` (the bare
        # mountpoint root) and `ls /mnt/<subdir>` list instead of
        # erroring. Without this fall-through the file arm shadowed the
        # dir arm below, so the mountpoint /mnt (always enumerated in
        # `ls /` as an mtab child of the kernel-planted /mnt->#f bind)
        # was a DANGLING entry — listed but unlistable.
        ffd: int32 = _open_fat_read(rname)
        if ffd != ENOENT:
            return ffd
        return _open_dir_fat(rname)
    elif fk == FS_KIND_EXT4:
        # Same file-then-directory fall-through for ext4 (/ext->#e).
        efd: int32 = _open_ext4_read(rname)
        if efd != ENOENT:
            return efd
        return _open_dir_ext(rname)
    file_idx: int32 = _lookup_name(rname)
    if file_idx < 0:
        # U32: directory-as-fd. Linux's openat(O_DIRECTORY) needs the
        # caller to be able to follow up with getdents64(). cpio is
        # flat (no DT_DIR entries), so we treat any path that's a
        # prefix of a registered file as an implicit directory and
        # snapshot its immediate children into a kmalloc'd NAME\n
        # buffer that FD_DIR_MARK fds walk. FAT / ext4 dirs go the
        # same path so busybox can ls /mnt as well as /etc.
        fkd: uint32 = vfs_fs_kind(rname)
        if fkd == FS_KIND_FAT:
            return _open_dir_fat(rname)
        if fkd == FS_KIND_EXT4:
            return _open_dir_ext(rname)
        if _is_initramfs_dir(rname) != 0:
            return _open_dir_cpio(rname)
        # Bare planted volume mountpoints with NOTHING mounted. The kernel
        # plants /ext->#e (ext4) and /mnt->#f (FAT) in EVERY namespace
        # (chan.ad::pgrp_init; _spec_localize maps #e->/ext, #f->/mnt), so
        # both names are ALWAYS enumerated in `ls /` as mtab children of
        # `/`. But when the backing volume is not mounted they are not
        # registered in vfs_mount (vfs_fs_kind == CPIO above) and every
        # arm ENOENTs — leaving a DANGLING `ls /` entry (listed but
        # unlistable). Present the unmounted mountpoint as an EMPTY
        # directory so the root listing stays coherent: every entry `ls /`
        # shows resolves. This matches an unmounted mountpoint on Linux
        # (`ls /mnt` on a fresh system = empty, not an error). A mounted
        # volume never reaches here — it is claimed by the FS_KIND arm
        # above (files) or _open_dir_fat/_open_dir_ext (dirs).
        if _path_eq_const(rname, cast[Ptr[uint8]]("/ext"), 4) != 0 \
                or _path_eq_const(rname, cast[Ptr[uint8]]("/mnt"), 4) != 0:
            return _open_empty_dir()
        return ENOENT
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = cast[uint32](file_idx)
    task[0].fd_pos[fdu] = 0
    return fd


DIR_BUF_SIZE: uint64 = 16384


# #450 F6 (Phase G, SYS_LISTDIR retirement): the conventional (pre-
# ns_walk) original path the current task passed to open(). Stashed by
# the SYS_OPEN syscall arm via vfs_open_set_orig_path BEFORE vfs_open
# runs; consumed by _open_dir_with after the backing FS fills its dir
# buffer, so chan_dir_mount_children can synthesize mount-table
# children keyed off the conventional name. Single uniprocessor global
# (no per-CPU split) because the SYS_OPEN syscall arm is non-preemptible
# between the set-orig and the open-completion read. An empty leading
# byte means "no orig stashed" — _open_dir_with skips synthesis.
_vfs_open_orig_path: Array[256, uint8]


def vfs_open_set_orig_path(orig: Ptr[uint8]):
    # Stamp the caller's conventional path into the per-open stash.
    # Truncates at 255 bytes (the backing array is 256, NUL-terminated).
    # An empty string clears the stash (skips mtab synthesis).
    if cast[uint64](orig) == 0:
        _vfs_open_orig_path[0] = 0
        return
    i: uint64 = 0
    while orig[i] != 0 and i < 255:
        _vfs_open_orig_path[i] = orig[i]
        i = i + 1
    _vfs_open_orig_path[i] = 0


def _install_dir_fd(fd: int32, buf: uint64, n: int64) -> int32:
    # fd→Chan fold: bind an already-rendered "NAME\n" directory-listing
    # buffer onto an already-allocated fd as a unified FD_CHAN_MARK fd
    # backed by a ptr-backed DEV_DIR_FILE pool chan. The buffer pointer +
    # length move INTO the chan (back_ptr / back_slot); the per-fd read
    # CURSOR stays in the task (fd_pos = 0). This replaces the legacy
    # FD_DIR_MARK install (fd_idx = FD_DIR_MARK; fd_buf = buf; fd_buflen =
    # n): a dir fd is now refcounted, so fork/dup share ONE buffer and a
    # task that exits holding one no longer leaks it (the buffer kfree
    # lives in namec_close's DEV_DIR_FILE arm now, not core.ad).
    #
    # On pool exhaustion the caller's buffer is kfree'd here and the fd is
    # closed, so the open fails cleanly with -EMFILE. `n` is the rendered
    # byte length (>= 0); an empty dir (n == 0) is fine — getdents64
    # reports EOF on the first call.
    cid: int32 = namec_open_dir_file(buf, cast[int32](n))
    if cid < 0:
        kfree(buf)
        vfs_close(fd)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _install_buf_fd(fd: int32, buf: uint64, n: int64) -> int32:
    # Phase 4b (fd→Chan): bind an already-rendered procfs/cgroup2/node
    # snapshot buffer onto an already-allocated fd as a unified
    # FD_CHAN_MARK fd backed by a ptr-backed DEV_BUF_FILE pool chan —
    # the snapshot sibling of _install_dir_fd above. The buffer pointer
    # + rendered length move INTO the chan (back_ptr / back_slot); the
    # per-fd read CURSOR stays in the task (fd_pos = 0). fd_buflen keeps
    # the rendered size so SEEK_END resolves locally. This replaces the
    # legacy FD_BUFFER_MARK install (fd_idx = FD_BUFFER_MARK; fd_buf =
    # buf): a snapshot fd is now refcounted, so fork/dup share ONE
    # buffer and a task that exits holding one frees it exactly once
    # via namec_close's kfree-on-last-ref arm.
    #
    # On pool exhaustion the buffer is kfree'd here and the fd released,
    # so the open fails cleanly with -EMFILE.
    cid: int32 = namec_open_buf_file(buf, cast[int32](n))
    if cid < 0:
        kfree(buf)
        vfs_close(fd)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = cast[uint64](n)
    return fd


def _open_dir_cpio(name: Ptr[char]) -> int32:
    return _open_dir_with(name, 0)


def _open_dir_fat(name: Ptr[char]) -> int32:
    return _open_dir_with(name, 1)


def _open_dir_ext(name: Ptr[char]) -> int32:
    return _open_dir_with(name, 2)


def _open_dir_with(name: Ptr[char], backend: int32) -> int32:
    # Common allocate-fd / kmalloc / fill / install pattern for the
    # three readdir backends. `backend` selects which listdir fills
    # the buffer (0 = cpio initramfs, 1 = FAT, 2 = ext4).
    #
    # #450 F6 (Phase G, SYS_LISTDIR retirement): the retired
    # vfs_listdir_ns syscall arm used to append namespace mount-table
    # children (the names of any binding whose parent is the original
    # conventional path) onto the backing FS listing — that's what makes
    # `bind '#c' /dev` show up as `dev` in `ls /`. The same synthesis
    # now happens HERE on the open-dir path: after the backing listdir
    # fills `buf`, we ask chan_dir_mount_children for any mtab children
    # of the ORIGINAL conventional path (stashed by the SYS_OPEN arm in
    # _vfs_open_orig_path before vfs_open ran). Keyed on the original
    # path (not the resolved one) because `/` itself can be a bind target
    # — see vfs_listdir_ns's comment for the full rationale.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                       # -ENOMEM
    bufp: Ptr[uint8] = cast[Ptr[uint8]](buf)
    n: int64 = 0
    if backend == 0:
        n = _cpio_listdir(name, bufp, DIR_BUF_SIZE)
    elif backend == 1:
        # vfs_fs_rel yields "" for the bare /mnt mountpoint (the FAT
        # volume root), so the old explicit "/mnt" special case folds in.
        n = fat_listdir(vfs_fs_rel(name), bufp, DIR_BUF_SIZE)
    else:
        n = ext4_listdir(vfs_fs_rel(name), bufp, DIR_BUF_SIZE)
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        return ENOENT
    # #450 F6: append mtab children of the ORIGINAL path. Empty / `#`-
    # prefixed orig skips synthesis (no namespace operation expects to
    # synthesize children for a device-server target).
    #
    # Bugfix (ls / missing binds): the _vfs_open_orig_path stash is only
    # set by the NATIVE SYS_OPEN syscall arm (arch/x86/kernel/syscall.ad).
    # The Linux-ABI open/openat path (linux_abi/u_syscalls.ad, what
    # busybox `ls` in the graphical terminal uses) and every in-kernel
    # vfs_open caller leave it EMPTY — so mount-table children were never
    # synthesized and `ls /` dropped every per-Pgrp bind (`/srv /net
    # /proc /dev /n`). Fall back to the path THIS open is listing (`name`,
    # the resolved conventional directory path passed down from vfs_open)
    # whenever the stash is empty. For `/` and ordinary mount points the
    # resolved name IS the conventional name, so union enumeration works
    # for every open path, not just native SYS_OPEN. The orig stash still
    # wins when present (it carries the pre-ns_walk name for the case
    # where a bind rewrites `/onlyetc` -> `/etc` and the resolved name no
    # longer matches the directory the user typed).
    base: uint64 = 0
    if n > 0:
        base = cast[uint64](n)
    orig: Ptr[uint8] = cast[Ptr[uint8]](&_vfs_open_orig_path[0])
    synth: Ptr[uint8] = orig
    if orig[0] == 0:
        synth = cast[Ptr[uint8]](name)
    if synth[0] != 0 and synth[0] != 35:              # '#'
        canon: Array[256, uint8]
        if _resolve_path_canonical(cast[Ptr[char]](synth),
                                   &canon[0], 256) == 0:
            n2: int64 = chan_dir_mount_children(&canon[0], bufp,
                                                DIR_BUF_SIZE, base)
            if n2 > 0:
                n = n2
    return _install_dir_fd(fd, buf, n)


# --- F10-6 followup: NAME\n -> Dir-record transform ----------------
#
# A directory fd's back_ptr buffer was rendered by the open-time
# listdir backends as a "NAME\n" line stream (see _open_dir_with /
# _open_dir_srv / _open_dir_blk / etc.). When userspace flips the fd
# into p9_dir_mode=1 (via SYS_CHAN_DIR_MODE), we walk the existing
# NAME\n entries, ask the backing FS for per-entry size + mode + qid
# via the same path-owning-server ladder do_stat uses, and re-encode
# the listing as Plan-9 Dir wire-format records (lib/p9dir.ad).
#
# The transform is best-effort on metadata: if a stat lookup fails
# (the entry is a synthesised mount-table child whose path doesn't
# resolve through any backing FS, or the backing has no stat hook)
# the record still emits with mode=0644 / length=0 — that way `ls -l`
# never *drops* a name from its output. Real metadata for cpio /
# tmpfs / ext4 leaves; default-filled for everything else (devs /
# proc / srv / net / etc.). uid/gid carry "hostowner" to match the
# convention devsrv_list_dir established in F10-6.

DIR_XFORM_UID:  Array[16, uint8]               # "hostowner" + NUL
DIR_XFORM_UID_INITED: int32 = 0


def _dir_xform_init_uid():
    # Plant the default uid/gid string into the BSS buffer once.
    if DIR_XFORM_UID_INITED != 0:
        return
    DIR_XFORM_UID[0]  = 104                            # 'h'
    DIR_XFORM_UID[1]  = 111                            # 'o'
    DIR_XFORM_UID[2]  = 115                            # 's'
    DIR_XFORM_UID[3]  = 116                            # 't'
    DIR_XFORM_UID[4]  = 111                            # 'o'
    DIR_XFORM_UID[5]  = 119                            # 'w'
    DIR_XFORM_UID[6]  = 110                            # 'n'
    DIR_XFORM_UID[7]  = 101                            # 'e'
    DIR_XFORM_UID[8]  = 114                            # 'r'
    DIR_XFORM_UID[9]  = 0
    DIR_XFORM_UID_INITED = 1


def _dir_xform_strlen(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _dir_xform_join(parent: Ptr[uint8], name: Ptr[uint8],
                    name_len: uint64, out: Ptr[uint8],
                    out_cap: uint64) -> uint64:
    # Render "parent/name" into out, NUL-terminated. Returns the joined
    # length (without the NUL). Returns 0 if the result would not fit.
    p_len: uint64 = _dir_xform_strlen(parent)
    # Strip trailing '/' from parent so "/" + "etc" -> "/etc" not "//etc".
    while p_len > 1 and parent[p_len - 1] == 47:       # '/'
        p_len = p_len - 1
    need: uint64 = p_len + 1 + name_len + 1            # parent + '/' + name + NUL
    if need > out_cap:
        return 0
    i: uint64 = 0
    while i < p_len:
        out[i] = parent[i]
        i = i + 1
    out[i] = 47                                        # '/'
    i = i + 1
    j: uint64 = 0
    while j < name_len:
        out[i + j] = name[j]
        j = j + 1
    out[i + name_len] = 0
    return i + name_len


def _dir_xform_lookup_meta(abs_path: Ptr[uint8],
                           out_qtype: Ptr[uint8],
                           out_mode: Ptr[uint32],
                           out_qpath: Ptr[uint64],
                           out_length: Ptr[uint64]) -> int32:
    # Best-effort per-backend lookup. Populates qtype/mode/qpath/length
    # for `abs_path` based on the owning server. Returns 0 on success
    # (always — the fallbacks below ensure every reachable path produces
    # *some* Dir record). Mirrors the do_stat ladder but stays in-kernel
    # (no user-buffer write), so we can call it from the transform
    # without crossing the uaccess boundary.
    srv: int32 = vfs_path_owning_server(cast[Ptr[char]](abs_path))
    # Defaults: regular file, mode 0644, qpath = 0, length = 0.
    out_qtype[0]  = P9_QTFILE
    out_mode[0]   = cast[uint32](0644)
    out_qpath[0]  = 0
    out_length[0] = 0
    if srv == SERVER_CPIO:
        # Inline cpio name lookup. Mirrors sysfile.ad::_cpio_lookup; the
        # symbol there is module-private so we re-do the walk here.
        idx: int32 = -1
        cp_count: uint64 = initramfs_entry_count()
        cp_i: uint64 = 0
        while cp_i < cp_count:
            cp_cand: Ptr[char] = initramfs_entry_name(cp_i)
            cp_k: uint64 = 0
            cp_eq: int32 = 1
            while True:
                cp_ca: int32 = cast[int32](abs_path[cp_k] & 0xFF)
                cp_cb: int32 = cp_cand[cp_k]
                if cp_ca != cp_cb:
                    cp_eq = 0
                    break
                if cp_ca == 0:
                    break
                cp_k = cp_k + 1
            if cp_eq != 0:
                idx = cast[int32](cp_i)
                cp_i = cp_count               # break
            else:
                cp_i = cp_i + 1
        if idx >= 0:
            out_qpath[0]  = cast[uint64](idx)
            out_length[0] = initramfs_entry_size(cast[uint64](idx))
            m: uint64 = initramfs_entry_mode(cast[uint64](idx))
            # cpio mode carries POSIX type bits in the high nibble; if
            # it's a directory, set DMDIR + QTDIR. Otherwise pass the
            # perm bits straight through.
            if (m & 0xF000) == 0x4000:                  # S_IFDIR
                out_qtype[0] = P9_QTDIR
                out_mode[0]  = P9_DMDIR | cast[uint32](m & 0xFFF)
            else:
                out_mode[0]  = cast[uint32](m & 0xFFF)
                if out_mode[0] == 0:
                    out_mode[0] = cast[uint32](0644)
        return 0
    if srv == SERVER_TMPFS:
        slot: int32 = tmpfs_lookup(cast[Ptr[char]](abs_path))
        if slot >= 0:
            out_qpath[0] = cast[uint64](cast[uint32](slot))
            if tmpfs_is_dir(slot) != 0:
                out_qtype[0] = P9_QTDIR
                out_mode[0]  = P9_DMDIR | cast[uint32](0755)
            else:
                out_length[0] = tmpfs_size(slot)
        return 0
    if srv == SERVER_EXT4:
        leaf: Ptr[char] = vfs_fs_rel(cast[Ptr[char]](abs_path))
        inum: uint32 = 0
        fsize: uint64 = 0
        if ext4_resolve_file(leaf, &inum, &fsize) != 0:
            out_qpath[0]  = cast[uint64](inum)
            out_length[0] = fsize
            return 0
        dinum: uint32 = ext4_resolve_dir(leaf)
        if dinum != 0:
            out_qtype[0] = P9_QTDIR
            out_mode[0]  = P9_DMDIR | cast[uint32](0755)
            out_qpath[0] = cast[uint64](dinum)
        return 0
    # Other servers (devs / proc / srv / net / auth / block / root /
    # FAT): keep the defaults. ls -l will show "?-rw-r--r-- ? 0 NAME".
    return 0


def vfs_dir_xform_to_records(parent_path: Ptr[uint8],
                             name_stream: Ptr[uint8],
                             name_stream_len: uint64,
                             out_buf: Ptr[uint8],
                             out_cap: uint64) -> int64:
    # F10-6 followup: NAME\n-line-stream -> Dir-record transform.
    # `parent_path` is the absolute directory whose listing produced
    # `name_stream`; we join each NAME to it for per-entry stat. The
    # caller is responsible for kmalloc'ing `out_buf` (>= out_cap) and
    # for kfree'ing the OLD NAME\n buffer once this returns successfully.
    # Returns the bytes written to `out_buf` (>= 0), or -1 on encode
    # overflow (the out buffer is too small for the full listing).
    _dir_xform_init_uid()
    uid_p: Ptr[uint8] = cast[Ptr[uint8]](&DIR_XFORM_UID[0])
    uid_len: uint64 = 9                                # "hostowner"
    out_pos: uint64 = 0
    i: uint64 = 0
    join_buf: Array[512, uint8]
    while i < name_stream_len:
        # One NAME\n entry starts at i. Find the '\n'.
        start: uint64 = i
        while i < name_stream_len and name_stream[i] != 10:
            i = i + 1
        nlen: uint64 = i - start
        if i < name_stream_len:
            i = i + 1                                  # skip the '\n'
        if nlen == 0:
            continue
        # Skip "." and ".." — the legacy listdirs DON'T emit these for
        # most backends, but some do; the Dir-record consumers don't
        # want them either way (ls handles dot-entry suppression on its
        # own; du shouldn't recurse into them).
        if nlen == 1 and name_stream[start] == 46:     # '.'
            continue
        if nlen == 2 and name_stream[start] == 46 \
                and name_stream[start + 1] == 46:      # '..'
            continue
        # Join parent + name -> abs_path (in the kernel scratch buffer).
        abs_len: uint64 = _dir_xform_join(
            parent_path,
            cast[Ptr[uint8]](cast[uint64](name_stream) + start),
            nlen,
            cast[Ptr[uint8]](&join_buf[0]), 512)
        qtype: uint8 = P9_QTFILE
        mode: uint32 = cast[uint32](0644)
        qpath: uint64 = 0
        length: uint64 = 0
        if abs_len > 0:
            _dir_xform_lookup_meta(
                cast[Ptr[uint8]](&join_buf[0]),
                &qtype, &mode, &qpath, &length)
        # Atime / mtime — no per-FS hook exposes mtime as a kernel-side
        # u32 yet; emit 0 (epoch) for both. ls -l prints "Jan  1  1970"
        # but the field is the wire-format slot _stat_hook_*'s
        # _write_dir_record uses, so adding real mtime is a one-line
        # change here once those hooks expose it.
        wrote: uint64 = p9_dir_encode_into(
            out_buf, out_pos, out_cap,
            qtype, 0, qpath,
            mode, 0, 0, length,
            cast[Ptr[uint8]](cast[uint64](name_stream) + start), nlen,
            uid_p, uid_len,
            uid_p, uid_len,
            uid_p, 0)
        if wrote == 0:
            # Out buffer full. Return what we've written so far —
            # callers see a clean truncation rather than corruption.
            return cast[int64](out_pos)
        out_pos = out_pos + wrote
    return cast[int64](out_pos)


def vfs_chan_p9_dir_mode_set(cid: int32, mode: int32,
                             parent_path: Ptr[uint8]) -> int32:
    # F10-6 followup: SYS_CHAN_DIR_MODE landing point. Flip a DEV_DIR_FILE
    # chan into Dir-record mode (mode=1) or back to NAME\n (mode=0; not
    # supported once the buffer is transformed — returns -1). On success
    # the chan's back_ptr is swapped from the NAME\n buffer to a freshly
    # kmalloc'd Dir-record buffer, the old buffer is kfree'd, and the
    # p9_dir_mode flag is set.
    if namec_chan_dev_type(cid) != DEV_DIR_FILE:
        return -1
    if mode == 0:
        if namec_chan_get_p9_dir_mode(cid) == 0:
            return 0                                   # already off
        return -1                                      # no flip-back
    if mode != 1:
        return -1
    if namec_chan_get_p9_dir_mode(cid) == 1:
        return 0                                       # already on
    old_ptr: uint64 = namec_chan_back_ptr(cid)
    old_len: int32 = namec_chan_back_slot(cid)
    if old_ptr == 0:
        # Empty directory — still mark Dir-mode but no buffer to
        # transform. Subsequent reads return 0 (EOF) which is correct.
        namec_chan_set_p9_dir_mode(cid, 1)
        return 0
    new_buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if new_buf == 0:
        return -1
    n: int64 = vfs_dir_xform_to_records(
        parent_path,
        cast[Ptr[uint8]](old_ptr), cast[uint64](cast[uint32](old_len)),
        cast[Ptr[uint8]](new_buf), DIR_BUF_SIZE)
    if n < 0:
        kfree(new_buf)
        return -1
    # Swap the chan's back_ptr to the new buffer. The old NAME\n buffer
    # is kfree'd here — the chan_close arm only frees what it sees in
    # back_ptr at last-close, so we must release the old one now.
    if namec_chan_set_back_ptr(cid, new_buf, cast[int32](n)) != 0:
        kfree(new_buf)
        return -1
    kfree(old_ptr)
    namec_chan_set_p9_dir_mode(cid, 1)
    return 0


def _open_dir_srv() -> int32:
    # V3/V3.5: `#s` directory listing (formerly `/srv`). Render the
    # devsrv table into a kmalloc'd buffer; install as an FD_DIR_MARK
    # fd so getdents64 + the busybox `ls` path both see the names.
    # Empty table -> n=0, which getdents64 reports as EOF on the
    # first call.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                       # -ENOMEM
    n: int64 = devsrv_list(cast[Ptr[uint8]](buf), DIR_BUF_SIZE)
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        return ENOENT
    return _install_dir_fd(fd, buf, n)


def _open_dir_blk() -> int32:
    # `#b` (post-bind /dev/blk) directory listing. Render the live
    # block-device names into a kmalloc'd FD_DIR_MARK buffer so
    # getdents64 + `ls`/`lsblk` see "nvme0n1", "nvme0n1p1", "vda", ...
    # The names come from blk_listdir (kernel/block/blk.ad), which walks
    # the registered blockdev table — NOT a literal string match here.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                       # -ENOMEM
    n: int64 = blk_listdir(cast[Ptr[uint8]](buf), DIR_BUF_SIZE)
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        return ENOENT
    return _install_dir_fd(fd, buf, n)


def _dev_dir_emit(buf: Ptr[uint8], count: uint64, out: uint64,
                  s: Ptr[uint8]) -> uint64:
    # Append the NUL-terminated name `s` as a "NAME\n" line into buf at
    # offset `out`, capped at `count`. Returns the new offset. A line
    # that would overflow the buffer is dropped (out is left unchanged).
    nlen: uint64 = 0
    while s[nlen] != 0:
        nlen = nlen + 1
    if nlen == 0:
        return out
    if out + nlen + 1 > count:
        return out
    j: uint64 = 0
    while j < nlen:
        buf[out + j] = s[j]
        j = j + 1
    buf[out + nlen] = 10                               # '\n'
    return out + nlen + 1


def _open_dir_dev() -> int32:
    # `#c` (post-bind /dev) directory listing. /dev is a device server:
    # its children are the device NODES the kernel exposes, not on-disk
    # files. We list the block subtree (`blk`, itself a `#b`-served
    # directory) plus the always-present synthetic stdio cdevs (cons,
    # null, zero). The enumeration comes from this server through the
    # `bind '#c' /dev`, NOT a literal "/dev" string-match in vfs_listdir.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                       # -ENOMEM
    bp: Ptr[uint8] = cast[Ptr[uint8]](buf)
    out: uint64 = 0
    out = _dev_dir_emit(bp, DIR_BUF_SIZE, out, "blk")
    out = _dev_dir_emit(bp, DIR_BUF_SIZE, out, "cons")
    out = _dev_dir_emit(bp, DIR_BUF_SIZE, out, "null")
    out = _dev_dir_emit(bp, DIR_BUF_SIZE, out, "zero")
    return _install_dir_fd(fd, buf, cast[int64](out))


def _dir_emit_dec(buf: Ptr[uint8], count: uint64, out: uint64,
                  v: uint64) -> uint64:
    # Append the decimal value `v` as a "NNN\n" line into buf at offset
    # `out`, capped at `count`. Returns the new offset (unchanged if the
    # line would overflow). Used by _open_dir_fd to render numeric
    # /fd/<N> child names.
    tmp: Array[24, uint8]
    tl: uint64 = 0
    if v == 0:
        tmp[0] = 48                                        # '0'
        tl = 1
    else:
        x: uint64 = v
        while x > 0:
            tmp[tl] = cast[uint8](48 + cast[uint8](x % 10))
            tl = tl + 1
            x = x / 10
    if out + tl + 1 > count:
        return out
    k: uint64 = 0
    while k < tl:
        buf[out + k] = tmp[tl - 1 - k]                     # reverse
        k = k + 1
    buf[out + tl] = 10                                     # '\n'
    return out + tl + 1


def _open_empty_dir() -> int32:
    # Install a directory fd whose listing is EMPTY. Used for a bare
    # planted volume mountpoint (/ext, /mnt) whose backing volume is not
    # mounted — so `ls`/`cd` on it behave like an ordinary empty
    # directory instead of ENOENT (see _open_read_body's mountpoint arm).
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                           # -ENOMEM
    return _install_dir_fd(fd, buf, 0)


def _open_dir_proc() -> int32:
    # `#p` (post-bind /proc) directory listing. devproc_listdir("")
    # renders the well-known proc files + one decimal entry per LIVE pid
    # (the same table walk render_tasks uses) into a NAME\n buffer. This
    # is what makes `ls /proc` and `cd /proc` RESOLVE. Previously the bare
    # `#p` open returned ENOENT, so /proc appeared in `ls /` (mtab-child
    # synthesis binds #p at /proc) yet could not itself be listed —
    # a dangling entry. World-readable, exactly like /proc on Linux;
    # per-task write gating stays in devproc for the individual leaves.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                           # -ENOMEM
    n: int64 = devproc_listdir(cast[Ptr[char]](""),
                               cast[Ptr[uint8]](buf), DIR_BUF_SIZE)
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        return ENOENT
    return _install_dir_fd(fd, buf, n)


def _open_dir_fd() -> int32:
    # `#d` (post-bind /fd) directory listing. Enumerate the calling
    # Pgrp's bound /fd/<N> names (the per-Pgrp devfd table) as decimal
    # entries so `ls /fd` and `cd /fd` RESOLVE. Previously bare `#d`
    # returned ENOENT, leaving /fd a dangling entry in `ls /` — it was
    # bound (hamsh's _setup_fd_namespace does `bind '#d' /fd`) and thus
    # enumerated as an mtab child of /, yet unlistable. A freshly-set-up
    # shell lists at least 0/1/2 (stdin/stdout/stderr).
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                           # -ENOMEM
    bp: Ptr[uint8] = cast[Ptr[uint8]](buf)
    out: uint64 = 0
    pg: uint64 = pgrp_current()
    i: uint64 = 0
    while i < DEVFD_SLOTS:
        if devfd_slot_kind(pg, cast[int32](i)) != DEVFD_NONE:
            out = _dir_emit_dec(bp, DIR_BUF_SIZE, out, i)
        i = i + 1
    return _install_dir_fd(fd, buf, cast[int64](out))


def _open_dev_leaf(leaf: Ptr[char], wr: int32) -> int32:
    # `#c/<leaf>` open (post-bind /dev/<leaf>). Forward to the per-device
    # handlers WITHOUT re-resolving the name (which would re-rewrite
    # /dev/<leaf> back to #c/<leaf> and loop). Covers the synthetic
    # stdio cdevs inline, the stateful per-fd cdevs (auth/fuse/ptmx/pts/
    # loop), and finally the namec devtab probe for the introspection
    # cdevs (cons, time, random, mouse, cpuinfo, ...). This is what keeps
    # `bind '#c' /dev` from shadowing the many /dev/* cdevs that vfs_open
    # / vfs_open_write otherwise match by literal path. `wr` is 1 for an
    # OWRITE/ORDWR open, 0 for OREAD — it only changes the namec probe
    # mode (every other cdev opens r/w-agnostically).
    #
    #   blk[/...]  -> the block subtree (#b server). A bare "blk" is the
    #                 directory; "blk/<name>..." routes to devblk.
    if leaf[0] == 0:
        return _open_dir_dev()
    # blk / blk/<name>... — route to the block server.
    if leaf[0] == 98 and leaf[1] == 108 and leaf[2] == 107:    # "blk"
        if leaf[3] == 0:
            return _open_dir_blk()
        if leaf[3] == 47:                                      # "blk/<...>"
            blp: uint64 = 0
            blrc: int32 = devblk_leaf_match(
                cast[Ptr[char]](cast[uint64](leaf) + 4), &blp)
            if blrc == 1:
                return _open_blk_marked(blp)
            set_current_errstr("blk: no such device")
            return ENOENT
    # null / zero / cons are stateless namec devtab cdevs (DEV_NULL /
    # DEV_ZERO / DEV_CONS) — they are resolved by the _namec_open probe
    # at the tail of this function, NOT by a literal leaf match here.
    # Stateful per-fd cdevs with no namec devtab entry — these were
    # matched by literal "/dev/<x>" path in vfs_open/vfs_open_write
    # BEFORE the namec probe, so reach them here too (the `bind '#c'
    # /dev` rewrites their conventional path to `#c/<x>`).
    if _cstr_eq_dev(leaf, "auth") != 0:
        return _open_auth_marked()
    # F10-1 (#454): rebuild the `#c/<leaf>` server-letter spelling once;
    # reused by the L2 path-handler dispatch and the namec devtab probe
    # below. The legacy `/dev/<leaf>` rebuild was a parallel path that
    # bypassed the per-Pgrp namespace; the F1 substrate gate now lives at
    # the top of _vfs_open_post_perm (resolve_path), and the post-resolve
    # namec devtab keys on `#c/<leaf>` only — so we have to hand the same
    # spelling back to the L2 dispatcher and to _namec_open. _devtab_lookup
    # and _devtab_lookup_wsys both consume `#c/<leaf>` after F10-1.
    scratch: Array[64, uint8]
    scratch[0] = 35                                            # '#'
    scratch[1] = 99                                            # 'c'
    scratch[2] = 47                                            # '/'
    k: uint64 = 0
    while leaf[k] != 0 and k + 4 < 64:
        scratch[3 + k] = cast[uint8](leaf[k] & 0xFF)
        k = k + 1
    scratch[3 + k] = 0
    leaf_full: Ptr[char] = cast[Ptr[char]](&scratch[0])
    # F4 #449: route #c/fuse, #c/ptmx and #c/pts/<N> through the
    # registered Layer-2 path-handler hook so the `#c/<leaf>` dispatch
    # path has no static dependency on linux_abi either. Accmode 0 =
    # OREAD here (the `#c/` dispatch is read-side); a write-side caller
    # arrives via the OWRITE branch in vfs_open_write. F10-1: the hook
    # now matches the `#c/<leaf>` server-letter spelling (post-F1
    # namespace-purity); the legacy literal `/dev/<leaf>` arm is gone.
    if l2_path_open_hook != cast[Fn[int32, Ptr[char], int32]](0):
        l2_devfd: int32 = l2_path_open_hook(leaf_full, 0)
        if l2_devfd != L2_PATH_NOT_HANDLED:
            return l2_devfd
    # #c/loop/ctl is a namec devtab cdev (DEV_LOOPCTL) since Phase 4b
    # — it resolves through the probe below with the other cdevs.
    # Everything else: the namec devtab probe (time / random / mouse /
    # cpuinfo / meminfo / uptime / loadavg / version / hostname / stat /
    # mounts / diskstats / ...).
    chan_fd: int32 = _namec_open(leaf_full, wr)
    if chan_fd != P9_NO_MOUNT:
        return chan_fd
    set_current_errstr("dev: no such device")
    return ENOENT


def _cstr_eq_dev(a: Ptr[char], b: Ptr[uint8]) -> int32:
    # NUL-terminated equality for short device leaf names.
    i: uint64 = 0
    while True:
        ca: int32 = a[i] & 0xFF
        cb: int32 = cast[int32](b[i])
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1
    return 0


def _open_dir_n() -> int32:
    # V3/V3.5: `#/` (formerly `/n`) — root-dir slot. Empty by default;
    # child Pgrps `bind` or `mount` things into subpaths AFTER doing
    # `bind '#/' /n`, and those bindings show up only as resolved
    # rewrites (the prefix matcher routes opens of `/n/<x>` to the
    # bound target). The slot itself has no synthetic children to
    # enumerate today. Same FD_DIR_MARK shape as the other dir-opens
    # so getdents64 / busybox ls don't need a special case.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                       # -ENOMEM
    return _install_dir_fd(fd, buf, 0)


def _open_srv_name(name: Ptr[char]) -> int32:
    # V4: `#s/<name>` (or post-bind `/srv/<name>`) open. Look up the
    # posted entry, then copy_fd_entry from the poster's task slot
    # into the caller's fd table so the returned fd is usable in the
    # caller's context. Misses (no such name) and kernel-only entries
    # (poster_slot=-1) both return ENOENT — the latter because we
    # have no source TaskStruct to dup from.
    src_slot: int32 = -1
    src_fd:   int32 = -1
    rc: int32 = devsrv_lookup_full(name, &src_slot, &src_fd)
    if rc < 0:
        return ENOENT
    if src_slot < 0:
        # Kernel-posted entry; no userspace source task to dup from.
        return ENOENT
    src_task: Ptr[TaskStruct] = task_struct_at(src_slot)
    if cast[uint64](src_task) == 0:
        return ENOENT
    src_fdu: uint64 = cast[uint64](src_fd)
    # Read the SOURCE task's shared table (owner) — the poster may be a thread.
    src_task = fd_owner_task(src_task)
    if src_task[0].fd_idx[src_fdu] == FD_CLOSED_MARK:
        # Poster's fd has since been closed — entry is stale. The
        # next devsrv_post on the same name will overwrite it, but
        # in the meantime the lookup fails.
        return ENOENT
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    new_fd: int32 = _alloc_fd(task)
    if new_fd < 0:
        return EMFILE
    if copy_fd_entry(task, cast[uint64](new_fd), src_task, src_fdu) < 0:
        return ENOENT
    return new_fd


# Phase 6 — `#<word>` long-form name dispatch helpers.

def _is_lower_letter(c: int32) -> int32:
    if c >= 97 and c <= 122:
        return 1
    return 0


def _is_digit_ch(c: int32) -> int32:
    if c >= 48 and c <= 57:
        return 1
    return 0


def _is_word_continuation(c: int32) -> int32:
    # Char that can appear AFTER the first letter of a sentinel-shape
    # name: [a-z0-9-]. Used to detect "this is a multi-char word" vs
    # "this is one of the legacy single-char built-ins like #c/#p".
    if _is_lower_letter(c) != 0:
        return 1
    if _is_digit_ch(c) != 0:
        return 1
    if c == 45:                                  # '-'
        return 1
    return 0


def _hash_word_extract(name: Ptr[char], out: Ptr[uint8], cap: uint64,
                       trailing_digits_out: Ptr[int32],
                       word_end_out: Ptr[uint64]) -> int32:
    # Given `name` pointing at `#<word>[<N>][/<rest>]`, copy the
    # alphabetic prefix of word into `out` (NUL-terminated), and
    # extract any trailing decimal-digit suffix into
    # trailing_digits_out (0 if none — caller uses 1 for top, N for
    # positional). `word_end_out` is set to the index in `name` just
    # past the last word/digit char (where '/' or NUL is expected).
    # Returns 0 on success, -1 on malformed (e.g., name[1] not a
    # letter — which the caller should have filtered).
    if name[1] == 0:
        return -1
    if _is_lower_letter(name[1]) == 0:
        return -1
    # Walk through the alpha part of the word.
    i: uint64 = 1
    o: uint64 = 0
    while name[i] != 0 and _is_lower_letter(name[i]) != 0 and o + 1 < cap:
        out[o] = cast[uint8](name[i])
        o = o + 1
        i = i + 1
    # Hyphens belong to the word too — Plan 9 doesn't have them
    # in built-ins, but our sentinel words allow `apt-cache` etc.
    # Mid-word hyphens followed by another letter join the same word.
    while name[i] == 45 and _is_lower_letter(name[i + 1]) != 0 and o + 1 < cap:
        out[o] = 45
        o = o + 1
        i = i + 1
        while name[i] != 0 and _is_lower_letter(name[i]) != 0 and o + 1 < cap:
            out[o] = cast[uint8](name[i])
            o = o + 1
            i = i + 1
    out[o] = 0
    # Now any trailing decimal digits — those become the positional
    # selector.
    n: int32 = 0
    digit_start: uint64 = i
    while _is_digit_ch(name[i]) != 0:
        n = n * 10 + (name[i] - 48)
        i = i + 1
    # Anonymous-partition names carry their digits IN the registered
    # word: init/main.ad::_register_anonymous pushes the literal word
    # "part0"/"part1"/... (sequential, no stack), where the trailing
    # digit is NOT a positional selector. ("#part0" is doubly lost on
    # the positional split: word "part" is never registered AND the
    # digit 0 is indistinguishable from "no digits".) Disambiguate by
    # the name table itself: when digits are present and the
    # alpha-only word resolves nowhere, but the full word+digits
    # string IS a registered name, fold the digits back into the
    # word. Positional resolution keeps precedence, so sentinel
    # `#home2`-style selectors behave exactly as before.
    if i > digit_start:
        sel_probe: int32 = n
        if sel_probe == 0:
            sel_probe = 1
        if name_lookup_at(out, sel_probe) == 0:
            o2: uint64 = o
            j: uint64 = digit_start
            while j < i and o2 + 1 < cap:
                out[o2] = cast[uint8](name[j])
                o2 = o2 + 1
                j = j + 1
            out[o2] = 0
            if name_lookup_at(out, 1) != 0:
                n = 0                  # digits folded into the word
            else:
                out[o] = 0             # restore the positional split
    trailing_digits_out[0] = n
    word_end_out[0] = i
    return 0


def _open_hash_long(name: Ptr[char]) -> int32:
    # Resolve `#<word>[<N>][/<rest>]` through chan.ad's named-stack
    # table. Special case: `#by-id/<partuuid>[/<rest>]` goes through
    # the persistent by-id alias table instead.
    word_buf: Array[40, uint8]
    pos: int32 = 0
    word_end: uint64 = 0
    if _hash_word_extract(name, &word_buf[0], 40, &pos, &word_end) < 0:
        return ENOENT
    # `#by-id` short-circuit.
    if _hash_is_by_id(&word_buf[0]) != 0:
        # name[word_end] must be '/', followed by the partuuid.
        if name[word_end] != 47:
            return ENOENT
        return _open_hash_by_id(name, word_end + 1)
    # Position semantics: no digits → top (pos=1); `#home2` → pos=2.
    sel: int32 = pos
    if sel == 0:
        sel = 1
    chan_ref: uint64 = name_lookup_at(&word_buf[0], sel)
    if chan_ref == 0:
        return ENOENT
    # Read the sentinel-declared dir for this entry, then route the
    # open to the on-disk ext4 path `(dir)(rest)`.
    dir_buf: Array[256, uint8]
    if name_lookup_dir(&word_buf[0], sel, &dir_buf[0], 256) < 0:
        return ENOENT
    return _open_named_subpath(&dir_buf[0], name, word_end)


def _hash_is_by_id(word: Ptr[uint8]) -> int32:
    # NUL-terminated equality with "by-id".
    lit: Ptr[uint8] = cast[Ptr[uint8]]("by-id")
    i: uint64 = 0
    while True:
        a: uint8 = word[i]
        b: uint8 = lit[i]
        if a != b:
            return 0
        if a == 0:
            return 1
        i = i + 1


def _open_hash_by_id(name: Ptr[char], partuuid_start: uint64) -> int32:
    # Parse `name[partuuid_start..]` up to the next '/' (or NUL) as
    # the partuuid; look it up in byid_table; route to ext4 with the
    # remainder.
    pu_buf: Array[40, uint8]
    i: uint64 = partuuid_start
    o: uint64 = 0
    while name[i] != 0 and name[i] != 47 and o + 1 < 40:
        pu_buf[o] = cast[uint8](name[i])
        o = o + 1
        i = i + 1
    pu_buf[o] = 0
    if o == 0:
        return ENOENT
    if byid_lookup(&pu_buf[0]) == 0:
        return ENOENT
    # Honor the by-id entry's stored sentinel relpath. With the multi-
    # root partition layout (`sysroot sysroot`, `distro distro`) a
    # frozen `bind '#sysroot' /` arrives here as
    # `#by-id/<partuuid>/sysroot/<rest>` — _freeze_named_source
    # (chan.ad) already baked the dir prefix into the path, so the
    # remainder from `i` is `/sysroot/<rest>` and an empty dir_prefix
    # composes the correct `/ext/sysroot/<rest>`. For a BARE
    # `#by-id/<partuuid>/<rest>` reference (not frozen-with-dir) we
    # fall back to the entry's stored dir so the partition's sentinel
    # relpath is still respected instead of resolving against the
    # partition root. (The whole-partition case stores "." / "" which
    # _open_named_subpath treats as no prefix.)
    dir_buf: Array[256, uint8]
    dir_buf[0] = 0
    byid_lookup_dir(&pu_buf[0], &dir_buf[0], 256)
    return _open_named_subpath(&dir_buf[0], name, i)


def _compose_ext_path(dir_prefix: Ptr[uint8], name: Ptr[char],
                      rest_start: uint64, out: Ptr[uint8],
                      cap: uint64) -> int32:
    # Compose a synthetic `/ext/<dir_prefix>/<rest>` path into `out`.
    # Returns the length written (excluding NUL), or -1 on overflow.
    # Factored out of _open_named_subpath so both the fd-backed open
    # and the fd-less blob slurp share one canonical composition.
    p: uint64 = 0
    # Plant "/ext".
    out[0] = 47                                  # '/'
    out[1] = 101                                 # 'e'
    out[2] = 120                                 # 'x'
    out[3] = 116                                 # 't'
    p = 4
    # Append "/<dir_prefix>" if non-empty AND not "." (which means
    # whole-partition per the sentinel convention).
    if dir_prefix[0] != 0 and dir_prefix[0] != 46:
        out[p] = 47                              # '/'
        p = p + 1
        k: uint64 = 0
        while dir_prefix[k] != 0 and p + 1 < cap:
            out[p] = dir_prefix[k]
            p = p + 1
            k = k + 1
        # Strip a trailing '/' the sentinel may include (`home/`).
        if out[p - 1] == 47:
            p = p - 1
    # Append the remainder of name (after the `#word` segment).
    if name[rest_start] == 47:
        # The remainder already has a leading '/'.
        pass
    elif name[rest_start] != 0:
        # Insert a '/' between dir_prefix and the remainder.
        out[p] = 47
        p = p + 1
    j: uint64 = rest_start
    while name[j] != 0 and p + 1 < cap:
        out[p] = cast[uint8](name[j])
        p = p + 1
        j = j + 1
    if p + 1 >= cap:
        return -1
    out[p] = 0
    return cast[int32](p)


def _open_named_subpath(dir_prefix: Ptr[uint8], name: Ptr[char],
                        rest_start: uint64) -> int32:
    # Compose a synthetic `/ext/<dir_prefix>/<rest>` path and call
    # the existing ext4 reader. This is the simplest pragmatic
    # Phase 6 implementation: with a single-mount ext4 state the
    # path resolution already lands on the right partition. Multi-
    # mount support is a future refactor.
    scratch: Array[512, uint8]
    if _compose_ext_path(dir_prefix, name, rest_start,
                         &scratch[0], 512) < 0:
        return ENOENT
    # Try the file reader first. Most named-root opens are file reads
    # (exec, cat) and that path is the cheapest.
    fd: int32 = _open_ext4_read(cast[Ptr[char]](&scratch[0]))
    if fd >= 0:
        return fd
    # NAMED-ROOT DIRECTORY OPEN (the `enter debian { /bin/ls / }` fix).
    # A Linux binary doing open("/", O_DIRECTORY)+getdents — busybox ls,
    # or any libc opendir — arrives here after `bind '#distro' /`
    # rewrote "/" to `#by-id/<uuid>/distro`, i.e. the composed path is
    # `/ext/distro` (a DIRECTORY, not a file). _open_ext4_read returns
    # ENOENT for a directory, so without this arm the open failed and
    # `ls /` reported "No such file or directory" / a write to "/foo"
    # reported "nonexistent directory" — the native-vs-Debian root
    # isolation looked broken because the Debian root was simply
    # unopenable. sys_listdir (the native Adder `ls`) sidestepped this
    # via vfs_listdir's `#`-arm, hence the asymmetry. Mirror that here:
    # if the composed path resolves to an ext4 directory, open it as a
    # readdir FD so getdents works. strip the "/ext" prefix the same
    # way ext4_resolve_dir expects (post-/ext/-strip tail; "" = root).
    rel: Ptr[char] = vfs_fs_rel(cast[Ptr[char]](&scratch[0]))
    if ext4_resolve_dir(rel) != 0:
        return _open_dir_ext(cast[Ptr[char]](&scratch[0]))
    return ENOENT


def _create_named_subpath(dir_prefix: Ptr[uint8], name: Ptr[char],
                          rest_start: uint64) -> int32:
    # WRITE-side analog of _open_named_subpath: compose the synthetic
    # `/ext/<dir_prefix>/<rest>` path for a named-root reference and
    # open-or-create it on ext4. This is what makes a write INSIDE the
    # Debian subsystem (`enter debian { sh -c 'echo x > /foo' }`, or
    # apt/dpkg laying down package files) land in the partition's
    # `distro/` subtree — `bind '#distro' /` rewrote "/foo" to
    # `#by-id/<uuid>/distro/foo`, which composes to `/ext/distro/foo`.
    # Without this, vfs_open_write's `#`-arm fell through to the
    # READ-only _open_hash_alias path, so a distro-side create reported
    # "nonexistent directory" and apt could not install anything.
    # Routing the create here (NOT to the native root) is also what
    # keeps the write OUT of sysroot: the composed path carries the
    # frozen `distro` dir prefix, so the bytes can only land under
    # distro/.
    scratch: Array[512, uint8]
    if _compose_ext_path(dir_prefix, name, rest_start,
                         &scratch[0], 512) < 0:
        return ENOENT
    eslot: int32 = ext4_open_create_or_trunc(
        vfs_fs_rel(cast[Ptr[char]](&scratch[0])))
    if eslot < 0:
        return ENOSPC
    # fd→Chan fold: a named-root (sentinel multi-root) write open lands
    # the same DEV_EXT4_FILE pool-chan fd as every other ext4 write — the
    # composed `/ext/<dir_prefix>/<rest>` path keeps the write inside the
    # named root's frozen dir prefix; only the fd plumbing changed.
    e_cid: int32 = namec_open_ext4_file(eslot)
    if e_cid < 0:
        ext4_close(eslot)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(e_cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_CHAN_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](cast[uint32](e_cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _open_hash_named_write(name: Ptr[char]) -> int32:
    # WRITE-side dispatch for a LONG-FORM named-root path
    # (`#by-id/<partuuid>/<dir>/<rest>` or `#<word>[<N>]/<rest>`).
    # Mirrors _open_hash_long's resolution but routes to the ext4
    # create path instead of the read path. Returns a positive fd, or
    # a negative errno (incl. P9_NO_MOUNT when this is NOT a long-form
    # named root, so the caller can fall through to the device-letter
    # _open_hash_alias path).
    word_buf: Array[40, uint8]
    pos: int32 = 0
    word_end: uint64 = 0
    if _hash_word_extract(name, &word_buf[0], 40, &pos, &word_end) < 0:
        return P9_NO_MOUNT
    if _hash_is_by_id(&word_buf[0]) != 0:
        if name[word_end] != 47:
            return P9_NO_MOUNT
        # Parse the partuuid up to the next '/'.
        pu_buf: Array[40, uint8]
        i: uint64 = word_end + 1
        o: uint64 = 0
        while name[i] != 0 and name[i] != 47 and o + 1 < 40:
            pu_buf[o] = cast[uint8](name[i])
            o = o + 1
            i = i + 1
        pu_buf[o] = 0
        if o == 0:
            return P9_NO_MOUNT
        if byid_lookup(&pu_buf[0]) == 0:
            return P9_NO_MOUNT
        dir_buf: Array[256, uint8]
        dir_buf[0] = 0
        byid_lookup_dir(&pu_buf[0], &dir_buf[0], 256)
        return _create_named_subpath(&dir_buf[0], name, i)
    # Bare `#<word>[<N>]/<rest>` (unfrozen named-root reference).
    sel: int32 = pos
    if sel == 0:
        sel = 1
    if name_lookup_at(&word_buf[0], sel) == 0:
        return P9_NO_MOUNT
    dir_buf2: Array[256, uint8]
    if name_lookup_dir(&word_buf[0], sel, &dir_buf2[0], 256) < 0:
        return P9_NO_MOUNT
    return _create_named_subpath(&dir_buf2[0], name, word_end)


def _ns_ext4_slurp_by_id(name: Ptr[char], buf_out: Ptr[uint64],
                         size_out: Ptr[uint64]) -> int32:
    # FD-LESS read of an ext4-backed `#by-id/<partuuid>/<dir>/<rest>`
    # path into a freshly kmalloc'd buffer. Returns 1 on success
    # (buf_out / size_out filled, caller owns the buffer), 0 if `name`
    # is not a resolvable `#by-id` ext4 path, -1 on a read/alloc error.
    #
    # WHY THIS EXISTS (the M16.img boot keystone): the kernel ELF-loads
    # /init at boot:36 — BEFORE the first user task is created (boot:38).
    # The boot/idle task has no usable fd table, so vfs_open() of the
    # resolved `#by-id/.../sysroot/init` path returns -EMFILE. ext4's
    # ext4_resolve_file + ext4_read_file need no fd, so we read the
    # partition file directly here. This is what lets a cpio-less
    # installed disk boot its real /init off ext4.
    if name[0] != cast[uint8]('#'):
        return 0
    word_buf: Array[40, uint8]
    pos: int32 = 0
    word_end: uint64 = 0
    if _hash_word_extract(name, &word_buf[0], 40, &pos, &word_end) < 0:
        return 0
    if _hash_is_by_id(&word_buf[0]) == 0:
        return 0
    if name[word_end] != 47:                     # need '/' before partuuid
        return 0
    partuuid_start: uint64 = word_end + 1
    # Parse the partuuid up to the next '/'.
    pu_buf: Array[40, uint8]
    i: uint64 = partuuid_start
    o: uint64 = 0
    while name[i] != 0 and name[i] != 47 and o + 1 < 40:
        pu_buf[o] = cast[uint8](name[i])
        o = o + 1
        i = i + 1
    pu_buf[o] = 0
    if o == 0:
        return 0
    if byid_lookup(&pu_buf[0]) == 0:
        return 0
    # Honor the by-id entry's stored sentinel relpath (same as
    # _open_hash_by_id). A frozen `bind '#sysroot' /` baked the dir
    # into the path, so the remainder from `i` already carries
    # `/sysroot/<rest>` and dir_prefix is empty; for a bare reference
    # the stored dir is applied.
    dir_buf: Array[256, uint8]
    dir_buf[0] = 0
    byid_lookup_dir(&pu_buf[0], &dir_buf[0], 256)
    scratch: Array[512, uint8]
    if _compose_ext_path(&dir_buf[0], name, i, &scratch[0], 512) < 0:
        return -1
    # scratch is now `/ext/<dir>/<rest>`; strip the `/ext/` prefix so
    # ext4_resolve_file walks relative to the partition root.
    rel: Ptr[char] = vfs_fs_rel(cast[Ptr[char]](&scratch[0]))
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(rel, &inum, &fsize) == 0:
        return -1
    if fsize == 0 or fsize > _NS_BLOB_MAX:
        return -1
    buf: uint64 = kmalloc(fsize)
    if buf == 0:
        return -1
    total: uint64 = 0
    while total < fsize:
        n: int64 = ext4_read_file(inum, total, fsize - total,
                                  cast[Ptr[uint8]](buf + total))
        if n <= 0:
            break
        total = total + cast[uint64](n)
    if total == 0:
        kfree(buf)
        return -1
    buf_out[0] = buf
    size_out[0] = total
    return 1


def _open_hash_alias(name: Ptr[char], wr: int32) -> int32:
    # V3.5: Plan 9 `#X` device-alias dispatch. `wr` is 1 for an
    # OWRITE/ORDWR open, 0 for OREAD; threaded to `#c/<leaf>` so the
    # namec write-mode probe (e.g. /dev/hostname write) is honoured when
    # the open arrives through the `bind '#c' /dev` rewrite.
    #
    # Each letter routes opens to a different kernel device. Userspace
    # init (user/init.ad) does the `bind '#X' /<conventional>` calls
    # at boot; subsequent opens of the conventional path arrive here
    # already-rewritten by ns_walk to the `#X` form.
    #
    #   '#s'        -> devsrv directory listing (`/srv` semantics).
    #   '#s/<name>' -> devsrv srvfd lookup (`/srv/<name>` semantics).
    #   '#p'        -> ENOENT (no synthetic listing of /proc itself yet).
    #   '#p/<pid>/<file>' -> devproc dispatch (`/proc/<pid>/<file>`).
    #   '#c'        -> /dev/cons-equivalent (read keyboard + UART RX,
    #                  write printk + serial + framebuffer).
    #   '#/'        -> empty-directory "root slot" (`/n` semantics —
    #                  conventional mount-point parent; child Pgrps
    #                  populate via `bind '#/' /n` + `mount srv /n/<x>`).
    #
    # Phase 6 (FS-discovery, docs/rootfs_partition.md): long-form
    # device names land here too. `#<word>[<N>]/...` where word is a
    # sentinel-declared name routes through chan.ad's named-stack
    # (top = #word, position N = #wordN). `#by-id/<partuuid>/...`
    # routes through the persistent by-id alias table.
    #
    # Anything else is ENOENT — extending the alphabet is a V4-or-
    # later question (`#e` envdev, `#d` devdir, etc.).
    if name[1] == 0:
        # Bare '#'.
        return ENOENT
    # Long-form name dispatch: if name[1] is a lowercase letter AND
    # name[2] is also a [a-z0-9-] (i.e., we have a multi-char word
    # rather than a single-char built-in), route through the named-
    # stack. The single-char built-ins ('s', 'p', 'c', '/', 'd')
    # remain reachable via the legacy arm below — their second char
    # is either NUL or '/'.
    if _is_lower_letter(name[1]) != 0 and _is_word_continuation(name[2]) != 0:
        return _open_hash_long(name)
    letter: int32 = name[1]
    # '#s' family — devsrv.
    if letter == 115:                                  # 's'
        if name[2] == 0:
            return _open_dir_srv()
        if name[2] == 47 and name[3] != 0:             # '#s/<...>'
            # devsrv_open expects a NUL-terminated leaf (no slashes);
            # walk the leaf and stop at the next '/' or NUL.
            i: uint64 = 3
            while name[i] != 0:
                if name[i] == 47:
                    return ENOENT                      # nested
                i = i + 1
            # Pass the leaf pointer (name + 3) directly — devsrv_open's
            # internal _srv_streq is NUL-terminated.
            leaf: Ptr[char] = cast[Ptr[char]](
                cast[uint64](name) + 3)
            return _open_srv_name(leaf)
        return ENOENT
    # '#p' family — devproc. Translate to a `/proc/<pid>/<file>`
    # NUL-terminated scratch string and forward to devproc_open. The
    # translation is cheap (8-byte prefix swap) and keeps devproc.ad
    # ignorant of the alias surface — same code path as a literal
    # /proc/<pid>/<file> open from a task that hasn't run init's bind.
    if letter == 112:                                  # 'p'
        if name[2] == 0:
            return _open_dir_proc()                     # bare '#p' — list /proc
        if name[2] != 47:
            return ENOENT
        # '#p/kmsg' — the kernel printk ring buffer. rc.boot does
        # `bind /proc '#p'`, which makes a userland open of the
        # conventional path /proc/kmsg arrive here as '#p/kmsg' (it is
        # rewritten by ns_walk before vfs_open's static
        # is_proc_path() arm can see it). kmsg is system-wide, not a
        # per-process file, so devproc_open (pid/<file> only) would
        # reject it; route it straight to the static procfs renderer
        # so `dmesg` can drain the whole ring. _open_proc sizes the
        # kmsg fd's buffer to the full ring (see fs/procfs.ad's
        # proc_buf_size) so the complete kernel log is retrievable —
        # including the low-severity printk the console-loglevel gate
        # keeps off the live console once userland is interactive.
        if _path_eq_const(name, "#p/kmsg", 7) != 0:
            return _open_proc("/proc/kmsg")
        return _open_hash_proc(name)
    # '#c' — console. Same shape as /dev/cons; cons is a stateless
    # namec devtab cdev (DEV_CONS), so the open routes through namec.
    # Accepts '#c' bare AND '#c/<leaf>' so future devcons paths (e.g.
    # '#c/cons', '#c/consctl') can land here without a routing change.
    if letter == 99:                                   # 'c'
        # `#c` is the conventional /dev device server. Init does
        # `bind '#c' /dev`, so an open of /dev/<x> arrives here as
        # `#c/<x>`. Bare `#c` is the DIRECTORY itself (`ls /dev`):
        # enumerate the device children. `#c/<leaf>` forwards to the
        # well-known per-device handlers via _open_dev_leaf (cons / null
        # / zero / blk / namec cdevs) so the bind doesn't shadow them.
        if name[2] == 0:
            return _open_dir_dev()
        if name[2] == 47:                              # '#c/<leaf>'
            return _open_dev_leaf(cast[Ptr[char]](
                cast[uint64](name) + 3), wr)
        return ENOENT
    # '#b' — block-device server. Init does `bind '#b' /dev/blk`, so an
    # open of /dev/blk/<name>{,/size,/ctl} arrives here as `#b/<name>...`.
    # Bare `#b` is the DIRECTORY (`ls /dev/blk`): enumerate the live
    # device names via blk_listdir. `#b/<leaf>` resolves the per-device
    # byte/size/ctl stream through devblk_leaf_match — the SAME devblk
    # backend the literal /dev/blk/<name> path uses, just reached via the
    # namespace bind instead of the legacy string-match.
    if letter == 98:                                   # 'b'
        if name[2] == 0:
            return _open_dir_blk()
        if name[2] == 47:                              # '#b/<leaf>'
            blp: uint64 = 0
            blrc: int32 = devblk_leaf_match(
                cast[Ptr[char]](cast[uint64](name) + 3), &blp)
            if blrc == 1:
                return _open_blk_marked(blp)
            set_current_errstr("blk: no such device")
            return ENOENT
        return ENOENT
    # '#I' — the IP / networking device server. Init does
    # `bind '#I' /net`, so an open of /net/tcp/clone (or any
    # /net/<proto>/<N>/{ctl,data,status,local,remote}) arrives here as
    # `#I/tcp/clone` (post ns_walk rewrite). Bare `#I` and
    # `#I/<proto>` and `#I/<proto>/<N>` are DIRECTORIES (enumerated by
    # vfs_listdir's `#I` arm); concrete files resolve through the SAME
    # devnet backend the legacy /net literal path used, just reached via
    # the namespace bind. Plan 9 uses `#I` for the IP stack; uppercase so
    # it doesn't collide with the lowercase long-form word dispatch.
    if letter == 73:                                   # 'I'
        if name[2] == 0:
            return _open_net_dir("")
        if name[2] == 47:                              # '#I/<rest>'
            return _open_net_leaf(cast[Ptr[char]](
                cast[uint64](name) + 2))
        return ENOENT
    # '#/' — root-dir slot. Synthetic empty directory; identical
    # shape to V3's `/n` (V3.5 rename: the concept is "anywhere bind
    # can graft against an empty parent", not specifically /n).
    if letter == 47:                                   # '/'
        if name[2] == 0:
            return _open_dir_n()
        return ENOENT
    # '#d' — HAMSH §7 fd device. `#d/<N>` resolves to the channel
    # bound at the name /fd/<N> in the calling process's Pgrp. The
    # open installs an FD_CHAN_MARK fd carrying a DEV_DEVFD inline
    # chan id whose wid bits hold the fd-number N; namec's DEV_DEVFD
    # arms resolve the name through the per-Pgrp devfd table at I/O
    # time. This is the substrate stdio rides on — the Linux integer
    # fd 0/1/2/N is a Layer-2 mapping ONTO the name /fd/N, not the
    # name itself.
    if letter == 100:                                  # 'd'
        if name[2] == 0:
            return _open_dir_fd()                       # bare '#d' — list /fd
        if name[2] != 47 or name[3] == 0:              # need '#d/<N>'
            return ENOENT
        # Parse the decimal fd-number after '#d/'.
        fdnum: int32 = 0
        i: uint64 = 3
        while name[i] != 0:
            c: int32 = name[i]
            if c < 48 or c > 57:
                return ENOENT                          # non-digit
            fdnum = fdnum * 10 + (c - 48)
            i = i + 1
        return _open_devfd_marked(fdnum)
    return ENOENT


def _open_devfd_marked(fdnum: int32) -> int32:
    # Phase 4c: install an FD_CHAN_MARK fd carrying a DEV_DEVFD INLINE
    # chan id whose wid bits hold the fd-number N. Stateless at open
    # time — the backing channel is resolved per-read/write against
    # the calling task's Pgrp devfd table (namec's DEV_DEVFD arms), so
    # a child that inherits this fd resolves /fd/N in ITS namespace,
    # not the opener's. Inline ⇒ no pool slot, close is a no-op, and
    # the id is deterministic per N (stable fstat identity for free).
    if fdnum < 0 or fdnum > 255:
        return ENOENT                  # wid field is 8 bits
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_CHAN_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](
        cast[uint32](namec_chan_id_devfd(fdnum)))
    return fd


def _proc_is_fd_dir(name: Ptr[char]) -> int32:
    # True iff `name` (the `#p/<rest>` server-letter spelling) names the
    # /proc/<pid>/fd OR /proc/self/fd directory exactly — i.e. the leaf
    # after the pid component is "fd" with nothing following. Used by
    # _open_hash_proc to route an open of that path to a directory fd
    # (devproc_fd_listdir) instead of the devproc text-leaf. name[0]='#',
    # name[1]='p', name[2]='/', so the pid component starts at name[3].
    i: uint64 = 3
    # "self/" alias?
    if name[i] == 115 and name[i + 1] == 101 and name[i + 2] == 108 \
            and name[i + 3] == 102 and name[i + 4] == 47:      # "self/"
        i = i + 5
    else:
        if name[i] < 48 or name[i] > 57:                       # not a digit
            return 0
        while name[i] >= 48 and name[i] <= 57:
            i = i + 1
        if name[i] != 47:                                      # need '/'
            return 0
        i = i + 1
    # Leaf must be exactly "fd".
    if name[i] == 102 and name[i + 1] == 100 and name[i + 2] == 0:
        return 1
    return 0


def _open_dir_proc_fd(path_ptr: Ptr[char]) -> int32:
    # Open /proc/<pid>/fd (or /proc/self/fd) as a LISTABLE directory fd.
    # Resolve the pid from the conventional path (`self` -> calling task),
    # render the numeric open-fd names into a kmalloc'd "N\n" buffer via
    # devproc_fd_listdir, and install it as an FD_CHAN_MARK dir fd so
    # getdents64 walks it. This is the directory apt's ExecFork() opendir()s
    # to take its fast fd-close path. path_ptr is "/proc/<pid>/fd" or
    # "/proc/self/fd" (NUL-terminated).
    pid: uint64 = 0
    j: uint64 = 6                                              # past "/proc/"
    if path_ptr[6] == 115 and path_ptr[7] == 101 \
            and path_ptr[8] == 108 and path_ptr[9] == 102 \
            and path_ptr[10] == 47:                            # "self/"
        pid = current_task_pid()
    else:
        while path_ptr[j] >= 48 and path_ptr[j] <= 57:
            pid = pid * 10 + cast[uint64](path_ptr[j] - 48)
            j = j + 1
    slot: int32 = task_lookup_by_pid(pid)
    if slot < 0:
        set_current_errstr("no such pid")
        return ENOENT
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        vfs_close(fd)
        return cast[int32](-12)                               # -ENOMEM
    n: int64 = devproc_fd_listdir(slot, cast[Ptr[uint8]](buf), DIR_BUF_SIZE)
    if n < 0:
        kfree(buf)
        vfs_close(fd)
        return ENOENT
    return _install_dir_fd(fd, buf, n)


def _proc_is_pid_dir(name: Ptr[char]) -> int32:
    # True iff `name` (the `#p/<rest>` server-letter spelling) names a
    # BARE per-pid directory — `#p/<digits>` or `#p/self` with nothing
    # after (a lone trailing '/' tolerated). This is the node busybox
    # ls/ps stat()s (via readdir("/proc") -> stat("/proc/<pid>")) before
    # enumerating its leaves; without this arm the open fell through to
    # the static renderer (_open_proc -> proc_render), which only knows
    # the flat well-known files and ENOENT'd every pid dir. name[0]='#',
    # name[1]='p', name[2]='/', so the pid component starts at name[3].
    i: uint64 = 3
    if name[i] == 115 and name[i + 1] == 101 and name[i + 2] == 108 \
            and name[i + 3] == 102:                        # "self"
        i = i + 4
    else:
        if name[i] < 48 or name[i] > 57:                   # not a digit
            return 0
        while name[i] >= 48 and name[i] <= 57:
            i = i + 1
    # Nothing (or a bare trailing '/') may follow for it to be the
    # directory itself rather than a leaf under it.
    if name[i] == 0:
        return 1
    if name[i] == 47 and name[i + 1] == 0:
        return 1
    return 0


def _open_dir_proc_pid(name: Ptr[char]) -> int32:
    # Open a bare `#p/<pid>` (or `#p/self`) as a LISTABLE directory fd.
    # devproc_listdir("/<pid>", ...) renders the per-task leaf names
    # (status, stat, cmdline, cwd, fd, ...) into a NAME\n buffer, and
    # _install_dir_fd binds it as a DEV_DIR_FILE chan fd so vfs_fd_is_dir
    # reports S_IFDIR — which is what lets busybox ls/ps stat the pid dir
    # without ENOENT and getdents64 its leaf files. `name` is "#p/<rest>";
    # the server-relative sub devproc_listdir wants is "/<rest>", i.e.
    # &name[2] (name[2] is the leading '/').
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        vfs_close(fd)
        return cast[int32](-12)                            # -ENOMEM
    n: int64 = devproc_listdir(cast[Ptr[char]](&name[2]),
                               cast[Ptr[uint8]](buf), DIR_BUF_SIZE)
    if n < 0:
        kfree(buf)
        vfs_close(fd)
        return ENOENT                                      # no such pid
    return _install_dir_fd(fd, buf, n)


def _open_hash_proc(name: Ptr[char]) -> int32:
    # Translate `#p/<rest>` to `/proc/<rest>` in a 96-byte scratch and
    # route. Two consumers:
    #   * `/proc/<pid>/<file>` — devproc_open (per-task introspection)
    #   * `/proc/<static>`     — proc_render via _open_proc
    #                            (version/uptime/tasks/meminfo/cpuinfo/
    #                             mounts/cmdline/kmsg/fs/by-name/<word>/
    #                             fs/by-id/<uuid>/fs/anonymous)
    # The static set landed expanded in Phase 8 (FS-discovery work);
    # `cat /proc/fs/by-name/distro` arrives here as `#p/fs/by-name/distro`
    # after rc.boot's `bind '#p' /proc` rewrite.
    scratch: Array[96, uint8]
    scratch[0] = 47                                    # '/'
    scratch[1] = 112                                   # 'p'
    scratch[2] = 114                                   # 'r'
    scratch[3] = 111                                   # 'o'
    scratch[4] = 99                                    # 'c'
    # name[0]='#', name[1]='p', name[2]='/', leaf starts at name[3].
    j: uint64 = 5
    i: uint64 = 2                                      # keep the '/'
    while name[i] != 0:
        if j + 1 >= 96:
            return ENOENT                              # path too long
        scratch[j] = cast[uint8](name[i] & 0xFF)
        j = j + 1
        i = i + 1
    scratch[j] = 0
    path_ptr: Ptr[char] = cast[Ptr[char]](&scratch[0])
    # /proc/<pid>/fd arm: this is a LISTABLE directory (Linux semantics),
    # not a text leaf. apt's ExecFork() opendir()s /proc/self/fd and
    # getdents the numeric fd names to take its fast fd-close path
    # (skipping the 1024-fcntl(F_SETFD) storm). Serve it as an
    # FD_CHAN_MARK directory fd backed by a rendered "N\n" listing so
    # getdents64 walks it like every other dir. Matched BEFORE
    # devproc_path_match so the `fd` leaf no longer opens as a buf file.
    if _proc_is_fd_dir(name) != 0:
        return _open_dir_proc_fd(path_ptr)
    # Bare /proc/<pid> (or /proc/self) directory arm: open it as a
    # listable dir fd (S_IFDIR) so busybox ls/ps can stat the pid dir it
    # just got from readdir("/proc"). Matched BEFORE devproc_path_match
    # (which only recognises /proc/<pid>/<leaf>) and before the static
    # renderer (which ENOENT'd every pid dir). QA-N17.
    if _proc_is_pid_dir(name) != 0:
        return _open_dir_proc_pid(name)
    # /proc/<pid>/<file> arm: forward to devproc_open. devproc_path_match
    # returns 1 iff the path is `/proc/<digits>/<known-tail>`.
    if devproc_path_match(path_ptr) != 0:
        rc: int64 = devproc_open(path_ptr)
        if rc < 0:
            return ENOENT
        return _install_proc_fd(cast[uint32](rc & 0xFFFFFFFF))
    # Static-renderer arm: kmsg / fs/* / version / uptime / ...
    return _open_proc(path_ptr)


# O_TRUNC plumbing for the tmpfs write-open path. The write-create backend
# dispatch (_vfs_open_write_post_perm -> tmpfs_open_for_write_t) is diffuse,
# so rather than thread a `do_trunc` arg through every backend the
# uniprocessor non-preemptible syscall arm latches the intent in this global
# (same pattern as _vfs_open_orig_path): 1 = truncate an existing file to 0
# (the default, == O_TRUNC), 0 = preserve its contents (O_WRONLY/O_RDWR
# without O_TRUNC — dpkg re-opens an unpacked control file this way). Set by
# vfs_open_write_t, consumed + reset in the tmpfs leg of post_perm.
_vfs_write_no_trunc: int32 = 0


def vfs_open_write_t(name: Ptr[char], do_trunc: int32) -> int32:
    # vfs_open_write honouring the caller's O_TRUNC bit. do_trunc==0 keeps
    # existing file content; ==1 truncates (the legacy default).
    if do_trunc != 0:
        _vfs_write_no_trunc = 0
    else:
        _vfs_write_no_trunc = 1
    r: int32 = vfs_open_write(name)
    _vfs_write_no_trunc = 0
    return r


def vfs_open_write(name: Ptr[char]) -> int32:
    # F3 #448: server-boundary perm gate on the write/create path. Same
    # shape as vfs_open but with PERM_W. The kernel-mediator entry point
    # vfs_open_write_kernel reuses _vfs_open_write_post_perm without the
    # gate.
    #
    # F10-1 (#454): resolve through the calling Pgrp's mount table FIRST
    # so the F1 substrate "unbound = ENOENT" gate fires before any other
    # dispatch, and chan_permission_check routes on the resolved
    # `#X/...` form (so the proper per-server perm body fires — without
    # the resolve, `/proc/self/ctl` defaulted to cpio's "writes are
    # categorically refused" arm instead of devproc's "let the backend
    # decide" arm).
    resolved: Array[256, uint8]
    rrc: int32 = resolve_path_create(name, &resolved[0], 256)
    if rrc != 0:
        return rrc
    rname: Ptr[char] = cast[Ptr[char]](&resolved[0])
    pc_wrc: int32 = chan_permission_check(rname, PERM_W)
    if pc_wrc != 0:
        _vfs_perm_set_errstr(rname)
        return pc_wrc
    fd: int32 = _vfs_open_write_post_perm(rname)
    # Phase D follow-up: stamp the per-fd opened-path slot — see
    # vfs_open above for the rationale.
    if fd >= 0:
        task: Ptr[TaskStruct] = fd_owner_task(current_task())
        task_fd_set_opened_path(task, cast[uint64](fd), &resolved[0])
        # dcache: a write-open may have CREATED the file (O_CREAT), which
        # turns a previously-cached NEGATIVE dentry for `name` live. The
        # create path is diffuse across backends, so bump the dcache
        # generation here so a stale negative entry can never be served
        # after a create. (Write-opens are far rarer than the read/stat/
        # exec resolves the dcache accelerates, so this is cheap.)
        fcache_dcache_bump_gen()
    return fd


def _vfs_open_write_post_perm(name: Ptr[char]) -> int32:
    # Open-or-create for write with O_CREAT | O_WRONLY | O_TRUNC
    # semantics, which is what `> file` shell redirection wants.
    # Writable backends:
    #   - /dev/null   — discards everything
    #   - /dev/zero   — same; writes are no-ops
    #   - tmpfs (in-RAM /tmp/*)
    #   - ext4 root (/ext/*) since M16.64 — single-block files only
    # cpio (initramfs) is read-only baked-in; procfs is read-only by
    # design; FAT writes aren't wired.
    #
    # F10-1 (#454): the namespace-resolved post-perm body. vfs_open_write
    # (and vfs_open_write_kernel) have ALREADY run resolve_path through
    # the calling task's Pgrp, so `name` is already the resolved
    # backend-key form. See _vfs_open_post_perm's header for the full
    # rationale.
    rname: Ptr[char] = name
    # cgroup v2 control-file OWRITE: `echo N > /sys/fs/cgroup/<g>/pids.max`
    # (etc.). MUST be checked BEFORE the `#`-alias arm below: a userland
    # open resolves to the localized "#r/fs/cgroup/<g>/<leaf>" spelling,
    # which would otherwise be routed to the (read-only) cpio server by
    # the `#` arm. The cgroupfs server admits a write only on a real
    # control leaf of an existing cgroup; the bytes flow through the
    # resulting fd into the live object (vfs_write FD_CGROUP_WRITE_MARK).
    if cgroup_fs_is_writable_leaf(rname) != 0:
        cgw0: int32 = _open_cgroup_write(rname)
        if cgw0 != ENOENT:
            return cgw0
    # V3.5: `#X` device aliases route through _open_hash_alias for
    # consistency with the read side. devcons is the only `#X` device
    # with a meaningful write path today (#s posts are sys_srv_post,
    # not file-write), but routing through one place keeps the
    # dispatch logic in lockstep when V4 adds writable srv/proc nodes.
    if rname[0] == 35:                                 # '#'
        # Named-root write-create first (e.g. apt/dpkg in `enter debian`
        # writing under #distro). Returns P9_NO_MOUNT when NOT a
        # long-form named root, so device-letter writes (#c cons etc.)
        # fall through to _open_hash_alias unchanged.
        wfd: int32 = _open_hash_named_write(rname)
        if wfd != P9_NO_MOUNT:
            return wfd
        return _open_hash_alias(rname, 1)              # OWRITE
    # /dev/null and /dev/zero are stateless namec devtab cdevs (DEV_NULL
    # / DEV_ZERO); the _namec_open(name, 1) OWRITE probe below resolves
    # them like the rest of the cdev family.
    # F9 #452 (namespace-purity): the literal `/dev/auth` pre-probe arm
    # for the OWRITE path is GONE. /dev/auth is now matched by namec's
    # devtab (NAMEC_NEEDS_AUTH sentinel) and the _namec_open below routes
    # the stateful AuthSlot allocation back through _open_auth_marked,
    # identically to the OREAD path. The ORDWR newshell idiom (write
    # user/pass, then read the verdict on the same fd) goes through the
    # OWRITE namec arm here.
    # F4 #449: PTY (and FUSE / cgroup) OWRITE path goes through the same
    # l2_path_open_hook dispatch as OREAD, with accmode = 1. The PTY
    # path-arm literals that lived here are GONE; the linux_abi side
    # decides which kinds even accept OWRITE (FUSE/cgroup return
    # L2_PATH_NOT_HANDLED for OWRITE because their write semantics flow
    # through the resulting fd, not at open).
    if l2_path_open_hook != cast[Fn[int32, Ptr[char], int32]](0):
        l2_wfd: int32 = l2_path_open_hook(rname, 1)
        if l2_wfd != L2_PATH_NOT_HANDLED:
            return l2_wfd
    # /dev/blk/<name>{,/size,/ctl} OWRITE side and /dev/loop/ctl OWRITE
    # side are namespace-resolved exactly like the OREAD path: the
    # installer's SYS_OPEN_WRITE of /dev/blk/<name> arrives rewritten to
    # `#b/<name>` (served by devblk_leaf_match in the `#`-arm above), and
    # losetup's write of /dev/loop/ctl arrives as `#c/loop/ctl` (served
    # by _open_dev_leaf's namec devtab probe). The legacy literal path
    # arms are GONE.
    # Phase D: the universal namec open path, OWRITE side. The same
    # probe vfs_open uses for reads — namec() walks the Pgrp mount
    # table, produces a local-device Chan for a /dev/<name> cdev or a
    # mounted-9P Chan for a path under a 9P SRV mount, and _namec_open
    # installs ONE FD_CHAN_MARK fd. Read-only cdevs (/dev/time,
    # /dev/version, ...) still open cleanly here; their devtab write
    # arm returns -1 so the rejection surfaces at write(2), exactly as
    # it did through the old FD_<NAME>_MARK arms. /dev/hostname's
    # devtab write arm accepts bytes. A P9_NO_MOUNT result means namec
    # does not own this path — fall through to the FS write routing.
    # ARCH §10: the /net file tree opens identically for read and write
    # — a /net file (ctl, data, ...) is r/w. It is a bound `#I` IP
    # device server now (`bind '#I' /net`); an open of /net/<...> arrives
    # rewritten to `#I/<...>` and is served by the `#`-dispatch arm in
    # vfs_open_write's head, so there is no literal /net match here.
    chan_wfd: int32 = _namec_open(rname, 1)            # OWRITE
    if chan_wfd != P9_NO_MOUNT:
        if chan_wfd == ENOENT:
            # The path is under a 9P mount but the file doesn't exist
            # yet — create it through namec_create (Tcreate via the
            # in-kernel 9P client). namec_create returns P9_NO_MOUNT
            # only if the SRV-mount probe somehow misses on the retry
            # (it won't — the prefix matched a line ago); treat that
            # as the original ENOENT to stay deterministic.
            chan_cfd: int32 = _namec_open_create(rname)
            if chan_cfd != P9_NO_MOUNT:
                return chan_cfd
            return ENOENT
        return chan_wfd
    # /proc/<pid>/* also opens on the OWRITE path (future note(2)
    # delivery via write("/proc/<pid>/note", ...)). It is a bound `#p`
    # proc device server now (`bind '#p' /proc`); an OWRITE open of
    # /proc/<pid>/<file> arrives rewritten to `#p/<pid>/<file>` and is
    # served by the `#`-dispatch arm at the head of vfs_open_write
    # (_open_hash_alias -> _open_hash_proc -> devproc_open). The legacy
    # literal devproc_path_match arm that used to sit here is GONE — all
    # /proc access is namespace-resolved, never a strcmp.
    # Phase D: the V4.1-era 9P SRV-mount OWRITE probe (_try_open_p9_write
    # / _try_create_p9 → FD_P9_MARK) is gone — the _namec_open OWRITE
    # probe above already routes a 9P-mounted path (walk+Topen, or
    # walk+Tcreate on a miss) to a Chan and installs a unified
    # FD_CHAN_MARK fd.
    if vfs_fs_kind(rname) == FS_KIND_TMPFS:
        # tmpfs_open_for_write returns a negative TMPFS_E* on failure
        # (-2 missing parent dir, -17 the path is a directory, -20 a
        # parent component is a file, -28 out of slots). Propagate it
        # verbatim so the caller's errstr reflects the real cause.
        # #155: a not-yet-existing tmpfs path becoming open-for-write is
        # an inotify IN_CREATE on its parent directory.
        ino_existed: int32 = tmpfs_lookup(rname)
        # Honour the caller's O_TRUNC intent: an O_WRONLY/O_RDWR re-open
        # WITHOUT O_TRUNC must keep existing content (the global defaults to
        # truncate, matching `> file` shell redirection + every create).
        do_trunc: int32 = 1
        if _vfs_write_no_trunc != 0:
            do_trunc = 0
        slot: int32 = tmpfs_open_for_write_t(rname, do_trunc)
        if slot < 0:
            return slot
        if ino_existed < 0:
            _vfs_inotify_notify(rname, IN_CREATE)
        # fd→Chan fold: a write-mode tmpfs fd shares the DEV_TMPFS_FILE
        # pool-chan path with the read fd (a tmpfs slot is mode-agnostic).
        # namec_write routes to tmpfs_write; namec_close frees no slot for
        # a named file (only anon memfd slots are reclaimed there).
        t_cid: int32 = namec_open_tmpfs_file(slot)
        if t_cid < 0:
            return EMFILE
        task: Ptr[TaskStruct] = fd_owner_task(current_task())
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            namec_close(t_cid)
            return EMFILE
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu] = FD_CHAN_MARK
        task[0].fd_pos[fdu] = 0
        task[0].fd_buf[fdu] = cast[uint64](cast[uint32](t_cid))
        task[0].fd_buflen[fdu] = 0
        return fd
    if vfs_fs_kind(rname) == FS_KIND_EXT4:
        # Subdir-aware (post-M16.x): ext4_open_create_or_trunc splits
        # `name` into parent + leaf, resolves the parent dir via
        # ext4_resolve_dir, and creates the file there. This is what
        # makes `cp -r SRC /ext/dst-on-disk` work end-to-end (cp -r
        # mkdir's the parent first via vfs_mkdir; this open lands the
        # per-file fd at THAT parent rather than the partition root).
        eslot: int32 = ext4_open_create_or_trunc(vfs_fs_rel(rname))
        if eslot < 0:
            return ENOSPC
        # fd→Chan fold: a write-mode ext4 fd shares the DEV_EXT4_FILE
        # pool-chan path with the read fd (the ext4 slot table is mode-
        # agnostic). namec_write routes to ext4_write_open_file;
        # namec_close → ext4_close releases the slot on last ref.
        e_cid: int32 = namec_open_ext4_file(eslot)
        if e_cid < 0:
            ext4_close(eslot)
            return EMFILE
        task: Ptr[TaskStruct] = fd_owner_task(current_task())
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            namec_close(e_cid)
            return EMFILE
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu] = FD_CHAN_MARK
        task[0].fd_pos[fdu] = 0
        task[0].fd_buf[fdu] = cast[uint64](cast[uint32](e_cid))
        task[0].fd_buflen[fdu] = 0
        return fd
    if vfs_fs_kind(rname) == FS_KIND_FAT:
        # M16.x §12.5: FAT write path. O_CREAT|O_TRUNC create, then
        # a write-mode slot. The fd is FD_FAT_MARK with the write bit
        # set in fd_buf so the dispatch tells write fds from read fds.
        wslot: int32 = fat_open_write(vfs_fs_rel(rname))
        if wslot < 0:
            return ENOSPC
        # fd→Chan fold: a write-mode FAT fd is a DEV_FAT_FILE pool chan
        # whose back_slot carries the write-slot index with the write
        # bit set (FAT_FD_WRITE_BIT). namec_write peels the bit and
        # forwards to fat_write_slot; namec_close → fat_close routes the
        # write-bit-tagged word back to the write-slot table.
        f_back: int32 = cast[int32](cast[uint64](wslot) | FAT_FD_WRITE_BIT)
        f_cid: int32 = namec_open_fat_file(f_back)
        if f_cid < 0:
            fat_close_write(wslot)
            return EMFILE
        task: Ptr[TaskStruct] = fd_owner_task(current_task())
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            namec_close(f_cid)
            return EMFILE
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu] = FD_CHAN_MARK
        task[0].fd_pos[fdu] = 0
        task[0].fd_buf[fdu] = cast[uint64](cast[uint32](f_cid))
        task[0].fd_buflen[fdu] = 0
        return fd
    return EROFS


def vfs_unlink(name: Ptr[char]) -> int32:
    # dcache: a name is going away (and a negative dentry may turn live on a
    # later create at the same path) — invalidate the dcache wholesale.
    fcache_dcache_bump_gen()
    # Mirrors fs/namei.c::do_unlinkat() at the smallest meaningful
    # scope: route by path prefix to the backing FS.
    #   /tmp/*  →  tmpfs_unlink
    #   /ext/*  →  ext4_unlink (M16.67, root dir + single-block scope)
    # Everything else falls back to -EROFS.
    if vfs_fs_kind(name) == FS_KIND_TMPFS:
        # #155: a successful tmpfs delete is an inotify IN_DELETE on the
        # parent directory.
        urc: int32 = tmpfs_unlink(name)
        if urc == 0:
            _vfs_inotify_notify(name, IN_DELETE)
        return urc
    if vfs_fs_kind(name) == FS_KIND_EXT4:
        return ext4_unlink(vfs_fs_rel(name))
    if vfs_fs_kind(name) == FS_KIND_FAT:
        # M16.x §12.5: FAT delete — frees the cluster chain and
        # tombstones the directory entry.
        if fat_delete(vfs_fs_rel(name)) != 0:
            return ENOENT
        return 0
    return EROFS


def vfs_rmdir(name: Ptr[char]) -> int32:
    fcache_dcache_bump_gen()                              # dcache: name gone
    # cgroup v2: `rmdir /sys/fs/cgroup/<g>` removes an EMPTY live cgroup
    # object (refused with -ENOTEMPTY while tasks remain attached), the
    # mirror of the vfs_mkdir cgroup arm. Route it into the object graph
    # before the on-disk rmdir routing.
    if is_cgroup_subgroup_path(name) != 0:
        return cgroup_fs_rmdir(name)
    # fs/namei.c::do_rmdirat() at the smallest meaningful scope: remove
    # an EMPTY directory, routed by path prefix to the backing FS.
    #   /tmp/*  →  tmpfs_unlink (already enforces empty-dir semantics,
    #              refusing a non-empty dir)
    #   /ext/*  →  ext4_rmdir (frees inode + data blocks, decrements the
    #              parent's nlink, tombstones the dirent; -ENOTEMPTY on
    #              a non-empty dir, -ENOTDIR on a non-dir target)
    #   /mnt/*  →  fat_delete (FAT dir removal)
    # Everything else falls back to -EROFS. Mirrors vfs_unlink's routing
    # exactly — the kernel rmdir(2) sysfile path should dispatch here.
    if vfs_fs_kind(name) == FS_KIND_TMPFS:
        # rmdir(2) MUST refuse a non-directory target with -ENOTDIR (and
        # leave it on disk). tmpfs_unlink removes a file OR an empty dir
        # indiscriminately, so calling it straight made rmdir() on a
        # regular tmpfs file SUCCEED and DELETE the file — which broke
        # dpkg's control-info check: dpkg probes each tmp.ci entry with
        # `rmdir(path)` and reads "success == it was a directory" (then
        # ohshit "package control info contained directory '<...>/control'")
        # while ENOTDIR means "regular file, fine". So a regular `control`
        # was both mis-reported as a directory AND silently unlinked.
        # Gate on the type first: only a real directory reaches the
        # empty-dir-enforcing tmpfs_unlink; a non-dir target returns
        # -ENOTDIR with no side effect. (tmpfs has no symlinks-to-dir
        # subtlety here — a symlink target is its own slot kind.)
        if tmpfs_path_is_dir(name) == 0:
            # Distinguish "not a directory" from "does not exist": a
            # missing name is -ENOENT, an existing non-dir is -ENOTDIR.
            if tmpfs_path_exists(name) == 0:
                return ENOENT
            return cast[int32](-20)                       # -ENOTDIR
        urc: int32 = tmpfs_unlink(name)
        if urc == 0:
            _vfs_inotify_notify(name, IN_DELETE)
        return urc
    if vfs_fs_kind(name) == FS_KIND_EXT4:
        return ext4_rmdir(vfs_fs_rel(name))
    if vfs_fs_kind(name) == FS_KIND_FAT:
        if fat_delete(vfs_fs_rel(name)) != 0:
            return ENOENT
        return 0
    return EROFS


def _mkdir_named_subpath(dir_prefix: Ptr[uint8], name: Ptr[char],
                         rest_start: uint64) -> int32:
    # mkdir analog of _create_named_subpath: compose the synthetic
    # `/ext/<dir_prefix>/<rest>` path for a named-root reference and
    # mkdir it on the live ext4 mount. ext4_mkdir_live does mkdir -p, so
    # a missing intermediate (`#sysroot/home/<user>` where `home/` does
    # not yet exist) is created too. Returns ext4_mkdir_live's verdict
    # (0 / -EEXIST / -ENOTDIR / -ENOENT / -EINVAL / -EROFS).
    scratch: Array[512, uint8]
    if _compose_ext_path(dir_prefix, name, rest_start,
                         &scratch[0], 512) < 0:
        return ENOENT
    return ext4_mkdir_live(vfs_fs_rel(cast[Ptr[char]](&scratch[0])))


def _hash_named_mkdir(name: Ptr[char]) -> int32:
    # mkdir dispatch for a LONG-FORM named-root path
    # (`#by-id/<partuuid>/<dir>/<rest>` or `#<word>[<N>]/<rest>`).
    # Mirrors _open_hash_named_write's resolution but routes to the ext4
    # mkdir path. This is what makes `mkdir /home/<user>` (which resolves
    # to `#sysroot/home/<user>` under the installed-boot `bind '#sysroot'
    # /`) and `mkdir '#<user>/Desktop'` (the useradd skel dirs on the
    # per-user home server) actually create directories instead of
    # falling through to the -EROFS tail. Returns P9_NO_MOUNT when NOT a
    # long-form named root so device-letter names (#c, #s, ...) fall
    # through to the caller's device/tmpfs routing unchanged.
    word_buf: Array[40, uint8]
    pos: int32 = 0
    word_end: uint64 = 0
    if _hash_word_extract(name, &word_buf[0], 40, &pos, &word_end) < 0:
        return P9_NO_MOUNT
    if _hash_is_by_id(&word_buf[0]) != 0:
        if name[word_end] != 47:
            return P9_NO_MOUNT
        pu_buf: Array[40, uint8]
        i: uint64 = word_end + 1
        o: uint64 = 0
        while name[i] != 0 and name[i] != 47 and o + 1 < 40:
            pu_buf[o] = cast[uint8](name[i])
            o = o + 1
            i = i + 1
        pu_buf[o] = 0
        if o == 0:
            return P9_NO_MOUNT
        if byid_lookup(&pu_buf[0]) == 0:
            return P9_NO_MOUNT
        dir_buf: Array[256, uint8]
        dir_buf[0] = 0
        byid_lookup_dir(&pu_buf[0], &dir_buf[0], 256)
        return _mkdir_named_subpath(&dir_buf[0], name, i)
    # Bare `#<word>[<N>]/<rest>` (unfrozen named-root reference).
    sel: int32 = pos
    if sel == 0:
        sel = 1
    if name_lookup_at(&word_buf[0], sel) == 0:
        return P9_NO_MOUNT
    dir_buf2: Array[256, uint8]
    if name_lookup_dir(&word_buf[0], sel, &dir_buf2[0], 256) < 0:
        return P9_NO_MOUNT
    return _mkdir_named_subpath(&dir_buf2[0], name, word_end)


def vfs_mkdir(name: Ptr[char]) -> int32:
    fcache_dcache_bump_gen()                # dcache: negative dentry may flip
    # cgroup v2: `mkdir /sys/fs/cgroup/<g>` creates a LIVE cgroup object
    # (with its control files visible via the cgroup_render dispatch),
    # not an on-disk directory. The cgroupfs server owns this name space;
    # route a one-level cgroup dir create straight into the object graph
    # before the tmpfs / 9P / ext4 routing. cgroup_fs_mkdir returns 0 /
    # -EEXIST / -ENOSPC / -EINVAL.
    if is_cgroup_subgroup_path(name) != 0:
        return cgroup_fs_mkdir(name)
    # fs/namei.c::do_mkdirat() at the smallest meaningful scope. The
    # caller passes an already-resolved absolute path.
    #   9P-mounted prefix  →  namec_mkdir (Tcreate DMDIR, mkdir -p)
    #   /tmp/*             →  tmpfs_mkdir (creates a dir entry under
    #                         the parent)
    #   /ext/*             →  ext4_mkdir_live (writes a real dir
    #                         entry on the live ext4 mount)
    #   else               →  -EROFS
    # The 9P arm comes FIRST: a path under a distrofs (or any 9P SRV)
    # mount must mkdir on the server, not fall through to the local
    # tmpfs/cpio routing. This is what lets `dpkg -i` create nested
    # package directories (/usr/bin, /usr/share/doc/<pkg>, ...) inside
    # an nsrun distrofs namespace. namec_mkdir returns NAMEC_FALLTHROUGH
    # when no 9P mount covers the path — then we fall to tmpfs.
    # TMPFS-SERVER `#t/...` FAST PATH. Inside an `enter linux { … }` ns the
    # writable /tmp is `bind '#t/tmp' /tmp`, so resolve_path localizes a
    # `/tmp/x` mkdir target to the tmpfs server key form `#t/tmp/x`. That
    # form must NOT go through namec_mkdir (which would match `#t` as a 9P
    # srv prefix and issue a Tcreate(DMDIR) the in-kernel tmpfs server does
    # not implement -> ENOSYS, breaking every `mkdir` inside the ns). The
    # tmpfs backend creates directories via tmpfs_mkdir, but its parent
    # walker (_resolve_parent / _mount_root) expects a literal `/tmp` or
    # `/var` prefix — so strip the leading `#t` (`#t/tmp/x` -> `/tmp/x`,
    # `#t/var/x` -> `/var/x`) and route straight there. This mirrors how
    # FILE writes already work (do_openchan -> tmpfs_open_for_write on a
    # `#t`-localized path); only the directory-create leg was unwired.
    # The `#t` server letter is ONLY matched when the char after `#t` is
    # '/' or NUL — mirroring _spec_localize's guard (fs/vfs.ad:4933). A
    # bare `#t<letter>` (e.g. `#tom/Desktop`, a per-user home server for a
    # user whose name starts with 't', or `#tmp`) is a MULTI-CHAR named
    # root, NOT the tmpfs server, and MUST fall through to the
    # `_hash_named_mkdir` arm below. Without the name[2] guard those roots
    # were mis-routed to tmpfs_mkdir("om/Desktop"), diverging from the
    # file open/read/stat paths (which all localize via _spec_localize) —
    # so `mkdir '#tom/Desktop'` silently landed in tmpfs instead of the
    # user's ext4 home subtree. resolve_path leaves `#<word>/...` verbatim.
    if name[0] == 35 and name[1] == 116 \
            and (name[2] == 0 or name[2] == 47):        # "#t" / "#t/..."
        # `#t` followed by '/' (or bare `#t`) -> the char after `#t` begins
        # the literal mount-relative path. `#t/tmp/x` has name[2]=='/'.
        if name[2] == 0:
            return EROFS                                # bare `#t` server root
        return tmpfs_mkdir(cast[Ptr[char]](cast[uint64](name) + 2))
    # LONG-FORM NAMED-ROOT `#<word>/...` (per-user home `#<name>`,
    # `#sysroot`, `#distro`, `#by-id/...`): compose the ext4 subpath and
    # mkdir on the live mount. Without this a `mkdir` of any path under
    # the installed-boot `bind '#sysroot' /` (every native path resolves
    # to `#sysroot/...`) and the useradd skel dirs (`#<name>/Desktop`)
    # fell through to the -EROFS tail. Returns P9_NO_MOUNT for a plain
    # device letter (#c/#s/#p/...) so those fall through unchanged.
    if name[0] == 35:                                   # '#'
        hmk: int32 = _hash_named_mkdir(name)
        if hmk != P9_NO_MOUNT:
            return hmk
    # TMPFS arm BEFORE the 9P namec arm: a `/tmp/x` or `/var/x` target the
    # GLOBAL mount table owns as tmpfs must create directly via tmpfs_mkdir.
    # Inside an `enter linux { … }` ns the writable /tmp is `bind '#t/tmp'
    # /tmp`, so the Pgrp mtab makes `chan_find_srv_prefix('/tmp/x')` match
    # the `#t` SRV bind — namec_mkdir would then issue a 9P Tcreate(DMDIR)
    # the in-kernel tmpfs server doesn't implement (-> ENOSYS, breaking
    # EVERY mkdir in the ns: dpkg --root=/tmp/inst, `mkdir -p`, …). Routing
    # tmpfs-owned paths here first sidesteps that. tmpfs_mkdir returns
    # 0 / -ENOENT / -EEXIST / -ENOTDIR / -ENOSPC / -ENAMETOOLONG verbatim.
    if vfs_fs_kind(name) == FS_KIND_TMPFS:
        return tmpfs_mkdir(name)
    nm_rc: int32 = namec_mkdir(name)
    if nm_rc != NAMEC_FALLTHROUGH:
        if nm_rc < 0:
            return ENOENT
        return 0
    # /ext/*: mkdir on the live ext4 mount. Strip the /ext prefix so
    # ext4_mkdir_live sees a partition-relative path. ext4_mkdir_live
    # returns 0 / -EEXIST / -ENOTDIR / -ENOENT / -EINVAL / -EROFS / -1.
    if vfs_fs_kind(name) == FS_KIND_EXT4:
        return ext4_mkdir_live(vfs_fs_rel(name))
    return EROFS


def vfs_named_mkdir_selftest() -> int32:
    # Regression guard for the `#t`-prefix collision in vfs_mkdir. A
    # MULTI-CHAR named root whose name starts with 't' (the useradd home
    # server `#tom` for a user named "tom", `#tux`, `#tmp`, ...) must NOT
    # be mistaken for the single-letter `#t` tmpfs server. Before the
    # name[2] guard, `vfs_mkdir("#tom/Desktop")` fell into the `#t`
    # fast-path and called `tmpfs_mkdir("om/Desktop")` — which fails its
    # parent walk and SILENTLY drops the create (exactly useradd's
    # "skel dir never materialised" symptom for a 't'-named user), instead
    # of composing the ext4 subtree path like the file open/read/stat
    # paths (all of which localize via _spec_localize's own name[2] guard).
    #
    # This proves the FULL vfs_mkdir path: register a scratch 't'-prefixed
    # named root anchored at the ext4 root (empty dir -> composes to
    # `/ext/<leaf>`), mkdir a fresh dir THROUGH vfs_mkdir, and confirm it
    # materialised on the live ext4 mount. Armed by the same
    # /etc/ext4-mkdir-test marker as ext4_mkdir_selftest.
    empty: Array[1, uint8]
    empty[0] = 0
    # "tselfroot" — 't'-prefixed, multi-char; NOT the `#t` server.
    troot: Array[10, uint8]
    troot[0] = cast[uint8]('t')
    troot[1] = cast[uint8]('s')
    troot[2] = cast[uint8]('e')
    troot[3] = cast[uint8]('l')
    troot[4] = cast[uint8]('f')
    troot[5] = cast[uint8]('r')
    troot[6] = cast[uint8]('o')
    troot[7] = cast[uint8]('o')
    troot[8] = cast[uint8]('t')
    troot[9] = 0
    # chan_ref just has to be non-zero for name_lookup_at to report the
    # root exists; the mkdir routing uses only the (empty) dir prefix.
    if name_push(&troot[0], 1, &empty[0], &empty[0]) != 0:
        printk0("[vfs-named-mkdir] FAIL: name_push scratch root\n")
        return -1
    # `#tselfroot/tselfmkr` -> _hash_named_mkdir -> /ext/tselfmkr on ext4.
    leaf: Ptr[char] = "tselfmkr"
    if ext4_resolve_dir(leaf) != 0:
        printk0("[vfs-named-mkdir] FAIL: target exists pre-mkdir\n")
        return -1
    mrc: int32 = vfs_mkdir(cast[Ptr[char]]("#tselfroot/tselfmkr"))
    if mrc != 0:
        printk1("[vfs-named-mkdir] FAIL: vfs_mkdir rc=%d (mis-routed?)\n",
                cast[uint64](cast[int64](mrc)))
        return -1
    if ext4_resolve_dir(leaf) == 0:
        # The dir did NOT land on ext4 -> the `#t` fast-path swallowed it.
        printk0("[vfs-named-mkdir] FAIL: `#t<word>` root mis-routed off ext4\n")
        return -1
    printk0("[vfs-named-mkdir] PASS\n")
    return 0


def vfs_rename(oldname: Ptr[char], newname: Ptr[char]) -> int32:
    fcache_dcache_bump_gen()                  # dcache: both names change state
    # Plan 9 wstat(2)'s "change the name field" leg. tmpfs and ext4
    # are both wired; ext4 does the dirent remove + insert (with
    # overwrite of an existing destination) in fs/ext4.ad. Both names
    # must live in the same backend — cross-backend renames return
    # -EROFS (a copy+unlink would be the userspace fallback).
    if vfs_fs_kind(oldname) == FS_KIND_TMPFS:
        if vfs_fs_kind(newname) != FS_KIND_TMPFS:
            return EROFS
        return tmpfs_rename(oldname, newname)
    if vfs_fs_kind(oldname) == FS_KIND_EXT4:
        if vfs_fs_kind(newname) != FS_KIND_EXT4:
            return EROFS
        return ext4_rename(vfs_fs_rel(oldname),
                           vfs_fs_rel(newname))
    return EROFS


def vfs_symlink(target: Ptr[char], linkpath: Ptr[char]) -> int32:
    fcache_dcache_bump_gen()                  # dcache: new name appears
    # Create a symlink at `linkpath` whose content (target) is `target`.
    # The existing resolver (_lookup_name / _resolve_with_symlinks) will
    # follow the link transparently when a process opens `linkpath`.
    #
    # Routing:
    #   /ext/*         → ext4_create_symlink (on-disk symlink support)
    #   /tmp/*, /var/* → tmpfs_create_symlink (RAM-backed; the target
    #                    string is stored inline in the slot and the
    #                    resolver follows it transparently on open)
    #   else           → -EROFS
    #
    # F10-2 #455: resolve linkpath through the calling Pgrp first so the
    # F1 substrate "unbound = ENOENT" gate fires and the perm dispatch
    # routes on the resolved `#X/...` form (mirrors vfs_open/vfs_open_write).
    # An unbound linkpath returns ENOENT here, surfaced verbatim.
    sl_resolved: Array[256, uint8]
    sl_rrc: int32 = resolve_path(linkpath, &sl_resolved[0], 256)
    if sl_rrc != 0:
        return sl_rrc
    if chan_permission_check(cast[Ptr[char]](&sl_resolved[0]),
                              PERM_W) != 0:
        return EPERM_PERM
    if vfs_fs_kind(linkpath) == FS_KIND_EXT4:
        parent_inum: uint64 = 2           # root dir — single-level scope
        leaf: Ptr[char] = vfs_fs_rel(linkpath)
        inum: uint32 = ext4_create_symlink(parent_inum, leaf, target)
        if inum == 0:
            return ENOENT
        return 0
    if vfs_fs_kind(linkpath) == FS_KIND_TMPFS:
        # tmpfs_create_symlink returns 0 on success or a negative
        # TMPFS_E* (which already lines up with the VFS errno space:
        # -ENOENT / -EEXIST / -ENOTDIR / -ENOSPC / -ENAMETOOLONG).
        return tmpfs_create_symlink(linkpath, target)
    return EROFS


# _vfs_file_server_id: return an opaque "file server identity" for a
# resolved absolute path.  The identity is used by vfs_link's cross-
# file-server rejection gate.
#
# Identity encoding:
#   * A path that resolves through a 9P SRV mount entry in the caller's
#     Pgrp has identity == the srvfd (positive integer unique per server).
#   * A path served by the LOCAL kernel (ext4 / tmpfs / cpio / devfs /
#     procfs) has identity == 0.
#
# Two paths are on the same file server iff their identities are equal.
# Specifically:
#   * Both local  (0 == 0)    → same server: allowed.
#   * Both 9P but same srvfd  → same server: allowed (unusual but valid
#     if a link across two mount points covers the same 9P session).
#   * Different srvfds        → different servers: rejected (-EXDEV).
#   * One local, one 9P       → different servers: rejected (-EXDEV).
#
# This is the Plan-9 namespace / file-server boundary check.  It does NOT
# consult POSIX mode bits — it asks "is this path on the same file server?"

# -EXDEV: cross-device link (Linux errno 18, Plan 9 cross-server link).
# The kernel uses small negative integers for errno; EXDEV maps to -18.
# Placed before vfs_link and exported so syscall.ad can distinguish it.
EXDEV_LINK: int32 = -18


def _vfs_file_server_id(path: Ptr[uint8]) -> int32:
    # Walk the calling task's Pgrp mount table. If the longest-prefix
    # CHAN_KIND_SRV entry covers `path`, return its srvfd. Otherwise
    # the path is on the local kernel: return 0.
    srvfd: int32 = 0
    root_fid: int32 = 0
    prefix_len: uint64 = 0
    if chan_find_srv_prefix(path, &srvfd, &root_fid, &prefix_len) != 0:
        # A 9P SRV mount covers this path.  The srvfd is the unique
        # identity of the remote file server for this Pgrp.
        return srvfd
    return 0           # local kernel path


def vfs_link(oldpath: Ptr[char], newpath: Ptr[char]) -> int32:
    fcache_dcache_bump_gen()                  # dcache: new name appears
    # Create a hard link: `newpath` is a second name for the same
    # underlying file object as `oldpath`.  Both paths MUST resolve
    # within the SAME file server in the caller's namespace — this is
    # Hamnix's primary link-permission boundary.
    #
    # The check is a Plan 9 / namespace-based boundary test:
    #   If oldpath resolves via a different file server than newpath,
    #   reject with -EXDEV (errno 18, "cross-device link"), regardless
    #   of whether both paths happen to live on the same physical disk.
    #   The boundary is the file SERVER in the caller's namespace, NOT
    #   the physical device.
    #
    # After passing the boundary check, route to the local ext4 backend
    # (the only writable FS with inode-level hardlink support right now).
    # tmpfs hardlinks are a follow-up.
    #
    # Access permission check: caller must have write permission on the
    # directory containing newpath (conservative: we check newpath's
    # prefix path). This is the defense-in-depth POSIX fallback; the
    # namespace/file-server check above is the primary gate.
    #
    # F10-2 #455: resolve through the calling Pgrp first so the gate
    # routes on the resolved `#X/...` form (mirrors vfs_open). Unbound
    # newpath returns ENOENT here.
    ln_resolved: Array[256, uint8]
    ln_rrc: int32 = resolve_path(newpath, &ln_resolved[0], 256)
    if ln_rrc != 0:
        return ln_rrc
    if chan_permission_check(cast[Ptr[char]](&ln_resolved[0]),
                              PERM_W) != 0:
        return EPERM_PERM

    # --- NAMESPACE / FILE-SERVER BOUNDARY CHECK ---
    # Compute identity for both paths.  We cast the Ptr[char] to
    # Ptr[uint8] for chan_find_srv_prefix (same bytes, different type).
    old_id: int32 = _vfs_file_server_id(cast[Ptr[uint8]](oldpath))
    new_id: int32 = _vfs_file_server_id(cast[Ptr[uint8]](newpath))
    if old_id != new_id:
        # Cross-file-server: reject with -EXDEV.  This is the headline
        # feature: a hardlink MUST NOT cross a namespace/file-server
        # boundary even when both paths sit on the same physical disk.
        printk_set_level(PRINTK_LEVEL_WARN)
        printk0("vfs_link: EXDEV: cross-9P-server link rejected\n")
        return EXDEV_LINK
    # Both paths are on the same file server.  Now route to the
    # backing store.
    ext_old: int32 = 0
    if vfs_fs_kind(oldpath) == FS_KIND_EXT4:
        ext_old = 1
    ext_new: int32 = 0
    if vfs_fs_kind(newpath) == FS_KIND_EXT4:
        ext_new = 1
    if ext_old != 0:
        if ext_new == 0:
            # Both resolved to local (id==0) but one is ext4 and the
            # other is a different local backend (tmpfs, cpio …).
            # Local backends are distinct per-mount-point "file servers"
            # in the Plan 9 sense — reject with -EXDEV.
            printk_set_level(PRINTK_LEVEL_WARN)
            printk0("vfs_link: EXDEV: cross-backend link rejected\n")
            return EXDEV_LINK
        src_leaf: Ptr[char] = vfs_fs_rel(oldpath)
        dst_leaf: Ptr[char] = vfs_fs_rel(newpath)
        # We only support root-directory hardlinks (parent_inum = 2).
        # This matches the single-level scope of ext4_create_file.
        if ext4_hardlink(src_leaf, dst_leaf, 2) != 0:
            return ENOENT
        return 0
    # tmpfs hardlinks: both names must live in the same tmpfs server
    # (/tmp/* or /var/*). A second slot is created for newpath aliasing
    # oldpath's data slot, with the link count tracked on the canonical
    # slot (fs/tmpfs.ad: tmpfs_hardlink). A tmpfs↔other-backend pair is a
    # cross-backend link and is rejected with -EXDEV, matching the ext4
    # leg above.
    tmp_old: int32 = 0
    if vfs_fs_kind(oldpath) == FS_KIND_TMPFS:
        tmp_old = 1
    tmp_new: int32 = 0
    if vfs_fs_kind(newpath) == FS_KIND_TMPFS:
        tmp_new = 1
    if tmp_old != 0:
        if tmp_new == 0:
            printk_set_level(PRINTK_LEVEL_WARN)
            printk0("vfs_link: EXDEV: cross-backend link rejected\n")
            return EXDEV_LINK
        # tmpfs_hardlink returns 0 on success or a negative TMPFS_E*
        # (ENOENT / EEXIST / ENOTDIR / ENOSPC / ENAMETOOLONG) — all in
        # the VFS errno space already.
        return tmpfs_hardlink(oldpath, newpath)
    if tmp_new != 0:
        # newpath is tmpfs but oldpath is some other local backend.
        printk_set_level(PRINTK_LEVEL_WARN)
        printk0("vfs_link: EXDEV: cross-backend link rejected\n")
        return EXDEV_LINK
    # cpio / other read-only local backends: hardlinks not implemented.
    return EROFS


def vfs_fsync(fd: int32) -> int32:
    # fsync(2) / fdatasync(2): flush the file's dirty data + metadata
    # to durable storage. Our write path is write-through and ordered
    # (data block written before the inode that references it), so
    # the ordering half of fsync's contract is already met when each
    # write returns. fsync's remaining job is the device-cache
    # barrier — ext4_fsync issues blk_flush on the mounted device.
    #
    #   DEV_EXT4_FILE chan  →  ext4_fsync (real device barrier)
    #   DEV_TMPFS_FILE chan →  0 (tmpfs is RAM-backed; nothing to flush —
    #                            falls through the ext4 check to return 0)
    #   other fds     →  0 (pipes/sockets/devnull have no durable
    #                       backing — fsync is a successful no-op,
    #                       which is what Linux returns for them too)
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return EBADF
    # fd→Chan fold: an ext4 file fd is an FD_CHAN_MARK fd backed by a
    # DEV_EXT4_FILE pool chan. fsync flushes the whole ext4 device, so
    # the per-fd identity only matters as "is this an ext4 fd?".
    if file_idx == FD_CHAN_MARK:
        if namec_chan_dev_type(_fd_chan_id(task, fdu)) == DEV_EXT4_FILE:
            # Page-cache writeback: flush any dirty page-cache pages to the
            # backing store BEFORE the device-cache barrier so fsync's
            # durability contract covers cached-but-unflushed file data.
            # (ext4's own write path is write-through + page-invalidating, so
            # today this is a no-op; it makes the contract explicit and
            # covers any future buffered-write producer.)
            fcache_sync_all()
            return ext4_fsync()
        return 0
    return 0


def vfs_fsync_all() -> int32:
    # sync(2): flush every writable filesystem. Today the only durable
    # mount is ext4 — tmpfs/procfs/pipes have no on-disk backing — so
    # this is ext4_fsync(). Returns 0 always (sync(2) cannot fail);
    # ext4_fsync's -1-when-unmounted is swallowed since "no ext4
    # mount" is not a sync failure.
    fcache_sync_all()                        # flush dirty page-cache pages
    ext4_fsync()
    return 0


def vfs_ftruncate(fd: int32, length: uint64) -> int32:
    # ftruncate(2): resize the open file referenced by `fd` to exactly
    # `length` bytes. Routes to the backing FS's truncate.
    #
    #   FD_EXT4_MARK  →  ext4_truncate_inode (frees / zero-fills blocks)
    #   other fds     →  -EINVAL (tmpfs ftruncate is a separate job in
    #                    fs/tmpfs.ad; pipes/sockets are not regular
    #                    files so -EINVAL is the correct refusal)
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return EBADF
    # fd→Chan fold: an ext4 file fd is an FD_CHAN_MARK fd backed by a
    # DEV_EXT4_FILE pool chan. Recover the ext4 open-file slot through
    # namec_chan_back_slot, then truncate exactly as the legacy
    # FD_EXT4_MARK arm did.
    if file_idx == FD_CHAN_MARK:
        ch_dt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
        if ch_dt == DEV_EXT4_FILE:
            eslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            inum: uint32 = ext4_open_inum(eslot)
            if inum == 0:
                return EINVAL
            if ext4_truncate_inode(inum, length) != 0:
                return EIO
            # Keep the cached open-file size coherent for read-back.
            ext4_set_open_size(eslot, length)
            return 0
        if ch_dt == DEV_TMPFS_FILE:
            # §memfd: ftruncate on a tmpfs / memfd file. Recover the tmpfs
            # slot through the chan; tmpfs_ftruncate enforces F_SEAL_SHRINK
            # / GROW / WRITE and resizes. It returns 0 or a negative tmpfs
            # errno (-EPERM / -EINVAL) which is already the Linux value.
            tslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            return tmpfs_ftruncate(tslot, length)
        return EINVAL
    return EINVAL


def vfs_truncate(name: Ptr[char], length: uint64) -> int32:
    # truncate(2): resize the file named by an absolute path. Only
    # ext4 has a path-resolved truncate; tmpfs/cpio paths return
    # -EROFS / -EINVAL. ext4_resolve_file walks the path to the
    # file's inum, then ext4_truncate_inode does the resize.
    if vfs_fs_kind(name) == FS_KIND_EXT4:
        inum: uint32 = 0
        fsize: uint64 = 0
        if ext4_resolve_file(vfs_fs_rel(name), &inum,
                             &fsize) == 0:
            return ENOENT
        if ext4_truncate_inode(inum, length) != 0:
            return EIO
        return 0
    if vfs_fs_kind(name) == FS_KIND_TMPFS:
        return EINVAL
    return EROFS


def vfs_chmod(name: Ptr[char], mode: uint16) -> int32:
    # chmod(2): set the permission/type bits of the file named by an
    # absolute path. Only ext4 persists per-inode mode bits; for
    # tmpfs/cpio (no per-inode mode storage) we mirror Linux's tmpfs
    # behaviour and return success as a no-op rather than failing.
    # ext4: resolve path -> inum, read inode, set i_mode, write back
    # (mirrors ext4_hardlink's read/modify/write idiom).
    if vfs_fs_kind(name) == FS_KIND_EXT4:
        inum: uint32 = 0
        fsize: uint64 = 0
        if ext4_resolve_file(vfs_fs_rel(name), &inum,
                             &fsize) == 0:
            return ENOENT
        inode: Array[256, uint8]
        if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
            return EIO
        ext4_inode_set_mode(&inode[0], mode)
        # i_mode is inode metadata; stamp ctime/mtime like setattr.
        _ext4_stamp_mtime(&inode[0])
        if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
            return EIO
        return 0
    if vfs_fs_kind(name) == FS_KIND_TMPFS:
        return 0                                  # no-op success
    return 0                                       # best-effort no-op


def vfs_set_mtime(name: Ptr[char], mtime: uint32) -> int32:
    # utimes/wstat-mtime: set the modification time of the file named
    # by an absolute path. ext4 persists i_mtime/i_ctime; tmpfs/cpio
    # have no per-inode time storage, so we accept the value as a
    # no-op success (matches Linux's utimensat on tmpfs).
    if vfs_fs_kind(name) == FS_KIND_EXT4:
        inum: uint32 = 0
        fsize: uint64 = 0
        if ext4_resolve_file(vfs_fs_rel(name), &inum,
                             &fsize) == 0:
            return ENOENT
        inode: Array[256, uint8]
        if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
            return EIO
        _ext4_write_u32(
            cast[Ptr[uint8]](cast[uint64](&inode[0]) \
                             + INODE_I_MTIME_OFFSET),
            mtime)
        if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
            return EIO
        return 0
    if vfs_fs_kind(name) == FS_KIND_TMPFS:
        return 0                                  # no-op success
    return 0                                       # best-effort no-op


def _path_eq_const(name: Ptr[char], expected: Ptr[uint8],
                   length: int32) -> int32:
    # True if name[0..length] matches expected and name[length] == 0.
    i: int32 = 0
    while i < length:
        if name[i] != cast[int32](expected[i]):
            return 0
        i = i + 1
    if name[length] != 0:
        return 0
    return 1


def _listdir_named_subpath(dir_prefix: Ptr[uint8], name: Ptr[char],
                           rest_start: uint64, buf: Ptr[uint8],
                           count: uint64) -> int64:
    # listdir analog of _open_named_subpath: compose a synthetic
    # `/ext/<dir_prefix>/<rest>` path and route to ext4_listdir. After
    # `bind '#sysroot' /`, `ls /bin` resolves (in resolve_path via
    # ns_walk) to `#by-id/<uuid>/sysroot/bin`; vfs_listdir's
    # `#` arm dispatches here so the partition directory actually lists.
    # Without this the `#by-id`/named-root arm fell through to -EINVAL —
    # the asymmetry that made exec-through-bind work but `ls` hang/fail.
    scratch: Array[512, uint8]
    p: uint64 = 0
    scratch[0] = 47                              # '/'
    scratch[1] = 101                             # 'e'
    scratch[2] = 120                             # 'x'
    scratch[3] = 116                             # 't'
    p = 4
    if dir_prefix[0] != 0 and dir_prefix[0] != 46:
        scratch[p] = 47                          # '/'
        p = p + 1
        k: uint64 = 0
        while dir_prefix[k] != 0 and p + 1 < 512:
            scratch[p] = dir_prefix[k]
            p = p + 1
            k = k + 1
        if scratch[p - 1] == 47:
            p = p - 1
    if name[rest_start] == 47:
        pass
    elif name[rest_start] != 0:
        scratch[p] = 47
        p = p + 1
    j: uint64 = rest_start
    while name[j] != 0 and p + 1 < 512:
        scratch[p] = cast[uint8](name[j])
        p = p + 1
        j = j + 1
    scratch[p] = 0
    # ext4_listdir wants the post-/ext/-strip tail. The composed path
    # always begins "/ext"; strip exactly that prefix. For the bare
    # "/ext" case (p == 4, partition root) the tail is the empty string,
    # which ext4_listdir resolves to the partition root directory.
    tail: Ptr[char] = cast[Ptr[char]](&scratch[0])
    if scratch[4] == 47:                          # "/ext/<...>"
        tail = cast[Ptr[char]](cast[uint64](&scratch[0]) + 5)
    else:                                          # bare "/ext"
        tail = cast[Ptr[char]](&_empty_str[0])
    return ext4_listdir(tail, buf, count)


def _listdir_hash_long(name: Ptr[char], buf: Ptr[uint8],
                       count: uint64) -> int64:
    # listdir analog of _open_hash_long: resolve a `#<word>[/<rest>]`
    # or `#by-id/<partuuid>[/<rest>]` named-root path to the partition
    # directory it aliases and list it. Mirrors the open-side dispatch
    # so `ls` through a bind sees exactly what `cat`/exec see.
    word_buf: Array[40, uint8]
    pos: int32 = 0
    word_end: uint64 = 0
    if _hash_word_extract(name, &word_buf[0], 40, &pos, &word_end) < 0:
        return cast[int64](EINVAL)
    if _hash_is_by_id(&word_buf[0]) != 0:
        if name[word_end] != 47:
            return cast[int64](EINVAL)
        # Parse the partuuid up to the next '/' (or NUL).
        pu_buf: Array[40, uint8]
        i: uint64 = word_end + 1
        o: uint64 = 0
        while name[i] != 0 and name[i] != 47 and o + 1 < 40:
            pu_buf[o] = cast[uint8](name[i])
            o = o + 1
            i = i + 1
        pu_buf[o] = 0
        if o == 0:
            return cast[int64](EINVAL)
        if byid_lookup(&pu_buf[0]) == 0:
            return cast[int64](EINVAL)
        dir_buf: Array[256, uint8]
        dir_buf[0] = 0
        byid_lookup_dir(&pu_buf[0], &dir_buf[0], 256)
        return _listdir_named_subpath(&dir_buf[0], name, i, buf, count)
    sel: int32 = pos
    if sel == 0:
        sel = 1
    if name_lookup_at(&word_buf[0], sel) == 0:
        return cast[int64](EINVAL)
    dir_buf2: Array[256, uint8]
    if name_lookup_dir(&word_buf[0], sel, &dir_buf2[0], 256) < 0:
        return cast[int64](EINVAL)
    return _listdir_named_subpath(&dir_buf2[0], name, word_end,
                                  buf, count)


def vfs_listdir_ns(orig: Ptr[char], name: Ptr[char], buf: Ptr[uint8],
                   count: uint64) -> int64:
    # Plan 9 namespace-aware directory listing. `name` is the resolved
    # path (post ns_walk); `orig` is the conventional path
    # the caller asked for (pre-resolution). First fill `buf` from the
    # backing FS / device server (vfs_listdir), then — keyed on `orig`,
    # which is the directory's name in the AMBIENT namespace — APPEND
    # the names of any mount-table bindings whose parent is `orig`.
    #
    # That second step is what makes `bind '#c' /dev` / `bind '#s' /srv`
    # show up as `dev` / `srv` in `ls /` even though no on-disk FS
    # carries those entries: the bound name lives in the namespace
    # (mtab), not on disk. Keying on `orig` (not the resolved `name`) is
    # essential because `/` itself is a bind target (sysroot bound at
    # `/`), so `name` would be `#by-id/.../sysroot` and lose the `/dev`
    # sibling. `orig` keeps the conventional `/` that the mtab children
    # hang off.
    n: int64 = vfs_listdir(name, buf, count)
    # Canonicalise `orig` (which may be relative — `ls` with no arg
    # passes the cwd, `ls .` passes ".") to an absolute conventional
    # directory path. This is the key the mtab children hang off; a raw
    # `#X` request is a device-server target whose children come from
    # the server itself and gets no synthesis.
    if orig[0] == 35:                                  # '#'
        return n
    canon: Array[256, uint8]
    if _resolve_path_canonical(orig, &canon[0], 256) != 0:
        return n
    base: uint64 = 0
    if n > 0:
        base = cast[uint64](n)
    total: int64 = chan_dir_mount_children(&canon[0], buf,
                                           count, base)
    # If the backend had no listing (error/empty) AND no mount child was
    # synthesized, propagate the backend's result so a genuinely invalid
    # path still surfaces -EINVAL rather than an empty directory.
    if n < 0 and total == 0:
        return n
    return total


def vfs_listdir(name: Ptr[char], buf: Ptr[uint8],
                count: uint64) -> int64:
    # Path-resolution wrapper. Routes the calling listdir to the
    # right backing FS by path prefix:
    #
    #   /mnt or /mnt/*     →  FAT
    #   /ext or /ext/*     →  EXT4 (root only for now)
    #   /, /etc, /bin, ... →  cpio initramfs (implicit dirs)
    #   anything else      →  -EINVAL
    #
    # The cpio branch is what makes `ls /`, `ls /etc`, and (after
    # `cd /etc`) bare `ls` work — pre-M16.135 those all returned
    # -EINVAL because vfs_listdir only knew about FAT + ext4. The
    # opendir/getdents path in vfs_open already routed cpio via
    # _is_initramfs_dir, so this mirrors that dispatch — the
    # asymmetry was the bug. Discovered on real-hardware GNOME
    # Boxes testing where `ls` (no args) and `ls <any path>`
    # showed "listdir failed".
    # Backend selection via the mount table. vfs_fs_rel yields "" for the
    # bare /mnt and /ext mountpoints (the volume roots), so the old
    # explicit "/mnt"/"/ext" empty-tail arms fold into these two.
    lfk: uint32 = vfs_fs_kind(name)
    if lfk == FS_KIND_FAT:
        return fat_listdir(vfs_fs_rel(name), buf, count)
    if lfk == FS_KIND_EXT4:
        return ext4_listdir(vfs_fs_rel(name), buf, count)
    # V1: tmpfs is a tree — `/tmp` and any mkdir'd subdir are real
    # directories. Routed before the cpio fallback (the initramfs has
    # no /tmp entry, so _is_initramfs_dir would never match it).
    # V2: /var is also tmpfs-backed (vfs_fs_shadow marks it), but a /var
    # path that tmpfs does not own falls through to cpio (per-entry
    # shadow, same rule as the OREAD dispatch) so a cpio-baked /var
    # directory still lists.
    if lfk == FS_KIND_TMPFS:
        if vfs_fs_shadow(name) != 0:
            if tmpfs_path_is_dir(name) != 0:
                return tmpfs_listdir(name, buf, count)
        else:
            if tmpfs_path_is_dir(name) != 0:
                return tmpfs_listdir(name, buf, count)
            return cast[int64](EINVAL)
    # V3.5: Plan 9 `#X` device-alias listing. `#s` renders the
    # devsrv table; `#/` (the root-dir slot, formerly the kernel's
    # synthetic `/n`) renders to 0 bytes because the slot has no
    # synthetic children — its only purpose is to be `bind`-targeted.
    # The V3 `/srv` / `/n` arms here are gone; if a caller really
    # wants `/srv`'s contents and userspace init has run, the path
    # has already been rewritten to `#s` by ns_walk
    # before reaching vfs_listdir.
    if name[0] == 35:                                  # '#'
        if name[1] == 115 and name[2] == 0:            # '#s'
            return devsrv_list(buf, count)
        if name[1] == 47 and name[2] == 0:             # '#/'
            return 0
        # `#b` (post-bind /dev/blk) — list the live block-device names
        # straight from the kernel's blockdev table. This is what makes
        # `ls /dev/blk` and lsblk's sys_listdir("/dev/blk") enumerate
        # the devices through the namespace bind, not a literal match.
        if name[1] == 98 and name[2] == 0:             # '#b'
            return blk_listdir(buf, count)
        # `#c` (post-bind /dev) — list the device server's children
        # (blk + the synthetic stdio cdevs). `_dev_listdir` mirrors
        # _open_dir_dev's child set so `ls /dev` and getdents agree.
        if name[1] == 99 and name[2] == 0:             # '#c'
            return _dev_listdir(buf, count)
        # `#c/<leaf>` listdir — only `blk` is itself a directory; route
        # it to the block server. (Other leaves are non-directory cdevs.)
        if name[1] == 99 and name[2] == 47:            # '#c/<leaf>'
            sub: Ptr[char] = cast[Ptr[char]](cast[uint64](name) + 3)
            if sub[0] == 98 and sub[1] == 108 and sub[2] == 107 \
                    and sub[3] == 0:                   # "blk"
                return blk_listdir(buf, count)
            return cast[int64](EINVAL)
        # `#I` (post-bind /net) — IP device server directory walk. Bare
        # `#I` lists the proto dirs (tcp/udp/icmp); `#I/<proto>` lists
        # `clone` plus the live conn numbers; `#I/<proto>/<N>` lists the
        # per-connection files. devnet_listdir takes the server-relative
        # subpath (the bytes after `#I`), so `ls /net` and getdents agree.
        if name[1] == 73:                              # '#I'
            if name[2] == 0:
                return devnet_listdir("", buf, count)
            if name[2] == 47:                          # '#I/<rest>'
                nsub: Ptr[char] = cast[Ptr[char]](cast[uint64](name) + 2)
                return devnet_listdir(nsub, buf, count)
            return cast[int64](EINVAL)
        # `#p` (post-bind /proc) — proc device server directory walk.
        # Bare `#p` lists the static well-known proc files (version,
        # cpuinfo, meminfo, ...) PLUS one decimal entry per live pid;
        # `#p/<pid>` lists that task's introspection files (status, stat,
        # io, limits, cmdline, maps, ctl, fd, ...). devproc_listdir takes
        # the server-relative subpath (the bytes after `#p`), so `ls
        # /proc` / `ls /proc/<pid>` and getdents agree. This replaces the
        # last literal `/proc` listing bypass: the listing is reached only
        # via the `bind '#p' /proc` namespace rewrite, never a strcmp.
        if name[1] == 112:                             # '#p'
            if name[2] == 0:
                return devproc_listdir("", buf, count)
            if name[2] == 47:                          # '#p/<rest>'
                psub: Ptr[char] = cast[Ptr[char]](cast[uint64](name) + 2)
                return devproc_listdir(psub, buf, count)
            return cast[int64](EINVAL)
        # Long-form named-root aliases: `#by-id/<uuid>/sysroot/bin`
        # (the frozen `bind '#sysroot' /` form) and bare `#<word>/...`
        # both list the partition directory they alias. Mirrors
        # vfs_open's _open_hash_long dispatch so `ls` follows a bind
        # exactly as exec/cat do. Anything with more than two chars
        # after '#' that isn't '#s'/'#/' is a long-form alias.
        if name[1] != 0 and name[2] != 0:
            return _listdir_hash_long(name, buf, count)
        return cast[int64](EINVAL)
    if _is_initramfs_dir(name) != 0:
        return _cpio_listdir(name, buf, count)
    return cast[int64](EINVAL)


_empty_str: Array[1, uint8]


def _dev_listdir(buf: Ptr[uint8], count: uint64) -> int64:
    # Directory walk for the /dev device server (`#c`). Emits the same
    # child set _open_dir_dev installs into its FD_DIR_MARK buffer, so a
    # getdents-based `ls /dev` and a sys_listdir("/dev") agree: the block
    # subtree plus the synthetic stdio cdevs.
    out: uint64 = 0
    out = _dev_dir_emit(buf, count, out, "blk")
    out = _dev_dir_emit(buf, count, out, "cons")
    out = _dev_dir_emit(buf, count, out, "null")
    out = _dev_dir_emit(buf, count, out, "zero")
    return cast[int64](out)


ENAMETOOLONG: int32 = -36


def _normalize_inplace(buf: Ptr[uint8]):
    # Compact "." and ".." components in-place on an absolute path.
    # buf must start with '/' and be NUL-terminated. After the pass:
    #
    #   "/foo/./bar"      -> "/foo/bar"
    #   "/foo/bar/.."     -> "/foo"
    #   "/.."             -> "/"
    #   "/a//b"           -> "/a/b"
    #
    # In-place is safe because write_pos always moves at most as fast
    # as read_pos; we only ever copy from a higher buffer index to a
    # lower one (or to itself).
    #
    # Bug-fix: the original implementation used `buf[read_pos] != 0`
    # as the outer-loop termination. That breaks on inputs like
    # "/etc/motd" where the second component ends exactly at the
    # buffer NUL: after copying "motd" forward, the body writes
    # buf[write_pos] = '/' at the SAME index the NUL was sitting in.
    # The outer loop then re-reads that fresh '/' as if it were more
    # input and walks off into uninitialised stack bytes — which on
    # an unlucky stack produces /etc/motd/<garbage>\0 in the output.
    # We snapshot the input length first and bound the outer loop on
    # it, so writes can't extend the "live" region the loop reads.
    end: uint64 = 0
    while buf[end] != 0:
        end = end + 1
    read_pos:  uint64 = 1                  # skip leading '/'
    write_pos: uint64 = 1
    while read_pos < end:
        comp_start: uint64 = read_pos
        while read_pos < end and buf[read_pos] != 47:
            read_pos = read_pos + 1
        comp_len: uint64 = read_pos - comp_start
        if read_pos < end and buf[read_pos] == 47:
            read_pos = read_pos + 1
        if comp_len == 0:
            # Empty (consecutive '/' or trailing '/'). Skip.
            continue
        if comp_len == 1 and buf[comp_start] == 46:
            # "." — skip.
            continue
        if comp_len == 2 and buf[comp_start] == 46 \
                and buf[comp_start + 1] == 46:
            # ".." — pop the previous component if any. Walk
            # write_pos back past the previous "/" and the entry
            # before it.
            if write_pos > 1:
                write_pos = write_pos - 1          # drop trailing '/'
                while write_pos > 1 and buf[write_pos - 1] != 47:
                    write_pos = write_pos - 1
            continue
        # Keep component: copy comp_start..comp_start+comp_len to
        # write_pos, then add separator.
        i: uint64 = 0
        while i < comp_len:
            buf[write_pos + i] = buf[comp_start + i]
            i = i + 1
        write_pos = write_pos + comp_len
        buf[write_pos] = 47
        write_pos = write_pos + 1
    # Strip the trailing '/' we appended (unless we're sitting on
    # the root '/').
    if write_pos > 1 and buf[write_pos - 1] == 47:
        write_pos = write_pos - 1
    buf[write_pos] = 0


# Union-mount probe cap. Matches chan.ad's MNT_CAP (32 mtab slots) —
# the largest possible number of union members at one name. Local
# copy because Adder doesn't evaluate imported constants inside the
# `while nth < ...` bound cleanly. Keep in sync with chan.ad MNT_CAP.
MNT_CAP_PROBE: uint64 = 32

# Chain-hop cap for resolve_path's walk loop. A hop happens when a
# union member's frozen to_path is itself a '/'-anchored name (only
# possible when the bound source was SRV-covered at bind time, or for
# a directly SRV-covered path). 4 is generous — freeze-at-bind
# collapses FILE->FILE chains, so real chains are depth 1-2.
NS_HOP_CAP: uint64 = 4


def _spec_localize(spec: Ptr[uint8], out: Ptr[uint8],
                   cap: uint64) -> int32:
    # Localize a kernel file-server spec to the server's backend key
    # space. The per-Pgrp walk (ns_walk) is the authority on WHETHER a
    # name resolves; the backends below keep their long-standing
    # internal path keys, and vfs_mount.ad's table is demoted to a
    # backend-internal key router. The localizations:
    #
    #   #r<rest> -> <rest>          ("" -> "/")   boot file server
    #   #t<rest> -> <rest>          ("" -> "/")   tmpfs server
    #   #e<rest> -> "/ext" + rest                 ext4 server
    #   #f<rest> -> "/mnt" + rest                 FAT server
    #
    # <rest> must be empty or start with '/' — otherwise the spec is a
    # multi-char `#<word>` named root (e.g. `#root`, `#tmp`), NOT one
    # of ours. Specs for other servers (#c, #s, #by-id/..., ...) are
    # not localized; vfs_open's `#` dispatch arms own them.
    #
    # Returns 1 (out populated), 0 (not a localizable spec; out
    # untouched), -1 (overflow).
    if spec[0] != 35:                                # '#'
        return 0
    c: uint8 = spec[1]
    pre: Ptr[uint8] = cast[Ptr[uint8]](0)
    if c == cast[uint8]('r') or c == cast[uint8]('t'):
        pre = cast[Ptr[uint8]]("")
    elif c == cast[uint8]('e'):
        pre = cast[Ptr[uint8]]("/ext")
    elif c == cast[uint8]('f'):
        pre = cast[Ptr[uint8]]("/mnt")
    else:
        return 0
    nxt: uint8 = spec[2]
    if nxt != 0 and nxt != 47:                       # not '/' or NUL
        return 0                                     # multi-char word
    o: uint64 = 0
    i: uint64 = 0
    while pre[i] != 0:
        if o + 1 >= cap:
            return -1
        out[o] = pre[i]
        o = o + 1
        i = i + 1
    i = 2
    while spec[i] != 0:
        if o + 1 >= cap:
            return -1
        out[o] = spec[i]
        o = o + 1
        i = i + 1
    if o == 0:
        # Bare "#r" / "#t" — the server root.
        if cap < 2:
            return -1
        out[0] = 47                                  # '/'
        o = 1
    out[o] = 0
    return 1


def _union_cpio_exists(resolved: Ptr[uint8]) -> int32:
    # 1 if `resolved` (NUL-terminated absolute path) names a cpio /
    # initramfs FILE. Equal-length C-string compare against every
    # registered entry — same probe _cpio_lookup uses in sysfile.ad,
    # inlined here so resolve_path doesn't depend on that module.
    count: uint64 = initramfs_entry_count()
    i: uint64 = 0
    while i < count:
        cand: Ptr[char] = initramfs_entry_name(i)
        k: uint64 = 0
        eq: int32 = 1
        while True:
            ca: int32 = cast[int32](resolved[k] & 0xFF)
            cb: int32 = cand[k]
            if ca != cb:
                eq = 0
                break
            if ca == 0:
                break
            k = k + 1
        if eq != 0:
            return 1
        i = i + 1
    return 0


def _union_resolved_exists(resolved: Ptr[uint8], srv: uint8) -> int32:
    # Existence probe for a union-member rewrite. Returns 1 if the
    # rewritten path names something that can actually be opened or
    # walked. The union ladder in resolve_path stops at the first
    # member that returns 1 — so a lookup through a union point lands
    # on whichever member actually holds the name.
    #
    # `srv` is the member's backend-server LETTER ('r' = cpio/boot,
    # 't' = tmpfs, ...). The probe MUST be scoped to that one backend:
    # `#r` (cpio) and `#t` (tmpfs) both localize to a bare absolute key
    # (e.g. `#t/etc/passwd` -> "/etc/passwd"), so the localized strings
    # are indistinguishable. Probing the cpio for a `#t` member would
    # let a NATIVE cpio file (e.g. the host's /etc/passwd) satisfy a
    # writable-overlay tmpfs member, shadowing the rerooted MREPL base
    # (#r/var/lib/distros/default) underneath it — exactly the bug that
    # made getpwnam("root") read Hamnix's native passwd inside
    # `enter linux`. Scope each member to its own server: a tmpfs member
    # exists only if tmpfs actually holds the name; a cpio member exists
    # only if the cpio archive holds it.
    rchar: Ptr[char] = cast[Ptr[char]](resolved)
    if srv == cast[uint8]('t'):
        # tmpfs member: ONLY the live tmpfs state counts. No cpio
        # fall-through — that is the underlying MREPL base's job.
        if tmpfs_lookup(rchar) >= 0:
            return 1
        if vfs_fs_kind(rchar) == FS_KIND_TMPFS \
                and tmpfs_path_is_dir(rchar) != 0:
            return 1
        return 0
    # cpio / boot-file member ('r', and the default for any other
    # localizable server): the cpio archive is the authority.
    if _union_cpio_exists(resolved) != 0:
        return 1
    if _is_initramfs_dir(rchar) != 0:
        return 1
    return 0


def _resolve_path_canonical(input: Ptr[char], output: Ptr[uint8],
                            count: uint64) -> int32:
    # Phase C / M16.107: canonicalise step. Produces an absolute,
    # normalised path in `output` from `input`. Pre-M16.105 this WAS
    # resolve_path; we've factored it out so resolve_path can layer
    # a mount-table prefix rewrite on top of the canonical form.
    if count == 0:
        return ENAMETOOLONG
    if input[0] == 47:                         # '/'
        i: uint64 = 0
        while i + 1 < count:
            c: uint8 = cast[uint8](input[i] & 0xFF)
            output[i] = c
            if c == 0:
                _normalize_inplace(output)
                return 0
            i = i + 1
        output[i] = 0
        return ENAMETOOLONG
    # Relative — prepend cwd. Append '/' between cwd and input
    # unless cwd already ends in one.
    cwd: Ptr[uint8] = get_cwd_buf(current_idx_get())
    j: uint64 = 0
    while j + 1 < count and cwd[j] != 0:
        output[j] = cwd[j]
        j = j + 1
    if j == 0:
        return ENAMETOOLONG                    # cwd was empty
    if output[j - 1] != 47:
        if j + 1 >= count:
            return ENAMETOOLONG
        output[j] = 47
        j = j + 1
    i: uint64 = 0
    while j + 1 < count:
        c: uint8 = cast[uint8](input[i] & 0xFF)
        output[j] = c
        if c == 0:
            _normalize_inplace(output)
            return 0
        i = i + 1
        j = j + 1
    output[j] = 0
    return ENAMETOOLONG


def _rp_copy(dst: Ptr[uint8], src: Ptr[uint8], count: uint64) -> int32:
    # Bounded NUL-terminated copy for resolve_path's buffers.
    # Returns 0 on success, ENAMETOOLONG on overflow.
    i: uint64 = 0
    while i + 1 < count:
        c: uint8 = src[i]
        dst[i] = c
        if c == 0:
            return 0
        i = i + 1
    if count > 0:
        dst[i] = 0
    return ENAMETOOLONG


def resolve_path_canonical(input: Ptr[char], output: Ptr[uint8],
                           count: uint64) -> int32:
    # PUBLIC: produce the CANONICAL NAMESPACE path for `input` — the
    # cwd-prepended, "."/".."-compacted, absolute name — WITHOUT the
    # ns_walk backend rewrite that resolve_path layers on top.
    #
    # This is what getwd/SYS_GETCWD must store and report: in Plan 9
    # the cwd path is reconstructed from the namespace name you walked
    # (the bind point, e.g. `/srv`), NOT the backend device the name
    # ultimately resolves to (`#s`). `cd srv; pwd` -> `/srv`, never
    # `#s`. resolve_path's ns_walk output is correct for OPENING the
    # directory but wrong for DISPLAYING the cwd.
    #
    # `#X` direct inputs are already canonical device-root references
    # (Plan 9 syntax); pass them through verbatim — a user who `cd`s
    # straight to `#s` sees `#s`.
    if input[0] == 35:                                 # '#'
        return _rp_copy(output, cast[Ptr[uint8]](input), count)
    return _resolve_path_canonical(input, output, count)


def resolve_path_create(input: Ptr[char], output: Ptr[uint8],
                        count: uint64) -> int32:
    # WRITE/CREATE-side namespace resolution. Plan 9 MCREATE semantics:
    # a create / write-open / rename-destination / mkdir / link target
    # under a union point MUST land in the highest-priority union member
    # that carries MCREATE — NOT in whichever member the name happens to
    # already EXIST in.
    #
    # This is the writable-overlay keystone. The recipe
    #     bind '#r/var/lib/distros/default' /     # read-only cpio base
    #     bind -bc '#t' /                         # writable tmpfs, MCREATE
    # unions a writable tmpfs MBEFORE the read-only cpio. The plain
    # resolve_path (read side) walks the union and returns whichever
    # member the name EXISTS in — so a name baked into the cpio
    # (e.g. /var/lib/dpkg/status, /usr/bin/dpkg) resolves to the
    # READ-ONLY cpio member. That is correct for READS, but for a
    # WRITE / rename-into-place it defeats the overlay: dpkg's
    #     write status-new (tmpfs) ; rename status-new -> status
    # would resolve `status` to the cpio member and the cross-backend
    # rename (tmpfs src, cpio dst) fails with ENOENT.
    #
    # Fix: when ANY visible union member covering the (canonical) path
    # carries MCREATE, route the operation to that member via
    # mnttab_create_target — which picks the highest-priority MCREATE
    # member and rewrites the path to its (server-anchored) form — then
    # localize the `#X` spec to its backend key. So `status` resolves to
    # `#t/var/lib/dpkg/status` -> tmpfs `/var/lib/dpkg/status`, the
    # writable member, regardless of the cpio-baked copy.
    #
    # When NO covering member has MCREATE (the common case: no overlay,
    # or a path outside any MCREATE union) this is a transparent no-op:
    # we defer to the normal resolve_path. `#X` direct specs and
    # relative paths are handled by canonicalising first.
    if input[0] == 35:                                 # '#' direct spec
        return resolve_path(input, output, count)
    # Canonicalise (cwd-prepend + "."/".." compaction) so the MCREATE
    # probe and create-target rewrite see the same absolute name the
    # read-side ns_walk would.
    canon: Array[256, uint8]
    crc: int32 = _resolve_path_canonical(input, &canon[0], 256)
    if crc != 0:
        return crc
    canon_c: Ptr[char] = cast[Ptr[char]](&canon[0])
    if mnttab_any_mcreate_covers(&canon[0]) == 0:
        # No MCREATE member covers this path — read-side resolution is
        # correct for creates too (single-member bind / no overlay).
        return resolve_path(canon_c, output, count)
    # An MCREATE member covers the path: force the create-target rewrite.
    tgt: Array[256, uint8]
    trc: int32 = mnttab_create_target(&canon[0], &tgt[0], 256)
    if trc <= 0:
        # mnttab_any_mcreate_covers said yes but create_target found no
        # member (race / inconsistency) — fall back to read resolution.
        return resolve_path(canon_c, output, count)
    # tgt holds the create-target member's rewrite. For our own server
    # specs (`#t/...`, `#r/...`, ...) localize to the backend key space
    # (e.g. `#t/var/lib/dpkg/status` -> `/var/lib/dpkg/status`); foreign
    # / SRV specs pass through verbatim for the `#`-dispatch arms.
    if tgt[0] == 35:                                   # '#' spec
        loc: Array[256, uint8]
        lrc: int32 = _spec_localize(&tgt[0], &loc[0], 256)
        if lrc < 0:
            return ENAMETOOLONG
        if lrc == 1:
            return _rp_copy(output, &loc[0], count)
        return _rp_copy(output, &tgt[0], count)
    return _rp_copy(output, &tgt[0], count)


def resolve_path(input: Ptr[char], output: Ptr[uint8],
                 count: uint64) -> int32:
    # dcache front end (Linux-parity dentry cache). A repeated namec
    # element-walk for the SAME absolute path in the SAME namespace is
    # served from fs/fcache.ad's dcache instead of re-walking the per-Pgrp
    # mount table. Keyed by (Pgrp pointer, input path) + a global namespace
    # generation that every mount/bind/unmount/rename/unlink bumps — so a
    # different namespace never gets a wrong hit and a structural change
    # instantly invalidates the cache.
    #
    # Only ABSOLUTE, non-`#`-spec inputs are cacheable: a relative path
    # resolves against the (per-task) cwd, which is not in the key, and a
    # `#X` direct server spec bypasses the namespace walk entirely. Those
    # fall straight through to the uncached resolver.
    if input[0] == 47 and input[1] != 0:                  # '/...' absolute
        pg: uint64 = current_pgrp()
        dc_val: Array[256, uint8]
        dc_srv: int32 = 0
        dc_neg: uint32 = 0
        if fcache_dcache_lookup(pg, cast[Ptr[uint8]](input),
                                &dc_val[0], &dc_srv, &dc_neg) == 1:
            if dc_neg != 0:
                return ENOENT
            return _rp_copy(output, &dc_val[0], count)
        rc: int32 = _resolve_path_uncached(input, output, count)
        # Cache the verdict. A success caches the resolved name; an ENOENT
        # caches a negative dentry. ENAMETOOLONG / other errors are NOT
        # cached (transient / buffer-shape dependent).
        if rc == 0:
            fcache_dcache_store(pg, cast[Ptr[uint8]](input),
                                output, 0, 0)
        elif rc == ENOENT:
            fcache_dcache_store(pg, cast[Ptr[uint8]](input),
                                cast[Ptr[uint8]](input), 0, 1)
        return rc
    return _resolve_path_uncached(input, output, count)


def _resolve_path_uncached(input: Ptr[char], output: Ptr[uint8],
                           count: uint64) -> int32:
    # Resolve `input` (absolute or relative, with or without "."/"..")
    # through the calling task's NAMESPACE into a backend-addressable
    # name in `output`. Returns 0 on success, -ENAMETOOLONG on
    # overflow, -ENOENT when no binding in the caller's Pgrp covers
    # the path.
    #
    # F1 substrate (audit #444): this is a per-Pgrp namespace WALK, not
    # a prefix veneer over a global path table. The pipeline:
    #
    #   1. Canonicalise (cwd-prepend + "."/".." compaction).
    #   2. ns_walk (chan.ad): find the DEEPEST bound name covering the
    #      canonical path in the CURRENT Pgrp's mount table — FILE
    #      binds and SRV (9P) mounts compete by depth — and enumerate
    #      the union members at that point in Plan 9 search order
    #      (MBEFORE newest-first -> MREPL -> MAFTER).
    #   3. For each member: localize its server spec (`#r/#t/#e/#f`)
    #      to the backend key space and probe existence; the first
    #      member that exists wins. A SRV member terminates the walk
    #      with the path itself (namec's chan_find_srv_prefix routes
    #      it). Foreign specs (#c, #s, #by-id/...) aren't probeable
    #      here — they win only as the head fall-back, exactly as
    #      before (vfs_open's `#` arms own them).
    #   4. No member exists -> fall back to the union head (member 0)
    #      so creates/writes under a bind resolve to the head member.
    #   5. UNBOUND -> -ENOENT. There is NO global root to fall through
    #      to: the default boot namespace is itself a set of bindings
    #      (pgrp_init), and a hermetic RFCNAMEG child sees only what
    #      its recipe bound.
    #
    # `#X` direct inputs bypass canonicalisation (Plan 9 direct server
    # reference — kernel device-root syntax). Our own server specs are
    # localized so `cat '#r/etc/motd'` works; other specs pass through
    # verbatim to vfs_open's `#` dispatch.
    scratch: Array[256, uint8]
    local: Array[256, uint8]
    head: Array[256, uint8]
    # #442 (a): wid-decimal scratch + reversal scratch, hoisted to the
    # function top per the Adder nested-frame quirk.
    rp_wbuf: Array[16, uint8]
    rp_tmp:  Array[16, uint8]
    # #442 (a): `#w<rest>` is the PER-PROCESS windowing-server letter
    # (rio-shape: each process's namespace binds its own window under
    # `#w`). Rewrite it to the global `#c/wsys/<caller-wid><rest>` form
    # the cdev backend already serves, then fall through to the normal
    # `'#'` arm below. This is the Plan 9 namespace bind WITHOUT a
    # per-wid mount entry: every task's `#w/event` resolves to its OWN
    # wid's event stream, no wid in the user-visible path. wid 0 (no
    # bound wid, e.g. from a kernel-direct open) falls back to wid 1,
    # the foreground — same default _wsys_wid_for_current applies.
    if input[0] == 35 and input[1] == 119:             # '#w'
        nxt2: char = input[2]
        if nxt2 == 0 or nxt2 == 47:                    # '#w' or '#w/...'
            my_wid: int32 = wsys_wid_for_current()
            if my_wid <= 0:
                my_wid = 1
            # Emit "#c/wsys/<wid>" then the rest of the input from
            # position 2 onward (already starts with '/' or NUL).
            prefix: Ptr[uint8] = cast[Ptr[uint8]]("#c/wsys/")
            po: uint64 = 0
            pi: uint64 = 0
            while prefix[pi] != 0:
                if po + 1 >= 256:
                    return ENAMETOOLONG
                scratch[po] = prefix[pi]
                po = po + 1
                pi = pi + 1
            # Decimal-emit the wid (1..MAX_WINDOWS, fits in <= 4 digits).
            # Mirrors _wsys_u64_to_dec's reverse-then-flip in devwsys.ad.
            wn: uint64 = 0
            v: uint64 = cast[uint64](my_wid)
            if v == 0:
                rp_wbuf[0] = 48                        # '0'
                wn = 1
            else:
                tn: uint64 = 0
                while v != 0:
                    rp_tmp[tn] = cast[uint8](v % 10) + 48
                    v = v / 10
                    tn = tn + 1
                wn = 0
                while wn < tn:
                    rp_wbuf[wn] = rp_tmp[tn - 1 - wn]
                    wn = wn + 1
            wj: uint64 = 0
            while wj < wn:
                if po + 1 >= 256:
                    return ENAMETOOLONG
                scratch[po] = rp_wbuf[wj]
                po = po + 1
                wj = wj + 1
            # Append the rest of input from position 2 (includes leading
            # '/' if any; for bare "#w" appends nothing -> "#c/wsys/<wid>"
            # which devwsys treats as the bare wid listing).
            ri: uint64 = 2
            while True:
                c2: uint8 = cast[uint8](input[ri] & 0xFF)
                if po + 1 >= 256:
                    return ENAMETOOLONG
                scratch[po] = c2
                if c2 == 0:
                    break
                po = po + 1
                ri = ri + 1
            return _rp_copy(output, &scratch[0], count)
    if input[0] == 35:                                 # '#'
        i: uint64 = 0
        while i + 1 < count and i + 1 < 256:
            c: uint8 = cast[uint8](input[i] & 0xFF)
            scratch[i] = c
            if c == 0:
                lrc0: int32 = _spec_localize(&scratch[0], &local[0], 256)
                if lrc0 < 0:
                    return ENAMETOOLONG
                if lrc0 == 1:
                    return _rp_copy(output, &local[0], count)
                return _rp_copy(output, &scratch[0], count)
            i = i + 1
        scratch[i] = 0
        return ENAMETOOLONG
    rc: int32 = _resolve_path_canonical(input, output, count)
    if rc != 0:
        return rc
    hop: uint64 = 0
    while hop < NS_HOP_CAP:
        have_head: int32 = 0
        advanced: int32 = 0
        nth: uint64 = 0
        while nth < MNT_CAP_PROBE:
            wrc: int32 = ns_walk(output, &scratch[0], 256, nth)
            if wrc == 0:
                # UNBOUND — nothing in this namespace serves the path.
                return ENOENT
            if wrc == 2:
                # SRV mount is the selected member: `output` already
                # holds the 9P-visible name. Done.
                return 0
            if wrc == -1:
                return ENAMETOOLONG
            if wrc == -2:
                # Past the last member: no candidate's target existed.
                nth = MNT_CAP_PROBE
            else:
                # wrc == 1: scratch holds the nth member's rewrite.
                if scratch[0] == 35:                   # '#' spec
                    lrc: int32 = _spec_localize(&scratch[0],
                                                &local[0], 256)
                    if lrc < 0:
                        return ENAMETOOLONG
                    if lrc == 1:
                        # Our server: probe the localized backend key,
                        # SCOPED to the member's server letter (scratch[1]
                        # is the `#X` letter). This keeps a `#t` (tmpfs)
                        # overlay member from being satisfied by a NATIVE
                        # cpio file at the same un-rerooted path, which
                        # would shadow the rerooted `#r` MREPL base below.
                        if have_head == 0:
                            _rp_copy(&head[0], &local[0], 256)
                            have_head = 1
                        if _union_resolved_exists(&local[0],
                                                  scratch[1]) != 0:
                            return _rp_copy(output, &local[0], count)
                    else:
                        # Foreign server spec (#c, #s, #by-id/...,
                        # frozen named roots): not probeable here.
                        # Eligible as the head fall-back only.
                        if have_head == 0:
                            _rp_copy(&head[0], &scratch[0], 256)
                            have_head = 1
                    nth = nth + 1
                else:
                    # '/'-anchored rewrite: the frozen source was
                    # SRV-covered at bind time — chain hop. Re-walk
                    # the rewritten path.
                    if _rp_copy(output, &scratch[0], count) != 0:
                        return ENAMETOOLONG
                    advanced = 1
                    nth = MNT_CAP_PROBE
        if advanced != 0:
            hop = hop + 1
        else:
            # Union exhausted without an existing member: fall back to
            # the head (highest-priority member) so creates/writes
            # under a bind resolve there.
            if have_head == 0:
                return ENOENT
            return _rp_copy(output, &head[0], count)
    # Hop cap exceeded — treat as a broken chain (cycle), not a fall-
    # through.
    return ENOENT


def vfs_pipe(out_fds: Ptr[int32]) -> int32:
    # Allocate a kernel pipe and place its read fd in out_fds[0] and
    # write fd in out_fds[1] in the calling task. Returns 0 on
    # success; -EMFILE if the caller doesn't have two free fd slots,
    # -ENOSPC if the global pipe table is full. We allocate fds in
    # the parent task only — children inherit by dup'ing.
    #
    # Phase 4c: each pipe END rides its own DEV_PIPE_R / DEV_PIPE_W
    # POOL chan (back_slot = pipe ring slot). pipe_alloc starts the
    # ring at readers=1/writers=1; each chan OWNS one of those
    # end-references, released by namec_close's DEV_PIPE arms on the
    # LAST fd holder (fork/dup bumps the chan refcount, not the pipe
    # counters).
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    rfd: int32 = _alloc_fd(task)
    if rfd < 0:
        return EMFILE
    # Provisionally mark rfd used so _alloc_fd skips it when we ask
    # for the second fd, but we haven't routed it anywhere yet.
    task[0].fd_idx[cast[uint64](rfd)] = FD_CHAN_MARK
    wfd: int32 = _alloc_fd(task)
    if wfd < 0:
        # Roll back the half-taken read fd before we error out.
        task[0].fd_idx[cast[uint64](rfd)] = FD_CLOSED_MARK
        return EMFILE

    slot: int32 = pipe_alloc()
    if slot < 0:
        task[0].fd_idx[cast[uint64](rfd)] = FD_CLOSED_MARK
        # wfd is still a bare _alloc_fd RESERVED slot (never installed) — free it.
        task[0].fd_idx[cast[uint64](wfd)] = FD_CLOSED_MARK
        return ENOSPC

    rch: int32 = namec_open_pipe_end(slot, 0)
    if rch < 0:
        # Chan pool exhausted — drop BOTH end-references so the ring
        # slot is reclaimed, then roll the fds back.
        pipe_close_reader(slot)
        pipe_close_writer(slot)
        task[0].fd_idx[cast[uint64](rfd)] = FD_CLOSED_MARK
        task[0].fd_idx[cast[uint64](wfd)] = FD_CLOSED_MARK
        return ENOSPC
    wch: int32 = namec_open_pipe_end(slot, 1)
    if wch < 0:
        # The read chan now owns the reader ref; namec_close releases
        # it. The writer ref is still raw — drop it directly.
        namec_close(rch)
        pipe_close_writer(slot)
        task[0].fd_idx[cast[uint64](rfd)] = FD_CLOSED_MARK
        task[0].fd_idx[cast[uint64](wfd)] = FD_CLOSED_MARK
        return ENOSPC

    rfdu: uint64 = cast[uint64](rfd)
    wfdu: uint64 = cast[uint64](wfd)
    task[0].fd_idx[rfdu] = FD_CHAN_MARK
    task[0].fd_pos[rfdu] = 0
    task[0].fd_buf[rfdu] = cast[uint64](cast[uint32](rch))
    task[0].fd_idx[wfdu] = FD_CHAN_MARK
    task[0].fd_pos[wfdu] = 0
    task[0].fd_buf[wfdu] = cast[uint64](cast[uint32](wch))

    out_fds[0] = rfd
    out_fds[1] = wfd
    return 0


def vfs_socketpair(out_fds: Ptr[int32]) -> int32:
    # V5: allocate a bidirectional socketpair in the calling task. Two
    # fds back the same SocketPair slot — fd[0] is end A, fd[1] is end
    # B. Writes on one fd appear as reads on the other and vice versa.
    # Returns 0 on success; -EMFILE if the caller can't fit two more
    # fds, -ENOSPC if the global SocketPair table is full.
    #
    # Mirrors vfs_pipe's allocation shape (alloc two fds first, then
    # the backing slot, then a DEV_SOCKETPAIR pool chan PER END, roll
    # back on failure) so the failure paths look the same to the
    # syscall dispatcher. Phase 4c (socket fold): each end is an
    # FD_CHAN_MARK fd; fd_buf carries the chan id, the chan's
    # back_slot carries the packed (slot << 1 | dir).
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    afd: int32 = _alloc_fd(task)
    if afd < 0:
        return EMFILE
    task[0].fd_idx[cast[uint64](afd)] = FD_CHAN_MARK   # provisional claim
    bfd: int32 = _alloc_fd(task)
    if bfd < 0:
        task[0].fd_idx[cast[uint64](afd)] = FD_CLOSED_MARK
        return EMFILE

    slot: int32 = sockpair_alloc()
    if slot < 0:
        task[0].fd_idx[cast[uint64](afd)] = FD_CLOSED_MARK
        # bfd is still a bare _alloc_fd RESERVED slot (never installed) — free it.
        task[0].fd_idx[cast[uint64](bfd)] = FD_CLOSED_MARK
        return ENOSPC

    ach: int32 = namec_open_sockpair_end(slot, 0)
    if ach < 0:
        # Chan pool exhausted — drop BOTH end-references so the slot
        # is reclaimed, then roll the fd back.
        sockpair_close(slot, 0)
        sockpair_close(slot, 1)
        task[0].fd_idx[cast[uint64](afd)] = FD_CLOSED_MARK
        task[0].fd_idx[cast[uint64](bfd)] = FD_CLOSED_MARK
        return ENOSPC
    bch: int32 = namec_open_sockpair_end(slot, 1)
    if bch < 0:
        # The end-A chan now owns ref A; namec_close releases it. The
        # end-B reference is still raw — drop it directly.
        namec_close(ach)
        sockpair_close(slot, 1)
        task[0].fd_idx[cast[uint64](afd)] = FD_CLOSED_MARK
        task[0].fd_idx[cast[uint64](bfd)] = FD_CLOSED_MARK
        return ENOSPC

    afdu: uint64 = cast[uint64](afd)
    bfdu: uint64 = cast[uint64](bfd)
    task[0].fd_idx[afdu] = FD_CHAN_MARK
    task[0].fd_pos[afdu] = 0
    task[0].fd_buf[afdu] = cast[uint64](cast[uint32](ach))
    task[0].fd_idx[bfdu] = FD_CHAN_MARK
    task[0].fd_pos[bfdu] = 0
    task[0].fd_buf[bfdu] = cast[uint64](cast[uint32](bch))

    out_fds[0] = afd
    out_fds[1] = bfd
    return 0


def vfs_fd_is_socketpair(fd: int32) -> int32:
    # V5: cheap probe so the 9P client (sys/src/9/port/9p_client.ad)
    # can detect a bidirectional transport without branching on fd
    # representation itself. Phase 4c (socket fold): a live endpoint
    # is an FD_CHAN_MARK fd over a DEV_SOCKETPAIR chan. Returns 1 if
    # `fd` is one, 0 otherwise.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    if task[0].fd_idx[cast[uint64](fd)] != FD_CHAN_MARK:
        return 0
    if namec_chan_sockpair_packed(
            _fd_chan_id(task, cast[uint64](fd))) >= 0:
        return 1
    return 0


def vfs_srv_dup_into_current(src_task: Ptr[TaskStruct],
                             src_fdu: uint64) -> int32:
    # V4 / sys_srv_open helper. Allocate the lowest free fd in the
    # CURRENT task, then copy_fd_entry from src_task[src_fdu] into
    # it. Returns the new fd on success, -EBADF if the source slot
    # is closed, -EMFILE if the caller is out of fd slots. Used by
    # arch/x86/kernel/syscall.ad::SYS_SRV_OPEN; lives here so the
    # `_alloc_fd` private helper stays private and the same
    # validation order is used as the rest of the open-family
    # routes (pipe, dup, dup2, FAT/EXT open).
    if cast[uint64](src_task) == 0:
        return EBADF
    if src_task[0].fd_idx[src_fdu] == FD_CLOSED_MARK:
        return EBADF
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    new_fd: int32 = _alloc_fd(task)
    if new_fd < 0:
        return EMFILE
    if copy_fd_entry(task, cast[uint64](new_fd), src_task, src_fdu) < 0:
        return EBADF
    return new_fd


def vfs_alloc_socket_fd() -> int32:
    # U35: claim an empty fd-table slot for a Linux-ABI socket fd.
    # Phase 4c (socket fold): the fd is an FD_CHAN_MARK fd over a
    # DEV_SOCKET pool chan allocated with back_slot = 0 ("no record
    # yet" — reads return EOF, writes answer EPIPE) until socket(2)
    # late-binds the backing record via vfs_socket_fd_set_record.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    ch: int32 = namec_open_socket(0)
    if ch < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK
        return EMFILE                      # chan pool exhausted
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](ch))
    task[0].fd_buflen[fdu] = 0
    return fd


def vfs_fd_is_socket(fd: int32) -> int32:
    # U35: cheap probe so poll(2) and the Layer-2 socket-call surface
    # can recognise socket fds without branching on fd representation.
    # Phase 4c (socket fold): a socket fd is an FD_CHAN_MARK fd over a
    # DEV_SOCKET chan. Returns 1 on a live socket fd, 0 otherwise
    # (including out-of-range / closed).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    if task[0].fd_idx[cast[uint64](fd)] != FD_CHAN_MARK:
        return 0
    if namec_chan_socket_fdbuf(
            _fd_chan_id(task, cast[uint64](fd))) >= 0:
        return 1
    return 0


def vfs_socket_fd_set_record(fd: int32, fdbuf: uint64) -> int32:
    # U-socket: stash the encoded backing id (usock_fdbuf_for_record /
    # afunix_fdbuf_for_ep / nl_fdbuf_for_ep — all 31-bit encodings)
    # behind a socket fd. linux_abi/u_syscalls.ad's socket(2) handler
    # calls this after it has allocated both the fd and the backing
    # record. Phase 4c (socket fold): the encoding lives in the
    # DEV_SOCKET chan's back_slot, not fd_buf (which carries the chan
    # id). Returns 0 on success, -EBADF if `fd` is not a live socket
    # fd.
    if vfs_fd_is_socket(fd) == 0:
        return EBADF
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    if namec_socket_set_record(_fd_chan_id(task, cast[uint64](fd)),
                               cast[int32](cast[uint32](fdbuf))) != 0:
        return EBADF
    return 0


def vfs_socket_fd_get_record(fd: int32) -> uint64:
    # U-socket: read back the encoded record id from behind a socket
    # fd. Returns 0 (== "no record") for a non-socket / closed fd so
    # the caller's usock_record_for_fdbuf decode yields -1.
    if vfs_fd_is_socket(fd) == 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    return cast[uint64](namec_chan_socket_fdbuf(
        _fd_chan_id(task, cast[uint64](fd))))


# --- DEV_SOCKET chan I/O + release bodies (Phase 4c socket fold) ----
#
# Verbatim ports of the retired FD_SOCKET_MARK arms, keyed on the
# fd_buf ENCODING (rec+1 / AF_UNIX tag / netlink tag / 0 = no record)
# the DEV_SOCKET chan carries in back_slot. namec_read / namec_read_nb
# / namec_write / namec_close dispatch here BY NAME (vfs imports
# namec; the reverse import would cycle). They live in vfs.ad because
# they drive the tcp/udp/tls/devnet stacks imported above.

def vfs_socket_chan_read(fdbuf: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    # Blocking socket read. A record-less socket (created but never
    # connect()'d, failed connect, or already closed) reads as
    # immediate EOF — the same answer the U35 stub gave.
    sk_rec: int32 = usock_record_for_fdbuf(fdbuf)
    if sk_rec < 0:
        return 0
    # §10 UDP: a datagram socket's read(2) pulls ONE datagram via the
    # UDP socket layer. A timeout with no data returns 0 (a UDP socket
    # is never at a stream EOF; plain read(2) has no EAGAIN channel).
    if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
        udp_slot_r: int32 = usock_get_tcp_slot(sk_rec)
        if udp_slot_r < 0:
            return 0
        ud_rn: int64 = udp_socket_recvfrom(
            udp_slot_r, buf, count, 500,
            cast[Ptr[uint32]](0), cast[Ptr[uint16]](0))
        if ud_rn < 0:
            return 0
        return ud_rn
    if usock_get_state(sk_rec) != USOCK_CONNECTED:
        return 0
    sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
    if sk_tcp < 0:
        return 0
    # U-TLS: a TLS-active socket reads the next decrypted
    # application_data record via the TLS record layer (keyed on the
    # /net conn). Latch CLOSED on EOF/error answers.
    if usock_is_tls(sk_rec) != 0:
        sk_netconn_r: int32 = usock_get_netconn(sk_rec)
        n_tls: int64 = tls_recv(sk_netconn_r, buf, count, 500)
        if n_tls <= 0:
            usock_set_state(sk_rec, USOCK_CLOSED)
        return n_tls
    # 500 jiffies (~5 s @ HZ=100) blocking budget — bounded so a dead
    # peer can't wedge the syscall. tcp_recv returns 0 on EITHER a
    # peer-FIN-with-no-data (true EOF) OR a plain timeout; ask the
    # slot directly and latch CLOSED only at genuine end-of-stream so
    # long-lived interactive servers (user/sshd.ad) can read again
    # after a bare timeout.
    n_sk: int64 = tcp_recv(sk_tcp, buf, count, 500)
    if n_sk < 0:
        usock_set_state(sk_rec, USOCK_CLOSED)
    elif n_sk == 0:
        if tcp_slot_at_eof(sk_tcp) != 0:
            usock_set_state(sk_rec, USOCK_CLOSED)
    return n_sk


def vfs_socket_chan_read_nb(fdbuf: uint64, buf: Ptr[uint8],
                            count: uint64) -> int64:
    # Non-blocking socket read: >0 bytes ready, 0 would-block, -1 true
    # EOF / error.
    sk_rec: int32 = usock_record_for_fdbuf(fdbuf)
    if sk_rec < 0:
        return -1
    # §10 UDP: a non-blocking read on a datagram socket returns a
    # queued datagram if one is ready, else 0 ("would block" — a UDP
    # socket is never at a true EOF).
    if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
        udp_slot_nb: int32 = usock_get_tcp_slot(sk_rec)
        if udp_slot_nb < 0:
            return -1
        if udp_socket_recv_pending(udp_slot_nb) == 0:
            return 0
        ud_nb: int64 = udp_socket_recvfrom(
            udp_slot_nb, buf, count, 1,
            cast[Ptr[uint32]](0), cast[Ptr[uint16]](0))
        if ud_nb < 0:
            return 0
        return ud_nb
    if usock_get_state(sk_rec) != USOCK_CONNECTED:
        return -1
    sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
    if sk_tcp < 0:
        return -1
    # TLS-active sockets have no non-blocking record-layer path; an
    # event-loop daemon over TLS is out of scope here.
    if usock_is_tls(sk_rec) != 0:
        return -1
    n_sk: int64 = tcp_recv_nb(sk_tcp, buf, count)
    if n_sk < 0:
        usock_set_state(sk_rec, USOCK_CLOSED)
    return n_sk


def vfs_socket_chan_write(fdbuf: uint64, buf: Ptr[uint8],
                          count: uint64) -> int64:
    # Blocking socket write. A record-less socket answers EPIPE (the
    # closest wired errno to ENOTCONN).
    sk_rec: int32 = usock_record_for_fdbuf(fdbuf)
    if sk_rec < 0:
        return cast[int64](EPIPE)
    # §10 UDP: a datagram socket's write(2) sends one datagram to the
    # connect(2)'d peer (-EPIPE standing in for -EDESTADDRREQ when
    # unconnected).
    if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
        udp_slot_w: int32 = usock_get_tcp_slot(sk_rec)
        if udp_slot_w < 0:
            return cast[int64](EPIPE)
        udp_peer: uint32 = usock_get_peer_addr(sk_rec)
        udp_pport: uint32 = usock_get_peer_port(sk_rec)
        if udp_peer == 0:
            # No peer — write(2) on an unconnected datagram socket.
            return cast[int64](EPIPE)
        ud_wn: int64 = udp_socket_sendto(
            udp_slot_w, udp_peer,
            cast[uint16](udp_pport & 0xFFFF), buf, count)
        if ud_wn < 0:
            return cast[int64](EPIPE)
        return ud_wn
    if usock_get_state(sk_rec) != USOCK_CONNECTED:
        return cast[int64](EPIPE)
    sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
    if sk_tcp < 0:
        return cast[int64](EPIPE)
    # U-TLS: a TLS-active fd encrypts each write through the TLS 1.3
    # record layer (keyed on the /net conn). tls_send's plaintext
    # scratch caps one record at ~2026 bytes — chunk at 2000 so a
    # larger write(2) drains as a sequence of records.
    if usock_is_tls(sk_rec) != 0:
        sk_netconn_w: int32 = usock_get_netconn(sk_rec)
        tls_sent: uint64 = 0
        while tls_sent < count:
            tls_chunk: uint64 = count - tls_sent
            if tls_chunk > 2000:
                tls_chunk = 2000
            tls_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                cast[uint64](buf) + tls_sent)
            tls_rc: int64 = tls_send(sk_netconn_w, tls_ptr, tls_chunk)
            if tls_rc <= 0:
                # Encrypt / transport failure. Latch CLOSED; report a
                # short count if earlier records made it, else EPIPE.
                usock_set_state(sk_rec, USOCK_CLOSED)
                if tls_sent > 0:
                    return cast[int64](tls_sent)
                return cast[int64](EPIPE)
            tls_sent = tls_sent + cast[uint64](tls_rc)
        return cast[int64](tls_sent)
    # tcp_send truncates each segment at TCP_MSS — loop until the
    # whole buffer drains. A mid-stream failure returns the partial
    # count if any bytes went out, else EPIPE.
    sk_sent: uint64 = 0
    while sk_sent < count:
        sk_ptr: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + sk_sent)
        sk_rc: int64 = tcp_send(sk_tcp, sk_ptr, count - sk_sent)
        if sk_rc <= 0:
            usock_set_state(sk_rec, USOCK_CLOSED)
            if sk_sent > 0:
                return cast[int64](sk_sent)
            return cast[int64](EPIPE)
        sk_sent = sk_sent + cast[uint64](sk_rc)
    return cast[int64](sk_sent)


def vfs_socket_chan_release(fdbuf: uint64):
    # The FULL socket teardown, run by namec_close's DEV_SOCKET arm on
    # the LAST chan reference. ONE copy now — the legacy model kept
    # this duplicated in vfs_close's FD_SOCKET_MARK arm AND
    # close_fd_in_task's by-name clone (both deleted).
    sk_rec: int32 = usock_record_for_fdbuf(fdbuf)
    if sk_rec < 0:
        return
    sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
    sk_netconn: int32 = usock_get_netconn(sk_rec)
    # §10 UDP: a datagram socket's stack slot is a udp.ad socket slot —
    # release it via udp_socket_close (no FIN handshake; UDP is
    # connectionless). Then free the backing record.
    if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
        if sk_tcp >= 0:
            udp_socket_close(sk_tcp)
        usock_free(sk_rec)
        return
    # U-TLS: a TLS-active fd gets a graceful TLS shutdown first — send
    # a close_notify alert (best-effort, keyed on the /net conn) and
    # reset the in-kernel TLS session so a later tls_connect(2) can
    # claim it again.
    if usock_is_tls(sk_rec) != 0:
        if sk_netconn >= 0:
            tls_close_notify(sk_netconn)
        tls_close()
        usock_set_tls(sk_rec, 0)
    # ARCH §10: a TCP socket fd's connection is owned by the /net file
    # tree (connect(2)/listen(2)/accept(2) cloned it). Dropping the
    # /net reference FIN-tears the TCP transport down. A record with
    # no /net conn (legacy / never-connected) falls back to a direct
    # tcp_close / tcp_listen_close.
    if sk_netconn >= 0:
        devnet_conn_unref(sk_netconn)
    elif sk_tcp >= 0:
        if usock_get_state(sk_rec) == USOCK_LISTENING:
            tcp_listen_close(sk_tcp)
        else:
            tcp_close(sk_tcp)
    usock_free(sk_rec)


# --- DEV_NET chan I/O + release bodies (Phase 4d net fold, F7 #390) ---
#
# Verbatim ports of the retired FD_NET_MARK arms, keyed on the
# (proto, conn, file-kind) pack the DEV_NET chan carries in back_slot
# (recovered as a uint64 here so the existing devnet_unpack_* helpers
# work unchanged). namec_read / namec_read_nb / namec_write /
# namec_close dispatch here BY NAME (vfs imports namec; the reverse
# import would cycle). They live in vfs.ad because they drive the
# devnet/tcp/udp/tls stacks vfs.ad already imports.
#
# `off` from namec_read is the byte cursor advanced by vfs_read after
# each call — the snapshot leaves (clone/status/local/remote/addr/
# dns/dns_lookup/dns_rlookup/ctl) consult it to EOF-terminate `cat` on
# a second read, EXACTLY the way the legacy mark arm consulted
# task.fd_pos[fdu]. The DATA leaf ignores off (TCP/UDP/TLS are
# stream-shaped).

def vfs_net_chan_read(net_pk: uint64, off: uint64, buf: Ptr[uint8],
                      count: uint64) -> int64:
    nf:  int32 = devnet_unpack_file(net_pk)
    nc:  int32 = devnet_unpack_conn(net_pk)
    if nf == NET_FILE_DATA:
        # The connection byte stream — a blocking read. ARCH §10: if a
        # `tls <host>` ctl command TLS-upgraded this conn, read(2)
        # decrypts transparently through the TLS 1.3 record layer
        # (tls_recv pulls the conn's data file + AEAD-opens).
        if devnet_conn_is_tls(nc) != 0:
            n_tls: int64 = tls_recv(nc, buf, count, 500)
            if n_tls <= 0:
                return 0
            return n_tls
        return devnet_data_read(nc, buf, count)
    # clone / status / local / remote / addr / dns* / ctl-accept: one-
    # shot text snapshots. A second read (off advanced) is EOF so `cat`
    # terminates.
    if off > 0:
        return 0
    # 192 bytes: the /net/icmp `status` line carries peer, id, tx/rx
    # counters, and last seq/ttl/rtt — up to ~120 chars.
    snap: Array[192, uint8]
    nlen: int64 = 0
    if nf == NET_FILE_CLONE:
        # Reading the clone fd yields the connection number — the
        # canonical "ctl-file discovery dance" from native-api.md.
        nlen = _devnet_render_dec(nc, &snap[0])
    elif nf == NET_FILE_STATUS:
        nlen = devnet_status_render(nc, &snap[0], 192)
    elif nf == NET_FILE_LOCAL:
        nlen = devnet_local_render(nc, &snap[0], 192)
    elif nf == NET_FILE_REMOTE:
        nlen = devnet_remote_render(nc, &snap[0], 192)
    elif nf == NET_FILE_ADDR:
        nlen = devnet_addr_render(&snap[0], 192)
    elif nf == NET_FILE_DNS:
        # F2 #447: /net/dns read renders "<a.b.c.d> <source>\n".
        nlen = devnet_dns_read(0, &snap[0], 192)
    elif nf == NET_FILE_DNS_LOOKUP or nf == NET_FILE_DNS_RLOOKUP:
        # F2 #447: read pulls the LAST DNS result written by the
        # paired write. Returns 0 (EOF) if no result is pending.
        nlen = devnet_dns_result_read(0, &snap[0], 192)
    elif nf == NET_FILE_IPIFC_CTL:
        # F2 #447: /net/ipifc/ctl is write-only — Plan 9 contract.
        set_current_errstr("ctl: not readable")
        return -1
    elif nf == NET_FILE_CTL:
        # A read of a ctl file returns the connection number of a peer
        # accepted on this conn (the clone-style discovery dance —
        # after a `accept` ctl write, read the ctl file to learn the
        # accepted conn number). If no accept is pending the read is
        # empty.
        acc: int32 = devnet_accept_take(nc)
        if acc < 0:
            return 0
        nlen = _devnet_render_dec(acc, &snap[0])
    else:
        return 0
    if nlen <= 0:
        return 0
    take: uint64 = cast[uint64](nlen)
    if take > count:
        take = count
    i: uint64 = 0
    while i < take:
        buf[i] = snap[i]
        i = i + 1
    return cast[int64](take)


def vfs_net_chan_read_nb(net_pk: uint64, off: uint64, buf: Ptr[uint8],
                         count: uint64) -> int64:
    # Non-blocking read of a /net fd. >0 bytes, 0 = would-block, -1 =
    # EOF/error. Only the DATA file has a would-block notion —
    # clone/status/local/remote/etc. are one-shot snapshots and
    # delegate to the blocking body (one-shot then EOF on the next
    # call). off is plumbed through so the snapshot delegation still
    # EOF-terminates on a second read.
    nf:  int32 = devnet_unpack_file(net_pk)
    nc:  int32 = devnet_unpack_conn(net_pk)
    if nf == NET_FILE_DATA:
        return devnet_data_read_nb(nc, buf, count)
    return vfs_net_chan_read(net_pk, off, buf, count)


def vfs_net_chan_write(net_pk: uint64, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # A write to the data file streams bytes onto the connection; a
    # write to the ctl file is ONE text command (connect / announce /
    # accept / hangup); the host-level files (/net/dns + /net/ipifc/ctl
    # + /net/dns/{,r}lookup) parse their own request line.
    nf: int32 = devnet_unpack_file(net_pk)
    nc: int32 = devnet_unpack_conn(net_pk)
    if nf == NET_FILE_DATA:
        # ARCH §10: a `tls`-upgraded conn encrypts each write through
        # the TLS 1.3 record layer before it hits the connection's
        # byte stream. tls_send's plaintext scratch is a 2048-byte
        # frame, so one record caps at ~2026 plaintext bytes; chunk
        # the user buffer at 2000 bytes per call so a write(2) larger
        # than one TLS record drains as a sequence of records.
        if devnet_conn_is_tls(nc) != 0:
            net_tls_sent: uint64 = 0
            while net_tls_sent < count:
                net_tls_chunk: uint64 = count - net_tls_sent
                if net_tls_chunk > 2000:
                    net_tls_chunk = 2000
                net_tls_ptr: Ptr[uint8] = cast[Ptr[uint8]](
                    cast[uint64](buf) + net_tls_sent)
                net_tls_rc: int64 = tls_send(nc, net_tls_ptr,
                                             net_tls_chunk)
                if net_tls_rc <= 0:
                    if net_tls_sent > 0:
                        return cast[int64](net_tls_sent)
                    return -1
                net_tls_sent = net_tls_sent + cast[uint64](net_tls_rc)
            return cast[int64](net_tls_sent)
        return devnet_data_write(nc, buf, count)
    if nf == NET_FILE_CTL:
        rc_ctl: int32 = devnet_ctl(nc, buf, count)
        if rc_ctl != NET_CTL_OK:
            set_current_errstr("net: ctl command failed")
            return -1
        # A ctl write consumes the whole command — report the full
        # count so the caller does not retry a "short write".
        return cast[int64](count)
    # F2 #447: host-level Plan-9-shape ctl files.
    if nf == NET_FILE_DNS:
        return devnet_dns_write(buf, count)
    if nf == NET_FILE_IPIFC_CTL:
        return devnet_ipifc_ctl_write(buf, count)
    if nf == NET_FILE_DNS_LOOKUP:
        return devnet_dns_lookup_write(buf, count)
    if nf == NET_FILE_DNS_RLOOKUP:
        return devnet_dns_rlookup_write(buf, count)
    # clone / status / local / remote / addr: not writable.
    set_current_errstr("net: file not writable")
    return -1


def vfs_net_chan_release(net_pk: uint64):
    # The /net conn-refcount release, run by namec_close's DEV_NET arm
    # on the LAST chan reference. ONE copy now — the legacy model put
    # this in vfs_close's FD_NET_MARK arm and core.ad's
    # close_fd_in_task did NOT mirror it (core knew nothing of
    # FD_NET_MARK), so a task that exited holding a /net fd leaked the
    # conn ref outright. Both bugs fixed: dup/fork share the chan and
    # the unref fires on last close; task exit goes through
    # close_fd_in_task → namec_close → here.
    net_conn: int32 = devnet_unpack_conn(net_pk)
    if net_conn >= 0:
        devnet_conn_unref(net_conn)


# --- Phase 4e (PTY fold, F7 #390): DEV_PTMX I/O + release bodies ----
#
# Called BY NAME from sys/src/9/port/namec.ad's DEV_PTMX dispatch
# arms (namec_read / namec_write / namec_close). vfs imports namec,
# so the reverse import would cycle — same pattern DEV_NET /
# DEV_SOCKET use. `pty_pk` is the verbatim legacy fd_buf pack
# ((slot << 1) | is_master) the chan carries in back_slot.

def vfs_ptmx_chan_read(pty_pk: uint64, buf: Ptr[uint8],
                       count: uint64) -> int64:
    # Verbatim port of the legacy FD_PTMX_MARK read arm. A master read
    # drains the slave's output (s2m queue); a slave read runs the
    # cooked/raw line discipline over the master-write queue (m2s).
    # Both block-yield until bytes are available (or the peer end
    # closes → EOF). The discipline + echo live in u_pty.ad. F4 #449:
    # dispatch through the registered hooks. If the PTY layer is not
    # bound (pure-native build) we cannot reach this arm anyway, since
    # no DEV_PTMX chan can be created — but guard defensively in case a
    # stale chan survives a reconfiguration.
    pty_slot: int32 = _pty_fd_slot(pty_pk)
    if _pty_fd_is_master(pty_pk) != 0:
        if pty_master_read_hook \
                == cast[Fn[int64, int32, Ptr[uint8], uint64]](0):
            return cast[int64](EBADF)
        return pty_master_read_hook(pty_slot, buf, count)
    if pty_slave_read_hook \
            == cast[Fn[int64, int32, Ptr[uint8], uint64]](0):
        return cast[int64](EBADF)
    return pty_slave_read_hook(pty_slot, buf, count)


def vfs_ptmx_chan_write(pty_pk: uint64, buf: Ptr[uint8],
                        count: uint64) -> int64:
    # Verbatim port of the legacy FD_PTMX_MARK write arm. A master
    # write feeds the slave's input queue (m2s — the bytes the terminal
    # "types"); a slave write feeds the master's read queue (s2m — the
    # program's output, OPOST|ONLCR applied). See u_pty.ad. F4 #449:
    # dispatch through the registered hooks.
    pty_slot: int32 = _pty_fd_slot(pty_pk)
    if _pty_fd_is_master(pty_pk) != 0:
        if pty_master_write_hook \
                == cast[Fn[int64, int32, Ptr[uint8], uint64]](0):
            return cast[int64](EBADF)
        return pty_master_write_hook(pty_slot, buf, count)
    if pty_slave_write_hook \
            == cast[Fn[int64, int32, Ptr[uint8], uint64]](0):
        return cast[int64](EBADF)
    return pty_slave_write_hook(pty_slot, buf, count)


def vfs_ptmx_readable(pty_pk: uint64) -> int32:
    # QA-N31: non-destructive readiness probe for a pty end (used by
    # vfs_fd_poll's DEV_PTMX arm and namec_poll_readable's DEV_PTMX arm).
    # A MASTER read drains the slave's output (s2m queue); a SLAVE read
    # drains the master-write queue (m2s). Report readable ONLY when the
    # end's source queue has bytes — mirrors the queue the matching read
    # path (vfs_ptmx_chan_read) blocks on. Returns 1 if a read would
    # return data now, else 0. Null hook (pure-native build) => not
    # readable (defensive; no DEV_PTMX chan can exist there anyway).
    pty_slot: int32 = _pty_fd_slot(pty_pk)
    if _pty_fd_is_master(pty_pk) != 0:
        if pty_master_readable_hook == cast[Fn[int32, int32]](0):
            return 0
        return pty_master_readable_hook(pty_slot)
    if pty_slave_readable_hook == cast[Fn[int32, int32]](0):
        return 0
    return pty_slave_readable_hook(pty_slot)


def vfs_ptmx_chan_release(pty_pk: uint64):
    # The per-end refcount release, run by namec_close's DEV_PTMX arm
    # on the LAST chan reference. ONE copy now — the legacy model
    # required PARALLEL FD_PTMX_MARK arms in BOTH vfs_close AND
    # close_fd_in_task (the latter delegated back here in spirit; in
    # practice the V5 ladder kept the unref next to the close path).
    # Releasing BOTH ends frees the pair slot inside u_pty.ad.
    pty_slot: int32 = _pty_fd_slot(pty_pk)
    if _pty_fd_is_master(pty_pk) != 0:
        if pty_master_unref_hook != cast[Fn[None, int32]](0):
            pty_master_unref_hook(pty_slot)
    else:
        if pty_slave_unref_hook != cast[Fn[None, int32]](0):
            pty_slave_unref_hook(pty_slot)


# --- DEV_FUSE_CONN / DEV_FUSE_FILE bodies ----------------------------
#
# Phase 4f (FUSE fold, F7 #390): verbatim ports of the legacy
# FD_FUSE_CONN_MARK + FD_FUSE_FILE_MARK arms that lived in vfs_read /
# vfs_write / vfs_close. namec.ad's DEV_FUSE_CONN / DEV_FUSE_FILE arms
# dispatch here BY NAME (vfs imports namec; the reverse import would
# cycle — same pattern DEV_PTMX / DEV_NET / DEV_SOCKET use).
# back_slot carries the raw fd_buf word: the conn-slot index for
# DEV_FUSE_CONN, the open-file token for DEV_FUSE_FILE.

def vfs_fuse_conn_chan_read(conn_slot: int32, ubuf: uint64,
                            count: uint64) -> int64:
    # §fuse: /dev/fuse read — the daemon drains one queued fuse_in
    # request (header+body). fuse_dev_read_hook copies the whole
    # request out via copy_to_user. A null hook means the FUSE layer
    # isn't loaded; -EBADF mirrors the legacy arm's guard.
    if fuse_dev_read_hook == cast[Fn[int64, int32, uint64, uint64]](0):
        return cast[int64](EBADF)
    return fuse_dev_read_hook(conn_slot, ubuf, count)


def vfs_fuse_conn_chan_write(conn_slot: int32, ubuf: uint64,
                             count: uint64) -> int64:
    # §fuse: /dev/fuse write — the daemon submits a fuse_out reply
    # (out_header + body). fuse_dev_write_hook validates the header,
    # matches it to the outstanding request by `unique`, and wakes the
    # blocked VFS caller. One complete reply per write.
    if fuse_dev_write_hook == cast[Fn[int64, int32, uint64, uint64]](0):
        return cast[int64](EBADF)
    return fuse_dev_write_hook(conn_slot, ubuf, count)


def vfs_fuse_conn_chan_release(conn_slot: int32):
    # §fuse: drop a /dev/fuse connection slot. Null hook = FUSE layer
    # not bound (no chan of this kind can exist anyway, but guard
    # defensively against a stale chan surviving a reconfiguration).
    if fuse_dev_close_hook != cast[Fn[None, int32]](0):
        fuse_dev_close_hook(conn_slot)


def vfs_fuse_file_chan_read(tok: int32, buf: Ptr[uint8],
                            count: uint64) -> int64:
    # §fuse: a path served through a FUSE mount — drive FUSE_READ over
    # the wire at the file's current offset. fuse_vfs_read_hook
    # maintains its OWN per-token position cursor (the legacy mark arm
    # passed neither off nor fd_pos), so the chan-level off cursor is
    # deliberately ignored here, matching the legacy contract.
    if fuse_vfs_read_hook == cast[Fn[int64, int32, Ptr[uint8], uint64]](0):
        return cast[int64](EBADF)
    return fuse_vfs_read_hook(tok, buf, count)


def vfs_fuse_file_chan_release(tok: int32):
    # §fuse: drive FUSE_RELEASE for a served-file token. Null hook
    # short-circuits (no FUSE layer bound).
    if fuse_vfs_close_hook != cast[Fn[None, int32]](0):
        fuse_vfs_close_hook(tok)


def vfs_fd_is_open(fd: int32) -> int32:
    # U35: poll(2) needs to distinguish "valid fd" from "fd not open"
    # (returns POLLNVAL for the latter). Returns 1 if the fd slot is
    # in any open state, 0 otherwise.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    if task[0].fd_idx[cast[uint64](fd)] == FD_CLOSED_MARK:
        return 0
    return 1


# =====================================================================
# §5 Layer-2 async I/O — fd-table helpers
# =====================================================================
#
# epoll / eventfd / timerfd / signalfd objects (linux_abi/u_epoll.ad)
# are referenced through a real per-task fd-table slot tagged with one
# of u_epoll.ad's FD_*_MARK markers; the slot's fd_buf carries the
# object's `slot_id + 1` (0 == "no object"). linux_abi/u_syscalls.ad
# cannot poke the fd table directly (it is per-task private state in
# core.ad), so these accessors are the bridge — the same shape as
# vfs_alloc_socket_fd / vfs_socket_fd_set_record above.

def vfs_alloc_l2_fd(mark: uint32) -> int32:
    # Claim an empty fd-table slot and tag it with a Layer-2 marker
    # (FD_EPOLL_MARK / FD_EVENTFD_MARK / FD_TIMERFD_MARK /
    # FD_SIGNALFD_MARK). fd_buf / fd_pos / fd_buflen start zero — the
    # caller fills fd_buf with the encoded object slot. Returns the fd
    # or -EMFILE when the table is full.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = mark
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = 0
    task[0].fd_buflen[fdu] = 0
    return fd


def vfs_fd_marker(fd: int32) -> uint32:
    # Raw fd_idx marker for `fd`, or FD_CLOSED_MARK for a bad/closed fd.
    # Lets the Layer-2 shim recognise its own object fds without
    # importing the per-task fd table.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return FD_CLOSED_MARK
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    return task[0].fd_idx[cast[uint64](fd)]


def vfs_fd_pty_pack(fd: int32) -> int64:
    # #165: if `fd` is an open PTY fd, return its packed (slot << 1) |
    # is_master pack, widened to int64. Returns -1 for any non-PTY /
    # closed fd. The Layer-2 ioctl shim uses this to route TIOCGPTN /
    # TIOCSPTLCK / TCGETS / TCSETS / TIOC{G,S}WINSZ on a pty to the
    # right pair without importing the pair pool.
    # Phase 4e (PTY fold, F7 #390): a PTY fd is now FD_CHAN_MARK over a
    # DEV_PTMX chan; recover the legacy pack via namec_chan_ptmx_pack.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return -1
    pty_cid: int32 = _fd_chan_id(task, fdu)
    return namec_chan_ptmx_pack(pty_cid)


def vfs_fd_pipe_slot(fd: int32) -> int32:
    # splice/tee/vmsplice support: if `fd` is one end of an anonymous
    # pipe (a DEV_PIPE_R / DEV_PIPE_W pool chan), return the backing
    # pipe-table slot riding in the chan's back_slot; otherwise -1. The
    # Layer-2 splice shim uses this both to recognise the pipe side of
    # a splice and to drive a non-consuming tee against the ring
    # directly.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return -1
    return namec_chan_pipe_slot(cast[int32](cast[uint32](task[0].fd_buf[fdu])))


def vfs_fd_is_pipe_read(fd: int32) -> int32:
    # 1 if `fd` is the READ end of an anonymous pipe, else 0.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return 0
    cid: int32 = cast[int32](cast[uint32](task[0].fd_buf[fdu]))
    if namec_chan_dev_type(cid) == DEV_PIPE_R:
        return 1
    return 0


def vfs_fd_is_pipe_write(fd: int32) -> int32:
    # 1 if `fd` is the WRITE end of an anonymous pipe, else 0.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return 0
    cid: int32 = cast[int32](cast[uint32](task[0].fd_buf[fdu]))
    if namec_chan_dev_type(cid) == DEV_PIPE_W:
        return 1
    return 0


def vfs_fd_is_console(fd: int32) -> int32:
    # #164: is `fd` backed by the physical console (keyboard / UART)?
    # The Linux-ABI termios line discipline (linux_abi/u_termios.ad)
    # keys its cooked-vs-raw read path off this: a tty fd gets canonical
    # line editing + echo, a pipe / file / socket fd is left untouched.
    #
    # Three shapes resolve to the console:
    #   * FD_STDIN_MARK — the kernel's own console stdin mark.
    #   * FD_CHAN_MARK whose namec chan is DEV_CONS — a /dev/cons (or
    #     /dev/console) open routed through the namec devtab (native
    #     binaries, /dev/cons opens). This is the inline-chan successor
    #     to the retired FD_CONS_MARK.
    #   * FD_CHAN_MARK / DEV_DEVFD whose /fd/N slot is bound to DEVFD_CONS — the
    #     HAMSH §7 stdio shape every `enter linux { … }` guest inherits
    #     (hamsh binds /fd/0,1,2 → DEVFD_CONS, COW-cloned into the
    #     rfork'd guest's Pgrp).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    m: uint32 = task[0].fd_idx[cast[uint64](fd)]
    if m == FD_STDIN_MARK:
        return 1
    if m == FD_CHAN_MARK:
        ch_id: int32 = _fd_chan_id(task, cast[uint64](fd))
        if namec_chan_dev_type(ch_id) == DEV_CONS:
            return 1
        # Phase 4c: an `#d/<N>` fd (DEV_DEVFD inline chan) whose /fd/N
        # slot is bound to DEVFD_CONS — the HAMSH §7 stdio shape every
        # `enter linux { … }` guest inherits.
        if namec_chan_dev_type(ch_id) == DEV_DEVFD:
            if devfd_slot_kind(pgrp_current(),
                               namec_chan_devfd_num(ch_id)) == DEVFD_CONS:
                return 1
    return 0


def vfs_console_read_nb(buf: Ptr[uint8], count: uint64) -> int64:
    # #164: non-blocking single-shot drain of the console input rings
    # (wsys cmd queue → PS/2 keyboard → UART), shared by the termios
    # cooked-mode line discipline. >0 bytes drained, 0 == would-block.
    # Never yields — the discipline owns the yield loop so it can echo /
    # edit between polls.
    return devcons_read_nb(buf, count)


def vfs_console_write(buf: Ptr[uint8], count: uint64) -> int64:
    # #164: console echo sink for the termios line discipline. Routes to
    # the same devcons_write the DEV_CONS / DEVFD_CONS write paths use
    # so an echoed keystroke lands on the user's screen identically to
    # the guest's own output (foreground-window gated, no kernel "[NNN]"
    # timestamp prefix).
    return devcons_write(buf, count)


def vfs_l2_fd_set_buf(fd: int32, val: uint64) -> int32:
    # Stash the encoded Layer-2 object slot into a Layer-2 fd's fd_buf.
    # Returns 0 on success, -EBADF if `fd` is not one of our markers.
    m: uint32 = vfs_fd_marker(fd)
    if m != FD_EPOLL_MARK and m != FD_EVENTFD_MARK \
            and m != FD_TIMERFD_MARK and m != FD_SIGNALFD_MARK \
            and m != FD_INOTIFY_MARK:
        return EBADF
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    task[0].fd_buf[cast[uint64](fd)] = val
    return 0


def vfs_l2_fd_get_buf(fd: int32) -> uint64:
    # Read back the encoded object slot from a Layer-2 fd's fd_buf.
    # Returns 0 ("no object") for a non-Layer-2 / closed fd.
    m: uint32 = vfs_fd_marker(fd)
    if m != FD_EPOLL_MARK and m != FD_EVENTFD_MARK \
            and m != FD_TIMERFD_MARK and m != FD_SIGNALFD_MARK \
            and m != FD_INOTIFY_MARK:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    return task[0].fd_buf[cast[uint64](fd)]


def vfs_fd_poll(fd: int32) -> uint32:
    # Non-destructive readiness probe for poll(2) / select(2) / epoll(7).
    # Returns a bitmask in the POLLIN(0x1)/POLLOUT(0x4)/POLLERR(0x8)/
    # POLLHUP(0x10) layout (which matches the low EPOLL* bits). NO bytes
    # are consumed — epoll_wait must be able to re-report a readable fd
    # on every wait. The Layer-2 epoll shim translates the result to the
    # caller's requested event mask.
    #
    # readiness model per fd kind:
    #   socket (TCP)   POLLIN if data buffered or peer FIN/closed;
    #                  POLLOUT always (the tx path never blocks here);
    #                  POLLHUP once the connection is CLOSED.
    #   socket (UDP)   POLLIN if a datagram is queued; POLLOUT always.
    #   pipe read end  POLLIN if bytes buffered; POLLHUP if all writers
    #                  gone (epoll treats a hung-up read end as ready).
    #   pipe write end POLLOUT if ring has space; POLLERR if no readers.
    #   socketpair     POLLIN if bytes buffered; POLLOUT always.
    #   eventfd        POLLIN if counter != 0; POLLOUT always.
    #   timerfd        POLLIN if an expiration is pending.
    #   signalfd       handled by the u_syscalls.ad shim (needs the
    #                  caller's pending-signal word) — reported 0 here.
    #   regular file / stdio / cdev — always POLLIN|POLLOUT (a regular
    #                  file is always immediately readable in Hamnix).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0x0020                       # POLLNVAL
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CLOSED_MARK:
        return 0x0020                       # POLLNVAL
    # Phase 4c (socket fold): the FD_SOCKET_MARK poll arm moved into
    # the FD_CHAN_MARK arm below (DEV_SOCKET, decoding the chan's
    # back_slot) — same UDP/TCP readiness bits. Phase 4d (net fold,
    # F7 #390): same shape — the FD_NET_MARK poll arm moved into the
    # FD_CHAN_MARK arm below (DEV_NET, decoding the chan's
    # back_slot pack).
    if fi == FD_CHAN_MARK:
        # Phase 4c: pipe ends are DEV_PIPE_R / DEV_PIPE_W pool chans —
        # render the same poll bits the legacy FD_PIPE_MARK arms did.
        # Every other chan family keeps the regular-file answer
        # (POLLIN|POLLOUT, always ready) it got from the fallthrough.
        p_cid: int32 = cast[int32](cast[uint32](task[0].fd_buf[fdu]))
        p_dev: int32 = namec_chan_dev_type(p_cid)
        if p_dev == DEV_PIPE_R:
            slot: int32 = namec_chan_back_slot(p_cid)
            ev_pr: uint32 = 0
            if pipe_readable(slot) != 0:
                ev_pr = 0x0001
            if pipe_writers(slot) == 0:
                ev_pr = ev_pr | 0x0011      # POLLHUP + POLLIN (EOF readable)
            return ev_pr
        if p_dev == DEV_PIPE_W:
            wslot: int32 = namec_chan_back_slot(p_cid)
            if pipe_readers(wslot) == 0:
                return 0x0008               # POLLERR — no readers
            ev_pw: uint32 = 0
            if pipe_writable(wslot) != 0:
                ev_pw = 0x0004
            return ev_pw
        if p_dev == DEV_SOCKET:
            # Phase 4c (socket fold): the verbatim legacy
            # FD_SOCKET_MARK readiness bits, keyed off the chan's
            # back_slot encoding.
            sk_rec: int32 = usock_record_for_fdbuf(
                cast[uint64](namec_chan_socket_fdbuf(p_cid)))
            if sk_rec < 0:
                return 0x0008               # POLLERR — recordless socket
            if usock_get_type(sk_rec) == USOCK_SOCK_DGRAM:
                ud: int32 = usock_get_tcp_slot(sk_rec)
                ev_u: uint32 = 0x0004       # UDP tx never blocks
                if udp_socket_recv_pending(ud) != 0:
                    ev_u = ev_u | 0x0001
                return ev_u
            if usock_get_state(sk_rec) != USOCK_CONNECTED:
                return 0x0014               # POLLHUP|POLLOUT
            sk_tcp: int32 = usock_get_tcp_slot(sk_rec)
            if sk_tcp < 0:
                return 0x0014
            ev_t: uint32 = 0x0004           # POLLOUT — tx never blocks
            if tcp_recv_pending(sk_tcp) != 0:
                ev_t = ev_t | 0x0001        # POLLIN — data or EOF
            if tcp_slot_at_eof(sk_tcp) != 0:
                ev_t = ev_t | 0x0011        # POLLHUP + POLLIN
            return ev_t
        if p_dev == DEV_SOCKETPAIR:
            # Phase 4c (socket fold): the verbatim legacy
            # FD_SOCKETPAIR_MARK readiness bits.
            sp_pkd:  uint64 = cast[uint64](
                namec_chan_sockpair_packed(p_cid))
            sp_slot: int32 = sockpair_unpack_slot(sp_pkd)
            sp_dir:  int32 = sockpair_unpack_dir(sp_pkd)
            ev_sp: uint32 = 0x0004          # tx side (best effort)
            if sockpair_readable(sp_slot, sp_dir) != 0:
                ev_sp = ev_sp | 0x0001
            if sockpair_peer_alive(sp_slot, sp_dir) == 0:
                ev_sp = ev_sp | 0x0011
            return ev_sp
        if p_dev == DEV_NET:
            # Phase 4d (net fold, F7 #390): the verbatim legacy
            # FD_NET_MARK readiness bits, keyed off the chan's
            # back_slot pack. Only the DATA file polls a connection;
            # every other /net file is a snapshot — always ready.
            net_pkp: uint64 = cast[uint64](namec_chan_net_pack(p_cid))
            if devnet_unpack_file(net_pkp) != NET_FILE_DATA:
                return 0x0005               # POLLIN|POLLOUT
            net_connp: int32 = devnet_unpack_conn(net_pkp)
            ev_np: uint32 = 0x0004          # POLLOUT — tx never blocks
            if devnet_data_pending(net_connp) != 0:
                ev_np = ev_np | 0x0001      # POLLIN — data or EOF
            if devnet_data_at_eof(net_connp) != 0:
                ev_np = ev_np | 0x0011      # POLLHUP + POLLIN
            return ev_np
        if p_dev == DEV_PTMX:
            # QA-N31: a pty end is a DEV_PTMX pool chan. WITHOUT this arm it
            # fell through to the always-ready return below, so a pty MASTER
            # (the terminal emulator's side) reported POLLIN even with an
            # EMPTY output queue — weston-terminal's epoll/poll then issued a
            # blocking read(master) that parked in pty_master_read's yield
            # loop, busy-looping the poll→read→block cycle. Report POLLIN
            # only when the end's source queue actually has bytes; the pty is
            # always writable (the peer queue drops on overflow, never
            # blocks). Decode the (slot<<1|is_master) pack from the chan.
            pk64: int64 = namec_chan_ptmx_pack(p_cid)
            ev_pt: uint32 = 0x0004          # POLLOUT — a pty write never blocks
            if pk64 >= 0:
                if vfs_ptmx_readable(cast[uint64](pk64)) != 0:
                    ev_pt = ev_pt | 0x0001  # POLLIN — data queued for this end
            return ev_pt
        return 0x0005                       # other chans: POLLIN|POLLOUT
    # F4 #449: poll-readable dispatch through registered hooks. A null
    # hook means the Layer-2 shim is not bound; an unlinked Layer-2 fd
    # cannot exist in that build, but we guard defensively.
    if fi == FD_EVENTFD_MARK:
        es: int32 = cast[int32](task[0].fd_buf[fdu]) - 1
        ev_e: uint32 = 0x0004               # an eventfd is always writable
        if uefd_readable_hook != cast[Fn[int32, int32]](0):
            if uefd_readable_hook(es) != 0:
                ev_e = ev_e | 0x0001
        return ev_e
    if fi == FD_TIMERFD_MARK:
        ts: int32 = cast[int32](task[0].fd_buf[fdu]) - 1
        if utfd_readable_hook != cast[Fn[int32, int32]](0):
            if utfd_readable_hook(ts) != 0:
                return 0x0001
        return 0
    if fi == FD_SIGNALFD_MARK:
        # Needs the caller's sig_pending word — the u_syscalls.ad shim
        # answers this one. From vfs's view: not readable.
        return 0
    if fi == FD_INOTIFY_MARK:
        # #155: an inotify fd is POLLIN-readable when events are queued.
        ino_p: int32 = cast[int32](task[0].fd_buf[fdu]) - 1
        if uino_readable_hook != cast[Fn[int32, int32]](0):
            if uino_readable_hook(ino_p) != 0:
                return 0x0001
        return 0
    if fi == FD_EPOLL_MARK:
        # An epoll fd is itself pollable (readable when any watched fd
        # is ready) — the shim handles nested epoll; vfs reports 0.
        return 0
    # Regular file, stdio, cdev, dir — always ready for both.
    return 0x0005                           # POLLIN | POLLOUT


# --- SYS_WAITFDS: native multi-fd readiness wait ---------------------
#
# vfs_waitfds(fds, nfds, timeout_ms) parks the caller until ANY of the
# named fds would return data from a read, then returns the INDEX of
# the first ready fd. -1 on timeout, -EINTR(-4) on signal wake.
#
# DESIGN — single shared queue, not per-fd registration. A task's
# wait_next is a single link, so a task can sit on exactly ONE
# WaitQueue at a time (Linux solves this with per-poll wait_queue_entry
# allocations; we have no heap). Instead every readiness PRODUCER that
# is part of the wait mesh calls kernel/sched/core.ad's
# waitfds_notify() (console input incl. UART IRQ + PS/2 kbd + wsys cmd
# inject + 100Hz tick, pipe_write, pipe writer-close EOF, devwsys
# pointer/keys writes), and the sleeper re-SCANS its whole fd set on
# every wake. nfds is tiny (<= NR_FDS = 64) so a re-scan is cheap.
#
# Probe classes (per fd, non-destructive, consumes nothing):
#   1  ready now
#   0  not ready; producer is wired to waitfds_notify(), a real
#      data-edge wake will arrive
#   2  not ready; producer NOT wired (e.g. PS/2 mouse IRQ ring, net
#      sockets) — the sleep slice is capped at 1 jiffy so the fd is
#      re-probed at tick granularity. Still a real HLT-parked sleep
#      (STATE_WAIT off the runqueue), never a busy spin.

def vfs_waitfds_probe(fd: int32) -> int32:
    # Classify one fd for vfs_waitfds. See class table above.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 1            # bad fd: "ready" — the error surfaces on read
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CLOSED_MARK:
        return 1
    if fi == FD_STDIN_MARK:
        # Legacy console stdin (same byte sources as /dev/cons).
        if devcons_poll_readable() != 0:
            return 1
        return 0                            # console_input_wake notifies
    if fi == FD_CHAN_MARK:
        return namec_poll_readable(_fd_chan_id(task, fdu))
    # Everything else: fall back on the non-destructive poll bitmap.
    # POLLIN/POLLERR/POLLHUP/POLLNVAL all mean "a read won't block".
    bits: uint32 = vfs_fd_poll(fd)
    if (bits & 0x0039) != 0:                # POLLIN|POLLERR|POLLHUP|POLLNVAL
        return 1
    return 2                                # no wake wiring: jiffy re-probe


def vfs_waitfds(fds: Ptr[int32], nfds: uint64, timeout_ms: int64) -> int64:
    # Block until one of fds[0..nfds) is read-ready. Returns the lowest
    # ready index, -1 on timeout, -4 (-EINTR) on signal wake. A
    # timeout_ms <= 0 means "poll once, never sleep".
    if nfds == 0:
        return -1
    if nfds > cast[uint64](_VFS_NR_FDS):
        nfds = cast[uint64](_VFS_NR_FDS)
    # Deadline in jiffies, rounding the ms budget UP so a 5ms request
    # still sleeps at least one 10ms tick rather than zero.
    now: uint64 = get_jiffies()
    deadline: uint64 = now
    if timeout_ms > 0:
        deadline = now + cast[uint64]((timeout_ms + 9) / 10)
    while True:
        # Scan phase: first ready fd wins.
        any_fallback: int32 = 0
        i: uint64 = 0
        while i < nfds:
            cls: int32 = vfs_waitfds_probe(fds[i])
            if cls == 1:
                return cast[int64](i)
            if cls == 2:
                any_fallback = 1
            i = i + 1
        now = get_jiffies()
        if now >= deadline:
            return -1
        # Sleep phase: two-phase prepare/recheck/commit on the shared
        # waitfds queue so a producer's wake between scan and sleep is
        # never lost.
        slice_j: uint64 = deadline - now
        if any_fallback != 0 and slice_j > 1:
            slice_j = 1                     # jiffy-granular re-probe
        wq_wait_prepare(waitfds_wq_ptr())
        # Recheck under registration: a wake that fired after the scan
        # above would otherwise be missed for the whole slice.
        i = 0
        while i < nfds:
            if vfs_waitfds_probe(fds[i]) == 1:
                wq_wait_cancel(waitfds_wq_ptr())
                return cast[int64](i)
            i = i + 1
        wrc: int32 = wq_wait_commit_timeout(waitfds_wq_ptr(), slice_j)
        if wrc == WQ_EINTR:
            return -4                       # -EINTR
        # WQ_TIMEOUT or data wake: loop re-scans and re-checks deadline.


def _vfs_dir_path_inode(task: Ptr[TaskStruct], fdu: uint64) -> uint64:
    # Stable st_ino for a directory fd, derived from its recorded open-path
    # (fd_opened_path, stamped by vfs_open). FNV-1a over the path bytes so
    # distinct directories get distinct inodes that DON'T move when the
    # backing chan id / snapshot buffer is recycled. The 0x44.. tag keeps
    # the value out of every other inode space (cpio index, ext4 0x41,
    # tmpfs 0x42, pipe/socket 0x43). Root "/" is forced to the conventional
    # inode 2 so it has ONE canonical id and the hash can never alias it
    # (every non-root dir is tagged 0x44.. >> 2, so no collision is
    # possible either way).
    p: Ptr[uint8] = task_fd_opened_path_ptr(task, fdu)
    if p[0] == 0:
        # No recorded path (shouldn't happen for a vfs_open'd dir) — fall
        # back to a tagged constant so it at least stays out of ino 2.
        return cast[uint64](0x4400000000000001)
    # "/" (root) -> conventional inode 2.
    if p[0] == 47 and p[1] == 0:
        return cast[uint64](2)
    h: uint64 = 0xCBF29CE484222325            # FNV-1a 64-bit offset basis
    i: uint64 = 0
    while p[i] != 0:
        h = h ^ cast[uint64](p[i])
        h = h * 0x100000001B3                 # FNV-1a 64-bit prime
        i = i + 1
    # Tag 0x44 in the top byte; keep 56 bits of hash. Force the low bits
    # away from 0/2 by OR-ing a 1 so it never reads as root/empty.
    return cast[uint64](0x4400000000000000) \
           | ((h & cast[uint64](0x00FFFFFFFFFFFFFF)) | cast[uint64](1))


def vfs_fd_inode(fd: int32) -> uint64:
    # §4: a STABLE, per-FILE-unique inode number for fstat(2).
    #
    # glibc's ld.so identifies an already-loaded shared object by the
    # (st_dev, st_ino) pair fstat returns: _dl_map_object_from_fd
    # fstats the just-opened DSO and, on a (dev,ino) match against an
    # already-mapped object, SKIPS the mmap and reuses the existing
    # link_map. The earlier fstat path keyed st_ino off the FD NUMBER
    # — but fd numbers are recycled across open/close, so a dlopen()ed
    # DSO that happened to land on the same fd slot a previously-
    # mapped DSO (e.g. libc.so.6) had used would collide: ld.so would
    # think the new DSO "is" libc, hand back libc's handle, and never
    # map the new object. dlsym() then failed with libc's name.
    #
    # The fix: derive the inode from the BACKING FILE's identity.
    #   * Regular initramfs file: fd_idx holds the cpio archive index
    #     — a stable per-file id. inode = index + 1 (so index 0 is a
    #     non-zero inode).
    #   * tmpfs / ext4 / FAT / dir-snapshot / pipe / socket / cdev:
    #     fd_idx is a high-bit marker and fd_buf holds the backing
    #     slot / buffer pointer. inode = marker-tagged fd_buf so two
    #     different tmpfs files differ, while staying disjoint from
    #     the initramfs index space (the marker high bits guarantee
    #     no overlap with a plain cpio index).
    # Either way: same file -> same inode, different file -> different
    # inode. That is the whole contract ld.so depends on.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CLOSED_MARK:
        return 0
    # 0xFE000000 is the marker floor: every special fd_idx marker
    # (cdev / pipe / socket / chan / ...) sits at or above it, while a
    # real initramfs cpio archive index is always far below. (The old
    # FD_PROC_MARK_BASE encoded markers that defined this boundary are
    # gone — Phase 4b — but the boundary stays valid and conservative.)
    # Literal here rather than an import to keep vfs.ad's already-large
    # import list stable.
    if cast[uint64](fi) < cast[uint64](0xFE000000):
        return cast[uint64](fi) + 1
    # fd→Chan fold: ext4 / tmpfs file fds are FD_CHAN_MARK fds whose
    # fd_buf holds the CHAN ID — a pool slot that is RECYCLED on close.
    # Keying st_ino off it broke ld.so on the ext4-backed Debian root
    # (#410): libmd.so.0 was opened/mmapped/closed, then libselinux.so.1
    # reused the same chan id, fstat returned the SAME (dev,ino), and
    # _dl_map_object_from_fd aliased libselinux to the already-loaded
    # libmd ("version 'LIBSELINUX_1.0' not found ... libmd.so.0").
    # Resolve the STABLE backing identity instead — the same one
    # vfs_fd_backing_info hands to file-backed mmap:
    #   * ext4  → the on-disk inum (distinct tag 0x41..).
    #   * tmpfs → the tmpfs slot, stable for the file's lifetime
    #     (distinct tag 0x42..).
    if fi == FD_CHAN_MARK:
        chdt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
        if chdt == DEV_EXT4_FILE:
            eslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            return cast[uint64](0x4100000000000000) \
                   | cast[uint64](ext4_open_inum(eslot))
        if chdt == DEV_TMPFS_FILE:
            tslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            return cast[uint64](0x4200000000000000) \
                   | cast[uint64](cast[uint32](tslot))
        if chdt == DEV_PIPE_R or chdt == DEV_PIPE_W \
                or chdt == DEV_SOCKET or chdt == DEV_SOCKETPAIR:
            # Phase 4c: a pipe end's stable identity is its RING slot,
            # not the recycled chan id — both ends of one pipe share the
            # slot, dev_type keeps R and W inodes distinct (tag 0x43..).
            # Socket fold: same scheme for sockets (back_slot = record
            # encoding, stable for the socket's lifetime) and sockpair
            # endpoints (back_slot = packed slot|dir — the two ends get
            # DISTINCT inodes, matching Linux where each end of
            # socketpair(2) is its own inode).
            pslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            return cast[uint64](0x4300000000000000) \
                   | (cast[uint64](cast[uint32](chdt)) << 32) \
                   | cast[uint64](cast[uint32](pslot))
        if chdt == DEV_DIR_FILE:
            # A directory fd (tmpfs / cpio / ext4 / FAT dir snapshot) is a
            # DEV_DIR_FILE chan whose back_slot holds the rendered snapshot
            # LENGTH and whose back_ptr is a freshly-kmalloc'd buffer — so
            # NEITHER is a stable per-DIRECTORY identity, and the recycled
            # chan id (fd_buf) is identical across sequential open/stat/close
            # of different dirs. That made lstat("/") and lstat("/var/lib/
            # dpkg/tmp.ci") return the SAME (st_dev, st_ino) — GNU rm then
            # refused "dangerous to operate recursively ... (same as '/')".
            # Derive the inode from a stable FNV-1a hash of the directory's
            # RECORDED OPEN-PATH (vfs_open stamps fd_opened_path), tagged
            # 0x44.. and never zero/2 (root keeps a fixed non-colliding id).
            return _vfs_dir_path_inode(task, fdu)
    # Other special-backed fd kinds: combine the marker with fd_buf
    # (backing slot or buffer address) so distinct files get distinct
    # inodes. The 0x4000_0000_0000_0000 bit keeps the whole value out
    # of the initramfs index range.
    return cast[uint64](0x4000000000000000) \
           | (cast[uint64](fi) << 32) \
           | (task[0].fd_buf[fdu] & cast[uint64](0xFFFFFFFF))


# ---------------------------------------------------------------------
# §file-mmap — kernel-side, identity-based file reads for file-backed
# mmap. A file-backed VMA must keep serving page faults even after the
# user closes the fd it was created from (POSIX), so we cannot key reads
# off the live per-task fd table. Instead, at mmap time we snapshot the
# file's STABLE backing identity (marker + backing slot/pointer + total
# size) into the VMA, and the #PF handler reads page bytes through
# vfs_pread_backing() — which dispatches on that snapshot, not on an fd.
#
# Supported backing kinds: initramfs (read-only cpio), tmpfs, ext4
# (read-only), and FD_BUFFER (the kmalloc'd snapshot buffer /proc files
# use). Other kinds (pipes, sockets, char devices, /net, ...) are not
# seekable random-access files and are rejected at mmap time.
# ---------------------------------------------------------------------

# A synthetic marker meaning "the backing is a plain initramfs cpio
# index" (the real initramfs index is stored in `backing`). Distinct
# from any FD_*_MARK so vfs_pread_backing can dispatch on it.
# 0xFFFFFFD2 is a free slot between FD_VT1_MARK (0xCF) and
# FD_INOTIFY_MARK (0xD3); it previously aliased FD_VT1_MARK at 0xCF.
FD_FILEMMAP_INITRAMFS: uint32 = 0xFFFFFFD2


def vfs_fd_backing_info(fd: int32, out_marker: Ptr[uint32],
                        out_backing: Ptr[uint64],
                        out_size: Ptr[uint64]) -> int32:
    # Snapshot the STABLE backing identity of `fd` for file-backed mmap.
    # On success returns 0 and fills *out_marker / *out_backing /
    # *out_size with values that vfs_pread_backing() can later read
    # through (independent of the fd staying open). Returns a negative
    # errno if the fd is closed, bad, or not a seekable file kind.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CLOSED_MARK:
        return cast[int32](EBADF)
    # A plain initramfs file: fd_idx IS the cpio index (< FE000000).
    if cast[uint64](fi) < cast[uint64](0xFE000000):
        out_marker[0]  = FD_FILEMMAP_INITRAMFS
        out_backing[0] = cast[uint64](fi)
        out_size[0]    = initramfs_entry_size(cast[uint64](fi))
        return 0
    # fd→Chan fold: ext4 and tmpfs file fds are now FD_CHAN_MARK fds
    # backed by a DEV_EXT4_FILE / DEV_TMPFS_FILE pool chan. file-backed
    # mmap resolves a STABLE backing identity so the #PF / writeback path
    # keeps working after the fd closes:
    #   * ext4 → the STABLE inum (not the recyclable slot); backing marker
    #     FD_EXT4_MARK so vfs_pread/pwrite_backing do an inum-addressed I/O.
    #   * tmpfs → the tmpfs slot IS the backing handle (no inum equivalent;
    #     this matches the legacy FD_TMPFS_MARK behaviour, which mmap'd the
    #     slot directly); backing marker FD_TMPFS_MARK.
    # FAT files are not mmap-backed, so there is no DEV_FAT_FILE arm here.
    if fi == FD_CHAN_MARK:
        chdt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
        if chdt == DEV_EXT4_FILE:
            slot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            inum: uint32 = ext4_open_inum(slot)
            out_marker[0]  = FD_EXT4_MARK
            out_backing[0] = cast[uint64](inum)
            out_size[0]    = ext4_open_size(slot)
            return 0
        if chdt == DEV_TMPFS_FILE:
            tslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            out_marker[0]  = FD_TMPFS_MARK
            out_backing[0] = cast[uint64](cast[uint32](tslot))
            out_size[0]    = tmpfs_size(tslot)
            return 0
        # Phase 4b: a rendered-snapshot fd (ex-FD_BUFFER_MARK) is now a
        # DEV_BUF_FILE pool chan whose kmalloc'd buffer lives in back_ptr.
        # FD_BUFFER_MARK survives ONLY as the opaque backing TAG the
        # fd-less mmap path (vfs_pread/pwrite_backing) dispatches on.
        # NOTE: the buffer is kfree'd when the LAST chan ref closes, so a
        # long-lived mapping over a closed snapshot fd would dangle — same
        # lifetime contract the legacy FD_BUFFER_MARK arm had.
        if chdt == DEV_BUF_FILE:
            out_marker[0]  = FD_BUFFER_MARK
            out_backing[0] = namec_chan_back_ptr(_fd_chan_id(task, fdu))
            out_size[0]    = task[0].fd_buflen[fdu]
            return 0
        return cast[int32](ENODEV)
    # Not a seekable, random-access file backing kind.
    return cast[int32](ENODEV)


# Stable backing-FS kind of an open fd, for fstatfs(2). Returns:
#   0 = ext4, 1 = tmpfs, 2 = FAT, 3 = ramfs/cpio (default).
# fd→Chan fold: ext4/FAT/tmpfs file fds are now FD_CHAN_MARK fds whose
# backing kind lives in the pool chan's dev_type (DEV_EXT4_FILE /
# DEV_FAT_FILE / DEV_TMPFS_FILE), NOT in fd_idx. The Layer-2 statfs shim
# can't read dev_type without importing namec, so it asks here. tmpfs
# reports as ramfs (kind 1) — the legacy FD_TMPFS_MARK path returned 1.
def vfs_fd_statfs_kind(fd: int32) -> int32:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 3
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CHAN_MARK:
        dt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
        if dt == DEV_EXT4_FILE:
            return 0
        if dt == DEV_TMPFS_FILE:
            return 1
        if dt == DEV_FAT_FILE:
            return 2
        return 3
    return 3


def vfs_resolve_backing(name: Ptr[char], out_marker: Ptr[uint32],
                        out_backing: Ptr[uint64],
                        out_size: Ptr[uint64]) -> int32:
    # FD-LESS sibling of vfs_fd_backing_info: resolve `name` straight to
    # a stable (marker, backing, size) triple WITHOUT allocating an fd.
    #
    # WHY THIS EXISTS: the kernel boot/idle task has no usable fd table
    # (the same reason _ns_ext4_slurp_by_id reads ext4 fd-lessly at
    # boot:36). A loop_attach() issued from a boot self-test or from the
    # /dev/loop/ctl handler therefore can't go through vfs_open() — it
    # would fail with -EMFILE before ever touching the backing store.
    # This resolver mirrors the on-disk routing order of vfs_open but
    # produces only the backing snapshot the loop driver needs, so the
    # data path (vfs_pread_backing / vfs_pwrite_backing) is identical to
    # the fd-based one. Returns 0 on success, a negative errno on miss.
    #
    # ext4 — resolve the inode fd-lessly (inum is stable across recycle).
    if vfs_fs_kind(name) == FS_KIND_EXT4:
        leaf: Ptr[char] = vfs_fs_rel(name)
        einum: uint32 = 0
        esize: uint64 = 0
        if ext4_resolve_file(leaf, &einum, &esize) == 0:
            return ENOENT
        out_marker[0]  = FD_EXT4_MARK
        out_backing[0] = cast[uint64](einum)
        out_size[0]    = esize
        return 0
    # tmpfs — a path that tmpfs owns and actually has (covers /tmp + /var).
    if vfs_fs_kind(name) == FS_KIND_TMPFS:
        if tmpfs_path_exists(name) != 0:
            tslot: int32 = tmpfs_lookup(name)
            if tslot >= 0:
                out_marker[0]  = FD_TMPFS_MARK
                out_backing[0] = cast[uint64](cast[uint32](tslot))
                out_size[0]    = tmpfs_size(tslot)
                return 0
    # cpio (initramfs) — the index IS the backing id; read-only.
    cidx: int32 = _lookup_name(name)
    if cidx >= 0:
        out_marker[0]  = FD_FILEMMAP_INITRAMFS
        out_backing[0] = cast[uint64](cidx)
        out_size[0]    = initramfs_entry_size(cast[uint64](cidx))
        return 0
    return ENOENT


def vfs_pread_backing(marker: uint32, backing: uint64, file_size: uint64,
                      offset: uint64, dst: Ptr[uint8],
                      count: uint64) -> int64:
    # Read up to `count` bytes at file offset `offset` from the backing
    # identified by (marker, backing). Returns bytes read (0 at/after
    # EOF). Independent of the per-task fd table — safe to call from the
    # #PF handler for a file-backed VMA whose fd may have been closed.
    if offset >= file_size:
        return 0
    remaining: uint64 = file_size - offset
    take: uint64 = count
    if take > remaining:
        take = remaining
    if take == 0:
        return 0
    if marker == FD_FILEMMAP_INITRAMFS:
        src: Ptr[uint8] = initramfs_entry_data(backing)
        _ua_stac()
        memcpy(dst, cast[Ptr[uint8]](cast[uint64](src) + offset), take)
        _ua_clac()
        return cast[int64](take)
    if marker == FD_TMPFS_MARK:
        n: uint64 = tmpfs_read(cast[int32](backing), dst, offset, take)
        return cast[int64](n)
    if marker == FD_EXT4_MARK:
        return ext4_read_file(cast[uint32](backing), offset, take, dst)
    if marker == FD_BUFFER_MARK:
        _ua_stac()
        memcpy(dst, cast[Ptr[uint8]](backing + offset), take)
        _ua_clac()
        return cast[int64](take)
    return cast[int64](-22)               # -EINVAL: unknown backing


def vfs_pwrite_backing(marker: uint32, backing: uint64,
                       offset: uint64, src: Ptr[uint8],
                       count: uint64) -> int64:
    # §shared-mmap: WRITE-BACK counterpart of vfs_pread_backing. Writes
    # `count` bytes from `src` to the backing object identified by
    # (marker, backing) at file `offset`. Used to flush dirty pages of a
    # MAP_SHARED writable file-backed mapping on msync(MS_SYNC) / munmap.
    # Independent of the per-task fd table — safe to call from the VMA
    # teardown / writeback path after the mmap fd was closed.
    #
    # initramfs (cpio) is READ-ONLY backing store — reject with -EROFS so
    # a MAP_SHARED-writable mapping over a cpio file never silently drops
    # or corrupts. tmpfs and ext4 are writable and route to their write
    # paths. FD_BUFFER_MARK (an in-memory kernel buffer) is writable too.
    if count == 0:
        return 0
    if marker == FD_FILEMMAP_INITRAMFS:
        return cast[int64](-30)           # -EROFS: cpio is read-only
    if marker == FD_TMPFS_MARK:
        n: uint64 = tmpfs_write(cast[int32](backing), src, offset, count)
        return cast[int64](n)
    if marker == FD_EXT4_MARK:
        return ext4_pwrite_inode(cast[uint32](backing), src, offset, count)
    if marker == FD_BUFFER_MARK:
        memcpy(cast[Ptr[uint8]](backing + offset), src, count)
        return cast[int64](count)
    return cast[int64](-22)               # -EINVAL: unknown backing


def vfs_backing_page_phys(marker: uint32, backing: uint64,
                          offset: uint64) -> uint64:
    # §shared-mmap coherence: return the PAGE-ALIGNED physical address of
    # the page holding byte `offset` of the backing object, IF that object
    # stores its data in directly-mappable page-aligned RAM. Only tmpfs
    # qualifies today (its data chunks are buddy-allocated page-aligned),
    # so a MAP_SHARED writable mmap of a tmpfs file can map the file's OWN
    # storage pages — a store through the mapping is then immediately
    # visible to tmpfs_read()/tmpfs_write() (and every other mapper), which
    # is exactly the coherence apt's pkgcache write-then-read demands.
    #
    # Returns the physical page (page-aligned, non-zero) on success, or 0
    # when the backing is NOT directly mappable (ext4 / cpio / kernel
    # buffer) — the caller then falls back to the copy-based shared page
    # cache. ext4/cpio cannot be mapped directly: ext4 data lives in the
    # block/buffer cache (not a stable per-file page array) and cpio is
    # read-only; both keep the copy path.
    if marker == FD_TMPFS_MARK:
        return tmpfs_page_phys(cast[int32](backing), offset)
    return 0


def vfs_backing_extend_size(marker: uint32, backing: uint64,
                            new_size: uint64):
    # §shared-mmap coherence: extend a tmpfs backing's recorded size to
    # `new_size` (never shrinks). Called from the writable shared-mmap
    # fault path so bytes stored THROUGH the mapping are visible to a
    # later tmpfs_read() of the file. A no-op for non-tmpfs backings.
    if marker == FD_TMPFS_MARK:
        tmpfs_extend_size(cast[int32](backing), new_size)


def _open_tmpfs_read(name: Ptr[char]) -> int32:
    # V1: tmpfs is a tree. A path resolving to a directory ("/tmp" or
    # a mkdir'd subdir) opens as a FD_DIR_MARK fd whose buffer is a
    # "NAME\n" snapshot of its children — same shape as the cpio /
    # FAT / ext4 directory-open path, so getdents64() / chdir's
    # is-a-dir probe / `ls` all work through it. A path resolving to
    # a file opens as the existing FD_TMPFS_MARK read fd.
    #
    # §links: if `name` resolves to a tmpfs SYMLINK, follow it
    # transparently — substitute the stored target. Tmpfs->tmpfs hops
    # are chased iteratively here (capped at 8, mirroring the cpio
    # _lookup_name 8-hop cap, so a cyclic chain fails cleanly instead of
    # spinning). The moment a target leaves tmpfs (points at an ext4 /
    # cpio / device path) we hand off to vfs_open, which routes it to the
    # right backend (and follows that backend's own symlinks).
    cur: Ptr[char] = name
    sym_hops: int32 = 0
    while tmpfs_path_is_symlink(cur) != 0:
        if sym_hops >= 8:
            return ENOENT
        sslot: int32 = tmpfs_lookup(cur)
        tgt: Ptr[uint8] = tmpfs_readlink(sslot)
        if cast[uint64](tgt) == 0:
            return ENOENT
        tgt_c: Ptr[char] = cast[Ptr[char]](tgt)
        if vfs_fs_kind(tgt_c) != FS_KIND_TMPFS:
            # Target lives on another backend — re-dispatch.
            return vfs_open(tgt_c)
        cur = tgt_c
        sym_hops = sym_hops + 1
    if tmpfs_path_is_dir(cur) != 0:
        task: Ptr[TaskStruct] = fd_owner_task(current_task())
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            return EMFILE
        buf: uint64 = kmalloc(DIR_BUF_SIZE)
        if buf == 0:
            task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
            return cast[int32](-12)                   # -ENOMEM
        n: int64 = tmpfs_listdir(cur, cast[Ptr[uint8]](buf),
                                 DIR_BUF_SIZE)
        if n < 0:
            task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
            kfree(buf)
            return ENOENT
        return _install_dir_fd(fd, buf, n)
    slot: int32 = tmpfs_lookup(cur)
    if slot < 0:
        return ENOENT
    # fd→Chan fold: a tmpfs file read fd is now a unified FD_CHAN_MARK fd
    # backed by a DEV_TMPFS_FILE pool chan (namec_open_tmpfs_file). The
    # tmpfs entry slot rides in the chan's back_slot; read/write/lseek/
    # close all dispatch through namec_read/write/close on dev_type. A
    # named /tmp,/var slot persists by path — namec_close frees no slot
    # (only anon memfd slots are reclaimed there).
    cid: int32 = namec_open_tmpfs_file(slot)
    if cid < 0:
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_CHAN_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def vfs_open_memfd(name: Ptr[char], allow_sealing: int32) -> int32:
    # §memfd: memfd_create(2)'s fd-allocation half. Creates a fresh
    # anonymous tmpfs file (via tmpfs_create_anon) and binds it to a new
    # fd using the EXISTING FD_TMPFS_MARK machinery — read/write/lseek/
    # ftruncate all reuse the named-tmpfs data path, keyed on the slot in
    # fd_buf. Returns the fd, or a negative errno (-ENOSPC if tmpfs is out
    # of slots, -EMFILE if the fd table is full).
    slot: int32 = tmpfs_create_anon(name, allow_sealing)
    if slot < 0:
        return slot                                   # -ENOSPC from tmpfs
    # fd→Chan fold: a memfd shares the DEV_TMPFS_FILE pool-chan path with
    # named tmpfs files (the tmpfs slot is mode-/origin-agnostic). The
    # seal state (F_SEAL_*) lives on the slot; vfs_fd_tmpfs_slot recovers
    # it through the chan's back_slot. namec_close sees tmpfs_is_anon!=0
    # on last ref and reclaims the anon slot — so a dup'd / forked memfd
    # is refcounted correctly and only the final close frees it.
    cid: int32 = namec_open_tmpfs_file(slot)
    if cid < 0:
        tmpfs_release_anon(slot)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_CHAN_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def vfs_install_tmpfs_slot_fd(slot: int32) -> int32:
    # §SCM_RIGHTS receive: bind a NEW fd in the CURRENT task's fd table to
    # an already-resolved tmpfs/memfd slot — the backing object a peer
    # passed over an AF_UNIX socket. Both ends then reach the SAME physical
    # pages (tmpfs MAP_SHARED page coherence), which is exactly what a
    # Wayland wl_shm pool fd needs. A fresh DEV_TMPFS_FILE chan is opened on
    # the slot (independent of the sender's chan); its last close routes
    # through namec_close's DEV_TMPFS_FILE arm → tmpfs_release_anon, which
    # drops the extra anon reference the sender's sendmsg took via
    # tmpfs_anon_ref. Returns the new fd, or a negative errno.
    if slot < 0:
        return EINVAL
    cid: int32 = namec_open_tmpfs_file(slot)
    if cid < 0:
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def vfs_fd_tmpfs_slot(fd: int32) -> int32:
    # §memfd: return the tmpfs slot index backing a tmpfs/memfd fd, or
    # -1 if `fd` is not one. The fcntl(F_ADD_SEALS / F_GET_SEALS) shim
    # uses this to reach the slot's seal state.
    #
    # fd→Chan fold: a tmpfs fd is now an FD_CHAN_MARK fd whose chan is a
    # DEV_TMPFS_FILE pool chan. The slot no longer lives in fd_buf (that
    # holds the opaque chan id) — recover it through the chan: confirm
    # the fd is FD_CHAN_MARK AND its dev_type is DEV_TMPFS_FILE, then
    # return namec_chan_back_slot(cid), which IS the tmpfs entry slot the
    # seal state hangs off. Getting this wrong silently breaks F_SEAL_*.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return -1
    cid: int32 = _fd_chan_id(task, fdu)
    if namec_chan_dev_type(cid) != DEV_TMPFS_FILE:
        return -1
    return namec_chan_back_slot(cid)


def _open_auth_marked() -> int32:
    # docs/security.md Phase 4 / namespace-purity Phase 4b: allocate a
    # per-fd /dev/auth slot from the devauth pool, wrap it in a DEV_AUTH
    # pool chan, and install an FD_CHAN_MARK fd carrying the chan id.
    # devauth_alloc returns < 0 if the pool is exhausted (8 concurrent
    # /dev/auth opens — far more than any realistic newshell
    # concurrency), in which case we surface -EMFILE. The chan refcount
    # makes fork/dup share ONE AuthSlot and frees it exactly once on the
    # last close — including the exit path through close_fd_in_task,
    # which the legacy FD_AUTH_MARK arm never reached (slot leak).
    slot: int32 = devauth_alloc()
    if slot < 0:
        set_current_errstr("auth: too many open /dev/auth fds")
        return EMFILE
    cid: int32 = namec_open_auth_file(slot)
    if cid < 0:
        devauth_close(slot)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _open_fuse_conn_marked() -> int32:
    # §fuse: allocate a /dev/fuse connection slot and install an
    # FD_CHAN_MARK fd over a DEV_FUSE_CONN pool chan whose back_slot
    # carries the slot index. The daemon read()s queued fuse_in requests
    # and write()s fuse_out replies on this fd, dispatched through the
    # FD_CHAN_MARK arm at the head of vfs_read / vfs_write into namec's
    # DEV_FUSE_CONN arms (which call vfs_fuse_conn_chan_*). Phase 4f
    # (FUSE fold, F7 #390): replaces the legacy FD_FUSE_CONN_MARK fd —
    # release now routes through namec_close, so a task that exits
    # holding the fd no longer leaks the conn slot (the legacy mark
    # only ran from vfs_close).
    if fuse_dev_open_hook == cast[Fn[int32]](0) \
            or fuse_dev_close_hook == cast[Fn[None, int32]](0):
        set_current_errstr("fuse: no FUSE layer bound")
        return cast[int32](-38)
    slot: int32 = fuse_dev_open_hook()
    if slot < 0:
        set_current_errstr("fuse: too many open /dev/fuse fds")
        return EMFILE
    cid: int32 = namec_open_fuse_conn(slot)
    if cid < 0:
        fuse_dev_close_hook(slot)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _open_fuse_file_marked(name: Ptr[char]) -> int32:
    # §fuse: open a path under a FUSE mount. fuse_vfs_open drives the
    # genuine LOOKUP+GETATTR+OPEN op sequence over the wire and returns
    # an open-file token; we install an FD_CHAN_MARK fd over a
    # DEV_FUSE_FILE pool chan whose back_slot carries the token.
    # vfs_read → namec_read → vfs_fuse_file_chan_read drives FUSE_READ;
    # close → namec_close → vfs_fuse_file_chan_release drives
    # FUSE_RELEASE on the LAST chan reference. Phase 4f (FUSE fold,
    # F7 #390): replaces the legacy FD_FUSE_FILE_MARK fd.
    if fuse_vfs_open_hook == cast[Fn[int64, Ptr[char]]](0) \
            or fuse_vfs_close_hook == cast[Fn[None, int32]](0):
        set_current_errstr("fuse: no FUSE layer bound")
        return cast[int32](-38)
    tok: int64 = fuse_vfs_open_hook(name)
    if tok < 0:
        set_current_errstr("fuse: lookup/open failed")
        return ENOENT
    cid: int32 = namec_open_fuse_file(cast[int32](tok))
    if cid < 0:
        fuse_vfs_close_hook(cast[int32](tok))
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def vfs_fd_fuse_slot(fd: int32) -> int32:
    # §fuse: map a userland fd to its FUSE connection slot index, or -1
    # if the fd is not an open /dev/fuse connection fd. mount(2) "fuse"
    # uses this to recover the connection slot named by the `fd=N` mount
    # option. Phase 4f: a /dev/fuse fd is an FD_CHAN_MARK fd whose
    # DEV_FUSE_CONN chan carries the conn slot in back_slot.
    if fd < 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if fdu >= cast[uint64](_VFS_NR_FDS):
        return -1
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return -1
    fc_cid: int32 = cast[int32](task[0].fd_buf[fdu])
    if namec_chan_dev_type(fc_cid) != DEV_FUSE_CONN:
        return -1
    return namec_chan_fuse_conn_slot(fc_cid)


def vfs_fd_auth_slot(fd: int32) -> int32:
    # docs/security.md Phase 4: map a userland fd to its /dev/auth slot
    # index, or -1 if the fd is not an open /dev/auth fd. The SYS_SETUID_AUTH
    # arm (arch/x86/kernel/syscall.ad) uses this to recover the slot whose
    # verified-uid it flips identity to — the Plan-9 "prove the password,
    # the kernel changes you" idiom, mediated through the same fd the
    # caller authenticated on. Phase 4b: an auth fd is an FD_CHAN_MARK fd
    # whose DEV_AUTH chan carries the AuthSlot index in back_slot.
    if fd < 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if fdu >= cast[uint64](_VFS_NR_FDS):
        return -1
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return -1
    au_cid: int32 = cast[int32](task[0].fd_buf[fdu])
    if namec_chan_dev_type(au_cid) != DEV_AUTH:
        return -1
    return namec_chan_back_slot(au_cid)


# --- #165: PTY open helpers ----------------------------------------
#
# fd_buf packs (slot << 1) | is_master so one FD_PTMX_MARK serves both
# the master (/dev/ptmx) and slave (/dev/pts/N) ends. fd_pos is unused
# (a tty is a stream, not seekable — see the lseek arm).

def _pty_fd_slot(pk: uint64) -> int32:
    return cast[int32](pk >> 1)


def _pty_fd_is_master(pk: uint64) -> int32:
    return cast[int32](pk & 1)


# F4 #449: public wrappers around the Layer-2 path-handler open
# helpers below, so linux_abi's l2_path_open_dispatch can route a
# /dev/ptmx, /dev/pts/<N>, /dev/fuse, /sys/fs/cgroup open back into
# vfs.ad without exposing the Layer-2 import surface (vfs.ad's per-task
# fd-table accessors stay private to this file).
def vfs_open_ptmx_l2() -> int32:
    return _open_ptmx()


def vfs_open_pts_l2(n: int32) -> int32:
    return _open_pts(n)


def vfs_open_fuse_conn_l2() -> int32:
    return _open_fuse_conn_marked()


def vfs_open_cgroup_l2(name: Ptr[char]) -> int32:
    return _open_cgroup(name)


def vfs_pts_path_index(name: Ptr[char]) -> int32:
    # Returns >= 0 for a well-formed /dev/pts/<digits> (the slave index),
    # -1 for a /dev/pts/<not-digits> path (-ENOENT), -2 when the path is
    # not under /dev/pts at all (the dispatcher falls through).
    return _pts_path_index(name)


def vfs_is_cgroup_path(name: Ptr[char]) -> int32:
    return is_cgroup_path(name)


def vfs_path_eq_const_l2(name: Ptr[char], expected: Ptr[uint8],
                         expected_len: int32) -> int32:
    # Public byte-by-byte path-prefix matcher for the l2_path_open_hook
    # dispatcher's literal-path arms.
    return _path_eq_const(name, expected, expected_len)


def _open_ptmx() -> int32:
    # /dev/ptmx open: allocate a fresh pair (master ref taken inside
    # pty_alloc_pair). Phase 4e (PTY fold, F7 #390): wrap the legacy
    # (slot << 1) | is_master pack in a DEV_PTMX pool chan and install
    # a unified FD_CHAN_MARK fd. The chan now OWNS the master end-ref
    # (one-per-chan); fork/dup bump the chan refcount and the last
    # namec_close runs vfs_ptmx_chan_release → pty_master_unref.
    # F4 #449: dispatch through the registered hook. A pure-native build
    # leaves the hooks null; we then fall through to -ENOSYS so the caller
    # sees a clear "no PTY layer in this image" answer.
    if pty_alloc_pair_hook == cast[Fn[int32]](0) \
            or pty_master_unref_hook == cast[Fn[None, int32]](0):
        set_current_errstr("ptmx: no PTY layer bound")
        return cast[int32](-38)                # -ENOSYS
    slot: int32 = pty_alloc_pair_hook()
    if slot < 0:
        set_current_errstr("ptmx: no free PTY pairs")
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        pty_master_unref_hook(slot)
        return EMFILE
    pack32_m: uint32 = (cast[uint32](slot) << 1) | 1
    cid_m: int32 = namec_open_ptmx(pack32_m)
    if cid_m < 0:
        pty_master_unref_hook(slot)
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK
        set_current_errstr("ptmx: chan pool exhausted")
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_CHAN_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](cast[uint32](cid_m))
    return fd


def _open_pts(slot: int32) -> int32:
    # /dev/pts/<N> open: take a slave ref (fails -EIO on a locked or
    # invalid pair). Phase 4e (PTY fold, F7 #390): wrap the legacy
    # (slot << 1) pack (is_master = 0 for the slave) in a DEV_PTMX pool
    # chan and install a unified FD_CHAN_MARK fd. The chan owns the
    # slave end-ref; last close runs vfs_ptmx_chan_release →
    # pty_slave_unref.
    # F4 #449: dispatch through the registered hook (see _open_ptmx).
    if pty_slave_open_hook == cast[Fn[int32, int32]](0) \
            or pty_slave_unref_hook == cast[Fn[None, int32]](0):
        set_current_errstr("pts: no PTY layer bound")
        return cast[int32](-38)
    rc: int32 = pty_slave_open_hook(slot)
    if rc != 0:
        set_current_errstr("pts: slave locked or invalid")
        return EIO
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        pty_slave_unref_hook(slot)
        return EMFILE
    pack32_s: uint32 = (cast[uint32](slot) << 1)
    cid_s: int32 = namec_open_ptmx(pack32_s)
    if cid_s < 0:
        pty_slave_unref_hook(slot)
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK
        set_current_errstr("pts: chan pool exhausted")
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu] = FD_CHAN_MARK
    task[0].fd_pos[fdu] = 0
    task[0].fd_buf[fdu] = cast[uint64](cast[uint32](cid_s))
    return fd


def _pts_path_index(name: Ptr[char]) -> int32:
    # Parse a `#c/pts/<digits>` path. Returns the slot index >=0 for a
    # well-formed numbered slave, -1 for a path that IS under #c/pts/
    # but isn't valid digits (-> -ENOENT), or -2 when the path is not
    # under #c/pts at all (caller falls through to other routing).
    #
    # F10-1 (#454): keyed on the `#c/pts/<N>` server-letter spelling.
    # The legacy `/dev/pts/<N>` literal-prefix parse was a parallel
    # resolution path; resolve_path now rewrites the userland /dev/pts/<N>
    # to `#c/pts/<N>` in a Pgrp where `bind '#c' /dev` is in force, and a
    # Pgrp without that bind ENOENTs in resolve_path before namec is hit.
    prefix: Array[8, uint8]
    prefix[0] = 35                              # '#'
    prefix[1] = 99                              # 'c'
    prefix[2] = 47                              # '/'
    prefix[3] = 112                             # 'p'
    prefix[4] = 116                             # 't'
    prefix[5] = 115                             # 's'
    prefix[6] = 47                              # '/'
    prefix[7] = 0                               # (unused — keeps Adder happy)
    i: uint64 = 0
    while i < 7:
        if name[i] != cast[int32](prefix[i]):
            return -2                           # not #c/pts/...
        i = i + 1
    # Parse decimal digits after the prefix; must be non-empty + NUL.
    if name[7] == 0:
        return -1                               # bare "#c/pts/"
    n: int32 = 0
    j: uint64 = 7
    while name[j] != 0:
        c: int32 = name[j]
        if c < 48 or c > 57:
            return -1                           # non-digit -> ENOENT
        n = n * 10 + (c - 48)
        j = j + 1
    return n


def _open_blk_marked(pack: uint64) -> int32:
    # /dev/blk/<name>{,/size,/ctl} open. `pack` already encodes the
    # block-device slot (low 32 bits) + mode (RAW / SIZE / CTL, shifted
    # into bits 32..). Phase 4b: wrap it in a DEV_BLK pool chan
    # (back_ptr carries the pack — wider than back_slot) and install an
    # FD_CHAN_MARK fd. fd_pos is the byte cursor (RAW mode); fd_buflen
    # snapshots the device capacity so the chan SEEK_END arm resolves
    # locally — SIZE/CTL fds keep 0 so SEEK_END pins to 0, matching the
    # legacy FD_BLK_MARK seek behaviour.
    cid: int32 = namec_open_blk_file(pack)
    if cid < 0:
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    cap: uint64 = 0
    if ((pack >> 32) & 0xFFFF) == 0:                  # BLK_MODE_RAW
        cap = devblk_capacity_bytes(pack)
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = cap
    return fd


# Phase 4b: _open_loop_marked is DELETED — /dev/loop/ctl is a namec
# devtab cdev (DEV_LOOPCTL, inline chan); the `#c/loop/ctl` leaf falls
# through _open_dev_leaf to the _namec_open probe like every other
# stateless cdev.


# --- ARCH §10: the /net 9P file-tree open path ----------------------
#
# An open of a /net path produces an FD_CHAN_MARK fd over a DEV_NET
# pool chan (Phase 4d fold; legacy: FD_NET_MARK). back_slot packs
# (proto, conn, file-kind) — see devnet.ad's devnet_pack. Three cases:
#
#   * /net/<proto>/clone — allocate a connection immediately so the
#     conn number is stable from the moment the fd exists; a read of
#     the clone fd renders that number. The clone fd itself holds the
#     conn's first reference, so closing it tears the conn down (Plan 9
#     keeps the conn alive as long as ANY fd into its dir is open).
#   * /net/<proto>/<N>/<file> — a per-file fd into an existing conn.
#     The conn's refcount is bumped; close drops it.
#   * /net or /net/<proto> or /net/<proto>/<N> directory — no readable
#     file shape yet; reported as ENOENT (a `ls /net` lister is a
#     follow-up).
#
# Returns a real fd >= 0, the NET_NOT sentinel when `name` is not a
# /net path (caller falls through), or an errno on a /net path that
# could not be opened.
NET_NOT: int32 = -20001


def _devnet_render_dec(v: int32, out: Ptr[uint8]) -> int64:
    # Render `v` (a /net connection number) as ASCII decimal + '\n'
    # into `out`. Returns bytes written. Used by the clone fd's read.
    if v < 0:
        out[0] = 45                                    # '-'
        out[1] = 49                                    # '1'
        out[2] = 10                                    # '\n'
        return 3
    val: uint64 = cast[uint64](v)
    if val == 0:
        out[0] = 48                                    # '0'
        out[1] = 10
        return 2
    digits: Array[24, uint8]
    n: uint64 = 0
    while val != 0:
        digits[n] = cast[uint8](val % 10) + 48
        val = val / 10
        n = n + 1
    p: uint64 = 0
    while n > 0:
        n = n - 1
        out[p] = digits[n]
        p = p + 1
    out[p] = 10                                        # '\n'
    p = p + 1
    return cast[int64](p)


def _open_net_dir(sub: Ptr[char]) -> int32:
    # `#I` directory listing (post-bind /net and its subdirectories).
    # `sub` is the device-server-relative path AFTER the `#I` letter:
    # "" for the server root, "/tcp" for a proto dir, "/tcp/<N>" for a
    # connection dir. Render the children into a kmalloc'd FD_DIR_MARK
    # buffer via devnet_listdir so getdents64 + `ls /net` see them.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    buf: uint64 = kmalloc(DIR_BUF_SIZE)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)                        # -ENOMEM
    n: int64 = devnet_listdir(sub, cast[Ptr[uint8]](buf), DIR_BUF_SIZE)
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        set_current_errstr("net: no such directory")
        return ENOENT
    return _install_dir_fd(fd, buf, n)


def _open_net_leaf(sub: Ptr[char]) -> int32:
    # `#I/<rest>` open (post-bind /net/<rest>). `sub` points at the
    # leading '/' after the `#I` letter (e.g. "/tcp/clone"). Reconstruct
    # the conventional "/net<sub>" path in scratch and route through the
    # SAME devnet backend the legacy literal /net arm used. A directory
    # target becomes a listing fd; a concrete file becomes an
    # FD_CHAN_MARK / DEV_NET fd via _open_net (Phase 4d fold).
    scratch: Array[160, uint8]
    scratch[0] = 47                                    # '/'
    scratch[1] = 110                                   # 'n'
    scratch[2] = 101                                   # 'e'
    scratch[3] = 116                                   # 't'
    k: uint64 = 0
    while sub[k] != 0 and k + 5 < 160:
        scratch[4 + k] = cast[uint8](sub[k] & 0xFF)
        k = k + 1
    scratch[4 + k] = 0
    full: Ptr[char] = cast[Ptr[char]](&scratch[0])
    # Classify first: a directory target lists; a file target opens.
    dproto: int32 = NET_PROTO_TCP
    dconn:  int32 = -1
    dfkind: int32 = NET_FILE_CLONE
    cls: int32 = devnet_path_classify(full, &dproto, &dconn, &dfkind)
    if cls == NETPATH_DIR:
        return _open_net_dir(sub)
    if cls == NETPATH_MISS:
        set_current_errstr("net: no such file")
        return ENOENT
    return _open_net(full)


def _open_net(name: Ptr[char]) -> int32:
    proto: int32 = NET_PROTO_TCP
    conn:  int32 = -1
    fkind: int32 = NET_FILE_CLONE
    cls: int32 = devnet_path_classify(name, &proto, &conn, &fkind)
    if cls == NETPATH_MISS:
        return NET_NOT
    if cls == NETPATH_DIR:
        # A /net directory — no file to open. (Directory listing is a
        # follow-up; for now an open of a bare dir is ENOENT.)
        set_current_errstr("net: not a file")
        return ENOENT
    # NETPATH_FILE.
    # Phase 4d (net fold, F7 #390): every arm below installs an
    # FD_CHAN_MARK fd over a DEV_NET pool chan whose back_slot carries
    # the (proto, conn, file-kind) pack. The conn refcount is held
    # ONE-PER-CHAN — the chan owns the ref the legacy fd held — so
    # fork/dup share via namec_chan_ref and the unref fires from
    # namec_close's DEV_NET arm on the LAST reference.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    if fkind == NET_FILE_CLONE:
        # clone: allocate the connection now.
        new_conn: int32 = devnet_clone(proto)
        if new_conn < 0:
            set_current_errstr("net: connection table full")
            return EMFILE
        fd: int32 = _alloc_fd(task)
        if fd < 0:
            devnet_conn_unref(new_conn)
            return EMFILE
        cid_cl: int32 = namec_open_net(cast[uint32](
            devnet_pack(proto, new_conn, NET_FILE_CLONE)))
        if cid_cl < 0:
            devnet_conn_unref(new_conn)
            task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK
            return EMFILE                  # chan pool exhausted
        fdu: uint64 = cast[uint64](fd)
        task[0].fd_idx[fdu]    = FD_CHAN_MARK
        task[0].fd_pos[fdu]    = 0
        task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid_cl))
        task[0].fd_buflen[fdu] = 0
        return fd
    # Host-level /net/addr leaf: no connection behind it, so no conn
    # ref. conn stays -1 (packs as NET_CONN_NONE; the release arm
    # skips unref on -1).
    if fkind == NET_FILE_ADDR:
        fda: int32 = _alloc_fd(task)
        if fda < 0:
            return EMFILE
        cid_a: int32 = namec_open_net(cast[uint32](
            devnet_pack(proto, -1, NET_FILE_ADDR)))
        if cid_a < 0:
            task[0].fd_idx[cast[uint64](fda)] = FD_CLOSED_MARK
            return EMFILE
        fdau: uint64 = cast[uint64](fda)
        task[0].fd_idx[fdau]    = FD_CHAN_MARK
        task[0].fd_pos[fdau]    = 0
        task[0].fd_buf[fdau]    = cast[uint64](cast[uint32](cid_a))
        task[0].fd_buflen[fdau] = 0
        return fda
    # F2 #447: host-level Plan-9-shape config + DNS lookup files. Same
    # conn==-1 shape as /net/addr — no per-connection state. The
    # read/write arms branch on fkind.
    if fkind == NET_FILE_DNS or fkind == NET_FILE_IPIFC_CTL \
            or fkind == NET_FILE_DNS_LOOKUP \
            or fkind == NET_FILE_DNS_RLOOKUP:
        fdh: int32 = _alloc_fd(task)
        if fdh < 0:
            return EMFILE
        cid_h: int32 = namec_open_net(cast[uint32](
            devnet_pack(proto, -1, fkind)))
        if cid_h < 0:
            task[0].fd_idx[cast[uint64](fdh)] = FD_CLOSED_MARK
            return EMFILE
        fdhu: uint64 = cast[uint64](fdh)
        task[0].fd_idx[fdhu]    = FD_CHAN_MARK
        task[0].fd_pos[fdhu]    = 0
        task[0].fd_buf[fdhu]    = cast[uint64](cast[uint32](cid_h))
        task[0].fd_buflen[fdhu] = 0
        return fdh
    # A per-file fd into an existing conn. The conn must already exist.
    if devnet_conn_proto(conn) < 0:
        set_current_errstr("net: no such connection")
        return ENOENT
    devnet_conn_ref(conn)
    fd2: int32 = _alloc_fd(task)
    if fd2 < 0:
        devnet_conn_unref(conn)
        return EMFILE
    cid_f: int32 = namec_open_net(cast[uint32](
        devnet_pack(proto, conn, fkind)))
    if cid_f < 0:
        devnet_conn_unref(conn)
        task[0].fd_idx[cast[uint64](fd2)] = FD_CLOSED_MARK
        return EMFILE
    fd2u: uint64 = cast[uint64](fd2)
    task[0].fd_idx[fd2u]    = FD_CHAN_MARK
    task[0].fd_pos[fd2u]    = 0
    task[0].fd_buf[fd2u]    = cast[uint64](cast[uint32](cid_f))
    task[0].fd_buflen[fd2u] = 0
    return fd2


# --- Phase D: the universal namec open path -------------------------
#
# _namec_open is the canonical chan-resolution entry point. It calls
# namec() — which walks the calling process's Pgrp mount table — and
# on a chan result installs ONE FD_CHAN_MARK fd carrying the opaque
# chan id in fd_buf. A local cdev (/dev/cons, /dev/time, ...) and a
# file on a mounted 9P server both arrive here and both produce an
# FD_CHAN_MARK fd; vfs_read / vfs_write / vfs_close dispatch them back
# into namec_read / namec_write / namec_close, which route devtab vs.
# mountrpc internally. The fd layer never learns local-vs-mounted.
#
# Return: a real fd >= 0 on a chan open; the P9_NO_MOUNT sentinel
# (-10000, == namec's NAMEC_FALLTHROUGH) when namec does NOT own the
# path so the caller falls through to its on-disk routing; or an
# errno (ENOENT / EMFILE) when the path IS a chan but the open failed.

def _namec_open(name: Ptr[char], mode: int32) -> int32:
    cid: int32 = namec(name, mode)
    if cid == NAMEC_FALLTHROUGH:
        return P9_NO_MOUNT
    if cid == NAMEC_NEEDS_AUTH:
        # F9 #452: namec resolved /dev/auth in the devtab (so a process
        # that unbinds `#c` from `/dev` won't reach this line — the
        # devtab match fires only when the path resolves to the `#c`
        # binding through the per-Pgrp namespace). The chan is stateful:
        # we own the AuthSlot alloc here because devauth.ad imports vfs,
        # imports namec, and a namec → devauth back-import would cycle.
        # _open_auth_marked runs devauth_alloc + namec_open_auth_file +
        # installs the FD_CHAN_MARK fd. The literal-path arm that USED
        # to live above this _namec_open call is GONE — there is no
        # `_path_eq_const(name, "/dev/auth")` pre-probe anywhere.
        return _open_auth_marked()
    if cid == NAMEC_ENOENT:
        return ENOENT
    if cid == NAMEC_EMFILE:
        return EMFILE
    if cid < 0:
        return ENOENT
    # Phase D proof line: a mounted-9P Chan was resolved + opened
    # purely through namec — no FD_<NAME>_MARK / FD_P9_MARK probe was
    # consulted. test_namec_chan.sh greps this marker to assert the
    # mounted-server open path is the universal namec/devtab path.
    if namec_chan_is_mounted(cid) != 0:
        printk0("[namec] mounted-9P chan opened via namec (DEV_MNT)\n")
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _namec_open_create(name: Ptr[char]) -> int32:
    # Create-on-write-open leg routed through namec. Only the 9P-mounted
    # case is creatable; namec_create returns NAMEC_FALLTHROUGH when no
    # mount covers the path.
    cid: int32 = namec_create(name)
    if cid == NAMEC_FALLTHROUGH:
        return P9_NO_MOUNT
    if cid < 0:
        return ENOENT
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _fd_chan_id(task: Ptr[TaskStruct], fdu: uint64) -> int32:
    # Recover the namec chan id from an FD_CHAN_MARK fd's fd_buf.
    return cast[int32](cast[uint32](task[0].fd_buf[fdu]))


# --- 9P-mount "no mount" sentinel ---------------------------------
#
# Phase D: the V1-era _try_open_p9 / _try_open_p9_write /
# _try_create_p9 helpers (which installed FD_P9_MARK fds directly)
# are GONE — sys/src/9/port/namec.ad's namec() now owns the 9P-
# mounted open path and installs the unified FD_CHAN_MARK fd. The
# only survivor is the sentinel value: _namec_open returns P9_NO_MOUNT
# (== namec's NAMEC_FALLTHROUGH, -10000) to mean "namec does not own
# this path; fall through to the local-FS routing". It is outside the
# errno range (EROFS=-30 etc.) so callers branch on equality without
# aliasing a real error.

P9_NO_MOUNT: int32 = -10000


def _install_proc_fd(encoded_mark: uint32) -> int32:
    # Phase 4b (fd→Chan): a /proc/<pid>/<file> fd is a unified
    # FD_CHAN_MARK fd backed by a DEV_PROC pool chan whose back_slot
    # carries the 24-bit (pid << 8 | kind) encoding from
    # devproc_open() (which has already validated the pid exists).
    # devproc_read/devproc_write decode it; namec dispatches to them
    # by name. The chan is stateless — namec_close's default
    # _chan_free is the entire release path. The read cursor stays in
    # fd_pos (devproc_read renders the whole snapshot at off==0 and
    # returns 0/EOF for off>0).
    cid: int32 = namec_open_proc_file(
        cast[int32](encoded_mark & 0x00FFFFFF))
    if cid < 0:
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = 0
    return fd


def _open_fat_read(name: Ptr[char]) -> int32:
    # fd→Chan fold: a FAT file read fd is now a unified FD_CHAN_MARK fd
    # backed by a DEV_FAT_FILE pool chan (namec_open_fat_file) rather
    # than a legacy FD_FAT_MARK per-task-array fd. The FAT open-file slot
    # lives in the chan's back_slot; the byte offset stays in fd_pos (the
    # DEV_MNT shape); the cached size stays in fd_buflen so SEEK_END /
    # fstat keep working. Release happens in namec_close → fat_close.
    basename: Ptr[char] = vfs_fs_rel(name)
    fat_slot: int32 = fat_open(basename)
    if fat_slot < 0:
        return ENOENT
    cid: int32 = namec_open_fat_file(fat_slot)
    if cid < 0:
        fat_close(fat_slot)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = fat_open_size(fat_slot)
    return fd


def _open_ext4_read(name: Ptr[char]) -> int32:
    # fd→Chan fold: an ext4 file read fd is now a unified FD_CHAN_MARK fd
    # backed by a DEV_EXT4_FILE pool chan (namec_open_ext4_file). The
    # ext4 open-file slot lives in the chan's back_slot; the offset stays
    # in fd_pos; the cached size stays in fd_buflen. Release happens in
    # namec_close → ext4_close (the single Chan release path), so a task
    # that exits holding this fd no longer leaks its ext4 slot.
    basename: Ptr[char] = vfs_fs_rel(name)
    ext_slot: int32 = ext4_open(basename)
    if ext_slot < 0:
        return ENOENT
    cid: int32 = namec_open_ext4_file(ext_slot)
    if cid < 0:
        ext4_close(ext_slot)
        return EMFILE
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        namec_close(cid)
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CHAN_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = cast[uint64](cast[uint32](cid))
    task[0].fd_buflen[fdu] = ext4_open_size(ext_slot)
    return fd


PROC_BUF_SIZE: uint64 = 4096


def _open_proc(name: Ptr[char]) -> int32:
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    # Most /proc entries render into one page; /proc/kmsg needs the
    # whole printk ring so `dmesg` retrieves the complete kernel log
    # (including messages the console-loglevel gate kept off the live
    # console). proc_buf_size() returns the right size per path.
    bufsz: uint64 = proc_buf_size(name)
    buf: uint64 = kmalloc(bufsz)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)              # -ENOMEM
    n: int64 = proc_render(name, cast[Ptr[uint8]](buf))
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        return ENOENT
    # Phase 4b (fd→Chan): the rendered snapshot moves INTO a ptr-backed
    # DEV_BUF_FILE pool chan (back_ptr = buffer, back_slot = length) and
    # the fd becomes a unified FD_CHAN_MARK fd. The read cursor stays in
    # fd_pos; fd_buflen keeps the rendered size so SEEK_END / fstat
    # resolve locally. Release (kfree on last ref) lives in namec_close.
    return _install_buf_fd(fd, buf, n)


def _open_cgroup(name: Ptr[char]) -> int32:
    # cgroup v2 interface-file open. Same snapshot mechanism as
    # _open_proc: render once into a kmalloc'd buffer, install a
    # read-only FD_BUFFER_MARK fd that walks it. Returns ENOENT (so the
    # caller falls through to the on-disk arms) for an unknown
    # /sys/fs/cgroup path rather than failing the open outright.
    if cgroup_path_match(name) == 0:
        # Not a known cgroup2 interface file. Let the caller fall
        # through to the on-disk filesystem arms.
        return ENOENT
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    # cgroup interface files all render well under one page.
    buf: uint64 = kmalloc(4096)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)              # -ENOMEM
    n: int64 = cgroup_render(name, cast[Ptr[uint8]](buf))
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        return ENOENT
    # Phase 4b: snapshot rides a DEV_BUF_FILE pool chan — see _open_proc.
    return _install_buf_fd(fd, buf, n)


def _open_cgroup_write(name: Ptr[char]) -> int32:
    # cgroup v2 control-file OWRITE open. The fd holds NO heap state: the
    # control-file PATH is recovered per-write from the fd's recorded
    # opened-path (task_fd_set_opened_path stamps it in vfs_open_write,
    # and copy_fd_entry propagates it across dup2/fork so a dup'd fd 1
    # sees the same path). vfs_write dispatches each non-whitespace write
    # into the live cgroup object. Returns ENOENT (caller falls through)
    # if the path is not a writable control leaf, EMFILE on fd
    # exhaustion. The allocation-free design sidesteps the dup2 UAF: the
    # shell `> file` dance dup2's the fd onto fd 1 then closes the
    # original, so any per-fd kmalloc would be freed out from under fd 1.
    if cgroup_fs_is_writable_leaf(name) == 0:
        return ENOENT
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    fdu: uint64 = cast[uint64](fd)
    task[0].fd_idx[fdu]    = FD_CGROUP_WRITE_MARK
    task[0].fd_pos[fdu]    = 0
    task[0].fd_buf[fdu]    = 0
    task[0].fd_buflen[fdu] = 0
    return fd


def _open_node(name: Ptr[char]) -> int32:
    # /sys/devices/system/node/* NUMA-node sysfs file open. Same snapshot
    # mechanism as _open_cgroup: render once into a kmalloc'd buffer, install a
    # read-only FD_BUFFER_MARK fd that walks it. Returns ENOENT (so the caller
    # falls through to the on-disk arms) for an unknown node path.
    if node_path_match(name) == 0:
        return ENOENT
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fd: int32 = _alloc_fd(task)
    if fd < 0:
        return EMFILE
    # NUMA node interface files all render well under one page.
    buf: uint64 = kmalloc(4096)
    if buf == 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        return cast[int32](-12)              # -ENOMEM
    n: int64 = node_render(name, cast[Ptr[uint8]](buf))
    if n < 0:
        task[0].fd_idx[cast[uint64](fd)] = FD_CLOSED_MARK   # free _alloc_fd reservation (#71)
        kfree(buf)
        return ENOENT
    # Phase 4b: snapshot rides a DEV_BUF_FILE pool chan — see _open_proc.
    return _install_buf_fd(fd, buf, n)


def _check_fd(fd: int32) -> int32:
    if fd < 0 or cast[uint32](fd) >= _VFS_NR_FDS:
        return EBADF
    return 0


def vfs_read_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    # Non-blocking read backing SYS_READ_NB. Returns >0 bytes ready,
    # 0 if the fd is open but momentarily empty ("would block"), or -1
    # on a true EOF / error. Only the two fd kinds an event-loop daemon
    # actually polls are special-cased — a connected socket and a pipe
    # read-end. Every other fd kind has no would-block notion here, so
    # we just delegate to the blocking vfs_read (a regular file always
    # has data or is at EOF immediately anyway).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]

    if file_idx == FD_CLOSED_MARK:
        return -1
    # Phase 4c (socket fold): the FD_SOCKET_MARK nb-read arm is GONE —
    # a socket fd is an FD_CHAN_MARK fd; the FD_CHAN_MARK arm below
    # dispatches through namec_read_nb's DEV_SOCKET arm into
    # vfs_socket_chan_read_nb (the verbatim body).
    # Phase 4d (net fold, F7 #390): the FD_NET_MARK nb-read arm is
    # GONE — a /net fd is an FD_CHAN_MARK fd; the FD_CHAN_MARK arm
    # below dispatches through namec_read_nb's DEV_NET arm into
    # vfs_net_chan_read_nb (the verbatim body — DATA gets the
    # non-blocking devnet_data_read_nb; snapshot leaves delegate to
    # the blocking vfs_net_chan_read).
    if file_idx == FD_CHAN_MARK:
        # hamUI daemon: /dev/cons (and any other cdev) is opened via
        # namec, so it installs an FD_CHAN_MARK fd — NOT FD_CONS_MARK.
        # A non-blocking poll of /dev/cons therefore lands here, not in
        # the FD_CONS_MARK arm above. Dispatch into namec's non-blocking
        # leg: namec_read_nb routes a DEV_CONS chan to devcons_read_nb
        # (returns 0 = would-block immediately when no key is queued) and
        # delegates every other chan kind to the blocking namec_read.
        chan_id: int32 = _fd_chan_id(task, fdu)
        coff:    uint64 = task[0].fd_pos[fdu]
        nc: int64 = namec_read_nb(chan_id, coff, buf, count)
        if nc > 0:
            task[0].fd_pos[fdu] = coff + cast[uint64](nc)
        return nc
    if file_idx == FD_STDIN_MARK:
        # TEMP_DEBUG_HEARTBEAT (see user/hamsh.ad): hamsh's interactive
        # loop polls stdin non-blocking so it can emit a periodic alive
        # tick to the framebuffer during real-hardware bring-up. The
        # blocking vfs_read arm above wedges the task inside the syscall
        # until kbd/UART produces a byte — useless on a box where the
        # keyboard isn't yet working. Here we peek the kbd FIFO then the
        # UART FIFO; on a byte we return it (1 byte; the line editor reads
        # one byte at a time anyway), on no byte we return 0 ("would
        # block") so the caller can do its own timed work and yield.
        #
        # Same console_set_interactive() handshake as the blocking arm —
        # the kernel uses the first stdin read as the "interactive prompt
        # is live" trigger to tighten the console log-level. Remove this
        # arm alongside the hamsh-side heartbeat once real-hardware
        # keyboard input works.
        console_set_interactive()
        # P0b: while a compositor (hamUId) holds the console-input grab,
        # the grab PARTITIONS physical input (see kernel/sched/core.ad):
        # the holder owns the PS/2 keyboard ring, every other reader
        # keeps the UART. The boot/login hamsh that shares the serial
        # console reads stdin via THIS FD_STDIN_MARK arm — without the
        # kbd gate it would race the DE for keystrokes typed at the
        # desktop, and without the uart EXEMPTION the DE's per-frame
        # /dev/cons drain would starve the serial session entirely
        # (#410 live-Debian gate). Mirrors devcons_read_nb.
        may_kbd: int32 = console_input_may_pop_kbd_current()
        may_uart: int32 = console_input_may_pop_uart_current()
        # hamUI Phase 1: prefer the wsys cmd-injection queue. An
        # outside agent writing `echo foo > /dev/wsys/1/cmd` queues
        # bytes here that hamsh's ed_readline drains exactly as it
        # would real keystrokes — no shell-side change required.
        c: int32 = wsys_cmd_pop()
        if c < 0 and may_kbd != 0:
            c = kbd_rx_pop()
        if c < 0 and may_uart != 0:
            c = uart_rx_pop()
        if c < 0:
            return 0                            # would-block
        b: uint8 = cast[uint8](c & 0xFF)
        if b == 13:
            b = 10                              # CR -> LF (match vfs_read)
        buf[0] = b
        if b == 10:
            # Echo the newline as user output — same as the blocking
            # arm — so the framebuffer cursor advances on Enter.
            early_putc_user(10)
        return 1
    # Anything else: no would-block semantics — fall back to the
    # ordinary blocking read.
    return vfs_read(fd, buf, count)


def vfs_write_nb(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    # §5: non-blocking write backing O_NONBLOCK on a pipe / socket fd.
    # Returns >0 bytes accepted, 0 if the fd is open but momentarily
    # full ("would block" — the Layer-2 shim translates this to
    # -EAGAIN), or a negative errno on a hard error (EPIPE, EBADF).
    # Only the two fd kinds an event-loop daemon writes are special-
    # cased; every other kind delegates to the ordinary vfs_write (a
    # regular file / cdev write never blocks meaningfully here).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return cast[int64](EBADF)
    if file_idx == FD_CHAN_MARK:
        # Phase 4c: a pipe write end is a DEV_PIPE_W pool chan. A single
        # non-blocking pipe write: pipe_write enqueues what the ring will
        # take (0 when full). EPIPE if every reader is gone. Any other
        # chan kind has no would-block notion — delegate to vfs_write.
        wnb_cid: int32 = cast[int32](cast[uint32](task[0].fd_buf[fdu]))
        if namec_chan_dev_type(wnb_cid) == DEV_PIPE_W:
            slot: int32 = namec_chan_back_slot(wnb_cid)
            if pipe_readers(slot) == 0:
                return cast[int64](EPIPE)
            return pipe_write(slot, buf, count)
        # Phase 4c (socket fold): a socketpair end is a DEV_SOCKETPAIR
        # chan — one non-blocking ring enqueue (0 when full), EPIPE
        # when the peer end is gone.
        if namec_chan_dev_type(wnb_cid) == DEV_SOCKETPAIR:
            sp_pkd:  uint64 = cast[uint64](namec_chan_sockpair_packed(wnb_cid))
            sp_slot: int32 = sockpair_unpack_slot(sp_pkd)
            sp_dir:  int32 = sockpair_unpack_dir(sp_pkd)
            if sockpair_peer_alive(sp_slot, sp_dir) == 0:
                return cast[int64](EPIPE)
            return sockpair_write(sp_slot, sp_dir, buf, count)
        # A DEV_SOCKET chan: tcp_send already does a single
        # non-blocking enqueue into the tx ring (it does not yield),
        # so a plain vfs_write on a socket is effectively non-blocking
        # already. Any other chan kind has no would-block notion.
        # Either way: delegate to vfs_write.
        return vfs_write(fd, buf, count)
    # Anything else: an ordinary write — never blocks meaningfully.
    return vfs_write(fd, buf, count)


def vfs_read(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]

    if file_idx == FD_CLOSED_MARK:
        return cast[int64](EBADF)
    if file_idx == FD_CHAN_MARK:
        # Phase D: namec Chan-backed fd. fd_buf carries the opaque
        # chan id. namec_read dispatches devtab (local cdev) vs.
        # mountrpc (9P T-messages over the mounted server) internally
        # — vfs_read does not branch on local-vs-mounted. fd_pos is
        # the byte offset (used only by the DEV_MNT mountrpc leg; an
        # inline cdev ignores it). This single arm REPLACES the dozen
        # FD_<NAME>_MARK cdev read arms below AND the FD_P9_MARK arm.
        chan_id: int32 = _fd_chan_id(task, fdu)
        # #459 / F6 follow-up: a folded directory fd is a DEV_DIR_FILE
        # chan whose namec_read arm routes to _dirfile_read and emits the
        # same "NAME\n" packed listing the retired SYS_LISTDIR produced.
        # That is the documented native-listdir contract (#450 F6: "the
        # dir-fd's DEV_DIR_FILE backing emits the same NAME\n bytes the
        # retired SYS_LISTDIR returned, so callers migrate by symbol
        # rename" — lib/p9.ad::p9_listdir, used by ls / du / find / help /
        # lsblk / hamde / hamUId / sshd / httpd / the supervisor's
        # svc_load_all_defs and many more). The earlier short-circuit here
        # returned -EISDIR for Linux read(2)-on-dir semantics; that broke
        # EVERY native listdir caller (svc_load_all_defs got -1 and the
        # graphical runlevel never started — see #459) without actually
        # being needed for Linux: glibc/busybox use getdents64 (Layer 2's
        # _u_getdents64 walks vfs_fd_dir_buf/_buflen directly, NOT this
        # read path), and Linux read(2) on a directory fd in a hamUI/native
        # context is unreachable. Drop the short-circuit and let namec_read
        # produce the listing.
        coff:    uint64 = task[0].fd_pos[fdu]
        # SMAP: `buf` may be a USER (US=1) page (pread64 / io_uring direct
        # read pass the user buffer straight through). namec_read's backend
        # memcpys file/tmpfs/proc bytes into it at CPL=0, so bracket with
        # STAC. Harmless for a kernel `buf`. This is the read path the
        # writable tmpfs overlay takes when dpkg/apt read a just-unpacked
        # file back inside `enter linux { }`.
        _ua_stac()
        nc: int64 = namec_read(chan_id, coff, buf, count)
        _ua_clac()
        if nc > 0:
            task[0].fd_pos[fdu] = coff + cast[uint64](nc)
        return nc
    # Phase 4c: the FD_DEVFD_MARK read arm is GONE — an `#d/<N>` fd is
    # an FD_CHAN_MARK / DEV_DEVFD inline chan; the FD_CHAN_MARK arm
    # above routes it through namec_read → devfd_read_blocking, which
    # carries the exact event-driven pipe sleep this arm held.
    if file_idx == FD_P9_MARK:
        # V1 legacy 9P-mounted file path — retained as a non-regressing
        # fallback for any FD_P9_MARK fd a not-yet-converted call site
        # might still install. fd_buf packs (srvfd << 32 | fid); fd_pos
        # is the offset. New opens route through FD_CHAN_MARK above.
        p9_packed: uint64 = task[0].fd_buf[fdu]
        srvfd_p9: int32 = p9c_decode_srvfd(p9_packed)
        fid_p9:   int32 = p9c_decode_fid(p9_packed)
        off:      uint64 = task[0].fd_pos[fdu]
        # SMAP: `buf` may be a USER (US=1) page — bracket the 9P backend's
        # CPL=0 copy into it (see the namec_read arm above).
        _ua_stac()
        n: int64 = p9c_read(srvfd_p9, fid_p9, off, buf,
                            cast[uint32](count))
        _ua_clac()
        if n > 0:
            task[0].fd_pos[fdu] = off + cast[uint64](n)
        return n
    # Phase 4e (PTY fold, F7 #390): the FD_PTMX_MARK read arm is GONE.
    # A /dev/ptmx or /dev/pts/<N> fd is an FD_CHAN_MARK fd over a
    # DEV_PTMX pool chan; the FD_CHAN_MARK arm at the head of vfs_read
    # dispatches it through namec_read → vfs_ptmx_chan_read (the
    # verbatim body: master/slave read with cooked/raw line discipline,
    # blocking-yield until bytes arrive or the peer closes for EOF).
    # Phase 4d (net fold, F7 #390): the FD_NET_MARK read arm is GONE.
    # A /net fd is an FD_CHAN_MARK fd over a DEV_NET pool chan; the
    # FD_CHAN_MARK arm at the head of vfs_read dispatches it through
    # namec_read → vfs_net_chan_read (the verbatim body: clone /
    # status / local / remote / addr / dns / dns_lookup / dns_rlookup
    # / ctl-accept snapshots EOF-terminate on the second read via the
    # chan's off cursor, the data file streams TCP/UDP/TLS bytes).
    # Phase 4c (socket fold): the FD_SOCKET_MARK blocking-read arm is
    # GONE — a socket fd is an FD_CHAN_MARK fd whose namec_read
    # DEV_SOCKET arm dispatches by name into vfs_socket_chan_read (the
    # verbatim port above: UDP datagram pull, TLS record-layer recv,
    # tcp_recv with the EOF-vs-timeout latch).
    # /dev/null, /dev/zero, /dev/cons, /dev/time, /dev/pid, /dev/random,
    # /dev/mouse, /dev/cpuinfo, /dev/meminfo, /dev/uptime, /dev/loadavg,
    # /dev/version, /dev/hostname, /dev/stat, /dev/mounts and
    # /dev/diskstats are stateless namec devtab cdevs (DEV_NULL ..
    # DEV_DISKSTATS). They open as FD_CHAN_MARK fds and read through the
    # FD_CHAN_MARK arm above into _devtab_read — there are no per-mark
    # read arms here anymore.
    # Phase 4b: the FD_BLK_MARK / FD_LOOP_MARK read arms are DELETED —
    # /dev/blk/<name> fds are DEV_BLK pool chans and /dev/loop/ctl is a
    # DEV_LOOPCTL inline chan; both read through the FD_CHAN_MARK arm
    # above (which advances fd_pos, preserving the byte/EOF cursors).
    # Phase 4b: the FD_AUTH_MARK read arm is DELETED — /dev/auth fds are
    # FD_CHAN_MARK fds; the FD_CHAN_MARK arm above routes them through
    # namec_read's DEV_AUTH dispatch into devauth_read.
    # Phase 4f (FUSE fold, F7 #390): the FD_FUSE_CONN_MARK / FD_FUSE_FILE_MARK
    # read arms are GONE. A /dev/fuse fd is an FD_CHAN_MARK fd over a
    # DEV_FUSE_CONN pool chan; a FUSE-served file fd is an FD_CHAN_MARK
    # fd over a DEV_FUSE_FILE pool chan. The FD_CHAN_MARK arm at the head
    # of vfs_read dispatches both through namec_read into
    # vfs_fuse_conn_chan_read / vfs_fuse_file_chan_read (verbatim ports
    # of the bodies above).
    # Phase 4b (fd→Chan): the legacy /proc/<pid>/<file> encoded-marker
    # read arm is GONE. A devproc fd is now an FD_CHAN_MARK fd backed by
    # a DEV_PROC pool chan; the FD_CHAN_MARK arm at the head of vfs_read
    # dispatches it through namec_read → devproc_read (back_slot carries
    # the pid<<8|kind encoding, fd_pos stays the EOF cursor).
    # Phase 4b (fd→Chan): the legacy FD_BUFFER_MARK read arm is GONE. A
    # procfs/cgroup2/node snapshot fd is now an FD_CHAN_MARK fd backed by
    # a ptr-backed DEV_BUF_FILE pool chan; the FD_CHAN_MARK arm at the
    # head of vfs_read dispatches it through namec_read into the shared
    # ptr-backed reader (_dirfile_read). The FD_DIR_MARK EISDIR arm is
    # GONE with its mark — a directory fd is a DEV_DIR_FILE chan and the
    # FD_CHAN_MARK arm answers EISDIR for it.
    # fd→Chan fold: the legacy FD_TMPFS_MARK read arm is GONE. A tmpfs /
    # memfd read fd is now an FD_CHAN_MARK fd (DEV_TMPFS_FILE pool chan);
    # the FD_CHAN_MARK arm at the head of vfs_read dispatches it through
    # namec_read into _tmpfsfile_read.
    if file_idx == FD_EVENTFD_MARK:
        # §5: a blocking read(2) on an eventfd. The 8-byte counter is
        # returned (and reset, or decremented in semaphore mode) once it
        # is non-zero; until then we yield-block, the same cadence the
        # pipe read end uses. count < 8 is -EINVAL per Linux. The
        # non-blocking variant is handled in the u_syscalls.ad shim
        # (which checks O_NONBLOCK and returns -EAGAIN instead).
        # F4 #449: dispatch through the registered hook.
        if count < 8:
            return cast[int64](EINVAL)
        if uefd_read_hook == cast[Fn[int64, int32]](0):
            return cast[int64](EBADF)
        es: int32 = cast[int32](task[0].fd_buf[fdu]) - 1
        while True:
            ev: int64 = uefd_read_hook(es)
            if ev >= 0:
                cast[Ptr[uint64]](buf)[0] = cast[uint64](ev)
                return 8
            if ev != -11:                      # not EAGAIN -> hard error
                return ev
            yield_to_others()
    if file_idx == FD_TIMERFD_MARK:
        # §5: a blocking read(2) on a timerfd. Returns the 8-byte
        # expiration count once at least one timer tick has fired;
        # yields until then. count < 8 is -EINVAL.
        # F4 #449: dispatch through the registered hook.
        if count < 8:
            return cast[int64](EINVAL)
        if utfd_read_hook == cast[Fn[int64, int32]](0):
            return cast[int64](EBADF)
        ts: int32 = cast[int32](task[0].fd_buf[fdu]) - 1
        while True:
            tv: int64 = utfd_read_hook(ts)
            if tv >= 0:
                cast[Ptr[uint64]](buf)[0] = cast[uint64](tv)
                return 8
            if tv != -11:
                return tv
            yield_to_others()
    # Phase 4c (socket fold): the FD_SOCKETPAIR_MARK blocking-read arm
    # is GONE — a socketpair end is an FD_CHAN_MARK fd whose namec_read
    # DEV_SOCKETPAIR arm runs sockpair_read_blocking (fs/socketpair.ad,
    # the verbatim port of the block-yield loop that lived here: EOF
    # once the peer end's refs hit 0).
    # fd→Chan fold: the legacy FD_FAT_MARK / FD_EXT4_MARK read arms are
    # GONE. A FAT / ext4 file fd is now an FD_CHAN_MARK fd (DEV_FAT_FILE /
    # DEV_EXT4_FILE pool chan); the FD_CHAN_MARK arm at the head of
    # vfs_read dispatches it through namec_read into _fatfile_read /
    # _ext4file_read. fd_pos is the byte offset (the DEV_MNT shape).
    # Phase 4c: the FD_PIPE_MARK_R / FD_PIPE_MARK_W arms are GONE the
    # same way — DEV_PIPE_R chans block inside namec_read →
    # pipe_read_blocking (fs/pipe.ad, the verbatim two-phase WaitQueue
    # port); a read on a DEV_PIPE_W chan answers -EBADF in namec_read.
    if file_idx == FD_STDIN_MARK:
        # M16.39: read from the software RX FIFO that timer_interrupt
        # drains the UART into. Ctrl-C (0x03) never lands in the FIFO
        # — the timer drain plucks it out and posts SIGINT instead.
        # Block until we see a full line ('\n' / '\r') or fill the
        # caller's buffer. Earlier revs returned early on a
        # transiently-empty FIFO with partial data, which made
        # hamsh treat "/cat /mnt/HELL" + "O.TXT" as TWO separate
        # commands when the host typed faster than the 100 Hz timer
        # could drain the hardware FIFO.
        #
        # A userland task reading stdin is the kernel's signal that
        # the interactive shell is up and waiting for the user — boot
        # rc scripts are *sourced from a file*, never via stdin, so
        # the first stdin read marks the transition to the live
        # prompt. Tighten the console log-level here so low-severity
        # printk chatter stops corrupting the line the user types.
        # console_set_interactive() is idempotent and cheap.
        console_set_interactive()
        # P0b: same console-input grab PARTITION as devcons_read / the
        # non-blocking stdin arm (see kernel/sched/core.ad). While the
        # DE holds the grab, a non-holder (the boot/login hamsh on the
        # serial console) must NOT pop the keyboard ring — otherwise it
        # races the compositor for keystrokes typed at the desktop —
        # but it KEEPS the UART ring: the serial line is its own
        # terminal, and gating it under the grab starved the serial
        # session dead while the DE was up (#410 live-Debian gate). A
        # non-holder with no poppable byte parks on console_wq below
        # until a serial byte / cmd injection / grab release wakes it.
        n: uint64 = 0
        while n < count:
            # Re-evaluate the grab each iteration so a release (DE exit)
            # is picked up by a parked reader on its next wake.
            may_kbd: int32 = console_input_may_pop_kbd_current()
            may_uart: int32 = console_input_may_pop_uart_current()
            # M16.75: check the PS/2 keyboard FIFO first, then UART.
            # Either input source feeds stdin transparently — useful
            # for real-hardware boot where the user is typing on a
            # PS/2 keyboard, not piping through serial.
            # hamUI Phase 1: the wsys cmd-injection queue precedes
            # both. Outside writers to /dev/wsys/1/cmd land here as if
            # the user typed them. devcons_read does the same; this
            # arm is the legacy stdin path that hamsh still uses for
            # the blocking-read case.
            c: int32 = wsys_cmd_pop()
            if c < 0 and may_kbd != 0:
                c = kbd_rx_pop()
            if c < 0 and may_uart != 0:
                c = uart_rx_pop()
            if c < 0:
                # Event-driven block: sleep on the console input wait queue
                # until a producer (UART RX IRQ / keyboard / wsys inject)
                # wakes us, instead of re-polling the FIFO on every timer
                # tick. A signal-wake (Ctrl-C) returns WQ_EINTR; surface it
                # as -EINTR so the read aborts (unless we already collected
                # bytes, in which case return the short read like Linux).
                rcw: int32 = console_wq_sleep()
                if rcw != 0:
                    if n > 0:
                        return cast[int64](n)
                    return cast[int64](WQ_EINTR)
                continue
            buf[n] = cast[uint8](c & 0xFF)
            n = n + 1
            if c == 10 or c == 13:
                if c == 13:
                    buf[n - 1] = 10
                # Echo the newline as userland output — no kernel
                # "[NNNNNN] " prefix should land on the user's input
                # line. early_putc_user takes the user-output path.
                early_putc_user(10)
                return cast[int64](n)
        return cast[int64](n)
    if file_idx == FD_STDOUT_MARK or file_idx == FD_STDERR_MARK:
        return cast[int64](EBADF)           # can't read these

    # initramfs file
    size: uint64 = initramfs_entry_size(cast[uint64](file_idx))
    pos:  uint64 = task[0].fd_pos[fdu]
    if pos >= size:
        return 0
    remaining: uint64 = size - pos
    take: uint64 = count
    if take > remaining:
        take = remaining
    src: Ptr[uint8] = initramfs_entry_data(cast[uint64](file_idx))
    # SMAP: `buf` may be a USER (US=1) page — several callers pass the
    # user buffer straight through (pread64 / io_uring direct-read /
    # vfs_read_all), which is exactly the path ld.so takes when it
    # pread64's a Debian binary's ELF segments inside `enter linux { }`.
    # The CPL=0 memcpy into that US=1 page needs STAC or CR4.SMAP=1
    # faults it. `src` is the kernel-resident initramfs blob (US=0),
    # unaffected by AC, so bracketing the whole copy is correct; for a
    # kernel `buf` STAC is a harmless no-op.
    _ua_stac()
    memcpy(buf, cast[Ptr[uint8]](cast[uint64](src) + pos), take)
    _ua_clac()
    task[0].fd_pos[fdu] = pos + take
    return cast[int64](take)


def vfs_write(fd: int32, buf: Ptr[uint8], count: uint64) -> int64:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]

    if file_idx == FD_CLOSED_MARK:
        return cast[int64](EBADF)
    if file_idx == FD_CHAN_MARK:
        # Phase D: namec Chan-backed fd. namec_write dispatches devtab
        # (local cdev) vs. mountrpc (9P over the mounted server)
        # internally — vfs_write never branches on local-vs-mounted.
        # Mirrors the FD_CHAN_MARK read arm. This single arm replaces
        # the dozen FD_<NAME>_MARK cdev write arms below + FD_P9_MARK.
        chan_id: int32 = _fd_chan_id(task, fdu)
        # fd→Chan fold: write(2) on a folded directory fd (DEV_DIR_FILE
        # chan) is EISDIR in Linux — short-circuit before namec_write,
        # which has no DEV_DIR_FILE write body (dir fds are read-only).
        if namec_chan_dev_type(chan_id) == DEV_DIR_FILE:
            return cast[int64](EISDIR)
        coff:    uint64 = task[0].fd_pos[fdu]
        # SMAP: `buf` may be a USER (US=1) page — pwrite64 / io_uring
        # direct-write pass the user buffer straight to vfs_write. namec_-
        # write's backend READS from it at CPL=0, so bracket with STAC
        # (harmless for a kernel `buf`). Symmetric to the vfs_read arms.
        _ua_stac()
        nc: int64 = namec_write(chan_id, coff, buf, count)
        _ua_clac()
        if nc > 0:
            task[0].fd_pos[fdu] = coff + cast[uint64](nc)
            # #155: a tmpfs write is an inotify IN_MODIFY on the file's
            # parent directory. This hook moved here from the retired
            # FD_TMPFS_MARK write arm — tmpfs_slot_name recovers the full
            # absolute path from the chan's tmpfs back_slot.
            if namec_chan_dev_type(chan_id) == DEV_TMPFS_FILE:
                _vfs_inotify_notify(
                    cast[Ptr[char]](tmpfs_slot_name(
                        namec_chan_back_slot(chan_id))),
                    IN_MODIFY)
        return nc
    if file_idx == FD_P9_MARK:
        # V1 legacy 9P write path — non-regressing fallback for any
        # surviving FD_P9_MARK fd. New opens route via FD_CHAN_MARK.
        p9_packed: uint64 = task[0].fd_buf[fdu]
        srvfd_p9: int32 = p9c_decode_srvfd(p9_packed)
        fid_p9:   int32 = p9c_decode_fid(p9_packed)
        off:      uint64 = task[0].fd_pos[fdu]
        # SMAP: `buf` may be a USER (US=1) page — bracket the 9P backend's
        # CPL=0 read from it (see the namec_write arm above).
        _ua_stac()
        n: int64 = p9c_write(srvfd_p9, fid_p9, off, buf,
                             cast[uint32](count))
        _ua_clac()
        if n > 0:
            task[0].fd_pos[fdu] = off + cast[uint64](n)
        return n
    # Phase 4c: the FD_DEVFD_MARK write arm is GONE — an `#d/<N>` fd is
    # an FD_CHAN_MARK / DEV_DEVFD inline chan; the FD_CHAN_MARK arm
    # above routes it through namec_write → devfd_write_blocking
    # (chunked pipe write, EPIPE on all-readers-gone).
    # Phase 4e (PTY fold, F7 #390): the FD_PTMX_MARK write arm is GONE.
    # A PTY fd is an FD_CHAN_MARK fd over a DEV_PTMX pool chan; the
    # FD_CHAN_MARK arm at the head of vfs_write dispatches it through
    # namec_write → vfs_ptmx_chan_write (the verbatim body: master
    # feeds m2s, slave feeds s2m with OPOST|ONLCR applied).
    # Phase 4d (net fold, F7 #390): the FD_NET_MARK write arm is GONE.
    # A /net fd is an FD_CHAN_MARK fd; the FD_CHAN_MARK arm at the
    # head of vfs_write dispatches it through namec_write's DEV_NET
    # arm into vfs_net_chan_write (the verbatim body: TCP/UDP/TLS data
    # streaming, ctl command parse, host-level /net/dns +
    # /net/ipifc/ctl + /net/dns/{,r}lookup write parsers).
    # /dev/cons, /dev/time, /dev/pid, /dev/random, /dev/mouse,
    # /dev/cpuinfo, /dev/meminfo, /dev/uptime, /dev/loadavg, /dev/version,
    # /dev/hostname, /dev/stat, /dev/mounts and /dev/diskstats are
    # stateless namec devtab cdevs. They open as FD_CHAN_MARK fds and
    # write through the FD_CHAN_MARK arm above into _devtab_write (which
    # rejects the read-only ones and accepts the /dev/cons fan-out,
    # /dev/random entropy-mix, /dev/hostname set) — there are no per-mark
    # write arms here anymore.
    # Phase 4b: the FD_BLK_MARK / FD_LOOP_MARK write arms are DELETED —
    # both families write through the FD_CHAN_MARK arm above into
    # namec_write's DEV_BLK / DEV_LOOPCTL dispatch.
    # Phase 4b: the FD_AUTH_MARK write arm is DELETED — /dev/auth fds
    # are FD_CHAN_MARK fds; namec_write's DEV_AUTH dispatch lands in
    # devauth_write (which still enforces the 1-attempt/sec rate limit).
    # Phase 4f (FUSE fold, F7 #390): the FD_FUSE_CONN_MARK write arm is
    # GONE. A /dev/fuse fd is an FD_CHAN_MARK fd; the FD_CHAN_MARK arm at
    # the head of vfs_write dispatches it through namec_write into
    # vfs_fuse_conn_chan_write. (DEV_FUSE_FILE answers -EROFS in
    # namec_write — the legacy FD_FUSE_FILE_MARK arm had no write body
    # and fell through to vfs_write's EROFS tail, preserved.)
    # Phase 4b (fd→Chan): the legacy /proc/<pid>/<file> encoded-marker
    # write arm is GONE. A devproc fd is an FD_CHAN_MARK fd backed by a
    # DEV_PROC pool chan; the FD_CHAN_MARK arm at the head of vfs_write
    # dispatches it through namec_write → devproc_write (note/notepg/ctl
    # writes included).
    # Phase 4c (socket fold): the FD_SOCKET_MARK blocking-write arm is
    # GONE — a socket fd is an FD_CHAN_MARK fd whose namec_write
    # DEV_SOCKET arm dispatches by name into vfs_socket_chan_write (the
    # verbatim port above: UDP sendto-the-peer, TLS 2000-byte record
    # chunking, tcp_send MSS loop with the partial-count-or-EPIPE
    # contract).
    # Phase 4b (fd→Chan): the legacy FD_BUFFER_MARK (-EROFS) and
    # FD_DIR_MARK (-EISDIR) write arms are GONE with their marks. A
    # snapshot fd is a DEV_BUF_FILE chan (namec_write answers -EROFS); a
    # directory fd is a DEV_DIR_FILE chan (the FD_CHAN_MARK arm at the
    # head of vfs_write short-circuits it with -EISDIR).
    # fd→Chan fold: the legacy FD_TMPFS_MARK write arm is GONE. A tmpfs /
    # memfd write fd is now an FD_CHAN_MARK fd (DEV_TMPFS_FILE pool chan)
    # dispatched through the FD_CHAN_MARK arm at the head of vfs_write into
    # namec_write -> _tmpfsfile_write. The #155 inotify IN_MODIFY post that
    # used to live here moved INTO that FD_CHAN_MARK head (it owns
    # _vfs_inotify_notify / tmpfs_slot_name, which namec must not import).
    # fd→Chan fold: the legacy FD_FAT_MARK / FD_EXT4_MARK write arms are
    # GONE. A write-mode FAT / ext4 file fd is now an FD_CHAN_MARK fd
    # (DEV_FAT_FILE / DEV_EXT4_FILE pool chan); the FD_CHAN_MARK arm at
    # the head of vfs_write dispatches it through namec_write into
    # _fatfile_write / _ext4file_write. _fatfile_write rejects a read-
    # mode FAT word with -EROFS; ext4's single-block short-count
    # semantics are preserved by ext4_write_open_file unchanged.
    if file_idx == FD_CGROUP_WRITE_MARK:
        # cgroup v2 control-file write. The control-file PATH is the fd's
        # recorded opened-path (allocation-free; survives the shell's
        # dup2-then-close redirect dance). The shell's echo writes each
        # ARGUMENT in its own write(2), and a control value is a SINGLE
        # argument ("2", "65536", "50000 100000", "<pid>") — so every
        # meaningful write carries the whole value. A purely-whitespace
        # write (the trailing "\n" echo appends) is a NO-OP, so it never
        # resets the limit to "max". Route by leaf:
        #   cgroup.procs  -> resolve the written pid to its task slot
        #                    (pid 0 == the writer) and migrate it.
        #   pids.max / memory.max / cpu.max -> pure parse+set.
        cg_path: Ptr[char] = cast[Ptr[char]](
            task_fd_opened_path_ptr(task, fdu))
        cdata: Ptr[char] = cast[Ptr[char]](buf)
        # Skip a whitespace-only write (don't reset the live value).
        ws_only: int32 = 1
        wi: uint64 = 0
        while wi < count:
            wc: uint8 = cast[uint8](cdata[wi])
            if wc != 32 and wc != 9 and wc != 10 and wc != 13:
                ws_only = 0
                break
            wi = wi + 1
        if ws_only != 0:
            return cast[int64](count)
        if cgroup_fs_path_is_procs(cg_path) != 0:
            pidv: int64 = 0
            if cgroup_fs_parse_first_dec(cdata, count, &pidv) == 0:
                return cast[int64](EINVAL)
            tpid: uint64 = cast[uint64](pidv)
            if tpid == 0:
                tpid = current_task_pid()    # `echo 0` == self
            tslot: int32 = task_lookup_by_pid(tpid)
            if tslot < 0:
                return cast[int64](-3)       # -ESRCH
            arc: int64 = cgroup_fs_attach(cg_path, cast[uint64](tslot))
            if arc != 0:
                return arc
            return cast[int64](count)
        wrc: int64 = cgroup_fs_write(cg_path, cdata, count)
        if wrc < 0:
            return wrc
        return cast[int64](count)
    if file_idx == FD_EVENTFD_MARK:
        # §5: write(2) on an eventfd — add the 8-byte value to the
        # counter. write < 8 bytes is -EINVAL. uefd_write rejects the
        # all-ones value and a counter overflow with -EINVAL too.
        # F4 #449: dispatch through the registered hook.
        if count < 8:
            return cast[int64](EINVAL)
        if uefd_write_hook == cast[Fn[int64, int32, uint64]](0):
            return cast[int64](EBADF)
        es: int32 = cast[int32](task[0].fd_buf[fdu]) - 1
        addend: uint64 = cast[Ptr[uint64]](buf)[0]
        return uefd_write_hook(es, addend)
    if file_idx == FD_TIMERFD_MARK:
        return cast[int64](EINVAL)             # a timerfd is not writable
    if file_idx == FD_SIGNALFD_MARK:
        return cast[int64](EINVAL)             # a signalfd is not writable
    if file_idx == FD_EPOLL_MARK:
        return cast[int64](EINVAL)             # an epoll fd is not writable
    # Phase 4c: the FD_PIPE_MARK_W blocking-write arm (and the
    # FD_PIPE_MARK_R -EBADF arm below) are GONE — a pipe end is an
    # FD_CHAN_MARK fd whose namec_write DEV_PIPE_W arm runs
    # pipe_write_blocking (fs/pipe.ad, the verbatim port of the loop
    # that lived here: EPIPE on no readers, partial count honored,
    # yield while full).
    # Phase 4c (socket fold): the FD_SOCKETPAIR_MARK blocking-write arm
    # is GONE — a socketpair end is an FD_CHAN_MARK fd whose namec_write
    # DEV_SOCKETPAIR arm runs sockpair_write_blocking (fs/socketpair.ad,
    # the verbatim port of the loop that lived here: EPIPE when the peer
    # end is gone, partial count honored, yield while the ring is full).
    if file_idx == FD_STDOUT_MARK or file_idx == FD_STDERR_MARK:
        # M16.77: mirror every byte to BOTH the UART and the VGA text
        # console. The UART feeds `-nographic` QEMU; the VGA / fb_text
        # console is what a real-hardware user sees on the monitor.
        # Same byte stream on both — early_putc_user() fans out to
        # UART + whichever framebuffer surface initialised in one call.
        #
        # USERLAND fd 1/2 write: route through early_putc_user, NOT
        # early_putc. The kernel printk path stamps every line with a
        # "[NNNNNN] " sequence number for boot-log ordering; that
        # belongs on kernel diagnostic output, not on the shell prompt,
        # not on `echo` output, not on a userland program's stdout.
        # early_putc_user emits raw bytes (still always-mirrored,
        # bypassing the console-loglevel gate) and updates the
        # line-start tracking so a following kernel printk still gets
        # its prefix.
        i: uint64 = 0
        while i < count:
            ch: int32 = cast[int32](buf[i])
            early_putc_user(ch)
            i = i + 1
        return cast[int64](count)
    if file_idx == FD_STDIN_MARK:
        return cast[int64](EBADF)

    # initramfs is read-only.
    return cast[int64](EROFS)


def vfs_dup(oldfd: int32) -> int32:
    # Allocate the smallest free fd, copy oldfd's entry into it.
    # Pipe refcounts get bumped via copy_fd_entry, so closing oldfd
    # later doesn't affect the duplicate. Returns the new fd or
    # -EBADF / -EMFILE.
    rc: int32 = _check_fd(oldfd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    oldu: uint64 = cast[uint64](oldfd)
    if task[0].fd_idx[oldu] == FD_CLOSED_MARK:
        return EBADF
    newfd: int32 = _alloc_fd(task)
    if newfd < 0:
        return EMFILE
    # Phase 4c (socket fold): the V5 sockpair_inc_ref pre-bump is GONE.
    # A socketpair end is an FD_CHAN_MARK fd; copy_fd_entry bumps the
    # CHAN refcount (namec_chan_ref) and the chan owns the single
    # SocketPair end-reference — dup never touches end-refs anymore.
    copy_fd_entry(task, cast[uint64](newfd), task, oldu)
    return newfd


def vfs_dup2(oldfd: int32, newfd: int32) -> int32:
    # Close newfd (if open) and copy oldfd's entry into it. If
    # oldfd == newfd we do nothing — POSIX, and crucially avoids
    # the close-then-copy footgun where closing the only remaining
    # reference to oldfd's resource would free it before we copy.
    rc: int32 = _check_fd(oldfd)
    if rc != 0:
        return rc
    rc = _check_fd(newfd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    oldu: uint64 = cast[uint64](oldfd)
    newu: uint64 = cast[uint64](newfd)
    if task[0].fd_idx[oldu] == FD_CLOSED_MARK:
        return EBADF
    if oldfd == newfd:
        return newfd
    if task[0].fd_idx[newu] != FD_CLOSED_MARK:
        # Phase 4c (socket fold): the V5 sockpair_close pre-drop is
        # GONE — close_fd_in_task → namec_close runs sockpair_close in
        # its DEV_SOCKETPAIR arm on the chan's last reference.
        close_fd_in_task(task, newu)
    # Phase 4c (socket fold): the V5 sockpair_inc_ref pre-bump is GONE
    # (see vfs_dup) — copy_fd_entry's namec_chan_ref covers it.
    copy_fd_entry(task, newu, task, oldu)
    return newfd


def vfs_close(fd: int32) -> int32:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return rc
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return EBADF
    # V1: 9P fd — issue Tclunk before the slot is reclaimed. We DO
    # fall through to close_fd_in_task afterwards so the per-task
    # slot is zeroed by the same cleanup path every other backend
    # uses (otherwise dup'd FD_P9_MARK fds would double-clunk on
    # second close, since close_fd_in_task doesn't know about the
    # 9P refcounting story yet — V2 lifts that).
    # fd→Chan unification: an FD_CHAN_MARK fd's release now lives in
    # close_fd_in_task (kernel/sched/core.ad), which calls namec_close on
    # the chan id in fd_buf. That makes explicit close (this path) and
    # exit cleanup (task_exit_current → task_close_all_fds →
    # close_fd_in_task) share ONE release path — and crucially stops an
    # FD_CHAN_MARK fd held at task exit from leaking its pool chan.
    # vfs_close therefore NO LONGER calls namec_close itself: doing so
    # here AND in the close_fd_in_task fall-through would double-release
    # (double-clunk the 9P fid, double-free the pool slot). The single
    # namec_close happens in close_fd_in_task at the bottom of this fn.
    if file_idx == FD_P9_MARK:
        p9_packed: uint64 = task[0].fd_buf[fdu]
        srvfd_p9: int32 = p9c_decode_srvfd(p9_packed)
        fid_p9:   int32 = p9c_decode_fid(p9_packed)
        p9c_clunk(srvfd_p9, fid_p9)
    # Phase 4b: the FD_AUTH_MARK close arm is DELETED — /dev/auth fds
    # are FD_CHAN_MARK fds, so the slot release (devauth_close, which
    # also zeroes the pass_buf) runs in namec_close's DEV_AUTH arm on
    # the LAST reference, reached from close_fd_in_task for explicit
    # close and exit cleanup alike.
    # Phase 4f (FUSE fold, F7 #390): the V5 FD_FUSE_CONN_MARK +
    # FD_FUSE_FILE_MARK close arms are GONE — both kinds are FD_CHAN_MARK
    # fds whose namec_close DEV_FUSE_CONN / DEV_FUSE_FILE arms run
    # vfs_fuse_conn_chan_release / vfs_fuse_file_chan_release on the
    # LAST chan reference. Fixes the legacy task-exit leak: the parallel
    # arms here only ran from explicit vfs_close (close_fd_in_task knew
    # nothing of the marks), so a task that exited holding a FUSE fd
    # leaked the conn slot / orphaned the FUSE_RELEASE over the wire.
    # Phase 4e (PTY fold, F7 #390): the V5 FD_PTMX_MARK close arm is
    # GONE — a PTY fd is an FD_CHAN_MARK fd; close_fd_in_task →
    # namec_close runs vfs_ptmx_chan_release in its DEV_PTMX arm on the
    # LAST chan reference, releasing the master/slave end-ref through
    # pty_master_unref / pty_slave_unref. The legacy model needed
    # PARALLEL arms in vfs_close AND close_fd_in_task (core knew
    # nothing of FD_PTMX_MARK so a task that exited holding the fd
    # leaked the end-ref) — fixed by the chan refcount. Releasing BOTH
    # ends frees the pair slot inside u_pty.ad.
    # Phase 4c (socket fold): the V5 FD_SOCKETPAIR_MARK close arm is
    # GONE — a socketpair end is an FD_CHAN_MARK fd; close_fd_in_task →
    # namec_close runs sockpair_close in its DEV_SOCKETPAIR arm on the
    # LAST chan reference (frees the rings once both ends' refs hit 0).
    # Phase 4d (net fold, F7 #390): the V5 FD_NET_MARK close arm is
    # GONE — a /net fd is an FD_CHAN_MARK fd; close_fd_in_task →
    # namec_close runs vfs_net_chan_release in its DEV_NET arm on the
    # LAST chan reference (devnet_conn_unref for a per-conn fd; no-op
    # for an addr/dns/dns_lookup host-level fd whose pack carries
    # conn==-1). The legacy model ran this teardown on the FIRST close
    # (here, with NO mirror in close_fd_in_task — core knew nothing of
    # FD_NET_MARK), so a dup'd /net fd FIN-tore the conn while the dup
    # was still live AND a task that exited holding the fd LEAKED the
    # conn ref outright. Both fixed by the chan refcount.
    # Phase 4c (socket fold): the U-socket FD_SOCKET_MARK close arm is
    # GONE — a socket fd is an FD_CHAN_MARK fd; close_fd_in_task →
    # namec_close runs the FULL teardown (vfs_socket_chan_release: UDP
    # slot close, TLS close_notify, /net conn unref or tcp_close /
    # tcp_listen_close, usock_free) in its DEV_SOCKET arm on the LAST
    # chan reference. The legacy model ran this teardown on the FIRST
    # close (here AND in close_fd_in_task's by-name clone), so a dup'd
    # socket fd FIN'd the connection while the dup was still live —
    # fixed by the chan refcount.
    # §5: a Layer-2 async-I/O fd (epoll / eventfd / timerfd / signalfd)
    # carries an object slot in fd_buf (encoded slot+1). Release the
    # confined object in linux_abi/u_epoll.ad BEFORE close_fd_in_task
    # wipes fd_buf — core.ad knows nothing of these markers (it must
    # not; they are Layer-2-only), so the teardown happens here, the
    # exact pattern the (now-retired) FD_PTMX_MARK / FD_NET_MARK arms used.
    # NOTE: a dup'd Layer-2 fd shares the underlying object; releasing
    # on first close and letting the dup keep a dangling slot id would
    # be a use-after-free. At this scope the Linux daemons under test
    # do not dup epoll/eventfd objects, so a plain release on close is
    # correct; a refcount is the V2 hardening (flagged in the report).
    # F4 #449: same null-tolerant release dispatch as the FUSE/PTY arms.
    if file_idx == FD_EPOLL_MARK:
        if uepoll_release_hook != cast[Fn[None, int32]](0):
            uepoll_release_hook(cast[int32](task[0].fd_buf[fdu]) - 1)
    if file_idx == FD_EVENTFD_MARK:
        if uefd_release_hook != cast[Fn[None, int32]](0):
            uefd_release_hook(cast[int32](task[0].fd_buf[fdu]) - 1)
    if file_idx == FD_TIMERFD_MARK:
        if utfd_release_hook != cast[Fn[None, int32]](0):
            utfd_release_hook(cast[int32](task[0].fd_buf[fdu]) - 1)
    if file_idx == FD_SIGNALFD_MARK:
        if usfd_release_hook != cast[Fn[None, int32]](0):
            usfd_release_hook(cast[int32](task[0].fd_buf[fdu]) - 1)
    if file_idx == FD_INOTIFY_MARK:
        if uino_release_hook != cast[Fn[None, int32]](0):
            uino_release_hook(cast[int32](task[0].fd_buf[fdu]) - 1)
    # cgroup v2 control-file write fd: nothing to release on close. The
    # value is applied per-write (vfs_write FD_CGROUP_WRITE_MARK arm) and
    # the fd holds no heap state (the path lives in the recorded
    # opened-path). close_fd_in_task just zeroes the slot.
    # #155: closing a tmpfs fd posts an inotify IN_CLOSE_WRITE on its
    # parent directory. fd→Chan fold: a tmpfs fd is now an FD_CHAN_MARK
    # fd whose chan is DEV_TMPFS_FILE, so key on the chan's dev_type and
    # recover the path from its tmpfs back_slot. This fires PER CLOSE
    # (matching the legacy FD_TMPFS_MARK behaviour) and must run BEFORE
    # close_fd_in_task → namec_close, which may free the slot (so
    # tmpfs_slot_name would no longer resolve). The §memfd anon-slot
    # reclaim MOVED into namec_close's DEV_TMPFS_FILE arm: it now fires
    # only on the LAST reference (tmpfs_is_anon), fixing the old
    # release-on-first-close UAF for a dup'd / forked memfd.
    if file_idx == FD_CHAN_MARK:
        tc_cid: int32 = _fd_chan_id(task, fdu)
        if namec_chan_dev_type(tc_cid) == DEV_TMPFS_FILE:
            _vfs_inotify_notify(
                cast[Ptr[char]](tmpfs_slot_name(
                    namec_chan_back_slot(tc_cid))),
                IN_CLOSE_WRITE)
    # Phase 4b (fd→Chan): the legacy devproc_is_proc_fd close hook is
    # GONE — a /proc/<pid>/<file> fd is a stateless DEV_PROC pool chan;
    # close_fd_in_task → namec_close → _chan_free is the entire path.
    # Delegate the release pattern to kernel/sched/core.ad's
    # close_fd_in_task — same helper task_exit_current uses, so
    # explicit-close and implicit-on-exit have identical cleanup
    # (kfree procfs buffer, decrement pipe refcounts, etc).
    close_fd_in_task(task, fdu)
    return 0


def vfs_lseek(fd: int32, offset: int64, whence: int32) -> int64:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return cast[int64](rc)
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    file_idx: uint32 = task[0].fd_idx[fdu]
    if file_idx == FD_CLOSED_MARK:
        return cast[int64](EBADF)
    # Phase 4b: the FD_BLK_MARK lseek arm is DELETED — a /dev/blk fd is
    # a DEV_BLK chan; the FD_CHAN_MARK seek arm below resolves SEEK_END
    # from fd_buflen, which _open_blk_marked snapshots as the device
    # capacity (RAW) or 0 (SIZE/CTL — SEEK_END pins to 0, the legacy
    # behaviour).
    # Phase 4c (socket fold): FD_SOCKET_MARK / FD_SOCKETPAIR_MARK left
    # this EINVAL ladder — socket fds are FD_CHAN_MARK fds now and get
    # the same answer from the DEV_SOCKET / DEV_SOCKETPAIR short-circuit
    # in the Chan seek arm below.
    if file_idx == FD_STDIN_MARK or file_idx == FD_STDOUT_MARK \
            or file_idx == FD_STDERR_MARK:
        # Linux returns ESPIPE for seek on a pipe / tty / char device.
        # Return ESPIPE (not EINVAL) so stream-skipping callers (dpkg's
        # data.tar unpack, glibc fd_skip) take their read-skip fallback
        # path, which keys on errno==ESPIPE.
        # Phase 4f (FUSE fold, F7 #390): the FD_FUSE_CONN_MARK +
        # FD_FUSE_FILE_MARK arms moved into the FD_CHAN_MARK seek arm
        # below — DEV_FUSE_CONN / DEV_FUSE_FILE short-circuit there
        # (a /dev/fuse conn is stream-shaped, a FUSE-served file's
        # cursor lives in the per-token state).
        return cast[int64](ESPIPE)
    # Phase 4b (fd→Chan): the legacy devproc encoded-marker EINVAL lseek
    # arm is GONE. A /proc/<pid>/<file> fd is an FD_CHAN_MARK fd and
    # falls into the Chan seek arm below — SEEK_SET/SEEK_CUR adjust
    # fd_pos, which is harmless: devproc_read renders the whole snapshot
    # only at off==0 and reports EOF for any off>0.
    # fd→Chan fold: the FD_TMPFS_MARK / FD_FAT_MARK / FD_EXT4_MARK lseek
    # arms are GONE. A tmpfs / FAT / ext4 file fd is an FD_CHAN_MARK fd
    # and seeks through the arm below.
    if file_idx == FD_P9_MARK or file_idx == FD_CHAN_MARK:
        # Phase 4c: an `#d/<N>` fd is a DEV_DEVFD inline chan — a
        # Layer-2 alias onto a stream-shaped backing channel (console
        # or a pipe end) whose cursor lives in the per-Pgrp devfd row,
        # NOT in fd_pos. Keep the legacy stream answer (EINVAL) rather
        # than letting the generic Chan seek below pretend success:
        # glibc's _u_file_size_via_lseek probes stdout at startup and
        # must see "not seekable" for /fd/N stdio, or stdio buffering
        # misclassifies the stream as a zero-length regular file.
        # DEV_PIPE_R / DEV_PIPE_W get the same answer — a pipe has no
        # cursor (the legacy mark ladder above said EINVAL too). So do
        # DEV_SOCKET / DEV_SOCKETPAIR (Phase 4c socket fold): a socket
        # is a stream, Linux says ESPIPE, our closest is EINVAL — the
        # answer the retired mark ladder gave.
        if file_idx == FD_CHAN_MARK:
            sk_dt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
            if sk_dt == DEV_DEVFD or sk_dt == DEV_PIPE_R \
                    or sk_dt == DEV_PIPE_W \
                    or sk_dt == DEV_SOCKET \
                    or sk_dt == DEV_SOCKETPAIR \
                    or sk_dt == DEV_PTMX \
                    or sk_dt == DEV_FUSE_CONN \
                    or sk_dt == DEV_FUSE_FILE:
                # These are STREAM-shaped (pipe/socket/fifo/tty/devfd) — a
                # seek is illegal. Linux returns ESPIPE here, NOT EINVAL.
                # dpkg's data.tar unpack lseek(SEEK_CUR)-probes the stream
                # and falls back to a read-skip iff errno==ESPIPE; an
                # EINVAL made it abort ("cannot skip padding ... failed to
                # seek (Invalid argument)"), blocking every package unpack.
                return cast[int64](ESPIPE)
        # 9P / namec-Chan seek. SEEK_SET / SEEK_CUR just adjust fd_pos
        # — a subsequent vfs_read passes the new offset through to the
        # DEV_MNT mountrpc leg's Tread (an inline cdev ignores the
        # offset). FD_CHAN_MARK shares this arm because a 9P-mounted
        # Chan is seekable the same way an FD_P9_MARK fd was.
        #
        # SEEK_END: a 9P-mounted Chan would need a Tstat round-trip to
        # discover the server-side length (not wired — EINVAL), but a
        # folded on-disk file fd (DEV_EXT4_FILE / DEV_FAT_FILE) cached
        # its size in fd_buflen at open, so SEEK_END resolves locally —
        # exactly what glibc's _u_file_size_via_lseek probe needs. A
        # write-mode fd has fd_buflen==0 (size lives in the fs write
        # slot), so SEEK_END pins to the write cursor base, matching the
        # legacy FD_FAT_MARK write-fd behaviour (size=0).
        new_pos: int64 = 0
        if whence == SEEK_SET:
            new_pos = offset
        elif whence == SEEK_CUR:
            new_pos = cast[int64](task[0].fd_pos[fdu]) + offset
        elif whence == SEEK_END:
            if file_idx != FD_CHAN_MARK:
                return cast[int64](EINVAL)
            ch_dt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
            if ch_dt == DEV_TMPFS_FILE:
                # tmpfs read/write fds carry no cached fd_buflen size (a
                # tmpfs file grows under in-place writes); snapshot the
                # live size through the chan's tmpfs back_slot instead.
                tsz: uint64 = tmpfs_size(namec_chan_back_slot(
                                            _fd_chan_id(task, fdu)))
                new_pos = cast[int64](tsz) + offset
            elif ch_dt == DEV_EXT4_FILE or ch_dt == DEV_FAT_FILE \
                    or ch_dt == DEV_BUF_FILE or ch_dt == DEV_BLK:
                # Phase 4b: a snapshot (ex-FD_BUFFER_MARK) fd cached its
                # rendered length in fd_buflen at open — /proc files are
                # seekable in Linux, and SEEK_SET/CUR/END now all work
                # where the legacy mark answered a blanket EINVAL.
                # DEV_BLK rides the same resolution: _open_blk_marked
                # snapshots the device capacity into fd_buflen for a RAW
                # fd (0 for SIZE/CTL), matching the legacy FD_BLK_MARK
                # SEEK_END behaviour exactly.
                new_pos = cast[int64](task[0].fd_buflen[fdu]) + offset
            else:
                return cast[int64](EINVAL)
        else:
            return cast[int64](EINVAL)
        if new_pos < 0:
            return cast[int64](EINVAL)
        task[0].fd_pos[fdu] = cast[uint64](new_pos)
        return new_pos

    size: uint64 = initramfs_entry_size(cast[uint64](file_idx))
    new_pos: int64 = 0
    if whence == SEEK_SET:
        new_pos = offset
    elif whence == SEEK_CUR:
        new_pos = cast[int64](task[0].fd_pos[fdu]) + offset
    elif whence == SEEK_END:
        new_pos = cast[int64](size) + offset
    else:
        return cast[int64](EINVAL)

    if new_pos < 0:
        return cast[int64](EINVAL)
    task[0].fd_pos[fdu] = cast[uint64](new_pos)
    return new_pos


# --- U32: directory-fd accessors for getdents64 -----------------------
#
# getdents64() in linux_abi/u_syscalls.ad needs to walk the per-fd
# NAME\n buffer prepared by _open_dir_with(). Rather than reach into
# task_struct fields from u_syscalls.ad, expose three small accessors
# that hide the layout and the DEV_DIR_FILE chan check.

def vfs_fd_is_dir(fd: int32) -> int32:
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return 0
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    # fd→Chan fold: a directory fd is now a unified FD_CHAN_MARK fd backed
    # by a DEV_DIR_FILE pool chan. The IFDIR keying (getdents64, _u_fill_
    # stat's S_IFDIR, chdir's not-a-directory probe) all route through
    # this one accessor, so resolving the folded fd here is enough — no
    # per-call-site FD_CHAN_MARK plumbing needed.
    if task[0].fd_idx[fdu] == FD_CHAN_MARK:
        if namec_chan_dev_type(_fd_chan_id(task, fdu)) == DEV_DIR_FILE:
            return 1
        return 0
    return 0


def vfs_fd_mtime(fd: int32) -> int64:
    # Report the file's modification time (Unix epoch seconds) for the
    # stat path. Only ext4 stores a real per-inode mtime today; for
    # every other fd flavour this returns -1 and the stat handler
    # falls back to the jiffies-derived clock. Used so `stat` reports
    # a genuine mtime and make-style "is target newer than source"
    # timestamp logic works against ext4 files.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    # fd→Chan fold: an ext4 file fd is an FD_CHAN_MARK fd backed by a
    # DEV_EXT4_FILE pool chan. Recover the ext4 slot via the chan; any
    # other fd flavour has no per-inode mtime.
    if task[0].fd_idx[fdu] != FD_CHAN_MARK:
        return -1
    chdt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
    # §stat-mtime: tmpfs files now carry a STABLE stored mtime (stamped at
    # create + on each real content change, NEVER on a bare stat). Surface
    # it so two stats of an unchanged tmpfs file return the SAME mtime.
    # Without this the stat path fell back to get_jiffies()/100 — an
    # ever-advancing value — so apt re-stat'd its Packages list file on
    # `apt-get install`, saw a newer mtime than `apt-get update` had
    # recorded in pkgcache.bin, judged the index file stale, and dropped
    # it as a download source -> "Can't find a source to download version".
    if chdt == DEV_TMPFS_FILE:
        tslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
        return cast[int64](tmpfs_mtime(tslot))
    if chdt != DEV_EXT4_FILE:
        return -1
    slot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
    inum: uint32 = ext4_open_inum(slot)
    if inum == 0:
        return -1
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    return cast[int64](ext4_inode_mtime(&inode[0]))


def vfs_fd_mode(fd: int32) -> int32:
    # Report the file's low-12 permission bits (rwx + setuid/gid/sticky) for
    # the fstat path. Returns -1 if no real mode is available (caller then
    # falls back to its default).
    #
    # WHY: dpkg's helper-program resolution (findprog / command-not-found
    # check in maintscript handling) stats each PATH candidate and requires
    # S_ISREG(mode) && (mode & 0111) — i.e. the execute bit MUST be set or it
    # reports "'sh'/'rm'/'tar'/'dpkg-deb' not found in PATH or not executable"
    # and aborts. The cpio initramfs stores the REAL mode per entry (the build
    # stages /bin/sh, /bin/tar, /usr/bin/dpkg-deb, ... 0755), but _u_fill_stat
    # used to hard-code 0644, stripping every execute bit — so EVERY staged
    # Debian helper looked non-executable to dpkg. Surface the genuine cpio /
    # ext4 mode here so the execute bit survives into fstat.
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CLOSED_MARK:
        return -1
    # Regular cpio file: fd_idx is the archive index; the entry carries its
    # real mode (S_IFREG | 0755 for staged executables). Return the low-12
    # permission bits.
    if cast[uint64](fi) < cast[uint64](0xFE000000):
        m: uint64 = initramfs_entry_mode(cast[uint64](fi))
        return cast[int32](m & cast[uint64](0xFFF))
    # ext4-backed file: read the on-disk inode mode (already real rwx bits).
    if fi == FD_CHAN_MARK:
        chdt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
        if chdt == DEV_EXT4_FILE:
            eslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            einum: uint32 = ext4_open_inum(eslot)
            if einum != 0:
                einode: Array[256, uint8]
                if ext4_read_inode(cast[uint64](einum), &einode[0]) == 0:
                    return cast[int32](ext4_inode_mode(&einode[0]) \
                                       & cast[uint32](0xFFF))
        # tmpfs file (dpkg unpacks package executables into the writable
        # tmpfs overlay): no per-file stored mode, so report a permissive
        # 0755 — the unpacked /usr/bin/<prog> must be runnable, and a tmpfs
        # data file being reported executable is harmless (the content, not
        # the bit, decides whether it's a valid program).
        if chdt == DEV_TMPFS_FILE:
            return cast[int32](0o755)
    return -1


def vfs_fd_owner(fd: int32, uid_out: Ptr[uint32], gid_out: Ptr[uint32]) -> int32:
    # Report the owning uid/gid of the file behind `fd`, for the Linux-ABI
    # DAC gate (_u_dac_check_fd). Returns 0 with *uid_out/*gid_out filled
    # for backends whose owner is known, or -1 ("owner unknown") otherwise.
    #
    # The caller treats -1 as "defer" — it does NOT deny on unknown owner,
    # because those backends (tmpfs, mounted-9P distrofs) enforce their OWN
    # policy at the server boundary (tmpfs_perm_check, distrofs Topen). The
    # Linux-ABI gate exists to cover the cpio/ext4 case where a per-file
    # `#r`/`#e` bind over a different-server root makes the path-string perm
    # dispatcher (chan_permission_check) classify the file as the WRONG
    # server — there the fd's REAL backend mode/owner is authoritative.
    #
    #   cpio (#r): every entry is root-owned by build convention (the cpio
    #              header carries uid=0/gid=0); -> (0, 0).
    #   ext4:      the on-disk inode's uid/gid.
    #   else:      unknown (-1).
    rc: int32 = _check_fd(fd)
    if rc != 0:
        return -1
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    fi: uint32 = task[0].fd_idx[fdu]
    if fi == FD_CLOSED_MARK:
        return -1
    # cpio archive index: root-owned by convention.
    if cast[uint64](fi) < cast[uint64](0xFE000000):
        uid_out[0] = 0
        gid_out[0] = 0
        return 0
    if fi == FD_CHAN_MARK:
        chdt: int32 = namec_chan_dev_type(_fd_chan_id(task, fdu))
        if chdt == DEV_EXT4_FILE:
            eslot: int32 = namec_chan_back_slot(_fd_chan_id(task, fdu))
            einum: uint32 = ext4_open_inum(eslot)
            if einum != 0:
                e_mode: uint16 = 0
                if ext4_inode_owner_at(einum, uid_out, gid_out,
                                       &e_mode) == 0:
                    return 0
    return -1


def vfs_fd_dir_buf(fd: int32) -> uint64:
    # fd→Chan fold: a dir fd's "NAME\n" buffer lives in the pool chan's
    # back_ptr (fd_buf holds the opaque chan id, NOT the buffer). Callers
    # gate on vfs_fd_is_dir() first, so a non-chan fd never reaches the
    # recovery; return 0 for anything else (Phase 4b: FD_DIR_MARK is gone).
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] == FD_CHAN_MARK:
        return namec_chan_back_ptr(_fd_chan_id(task, fdu))
    return 0


def vfs_fd_dir_buflen(fd: int32) -> uint64:
    # fd→Chan fold: a dir fd's listing length is the chan's back_slot
    # (fd_buflen is 0 for a folded fd). back_slot is stored as an int32
    # byte length; widen it through uint32 so it never sign-extends.
    # Phase 4b: FD_DIR_MARK is gone — non-chan fds report 0.
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    fdu: uint64 = cast[uint64](fd)
    if task[0].fd_idx[fdu] == FD_CHAN_MARK:
        return cast[uint64](cast[uint32](
            namec_chan_back_slot(_fd_chan_id(task, fdu))))
    return 0


def vfs_fd_dir_pos(fd: int32) -> uint64:
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    return task[0].fd_pos[cast[uint64](fd)]


def vfs_fd_dir_set_pos(fd: int32, pos: uint64):
    task: Ptr[TaskStruct] = fd_owner_task(current_task())
    task[0].fd_pos[cast[uint64](fd)] = pos


# --- distrofs persistent backing store: REMOVED -------------------
#
# The SYS_DFS_LOAD / SYS_DFS_SAVE private kernel backing channel for
# user/distrofs.ad's snapshot lived here (vfs_distrofs_save/load +
# the kernel-owned "distrofsN.dat" name). It bypassed the namespace:
# a userland file server persisting through a magic syscall instead
# of a file. distrofs now opens a REAL backing file through its own
# namespace ("#part0/distrofs<inst>.dat" by default — byte-identical
# location to the old kernel blob, so old snapshots import cleanly)
# and gets the durability barrier from the /dev/sync cdev
# (sys/src/9/port/namec.ad -> ext4_fsync). Syscall numbers 283/284
# are retired, never to be reused.


# --- tmpfs symlink + hard-link self-test ----------------------------
#
# Driven by /etc/tmpfs-link-test (planted by scripts/build_initramfs.py
# under ENABLE_TMPFS_LINK_TEST=1). init/main.ad's boot:37.tln hook scans
# for the marker and calls tmpfs_link_selftest(). It exercises the full
# RAM-backed link contract added to fs/tmpfs.ad:
#   1. create a tmpfs file with known contents;
#   2. create a tmpfs SYMLINK to it and verify opening the symlink reads
#      the file's contents (resolver-follow through _open_tmpfs_read);
#   3. create a tmpfs HARD LINK and verify both names read the same data;
#   4. unlink one hard-link name and verify the other still reads the
#      data (link-count > 0 keeps the storage alive);
#   5. unlink the last name and verify it is gone (storage freed).
# Prints [TMPFS_LINK] PASS on success or [TMPFS_LINK] FAIL ... on any
# mismatch, at EMERG level so the marker always reaches the console.

_TLINK_BODY: Array[16, uint8]
_TLINK_RBUF: Array[64, uint8]


def _tlink_emerg(msg: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(msg)


def _tlink_read_all(path: Ptr[char], out: Ptr[uint8],
                    cap: uint64) -> int64:
    # Open `path` for read (following any symlink), read up to `cap`
    # bytes into `out`, close. Returns bytes read, or a negative open/
    # read error. Used to verify a name reads the expected contents.
    fd: int32 = vfs_open(path)
    if fd < 0:
        return cast[int64](fd)
    n: int64 = vfs_read(fd, out, cap)
    vfs_close(fd)
    return n


def _tlink_body_matches(out: Ptr[uint8], n: int64) -> int32:
    # 1 if `out[0..n)` equals the 6-byte known body, else 0.
    if n != 6:
        return 0
    i: uint64 = 0
    while i < 6:
        if out[i] != _TLINK_BODY[i]:
            return 0
        i = i + 1
    return 1


def tmpfs_link_selftest() -> int32:
    # Boot-task fd-table priming: like fstat_backend_selftest, this runs
    # from the kernel-init task whose fd table is still all-zero .bss, so
    # every fd_idx slot reads as 0 ("cpio index 0"), not FD_CLOSED_MARK,
    # and _alloc_fd would report EMFILE on the first open. Snapshot slots
    # 3..15 (0..2 are the std streams) to FD_CLOSED_MARK, run the test,
    # then restore. The selftest opens/closes its fds in matched pairs so
    # the table is clean by the time we restore anyway, but snapshot +
    # restore keeps the boot task's later use of stdio untouched.
    seltask: Ptr[TaskStruct] = fd_owner_task(current_task())
    saved: Array[16, uint32]
    fclr: uint64 = 3
    while fclr < 16:
        saved[fclr] = seltask[0].fd_idx[fclr]
        seltask[0].fd_idx[fclr] = FD_CLOSED_MARK
        fclr = fclr + 1

    rc: int32 = _tmpfs_link_selftest_body()

    # Restore the boot task's fd slots.
    frst: uint64 = 3
    while frst < 16:
        seltask[0].fd_idx[frst] = saved[frst]
        frst = frst + 1
    return rc


def _tmpfs_link_selftest_body() -> int32:
    # Known 6-byte payload "LINK!\n".
    _TLINK_BODY[0] = 76     # 'L'
    _TLINK_BODY[1] = 73     # 'I'
    _TLINK_BODY[2] = 78     # 'N'
    _TLINK_BODY[3] = 75     # 'K'
    _TLINK_BODY[4] = 33     # '!'
    _TLINK_BODY[5] = 10     # '\n'
    want: uint64 = 6

    file_path: Ptr[char] = "/tmp/link-orig"
    sym_path:  Ptr[char] = "/tmp/link-sym"
    h1_path:   Ptr[char] = "/tmp/link-h1"
    h2_path:   Ptr[char] = "/tmp/link-h2"

    # (1) Create the original file with the known contents.
    wfd: int32 = vfs_open_write(file_path)
    if wfd < 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: open_write /tmp/link-orig\n")
        return -1
    wn: int64 = vfs_write(wfd, &_TLINK_BODY[0], want)
    vfs_close(wfd)
    if wn != cast[int64](want):
        _tlink_emerg("[TMPFS_LINK] FAIL: short write to original\n")
        return -1
    on: int64 = _tlink_read_all(file_path, &_TLINK_RBUF[0], 64)
    if _tlink_body_matches(&_TLINK_RBUF[0], on) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: original read-back mismatch\n")
        return -1

    # (2) Symlink → original; opening the symlink must read the file.
    sr: int32 = vfs_symlink(file_path, sym_path)
    if sr != 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: vfs_symlink returned nonzero\n")
        return -1
    if tmpfs_path_is_symlink(sym_path) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: symlink slot not SYMLINK-kind\n")
        return -1
    sn: int64 = _tlink_read_all(sym_path, &_TLINK_RBUF[0], 64)
    if _tlink_body_matches(&_TLINK_RBUF[0], sn) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: symlink-follow read mismatch\n")
        return -1

    # (3) Hard link → original; both names must read the same data.
    hr: int32 = vfs_link(file_path, h1_path)
    if hr != 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: vfs_link (h1) returned nonzero\n")
        return -1
    h1n: int64 = _tlink_read_all(h1_path, &_TLINK_RBUF[0], 64)
    if _tlink_body_matches(&_TLINK_RBUF[0], h1n) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: hardlink h1 read mismatch\n")
        return -1
    # A second hard link, so we can prove link-count survives one unlink.
    hr2: int32 = vfs_link(h1_path, h2_path)
    if hr2 != 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: vfs_link (h2) returned nonzero\n")
        return -1
    h2n: int64 = _tlink_read_all(h2_path, &_TLINK_RBUF[0], 64)
    if _tlink_body_matches(&_TLINK_RBUF[0], h2n) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: hardlink h2 read mismatch\n")
        return -1

    # (4) Unlink the ORIGINAL (canonical) name. The two hard links must
    # still read the data — storage stays alive while nlink > 0, and the
    # canonical data slot is promoted to a surviving alias.
    ur: int32 = vfs_unlink(file_path)
    if ur != 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: unlink original returned nonzero\n")
        return -1
    if vfs_open(file_path) >= 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: original still openable post-unlink\n")
        return -1
    a1: int64 = _tlink_read_all(h1_path, &_TLINK_RBUF[0], 64)
    if _tlink_body_matches(&_TLINK_RBUF[0], a1) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: h1 read mismatch after unlink\n")
        return -1
    a2: int64 = _tlink_read_all(h2_path, &_TLINK_RBUF[0], 64)
    if _tlink_body_matches(&_TLINK_RBUF[0], a2) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: h2 read mismatch after unlink\n")
        return -1

    # Unlink one hard-link name; the other must still read the data.
    u1: int32 = vfs_unlink(h1_path)
    if u1 != 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: unlink h1 returned nonzero\n")
        return -1
    b2: int64 = _tlink_read_all(h2_path, &_TLINK_RBUF[0], 64)
    if _tlink_body_matches(&_TLINK_RBUF[0], b2) == 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: h2 read mismatch after h1 unlink\n")
        return -1

    # (5) Unlink the LAST name; the file must be gone.
    u2: int32 = vfs_unlink(h2_path)
    if u2 != 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: unlink h2 returned nonzero\n")
        return -1
    if vfs_open(h2_path) >= 0:
        _tlink_emerg("[TMPFS_LINK] FAIL: h2 still openable after last unlink\n")
        return -1

    # Tidy up the symlink (it still points at the now-gone original;
    # removing it leaves tmpfs clean for the rest of boot).
    vfs_unlink(sym_path)

    _tlink_emerg("[TMPFS_LINK] PASS\n")
    return 0


# -------------------------------------------------------------------
# cgroup v2 (/sys/fs/cgroup) end-to-end self-test.
#
# Drives the REAL open()/read() VFS path (vfs_open -> is_cgroup_path
# -> _open_cgroup -> FD_BUFFER_MARK read) rather than calling the
# renderer directly, so it proves the full Linux-namespace dispatch
# wiring works, not just the text generation. Gated on the cpio marker
# /etc/cgroup2-test (scripts/test_cgroup2.sh). Prints [CGROUP2] PASS /
# [CGROUP2] FAIL ... at EMERG level so the marker reaches the console.

_CG2_RBUF: Array[4096, uint8]


def _cg2_emerg(msg: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(msg)


def _cg2_read_all(path: Ptr[char], out: Ptr[uint8], cap: uint64) -> int64:
    # Open `path`, read up to `cap` bytes, close. Returns bytes read,
    # or a negative open/read error.
    fd: int32 = vfs_open(path)
    if fd < 0:
        return cast[int64](fd)
    n: int64 = vfs_read(fd, out, cap)
    vfs_close(fd)
    return n


def _cg2_buf_contains(buf: Ptr[uint8], n: int64, needle: Ptr[uint8]) -> int32:
    # 1 iff the NUL-terminated `needle` appears within buf[0..n).
    if n <= 0:
        return 0
    nn: uint64 = cast[uint64](n)
    nlen: uint64 = 0
    while needle[nlen] != 0:
        nlen = nlen + 1
    if nlen == 0:
        return 1
    if nlen > nn:
        return 0
    i: uint64 = 0
    last: uint64 = nn - nlen
    while i <= last:
        j: uint64 = 0
        ok: int32 = 1
        while j < nlen:
            if buf[i + j] != needle[j]:
                ok = 0
                j = nlen
            else:
                j = j + 1
        if ok == 1:
            return 1
        i = i + 1
    return 0


def _cg2_buf_has_digit(buf: Ptr[uint8], n: int64) -> int32:
    # 1 iff buf[0..n) contains an ASCII decimal digit (so a value
    # "parses as a number"). Used for memory.current / cgroup.procs /
    # pids.current.
    if n <= 0:
        return 0
    i: uint64 = 0
    nn: uint64 = cast[uint64](n)
    while i < nn:
        c: uint8 = buf[i]
        if c >= 48 and c <= 57:
            return 1
        i = i + 1
    return 0


def cgroup2_vfs_selftest() -> int32:
    # Same boot-task fd-table priming as tmpfs_link_selftest: the
    # kernel-init task's fd table is all-zero .bss, so slots read as
    # "cpio index 0" rather than FD_CLOSED_MARK and _alloc_fd would
    # EMFILE. Snapshot 3..15, run the body, restore.
    seltask: Ptr[TaskStruct] = fd_owner_task(current_task())
    saved: Array[16, uint32]
    fclr: uint64 = 3
    while fclr < 16:
        saved[fclr] = seltask[0].fd_idx[fclr]
        seltask[0].fd_idx[fclr] = FD_CLOSED_MARK
        fclr = fclr + 1

    rc: int32 = _cgroup2_vfs_selftest_body()

    frst: uint64 = 3
    while frst < 16:
        seltask[0].fd_idx[frst] = saved[frst]
        frst = frst + 1
    return rc


def _cgroup2_vfs_selftest_body() -> int32:
    # (1) cgroup.controllers must list "memory" and "pids".
    cn: int64 = _cg2_read_all("/sys/fs/cgroup/cgroup.controllers",
                              &_CG2_RBUF[0], 4096)
    if cn <= 0:
        _cg2_emerg("[CGROUP2] FAIL: open/read cgroup.controllers\n")
        return -1
    if _cg2_buf_contains(&_CG2_RBUF[0], cn, "memory") == 0:
        _cg2_emerg("[CGROUP2] FAIL: cgroup.controllers missing 'memory'\n")
        return -1
    if _cg2_buf_contains(&_CG2_RBUF[0], cn, "pids") == 0:
        _cg2_emerg("[CGROUP2] FAIL: cgroup.controllers missing 'pids'\n")
        return -1

    # (2) cgroup.procs must be non-empty and contain a pid (a digit).
    pn: int64 = _cg2_read_all("/sys/fs/cgroup/cgroup.procs",
                              &_CG2_RBUF[0], 4096)
    if pn <= 0:
        _cg2_emerg("[CGROUP2] FAIL: open/read cgroup.procs\n")
        return -1
    if _cg2_buf_has_digit(&_CG2_RBUF[0], pn) == 0:
        _cg2_emerg("[CGROUP2] FAIL: cgroup.procs has no pid\n")
        return -1

    # (3) memory.current must parse as a number.
    mn: int64 = _cg2_read_all("/sys/fs/cgroup/memory.current",
                              &_CG2_RBUF[0], 4096)
    if mn <= 0:
        _cg2_emerg("[CGROUP2] FAIL: open/read memory.current\n")
        return -1
    if _cg2_buf_has_digit(&_CG2_RBUF[0], mn) == 0:
        _cg2_emerg("[CGROUP2] FAIL: memory.current not numeric\n")
        return -1

    # (4) pids.max must read the literal "max" (uncapped root).
    xn: int64 = _cg2_read_all("/sys/fs/cgroup/pids.max",
                              &_CG2_RBUF[0], 4096)
    if xn <= 0:
        _cg2_emerg("[CGROUP2] FAIL: open/read pids.max\n")
        return -1
    if _cg2_buf_contains(&_CG2_RBUF[0], xn, "max") == 0:
        _cg2_emerg("[CGROUP2] FAIL: pids.max not 'max'\n")
        return -1

    # (5) cgroup.type must read "domain".
    tn: int64 = _cg2_read_all("/sys/fs/cgroup/cgroup.type",
                              &_CG2_RBUF[0], 4096)
    if tn <= 0:
        _cg2_emerg("[CGROUP2] FAIL: open/read cgroup.type\n")
        return -1
    if _cg2_buf_contains(&_CG2_RBUF[0], tn, "domain") == 0:
        _cg2_emerg("[CGROUP2] FAIL: cgroup.type not 'domain'\n")
        return -1

    _cg2_emerg("[CGROUP2] PASS\n")
    return 0


# /sys/devices/system/node/ (NUMA node sysfs) end-to-end self-test.
#
# Drives the REAL open()/read() VFS path (vfs_open -> is_node_path ->
# _open_node -> FD_BUFFER_MARK read), proving the render-on-open wiring for the
# NUMA-node sysfs works, not just the text generation. Called from init/main.ad
# right after mempolicy_selftest under the boot:37.mempolicy gate. Reuses the
# cgroup2 fd-priming + read helpers. Returns 1 on success, 0 on failure, and
# prints [MEMPOLICY] PASS/FAIL markers at EMERG level so they reach the console.

def node_sysfs_vfs_selftest() -> int32:
    # Prime the boot task's fd table the same way cgroup2_vfs_selftest does:
    # the kernel-init task's fd table is all-zero .bss, so slots read as "cpio
    # index 0" rather than FD_CLOSED_MARK and _alloc_fd would EMFILE. Snapshot
    # 3..15, run the body, restore.
    seltask: Ptr[TaskStruct] = fd_owner_task(current_task())
    saved: Array[16, uint32]
    fclr: uint64 = 3
    while fclr < 16:
        saved[fclr] = seltask[0].fd_idx[fclr]
        seltask[0].fd_idx[fclr] = FD_CLOSED_MARK
        fclr = fclr + 1

    rc: int32 = _node_sysfs_vfs_selftest_body()

    frst: uint64 = 3
    while frst < 16:
        seltask[0].fd_idx[frst] = saved[frst]
        frst = frst + 1
    return rc


def _node_sysfs_vfs_selftest_body() -> int32:
    # (1) /sys/devices/system/node/online must read "0".
    on: int64 = _cg2_read_all("/sys/devices/system/node/online",
                              &_CG2_RBUF[0], 4096)
    if on <= 0:
        _cg2_emerg("[MEMPOLICY] FAIL: open/read node/online\n")
        return 0
    if _CG2_RBUF[0] != cast[uint8](48):              # ASCII '0'
        _cg2_emerg("[MEMPOLICY] FAIL: node/online not '0'\n")
        return 0
    # (2) /sys/devices/system/node/node0/meminfo must contain "MemTotal".
    mn: int64 = _cg2_read_all("/sys/devices/system/node/node0/meminfo",
                              &_CG2_RBUF[0], 4096)
    if mn <= 0:
        _cg2_emerg("[MEMPOLICY] FAIL: open/read node0/meminfo\n")
        return 0
    if _cg2_buf_contains(&_CG2_RBUF[0], mn, "MemTotal") == 0:
        _cg2_emerg("[MEMPOLICY] FAIL: node0/meminfo missing MemTotal\n")
        return 0
    _cg2_emerg("[MEMPOLICY] PASS /sys/.../node/online == '0' (VFS path)\n")
    return 1

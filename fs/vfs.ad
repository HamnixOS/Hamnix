    NET_PROTO_TCP, NET_PROTO_UDP,
    NET_FILE_CLONE, NET_FILE_CTL, NET_FILE_DATA,
    NET_FILE_STATUS, NET_FILE_LOCAL, NET_FILE_REMOTE,
    NET_FILE_ADDR,
    # F2 #447: host-level Plan-9-shape config + DNS lookup files.
    NET_FILE_DNS, NET_FILE_IPIFC_CTL,
    NET_FILE_DNS_LOOKUP, NET_FILE_DNS_RLOOKUP,
    devnet_dns_read, devnet_dns_write,
    devnet_ipifc_ctl_write,
    devnet_dns_lookup_write, devnet_dns_rlookup_write,
    devnet_dns_result_read,
    NETPATH_MISS, NETPATH_DIR, NETPATH_FILE,
    devnet_path_classify, devnet_clone, devnet_conn_ref,
    devnet_conn_unref, devnet_ctl,
    devnet_data_read, devnet_data_read_nb, devnet_data_write,
    devnet_data_pending, devnet_data_at_eof,
    devnet_conn_is_tls,
    devnet_status_render, devnet_local_render, devnet_remote_render,
    devnet_addr_render,
    devnet_pack, devnet_unpack_file, devnet_unpack_proto,
    devnet_unpack_conn, devnet_conn_proto,
    devnet_accept_take, devnet_accept_pending,
    devnet_listdir,
    NET_CTL_OK,
    # F10-2 #455: server-boundary perm policy lives in the server file.
    # devnet admits world-r on everything, world-w on per-conn surfaces
    # (sockets are user-level), hostowner-w on host-level config
    # (/net/dns server pin, /net/ipifc/ctl, /net/addr).
    devnet_perm_check,
)
# F10-5 #460: audio's server-boundary perm body lives WITH the audio
# server. Imported here only for the chan_permission_check dispatch arm
# (SERVER_AUDIO). Mirrors the devblk/devnet/devauth pattern.
from drivers.audio.audio_cdev import devaudio_perm_check
# §5 Layer-2 async I/O: eventfd / timerfd / signalfd fds tagged with the
# FD_*_MARK markers below route their read/write back into the confined
# Layer-2 object pools in linux_abi/u_epoll.ad. epoll fds are NOT
# readable/writable — epoll_wait drives them via the u_syscalls.ad shim,
# never through vfs_read. The signalfd read arm needs the caller's
# pending-signal word, which u_syscalls.ad supplies; vfs_read just
# reports it has no data (the shim handles it).
#
# F4 #449 leaf inversion: the static `from linux_abi.u_epoll import …`
# line is gone. The five FD_*_MARK constants + IN_* event mask constants
# are REDEFINED natively below (same values u_epoll.ad used so the wire
# meaning is unchanged); u_epoll.ad and u_syscalls.ad import them back
# from this module. Pool ops (uefd_/utfd_/usfd_/uino_/uepoll_) are
# dispatched through the per-kind function pointers planted by
# epoll_family_ops_init() at boot.

# §fuse: the Linux-ABI /dev/fuse char device + FUSE wire protocol
# (linux_abi/u_fuse.ad). A daemon opens /dev/fuse -> a connection fd
# (FD_FUSE_CONN_MARK), mounts a target prefix, and serves a filesystem the
# VFS reads through over the genuine fuse_in/fuse_out header protocol. A
# path under a fuse mount opens to an FD_FUSE_FILE_MARK fd whose fd_buf
# carries the open-file token; vfs_read/close drive FUSE_READ / FUSE_RELEASE.
#
# F4 #449 leaf inversion: the static `from linux_abi.u_fuse import …`
# line is gone. The two FD_FUSE_*_MARK constants are REDEFINED natively
# below (same values u_fuse.ad used; u_fuse.ad imports them back). The
# dev/mount/file ops are dispatched through the per-kind function
# pointers planted by fuse_ops_init() at boot.


# =====================================================================
# inotify notification hook (#155)
# =====================================================================
#
# inotify (a Layer-2 / Linux-ABI object — its pools live in
# linux_abi/u_epoll.ad) needs the filesystem to tell it when a watched
# directory sees a create / delete / modify. vfs.ad (Layer 0/1) must NOT
# statically depend on the Layer-2 inotify pool — so the dependency is
# inverted exactly like kernel/sched/core.ad's `cleartid_wake_hook`:
# u_syscalls.ad registers its `uino_post` routine here at bring-up, and
# the vfs create/unlink/write/close arms call it through this pointer.
# A pure native (no Linux-ABI) build leaves the hook null and the
# notify calls are inert.
#
# Signature: (dir_path: Ptr[uint8], name: Ptr[uint8], mask: uint32).
# `dir_path` is the absolute directory the event happened in; `name` is
# the basename of the affected entry; `mask` is one IN_* bit.
inotify_notify_hook: Fn[None, Ptr[uint8], Ptr[uint8], uint32]


def register_inotify_notify_hook(
        hook: Fn[None, Ptr[uint8], Ptr[uint8], uint32]):
    # Called once from linux_abi/u_syscalls.ad's bring-up. After this,
    # vfs's create/delete/modify arms route events to the inotify pool.
    inotify_notify_hook = hook


def _vfs_inotify_notify(abs_path: Ptr[char], mask: uint32):
    # Split an absolute file path into (dir, basename) and fire the
    # inotify hook (if registered). Used by the create/unlink/modify/
    # close arms. Pure string work — no Layer-2 import.
    if inotify_notify_hook == cast[Fn[None, Ptr[uint8], Ptr[uint8],
                                       uint32]](0):
        return
    p: Ptr[uint8] = cast[Ptr[uint8]](abs_path)
    # Find the last '/'.
    last: int64 = -1
    i: uint64 = 0
    while i < 256:
        c: uint8 = p[i]
        if c == 0:
            break
        if c == 47:                                  # '/'
            last = cast[int64](i)
        i = i + 1
    dir_buf: Array[256, uint8]
    name_buf: Array[64, uint8]
    if last < 0:
        # No slash: treat the whole thing as a basename in ".".
        dir_buf[0] = 46                              # '.'
        dir_buf[1] = 0
        _vfs_ino_copy_name(&name_buf[0], p, 0)
    else:
        lu: uint64 = cast[uint64](last)
        # Directory = everything before the last slash. A leading-slash-
        # only path ("/foo") has dir == "/".
        if lu == 0:
            dir_buf[0] = 47                          # '/'
            dir_buf[1] = 0
        else:
            j: uint64 = 0
            while j < lu and j < 255:
                dir_buf[j] = p[j]
                j = j + 1
            dir_buf[j] = 0
        _vfs_ino_copy_name(&name_buf[0], p, lu + 1)
    inotify_notify_hook(&dir_buf[0], &name_buf[0], mask)


def _vfs_ino_copy_name(dst: Ptr[uint8], src: Ptr[uint8], start: uint64):
    # Copy the NUL-terminated basename starting at src[start] into dst
    # (cap 64 incl NUL).
    i: uint64 = 0
    while i < 63:
        c: uint8 = src[start + i]
        dst[i] = c
        if c == 0:
            return
        i = i + 1
    dst[63] = 0


# =====================================================================
# F4 #449 leaf inversion: Layer-2 fd kind constants + per-op hooks
# =====================================================================
#
# All of these used to be imported from linux_abi/u_pty.ad, u_epoll.ad,
# and u_fuse.ad. The static imports made vfs.ad a Layer-1 consumer of
# Layer-2 symbols — a leaf violation. F4 inverts the direction: the
# constants are declared natively here (with the same wire values the
# Layer-2 modules used), and each Layer-2 module registers its operation
# implementations through the register_*_hook entry points below at
# bring-up. linux_abi/u_pty.ad, u_epoll.ad and u_fuse.ad import the
# FD_*_MARK constants BACK from this module so the marker values stay
# single-sourced and the import graph is acyclic.
#
# A pure-native build (no Linux ABI linked) leaves every hook null. The
# vfs_read/write/close/poll arms below check each hook before calling,
# so an unregistered Layer-2 kind simply has no effect — the right
# behaviour, because no fd of that kind can exist in a build without
# the registering shim.

# --- FD marker constants --------------------------------------------
# Values match linux_abi/u_pty.ad, u_epoll.ad, and u_fuse.ad. Kept here
# so vfs.ad's dispatch arms compile without a linux_abi import.
FD_PTMX_MARK:         uint32 = 0xFFFFFFCA
# cgroup v2 control-file write fd. A `> /sys/fs/cgroup/<g>/pids.max`
# (etc.) open installs this mark; fd_buf carries a kmalloc'd copy of the
# resolved control-file path. vfs_write dispatches the bytes into the
# live cgroup object (cgroup_fs_write / cgroup_fs_attach); vfs_close
# kfrees the path. Plan 9 shape: the write reaches the object via the
# cgroupfs server's write handler, no new syscall.
FD_CGROUP_WRITE_MARK: uint32 = 0xFFFFFFCB
FD_FUSE_CONN_MARK:    uint32 = 0xFFFFFFC9
FD_FUSE_FILE_MARK:    uint32 = 0xFFFFFFC8
FD_EPOLL_MARK:        uint32 = 0xFFFFFFD7
FD_EVENTFD_MARK:      uint32 = 0xFFFFFFD6
FD_TIMERFD_MARK:      uint32 = 0xFFFFFFD5
FD_SIGNALFD_MARK:     uint32 = 0xFFFFFFD4
FD_INOTIFY_MARK:      uint32 = 0xFFFFFFD3

# --- inotify event-mask bits ----------------------------------------
# Used by vfs's create/delete/modify/close-write notify posts (which
# fire through inotify_notify_hook above). Single-sourced here so the
# notify call sites don't need a linux_abi import.
IN_MODIFY:      uint32 = 0x00000002
IN_CLOSE_WRITE: uint32 = 0x00000008
IN_CREATE:      uint32 = 0x00000100
IN_DELETE:      uint32 = 0x00000200

# --- /dev/ptmx + /dev/pts/<N> + /dev/fuse + /sys/fs/cgroup path open hook ---
# F9 #452 tagged the four `is_<x>_path` / `_path_eq_const` literal arms
# in vfs_open / vfs_open_write as DEFERRED-to-F4. F4's plan: replace
# them with one shim-registered path-handler dispatcher. linux_abi/init
# plants a single function pointer here at boot; the vfs_open*'s pre-
# namec branch invokes it once. The dispatcher returns:
#
#   *  >= 0          : an opened fd; vfs_open returns it.
#   *  L2_PATH_NOT_HANDLED : the path is not owned by any Layer-2 handler;
#                     vfs_open falls through to namec / on-disk arms.
#   *  any other negative : an opened-but-failed -errno; vfs_open returns it.
#
# accmode encoding mirrors _u_open's mode: 0 = OREAD, 1 = OWRITE, else
# OREAD by default (the legacy ptmx OWRITE arm is the only consumer).
L2_PATH_NOT_HANDLED: int32 = -32768

l2_path_open_hook: Fn[int32, Ptr[char], int32]


def register_l2_path_open_hook(hook: Fn[int32, Ptr[char], int32]):
    # linux_abi/init.ad calls this once. The vfs_open / vfs_open_write
    # pre-namec arm then routes /dev/ptmx, /dev/pts/<N>, /dev/fuse, and
    # /sys/fs/cgroup paths into linux_abi without a static import.
    l2_path_open_hook = hook


# --- FD_PTMX_MARK ops (linux_abi/u_pty.ad) ---------------------------
pty_alloc_pair_hook:   Fn[int32]
pty_slave_open_hook:   Fn[int32, int32]
pty_master_unref_hook: Fn[None, int32]
pty_slave_unref_hook:  Fn[None, int32]
pty_master_read_hook:  Fn[int64, int32, Ptr[uint8], uint64]
pty_slave_read_hook:   Fn[int64, int32, Ptr[uint8], uint64]
pty_master_write_hook: Fn[int64, int32, Ptr[uint8], uint64]
pty_slave_write_hook:  Fn[int64, int32, Ptr[uint8], uint64]
# QA-N31: non-destructive readiness predicates for poll(2)/epoll/waitfds on
# a pty end. pty_master_readable(slot)=1 iff the s2m (slave->master output)
# queue has bytes; pty_slave_readable(slot)=1 iff the m2s (master->slave
# input) queue has bytes. Null in a pure-native build (no DEV_PTMX chan can
# exist), guarded at every call site.
pty_master_readable_hook: Fn[int32, int32]
pty_slave_readable_hook:  Fn[int32, int32]


def register_pty_ops_hook(
        alloc_pair_op:   Fn[int32],
        slave_open_op:   Fn[int32, int32],
        master_unref_op: Fn[None, int32],
        slave_unref_op:  Fn[None, int32],
        master_read_op:  Fn[int64, int32, Ptr[uint8], uint64],
        slave_read_op:   Fn[int64, int32, Ptr[uint8], uint64],
        master_write_op: Fn[int64, int32, Ptr[uint8], uint64],
        slave_write_op:  Fn[int64, int32, Ptr[uint8], uint64],
        master_readable_op: Fn[int32, int32],
        slave_readable_op:  Fn[int32, int32]):
    pty_alloc_pair_hook   = alloc_pair_op
    pty_slave_open_hook   = slave_open_op
    pty_master_unref_hook = master_unref_op
    pty_slave_unref_hook  = slave_unref_op
    pty_master_read_hook  = master_read_op
    pty_slave_read_hook   = slave_read_op
    pty_master_write_hook = master_write_op
    pty_slave_write_hook  = slave_write_op
    pty_master_readable_hook = master_readable_op
    pty_slave_readable_hook  = slave_readable_op


# --- FD_FUSE_*_MARK ops (linux_abi/u_fuse.ad) ------------------------
fuse_dev_open_hook:     Fn[int32]
fuse_dev_read_hook:     Fn[int64, int32, uint64, uint64]
fuse_dev_write_hook:    Fn[int64, int32, uint64, uint64]
fuse_dev_close_hook:    Fn[None, int32]
fuse_mount_match_hook:  Fn[int32, Ptr[char]]
fuse_vfs_open_hook:     Fn[int64, Ptr[char]]
fuse_vfs_read_hook:     Fn[int64, int32, Ptr[uint8], uint64]
fuse_vfs_close_hook:    Fn[None, int32]


def register_fuse_ops_hook(
        dev_open_op:     Fn[int32],
        dev_read_op:     Fn[int64, int32, uint64, uint64],
        dev_write_op:    Fn[int64, int32, uint64, uint64],
        dev_close_op:    Fn[None, int32],
        mount_match_op:  Fn[int32, Ptr[char]],
        vfs_open_op:     Fn[int64, Ptr[char]],
        vfs_read_op:     Fn[int64, int32, Ptr[uint8], uint64],
        vfs_close_op:    Fn[None, int32]):
    fuse_dev_open_hook    = dev_open_op
    fuse_dev_read_hook    = dev_read_op
    fuse_dev_write_hook   = dev_write_op
    fuse_dev_close_hook   = dev_close_op
    fuse_mount_match_hook = mount_match_op
    fuse_vfs_open_hook    = vfs_open_op
    fuse_vfs_read_hook    = vfs_read_op
    fuse_vfs_close_hook   = vfs_close_op


# --- FD_*_MARK epoll/eventfd/timerfd/signalfd/inotify ops
#     (linux_abi/u_epoll.ad) -----------------------------------------
uefd_release_hook:   Fn[None, int32]
uefd_readable_hook:  Fn[int32, int32]
uefd_read_hook:      Fn[int64, int32]
uefd_write_hook:     Fn[int64, int32, uint64]
utfd_release_hook:   Fn[None, int32]
utfd_readable_hook:  Fn[int32, int32]
utfd_read_hook:      Fn[int64, int32]
usfd_release_hook:   Fn[None, int32]
uino_release_hook:   Fn[None, int32]
uino_readable_hook:  Fn[int32, int32]
uepoll_release_hook: Fn[None, int32]


def register_epoll_family_ops_hook(
        eventfd_release_op:  Fn[None, int32],
        eventfd_readable_op: Fn[int32, int32],
        eventfd_read_op:     Fn[int64, int32],
        eventfd_write_op:    Fn[int64, int32, uint64],
        timerfd_release_op:  Fn[None, int32],
        timerfd_readable_op: Fn[int32, int32],
        timerfd_read_op:     Fn[int64, int32],
        signalfd_release_op: Fn[None, int32],
        inotify_release_op:  Fn[None, int32],
        inotify_readable_op: Fn[int32, int32],
        epoll_release_op:    Fn[None, int32]):
    uefd_release_hook   = eventfd_release_op
    uefd_readable_hook  = eventfd_readable_op
    uefd_read_hook      = eventfd_read_op
    uefd_write_hook     = eventfd_write_op
    utfd_release_hook   = timerfd_release_op
    utfd_readable_hook  = timerfd_readable_op
    utfd_read_hook      = timerfd_read_op
    usfd_release_hook   = signalfd_release_op
    uino_release_hook   = inotify_release_op
    uino_readable_hook  = inotify_readable_op
    uepoll_release_hook = epoll_release_op


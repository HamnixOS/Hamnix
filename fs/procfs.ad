# /proc/mounts (real): the calling task's per-process namespace mount
# table lives in its Pgrp mtab. chan.ad already renders that mtab as
# ns(1)-shape text (pgrp_render_ns) and counts live entries
# (mnttab_entry_count). render_mounts() calls those and re-shapes the
# ns(1) lines into the Linux 6-field /proc/mounts form. mnttab_bind is
# called only by the boot self-test below to prove a runtime bind
# shows up in the rendered table.
from sys.src.port9.port.chan import (
    pgrp_current, pgrp_render_ns, mnttab_entry_count, mnttab_bind,
)

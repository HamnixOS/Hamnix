extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]

# CPUID dispatcher (asm); same one arch/x86/kernel/smp.ad declares.
# out[4] = {eax, ebx, ecx, edx} for the requested leaf/subleaf.
extern def cpuid_get(leaf: uint32, subleaf: uint32, out: Ptr[uint32])


# -------------------------------------------------------------------
# /proc/svc — service-supervisor mirror
#
# The supervisor itself lives in userland (user/hamsh.ad — hamsh IS
# PID 1). Its in-memory registry holds runtime state (pid, state,
# uptime, restarts, exec line, ...). To make that state visible via
# `cat /proc/svc/<name>` we keep a parallel kernel-side mirror that
# hamsh updates whenever it changes a service's state, via a tiny
# publish syscall (SYS_SVC_PUBLISH, arch/x86/kernel/syscall.ad).
#
# The mirror is intentionally a flat fixed-size table (no allocation,
# no locking — single-writer hamsh, single-reader procfs render at
# /proc open time). One slot per service, name as the key.
#
# Phase 6 of the service-supervisor work: `cat /proc/svc/sshd |
# grep ...`-style introspection without the shell builtin.
SVC_PROC_MAX:        uint64 = 32
SVC_PROC_NAME_MAX:   uint64 = 32
SVC_PROC_NS_MAX:     uint64 = 16
SVC_PROC_EXEC_MAX:   uint64 = 256
SVC_PROC_DESC_MAX:   uint64 = 96

# State / restart-policy constants must match user/hamsh.ad's
# SVC_STATE_* / SVC_RESTART_*. Duplicated here because Adder doesn't
# (today) share constants between the kernel and userland builds.
SVC_PROC_STATE_STOPPED:    int32 = 0
SVC_PROC_STATE_RUNNING:    int32 = 1
SVC_PROC_STATE_FAILED:     int32 = 2
SVC_PROC_STATE_RESTARTING: int32 = 3
SVC_PROC_RESTART_NEVER:    int32 = 0
SVC_PROC_RESTART_ON_FAIL:  int32 = 1
SVC_PROC_RESTART_ALWAYS:   int32 = 2

# Per-slot mirror state. Parallel arrays in the same idiom as
# user/hamsh.ad's svc_* tables.
svc_proc_in_use:        Array[32, int32]
svc_proc_name:          Array[1024, uint8]      # 32 * 32
svc_proc_ns:            Array[512, uint8]       # 32 * 16
svc_proc_exec:          Array[8192, uint8]      # 32 * 256
svc_proc_desc:          Array[3072, uint8]      # 32 * 96
svc_proc_state:         Array[32, int32]
svc_proc_pid:           Array[32, int32]
svc_proc_restart_pol:   Array[32, int32]
svc_proc_restarts:      Array[32, int32]
svc_proc_uid:           Array[32, uint32]
svc_proc_last_start_j:  Array[32, uint64]
svc_proc_count:         uint64 = 0              # high-water mark


def _svc_proc_name_at(idx: uint64) -> Ptr[uint8]:
    return &svc_proc_name[idx * SVC_PROC_NAME_MAX]


def _svc_proc_ns_at(idx: uint64) -> Ptr[uint8]:
    return &svc_proc_ns[idx * SVC_PROC_NS_MAX]


def _svc_proc_exec_at(idx: uint64) -> Ptr[uint8]:
    return &svc_proc_exec[idx * SVC_PROC_EXEC_MAX]


def _svc_proc_desc_at(idx: uint64) -> Ptr[uint8]:
    return &svc_proc_desc[idx * SVC_PROC_DESC_MAX]


def _svc_proc_cstr_eq(a: Ptr[uint8], b: Ptr[uint8]) -> int32:
    # NUL-terminated equality, byte-for-byte. Returns 1 iff equal.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: uint8 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def _svc_proc_copy_in(dst: Ptr[uint8], src: Ptr[uint8], cap: uint64):
    # NUL-terminated bounded copy; truncates rather than overflowing.
    i: uint64 = 0
    while src[i] != 0 and i + 1 < cap:
        dst[i] = src[i]
        i = i + 1
    dst[i] = 0


def _svc_proc_lookup(name: Ptr[uint8]) -> int64:
    # Find the slot whose name matches; -1 if not present.
    i: uint64 = 0
    while i < svc_proc_count:
        if svc_proc_in_use[i] != 0:
            if _svc_proc_cstr_eq(_svc_proc_name_at(i), name) != 0:
                return cast[int64](i)
        i = i + 1
    return -1


def _svc_proc_alloc() -> int64:
    # First-fit allocation across the fixed slot table.
    i: uint64 = 0
    while i < SVC_PROC_MAX:
        if svc_proc_in_use[i] == 0:
            return cast[int64](i)
        i = i + 1
    return -1


# Publish payload layout. Must match user/hamsh.ad's sys_svc_publish
# builder. Bytes (little-endian, packed):
#   off  size  field
#     0    4   state          (int32)
#     4    4   pid            (int32)
#     8    4   restart_pol    (int32)
#    12    4   restarts       (int32)
#    16    4   uid            (uint32)
#    20    4   _pad
#    24    8   last_start_j   (uint64)
#    32   16   ns             (NUL-terminated)
#    48  256   exec           (NUL-terminated)
#   304   96   desc           (NUL-terminated)
# Total: 400 bytes.
SVC_PROC_PAYLOAD_BYTES: uint64 = 400


def _payload_i32(payload: Ptr[uint8], off: uint64) -> int32:
    # Little-endian 4-byte read as signed int32.
    b0: uint32 = cast[uint32](payload[off])
    b1: uint32 = cast[uint32](payload[off + 1])
    b2: uint32 = cast[uint32](payload[off + 2])
    b3: uint32 = cast[uint32](payload[off + 3])
    v: uint32 = b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
    return cast[int32](v)


def _payload_u32(payload: Ptr[uint8], off: uint64) -> uint32:
    b0: uint32 = cast[uint32](payload[off])
    b1: uint32 = cast[uint32](payload[off + 1])
    b2: uint32 = cast[uint32](payload[off + 2])
    b3: uint32 = cast[uint32](payload[off + 3])
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)


def _payload_u64(payload: Ptr[uint8], off: uint64) -> uint64:
    lo: uint64 = cast[uint64](_payload_u32(payload, off))
    hi: uint64 = cast[uint64](_payload_u32(payload, off + 4))
    return lo | (hi << 32)


def svc_proc_publish(name: Ptr[uint8], payload: Ptr[uint8]) -> int32:
    # Insert-or-update the mirror entry for `name` from a 400-byte
    # binary payload. Returns 0 on success, -1 if the slot table is
    # full and the name isn't already present.
    idx: int64 = _svc_proc_lookup(name)
    if idx < 0:
        idx = _svc_proc_alloc()
        if idx < 0:
            return -1
        u_new: uint64 = cast[uint64](idx)
        svc_proc_in_use[u_new] = 1
        _svc_proc_copy_in(_svc_proc_name_at(u_new), name, SVC_PROC_NAME_MAX)
        if u_new >= svc_proc_count:
            svc_proc_count = u_new + 1
    u: uint64 = cast[uint64](idx)
    svc_proc_state[u]        = _payload_i32(payload, 0)
    svc_proc_pid[u]          = _payload_i32(payload, 4)
    svc_proc_restart_pol[u]  = _payload_i32(payload, 8)
    svc_proc_restarts[u]     = _payload_i32(payload, 12)
    svc_proc_uid[u]          = _payload_u32(payload, 16)
    svc_proc_last_start_j[u] = _payload_u64(payload, 24)
    _svc_proc_copy_in(_svc_proc_ns_at(u),
                      cast[Ptr[uint8]](cast[uint64](payload) + 32),
                      SVC_PROC_NS_MAX)
    _svc_proc_copy_in(_svc_proc_exec_at(u),
                      cast[Ptr[uint8]](cast[uint64](payload) + 48),
                      SVC_PROC_EXEC_MAX)
    _svc_proc_copy_in(_svc_proc_desc_at(u),
                      cast[Ptr[uint8]](cast[uint64](payload) + 304),
                      SVC_PROC_DESC_MAX)
    return 0


def svc_proc_unpublish(name: Ptr[uint8]) -> int32:
    # Drop the mirror entry for `name`. Returns 0 if removed, -1 if
    # the name wasn't registered (idempotent caller can ignore).
    idx: int64 = _svc_proc_lookup(name)
    if idx < 0:
        return -1
    u: uint64 = cast[uint64](idx)
    svc_proc_in_use[u] = 0
    svc_proc_name[u * SVC_PROC_NAME_MAX] = 0
    return 0


# -------------------------------------------------------------------
# /proc/svc control mailbox — native-command -> PID-1-supervisor RPC
#
# The supervisor (user/hamsh.ad, PID 1) owns the live service table.
# A native CLI like `service` or `init` runs in some OTHER process and
# cannot reach that table directly. SYS_SVC_PUBLISH already gives the
# supervisor a one-way push into the kernel for `cat /proc/svc/<name>`
# introspection; this mailbox is the matching REVERSE channel: a native
# command enqueues a request here, and the supervisor drains it on its
# next tick (svc_supervisor_tick).
#
# The mailbox is a tiny fixed-size FIFO. Each entry is (verb, name):
#   verb 1 = start      name = service
#   verb 2 = stop       name = service
#   verb 3 = restart    name = service
#   verb 4 = enable     name = service   (mark autostart in a runlevel)
#   verb 5 = disable    name = service
#   verb 6 = runlevel   name = level digit as text ("0".."6")
# Single-writer-per-slot, single-reader (PID 1) — no locking needed on
# the cooperative scheduler (a syscall runs to completion before the
# supervisor tick can observe the queue). The producer bumps the write
# index; the consumer bumps the read index; full queue drops the oldest
# pending request rather than blocking the caller.
SVC_CTL_QUEUE_MAX:  uint64 = 32
SVC_CTL_NAME_MAX:   uint64 = 32
svc_ctl_verb:       Array[32, int32]
svc_ctl_name:       Array[1024, uint8]      # 32 * 32, NUL-terminated
svc_ctl_head:       uint64 = 0              # next slot to consume
svc_ctl_tail:       uint64 = 0              # next slot to fill
svc_ctl_count:      uint64 = 0              # pending entries


def _svc_ctl_name_at(idx: uint64) -> Ptr[uint8]:
    return &svc_ctl_name[idx * SVC_CTL_NAME_MAX]


def svc_ctl_enqueue(verb: int32, name: Ptr[uint8]) -> int32:
    # Producer side (called from the SYS_SVC_CTL arm). Append a request.
    # If the queue is full we discard the OLDEST pending request to make
    # room (a stuck supervisor must never wedge a CLI). Returns 0.
    if svc_ctl_count >= SVC_CTL_QUEUE_MAX:
        # Drop oldest: advance head, decrement count.
        svc_ctl_head = (svc_ctl_head + 1) % SVC_CTL_QUEUE_MAX
        svc_ctl_count = svc_ctl_count - 1
    slot: uint64 = svc_ctl_tail
    svc_ctl_verb[slot] = verb
    dst: Ptr[uint8] = _svc_ctl_name_at(slot)
    i: uint64 = 0
    if cast[uint64](name) != 0:
        while name[i] != 0 and i + 1 < SVC_CTL_NAME_MAX:
            dst[i] = name[i]
            i = i + 1
    dst[i] = 0
    svc_ctl_tail = (svc_ctl_tail + 1) % SVC_CTL_QUEUE_MAX
    svc_ctl_count = svc_ctl_count + 1
    return 0


# Consumer-side scratch: the supervisor calls svc_ctl_dequeue, which
# copies the front request's name into svc_ctl_out_name and returns the
# verb (0 when the queue is empty). The supervisor reads svc_ctl_out_*.
svc_ctl_out_verb:   int32 = 0
svc_ctl_out_name:   Array[32, uint8]


def svc_ctl_dequeue() -> int32:
    # Consumer side (called from the supervisor tick in PID 1 via
    # SYS_SVC_CTL with verb 0 = poll). Pops the front request into
    # svc_ctl_out_verb / svc_ctl_out_name and returns the verb, or 0 if
    # the queue is empty.
    if svc_ctl_count == 0:
        svc_ctl_out_verb = 0
        svc_ctl_out_name[0] = 0
        return 0
    slot: uint64 = svc_ctl_head
    v: int32 = svc_ctl_verb[slot]
    src: Ptr[uint8] = _svc_ctl_name_at(slot)
    i: uint64 = 0
    while src[i] != 0 and i + 1 < SVC_CTL_NAME_MAX:
        svc_ctl_out_name[i] = src[i]
        i = i + 1
    svc_ctl_out_name[i] = 0
    svc_ctl_head = (svc_ctl_head + 1) % SVC_CTL_QUEUE_MAX
    svc_ctl_count = svc_ctl_count - 1
    svc_ctl_out_verb = v
    return v


def svc_ctl_out_name_ptr() -> Ptr[uint8]:
    return &svc_ctl_out_name[0]


# -------------------------------------------------------------------
# F2 #447 — /proc/svc/ctl text-verb apply
#
# Both the SYS_SVC_CTL syscall arm (deprecated thin shim) and writes to
# /proc/svc/ctl land here after the dispatch boundary copies the buffer
# into kernel memory. The verb table is the Plan-9-shape replacement for
# SYS_SVC_CTL — instead of a (verb-int, name-ptr) pair, the caller writes
# a line "<verb> <name>\n" to the ctl file and the same svc_ctl_enqueue /
# svc_proc_unpublish helpers run.
#
# Verbs accepted (matches SYS_SVC_CTL's producer verbs 1..6 plus
# `unpublish`):
#   start <name>     stop <name>      restart <name>
#   enable <name>    disable <name>   runlevel <digit>
#   unpublish <name>
#
# Returns 0 on a recognised + applied verb, -1 on a parse failure / bad
# verb. The caller's errstr is set on -1.
SVC_CTL_VERB_START:     int32 = 1
SVC_CTL_VERB_STOP:      int32 = 2
SVC_CTL_VERB_RESTART:   int32 = 3
SVC_CTL_VERB_ENABLE:    int32 = 4
SVC_CTL_VERB_DISABLE:   int32 = 5
SVC_CTL_VERB_RUNLEVEL:  int32 = 6


def _svc_ctl_is_ws(c: uint8) -> int32:
    if c == 32 or c == 9 or c == 10 or c == 13:
        return 1
    return 0


def _svc_ctl_word_eq(buf: Ptr[uint8], count: uint64, start: uint64,
                     end: uint64, word: Ptr[uint8]) -> int32:
    # True iff the byte range buf[start..end) exactly matches the
    # NUL-terminated `word`.
    wl: uint64 = 0
    while word[wl] != 0:
        wl = wl + 1
    if end - start != wl:
        return 0
    i: uint64 = 0
    while i < wl:
        if buf[start + i] != word[i]:
            return 0
        i = i + 1
    return 1


def svc_ctl_text_apply(buf: Ptr[uint8], count: uint64) -> int32:
    # Parse one "<verb> <name>\n" line. The buffer is kernel memory (the
    # caller — either the SYS_SVC_CTL arm in arch/x86/kernel/syscall.ad
    # or the /proc/svc/ctl write arm in sys/src/9/port/devproc.ad —
    # bounce-copies user bytes through copy_from_user before calling).
    # Returns 0 on success, -1 on a malformed line / unknown verb. On
    # -1, set_current_errstr is called so callers can surface "errstr".
    if count == 0:
        return -1
    # Skip leading whitespace.
    p: uint64 = 0
    while p < count and _svc_ctl_is_ws(buf[p]) == 1:
        p = p + 1
    verb_start: uint64 = p
    while p < count and _svc_ctl_is_ws(buf[p]) == 0:
        p = p + 1
    verb_end: uint64 = p
    if verb_start == verb_end:
        set_current_errstr("svc/ctl: missing verb")
        return -1
    # Skip whitespace, then read the name (rest-of-line up to '\n' or
    # NUL — name may have NO embedded whitespace except the terminator).
    while p < count and (buf[p] == 32 or buf[p] == 9):
        p = p + 1
    name_start: uint64 = p
    while p < count and _svc_ctl_is_ws(buf[p]) == 0:
        p = p + 1
    name_end: uint64 = p
    if name_start == name_end:
        set_current_errstr("svc/ctl: missing name")
        return -1
    # Stage the name in a NUL-terminated scratch (the queue copies it
    # immediately on enqueue, so a stack buffer is safe).
    namebuf: Array[64, uint8]
    nlen: uint64 = name_end - name_start
    if nlen >= 63:
        nlen = 63
    j: uint64 = 0
    while j < nlen:
        namebuf[j] = buf[name_start + j]
        j = j + 1
    namebuf[nlen] = 0
    nameptr: Ptr[uint8] = &namebuf[0]
    # Producer verbs (1..6).
    if _svc_ctl_word_eq(buf, count, verb_start, verb_end, "start") == 1:
        svc_ctl_enqueue(SVC_CTL_VERB_START, nameptr)
        return 0
    if _svc_ctl_word_eq(buf, count, verb_start, verb_end, "stop") == 1:
        svc_ctl_enqueue(SVC_CTL_VERB_STOP, nameptr)
        return 0
    if _svc_ctl_word_eq(buf, count, verb_start, verb_end, "restart") == 1:
        svc_ctl_enqueue(SVC_CTL_VERB_RESTART, nameptr)
        return 0
    if _svc_ctl_word_eq(buf, count, verb_start, verb_end, "enable") == 1:
        svc_ctl_enqueue(SVC_CTL_VERB_ENABLE, nameptr)
        return 0
    if _svc_ctl_word_eq(buf, count, verb_start, verb_end, "disable") == 1:
        svc_ctl_enqueue(SVC_CTL_VERB_DISABLE, nameptr)
        return 0
    if _svc_ctl_word_eq(buf, count, verb_start, verb_end, "runlevel") == 1:
        # The "name" here is the digit ("0".."6"). svc_ctl_enqueue copies
        # it verbatim; the PID-1 supervisor parses it on dequeue.
        svc_ctl_enqueue(SVC_CTL_VERB_RUNLEVEL, nameptr)
        return 0
    if _svc_ctl_word_eq(buf, count, verb_start, verb_end, "unpublish") == 1:
        # Drop the kernel mirror entry. Hostowner-only (mirrors the
        # SYS_SVC_PUBLISH gate) — the write path checks uid==1 BEFORE
        # calling this helper (see devproc_write / SYS_SVC_CTL arm).
        svc_proc_unpublish(nameptr)
        return 0
    set_current_errstr("svc/ctl: bad verb")
    return -1


def _svc_proc_state_label(st: int32) -> Ptr[uint8]:
    if st == SVC_PROC_STATE_RUNNING:
        return "running"
    if st == SVC_PROC_STATE_FAILED:
        return "failed"
    if st == SVC_PROC_STATE_RESTARTING:
        return "restarting"
    return "stopped"


def _svc_proc_restart_label(p: int32) -> Ptr[uint8]:
    if p == SVC_PROC_RESTART_ALWAYS:
        return "always"
    if p == SVC_PROC_RESTART_ON_FAIL:
        return "on-failure"
    return "never"


def _svc_proc_render_one(buf: Ptr[uint8], pos: uint64, u: uint64) -> uint64:
    # Render one service's status line. Mirrors user/hamsh.ad's
    # svc_render_one shape so `cat /proc/svc/sshd` matches the
    # `svc status sshd` output field-for-field:
    #   <name>  state=<s>  ns=<ns>  pid=<n>  restart=<p>
    #   restarts=<n>  [uptime=<s>s]  exec=<cmd>  [desc=<text>]
    pos = _buf_put_str(buf, pos, _svc_proc_name_at(u))
    pos = _buf_put_str(buf, pos, "  state=")
    pos = _buf_put_str(buf, pos, _svc_proc_state_label(svc_proc_state[u]))
    pos = _buf_put_str(buf, pos, "  ns=")
    pos = _buf_put_str(buf, pos, _svc_proc_ns_at(u))
    pos = _buf_put_str(buf, pos, "  pid=")
    if svc_proc_pid[u] >= 0:
        pos = _buf_put_dec(buf, pos, cast[uint64](svc_proc_pid[u]))
    else:
        pos = _buf_put_str(buf, pos, "0")
    pos = _buf_put_str(buf, pos, "  restart=")
    pos = _buf_put_str(buf, pos,
                       _svc_proc_restart_label(svc_proc_restart_pol[u]))
    pos = _buf_put_str(buf, pos, "  restarts=")
    if svc_proc_restarts[u] >= 0:
        pos = _buf_put_dec(buf, pos, cast[uint64](svc_proc_restarts[u]))
    else:
        pos = _buf_put_str(buf, pos, "0")
    # Uptime (seconds) — only meaningful when running and last-start
    # was recorded. jiffies tick at 100 Hz (M16.22 LAPIC + PIT).
    if svc_proc_state[u] == SVC_PROC_STATE_RUNNING \
            and svc_proc_last_start_j[u] != 0:
        now: uint64 = get_jiffies()
        if now >= svc_proc_last_start_j[u]:
            up_j: uint64 = now - svc_proc_last_start_j[u]
            pos = _buf_put_str(buf, pos, "  uptime=")
            pos = _buf_put_dec(buf, pos, up_j / 100)
            pos = _buf_put_str(buf, pos, "s")
    pos = _buf_put_str(buf, pos, "  exec=")
    pos = _buf_put_str(buf, pos, _svc_proc_exec_at(u))
    desc_p: Ptr[uint8] = _svc_proc_desc_at(u)
    if desc_p[0] != 0:
        pos = _buf_put_str(buf, pos, "  desc=")
        pos = _buf_put_str(buf, pos, desc_p)
    buf[pos] = 10                               # '\n'
    pos = pos + 1
    return pos


def render_svc_list(buf: Ptr[uint8]) -> uint64:
    # `cat /proc/svc` (directory readout) — one line per registered
    # service. Matches `svc status` (no name) output, so existing
    # shell pipelines stay drop-in compatible.
    pos: uint64 = 0
    if svc_proc_count == 0:
        pos = _buf_put_str(buf, pos, "svc: no services registered\n")
        return pos
    i: uint64 = 0
    while i < svc_proc_count:
        if svc_proc_in_use[i] != 0:
            pos = _svc_proc_render_one(buf, pos, i)
        i = i + 1
    return pos


def render_svc_one(name: Ptr[char], buf: Ptr[uint8]) -> uint64:
    # `cat /proc/svc/<name>` — one-service rendering. Matches
    # `svc status <name>` byte-for-byte (same field set, same
    # separators) per the brief: "`cat /proc/svc/sshd` shows
    # `state=running` + `pid=N`".
    pos: uint64 = 0
    # Materialise `name` (Ptr[char]) as a uint8 view for the lookup
    # helper. We copy at most SVC_PROC_NAME_MAX bytes into a scratch
    # buffer to bound the work.
    scratch: Array[64, uint8]
    j: uint64 = 0
    while j + 1 < 64 and name[j] != 0:
        scratch[j] = cast[uint8](name[j] & 0xFF)
        j = j + 1
    scratch[j] = 0
    idx: int64 = _svc_proc_lookup(&scratch[0])
    if idx < 0:
        pos = _buf_put_str(buf, pos, "svc: not registered: ")
        pos = _buf_put_str(buf, pos, &scratch[0])
        buf[pos] = 10
        pos = pos + 1
        return pos
    u: uint64 = cast[uint64](idx)
    pos = _svc_proc_render_one(buf, pos, u)
    return pos


def _str_len(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _buf_put_str(buf: Ptr[uint8], pos: uint64, s: Ptr[uint8]) -> uint64:
    # Copy a NUL-terminated string into buf at offset pos. Returns
    # new offset. NUL is NOT written.
    n: uint64 = _str_len(s)
    memcpy(cast[Ptr[uint8]](cast[uint64](buf) + pos), s, n)
    return pos + n


def _buf_put_dec(buf: Ptr[uint8], pos: uint64, value: uint64) -> uint64:
    # Decimal-print value into buf at pos; returns new offset. Uses
    # a small reverse-fill stack like printk.ad's _print_decimal.
    if value == 0:
        buf[pos] = 48                  # '0'
        return pos + 1
    digits: Array[24, uint8]
    n: uint64 = 0
    while value != 0:
        digits[n] = cast[uint8](value % 10) + 48
        value = value / 10
        n = n + 1
    # digits is reversed; copy out from top
    out: uint64 = pos
    while n > 0:
        n = n - 1
        buf[out] = digits[n]
        out = out + 1
    return out


def _buf_put_name0(buf: Ptr[uint8], pos: uint64, name0: uint64) -> uint64:
    # name0 is an 8-char ASCII tag packed so that hex 0x5f5f696e69745f5f
    # reads "__init__" — i.e. the MOST significant byte is character 0.
    # That matches how init/main.ad and the syscall handlers spell the
    # tags by eye; we walk top-down so the rendered string matches.
    out: uint64 = pos
    i: uint64 = 0
    while i < 8:
        c: uint8 = cast[uint8]((name0 >> ((7 - i) * 8)) & 0xFF)
        if c == 0:
            return out
        buf[out] = c
        out = out + 1
        i = i + 1
    return out


def _buf_put_comm(buf: Ptr[uint8], pos: uint64, slot: int32) -> uint64:
    # Render a task's COMM column. Precedence, mirroring
    # _emit_comm_into() in sys/src/9/port/devproc.ad:
    #   1. task_struct.comm  — the full basename (up to 15 chars),
    #      stamped by set_task_name0_from_path() on every execve. This
    #      is what a user wants to see; the 8-byte name0 tag truncates
    #      ("hamdeskt" for hamdesktop).
    #   2. name0             — kernel threads never execve, so comm is
    #      zeroed for them; they carry a creation-time 8-char tag.
    #   3. "[kthread]"       — a kthread spawned with name0 = 0 (the
    #      in-kernel test harnesses do this). Never emit an empty
    #      column: consumers split on tabs and a ragged table is a bug.
    comm: Ptr[uint8] = get_task_comm_ptr(cast[uint64](slot))
    if comm[0] != 0:
        out: uint64 = pos
        i: uint64 = 0
        while i < 16 and comm[i] != 0:
            buf[out] = comm[i]
            out = out + 1
            i = i + 1
        return out
    # Test the TOP byte, not the whole word: character 0 lives there, so
    # a tag whose first byte is NUL renders as nothing at all.
    name0: uint64 = task_name0_at(slot)
    if (name0 >> 56) != 0:
        return _buf_put_name0(buf, pos, name0)
    return _buf_put_str(buf, pos, "[kthread]")


def _state_label(state: uint64) -> Ptr[uint8]:
    # Map state constants to a single-letter Linux-style tag plus a
    # short human name. We return just the letter; /proc/tasks prints
    # it followed by a space and the comm so the layout is greppable.
    if state == STATE_RUNNING:
        return "R"
    if state == STATE_READY:
        return "S"                      # "sleeping/ready"
    if state == STATE_WAIT:
        return "S"                      # interruptible sleep (on a wait queue)
    if state == STATE_EXITED:
        return "Z"                      # "zombie"
    if state == STATE_REAPING:
        return "Z"                      # reaped, awaiting RCU-grace-period free
    return "?"


def render_version(buf: Ptr[uint8]) -> uint64:
    # Static banner. Adder hasn't gained __FILE__/__DATE__-style
    # build-time constants yet, so the version string lives here.
    return _buf_put_str(buf, 0,
        "Hamnix bare-metal kernel — M16.36 (procfs + /ps)\n")


def render_uptime(buf: Ptr[uint8]) -> uint64:
    # jiffies is incremented at 100 Hz (M16.22 LAPIC timer + the
    # earlier PIT calibration); a centisecond is the natural unit.
    # Format: "<centiseconds> cs (<jiffies> jiffies)\n".
    j: uint64 = get_jiffies()
    pos: uint64 = 0
    pos = _buf_put_dec(buf, pos, j)
    pos = _buf_put_str(buf, pos, " cs (")
    pos = _buf_put_dec(buf, pos, j)
    pos = _buf_put_str(buf, pos, " jiffies)\n")
    return pos


def _buf_put_dec2(buf: Ptr[uint8], pos: uint64, value: uint64) -> uint64:
    # Zero-padded two-digit decimal — used by ISO-8601 components
    # (month, day, hour, minute, second) so the rendered text always
    # has the canonical width Linux's date(1) emits. value is clamped
    # to 0..99 in practice (month <=12, hour <=23, ...), but we render
    # whatever's in-range and silently truncate the high bits.
    v: uint64 = value % 100
    buf[pos]     = cast[uint8](v / 10) + 48
    buf[pos + 1] = cast[uint8](v % 10) + 48
    return pos + 2


def _buf_put_dec4(buf: Ptr[uint8], pos: uint64, value: uint64) -> uint64:
    # Zero-padded four-digit decimal for the year field. Same shape
    # as _buf_put_dec2; we don't clamp to 9999 because the renderer
    # is only ever called with epoch_to_broken_down output, which is
    # bounded by the input epoch (no future epoch we'll see in this
    # decade overflows the four-digit window).
    v: uint64 = value % 10000
    buf[pos]     = cast[uint8](v / 1000) + 48
    buf[pos + 1] = cast[uint8]((v / 100) % 10) + 48
    buf[pos + 2] = cast[uint8]((v / 10) % 10) + 48
    buf[pos + 3] = cast[uint8](v % 10) + 48
    return pos + 4


def render_realtime(buf: Ptr[uint8]) -> uint64:
    # Wall-clock + uptime snapshot. Two lines:
    #
    #   <ISO-8601 UTC> <epoch_seconds>\n
    #   <uptime_seconds>.<cs> <jiffies>\n
    #
    # When the boot RTC read failed (rtc_boot_epoch == 0) the wall
    # column is rendered as `unavailable 0` so userland `date` can
    # detect the sentinel and emit a graceful error rather than
    # printing 1970-01-01. The uptime line is always populated.
    pos: uint64 = 0
    wall: uint64 = time_realtime_seconds()
    if wall == 0:
        pos = _buf_put_str(buf, pos, "unavailable 0\n")
    else:
        year:   uint32 = 0
        month:  uint32 = 0
        day:    uint32 = 0
        hour:   uint32 = 0
        minute: uint32 = 0
        sec:    uint32 = 0
        epoch_to_broken_down(wall, &year, &month, &day,
                             &hour, &minute, &sec)
        pos = _buf_put_dec4(buf, pos, cast[uint64](year))
        buf[pos] = 45                              # '-'
        pos = pos + 1
        pos = _buf_put_dec2(buf, pos, cast[uint64](month))
        buf[pos] = 45                              # '-'
        pos = pos + 1
        pos = _buf_put_dec2(buf, pos, cast[uint64](day))
        buf[pos] = 84                              # 'T'
        pos = pos + 1
        pos = _buf_put_dec2(buf, pos, cast[uint64](hour))
        buf[pos] = 58                              # ':'
        pos = pos + 1
        pos = _buf_put_dec2(buf, pos, cast[uint64](minute))
        buf[pos] = 58                              # ':'
        pos = pos + 1
        pos = _buf_put_dec2(buf, pos, cast[uint64](sec))
        buf[pos] = 90                              # 'Z'
        pos = pos + 1
        buf[pos] = 32                              # ' '
        pos = pos + 1
        pos = _buf_put_dec(buf, pos, wall)
        buf[pos] = 10                              # '\n'
        pos = pos + 1
    # Second line: uptime in seconds + centiseconds + jiffies count.
    # Same source as /proc/uptime, repackaged so a single read of
    # /proc/realtime gives a self-consistent (wall, monotonic) pair.
    j: uint64 = get_jiffies()
    secs: uint64 = j / 100
    cs:   uint64 = j % 100
    pos = _buf_put_dec(buf, pos, secs)
    buf[pos] = 46                                  # '.'
    pos = pos + 1
    buf[pos]     = cast[uint8](cs / 10) + 48
    buf[pos + 1] = cast[uint8](cs % 10) + 48
    pos = pos + 2
    buf[pos] = 32                                  # ' '
    pos = pos + 1
    pos = _buf_put_dec(buf, pos, j)
    buf[pos] = 10                                  # '\n'
    pos = pos + 1
    return pos


# /proc/tasks renders one line per live task slot. With NTASKS=256 and a
# worst-case 28-byte line the full table needs ~7 KiB, so it gets its own
# buffer size rather than the shared one-page default (a 15-char comm no
# longer fits the 4 KiB page the 8-char name0 tag used to).
# Longest line grew when the UTIME/STIME columns were appended: 10-digit
# pid + tab + state + tab + 15-char comm + tab + 20-digit utime + tab +
# 20-digit stime + newline. Round the per-line reserve up to 72 and grow
# the whole-table buffer to match (256 slots worst case).
PROC_TASKS_LINE_MAX: uint64 = 72
PROC_TASKS_BUF_SIZE: uint64 = 20480


def render_tasks(buf: Ptr[uint8]) -> uint64:
    # One line per non-FREE slot:
    #   "<pid>\t<state>\t<comm>\n"
    # Tabs not spaces so a future `column` / awk parse stays simple
    # (and so we don't have to align numerically right now).
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "PID\tSTATE\tCOMM\tUTIME\tSTIME\n")
    n: uint64 = task_table_size()
    i: uint64 = 0
    while i < n:
        slot: int32 = cast[int32](i)
        st: uint64 = task_state(slot)
        # Longest possible line: 10-digit pid + tab + state + tab +
        # 15-char comm + newline = 28 bytes. Stop before we could run
        # off the end of the caller's buffer (proc_buf_size gives us
        # PROC_TASKS_BUF_SIZE, sized for a full NTASKS table, but a
        # bound here is what makes that sizing non-load-bearing).
        if pos + PROC_TASKS_LINE_MAX > PROC_TASKS_BUF_SIZE:
            return pos
        if st != STATE_FREE:
            pos = _buf_put_dec(buf, pos, task_pid_at(slot))
            buf[pos] = 9                # tab
            pos = pos + 1
            pos = _buf_put_str(buf, pos, _state_label(st))
            buf[pos] = 9
            pos = pos + 1
            pos = _buf_put_comm(buf, pos, slot)
            # Trailing UTIME/STIME columns (cumulative ticks, HZ=100). A
            # graphical monitor deltas these over its sample interval to
            # derive a per-process CPU%. Kept AFTER comm so comm stays the
            # 3rd tab field for every existing parser.
            buf[pos] = 9                # tab
            pos = pos + 1
            pos = _buf_put_dec(buf, pos, task_utime_ticks_at(slot))
            buf[pos] = 9                # tab
            pos = pos + 1
            pos = _buf_put_dec(buf, pos, task_stime_ticks_at(slot))
            buf[pos] = 10               # newline
            pos = pos + 1
        i = i + 1
    return pos


def render_meminfo(buf: Ptr[uint8]) -> uint64:
    # GNU `free` and friends parse this — three lines is the minimum
    # shape they tolerate. Page size is 4 KiB so pages*4 = kB directly,
    # which keeps us out of 64-bit division by 1024 and matches what
    # Linux's si_meminfo() ultimately reports through the same units.
    total_kb: uint64 = page_alloc_total() * 4
    free_kb:  uint64 = page_alloc_free_count() * 4
    # No reclaimable cache layer yet, so MemAvailable == MemFree (this
    # is what the kernel reports too before slab accounting is wired).
    avail_kb: uint64 = free_kb
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "MemTotal:        ")
    pos = _buf_put_dec(buf, pos, total_kb)
    pos = _buf_put_str(buf, pos, " kB\n")
    pos = _buf_put_str(buf, pos, "MemFree:         ")
    pos = _buf_put_dec(buf, pos, free_kb)
    pos = _buf_put_str(buf, pos, " kB\n")
    pos = _buf_put_str(buf, pos, "MemAvailable:    ")
    pos = _buf_put_dec(buf, pos, avail_kb)
    pos = _buf_put_str(buf, pos, " kB\n")
    return pos


# --- /proc/cpuinfo: real CPUID identity + per-CPU SMP enumeration ---
#
# We mirror arch/x86/kernel/cpu/proc.c: one stanza per online logical
# CPU, with identity fields derived from real CPUID leaves. The CPUID
# identity is the same across cores on the symmetric SMP VMs we run
# (and on uniform silicon), which is exactly what Linux reports too —
# only the `processor :` index differs per stanza.
#
# Tab layout matches Linux byte-for-byte: most keys use a single \t,
# but `model name` and `cpu MHz` use \t\t because their key text is
# short enough that Linux pads them to the column with a second tab.
# `nproc` counts `^processor` lines; `lscpu` parses vendor_id /
# model name / cpu family / model / stepping.

def _cpuid_put_reg(buf: Ptr[uint8], pos: uint64, reg: uint32) -> uint64:
    # Append the 4 little-endian bytes of a 32-bit CPUID register as
    # ASCII chars. byte 0 (low 8 bits) is the first character — this is
    # how the vendor/brand strings are laid out in EBX/EDX/ECX etc.
    out: uint64 = pos
    i: uint64 = 0
    while i < 4:
        c: uint8 = cast[uint8]((reg >> (i * 8)) & 0xFF)
        if c == 0:
            return out
        buf[out] = c
        out = out + 1
        i = i + 1
    return out


def _cpuinfo_put_vendor(buf: Ptr[uint8], pos: uint64) -> uint64:
    # CPUID leaf 0: 12-char vendor string in EBX, EDX, ECX (that order).
    # "GenuineIntel" = EBX="Genu", EDX="ineI", ECX="ntel".
    leaf0: Array[4, uint32]
    cpuid_get(cast[uint32](0), cast[uint32](0), &leaf0[0])
    out: uint64 = pos
    out = _cpuid_put_reg(buf, out, leaf0[1])      # EBX
    out = _cpuid_put_reg(buf, out, leaf0[3])      # EDX
    out = _cpuid_put_reg(buf, out, leaf0[2])      # ECX
    return out


def _cpuinfo_put_brand(buf: Ptr[uint8], pos: uint64) -> uint64:
    # CPUID extended leaves 0x80000002/3/4 hold the 48-byte brand
    # string (16 bytes per leaf, EAX/EBX/ECX/EDX). Only valid when
    # leaf 0x80000000 EAX >= 0x80000004; else fall back to a generic
    # truthful label.
    ext: Array[4, uint32]
    cpuid_get(cast[uint32](0x80000000), cast[uint32](0), &ext[0])
    if ext[0] < cast[uint32](0x80000004):
        return _buf_put_str(buf, pos, "x86_64 generic")
    out: uint64 = pos
    leaf: uint32 = cast[uint32](0x80000002)
    n: uint64 = 0
    while n < 3:
        regs: Array[4, uint32]
        cpuid_get(leaf, cast[uint32](0), &regs[0])
        out = _cpuid_put_reg(buf, out, regs[0])   # EAX
        out = _cpuid_put_reg(buf, out, regs[1])   # EBX
        out = _cpuid_put_reg(buf, out, regs[2])   # ECX
        out = _cpuid_put_reg(buf, out, regs[3])   # EDX
        leaf = leaf + cast[uint32](1)
        n = n + 1
    return out


def _cpuinfo_render_one(buf: Ptr[uint8], pos: uint64, idx: uint64) -> uint64:
    # Render a single processor stanza. CPUID identity fields are read
    # fresh per stanza but are uniform across logical CPUs on the SMP
    # VMs we target (same as Linux on symmetric silicon).
    leaf1: Array[4, uint32]
    cpuid_get(cast[uint32](1), cast[uint32](0), &leaf1[0])
    eax: uint32 = leaf1[0]

    base_family: uint64 = cast[uint64]((eax >> 8) & cast[uint32](0xF))
    ext_family:  uint64 = cast[uint64]((eax >> 20) & cast[uint32](0xFF))
    family: uint64 = base_family
    if base_family == 0xF:
        family = base_family + ext_family

    base_model: uint64 = cast[uint64]((eax >> 4) & cast[uint32](0xF))
    ext_model:  uint64 = cast[uint64]((eax >> 16) & cast[uint32](0xF))
    model: uint64 = base_model
    if base_family == 0xF or base_family == 6:
        model = base_model | (ext_model << 4)

    stepping: uint64 = cast[uint64](eax & cast[uint32](0xF))

    pos2: uint64 = pos
    pos2 = _buf_put_str(buf, pos2, "processor\t: ")
    pos2 = _buf_put_dec(buf, pos2, idx)
    buf[pos2] = 10
    pos2 = pos2 + 1

    pos2 = _buf_put_str(buf, pos2, "vendor_id\t: ")
    pos2 = _cpuinfo_put_vendor(buf, pos2)
    buf[pos2] = 10
    pos2 = pos2 + 1

    pos2 = _buf_put_str(buf, pos2, "cpu family\t: ")
    pos2 = _buf_put_dec(buf, pos2, family)
    buf[pos2] = 10
    pos2 = pos2 + 1

    pos2 = _buf_put_str(buf, pos2, "model\t\t: ")
    pos2 = _buf_put_dec(buf, pos2, model)
    buf[pos2] = 10
    pos2 = pos2 + 1

    pos2 = _buf_put_str(buf, pos2, "model name\t: ")
    pos2 = _cpuinfo_put_brand(buf, pos2)
    buf[pos2] = 10
    pos2 = pos2 + 1

    pos2 = _buf_put_str(buf, pos2, "stepping\t: ")
    pos2 = _buf_put_dec(buf, pos2, stepping)
    buf[pos2] = 10
    pos2 = pos2 + 1

    # cpu MHz from the calibrated TSC if available, else a fallback.
    hz: uint64 = tsc_hz_get()
    mhz: uint64 = 1000
    if hz != 0:
        mhz = hz / 1000000
    pos2 = _buf_put_str(buf, pos2, "cpu MHz\t\t: ")
    pos2 = _buf_put_dec(buf, pos2, mhz)
    buf[pos2] = 10
    pos2 = pos2 + 1

    # A small, real flag subset derived from CPUID.01h EDX/ECX. lscpu
    # and friends scan this line; we emit only architecturally-stable
    # bits to keep the change tight.
    edx: uint32 = leaf1[3]
    ecx: uint32 = leaf1[2]
    pos2 = _buf_put_str(buf, pos2, "flags\t\t:")
    if (edx & cast[uint32](0x00000001)) != 0:
        pos2 = _buf_put_str(buf, pos2, " fpu")
    if (edx & cast[uint32](0x00000010)) != 0:
        pos2 = _buf_put_str(buf, pos2, " tsc")
    if (edx & cast[uint32](0x00000020)) != 0:
        pos2 = _buf_put_str(buf, pos2, " msr")
    if (edx & cast[uint32](0x02000000)) != 0:
        pos2 = _buf_put_str(buf, pos2, " sse")
    if (edx & cast[uint32](0x04000000)) != 0:
        pos2 = _buf_put_str(buf, pos2, " sse2")
    if (ecx & cast[uint32](0x00000001)) != 0:
        pos2 = _buf_put_str(buf, pos2, " sse3")
    if (ecx & cast[uint32](0x80000000)) != 0:
        pos2 = _buf_put_str(buf, pos2, " hypervisor")
    buf[pos2] = 10
    pos2 = pos2 + 1

    # Blank line between stanzas, matching Linux.
    buf[pos2] = 10
    pos2 = pos2 + 1
    return pos2


def render_cpuinfo(buf: Ptr[uint8]) -> uint64:
    # One stanza per online logical CPU. SMP count comes from the live
    # boot-state counter the AP bring-up bumps (smp.ad cpus_online).
    ncpu: uint64 = get_cpus_online()
    if ncpu == 0:
        ncpu = 1
    pos: uint64 = 0
    i: uint64 = 0
    while i < ncpu:
        pos = _cpuinfo_render_one(buf, pos, i)
        i = i + 1
    return pos


def cpuinfo_selftest() -> int32:
    # Boot self-test for the real /proc/cpuinfo renderer. Renders into a
    # scratch buffer and asserts:
    #   * a REAL vendor string is present (CPUID leaf-0, not "Hamnix")
    #   * "processor\t: 0" appears
    #   * the count of "processor\t:" lines == get_cpus_online()
    # printk0 a single PASS/FAIL line.
    sbuf: Array[4096, uint8]
    n: uint64 = render_cpuinfo(&sbuf[0])

    # Must not be the old literal placeholder vendor.
    if _cpuinfo_buf_contains(&sbuf[0], n, "Hamnix") != 0:
        printk0("[CPUINFO] FAIL placeholder vendor present\n")
        return 0

    # Real vendor: derive leaf-0 string and confirm it's in the output.
    vbuf: Array[16, uint8]
    vn: uint64 = _cpuinfo_put_vendor(&vbuf[0], 0)
    vbuf[vn] = 0
    if vn == 0:
        printk0("[CPUINFO] FAIL empty vendor\n")
        return 0
    if _cpuinfo_buf_contains(&sbuf[0], n, &vbuf[0]) == 0:
        printk0("[CPUINFO] FAIL real vendor missing\n")
        return 0

    # processor : 0 stanza header present.
    if _cpuinfo_buf_contains(&sbuf[0], n, "processor\t: 0") == 0:
        printk0("[CPUINFO] FAIL processor 0 header missing\n")
        return 0

    # processor-line count == SMP online count.
    pcount: uint64 = _cpuinfo_count_proc_lines(&sbuf[0], n)
    ncpu: uint64 = get_cpus_online()
    if ncpu == 0:
        ncpu = 1
    if pcount != ncpu:
        printk2("[CPUINFO] FAIL proc-lines %d != cpus %d\n", pcount, ncpu)
        return 0

    printk2("[CPUINFO] PASS vendor ok, %d processor stanza(s), cpus=%d\n",
            pcount, ncpu)
    return 1


def _cpuinfo_buf_contains(buf: Ptr[uint8], n: uint64, needle: Ptr[uint8]) -> int32:
    # Naive substring search over the first n bytes of buf.
    m: uint64 = _str_len(needle)
    if m == 0:
        return 1
    if m > n:
        return 0
    i: uint64 = 0
    while i + m <= n:
        j: uint64 = 0
        while j < m:
            if buf[i + j] != needle[j]:
                j = m + 1
            else:
                j = j + 1
        if j == m:
            return 1
        i = i + 1
    return 0


def _cpuinfo_count_proc_lines(buf: Ptr[uint8], n: uint64) -> uint64:
    # Count occurrences of a line starting with "processor\t:" — the
    # same shape `nproc` counts. A match requires being at buf start or
    # right after a newline.
    cnt: uint64 = 0
    i: uint64 = 0
    while i < n:
        at_line_start: int32 = 0
        if i == 0:
            at_line_start = 1
        else:
            if buf[i - 1] == 10:
                at_line_start = 1
        if at_line_start != 0:
            if _cpuinfo_match_proc_at(buf, n, i) != 0:
                cnt = cnt + 1
        i = i + 1
    return cnt


def _cpuinfo_match_proc_at(buf: Ptr[uint8], n: uint64, off: uint64) -> int32:
    # Match the literal "processor\t:" at buf[off..].
    pat: Array[12, uint8]
    pn: uint64 = _buf_put_str(&pat[0], 0, "processor\t:")
    pat[pn] = 0
    if off + pn > n:
        return 0
    k: uint64 = 0
    while k < pn:
        if buf[off + k] != pat[k]:
            return 0
        k = k + 1
    return 1


def render_oops(buf: Ptr[uint8], max: uint64) -> uint64:
    # /proc/oops — the RAW 548-byte structured panic record from
    # OOPS.BIN, byte-for-byte. Userland decoders (user/oopsread.ad)
    # parse the layout defined in kernel/printk/esp_log.ad. Returns 0
    # when no oops has been captured / no OOPS.BIN extent armed.
    if esp_log_oops_is_ready() == 0:
        return 0
    n: int64 = esp_log_read_oops(buf, max)
    if n < 0:
        return 0
    return cast[uint64](n)


def render_kmsg(buf: Ptr[uint8], max: uint64) -> uint64:
    # Drain the most-recent slice of the printk ring buffer into the
    # caller's procfs snapshot buffer. Linux's /proc/kmsg is a
    # streaming interface (you read until the FIFO drains, then
    # block); ours is a one-shot snapshot — same trade-off the rest
    # of /proc makes today.
    #
    # `max` is the buffer _open_proc kmalloc'd for this fd. proc_buf_size()
    # makes that buffer PRINTK_LOG_SIZE bytes for /proc/kmsg (not the
    # one-page default), so the snapshot covers the WHOLE ring — every
    # kernel message survives in dmesg, including low-severity printk
    # the console-loglevel gate suppressed from the live console once
    # userland went interactive.
    return printk_log_snapshot(buf, max)


def render_cmdline(buf: Ptr[uint8]) -> uint64:
    # §13: /proc/cmdline. Hamnix boots via QEMU's `-kernel` path with
    # no kernel command line parsed at boot, so there is no captured
    # cmdline string to echo. We emit a single accurate line naming
    # the boot image plus the console Hamnix actually uses (the
    # 8250 UART at ttyS0). A Linux program scanning /proc/cmdline for
    # `console=` or `BOOT_IMAGE=` gets a well-formed, truthful answer;
    # a real boot-time cmdline capture is a separate follow-up that
    # belongs in the early-boot path, not here.
    return _buf_put_str(buf, 0,
        "BOOT_IMAGE=/hamnix-kernel.elf console=ttyS0\n")


# --- /proc/mounts: real per-namespace mount table -------------------
#
# The base filesystems (ramfs /, procfs /proc, tmpfs /tmp, fat /mnt,
# ext4 /ext) are root-pinned: the kernel never unmounts them, and they
# don't live in any per-Pgrp bind table, so they're emitted as fixed
# leading lines. AFTER those we append the calling task's REAL
# namespace bind/mount entries — chan.ad renders its Pgrp mtab as
# ns(1)-shape text (pgrp_render_ns), which we re-shape into the Linux
# 6-field /proc/mounts form so mount(8)/df/libmount can parse it.
#
# ns(1) line shapes produced by pgrp_render_ns:
#   bind <from> <to>[ -b/-a][ as <label>]
#   mount #s/<srvfd> <to>[ -b/-a][ as <label>]
# We translate:
#   bind   ->  <from>     <to>  none  bind,rw  0 0
#   mount  ->  #s/<srvfd> <to>  9p    rw       0 0
# Trailing union/label decorations (-b/-a/as) are dropped: /proc/mounts
# has no field for them. A fresh namespace with no extra binds yields
# exactly the base lines (mnttab_entry_count()==0 -> no dynamic tail).

def _mounts_is_ws(c: uint8) -> int32:
    if c == 32:                        # ' '
        return 1
    if c == 9:                         # '\t'
        return 1
    return 0


def _mounts_copy_token(dst: Ptr[uint8], dpos: uint64,
                       src: Ptr[uint8], spos: uint64,
                       slen: uint64) -> uint64:
    # Copy the whitespace-delimited token starting at src[spos] into
    # dst[dpos]. Returns the new dst position. Stops at whitespace,
    # newline, or end of src.
    p: uint64 = dpos
    i: uint64 = spos
    while i < slen:
        c: uint8 = src[i]
        if c == 10 or _mounts_is_ws(c) != 0:
            i = slen                   # break
        else:
            dst[p] = c
            p = p + 1
            i = i + 1
    return p


def _mounts_skip_ws(src: Ptr[uint8], spos: uint64, slen: uint64) -> uint64:
    i: uint64 = spos
    while i < slen and _mounts_is_ws(src[i]) != 0:
        i = i + 1
    return i


def _mounts_skip_token(src: Ptr[uint8], spos: uint64, slen: uint64) -> uint64:
    i: uint64 = spos
    while i < slen and src[i] != 10 and _mounts_is_ws(src[i]) == 0:
        i = i + 1
    return i


def _mounts_line_end(src: Ptr[uint8], spos: uint64, slen: uint64) -> uint64:
    # Index just past the next newline (or slen).
    i: uint64 = spos
    while i < slen and src[i] != 10:
        i = i + 1
    if i < slen:
        i = i + 1                      # consume the '\n'
    return i


def _mounts_tok_is(src: Ptr[uint8], spos: uint64, slen: uint64,
                   lit: Ptr[uint8]) -> int32:
    # Does the token at src[spos] exactly equal NUL-terminated lit?
    i: uint64 = spos
    k: uint64 = 0
    while lit[k] != 0:
        if i >= slen:
            return 0
        c: uint8 = src[i]
        if c == 10 or _mounts_is_ws(c) != 0:
            return 0
        if c != lit[k]:
            return 0
        i = i + 1
        k = k + 1
    # token must end here (whitespace/newline/eof)
    if i >= slen:
        return 1
    c2: uint8 = src[i]
    if c2 == 10 or _mounts_is_ws(c2) != 0:
        return 1
    return 0


def _mounts_append_ns(buf: Ptr[uint8], pos: uint64,
                      ns: Ptr[uint8], nslen: uint64) -> uint64:
    # Walk ns(1)-shape text and emit one 6-field /proc/mounts line per
    # input line. Unknown/blank lines are skipped.
    out: uint64 = pos
    i: uint64 = 0
    while i < nslen:
        i = _mounts_skip_ws(ns, i, nslen)
        if i >= nslen or ns[i] == 10:
            # blank line — advance past it
            i = _mounts_line_end(ns, i, nslen)
        elif _mounts_tok_is(ns, i, nslen, "bind") != 0:
            # bind <from> <to> ...
            i = _mounts_skip_token(ns, i, nslen)       # past "bind"
            i = _mounts_skip_ws(ns, i, nslen)
            line0: uint64 = out
            out = _mounts_copy_token(buf, out, ns, i, nslen)   # device=<from>
            if out == line0:
                # malformed: no device — skip the line
                i = _mounts_line_end(ns, i, nslen)
            else:
                buf[out] = 32                              # ' '
                out = out + 1
                i = _mounts_skip_token(ns, i, nslen)
                i = _mounts_skip_ws(ns, i, nslen)
                out = _mounts_copy_token(buf, out, ns, i, nslen)   # mountpoint
                out = _buf_put_str(buf, out, " none bind,rw 0 0\n")
                i = _mounts_line_end(ns, i, nslen)
        elif _mounts_tok_is(ns, i, nslen, "mount") != 0:
            # mount #s/<srvfd> <to> ...
            i = _mounts_skip_token(ns, i, nslen)       # past "mount"
            i = _mounts_skip_ws(ns, i, nslen)
            line0m: uint64 = out
            out = _mounts_copy_token(buf, out, ns, i, nslen)   # device=#s/<fd>
            if out == line0m:
                i = _mounts_line_end(ns, i, nslen)
            else:
                buf[out] = 32                              # ' '
                out = out + 1
                i = _mounts_skip_token(ns, i, nslen)
                i = _mounts_skip_ws(ns, i, nslen)
                out = _mounts_copy_token(buf, out, ns, i, nslen)   # mountpoint
                out = _buf_put_str(buf, out, " 9p rw 0 0\n")
                i = _mounts_line_end(ns, i, nslen)
        else:
            # unrecognized leading token — skip the whole line
            i = _mounts_line_end(ns, i, nslen)
    return out


def render_mounts(buf: Ptr[uint8]) -> uint64:
    # Root-pinned base filesystems (always present), then the calling
    # task's REAL per-namespace bind/mount entries from its Pgrp mtab.
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "ramfs / ramfs rw 0 0\n")
    pos = _buf_put_str(buf, pos, "procfs /proc procfs rw 0 0\n")
    pos = _buf_put_str(buf, pos, "tmpfs /tmp tmpfs rw 0 0\n")
    pos = _buf_put_str(buf, pos, "fat /mnt fat ro 0 0\n")
    pos = _buf_put_str(buf, pos, "ext4 /ext ext4 rw 0 0\n")
    # cgroup v2 unified hierarchy (Linux-namespace furniture). systemd
    # and container tools find /sys/fs/cgroup via this mount line; the
    # interface files are served by cgroup_render() above.
    pos = _buf_put_str(buf, pos,
        "cgroup2 /sys/fs/cgroup cgroup2 rw,nsdelegate 0 0\n")

    # Dynamic per-namespace entries. Skip the whole step when the
    # caller's namespace carries no extra binds — no regression vs the
    # static view for the common (fresh-namespace) case.
    if mnttab_entry_count() == 0:
        return pos
    nsbuf: Array[2048, uint8]
    p: uint64 = pgrp_current()
    nlen: int64 = pgrp_render_ns(p, &nsbuf[0], cast[uint64](2048))
    if nlen <= 0:
        return pos
    pos = _mounts_append_ns(buf, pos, &nsbuf[0], cast[uint64](nlen))
    return pos


def procmounts_selftest() -> int32:
    # Boot self-test for the real /proc/mounts renderer. Renders into a
    # scratch buffer and asserts the root-pinned base lines are present;
    # then performs a runtime bind via mnttab_bind and re-renders,
    # asserting the new bind shows up as a 6-field /proc/mounts line.
    sbuf: Array[4096, uint8]
    n: uint64 = render_mounts(&sbuf[0])

    # Base lines must always be present.
    if _cpuinfo_buf_contains(&sbuf[0], n, "ext4 /ext ext4 rw 0 0") == 0:
        printk0("[PROCMOUNTS] FAIL base ext4 line missing\n")
        return 0
    if _cpuinfo_buf_contains(&sbuf[0], n, "procfs /proc procfs rw 0 0") == 0:
        printk0("[PROCMOUNTS] FAIL base procfs line missing\n")
        return 0

    # Perform a runtime bind in the calling task's namespace.
    if mnttab_bind("/proc-mounts-test-src", "/proc-mounts-test-dst",
                   cast[int32](0)) != 0:
        printk0("[PROCMOUNTS] FAIL mnttab_bind failed\n")
        return 0

    # Re-render: the bind must now appear as a 6-field bind line.
    n = render_mounts(&sbuf[0])
    if _cpuinfo_buf_contains(&sbuf[0], n,
            "/proc-mounts-test-src /proc-mounts-test-dst none bind,rw 0 0") \
            == 0:
        printk0("[PROCMOUNTS] FAIL dynamic bind line missing\n")
        return 0

    printk0("[PROCMOUNTS] PASS base + dynamic bind entry rendered\n")
    return 1


# -------------------------------------------------------------------
# /proc/net/{tcp,udp,arp,route,dev} — Linux-format network state
#
# Mirrors fs/proc/net/* in Linux at the smallest shipping scope. Every
# node renders live kernel net state into the Linux text format so the
# stock Linux tools that parse /proc/net (netstat, ss, ifconfig, route,
# arp -a) read them byte-compatibly. All addresses follow Linux's wire
# conventions: /proc/net/tcp + /proc/net/udp print the IPv4 as the
# little-endian hex of the 32-bit network-order address; /proc/net/route
# prints destination/gateway/mask the same little-endian way. Ports in
# tcp/udp are big-endian (network) hex; here we render them host-order
# hex since that is what the slot/socket tables store.

# Module-scope scratch buffer for the boot self-test (renderers write
# into the caller-supplied page; this is only the self-test target).
procnet_selftest_buf: Array[4096, uint8]


def _hex_nib(v: uint8) -> uint8:
    # One hex nibble (0..15) -> ASCII '0'..'9','A'..'F'.
    if v < 10:
        return v + 48                          # '0'
    return (v - 10) + 65                        # 'A'


def _buf_put_hex8(buf: Ptr[uint8], pos: uint64, value: uint32) -> uint64:
    # 8 hex digits, MSB first, zero-padded (%08X).
    i: int32 = 7
    while i >= 0:
        nib: uint8 = cast[uint8]((value >> cast[uint32](i * 4)) & 0xF)
        buf[pos] = _hex_nib(nib)
        pos = pos + 1
        i = i - 1
    return pos


def _buf_put_hex4(buf: Ptr[uint8], pos: uint64, value: uint16) -> uint64:
    # 4 hex digits, MSB first, zero-padded (%04X).
    v: uint32 = cast[uint32](value)
    i: int32 = 3
    while i >= 0:
        nib: uint8 = cast[uint8]((v >> cast[uint32](i * 4)) & 0xF)
        buf[pos] = _hex_nib(nib)
        pos = pos + 1
        i = i - 1
    return pos


def _buf_put_hex2(buf: Ptr[uint8], pos: uint64, value: uint8) -> uint64:
    # 2 hex digits (%02X).
    buf[pos] = _hex_nib((value >> 4) & 0xF)
    buf[pos + 1] = _hex_nib(value & 0xF)
    return pos + 2


def _swap32(v: uint32) -> uint32:
    # Byte-reverse a 32-bit word. Our IP getters pack the first dotted-
    # quad octet in the HIGH byte (a.b.c.d -> 0xAABBCCDD); Linux prints
    # /proc/net addresses as the little-endian hex of the network-order
    # bytes, i.e. 0xDDCCBBAA. Swapping converts one to the other.
    b0: uint32 = (v >> 24) & 0xFF
    b1: uint32 = (v >> 16) & 0xFF
    b2: uint32 = (v >> 8) & 0xFF
    b3: uint32 = v & 0xFF
    return (b3 << 24) | (b2 << 16) | (b1 << 8) | b0


def _buf_put_le_addr(buf: Ptr[uint8], pos: uint64, ip_hi: uint32) -> uint64:
    # Render an IPv4 (packed first-octet-high) as Linux's little-endian
    # %08X /proc/net address.
    return _buf_put_hex8(buf, pos, _swap32(ip_hi))


def _buf_put_dec_pad(buf: Ptr[uint8], pos: uint64, value: uint64,
                     width: uint64) -> uint64:
    # Right-justify a decimal in a field `width` wide with leading
    # spaces (e.g. "%4d"). Used for the /proc/net/tcp `sl` column.
    digits: Array[24, uint8]
    n: uint64 = 0
    if value == 0:
        digits[0] = 48
        n = 1
    else:
        v: uint64 = value
        while v != 0:
            digits[n] = cast[uint8](v % 10) + 48
            v = v / 10
            n = n + 1
    pad: uint64 = 0
    while pad + n < width:
        buf[pos] = 32                          # ' '
        pos = pos + 1
        pad = pad + 1
    k: uint64 = n
    while k > 0:
        k = k - 1
        buf[pos] = digits[k]
        pos = pos + 1
    return pos


def _net_tcp_state_num(st: uint32) -> uint32:
    # Map the kernel's TCP_* enum (drivers/net/tcp.ad) to Linux's
    # /proc/net/tcp numeric state. The two enums already line up 1:1
    # for the states we implement (CLOSED..TIME_WAIT == 0..10 in BOTH),
    # but Linux uses 1=ESTABLISHED..11=CLOSING ordering. Translate so
    # netstat/ss print the right state name. Our enum:
    #   CLOSED=0 LISTEN=1 SYN_SENT=2 SYN_RECV=3 ESTABLISHED=4
    #   FIN_WAIT_1=5 FIN_WAIT_2=6 CLOSE_WAIT=7 CLOSING=8 LAST_ACK=9
    #   TIME_WAIT=10
    # Linux /proc enum (include/net/tcp_states.h, +1 vs the C enum):
    #   ESTABLISHED=1 SYN_SENT=2 SYN_RECV=3 FIN_WAIT1=4 FIN_WAIT2=5
    #   TIME_WAIT=6 CLOSE=7 CLOSE_WAIT=8 LAST_ACK=9 LISTEN=10 CLOSING=11
    if st == TCP_CLOSED:
        return 7                                # TCP_CLOSE
    if st == 1:                                 # our LISTEN
        return 10
    if st == 2:                                 # SYN_SENT
        return 2
    if st == 3:                                 # SYN_RECV
        return 3
    if st == 4:                                 # ESTABLISHED
        return 1
    if st == 5:                                 # FIN_WAIT_1
        return 4
    if st == 6:                                 # FIN_WAIT_2
        return 5
    if st == 7:                                 # CLOSE_WAIT
        return 8
    if st == 8:                                 # CLOSING
        return 11
    if st == 9:                                 # LAST_ACK
        return 9
    if st == 10:                                # TIME_WAIT
        return 6
    return 7


def _net_put_conn_row(buf: Ptr[uint8], pos: uint64, sl: uint64,
                      laddr_hi: uint32, lport: uint16,
                      raddr_hi: uint32, rport: uint16,
                      st: uint32) -> uint64:
    # One /proc/net/{tcp,udp} row:
    #   "  sl: LADDR:LPORT RADDR:RPORT ST tx rx tr when retr uid to inode\n"
    # We fill the columns we don't track with the zero values Linux
    # prints for an idle socket, keeping the field layout intact so
    # netstat/ss tokenise it correctly.
    pos = _buf_put_dec_pad(buf, pos, sl, 4)
    buf[pos] = 58                              # ':'
    pos = pos + 1
    buf[pos] = 32
    pos = pos + 1
    pos = _buf_put_le_addr(buf, pos, laddr_hi)
    buf[pos] = 58
    pos = pos + 1
    pos = _buf_put_hex4(buf, pos, lport)
    buf[pos] = 32
    pos = pos + 1
    pos = _buf_put_le_addr(buf, pos, raddr_hi)
    buf[pos] = 58
    pos = pos + 1
    pos = _buf_put_hex4(buf, pos, rport)
    buf[pos] = 32
    pos = pos + 1
    pos = _buf_put_hex2(buf, pos, cast[uint8](st & 0xFF))
    # tx_queue:rx_queue tr:tm->when retrnsmt  (all zero — untracked)
    pos = _buf_put_str(buf, pos, " 00000000:00000000 00:00000000 00000000")
    # uid  timeout inode
    pos = _buf_put_str(buf, pos, "     0        0 0\n")
    return pos


def render_net_tcp(buf: Ptr[uint8]) -> uint64:
    # /proc/net/tcp — one row per active TCB plus any CONNECTED kernel
    # stream socket the TCB table doesn't already cover.
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos,
        "  sl  local_address rem_address   st tx_queue rx_queue tr tm->when retrnsmt   uid  timeout inode\n")
    sl: uint64 = 0
    laddr_hi: uint32 = 0
    if ip_have_our_ip() != 0:
        laddr_hi = _net_our_ip_hi()
    n: uint64 = tcp_num_slots()
    i: uint64 = 0
    while i < n:
        st: uint32 = tcp_slot_st(i)
        if st != TCP_CLOSED:
            lnum: uint32 = _net_tcp_state_num(st)
            pos = _net_put_conn_row(buf, pos, sl, laddr_hi,
                                    tcp_slot_lport(i),
                                    tcp_slot_rip(i), tcp_slot_rport(i),
                                    lnum)
            sl = sl + 1
        i = i + 1
    return pos


def render_net_udp(buf: Ptr[uint8]) -> uint64:
    # /proc/net/udp — one row per non-free DGRAM kernel socket. UDP is
    # connectionless, so Linux always prints state 07 (TCP_CLOSE) for
    # UDP sockets; we do the same. Ports/IPs come from the kernel socket
    # table (network order; we host-order the port for %04X).
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos,
        "  sl  local_address rem_address   st tx_queue rx_queue tr tm->when retrnsmt   uid  timeout inode\n")
    sl: uint64 = 0
    i: uint64 = 0
    while i < 16:
        if ksock_slot_state(i) != SS_FREE:
            if ksock_slot_type(i) == KSOCK_DGRAM:
                # ksock IPs are network-order packed first-octet-high
                # (same as our other getters); ports are network order.
                lport: uint16 = _net_ntohs(ksock_slot_local_port(i))
                rport: uint16 = _net_ntohs(ksock_slot_peer_port(i))
                pos = _net_put_conn_row(buf, pos, sl,
                                        ksock_slot_local_ip(i), lport,
                                        ksock_slot_peer_ip(i), rport,
                                        7)
                sl = sl + 1
        i = i + 1
    return pos


def render_net_arp(buf: Ptr[uint8]) -> uint64:
    # /proc/net/arp — one row per live ARP cache entry:
    #   IP address  HW type  Flags  HW address  Mask  Device
    # HW type 0x1 = ARPHRD_ETHER, Flags 0x2 = ATF_COM (complete).
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos,
        "IP address       HW type     Flags       HW address            Mask     Device\n")
    ifn: Ptr[uint8] = nd_name_ptr()
    n: uint64 = arp_cache_size()
    i: uint64 = 0
    while i < n:
        if arp_slot_valid(i) != 0:
            ip_hi: uint32 = arp_slot_ip(i)
            # "10.0.2.2        " — dotted quad left-justified in 16 cols.
            start: uint64 = pos
            pos = _net_put_dotted(buf, pos, ip_hi)
            while pos - start < 16:
                buf[pos] = 32
                pos = pos + 1
            pos = _buf_put_str(buf, pos, "0x1         0x2         ")
            # MAC "aa:bb:cc:dd:ee:ff"
            j: uint64 = 0
            while j < 6:
                if j > 0:
                    buf[pos] = 58
                    pos = pos + 1
                pos = _buf_put_hex2(buf, pos, arp_slot_mac_byte(i, j))
                j = j + 1
            pos = _buf_put_str(buf, pos, "     *        ")
            pos = _net_put_ifname(buf, pos, ifn)
            buf[pos] = 10
            pos = pos + 1
        i = i + 1
    return pos


def render_net_route(buf: Ptr[uint8]) -> uint64:
    # /proc/net/route — kernel routing table, tab-separated, Linux
    # format. Addresses are little-endian hex of the network-order
    # address. We emit two routes when configured: the default route
    # (0.0.0.0 via gateway, flags 0x3 = UP|GATEWAY) and the on-link
    # subnet route (network/netmask, gateway 0.0.0.0, flags 0x1 = UP).
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos,
        "Iface\tDestination\tGateway \tFlags\tRefCnt\tUse\tMetric\tMask\t\tMTU\tWindow\tIRTT\n")
    ifn: Ptr[uint8] = nd_name_ptr()
    mtu: uint64 = cast[uint64](nd_mtu_get())
    # Default route via the gateway.
    if ip_have_gateway() != 0:
        gw_hi: uint32 = _net_gateway_hi()
        pos = _net_put_ifname(buf, pos, ifn)
        buf[pos] = 9
        pos = pos + 1
        pos = _buf_put_hex8(buf, pos, 0)                 # dest 0.0.0.0
        buf[pos] = 9
        pos = pos + 1
        pos = _buf_put_hex8(buf, pos, _swap32(gw_hi))    # gateway LE
        pos = _buf_put_str(buf, pos, "\t0003\t0\t0\t0\t")
        pos = _buf_put_hex8(buf, pos, 0)                 # mask 0.0.0.0
        pos = _net_put_route_tail(buf, pos, mtu)
    # On-link subnet route.
    if ip_have_our_ip() != 0:
        mask_hi: uint32 = _net_netmask_hi()
        net_hi: uint32 = _net_our_ip_hi() & mask_hi
        pos = _net_put_ifname(buf, pos, ifn)
        buf[pos] = 9
        pos = pos + 1
        pos = _buf_put_hex8(buf, pos, _swap32(net_hi))   # dest = network
        buf[pos] = 9
        pos = pos + 1
        pos = _buf_put_hex8(buf, pos, 0)                 # gateway 0.0.0.0
        pos = _buf_put_str(buf, pos, "\t0001\t0\t0\t0\t")
        pos = _buf_put_hex8(buf, pos, _swap32(mask_hi))  # mask LE
        pos = _net_put_route_tail(buf, pos, mtu)
    return pos


def render_net_dev(buf: Ptr[uint8]) -> uint64:
    # /proc/net/dev — two header lines, then one row per interface. We
    # have a loopback (synthetic, all-zero counters) and the single real
    # NIC. We track packet counters but no byte counters, so the bytes
    # columns are 0 and the *_packets columns carry the real counts.
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos,
        "Inter-|   Receive                                                |  Transmit\n")
    pos = _buf_put_str(buf, pos,
        " face |bytes    packets errs drop fifo frame compressed multicast|bytes    packets errs drop fifo colls carrier compressed\n")
    # lo — synthetic loopback, all zeros.
    pos = _net_put_dev_row(buf, pos, "lo", 0, 0, 0, 0)
    # The real NIC. nd_name is empty until the driver sets it; fall back
    # to "eth0" so the row is always greppable.
    ifn: Ptr[uint8] = nd_name_ptr()
    if ifn[0] == 0:
        pos = _net_put_dev_row(buf, pos, "eth0",
                               nd_rx_pkts_get(), nd_rx_drop_get(),
                               nd_tx_pkts_get(), 0)
    else:
        pos = _net_put_dev_row_p(buf, pos, ifn,
                                 nd_rx_pkts_get(), nd_rx_drop_get(),
                                 nd_tx_pkts_get(), 0)
    return pos


def render_net_sockstat(buf: Ptr[uint8]) -> uint64:
    # /proc/net/sockstat — kernel socket usage summary. Linux format:
    #   sockets: used <N>
    #   TCP: inuse <N> orphan <N> tw <N> alloc <N> mem <N>
    #   UDP: inuse <N> mem <N>
    #   UDPLITE: inuse <N>
    #   RAW: inuse <N>
    #   FRAG: inuse <N> memory <N>
    # We count from two sources: the TCB table (active TCPs in non-CLOSED
    # state, including LISTENers) and the kernel socket table
    # (KSOCK_STREAM/DGRAM/RAW slots in non-FREE state). "tw" counts TIME_WAIT
    # TCPs specifically. orphan/mem/UDPLITE/FRAG are untracked → 0.
    tcp_inuse: uint64 = 0
    tcp_tw: uint64 = 0
    tcp_alloc: uint64 = 0
    n: uint64 = tcp_num_slots()
    i: uint64 = 0
    while i < n:
        st: uint32 = tcp_slot_st(i)
        if st != TCP_CLOSED:
            tcp_inuse = tcp_inuse + 1
            tcp_alloc = tcp_alloc + 1
            if st == 10:                            # our TIME_WAIT
                tcp_tw = tcp_tw + 1
        i = i + 1
    udp_inuse: uint64 = 0
    raw_inuse: uint64 = 0
    stream_inuse: uint64 = 0                        # ksock STREAMs (rare)
    i = 0
    while i < KSOCK_MAX:
        if ksock_slot_state(i) != SS_FREE:
            t: int32 = ksock_slot_type(i)
            if t == KSOCK_DGRAM:
                udp_inuse = udp_inuse + 1
            else:
                if t == KSOCK_RAW:
                    raw_inuse = raw_inuse + 1
                else:
                    if t == KSOCK_STREAM:
                        stream_inuse = stream_inuse + 1
        i = i + 1
    # "sockets: used" is the total across all families/types.
    total: uint64 = tcp_inuse + udp_inuse + raw_inuse + stream_inuse
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "sockets: used ")
    pos = _buf_put_dec(buf, pos, total)
    buf[pos] = 10
    pos = pos + 1
    pos = _buf_put_str(buf, pos, "TCP: inuse ")
    pos = _buf_put_dec(buf, pos, tcp_inuse)
    pos = _buf_put_str(buf, pos, " orphan 0 tw ")
    pos = _buf_put_dec(buf, pos, tcp_tw)
    pos = _buf_put_str(buf, pos, " alloc ")
    pos = _buf_put_dec(buf, pos, tcp_alloc)
    pos = _buf_put_str(buf, pos, " mem 0\n")
    pos = _buf_put_str(buf, pos, "UDP: inuse ")
    pos = _buf_put_dec(buf, pos, udp_inuse)
    pos = _buf_put_str(buf, pos, " mem 0\n")
    pos = _buf_put_str(buf, pos, "UDPLITE: inuse 0\n")
    pos = _buf_put_str(buf, pos, "RAW: inuse ")
    pos = _buf_put_dec(buf, pos, raw_inuse)
    buf[pos] = 10
    pos = pos + 1
    pos = _buf_put_str(buf, pos, "FRAG: inuse 0 memory 0\n")
    return pos


# --- small render helpers shared by the /proc/net family ------------

def _net_ntohs(v: uint16) -> uint16:
    # Network->host 16-bit swap (the socket table stores ports in
    # network order; %04X wants host order so the printed hex matches
    # Linux which prints the network-order value byte-swapped).
    return cast[uint16]((cast[uint32](v) >> 8) | ((cast[uint32](v) & 0xFF) << 8))


def _net_our_ip_hi() -> uint32:
    b0: uint32 = cast[uint32](ip_our_ip_b(0))
    b1: uint32 = cast[uint32](ip_our_ip_b(1))
    b2: uint32 = cast[uint32](ip_our_ip_b(2))
    b3: uint32 = cast[uint32](ip_our_ip_b(3))
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3


def _net_gateway_hi() -> uint32:
    b0: uint32 = cast[uint32](ip_gateway_b(0))
    b1: uint32 = cast[uint32](ip_gateway_b(1))
    b2: uint32 = cast[uint32](ip_gateway_b(2))
    b3: uint32 = cast[uint32](ip_gateway_b(3))
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3


def _net_netmask_hi() -> uint32:
    # When no netmask is configured, default to /24 (255.255.255.0) so
    # the on-link route still has a sane mask.
    if ip_have_netmask() == 0:
        return 0xFFFFFF00
    b0: uint32 = cast[uint32](ip_netmask_b(0))
    b1: uint32 = cast[uint32](ip_netmask_b(1))
    b2: uint32 = cast[uint32](ip_netmask_b(2))
    b3: uint32 = cast[uint32](ip_netmask_b(3))
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3


def _net_put_dotted(buf: Ptr[uint8], pos: uint64, ip_hi: uint32) -> uint64:
    # Dotted-quad from a first-octet-high packed IP.
    pos = _buf_put_dec(buf, pos, cast[uint64]((ip_hi >> 24) & 0xFF))
    buf[pos] = 46
    pos = pos + 1
    pos = _buf_put_dec(buf, pos, cast[uint64]((ip_hi >> 16) & 0xFF))
    buf[pos] = 46
    pos = pos + 1
    pos = _buf_put_dec(buf, pos, cast[uint64]((ip_hi >> 8) & 0xFF))
    buf[pos] = 46
    pos = pos + 1
    pos = _buf_put_dec(buf, pos, cast[uint64](ip_hi & 0xFF))
    return pos


def _net_put_ifname(buf: Ptr[uint8], pos: uint64, ifn: Ptr[uint8]) -> uint64:
    # Interface name, with an "eth0" fallback when nd_name is empty.
    if ifn[0] == 0:
        return _buf_put_str(buf, pos, "eth0")
    return _buf_put_str(buf, pos, ifn)


def _net_put_route_tail(buf: Ptr[uint8], pos: uint64, mtu: uint64) -> uint64:
    # "\tMTU\t0\t0\n" — MTU then Window/IRTT (both 0).
    buf[pos] = 9
    pos = pos + 1
    pos = _buf_put_dec(buf, pos, mtu)
    pos = _buf_put_str(buf, pos, "\t0\t0\n")
    return pos


def _net_put_dev_counts(buf: Ptr[uint8], pos: uint64, rx_pkts: uint64,
                        rx_drop: uint64, tx_pkts: uint64,
                        tx_drop: uint64) -> uint64:
    # The 16 counter columns. bytes/errs/fifo/frame/compressed/multicast
    # /colls/carrier are untracked (0); packets + drop are real.
    #   RX: bytes packets errs drop fifo frame compressed multicast
    pos = _buf_put_str(buf, pos, "       0 ")        # rx bytes
    pos = _buf_put_dec(buf, pos, rx_pkts)
    buf[pos] = 32
    pos = pos + 1
    pos = _buf_put_str(buf, pos, "0 ")               # errs
    pos = _buf_put_dec(buf, pos, rx_drop)
    pos = _buf_put_str(buf, pos, " 0 0 0 0")         # fifo frame compr mcast
    #   TX: bytes packets errs drop fifo colls carrier compressed
    pos = _buf_put_str(buf, pos, "        0 ")       # tx bytes
    pos = _buf_put_dec(buf, pos, tx_pkts)
    buf[pos] = 32
    pos = pos + 1
    pos = _buf_put_str(buf, pos, "0 ")               # errs
    pos = _buf_put_dec(buf, pos, tx_drop)
    pos = _buf_put_str(buf, pos, " 0 0 0 0\n")       # fifo colls carrier compr
    return pos


def _net_put_dev_row(buf: Ptr[uint8], pos: uint64, name: Ptr[uint8],
                     rx_pkts: uint64, rx_drop: uint64,
                     tx_pkts: uint64, tx_drop: uint64) -> uint64:
    # "<name>: <counts>\n". /proc/net/dev right-justifies the name in a
    # 6-char field; we keep it simple-but-parseable (leading spaces +
    # name + ':').
    start: uint64 = pos
    pos = _buf_put_str(buf, pos, name)
    # Right-justify is cosmetic; Linux tools split on ':' so a plain
    # "name:" works. Pad to align the common 1-2 char names anyway.
    while pos - start < 6:
        buf[pos] = 32
        pos = pos + 1
    buf[pos] = 58
    pos = pos + 1
    return _net_put_dev_counts(buf, pos, rx_pkts, rx_drop, tx_pkts, tx_drop)


def _net_put_dev_row_p(buf: Ptr[uint8], pos: uint64, name: Ptr[uint8],
                       rx_pkts: uint64, rx_drop: uint64,
                       tx_pkts: uint64, tx_drop: uint64) -> uint64:
    # Same as _net_put_dev_row but name comes from a live buffer ptr.
    return _net_put_dev_row(buf, pos, name, rx_pkts, rx_drop,
                            tx_pkts, tx_drop)


def procnet_selftest() -> int32:
    # Boot self-test: render each /proc/net node and assert the header
    # line and basic shape are present. Returns 1 on PASS, 0 on FAIL.
    n: uint64 = render_net_tcp(&procnet_selftest_buf[0])
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n,
            "local_address rem_address") == 0:
        printk0("[PROCNET] FAIL /proc/net/tcp header missing\n")
        return 0
    n = render_net_udp(&procnet_selftest_buf[0])
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n,
            "local_address rem_address") == 0:
        printk0("[PROCNET] FAIL /proc/net/udp header missing\n")
        return 0
    n = render_net_arp(&procnet_selftest_buf[0])
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n,
            "HW address") == 0:
        printk0("[PROCNET] FAIL /proc/net/arp header missing\n")
        return 0
    n = render_net_route(&procnet_selftest_buf[0])
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n,
            "Destination") == 0:
        printk0("[PROCNET] FAIL /proc/net/route header missing\n")
        return 0
    n = render_net_dev(&procnet_selftest_buf[0])
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n,
            "face |bytes") == 0:
        printk0("[PROCNET] FAIL /proc/net/dev header missing\n")
        return 0
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n, "lo") == 0:
        printk0("[PROCNET] FAIL /proc/net/dev lo row missing\n")
        return 0
    n = render_net_sockstat(&procnet_selftest_buf[0])
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n,
            "sockets: used") == 0:
        printk0("[PROCNET] FAIL /proc/net/sockstat header missing\n")
        return 0
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n, "TCP: inuse") == 0:
        printk0("[PROCNET] FAIL /proc/net/sockstat TCP row missing\n")
        return 0
    if _cpuinfo_buf_contains(&procnet_selftest_buf[0], n, "UDP: inuse") == 0:
        printk0("[PROCNET] FAIL /proc/net/sockstat UDP row missing\n")
        return 0
    printk0("[PROCNET] PASS tcp/udp/arp/route/dev/sockstat rendered\n")
    return 1


# -------------------------------------------------------------------
# /sys/fs/cgroup — cgroup v2 (unified hierarchy) pseudo-filesystem
#
# Linux-ABI furniture for the Linux namespace, NOT the native Hamnix
# resource model. Native per-namespace resource control is Plan-9-shape
# (sys/src/9/port/devnscap.ad, #174) and is deliberately NOT routed
# through here. This is a mostly-read-only, structurally-correct
# cgroup2 view so stock Debian/systemd userland that probes
# /sys/fs/cgroup at startup (systemd, systemd-detect-virt, container
# tools, many daemons) finds the interface files it expects.
#
# cgroup v2 = a single unified hierarchy. We present only the root
# cgroup: every live process is a member of the root cgroup (there are
# no sub-cgroups), which is exactly what a freshly-booted system with
# no delegated cgroups looks like. The root interface files are:
#
#   cgroup.controllers      enabled controllers: "cpu memory pids\n"
#   cgroup.subtree_control  controllers enabled on children (empty)
#   cgroup.procs            one pid per line — root cgroup membership
#   cgroup.type             "domain\n" (the root is always a domain)
#   cgroup.max.depth        "max\n"
#   cgroup.max.descendants  "max\n"
#   cpu.stat                usage_usec/user_usec/system_usec ("0")
#   memory.current          bytes charged to the root cgroup
#   memory.max              "max\n" (root is uncapped)
#   pids.current            live process count
#   pids.max                "max\n" (root is uncapped)
#
# Values backed by real native accounting where cheap:
#   - memory.current = in-use page frames * PAGE_SIZE (page_alloc)
#   - pids.current   = live task slots (same walk as render_tasks)
#   - cgroup.procs   = the live pids themselves
# Caps render the literal string "max" (cgroup v2 convention for "no
# limit"); cpu.stat counters render 0 until per-cgroup CPU accounting
# exists — a structurally-valid file is the bar.

def render_cgroup_controllers(buf: Ptr[uint8]) -> uint64:
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "cpu memory pids\n")
    return pos


def render_cgroup_subtree_control(buf: Ptr[uint8]) -> uint64:
    # No controllers enabled on children of the root: empty file
    # (a single newline is the canonical "empty" cgroup2 read).
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "\n")
    return pos


def render_cgroup_procs(buf: Ptr[uint8]) -> uint64:
    # One pid per line — every live process is in the root cgroup.
    # Same task-table walk as render_tasks(); no header (cgroup.procs
    # is a bare pid list, newline-separated).
    pos: uint64 = 0
    n: uint64 = task_table_size()
    i: uint64 = 0
    while i < n:
        slot: int32 = cast[int32](i)
        st: uint64 = task_state(slot)
        if st != STATE_FREE:
            pos = _buf_put_dec(buf, pos, task_pid_at(slot))
            buf[pos] = 10               # newline
            pos = pos + 1
        i = i + 1
    return pos


def render_cgroup_type(buf: Ptr[uint8]) -> uint64:
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "domain\n")
    return pos


def render_cgroup_max_str(buf: Ptr[uint8]) -> uint64:
    # cgroup.max.depth / cgroup.max.descendants / memory.max / pids.max
    # all read "max" when uncapped (cgroup v2 convention).
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "max\n")
    return pos


def render_cgroup_cpu_stat(buf: Ptr[uint8]) -> uint64:
    # Minimal valid cpu.stat. Per-cgroup CPU accounting doesn't exist
    # yet, so the three required counters render 0. Stock parsers
    # (systemd's cgroup-util) accept this verbatim.
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "usage_usec 0\n")
    pos = _buf_put_str(buf, pos, "user_usec 0\n")
    pos = _buf_put_str(buf, pos, "system_usec 0\n")
    return pos


def render_cgroup_memory_current(buf: Ptr[uint8]) -> uint64:
    # Bytes charged to the root cgroup. Backed by real native
    # accounting: in-use page frames * PAGE_SIZE. The root cgroup
    # accounts the whole system, so total-minus-free pages is the
    # honest "current" charge.
    total: uint64 = page_alloc_total()
    free:  uint64 = page_alloc_free_count()
    in_use: uint64 = 0
    if total >= free:
        in_use = total - free
    pos: uint64 = 0
    pos = _buf_put_dec(buf, pos, in_use * 4096)
    buf[pos] = 10
    pos = pos + 1
    return pos


def render_cgroup_pids_current(buf: Ptr[uint8]) -> uint64:
    # Live process count — same task-table walk as cgroup.procs.
    live: uint64 = 0
    n: uint64 = task_table_size()
    i: uint64 = 0
    while i < n:
        if task_state(cast[int32](i)) != STATE_FREE:
            live = live + 1
        i = i + 1
    pos: uint64 = 0
    pos = _buf_put_dec(buf, pos, live)
    buf[pos] = 10
    pos = pos + 1
    return pos


# cgroup v2 paths reach the kernel in TWO spellings depending on the
# caller's namespace:
#   * "/sys/fs/cgroup/..."  — a kernel-context / unrewritten open.
#   * "#r/fs/cgroup/..."    — a userland open after resolve_path: a
#     default Linux task has `/sys` bound to the cpio server `#r`, and
#     since cpio ships no /sys/fs/cgroup files, resolve_path's
#     union-head fallback returns the LOCALIZED head spelling
#     "#r/fs/cgroup/<...>". Every cgroup predicate/dispatcher below
#     canonicalises BOTH spellings to the "/sys/fs/cgroup/..." form via
#     _cg_canon before matching, so the live object graph is reachable
#     from a shell exactly as it is from kernel context.
def _cg_canon(name: Ptr[char], out: Ptr[char]) -> int32:
    # If `name` is a cgroup path in either spelling, write its canonical
    # "/sys/fs/cgroup<tail>" form into `out` (NUL-terminated, <=255) and
    # return 1. Otherwise return 0 (out unspecified).
    src: Ptr[char] = name
    if _path_starts_with(name, "#r/fs/cgroup") != 0:
        # Skip the "#r" (2 bytes); the remainder is "/fs/cgroup<tail>".
        src = cast[Ptr[char]](cast[uint64](name) + 2)
    elif _path_starts_with(name, "/sys/fs/cgroup") != 0:
        src = cast[Ptr[char]](cast[uint64](name) + 4)  # skip "/sys"
    elif _path_starts_with(name, "/fs/cgroup") != 0:
        # The `#r` cpio server localizes onto the "/" root, so
        # resolve_path's union-head fallback for "/sys/fs/cgroup/<...>"
        # actually returns "/fs/cgroup/<...>" (the `#r`-relative tail
        # under the cpio root). This is the spelling a SHELL open
        # produces.
        src = name                                    # already "/fs/cgroup<tail>"
    else:
        return 0
    # `src` now points at "/fs/cgroup<tail>"; emit "/sys" + src.
    pfx: Ptr[char] = "/sys"
    o: uint64 = 0
    i: uint64 = 0
    while cast[uint8](pfx[i]) != 0:
        out[o] = pfx[i]
        o = o + 1
        i = i + 1
    j: uint64 = 0
    while o < 255:
        c: uint8 = cast[uint8](src[j])
        out[o] = cast[char](c)
        if c == 0:
            return 1
        o = o + 1
        j = j + 1
    out[255] = cast[char](0)
    return 1


def is_cgroup_path(name: Ptr[char]) -> int32:
    # True if `name` is a cgroup v2 path in EITHER spelling (see
    # _cg_canon): the localized "#r/fs/cgroup..." or "/sys/fs/cgroup...".
    if _path_starts_with(name, "/sys/fs/cgroup") != 0:
        return 1
    if _path_starts_with(name, "#r/fs/cgroup") != 0:
        return 1
    if _path_starts_with(name, "/fs/cgroup") != 0:
        return 1
    return 0


# F11 (2026-06-13): per-cgroup cpu.max / cpu.stat path arms. Sub-paths
# look like /sys/fs/cgroup/<name>/cpu.max — split that into (<name>,
# <leaf>) so the open / write paths can route to the cgroup_cpu module.
#
# Layer-2-only API: lives in procfs because the cgroup view is the
# Linux-namespace pseudo-fs, and we already do all path-arm dispatch
# here. The Layer-2 cgroup_cpu module owns the cgroup OBJECTS.
def _cg_split(path_in: Ptr[char], name_out: Ptr[char], leaf_out: Ptr[char]) -> int32:
    # Parses "/sys/fs/cgroup/<name>/<leaf>" — copies <name> into
    # name_out (NUL-terminated, max 31 bytes) and <leaf> into leaf_out
    # (NUL-terminated, max 31 bytes). Returns 1 on a clean parse,
    # 0 otherwise.  Rejects empty <name> / empty <leaf> / paths with
    # any further slash segments (single-level only). Accepts both the
    # "/sys/fs/cgroup/..." and the localized "#r/fs/cgroup/..." spelling
    # (canonicalised up front).
    canon: Array[256, char]
    if _cg_canon(path_in, &canon[0]) == 0:
        return 0
    path: Ptr[char] = &canon[0]
    prefix: Ptr[char] = "/sys/fs/cgroup/"
    p: uint64 = 0
    while cast[uint8](prefix[p]) != 0:
        if cast[uint8](path[p]) != cast[uint8](prefix[p]):
            return 0
        p = p + 1
    # p indexes the first byte after "/sys/fs/cgroup/"
    # Reserved root-level names (cgroup.controllers, memory.current,
    # ...) all contain a '.' as their FIRST separator, never a '/' —
    # so the presence of a '/' after `p` and before the trailing NUL
    # distinguishes a nested cgroup from a root leaf.
    n: uint64 = 0
    while n < 31:
        c: uint8 = cast[uint8](path[p + n])
        if c == 0:
            return 0   # no slash → root leaf, not our case
        if c == 47: # '/'
            break
        name_out[n] = cast[char](c)
        n = n + 1
    if n == 0:
        return 0
    if cast[uint8](path[p + n]) != 47:
        return 0
    name_out[n] = cast[char](0)
    # Leaf after the slash.
    q: uint64 = p + n + 1
    m: uint64 = 0
    while m < 31:
        c2: uint8 = cast[uint8](path[q + m])
        if c2 == 0:
            break
        if c2 == 47:
            return 0   # extra slash = nested subgroup, not supported v1
        leaf_out[m] = cast[char](c2)
        m = m + 1
    if m == 0:
        return 0
    leaf_out[m] = cast[char](0)
    return 1


def cgroup_path_match(path_in: Ptr[char]) -> int32:
    # 1 iff `path` is a known cgroup v2 interface file (the set
    # cgroup_render dispatches). Lets the open path check membership
    # WITHOUT rendering into a buffer first. Accepts both spellings via
    # _cg_canon (the "#r/fs/cgroup..." localized form a shell open
    # produces and the "/sys/fs/cgroup..." kernel-context form).
    cm: Array[256, char]
    if _cg_canon(path_in, &cm[0]) == 0:
        return 0
    path: Ptr[char] = &cm[0]
    if _path_eq(path, "/sys/fs/cgroup/cgroup.controllers") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/cgroup.subtree_control") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/cgroup.procs") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/cgroup.type") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/cgroup.max.depth") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/cgroup.max.descendants") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/cpu.stat") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/memory.current") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/memory.max") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/pids.current") != 0:
        return 1
    if _path_eq(path, "/sys/fs/cgroup/pids.max") != 0:
        return 1
    # F11: nested cgroup leaves we support.
    cg_name_buf: Array[64, char]
    cg_leaf_buf: Array[64, char]
    if _cg_split(path, &cg_name_buf[0], &cg_leaf_buf[0]) != 0:
        if _path_eq(&cg_leaf_buf[0], "cpu.max") != 0:
            return 1
        if _path_eq(&cg_leaf_buf[0], "cpu.stat") != 0:
            return 1
        if _path_eq(&cg_leaf_buf[0], "cgroup.procs") != 0:
            return 1
        if _path_eq(&cg_leaf_buf[0], "pids.max") != 0:
            return 1
        if _path_eq(&cg_leaf_buf[0], "pids.current") != 0:
            return 1
        if _path_eq(&cg_leaf_buf[0], "memory.max") != 0:
            return 1
        if _path_eq(&cg_leaf_buf[0], "memory.current") != 0:
            return 1
    return 0


def cgroup_render(path_in: Ptr[char], buf: Ptr[uint8]) -> int64:
    # Dispatch a /sys/fs/cgroup/<file> path to its renderer. Returns
    # bytes written, or -1 for an unknown path. Mirrors proc_render's
    # shape; the open path in fs/vfs.ad gates on is_cgroup_path() first.
    # Accepts both spellings via _cg_canon (see cgroup_path_match).
    cr: Array[256, char]
    if _cg_canon(path_in, &cr[0]) == 0:
        return cast[int64](-1)
    path: Ptr[char] = &cr[0]
    if _path_eq(path, "/sys/fs/cgroup/cgroup.controllers") != 0:
        return cast[int64](render_cgroup_controllers(buf))
    if _path_eq(path, "/sys/fs/cgroup/cgroup.subtree_control") != 0:
        return cast[int64](render_cgroup_subtree_control(buf))
    if _path_eq(path, "/sys/fs/cgroup/cgroup.procs") != 0:
        return cast[int64](render_cgroup_procs(buf))
    if _path_eq(path, "/sys/fs/cgroup/cgroup.type") != 0:
        return cast[int64](render_cgroup_type(buf))
    if _path_eq(path, "/sys/fs/cgroup/cgroup.max.depth") != 0:
        return cast[int64](render_cgroup_max_str(buf))
    if _path_eq(path, "/sys/fs/cgroup/cgroup.max.descendants") != 0:
        return cast[int64](render_cgroup_max_str(buf))
    if _path_eq(path, "/sys/fs/cgroup/cpu.stat") != 0:
        return cast[int64](render_cgroup_cpu_stat(buf))
    if _path_eq(path, "/sys/fs/cgroup/memory.current") != 0:
        return cast[int64](render_cgroup_memory_current(buf))
    if _path_eq(path, "/sys/fs/cgroup/memory.max") != 0:
        return cast[int64](render_cgroup_max_str(buf))
    if _path_eq(path, "/sys/fs/cgroup/pids.current") != 0:
        return cast[int64](render_cgroup_pids_current(buf))
    if _path_eq(path, "/sys/fs/cgroup/pids.max") != 0:
        return cast[int64](render_cgroup_max_str(buf))
    # F11: nested per-cgroup files.
    cg_name_buf: Array[64, char]
    cg_leaf_buf: Array[64, char]
    if _cg_split(path, &cg_name_buf[0], &cg_leaf_buf[0]) != 0:
        slot: int32 = cgroup_cpu_lookup(&cg_name_buf[0])
        if slot < 1:
            return -1
        if _path_eq(&cg_leaf_buf[0], "cpu.max") != 0:
            return cast[int64](cgroup_cpu_render_max(slot, buf))
        if _path_eq(&cg_leaf_buf[0], "cpu.stat") != 0:
            return cast[int64](cgroup_cpu_render_stat(slot, buf))
        if _path_eq(&cg_leaf_buf[0], "cgroup.procs") != 0:
            # The "members of this cgroup" file: walk g_task_cg and
            # print pids of tasks assigned to this slot. Implementation
            # stays in cgroup_cpu.ad via a render helper.
            return cast[int64](cgroup_cpu_render_procs(slot, buf))
        if _path_eq(&cg_leaf_buf[0], "pids.max") != 0:
            return cast[int64](cgroup_pids_render_max(slot, buf))
        if _path_eq(&cg_leaf_buf[0], "pids.current") != 0:
            return cast[int64](cgroup_pids_render_current(slot, buf))
        if _path_eq(&cg_leaf_buf[0], "memory.max") != 0:
            return cast[int64](cgroup_mem_render_max(slot, buf))
        if _path_eq(&cg_leaf_buf[0], "memory.current") != 0:
            return cast[int64](cgroup_mem_render_current(slot, buf))
    return -1


# =====================================================================
# cgroup v2 WRITE / MKDIR surface — fs ops reach the live object graph
# =====================================================================
#
# These are the filesystem-side dispatchers the cgroupfs server's
# mkdir / rmdir / write handlers call so a shell can drive the live
# controllers:
#   mkdir /sys/fs/cgroup/<g>             -> cgroup_cpu_mkdir
#   rmdir /sys/fs/cgroup/<g>             -> cgroup_cpu_rmdir
#   echo N   > .../<g>/pids.max          -> cgroup_pids_write_max
#   echo N   > .../<g>/memory.max        -> cgroup_mem_write_max
#   echo Q P > .../<g>/cpu.max           -> cgroup_cpu_write_max
#   echo SLOT> .../<g>/cgroup.procs      -> cgroup_pids_attach_count
# The path-arm split (_cg_split) and the cgroup object lookup
# (cgroup_cpu_lookup) already live in this file; the live-object
# mutators live in kernel/sched/cgroup_cpu.ad. We keep cgroup.procs as
# a SLOT write (matching cgroup_cpu_render_procs, which renders task
# SLOT ids) so the write/read surface round-trips a single handle; the
# vfs layer resolves a real pid -> slot before calling us.

def is_cgroup_subgroup_path(path_in: Ptr[char]) -> int32:
    # 1 iff `path` is exactly "/sys/fs/cgroup/<name>" (a one-level
    # cgroup directory, no leaf). Used by vfs_mkdir / vfs_rmdir to
    # decide a cgroup dir create/remove vs. an on-disk mkdir. Rejects the
    # bare root and any leaf file (which contains a '.' or a second '/').
    # Accepts both spellings via _cg_canon (a userland mkdir's resolved
    # target arrives as "#r/fs/cgroup/<name>").
    canon: Array[256, char]
    if _cg_canon(path_in, &canon[0]) == 0:
        return 0
    path: Ptr[char] = &canon[0]
    prefix: Ptr[char] = "/sys/fs/cgroup/"
    p: uint64 = 0
    while cast[uint8](prefix[p]) != 0:
        if cast[uint8](path[p]) != cast[uint8](prefix[p]):
            return 0
        p = p + 1
    # After the prefix: a non-empty run of name chars with NO '/' and NO
    # '.' (an interface file like cgroup.procs / memory.max always has a
    # '.'; a nested leaf has a '/'). Plain "<name>" -> a subgroup dir.
    n: uint64 = 0
    while True:
        c: uint8 = cast[uint8](path[p + n])
        if c == 0:
            break
        if c == 47:          # '/' -> deeper than one level (leaf path)
            return 0
        if c == 46:          # '.' -> a root interface file, not a dir
            return 0
        n = n + 1
    if n == 0:
        return 0             # bare "/sys/fs/cgroup/" root
    return 1


def _cg_subgroup_name(path_in: Ptr[char], out: Ptr[char]) -> int32:
    # Copy the "<name>" of a "/sys/fs/cgroup/<name>" path into `out`
    # (NUL-terminated, max 31 bytes). Caller has checked
    # is_cgroup_subgroup_path. Returns 1 on success. Canonicalises both
    # spellings (see _cg_canon).
    canon: Array[256, char]
    if _cg_canon(path_in, &canon[0]) == 0:
        return 0
    path: Ptr[char] = &canon[0]
    prefix: Ptr[char] = "/sys/fs/cgroup/"
    p: uint64 = 0
    while cast[uint8](prefix[p]) != 0:
        p = p + 1
    n: uint64 = 0
    while n < 31:
        c: uint8 = cast[uint8](path[p + n])
        if c == 0:
            break
        out[n] = cast[char](c)
        n = n + 1
    out[n] = cast[char](0)
    if n == 0:
        return 0
    return 1


def cgroup_fs_mkdir(path: Ptr[char]) -> int32:
    # mkdir /sys/fs/cgroup/<name> -> create a live cgroup. Returns 0 on
    # success, -17 (-EEXIST) / -28 (-ENOSPC) / -22 (-EINVAL) on failure.
    if is_cgroup_subgroup_path(path) == 0:
        return -22
    nb: Array[64, char]
    if _cg_subgroup_name(path, &nb[0]) == 0:
        return -22
    rc: int32 = cgroup_cpu_mkdir(&nb[0])
    if rc < 1:
        # mkdir returns -1 for already-exists OR no-room. Disambiguate:
        # if the name already resolves, it's EEXIST; else ENOSPC.
        if cgroup_cpu_lookup(&nb[0]) >= 1:
            return -17                      # -EEXIST
        return -28                          # -ENOSPC
    return 0


def cgroup_fs_rmdir(path: Ptr[char]) -> int32:
    # rmdir /sys/fs/cgroup/<name> -> remove an empty live cgroup.
    if is_cgroup_subgroup_path(path) == 0:
        return -22
    nb: Array[64, char]
    if _cg_subgroup_name(path, &nb[0]) == 0:
        return -22
    return cgroup_cpu_rmdir(&nb[0])


def cgroup_fs_is_writable_leaf(path: Ptr[char]) -> int32:
    # 1 iff `path` is a per-cgroup leaf that accepts writes
    # (pids.max / memory.max / cpu.max / cgroup.procs). Lets the open
    # path admit an OWRITE only on a real control file.
    cg_name_buf: Array[64, char]
    cg_leaf_buf: Array[64, char]
    if _cg_split(path, &cg_name_buf[0], &cg_leaf_buf[0]) == 0:
        return 0
    if cgroup_cpu_lookup(&cg_name_buf[0]) < 1:
        return 0
    if _path_eq(&cg_leaf_buf[0], "pids.max") != 0:
        return 1
    if _path_eq(&cg_leaf_buf[0], "memory.max") != 0:
        return 1
    if _path_eq(&cg_leaf_buf[0], "cpu.max") != 0:
        return 1
    if _path_eq(&cg_leaf_buf[0], "cgroup.procs") != 0:
        return 1
    return 0


def cgroup_fs_parse_first_dec(data: Ptr[char], n: uint64,
                              out: Ptr[int64]) -> int32:
    # Parse the FIRST decimal integer in `data[0..n)`, skipping leading
    # whitespace. Returns 1 on success (value in *out), 0 if no digit.
    # Used by the cgroup.procs write to recover a pid.
    i: uint64 = 0
    while i < n:
        c: uint8 = cast[uint8](data[i])
        if c >= 48 and c <= 57:
            break
        if c != 32 and c != 9 and c != 10:
            # A non-space, non-digit lead (e.g. 'max') => no pid.
            return 0
        i = i + 1
    if i >= n:
        return 0
    v: int64 = 0
    got: int32 = 0
    while i < n:
        c2: uint8 = cast[uint8](data[i])
        if c2 < 48 or c2 > 57:
            break
        v = v * 10 + cast[int64](c2 - 48)
        got = 1
        i = i + 1
    if got == 0:
        return 0
    out[0] = v
    return 1


def cgroup_fs_write(path: Ptr[char], data: Ptr[char], n: uint64) -> int64:
    # Dispatch a write to a per-cgroup control file into the live object.
    # Returns the byte count consumed (== n) on success, or a negative
    # errno. The cgroup.procs arm is NOT handled here (it needs a real
    # pid->task-slot resolution that lives in the scheduler, reachable
    # from vfs.ad); vfs.ad routes cgroup.procs through cgroup_fs_attach
    # after resolving the pid. pids.max/memory.max/cpu.max are pure
    # parse+set and resolve entirely here.
    cg_name_buf: Array[64, char]
    cg_leaf_buf: Array[64, char]
    if _cg_split(path, &cg_name_buf[0], &cg_leaf_buf[0]) == 0:
        return cast[int64](-22)             # -EINVAL: not a leaf path
    slot: int32 = cgroup_cpu_lookup(&cg_name_buf[0])
    if slot < 1:
        return cast[int64](-2)              # -ENOENT
    rc: int32 = 0
    if _path_eq(&cg_leaf_buf[0], "pids.max") != 0:
        rc = cgroup_pids_write_max(slot, data, n)
    elif _path_eq(&cg_leaf_buf[0], "memory.max") != 0:
        rc = cgroup_mem_write_max(slot, data, n)
    elif _path_eq(&cg_leaf_buf[0], "cpu.max") != 0:
        rc = cgroup_cpu_write_max(slot, data, n)
    else:
        return cast[int64](-13)             # -EACCES: read-only leaf
    if rc != 0:
        return cast[int64](rc)
    return cast[int64](n)


def cgroup_fs_attach(path: Ptr[char], task_slot: uint64) -> int64:
    # cgroup.procs write arm: move `task_slot` into the cgroup named by
    # `path`. Caller (vfs.ad) has resolved the written pid -> task slot.
    # Returns 0 on success, negative errno on failure.
    cg_name_buf: Array[64, char]
    cg_leaf_buf: Array[64, char]
    if _cg_split(path, &cg_name_buf[0], &cg_leaf_buf[0]) == 0:
        return cast[int64](-22)
    if _path_eq(&cg_leaf_buf[0], "cgroup.procs") == 0:
        return cast[int64](-22)
    slot: int32 = cgroup_cpu_lookup(&cg_name_buf[0])
    if slot < 1:
        return cast[int64](-2)
    rc: int32 = cgroup_pids_attach_count(slot, task_slot)
    if rc != 0:
        return cast[int64](rc)
    return cast[int64](0)


def cgroup_fs_path_is_procs(path: Ptr[char]) -> int32:
    # 1 iff `path` is ".../<g>/cgroup.procs". Lets vfs.ad pick the
    # pid-resolving attach arm vs. the plain parse arm.
    cg_name_buf: Array[64, char]
    cg_leaf_buf: Array[64, char]
    if _cg_split(path, &cg_name_buf[0], &cg_leaf_buf[0]) == 0:
        return 0
    if _path_eq(&cg_leaf_buf[0], "cgroup.procs") != 0:
        return 1
    return 0


# =====================================================================
# /sys/devices/system/node/ — NUMA node topology (single-node, honest)
# =====================================================================
#
# Linux-ABI furniture for numactl / numastat / libnuma. Hamnix presents a
# SINGLE NUMA node (node 0). These files are exactly what a one-node Linux box
# exposes, rendered from the same live total/free-mem counters /proc/meminfo
# uses and the real online-CPU count:
#
#   /sys/devices/system/node/online        -> "0\n"   (online node list)
#   /sys/devices/system/node/possible      -> "0\n"   (possible node list)
#   /sys/devices/system/node/has_memory    -> "0\n"
#   /sys/devices/system/node/has_normal_memory -> "0\n"
#   /sys/devices/system/node/has_cpu       -> "0\n"
#   /sys/devices/system/node/node0/meminfo -> per-node MemTotal/MemFree/...
#   /sys/devices/system/node/node0/cpulist -> "0-<n-1>\n" (CPUs on node 0)
#   /sys/devices/system/node/node0/cpumap  -> hex CPU bitmask
#
# numactl --hardware reads online + node0/meminfo + node0/cpumap; numastat
# reads node0/meminfo. On one node every CPU and all memory belong to node 0,
# which is the honest answer.

def render_node_online(buf: Ptr[uint8]) -> uint64:
    # The kernel-format node list. One node -> "0".
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "0\n")
    return pos


def render_node0_meminfo(buf: Ptr[uint8]) -> uint64:
    # Per-node meminfo, kernel format: "Node 0 MemTotal: <kB> kB" etc.
    # On a single node the whole system's memory belongs to node 0, so the
    # totals match /proc/meminfo. numastat parses MemTotal/MemFree/MemUsed.
    total_kb: uint64 = page_alloc_total() * 4
    free_kb:  uint64 = page_alloc_free_count() * 4
    used_kb:  uint64 = 0
    if total_kb >= free_kb:
        used_kb = total_kb - free_kb
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "Node 0 MemTotal:       ")
    pos = _buf_put_dec(buf, pos, total_kb)
    pos = _buf_put_str(buf, pos, " kB\n")
    pos = _buf_put_str(buf, pos, "Node 0 MemFree:        ")
    pos = _buf_put_dec(buf, pos, free_kb)
    pos = _buf_put_str(buf, pos, " kB\n")
    pos = _buf_put_str(buf, pos, "Node 0 MemUsed:        ")
    pos = _buf_put_dec(buf, pos, used_kb)
    pos = _buf_put_str(buf, pos, " kB\n")
    return pos


def render_node0_cpulist(buf: Ptr[uint8]) -> uint64:
    # CPUs belonging to node 0, kernel "cpulist" range format. With N online
    # CPUs that's "0" (N==1) or "0-<N-1>" (N>1).
    ncpu: uint64 = get_cpus_online()
    if ncpu == 0:
        ncpu = 1
    pos: uint64 = 0
    if ncpu == 1:
        pos = _buf_put_str(buf, pos, "0\n")
        return pos
    pos = _buf_put_str(buf, pos, "0-")
    pos = _buf_put_dec(buf, pos, ncpu - 1)
    buf[pos] = 10
    pos = pos + 1
    return pos


def render_node0_cpumap(buf: Ptr[uint8]) -> uint64:
    # CPU bitmask for node 0, kernel "cpumap" hex format (comma-separated
    # 32-bit groups, low group last). With ncpu online CPUs the low `ncpu`
    # bits are set. ncpu <= 32 on the SMP VMs we run, so a single 32-bit
    # group suffices; render it as lowercase hex.
    ncpu: uint64 = get_cpus_online()
    if ncpu == 0:
        ncpu = 1
    if ncpu > 32:
        ncpu = 32
    mask: uint64 = 0
    if ncpu >= 32:
        mask = 0xFFFFFFFF
    else:
        mask = (cast[uint64](1) << ncpu) - 1
    HEX: Ptr[uint8] = "0123456789abcdef"
    pos: uint64 = 0
    # Render the 32-bit mask as 8 hex nibbles, high nibble first.
    i: uint64 = 0
    while i < 8:
        nib: uint64 = (mask >> ((7 - i) * 4)) & 0xF
        buf[pos] = HEX[nib]
        pos = pos + 1
        i = i + 1
    buf[pos] = 10
    pos = pos + 1
    return pos


def is_node_path(name: Ptr[char]) -> int32:
    # True if `name` starts with "/sys/devices/system/node". Covers the
    # node-set files and the per-node node0/ subtree.
    return _path_starts_with(name, "/sys/devices/system/node")


def node_path_match(path: Ptr[char]) -> int32:
    # 1 iff `path` is a known NUMA-node sysfs file (the set node_render
    # dispatches). Lets the open path check membership WITHOUT rendering.
    if _path_eq(path, "/sys/devices/system/node/online") != 0:
        return 1
    if _path_eq(path, "/sys/devices/system/node/possible") != 0:
        return 1
    if _path_eq(path, "/sys/devices/system/node/has_memory") != 0:
        return 1
    if _path_eq(path, "/sys/devices/system/node/has_normal_memory") != 0:
        return 1
    if _path_eq(path, "/sys/devices/system/node/has_cpu") != 0:
        return 1
    if _path_eq(path, "/sys/devices/system/node/node0/meminfo") != 0:
        return 1
    if _path_eq(path, "/sys/devices/system/node/node0/cpulist") != 0:
        return 1
    if _path_eq(path, "/sys/devices/system/node/node0/cpumap") != 0:
        return 1
    return 0


def node_render(path: Ptr[char], buf: Ptr[uint8]) -> int64:
    # Dispatch a /sys/devices/system/node/<file> path to its renderer.
    # Returns bytes written, or -1 for an unknown path. Mirrors
    # cgroup_render; the open path in fs/vfs.ad gates on is_node_path first.
    if _path_eq(path, "/sys/devices/system/node/online") != 0:
        return cast[int64](render_node_online(buf))
    if _path_eq(path, "/sys/devices/system/node/possible") != 0:
        return cast[int64](render_node_online(buf))
    if _path_eq(path, "/sys/devices/system/node/has_memory") != 0:
        return cast[int64](render_node_online(buf))
    if _path_eq(path, "/sys/devices/system/node/has_normal_memory") != 0:
        return cast[int64](render_node_online(buf))
    if _path_eq(path, "/sys/devices/system/node/has_cpu") != 0:
        return cast[int64](render_node_online(buf))
    if _path_eq(path, "/sys/devices/system/node/node0/meminfo") != 0:
        return cast[int64](render_node0_meminfo(buf))
    if _path_eq(path, "/sys/devices/system/node/node0/cpulist") != 0:
        return cast[int64](render_node0_cpulist(buf))
    if _path_eq(path, "/sys/devices/system/node/node0/cpumap") != 0:
        return cast[int64](render_node0_cpumap(buf))
    return -1


def proc_render(path: Ptr[char], buf: Ptr[uint8]) -> int64:
    # Dispatch on path. Returns bytes written, or -1 if the path
    # isn't a known /proc entry. Caller has already established
    # `path` starts with "/proc/" so we only have to match the tail.
    if _path_eq(path, "/proc/version") != 0:
        return cast[int64](render_version(buf))
    if _path_eq(path, "/proc/uptime") != 0:
        return cast[int64](render_uptime(buf))
    if _path_eq(path, "/proc/realtime") != 0:
        return cast[int64](render_realtime(buf))
    if _path_eq(path, "/proc/tasks") != 0:
        return cast[int64](render_tasks(buf))
    if _path_eq(path, "/proc/meminfo") != 0:
        return cast[int64](render_meminfo(buf))
    if _path_eq(path, "/proc/cpuinfo") != 0:
        return cast[int64](render_cpuinfo(buf))
    if _path_eq(path, "/proc/mounts") != 0:
        return cast[int64](render_mounts(buf))
    # /proc/net/* — live network state in Linux text format, so stock
    # Linux tools (netstat, ss, ifconfig, route, arp -a) parse them.
    if _path_eq(path, "/proc/net/tcp") != 0:
        return cast[int64](render_net_tcp(buf))
    if _path_eq(path, "/proc/net/udp") != 0:
        return cast[int64](render_net_udp(buf))
    if _path_eq(path, "/proc/net/arp") != 0:
        return cast[int64](render_net_arp(buf))
    if _path_eq(path, "/proc/net/route") != 0:
        return cast[int64](render_net_route(buf))
    if _path_eq(path, "/proc/net/dev") != 0:
        return cast[int64](render_net_dev(buf))
    if _path_eq(path, "/proc/net/sockstat") != 0:
        return cast[int64](render_net_sockstat(buf))
    if _path_eq(path, "/proc/cmdline") != 0:
        return cast[int64](render_cmdline(buf))
    if _path_eq(path, "/proc/kmsg") != 0:
        # _open_proc sizes the kmsg fd's buffer with proc_buf_size()
        # below — PRINTK_LOG_SIZE bytes — so the snapshot tails the
        # whole ring rather than only the last page.
        return cast[int64](render_kmsg(buf, PRINTK_LOG_SIZE))
    if _path_eq(path, "/proc/oops") != 0:
        # Structured panic record (raw bytes). Sized below in
        # proc_buf_size to ESP_OOPS_RECORD_LEN.
        return cast[int64](render_oops(buf, ESP_OOPS_RECORD_LEN))
    # Phase 8: /proc/fs/{by-name,by-id,anonymous} introspection. The
    # by-name/<word> and by-id/<uuid> arms parse the trailing slug
    # out of the path before dispatching.
    if _path_eq(path, "/proc/fs/anonymous") != 0:
        return cast[int64](render_fs_anonymous(buf))
    if _path_starts_with(path, "/proc/fs/by-name/") != 0:
        word_p: Ptr[char] = cast[Ptr[char]](cast[uint64](path) + 17)
        return cast[int64](render_fs_by_name(word_p, buf))
    if _path_starts_with(path, "/proc/fs/by-id/") != 0:
        uuid_p: Ptr[char] = cast[Ptr[char]](cast[uint64](path) + 15)
        return cast[int64](render_fs_by_id(uuid_p, buf))
    # /proc/svc family — service supervisor mirror. The bare "/proc/svc"
    # (and the directory form "/proc/svc/") dumps every registered
    # service; "/proc/svc/<name>" dumps just one. The check order
    # matters — the prefix match would also fire on bare "/proc/svc/"
    # but no name remains, so we explicitly handle both first.
    if _path_eq(path, "/proc/svc") != 0:
        return cast[int64](render_svc_list(buf))
    if _path_eq(path, "/proc/svc/") != 0:
        return cast[int64](render_svc_list(buf))
    if _path_starts_with(path, "/proc/svc/") != 0:
        name_p: Ptr[char] = cast[Ptr[char]](cast[uint64](path) + 10)
        return cast[int64](render_svc_one(name_p, buf))
    return -1


def proc_buf_size(path: Ptr[char]) -> uint64:
    # Buffer size _open_proc should kmalloc for a given /proc path.
    # Everything renders comfortably into one page except /proc/kmsg,
    # which is a tail of the 64 KiB printk ring: a one-page buffer
    # would silently drop all but the last ~4 KiB of the kernel log,
    # which now matters because the console-loglevel gate routes
    # suppressed messages only into that ring. Give kmsg a buffer the
    # size of the whole ring so `dmesg` retrieves the complete log.
    if _path_eq(path, "/proc/kmsg") != 0:
        return PRINTK_LOG_SIZE
    if _path_eq(path, "/proc/oops") != 0:
        return ESP_OOPS_RECORD_LEN
    if _path_eq(path, "/proc/tasks") != 0:
        return PROC_TASKS_BUF_SIZE
    return 4096


def _path_eq(a: Ptr[char], b: Ptr[char]) -> int32:
    i: int32 = 0
    while True:
        ca: int32 = a[i]
        cb: int32 = b[i]
        if ca != cb:
            return 0
        if ca == 0:
            return 1
        i = i + 1


def _path_starts_with(a: Ptr[char], prefix: Ptr[char]) -> int32:
    # 1 iff `a` starts with `prefix` (NUL-terminated comparison up to
    # the length of `prefix`). Returns 0 on mismatch.
    i: int32 = 0
    while True:
        pc: int32 = prefix[i]
        if pc == 0:
            return 1
        if a[i] != pc:
            return 0
        i = i + 1


def render_fs_anonymous(buf: Ptr[uint8]) -> uint64:
    # `/proc/fs/anonymous` — list of partitions registered as
    # `#part<N>` (no sentinel). The by-id table carries an empty
    # sentinel string for anonymous registrations; we walk it and
    # pick the empties. Lines:
    #
    #   partuuid=<uuid>   anonymous=true
    #
    # The doc spec calls for `#partN -> partuuid` mappings; with the
    # current named-stack we'd need a reverse lookup. The pragmatic
    # render walks by-id and prints any entry whose sentinel field
    # is empty.
    pos: uint64 = 0
    pos = _buf_put_str(buf, pos, "# /proc/fs/anonymous: partitions without sentinel\n")
    n: uint64 = byid_table_size()
    s: uint64 = 0
    found_any: int32 = 0
    while s < 32:
        if byid_table_entry_in_use(s) != 0:
            sent: Ptr[uint8] = byid_table_entry_sentinel(s)
            if sent[0] == 0:
                # anonymous record
                pu: Ptr[uint8] = byid_table_entry_partuuid(s)
                pos = _buf_put_str(buf, pos, "partuuid=")
                pos = _buf_put_str(buf, pos, pu)
                pos = _buf_put_str(buf, pos, "  anonymous=true\n")
                found_any = 1
        s = s + 1
    if found_any == 0:
        pos = _buf_put_str(buf, pos, "(no anonymous partitions registered)\n")
    return pos


def _word_eq_cstr(a: Ptr[uint8], b: Ptr[char]) -> int32:
    # NUL-terminated equality of two C-string views.
    i: uint64 = 0
    while True:
        ca: uint8 = a[i]
        cb: int32 = b[i]
        if ca != cast[uint8](cb & 0xFF):
            return 0
        if ca == 0:
            return 1
        i = i + 1


def render_fs_by_name(word: Ptr[char], buf: Ptr[uint8]) -> uint64:
    # `/proc/fs/by-name/<word>` — render the LIFO stack for a single
    # name as in the doc example:
    #
    #   1 (#home):   partuuid=ABCD-EFGH  sentinel=`home`  dir=`home/`
    #   2 (#home2):  partuuid=1234-5678  sentinel=`home`  dir=`home/`
    pos: uint64 = 0
    # Find the slot whose word matches the request. Linear over
    # name_table; word strings are at most 32 bytes.
    n_slots: uint64 = 32                          # NAME_TABLE_MAX (chan.ad)
    target_slot: int64 = -1
    s: uint64 = 0
    while s < n_slots:
        if name_table_slot_in_use(s) != 0:
            sw: Ptr[uint8] = name_table_slot_word(s)
            if _word_eq_cstr(sw, word) != 0:
                target_slot = cast[int64](s)
                s = n_slots
            else:
                s = s + 1
        else:
            s = s + 1
    pos = _buf_put_str(buf, pos, "# /proc/fs/by-name/")
    pos = _buf_put_cstr(buf, pos, word)
    pos = _buf_put_str(buf, pos, "\n")
    if target_slot < 0:
        pos = _buf_put_str(buf, pos, "(no stack for this word)\n")
        return pos
    # Render top→bottom. name_stack_depth gives total entries; we
    # iterate positions 1..depth.
    word_buf: Array[40, uint8]
    j: int32 = 0
    while j < 40 and word[j] != 0:
        word_buf[j] = cast[uint8](word[j] & 0xFF)
        j = j + 1
    word_buf[j] = 0
    depth: int32 = name_stack_depth(&word_buf[0])
    pp: int32 = 1
    while pp <= depth:
        pu_buf: Array[40, uint8]
        dir_buf: Array[256, uint8]
        if name_lookup_partuuid(&word_buf[0], pp, &pu_buf[0], 40) != 0:
            pu_buf[0] = cast[uint8](63)           # '?'
            pu_buf[1] = 0
        if name_lookup_dir(&word_buf[0], pp, &dir_buf[0], 256) != 0:
            dir_buf[0] = cast[uint8](63)
            dir_buf[1] = 0
        # `pp (#wordN):  partuuid=...  sentinel=`word`  dir=`...`\n`
        pos = _buf_put_dec(buf, pos, cast[uint64](pp))
        pos = _buf_put_str(buf, pos, " (#")
        pos = _buf_put_str(buf, pos, &word_buf[0])
        if pp > 1:
            pos = _buf_put_dec(buf, pos, cast[uint64](pp))
        pos = _buf_put_str(buf, pos, "):  partuuid=")
        pos = _buf_put_str(buf, pos, &pu_buf[0])
        pos = _buf_put_str(buf, pos, "  sentinel=`")
        pos = _buf_put_str(buf, pos, &word_buf[0])
        pos = _buf_put_str(buf, pos, "`  dir=`")
        pos = _buf_put_str(buf, pos, &dir_buf[0])
        pos = _buf_put_str(buf, pos, "`\n")
        pp = pp + 1
    return pos


def render_fs_by_id(partuuid: Ptr[char], buf: Ptr[uint8]) -> uint64:
    # `/proc/fs/by-id/<partuuid>` — render the partition identity
    # record:
    #
    #   partition=<uuid>  sentinel=`<word>`  dir=`<path>`
    #
    # Plus a list of named slots this partition occupies (Phase 9
    # extension; today the simple identity is enough).
    pos: uint64 = 0
    s: uint64 = 0
    found: int64 = -1
    while s < 32:
        if byid_table_entry_in_use(s) != 0:
            pu: Ptr[uint8] = byid_table_entry_partuuid(s)
            if _word_eq_cstr(pu, partuuid) != 0:
                found = cast[int64](s)
                s = 32
            else:
                s = s + 1
        else:
            s = s + 1
    pos = _buf_put_str(buf, pos, "# /proc/fs/by-id/")
    pos = _buf_put_cstr(buf, pos, partuuid)
    pos = _buf_put_str(buf, pos, "\n")
    if found < 0:
        pos = _buf_put_str(buf, pos, "(unknown partition uuid)\n")
        return pos
    fu: uint64 = cast[uint64](found)
    pos = _buf_put_str(buf, pos, "partition=")
    pos = _buf_put_str(buf, pos, byid_table_entry_partuuid(fu))
    pos = _buf_put_str(buf, pos, "  sentinel=`")
    pos = _buf_put_str(buf, pos, byid_table_entry_sentinel(fu))
    pos = _buf_put_str(buf, pos, "`  dir=`")
    pos = _buf_put_str(buf, pos, byid_table_entry_dir(fu))
    pos = _buf_put_str(buf, pos, "`\n")
    return pos


def _buf_put_cstr(buf: Ptr[uint8], pos: uint64, s: Ptr[char]) -> uint64:
    # Like _buf_put_str but for Ptr[char] inputs (procfs's path uses
    # this type from the VFS surface).
    i: uint64 = 0
    while s[i] != 0:
        buf[pos + i] = cast[uint8](s[i] & 0xFF)
        i = i + 1
    return pos + i



# fs/procfs.ad
#
# Tiny read-only /proc — mirrors fs/proc/*.c in Linux at the smallest
# shipping scope. We don't have a real directory abstraction yet, so
# the set of paths is fixed (no readdir, no /proc/<pid>/ wildcards).
# The supported paths are:
#
#   /proc/version    one-line kernel banner
#   /proc/uptime     centiseconds since boot, as "<u> cs (<j> jiffies)\n"
#   /proc/tasks      one line per live task slot:
#                    "<pid> <state> <comm>\n"
#
# Each open renders into a fresh kmalloc'd buffer; subsequent reads
# serve from that snapshot. That means /proc/uptime read after a
# 1-second sleep won't tick if you don't reopen — same trade-off
# Linux makes for the simpler procfs entries (text is captured at
# read time, not stream time).
#
# Caller contract: render_*() writes into a 1-page buffer (4096 bytes
# is plenty for any of these) and returns the number of bytes written.

from kernel.sched.core import (
    STATE_FREE, STATE_READY, STATE_RUNNING, STATE_EXITED, STATE_WAIT,
    STATE_REAPING,
    task_state, task_pid_at, task_name0_at, task_table_size,
    get_task_comm_ptr,
    # Per-task cumulative CPU-time accounting (HZ=100, 1 tick = 1 cs).
    # /proc/tasks appends these as trailing UTIME/STIME columns so a
    # graphical monitor (hammonscene) can delta them into a per-process
    # CPU%. Appended AFTER comm so COMM stays field 3 — every existing
    # `awk -F'\t' $3` consumer (ps/pgrep/test_proc_tasks_comm) is unaffected.
    task_utime_ticks_at, task_stime_ticks_at,
    # F2 #447: svc_ctl_text_apply / proc_ctl_apply_pri set the current
    # task's errstr on a malformed verb so the write(2) caller sees a
    # readable reason via SYS_ERRSTR.
    set_current_errstr,
)
from arch.x86.kernel.time import get_jiffies, tsc_hz_get
from arch.x86.kernel.smp import get_cpus_online
from mm.page_alloc import page_alloc_total, page_alloc_free_count
from kernel.printk.printk_log import printk_log_snapshot, PRINTK_LOG_SIZE
from kernel.printk.printk import printk0, printk2
# F11 (2026-06-13): per-cgroup cpu.max / cpu.stat / cgroup.procs
# renderers live in the Layer-2 cgroup_cpu module which owns the
# cgroup objects. procfs only routes paths to them.
from kernel.sched.cgroup_cpu import (
    cgroup_cpu_lookup, cgroup_cpu_render_max,
    cgroup_cpu_render_stat, cgroup_cpu_render_procs,
    # cgroup v2 pids + memory controller renders (per-cgroup leaves).
    cgroup_pids_render_max, cgroup_pids_render_current,
    cgroup_mem_render_max, cgroup_mem_render_current,
    # cgroup v2 WRITE/MKDIR surface — the fs ops below mutate the live
    # object graph (mkdir/rmdir a cgroup; echo into pids.max/memory.max/
    # cpu.max; echo a task slot into cgroup.procs).
    cgroup_cpu_mkdir, cgroup_cpu_rmdir,
    cgroup_pids_write_max, cgroup_mem_write_max, cgroup_cpu_write_max,
    cgroup_pids_attach_count,
)
# /proc/oops: hand userland the raw 548-byte panic record off OOPS.BIN
# so `oopsread` (and any future shim) can render it human-readable.
# Plan 9 shape: the panic is exposed as a FILE, not a syscall.
from kernel.printk.esp_log import (
    esp_log_read_oops, esp_log_oops_is_ready, ESP_OOPS_RECORD_LEN,
)

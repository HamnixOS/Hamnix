# fs/vfs_mount.ad
#
# Multi-mount VFS scaffold. Currently fs/vfs.ad hardcodes path
# prefix routing; this module sketches the future structure where
# every mount is a record in a table, looked up by longest-prefix
# match. Linux mapping: fs/namespace.c + struct vfsmount.
#
# This is L-track + U-series infrastructure. Not wired yet.

from kernel.printk.printk import printk0, printk1, printk2


# Mount table entry. Per real Linux, each mount carries a
# (mountpoint, fs_type, root_inode, super_block) tuple. We track
# enough for prefix routing + handler dispatch.

MNT_NAME_MAX:    uint64 = 32
MOUNT_TABLE_MAX: uint64 = 16

# fs_kind enumeration. 0 means an unused slot. The numeric values
# get cross-checked against the real driver tables when those land;
# for now they're just discriminators so mount_lookup() callers can
# fan out without re-parsing the path.
FS_KIND_UNUSED: uint32 = 0
FS_KIND_CPIO:   uint32 = 1
FS_KIND_PROCFS: uint32 = 2
FS_KIND_TMPFS:  uint32 = 3
FS_KIND_FAT:    uint32 = 4
FS_KIND_EXT4:   uint32 = 5
FS_KIND_DEVFS:  uint32 = 6


class MountEntry:
    used:        uint32
    fs_kind:     uint32      # 0=unused, 1=cpio, 2=procfs, 3=tmpfs, 4=fat, 5=ext4, 6=devfs
    name_len:    uint32
    pad:         uint32
    mountpoint:  Array[32, uint8]    # NUL-terminated path
    private:     uint64              # FS-specific cookie (slot id, etc)


mount_table: Array[16, MountEntry]
nr_mounts:   uint64 = 0


def _cstr_len(s: Ptr[char]) -> uint64:
    # NUL-terminated C string length. Caps at MNT_NAME_MAX so a
    # caller passing junk can't run us off the end of mappable
    # memory (mountpoints in the table are 32 bytes max).
    i: uint64 = 0
    while i < MNT_NAME_MAX:
        if s[i] == 0:
            return i
        i = i + 1
    return MNT_NAME_MAX


def _name_copy(dst: Ptr[uint8], src: Ptr[char], max: uint64) -> uint32:
    # Copy NUL-terminated src into dst, cap at max-1. Returns the
    # byte count written (NOT counting the terminator) or 0 if src
    # was too long. Same shape as fs/tmpfs.ad::_name_copy.
    i: uint64 = 0
    while i + 1 < max:
        c: uint8 = cast[uint8](src[i] & 0xFF)
        dst[i] = c
        if c == 0:
            return cast[uint32](i)
        i = i + 1
    if src[i] == 0:
        dst[i] = 0
        return cast[uint32](i)
    return 0


def _is_prefix(prefix: Ptr[uint8], plen: uint32,
               path: Ptr[char]) -> int32:
    # True if `path` starts with the first `plen` bytes of `prefix`
    # AND the boundary in `path` is a path separator OR end-of-string.
    # That last guard stops "/proc" from spuriously matching against
    # "/procfoo" — same trick fs/namespace.c uses with
    # is_subdir() / path_is_under().
    i: uint64 = 0
    pl: uint64 = cast[uint64](plen)
    while i < pl:
        if path[i] == 0:
            return 0                          # path shorter than prefix
        pc: int32 = cast[int32](prefix[i])
        nc: int32 = path[i]
        if pc != nc:
            return 0
        i = i + 1
    # Prefix consumed. Boundary must be '/' or '\0'. Special case:
    # if the mountpoint itself was "/" (plen == 1, prefix[0] == '/'),
    # the path already starts with '/', no extra check needed.
    boundary: int32 = path[pl]
    if boundary == 0:
        return 1
    if boundary == 47:                        # '/'
        return 1
    return 0


def mount_register(path: Ptr[char], fs_kind: uint32,
                   private: uint64) -> int32:
    # Claim a slot in the mount table. Returns slot id or -1 if full.
    # No de-dup: registering the same mountpoint twice will succeed
    # and the second slot will shadow the first for lookups (Linux's
    # bind-mount semantics — last-registered wins). We'll add a
    # proper namespace tree later.
    i: uint64 = 0
    while i < MOUNT_TABLE_MAX:
        if mount_table[i].used == 0:
            n: uint32 = _name_copy(&mount_table[i].mountpoint[0],
                                   path, MNT_NAME_MAX)
            if n == 0:
                # Either zero-length or didn't fit. Either way the
                # slot stays free; bail with -1 like the rest of the
                # kernel's "couldn't claim" returns.
                printk0("vfs_mount: bad mountpoint\n")
                return -1
            mount_table[i].fs_kind  = fs_kind
            mount_table[i].name_len = n
            mount_table[i].private  = private
            mount_table[i].used     = 1
            nr_mounts = nr_mounts + 1
            return cast[int32](i)
        i = i + 1
    printk0("vfs_mount: table full\n")
    return -1


def mount_unregister(slot: int32) -> int32:
    # Free a slot. Returns 0 on success, -1 on out-of-range / already
    # free. Doesn't tear down the FS itself — that's the caller's
    # job (umount() will eventually do drop_super() etc).
    if slot < 0:
        return -1
    su: uint64 = cast[uint64](slot)
    if su >= MOUNT_TABLE_MAX:
        return -1
    if mount_table[su].used == 0:
        return -1
    mount_table[su].used         = 0
    mount_table[su].fs_kind      = FS_KIND_UNUSED
    mount_table[su].name_len     = 0
    mount_table[su].private      = 0
    mount_table[su].mountpoint[0] = 0
    if nr_mounts > 0:
        nr_mounts = nr_mounts - 1
    return 0


def mount_lookup(path: Ptr[char]) -> int32:
    # Longest-prefix match. Returns the slot id whose mountpoint is
    # the longest prefix of `path`, or -1 if no match (e.g., absolute
    # paths beyond all registered mounts).
    best: int32 = -1
    best_len: uint32 = 0
    i: uint64 = 0
    while i < MOUNT_TABLE_MAX:
        if mount_table[i].used != 0:
            plen: uint32 = mount_table[i].name_len
            if _is_prefix(&mount_table[i].mountpoint[0], plen, path) != 0:
                if plen > best_len or best < 0:
                    best = cast[int32](i)
                    best_len = plen
        i = i + 1
    return best


def mount_strip_prefix(slot: int32, path: Ptr[char]) -> Ptr[char]:
    # Given a path that matched mount `slot`, return the
    # post-mountpoint tail. e.g. ("/usr/bin/echo", "/usr") -> "/bin/echo".
    # If the path equals the mountpoint exactly the tail is "" (the
    # NUL terminator inside `path`), which callers should treat as a
    # request for the mount root.
    if slot < 0:
        return path
    su: uint64 = cast[uint64](slot)
    if su >= MOUNT_TABLE_MAX:
        return path
    if mount_table[su].used == 0:
        return path
    plen: uint64 = cast[uint64](mount_table[su].name_len)
    # Special case: a mountpoint of "/" has length 1 but we want the
    # tail to include the leading '/' (so "/foo" -> "/foo"). Detect
    # the root mount and return the path unchanged.
    if plen == 1:
        if mount_table[su].mountpoint[0] == 47:
            return path
    return cast[Ptr[char]](cast[uint64](path) + plen)


# Auto-register the current Hamnix mounts at boot. Called from
# init/main.ad after each FS init.
def vfs_mount_init():
    # The existing hardcoded routes get redeclared here:
    mount_register("/proc", FS_KIND_PROCFS, 0)
    mount_register("/tmp",  FS_KIND_TMPFS,  0)
    # /mnt, /ext, /dev added when their drivers come up.
    printk0("vfs_mount: scaffold initialised\n")

# fs/fat_mkfs.ad
#
# Real kernel-side FAT12 formatter — sibling of fs/ext4.ad::ext4_mkfs.
# Writes a fresh, mountable FAT12 volume onto a registered block device
# (slot identified by /dev/blk/<dev>'s CTL dispatch in
# sys/src/9/port/devblk.ad). Replaces the earlier ENOSYS stub.
#
# What gets written:
#
#   sector 0        : boot sector / BPB + extended BPB + 0x55AA sig
#   reserved..      : nothing else (reserved = 1)
#   FAT region      : two identical FAT copies, seeded with
#                       FAT[0] = 0xFF8  (media byte 0xF8 + 0xF nibbles)
#                       FAT[1] = 0xFFF  (end-of-chain marker)
#                     packed per FAT12's 12-bit nibble layout; the
#                     remaining entries are zero (free clusters).
#   root dir region : zeroed (512 dirents); a single volume-label
#                     dirent ("HAMNIX     ", attr 0x08) is written first.
#
# FAT12 vs FAT16: decided by cluster count. FAT12 tops out at 4084
# clusters. The 32 MiB target with 16 KiB clusters yields ~2000
# clusters, well under the ceiling, so this implements FAT12 ONLY and
# rejects (with -EINVAL) any geometry that would exceed 4084 clusters.
#
# Geometry for the 32 MiB default (mformat `-c 32` shape):
#
#   - 32 MiB volume     = 65536 sectors of 512 B
#   - heads=64, sec/track=32
#   - cluster=32 sectors = 16 KiB clusters
#   - reserved=1, FATs=2, root_entries=512 (FAT12 fixed)
#   - root_dir_sectors = (512 * 32) / 512 = 32 sectors
#   - sectors/FAT computed iteratively (see _compute_sectors_per_fat)
#   - resulting clusters ~2000 -> FAT12.

from kernel.block.blk import (
    blk_write_sectors, blk_read_sectors, blk_capacity_sectors,
    find_blockdev, SECTOR_SIZE,
)
from kernel.printk.printk import (
    printk0, printk1, printk2,
    printk_set_level, PRINTK_LEVEL_EMERG,
)

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


# --- tunable geometry constants (FAT12) --------------------------------
_FMK_BYTES_PER_SECTOR:  uint64 = 512
_FMK_SECTORS_PER_CLU:   uint64 = 32          # 16 KiB clusters
_FMK_RESERVED_SECTORS:  uint64 = 1
_FMK_NUM_FATS:          uint64 = 2
_FMK_ROOT_ENTRIES:      uint64 = 512
_FMK_SECTORS_PER_TRACK: uint64 = 32
_FMK_NUM_HEADS:         uint64 = 64
_FMK_MEDIA:             uint64 = 0xF8
_FMK_FAT12_MAX_CLUSTERS: uint64 = 4084
_FMK_FAT16_MAX_CLUSTERS: uint64 = 65524

# FAT type tags returned by _fmk_pick_type / passed to writers.
_FMK_TYPE_FAT12:        uint64 = 12
_FMK_TYPE_FAT16:        uint64 = 16
_FMK_TYPE_FAT32:        uint64 = 32

# FAT32-specific geometry. FAT12/FAT16 keep _FMK_SECTORS_PER_CLU (32) and
# _FMK_RESERVED_SECTORS (1) for byte-for-byte parity with the landed tests.
# FAT32 uses smaller 4 KiB clusters (so a few-hundred-MiB disk lands above
# the 65524 FAT16 ceiling) and 32 reserved sectors (room for the FSInfo
# sector + a backup boot sector), per the canonical FAT32 layout.
_FMK_FAT32_SECTORS_PER_CLU: uint64 = 8    # 4 KiB clusters
_FMK_FAT32_RESERVED_SECTORS: uint64 = 32
_FMK_FAT32_FSINFO_SECTOR:   uint64 = 1
_FMK_FAT32_BKBOOT_SECTOR:   uint64 = 6
_FMK_FAT32_ROOT_CLUSTER:    uint64 = 2

# A single 512-byte scratch sector. The formatter never recurses, and
# the kernel never calls it reentrantly, so one global buffer is safe.
_fmk_sector: Array[512, uint8]


# --- little-endian field writers ---------------------------------------

def _fmk_put_u16(p: Ptr[uint8], off: uint64, v: uint64):
    p[off]     = cast[uint8](v & 0xFF)
    p[off + 1] = cast[uint8]((v >> 8) & 0xFF)


def _fmk_put_u32(p: Ptr[uint8], off: uint64, v: uint64):
    p[off]     = cast[uint8](v & 0xFF)
    p[off + 1] = cast[uint8]((v >> 8) & 0xFF)
    p[off + 2] = cast[uint8]((v >> 16) & 0xFF)
    p[off + 3] = cast[uint8]((v >> 24) & 0xFF)


# --- root-dir-sector count ---------------------------------------------

def _fmk_root_dir_sectors() -> uint64:
    # ((root_entries * 32) + (bytes/sector - 1)) / bytes/sector
    return ((_FMK_ROOT_ENTRIES * 32) + (_FMK_BYTES_PER_SECTOR - 1)) \
           / _FMK_BYTES_PER_SECTOR


# --- sectors/FAT iterative solve ---------------------------------------
#
# The classic mkdosfs fixpoint: pick sectors/FAT N, derive the number
# of data clusters that leaves, recompute the FAT size needed to index
# those clusters (+2 reserved entries) at 1.5 bytes/entry, and iterate
# until N stops growing. FAT12 = 12 bits = 3 nibbles = 1.5 bytes/entry.

def _fmk_sectors_per_fat_typed(total_sectors: uint64,
                               fat_type: uint64) -> uint64:
    rds: uint64 = _fmk_root_dir_sectors()
    n: uint64 = 1
    # Bounded fixpoint: N can only grow, and is tiny (a few sectors for
    # 32 MiB). 64 iterations is far more than enough.
    iters: uint64 = 0
    while iters < 64:
        # System area = reserved + FATs*N + root-dir sectors.
        sys_sectors: uint64 = _FMK_RESERVED_SECTORS \
                            + _FMK_NUM_FATS * n + rds
        if sys_sectors >= total_sectors:
            return 0
        data_sectors: uint64 = total_sectors - sys_sectors
        clusters: uint64 = data_sectors / _FMK_SECTORS_PER_CLU
        # FAT must hold (clusters + 2) entries, rounded up to a whole
        # sector. FAT12 = 12 bits = 1.5 bytes/entry; FAT16 = 2 bytes/entry.
        fat_bytes: uint64 = 0
        if fat_type == _FMK_TYPE_FAT16:
            fat_bytes = (clusters + 2) * 2
        else:
            fat_bytes = ((clusters + 2) * 3 + 1) / 2     # ceil(*1.5)
        need: uint64 = (fat_bytes + (_FMK_BYTES_PER_SECTOR - 1)) \
                     / _FMK_BYTES_PER_SECTOR
        if need <= n:
            return n
        n = need
        iters = iters + 1
    return n


def _fmk_sectors_per_fat(total_sectors: uint64) -> uint64:
    # FAT12 wrapper, preserved for the existing call sites.
    return _fmk_sectors_per_fat_typed(total_sectors, _FMK_TYPE_FAT12)


def _fmk_cluster_count(total_sectors: uint64, spf: uint64) -> uint64:
    sys_sectors: uint64 = _FMK_RESERVED_SECTORS \
                        + _FMK_NUM_FATS * spf + _fmk_root_dir_sectors()
    if sys_sectors >= total_sectors:
        return 0
    return (total_sectors - sys_sectors) / _FMK_SECTORS_PER_CLU


# --- FAT32 sectors/FAT iterative solve ---------------------------------
#
# Same mkdosfs fixpoint as the FAT12/16 solver, but with FAT32 geometry:
# 4 bytes/entry, no fixed root-dir region (the root is a regular cluster
# chain in the data area), and 32 reserved sectors. The data region is
# carved with 4 KiB clusters.

def _fmk_sectors_per_fat32(total_sectors: uint64) -> uint64:
    n: uint64 = 1
    iters: uint64 = 0
    while iters < 64:
        # System area = reserved + FATs*N (no root-dir region in FAT32).
        sys_sectors: uint64 = _FMK_FAT32_RESERVED_SECTORS \
                            + _FMK_NUM_FATS * n
        if sys_sectors >= total_sectors:
            return 0
        data_sectors: uint64 = total_sectors - sys_sectors
        clusters: uint64 = data_sectors / _FMK_FAT32_SECTORS_PER_CLU
        # FAT must hold (clusters + 2) 32-bit entries, rounded to a sector.
        fat_bytes: uint64 = (clusters + 2) * 4
        need: uint64 = (fat_bytes + (_FMK_BYTES_PER_SECTOR - 1)) \
                     / _FMK_BYTES_PER_SECTOR
        if need <= n:
            return n
        n = need
        iters = iters + 1
    return n


def _fmk_cluster_count32(total_sectors: uint64, spf: uint64) -> uint64:
    sys_sectors: uint64 = _FMK_FAT32_RESERVED_SECTORS \
                        + _FMK_NUM_FATS * spf
    if sys_sectors >= total_sectors:
        return 0
    return (total_sectors - sys_sectors) / _FMK_FAT32_SECTORS_PER_CLU


# --- boot sector / BPB -------------------------------------------------

def _fmk_write_boot_sector(slot: int32, total_sectors: uint64,
                           spf: uint64, fat_type: uint64) -> int32:
    p: Ptr[uint8] = &_fmk_sector[0]
    memset(p, 0, 512)

    # Jump instruction (EB 3C 90) + OEM name "MSWIN4.1".
    p[0] = 0xEB
    p[1] = 0x3C
    p[2] = 0x90
    p[3]  = 0x4D                       # 'M'
    p[4]  = 0x53                       # 'S'
    p[5]  = 0x57                       # 'W'
    p[6]  = 0x49                       # 'I'
    p[7]  = 0x4E                       # 'N'
    p[8]  = 0x34                       # '4'
    p[9]  = 0x2E                       # '.'
    p[10] = 0x31                       # '1'

    # --- BPB ---
    _fmk_put_u16(p, 11, _FMK_BYTES_PER_SECTOR)     # bytes/sector
    p[13] = cast[uint8](_FMK_SECTORS_PER_CLU)      # sectors/cluster
    _fmk_put_u16(p, 14, _FMK_RESERVED_SECTORS)     # reserved sectors
    p[16] = cast[uint8](_FMK_NUM_FATS)             # FAT count
    _fmk_put_u16(p, 17, _FMK_ROOT_ENTRIES)         # root dir entries
    # Total sectors: if it fits in 16 bits use the 16-bit field at 19,
    # else use the 32-bit field at 32 (16-bit field = 0).
    if total_sectors < 0x10000:
        _fmk_put_u16(p, 19, total_sectors)
        _fmk_put_u32(p, 32, 0)
    else:
        _fmk_put_u16(p, 19, 0)
        _fmk_put_u32(p, 32, total_sectors)
    p[21] = cast[uint8](_FMK_MEDIA)                # media descriptor
    _fmk_put_u16(p, 22, spf)                        # sectors/FAT (16-bit)
    _fmk_put_u16(p, 24, _FMK_SECTORS_PER_TRACK)    # sectors/track
    _fmk_put_u16(p, 26, _FMK_NUM_HEADS)            # heads
    _fmk_put_u32(p, 28, 0)                          # hidden sectors

    # --- Extended BPB (FAT12/16 layout) ---
    p[36] = 0x80                       # drive number (0x80 = hard disk)
    p[37] = 0                          # reserved (NT flags)
    p[38] = 0x29                       # extended boot signature
    _fmk_put_u32(p, 39, 0x48414D58)    # volume id (arbitrary; "HAMX" LE-ish)

    # Volume label "HAMNIX     " (11 bytes, space padded), offset 43.
    _label: Ptr[uint8] = "HAMNIX     "
    li: uint64 = 0
    while li < 11:
        p[43 + li] = _label[li]
        li = li + 1

    # FS type "FAT12   " / "FAT16   " (8 bytes, space padded), offset 54.
    _fstype: Ptr[uint8] = "FAT12   "
    if fat_type == _FMK_TYPE_FAT16:
        _fstype = "FAT16   "
    fi: uint64 = 0
    while fi < 8:
        p[54 + fi] = _fstype[fi]
        fi = fi + 1

    # Boot signature.
    p[510] = 0x55
    p[511] = 0xAA

    return blk_write_sectors(slot, 0, 1, p)


# --- FAT region --------------------------------------------------------

def _fmk_write_fats(slot: int32, spf: uint64, fat_type: uint64) -> int32:
    # Seed the first FAT sector with the two reserved entries.
    #
    # FAT12: FAT[0] = 0xFF8 (media byte 0xF8 in low nibbles + 0xF),
    # FAT[1] = 0xFFF (EOC), packed two 12-bit entries per 3 bytes:
    #   byte0 = E0[7:0]
    #   byte1 = (E1[3:0] << 4) | E0[11:8]
    #   byte2 = E1[11:4]
    # With E0 = 0xFF8, E1 = 0xFFF -> bytes 0xF8 0xFF 0xFF.
    #
    # FAT16: FAT[0] = 0xFFF8 (low byte = media descriptor 0xF8),
    # FAT[1] = 0xFFFF (EOC), each a little-endian 16-bit entry:
    #   bytes 0..1 = F8 FF, bytes 2..3 = FF FF.
    fat0_12: uint64 = (cast[uint64](_FMK_MEDIA) & 0xFFF) | 0xF00
    fat1_12: uint64 = 0xFFF
    fat0_16: uint64 = (cast[uint64](_FMK_MEDIA) & 0xFF) | 0xFF00
    fat1_16: uint64 = 0xFFFF
    f: uint64 = 0
    while f < _FMK_NUM_FATS:
        fat_lba: uint64 = _FMK_RESERVED_SECTORS + f * spf
        # First sector carries the two seed entries; rest are zero.
        s: uint64 = 0
        while s < spf:
            p: Ptr[uint8] = &_fmk_sector[0]
            memset(p, 0, 512)
            if s == 0:
                if fat_type == _FMK_TYPE_FAT16:
                    _fmk_put_u16(p, 0, fat0_16)
                    _fmk_put_u16(p, 2, fat1_16)
                else:
                    p[0] = cast[uint8](fat0_12 & 0xFF)
                    p[1] = cast[uint8](((fat1_12 & 0xF) << 4) | ((fat0_12 >> 8) & 0xF))
                    p[2] = cast[uint8]((fat1_12 >> 4) & 0xFF)
            rc: int32 = blk_write_sectors(slot, fat_lba + s, 1, p)
            if rc != 0:
                return rc
            s = s + 1
        f = f + 1
    return 0


# --- root directory region ---------------------------------------------

def _fmk_write_root_dir(slot: int32, spf: uint64) -> int32:
    rds: uint64 = _fmk_root_dir_sectors()
    root_lba: uint64 = _FMK_RESERVED_SECTORS + _FMK_NUM_FATS * spf
    s: uint64 = 0
    while s < rds:
        p: Ptr[uint8] = &_fmk_sector[0]
        memset(p, 0, 512)
        if s == 0:
            # Volume-label dirent (attr 0x08) as the first entry. Name
            # field is the 11-byte label, no extension separator.
            _label: Ptr[uint8] = "HAMNIX     "
            li: uint64 = 0
            while li < 11:
                p[li] = _label[li]
                li = li + 1
            p[11] = 0x08               # ATTR_VOLUME_ID
        rc: int32 = blk_write_sectors(slot, root_lba + s, 1, p)
        if rc != 0:
            return rc
        s = s + 1
    return 0


# --- FAT32 boot sector / BPB -------------------------------------------
#
# Writes a canonical FAT32 BPB to sector 0 (and a backup copy to sector
# BPB_BkBootSec). Differences from the FAT12/16 BPB:
#   - BPB_RootEntCnt (0x11) = 0; BPB_FATSz16 (0x16) = 0; TotSec16 (0x13) = 0.
#   - Real FAT size in BPB_FATSz32 (0x24, 4 B); total sectors in TotSec32 (0x20).
#   - FAT32 extended fields: ExtFlags (0x28), FSVer (0x2A), RootClus (0x2C),
#     FSInfo (0x30), BkBootSec (0x32).
#   - Extended boot-signature block shifts to 0x40: drive number (0x40),
#     BS_BootSig (0x42)=0x29, VolID (0x43), VolLab (0x47, 11 B),
#     BS_FilSysType (0x52, 8 B) = "FAT32   ".

def _fmk_fill_boot_sector32(p: Ptr[uint8], total_sectors: uint64,
                            spf: uint64):
    memset(p, 0, 512)

    # Jump instruction (EB 58 90) + OEM name "MSWIN4.1".
    p[0] = 0xEB
    p[1] = 0x58
    p[2] = 0x90
    p[3]  = 0x4D                       # 'M'
    p[4]  = 0x53                       # 'S'
    p[5]  = 0x57                       # 'W'
    p[6]  = 0x49                       # 'I'
    p[7]  = 0x4E                       # 'N'
    p[8]  = 0x34                       # '4'
    p[9]  = 0x2E                       # '.'
    p[10] = 0x31                       # '1'

    # --- BPB (shared layout) ---
    _fmk_put_u16(p, 11, _FMK_BYTES_PER_SECTOR)         # bytes/sector
    p[13] = cast[uint8](_FMK_FAT32_SECTORS_PER_CLU)    # sectors/cluster
    _fmk_put_u16(p, 14, _FMK_FAT32_RESERVED_SECTORS)   # reserved sectors
    p[16] = cast[uint8](_FMK_NUM_FATS)                 # FAT count
    _fmk_put_u16(p, 17, 0)                              # root entries = 0 (FAT32)
    _fmk_put_u16(p, 19, 0)                              # TotSec16 = 0 (FAT32)
    p[21] = cast[uint8](_FMK_MEDIA)                     # media descriptor
    _fmk_put_u16(p, 22, 0)                              # FATSz16 = 0 (FAT32)
    _fmk_put_u16(p, 24, _FMK_SECTORS_PER_TRACK)        # sectors/track
    _fmk_put_u16(p, 26, _FMK_NUM_HEADS)                # heads
    _fmk_put_u32(p, 28, 0)                              # hidden sectors
    _fmk_put_u32(p, 32, total_sectors)                 # TotSec32

    # --- FAT32 extended BPB ---
    _fmk_put_u32(p, 36, spf)                            # BPB_FATSz32
    _fmk_put_u16(p, 40, 0)                              # BPB_ExtFlags (mirror all FATs)
    _fmk_put_u16(p, 42, 0)                              # BPB_FSVer = 0
    _fmk_put_u32(p, 44, _FMK_FAT32_ROOT_CLUSTER)       # BPB_RootClus = 2
    _fmk_put_u16(p, 48, _FMK_FAT32_FSINFO_SECTOR)      # BPB_FSInfo = 1
    _fmk_put_u16(p, 50, _FMK_FAT32_BKBOOT_SECTOR)      # BPB_BkBootSec = 6

    # --- Extended boot-signature block (FAT32 offsets) ---
    p[64] = 0x80                       # BS_DrvNum (0x40)
    p[65] = 0                          # BS_Reserved1 (0x41)
    p[66] = 0x29                       # BS_BootSig (0x42)
    _fmk_put_u32(p, 67, 0x48414D58)    # BS_VolID (0x43)

    # Volume label "HAMNIX     " (11 bytes), offset 0x47 (71).
    _label: Ptr[uint8] = "HAMNIX     "
    li: uint64 = 0
    while li < 11:
        p[71 + li] = _label[li]
        li = li + 1

    # BS_FilSysType "FAT32   " (8 bytes), offset 0x52 (82).
    _fstype: Ptr[uint8] = "FAT32   "
    fi: uint64 = 0
    while fi < 8:
        p[82 + fi] = _fstype[fi]
        fi = fi + 1

    # Boot signature.
    p[510] = 0x55
    p[511] = 0xAA


def _fmk_write_boot_sector32(slot: int32, total_sectors: uint64,
                             spf: uint64) -> int32:
    p: Ptr[uint8] = &_fmk_sector[0]
    _fmk_fill_boot_sector32(p, total_sectors, spf)
    rc: int32 = blk_write_sectors(slot, 0, 1, p)
    if rc != 0:
        return rc
    # Backup boot sector at BPB_BkBootSec (re-fill; the buffer is global).
    _fmk_fill_boot_sector32(p, total_sectors, spf)
    return blk_write_sectors(slot, _FMK_FAT32_BKBOOT_SECTOR, 1, p)


# --- FAT32 FSInfo sector -----------------------------------------------
#
# Sector 1 (BPB_FSInfo). Lead sig 0x41615252 at 0, struct sig 0x61417272
# at 0x1E4, free-count + next-free hints (0xFFFFFFFF = unknown), trail sig
# 0xAA550000 at 0x1FC. A backup copy lands at BkBootSec+1.

def _fmk_write_fsinfo32(slot: int32) -> int32:
    p: Ptr[uint8] = &_fmk_sector[0]
    memset(p, 0, 512)
    _fmk_put_u32(p, 0, 0x41615252)         # FSI_LeadSig
    _fmk_put_u32(p, 484, 0x61417272)       # FSI_StrucSig (0x1E4)
    _fmk_put_u32(p, 488, 0xFFFFFFFF)       # FSI_Free_Count (unknown)
    _fmk_put_u32(p, 492, 0xFFFFFFFF)       # FSI_Nxt_Free (unknown)
    _fmk_put_u32(p, 508, 0xAA550000)       # FSI_TrailSig (0x1FC)
    rc: int32 = blk_write_sectors(slot, _FMK_FAT32_FSINFO_SECTOR, 1, p)
    if rc != 0:
        return rc
    # Backup FSInfo at BkBootSec + 1.
    memset(p, 0, 512)
    _fmk_put_u32(p, 0, 0x41615252)
    _fmk_put_u32(p, 484, 0x61417272)
    _fmk_put_u32(p, 488, 0xFFFFFFFF)
    _fmk_put_u32(p, 492, 0xFFFFFFFF)
    _fmk_put_u32(p, 508, 0xAA550000)
    return blk_write_sectors(slot, _FMK_FAT32_BKBOOT_SECTOR + 1, 1, p)


# --- FAT32 FAT region --------------------------------------------------
#
# Seeds the first FAT sector of each copy with the three reserved 32-bit
# entries:
#   entry0 = 0x0FFFFFF8  (low byte = media descriptor 0xF8)
#   entry1 = 0x0FFFFFFF  (EOC marker)
#   entry2 = 0x0FFFFFFF  (root directory = single cluster, EOC)
# The rest of every FAT sector is zero (free clusters).

def _fmk_write_fats32(slot: int32, spf: uint64) -> int32:
    f: uint64 = 0
    while f < _FMK_NUM_FATS:
        fat_lba: uint64 = _FMK_FAT32_RESERVED_SECTORS + f * spf
        s: uint64 = 0
        while s < spf:
            p: Ptr[uint8] = &_fmk_sector[0]
            memset(p, 0, 512)
            if s == 0:
                _fmk_put_u32(p, 0, 0x0FFFFFF8)     # entry0
                _fmk_put_u32(p, 4, 0x0FFFFFFF)     # entry1 (EOC)
                _fmk_put_u32(p, 8, 0x0FFFFFFF)     # entry2 (root, EOC)
            rc: int32 = blk_write_sectors(slot, fat_lba + s, 1, p)
            if rc != 0:
                return rc
            s = s + 1
        f = f + 1
    return 0


# --- FAT32 root-directory cluster --------------------------------------
#
# In FAT32 the root directory is a regular cluster chain. We allocate a
# single cluster (cluster 2) and zero it, then drop the volume-label
# dirent (attr 0x08) as the first entry — same shape as the FAT12/16 root.

def _fmk_write_root_dir32(slot: int32, spf: uint64) -> int32:
    # Data region begins after reserved + the FAT copies. Cluster N lives
    # at data_start + (N - 2) * sectors/cluster; the root is cluster 2.
    data_start: uint64 = _FMK_FAT32_RESERVED_SECTORS + _FMK_NUM_FATS * spf
    root_lba: uint64 = data_start
    s: uint64 = 0
    while s < _FMK_FAT32_SECTORS_PER_CLU:
        p: Ptr[uint8] = &_fmk_sector[0]
        memset(p, 0, 512)
        if s == 0:
            _label: Ptr[uint8] = "HAMNIX     "
            li: uint64 = 0
            while li < 11:
                p[li] = _label[li]
                li = li + 1
            p[11] = 0x08               # ATTR_VOLUME_ID
        rc: int32 = blk_write_sectors(slot, root_lba + s, 1, p)
        if rc != 0:
            return rc
        s = s + 1
    return 0


# --- public entry ------------------------------------------------------

def fat_mkfs(slot: int32, size_mb: uint64) -> int32:
    # Format the block device `slot` as a fresh FAT12 volume. If
    # size_mb is 0, use the device's full capacity. Returns 0 on
    # success, negative on error.
    if slot < 0:
        printk0("fat_mkfs: invalid slot\n")
        return -1

    cap_sectors: uint64 = blk_capacity_sectors(slot)
    if cap_sectors == 0:
        printk0("fat_mkfs: device has zero capacity\n")
        return -1

    total_sectors: uint64 = cap_sectors
    if size_mb != 0:
        req: uint64 = size_mb * (1024 * 1024 / 512)      # MiB -> sectors
        if req > cap_sectors:
            printk2("fat_mkfs: size %d MiB exceeds capacity (%d sectors)\n",
                    size_mb, cap_sectors)
            return -1
        total_sectors = req

    if total_sectors < 64:
        printk1("fat_mkfs: volume too small (%d sectors)\n", total_sectors)
        return -22

    # FAT type selection.
    #
    # FAT12/16 carve the data region with 16 KiB clusters; with that fixed
    # cluster size a large disk (e.g. 512 MiB) still indexes under 65524
    # clusters and would otherwise pick FAT16. Real mkdosfs instead drops
    # to a SMALLER cluster size on large volumes so they land in the FAT32
    # range. Mirror that: if the volume is big enough that FAT32 geometry
    # (4 KiB clusters) yields more than the FAT16 ceiling of clusters, go
    # FAT32 straight away. This keeps the FAT12/FAT16 paths byte-for-byte
    # identical for the smaller volumes their tests format.
    fat_type: uint64 = _FMK_TYPE_FAT12
    spf: uint64 = 0
    clusters: uint64 = 0

    spf32_probe: uint64 = _fmk_sectors_per_fat32(total_sectors)
    if spf32_probe != 0:
        clu32_probe: uint64 = _fmk_cluster_count32(total_sectors, spf32_probe)
        if clu32_probe > _FMK_FAT16_MAX_CLUSTERS:
            fat_type = _FMK_TYPE_FAT32
            spf = spf32_probe
            clusters = clu32_probe

    if fat_type != _FMK_TYPE_FAT32:
        return _fmk_format_small(slot, total_sectors)

    printk2("fat_mkfs: total_sectors=%d sectors/FAT=%d\n",
            total_sectors, spf)
    printk1("fat_mkfs: data clusters=%d (FAT32)\n", clusters)
    rc32: int32 = _fmk_write_boot_sector32(slot, total_sectors, spf)
    if rc32 != 0:
        printk0("fat_mkfs: boot-sector write failed\n")
        return -5
    rc32 = _fmk_write_fsinfo32(slot)
    if rc32 != 0:
        printk0("fat_mkfs: FSInfo write failed\n")
        return -5
    rc32 = _fmk_write_fats32(slot, spf)
    if rc32 != 0:
        printk0("fat_mkfs: FAT write failed\n")
        return -5
    rc32 = _fmk_write_root_dir32(slot, spf)
    if rc32 != 0:
        printk0("fat_mkfs: root-dir write failed\n")
        return -5
    printk0("fat_mkfs: FAT32 format complete\n")
    return 0


# Format a FAT12/FAT16 volume (16 KiB clusters). Split out of fat_mkfs so
# the FAT32 selection can short-circuit cleanly. Byte-for-byte identical
# to the original FAT12/FAT16 sizing+writing logic.
def _fmk_format_small(slot: int32, total_sectors: uint64) -> int32:
    fat_type: uint64 = _FMK_TYPE_FAT12
    spf: uint64 = _fmk_sectors_per_fat_typed(total_sectors, _FMK_TYPE_FAT12)
    if spf == 0:
        printk0("fat_mkfs: geometry too small for a FAT\n")
        return -22

    clusters: uint64 = _fmk_cluster_count(total_sectors, spf)
    if clusters == 0:
        printk0("fat_mkfs: no data clusters fit\n")
        return -22

    if clusters > _FMK_FAT12_MAX_CLUSTERS:
        # Re-size for FAT16 (2 bytes/entry) and recompute the cluster count
        # off the new, larger FAT.
        fat_type = _FMK_TYPE_FAT16
        spf = _fmk_sectors_per_fat_typed(total_sectors, _FMK_TYPE_FAT16)
        if spf == 0:
            printk0("fat_mkfs: geometry too small for a FAT16 FAT\n")
            return -22
        clusters = _fmk_cluster_count(total_sectors, spf)
        if clusters == 0:
            printk0("fat_mkfs: no data clusters fit (FAT16)\n")
            return -22
        if clusters > _FMK_FAT16_MAX_CLUSTERS:
            # The FAT32 selection in fat_mkfs() already routes large
            # volumes away from here, so reaching this with a FAT16 cluster
            # count over the ceiling means the geometry is genuinely out of
            # range. Refuse rather than write a malformed FAT16 volume.
            printk2("fat_mkfs: %d clusters exceeds FAT16 ceiling %d\n",
                    clusters, _FMK_FAT16_MAX_CLUSTERS)
            return -22

    printk2("fat_mkfs: total_sectors=%d sectors/FAT=%d\n",
            total_sectors, spf)
    if fat_type == _FMK_TYPE_FAT16:
        printk1("fat_mkfs: data clusters=%d (FAT16)\n", clusters)
    else:
        printk1("fat_mkfs: data clusters=%d (FAT12)\n", clusters)

    rc: int32 = _fmk_write_boot_sector(slot, total_sectors, spf, fat_type)
    if rc != 0:
        printk0("fat_mkfs: boot-sector write failed\n")
        return -5
    rc = _fmk_write_fats(slot, spf, fat_type)
    if rc != 0:
        printk0("fat_mkfs: FAT write failed\n")
        return -5
    rc = _fmk_write_root_dir(slot, spf)
    if rc != 0:
        printk0("fat_mkfs: root-dir write failed\n")
        return -5

    if fat_type == _FMK_TYPE_FAT16:
        printk0("fat_mkfs: FAT16 format complete\n")
    else:
        printk0("fat_mkfs: FAT12 format complete\n")
    return 0


# --- boot self-test ----------------------------------------------------
#
# Formats the AHCI scratch disk registered as "sd0" by the test harness
# (scripts/test_fat_mkfs.sh attaches a QEMU AHCI disk), then reads the
# boot sector + first FAT sector back through the generic block layer and
# verifies the BPB fields and the packed FAT[0]/FAT[1] seed. Prints a
# single "[FAT_MKFS] PASS" or "[FAT_MKFS] FAIL ..." at EMERG so it reaches
# serial. Returns 1 on PASS, 0 on FAIL.

_fmk_verify_buf: Array[512, uint8]


def _fmk_rd_u16(p: Ptr[uint8], off: uint64) -> uint64:
    return cast[uint64](p[off]) | (cast[uint64](p[off + 1]) << 8)


def fat_mkfs_selftest() -> int32:
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[FAT_MKFS] self-test start\n")

    slot: int32 = find_blockdev("sd0")
    if slot < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: sd0 not registered\n")
        return 0

    # Format a 32 MiB FAT12 volume (the documented target). The scratch
    # disk is sized >= 32 MiB by the harness.
    rc: int32 = fat_mkfs(slot, 32)
    if rc != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT_MKFS] FAIL: fat_mkfs returned %d\n", cast[uint64](rc))
        return 0

    # Read sector 0 back and verify the BPB.
    vp: Ptr[uint8] = &_fmk_verify_buf[0]
    memset(vp, 0, 512)
    if blk_read_sectors(slot, 0, 1, vp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: boot-sector readback failed\n")
        return 0

    if vp[510] != 0x55 or vp[511] != 0xAA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: bad 0x55AA signature\n")
        return 0

    bps: uint64 = _fmk_rd_u16(vp, 11)
    if bps != _FMK_BYTES_PER_SECTOR:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT_MKFS] FAIL: bytes/sector=%d\n", bps)
        return 0

    if cast[uint64](vp[13]) != _FMK_SECTORS_PER_CLU:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT_MKFS] FAIL: sectors/cluster=%d\n", cast[uint64](vp[13]))
        return 0

    if _fmk_rd_u16(vp, 14) != _FMK_RESERVED_SECTORS:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: reserved sectors\n")
        return 0

    if cast[uint64](vp[16]) != _FMK_NUM_FATS:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: FAT count\n")
        return 0

    if _fmk_rd_u16(vp, 17) != _FMK_ROOT_ENTRIES:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: root entries\n")
        return 0

    if cast[uint64](vp[21]) != _FMK_MEDIA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: media descriptor\n")
        return 0

    spf: uint64 = _fmk_rd_u16(vp, 22)
    if spf == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: sectors/FAT is zero\n")
        return 0

    # FS type string "FAT12   " at offset 54.
    _fstype: Ptr[uint8] = "FAT12   "
    fi: uint64 = 0
    while fi < 8:
        if vp[54 + fi] != _fstype[fi]:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk0("[FAT_MKFS] FAIL: fs type string\n")
            return 0
        fi = fi + 1

    # Read the first FAT sector and verify the packed FAT[0]/FAT[1] seed.
    memset(vp, 0, 512)
    if blk_read_sectors(slot, _FMK_RESERVED_SECTORS, 1, vp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT_MKFS] FAIL: FAT readback failed\n")
        return 0
    # Expected packed bytes: 0xF8 0xFF 0xFF.
    if vp[0] != 0xF8 or vp[1] != 0xFF or vp[2] != 0xFF:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[FAT_MKFS] FAIL: FAT seed (%x %x ...)\n",
                cast[uint64](vp[0]), cast[uint64](vp[1]))
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[FAT_MKFS] PASS\n")
    return 1


# --- FAT16 boot self-test ----------------------------------------------
#
# Formats a volume sized into the FAT16 cluster window (>4084 clusters)
# on the AHCI scratch disk registered as "sd0", then reads back the BPB
# and the first FAT sector and verifies: bytes/sector + sectors/cluster
# sane, "FAT16   " fs-type string, FAT entry0 low byte 0xF8, entry1
# 0xFFFF, boot signature 0x55AA. With 16 KiB clusters a 128 MiB volume
# yields ~8188 clusters — comfortably inside the FAT16 range. Prints a
# single "[FAT16_MKFS] PASS" / "[FAT16_MKFS] FAIL ..." at EMERG so it
# reaches serial. Returns 1 on PASS, 0 on FAIL.

def fat16_mkfs_selftest() -> int32:
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[FAT16_MKFS] self-test start\n")

    slot: int32 = find_blockdev("sd0")
    if slot < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT16_MKFS] FAIL: sd0 not registered\n")
        return 0

    # Format a 128 MiB volume -> ~8188 clusters -> FAT16. The scratch disk
    # is sized >= 128 MiB by the harness.
    rc: int32 = fat_mkfs(slot, 128)
    if rc != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT16_MKFS] FAIL: fat_mkfs returned %d\n", cast[uint64](rc))
        return 0

    # Read sector 0 back and verify the BPB.
    vp: Ptr[uint8] = &_fmk_verify_buf[0]
    memset(vp, 0, 512)
    if blk_read_sectors(slot, 0, 1, vp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT16_MKFS] FAIL: boot-sector readback failed\n")
        return 0

    if vp[510] != 0x55 or vp[511] != 0xAA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT16_MKFS] FAIL: bad 0x55AA signature\n")
        return 0

    bps: uint64 = _fmk_rd_u16(vp, 11)
    if bps != _FMK_BYTES_PER_SECTOR:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT16_MKFS] FAIL: bytes/sector=%d\n", bps)
        return 0

    if cast[uint64](vp[13]) != _FMK_SECTORS_PER_CLU:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT16_MKFS] FAIL: sectors/cluster=%d\n", cast[uint64](vp[13]))
        return 0

    spf: uint64 = _fmk_rd_u16(vp, 22)
    if spf == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT16_MKFS] FAIL: sectors/FAT is zero\n")
        return 0

    # FS type string "FAT16   " at offset 54.
    _fstype: Ptr[uint8] = "FAT16   "
    fi: uint64 = 0
    while fi < 8:
        if vp[54 + fi] != _fstype[fi]:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk0("[FAT16_MKFS] FAIL: fs type string\n")
            return 0
        fi = fi + 1

    # Read the first FAT sector and verify the 16-bit FAT[0]/FAT[1] seed.
    memset(vp, 0, 512)
    if blk_read_sectors(slot, _FMK_RESERVED_SECTORS, 1, vp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT16_MKFS] FAIL: FAT readback failed\n")
        return 0
    # Expected: entry0 = 0xFFF8 (low byte 0xF8), entry1 = 0xFFFF.
    e0: uint64 = _fmk_rd_u16(vp, 0)
    e1: uint64 = _fmk_rd_u16(vp, 2)
    if (e0 & 0xFF) != _FMK_MEDIA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT16_MKFS] FAIL: FAT entry0 low byte=%x\n", e0 & 0xFF)
        return 0
    if e1 != 0xFFFF:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT16_MKFS] FAIL: FAT entry1=%x\n", e1)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[FAT16_MKFS] PASS\n")
    return 1


# --- FAT32 boot self-test ----------------------------------------------
#
# Formats a volume sized into the FAT32 cluster window (>65524 clusters)
# on the AHCI scratch disk registered as "sd0", then reads back the BPB
# and the first FAT sector and verifies the FAT32-specific structure:
# BPB_FATSz16 (0x16)==0, BPB_RootEntCnt (0x11)==0, BPB_RootClus (0x2C)==2,
# BS_FilSysType (0x52) string "FAT32   ", 32-bit FAT entry0 low byte 0xF8,
# entry1 low 28 bits all-ones, boot signature 0x55AA. With 4 KiB clusters
# a 512 MiB volume yields ~131000 clusters — comfortably above the 65524
# FAT16 ceiling. Prints a single "[FAT32_MKFS] PASS" / "[FAT32_MKFS] FAIL
# ..." at EMERG so it reaches serial. Returns 1 on PASS, 0 on FAIL.

def _fmk_rd_u32(p: Ptr[uint8], off: uint64) -> uint64:
    return cast[uint64](p[off]) \
         | (cast[uint64](p[off + 1]) << 8) \
         | (cast[uint64](p[off + 2]) << 16) \
         | (cast[uint64](p[off + 3]) << 24)


def fat32_mkfs_selftest() -> int32:
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[FAT32_MKFS] self-test start\n")

    slot: int32 = find_blockdev("sd0")
    if slot < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: sd0 not registered\n")
        return 0

    # Format a 512 MiB volume -> ~131000 clusters at 4 KiB clusters ->
    # FAT32. The scratch disk is sized >= 512 MiB by the harness.
    rc: int32 = fat_mkfs(slot, 512)
    if rc != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT32_MKFS] FAIL: fat_mkfs returned %d\n", cast[uint64](rc))
        return 0

    # Read sector 0 back and verify the BPB.
    vp: Ptr[uint8] = &_fmk_verify_buf[0]
    memset(vp, 0, 512)
    if blk_read_sectors(slot, 0, 1, vp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: boot-sector readback failed\n")
        return 0

    if vp[510] != 0x55 or vp[511] != 0xAA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: bad 0x55AA signature\n")
        return 0

    bps: uint64 = _fmk_rd_u16(vp, 11)
    if bps != _FMK_BYTES_PER_SECTOR:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT32_MKFS] FAIL: bytes/sector=%d\n", bps)
        return 0

    # FAT32: 16-bit FAT-size field MUST be 0 (size lives in FATSz32).
    if _fmk_rd_u16(vp, 22) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: BPB_FATSz16 != 0\n")
        return 0

    # FAT32: root-entry count MUST be 0 (root is a cluster chain).
    if _fmk_rd_u16(vp, 17) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: BPB_RootEntCnt != 0\n")
        return 0

    # FAT32: total-sectors-16 MUST be 0 (count lives in TotSec32).
    if _fmk_rd_u16(vp, 19) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: BPB_TotSec16 != 0\n")
        return 0

    # FAT32 sectors/FAT in the 32-bit field at 0x24 (36).
    spf32: uint64 = _fmk_rd_u32(vp, 36)
    if spf32 == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: BPB_FATSz32 is zero\n")
        return 0

    # FAT32 root cluster at 0x2C (44) MUST be 2.
    root_clus: uint64 = _fmk_rd_u32(vp, 44)
    if root_clus != _FMK_FAT32_ROOT_CLUSTER:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT32_MKFS] FAIL: BPB_RootClus=%d\n", root_clus)
        return 0

    # BS_FilSysType string "FAT32   " at offset 0x52 (82).
    _fstype: Ptr[uint8] = "FAT32   "
    fi: uint64 = 0
    while fi < 8:
        if vp[82 + fi] != _fstype[fi]:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk0("[FAT32_MKFS] FAIL: fs type string\n")
            return 0
        fi = fi + 1

    # Read the first FAT sector and verify the 32-bit FAT entry seeds.
    memset(vp, 0, 512)
    if blk_read_sectors(slot, _FMK_FAT32_RESERVED_SECTORS, 1, vp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[FAT32_MKFS] FAIL: FAT readback failed\n")
        return 0
    e0: uint64 = _fmk_rd_u32(vp, 0)
    e1: uint64 = _fmk_rd_u32(vp, 4)
    e2: uint64 = _fmk_rd_u32(vp, 8)
    if (e0 & 0xFF) != _FMK_MEDIA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT32_MKFS] FAIL: FAT entry0 low byte=%x\n", e0 & 0xFF)
        return 0
    # entry1: low 28 bits all-ones (top nibble reserved/ignored).
    if (e1 & 0x0FFFFFFF) != 0x0FFFFFFF:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT32_MKFS] FAIL: FAT entry1=%x\n", e1 & 0x0FFFFFFF)
        return 0
    # entry2: root directory = single EOC cluster (low 28 bits all-ones).
    if (e2 & 0x0FFFFFFF) != 0x0FFFFFFF:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[FAT32_MKFS] FAIL: FAT entry2 (root)=%x\n", e2 & 0x0FFFFFFF)
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[FAT32_MKFS] PASS\n")
    return 1

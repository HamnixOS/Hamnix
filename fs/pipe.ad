# fs/pipe.ad
#
# Anonymous pipes — kernel side. A pipe is a fixed-capacity ring
# buffer with separate refcounts for its read and write ends.
# Closing an end decrements the matching count; when both hit zero
# the slot is reclaimed.
#
# Semantics (mirroring Linux's pipe semantics at minimum scope):
#
#   read end:
#     - byte(s) available → return them (partial reads are fine)
#     - empty, writers > 0  → "would block" (vfs caller yields)
#     - empty, writers == 0 → EOF (return 0)
#
#   write end:
#     - free space available → enqueue (partial writes are fine)
#     - full, readers > 0   → "would block" (vfs caller yields)
#     - full, readers == 0  → EPIPE
#
# No SIGPIPE yet — userspace gets back -EPIPE explicitly and decides
# what to do. Real Linux raises a signal; we'll get there when the
# signal subsystem lands.

from mm.slab import kmalloc, kfree
from kernel.printk.printk import printk0, printk1, printk_set_level
# Event-driven blocking: a pipe read end that finds the ring empty sleeps
# on the pipe's per-slot read_wq instead of poll-yielding on the timer
# tick. The write path and the writer-close path wake it.
# Phase 4c (pipe fold): the BLOCKING loops moved here from fs/vfs.ad's
# retired FD_PIPE_MARK_R/W arms — pipe_read_blocking parks on the
# two-phase WaitQueue API (prepare → recheck → commit, WQ_EINTR on
# signal); pipe_write_blocking is the chunked drain-and-yield writer.
# namec's DEV_PIPE_R/DEV_PIPE_W pool-chan arms dispatch here.
from kernel.sched.core import (
    WaitQueue, wq_init, wq_wake_all, waitfds_notify,
    wq_wait_prepare, wq_wait_cancel, wq_wait_commit, WQ_EINTR,
    yield_to_others,
    # Phase 4c gate plumbing (pipechan_selftest below): the boot task's
    # fd table is uninitialised at boot — free a few high slots via the
    # setters, restore after. copy_fd_entry is the REAL fork/dup hook
    # (bumps the shared chan refcount), so the selftest can prove a
    # dup'd pipe fd doesn't yank the end out from under its sibling.
    TaskStruct, current_task, current_idx_get, copy_fd_entry,
    FD_CLOSED_MARK,
    task_fd_idx_at, task_fd_buf_at,
    task_set_fd_idx_at, task_set_fd_buf_at,
)
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


PIPE_MAX: uint64 = 32
# Ring capacity. The smoke-test path's 1 KiB original was sized for
# tiny <100-byte 9P messages; the nsrun-launched distrofs install path
# carries up to one full msize-sized T-msg per pipe_write
# (P9_MSIZE_DEFAULT = 128 KiB in lib/9p/9p.ad), and a 1 KiB ring would
# force ~128 yield/wake cycles per Twrite. Sizing the ring to one full
# msize collapses each Twrite into a single ring fill -> reader drain
# context switch, killing the pipe-side half of the libc6 install
# bottleneck. 32 slots × 128 KiB = 4 MiB worst-case slab use.
PIPE_CAP: uint64 = 131072


class Pipe:
    buf:     uint64               # kmalloc'd ring or 0 (free slot)
    head:    uint64               # next-read offset (mod cap)
    tail:    uint64               # next-write offset (mod cap)
    count:   uint64               # bytes currently buffered
    cap:     uint64               # ring capacity (== PIPE_CAP)
    readers: uint64               # open read-end count
    writers: uint64               # open write-end count
    used:    uint64               # 1 = in use, 0 = free
    # Event-driven blocking: read ends that find the ring empty sleep
    # here; pipe_write and pipe_close_writer (EOF) wake them. Head field
    # zero-initialised (empty queue) on a fresh slot.
    read_wq: WaitQueue


# Keep this length in lockstep with PIPE_MAX above. The Adder type
# parser wants a literal here, so bump both together. 32 slots covers
# the ssh-bridge + 3× distrofs (apt install path) and leaves headroom
# for nested namespaces; each slot is ~64 B of metadata + a PIPE_CAP
# ring allocated lazily in pipe_alloc.
pipe_table: Array[32, Pipe]


def _pipe_find_free_slot() -> int32:
    i: uint64 = 0
    while i < PIPE_MAX:
        if pipe_table[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def pipe_alloc() -> int32:
    # Returns a slot with readers = writers = 1 (caller owns one of
    # each, just as a brand-new pipe() returns one rfd + one wfd to
    # the caller). -1 on out-of-slots / OOM.
    slot: int32 = _pipe_find_free_slot()
    if slot < 0:
        printk0("pipe: out of slots\n")
        return -1
    su: uint64 = cast[uint64](slot)

    if pipe_table[su].buf == 0:
        b: uint64 = kmalloc(PIPE_CAP)
        if b == 0:
            return -1
        pipe_table[su].buf = b
    pipe_table[su].cap     = PIPE_CAP
    pipe_table[su].head    = 0
    pipe_table[su].tail    = 0
    pipe_table[su].count   = 0
    pipe_table[su].readers = 1
    pipe_table[su].writers = 1
    pipe_table[su].used    = 1
    # Recycled-slot hygiene: start with an empty read wait queue so a new
    # pipe never inherits a previous tenant's stale waiter link.
    wq_init(&pipe_table[su].read_wq)
    return slot


def pipe_alloc_chan() -> int32:
    # HAMSH §7: allocate a pipe slot with NO owning references
    # (readers == writers == 0). Unlike pipe_alloc — which hands the
    # caller one reader + one writer fd — a pipe-as-Chan is owned
    # ENTIRELY by the /fd/N names it gets bound at: the shell holds no
    # fd of its own, so the only references are the ones devfd_bind's
    # pipe_inc_reader / pipe_inc_writer create. Returns the slot, or
    # -1 on out-of-slots / OOM.
    #
    # Caller contract: the slot MUST get at least one reader-bind and
    # one writer-bind before any other code path runs _maybe_free on
    # it — a slot sitting at 0/0 looks reclaimable. The shell does both
    # binds back-to-back per pipe stage, so the window never opens.
    slot: int32 = _pipe_find_free_slot()
    if slot < 0:
        printk0("pipe: out of slots\n")
        return -1
    su: uint64 = cast[uint64](slot)
    if pipe_table[su].buf == 0:
        b: uint64 = kmalloc(PIPE_CAP)
        if b == 0:
            return -1
        pipe_table[su].buf = b
    pipe_table[su].cap     = PIPE_CAP
    pipe_table[su].head    = 0
    pipe_table[su].tail    = 0
    pipe_table[su].count   = 0
    pipe_table[su].readers = 0
    pipe_table[su].writers = 0
    pipe_table[su].used    = 1
    # Recycled-slot hygiene: empty read wait queue (see pipe_alloc).
    wq_init(&pipe_table[su].read_wq)
    return slot


def pipe_inc_reader(slot: int32):
    pipe_table[cast[uint64](slot)].readers = \
        pipe_table[cast[uint64](slot)].readers + 1


def pipe_inc_writer(slot: int32):
    pipe_table[cast[uint64](slot)].writers = \
        pipe_table[cast[uint64](slot)].writers + 1


def _maybe_free(slot: int32):
    su: uint64 = cast[uint64](slot)
    if pipe_table[su].readers == 0 and pipe_table[su].writers == 0:
        # Both ends gone — return the ring to the slab and free the
        # slot. We zero used so a future pipe_alloc reclaims it; the
        # buf pointer is intentionally left set so we can lazy-reuse
        # the allocation, but we'll re-init head/tail/count on the
        # next alloc.
        if pipe_table[su].buf != 0:
            kfree(pipe_table[su].buf)
            pipe_table[su].buf = 0
        pipe_table[su].used = 0


def pipe_close_reader(slot: int32):
    su: uint64 = cast[uint64](slot)
    if pipe_table[su].readers > 0:
        pipe_table[su].readers = pipe_table[su].readers - 1
    _maybe_free(slot)


def pipe_close_writer(slot: int32):
    su: uint64 = cast[uint64](slot)
    if pipe_table[su].writers > 0:
        pipe_table[su].writers = pipe_table[su].writers - 1
    # Event-driven EOF: the last writer going away means a blocked reader
    # must wake to observe end-of-file (pipe_read returns 0 with no
    # writers). Wake BEFORE _maybe_free, which may reclaim the slot. The
    # woken reader re-checks pipe_writers() and returns EOF.
    if pipe_table[su].writers == 0:
        wq_wake_all(&pipe_table[su].read_wq)
        # EOF is a readiness edge for SYS_WAITFDS waiters too.
        waitfds_notify()
    _maybe_free(slot)


def pipe_read_wq(slot: int32) -> Ptr[WaitQueue]:
    # Event-driven blocking: the read end's wait queue. vfs_read's
    # FD_PIPE_MARK_R / devfd pipe arms sleep on this when the ring is
    # empty; pipe_write / pipe_close_writer wake it.
    return &pipe_table[cast[uint64](slot)].read_wq


def pipe_readers(slot: int32) -> uint64:
    return pipe_table[cast[uint64](slot)].readers


def pipe_writers(slot: int32) -> uint64:
    return pipe_table[cast[uint64](slot)].writers


def pipe_readable(slot: int32) -> int32:
    # 1 if a read on this pipe would return bytes immediately, else 0.
    # Non-destructive — used by the §5 poll(2)/epoll(7) readiness probe
    # (fs/vfs.ad::vfs_fd_poll). EOF (no writers) is reported separately
    # by the caller, which checks pipe_writers().
    su: uint64 = cast[uint64](slot)
    if su >= PIPE_MAX:
        return 0
    if pipe_table[su].used == 0:
        return 0
    if pipe_table[su].count > 0:
        return 1
    return 0


def pipe_writable(slot: int32) -> int32:
    # 1 if a write would accept at least one byte (ring not full).
    # Non-destructive readiness probe for poll(2)/epoll(7).
    su: uint64 = cast[uint64](slot)
    if su >= PIPE_MAX:
        return 0
    if pipe_table[su].used == 0:
        return 0
    if pipe_table[su].count < pipe_table[su].cap:
        return 1
    return 0


def pipe_count(slot: int32) -> uint64:
    # Bytes currently buffered in the ring (0 for a free / OOR slot).
    su: uint64 = cast[uint64](slot)
    if su >= PIPE_MAX:
        return 0
    if pipe_table[su].used == 0:
        return 0
    return pipe_table[su].count


def pipe_peek(slot: int32, dst: Ptr[uint8], count: uint64) -> int64:
    # tee(2) support: copy up to `count` bytes out of the ring WITHOUT
    # consuming them — head/tail/count are left untouched so the bytes
    # stay readable. Returns bytes copied (0 when the ring is empty).
    su:  uint64 = cast[uint64](slot)
    have: uint64 = pipe_table[su].count
    if have == 0:
        return 0
    take: uint64 = count
    if take > have:
        take = have

    cap:  uint64 = pipe_table[su].cap
    head: uint64 = pipe_table[su].head
    buf:  uint64 = pipe_table[su].buf

    # Two-segment copy: head to end-of-ring, then wraparound. Identical
    # to pipe_read's body minus the head/count advance.
    first: uint64 = cap - head
    if first > take:
        first = take
    memcpy(dst, cast[Ptr[uint8]](buf + head), first)
    if take > first:
        memcpy(cast[Ptr[uint8]](cast[uint64](dst) + first),
               cast[Ptr[uint8]](buf), take - first)
    return cast[int64](take)


def pipe_read(slot: int32, dst: Ptr[uint8], count: uint64) -> int64:
    # Returns bytes copied; 0 means "nothing right now — caller has
    # to check writers to distinguish EOF from would-block". Reads
    # are non-blocking at this layer; vfs_read wraps the yield loop.
    su:  uint64 = cast[uint64](slot)
    have: uint64 = pipe_table[su].count
    if have == 0:
        return 0
    take: uint64 = count
    if take > have:
        take = have

    cap:  uint64 = pipe_table[su].cap
    head: uint64 = pipe_table[su].head
    buf:  uint64 = pipe_table[su].buf

    # Two-segment copy: from head to end-of-ring, then wraparound.
    first: uint64 = cap - head
    if first > take:
        first = take
    memcpy(dst, cast[Ptr[uint8]](buf + head), first)
    if take > first:
        memcpy(cast[Ptr[uint8]](cast[uint64](dst) + first),
               cast[Ptr[uint8]](buf), take - first)

    pipe_table[su].head  = (head + take) % cap
    pipe_table[su].count = have - take
    return cast[int64](take)


def pipe_read_blocking(slot: int32, dst: Ptr[uint8],
                       count: uint64) -> int64:
    # Phase 4c (pipe fold): the blocking read body, verbatim from the
    # retired fs/vfs.ad FD_PIPE_MARK_R arm. Sleep on the pipe's read
    # wait queue until a writer enqueues bytes (pipe_write wakes us) OR
    # the last writer closes (pipe_close_writer wakes us so we observe
    # EOF). This is the event-driven model — the reader is STATE_WAIT
    # (off the runqueue) while idle, woken directly by the producer
    # rather than re-polled on every 100 Hz timer tick. A signal-wake
    # returns WQ_EINTR so the read aborts with -EINTR.
    while True:
        n: int64 = pipe_read(slot, dst, count)
        if n > 0:
            return n
        if pipe_writers(slot) == 0:
            return 0                       # all writers gone -> EOF
        # Two-phase wait to close the SMP lost-wakeup window: queue
        # ourselves FIRST, then re-check the pipe (and writer count)
        # while queued. If a writer raced bytes in / closed between the
        # checks above and here, the recheck sees it and we cancel
        # instead of sleeping forever. Only commit to sleep when the
        # pipe is still empty AND a writer still exists.
        pwq: Ptr[WaitQueue] = pipe_read_wq(slot)
        wq_wait_prepare(pwq)
        if pipe_readable(slot) != 0 or pipe_writers(slot) == 0:
            wq_wait_cancel(pwq)
            continue
        rcp: int32 = wq_wait_commit(pwq)
        if rcp != 0:
            return cast[int64](WQ_EINTR)


def pipe_write_blocking(slot: int32, src: Ptr[uint8],
                        count: uint64) -> int64:
    # Phase 4c (pipe fold): the blocking write body, verbatim from the
    # retired fs/vfs.ad FD_PIPE_MARK_W arm. Drain as much as the ring
    # will accept, yielding when full until a reader makes room. EPIPE
    # (-32) if every reader has closed (matches Linux's write-after-
    # close error; no SIGPIPE yet — userland sees the errno).
    total: uint64 = 0
    while total < count:
        if pipe_readers(slot) == 0:
            if total > 0:
                return cast[int64](total)
            return -32                     # -EPIPE
        chunk: int64 = pipe_write(slot,
            cast[Ptr[uint8]](cast[uint64](src) + total),
            count - total)
        if chunk > 0:
            total = total + cast[uint64](chunk)
        else:
            yield_to_others()
    return cast[int64](total)


def pipe_write(slot: int32, src: Ptr[uint8], count: uint64) -> int64:
    # Returns bytes copied. 0 here means "ring is full right now" —
    # caller checks readers to distinguish from EPIPE.
    su:  uint64 = cast[uint64](slot)
    have: uint64 = pipe_table[su].count
    cap:  uint64 = pipe_table[su].cap
    if have >= cap:
        return 0
    free_space: uint64 = cap - have
    take: uint64 = count
    if take > free_space:
        take = free_space

    tail: uint64 = pipe_table[su].tail
    buf:  uint64 = pipe_table[su].buf

    first: uint64 = cap - tail
    if first > take:
        first = take
    memcpy(cast[Ptr[uint8]](buf + tail), src, first)
    if take > first:
        memcpy(cast[Ptr[uint8]](buf),
               cast[Ptr[uint8]](cast[uint64](src) + first), take - first)

    pipe_table[su].tail  = (tail + take) % cap
    pipe_table[su].count = have + take
    # Event-driven: bytes are now available; wake any reader sleeping on
    # this pipe's read wait queue so it drains them promptly instead of
    # waiting for a timer-tick re-poll.
    if take > 0:
        wq_wake_all(&pipe_table[su].read_wq)
        # Also kick multi-fd SYS_WAITFDS waiters whose set includes this
        # pipe's read end.
        waitfds_notify()
    return cast[int64](take)


# --- pipechan_selftest -----------------------------------------------
#
# Phase 4c gate: proves the FD_PIPE_MARK_R/W → DEV_PIPE_R/DEV_PIPE_W
# pool-chan fold end to end WITHOUT serial input (the legacy pipe gates
# drive hamsh over serial stdin, which this host loses; scripts/
# test_pipe_chan.sh boots with stdin </dev/null and greps the
# [PIPECHAN] marker):
#
#   * vfs_pipe lands TWO FD_CHAN_MARK fds whose chan ids resolve to the
#     SAME ring slot via namec_chan_pipe_slot (representation check).
#   * vfs_waitfds_probe(rfd) walks 0 → 1 → 0 across write/drain — the
#     namec_poll_readable DEV_PIPE_R arm (class 0 = wired to
#     waitfds_notify; the fold must NOT regress pipe polls to
#     always-ready).
#   * write via the chan (namec_write → pipe_write_blocking), read it
#     back (namec_read → pipe_read_blocking) — payload carries through.
#   * a dup'd read fd (copy_fd_entry — the REAL fork/dup hook, which
#     bumps the CHAN refcount) is closed FIRST and the original still
#     reads — the legacy model held one pipe ref PER FD; the chan model
#     holds one per CHAN, released only on the last holder.
#   * fstat identity: both ends report the 0x43-tagged ring-slot inode,
#     R and W distinct (#410 stable-identity contract).
#   * vfs_lseek is rejected (a pipe has no cursor).
#   * close(wfd) → EOF: probe says ready, read returns 0.
#   * fresh pipe, close(rfd) first → vfs_write answers -EPIPE (-32).
#
# vfs_* / namec_chan_pipe_slot are resolved BY NAME (the whole-kernel
# Adder merge) — vfs.ad and namec.ad both import fs/pipe.ad, so a
# literal import here would cycle. Returns 1 PASS, 0 FAIL. PUBLIC so
# init/main.ad can call it.

def pipechan_selftest() -> int32:
    # The boot task's fd table is uninitialised (all-zero ≠
    # FD_CLOSED_MARK ⇒ _alloc_fd sees every slot in use): free slots
    # 10/11/12 deterministically, restore them on the way out.
    boot_slot: int32 = cast[int32](current_idx_get())
    s10i: uint32 = task_fd_idx_at(boot_slot, 10)
    s10b: uint64 = task_fd_buf_at(boot_slot, 10)
    s11i: uint32 = task_fd_idx_at(boot_slot, 11)
    s11b: uint64 = task_fd_buf_at(boot_slot, 11)
    s12i: uint32 = task_fd_idx_at(boot_slot, 12)
    s12b: uint64 = task_fd_buf_at(boot_slot, 12)
    task_set_fd_idx_at(boot_slot, 10, FD_CLOSED_MARK)
    task_set_fd_buf_at(boot_slot, 10, 0)
    task_set_fd_idx_at(boot_slot, 11, FD_CLOSED_MARK)
    task_set_fd_buf_at(boot_slot, 11, 0)
    task_set_fd_idx_at(boot_slot, 12, FD_CLOSED_MARK)
    task_set_fd_buf_at(boot_slot, 12, 0)

    ok: int32 = 1
    fds: Array[2, int32]
    fds[0] = -1
    fds[1] = -1
    if vfs_pipe(&fds[0]) != 0:
        printk0("[PIPECHAN] FAIL vfs_pipe\n")
        ok = 0
    rfd: int32 = fds[0]
    wfd: int32 = fds[1]

    if ok == 1:
        # Representation: both fds carry chan ids that resolve to the
        # SAME pipe ring slot (and resolve at all — non-pipe chans
        # answer -1).
        rcid: int32 = cast[int32](cast[uint32](
            task_fd_buf_at(boot_slot, cast[uint64](rfd))))
        wcid: int32 = cast[int32](cast[uint32](
            task_fd_buf_at(boot_slot, cast[uint64](wfd))))
        rslot: int32 = namec_chan_pipe_slot(rcid)
        wslot: int32 = namec_chan_pipe_slot(wcid)
        if rslot < 0 or rslot != wslot:
            printk1("[PIPECHAN] FAIL slot resolve rslot=%d\n",
                    cast[uint64](cast[uint32](rslot)))
            ok = 0

    if ok == 1 and vfs_waitfds_probe(rfd) != 0:
        # Empty pipe + live writer ⇒ class 0 (wired, not ready). The
        # legacy FD_CHAN fallthrough said "always ready" — tripwire.
        printk0("[PIPECHAN] FAIL probe!=0 on empty pipe\n")
        ok = 0

    if ok == 1:
        payload: Array[8, uint8]
        payload[0] = 112        # 'p'
        payload[1] = 52         # '4'
        payload[2] = 99         # 'c'
        payload[3] = 33         # '!'
        wn: int64 = vfs_write(wfd, &payload[0], 4)
        if wn != 4:
            printk1("[PIPECHAN] FAIL write rc=%d\n", cast[uint64](wn))
            ok = 0
        if ok == 1 and vfs_waitfds_probe(rfd) != 1:
            printk0("[PIPECHAN] FAIL probe!=1 with bytes queued\n")
            ok = 0

    if ok == 1:
        # Dup the READ end (the real fork/dup hook: bumps the chan
        # refcount), close the dup — the original MUST still drain the
        # payload. Under the legacy per-fd pipe refs this was safe by
        # construction; under chans it proves namec_chan_ref/namec_close
        # pair correctly.
        tsk: Ptr[TaskStruct] = current_task()
        if copy_fd_entry(tsk, 12, tsk, cast[uint64](rfd)) != 0:
            printk0("[PIPECHAN] FAIL dup copy_fd_entry\n")
            ok = 0
        if ok == 1 and vfs_close(12) != 0:
            printk0("[PIPECHAN] FAIL close(dup)\n")
            ok = 0
        if ok == 1:
            rbuf: Array[8, uint8]
            rn: int64 = vfs_read(rfd, &rbuf[0], 8)
            if rn != 4 or rbuf[0] != 112 or rbuf[1] != 52 \
                    or rbuf[2] != 99 or rbuf[3] != 33:
                printk1("[PIPECHAN] FAIL read rc=%d\n", cast[uint64](rn))
                ok = 0
        if ok == 1 and vfs_waitfds_probe(rfd) != 0:
            printk0("[PIPECHAN] FAIL probe!=0 after drain\n")
            ok = 0

    if ok == 1:
        # Stable fstat identity (#410): 0x43-tagged ring-slot inodes,
        # R and W ends distinct.
        ir: uint64 = vfs_fd_inode(rfd)
        iw: uint64 = vfs_fd_inode(wfd)
        if (ir >> 56) != 0x43 or (iw >> 56) != 0x43 or ir == iw:
            printk1("[PIPECHAN] FAIL inode tag ir=%x\n", ir)
            ok = 0

    if ok == 1 and vfs_lseek(rfd, 0, 0) >= 0:
        printk0("[PIPECHAN] FAIL lseek accepted on pipe fd\n")
        ok = 0

    if ok == 1:
        # EOF: last writer gone ⇒ probe says ready, read returns 0.
        vfs_close(wfd)
        wfd = -1
        if vfs_waitfds_probe(rfd) != 1:
            printk0("[PIPECHAN] FAIL probe!=1 at EOF\n")
            ok = 0
        if ok == 1:
            ebuf: Array[8, uint8]
            en: int64 = vfs_read(rfd, &ebuf[0], 8)
            if en != 0:
                printk1("[PIPECHAN] FAIL EOF read rc=%d\n",
                        cast[uint64](en))
                ok = 0

    if ok == 1:
        # EPIPE: fresh pipe, reader closed first ⇒ write answers -32.
        vfs_close(rfd)
        rfd = -1
        fds2: Array[2, int32]
        if vfs_pipe(&fds2[0]) != 0:
            printk0("[PIPECHAN] FAIL second vfs_pipe\n")
            ok = 0
        else:
            vfs_close(fds2[0])
            pbuf: Array[4, uint8]
            pbuf[0] = 120       # 'x'
            pn: int64 = vfs_write(fds2[1], &pbuf[0], 1)
            if pn != -32:
                printk1("[PIPECHAN] FAIL EPIPE rc=%d\n", cast[uint64](pn))
                ok = 0
            vfs_close(fds2[1])

    # Teardown: close whatever is still open, restore the boot slots.
    if rfd >= 0:
        vfs_close(rfd)
    if wfd >= 0:
        vfs_close(wfd)
    task_set_fd_idx_at(boot_slot, 10, s10i)
    task_set_fd_buf_at(boot_slot, 10, s10b)
    task_set_fd_idx_at(boot_slot, 11, s11i)
    task_set_fd_buf_at(boot_slot, 11, s11b)
    task_set_fd_idx_at(boot_slot, 12, s12i)
    task_set_fd_buf_at(boot_slot, 12, s12b)

    if ok == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[PIPECHAN] FAIL\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[PIPECHAN] PASS pipe()/dup/probe/EOF/EPIPE/fstat over DEV_PIPE chans\n")
    return 1

# fs/ext4.ad
#
# EXT4 read-only — mirror of fs/ext4/super.c at the smallest
# meaningful scope. M16.51 ships ONLY the superblock parser; the
# rest of the read path (group descriptors → inode table → extent
# tree → directory walk) lands in subsequent milestones.
#
# Single-mount only (one global state block). Multiple mounts wait
# for the VFS superblock/inode/dentry refactor.
#
# On-disk layout we care about for the superblock:
#
#   - The superblock sits at byte offset 1024 from the start of
#     the filesystem (sector 2 with 512-byte sectors). Always
#     1024 bytes, regardless of block_size.
#   - block_size = 1024 << s_log_block_size.
#   - block group descriptors follow the superblock's block.
#   - inode table for block group N starts at the block address
#     stored in the group descriptor.
#
# Field offsets (relative to the start of the 1024-byte sb):
#   0x00  s_inodes_count       u32
#   0x04  s_blocks_count_lo    u32
#   0x14  s_first_data_block   u32
#   0x18  s_log_block_size     u32
#   0x20  s_blocks_per_group   u32
#   0x28  s_inodes_per_group   u32
#   0x38  s_magic              u16  (0xEF53)
#   0x58  s_inode_size         u16

from kernel.block.blk import (
    blk_read_sectors, blk_write_sectors, blk_flush, find_blockdev,
    SECTOR_SIZE,
)
from kernel.printk.printk import printk0, printk1, printk2
from drivers.rtc.cmos import rtc_read_unix_time

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


EXT4_MAGIC: uint16 = 0xEF53

# struct stat-style inode mode bits we care about. The ext4 i_mode
# field encodes file type in the high nibble (mask 0xF000). 0x8000 is
# regular file, 0x4000 is directory, 0xA000 is symlink — the value
# /usr/include/linux/stat.h calls S_IFLNK.
S_IFLNK: uint16 = 0xA000


# Mount state — single mount.
ext4_blockdev_slot:   int32  = -1
ext4_block_size:      uint64 = 0
ext4_blocks_per_grp:  uint64 = 0
ext4_inodes_per_grp:  uint64 = 0
ext4_inodes_count:    uint64 = 0
ext4_blocks_count:    uint64 = 0
ext4_first_data_blk:  uint64 = 0
ext4_inode_size:      uint64 = 0
# Group descriptor size — 32 bytes for legacy ext2/3 / pre-64bit
# ext4, 64 bytes for modern ext4 with the 64BIT feature. Read from
# the superblock's s_desc_size (offset 0xFE).
ext4_desc_size:       uint64 = 0
# Block where the group descriptor table starts. For 1 KiB blocks
# with s_first_data_block = 1, the SB is in block 1 and the GDT
# follows in block 2. For other block sizes, it's s_first_data_block
# + 1.
ext4_gdt_block:       uint64 = 0

# Two sectors of scratch for the boot+superblock read. The sb is at
# byte offset 1024 from the partition start; two sectors (0..1023)
# cover the boot area, and we need sectors 2..3 for the sb itself.
ext4_sb_buf: Array[1024, uint8]


def _ext4_read_u16(p: Ptr[uint8]) -> uint16:
    return cast[uint16](p[0]) | (cast[uint16](p[1]) << 8)


def _ext4_read_u32(p: Ptr[uint8]) -> uint32:
    return (cast[uint32](p[0])
            | (cast[uint32](p[1]) << 8)
            | (cast[uint32](p[2]) << 16)
            | (cast[uint32](p[3]) << 24))


def ext4_init(slot: int32) -> int32:
    # Read the 1024-byte superblock from sectors 2..3 of the block
    # device. Returns 0 on success, -1 on read failure / wrong magic.
    rc: int32 = blk_read_sectors(slot, 2, 2, &ext4_sb_buf[0])
    if rc != 0:
        printk0("ext4: failed to read superblock\n")
        return -1

    sb: Ptr[uint8] = &ext4_sb_buf[0]
    magic: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x38))
    if magic != EXT4_MAGIC:
        printk1("ext4: bad magic %x (not an ext2/3/4 fs)\n",
                cast[uint64](magic))
        return -1

    log_block_size: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x18))
    ext4_block_size      = cast[uint64](1024) << cast[uint64](log_block_size)
    ext4_inodes_count    = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x00)))
    ext4_blocks_count    = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x04)))
    ext4_first_data_blk  = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x14)))
    ext4_blocks_per_grp  = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x20)))
    ext4_inodes_per_grp  = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x28)))
    ext4_inode_size      = cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x58)))
    if ext4_inode_size == 0:
        ext4_inode_size = 128                  # ext2 default
    ext4_desc_size       = cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](sb) + 0xFE)))
    if ext4_desc_size == 0:
        ext4_desc_size = 32                    # legacy default
    ext4_gdt_block = ext4_first_data_blk + 1

    ext4_blockdev_slot = slot
    printk2("ext4: mounted; block_size=%d inodes_count=%d\n",
            ext4_block_size, ext4_inodes_count)
    printk2("ext4:   blocks_per_group=%d inodes_per_group=%d\n",
            ext4_blocks_per_grp, ext4_inodes_per_grp)
    printk2("ext4:   first_data_block=%d inode_size=%d\n",
            ext4_first_data_blk, ext4_inode_size)
    return 0


def ext4_is_mounted() -> int32:
    if ext4_blockdev_slot < 0:
        return 0
    return 1


# Scratch buffer for one filesystem block. Sized to cover the 4 KiB
# blocks ext4_mkfs produces (M16.x) AND the 1 KiB blocks the existing
# test image uses. Larger block sizes (16 KiB+) would need bumping or
# a slab allocation per call.
ext4_blk_buf: Array[4096, uint8]

# Separate scratch for the extent-tree walk. _ext4_logical_to_physical
# is called by ext4_read_file just BEFORE that function reads the
# physical data block into ext4_blk_buf — so reusing the same buffer
# for index-node reads would race with the data read on the same
# iteration. Same 4 KiB sizing as ext4_blk_buf.
ext4_ext_scratch: Array[4096, uint8]


def _ext4_read_block(block_nr: uint64, buf: Ptr[uint8]) -> int32:
    # Read filesystem block `block_nr` into `buf`. Always reads
    # exactly ext4_block_size bytes (2 sectors for 1 KiB, 8 sectors
    # for 4 KiB).
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    lba: uint64 = block_nr * sectors_per_block
    return blk_read_sectors(ext4_blockdev_slot, lba, sectors_per_block, buf)


def _ext4_write_block(block_nr: uint64, buf: Ptr[uint8]) -> int32:
    # Symmetric write. Used for bitmap updates and (eventually)
    # data block writes during file create / extend.
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    lba: uint64 = block_nr * sectors_per_block
    return blk_write_sectors(ext4_blockdev_slot, lba, sectors_per_block, buf)


def ext4_read_inode(inum: uint64, out: Ptr[uint8]) -> int32:
    # Locate inode `inum` (1-indexed, like Linux) via the standard
    # ext4 lookup pattern: pick its block group, read that group's
    # descriptor to find bg_inode_table_lo, then index into the
    # inode table by (inum-1) mod inodes_per_group.
    if inum == 0 or inum > ext4_inodes_count:
        return -1

    grp:    uint64 = (inum - 1) / ext4_inodes_per_grp
    idx:    uint64 = (inum - 1) % ext4_inodes_per_grp

    # Read the GDT block + offset to find this group's descriptor.
    desc_byte_off: uint64 = grp * ext4_desc_size
    gdt_block:     uint64 = ext4_gdt_block + desc_byte_off / ext4_block_size
    within:        uint64 = desc_byte_off % ext4_block_size
    if _ext4_read_block(gdt_block, &ext4_blk_buf[0]) != 0:
        return -1
    inode_table_block: uint64 = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0]) + within + 8)))

    # Read the inode table block(s) holding inode `inum` and copy
    # the inode_size bytes into the caller's buffer.
    inode_byte: uint64 = inode_table_block * ext4_block_size \
                       + idx * ext4_inode_size
    sec_lba:   uint64 = inode_byte / SECTOR_SIZE
    sec_off:   uint64 = inode_byte % SECTOR_SIZE
    # Up to 256 bytes can span at most one sector boundary (sectors
    # are 512 bytes); read 2 sectors to be safe regardless of off.
    if blk_read_sectors(ext4_blockdev_slot, sec_lba, 2,
                        &ext4_blk_buf[0]) != 0:
        return -1
    src: uint64 = cast[uint64](&ext4_blk_buf[0]) + sec_off
    memcpy(out, cast[Ptr[uint8]](src), ext4_inode_size)
    return 0


def ext4_inode_mode(buf: Ptr[uint8]) -> uint16:
    # struct ext4_inode.i_mode at offset 0.
    return _ext4_read_u16(buf)


def ext4_inode_size_lo(buf: Ptr[uint8]) -> uint32:
    # struct ext4_inode.i_size_lo at offset 4.
    return _ext4_read_u32(cast[Ptr[uint8]](cast[uint64](buf) + 4))


# --- extent tree --------------------------------------------------
#
# i_block[60 bytes] starts at inode offset 0x28. For inodes with
# the EXTENTS flag set (default in modern ext4), the first 12 bytes
# are a struct ext4_extent_header:
#
#   0x00  u16 eh_magic       (0xF30A)
#   0x02  u16 eh_entries
#   0x04  u16 eh_max
#   0x06  u16 eh_depth       (0 = leaf, >0 = index — we don't
#                              walk indirect index blocks yet)
#   0x08  u32 eh_generation
#
# Followed by up to 4 struct ext4_extent records (12 bytes each at
# depth 0):
#
#   0x00  u32 ee_block       (logical block, file_offset / blk_sz)
#   0x04  u16 ee_len
#   0x06  u16 ee_start_hi
#   0x08  u32 ee_start_lo
#
# Files small enough that all extents fit inline (>= ~50 KiB for
# 1 KiB blocks) are completely described by this 60-byte window.

INODE_I_BLOCK_OFFSET: uint64 = 40             # 0x28
EXT4_EXTENT_MAGIC:    uint16 = 0xF30A


def ext4_inode_first_extent_block(buf: Ptr[uint8]) -> uint64:
    # Returns the physical block holding logical block 0 of the file.
    # For directories this is the dir's first data block; for files
    # the start of the data. Walks index nodes transparently, so a
    # depth > 0 directory or a sparse-front file resolves correctly.
    return _ext4_logical_to_physical(buf, 0)


# --- directory walk -----------------------------------------------
#
# Each ext4 directory block is a sequence of struct ext4_dir_entry_2:
#
#   0x00  u32 inode
#   0x04  u16 rec_len    (record length, including padding to 4)
#   0x06  u8  name_len
#   0x07  u8  file_type
#   0x08  name[name_len]
#
# rec_len walks us to the next entry. The last entry in the block
# has rec_len that spans to end-of-block (consuming the remainder
# as implicit padding).

DIR_ENTRY_HDR_BYTES: uint64 = 8


def _name_eq_with_len(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    # Byte-compare a[0..n] against b[0..n-1] plus require b[n] == 0
    # (so "HELLO" doesn't match against "HELLO.TXT" or vice versa).
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if b[n] != 0:
        return 0
    return 1


def ext4_dir_lookup(dir_inode_buf: Ptr[uint8],
                    name: Ptr[char]) -> uint32:
    # Walk EVERY data block of the directory looking for `name`. A
    # directory's size grows in block-sized chunks as it accumulates
    # entries; ~30 entries fills a 1 KiB block, after which ext4
    # allocates another block. Walking only block 0 (the M16.51..58
    # behavior) silently truncates lookups for large dirs. Returns
    # the matched inode number, or 0 on miss.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(dir_inode_buf))
    if dir_size == 0:
        return 0
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(dir_inode_buf, lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        pos: uint64 = 0
        while pos + DIR_ENTRY_HDR_BYTES <= ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if rec_len == 0:
                break                              # advance to next block
            if inum != 0:
                name_len: uint64 = cast[uint64](cast[Ptr[uint8]](e + 6)[0])
                if _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                     cast[Ptr[uint8]](name),
                                     name_len) != 0:
                    return inum
            pos = pos + cast[uint64](rec_len)
        lb = lb + 1
    return 0


# --- file read ----------------------------------------------------
#
# Walks the inode's inline leaf extents looking for the extent that
# contains logical block N. Returns the physical block, or 0 on miss
# (sparse file or N past end-of-file). Index nodes (eh_depth > 0)
# are deferred — they kick in for files >> 50 KiB.

def _ext4_logical_to_physical(inode_buf: Ptr[uint8],
                              logical_blk: uint64) -> uint64:
    # Walk the extent tree from the inode's i_block root to the leaf
    # that owns `logical_blk`. The root header lives at inode+0x28;
    # for depth-> 0 we follow index records into a child block,
    # repointing eh at the child's header and looping. Linux's
    # fs/ext4/extents.c::ext4_ext_find_extent does the same.
    #
    # Index-record layout (12 bytes, same size as leaf extents):
    #     0x00  u32 ei_block     lowest logical block this child covers
    #     0x04  u32 ei_leaf_lo   physical block of the child node
    #     0x08  u16 ei_leaf_hi   high 16 bits (48-bit phys total)
    #     0x0A  u16 ei_unused
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    # 5 levels is comfortably more than ext4 ever produces in practice
    # — even 16 TB filesystems top out around 3-4. The bound is here
    # so a malformed header pointing into a cycle doesn't loop forever.
    safety: int32 = 5
    while safety > 0:
        safety = safety - 1
        magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
        if magic != EXT4_EXTENT_MAGIC:
            return 0
        entries: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 2))
        depth:   uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 6))
        if depth == 0:
            # Leaf: find the extent covering logical_blk.
            i: uint16 = 0
            while i < entries:
                ee: uint64 = eh + 12 + cast[uint64](i) * 12
                ee_block:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 0))
                ee_len:      uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 4))
                ee_start_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 6))
                ee_start_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 8))
                eb: uint64 = cast[uint64](ee_block)
                if logical_blk >= eb and logical_blk < eb + cast[uint64](ee_len):
                    phys_base: uint64 = (cast[uint64](ee_start_hi) << 32) \
                                      | cast[uint64](ee_start_lo)
                    return phys_base + (logical_blk - eb)
                i = i + 1
            return 0
        # Index node: pick the RIGHTMOST entry whose ei_block <=
        # logical_blk. Entries are sorted ascending by ei_block, so a
        # simple linear scan with a "best so far" cursor is correct.
        chosen: int32 = -1
        j: uint16 = 0
        while j < entries:
            ei: uint64 = eh + 12 + cast[uint64](j) * 12
            ei_block: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 0))
            if cast[uint64](ei_block) <= logical_blk:
                chosen = cast[int32](j)
            else:
                break
            j = j + 1
        if chosen < 0:
            return 0
        ei: uint64 = eh + 12 + cast[uint64](chosen) * 12
        ei_leaf_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        ei_leaf_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        child_blk: uint64 = (cast[uint64](ei_leaf_hi) << 32) \
                          | cast[uint64](ei_leaf_lo)
        if _ext4_read_block(child_blk, &ext4_ext_scratch[0]) != 0:
            return 0
        eh = cast[uint64](&ext4_ext_scratch[0])
    return 0


def ext4_read_file(inum: uint32, pos: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int64:
    # Reads `count` bytes starting at file offset `pos` from the
    # file at inode `inum`. Returns bytes read; 0 on EOF.
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    size: uint64 = cast[uint64](ext4_inode_size_lo(&inode[0]))
    if pos >= size:
        return 0
    remaining: uint64 = size - pos
    if count > remaining:
        count = remaining

    total: uint64 = 0
    while total < count:
        cur_off: uint64 = pos + total
        logical_blk: uint64 = cur_off / ext4_block_size
        off_in_blk:  uint64 = cur_off % ext4_block_size
        phys_blk: uint64 = _ext4_logical_to_physical(&inode[0],
                                                    logical_blk)
        if phys_blk == 0:
            return cast[int64](total)
        if _ext4_read_block(phys_blk, &ext4_blk_buf[0]) != 0:
            return cast[int64](total)
        chunk: uint64 = ext4_block_size - off_in_blk
        if chunk > count - total:
            chunk = count - total
        memcpy(cast[Ptr[uint8]](cast[uint64](buf) + total),
               cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0])
                                + off_in_blk),
               chunk)
        total = total + chunk
    return cast[int64](total)


# --- open-file slot table for VFS integration --------------------

class Ext4OpenFile:
    used:      uint32
    pad:       uint32
    inum:      uint32
    pad2:      uint32
    file_size: uint64


EXT4_MAX_OPEN: uint64 = 8
ext4_open_files: Array[8, Ext4OpenFile]


def _ext4_path_next_component(path: Ptr[char], start: uint64,
                              out_buf: Ptr[uint8]) -> int64:
    # Same shape as fat's _path_next_component: copy bytes into
    # out_buf until '/' or NUL. NUL-terminate, return index of byte
    # after the slash or -1 on NUL termination.
    i: uint64 = 0
    while True:
        c: int32 = path[start + i]
        if c == 0:
            out_buf[i] = 0
            return -1
        if c == 47:                               # '/'
            out_buf[i] = 0
            return cast[int64](start + i + 1)
        out_buf[i] = cast[uint8](c & 0xFF)
        i = i + 1


# --- symlink follow (M16.68) --------------------------------------
#
# ext4 stores symlink targets two ways:
#
#   * "fast" link (i_size <= 60): target lives INLINE in i_block,
#     the same 60-byte window normally used for the extent tree.
#     mkfs/debugfs sets i_blocks_lo = 0 because no data block is
#     allocated. Linux's ext4_inode_is_fast_symlink() uses the same
#     test; the read just memcpy's out of i_block.
#   * "slow" link (i_size > 60): target lives in the file's first
#     data block, reached via the standard extent walk.
#
# In both cases the target is a raw byte string with no trailing NUL
# on disk — we add one ourselves on the way out so the caller can
# treat it as a C string.

# Working buffers for path rewriting during symlink follow. Single
# mount, single thread, so a pair of static buffers is enough.
ext4_path_work: Array[256, uint8]
ext4_link_target: Array[256, uint8]


def _ext4_read_symlink_target(inode_buf: Ptr[uint8],
                              out_buf: Ptr[uint8],
                              out_size: uint64) -> int32:
    # Read the symlink's target into out_buf, NUL-terminated. Returns
    # 0 on success, -1 on read failure or empty/truncated link.
    if out_size == 0:
        return -1
    isize: uint64 = cast[uint64](ext4_inode_size_lo(inode_buf))
    if isize == 0:
        out_buf[0] = 0
        return -1
    # Reserve one byte for our NUL terminator.
    take: uint64 = isize
    if take > out_size - 1:
        take = out_size - 1
    if isize <= 60:
        # Fast symlink: target inline in i_block at offset 0x28.
        src: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
        memcpy(out_buf, cast[Ptr[uint8]](src), take)
    else:
        # Slow symlink: target lives in the first data block. Reuse
        # the standard extent → physical → read pipeline.
        phys: uint64 = _ext4_logical_to_physical(inode_buf, 0)
        if phys == 0:
            return -1
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        memcpy(out_buf, &ext4_blk_buf[0], take)
    out_buf[take] = 0
    return 0


def _ext4_strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _ext4_path_starts_with_ext(s: Ptr[uint8]) -> int32:
    # Match "/ext/" prefix on a raw byte buffer.
    prefix: Ptr[uint8] = "/ext/"
    i: uint64 = 0
    while i < 5:
        if s[i] != prefix[i]:
            return 0
        i = i + 1
    return 1


# Resolution result returned by _resolve_with_symlinks. Callers pull
# the bits they care about (file vs dir, inum, file size).
class Ext4ResolveResult:
    inum:       uint32
    is_dir:     uint32
    file_size:  uint64


def _resolve_with_symlinks(path: Ptr[char],
                           result: Ptr[Ext4ResolveResult]) -> int32:
    # Walk `path` from the ext4 root with symlink follow-through. On
    # an intermediate (or final) component that resolves to a symlink,
    # splice the target into the working path string and restart from
    # root. Bounded at 8 follows to break loops (matches Linux's
    # MAXSYMLINKS default).
    #
    # Returns 1 on hit (fills *result), 0 on miss.
    if path[0] == 0:
        # Empty path → ext4 root.
        result[0].inum      = 2
        result[0].is_dir    = 1
        result[0].file_size = 0
        return 1

    # Snapshot the input path into our mutable scratch.
    pi: uint64 = 0
    while True:
        c: int32 = path[pi]
        if pi >= 255:
            return 0
        ext4_path_work[pi] = cast[uint8](c & 0xFF)
        if c == 0:
            break
        pi = pi + 1

    follows: int32 = 0
    while True:
        cur_inode: Array[256, uint8]
        if ext4_read_inode(2, &cur_inode[0]) != 0:
            return 0
        cur_inum: uint32 = 2
        component: Array[64, uint8]
        start: uint64 = 0
        restart: int32 = 0
        while restart == 0:
            nxt: int64 = _ext4_path_next_component(
                cast[Ptr[char]](&ext4_path_work[0]), start,
                &component[0])
            if component[0] == 0:
                # Empty component. For a trailing slash on a dir path
                # we want to return the current dir; bare empty path
                # was handled above.
                if nxt < 0:
                    result[0].inum      = cur_inum
                    result[0].is_dir    = 1
                    result[0].file_size = 0
                    return 1
                start = cast[uint64](nxt)
                continue
            inum: uint32 = ext4_dir_lookup(&cur_inode[0],
                                           cast[Ptr[char]](&component[0]))
            if inum == 0:
                return 0
            if ext4_read_inode(cast[uint64](inum), &cur_inode[0]) != 0:
                return 0
            mode: uint16 = ext4_inode_mode(&cur_inode[0])
            type_bits: uint16 = mode & 0xF000

            if type_bits == S_IFLNK:
                if follows >= 8:
                    return 0
                follows = follows + 1
                if _ext4_read_symlink_target(
                        &cur_inode[0], &ext4_link_target[0], 256) != 0:
                    return 0
                # Splice the target into ext4_path_work.
                # `start` currently points at the first byte of the
                # component we just consumed; `nxt` points one byte
                # past the slash that ended it (or is -1 for the
                # last component). The "tail" (bytes still to walk)
                # is ext4_path_work[nxt..] for nxt >= 0, else "".
                tail_start: uint64 = 0
                has_tail: int32 = 0
                if nxt >= 0:
                    tail_start = cast[uint64](nxt)
                    if ext4_path_work[tail_start] != 0:
                        has_tail = 1
                # Pull tail out into its own scratch so we can rewrite
                # ext4_path_work in place. Reuse `component` (64 B) for
                # short tails; bail if the tail wouldn't fit.
                tail_buf: Array[256, uint8]
                tail_len: uint64 = 0
                if has_tail != 0:
                    j: uint64 = 0
                    while j < 255:
                        b: uint8 = ext4_path_work[tail_start + j]
                        tail_buf[j] = b
                        if b == 0:
                            break
                        j = j + 1
                    tail_buf[255] = 0
                    tail_len = j

                # Pick the new "prefix" (bytes before the symlink
                # component) and the spliced "middle" (the target).
                tgt: Ptr[uint8] = &ext4_link_target[0]
                middle_off: uint64 = 0          # how many bytes of tgt to skip
                prefix_len: uint64 = 0          # bytes of ext4_path_work to keep
                if ext4_link_target[0] == 47:   # '/'
                    # Absolute target. Restart the walk from the ext4
                    # root. Two flavors:
                    #   * "/ext/foo"  — kernel-namespace absolute path.
                    #     Strip the "/ext/" prefix and walk "foo".
                    #   * "/foo"      — ext4-namespace absolute (what
                    #     debugfs writes by default). Skip the single
                    #     leading slash and walk "foo".
                    if _ext4_path_starts_with_ext(tgt) != 0:
                        middle_off = 5          # skip "/ext/"
                    else:
                        middle_off = 1          # skip "/"
                    prefix_len = 0
                else:
                    middle_off = 0
                    prefix_len = start          # keep walked-bytes
                tgt_len: uint64 = _ext4_strlen_u8(tgt)
                if tgt_len < middle_off:
                    return 0
                tgt_len = tgt_len - middle_off

                # Build the new working path: [prefix][target tail]['/' tail].
                need: uint64 = prefix_len + tgt_len
                if has_tail != 0:
                    need = need + 1 + tail_len  # '/' + tail bytes
                if need >= 255:
                    return 0
                # If prefix_len == 0 we'd be overwriting from index 0
                # — same as the "restart from root" case. Either way,
                # write the target into [prefix_len..] then '/' + tail.
                k: uint64 = 0
                while k < tgt_len:
                    ext4_path_work[prefix_len + k] = \
                        ext4_link_target[middle_off + k]
                    k = k + 1
                wpos: uint64 = prefix_len + tgt_len
                if has_tail != 0:
                    ext4_path_work[wpos] = 47   # '/'
                    wpos = wpos + 1
                    m: uint64 = 0
                    while m < tail_len:
                        ext4_path_work[wpos + m] = tail_buf[m]
                        m = m + 1
                    wpos = wpos + tail_len
                ext4_path_work[wpos] = 0
                restart = 1
                continue

            is_dir: int32 = 0
            if type_bits == 0x4000:
                is_dir = 1
            if nxt < 0:
                # Last component.
                result[0].inum = inum
                if is_dir != 0:
                    result[0].is_dir    = 1
                    result[0].file_size = 0
                else:
                    result[0].is_dir    = 0
                    result[0].file_size = cast[uint64](
                        ext4_inode_size_lo(&cur_inode[0]))
                return 1
            # Intermediate component. Must be a directory now.
            if is_dir == 0:
                return 0
            cur_inum = inum
            start = cast[uint64](nxt)


def ext4_resolve_file(path: Ptr[char], out_inum: Ptr[uint32],
                      out_size: Ptr[uint64]) -> int32:
    # Walk `path` (caller already stripped /ext/) component by
    # component. Each component must be a directory entry in the
    # current directory; the LAST component must be a regular file.
    # Returns 1 on hit (fills out_inum / out_size), 0 on miss.
    #
    # Intermediate or final components that are symlinks are followed
    # transparently (M16.68); bounded at 8 follows to break loops.
    if path[0] == 0:
        return 0                                  # empty path → root, not a file
    r: Ext4ResolveResult
    if _resolve_with_symlinks(path, &r) == 0:
        return 0
    if r.is_dir != 0:
        return 0
    out_inum[0] = r.inum
    out_size[0] = r.file_size
    return 1


def ext4_resolve_dir(path: Ptr[char]) -> uint32:
    # Walk path to a DIRECTORY inode, returning its inum. Empty
    # path → root (inum 2). Returns 0 on miss / not-a-dir.
    # Symlink-aware (M16.68): intermediate symlinks follow through.
    if path[0] == 0:
        return 2
    r: Ext4ResolveResult
    if _resolve_with_symlinks(path, &r) == 0:
        return 0
    if r.is_dir == 0:
        return 0
    return r.inum


def ext4_open(name: Ptr[char]) -> int32:
    # Open /ext/<name> (caller already stripped /ext/). Walks the
    # full path so nested files like /ext/SUB/NESTED.TXT resolve.
    # Snapshots inum + size into a slot. Returns slot index or -1.
    if ext4_blockdev_slot < 0:
        return -1
    if name[0] == 0:
        return -1                                # not for the root dir
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(name, &inum, &fsize) == 0:
        return -1
    i: uint64 = 0
    while i < EXT4_MAX_OPEN:
        if ext4_open_files[i].used == 0:
            ext4_open_files[i].used      = 1
            ext4_open_files[i].inum      = inum
            ext4_open_files[i].file_size = fsize
            return cast[int32](i)
        i = i + 1
    printk0("ext4: open-file table full\n")
    return -1


def ext4_close(slot: int32):
    ext4_open_files[cast[uint64](slot)].used = 0


def ext4_open_size(slot: int32) -> uint64:
    return ext4_open_files[cast[uint64](slot)].file_size


def ext4_open_inum(slot: int32) -> uint32:
    return ext4_open_files[cast[uint64](slot)].inum


def ext4_set_open_size(slot: int32, size: uint64):
    # Refresh the cached file_size after an out-of-band size change
    # (ftruncate) so ext4_open_size() stays accurate for read-back.
    if slot < 0:
        return
    ext4_open_files[cast[uint64](slot)].file_size = size


def ext4_listdir(path: Ptr[char], buf: Ptr[uint8],
                 count: uint64) -> int64:
    # Pack the named directory's entries into buf as "NAME\n" lines.
    # path is the post-/ext/-strip tail (e.g. "" for root, "SUB"
    # for /ext/SUB). Walks every data block of the resolved
    # directory inode, so dirs that span multiple blocks (root
    # with many files, etc.) list completely.
    if count == 0:
        return -1
    if ext4_blockdev_slot < 0:
        return -1
    dir_inum: uint32 = ext4_resolve_dir(path)
    if dir_inum == 0:
        return -2                                # -ENOENT
    dir_inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](dir_inum), &dir_inode[0]) != 0:
        return -1
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&dir_inode[0]))
    if dir_size == 0:
        return 0
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    out: uint64 = 0
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&dir_inode[0], lb)
        if phys == 0:
            return cast[int64](out)
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return cast[int64](out)
        pos: uint64 = 0
        while pos + DIR_ENTRY_HDR_BYTES <= ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            ent_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            rec_len:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if rec_len == 0:
                break                              # next block
            if ent_inum != 0:
                name_len: uint64 = cast[uint64](cast[Ptr[uint8]](e + 6)[0])
                # Need room for the name + '\n' + leave 1 spare for NUL.
                if out + name_len + 1 >= count:
                    return cast[int64](out)
                i: uint64 = 0
                while i < name_len:
                    buf[out + i] = cast[Ptr[uint8]](e + 8 + i)[0]
                    i = i + 1
                buf[out + name_len] = 10            # '\n'
                out = out + name_len + 1
            pos = pos + cast[uint64](rec_len)
        lb = lb + 1
    return cast[int64](out)


def is_ext_path(name: Ptr[char]) -> int32:
    # /ext/ prefix check, same shape as is_fat_path.
    #
    # M16.x: also the lazy trigger point for ext4_mkfs_self_test().
    # block_smoke_test() in init/main.ad runs BEFORE ahci_smoke_test
    # registers sd0p1, so calling the self-test from ext4_init's tail
    # fires too early. is_ext_path runs on every VFS open from
    # userspace — by then ahci_smoke_test has long finished and
    # sd0p1 is live. The one-shot gate inside _ext4_mkfs_self_test_maybe
    # keeps subsequent VFS opens cheap (one global compare + branch).
    _ext4_mkfs_self_test_maybe()
    prefix: Ptr[uint8] = "/ext/"
    i: int32 = 0
    while True:
        p: int32 = prefix[i]
        if p == 0:
            return 1
        n: int32 = name[i]
        if n != p:
            return 0
        i = i + 1


def strip_ext_prefix(name: Ptr[char]) -> Ptr[char]:
    # "/ext/" is 5 chars.
    return cast[Ptr[char]](cast[uint64](name) + 5)


def ext4_dir_dump(dir_inode_buf: Ptr[uint8]):
    # Read the directory's first data block and print each entry's
    # name. Only handles single-block dirs for now (no FAT-chain
    # walk across multiple extents).
    blk: uint64 = ext4_inode_first_extent_block(dir_inode_buf)
    if blk == 0:
        printk0("ext4: empty/index directory (M16.54)\n")
        return
    if _ext4_read_block(blk, &ext4_blk_buf[0]) != 0:
        printk0("ext4: dir block read failed\n")
        return
    pos: uint64 = 0
    while pos + DIR_ENTRY_HDR_BYTES <= ext4_block_size:
        e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
        inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
        rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
        if rec_len == 0:
            return                              # malformed
        if inum != 0:
            name_len: uint8 = cast[Ptr[uint8]](e + 6)[0]
            printk1("  dirent inode=%d name='", cast[uint64](inum))
            i: uint64 = 0
            while i < cast[uint64](name_len):
                printk1("%c",
                        cast[uint64](cast[Ptr[uint8]](e + 8 + i)[0]))
                i = i + 1
            printk0("'\n")
        pos = pos + cast[uint64](rec_len)


# --- block bitmap (M16.61) ----------------------------------------
#
# Each block group has a one-block bitmap with one bit per data block
# in the group. Bit set = block is allocated; bit clear = block is
# free. Layout (low bit first within each byte — matches Linux):
#
#     byte 0: bits for blocks N+0..N+7   (low bit = N+0)
#     byte 1: bits for blocks N+8..N+15
#     ...
#
# where N is the group's first data block. Group 0's bitmap typically
# lives at the block named in the group descriptor's
# bg_block_bitmap_lo field (offset 0). For 64BIT ext4, bg_block_bitmap
# is split lo/hi at offsets 0 and 0x20, but our 1 MiB test image stays
# 32-bit so the hi half is unused.
#
# Scratch buffer for one bitmap block. Separate from ext4_blk_buf
# because alloc callers want to keep their dir/extent buffer intact
# while we mutate the bitmap.

ext4_bitmap_buf: Array[4096, uint8]


def _ext4_group_desc_field_u32(grp: uint64, field_off: uint64) -> uint32:
    # Read a u32 field at byte offset `field_off` within group `grp`'s
    # descriptor. Returns 0 on read failure (caller checks against
    # known-nonzero fields like bg_block_bitmap).
    desc_byte_off: uint64 = grp * ext4_desc_size
    gdt_block:     uint64 = ext4_gdt_block + desc_byte_off / ext4_block_size
    within:        uint64 = desc_byte_off % ext4_block_size
    if _ext4_read_block(gdt_block, &ext4_blk_buf[0]) != 0:
        return 0
    return _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0]) + within + field_off))


def ext4_alloc_block() -> uint64:
    # Find a free data block in group 0, mark it allocated, write the
    # bitmap back. Returns the absolute filesystem block number, or
    # 0 on failure (out-of-space or I/O error).
    #
    # M16.61 only searches group 0 — multi-group allocation is the
    # natural follow-up. For our 1 MiB / 8192-blocks-per-group test
    # image this is a non-issue; real-world ext4 would loop groups.
    if ext4_blockdev_slot < 0:
        return 0
    bm_block: uint32 = _ext4_group_desc_field_u32(0, 0)        # bg_block_bitmap_lo
    if bm_block == 0:
        printk0("ext4: bg_block_bitmap_lo is zero\n")
        return 0
    if _ext4_read_block(cast[uint64](bm_block), &ext4_bitmap_buf[0]) != 0:
        return 0
    # Scan for the first 0 bit. Group 0's bitmap covers blocks
    # 0..blocks_per_group-1 of the filesystem, but the first
    # ~few-dozen blocks are sb+gdt+bitmaps+inode_table and are
    # already marked allocated by mkfs. We just take the first free
    # bit we find.
    byte_idx: uint64 = 0
    nbytes: uint64 = ext4_block_size
    if nbytes > ext4_blocks_per_grp / 8:
        nbytes = ext4_blocks_per_grp / 8
    while byte_idx < nbytes:
        b: uint8 = ext4_bitmap_buf[byte_idx]
        if b != 0xFF:
            bit_idx: uint64 = 0
            while bit_idx < 8:
                mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
                if (b & mask) == 0:
                    # Mark allocated.
                    ext4_bitmap_buf[byte_idx] = b | mask
                    if _ext4_write_block(cast[uint64](bm_block),
                                         &ext4_bitmap_buf[0]) != 0:
                        printk0("ext4: bitmap write failed\n")
                        return 0
                    # Group 0's blocks start at s_first_data_block;
                    # bit 0 of the bitmap is block s_first_data_block.
                    return ext4_first_data_blk \
                         + byte_idx * 8 + bit_idx
                bit_idx = bit_idx + 1
        byte_idx = byte_idx + 1
    printk0("ext4: no free block in group 0\n")
    return 0


def ext4_free_block(block_nr: uint64) -> int32:
    # Clear the bitmap bit for `block_nr` and write the bitmap back.
    # Returns 0 on success, -1 on out-of-range / I/O failure. Like
    # alloc, M16.61 only handles group 0; cross-group free is the
    # symmetric follow-up.
    if ext4_blockdev_slot < 0:
        return -1
    if block_nr < ext4_first_data_blk:
        return -1
    rel: uint64 = block_nr - ext4_first_data_blk
    if rel >= ext4_blocks_per_grp:
        printk0("ext4: free_block: block not in group 0\n")
        return -1
    bm_block: uint32 = _ext4_group_desc_field_u32(0, 0)
    if bm_block == 0:
        return -1
    if _ext4_read_block(cast[uint64](bm_block), &ext4_bitmap_buf[0]) != 0:
        return -1
    byte_idx: uint64 = rel / 8
    bit_idx:  uint64 = rel % 8
    mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
    ext4_bitmap_buf[byte_idx] = ext4_bitmap_buf[byte_idx] & (~mask)
    return _ext4_write_block(cast[uint64](bm_block),
                             &ext4_bitmap_buf[0])


def ext4_bitmap_smoke_test() -> int32:
    # Exercise the block allocator: alloc → re-alloc → free both.
    # Verifies that
    #   (a) allocations succeed and return distinct blocks
    #   (b) the bitmap actually mutates on disk (re-alloc would
    #       return the same block if the write didn't stick)
    #   (c) free clears the bit (next alloc-after-free returns
    #       one of the freed blocks)
    # Returns 0 on PASS, -1 on FAIL. Caller prints the marker.
    a: uint64 = ext4_alloc_block()
    if a == 0:
        printk0("ext4: bitmap smoke FAIL (first alloc)\n")
        return -1
    b: uint64 = ext4_alloc_block()
    if b == 0 or b == a:
        printk0("ext4: bitmap smoke FAIL (second alloc returned same/zero)\n")
        ext4_free_block(a)
        return -1
    # Free the two blocks. Then allocate again — we should get one
    # of the freed blocks back (allocator is first-fit so it picks
    # the lower-numbered one).
    if ext4_free_block(a) != 0:
        printk0("ext4: bitmap smoke FAIL (free a)\n")
        ext4_free_block(b)
        return -1
    if ext4_free_block(b) != 0:
        printk0("ext4: bitmap smoke FAIL (free b)\n")
        return -1
    c: uint64 = ext4_alloc_block()
    if c != a:
        printk1("ext4: bitmap smoke FAIL (post-free alloc returned %d)\n", c)
        if c != 0:
            ext4_free_block(c)
        return -1
    # Clean up the round-trip so we leave the FS as we found it.
    ext4_free_block(c)
    # M16.62: round-trip an inode alloc/free.
    ia: uint32 = ext4_alloc_inode()
    if ia == 0:
        printk0("ext4: bitmap smoke FAIL (inode alloc)\n")
        return -1
    ib: uint32 = ext4_alloc_inode()
    if ib == 0 or ib == ia:
        printk0("ext4: bitmap smoke FAIL (inode realloc)\n")
        ext4_free_inode(ia)
        return -1
    if ext4_free_inode(ia) != 0 or ext4_free_inode(ib) != 0:
        printk0("ext4: bitmap smoke FAIL (inode free)\n")
        return -1
    printk2("ext4: bitmap smoke PASS (blk=%d ino=%d)\n",
            a, cast[uint64](ia))
    return 0


# --- inode bitmap (M16.62) ----------------------------------------
#
# Same shape as the block bitmap but indexes inodes within the group.
# At group descriptor offset 4 (bg_inode_bitmap_lo). Bit N (0-based)
# corresponds to inode (group * inodes_per_grp + N + 1) — note the +1
# because ext4 inodes are 1-indexed.
#
# Reserved inodes (typically 1..s_first_ino-1, with s_first_ino == 11
# in modern mkfs.ext4) are already marked allocated by mkfs, so a
# first-fit search just skips them naturally. No special-case needed.

def ext4_alloc_inode() -> uint32:
    # Find a free inode in group 0, mark it allocated, write the
    # bitmap back. Returns the absolute inode number (1-based), or
    # 0 on failure.
    if ext4_blockdev_slot < 0:
        return 0
    bm_block: uint32 = _ext4_group_desc_field_u32(0, 4)        # bg_inode_bitmap_lo
    if bm_block == 0:
        printk0("ext4: bg_inode_bitmap_lo is zero\n")
        return 0
    if _ext4_read_block(cast[uint64](bm_block), &ext4_bitmap_buf[0]) != 0:
        return 0
    nbytes: uint64 = ext4_block_size
    if nbytes > ext4_inodes_per_grp / 8:
        nbytes = ext4_inodes_per_grp / 8
    byte_idx: uint64 = 0
    while byte_idx < nbytes:
        b: uint8 = ext4_bitmap_buf[byte_idx]
        if b != 0xFF:
            bit_idx: uint64 = 0
            while bit_idx < 8:
                mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
                if (b & mask) == 0:
                    ext4_bitmap_buf[byte_idx] = b | mask
                    if _ext4_write_block(cast[uint64](bm_block),
                                         &ext4_bitmap_buf[0]) != 0:
                        printk0("ext4: inode bitmap write failed\n")
                        return 0
                    # bit (byte*8 + bit) → inode (group*ipg + bit + 1)
                    return cast[uint32](byte_idx * 8 + bit_idx + 1)
                bit_idx = bit_idx + 1
        byte_idx = byte_idx + 1
    printk0("ext4: no free inode in group 0\n")
    return 0


def ext4_free_inode(inum: uint32) -> int32:
    # Clear the inode bitmap bit for `inum`. Refuses cross-group inums
    # for the same reason ext4_free_block does (group-0 scope until a
    # follow-up adds multi-group walks).
    if ext4_blockdev_slot < 0:
        return -1
    if inum == 0:
        return -1
    iu: uint64 = cast[uint64](inum)
    if iu > ext4_inodes_per_grp:
        printk0("ext4: free_inode: inode not in group 0\n")
        return -1
    bm_block: uint32 = _ext4_group_desc_field_u32(0, 4)
    if bm_block == 0:
        return -1
    if _ext4_read_block(cast[uint64](bm_block), &ext4_bitmap_buf[0]) != 0:
        return -1
    rel: uint64 = iu - 1                                # bit index within group
    byte_idx: uint64 = rel / 8
    bit_idx:  uint64 = rel % 8
    mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
    ext4_bitmap_buf[byte_idx] = ext4_bitmap_buf[byte_idx] & (~mask)
    return _ext4_write_block(cast[uint64](bm_block),
                             &ext4_bitmap_buf[0])


# --- inode write + file create (M16.63) ---------------------------
#
# ext4_write_inode is the symmetric counterpart of ext4_read_inode:
# locate the on-disk inode bytes via the same group / table / index
# math, then write inode_size bytes at that offset. Implemented as a
# read-modify-write on the 2 sectors that cover the inode — the
# inode (128 or 256 bytes) is always sector-aligned within the table
# but may straddle sector boundaries.

def ext4_write_inode(inum: uint64, src: Ptr[uint8]) -> int32:
    if inum == 0 or inum > ext4_inodes_count:
        return -1
    grp:    uint64 = (inum - 1) / ext4_inodes_per_grp
    idx:    uint64 = (inum - 1) % ext4_inodes_per_grp
    inode_table_block: uint64 = cast[uint64](
        _ext4_group_desc_field_u32(grp, 8))
    if inode_table_block == 0:
        return -1
    inode_byte: uint64 = inode_table_block * ext4_block_size \
                       + idx * ext4_inode_size
    sec_lba:   uint64 = inode_byte / SECTOR_SIZE
    sec_off:   uint64 = inode_byte % SECTOR_SIZE
    # Read 2 sectors → RMW → write 2 sectors. ext4_blk_buf is the
    # natural scratch (1024 bytes, fits 2 sectors).
    if blk_read_sectors(ext4_blockdev_slot, sec_lba, 2,
                        &ext4_blk_buf[0]) != 0:
        return -1
    dst: uint64 = cast[uint64](&ext4_blk_buf[0]) + sec_off
    memcpy(cast[Ptr[uint8]](dst), src, ext4_inode_size)
    return blk_write_sectors(ext4_blockdev_slot, sec_lba, 2,
                             &ext4_blk_buf[0])


def _ext4_write_u16(p: Ptr[uint8], v: uint16):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)


def _ext4_write_u32(p: Ptr[uint8], v: uint32):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)
    p[2] = cast[uint8]((v >> 16) & 0xFF)
    p[3] = cast[uint8]((v >> 24) & 0xFF)


# In-memory builder scratch for a fresh inode (sized for the
# largest inode_size we'd see: 256 bytes).
ext4_new_inode_buf: Array[256, uint8]


# --- per-inode mtime (M16.x §12.3) --------------------------------
#
# ext4 stores three 32-bit Unix timestamps in the inode:
#
#   0x08  i_atime   last access
#   0x0C  i_ctime   last status change (inode metadata)
#   0x10  i_mtime   last data modification
#
# (256-byte inodes also carry *_extra nanosecond/epoch-high words at
# 0x84/0x88/0x8C, but a plain seconds timestamp at the lo offsets is
# what `stat` and make's timestamp logic read first — Linux fills the
# extra words only when the inode is large enough AND the feature is
# on. We keep it to the lo words, which every ext2/3/4 reader honours.)
#
# A freshly-mkfs'd inode has all three at 0; we stamp them with the
# RTC epoch on create and refresh i_mtime + i_ctime on every write or
# truncate so `stat` reports a real, monotonically-advancing mtime and
# make-style "is the target newer than the source" logic works.

INODE_I_ATIME_OFFSET: uint64 = 0x08
INODE_I_CTIME_OFFSET: uint64 = 0x0C
INODE_I_MTIME_OFFSET: uint64 = 0x10


def _ext4_now_epoch() -> uint32:
    # Wall-clock seconds for a timestamp stamp. The RTC is the source
    # of truth; if it's unreadable we fall back to 0 (the mkfs default)
    # rather than inventing a bogus time.
    t: int64 = rtc_read_unix_time()
    if t < 0:
        return 0
    return cast[uint32](t)


def ext4_inode_mtime(buf: Ptr[uint8]) -> uint32:
    # struct ext4_inode.i_mtime — Unix epoch seconds. Exposed so the
    # VFS stat path can report a real mtime instead of a jiffies guess.
    return _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](buf) + INODE_I_MTIME_OFFSET))


def _ext4_stamp_mtime(inode_buf: Ptr[uint8]):
    # Refresh i_mtime + i_ctime in an in-memory inode buffer. ctime
    # tracks any inode-metadata change, so a data write (which bumps
    # i_size / extents) bumps ctime too — matches Linux's
    # ext4_current_time() use in ext4_write_end / ext4_setattr.
    now: uint32 = _ext4_now_epoch()
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_MTIME_OFFSET),
        now)
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_CTIME_OFFSET),
        now)


def _ext4_stamp_all_times(inode_buf: Ptr[uint8]):
    # Stamp atime + ctime + mtime — used at create time so a fresh
    # inode carries a coherent timestamp triple instead of epoch 0.
    now: uint32 = _ext4_now_epoch()
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_ATIME_OFFSET),
        now)
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_CTIME_OFFSET),
        now)
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_MTIME_OFFSET),
        now)


def _ext4_zero(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        p[i] = 0
        i = i + 1


def _ext4_init_regular_inode(data_blk: uint64, size: uint64):
    # Populate ext4_new_inode_buf with a minimal valid regular-file
    # inode: mode 0664 + IFREG (0x81B4), one extent pointing at
    # `data_blk`, i_size_lo = `size`, EXTENTS flag set.
    p: Ptr[uint8] = &ext4_new_inode_buf[0]
    _ext4_zero(p, ext4_inode_size)
    _ext4_write_u16(p, 0x81B4)                      # i_mode
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4),
                    cast[uint32](size))             # i_size_lo
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26),
                    1)                              # i_links_count
    # i_blocks_lo is in 512-byte units regardless of fs block size.
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28),
                    cast[uint32](sectors_per_block))
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32),
                    0x80000)                        # i_flags = EXT4_EXTENTS_FL
    # i_block (60 bytes at +0x28): extent header + one extent.
    eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)    # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)    # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)    # eh_depth (leaf)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)    # eh_generation
    # Single extent: ee_block=0, ee_len=1, hi=0, lo=data_blk.
    _ext4_write_u32(cast[Ptr[uint8]](eh + 12), 0)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 16), 1)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 18), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 20),
                    cast[uint32](data_blk))
    # Stamp atime/ctime/mtime with the wall clock so a freshly-created
    # file reports a real mtime through stat (M16.x §12.3).
    _ext4_stamp_all_times(p)


def _ext4_strlen(name: Ptr[char]) -> uint64:
    n: uint64 = 0
    while name[n] != 0:
        n = n + 1
    return n


def _ext4_dirent_padded_size(name_len: uint64) -> uint64:
    # ext4 dirent rec_len is always a multiple of 4. Header is 8
    # bytes; pad (8 + name_len) up to the next 4-byte boundary.
    raw: uint64 = 8 + name_len
    return (raw + 3) & ~cast[uint64](3)


def ext4_dir_insert(parent_inum: uint64, name: Ptr[char],
                    child_inum: uint32, file_type: uint8) -> int32:
    # Append a dirent for (name, child_inum) to the LAST block of
    # parent_inum's directory. Splits the existing last entry's
    # padding to make room. M16.63 does NOT grow the directory by
    # allocating a new block — if the last block has no slack, this
    # fails with -1.
    if parent_inum == 0:
        return -1
    name_len: uint64 = _ext4_strlen(name)
    if name_len == 0 or name_len > 255:
        return -1
    needed: uint64 = _ext4_dirent_padded_size(name_len)

    parent_inode: Array[256, uint8]
    if ext4_read_inode(parent_inum, &parent_inode[0]) != 0:
        return -1
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&parent_inode[0]))
    if dir_size == 0:
        return -1
    last_lb: uint64 = dir_size / ext4_block_size - 1
    phys: uint64 = _ext4_logical_to_physical(&parent_inode[0], last_lb)
    if phys == 0:
        return -1
    if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
        return -1

    # Walk every entry looking for an insertion slot. Two slot
    # shapes accept a new entry (Linux's ext4_add_entry uses the
    # same rule):
    #
    #   (1) An entry with inum == 0 (tombstone) whose rec_len is
    #       big enough for our padded footprint — overwrite in
    #       place, keep its rec_len.
    #   (2) A live entry whose declared rec_len is at least its
    #       own true (padded) size + our `needed` — split: shrink
    #       this entry to its true size, append our new entry in
    #       the freed tail.
    #
    # The terminal entry of a dir block typically carries large
    # excess rec_len from the last split — that's the natural
    # insertion point as the dir grows. Walking ALL entries (not
    # just the last) also handles the common tombstone-after-the-
    # last-real-entry layout debugfs/mkfs leaves behind.
    pos: uint64 = 0
    while pos < ext4_block_size:
        e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
        e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
        e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
        if e_rec_len == 0:
            return -1                              # malformed
        if e_inum == 0:
            if cast[uint64](e_rec_len) >= needed:
                # Reuse this tombstone in place — keep its rec_len.
                _ext4_write_u32(cast[Ptr[uint8]](e + 0), child_inum)
                cast[Ptr[uint8]](e + 6)[0] = cast[uint8](name_len)
                cast[Ptr[uint8]](e + 7)[0] = file_type
                i: uint64 = 0
                while i < name_len:
                    cast[Ptr[uint8]](e + 8 + i)[0] = cast[uint8](name[i])
                    i = i + 1
                # Zero the name's trailing pad.
                pp: uint64 = 8 + name_len
                while pp < cast[uint64](e_rec_len):
                    cast[Ptr[uint8]](e + pp)[0] = 0
                    pp = pp + 1
                return _ext4_write_block(phys, &ext4_blk_buf[0])
        else:
            e_name_len: uint8 = cast[Ptr[uint8]](e + 6)[0]
            true_e: uint64 = _ext4_dirent_padded_size(
                cast[uint64](e_name_len))
            if cast[uint64](e_rec_len) >= true_e + needed:
                # Split: shrink to true size, append new in the tail.
                new_rec_len: uint64 = cast[uint64](e_rec_len) - true_e
                _ext4_write_u16(cast[Ptr[uint8]](e + 4),
                                cast[uint16](true_e))
                new_off: uint64 = pos + true_e
                new_e: uint64 = cast[uint64](&ext4_blk_buf[0]) + new_off
                _ext4_write_u32(cast[Ptr[uint8]](new_e + 0), child_inum)
                _ext4_write_u16(cast[Ptr[uint8]](new_e + 4),
                                cast[uint16](new_rec_len))
                cast[Ptr[uint8]](new_e + 6)[0] = cast[uint8](name_len)
                cast[Ptr[uint8]](new_e + 7)[0] = file_type
                i: uint64 = 0
                while i < name_len:
                    cast[Ptr[uint8]](new_e + 8 + i)[0] = cast[uint8](name[i])
                    i = i + 1
                pp: uint64 = 8 + name_len
                while pp < new_rec_len:
                    cast[Ptr[uint8]](new_e + pp)[0] = 0
                    pp = pp + 1
                return _ext4_write_block(phys, &ext4_blk_buf[0])
        pos = pos + cast[uint64](e_rec_len)
    printk0("ext4: dir block full (no slack for insert)\n")
    return -1


def ext4_create_file(parent_inum: uint64, name: Ptr[char],
                     body: Ptr[uint8], body_len: uint64) -> uint32:
    # Top-level orchestration: alloc inode + alloc block, write the
    # body into the block, build a fresh inode pointing at it, write
    # the inode into the inode table, and splice a dirent into the
    # parent. Returns the new inum on success, 0 on failure (with
    # best-effort rollback of any partial allocs).
    if body_len > ext4_block_size:
        printk0("ext4: create_file: body > one block (M16.63 scope)\n")
        return 0
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        printk0("ext4: create_file FAIL (alloc_inode)\n")
        return 0
    new_blk: uint64 = ext4_alloc_block()
    if new_blk == 0:
        printk0("ext4: create_file FAIL (alloc_block)\n")
        ext4_free_inode(new_inum)
        return 0

    # Write body into the new data block. Zero-pad the rest so we
    # don't expose previous tenants' data.
    _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
    if body_len > 0:
        memcpy(&ext4_blk_buf[0], body, body_len)
    if _ext4_write_block(new_blk, &ext4_blk_buf[0]) != 0:
        printk0("ext4: create_file FAIL (write data)\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0

    _ext4_init_regular_inode(new_blk, body_len)
    if ext4_write_inode(cast[uint64](new_inum),
                        &ext4_new_inode_buf[0]) != 0:
        printk0("ext4: create_file FAIL (write inode)\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0

    # 1 = EXT4_FT_REG_FILE in linux/ext4.h
    if ext4_dir_insert(parent_inum, name, new_inum, 1) != 0:
        printk0("ext4: create_file FAIL (dir_insert)\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0
    return new_inum


def ext4_create_smoke_test() -> int32:
    # End-to-end: create /ext/SMOKE.TXT with a known body, then verify
    # the read path delivers the same bytes. Tests inode write, block
    # write, dirent insert, AND the existing read path against the
    # newly-created file. On PASS leaves SMOKE.TXT in the FS (we don't
    # have an unlink yet); on FAIL prints a marker and returns -1.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "CREATE_OK ext4 file-create round-trip works\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    inum: uint32 = ext4_create_file(2, "SMOKE.TXT", body, blen)
    if inum == 0:
        printk0("ext4: create smoke FAIL (create_file returned 0)\n")
        return -1
    # Read it back via the standard path.
    resolved_inum: uint32 = 0
    resolved_size: uint64 = 0
    if ext4_resolve_file("SMOKE.TXT", &resolved_inum,
                         &resolved_size) == 0:
        printk0("ext4: create smoke FAIL (resolve missed)\n")
        return -1
    if resolved_inum != inum:
        printk2("ext4: create smoke FAIL (resolved %d != created %d)\n",
                cast[uint64](resolved_inum), cast[uint64](inum))
        return -1
    if resolved_size != blen:
        printk0("ext4: create smoke FAIL (size mismatch)\n")
        return -1
    rb: Array[64, uint8]
    n: int64 = ext4_read_file(inum, 0, blen, &rb[0])
    if n != cast[int64](blen):
        printk0("ext4: create smoke FAIL (read short)\n")
        return -1
    i: uint64 = 0
    while i < blen:
        if rb[i] != body[i]:
            printk1("ext4: create smoke FAIL (byte %d mismatch)\n", i)
            return -1
        i = i + 1
    printk2("ext4: create smoke PASS (inum=%d size=%d)\n",
            cast[uint64](inum), blen)
    return 0


# --- ext4 write (M16.64) ------------------------------------------
#
# Write-mode opens. Backed by the same ext4_open_files slot table as
# reads, plus a per-slot "write" flag so vfs_write knows whether to
# RMW the data block or refuse. M16.64 is single-block scope: files
# created via vfs_open_write are capped at ext4_block_size bytes
# (1 KiB on our image). Larger writes will need extent extension —
# the natural follow-up.
#
# Semantics on open:
#   * if the file already exists, free its inode + data block and
#     re-create empty (matches O_CREAT | O_TRUNC, which is what
#     hamsh's `> file` wants)
#   * if not, allocate inode + block, write an empty inode, splice
#     a dirent into the parent
# Open returns a slot index; vfs_write does the RMW; close flushes
# the final inode i_size via a re-write (it's already up-to-date
# because we update i_size on each write — close is just close).

def _ext4_dir_unlink_in_root(name: Ptr[char]) -> uint32:
    # Find `name` in root dir, mark its dirent inum=0 (tombstone),
    # write the block back. Returns the previous inum on hit, 0 on
    # miss. We don't extend the previous entry's rec_len to absorb
    # the tombstone — leaving the tombstone slot lets a future
    # M16.64 create reuse it directly via the tombstone path in
    # ext4_dir_insert.
    root_inode: Array[256, uint8]
    if ext4_read_inode(2, &root_inode[0]) != 0:
        return 0
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&root_inode[0]))
    if dir_size == 0:
        return 0
    nblocks: uint64 = dir_size / ext4_block_size
    nlen: uint64 = _ext4_strlen(name)
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&root_inode[0], lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(
                cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    _ext4_write_u32(cast[Ptr[uint8]](e + 0), 0)
                    _ext4_write_block(phys, &ext4_blk_buf[0])
                    return e_inum
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 0


def ext4_open_create_or_trunc(name: Ptr[char]) -> int32:
    # O_CREAT|O_TRUNC: nuke any existing entry, create fresh-empty,
    # open it as a write-capable slot. M16.64 scope: root dir only,
    # single block per file. Caller is vfs_open_write for /ext paths.
    if ext4_blockdev_slot < 0:
        return -1
    # Unlink old (best-effort — also frees its inode + first block).
    old_inum: uint32 = _ext4_dir_unlink_in_root(name)
    if old_inum != 0:
        ext4_free_inode(old_inum)
        # We don't free old blocks — would require walking the
        # extent tree. For M16.64 this is a small leak per
        # overwrite; tightened up in a follow-up.
    # Fresh-empty create.
    empty: Array[1, uint8]
    new_inum: uint32 = ext4_create_file(2, name, &empty[0], 0)
    if new_inum == 0:
        return -1
    # Open it for I/O via the existing read-path slot table.
    # ext4_open does a full path resolve, so it picks up the new
    # dirent we just spliced into root.
    return ext4_open(name)


def ext4_write_open_file(slot: int32, src: Ptr[uint8],
                         pos: uint64, count: uint64) -> int64:
    # RMW the file's first data block at `pos`, bounded by the
    # block size (M16.64 single-block scope). Updates the on-disk
    # inode's i_size_lo if the write extends the file.
    if slot < 0:
        return -1
    if pos >= ext4_block_size:
        return 0                                # past single-block cap
    take: uint64 = count
    if pos + take > ext4_block_size:
        take = ext4_block_size - pos
    inum: uint32 = ext4_open_inum(slot)
    if inum == 0:
        return -1
    # Read the inode to find the data block, and to update size.
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    phys: uint64 = _ext4_logical_to_physical(&inode[0], 0)
    if phys == 0:
        return -1
    # Read-modify-write the data block.
    if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
        return -1
    memcpy(cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0]) + pos),
           src, take)
    if _ext4_write_block(phys, &ext4_blk_buf[0]) != 0:
        return -1
    # Extend i_size if needed, and always refresh mtime: a write
    # mutates the data even when it doesn't grow the file, so stat
    # must see a fresh mtime regardless (M16.x §12.3).
    cur_size: uint32 = ext4_inode_size_lo(&inode[0])
    new_end:  uint64 = pos + take
    if new_end > cast[uint64](cur_size):
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                        cast[uint32](new_end))
        # Update the cached size in the open-file slot so the
        # ext4_open_size() helper stays accurate for read-back.
        ext4_open_files[cast[uint64](slot)].file_size = new_end
    _ext4_stamp_mtime(&inode[0])
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    return cast[int64](take)


# --- ext4 unlink (M16.67) -----------------------------------------
#
# Delete a regular file from the root directory. Frees the inode,
# frees its first data block (extent walks past one block aren't
# yet wired — file extension is the same TODO), and tombstones its
# dirent. Linux's ext4_unlink does this under the journal; we
# don't have a journal, so the writes go straight to disk in the
# same order Linux's no-journal path (`ext4_journal_get_write_access`
# is a no-op without has_journal) commits them.

def ext4_unlink(name: Ptr[char]) -> int32:
    if ext4_blockdev_slot < 0:
        return -1
    # First locate the inode WITHOUT modifying the dirent yet —
    # we need the inum so we can read the inode and find its data
    # block before we lose the pointer.
    target_inum: uint32 = 0
    nlen: uint64 = _ext4_strlen(name)
    root_inode: Array[256, uint8]
    if ext4_read_inode(2, &root_inode[0]) != 0:
        return -1
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&root_inode[0]))
    if dir_size == 0:
        return -2                                  # -ENOENT
    nblocks: uint64 = dir_size / ext4_block_size
    target_phys: uint64 = 0
    target_pos:  uint64 = 0
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&root_inode[0], lb)
        if phys == 0:
            return -2
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    target_inum = e_inum
                    target_phys = phys
                    target_pos  = pos
                    break
            pos = pos + cast[uint64](e_rec_len)
        if target_inum != 0:
            break
        lb = lb + 1
    if target_inum == 0:
        return -2                                  # -ENOENT

    # Read the file's inode to find its first data block, then free
    # that block. Multi-extent / index-tree files would need a full
    # extent walk + free; M16.67 scope is single-block files (matches
    # the M16.64 create + write cap).
    finode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](target_inum), &finode[0]) == 0:
        phys_data: uint64 = _ext4_logical_to_physical(&finode[0], 0)
        if phys_data != 0:
            ext4_free_block(phys_data)
    # Free the inode regardless — even if the block free failed,
    # we want the inode slot reclaimed.
    ext4_free_inode(target_inum)

    # Tombstone the dirent. We don't coalesce with the previous
    # entry's rec_len — leaving the slot in-place lets a future
    # create reuse it via ext4_dir_insert's tombstone path.
    # Re-read the block (the inode-related reads above may have
    # trampled ext4_blk_buf via ext4_read_inode).
    if _ext4_read_block(target_phys, &ext4_blk_buf[0]) != 0:
        return -1
    _ext4_write_u32(cast[Ptr[uint8]](
        cast[uint64](&ext4_blk_buf[0]) + target_pos + 0), 0)
    return _ext4_write_block(target_phys, &ext4_blk_buf[0])


# --- truncate / ftruncate (M16.x §12.2) ---------------------------
#
# Resize a regular file to an arbitrary byte length, freeing or
# allocating blocks as needed and updating i_size. Scope: files whose
# extents fit inline in the inode's i_block window (depth-0 leaf,
# eh_max 4) — that covers everything our create/write path produces
# and any small file on a real ext4 volume. A file deep enough to
# need an index node (eh_depth > 0) is rejected with -1; growing such
# a file would need to split the extent tree, which is a documented
# follow-up.
#
# Linux's ext4_truncate() does the same two jobs: ext4_ext_remove_space
# for a shrink, and (on grow) leaves the tail sparse / zero-fills the
# partial block. We mirror that: shrink frees the now-unreachable
# blocks and trims/drops leaf extents; grow appends extents (each one
# block) and zero-fills, so a read of the grown region returns zeros.

EXT4_EH_DEPTH_OFFSET:   uint64 = 6
EXT4_EH_ENTRIES_OFFSET: uint64 = 2


def _ext4_leaf_entries(inode_buf: Ptr[uint8]) -> int32:
    # Number of extents in the inode's inline leaf. Returns -1 if the
    # inode is not a depth-0 extents inode (bad magic, or an index
    # node we don't rewrite).
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return -1
    depth: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_DEPTH_OFFSET))
    if depth != 0:
        return -1
    return cast[int32](_ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET)))


def _ext4_inode_block_count(inode_buf: Ptr[uint8]) -> uint64:
    # Total logical blocks covered by the inline leaf extents — i.e.
    # how many blocks of file data are currently allocated. Returns 0
    # for an empty or non-leaf inode.
    n: int32 = _ext4_leaf_entries(inode_buf)
    if n < 0:
        return 0
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    total: uint64 = 0
    i: int32 = 0
    while i < n:
        ee: uint64 = eh + 12 + cast[uint64](i) * 12
        ee_block: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 0))
        ee_len:   uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 4))
        end: uint64 = cast[uint64](ee_block) + cast[uint64](ee_len)
        if end > total:
            total = end
        i = i + 1
    return total


def _ext4_extent_append_block(inode_buf: Ptr[uint8],
                              logical_blk: uint64,
                              phys_blk: uint64) -> int32:
    # Append a one-block extent (ee_block=logical_blk, ee_len=1) to the
    # inode's inline leaf. If the new logical block is contiguous with
    # the last extent's physical run, the last extent is simply
    # lengthened instead of consuming a new slot (the same coalescing
    # ext4_ext_try_to_merge does). Returns 0 on success, -1 if the
    # leaf is full (eh_entries == eh_max) and no merge was possible.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return -1
    depth: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_DEPTH_OFFSET))
    if depth != 0:
        return -1
    entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    eh_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if entries > 0:
        # Try to extend the last extent if the new block continues it.
        last: uint64 = eh + 12 + cast[uint64](entries - 1) * 12
        l_block:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](last + 0))
        l_len:      uint16 = _ext4_read_u16(cast[Ptr[uint8]](last + 4))
        l_start_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](last + 6))
        l_start_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](last + 8))
        l_phys: uint64 = (cast[uint64](l_start_hi) << 32) \
                       | cast[uint64](l_start_lo)
        l_logend:  uint64 = cast[uint64](l_block) + cast[uint64](l_len)
        l_physend: uint64 = l_phys + cast[uint64](l_len)
        if l_logend == logical_blk and l_physend == phys_blk \
                and l_len < 32768:
            _ext4_write_u16(cast[Ptr[uint8]](last + 4),
                            cast[uint16](l_len + 1))
            return 0
    if entries >= eh_max:
        printk0("ext4: extent leaf full (truncate-grow needs index)\n")
        return -1
    ne: uint64 = eh + 12 + cast[uint64](entries) * 12
    _ext4_write_u32(cast[Ptr[uint8]](ne + 0),
                    cast[uint32](logical_blk))
    _ext4_write_u16(cast[Ptr[uint8]](ne + 4), 1)
    _ext4_write_u16(cast[Ptr[uint8]](ne + 6),
                    cast[uint16]((phys_blk >> 32) & 0xFFFF))
    _ext4_write_u32(cast[Ptr[uint8]](ne + 8),
                    cast[uint32](phys_blk & 0xFFFFFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](entries + 1))
    return 0


def _ext4_extent_trim_to(inode_buf: Ptr[uint8],
                         keep_blocks: uint64) -> int32:
    # Drop file data past logical block `keep_blocks`: free every
    # physical block at logical index >= keep_blocks and rewrite the
    # leaf so only the first `keep_blocks` logical blocks survive. An
    # extent that straddles the cut is split (its ee_len shrunk);
    # extents entirely past the cut are dropped and their blocks
    # freed. Returns 0 on success, -1 on a non-leaf inode.
    n: int32 = _ext4_leaf_entries(inode_buf)
    if n < 0:
        return -1
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    surviving: int32 = 0
    i: int32 = 0
    while i < n:
        ee: uint64 = eh + 12 + cast[uint64](i) * 12
        ee_block:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 0))
        ee_len:      uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 4))
        ee_start_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 6))
        ee_start_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 8))
        eb:    uint64 = cast[uint64](ee_block)
        elen:  uint64 = cast[uint64](ee_len)
        ephys: uint64 = (cast[uint64](ee_start_hi) << 32) \
                      | cast[uint64](ee_start_lo)
        if eb >= keep_blocks:
            # Whole extent is past the cut — free every block in it.
            k: uint64 = 0
            while k < elen:
                ext4_free_block(ephys + k)
                k = k + 1
        elif eb + elen > keep_blocks:
            # Extent straddles the cut — keep the head, free the tail.
            keep_len: uint64 = keep_blocks - eb
            j: uint64 = keep_len
            while j < elen:
                ext4_free_block(ephys + j)
                j = j + 1
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            _ext4_write_u32(cast[Ptr[uint8]](sv + 0),
                            cast[uint32](eb))
            _ext4_write_u16(cast[Ptr[uint8]](sv + 4),
                            cast[uint16](keep_len))
            _ext4_write_u16(cast[Ptr[uint8]](sv + 6),
                            cast[uint16]((ephys >> 32) & 0xFFFF))
            _ext4_write_u32(cast[Ptr[uint8]](sv + 8),
                            cast[uint32](ephys & 0xFFFFFFFF))
            surviving = surviving + 1
        else:
            # Extent is entirely before the cut — copy it down to the
            # next surviving slot (compaction; no-op when i == surviving).
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            if sv != ee:
                _ext4_write_u32(cast[Ptr[uint8]](sv + 0), ee_block)
                _ext4_write_u16(cast[Ptr[uint8]](sv + 4), ee_len)
                _ext4_write_u16(cast[Ptr[uint8]](sv + 6), ee_start_hi)
                _ext4_write_u32(cast[Ptr[uint8]](sv + 8), ee_start_lo)
            surviving = surviving + 1
        i = i + 1
    # Zero the dropped slots so a stale extent never gets walked.
    z: int32 = surviving
    while z < n:
        zz: uint64 = eh + 12 + cast[uint64](z) * 12
        _ext4_zero(cast[Ptr[uint8]](zz), 12)
        z = z + 1
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](surviving))
    return 0


def ext4_truncate_inode(inum: uint32, new_len: uint64) -> int32:
    # Resize the file at `inum` to exactly `new_len` bytes. Backs both
    # truncate(2) (path) and ftruncate(2) (fd) — the caller resolves
    # the path / fd to an inum, this does the inode-level work.
    #
    #   shrink: free the blocks past the new length, trim the leaf,
    #           drop i_size. The first block of the surviving region
    #           keeps its bytes; the bytes past new_len within the
    #           last kept block are left as-is on disk but are
    #           unreachable (i_size hides them) — Linux does the same.
    #   grow:   allocate fresh zero-filled blocks for the new tail,
    #           append one-block extents, raise i_size. A read of the
    #           grown region returns zeros (the new blocks are zeroed
    #           before being written out).
    #
    # Returns 0 on success, -1 on I/O error / unsupported inode shape.
    if ext4_blockdev_slot < 0:
        return -1
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    if _ext4_leaf_entries(&inode[0]) < 0:
        printk0("ext4: truncate: inode not a depth-0 extents file\n")
        return -1
    old_len: uint64 = cast[uint64](ext4_inode_size_lo(&inode[0]))
    if new_len == old_len:
        return 0
    old_blocks: uint64 = (old_len + ext4_block_size - 1) \
                       / ext4_block_size
    new_blocks: uint64 = (new_len + ext4_block_size - 1) \
                       / ext4_block_size

    if new_len < old_len:
        # Shrink. Free blocks past new_blocks, trim the leaf.
        if _ext4_extent_trim_to(&inode[0], new_blocks) != 0:
            return -1
        # If the new end falls mid-block, zero the slack inside the
        # last surviving block so a later grow can't resurrect stale
        # bytes (Linux's block_truncate_page).
        tail: uint64 = new_len % ext4_block_size
        if tail != 0 and new_blocks > 0:
            phys: uint64 = _ext4_logical_to_physical(&inode[0],
                                                     new_blocks - 1)
            if phys != 0:
                if _ext4_read_block(phys, &ext4_blk_buf[0]) == 0:
                    _ext4_zero(
                        cast[Ptr[uint8]](
                            cast[uint64](&ext4_blk_buf[0]) + tail),
                        ext4_block_size - tail)
                    if _ext4_write_block(phys,
                                         &ext4_blk_buf[0]) != 0:
                        return -1
    else:
        # Grow. Allocate + zero each new block, append an extent.
        lb: uint64 = old_blocks
        while lb < new_blocks:
            nb: uint64 = ext4_alloc_block()
            if nb == 0:
                printk0("ext4: truncate-grow: out of space\n")
                return -1
            _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
            if _ext4_write_block(nb, &ext4_blk_buf[0]) != 0:
                ext4_free_block(nb)
                return -1
            if _ext4_extent_append_block(&inode[0], lb, nb) != 0:
                ext4_free_block(nb)
                return -1
            lb = lb + 1
        # If old_len ended mid-block, that partial block already
        # carries its old bytes; the grown region beyond old_len in
        # that same block must read as zero. Zero the slack.
        tail: uint64 = old_len % ext4_block_size
        if tail != 0 and old_blocks > 0:
            phys: uint64 = _ext4_logical_to_physical(&inode[0],
                                                     old_blocks - 1)
            if phys != 0:
                if _ext4_read_block(phys, &ext4_blk_buf[0]) == 0:
                    _ext4_zero(
                        cast[Ptr[uint8]](
                            cast[uint64](&ext4_blk_buf[0]) + tail),
                        ext4_block_size - tail)
                    if _ext4_write_block(phys,
                                         &ext4_blk_buf[0]) != 0:
                        return -1

    # Commit the new size + a fresh mtime/ctime.
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                    cast[uint32](new_len))
    _ext4_stamp_mtime(&inode[0])
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    return 0


# --- ext4 rename (M16.x §12.1) ------------------------------------
#
# Move a directory entry from one parent directory to another (or
# rename it within the same directory). Mirrors fs/ext4/namei.c
# ext4_rename at minimum scope:
#
#   1. resolve the source's parent dir + the source dirent (inum,
#      file_type),
#   2. resolve the destination's parent dir,
#   3. if the destination name already exists, unlink it first
#      (overwrite semantics — what rename(2) and `mv` expect),
#   4. insert a dirent for (dest_name -> src_inum) in the dest dir,
#   5. tombstone the source dirent.
#
# The same-directory case (dst parent == src parent) is just a
# special case of the cross-directory path and needs no extra code,
# EXCEPT that we must insert into the new name BEFORE tombstoning the
# old one so the inode is never momentarily unreferenced. We order it
# that way unconditionally.
#
# Scope: regular files in directories reachable from the ext4 root.
# Renaming a directory inode works too (the dirent move is identical)
# but we don't fix up the moved dir's ".." entry — a follow-up. The
# VFS only routes file renames here today.

def _ext4_dir_find_entry(dir_inum: uint64, name: Ptr[char],
                         out_inum: Ptr[uint32],
                         out_ftype: Ptr[uint8]) -> int32:
    # Locate `name` in directory `dir_inum`. On hit, fills out_inum +
    # out_ftype and returns 1; returns 0 on miss, -1 on I/O error.
    if dir_inum == 0:
        return -1
    dir_inode: Array[256, uint8]
    if ext4_read_inode(dir_inum, &dir_inode[0]) != 0:
        return -1
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&dir_inode[0]))
    if dir_size == 0:
        return 0
    nlen: uint64 = _ext4_strlen(name)
    nblocks: uint64 = (dir_size + ext4_block_size - 1) \
                    / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&dir_inode[0], lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    out_inum[0]  = e_inum
                    out_ftype[0] = cast[Ptr[uint8]](e + 7)[0]
                    return 1
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 0


def _ext4_dir_tombstone(dir_inum: uint64, name: Ptr[char]) -> int32:
    # Mark the dirent for `name` in directory `dir_inum` as inum=0.
    # Returns the previous inum on hit, 0 on miss / error. Works on
    # any directory (not just root) — the generalisation of
    # _ext4_dir_unlink_in_root that rename needs.
    if dir_inum == 0:
        return 0
    dir_inode: Array[256, uint8]
    if ext4_read_inode(dir_inum, &dir_inode[0]) != 0:
        return 0
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&dir_inode[0]))
    if dir_size == 0:
        return 0
    nlen: uint64 = _ext4_strlen(name)
    nblocks: uint64 = (dir_size + ext4_block_size - 1) \
                    / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&dir_inode[0], lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    _ext4_write_u32(cast[Ptr[uint8]](e + 0), 0)
                    if _ext4_write_block(phys, &ext4_blk_buf[0]) != 0:
                        return 0
                    return e_inum
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 0


def _ext4_split_dir_path(path: Ptr[char], parent_out: Ptr[uint8],
                         leaf_out: Ptr[uint8]) -> int32:
    # Split a /ext-relative path "SUB/FILE.TXT" into the parent dir
    # path "SUB" (parent_out) and the leaf name "FILE.TXT" (leaf_out).
    # A bare leaf "FILE.TXT" yields parent "" (the ext4 root). Both
    # output buffers are 256 bytes. Returns 0 on success, -1 if the
    # leaf is empty or the path is too long.
    n: uint64 = _ext4_strlen(path)
    if n == 0 or n >= 255:
        return -1
    # Find the last '/'.
    last_slash: int64 = -1
    i: uint64 = 0
    while i < n:
        if path[i] == 47:
            last_slash = cast[int64](i)
        i = i + 1
    if last_slash < 0:
        parent_out[0] = 0
        j: uint64 = 0
        while j <= n:
            leaf_out[j] = cast[uint8](path[j] & 0xFF)
            j = j + 1
        return 0
    ls: uint64 = cast[uint64](last_slash)
    k: uint64 = 0
    while k < ls:
        parent_out[k] = cast[uint8](path[k] & 0xFF)
        k = k + 1
    parent_out[ls] = 0
    # Leaf is everything after the slash.
    src: uint64 = ls + 1
    m: uint64 = 0
    while src + m <= n:
        leaf_out[m] = cast[uint8](path[src + m] & 0xFF)
        m = m + 1
    if leaf_out[0] == 0:
        return -1
    return 0


# Scratch path buffers for rename's parent/leaf split. Single mount,
# single thread, so static buffers are safe.
ext4_rn_old_parent: Array[256, uint8]
ext4_rn_old_leaf:   Array[256, uint8]
ext4_rn_new_parent: Array[256, uint8]
ext4_rn_new_leaf:   Array[256, uint8]


def ext4_rename(old_path: Ptr[char], new_path: Ptr[char]) -> int32:
    # Rename / move within the ext4 volume. `old_path` and `new_path`
    # are both /ext-relative (caller stripped the /ext/ prefix).
    # Returns 0 on success, a negative errno on failure.
    if ext4_blockdev_slot < 0:
        return -1
    if _ext4_split_dir_path(old_path, &ext4_rn_old_parent[0],
                            &ext4_rn_old_leaf[0]) != 0:
        return -2                                  # -ENOENT-ish
    if _ext4_split_dir_path(new_path, &ext4_rn_new_parent[0],
                            &ext4_rn_new_leaf[0]) != 0:
        return -2

    old_parent_inum: uint32 = ext4_resolve_dir(
        cast[Ptr[char]](&ext4_rn_old_parent[0]))
    if old_parent_inum == 0:
        return -2
    new_parent_inum: uint32 = ext4_resolve_dir(
        cast[Ptr[char]](&ext4_rn_new_parent[0]))
    if new_parent_inum == 0:
        return -2

    # Resolve the source dirent (inum + file_type) BEFORE touching
    # anything — if the source doesn't exist there is nothing to do.
    src_inum:  uint32 = 0
    src_ftype: uint8  = 0
    sr: int32 = _ext4_dir_find_entry(
        cast[uint64](old_parent_inum),
        cast[Ptr[char]](&ext4_rn_old_leaf[0]),
        &src_inum, &src_ftype)
    if sr <= 0:
        return -2                                  # -ENOENT

    # If source and destination name the same dirent, nothing to do.
    if old_parent_inum == new_parent_inum:
        same: int32 = _name_eq_with_len(
            &ext4_rn_old_leaf[0], &ext4_rn_new_leaf[0],
            _ext4_strlen(cast[Ptr[char]](&ext4_rn_old_leaf[0])))
        if same != 0:
            return 0

    # Overwrite case: if the destination name already exists, unlink
    # the old occupant first (free its inode + first data block, then
    # tombstone its dirent). rename(2) replaces atomically — we don't
    # have a journal, so we accept the tiny window where the dest
    # name is briefly absent.
    dst_inum:  uint32 = 0
    dst_ftype: uint8  = 0
    dr: int32 = _ext4_dir_find_entry(
        cast[uint64](new_parent_inum),
        cast[Ptr[char]](&ext4_rn_new_leaf[0]),
        &dst_inum, &dst_ftype)
    if dr < 0:
        return -1
    if dr > 0:
        # Free the overwritten file's inode + its inline-leaf blocks.
        victim: Array[256, uint8]
        if ext4_read_inode(cast[uint64](dst_inum), &victim[0]) == 0:
            vblocks: uint64 = _ext4_inode_block_count(&victim[0])
            vb: uint64 = 0
            while vb < vblocks:
                vphys: uint64 = _ext4_logical_to_physical(&victim[0],
                                                          vb)
                if vphys != 0:
                    ext4_free_block(vphys)
                vb = vb + 1
        ext4_free_inode(dst_inum)
        _ext4_dir_tombstone(cast[uint64](new_parent_inum),
                            cast[Ptr[char]](&ext4_rn_new_leaf[0]))

    # Insert the dirent under the new name FIRST (so src_inum is never
    # momentarily unreferenced), then tombstone the old dirent.
    if ext4_dir_insert(cast[uint64](new_parent_inum),
                       cast[Ptr[char]](&ext4_rn_new_leaf[0]),
                       src_inum, src_ftype) != 0:
        printk0("ext4: rename: dir_insert failed (dest dir full)\n")
        return -1
    if _ext4_dir_tombstone(cast[uint64](old_parent_inum),
                           cast[Ptr[char]](&ext4_rn_old_leaf[0])) == 0:
        # The source vanished between find and tombstone — unusual,
        # but the new dirent is already in place, so the file is not
        # lost. Report success: the rename's effect is complete.
        printk0("ext4: rename: source dirent already gone\n")
    return 0


# --- ext4 fsync (M16.x §12.4) -------------------------------------
#
# Our ext4 write path is write-through: ext4_write_open_file,
# ext4_truncate_inode, ext4_create_file and friends all push data and
# metadata to the block device with synchronous blk_write_sectors
# calls, and they order those calls data-before-metadata (the data
# block is written before the inode that points at it; the inode is
# written before the dirent that names it). So by the time any of
# those functions returns, the *ordering* half of fsync's contract is
# already satisfied on disk.
#
# What fsync still owes is the device-cache barrier: a hint to the
# block device to push its own volatile write cache to non-volatile
# media. blk_flush issues that barrier (SYNCHRONIZE CACHE / NVMe
# FLUSH / virtio FLUSH); a device with no volatile cache reports
# immediate success. So ext4_fsync is, correctly, just blk_flush on
# the mounted device — there are no buffered-but-unwritten ext4
# structures of our own to drain first.
#
# A future buffered/write-back ext4 (a real page cache, delayed
# allocation) would grow a "flush my dirty buffers, in order, THEN
# blk_flush" body here. Until then this is complete, not a stub.

def ext4_fsync() -> int32:
    # Flush the mounted ext4 device's write cache. Returns 0 on
    # success, -1 if no ext4 volume is mounted.
    if ext4_blockdev_slot < 0:
        return -1
    return blk_flush(ext4_blockdev_slot)


# --- §12 smoke tests ----------------------------------------------
#
# Exercise rename, truncate/ftruncate, fsync and the persistence of
# all three through the ext4 read path. Run once at boot (gated by
# the same one-shot as the mkfs self-test); each prints a PASS/FAIL
# marker the test scripts grep for.

def _ext4_read_back_eq(inum: uint32, expect: Ptr[uint8],
                       n: uint64) -> int32:
    # Read n bytes from inode `inum` and byte-compare against expect.
    # Returns 1 on match, 0 on mismatch / short read.
    rb: Array[256, uint8]
    if n > 256:
        return 0
    got: int64 = ext4_read_file(inum, 0, n, &rb[0])
    if got != cast[int64](n):
        return 0
    i: uint64 = 0
    while i < n:
        if rb[i] != expect[i]:
            return 0
        i = i + 1
    return 1


def ext4_rename_smoke_test() -> int32:
    # Create RNSRC.TXT, rename it to RNDST.TXT, verify the bytes
    # survive the move and that the old name is gone. Then create a
    # second file and rename it ONTO RNDST.TXT to exercise the
    # overwrite-existing-target path.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "RENAME_PAYLOAD ext4 rename keeps data\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    src_inum: uint32 = ext4_create_file(2, "RNSRC.TXT", body, blen)
    if src_inum == 0:
        printk0("ext4: rename smoke FAIL (create RNSRC)\n")
        return -1
    if ext4_rename("RNSRC.TXT", "RNDST.TXT") != 0:
        printk0("ext4: rename smoke FAIL (rename op)\n")
        return -1
    # Old name must be gone.
    gi: uint32 = 0
    gs: uint64 = 0
    if ext4_resolve_file("RNSRC.TXT", &gi, &gs) != 0:
        printk0("ext4: rename smoke FAIL (old name still resolves)\n")
        return -1
    # New name must resolve to the SAME inode with the SAME bytes.
    ni: uint32 = 0
    ns: uint64 = 0
    if ext4_resolve_file("RNDST.TXT", &ni, &ns) == 0:
        printk0("ext4: rename smoke FAIL (new name missing)\n")
        return -1
    if ni != src_inum:
        printk0("ext4: rename smoke FAIL (inode changed)\n")
        return -1
    if _ext4_read_back_eq(ni, body, blen) == 0:
        printk0("ext4: rename smoke FAIL (data corrupt after move)\n")
        return -1
    # Overwrite case: a second file renamed onto RNDST.TXT.
    body2: Ptr[uint8] = "OVERWRITE_PAYLOAD ext4 rename clobbers dst\n"
    b2len: uint64 = _ext4_strlen(cast[Ptr[char]](body2))
    src2: uint32 = ext4_create_file(2, "RNSRC2.TXT", body2, b2len)
    if src2 == 0:
        printk0("ext4: rename smoke FAIL (create RNSRC2)\n")
        return -1
    if ext4_rename("RNSRC2.TXT", "RNDST.TXT") != 0:
        printk0("ext4: rename smoke FAIL (overwrite rename)\n")
        return -1
    oi: uint32 = 0
    os: uint64 = 0
    if ext4_resolve_file("RNDST.TXT", &oi, &os) == 0:
        printk0("ext4: rename smoke FAIL (dst missing post-overwrite)\n")
        return -1
    if oi != src2:
        printk0("ext4: rename smoke FAIL (dst not the new inode)\n")
        return -1
    if _ext4_read_back_eq(oi, body2, b2len) == 0:
        printk0("ext4: rename smoke FAIL (overwrite data wrong)\n")
        return -1
    # Leave the FS as we found it — unlink the test leftover so the
    # root-dir entry count other tests assert against is unperturbed.
    ext4_unlink("RNDST.TXT")
    printk0("ext4: rename smoke PASS\n")
    return 0


def ext4_truncate_smoke_test() -> int32:
    # Create a file, grow it past one block, shrink it back inside one
    # block, verify i_size and the data tracking the resize.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "TRUNC_HEAD ext4 truncate test base bytes\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    inum: uint32 = ext4_create_file(2, "TRUNC.TXT", body, blen)
    if inum == 0:
        printk0("ext4: truncate smoke FAIL (create)\n")
        return -1
    # Grow to 2.5 blocks. The new tail must read back as zeros.
    grow_to: uint64 = ext4_block_size * 2 + ext4_block_size / 2
    if ext4_truncate_inode(inum, grow_to) != 0:
        printk0("ext4: truncate smoke FAIL (grow op)\n")
        return -1
    g_inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &g_inode[0]) != 0:
        printk0("ext4: truncate smoke FAIL (reread after grow)\n")
        return -1
    if cast[uint64](ext4_inode_size_lo(&g_inode[0])) != grow_to:
        printk0("ext4: truncate smoke FAIL (grown i_size wrong)\n")
        return -1
    # The original head bytes must still be intact.
    rb: Array[256, uint8]
    if ext4_read_file(inum, 0, blen, &rb[0]) != cast[int64](blen):
        printk0("ext4: truncate smoke FAIL (head read short)\n")
        return -1
    i: uint64 = 0
    while i < blen:
        if rb[i] != body[i]:
            printk0("ext4: truncate smoke FAIL (head corrupt)\n")
            return -1
        i = i + 1
    # A byte well past old EOF (but inside the grown region) reads 0.
    zb: Array[16, uint8]
    if ext4_read_file(inum, ext4_block_size + 100, 16, &zb[0]) \
            != 16:
        printk0("ext4: truncate smoke FAIL (zero region read short)\n")
        return -1
    j: uint64 = 0
    while j < 16:
        if zb[j] != 0:
            printk0("ext4: truncate smoke FAIL (grown tail not zero)\n")
            return -1
        j = j + 1
    # Shrink back to 10 bytes — inside the first block.
    if ext4_truncate_inode(inum, 10) != 0:
        printk0("ext4: truncate smoke FAIL (shrink op)\n")
        return -1
    s_inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &s_inode[0]) != 0:
        printk0("ext4: truncate smoke FAIL (reread after shrink)\n")
        return -1
    if cast[uint64](ext4_inode_size_lo(&s_inode[0])) != 10:
        printk0("ext4: truncate smoke FAIL (shrunk i_size wrong)\n")
        return -1
    # A read past the new 10-byte EOF must return 0 (EOF).
    if ext4_read_file(inum, 10, 8, &zb[0]) != 0:
        printk0("ext4: truncate smoke FAIL (read past shrunk EOF)\n")
        return -1
    # First 10 bytes must still match the original head.
    if ext4_read_file(inum, 0, 10, &rb[0]) != 10:
        printk0("ext4: truncate smoke FAIL (post-shrink head short)\n")
        return -1
    k: uint64 = 0
    while k < 10:
        if rb[k] != body[k]:
            printk0("ext4: truncate smoke FAIL (post-shrink head bad)\n")
            return -1
        k = k + 1
    # File is back inside one block after the shrink — unlink cleanly.
    ext4_unlink("TRUNC.TXT")
    printk0("ext4: truncate smoke PASS\n")
    return 0


def ext4_fsync_smoke_test() -> int32:
    # Create a file, write a marker, fsync, then re-read via the
    # standard read path. fsync must return 0 and the bytes must
    # survive. A real crash-consistency proof lives in the persistence
    # test (reboot QEMU against the same image) — this checks the
    # fsync call itself succeeds and orders correctly.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "FSYNC_DURABLE ext4 fsync flushed this\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    inum: uint32 = ext4_create_file(2, "FSYNC.TXT", body, blen)
    if inum == 0:
        printk0("ext4: fsync smoke FAIL (create)\n")
        return -1
    if ext4_fsync() != 0:
        printk0("ext4: fsync smoke FAIL (fsync returned error)\n")
        return -1
    if _ext4_read_back_eq(inum, body, blen) == 0:
        printk0("ext4: fsync smoke FAIL (data wrong after fsync)\n")
        return -1
    ext4_unlink("FSYNC.TXT")
    printk0("ext4: fsync smoke PASS\n")
    return 0


# --- ext4 blob save / load (distrofs persistent backing) ----------
#
# distrofs (user/distrofs.ad) is a userland 9P file-server whose node
# + data tables live in RAM. To make an installed package survive a
# reboot it needs a DURABLE backing store: it serialises its whole
# table image into one buffer and asks the kernel to persist that
# buffer as a single root-directory file on the mounted ext4 volume.
#
# ext4_blob_save writes an arbitrary-length buffer to a named file in
# the ext4 root directory, growing the file across as many data blocks
# as the length needs. The existing M16.64 create/write path is
# single-block; this is the multi-block writer the persistent-distrofs
# milestone needs. It is NOT a general open()/write() path — it always
# create-or-truncates the WHOLE file from one in-memory buffer, which
# is exactly the snapshot semantics distrofs wants and keeps the code
# small and corruption-free (no partial-block RMW, no extent surgery
# on an existing tree).
#
# Block allocation: ext4_alloc_block() always returns the first free
# bit, so calling it N times in a row hands back N CONSECUTIVE blocks.
# _ext4_extent_append_block() coalesces a contiguous run into a single
# extent, so the inline depth-0 leaf (eh_max 4) holds a blob of any
# size as long as the run stays contiguous — which it does on a fresh
# region. A fragmented volume could need >4 extents; ext4_blob_save
# detects a full leaf and fails cleanly (-1) rather than corrupt.
#
# ext4_blob_load resolves the named root file and reads it back via
# the standard multi-block ext4_read_file path.

# Per-block scratch for blob save (separate from ext4_blk_buf so an
# in-flight inode read during the loop can't trample it).
ext4_blob_buf: Array[4096, uint8]
# Inode scratch for the blob writer.
ext4_blob_inode: Array[256, uint8]


def ext4_blob_save(name: Ptr[char], src: Ptr[uint8],
                   length: uint64) -> int64:
    # Create-or-overwrite the root-directory file `name` so it holds
    # exactly `length` bytes copied from `src`, then fsync the volume.
    # Returns the byte count written on success, -1 on any failure.
    if ext4_blockdev_slot < 0:
        return cast[int64](-1)
    # Drop any previous incarnation of the file: tombstone its dirent
    # and free its inode. We also walk its extent leaf and free every
    # data block so a repeated save does not leak the volume away.
    old_inum: uint32 = _ext4_dir_unlink_in_root(name)
    if old_inum != 0:
        if ext4_read_inode(cast[uint64](old_inum),
                           &ext4_blob_inode[0]) == 0:
            _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(old_inum)
    # Allocate a fresh inode for the new file.
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        printk0("ext4: blob_save FAIL (alloc_inode)\n")
        return cast[int64](-1)
    # Start from a minimal empty regular inode: mode 0664 + IFREG, an
    # empty depth-0 extent leaf, i_size 0. _ext4_init_regular_inode
    # wants a data block; we instead hand-build an EMPTY leaf so the
    # append loop below grows it block by block.
    p: Ptr[uint8] = &ext4_blob_inode[0]
    _ext4_zero(p, ext4_inode_size)
    _ext4_write_u16(p, 0x81B4)                       # i_mode = IFREG|0664
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26), 1)  # i_links
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32),
                    0x80000)                         # EXT4_EXTENTS_FL
    eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)     # eh_entries = 0
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)     # eh_max = 4
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)     # eh_depth = 0
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)     # eh_generation
    _ext4_stamp_all_times(p)
    # Grow the file block by block.
    nblocks: uint64 = (length + ext4_block_size - 1) / ext4_block_size
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    lb: uint64 = 0
    while lb < nblocks:
        nb: uint64 = ext4_alloc_block()
        if nb == 0:
            printk0("ext4: blob_save FAIL (out of blocks)\n")
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        # Fill the block: copy this slice of src, zero-pad the tail.
        _ext4_zero(&ext4_blob_buf[0], ext4_block_size)
        off: uint64 = lb * ext4_block_size
        chunk: uint64 = length - off
        if chunk > ext4_block_size:
            chunk = ext4_block_size
        if chunk > 0:
            memcpy(&ext4_blob_buf[0],
                   cast[Ptr[uint8]](cast[uint64](src) + off), chunk)
        if _ext4_write_block(nb, &ext4_blob_buf[0]) != 0:
            printk0("ext4: blob_save FAIL (write data block)\n")
            ext4_free_block(nb)
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        if _ext4_extent_append_block(&ext4_blob_inode[0], lb, nb) != 0:
            printk0("ext4: blob_save FAIL (extent leaf full)\n")
            ext4_free_block(nb)
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        lb = lb + 1
    # Stamp i_size and i_blocks, write the inode out.
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4),
                    cast[uint32](length))            # i_size_lo
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28),
                    cast[uint32](nblocks * sectors_per_block))  # i_blocks_lo
    _ext4_stamp_mtime(p)
    if ext4_write_inode(cast[uint64](new_inum),
                        &ext4_blob_inode[0]) != 0:
        printk0("ext4: blob_save FAIL (write inode)\n")
        _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(new_inum)
        return cast[int64](-1)
    # Splice the dirent into the root directory (EXT4_FT_REG_FILE = 1).
    if ext4_dir_insert(2, name, new_inum, 1) != 0:
        printk0("ext4: blob_save FAIL (dir_insert)\n")
        _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(new_inum)
        return cast[int64](-1)
    # Durable: flush the block-device write cache (the same barrier
    # ext4_fsync issues). Without this the snapshot is only in the
    # device cache and a reboot could lose it.
    blk_flush(ext4_blockdev_slot)
    return cast[int64](length)


def ext4_blob_load(name: Ptr[char], dst: Ptr[uint8],
                   max_len: uint64) -> int64:
    # Read the root-directory file `name` into `dst` (at most max_len
    # bytes). Returns the byte count read, 0 if the file does not
    # exist, -1 on I/O error / no ext4 volume.
    if ext4_blockdev_slot < 0:
        return cast[int64](-1)
    inum: uint32 = 0
    size: uint64 = 0
    if ext4_resolve_file(name, &inum, &size) == 0:
        return cast[int64](0)                        # no snapshot yet
    want: uint64 = size
    if want > max_len:
        want = max_len
    if want == 0:
        return cast[int64](0)
    return ext4_read_file(inum, 0, want, dst)


# --- ext4_mkfs (M16.x) --------------------------------------------
#
# Format a freshly-partitioned slice as ext4. Mirrors the simplest
# viable subset of e2fsprogs/mke2fs.c — single block group, no
# journal, extents-only (so the existing M16.51..67 read path picks
# the FS up unchanged). The resulting filesystem has:
#
#   * 4 KiB blocks (s_log_block_size = 2)
#   * 256-byte inodes (s_inode_size = 256)
#   * one block group (we accept partitions up to 32768 blocks =
#     128 MiB; larger slices are clamped to one group — multi-group
#     mkfs is a documented follow-up)
#   * 8192 inodes/group, inode #2 = the root directory containing
#     just "." and ".."
#   * legacy 32-byte group descriptors (no 64BIT, no metadata_csum,
#     no journal — Linux's tune2fs -O ^has_journal output shape)
#   * volume label "hamnix-mkfs"
#
# On-disk layout inside the partition (blocks are 4 KiB; sectors are
# 512 bytes, 8 sectors per block):
#
#   block 0   bytes 0..1023 = boot area; bytes 1024..2047 = SB
#   block 1   group descriptor table (one 32-byte entry, rest zero)
#   block 2   block bitmap (first 517 bits = metadata + root data)
#   block 3   inode bitmap (first 10 bits set = inodes 1..10)
#   block 4..515  inode table (8192 × 256 B = 512 blocks)
#   block 516 root directory's first data block (. and .. dirents)
#
# `ext4_mkfs(slot, total_sectors)` performs no read-back — it just
# blasts the metadata out. The caller is expected to immediately
# `ext4_init(slot)` to mount the freshly-formatted FS, which doubles
# as a self-check that the structures we wrote are coherent.

EXT4_MKFS_BLOCK_SIZE:      uint64 = 4096
EXT4_MKFS_LOG_BLOCK:       uint32 = 2          # 1024 << 2 = 4096
EXT4_MKFS_INODE_SIZE:      uint64 = 256
EXT4_MKFS_INODES_PER_GRP:  uint64 = 8192
EXT4_MKFS_BLOCKS_PER_GRP:  uint64 = 32768
EXT4_MKFS_FIRST_INODE:     uint32 = 11
EXT4_MKFS_RESERVED_INODES: uint64 = 10

# Group-0 metadata block addresses (4 KiB blocks, s_first_data_block=0).
EXT4_MKFS_SB_BLOCK:           uint64 = 0
EXT4_MKFS_GDT_BLOCK:          uint64 = 1
EXT4_MKFS_BLOCK_BITMAP_BLOCK: uint64 = 2
EXT4_MKFS_INODE_BITMAP_BLOCK: uint64 = 3
EXT4_MKFS_INODE_TABLE_BLOCK:  uint64 = 4
EXT4_MKFS_INODE_TABLE_BLOCKS: uint64 = 512     # 8192 × 256 / 4096
EXT4_MKFS_ROOT_DATA_BLOCK:    uint64 = 516
EXT4_MKFS_METADATA_BLOCKS:    uint64 = 517     # bits 0..516 in blk bitmap

# 4 KiB scratch buffer for mkfs page writes.
ext4_mkfs_buf: Array[4096, uint8]


def _ext4_mkfs_write_block(slot: int32, blk_nr: uint64,
                           buf: Ptr[uint8]) -> int32:
    # Slot-aware write of one 4 KiB block. ext4_mkfs runs BEFORE
    # ext4_init has populated the mount globals, so we can't use the
    # global-state-dependent _ext4_write_block.
    lba: uint64 = blk_nr * 8
    return blk_write_sectors(slot, lba, 8, buf)


def _ext4_mkfs_write_label(p: Ptr[uint8]):
    # Copy "hamnix-mkfs" (11 bytes + NUL pad) into the 16-byte
    # s_volume_name area at superblock offset 0x78.
    label: Ptr[uint8] = "hamnix-mkfs"
    i: uint64 = 0
    while i < 11:
        p[i] = label[i]
        i = i + 1
    while i < 16:
        p[i] = 0
        i = i + 1


def _ext4_mkfs_build_superblock(buf: Ptr[uint8],
                                blocks_count: uint64,
                                free_blocks: uint64) -> int32:
    # Build a 1024-byte superblock at &buf[1024..2047] (the boot area
    # at 0..1023 stays zero). `buf` is the full 4 KiB block 0 scratch.
    sb: uint64 = cast[uint64](buf) + 1024
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x00),
                    cast[uint32](EXT4_MKFS_INODES_PER_GRP))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x04),
                    cast[uint32](blocks_count))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x0C),
                    cast[uint32](free_blocks))
    free_inodes: uint64 = EXT4_MKFS_INODES_PER_GRP \
                          - EXT4_MKFS_RESERVED_INODES
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x10),
                    cast[uint32](free_inodes))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x14), 0)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x18),
                    EXT4_MKFS_LOG_BLOCK)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x1C),
                    EXT4_MKFS_LOG_BLOCK)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x20),
                    cast[uint32](EXT4_MKFS_BLOCKS_PER_GRP))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x24),
                    cast[uint32](EXT4_MKFS_BLOCKS_PER_GRP))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x28),
                    cast[uint32](EXT4_MKFS_INODES_PER_GRP))
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x38), EXT4_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x3A), 1)
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x3C), 1)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x48), 0)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x4C), 1)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x54),
                    cast[uint32](EXT4_MKFS_FIRST_INODE))
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x58),
                    cast[uint16](EXT4_MKFS_INODE_SIZE))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x5C), 0)
    # s_feature_incompat: EXTENTS (0x40) | FILETYPE (0x2).
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x60), 0x42)
    # s_feature_ro_compat: SPARSE_SUPER (0x1) | LARGE_FILE (0x2).
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x64), 0x3)
    _ext4_mkfs_write_label(cast[Ptr[uint8]](sb + 0x78))
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0xFE), 0)
    return 0


def _ext4_mkfs_build_gdt(buf: Ptr[uint8], free_blocks: uint64,
                         free_inodes: uint64) -> int32:
    p: uint64 = cast[uint64](buf)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x00),
                    cast[uint32](EXT4_MKFS_BLOCK_BITMAP_BLOCK))
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x04),
                    cast[uint32](EXT4_MKFS_INODE_BITMAP_BLOCK))
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x08),
                    cast[uint32](EXT4_MKFS_INODE_TABLE_BLOCK))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x0C),
                    cast[uint16](free_blocks))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x0E),
                    cast[uint16](free_inodes))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x10), 1)
    return 0


def _ext4_mkfs_build_block_bitmap(buf: Ptr[uint8]) -> int32:
    in_use: uint64 = EXT4_MKFS_METADATA_BLOCKS
    full_bytes: uint64 = in_use / 8
    i: uint64 = 0
    while i < full_bytes:
        buf[i] = 0xFF
        i = i + 1
    rem: uint64 = in_use % 8
    if rem != 0:
        bit_idx: uint64 = 0
        m: uint8 = 0
        while bit_idx < rem:
            m = m | (cast[uint8](1) << cast[uint8](bit_idx))
            bit_idx = bit_idx + 1
        buf[full_bytes] = m
    return 0


def _ext4_mkfs_build_inode_bitmap(buf: Ptr[uint8]) -> int32:
    full_bytes: uint64 = EXT4_MKFS_RESERVED_INODES / 8
    i: uint64 = 0
    while i < full_bytes:
        buf[i] = 0xFF
        i = i + 1
    rem: uint64 = EXT4_MKFS_RESERVED_INODES % 8
    if rem != 0:
        bit_idx: uint64 = 0
        m: uint8 = 0
        while bit_idx < rem:
            m = m | (cast[uint8](1) << cast[uint8](bit_idx))
            bit_idx = bit_idx + 1
        buf[full_bytes] = m
    return 0


def _ext4_mkfs_build_root_inode(buf: Ptr[uint8]) -> int32:
    p: uint64 = cast[uint64](buf)
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x00), 0x41ED)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x04),
                    cast[uint32](EXT4_MKFS_BLOCK_SIZE))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x1A), 2)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x1C), 8)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x20), 0x80000)
    eh: uint64 = p + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 12), 0)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 16), 1)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 18), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 20),
                    cast[uint32](EXT4_MKFS_ROOT_DATA_BLOCK))
    return 0


def _ext4_mkfs_build_root_dirblock(buf: Ptr[uint8]) -> int32:
    p: uint64 = cast[uint64](buf)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0), 2)
    _ext4_write_u16(cast[Ptr[uint8]](p + 4), 12)
    cast[Ptr[uint8]](p + 6)[0] = 1
    cast[Ptr[uint8]](p + 7)[0] = 2
    cast[Ptr[uint8]](p + 8)[0] = 0x2E
    rest: uint64 = EXT4_MKFS_BLOCK_SIZE - 12
    _ext4_write_u32(cast[Ptr[uint8]](p + 12), 2)
    _ext4_write_u16(cast[Ptr[uint8]](p + 16),
                    cast[uint16](rest))
    cast[Ptr[uint8]](p + 18)[0] = 2
    cast[Ptr[uint8]](p + 19)[0] = 2
    cast[Ptr[uint8]](p + 20)[0] = 0x2E
    cast[Ptr[uint8]](p + 21)[0] = 0x2E
    return 0


def ext4_mkfs(slot: int32, total_sectors: uint64) -> int32:
    # Format the block device at `slot` as a single-group ext4
    # filesystem. `total_sectors` is the partition capacity in
    # 512-byte sectors. Returns 0 on success, -1 on failure.
    if slot < 0:
        return -1
    if total_sectors < 4136:
        printk0("ext4: mkfs: partition too small (need >= 2 MiB)\n")
        return -1
    total_blocks: uint64 = total_sectors / 8
    if total_blocks > EXT4_MKFS_BLOCKS_PER_GRP:
        total_blocks = EXT4_MKFS_BLOCKS_PER_GRP
    free_blocks: uint64 = total_blocks - EXT4_MKFS_METADATA_BLOCKS
    free_inodes: uint64 = EXT4_MKFS_INODES_PER_GRP \
                          - EXT4_MKFS_RESERVED_INODES

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_superblock(&ext4_mkfs_buf[0], total_blocks,
                                free_blocks)
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_SB_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write superblock failed\n")
        return -1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_gdt(&ext4_mkfs_buf[0], free_blocks, free_inodes)
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_GDT_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write GDT failed\n")
        return -1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_block_bitmap(&ext4_mkfs_buf[0])
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_BLOCK_BITMAP_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write block bitmap failed\n")
        return -1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_inode_bitmap(&ext4_mkfs_buf[0])
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_INODE_BITMAP_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write inode bitmap failed\n")
        return -1

    # Inode #2 lives at byte offset 256 within the first inode-table
    # block (table position 1, 0-indexed). Build that block specially;
    # the rest of the table is plain zeros.
    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_root_inode(
        cast[Ptr[uint8]](
            cast[uint64](&ext4_mkfs_buf[0])
            + EXT4_MKFS_INODE_SIZE))
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_INODE_TABLE_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write inode table block 0 failed\n")
        return -1
    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    rem_blk: uint64 = 1
    while rem_blk < EXT4_MKFS_INODE_TABLE_BLOCKS:
        if _ext4_mkfs_write_block(slot,
                EXT4_MKFS_INODE_TABLE_BLOCK + rem_blk,
                &ext4_mkfs_buf[0]) != 0:
            printk0("ext4: mkfs: write inode table tail failed\n")
            return -1
        rem_blk = rem_blk + 1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_root_dirblock(&ext4_mkfs_buf[0])
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_ROOT_DATA_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write root dir block failed\n")
        return -1

    printk2("[ext4] mkfs slot=%d total_blocks=%d OK\n",
            cast[uint64](slot), total_blocks)
    return 0


# ---- mkfs self-test ----------------------------------------------
#
# Locates sd0p1 (or nvme0n1p1) and runs mkfs + re-mount + verify
# against it. Save/restore the mount globals around the run so a
# concurrent /ext mount on a different slot survives.
ext4_mkfs_self_test_done: uint32 = 0


def _ext4_mkfs_find_target() -> int32:
    s: int32 = find_blockdev("sd0p1")
    if s >= 0:
        return s
    s = find_blockdev("nvme0n1p1")
    if s >= 0:
        return s
    return -1


def _ext4_mkfs_verify_root(slot: int32) -> int32:
    # Read inode #2 and walk its first dir block. Returns 0 on PASS,
    # -1 on FAIL.
    ino_buf: Array[256, uint8]
    if ext4_read_inode(2, &ino_buf[0]) != 0:
        printk0("[ext4] mkfs verify FAIL (read inode #2)\n")
        return -1
    mode: uint16 = ext4_inode_mode(&ino_buf[0])
    if (mode & 0xF000) != 0x4000:
        printk1("[ext4] mkfs verify FAIL (inode #2 mode=%x not dir)\n",
                cast[uint64](mode))
        return -1
    phys: uint64 = ext4_inode_first_extent_block(&ino_buf[0])
    if phys == 0:
        printk0("[ext4] mkfs verify FAIL (root has no data block)\n")
        return -1
    if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
        printk0("[ext4] mkfs verify FAIL (root dir read)\n")
        return -1
    e: uint64 = cast[uint64](&ext4_blk_buf[0])
    e0_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
    e0_rec:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
    e0_nl:   uint8  = cast[Ptr[uint8]](e + 6)[0]
    e0_c0:   uint8  = cast[Ptr[uint8]](e + 8)[0]
    if e0_inum != 2 or e0_nl != 1 or e0_c0 != 0x2E:
        printk0("[ext4] mkfs verify FAIL (root dirent[0] != .)\n")
        return -1
    e2: uint64 = e + cast[uint64](e0_rec)
    e1_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e2 + 0))
    e1_nl:   uint8  = cast[Ptr[uint8]](e2 + 6)[0]
    e1_c0:   uint8  = cast[Ptr[uint8]](e2 + 8)[0]
    e1_c1:   uint8  = cast[Ptr[uint8]](e2 + 9)[0]
    if e1_inum != 2 or e1_nl != 2 or e1_c0 != 0x2E or e1_c1 != 0x2E:
        printk0("[ext4] mkfs verify FAIL (root dirent[1] != ..)\n")
        return -1
    return 0


def _ext4_mkfs_restore_state(s_slot: int32, s_bs: uint64, s_bpg: uint64,
                             s_ipg: uint64, s_ic: uint64, s_bc: uint64,
                             s_fdb: uint64, s_isz: uint64, s_ds: uint64,
                             s_gdt: uint64):
    # Restore the mount snapshot taken at the top of
    # ext4_mkfs_self_test. Factored out so both success and failure
    # paths reach a single restore point.
    ext4_blockdev_slot   = s_slot
    ext4_block_size      = s_bs
    ext4_blocks_per_grp  = s_bpg
    ext4_inodes_per_grp  = s_ipg
    ext4_inodes_count    = s_ic
    ext4_blocks_count    = s_bc
    ext4_first_data_blk  = s_fdb
    ext4_inode_size      = s_isz
    ext4_desc_size       = s_ds
    ext4_gdt_block       = s_gdt


def ext4_mkfs_self_test() -> int32:
    target: int32 = _ext4_mkfs_find_target()
    if target < 0:
        printk0("[ext4] mkfs self-test SKIP (no partition device)\n")
        return 0
    s_slot:  int32  = ext4_blockdev_slot
    s_bs:    uint64 = ext4_block_size
    s_bpg:   uint64 = ext4_blocks_per_grp
    s_ipg:   uint64 = ext4_inodes_per_grp
    s_ic:    uint64 = ext4_inodes_count
    s_bc:    uint64 = ext4_blocks_count
    s_fdb:   uint64 = ext4_first_data_blk
    s_isz:   uint64 = ext4_inode_size
    s_ds:    uint64 = ext4_desc_size
    s_gdt:   uint64 = ext4_gdt_block

    # test_mkfs.sh sizes p1 at 63488 sectors (31 MiB). ext4_mkfs caps
    # at one block group (32768 blocks = 128 MiB).
    test_sectors: uint64 = 63488
    if ext4_mkfs(target, test_sectors) != 0:
        printk0("[ext4] mkfs self-test FAIL (ext4_mkfs)\n")
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1
    printk1("[ext4] mkfs sd0p1 OK (slot=%d)\n",
            cast[uint64](target))

    if ext4_init(target) != 0:
        printk0("[ext4] mkfs self-test FAIL (re-mount)\n")
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1
    printk1("[ext4] mounted sd0p1 ro=0 (slot=%d)\n",
            cast[uint64](target))

    if _ext4_mkfs_verify_root(target) != 0:
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1
    printk0("[ext4] / contains . ..\n")
    _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                             s_bc, s_fdb, s_isz, s_ds, s_gdt)
    printk0("[ext4] mkfs self-test PASS\n")
    return 0


def _ext4_mkfs_self_test_maybe():
    # Single-shot gate. Called from is_ext_path on every VFS open;
    # the gate keeps subsequent calls to a single global compare.
    if ext4_mkfs_self_test_done != 0:
        return
    ext4_mkfs_self_test_done = 1
    ext4_mkfs_self_test()

# fs/ext4.ad
#
# EXT4 read-only — mirror of fs/ext4/super.c at the smallest
# meaningful scope. M16.51 ships ONLY the superblock parser; the
# rest of the read path (group descriptors → inode table → extent
# tree → directory walk) lands in subsequent milestones.
#
# Single-mount only (one global state block). Multiple mounts wait
# for the VFS superblock/inode/dentry refactor.
#
# On-disk layout we care about for the superblock:
#
#   - The superblock sits at byte offset 1024 from the start of
#     the filesystem (sector 2 with 512-byte sectors). Always
#     1024 bytes, regardless of block_size.
#   - block_size = 1024 << s_log_block_size.
#   - block group descriptors follow the superblock's block.
#   - inode table for block group N starts at the block address
#     stored in the group descriptor.
#
# Field offsets (relative to the start of the 1024-byte sb):
#   0x00  s_inodes_count       u32
#   0x04  s_blocks_count_lo    u32
#   0x14  s_first_data_block   u32
#   0x18  s_log_block_size     u32
#   0x20  s_blocks_per_group   u32
#   0x28  s_inodes_per_group   u32
#   0x38  s_magic              u16  (0xEF53)
#   0x58  s_inode_size         u16

from kernel.block.blk import (
    blk_read_sectors, blk_write_sectors, blk_flush, find_blockdev,
    blk_capacity_sectors, SECTOR_SIZE,
)
from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level, PRINTK_LEVEL_EMERG,
)
from fs.vfs_mount import vfs_mount_ext4
from drivers.rtc.cmos import rtc_read_unix_time
# Linux-shape file page cache (fs/fcache.ad): regular ext4 file reads go
# through a per-inode address_space so a re-read of the same page skips the
# extent walk + block I/O, and writes dirty the cached page + write through.
from fs.fcache import (
    fcache_page_lookup, fcache_page_data, fcache_page_install,
    fcache_invalidate_inode, fcache_inode_writeback,
    fcache_drop_inode_nowriteback,
    PC_SRV_EXT4, PC_PAGE_SIZE,
)
# docs/security.md Phase 6: stamp the creating task's uid/gid into
# the new inode's i_uid/i_gid fields. Kernel-internal create paths
# (mkfs root inode, blob_save) fall back to uid 1 (hostowner).
from kernel.sched.core import (
    current_task_uid, current_task_gid, UID_HOSTOWNER,
    set_current_errstr,
)


# Per-backend errstr: ext4 failure sites pass a literal "ext4: <reason>"
# to set_current_errstr so SYS_ERRSTR consumers (errstr(2), userland
# perror) can identify the failing backend without parsing return codes.
# See sysfile.ad for the syscall-layer fallback that only fires when
# the buffer is still empty.
# #149: the ext4 journal (JBD2). ext4_init detects the has_journal
# feature, reads the journal inode (conventionally inode 8), hands the
# journal's logical->physical block map to jbd2_attach, and recovers
# any uncheckpointed transactions on an unclean mount.
from fs.jbd2 import (
    jbd2_attach, jbd2_recover, jbd2_is_attached,
    jbd2_txn_begin, jbd2_txn_add, jbd2_txn_commit, jbd2_txn_checkpoint,
    jbd2_txn_skip_checkpoint, jbd2_txn_abort, jbd2_txn_commit_nocommitblk,
    jbd2_super_magic_read,
    jbd2_fc_blocks, jbd2_fc_first_lblk, jbd2_fc_read, jbd2_fc_write,
    jbd2_block_size_get, jbd2_fc_enable,
)
# RO_COMPAT_METADATA_CSUM (#endgame): crc32c integrity for ext4
# metadata. crc32c_update is the running-register primitive ext4 chains
# for seeded per-object checksums; crc32c is the finalized form whose
# KAT (crc32c("123456789")==0xE3069283) self-checks the polynomial.
from fs.crc32c import crc32c, crc32c_update, crc32c_selftest
from fs.sha256 import sha256_oneshot
# AES-256-XTS (the aes-xts-plain64 data-unit transform shared with dm-crypt,
# fs/aes_xts.ad) — ext4 fscrypt uses it for per-file content encryption at
# rest: each data block is XTS-transformed under the file's content key with
# the file LOGICAL BLOCK NUMBER as the tweak/data-unit index.
from fs.aes_xts import (
    aes_xts_set_key, aes_xts_encrypt_unit, aes_xts_decrypt_unit,
)

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


EXT4_MAGIC: uint16 = 0xEF53

# struct stat-style inode mode bits we care about. The ext4 i_mode
# field encodes file type in the high nibble (mask 0xF000). 0x8000 is
# regular file, 0x4000 is directory, 0xA000 is symlink — the value
# /usr/include/linux/stat.h calls S_IFLNK.
S_IFLNK: uint16 = 0xA000


# Mount state — single mount.
ext4_blockdev_slot:   int32  = -1
ext4_block_size:      uint64 = 0
ext4_blocks_per_grp:  uint64 = 0
ext4_inodes_per_grp:  uint64 = 0
ext4_inodes_count:    uint64 = 0
ext4_blocks_count:    uint64 = 0
ext4_first_data_blk:  uint64 = 0
ext4_inode_size:      uint64 = 0
# Group descriptor size — 32 bytes for legacy ext2/3 / pre-64bit
# ext4, 64 bytes for modern ext4 with the 64BIT feature. Read from
# the superblock's s_desc_size (offset 0xFE).
ext4_desc_size:       uint64 = 0
# Block where the group descriptor table starts. For 1 KiB blocks
# with s_first_data_block = 1, the SB is in block 1 and the GDT
# follows in block 2. For other block sizes, it's s_first_data_block
# + 1.
ext4_gdt_block:       uint64 = 0

# Two sectors of scratch for the boot+superblock read. The sb is at
# byte offset 1024 from the partition start; two sectors (0..1023)
# cover the boot area, and we need sectors 2..3 for the sb itself.
ext4_sb_buf: Array[1024, uint8]

# RO_COMPAT_METADATA_CSUM mount state. ext4_metadata_csum is 1 once
# the superblock's s_feature_ro_compat declares the feature AND the
# crc32c KAT passed at mount; while it is 0 every checksum path is a
# no-op (a filesystem WITHOUT the feature is read/written exactly as
# before). ext4_csum_seed is the per-filesystem seed: crc32c_update(
# ~0, s_uuid, 16) — the running register that every per-object inode /
# dir-block / extent-block checksum chains its object identifiers onto.
# s_uuid lives at superblock offset 0x68 (16 bytes).
ext4_metadata_csum: int32  = 0
ext4_csum_seed:     uint32 = 0
EXT4_SB_OFF_UUID:   uint64 = 0x68
EXT4_SB_OFF_CHECKSUM: uint64 = 0x3FC      # s_checksum, last u32 of the 1 KiB sb

# INCOMPAT_INLINE_DATA mount state. ext4_inline_data is 1 once the
# superblock's s_feature_incompat declares the feature (bit 0x8000).
# While it is 0 the per-inode inline flag is ignored entirely, so a
# filesystem WITHOUT the feature reads exactly as before. When the
# feature is on and an inode carries EXT4_INODE_INLINE_DATA (i_flags
# bit 0x10000000) its data lives directly inside the inode: the first
# up-to-60 bytes in the i_block[] area (offset 0x28), with any
# overflow in the "system.data" extended attribute. Such inodes own
# NO data blocks / extents.
ext4_inline_data:   int32  = 0

# RO_COMPAT_BIGALLOC mount state. With bigalloc the unit of block
# allocation/accounting becomes a CLUSTER = block_size << s_log_cluster_size
# (e.g. 16 KiB or 64 KiB clusters of 4 KiB blocks). The "block bitmap" of
# each group becomes a CLUSTER bitmap whose bit N covers cluster N
# (= ext4_cluster_ratio consecutive blocks). Extents still record physical
# BLOCK numbers, so the file-data read path is unaffected: only bitmap /
# free-space accounting is per-cluster.
#
#   ext4_bigalloc        — 1 once s_feature_ro_compat declares BIGALLOC.
#   ext4_log_cluster_size— s_log_cluster_size (sb off 0x1C). When BIGALLOC
#                          is off this equals s_log_block_size and every
#                          derived quantity collapses to its block form, so
#                          a non-bigalloc image behaves EXACTLY as before.
#   ext4_cluster_size    — block_size << (log_cluster_size - log_block_size)
#                          = bytes per cluster.
#   ext4_cluster_ratio   — blocks per cluster = cluster_size / block_size
#                          (1 when BIGALLOC is off).
#   ext4_clusters_per_grp— s_clusters_per_group (sb off 0x24). The cluster
#                          bitmap covers this many bits per group. When
#                          BIGALLOC is off this equals blocks_per_group.
ext4_bigalloc:         int32  = 0
ext4_log_cluster_size: uint64 = 0
ext4_cluster_size:     uint64 = 0
ext4_cluster_ratio:    uint64 = 1
ext4_clusters_per_grp: uint64 = 0

# INCOMPAT_64BIT mount state. When the superblock declares the feature
# (s_feature_incompat & 0x80) the group descriptor is 64 bytes and the
# bg_block_bitmap / bg_inode_bitmap / bg_inode_table block numbers are
# split lo (offsets 0x00/0x04/0x08) + hi (offsets 0x20/0x24/0x28). The
# descriptor-field reader combines both halves only when this is 1; a
# 32-bit image leaves ext4_64bit 0 and reads ONLY the lo half exactly
# as before (the hi area may be unused/garbage in a 32-byte descriptor).
ext4_64bit: int32 = 0
# INCOMPAT_FLEX_BG mount state. When the superblock declares the
# feature (s_feature_incompat & 0x200) the block bitmap, inode bitmap
# and inode table for a run of 2^s_log_groups_per_flex consecutive
# block groups are NOT each at the head of their own group — mke2fs
# packs them contiguously at the start of the flex group's LEADER
# (first) group. The on-disk group descriptors still record the REAL
# (relocated) bitmap/inode-table block numbers, so a correct READER
# never computes those locations from a fixed per-group layout: it
# always trusts the descriptor fields. ext4's read path here already
# does exactly that (ext4_read_inode reads bg_inode_table from the
# descriptor; the bitmap helpers read bg_*_bitmap from the descriptor),
# so honouring flex_bg is a matter of (a) using the 64BIT-aware
# descriptor reader so the relocated locations are read in full, and
# (b) recording the feature for diagnostics. A no-feature image leaves
# ext4_flex_bg 0 / ext4_log_groups_per_flex 0 and behaves identically.
ext4_flex_bg:              int32  = 0
ext4_log_groups_per_flex:  uint64 = 0

# INCOMPAT_EA_INODE mount state. When the superblock declares the
# feature (s_feature_incompat & 0x400) a single extended attribute whose
# value is too large for the inline / external-block value region may be
# stored in its OWN dedicated inode. For such an xattr the entry's
# e_value_inum field (the u32 at entry offset 0x04 that, without this
# feature, is the always-zero e_value_block) names that inode; the value
# bytes are the referenced inode's regular file data (read via the normal
# extent / block-map path) and the value length is that inode's i_size.
# While ext4_ea_inode is 0 the e_value_inum field is ignored entirely, so
# a filesystem WITHOUT the feature reads exactly as before.
ext4_ea_inode: int32 = 0

# INCOMPAT_LARGEDIR mount state. When the superblock declares the feature
# (s_feature_incompat & 0x4000) an htree directory's dx index may grow to
# 3 levels (dx_root.indirect_levels == 2); without it the tree is capped
# at 2 levels (indirect_levels <= 1), exactly as Linux gates it. The WRITE
# path consults this flag before growing a 2-level tree to 3 levels.
ext4_large_dir: int32 = 0

# COMPAT_FAST_COMMIT mount state. When the superblock declares the
# feature (s_feature_compat & 0x400) the journal carries a reserved
# fast-commit tail region; fsync may record a compact per-inode change
# log there (CREAT/UNLINK/INODE/ADD_RANGE/DEL_RANGE/PAD tags ended by a
# crc'd TAIL) and durably commit a single inode without a full JBD2
# transaction. Replay on mount scans the fc region and re-applies the
# tagged changes. While ext4_fast_commit is 0 the fc area is ignored and
# the filesystem behaves exactly as before. See the fast_commit block
# near the end of this file.
ext4_fast_commit: int32 = 0

# #149: journal (JBD2) mount state. s_feature_compat HAS_JOURNAL (0x4)
# and s_journal_inum (sb offset 0xE0) tell us whether a journal exists
# and which inode holds it. ext4_has_journal is 1 once jbd2_attach
# parsed a valid JBD2 superblock from that inode.
ext4_journal_inum: uint32 = 0
ext4_has_journal:  int32  = 0

# Journal logical->physical block map handed to jbd2_attach. The
# journal inode's data blocks are resolved through the extent tree and
# laid out here, indexed by journal logical block. 4096 entries covers
# a 16 MiB journal at 4 KiB blocks / 4 MiB at 1 KiB blocks — enough for
# every image we mint.
EXT4_JOURNAL_MAP_MAX: uint64 = 4096
ext4_journal_map: Array[4096, uint64]

# Scratch block for the #149 journal crash-consistency self-test. Kept
# separate from ext4_blk_buf so the self-test's stage-and-verify dance
# (which reads back via ext4_blk_buf) never clobbers the block it just
# staged. 4 KiB covers both 1 KiB and 4 KiB fs blocks.
ext4_jtest_buf: Array[4096, uint8]

# --- htree (dir_index) hash state ---------------------------------
# Directory hashing for EXT4_INDEX_FL directories. The superblock
# carries the default hash algorithm (s_def_hash_version @ 0xFC), the
# 16-byte hash seed (s_hash_seed[4] @ 0xEC), and a SIGNED/UNSIGNED
# selector in s_flags (@ 0x160). Linux's ext4fs_dirhash() picks
# str2hashbuf_signed by default and adds s_hash_unsigned (3) to the
# hash_version when s_flags requests the unsigned variant.
#   ext4_def_hash_version — s_def_hash_version (0=legacy,1=half_md4,2=tea)
#   ext4_hash_seed[4]     — s_hash_seed[4] (all-zero ⇒ the built-in
#                           0x67452301.. default MD4 IV is used)
#   ext4_hash_unsigned    — 3 when s_flags has UNSIGNED_HASH (bit 0x2),
#                           else 0 (signed; the default on x86).
# These are populated in ext4_init from the live superblock so on-disk
# htree dirs minted by Linux/mke2fs resolve bit-for-bit.
ext4_def_hash_version: uint32 = 1
ext4_hash_seed:        Array[4, uint32]
ext4_hash_unsigned:    uint32 = 0

# Dedicated scratch block for dx_root / dx_node index-block reads during
# an htree descent. Kept SEPARATE from ext4_blk_buf because the leaf
# scan (_ext4_dirblock_lookup) reads the candidate leaf THROUGH
# ext4_blk_buf — re-using the same buffer for the index blocks would
# clobber the dx_entry array mid-descent. 4 KiB covers 1 KiB..4 KiB fs
# blocks; an undersized buffer would overflow into the next BSS global.
ext4_htree_buf: Array[4096, uint8]

# Instrumentation: counts the number of directory DATA (leaf) blocks the
# last lookup actually read. A genuine htree descend lands on ONE leaf
# (plus any collision-chain continuations), whereas the linear fallback
# touches every block. The self-test asserts the htree path read far
# fewer blocks than the linear scan, proving the index was used.
ext4_htree_leaf_reads: uint64 = 0

# --- htree (dir_index) INSERT / leaf-split scratch ----------------
# The WRITE path (ext4_htree_dir_insert + _ext4_htree_do_split) needs
# its OWN block buffers, kept disjoint from ext4_blk_buf (the leaf the
# insert mutates) and ext4_htree_buf (the index node it edits) so a
# split can hold the old leaf, the new leaf and the parent index node
# in flight simultaneously.
#   ext4_htins_oldleaf — the leaf being split (rewritten in place)
#   ext4_htins_newleaf — the freshly allocated sibling leaf
#   ext4_htins_idxbuf  — the dx_root/dx_node index block being edited
# 4 KiB each covers 1 KiB..4 KiB fs blocks; undersizing would overflow
# into the next BSS global (the recurring trap).
ext4_htins_oldleaf: Array[4096, uint8]
ext4_htins_newleaf: Array[4096, uint8]
ext4_htins_idxbuf:  Array[4096, uint8]

# do_split sort map: one (hash, byte-offset, rec_len) triple per live
# dirent in the leaf being split. A 1 KiB block holds at most ~85 8-byte
# records, a 4 KiB block ~340; 512 slots is a safe ceiling for any block
# size we mint. Three parallel arrays avoid a struct.
EXT4_HTINS_MAP_MAX: uint64 = 512
ext4_htins_map_hash: Array[512, uint32]
ext4_htins_map_off:  Array[512, uint16]
ext4_htins_map_rlen: Array[512, uint16]

# Logical block of each frame's index node, recorded during the WRITE
# descent so the parent dx index node can be re-read + edited when a
# leaf split needs a new dx_entry inserted. Frame 0 == dir logical 0.
ext4_htins_frame_logical: Array[8, uint64]
ext4_htins_frame_eoff:    Array[8, uint64]
ext4_htins_frame_at:      Array[8, uint32]
ext4_htins_nframes:       uint32 = 0


def _ext4_read_u16(p: Ptr[uint8]) -> uint16:
    return cast[uint16](p[0]) | (cast[uint16](p[1]) << 8)


def _ext4_read_u32(p: Ptr[uint8]) -> uint32:
    return (cast[uint32](p[0])
            | (cast[uint32](p[1]) << 8)
            | (cast[uint32](p[2]) << 16)
            | (cast[uint32](p[3]) << 24))


# --- metadata_csum (RO_COMPAT_METADATA_CSUM) ----------------------
#
# When the feature is set, ext4 protects each metadata object with a
# crc32c seeded by the filesystem UUID (and, per object, the inode
# number + i_generation). The on-disk register is the RAW running CRC
# (no final xor). These helpers verify on read and recompute on write.
# All of them are no-ops when ext4_metadata_csum == 0, so a filesystem
# without the feature is untouched.


def _ext4_inode_csum(inode_buf: Ptr[uint8], inum: uint64) -> uint32:
    # Compute the crc32c an inode SHOULD carry. The seed chains the
    # fs UUID seed with the inode number and i_generation (both LE32),
    # then folds the entire inode with its checksum fields zeroed.
    #   l_i_checksum_lo  u16 @ 0x7C (osd2.linux2)
    #   i_checksum_hi    u16 @ 0x82 (present only when inode_size > 128
    #                                AND i_extra_isize covers 0x82)
    gen: uint32 = _ext4_read_u32(cast[Ptr[uint8]](cast[uint64](inode_buf)
                                                  + 0x64))
    inum_le: Array[4, uint8]
    _ext4_write_u32(&inum_le[0], cast[uint32](inum))
    gen_le: Array[4, uint8]
    _ext4_write_u32(&gen_le[0], gen)
    seed: uint32 = ext4_csum_seed
    seed = crc32c_update(seed, &inum_le[0], 4)
    seed = crc32c_update(seed, &gen_le[0], 4)
    # Fold the inode with checksum fields temporarily zeroed. Save +
    # restore so the caller's buffer is unperturbed.
    save_lo: uint16 = _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](inode_buf)
                                                      + 0x7C))
    has_hi: int32 = 0
    save_hi: uint16 = 0
    if ext4_inode_size > 128:
        extra: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
            cast[uint64](inode_buf) + 0x80))
        # i_checksum_hi at 0x82 is the 3rd extra-isize word; present
        # when extra_isize reaches it (offset 0x82 - 0x80 + 2 = 4).
        if cast[uint64](extra) >= 4:
            has_hi = 1
            save_hi = _ext4_read_u16(cast[Ptr[uint8]](
                cast[uint64](inode_buf) + 0x82))
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](inode_buf) + 0x7C), 0)
    if has_hi != 0:
        _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](inode_buf) + 0x82), 0)
    c: uint32 = crc32c_update(seed, inode_buf, ext4_inode_size)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](inode_buf) + 0x7C), save_lo)
    if has_hi != 0:
        _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](inode_buf) + 0x82),
                        save_hi)
    return c


def _ext4_inode_stored_csum(inode_buf: Ptr[uint8]) -> uint32:
    # Read the stored checksum out of l_i_checksum_lo (+hi). When the
    # hi half is absent only the low 16 bits are meaningful.
    lo: uint16 = _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](inode_buf)
                                                 + 0x7C))
    hi: uint16 = 0
    if ext4_inode_size > 128:
        extra: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
            cast[uint64](inode_buf) + 0x80))
        if cast[uint64](extra) >= 4:
            hi = _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](inode_buf)
                                                 + 0x82))
    return (cast[uint32](hi) << 16) | cast[uint32](lo)


def _ext4_inode_csum_set(inode_buf: Ptr[uint8], inum: uint64):
    # Recompute and store the inode checksum. No-op unless the feature
    # is on. Called on every inode write so a write→re-read validates.
    if ext4_metadata_csum == 0:
        return
    c: uint32 = _ext4_inode_csum(inode_buf, inum)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](inode_buf) + 0x7C),
                    cast[uint16](c & 0xFFFF))
    if ext4_inode_size > 128:
        extra: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
            cast[uint64](inode_buf) + 0x80))
        if cast[uint64](extra) >= 4:
            _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](inode_buf) + 0x82),
                            cast[uint16]((c >> 16) & 0xFFFF))


def ext4_inode_csum_ok(inode_buf: Ptr[uint8], inum: uint64) -> int32:
    # 1 if the inode's stored checksum matches (or feature off / hi
    # absent makes a half-width compare). Returns 0 on mismatch.
    if ext4_metadata_csum == 0:
        return 1
    want: uint32 = _ext4_inode_csum(inode_buf, inum)
    got:  uint32 = _ext4_inode_stored_csum(inode_buf)
    # When inode_size==128 only the low 16 bits exist on disk.
    if ext4_inode_size <= 128:
        if (want & 0xFFFF) == (got & 0xFFFF):
            return 1
        return 0
    if want == got:
        return 1
    return 0


def _ext4_dirblock_csum_seed(dir_inum: uint64, dir_gen: uint32) -> uint32:
    seed: uint32 = ext4_csum_seed
    inum_le: Array[4, uint8]
    _ext4_write_u32(&inum_le[0], cast[uint32](dir_inum))
    gen_le: Array[4, uint8]
    _ext4_write_u32(&gen_le[0], dir_gen)
    seed = crc32c_update(seed, &inum_le[0], 4)
    seed = crc32c_update(seed, &gen_le[0], 4)
    return seed


def _ext4_dirblock_csum(block_buf: Ptr[uint8], dir_inum: uint64,
                        dir_gen: uint32) -> uint32:
    # crc32c over the directory block EXCLUDING its 12-byte
    # ext4_dir_entry_tail, seeded by uuid+inum+generation. The tail's
    # det_checksum (last u32 of the block) stores this value.
    seed: uint32 = _ext4_dirblock_csum_seed(dir_inum, dir_gen)
    return crc32c_update(seed, block_buf, ext4_block_size - 12)


def ext4_dirblock_csum_ok(block_buf: Ptr[uint8], dir_inum: uint64,
                          dir_gen: uint32) -> int32:
    # Verify a directory leaf block that carries a dir_entry_tail. A
    # tail is a fake entry at block_size-12 with inode==0, rec_len==12,
    # name_len==0, file_type==0xDE; its last u32 is det_checksum. Blocks
    # without a recognisable tail (e.g. htree index blocks) are skipped
    # (return 1) — only verify what actually carries a checksum.
    if ext4_metadata_csum == 0:
        return 1
    tail: uint64 = cast[uint64](block_buf) + ext4_block_size - 12
    t_inode:   uint32 = _ext4_read_u32(cast[Ptr[uint8]](tail + 0))
    t_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](tail + 4))
    t_ft:      uint8  = cast[Ptr[uint8]](tail + 7)[0]
    if t_inode != 0 or t_rec_len != 12 or t_ft != 0xDE:
        return 1                                # not a checksummed tail
    stored: uint32 = _ext4_read_u32(cast[Ptr[uint8]](tail + 8))
    if _ext4_dirblock_csum(block_buf, dir_inum, dir_gen) == stored:
        return 1
    return 0


def ext4_dirblock_csum_set(block_buf: Ptr[uint8], dir_inum: uint64,
                           dir_gen: uint32):
    # Stamp the dir_entry_tail's det_checksum. No-op unless the feature
    # is on and the block already carries a recognisable tail.
    if ext4_metadata_csum == 0:
        return
    tail: uint64 = cast[uint64](block_buf) + ext4_block_size - 12
    t_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](tail + 4))
    t_ft:      uint8  = cast[Ptr[uint8]](tail + 7)[0]
    if t_rec_len != 12 or t_ft != 0xDE:
        return
    c: uint32 = _ext4_dirblock_csum(block_buf, dir_inum, dir_gen)
    _ext4_write_u32(cast[Ptr[uint8]](tail + 8), c)


def _ext4_dirblock_stamp_in_buf(parent_inum: uint64, parent_gen: uint32):
    # Restamp the dir_entry_tail checksum in ext4_blk_buf (the scratch
    # the dirent-insert/unlink paths mutate a directory block in) before
    # it is written back, so a metadata_csum directory write keeps the
    # block's tail checksum valid. No-op without the feature.
    #
    # The seed needs the parent's inode number AND i_generation; callers
    # pass the generation directly (read out of the parent-inode buffer
    # they already hold) because the only other source — ext4_read_inode —
    # reads through ext4_blk_buf, which is the very buffer holding the
    # mutated directory block we're about to checksum and write. Reading
    # the inode here would clobber it. Passing parent_gen keeps this
    # buffer-safe.
    if ext4_metadata_csum == 0:
        return
    ext4_dirblock_csum_set(&ext4_blk_buf[0], parent_inum, parent_gen)


def _ext4_sb_csum() -> uint32:
    # crc32c over the on-disk superblock image in ext4_sb_buf MINUS the
    # trailing 4-byte s_checksum. RAW register (no final xor).
    return crc32c_update(0xFFFFFFFF, &ext4_sb_buf[0], EXT4_SB_OFF_CHECKSUM)


def ext4_sb_csum_ok() -> int32:
    if ext4_metadata_csum == 0:
        return 1
    stored: uint32 = _ext4_read_u32(cast[Ptr[uint8]](
        cast[uint64](&ext4_sb_buf[0]) + EXT4_SB_OFF_CHECKSUM))
    if _ext4_sb_csum() == stored:
        return 1
    return 0


# The metadata_csum self-test reads the root directory's first data
# block; keep a dedicated scratch so it never collides with the buffers
# the verification helpers themselves chase through.
ext4_csum_test_buf: Array[4096, uint8]


def _ext4_csum_run_selftest():
    # Driven from ext4_init() ONLY when the mounted fs declares
    # metadata_csum. Proves, on a real image, that:
    #   (a) the crc32c KAT passes,
    #   (b) the superblock checksum verifies,
    #   (c) a real inode checksum verifies,
    #   (d) a real directory-block checksum verifies,
    #   (e) corruption is DETECTED (negative test),
    #   (f) a recompute→re-read round-trip yields a valid checksum.
    # Each step prints a [ext4csum] line; a final [ext4csum] PASS only
    # if every step passed. Logging is gated on the feature, so a
    # normal (no-csum) boot stays quiet.
    ok_all: int32 = 1

    # (a) crc32c known-answer test.
    if crc32c_selftest() != 0:
        printk0("[ext4csum] PASS verify-crc32c-kat (crc32c('123456789')=0xE3069283)\n")
    else:
        printk0("[ext4csum] FAIL verify-crc32c-kat\n")
        ok_all = 0

    # (b) superblock checksum.
    if ext4_sb_csum_ok() != 0:
        printk0("[ext4csum] PASS verify-superblock\n")
    else:
        printk0("[ext4csum] FAIL verify-superblock\n")
        ok_all = 0

    # (c) inode checksum — read the root inode (#2) and verify.
    ino: Array[256, uint8]
    if ext4_read_inode(2, &ino[0]) == 0:
        if ext4_inode_csum_ok(&ino[0], 2) != 0:
            printk0("[ext4csum] PASS verify-inode (root inode #2)\n")
        else:
            printk0("[ext4csum] FAIL verify-inode\n")
            ok_all = 0
    else:
        printk0("[ext4csum] FAIL verify-inode (read failed)\n")
        ok_all = 0

    # (d) directory-block checksum — root dir's first data block.
    dir_gen: uint32 = _ext4_read_u32(cast[Ptr[uint8]](cast[uint64](&ino[0])
                                                      + 0x64))
    dblk: uint64 = _ext4_logical_to_physical(&ino[0], 0)
    dirblk_ok: int32 = 0
    if dblk != 0:
        if _ext4_read_block(dblk, &ext4_csum_test_buf[0]) == 0:
            if ext4_dirblock_csum_ok(&ext4_csum_test_buf[0], 2, dir_gen) != 0:
                printk0("[ext4csum] PASS verify-dirblock (root dir block)\n")
                dirblk_ok = 1
            else:
                printk0("[ext4csum] FAIL verify-dirblock\n")
                ok_all = 0
    if dirblk_ok == 0 and dblk == 0:
        printk0("[ext4csum] FAIL verify-dirblock (no root data block)\n")
        ok_all = 0

    # (e) negative test: flip a byte in the dir block in RAM and confirm
    # the checksum no longer matches (corruption is DETECTED). Restore
    # the byte afterwards so nothing is written back corrupt.
    if dirblk_ok != 0:
        victim: uint8 = ext4_csum_test_buf[0]
        ext4_csum_test_buf[0] = victim ^ cast[uint8](0xFF)
        if ext4_dirblock_csum_ok(&ext4_csum_test_buf[0], 2, dir_gen) == 0:
            printk0("[ext4csum] PASS detect-corruption (flipped byte rejected)\n")
        else:
            printk0("[ext4csum] FAIL detect-corruption (mutation undetected)\n")
            ok_all = 0
        ext4_csum_test_buf[0] = victim

    # (f) write/recompute round-trip: zero the checksum register in a
    # copy, recompute it via the writer path, then verify the reader
    # accepts it — proving the writer reproduces the on-disk value.
    if ext4_read_inode(2, &ino[0]) == 0:
        _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](&ino[0]) + 0x7C), 0)
        if ext4_inode_size > 128:
            _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](&ino[0]) + 0x82), 0)
        _ext4_inode_csum_set(&ino[0], 2)
        if ext4_inode_csum_ok(&ino[0], 2) != 0:
            printk0("[ext4csum] PASS roundtrip-inode (recompute matches)\n")
        else:
            printk0("[ext4csum] FAIL roundtrip-inode\n")
            ok_all = 0
    else:
        printk0("[ext4csum] FAIL roundtrip-inode (read failed)\n")
        ok_all = 0

    if ok_all != 0:
        printk0("[ext4csum] PASS\n")
    else:
        printk0("[ext4csum] FAIL\n")


def ext4_init(slot: int32) -> int32:
    # Read the 1024-byte superblock from sectors 2..3 of the block
    # device. Returns 0 on success, -1 on read failure / wrong magic.
    rc: int32 = blk_read_sectors(slot, 2, 2, &ext4_sb_buf[0])
    if rc != 0:
        printk0("ext4: failed to read superblock\n")
        return -1

    sb: Ptr[uint8] = &ext4_sb_buf[0]
    magic: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x38))
    if magic != EXT4_MAGIC:
        printk1("ext4: bad magic %x (not an ext2/3/4 fs)\n",
                cast[uint64](magic))
        return -1

    log_block_size: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x18))
    ext4_block_size      = cast[uint64](1024) << cast[uint64](log_block_size)
    ext4_inodes_count    = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x00)))
    ext4_blocks_count    = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x04)))
    ext4_first_data_blk  = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x14)))
    ext4_blocks_per_grp  = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x20)))
    ext4_inodes_per_grp  = cast[uint64](_ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x28)))
    ext4_inode_size      = cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x58)))
    if ext4_inode_size == 0:
        ext4_inode_size = 128                  # ext2 default
    ext4_desc_size       = cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](sb) + 0xFE)))
    if ext4_desc_size == 0:
        ext4_desc_size = 32                    # legacy default
    ext4_gdt_block = ext4_first_data_blk + 1

    # #149: read the journal feature flag + journal inode number from
    # the superblock so the post-mount journal hookup knows whether to
    # look for a JBD2 journal and where it lives.
    feature_compat: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x5C))
    if (feature_compat & 0x4) != 0:
        ext4_journal_inum = _ext4_read_u32(
            cast[Ptr[uint8]](cast[uint64](sb) + 0xE0))
        if ext4_journal_inum == 0:
            ext4_journal_inum = 8          # JBD2 convention
    else:
        ext4_journal_inum = 0

    # COMPAT_FAST_COMMIT: the journal carries a reserved fast-commit tail.
    # Arm the fast-commit write/replay layer. A no-feature image leaves
    # ext4_fast_commit 0 and the fc area is never touched.
    ext4_fast_commit = 0
    if (feature_compat & EXT4_FEATURE_COMPAT_FAST_COMMIT) != 0:
        ext4_fast_commit = 1
        printk0("ext4: COMPAT_FAST_COMMIT present; fast-commit log armed\n")

    # RO_COMPAT_METADATA_CSUM: when the superblock declares the feature
    # (s_feature_ro_compat & 0x400) build the per-fs checksum seed from
    # s_uuid (offset 0x68, 16 bytes) and arm verification. The seed is
    # the RAW running register crc32c_update(~0, uuid, 16) that every
    # per-object inode / dir-block checksum chains onto. We also gate on
    # the crc32c KAT so a broken crc primitive never silently "passes"
    # verification. A no-feature filesystem leaves ext4_metadata_csum 0
    # and behaves exactly as before.
    ext4_metadata_csum = 0
    ext4_csum_seed = 0
    ro_compat: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + EXT4_SB_OFF_FEATURE_RO_COMPAT))
    if (ro_compat & EXT4_FEATURE_RO_COMPAT_METADATA_CSUM) != 0:
        if crc32c_selftest() != 0:
            ext4_csum_seed = crc32c_update(
                0xFFFFFFFF,
                cast[Ptr[uint8]](cast[uint64](sb) + EXT4_SB_OFF_UUID), 16)
            ext4_metadata_csum = 1
        else:
            printk0("ext4: crc32c KAT failed; metadata_csum verify disabled\n")

    # INCOMPAT_INLINE_DATA: when the superblock declares the feature
    # (s_feature_incompat & 0x8000) tiny files/dirs may store their data
    # directly inside the inode (i_block[] + the system.data xattr)
    # instead of in data blocks. We arm read support; a no-feature image
    # leaves ext4_inline_data 0 and the per-inode inline flag is ignored.
    ext4_inline_data = 0
    incompat_feat: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + EXT4_SB_OFF_FEATURE_INCOMPAT))
    if (incompat_feat & EXT4_FEATURE_INCOMPAT_INLINE_DATA) != 0:
        ext4_inline_data = 1
        printk0("ext4: INCOMPAT_INLINE_DATA present; inline read path armed\n")

    # htree (dir_index) hash parameters. s_def_hash_version (0xFC, 1 byte)
    # selects the algorithm; s_hash_seed[4] (0xEC, 16 bytes) is the
    # per-fs MD4/TEA seed; s_flags (0x160) bit 0x2 = UNSIGNED_HASH ⇒
    # add 3 to the version (the unsigned str2hashbuf variant), bit 0x1 =
    # SIGNED_HASH ⇒ the default signed variant. This mirrors Linux
    # ext4_fill_super so on-disk htree dirs resolve bit-for-bit.
    ext4_def_hash_version = cast[uint32](
        cast[Ptr[uint8]](cast[uint64](sb) + 0xFC)[0])
    h_i: uint64 = 0
    while h_i < 4:
        ext4_hash_seed[h_i] = _ext4_read_u32(
            cast[Ptr[uint8]](cast[uint64](sb) + 0xEC + h_i * 4))
        h_i = h_i + 1
    sb_flags: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](sb) + 0x160))
    if (sb_flags & EXT4_FLAGS_UNSIGNED_HASH) != 0:
        ext4_hash_unsigned = 3
    else:
        ext4_hash_unsigned = 0

    # RO_COMPAT_BIGALLOC: when the superblock declares the feature
    # (s_feature_ro_compat & 0x200) the unit of block allocation/accounting
    # is a CLUSTER = block_size << (s_log_cluster_size - s_log_block_size),
    # and each group's "block bitmap" is a CLUSTER bitmap of
    # s_clusters_per_group bits. Extents still record physical BLOCK
    # numbers, so the file-data read path is untouched — only bitmap /
    # free-cluster math becomes per-cluster. A no-feature image leaves
    # ext4_bigalloc 0 with cluster_ratio 1 / cluster_size == block_size, so
    # every existing block-level computation is bit-for-bit unchanged.
    ext4_bigalloc = 0
    ext4_log_cluster_size = cast[uint64](log_block_size)
    ext4_cluster_size = ext4_block_size
    ext4_cluster_ratio = 1
    ext4_clusters_per_grp = ext4_blocks_per_grp
    if (ro_compat & EXT4_FEATURE_RO_COMPAT_BIGALLOC) != 0:
        ext4_bigalloc = 1
        ext4_log_cluster_size = cast[uint64](_ext4_read_u32(
            cast[Ptr[uint8]](cast[uint64](sb)
                             + EXT4_SB_OFF_LOG_CLUSTER_SIZE)))
        # cluster_size = 1024 << log_cluster_size (mirrors block_size).
        ext4_cluster_size = cast[uint64](1024) << ext4_log_cluster_size
        # blocks per cluster: cluster_size / block_size. log_cluster_size
        # >= log_block_size on a valid bigalloc image, so this is >= 1.
        ext4_cluster_ratio = ext4_cluster_size / ext4_block_size
        if ext4_cluster_ratio == 0:
            ext4_cluster_ratio = 1
        ext4_clusters_per_grp = cast[uint64](_ext4_read_u32(
            cast[Ptr[uint8]](cast[uint64](sb)
                             + EXT4_SB_OFF_CLUSTERS_PER_GROUP)))
        # Defensive fallback: a malformed/zero s_clusters_per_group is
        # derivable from blocks_per_group / cluster_ratio.
        if ext4_clusters_per_grp == 0:
            ext4_clusters_per_grp = ext4_blocks_per_grp / ext4_cluster_ratio
        printk2("ext4: RO_COMPAT_BIGALLOC present; cluster_size=%d ratio=%d\n",
                ext4_cluster_size, ext4_cluster_ratio)
        printk1("ext4:   clusters_per_group=%d\n", ext4_clusters_per_grp)

    # INCOMPAT_64BIT: with a 64-byte group descriptor the bitmap /
    # inode-table block numbers carry a high 32-bit half (offsets
    # 0x20/0x24/0x28). Arm the lo+hi combine in the descriptor-field
    # reader. A 32-bit image leaves ext4_64bit 0 so only the lo half is
    # read — bit-for-bit the historical behaviour. We additionally
    # require a >=64-byte descriptor before trusting the hi area, since
    # the hi fields physically don't exist in a 32-byte descriptor.
    ext4_64bit = 0
    if (incompat_feat & EXT4_FEATURE_INCOMPAT_64BIT) != 0 \
       and ext4_desc_size >= 64:
        ext4_64bit = 1

    # INCOMPAT_FLEX_BG: the bitmaps + inode tables of a run of
    # 2^s_log_groups_per_flex consecutive groups are packed into the
    # flex group's leader. The descriptors already store the relocated
    # locations, and every read path here trusts the descriptor fields,
    # so reading a flex_bg image is correct as long as those fields are
    # read in full (lo+hi via ext4_64bit above). We record the feature
    # and the flex size for diagnostics; a no-feature image leaves
    # ext4_flex_bg 0 and reads exactly as before.
    ext4_flex_bg = 0
    ext4_log_groups_per_flex = 0
    if (incompat_feat & EXT4_FEATURE_INCOMPAT_FLEX_BG) != 0:
        ext4_flex_bg = 1
        lgpf: uint8 = cast[Ptr[uint8]](cast[uint64](sb)
            + EXT4_SB_OFF_LOG_GROUPS_PER_FLEX)[0]
        ext4_log_groups_per_flex = cast[uint64](lgpf)
        printk1("ext4: INCOMPAT_FLEX_BG present; log_groups_per_flex=%d\n",
                ext4_log_groups_per_flex)
        printk0("ext4:   metadata located via descriptor fields (flex-aware)\n")

    # INCOMPAT_EA_INODE: an xattr value too big for the inline / external
    # block value region is stored in its own inode, named by the entry's
    # e_value_inum field. Arm the xattr read path to follow e_value_inum.
    # A no-feature image leaves ext4_ea_inode 0 and the field is ignored.
    ext4_ea_inode = 0
    if (incompat_feat & EXT4_FEATURE_INCOMPAT_EA_INODE) != 0:
        ext4_ea_inode = 1
        printk0("ext4: INCOMPAT_EA_INODE present; ea-inode xattr read armed\n")

    # INCOMPAT_LARGEDIR: htree dir index may grow to 3 levels. Without the
    # feature the write path caps growth at 2 levels (indirect_levels<=1),
    # exactly as Linux gates dx index growth. Read paths descend whatever
    # depth the on-disk dx_root declares (a malformed indirect_levels>=2 on
    # a no-largedir image is rejected by the descend's structural checks).
    ext4_large_dir = 0
    if (incompat_feat & EXT4_FEATURE_INCOMPAT_LARGEDIR) != 0:
        ext4_large_dir = 1
        printk0("ext4: INCOMPAT_LARGEDIR present; 3-level htree growth armed\n")

    ext4_blockdev_slot = slot
    # Bind this volume at /ext in the VFS mount table so vfs_open/listdir/
    # stat/... route /ext/* to the ext4 backend by longest-prefix match
    # (replaces the old is_ext_path strcmp). Idempotent across the kernel's
    # many ext4_init call sites (single-mount model: last mount wins).
    vfs_mount_ext4()
    printk2("ext4: mounted; block_size=%d inodes_count=%d\n",
            ext4_block_size, ext4_inodes_count)
    printk2("ext4:   blocks_per_group=%d inodes_per_group=%d\n",
            ext4_blocks_per_grp, ext4_inodes_per_grp)
    printk2("ext4:   first_data_block=%d inode_size=%d\n",
            ext4_first_data_blk, ext4_inode_size)

    # #149: detect + attach + recover the journal. A no-journal image
    # (^has_journal) leaves ext4_has_journal at 0 and the FS behaves
    # exactly as before. A journalled image parses its JBD2 superblock
    # and replays any uncheckpointed transactions before we return.
    _ext4_journal_setup()

    # RO_COMPAT_METADATA_CSUM self-test. Runs ONLY on a metadata_csum
    # filesystem (the seed/feature were armed above); a normal no-csum
    # boot skips it entirely and emits no [ext4csum] lines. Verifies the
    # superblock, an inode, and a directory block on read, proves
    # corruption is detected, and round-trips a recompute.
    if ext4_metadata_csum != 0:
        _ext4_csum_run_selftest()
    return 0


def _ext4_journal_setup() -> int32:
    # Build the journal inode's logical->physical block map and hand it
    # to jbd2_attach, then run recovery. Returns 0 on success / no
    # journal, -1 only if a journal exists but its superblock is bad.
    ext4_has_journal = 0
    if ext4_journal_inum == 0:
        printk0("ext4: no journal (has_journal feature off)\n")
        return 0
    # Read the journal inode to learn its size (journal length).
    jino: Array[256, uint8]
    if ext4_read_inode(cast[uint64](ext4_journal_inum), &jino[0]) != 0:
        printk0("ext4: failed to read journal inode\n")
        return -1
    jsize: uint64 = cast[uint64](ext4_inode_size_lo(&jino[0]))
    # Some ext4 images keep the high 32 bits of journal size in
    # i_size_high (offset 0x6C); the journals we mint are well under
    # 4 GiB so the lo word is authoritative.
    njblocks: uint64 = jsize / ext4_block_size
    if njblocks == 0 or njblocks > EXT4_JOURNAL_MAP_MAX:
        printk1("ext4: journal block count %d out of range\n", njblocks)
        return -1
    # Resolve every journal logical block to its physical fs block via
    # the journal inode's extent tree.
    lb: uint64 = 0
    while lb < njblocks:
        phys: uint64 = _ext4_logical_to_physical(&jino[0], lb)
        if phys == 0:
            printk1("ext4: journal lblk %d unmapped\n", lb)
            return -1
        ext4_journal_map[lb] = phys
        lb = lb + 1
    if jbd2_attach(ext4_blockdev_slot, ext4_block_size,
                   &ext4_journal_map[0], njblocks) != 0:
        printk0("ext4: jbd2_attach failed (journal superblock bad)\n")
        return -1
    ext4_has_journal = 1
    # COMPAT_FAST_COMMIT: reserve the journal's tail blocks for the
    # fine-grained fast-commit log now that the journal geometry is known.
    if ext4_fast_commit != 0:
        jbd2_fc_enable()
        printk1("ext4: fast-commit tail reserved (%d journal blocks)\n",
                jbd2_fc_blocks())
    printk0("ext4: journal attached (JBD2)\n")
    # Replay any committed-but-uncheckpointed transactions left by an
    # unclean shutdown. On a clean journal this is a no-op.
    jbd2_recover()
    # COMPAT_FAST_COMMIT: after the full-journal replay, scan the reserved
    # fast-commit tail and re-apply any durably-recorded per-inode changes
    # whose full transaction never landed. No-op when the feature is off
    # or the fc region is empty/clean.
    if ext4_fast_commit != 0:
        _ext4_fc_replay()
    return 0


def ext4_journal_active() -> int32:
    # 1 if a JBD2 journal is mounted and ready to wrap metadata writes.
    if ext4_has_journal != 0 and jbd2_is_attached() != 0:
        return 1
    return 0


def ext4_is_mounted() -> int32:
    if ext4_blockdev_slot < 0:
        return 0
    return 1


# Scratch buffer for one filesystem block. Sized to cover the 4 KiB
# blocks ext4_mkfs produces (M16.x) AND the 1 KiB blocks the existing
# test image uses. Larger block sizes (16 KiB+) would need bumping or
# a slab allocation per call.
ext4_blk_buf: Array[4096, uint8]

# Separate scratch for the extent-tree walk. _ext4_logical_to_physical
# is called by ext4_read_file just BEFORE that function reads the
# physical data block into ext4_blk_buf — so reusing the same buffer
# for index-node reads would race with the data read on the same
# iteration. Same 4 KiB sizing as ext4_blk_buf.
ext4_ext_scratch: Array[4096, uint8]


def _ext4_read_block(block_nr: uint64, buf: Ptr[uint8]) -> int32:
    # Read filesystem block `block_nr` into `buf`. Always reads
    # exactly ext4_block_size bytes (2 sectors for 1 KiB, 8 sectors
    # for 4 KiB).
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    lba: uint64 = block_nr * sectors_per_block
    return blk_read_sectors(ext4_blockdev_slot, lba, sectors_per_block, buf)


def _ext4_write_block(block_nr: uint64, buf: Ptr[uint8]) -> int32:
    # Symmetric write. Used for bitmap updates and (eventually)
    # data block writes during file create / extend.
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    lba: uint64 = block_nr * sectors_per_block
    return blk_write_sectors(ext4_blockdev_slot, lba, sectors_per_block, buf)


def _ext4_journal_write_block(block_nr: uint64, buf: Ptr[uint8]) -> int32:
    # #149: write a single METADATA block crash-consistently. When a
    # JBD2 journal is mounted, the new block contents are first logged
    # (descriptor + data + commit) and only then checkpointed to the
    # final location — so a crash either leaves the OLD block intact
    # (commit never reached the journal) or recovers the NEW block
    # (commit landed, replay finishes the checkpoint). With no journal
    # this degrades to a straight-through _ext4_write_block, matching
    # the historical no-journal behaviour.
    #
    # This is ordered/metadata-mode journaling: only metadata blocks
    # flow through here. File DATA is written straight to its final home
    # by the ext4 write path BEFORE the metadata transaction commits.
    if ext4_journal_active() == 0:
        return _ext4_write_block(block_nr, buf)
    if jbd2_txn_begin() != 0:
        # Journal busy / unusable — fall back rather than lose the write.
        return _ext4_write_block(block_nr, buf)
    if jbd2_txn_add(block_nr, buf) != 0:
        jbd2_txn_abort()
        return _ext4_write_block(block_nr, buf)
    if jbd2_txn_commit() != 0:
        return _ext4_write_block(block_nr, buf)
    return jbd2_txn_checkpoint()


def ext4_read_inode(inum: uint64, out: Ptr[uint8]) -> int32:
    # Locate inode `inum` (1-indexed, like Linux) via the standard
    # ext4 lookup pattern: pick its block group, read that group's
    # descriptor to find bg_inode_table_lo, then index into the
    # inode table by (inum-1) mod inodes_per_group.
    if inum == 0 or inum > ext4_inodes_count:
        return -1

    grp:    uint64 = (inum - 1) / ext4_inodes_per_grp
    idx:    uint64 = (inum - 1) % ext4_inodes_per_grp

    # Find this group's inode table from its descriptor's bg_inode_table
    # field (lo @ 0x08, hi @ 0x28 on 64BIT). This descriptor-supplied
    # location is authoritative: on a flex_bg image the inode tables of
    # a whole flex group are packed into the leader group, so inodes
    # living in a non-zero group resolve to a table block in a DIFFERENT
    # group than `grp`. Computing a fixed per-group layout here would be
    # wrong for flex_bg; reading the descriptor field is correct for
    # both flex and non-flex images.
    inode_table_block: uint64 = _ext4_group_desc_block_u64(
        grp, EXT4_BG_INODE_TABLE_LO, EXT4_BG_INODE_TABLE_HI)
    if inode_table_block == 0:
        return -1

    # Read the inode table block(s) holding inode `inum` and copy
    # the inode_size bytes into the caller's buffer.
    inode_byte: uint64 = inode_table_block * ext4_block_size \
                       + idx * ext4_inode_size
    sec_lba:   uint64 = inode_byte / SECTOR_SIZE
    sec_off:   uint64 = inode_byte % SECTOR_SIZE
    # Up to 256 bytes can span at most one sector boundary (sectors
    # are 512 bytes); read 2 sectors to be safe regardless of off.
    if blk_read_sectors(ext4_blockdev_slot, sec_lba, 2,
                        &ext4_blk_buf[0]) != 0:
        return -1
    src: uint64 = cast[uint64](&ext4_blk_buf[0]) + sec_off
    memcpy(out, cast[Ptr[uint8]](src), ext4_inode_size)
    return 0


def ext4_inode_mode(buf: Ptr[uint8]) -> uint16:
    # struct ext4_inode.i_mode at offset 0.
    return _ext4_read_u16(buf)


def ext4_path_mode(path: Ptr[char]) -> int32:
    # Resolve `path` (the post-/ext/-strip tail, e.g. "bin/busybox" or
    # "" for root) to its inode and return the full i_mode word (the
    # S_IF* type bits OR'd with the low-9 rwx permission bits). Returns
    # -1 if the path does not resolve or ext4 is not mounted. This is a
    # READ-ONLY accessor used by the Linux-ABI access(2) handler to do a
    # real R/W/X permission check against the file's mode bits — it is
    # the only path→i_mode bridge in ext4.ad and follows symlinks the
    # same way ext4_resolve_file / ext4_resolve_dir do.
    if ext4_blockdev_slot < 0:
        return -1
    r: Ext4ResolveResult
    if _resolve_with_symlinks(path, &r) == 0:
        return -1
    inode_buf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](r.inum), &inode_buf[0]) != 0:
        return -1
    return cast[int32](ext4_inode_mode(&inode_buf[0]))


def ext4_inode_size_lo(buf: Ptr[uint8]) -> uint32:
    # struct ext4_inode.i_size_lo at offset 4.
    return _ext4_read_u32(cast[Ptr[uint8]](cast[uint64](buf) + 4))


# struct ext4_inode.i_flags is a u32 at offset 0x20. EXT4_INDEX_FL
# (0x1000) marks a directory whose entries are organised as a hashed
# B-tree (htree / dir_index) rather than a flat linear list. Such a
# directory is resolved by REAL htree hash descent: ext4_dir_lookup
# hashes the name (ext4_dirhash, Linux-compatible) and walks the
# dx_root/dx_node index to the ONE indexed leaf block. See
# ext4_dir_lookup_htree. The linear all-block scan is retained as a
# fallback (and for verification): htree index blocks each begin with a
# single fake ext4_dir_entry_2 whose rec_len pads to end-of-block, so a
# strictly bounded linear scan naturally skips them and harvests only
# real leaf entries. See _ext4_dirblock_lookup.
INODE_I_FLAGS_OFFSET: uint64 = 0x20           # i_flags
EXT4_INDEX_FL:        uint32 = 0x1000         # dir uses htree index
# s_flags bits (superblock 0x160). UNSIGNED_HASH adds 3 to the dirhash
# version so the unsigned str2hashbuf variant is used; SIGNED_HASH (0x1)
# is the default signed variant.
EXT4_FLAGS_SIGNED_HASH:   uint32 = 0x1
EXT4_FLAGS_UNSIGNED_HASH: uint32 = 0x2
# Dirhash algorithm ids (s_def_hash_version / dx_root_info.hash_version).
EXT4_DX_HASH_LEGACY:          uint32 = 0
EXT4_DX_HASH_HALF_MD4:        uint32 = 1
EXT4_DX_HASH_TEA:             uint32 = 2
EXT4_DX_HASH_LEGACY_UNSIGNED: uint32 = 3
EXT4_DX_HASH_HALF_MD4_UNSIGNED: uint32 = 4
EXT4_DX_HASH_TEA_UNSIGNED:    uint32 = 5
# EXT4_HTREE_EOF_32BIT = (1<<31)-1; a hash that collides with the EOF
# sentinel (after <<1) is nudged down by one so it never equals EOF.
EXT4_HTREE_EOF_32BIT: uint32 = 0x7FFFFFFF
# EXT4_INODE_INLINE_DATA: inode's data lives inside the inode itself
# (i_block[] + system.data xattr) rather than in data blocks. Only
# meaningful when the filesystem carries INCOMPAT_INLINE_DATA.
EXT4_INLINE_DATA_FL:  uint32 = 0x10000000
# EXT4_VERITY_FL: the file's data is protected by a built-in, read-only
# Merkle hash tree (fs-verity). Once set, every read of the file's data
# is verified against a salted-SHA-256 Merkle tree rooted at a trusted
# root hash; any tampering with the data OR the hash tree makes the read
# fail (EIO). Matches Linux's EXT4_VERITY_FL (0x00100000). Only meaningful
# when the verity registry holds the inode's tree (ext4_verity_enable).
EXT4_VERITY_FL:       uint32 = 0x00100000
# EXT4_ENCRYPT_FL: the file's data is stored ENCRYPTED at rest (fscrypt).
# Once set, every data block is AES-256-XTS-transformed under a per-file
# content key (the file logical block number is the XTS tweak) before it
# hits the backing device, and decrypted transparently on read. Matches
# Linux's EXT4_ENCRYPT_FL (0x00000800). Only meaningful when the fscrypt
# registry holds the inode's content key (ext4_fscrypt_set_policy).
EXT4_ENCRYPT_FL:      uint32 = 0x00000800

# The in-inode portion of inline data starts at the i_block[] window
# (inode offset 0x28) and is at most 60 bytes (the i_block[] size).
EXT4_INLINE_IBLOCK_OFF:  uint64 = 0x28
EXT4_INLINE_IBLOCK_MAX:  uint64 = 60


def ext4_inode_flags(buf: Ptr[uint8]) -> uint32:
    return _ext4_read_u32(cast[Ptr[uint8]](cast[uint64](buf)
                                           + INODE_I_FLAGS_OFFSET))


def ext4_inode_is_htree_dir(buf: Ptr[uint8]) -> int32:
    if (ext4_inode_flags(buf) & EXT4_INDEX_FL) != 0:
        return 1
    return 0


def ext4_inode_is_inline(buf: Ptr[uint8]) -> int32:
    # 1 if this inode stores its data inline (feature armed AND the
    # per-inode EXT4_INODE_INLINE_DATA flag is set). Gated on the
    # mount-time feature flag so non-inline images behave exactly as
    # before even if some inode spuriously carries the bit.
    if ext4_inline_data == 0:
        return 0
    if (ext4_inode_flags(buf) & EXT4_INLINE_DATA_FL) != 0:
        return 1
    return 0


# docs/security.md Phase 5: ext4 inode owner/group accessors. Layout
# is the standard ext4 / ext2 inode struct:
#   offset 0x02  i_uid       (u16 — low 16 bits of UID)
#   offset 0x18  i_gid       (u16 — low 16 bits of GID)
#   offset 0x7C  i_uid_high  (u16 — high 16 bits, only meaningful when
#                              s_inode_size >= 256)
#   offset 0x7E  i_gid_high  (u16)
# Hamnix uses 32-bit uids (uid 1 = hostowner, 1000+ = regular users)
# which fit in 16 bits, so the *_high halves stay 0 in practice. The
# helpers still synthesise the full 32-bit value to stay forward-
# compatible with any 32-bit-uid filesystem we read.


def ext4_inode_uid(buf: Ptr[uint8]) -> uint32:
    lo: uint16 = _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x02))
    hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x7C))
    return (cast[uint32](hi) << 16) | cast[uint32](lo)


def ext4_inode_gid(buf: Ptr[uint8]) -> uint32:
    lo: uint16 = _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x18))
    hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x7E))
    return (cast[uint32](hi) << 16) | cast[uint32](lo)


def ext4_inode_set_uid(buf: Ptr[uint8], uid: uint32):
    # Stamp uid into the inode buffer. Splits across i_uid (low 16) and
    # i_uid_high (high 16) per the standard ext4 layout. Phase 6 uses
    # this on inode-create paths.
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x02),
                    cast[uint16](uid & 0xFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x7C),
                    cast[uint16]((uid >> 16) & 0xFFFF))


def ext4_inode_set_gid(buf: Ptr[uint8], gid: uint32):
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x18),
                    cast[uint16](gid & 0xFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](buf) + 0x7E),
                    cast[uint16]((gid >> 16) & 0xFFFF))


def ext4_inode_set_mode(buf: Ptr[uint8], mode: uint16):
    _ext4_write_u16(buf, mode)


def ext4_inode_owner_at(inum: uint32, uid_out: Ptr[uint32],
                        gid_out: Ptr[uint32], mode_out: Ptr[uint16]) -> int32:
    # Read inode `inum` and decompose its owner/group/mode into the
    # caller's out-pointers. Returns 0 on success, -1 if the inode read
    # itself failed (volume not mounted, bad inum, I/O error).
    if ext4_blockdev_slot < 0:
        return -1
    if inum == 0:
        return -1
    ino_buf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &ino_buf[0]) != 0:
        return -1
    uid_out[0] = ext4_inode_uid(&ino_buf[0])
    gid_out[0] = ext4_inode_gid(&ino_buf[0])
    mode_out[0] = ext4_inode_mode(&ino_buf[0])
    return 0


# --- F3 #448: ext4-side perm-check op ------------------------------
#
# The ext4 server's permission policy is OWNED HERE — the kernel vfs
# delegates via `chan_permission_check` → `_perm_check_ext4`
# (fs/vfs.ad), which calls into this function. The on-disk uid/gid +
# 9 mode bits are an ext4 implementation detail; vfs has no business
# knowing about them. Returns 0 on grant, -1 (== EPERM_PERM in vfs.ad)
# on denial. A non-existent file returns 0 — vfs's open path will
# surface ENOENT, not synthesise a permission error here.
#
# `want`: PERM_R(4) | PERM_W(2) | PERM_X(1), any combination, same as
# the vfs constants. We don't import them to avoid a fs.ext4 ←→ fs.vfs
# cycle; the numeric contract is fixed in docs/security.md.

def ext4_perm_check(leaf: Ptr[char], want: int32,
                    caller_uid: uint32, caller_gid: uint32) -> int32:
    # Resolve, read the inode's owner/group/mode, apply owner→group→
    # other selector. NO `uid==1` bypass here — the vfs-level dispatcher
    # admits hostowner if its policy says so; the ext4 server's
    # mode-bit machinery is the same for everyone who reaches it.
    inum: uint32 = 0
    size: uint64 = 0
    if ext4_resolve_file(leaf, &inum, &size) == 0:
        return 0                                           # ENOENT path; defer
    f_uid: uint32 = 0
    f_gid: uint32 = 0
    f_mode: uint16 = 0
    if ext4_inode_owner_at(inum, &f_uid, &f_gid, &f_mode) < 0:
        return 0                                           # I/O error; let open report
    bits: int32 = 0
    if caller_uid == f_uid:
        bits = cast[int32]((f_mode >> 6) & 0x7)
    elif caller_gid == f_gid:
        bits = cast[int32]((f_mode >> 3) & 0x7)
    else:
        bits = cast[int32](f_mode & 0x7)
    if (bits & want) == want:
        return 0
    return -1                                              # EPERM_PERM


# --- extent tree --------------------------------------------------
#
# i_block[60 bytes] starts at inode offset 0x28. For inodes with
# the EXTENTS flag set (default in modern ext4), the first 12 bytes
# are a struct ext4_extent_header:
#
#   0x00  u16 eh_magic       (0xF30A)
#   0x02  u16 eh_entries
#   0x04  u16 eh_max
#   0x06  u16 eh_depth       (0 = leaf, >0 = index — index nodes
#                              ARE walked: see _ext4_logical_to_physical
#                              for read and _ext4_extent_append_block /
#                              _ext4_extent_trim_to for grow/shrink)
#   0x08  u32 eh_generation
#
# Followed by up to 4 struct ext4_extent records (12 bytes each at
# depth 0):
#
#   0x00  u32 ee_block       (logical block, file_offset / blk_sz)
#   0x04  u16 ee_len
#   0x06  u16 ee_start_hi
#   0x08  u32 ee_start_lo
#
# Files small enough that all extents fit inline (>= ~50 KiB for
# 1 KiB blocks) are completely described by this 60-byte window.

INODE_I_BLOCK_OFFSET: uint64 = 40             # 0x28
EXT4_EXTENT_MAGIC:    uint16 = 0xF30A


def ext4_inode_first_extent_block(buf: Ptr[uint8]) -> uint64:
    # Returns the physical block holding logical block 0 of the file.
    # For directories this is the dir's first data block; for files
    # the start of the data. Walks index nodes transparently, so a
    # depth > 0 directory or a sparse-front file resolves correctly.
    return _ext4_logical_to_physical(buf, 0)


# --- directory walk -----------------------------------------------
#
# Each ext4 directory block is a sequence of struct ext4_dir_entry_2:
#
#   0x00  u32 inode
#   0x04  u16 rec_len    (record length, including padding to 4)
#   0x06  u8  name_len
#   0x07  u8  file_type
#   0x08  name[name_len]
#
# rec_len walks us to the next entry. The last entry in the block
# has rec_len that spans to end-of-block (consuming the remainder
# as implicit padding).
#
# Multi-block directories: a directory's i_size grows in whole-block
# increments as it accumulates entries. Once the entries overflow one
# block ext4 maps a second data block, and so on; each block is a
# self-contained sequence of records (the last record in EACH block
# pads its rec_len to that block's end, so a record never straddles a
# block boundary). The lookup / readdir walks therefore iterate EVERY
# data block of the directory inode (via the extent walk used for file
# reads) and scan each block independently — never running a record
# from one block into the next.
#
# On-disk records are UNTRUSTED. Every scan loop below bounds itself
# strictly: rec_len must be >= the 8-byte header, must not run the
# record past end-of-block, and name_len must fit inside both the
# record and the block. A record that violates any of these ends the
# scan of that block rather than reading out of bounds.

DIR_ENTRY_HDR_BYTES: uint64 = 8


def _name_eq_with_len(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    # Byte-compare a[0..n] against b[0..n-1] plus require b[n] == 0
    # (so "HELLO" doesn't match against "HELLO.TXT" or vice versa).
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    if b[n] != 0:
        return 0
    return 1


def _ext4_dirblock_lookup(name: Ptr[char]) -> uint32:
    # Scan the single directory block already loaded into ext4_blk_buf
    # for an entry matching `name`. Returns the matched inode number,
    # or 0 on miss. Every record is bounds-checked against UNTRUSTED
    # on-disk data: a record whose rec_len can't hold its own header,
    # runs past end-of-block, or whose name overflows the record/block
    # ends the scan rather than reading out of bounds.
    #
    # htree index blocks (dx_root / dx_node) carry one fake entry that
    # pads rec_len to end-of-block with no real name to match, so this
    # linear scan harmlessly skips them — only leaf-block entries hit.
    pos: uint64 = 0
    while pos + DIR_ENTRY_HDR_BYTES <= ext4_block_size:
        e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
        inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
        rec_len: uint64 = cast[uint64](_ext4_read_u16(cast[Ptr[uint8]](e + 4)))
        if rec_len < DIR_ENTRY_HDR_BYTES:
            break                                  # too small for a header
        if pos + rec_len > ext4_block_size:
            break                                  # record runs off block
        if inum != 0:
            name_len: uint64 = cast[uint64](cast[Ptr[uint8]](e + 6)[0])
            # name must fit inside both this record and this block.
            if DIR_ENTRY_HDR_BYTES + name_len <= rec_len and \
               pos + DIR_ENTRY_HDR_BYTES + name_len <= ext4_block_size:
                if _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                     cast[Ptr[uint8]](name),
                                     name_len) != 0:
                    return inum
        pos = pos + rec_len
    return 0


# --- htree (dir_index) hash lookup --------------------------------
#
# EXT4_INDEX_FL directories store their entries in hashed-B-tree order:
# logical block 0 is a dx_root, optional dx_node interior blocks index
# further, and the leaf blocks hold the real ext4_dir_entry_2 records.
# A lookup hashes the name (ext4_dirhash, bit-for-bit compatible with
# Linux's fs/ext4/hash.c), then binary-searches the dx_entry array at
# each level to descend to the ONE leaf block whose hash range covers
# the name — touching one leaf instead of every block. Collision chains
# (where several leaves share a hash) are followed while the next leaf's
# hash (low bit masked) still equals the target hash.

DX_HASH_DELTA: uint32 = 0x9E3779B9


def _ext4_u32_at(p: uint64) -> uint32:
    return _ext4_read_u32(cast[Ptr[uint8]](p))


def _rol32(x: uint32, s: uint32) -> uint32:
    s = s & 31
    if s == 0:
        return x
    return (x << s) | (x >> (32 - s))


def _md4_F(x: uint32, y: uint32, z: uint32) -> uint32:
    return z ^ (x & (y ^ z))


def _md4_G(x: uint32, y: uint32, z: uint32) -> uint32:
    return (x & y) + ((x ^ y) & z)


def _md4_H(x: uint32, y: uint32, z: uint32) -> uint32:
    return x ^ y ^ z


# Basic cut-down MD4 transform over an 8-word input. Mutates buf[0..3].
# Mirrors Linux half_md4_transform exactly (K2=0o13240474631=0x5A827999,
# K3=0o15666365641=0x6ED9EBA1).
def _half_md4_transform(buf: Ptr[uint32], in_: Ptr[uint32]):
    a: uint32 = buf[0]
    b: uint32 = buf[1]
    c: uint32 = buf[2]
    d: uint32 = buf[3]
    K2: uint32 = 0x5A827999
    K3: uint32 = 0x6ED9EBA1
    # Round 1 (F)
    a = _rol32(a + _md4_F(b, c, d) + in_[0], 3)
    d = _rol32(d + _md4_F(a, b, c) + in_[1], 7)
    c = _rol32(c + _md4_F(d, a, b) + in_[2], 11)
    b = _rol32(b + _md4_F(c, d, a) + in_[3], 19)
    a = _rol32(a + _md4_F(b, c, d) + in_[4], 3)
    d = _rol32(d + _md4_F(a, b, c) + in_[5], 7)
    c = _rol32(c + _md4_F(d, a, b) + in_[6], 11)
    b = _rol32(b + _md4_F(c, d, a) + in_[7], 19)
    # Round 2 (G)
    a = _rol32(a + _md4_G(b, c, d) + in_[1] + K2, 3)
    d = _rol32(d + _md4_G(a, b, c) + in_[3] + K2, 5)
    c = _rol32(c + _md4_G(d, a, b) + in_[5] + K2, 9)
    b = _rol32(b + _md4_G(c, d, a) + in_[7] + K2, 13)
    a = _rol32(a + _md4_G(b, c, d) + in_[0] + K2, 3)
    d = _rol32(d + _md4_G(a, b, c) + in_[2] + K2, 5)
    c = _rol32(c + _md4_G(d, a, b) + in_[4] + K2, 9)
    b = _rol32(b + _md4_G(c, d, a) + in_[6] + K2, 13)
    # Round 3 (H)
    a = _rol32(a + _md4_H(b, c, d) + in_[3] + K3, 3)
    d = _rol32(d + _md4_H(a, b, c) + in_[7] + K3, 9)
    c = _rol32(c + _md4_H(d, a, b) + in_[2] + K3, 11)
    b = _rol32(b + _md4_H(c, d, a) + in_[6] + K3, 15)
    a = _rol32(a + _md4_H(b, c, d) + in_[1] + K3, 3)
    d = _rol32(d + _md4_H(a, b, c) + in_[5] + K3, 9)
    c = _rol32(c + _md4_H(d, a, b) + in_[0] + K3, 11)
    b = _rol32(b + _md4_H(c, d, a) + in_[4] + K3, 15)
    buf[0] = buf[0] + a
    buf[1] = buf[1] + b
    buf[2] = buf[2] + c
    buf[3] = buf[3] + d


# TEA transform over a 4-word input. Mutates buf[0..1]. Mirrors Linux
# TEA_transform (16 rounds).
def _tea_transform(buf: Ptr[uint32], in_: Ptr[uint32]):
    sum_: uint32 = 0
    b0: uint32 = buf[0]
    b1: uint32 = buf[1]
    a: uint32 = in_[0]
    b: uint32 = in_[1]
    c: uint32 = in_[2]
    d: uint32 = in_[3]
    n: int32 = 16
    while n > 0:
        sum_ = sum_ + DX_HASH_DELTA
        b0 = b0 + (((b1 << 4) + a) ^ (b1 + sum_) ^ ((b1 >> 5) + b))
        b1 = b1 + (((b0 << 4) + c) ^ (b0 + sum_) ^ ((b0 >> 5) + d))
        n = n - 1
    buf[0] = buf[0] + b0
    buf[1] = buf[1] + b1


# str2hashbuf: pack `length` name bytes into `num` 32-bit words (MD4/TEA
# input). `signed_chars` selects the signed vs unsigned char extension —
# Linux's str2hashbuf_signed / str2hashbuf_unsigned. `name` points at the
# remaining tail; we read at most num*4 bytes from it.
def _str2hashbuf(name: Ptr[uint8], length: uint64, out: Ptr[uint32],
                 num: int32, signed_chars: int32):
    lu: uint32 = cast[uint32](length)
    pad: uint32 = lu | (lu << 8)
    pad = pad | (pad << 16)
    val: uint32 = pad
    cap: uint64 = length
    nm: int32 = num
    if cap > cast[uint64](num) * 4:
        cap = cast[uint64](num) * 4
    oi: uint64 = 0
    i: uint64 = 0
    while i < cap:
        cb: uint8 = name[i]
        cv: uint32 = cast[uint32](cb)
        if signed_chars != 0 and cb >= 128:
            # signed char: sign-extend the byte to 32 bits (val += (int)c
            # where c is negative). Two's-complement: c - 256.
            cv = cast[uint32](cast[int32](cast[uint32](cb)) - 256)
        val = cv + (val << 8)
        if (i & 3) == 3:
            out[oi] = val
            oi = oi + 1
            val = pad
            nm = nm - 1
        i = i + 1
    nm = nm - 1
    if nm >= 0:
        out[oi] = val
        oi = oi + 1
    while True:
        nm = nm - 1
        if nm < 0:
            break
        out[oi] = pad
        oi = oi + 1


# The old "legacy" hash (dx_hack_hash). signed_chars selects the signed
# vs unsigned char interpretation.
def _dx_hack_hash(name: Ptr[uint8], length: uint64,
                  signed_chars: int32) -> uint32:
    hash0: uint32 = 0x12a3fe2d
    hash1: uint32 = 0x37abe8f9
    i: uint64 = 0
    while i < length:
        cb: uint8 = name[i]
        cv: uint32 = cast[uint32](cb)
        if signed_chars != 0 and cb >= 128:
            cv = cast[uint32](cast[int32](cast[uint32](cb)) - 256)
        hash: uint32 = hash1 + (hash0 ^ (cv * 7152373))
        if (hash & 0x80000000) != 0:
            hash = hash - 0x7fffffff
        hash1 = hash0
        hash0 = hash
        i = i + 1
    return hash0 << 1


# Compute the ext4 directory hash for `name` (length bytes), returning
# the 32-bit MAJOR hash and writing the minor hash to *minor_out. The
# algorithm + seed are taken from the live superblock (ext4_def_hash_*),
# and the result matches Linux ext4fs_dirhash bit-for-bit.
def ext4_dirhash(name: Ptr[uint8], length: uint64,
                 minor_out: Ptr[uint32]) -> uint32:
    version: uint32 = ext4_def_hash_version
    # Signed by default; the unsigned variants are version+3.
    if version <= EXT4_DX_HASH_TEA:
        version = version + ext4_hash_unsigned
    signed_chars: int32 = 1
    base: uint32 = version
    if version == EXT4_DX_HASH_LEGACY_UNSIGNED:
        base = EXT4_DX_HASH_LEGACY
        signed_chars = 0
    elif version == EXT4_DX_HASH_HALF_MD4_UNSIGNED:
        base = EXT4_DX_HASH_HALF_MD4
        signed_chars = 0
    elif version == EXT4_DX_HASH_TEA_UNSIGNED:
        base = EXT4_DX_HASH_TEA
        signed_chars = 0

    buf: Array[4, uint32]
    buf[0] = 0x67452301
    buf[1] = 0xefcdab89
    buf[2] = 0x98badcfe
    buf[3] = 0x10325476
    # If the seed is non-zero, it replaces the default IV.
    if (ext4_hash_seed[0] | ext4_hash_seed[1]
            | ext4_hash_seed[2] | ext4_hash_seed[3]) != 0:
        buf[0] = ext4_hash_seed[0]
        buf[1] = ext4_hash_seed[1]
        buf[2] = ext4_hash_seed[2]
        buf[3] = ext4_hash_seed[3]

    major: uint32 = 0
    minor: uint32 = 0
    in_: Array[8, uint32]
    if base == EXT4_DX_HASH_LEGACY:
        major = _dx_hack_hash(name, length, signed_chars)
        minor = 0
    elif base == EXT4_DX_HASH_HALF_MD4:
        p: uint64 = 0
        rem: int64 = cast[int64](length)
        while rem > 0:
            _str2hashbuf(cast[Ptr[uint8]](cast[uint64](name) + p),
                         cast[uint64](rem), &in_[0], 8, signed_chars)
            _half_md4_transform(&buf[0], &in_[0])
            rem = rem - 32
            p = p + 32
        major = buf[1]
        minor = buf[2]
    elif base == EXT4_DX_HASH_TEA:
        p2: uint64 = 0
        rem2: int64 = cast[int64](length)
        while rem2 > 0:
            _str2hashbuf(cast[Ptr[uint8]](cast[uint64](name) + p2),
                         cast[uint64](rem2), &in_[0], 4, signed_chars)
            _tea_transform(&buf[0], &in_[0])
            rem2 = rem2 - 16
            p2 = p2 + 16
        major = buf[0]
        minor = buf[1]

    major = major & 0xFFFFFFFE
    # EOF sentinel guard: (EOF_32BIT << 1) == 0xFFFFFFFE; nudge down.
    if major == ((EXT4_HTREE_EOF_32BIT << 1) & 0xFFFFFFFE):
        major = (EXT4_HTREE_EOF_32BIT - 1) << 1
    minor_out[0] = minor
    return major


# dx_entry helpers: a dx_entry is {u32 hash, u32 block}. The FIRST entry
# of the array doubles as a dx_countlimit {u16 limit, u16 count} packed
# into its hash field.
def _dx_get_count(entries: uint64) -> uint32:
    return cast[uint32](_ext4_read_u16(cast[Ptr[uint8]](entries + 2)))


def _dx_get_limit(entries: uint64) -> uint32:
    return cast[uint32](_ext4_read_u16(cast[Ptr[uint8]](entries)))


def _dx_entry_hash(entries: uint64, idx: uint32) -> uint32:
    return _ext4_u32_at(entries + cast[uint64](idx) * 8 + 0)


def _dx_entry_block(entries: uint64, idx: uint32) -> uint32:
    return _ext4_u32_at(entries + cast[uint64](idx) * 8 + 4)


# Binary-search a dx_entry array (count entries, entry 0 is the
# countlimit) for the last entry whose hash is <= target. Returns its
# index (>=0); always at least 0 (the catch-all first real slot).
def _dx_bsearch(entries: uint64, count: uint32, hash: uint32) -> uint32:
    # Linux: p = entries+1; q = entries+count-1; pick p-1.
    lo: int64 = 1
    hi: int64 = cast[int64](count) - 1
    while lo <= hi:
        mid: int64 = lo + (hi - lo) / 2
        if _dx_entry_hash(entries, cast[uint32](mid)) > hash:
            hi = mid - 1
        else:
            lo = mid + 1
    # `at` = (p) - 1 where p == lo.
    at: int64 = lo - 1
    if at < 0:
        at = 0
    return cast[uint32](at)


# Descend the htree for `name`/`hash`, returning the logical leaf block
# to scan first, or returning -1 (cast) on any structural error so the
# caller can fall back to the linear scan. `levels_out` records the
# number of index levels descended (diagnostic). Index blocks are read
# through ext4_htree_buf so the leaf scan's ext4_blk_buf is untouched.
#
# Also fills entry_blocks[]/entry_counts[]/entry_at[] frame state for the
# collision-chain continuation walk done by the caller.
ext4_htree_frame_block: Array[8, uint64]   # logical block of each frame's index node
ext4_htree_frame_at:    Array[8, uint32]   # current dx_entry index at each frame
ext4_htree_frame_count: Array[8, uint32]   # dx_entry count at each frame
ext4_htree_frame_eoff:  Array[8, uint64]   # byte offset of entries[] within ext4_htree_buf load
ext4_htree_nframes:     uint32 = 0


def _ext4_htree_descend(dir_inode_buf: Ptr[uint8], hash: uint32) -> int64:
    # Read logical block 0 (the dx_root).
    phys0: uint64 = _ext4_logical_to_physical(dir_inode_buf, 0)
    if phys0 == 0:
        return -1
    if _ext4_read_block(phys0, &ext4_htree_buf[0]) != 0:
        return -1
    base: uint64 = cast[uint64](&ext4_htree_buf[0])
    # dx_root_info lives at offset 0x18: reserved(4) hash_version(1)
    # info_length(1) indirect_levels(1) unused_flags(1). entries[] start
    # at 0x18 + info_length.
    hash_version: uint8 = cast[Ptr[uint8]](base + 0x1C)[0]
    info_length:  uint8 = cast[Ptr[uint8]](base + 0x1D)[0]
    indirect:     uint8 = cast[Ptr[uint8]](base + 0x1E)[0]
    unused_flags: uint8 = cast[Ptr[uint8]](base + 0x1F)[0]
    if unused_flags != 0:
        return -1
    # info_length must be 8 for a well-formed dx_root.
    if info_length != 8:
        return -1
    if cast[uint32](indirect) >= 8:
        return -1
    entries_off: uint64 = 0x18 + cast[uint64](info_length)
    entries: uint64 = base + entries_off

    level: uint32 = 0
    ext4_htree_nframes = cast[uint32](indirect) + 1
    while True:
        count: uint32 = _dx_get_count(entries)
        limit: uint32 = _dx_get_limit(entries)
        if count == 0 or count > limit:
            return -1
        at: uint32 = _dx_bsearch(entries, count, hash)
        # Record this frame for the collision-chain continuation walk.
        ext4_htree_frame_at[level] = at
        ext4_htree_frame_count[level] = count
        ext4_htree_frame_eoff[level] = entries_off
        child_block: uint32 = _dx_entry_block(entries, at)
        if level >= cast[uint32](indirect):
            # `at` points at the leaf block; child_block is the leaf's
            # LOGICAL block within the dir.
            return cast[int64](cast[uint64](child_block))
        # Descend into the dx_node interior block (logical child_block).
        phys: uint64 = _ext4_logical_to_physical(
            dir_inode_buf, cast[uint64](child_block))
        if phys == 0:
            return -1
        if _ext4_read_block(phys, &ext4_htree_buf[0]) != 0:
            return -1
        base = cast[uint64](&ext4_htree_buf[0])
        # dx_node: a fake dirent (8 bytes) then entries[].
        entries_off = 8
        entries = base + entries_off
        level = level + 1


# Re-load the index block for `level` into ext4_htree_buf and return the
# byte address of its entries[] array. Used by the continuation walk,
# which must re-read parent index nodes after the leaf scan clobbered
# ext4_htree_buf is NOT a concern here (leaf uses ext4_blk_buf), but the
# descent path reuses ext4_htree_buf per level, so we reconstruct.
def _ext4_htree_reload_entries(dir_inode_buf: Ptr[uint8],
                               logical_blk: uint64,
                               entries_off: uint64) -> uint64:
    phys: uint64 = _ext4_logical_to_physical(dir_inode_buf, logical_blk)
    if phys == 0:
        return 0
    if _ext4_read_block(phys, &ext4_htree_buf[0]) != 0:
        return 0
    return cast[uint64](&ext4_htree_buf[0]) + entries_off


# Advance the htree frame stack to the next leaf block for collision-chain
# continuation. Mirrors Linux ext4_htree_next_block. Returns the next
# LOGICAL leaf block (>=0) if the walk should continue (and the next
# block's hash, low-bit masked, still equals `hash`), or -1 to stop.
#
# `logical_path[]` carries the logical block number of each frame's index
# node so parent nodes can be re-read after the leaf scan reused
# ext4_htree_buf. Frame 0's index node is dir logical block 0.
ext4_htree_logical_path: Array[8, uint64]


def _ext4_htree_next_leaf(dir_inode_buf: Ptr[uint8], hash: uint32) -> int64:
    nf: int32 = cast[int32](ext4_htree_nframes)
    # Re-load the leaf's parent frame (deepest index frame) since the
    # leaf scan used ext4_blk_buf, leaving ext4_htree_buf holding the
    # deepest index node from the descent — but only if nframes == 1
    # (root is the parent). For multi-level we must re-read each frame's
    # node as we climb. We reconstruct from logical_path + eoff.
    p: int32 = nf - 1
    num_climb: int32 = 0
    while True:
        # Re-load frame p's index node and advance its `at`.
        ent: uint64 = _ext4_htree_reload_entries(
            dir_inode_buf, ext4_htree_logical_path[p],
            ext4_htree_frame_eoff[p])
        if ent == 0:
            return -1
        ext4_htree_frame_at[p] = ext4_htree_frame_at[p] + 1
        if ext4_htree_frame_at[p] < ext4_htree_frame_count[p]:
            break
        if p == 0:
            return -1
        num_climb = num_climb + 1
        p = p - 1

    # Check continuation hash: with hash low bit 0, require (bhash&~1)==hash.
    ent2: uint64 = _ext4_htree_reload_entries(
        dir_inode_buf, ext4_htree_logical_path[p],
        ext4_htree_frame_eoff[p])
    if ent2 == 0:
        return -1
    bhash: uint32 = _dx_entry_hash(ent2, ext4_htree_frame_at[p])
    if (hash & 1) == 0:
        if (bhash & 0xFFFFFFFE) != hash:
            return -1

    # Walk back down to the new leaf, refreshing child frames.
    while num_climb > 0:
        ent3: uint64 = _ext4_htree_reload_entries(
            dir_inode_buf, ext4_htree_logical_path[p],
            ext4_htree_frame_eoff[p])
        if ent3 == 0:
            return -1
        child: uint32 = _dx_entry_block(ent3, ext4_htree_frame_at[p])
        # Descend into child interior node: its logical block is `child`,
        # entries start after the 8-byte fake dirent.
        p = p + 1
        ext4_htree_logical_path[p] = cast[uint64](child)
        ext4_htree_frame_eoff[p] = 8
        ent4: uint64 = _ext4_htree_reload_entries(
            dir_inode_buf, ext4_htree_logical_path[p], 8)
        if ent4 == 0:
            return -1
        ext4_htree_frame_at[p] = 0
        ext4_htree_frame_count[p] = _dx_get_count(ent4)
        num_climb = num_climb - 1

    # p now indexes the deepest frame; its `at` selects the leaf block.
    ent5: uint64 = _ext4_htree_reload_entries(
        dir_inode_buf, ext4_htree_logical_path[p],
        ext4_htree_frame_eoff[p])
    if ent5 == 0:
        return -1
    leaf: uint32 = _dx_entry_block(ent5, ext4_htree_frame_at[p])
    return cast[int64](cast[uint64](leaf))


# Htree lookup: hash `name`, descend the dx tree to the indexed leaf,
# scan it (and any collision-chain continuation leaves), and return the
# matched inode number or 0 on miss. Returns 0 (and leaves the caller to
# fall back to a linear scan) on any structural anomaly — but a well-
# formed htree dir resolves entirely here, touching only the indexed
# leaf block(s) rather than every directory block.
# Set to 1 when the last ext4_dir_lookup_htree() completed a genuine
# hash-descend (so a 0 result is a real miss, not a structural fallback).
# When it stays 0 the caller must run the linear scan instead.
ext4_htree_used: int32 = 0


def ext4_dir_lookup_htree(dir_inode_buf: Ptr[uint8],
                          name: Ptr[char]) -> uint32:
    ext4_htree_used = 0
    nlen: uint64 = _ext4_strlen(name)
    minor: uint32 = 0
    hash: uint32 = ext4_dirhash(cast[Ptr[uint8]](name), nlen, &minor)

    leaf_i64: int64 = _ext4_htree_descend(dir_inode_buf, hash)
    if leaf_i64 < 0:
        return 0
    # Seed the logical_path with each frame's index-node logical block.
    # Frame 0 is dir logical block 0; deeper frames' logical blocks were
    # recorded as we descended via entries_off/at — but the descend loop
    # overwrote ext4_htree_buf each level, so reconstruct the path by
    # re-descending the block pointers. Frame 0 = block 0; each child's
    # logical block is the dx_entry block at the parent's chosen `at`.
    ext4_htree_logical_path[0] = 0
    pi: uint32 = 1
    parent_logical: uint64 = 0
    while pi < ext4_htree_nframes:
        ent: uint64 = _ext4_htree_reload_entries(
            dir_inode_buf, parent_logical, ext4_htree_frame_eoff[pi - 1])
        if ent == 0:
            return 0
        child: uint32 = _dx_entry_block(ent, ext4_htree_frame_at[pi - 1])
        ext4_htree_logical_path[pi] = cast[uint64](child)
        parent_logical = cast[uint64](child)
        pi = pi + 1

    # Descend + path reconstruction succeeded: from here a 0 result is a
    # genuine miss, so the caller need not re-run the linear scan.
    ext4_htree_used = 1
    leaf_logical: uint64 = cast[uint64](leaf_i64)
    # Scan the indexed leaf, then follow collision-chain continuations.
    chain_guard: int32 = 64
    while chain_guard > 0:
        chain_guard = chain_guard - 1
        phys: uint64 = _ext4_logical_to_physical(dir_inode_buf, leaf_logical)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        ext4_htree_leaf_reads = ext4_htree_leaf_reads + 1
        hit: uint32 = _ext4_dirblock_lookup(name)
        if hit != 0:
            return hit
        nxt: int64 = _ext4_htree_next_leaf(dir_inode_buf, hash)
        if nxt < 0:
            return 0
        leaf_logical = cast[uint64](nxt)
    return 0


# --- htree self-test ----------------------------------------------
#
# Gated on /etc/ext4-htree-test (planted by build_initramfs.py). Two
# phases:
#   (1) HASH KAT — drive ext4_dirhash against a FIXED seed for the
#       legacy / half_md4 / TEA algorithms and compare to values
#       precomputed by Linux's debugfs `dx_hash` (e2fsprogs). This
#       proves the hash matches Linux bit-for-bit.
#   (2) LIVE DESCEND — resolve the on-disk htree directory "bigdir"
#       (minted by scripts/test_ext4_htree.sh with enough entries to
#       force >=1 dx index level), look up several names via the
#       hash-descend path, cross-check each against the linear scan,
#       and assert the descend touched only a handful of leaf blocks
#       (not every directory block).
ext4_htree_kat_seed: Array[4, uint32]


def _ext4_htree_set_kat_seed():
    ext4_htree_kat_seed[0] = 0x6bfd0c43
    ext4_htree_kat_seed[1] = 0xfb4d39c8
    ext4_htree_kat_seed[2] = 0x63554394
    ext4_htree_kat_seed[3] = 0xc81375ed


def _ext4_htree_kat_one(name: Ptr[char], version: uint32,
                        exp_major: uint32, exp_minor: uint32) -> int32:
    # Save + override the live hash state with the fixed KAT seed and the
    # requested version, hash `name`, compare, then restore.
    sv0: uint32 = ext4_hash_seed[0]
    sv1: uint32 = ext4_hash_seed[1]
    sv2: uint32 = ext4_hash_seed[2]
    sv3: uint32 = ext4_hash_seed[3]
    sv_ver: uint32 = ext4_def_hash_version
    sv_uns: uint32 = ext4_hash_unsigned
    ext4_hash_seed[0] = ext4_htree_kat_seed[0]
    ext4_hash_seed[1] = ext4_htree_kat_seed[1]
    ext4_hash_seed[2] = ext4_htree_kat_seed[2]
    ext4_hash_seed[3] = ext4_htree_kat_seed[3]
    ext4_def_hash_version = version
    ext4_hash_unsigned = 0                       # signed (default on x86)
    minor: uint32 = 0
    major: uint32 = ext4_dirhash(cast[Ptr[uint8]](name),
                                 _ext4_strlen(name), &minor)
    ext4_hash_seed[0] = sv0
    ext4_hash_seed[1] = sv1
    ext4_hash_seed[2] = sv2
    ext4_hash_seed[3] = sv3
    ext4_def_hash_version = sv_ver
    ext4_hash_unsigned = sv_uns
    if major == exp_major and minor == exp_minor:
        return 1
    printk2("[ext4-htree]   KAT MISS got major=%x minor=%x\n",
            cast[uint64](major), cast[uint64](minor))
    printk2("[ext4-htree]   KAT     exp major=%x minor=%x\n",
            cast[uint64](exp_major), cast[uint64](exp_minor))
    return 0


def ext4_htree_selftest():
    if ext4_blockdev_slot < 0:
        printk0("[ext4-htree] FAIL: ext4 not mounted\n")
        return
    _ext4_htree_set_kat_seed()
    ok_all: int32 = 1

    # --- Phase 1: hash KAT vs Linux/debugfs (fixed seed) ---
    kat_ok: int32 = 1
    # legacy (version 0)
    if _ext4_htree_kat_one("a", 0, 0xe74b53e2, 0) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("testname", 0, 0x64032cb0, 0) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("file000123", 0, 0xbd992e0e, 0) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("0123456789ABCDEF", 0, 0xf4ca76fc, 0) == 0:
        kat_ok = 0
    # half_md4 (version 1, the mke2fs default)
    if _ext4_htree_kat_one("a", 1, 0x172e1522, 0xd1b59de3) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("abc", 1, 0x7e233c12, 0x9b1bf832) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("testname", 1, 0x0e75b534, 0x1eaf896c) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("file000123", 1, 0xddf18ee0, 0x28e90e00) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("0123456789ABCDEF", 1, 0x93e12ea0, 0x9cee3129) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("zzzzzzzzzzzzzzzzzzzzzzzzz", 1,
                           0x4d59c7e6, 0xe2c00f69) == 0:
        kat_ok = 0
    # tea (version 2)
    if _ext4_htree_kat_one("a", 2, 0xe530d80c, 0x058b7511) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("testname", 2, 0x524b6f08, 0xe3a72d59) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("file000123", 2, 0xb826e0d6, 0xdc34f003) == 0:
        kat_ok = 0
    if _ext4_htree_kat_one("0123456789ABCDEF", 2, 0x4ea29570, 0x6111947e) == 0:
        kat_ok = 0
    if kat_ok != 0:
        printk0("[ext4-htree] PASS hash-KAT (legacy/half_md4/tea match Linux)\n")
    else:
        printk0("[ext4-htree] FAIL hash-KAT\n")
        ok_all = 0

    # --- Phase 2: live htree descend on the on-disk dir "bigdir" ---
    dir_inum: uint32 = ext4_resolve_dir("bigdir")
    if dir_inum == 0:
        printk0("[ext4-htree] FAIL: cannot resolve /bigdir\n")
        printk0("[ext4-htree] FAIL\n")
        return
    dirbuf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](dir_inum), &dirbuf[0]) != 0:
        printk0("[ext4-htree] FAIL: cannot read bigdir inode\n")
        printk0("[ext4-htree] FAIL\n")
        return
    if ext4_inode_is_htree_dir(&dirbuf[0]) == 0:
        printk0("[ext4-htree] FAIL: bigdir is not an htree (dir_index) dir\n")
        ok_all = 0
    else:
        printk0("[ext4-htree] PASS bigdir is EXT4_INDEX_FL (htree)\n")

    # How many data blocks does the directory span? The linear scan
    # would touch ALL of them; a real descend touches only a few.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&dirbuf[0]))
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    printk1("[ext4-htree] bigdir spans %d directory blocks\n", nblocks)

    # Report the descend depth: parse the dx_root indirect_levels.
    phys0: uint64 = _ext4_logical_to_physical(&dirbuf[0], 0)
    if phys0 != 0 and _ext4_read_block(phys0, &ext4_htree_buf[0]) == 0:
        ind: uint8 = cast[Ptr[uint8]](
            cast[uint64](&ext4_htree_buf[0]) + 0x1E)[0]
        printk1("[ext4-htree] dx_root indirect_levels=%d\n",
                cast[uint64](ind))
        if cast[uint32](ind) < 1:
            printk0("[ext4-htree] FAIL: expected >=1 index level\n")
            ok_all = 0

    # Look up several names spread across the hash space. For each,
    # cross-check the hash-descend result against the linear scan and
    # assert the descend read only a small number of leaf blocks.
    names: Array[6, Ptr[char]]
    names[0] = "file000000"
    names[1] = "file002500"
    names[2] = "file005999"
    names[3] = "file003333"
    names[4] = "file000777"
    names[5] = "file004242"
    ni: uint64 = 0
    lookups_ok: int32 = 1
    max_leaf_reads: uint64 = 0
    while ni < 6:
        nm: Ptr[char] = names[ni]
        # htree descend
        ext4_htree_leaf_reads = 0
        ht_inum: uint32 = ext4_dir_lookup_htree(&dirbuf[0], nm)
        if ext4_htree_used == 0:
            printk1("[ext4-htree] FAIL: htree path bailed for name #%d\n", ni)
            lookups_ok = 0
            ni = ni + 1
            continue
        leaf_reads: uint64 = ext4_htree_leaf_reads
        if leaf_reads > max_leaf_reads:
            max_leaf_reads = leaf_reads
        # linear cross-check: temporarily force the linear scan by
        # walking every block ourselves (the linear scan helper).
        lin_inum: uint32 = _ext4_dir_lookup_linear(&dirbuf[0], nm)
        if ht_inum == 0:
            printk1("[ext4-htree] FAIL: htree miss for present name #%d\n", ni)
            lookups_ok = 0
        elif ht_inum != lin_inum:
            printk2("[ext4-htree] FAIL: htree inum %d != linear %d\n",
                    cast[uint64](ht_inum), cast[uint64](lin_inum))
            lookups_ok = 0
        else:
            printk2("[ext4-htree]   '...' -> inode %d (leaf reads=%d)\n",
                    cast[uint64](ht_inum), leaf_reads)
        ni = ni + 1

    # A missing name must also resolve as a miss through the descend.
    ext4_htree_leaf_reads = 0
    miss_inum: uint32 = ext4_dir_lookup_htree(&dirbuf[0], "no_such_file_zzz")
    if ext4_htree_used != 0 and miss_inum == 0:
        printk0("[ext4-htree] PASS negative lookup (absent name → 0)\n")
    else:
        printk0("[ext4-htree] FAIL negative lookup\n")
        lookups_ok = 0

    if lookups_ok != 0:
        printk1("[ext4-htree] PASS descend (max leaf reads=%d per lookup)\n",
                max_leaf_reads)
    else:
        ok_all = 0

    # The descend must touch FAR fewer blocks than the directory spans —
    # this is the proof the index was used, not a disguised full scan.
    if max_leaf_reads == 0 or max_leaf_reads * 4 >= nblocks:
        printk0("[ext4-htree] FAIL: descend touched too many blocks\n")
        ok_all = 0
    else:
        printk2("[ext4-htree] PASS index-not-linear (%d leaf reads << %d blocks)\n",
                max_leaf_reads, nblocks)

    if ok_all != 0:
        printk0("[ext4-htree] PASS\n")
    else:
        printk0("[ext4-htree] FAIL\n")


# --- htree INSERT self-test ---------------------------------------
#
# Gated on /etc/ext4-htins-test (planted by build_initramfs.py when
# ENABLE_EXT4_HTINS_TEST=1). Drives the WRITE path:
#   (1) resolve the on-disk htree directory "htdir" (minted by
#       scripts/test_ext4_htree_insert.sh with enough entries to be a
#       real dir_index dir),
#   (2) record the dx_root indirect_levels BEFORE,
#   (3) insert a batch of NEW names (forcing >= 1 leaf split and ideally
#       an index-level growth) via ext4_create_file -> ext4_dir_insert ->
#       ext4_htree_dir_insert,
#   (4) verify EVERY inserted name resolves via the hash-descend lookup
#       to the inode that was created for it,
#   (5) verify the directory still validates: each inserted name's
#       descend result matches the independent linear scan, and the
#       dx_root indirect_levels grew (or stayed >=1),
#   (6) verify a pre-existing name still resolves (split didn't lose it).
# Verdict is computed from real lookups + a structure check, NOT a
# hard-coded PASS. WRITES the image, so opt-in via the marker.

# How many fresh names to insert. The test fixture seeds "htdir" with
# enough entries that its dx_root is nearly full (count ~111 of limit
# 124 at 1 KiB blocks, indirect_levels 0); inserting this many more names
# forces many leaf splits, fills the dx_root, and triggers the 0->1
# index-level growth — then keeps inserting so the resulting two-level
# htree is exercised by further descends/inserts.
EXT4_HTINS_INSERT_COUNT: uint64 = 1200

# Scratch name buffer ("ins000000\0" style). 24 bytes is ample for the
# "ins" prefix + a 6-digit counter + NUL (undersizing overflows the next
# BSS global — the recurring trap).
ext4_htins_namebuf: Array[24, uint8]


def _ext4_htins_make_name(idx: uint64):
    # Format "ins%06u" into ext4_htins_namebuf with a trailing NUL.
    ext4_htins_namebuf[0] = 0x69                              # 'i'
    ext4_htins_namebuf[1] = 0x6E                              # 'n'
    ext4_htins_namebuf[2] = 0x73                              # 's'
    d: uint64 = idx
    p: uint64 = 8
    while p >= 3:
        ext4_htins_namebuf[p] = cast[uint8](0x30 + cast[uint8](d % 10))
        d = d / 10
        if p == 3:
            p = 2                                            # exit
        else:
            p = p - 1
    ext4_htins_namebuf[9] = 0


def _ext4_htins_dx_levels(dir_inum: uint32) -> int64:
    # Read the dx_root indirect_levels of `dir_inum`. Returns -1 on error.
    dirbuf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](dir_inum), &dirbuf[0]) != 0:
        return -1
    phys0: uint64 = _ext4_logical_to_physical(&dirbuf[0], 0)
    if phys0 == 0:
        return -1
    if _ext4_read_block(phys0, &ext4_htree_buf[0]) != 0:
        return -1
    ind: uint8 = cast[Ptr[uint8]](
        cast[uint64](&ext4_htree_buf[0]) + 0x1E)[0]
    return cast[int64](cast[uint64](ind))


def ext4_htree_insert_selftest():
    if ext4_blockdev_slot < 0:
        printk0("[ext4-htins] FAIL: ext4 not mounted\n")
        return
    if ext4_metadata_csum != 0:
        printk0("[ext4-htins] FAIL: image carries metadata_csum (use ^metadata_csum)\n")
        printk0("[ext4-htins] FAIL\n")
        return
    ok_all: int32 = 1

    dir_inum: uint32 = ext4_resolve_dir("htdir")
    if dir_inum == 0:
        printk0("[ext4-htins] FAIL: cannot resolve /htdir\n")
        printk0("[ext4-htins] FAIL\n")
        return
    dirbuf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](dir_inum), &dirbuf[0]) != 0:
        printk0("[ext4-htins] FAIL: cannot read htdir inode\n")
        printk0("[ext4-htins] FAIL\n")
        return
    if ext4_inode_is_htree_dir(&dirbuf[0]) == 0:
        printk0("[ext4-htins] FAIL: htdir is not an htree (dir_index) dir\n")
        printk0("[ext4-htins] FAIL\n")
        return
    printk0("[ext4-htins] PASS htdir is EXT4_INDEX_FL (htree)\n")

    levels_before: int64 = _ext4_htins_dx_levels(dir_inum)
    blocks_before: uint64 = cast[uint64](
        ext4_inode_size_lo(&dirbuf[0])) / ext4_block_size
    printk2("[ext4-htins] before: indirect_levels=%d, %d dir blocks\n",
            cast[uint64](levels_before), blocks_before)

    # Sanity: a pre-existing name must resolve up-front so we can prove
    # the splits below don't lose it.
    pre_inum: uint32 = ext4_dir_lookup_htree(&dirbuf[0], "seed000000")
    if pre_inum == 0 or ext4_htree_used == 0:
        printk0("[ext4-htins] FAIL: seed000000 missing before inserts\n")
        ok_all = 0

    # Insert a batch of NEW names through the full create path (which
    # routes EXT4_INDEX_FL parents to ext4_htree_dir_insert). Each create
    # mints a real inode; we record nothing but the success count — the
    # lookup phase reproduces each name and asserts it resolves.
    body: Ptr[uint8] = "x"
    inserted: uint64 = 0
    i: uint64 = 0
    while i < EXT4_HTINS_INSERT_COUNT:
        _ext4_htins_make_name(i)
        ni: uint32 = ext4_create_file(
            cast[uint64](dir_inum),
            cast[Ptr[char]](&ext4_htins_namebuf[0]), body, 1)
        if ni == 0:
            printk1("[ext4-htins] FAIL: create failed at #%d\n", i)
            ok_all = 0
            i = EXT4_HTINS_INSERT_COUNT
        else:
            inserted = inserted + 1
            i = i + 1
    printk1("[ext4-htins] inserted %d new names\n", inserted)

    # Re-read the dir inode (i_size / extents grew across splits).
    if ext4_read_inode(cast[uint64](dir_inum), &dirbuf[0]) != 0:
        printk0("[ext4-htins] FAIL: re-read htdir inode\n")
        printk0("[ext4-htins] FAIL\n")
        return
    levels_after: int64 = _ext4_htins_dx_levels(dir_inum)
    blocks_after: uint64 = cast[uint64](
        ext4_inode_size_lo(&dirbuf[0])) / ext4_block_size
    printk2("[ext4-htins] after:  indirect_levels=%d, %d dir blocks\n",
            cast[uint64](levels_after), blocks_after)

    # A leaf split allocates a new directory block — so the dir MUST have
    # grown. (Proves real splitting happened, not in-place reuse.)
    if blocks_after <= blocks_before:
        printk0("[ext4-htins] FAIL: dir did not grow (no leaf split)\n")
        ok_all = 0
    else:
        printk1("[ext4-htins] PASS leaf split grew dir by %d block(s)\n",
                blocks_after - blocks_before)

    # Verify EVERY inserted name resolves via the hash-descend path AND
    # matches the independent linear scan (no corruption).
    verified: uint64 = 0
    lookups_ok: int32 = 1
    j: uint64 = 0
    while j < inserted:
        _ext4_htins_make_name(j)
        nmp: Ptr[char] = cast[Ptr[char]](&ext4_htins_namebuf[0])
        ext4_htree_used = 0
        ht_inum: uint32 = ext4_dir_lookup_htree(&dirbuf[0], nmp)
        if ext4_htree_used == 0:
            printk1("[ext4-htins] FAIL: htree path bailed for ins#%d\n", j)
            lookups_ok = 0
            j = inserted
        elif ht_inum == 0:
            printk1("[ext4-htins] FAIL: htree miss for ins#%d\n", j)
            lookups_ok = 0
            j = inserted
        else:
            lin_inum: uint32 = _ext4_dir_lookup_linear(&dirbuf[0], nmp)
            if ht_inum != lin_inum:
                printk2("[ext4-htins] FAIL: ins htree %d != linear %d\n",
                        cast[uint64](ht_inum), cast[uint64](lin_inum))
                lookups_ok = 0
                j = inserted
            else:
                verified = verified + 1
                j = j + 1
    if lookups_ok != 0 and verified == inserted and inserted > 0:
        printk1("[ext4-htins] PASS all %d inserted names resolve via descend\n",
                verified)
    else:
        printk2("[ext4-htins] FAIL: only %d/%d inserted names verified\n",
                verified, inserted)
        ok_all = 0

    # The pre-existing seed name must STILL resolve after all the splits.
    post_inum: uint32 = ext4_dir_lookup_htree(&dirbuf[0], "seed000000")
    if ext4_htree_used != 0 and post_inum != 0 and post_inum == pre_inum:
        printk0("[ext4-htins] PASS pre-existing name survived splits\n")
    else:
        printk0("[ext4-htins] FAIL: pre-existing name lost across splits\n")
        ok_all = 0

    # Structure: the index must remain >= 1 level. If it started at 0 it
    # should have grown to 1 (index-level growth); if it started >=1 it
    # stays valid.
    if levels_after < 1:
        printk0("[ext4-htins] FAIL: dx index has no indirect level\n")
        ok_all = 0
    elif levels_after > levels_before:
        printk2("[ext4-htins] PASS index grew %d -> %d level(s)\n",
                cast[uint64](levels_before), cast[uint64](levels_after))
    else:
        printk1("[ext4-htins] PASS index stable at %d level(s)\n",
                cast[uint64](levels_after))

    if ok_all != 0:
        printk0("[ext4-htins] PASS\n")
    else:
        printk0("[ext4-htins] FAIL\n")


# --- large_dir (3-level htree) self-test --------------------------
#
# Gated on /etc/ext4-largedir-test (planted by build_initramfs.py when
# ENABLE_EXT4_LARGEDIR_TEST=1). Proves the INCOMPAT_LARGEDIR write path:
# growing a 2-level htree (dx_root.indirect_levels==1) to 3 levels
# (indirect_levels==2) when the root index node itself fills, gated on
# the large_dir feature being set in the superblock.
#
#   (1) resolve the on-disk "lgdir" directory (minted by
#       scripts/test_ext4_largedir.sh as a 2-level htree whose dx_root is
#       NEARLY FULL — ~117 of its 124-entry limit at 1 KiB blocks),
#   (2) assert it starts at indirect_levels == 1 (a genuine 2-level tree),
#   (3) insert NEW long names through the full create ->
#       ext4_htree_dir_insert WRITE path until the dx_root overflows and
#       the tree grows to indirect_levels == 2 (a real 3-level htree),
#   (4) assert the tree actually reached 3 levels (indirect_levels==2) —
#       only reachable because the superblock declares large_dir,
#   (5) verify EVERY inserted name resolves via the 3-level hash descend
#       AND matches an independent linear scan (no corruption), and that
#       at least one lookup descended a genuine 3-frame path
#       (ext4_htree_nframes == 3),
#   (6) confirm a pre-existing seed name still resolves after the growth.
# The verdict is computed from real lookups + the depth assertion, NOT a
# hard-coded PASS. WRITES the image, so opt-in via the marker.

# Long-name scheme: a 240-char 'z' prefix + a 7-digit counter (matches the
# host fixture's file names so kernel-inserted names hash into the same
# distribution). Total 247 chars + NUL. Few entries fit per 1 KiB leaf, so
# leaves split fast and the index deepens with a modest insert budget.
EXT4_LARGEDIR_PREFIX_LEN: uint64 = 240
EXT4_LARGEDIR_NAME_LEN:   uint64 = 247
# Counter base: the host seeds indices [0, SEED_COUNT); the kernel inserts
# fresh names at indices [SEED_BASE, SEED_BASE + cap) so they never collide
# with the seeds. The host fixture uses up to ~28000 seeds; start well past.
EXT4_LARGEDIR_SEED_BASE:  uint64 = 100000
# Upper bound on kernel inserts before giving up forcing the 1->2 growth.
# The fixture starts as a near-full 2-level tree; pushing its dx_root over
# 124 entries (forcing several interior-node splits) takes many thousands
# of inserts. These go through ext4_htree_dir_insert DIRECTLY (no per-name
# inode/data-block allocation), so they are cheap; this is a generous cap.
EXT4_LARGEDIR_MAX_INSERT: uint64 = 30000
# Every inserted dirent points at this existing inode (the ext4 root dir,
# EXT2_ROOT_INO == 2). We do NOT allocate a fresh inode per name: the
# kernel's inode allocator only serves group 0 (512 inodes) and the host
# seed already exhausts it, so ext4_create_file would fail. The htree WRITE
# path under test does not care what the child inum refers to — it indexes
# the NAME by hash. (e2fsck flags only a link-count discrepancy on inode 2,
# a Pass-4 issue orthogonal to htree/directory-structure correctness.)
EXT4_LARGEDIR_CHILD_INUM: uint32 = 2

# Name scratch: 247 chars + NUL = 248; round up to 256 (undersizing would
# overflow the next BSS global — the recurring trap).
ext4_largedir_namebuf: Array[256, uint8]


def _ext4_largedir_make_name(idx: uint64):
    # Build "zzz...z%07u" (240 'z' + 7-digit counter) + NUL.
    p: uint64 = 0
    while p < EXT4_LARGEDIR_PREFIX_LEN:
        ext4_largedir_namebuf[p] = 0x7A                          # 'z'
        p = p + 1
    # 7-digit zero-padded counter at [240..246].
    d: uint64 = idx
    q: uint64 = EXT4_LARGEDIR_PREFIX_LEN + 6
    cont: int32 = 1
    while cont != 0:
        ext4_largedir_namebuf[q] = cast[uint8](0x30 + cast[uint8](d % 10))
        d = d / 10
        if q == EXT4_LARGEDIR_PREFIX_LEN:
            cont = 0
        else:
            q = q - 1
    ext4_largedir_namebuf[EXT4_LARGEDIR_NAME_LEN] = 0


def ext4_largedir_selftest():
    if ext4_blockdev_slot < 0:
        printk0("[ext4-largedir] FAIL: ext4 not mounted\n")
        return
    if ext4_metadata_csum != 0:
        printk0("[ext4-largedir] FAIL: image carries metadata_csum (use ^metadata_csum)\n")
        printk0("[ext4-largedir] FAIL\n")
        return
    if ext4_large_dir == 0:
        printk0("[ext4-largedir] FAIL: superblock lacks INCOMPAT_LARGEDIR\n")
        printk0("[ext4-largedir] FAIL\n")
        return
    printk0("[ext4-largedir] PASS superblock declares large_dir\n")
    ok_all: int32 = 1

    dir_inum: uint32 = ext4_resolve_dir("lgdir")
    if dir_inum == 0:
        printk0("[ext4-largedir] FAIL: cannot resolve /lgdir\n")
        printk0("[ext4-largedir] FAIL\n")
        return
    dirbuf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](dir_inum), &dirbuf[0]) != 0:
        printk0("[ext4-largedir] FAIL: cannot read lgdir inode\n")
        printk0("[ext4-largedir] FAIL\n")
        return
    if ext4_inode_is_htree_dir(&dirbuf[0]) == 0:
        printk0("[ext4-largedir] FAIL: lgdir is not an htree dir\n")
        printk0("[ext4-largedir] FAIL\n")
        return

    levels_before: int64 = _ext4_htins_dx_levels(dir_inum)
    blocks_before: uint64 = cast[uint64](
        ext4_inode_size_lo(&dirbuf[0])) / ext4_block_size
    printk2("[ext4-largedir] before: indirect_levels=%d, %d dir blocks\n",
            cast[uint64](levels_before), blocks_before)
    # The fixture is minted as a 2-level htree (root near-full); if it is
    # not, the test cannot exercise the 1->2 growth.
    if levels_before != 1:
        printk1("[ext4-largedir] FAIL: fixture not 2-level (got %d)\n",
                cast[uint64](levels_before))
        printk0("[ext4-largedir] FAIL\n")
        return
    printk0("[ext4-largedir] PASS fixture starts as a 2-level htree\n")

    # A pre-existing seed name must resolve up-front (proves the growth
    # below doesn't lose it). Use seed index 0.
    _ext4_largedir_make_name(0)
    seed_name: Ptr[char] = cast[Ptr[char]](&ext4_largedir_namebuf[0])
    pre_inum: uint32 = ext4_dir_lookup_htree(&dirbuf[0], seed_name)
    if pre_inum == 0 or ext4_htree_used == 0:
        printk0("[ext4-largedir] FAIL: seed name missing before inserts\n")
        ok_all = 0

    # Insert fresh long names DIRECTLY via ext4_htree_dir_insert (each
    # dirent points at the existing root inode; no inode/data-block alloc)
    # until the dx_root overflows and the tree grows to indirect_levels==2
    # (3 levels). Stop as soon as growth is observed. Record the inserted
    # count so the lookup phase can replay every name.
    inserted: uint64 = 0
    grew: int32 = 0
    i: uint64 = 0
    while i < EXT4_LARGEDIR_MAX_INSERT:
        _ext4_largedir_make_name(EXT4_LARGEDIR_SEED_BASE + i)
        rc: int32 = ext4_htree_dir_insert(
            cast[uint64](dir_inum),
            cast[Ptr[char]](&ext4_largedir_namebuf[0]),
            EXT4_LARGEDIR_CHILD_INUM, 1)
        if rc != 0:
            printk1("[ext4-largedir] FAIL: htree insert failed at #%d\n", i)
            ok_all = 0
            i = EXT4_LARGEDIR_MAX_INSERT
        else:
            inserted = inserted + 1
            i = i + 1
            # Check for 1->2 growth every 256 inserts to bound the re-read
            # cost; once it grows we can stop early.
            if (inserted % 256) == 0:
                lv: int64 = _ext4_htins_dx_levels(dir_inum)
                if lv >= 2:
                    grew = 1
                    i = EXT4_LARGEDIR_MAX_INSERT
    printk1("[ext4-largedir] inserted %d new names\n", inserted)

    # Re-read the dir inode (i_size / extents grew across splits + growth).
    if ext4_read_inode(cast[uint64](dir_inum), &dirbuf[0]) != 0:
        printk0("[ext4-largedir] FAIL: re-read lgdir inode\n")
        printk0("[ext4-largedir] FAIL\n")
        return
    levels_after: int64 = _ext4_htins_dx_levels(dir_inum)
    blocks_after: uint64 = cast[uint64](
        ext4_inode_size_lo(&dirbuf[0])) / ext4_block_size
    printk2("[ext4-largedir] after:  indirect_levels=%d, %d dir blocks\n",
            cast[uint64](levels_after), blocks_after)

    # THE core assertion: the tree must have grown to a genuine 3 levels.
    if levels_after < 2:
        printk1("[ext4-largedir] FAIL: index did not reach 3 levels (got %d)\n",
                cast[uint64](levels_after))
        ok_all = 0
    else:
        printk2("[ext4-largedir] PASS index grew %d -> %d levels (3-level htree)\n",
                cast[uint64](levels_before), cast[uint64](levels_after))

    # Verify EVERY inserted name resolves via the (now 3-level) hash
    # descend AND matches the independent linear scan. Track whether any
    # lookup descended a genuine 3-frame path.
    verified: uint64 = 0
    lookups_ok: int32 = 1
    saw_three_frames: int32 = 0
    j: uint64 = 0
    while j < inserted:
        _ext4_largedir_make_name(EXT4_LARGEDIR_SEED_BASE + j)
        nmp: Ptr[char] = cast[Ptr[char]](&ext4_largedir_namebuf[0])
        ext4_htree_used = 0
        ht_inum: uint32 = ext4_dir_lookup_htree(&dirbuf[0], nmp)
        if ext4_htree_used == 0:
            printk1("[ext4-largedir] FAIL: htree path bailed for #%d\n", j)
            lookups_ok = 0
            j = inserted
        elif ht_inum == 0:
            printk1("[ext4-largedir] FAIL: htree miss for #%d\n", j)
            lookups_ok = 0
            j = inserted
        else:
            if ext4_htree_nframes >= 3:
                saw_three_frames = 1
            lin_inum: uint32 = _ext4_dir_lookup_linear(&dirbuf[0], nmp)
            if ht_inum != lin_inum:
                printk2("[ext4-largedir] FAIL: htree %d != linear %d\n",
                        cast[uint64](ht_inum), cast[uint64](lin_inum))
                lookups_ok = 0
                j = inserted
            else:
                verified = verified + 1
                j = j + 1
    if lookups_ok != 0 and verified == inserted and inserted > 0:
        printk1("[ext4-largedir] PASS all %d inserted names resolve via descend\n",
                verified)
    else:
        printk2("[ext4-largedir] FAIL: only %d/%d inserted names verified\n",
                verified, inserted)
        ok_all = 0

    if saw_three_frames != 0:
        printk0("[ext4-largedir] PASS a lookup descended a 3-frame (root->l2->leaf) path\n")
    else:
        printk0("[ext4-largedir] FAIL: no lookup descended a 3-level path\n")
        ok_all = 0

    # The pre-existing seed name must STILL resolve after the growth.
    # Regenerate seed index 0 into the shared name buffer first — the insert
    # and verify loops above overwrote it with later names.
    _ext4_largedir_make_name(0)
    post_inum: uint32 = ext4_dir_lookup_htree(
        &dirbuf[0], cast[Ptr[char]](&ext4_largedir_namebuf[0]))
    if ext4_htree_used != 0 and post_inum != 0 and post_inum == pre_inum:
        printk0("[ext4-largedir] PASS pre-existing seed survived the growth\n")
    else:
        printk0("[ext4-largedir] FAIL: pre-existing seed lost across growth\n")
        ok_all = 0

    if ok_all != 0:
        printk0("[ext4-largedir] PASS\n")
    else:
        printk0("[ext4-largedir] FAIL\n")


def _ext4_dir_lookup_linear(dir_inode_buf: Ptr[uint8],
                            name: Ptr[char]) -> uint32:
    # Pure linear all-block scan, used by the self-test to cross-check
    # the htree descend result. Identical to the fallback in
    # ext4_dir_lookup but never consults the index.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(dir_inode_buf))
    if dir_size == 0:
        return 0
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(dir_inode_buf, lb)
        if phys == 0:
            lb = lb + 1
            continue
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        hit: uint32 = _ext4_dirblock_lookup(name)
        if hit != 0:
            return hit
        lb = lb + 1
    return 0


def ext4_dir_lookup(dir_inode_buf: Ptr[uint8],
                    name: Ptr[char]) -> uint32:
    # Walk EVERY data block of the directory looking for `name`. A
    # directory's size grows in block-sized chunks as it accumulates
    # entries; ~30 entries fills a 1 KiB block, after which ext4
    # allocates another block. Walking only block 0 silently truncates
    # lookups once a directory overflows its first block, so we iterate
    # all blocks here. Returns the matched inode number, or 0 on miss.
    #
    # htree (EXT4_INDEX_FL) directories: hash the name and descend the
    # dx_root/dx_node B-tree to the ONE indexed leaf block (plus any
    # collision-chain continuation), instead of scanning every block.
    # ext4_dir_lookup_htree sets ext4_htree_used=1 once it completes a
    # genuine descend, so a 0 result is a real miss and we return it. On
    # any structural anomaly it leaves the flag 0 and we fall through to
    # the linear scan below (which still works on htree dirs because the
    # index blocks' lone fake entry pads to end-of-block and is skipped).
    if ext4_inode_is_htree_dir(dir_inode_buf) != 0:
        ht_hit: uint32 = ext4_dir_lookup_htree(dir_inode_buf, name)
        if ext4_htree_used != 0:
            return ht_hit
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(dir_inode_buf))
    if dir_size == 0:
        return 0
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(dir_inode_buf, lb)
        if phys == 0:
            # Sparse hole in a directory: skip it, keep walking the
            # remaining mapped blocks rather than aborting the lookup.
            lb = lb + 1
            continue
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        hit: uint32 = _ext4_dirblock_lookup(name)
        if hit != 0:
            return hit
        lb = lb + 1
    return 0


# --- file read ----------------------------------------------------
#
# Walks the extent tree (any depth) looking for the extent that
# contains logical block N. Returns the physical block, or 0 on miss
# (sparse file or N past end-of-file). Index nodes (eh_depth > 0) are
# walked transparently: each level's chosen index record points at a
# child block holding the next-level header, until a depth-0 leaf is
# reached. This is what lets a file exceed the 4-inline-extent ceiling.

def _ext4_logical_to_physical(inode_buf: Ptr[uint8],
                              logical_blk: uint64) -> uint64:
    # Walk the extent tree from the inode's i_block root to the leaf
    # that owns `logical_blk`. The root header lives at inode+0x28;
    # for depth-> 0 we follow index records into a child block,
    # repointing eh at the child's header and looping. Linux's
    # fs/ext4/extents.c::ext4_ext_find_extent does the same.
    #
    # Index-record layout (12 bytes, same size as leaf extents):
    #     0x00  u32 ei_block     lowest logical block this child covers
    #     0x04  u32 ei_leaf_lo   physical block of the child node
    #     0x08  u16 ei_leaf_hi   high 16 bits (48-bit phys total)
    #     0x0A  u16 ei_unused
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    # 5 levels is comfortably more than ext4 ever produces in practice
    # — even 16 TB filesystems top out around 3-4. The bound is here
    # so a malformed header pointing into a cycle doesn't loop forever.
    safety: int32 = 5
    while safety > 0:
        safety = safety - 1
        magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
        if magic != EXT4_EXTENT_MAGIC:
            return 0
        entries: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 2))
        eh_max:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
        depth:   uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 6))
        # On-disk header is UNTRUSTED. Reject an entry count that
        # exceeds the declared capacity (eh_entries <= eh_max) — that
        # would read records past the node's allocation — and a depth
        # the FS never produces. Bail to "unmapped" rather than walk
        # out of bounds. (eh_max==0 at depth 0 is a legitimately empty
        # freshly-created leaf, so only enforce the relation, not >0.)
        if entries > eh_max:
            return 0
        if depth > 5:
            return 0
        if depth == 0:
            # Leaf: find the extent covering logical_blk.
            i: uint16 = 0
            while i < entries:
                ee: uint64 = eh + 12 + cast[uint64](i) * 12
                ee_block:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 0))
                ee_len:      uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 4))
                ee_start_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 6))
                ee_start_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 8))
                eb: uint64 = cast[uint64](ee_block)
                if logical_blk >= eb and logical_blk < eb + cast[uint64](ee_len):
                    phys_base: uint64 = (cast[uint64](ee_start_hi) << 32) \
                                      | cast[uint64](ee_start_lo)
                    return phys_base + (logical_blk - eb)
                i = i + 1
            return 0
        # Index node: pick the RIGHTMOST entry whose ei_block <=
        # logical_blk. Entries are sorted ascending by ei_block, so a
        # simple linear scan with a "best so far" cursor is correct.
        chosen: int32 = -1
        j: uint16 = 0
        while j < entries:
            ei: uint64 = eh + 12 + cast[uint64](j) * 12
            ei_block: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 0))
            if cast[uint64](ei_block) <= logical_blk:
                chosen = cast[int32](j)
            else:
                break
            j = j + 1
        if chosen < 0:
            return 0
        ei: uint64 = eh + 12 + cast[uint64](chosen) * 12
        ei_leaf_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        ei_leaf_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        child_blk: uint64 = (cast[uint64](ei_leaf_hi) << 32) \
                          | cast[uint64](ei_leaf_lo)
        if _ext4_read_block(child_blk, &ext4_ext_scratch[0]) != 0:
            return 0
        eh = cast[uint64](&ext4_ext_scratch[0])
    return 0


# --- inline_data (INCOMPAT_INLINE_DATA) read path ----------------
#
# An inode with EXT4_INODE_INLINE_DATA holds its bytes directly:
#   * bytes [0, 60)        : the i_block[] window at inode offset 0x28
#   * bytes [60, i_size)   : the value of the "system.data" xattr
# There are NO extents / data blocks. The system.data xattr value
# carries exactly i_size-60 bytes (it may itself live in-inode or in
# the external i_file_acl block — ext4_getxattr handles both).

# Scratch for the system.data xattr value (inline overflow past the
# first 60 bytes). One fs block bounds the maximum: the external xattr
# block is a single block, and an in-inode value is far smaller. Sized
# to the largest fs block we mount so a full system.data value never
# overflows this buffer.
ext4_inline_data_buf: Array[4096, uint8]


def _ext4_read_inline_data(inode_buf: Ptr[uint8], pos: uint64,
                           count: uint64, buf: Ptr[uint8]) -> int64:
    # Copy up to `count` bytes from file offset `pos` of an inline-data
    # inode into `buf`. Caller has already clamped count to <= i_size-pos
    # and verified pos < i_size. Returns bytes copied, or -1 on error
    # (system.data xattr expected but missing/too large).
    total: uint64 = 0
    # Part 1: the i_block[] window covers logical bytes [0, 60).
    iblock_base: uint64 = cast[uint64](inode_buf) + EXT4_INLINE_IBLOCK_OFF
    if pos < EXT4_INLINE_IBLOCK_MAX:
        avail: uint64 = EXT4_INLINE_IBLOCK_MAX - pos
        chunk: uint64 = count
        if chunk > avail:
            chunk = avail
        memcpy(buf, cast[Ptr[uint8]](iblock_base + pos), chunk)
        total = chunk
    if total >= count:
        return cast[int64](total)
    # Part 2: bytes at or past offset 60 come from system.data. Fetch the
    # whole value once (bounded by the xattr block) then slice it.
    n: int32 = ext4_getxattr(inode_buf, "system.data", 11,
                             &ext4_inline_data_buf[0], 4096)
    if n < 0:
        return -1
    val_len: uint64 = cast[uint64](n)
    # File offset of the next byte we still owe the caller.
    next_off: uint64 = pos + total
    # Offset of that byte inside the system.data value (value byte 0 maps
    # to file offset 60).
    xoff: uint64 = next_off - EXT4_INLINE_IBLOCK_MAX
    if xoff >= val_len:
        return cast[int64](total)
    want: uint64 = count - total
    avail2: uint64 = val_len - xoff
    if want > avail2:
        want = avail2
    memcpy(cast[Ptr[uint8]](cast[uint64](buf) + total),
           cast[Ptr[uint8]](cast[uint64](&ext4_inline_data_buf[0]) + xoff),
           want)
    total = total + want
    return cast[int64](total)


def ext4_read_file(inum: uint32, pos: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int64:
    # Reads `count` bytes starting at file offset `pos` from the
    # file at inode `inum`. Returns bytes read; 0 on EOF.
    #
    # Linux-parity page cache: normal (non-inline/verity/crypt) extent reads
    # are served PAGE-BY-PAGE through the per-inode address_space (fcache).
    # A page resident in the cache skips the extent walk + block I/O
    # entirely; a miss populates the page from the backing store via
    # _ext4_read_file_raw and is then served from the cache on the next read.
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    size: uint64 = cast[uint64](ext4_inode_size_lo(&inode[0]))
    if pos >= size:
        return 0
    remaining: uint64 = size - pos
    if count > remaining:
        count = remaining

    # inline_data inode: bytes live in the inode (i_block[] + system.data
    # xattr), not in extents. Gated on the mount-time feature flag. These
    # do NOT go through the page cache (no stable backing pages).
    if ext4_inode_is_inline(&inode[0]) != 0:
        return _ext4_read_inline_data(&inode[0], pos, count, buf)

    # verity / fscrypt inodes also bypass the page cache (the verified /
    # decrypted bytes are produced by their own paths below).
    flags_w: uint32 = ext4_inode_flags(&inode[0])
    if (flags_w & EXT4_VERITY_FL) == 0 \
            and (flags_w & EXT4_ENCRYPT_FL) == 0:
        return _ext4_read_file_cached(cast[uint32](inum), pos, count,
                                      size, buf)
    return _ext4_read_file_raw(inum, pos, count, buf)


def _ext4_read_file_cached(inum: uint32, pos: uint64, count: uint64,
                           size: uint64, buf: Ptr[uint8]) -> int64:
    # Page-cache front end for normal extent reads. `count` is already
    # clamped to <= size-pos by the caller. Serves each touched page from
    # the per-inode address_space, populating misses from the raw reader.
    srv: int32 = PC_SRV_EXT4
    ino:  uint64 = cast[uint64](inum)
    total: uint64 = 0
    pgtmp: Array[4096, uint8]
    while total < count:
        cur_off:   uint64 = pos + total
        pg_index:  uint64 = cur_off / PC_PAGE_SIZE
        off_in_pg: uint64 = cur_off % PC_PAGE_SIZE
        chunk: uint64 = PC_PAGE_SIZE - off_in_pg
        if chunk > count - total:
            chunk = count - total
        slot: int64 = fcache_page_lookup(srv, ino, pg_index)
        if slot < 0:
            # MISS: read the full page from backing (clamped to EOF) and
            # install it, then serve from the freshly cached copy.
            pg_base: uint64 = pg_index * PC_PAGE_SIZE
            want: uint64 = PC_PAGE_SIZE
            if pg_base + want > size:
                want = size - pg_base
            got: int64 = _ext4_read_file_raw(inum, pg_base, want, &pgtmp[0])
            if got < 0:
                if total > 0:
                    return cast[int64](total)
                return got
            fcache_page_install(srv, ino, pg_index, &pgtmp[0],
                                cast[uint64](got), 0)
            slot = fcache_page_lookup(srv, ino, pg_index)
            if slot < 0:
                # Cache could not hold the page (shouldn't happen) — fall
                # back to a direct backing read for this chunk.
                got2: int64 = _ext4_read_file_raw(inum, cur_off, chunk,
                    cast[Ptr[uint8]](cast[uint64](buf) + total))
                if got2 <= 0:
                    return cast[int64](total)
                total = total + cast[uint64](got2)
                continue
        pdata: uint64 = fcache_page_data(cast[uint64](slot))
        memcpy(cast[Ptr[uint8]](cast[uint64](buf) + total),
               cast[Ptr[uint8]](pdata + off_in_pg), chunk)
        total = total + chunk
    return cast[int64](total)


def _ext4_read_file_raw(inum: uint32, pos: uint64, count: uint64,
                        buf: Ptr[uint8]) -> int64:
    # The original extent-walk reader (no page cache). Used to populate the
    # page cache and to serve inline/verity/fscrypt inodes directly.
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    size: uint64 = cast[uint64](ext4_inode_size_lo(&inode[0]))
    if pos >= size:
        return 0
    remaining: uint64 = size - pos
    if count > remaining:
        count = remaining

    if ext4_inode_is_inline(&inode[0]) != 0:
        return _ext4_read_inline_data(&inode[0], pos, count, buf)

    # fs-verity: if this inode carries EXT4_VERITY_FL AND the verity
    # registry holds its Merkle tree, route the read through the verified
    # block path. Every data block returned is checked against its salted
    # SHA-256 Merkle leaf up to the trusted root; tampering with the data
    # OR the hash tree fails the read with EIO (-5). Non-verity inodes
    # skip this entirely and behave exactly as before.
    if (ext4_inode_flags(&inode[0]) & EXT4_VERITY_FL) != 0:
        vslot: int32 = _ext4_verity_find(cast[uint32](inum))
        if vslot >= 0:
            return _ext4_verity_read(cast[uint32](inum), vslot,
                                     &inode[0], pos, count, buf)

    # fscrypt: if this inode carries EXT4_ENCRYPT_FL AND the fscrypt registry
    # holds its per-file content key, route the read through the decrypt
    # path. Each ext4 data block was stored AES-256-XTS-encrypted (tweak =
    # file logical block number); the decrypt path fetches the CIPHERTEXT off
    # disk and XTS-decrypts it back to plaintext. Non-encrypted inodes skip
    # this entirely and behave exactly as before.
    if (ext4_inode_flags(&inode[0]) & EXT4_ENCRYPT_FL) != 0:
        cslot: int32 = _ext4_fscrypt_find(cast[uint32](inum))
        if cslot >= 0:
            return _ext4_fscrypt_read(cast[uint32](inum), cslot,
                                      &inode[0], pos, count, buf)

    total: uint64 = 0
    while total < count:
        cur_off: uint64 = pos + total
        logical_blk: uint64 = cur_off / ext4_block_size
        off_in_blk:  uint64 = cur_off % ext4_block_size
        chunk: uint64 = ext4_block_size - off_in_blk
        if chunk > count - total:
            chunk = count - total
        phys_blk: uint64 = _ext4_logical_to_physical(&inode[0],
                                                    logical_blk)
        if phys_blk == 0:
            # SPARSE-FILE HOLE: a logical block inside i_size with no
            # extent coverage reads as ZEROS (Linux semantics) — it is
            # NOT EOF. mke2fs -d and rsync --sparse stage all-zero
            # blocks as holes (e.g. ld.so's inter-PT_LOAD zero padding),
            # so bailing here used to TRUNCATE every sparse file at its
            # first hole — the #410 live-Debian W^X root cause: ld.so
            # came back 161 KiB of 220 KiB and executed garbage.
            _ext4_zero(cast[Ptr[uint8]](cast[uint64](buf) + total),
                       chunk)
            total = total + chunk
        else:
            if _ext4_read_block(phys_blk, &ext4_blk_buf[0]) != 0:
                return cast[int64](total)
            memcpy(cast[Ptr[uint8]](cast[uint64](buf) + total),
                   cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0])
                                    + off_in_blk),
                   chunk)
            total = total + chunk
    return cast[int64](total)


# --- open-file slot table for VFS integration --------------------

class Ext4OpenFile:
    used:      uint32
    pad:       uint32
    inum:      uint32
    pad2:      uint32
    file_size: uint64


# Capacity of the GLOBAL ext4 open-file table (every task, every process,
# shares it). This was 8 — a ceiling any real Linux program blows through
# instantly, and the failure was SILENT AND MISLEADING: ext4_open returned
# the same -1 for "no such file" and "table full", and vfs's
# _open_ext4_read mapped that -1 to ENOENT. So the 9th concurrently-open
# ext4 file, and every one after it, reported "no such file" for a file
# that plainly exists.
#
# That is exactly what wedged Firefox (#73 / the wl_shm-no-commit hang):
# the browser holds its DSOs + omni.ja open, so by the time Pango's
# fontconfig worker thread runs FcInit() every font open() answered ENOENT.
# fontconfig therefore built an EMPTY system font set, FcFontSetMatch() and
# FcFontSetSort() both returned NULL, and Pango's
#     while (!pats->match && !pats->fontset) g_cond_wait (&pats->cond, ...)
# (pangofc-fontmap.c:1193) never terminated — the main thread parked
# forever, so nsWindow::Show() never ran and no xdg_toplevel / wl_shm
# buffer was ever committed. Nothing was wrong with the futex, the
# compositor, or the transport.
#
# 512 slots x sizeof(Ext4OpenFile) (24 B) = 12 KiB of BSS — nothing, and it
# comfortably covers the per-task fd ceiling (_VFS_NR_FDS = 64) times a
# handful of live Linux processes. Slots are released on namec_close, so
# they are not leaked by an exiting task.
EXT4_MAX_OPEN: uint64 = 512
ext4_open_files: Array[512, Ext4OpenFile]

# Distinguishes ext4_open's two failure modes for callers that care.
# Historically both were -1, which is what made the exhaustion invisible.
EXT4_OPEN_ENOENT: int32 = -1        # path does not resolve
EXT4_OPEN_EMFILE: int32 = -2        # open-file table exhausted


def _ext4_path_next_component(path: Ptr[char], start: uint64,
                              out_buf: Ptr[uint8]) -> int64:
    # Same shape as fat's _path_next_component: copy bytes into
    # out_buf until '/' or NUL. NUL-terminate, return index of byte
    # after the slash or -1 on NUL termination.
    i: uint64 = 0
    while True:
        c: int32 = path[start + i]
        if c == 0:
            out_buf[i] = 0
            return -1
        if c == 47:                               # '/'
            out_buf[i] = 0
            return cast[int64](start + i + 1)
        out_buf[i] = cast[uint8](c & 0xFF)
        i = i + 1


# --- symlink follow (M16.68) --------------------------------------
#
# ext4 stores symlink targets two ways:
#
#   * "fast" link (i_size <= 60): target lives INLINE in i_block,
#     the same 60-byte window normally used for the extent tree.
#     mkfs/debugfs sets i_blocks_lo = 0 because no data block is
#     allocated. Linux's ext4_inode_is_fast_symlink() uses the same
#     test; the read just memcpy's out of i_block.
#   * "slow" link (i_size > 60): target lives in the file's first
#     data block, reached via the standard extent walk.
#
# In both cases the target is a raw byte string with no trailing NUL
# on disk — we add one ourselves on the way out so the caller can
# treat it as a C string.

# Working buffers for path rewriting during symlink follow. Single
# mount, single thread, so a pair of static buffers is enough.
ext4_path_work: Array[256, uint8]
ext4_link_target: Array[256, uint8]


def _ext4_read_symlink_target(inode_buf: Ptr[uint8],
                              out_buf: Ptr[uint8],
                              out_size: uint64) -> int32:
    # Read the symlink's target into out_buf, NUL-terminated. Returns
    # 0 on success, -1 on read failure or empty/truncated link.
    if out_size == 0:
        return -1
    isize: uint64 = cast[uint64](ext4_inode_size_lo(inode_buf))
    if isize == 0:
        out_buf[0] = 0
        return -1
    # Reserve one byte for our NUL terminator.
    take: uint64 = isize
    if take > out_size - 1:
        take = out_size - 1
    if isize <= 60:
        # Fast symlink: target inline in i_block at offset 0x28.
        src: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
        memcpy(out_buf, cast[Ptr[uint8]](src), take)
    else:
        # Slow symlink: target lives in the first data block. Reuse
        # the standard extent → physical → read pipeline.
        phys: uint64 = _ext4_logical_to_physical(inode_buf, 0)
        if phys == 0:
            return -1
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        memcpy(out_buf, &ext4_blk_buf[0], take)
    out_buf[take] = 0
    return 0


def _ext4_strlen_u8(s: Ptr[uint8]) -> uint64:
    n: uint64 = 0
    while s[n] != 0:
        n = n + 1
    return n


def _ext4_path_starts_with_ext(s: Ptr[uint8]) -> int32:
    # Match "/ext/" prefix on a raw byte buffer.
    prefix: Ptr[uint8] = "/ext/"
    i: uint64 = 0
    while i < 5:
        if s[i] != prefix[i]:
            return 0
        i = i + 1
    return 1


# Resolution result returned by _resolve_with_symlinks. Callers pull
# the bits they care about (file vs dir, inum, file size).
class Ext4ResolveResult:
    inum:       uint32
    is_dir:     uint32
    file_size:  uint64


def _resolve_with_symlinks(path: Ptr[char],
                           result: Ptr[Ext4ResolveResult]) -> int32:
    # Walk `path` from the ext4 root with symlink follow-through. On
    # an intermediate (or final) component that resolves to a symlink,
    # splice the target into the working path string and restart from
    # root. Bounded at 8 follows to break loops (matches Linux's
    # MAXSYMLINKS default).
    #
    # Returns 1 on hit (fills *result), 0 on miss.
    if path[0] == 0:
        # Empty path → ext4 root.
        result[0].inum      = 2
        result[0].is_dir    = 1
        result[0].file_size = 0
        return 1

    # Snapshot the input path into our mutable scratch.
    pi: uint64 = 0
    while True:
        c: int32 = path[pi]
        if pi >= 255:
            return 0
        ext4_path_work[pi] = cast[uint8](c & 0xFF)
        if c == 0:
            break
        pi = pi + 1

    follows: int32 = 0
    while True:
        cur_inode: Array[256, uint8]
        if ext4_read_inode(2, &cur_inode[0]) != 0:
            return 0
        cur_inum: uint32 = 2
        component: Array[64, uint8]
        start: uint64 = 0
        restart: int32 = 0
        while restart == 0:
            nxt: int64 = _ext4_path_next_component(
                cast[Ptr[char]](&ext4_path_work[0]), start,
                &component[0])
            if component[0] == 0:
                # Empty component. For a trailing slash on a dir path
                # we want to return the current dir; bare empty path
                # was handled above.
                if nxt < 0:
                    result[0].inum      = cur_inum
                    result[0].is_dir    = 1
                    result[0].file_size = 0
                    return 1
                start = cast[uint64](nxt)
                continue
            inum: uint32 = ext4_dir_lookup(&cur_inode[0],
                                           cast[Ptr[char]](&component[0]))
            if inum == 0:
                return 0
            if ext4_read_inode(cast[uint64](inum), &cur_inode[0]) != 0:
                return 0
            mode: uint16 = ext4_inode_mode(&cur_inode[0])
            type_bits: uint16 = mode & 0xF000

            if type_bits == S_IFLNK:
                if follows >= 8:
                    return 0
                follows = follows + 1
                if _ext4_read_symlink_target(
                        &cur_inode[0], &ext4_link_target[0], 256) != 0:
                    return 0
                # Splice the target into ext4_path_work.
                # `start` currently points at the first byte of the
                # component we just consumed; `nxt` points one byte
                # past the slash that ended it (or is -1 for the
                # last component). The "tail" (bytes still to walk)
                # is ext4_path_work[nxt..] for nxt >= 0, else "".
                tail_start: uint64 = 0
                has_tail: int32 = 0
                if nxt >= 0:
                    tail_start = cast[uint64](nxt)
                    if ext4_path_work[tail_start] != 0:
                        has_tail = 1
                # Pull tail out into its own scratch so we can rewrite
                # ext4_path_work in place. Reuse `component` (64 B) for
                # short tails; bail if the tail wouldn't fit.
                tail_buf: Array[256, uint8]
                tail_len: uint64 = 0
                if has_tail != 0:
                    j: uint64 = 0
                    while j < 255:
                        b: uint8 = ext4_path_work[tail_start + j]
                        tail_buf[j] = b
                        if b == 0:
                            break
                        j = j + 1
                    tail_buf[255] = 0
                    tail_len = j

                # Pick the new "prefix" (bytes before the symlink
                # component) and the spliced "middle" (the target).
                tgt: Ptr[uint8] = &ext4_link_target[0]
                middle_off: uint64 = 0          # how many bytes of tgt to skip
                prefix_len: uint64 = 0          # bytes of ext4_path_work to keep
                if ext4_link_target[0] == 47:   # '/'
                    # Absolute target. Restart the walk from the ext4
                    # root. Two flavors:
                    #   * "/ext/foo"  — kernel-namespace absolute path.
                    #     Strip the "/ext/" prefix and walk "foo".
                    #   * "/foo"      — ext4-namespace absolute (what
                    #     debugfs writes by default). Skip the single
                    #     leading slash and walk "foo".
                    if _ext4_path_starts_with_ext(tgt) != 0:
                        middle_off = 5          # skip "/ext/"
                    else:
                        middle_off = 1          # skip "/"
                    prefix_len = 0
                else:
                    middle_off = 0
                    prefix_len = start          # keep walked-bytes
                tgt_len: uint64 = _ext4_strlen_u8(tgt)
                if tgt_len < middle_off:
                    return 0
                tgt_len = tgt_len - middle_off

                # Build the new working path: [prefix][target tail]['/' tail].
                need: uint64 = prefix_len + tgt_len
                if has_tail != 0:
                    need = need + 1 + tail_len  # '/' + tail bytes
                if need >= 255:
                    return 0
                # If prefix_len == 0 we'd be overwriting from index 0
                # — same as the "restart from root" case. Either way,
                # write the target into [prefix_len..] then '/' + tail.
                k: uint64 = 0
                while k < tgt_len:
                    ext4_path_work[prefix_len + k] = \
                        ext4_link_target[middle_off + k]
                    k = k + 1
                wpos: uint64 = prefix_len + tgt_len
                if has_tail != 0:
                    ext4_path_work[wpos] = 47   # '/'
                    wpos = wpos + 1
                    m: uint64 = 0
                    while m < tail_len:
                        ext4_path_work[wpos + m] = tail_buf[m]
                        m = m + 1
                    wpos = wpos + tail_len
                ext4_path_work[wpos] = 0
                restart = 1
                continue

            is_dir: int32 = 0
            if type_bits == 0x4000:
                is_dir = 1
            if nxt < 0:
                # Last component.
                result[0].inum = inum
                if is_dir != 0:
                    result[0].is_dir    = 1
                    result[0].file_size = 0
                else:
                    result[0].is_dir    = 0
                    result[0].file_size = cast[uint64](
                        ext4_inode_size_lo(&cur_inode[0]))
                return 1
            # Intermediate component. Must be a directory now.
            if is_dir == 0:
                return 0
            cur_inum = inum
            start = cast[uint64](nxt)


def ext4_resolve_file(path: Ptr[char], out_inum: Ptr[uint32],
                      out_size: Ptr[uint64]) -> int32:
    # Walk `path` (caller already stripped /ext/) component by
    # component. Each component must be a directory entry in the
    # current directory; the LAST component must be a regular file.
    # Returns 1 on hit (fills out_inum / out_size), 0 on miss.
    #
    # Intermediate or final components that are symlinks are followed
    # transparently (M16.68); bounded at 8 follows to break loops.
    #
    # Lazy mkfs self-test wake (opt-in, single-shot). Historically
    # is_ext_path() fired this on every VFS open; now that vfs.ad selects
    # the ext4 backend through the mount table instead of strcmp, the
    # chokepoint moves here — the first userland /ext file resolve wakes
    # the (gated, normally-no-op) self-test. See scripts/test_mkfs.sh.
    _ext4_mkfs_self_test_maybe()
    if path[0] == 0:
        return 0                                  # empty path → root, not a file
    r: Ext4ResolveResult
    if _resolve_with_symlinks(path, &r) == 0:
        return 0
    if r.is_dir != 0:
        return 0
    out_inum[0] = r.inum
    out_size[0] = r.file_size
    return 1


def ext4_resolve_dir(path: Ptr[char]) -> uint32:
    # Walk path to a DIRECTORY inode, returning its inum. Empty
    # path → root (inum 2). Returns 0 on miss / not-a-dir.
    # Symlink-aware (M16.68): intermediate symlinks follow through.
    _ext4_mkfs_self_test_maybe()
    if path[0] == 0:
        return 2
    r: Ext4ResolveResult
    if _resolve_with_symlinks(path, &r) == 0:
        return 0
    if r.is_dir == 0:
        return 0
    return r.inum


def ext4_read_root_file(name: Ptr[char], out_buf: Ptr[uint8],
                        cap: uint64, out_size: Ptr[uint64]) -> int32:
    # Read the file at `/<name>` (relative to the partition root) into
    # `out_buf`, up to `cap` bytes. Writes the actual bytes-read count
    # to out_size. Returns 0 on success, -1 on:
    #   * not-mounted (ext4_blockdev_slot < 0)
    #   * file absent / is-a-dir
    #   * read error from the block layer.
    #
    # Used by init/main.ad's Phase 5 sentinel discovery to read
    # `.hamnix-roots` from the partition root before deciding whether
    # to register named or anonymous mounts.
    if ext4_blockdev_slot < 0:
        return -1
    if name == cast[Ptr[char]](0) or name[0] == 0:
        return -1
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(name, &inum, &fsize) == 0:
        return -1
    take: uint64 = fsize
    if take > cap:
        take = cap
    n: int64 = ext4_read_file(inum, 0, take, out_buf)
    if n < 0:
        return -1
    out_size[0] = cast[uint64](n)
    return 0


def ext4_open(name: Ptr[char]) -> int32:
    # Open /ext/<name> (caller already stripped /ext/). Walks the
    # full path so nested files like /ext/SUB/NESTED.TXT resolve.
    # Snapshots inum + size into a slot. Returns slot index or -1.
    if ext4_blockdev_slot < 0:
        set_current_errstr("ext4: volume not mounted")
        return EXT4_OPEN_ENOENT
    if name[0] == 0:
        set_current_errstr("ext4: open: empty path")
        return EXT4_OPEN_ENOENT                  # not for the root dir
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(name, &inum, &fsize) == 0:
        set_current_errstr("ext4: no such file")
        return EXT4_OPEN_ENOENT
    i: uint64 = 0
    while i < EXT4_MAX_OPEN:
        if ext4_open_files[i].used == 0:
            ext4_open_files[i].used      = 1
            ext4_open_files[i].inum      = inum
            ext4_open_files[i].file_size = fsize
            return cast[int32](i)
        i = i + 1
    # Exhaustion must NEVER be silent again: for years this printk was
    # INFO-level (swallowed by console_set_interactive's gate) and the
    # errno handed to userspace was ENOENT, so a program that ran out of
    # slots was told its files had vanished. Stamp EMERG so the line always
    # reaches the serial console, and return a DISTINCT code so
    # _open_ext4_read can answer EMFILE like a real kernel.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("ext4: open-file table full (%d slots) - returning EMFILE\n",
            EXT4_MAX_OPEN)
    set_current_errstr("ext4: open-file table full")
    return EXT4_OPEN_EMFILE


def ext4_close(slot: int32):
    ext4_open_files[cast[uint64](slot)].used = 0


def ext4_open_size(slot: int32) -> uint64:
    return ext4_open_files[cast[uint64](slot)].file_size


def ext4_open_inum(slot: int32) -> uint32:
    return ext4_open_files[cast[uint64](slot)].inum


def ext4_set_open_size(slot: int32, size: uint64):
    # Refresh the cached file_size after an out-of-band size change
    # (ftruncate) so ext4_open_size() stays accurate for read-back.
    if slot < 0:
        return
    ext4_open_files[cast[uint64](slot)].file_size = size


def ext4_listdir(path: Ptr[char], buf: Ptr[uint8],
                 count: uint64) -> int64:
    # Pack the named directory's entries into buf as "NAME\n" lines.
    # path is the post-/ext/-strip tail (e.g. "" for root, "SUB"
    # for /ext/SUB). Walks every data block of the resolved
    # directory inode, so dirs that span multiple blocks (root
    # with many files, etc.) list completely.
    if count == 0:
        return -1
    if ext4_blockdev_slot < 0:
        return -1
    dir_inum: uint32 = ext4_resolve_dir(path)
    if dir_inum == 0:
        return -2                                # -ENOENT
    dir_inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](dir_inum), &dir_inode[0]) != 0:
        return -1
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&dir_inode[0]))
    if dir_size == 0:
        return 0
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    out: uint64 = 0
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&dir_inode[0], lb)
        if phys == 0:
            # Sparse hole — skip and keep enumerating later blocks.
            lb = lb + 1
            continue
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return cast[int64](out)
        pos: uint64 = 0
        while pos + DIR_ENTRY_HDR_BYTES <= ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            ent_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            rec_len:  uint64 = cast[uint64](
                _ext4_read_u16(cast[Ptr[uint8]](e + 4)))
            if rec_len < DIR_ENTRY_HDR_BYTES:
                break                              # malformed, next block
            if pos + rec_len > ext4_block_size:
                break                              # record runs off block
            if ent_inum != 0:
                name_len: uint64 = cast[uint64](cast[Ptr[uint8]](e + 6)[0])
                # Bound name against record AND block before copying.
                if DIR_ENTRY_HDR_BYTES + name_len <= rec_len and \
                   pos + DIR_ENTRY_HDR_BYTES + name_len <= ext4_block_size:
                    # Need room for the name + '\n' + 1 spare for NUL.
                    if out + name_len + 1 >= count:
                        return cast[int64](out)
                    i: uint64 = 0
                    while i < name_len:
                        buf[out + i] = cast[Ptr[uint8]](e + 8 + i)[0]
                        i = i + 1
                    buf[out + name_len] = 10        # '\n'
                    out = out + name_len + 1
            pos = pos + rec_len
        lb = lb + 1
    return cast[int64](out)


def strip_ext_prefix(name: Ptr[char]) -> Ptr[char]:
    # "/ext/" is 5 chars.
    return cast[Ptr[char]](cast[uint64](name) + 5)


def ext4_dir_dump(dir_inode_buf: Ptr[uint8]):
    # Print every entry's name across ALL data blocks of the directory
    # (not just block 0). Walks the inode's extent map block by block,
    # scanning each block's linear ext4_dir_entry_2 records with strict
    # bounds against untrusted on-disk data. htree (EXT4_INDEX_FL) dirs
    # are dumped by linear-leaf-scan: index blocks contribute their lone
    # fake (inode==0) entry only, so just the real leaf entries print.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(dir_inode_buf))
    if dir_size == 0:
        printk0("ext4: empty/index directory (M16.54)\n")
        return
    if ext4_inode_is_htree_dir(dir_inode_buf) != 0:
        printk0("ext4: htree dir (linear-leaf-scan)\n")
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(dir_inode_buf, lb)
        if phys == 0:
            lb = lb + 1
            continue
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            printk0("ext4: dir block read failed\n")
            return
        pos: uint64 = 0
        while pos + DIR_ENTRY_HDR_BYTES <= ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            rec_len: uint64 = cast[uint64](
                _ext4_read_u16(cast[Ptr[uint8]](e + 4)))
            if rec_len < DIR_ENTRY_HDR_BYTES:
                break                              # malformed, next block
            if pos + rec_len > ext4_block_size:
                break                              # record runs off block
            if inum != 0:
                name_len: uint64 = cast[uint64](cast[Ptr[uint8]](e + 6)[0])
                if DIR_ENTRY_HDR_BYTES + name_len <= rec_len and \
                   pos + DIR_ENTRY_HDR_BYTES + name_len <= ext4_block_size:
                    printk1("  dirent inode=%d name='", cast[uint64](inum))
                    i: uint64 = 0
                    while i < name_len:
                        printk1("%c",
                                cast[uint64](cast[Ptr[uint8]](e + 8 + i)[0]))
                        i = i + 1
                    printk0("'\n")
            pos = pos + rec_len
        lb = lb + 1


# --- block bitmap (M16.61) ----------------------------------------
#
# Each block group has a one-block bitmap with one bit per data block
# in the group. Bit set = block is allocated; bit clear = block is
# free. Layout (low bit first within each byte — matches Linux):
#
#     byte 0: bits for blocks N+0..N+7   (low bit = N+0)
#     byte 1: bits for blocks N+8..N+15
#     ...
#
# where N is the group's first data block. Group 0's bitmap typically
# lives at the block named in the group descriptor's
# bg_block_bitmap_lo field (offset 0). For 64BIT ext4, bg_block_bitmap
# is split lo/hi at offsets 0 and 0x20, but our 1 MiB test image stays
# 32-bit so the hi half is unused.
#
# Scratch buffer for one bitmap block. Separate from ext4_blk_buf
# because alloc callers want to keep their dir/extent buffer intact
# while we mutate the bitmap.

ext4_bitmap_buf: Array[4096, uint8]


def _ext4_group_desc_field_u32(grp: uint64, field_off: uint64) -> uint32:
    # Read a u32 field at byte offset `field_off` within group `grp`'s
    # descriptor. Returns 0 on read failure (caller checks against
    # known-nonzero fields like bg_block_bitmap).
    desc_byte_off: uint64 = grp * ext4_desc_size
    gdt_block:     uint64 = ext4_gdt_block + desc_byte_off / ext4_block_size
    within:        uint64 = desc_byte_off % ext4_block_size
    if _ext4_read_block(gdt_block, &ext4_blk_buf[0]) != 0:
        return 0
    return _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0]) + within + field_off))


def _ext4_group_desc_block_u64(grp: uint64, lo_off: uint64,
                               hi_off: uint64) -> uint64:
    # Read a block-number field from group `grp`'s descriptor that is
    # split into a low u32 at `lo_off` and (on a 64BIT / >=64-byte
    # descriptor) a high u32 at `hi_off`. This is THE accessor for the
    # bg_block_bitmap / bg_inode_bitmap / bg_inode_table block numbers,
    # which on a flex_bg image point at the (relocated) packed metadata
    # in the flex group's leader. Trusting these descriptor-supplied
    # locations — rather than computing a fixed per-group layout — is
    # exactly what makes flex_bg read correctly.
    #
    # The hi half is folded in ONLY when ext4_64bit is armed; a 32-bit
    # image reads the lo half alone, so a 32-byte descriptor's
    # nonexistent hi area is never touched (bit-for-bit unchanged).
    desc_byte_off: uint64 = grp * ext4_desc_size
    gdt_block:     uint64 = ext4_gdt_block + desc_byte_off / ext4_block_size
    within:        uint64 = desc_byte_off % ext4_block_size
    if _ext4_read_block(gdt_block, &ext4_blk_buf[0]) != 0:
        return 0
    lo: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0]) + within + lo_off))
    block: uint64 = cast[uint64](lo)
    if ext4_64bit != 0:
        hi: uint32 = _ext4_read_u32(
            cast[Ptr[uint8]](cast[uint64](&ext4_blk_buf[0]) + within + hi_off))
        block = block | (cast[uint64](hi) << 32)
    return block


def _ext4_num_groups() -> uint64:
    # Number of block groups in the mounted FS. Derived from the
    # current ext4_blocks_count (which ext4_init refreshes from the
    # on-disk superblock, including post-grow re-init).
    #
    #   blocks_count = first_data_block + ngroups * blocks_per_group
    # for fully-populated groups. ext4 allows a partial tail group;
    # round UP so the tail's bitmap is searched too.
    if ext4_blocks_per_grp == 0:
        return 1
    if ext4_blocks_count <= ext4_first_data_blk:
        return 1
    span: uint64 = ext4_blocks_count - ext4_first_data_blk
    return (span + ext4_blocks_per_grp - 1) / ext4_blocks_per_grp


# --- allocator metadata maintenance (free counts + metadata_csum) ----
#
# The block/inode allocators mutate a group's bitmap in place. For the
# on-disk image to stay e2fsck-clean every such mutation must ALSO:
#   * adjust that group's GDT free-block / free-inode count,
#   * (metadata_csum) recompute the group's bitmap csum + bg_checksum,
#   * adjust the superblock's free-block / free-inode count + s_checksum
#     and write the superblock back.
# These helpers centralise that bookkeeping so alloc/free stay symmetric
# and a write→e2fsck round-trip is green on a metadata_csum FS (the
# shape the installer's grown root carries). On a no-csum FS the csum
# steps are skipped but the free-count maintenance still runs.

def _ext4_mounted_gd_csum(desc: Ptr[uint8], group: uint64) -> uint16:
    # bg_checksum for the MOUNTED volume, mirroring _ext4_resize_gd_csum
    # but seeded by the mounted ext4_csum_seed and sized by ext4_desc_size.
    g_le: Array[4, uint8]
    _ext4_write_u32(&g_le[0], cast[uint32](group))
    crc: uint32 = crc32c_update(ext4_csum_seed, &g_le[0], 4)
    crc = crc32c_update(crc, desc, EXT4_BG_CHECKSUM)
    zero2: Array[2, uint8]
    zero2[0] = 0
    zero2[1] = 0
    crc = crc32c_update(crc, &zero2[0], 2)
    after: uint64 = EXT4_BG_CHECKSUM + 2
    if ext4_desc_size > after:
        crc = crc32c_update(
            crc,
            cast[Ptr[uint8]](cast[uint64](desc) + after),
            ext4_desc_size - after)
    return cast[uint16](crc & 0xFFFF)


def _ext4_gd_update_after_bitmap(grp: uint64, is_inode: int32,
                                 bitmap: Ptr[uint8],
                                 free_delta: int64) -> int32:
    # Read group `grp`'s descriptor, apply `free_delta` to its free-block
    # (is_inode==0) or free-inode (is_inode!=0) count, refresh the matching
    # bitmap csum (metadata_csum only), recompute bg_checksum, and write
    # the GDT block back. `bitmap` is the FULL bitmap block just persisted.
    desc_byte_off: uint64 = grp * ext4_desc_size
    gdt_block:     uint64 = ext4_gdt_block + desc_byte_off / ext4_block_size
    within:        uint64 = desc_byte_off % ext4_block_size
    if _ext4_read_block(gdt_block, &ext4_blk_buf[0]) != 0:
        return -1
    entry: uint64 = cast[uint64](&ext4_blk_buf[0]) + within

    # --- free count (lo + optional hi half) ---
    free_lo_off: uint64 = EXT4_BG_FREE_BLOCKS_LO
    free_hi_off: uint64 = EXT4_BG_FREE_BLOCKS_HI
    if is_inode != 0:
        free_lo_off = EXT4_BG_FREE_INODES_LO
        free_hi_off = EXT4_BG_FREE_INODES_HI
    cur: uint64 = cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](entry + free_lo_off)))
    has_hi: int32 = 0
    if ext4_64bit != 0 and ext4_desc_size >= 64:
        has_hi = 1
        cur = cur | (cast[uint64](_ext4_read_u16(
            cast[Ptr[uint8]](entry + free_hi_off))) << 16)
    new_free: uint64 = cast[uint64](cast[int64](cur) + free_delta)
    _ext4_write_u16(cast[Ptr[uint8]](entry + free_lo_off),
                    cast[uint16](new_free & 0xFFFF))
    if has_hi != 0:
        _ext4_write_u16(cast[Ptr[uint8]](entry + free_hi_off),
                        cast[uint16]((new_free >> 16) & 0xFFFF))

    # --- bitmap csum (metadata_csum only) ---
    if ext4_metadata_csum != 0:
        # Linux checksums the live-bit span, not the whole block: block
        # bitmaps over clusters_per_group/8, inode bitmaps over
        # (inodes_per_group+7)/8 — both capped at the block size.
        csum_bytes: uint64 = ext4_clusters_per_grp / 8
        lo_off: uint64 = EXT4_BG_BLOCK_BITMAP_CSUM_LO
        hi_off: uint64 = EXT4_BG_BLOCK_BITMAP_CSUM_HI
        if is_inode != 0:
            csum_bytes = (ext4_inodes_per_grp + 7) / 8
            lo_off = EXT4_BG_INODE_BITMAP_CSUM_LO
            hi_off = EXT4_BG_INODE_BITMAP_CSUM_HI
        if csum_bytes > ext4_block_size:
            csum_bytes = ext4_block_size
        bcsum: uint32 = crc32c_update(ext4_csum_seed, bitmap, csum_bytes)
        _ext4_write_u16(cast[Ptr[uint8]](entry + lo_off),
                        cast[uint16](bcsum & 0xFFFF))
        if ext4_desc_size >= 64:
            _ext4_write_u16(cast[Ptr[uint8]](entry + hi_off),
                            cast[uint16]((bcsum >> 16) & 0xFFFF))
        # bg_checksum LAST — it folds the rest of the descriptor.
        bg_c: uint16 = _ext4_mounted_gd_csum(
            cast[Ptr[uint8]](entry), grp)
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_CHECKSUM), bg_c)

    return _ext4_write_block(gdt_block, &ext4_blk_buf[0])


def _ext4_gd_inode_alloc_update(grp: uint64, group_rel_bit: uint64,
                                bitmap: Ptr[uint8]) -> int32:
    # Inode-allocation GDT maintenance for group `grp`: free-inode count
    # -1, refresh bg_itable_unused (the count of high inodes never yet
    # used), refresh inode-bitmap csum + bg_checksum, write GDT back.
    #
    # bg_itable_unused: inodes [ipg - itable_unused + 1 .. ipg] are the
    # never-used tail. Allocating group-relative bit `group_rel_bit`
    # (0-based) consumes inode (group_rel_bit+1); if that reaches into the
    # unused tail, shrink itable_unused so it only covers inodes ABOVE the
    # one we just allocated. e2fsck flags an allocated inode that still
    # sits inside the unused-tail region, which is exactly the bug a naive
    # bitmap-only alloc hits.
    desc_byte_off: uint64 = grp * ext4_desc_size
    gdt_block:     uint64 = ext4_gdt_block + desc_byte_off / ext4_block_size
    within:        uint64 = desc_byte_off % ext4_block_size
    if _ext4_read_block(gdt_block, &ext4_blk_buf[0]) != 0:
        return -1
    entry: uint64 = cast[uint64](&ext4_blk_buf[0]) + within

    # free-inode count -1 (lo + optional hi).
    cur: uint64 = cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](entry + EXT4_BG_FREE_INODES_LO)))
    has_hi: int32 = 0
    if ext4_64bit != 0 and ext4_desc_size >= 64:
        has_hi = 1
        cur = cur | (cast[uint64](_ext4_read_u16(
            cast[Ptr[uint8]](entry + EXT4_BG_FREE_INODES_HI))) << 16)
    if cur > 0:
        cur = cur - 1
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_INODES_LO),
                    cast[uint16](cur & 0xFFFF))
    if has_hi != 0:
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_INODES_HI),
                        cast[uint16]((cur >> 16) & 0xFFFF))

    # itable_unused: only meaningful under metadata_csum / gdt_csum. If
    # the allocated inode falls within the unused tail, pull the watermark
    # down to (ipg - (group_rel_bit + 1)) so the allocated inode is no
    # longer counted as "never used".
    iu_lo: uint64 = cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](entry + EXT4_BG_ITABLE_UNUSED_LO)))
    itu: uint64 = iu_lo
    if has_hi != 0:
        itu = itu | (cast[uint64](_ext4_read_u16(
            cast[Ptr[uint8]](entry + EXT4_BG_ITABLE_UNUSED_HI))) << 16)
    used_inodes: uint64 = group_rel_bit + 1
    if ext4_inodes_per_grp > used_inodes:
        max_unused: uint64 = ext4_inodes_per_grp - used_inodes
        if itu > max_unused:
            itu = max_unused
            _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_ITABLE_UNUSED_LO),
                            cast[uint16](itu & 0xFFFF))
            if has_hi != 0:
                _ext4_write_u16(
                    cast[Ptr[uint8]](entry + EXT4_BG_ITABLE_UNUSED_HI),
                    cast[uint16]((itu >> 16) & 0xFFFF))

    if ext4_metadata_csum != 0:
        # Inode bitmap csum spans (inodes_per_group+7)/8 bytes (live bits
        # only), capped at the block size — matching Linux.
        ib_bytes: uint64 = (ext4_inodes_per_grp + 7) / 8
        if ib_bytes > ext4_block_size:
            ib_bytes = ext4_block_size
        bcsum: uint32 = crc32c_update(ext4_csum_seed, bitmap, ib_bytes)
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_INODE_BITMAP_CSUM_LO),
                        cast[uint16](bcsum & 0xFFFF))
        if ext4_desc_size >= 64:
            _ext4_write_u16(
                cast[Ptr[uint8]](entry + EXT4_BG_INODE_BITMAP_CSUM_HI),
                cast[uint16]((bcsum >> 16) & 0xFFFF))
        bg_c: uint16 = _ext4_mounted_gd_csum(cast[Ptr[uint8]](entry), grp)
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_CHECKSUM), bg_c)

    return _ext4_write_block(gdt_block, &ext4_blk_buf[0])


def _ext4_sb_adjust_free(d_blocks: int64, d_inodes: int64) -> int32:
    # Apply free-count deltas to the on-disk superblock, recompute
    # s_checksum (metadata_csum only), and write the SB back to sectors
    # 2..3. Keeps the global ext4_sb_buf in sync so a later mount/csum
    # check agrees. The mounted-volume read path never wrote the SB back,
    # so without this an alloc left the on-disk free counts stale and
    # e2fsck flagged "Free blocks/inodes count wrong".
    if ext4_blockdev_slot < 0:
        return -1
    if d_blocks != 0:
        fb_lo: uint64 = cast[uint64](_ext4_read_u32(
            cast[Ptr[uint8]](cast[uint64](&ext4_sb_buf[0])
                             + EXT4_SB_OFF_FREE_BLOCKS_LO)))
        fb: uint64 = fb_lo
        if ext4_64bit != 0:
            fb = fb | (cast[uint64](_ext4_read_u32(
                cast[Ptr[uint8]](cast[uint64](&ext4_sb_buf[0])
                                 + EXT4_SB_OFF_FREE_BLOCKS_HI))) << 32)
        fb = cast[uint64](cast[int64](fb) + d_blocks)
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&ext4_sb_buf[0])
                        + EXT4_SB_OFF_FREE_BLOCKS_LO),
                        cast[uint32](fb & 0xFFFFFFFF))
        if ext4_64bit != 0:
            _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&ext4_sb_buf[0])
                            + EXT4_SB_OFF_FREE_BLOCKS_HI),
                            cast[uint32]((fb >> 32) & 0xFFFFFFFF))
    if d_inodes != 0:
        fi: uint32 = _ext4_read_u32(
            cast[Ptr[uint8]](cast[uint64](&ext4_sb_buf[0])
                             + EXT4_SB_OFF_FREE_INODES))
        fi = cast[uint32](cast[int64](cast[uint64](fi)) + d_inodes)
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&ext4_sb_buf[0])
                        + EXT4_SB_OFF_FREE_INODES), fi)
    if ext4_metadata_csum != 0:
        sc: uint32 = _ext4_sb_csum()
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&ext4_sb_buf[0])
                        + EXT4_SB_OFF_CHECKSUM), sc)
    return blk_write_sectors(ext4_blockdev_slot, 2, 2, &ext4_sb_buf[0])


def ext4_alloc_block() -> uint64:
    # Find a free data block by scanning every block group in order,
    # mark it allocated, write that group's bitmap back. Returns the
    # absolute filesystem block number, or 0 on failure (out-of-space
    # across all groups or I/O error).
    #
    # M16.61 was group-0-only; this is the multi-group follow-up the
    # comment block flagged. After ext4_resize_grow appends groups,
    # the new groups have plenty of free bitmap bits and we need to
    # walk past a packed group 0 to reach them (e.g. first-boot
    # sentinel-write after the installer payload fills group 0).
    if ext4_blockdev_slot < 0:
        return 0
    ngroups: uint64 = _ext4_num_groups()
    # Max bytes of a group's bitmap that can carry allocation bits. The
    # group's bitmap holds one bit per CLUSTER (per BLOCK when bigalloc is
    # off — cluster_ratio==1, clusters_per_grp==blocks_per_grp, so this is
    # identical to the old block math). A bitmap block is ext4_block_size
    # bytes, but a group only has clusters_per_group bits.
    nbytes: uint64 = ext4_block_size
    if nbytes > ext4_clusters_per_grp / 8:
        nbytes = ext4_clusters_per_grp / 8
    g: uint64 = 0
    while g < ngroups:
        # bg_block_bitmap (lo @ 0x00, hi @ 0x20 on 64BIT). On a flex_bg
        # image this points at the packed block bitmap in the flex
        # group's leader, not the head of group g — the descriptor field
        # is authoritative.
        bm_block: uint64 = _ext4_group_desc_block_u64(
            g, EXT4_BG_BLOCK_BITMAP_LO, EXT4_BG_BLOCK_BITMAP_HI)
        if bm_block != 0:
            if _ext4_read_block(bm_block,
                                &ext4_bitmap_buf[0]) == 0:
                # First-fit: scan bytes left-to-right, then bits LSB
                # to MSB within each non-0xFF byte. Same shape as the
                # group-0 path it replaces.
                byte_idx: uint64 = 0
                while byte_idx < nbytes:
                    b: uint8 = ext4_bitmap_buf[byte_idx]
                    if b != 0xFF:
                        bit_idx: uint64 = 0
                        while bit_idx < 8:
                            mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
                            if (b & mask) == 0:
                                ext4_bitmap_buf[byte_idx] = b | mask
                                if _ext4_write_block(cast[uint64](bm_block),
                                                     &ext4_bitmap_buf[0]) != 0:
                                    printk0("ext4: bitmap write failed\n")
                                    return 0
                                # Keep the on-disk bookkeeping consistent:
                                # one fewer free block in this group + the
                                # superblock, refreshed bitmap csum + group/
                                # sb checksums (metadata_csum). Without this
                                # an alloc leaves e2fsck flagging stale free
                                # counts / bad bitmap csums.
                                _ext4_gd_update_after_bitmap(
                                    g, 0, &ext4_bitmap_buf[0], -1)
                                _ext4_sb_adjust_free(-1, 0)
                                # Group g's bit 0 is cluster 0, whose first
                                # block is first_data_block + g*bpg. Bit C
                                # maps to block base + C*cluster_ratio. With
                                # bigalloc off cluster_ratio==1, so this is
                                # the old first_data_block + g*bpg + bit.
                                cidx: uint64 = byte_idx * 8 + bit_idx
                                return ext4_first_data_blk \
                                     + g * ext4_blocks_per_grp \
                                     + cidx * ext4_cluster_ratio
                            bit_idx = bit_idx + 1
                    byte_idx = byte_idx + 1
        # This group is full (or had a zero/unreadable bitmap);
        # keep walking.
        g = g + 1
    printk0("ext4: no free block in any group\n")
    return 0


def ext4_free_block(block_nr: uint64) -> int32:
    # Clear the bitmap bit for `block_nr` and write its group's
    # bitmap back. Returns 0 on success, -1 on out-of-range / I/O
    # failure. Multi-group symmetric with ext4_alloc_block.
    if ext4_blockdev_slot < 0:
        return -1
    if block_nr < ext4_first_data_blk:
        return -1
    if ext4_blocks_per_grp == 0:
        return -1
    rel: uint64 = block_nr - ext4_first_data_blk
    g:   uint64 = rel / ext4_blocks_per_grp
    blk_in_grp: uint64 = rel % ext4_blocks_per_grp
    # The bitmap bit is the CLUSTER index within the group. With bigalloc
    # off cluster_ratio==1, so bit == blk_in_grp (the old behaviour). With
    # bigalloc on, several blocks share one cluster bit.
    bit: uint64 = blk_in_grp / ext4_cluster_ratio
    if g >= _ext4_num_groups():
        printk0("ext4: free_block: block past last group\n")
        return -1
    # bg_block_bitmap (lo @ 0x00, hi @ 0x20) — descriptor-supplied,
    # flex-relocated location.
    bm_block: uint64 = _ext4_group_desc_block_u64(
        g, EXT4_BG_BLOCK_BITMAP_LO, EXT4_BG_BLOCK_BITMAP_HI)
    if bm_block == 0:
        return -1
    if _ext4_read_block(bm_block, &ext4_bitmap_buf[0]) != 0:
        return -1
    byte_idx: uint64 = bit / 8
    bit_idx:  uint64 = bit % 8
    mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
    ext4_bitmap_buf[byte_idx] = ext4_bitmap_buf[byte_idx] & (~mask)
    if _ext4_write_block(bm_block, &ext4_bitmap_buf[0]) != 0:
        return -1
    # One more free block in this group + the superblock; refresh csums.
    _ext4_gd_update_after_bitmap(g, 0, &ext4_bitmap_buf[0], 1)
    _ext4_sb_adjust_free(1, 0)
    return 0


def ext4_bitmap_smoke_test() -> int32:
    # Exercise the block allocator: alloc → re-alloc → free both.
    # Verifies that
    #   (a) allocations succeed and return distinct blocks
    #   (b) the bitmap actually mutates on disk (re-alloc would
    #       return the same block if the write didn't stick)
    #   (c) free clears the bit (next alloc-after-free returns
    #       one of the freed blocks)
    # Returns 0 on PASS, -1 on FAIL. Caller prints the marker.
    a: uint64 = ext4_alloc_block()
    if a == 0:
        printk0("ext4: bitmap smoke FAIL (first alloc)\n")
        return -1
    b: uint64 = ext4_alloc_block()
    if b == 0 or b == a:
        printk0("ext4: bitmap smoke FAIL (second alloc returned same/zero)\n")
        ext4_free_block(a)
        return -1
    # Free the two blocks. Then allocate again — we should get one
    # of the freed blocks back (allocator is first-fit so it picks
    # the lower-numbered one).
    if ext4_free_block(a) != 0:
        printk0("ext4: bitmap smoke FAIL (free a)\n")
        ext4_free_block(b)
        return -1
    if ext4_free_block(b) != 0:
        printk0("ext4: bitmap smoke FAIL (free b)\n")
        return -1
    c: uint64 = ext4_alloc_block()
    if c != a:
        printk1("ext4: bitmap smoke FAIL (post-free alloc returned %d)\n", c)
        if c != 0:
            ext4_free_block(c)
        return -1
    # Clean up the round-trip so we leave the FS as we found it.
    ext4_free_block(c)
    # M16.62: round-trip an inode alloc/free.
    ia: uint32 = ext4_alloc_inode()
    if ia == 0:
        printk0("ext4: bitmap smoke FAIL (inode alloc)\n")
        return -1
    ib: uint32 = ext4_alloc_inode()
    if ib == 0 or ib == ia:
        printk0("ext4: bitmap smoke FAIL (inode realloc)\n")
        ext4_free_inode(ia)
        return -1
    if ext4_free_inode(ia) != 0 or ext4_free_inode(ib) != 0:
        printk0("ext4: bitmap smoke FAIL (inode free)\n")
        return -1
    printk2("ext4: bitmap smoke PASS (blk=%d ino=%d)\n",
            a, cast[uint64](ia))
    return 0


# --- inode bitmap (M16.62) ----------------------------------------
#
# Same shape as the block bitmap but indexes inodes within the group.
# At group descriptor offset 4 (bg_inode_bitmap_lo). Bit N (0-based)
# corresponds to inode (group * inodes_per_grp + N + 1) — note the +1
# because ext4 inodes are 1-indexed.
#
# Reserved inodes (typically 1..s_first_ino-1, with s_first_ino == 11
# in modern mkfs.ext4) are already marked allocated by mkfs, so a
# first-fit search just skips them naturally. No special-case needed.

def ext4_alloc_inode() -> uint32:
    # Find a free inode in ANY group, mark it allocated, write the
    # bitmap back. Returns the absolute inode number (1-based), or
    # 0 on failure.
    #
    # MULTI-GROUP (QA-N30): this used to scan ONLY group 0's inode
    # bitmap and return "no free inode" the moment group 0 filled up —
    # even though every other group still had thousands of free inodes.
    # A live image built by host mke2fs packs group 0's inodes with the
    # Debian payload, so the FIRST new-file create in the running system
    # (`enter linux { echo hi > /foo }`, a regular-user home write, dpkg
    # laying a package file) hit a spurious ENOSPC despite the fs having
    # ample free inodes AND blocks. ext4_alloc_block already walks every
    # group for exactly this reason (see its "installer payload fills
    # group 0" note); the inode allocator was its unfixed twin. Both the
    # per-group inode bitmap and the inode-table read/write path
    # (ext4_read_inode / ext4_write_inode) are already group-aware —
    # they derive the group from the absolute inode number — so an inode
    # allocated out of group g > 0 is read/written correctly.
    if ext4_blockdev_slot < 0:
        return 0
    ngroups: uint64 = _ext4_num_groups()
    # A group's inode bitmap carries one bit per inode, capped at
    # inodes_per_group bits (and never more than a bitmap block holds).
    nbytes: uint64 = ext4_block_size
    if nbytes > ext4_inodes_per_grp / 8:
        nbytes = ext4_inodes_per_grp / 8
    g: uint64 = 0
    while g < ngroups:
        # bg_inode_bitmap (lo @ 0x04, hi @ 0x24) — descriptor-supplied,
        # flex-relocated location for group g.
        bm_block: uint64 = _ext4_group_desc_block_u64(
            g, EXT4_BG_INODE_BITMAP_LO, EXT4_BG_INODE_BITMAP_HI)
        if bm_block != 0:
            if _ext4_read_block(bm_block, &ext4_bitmap_buf[0]) == 0:
                # First-fit within this group. Reserved inodes (group 0's
                # 1..s_first_ino-1) are already set by mkfs, so first-fit
                # skips them naturally.
                byte_idx: uint64 = 0
                while byte_idx < nbytes:
                    b: uint8 = ext4_bitmap_buf[byte_idx]
                    if b != 0xFF:
                        bit_idx: uint64 = 0
                        while bit_idx < 8:
                            mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
                            if (b & mask) == 0:
                                ext4_bitmap_buf[byte_idx] = b | mask
                                if _ext4_write_block(cast[uint64](bm_block),
                                                     &ext4_bitmap_buf[0]) != 0:
                                    printk0("ext4: inode bitmap write failed\n")
                                    return 0
                                # GDT free-inode count / itable_unused /
                                # inode-bitmap csum + bg_checksum for group
                                # g, then the superblock free count.
                                rel_bit: uint64 = byte_idx * 8 + bit_idx
                                _ext4_gd_inode_alloc_update(g, rel_bit,
                                                            &ext4_bitmap_buf[0])
                                _ext4_sb_adjust_free(0, -1)
                                # bit (byte*8 + bit) in group g →
                                # inode (g*ipg + bit + 1)
                                return cast[uint32](
                                    g * ext4_inodes_per_grp + rel_bit + 1)
                            bit_idx = bit_idx + 1
                    byte_idx = byte_idx + 1
        # This group is full (or had a zero/unreadable bitmap); keep
        # walking to the next group.
        g = g + 1
    printk0("ext4: no free inode in any group\n")
    return 0


def ext4_free_inode(inum: uint32) -> int32:
    # Clear the inode bitmap bit for `inum`. Refuses cross-group inums
    # for the same reason ext4_free_block does (group-0 scope until a
    # follow-up adds multi-group walks).
    if ext4_blockdev_slot < 0:
        return -1
    if inum == 0:
        return -1
    iu: uint64 = cast[uint64](inum)
    if iu > ext4_inodes_per_grp:
        printk0("ext4: free_inode: inode not in group 0\n")
        return -1
    # bg_inode_bitmap (lo @ 0x04, hi @ 0x24) — descriptor-supplied,
    # flex-relocated location.
    bm_block: uint64 = _ext4_group_desc_block_u64(
        0, EXT4_BG_INODE_BITMAP_LO, EXT4_BG_INODE_BITMAP_HI)
    if bm_block == 0:
        return -1
    if _ext4_read_block(bm_block, &ext4_bitmap_buf[0]) != 0:
        return -1
    rel: uint64 = iu - 1                                # bit index within group
    byte_idx: uint64 = rel / 8
    bit_idx:  uint64 = rel % 8
    mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
    ext4_bitmap_buf[byte_idx] = ext4_bitmap_buf[byte_idx] & (~mask)
    if _ext4_write_block(bm_block, &ext4_bitmap_buf[0]) != 0:
        return -1
    # One more free inode in group 0 + the superblock; refresh csums.
    # (itable_unused is a never-used watermark — it only shrinks, so a
    # free leaves it alone.)
    _ext4_gd_update_after_bitmap(0, 1, &ext4_bitmap_buf[0], 1)
    _ext4_sb_adjust_free(0, 1)
    return 0


# --- inode write + file create (M16.63) ---------------------------
#
# ext4_write_inode is the symmetric counterpart of ext4_read_inode:
# locate the on-disk inode bytes via the same group / table / index
# math, then write inode_size bytes at that offset. Implemented as a
# read-modify-write on the 2 sectors that cover the inode — the
# inode (128 or 256 bytes) is always sector-aligned within the table
# but may straddle sector boundaries.

def ext4_write_inode(inum: uint64, src: Ptr[uint8]) -> int32:
    if inum == 0 or inum > ext4_inodes_count:
        return -1
    grp:    uint64 = (inum - 1) / ext4_inodes_per_grp
    idx:    uint64 = (inum - 1) % ext4_inodes_per_grp
    # bg_inode_table (lo @ 0x08, hi @ 0x28) — the descriptor-supplied,
    # flex-relocated inode-table location, symmetric with the reader.
    inode_table_block: uint64 = _ext4_group_desc_block_u64(
        grp, EXT4_BG_INODE_TABLE_LO, EXT4_BG_INODE_TABLE_HI)
    if inode_table_block == 0:
        return -1
    inode_byte: uint64 = inode_table_block * ext4_block_size \
                       + idx * ext4_inode_size
    sec_lba:   uint64 = inode_byte / SECTOR_SIZE
    sec_off:   uint64 = inode_byte % SECTOR_SIZE
    # metadata_csum: recompute l_i_checksum_lo (+hi) over the inode
    # we're about to persist so a write→re-read validates. No-op on a
    # filesystem without the feature.
    _ext4_inode_csum_set(src, inum)
    # Read 2 sectors → RMW → write 2 sectors. ext4_blk_buf is the
    # natural scratch (1024 bytes, fits 2 sectors).
    if blk_read_sectors(ext4_blockdev_slot, sec_lba, 2,
                        &ext4_blk_buf[0]) != 0:
        return -1
    dst: uint64 = cast[uint64](&ext4_blk_buf[0]) + sec_off
    memcpy(cast[Ptr[uint8]](dst), src, ext4_inode_size)
    return blk_write_sectors(ext4_blockdev_slot, sec_lba, 2,
                             &ext4_blk_buf[0])


def _ext4_write_u16(p: Ptr[uint8], v: uint16):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)


def _ext4_write_u32(p: Ptr[uint8], v: uint32):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)
    p[2] = cast[uint8]((v >> 16) & 0xFF)
    p[3] = cast[uint8]((v >> 24) & 0xFF)


# In-memory builder scratch for a fresh inode (sized for the
# largest inode_size we'd see: 256 bytes).
ext4_new_inode_buf: Array[256, uint8]


# --- per-inode mtime (M16.x §12.3) --------------------------------
#
# ext4 stores three 32-bit Unix timestamps in the inode:
#
#   0x08  i_atime   last access
#   0x0C  i_ctime   last status change (inode metadata)
#   0x10  i_mtime   last data modification
#
# (256-byte inodes also carry *_extra nanosecond/epoch-high words at
# 0x84/0x88/0x8C, but a plain seconds timestamp at the lo offsets is
# what `stat` and make's timestamp logic read first — Linux fills the
# extra words only when the inode is large enough AND the feature is
# on. We keep it to the lo words, which every ext2/3/4 reader honours.)
#
# A freshly-mkfs'd inode has all three at 0; we stamp them with the
# RTC epoch on create and refresh i_mtime + i_ctime on every write or
# truncate so `stat` reports a real, monotonically-advancing mtime and
# make-style "is the target newer than the source" logic works.

INODE_I_ATIME_OFFSET: uint64 = 0x08
INODE_I_CTIME_OFFSET: uint64 = 0x0C
INODE_I_MTIME_OFFSET: uint64 = 0x10


def _ext4_now_epoch() -> uint32:
    # Wall-clock seconds for a timestamp stamp. The RTC is the source
    # of truth; if it's unreadable we fall back to 0 (the mkfs default)
    # rather than inventing a bogus time.
    t: int64 = rtc_read_unix_time()
    if t < 0:
        return 0
    return cast[uint32](t)


def ext4_inode_mtime(buf: Ptr[uint8]) -> uint32:
    # struct ext4_inode.i_mtime — Unix epoch seconds. Exposed so the
    # VFS stat path can report a real mtime instead of a jiffies guess.
    return _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](buf) + INODE_I_MTIME_OFFSET))


def _ext4_stamp_mtime(inode_buf: Ptr[uint8]):
    # Refresh i_mtime + i_ctime in an in-memory inode buffer. ctime
    # tracks any inode-metadata change, so a data write (which bumps
    # i_size / extents) bumps ctime too — matches Linux's
    # ext4_current_time() use in ext4_write_end / ext4_setattr.
    now: uint32 = _ext4_now_epoch()
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_MTIME_OFFSET),
        now)
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_CTIME_OFFSET),
        now)


def _ext4_stamp_all_times(inode_buf: Ptr[uint8]):
    # Stamp atime + ctime + mtime — used at create time so a fresh
    # inode carries a coherent timestamp triple instead of epoch 0.
    now: uint32 = _ext4_now_epoch()
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_ATIME_OFFSET),
        now)
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_CTIME_OFFSET),
        now)
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_MTIME_OFFSET),
        now)


def _ext4_zero(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        p[i] = 0
        i = i + 1


def _ext4_init_regular_inode(data_blk: uint64, size: uint64):
    # Populate ext4_new_inode_buf with a minimal valid regular-file
    # inode: mode 0664 + IFREG (0x81B4), one extent pointing at
    # `data_blk`, i_size_lo = `size`, EXTENTS flag set.
    p: Ptr[uint8] = &ext4_new_inode_buf[0]
    _ext4_zero(p, ext4_inode_size)
    _ext4_write_u16(p, 0x81B4)                      # i_mode
    # docs/security.md Phase 6: stamp owner/group from the calling
    # task. A regular user creating a file owns it; hostowner-side
    # kernel paths (boot rc, hpm install, installer) stamp uid 1.
    # current_task_uid/gid is safe to call here — we're inside a
    # syscall context for every userland-triggered create.
    _ext4_inode_stamp_creator(p)
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4),
                    cast[uint32](size))             # i_size_lo
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26),
                    1)                              # i_links_count
    # i_blocks_lo is in 512-byte units regardless of fs block size.
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28),
                    cast[uint32](sectors_per_block))
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32),
                    0x80000)                        # i_flags = EXT4_EXTENTS_FL
    # i_block (60 bytes at +0x28): extent header + one extent.
    eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)    # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)    # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)    # eh_depth (leaf)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)    # eh_generation
    # Single extent: ee_block=0, ee_len=1, hi=0, lo=data_blk.
    _ext4_write_u32(cast[Ptr[uint8]](eh + 12), 0)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 16), 1)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 18), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 20),
                    cast[uint32](data_blk))
    # Stamp atime/ctime/mtime with the wall clock so a freshly-created
    # file reports a real mtime through stat (M16.x §12.3).
    _ext4_stamp_all_times(p)


def _ext4_inode_stamp_creator(inode_buf: Ptr[uint8]):
    # docs/security.md Phase 6: write the calling task's uid/gid into
    # i_uid_lo/i_uid_hi + i_gid_lo/i_gid_hi. Falls back to hostowner
    # (UID_HOSTOWNER) when the call originates from a kernel context
    # with no current task (boot bring-up, the kernel-internal mkfs path
    # which uses _ext4_mkfs_build_root_inode directly).
    #
    # F10-3 #456: the boot-context fallback stays HOSTOWNER (not NOBODY)
    # — the mkfs path lays down /etc, /bin, /home, ... and those need a
    # real owner. The uid==0 sentinel still flags "no current task",
    # because slot 0 (boot kthread) is .bss-zeroed and a kernel-context
    # filesystem build genuinely has no userland identity to inherit.
    cu: uint32 = current_task_uid()
    cg: uint32 = current_task_gid()
    if cu == 0:
        # uid 0 doesn't exist in Hamnix per docs/security.md; treat the
        # "current_task_uid returned 0" reading as "no task / boot
        # context" and stamp hostowner.
        cu = UID_HOSTOWNER
        cg = UID_HOSTOWNER
    ext4_inode_set_uid(inode_buf, cu)
    ext4_inode_set_gid(inode_buf, cg)


def _ext4_strlen(name: Ptr[char]) -> uint64:
    n: uint64 = 0
    while name[n] != 0:
        n = n + 1
    return n


def _ext4_dirent_padded_size(name_len: uint64) -> uint64:
    # ext4 dirent rec_len is always a multiple of 4. Header is 8
    # bytes; pad (8 + name_len) up to the next 4-byte boundary.
    raw: uint64 = 8 + name_len
    return (raw + 3) & ~cast[uint64](3)


def ext4_dir_insert(parent_inum: uint64, name: Ptr[char],
                    child_inum: uint32, file_type: uint8) -> int32:
    # Append a dirent for (name, child_inum) to the LAST block of
    # parent_inum's directory. Splits the existing last entry's
    # padding to make room. M16.63 does NOT grow the directory by
    # allocating a new block — if the last block has no slack, this
    # fails with -1.
    if parent_inum == 0:
        return -1
    name_len: uint64 = _ext4_strlen(name)
    if name_len == 0 or name_len > 255:
        return -1
    needed: uint64 = _ext4_dirent_padded_size(name_len)

    parent_inode: Array[256, uint8]
    if ext4_read_inode(parent_inum, &parent_inode[0]) != 0:
        return -1
    # If the parent is an EXT4_INDEX_FL (htree / dir_index) directory,
    # route to the hash-indexed insert path: descend the dx index to the
    # target leaf, split it if full, and maintain the index. The linear
    # last-block split below would corrupt an htree (its leaves are
    # hash-ordered, not append-ordered).
    if ext4_inode_is_htree_dir(&parent_inode[0]) != 0:
        return ext4_htree_dir_insert(parent_inum, name, child_inum,
                                     file_type)
    # Capture i_generation now (before any ext4_blk_buf reuse) so the
    # dir-block checksum restamp below can seed correctly without an
    # inode re-read that would clobber the mutated dir block.
    parent_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&parent_inode[0]) + 0x64))
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&parent_inode[0]))
    if dir_size == 0:
        return -1
    last_lb: uint64 = dir_size / ext4_block_size - 1
    phys: uint64 = _ext4_logical_to_physical(&parent_inode[0], last_lb)
    if phys == 0:
        return -1
    if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
        return -1

    # Walk every entry looking for an insertion slot. Two slot
    # shapes accept a new entry (Linux's ext4_add_entry uses the
    # same rule):
    #
    #   (1) An entry with inum == 0 (tombstone) whose rec_len is
    #       big enough for our padded footprint — overwrite in
    #       place, keep its rec_len.
    #   (2) A live entry whose declared rec_len is at least its
    #       own true (padded) size + our `needed` — split: shrink
    #       this entry to its true size, append our new entry in
    #       the freed tail.
    #
    # The terminal entry of a dir block typically carries large
    # excess rec_len from the last split — that's the natural
    # insertion point as the dir grows. Walking ALL entries (not
    # just the last) also handles the common tombstone-after-the-
    # last-real-entry layout debugfs/mkfs leaves behind.
    pos: uint64 = 0
    while pos < ext4_block_size:
        e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
        e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
        e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
        if e_rec_len == 0:
            return -1                              # malformed
        if e_inum == 0:
            if cast[uint64](e_rec_len) >= needed:
                # Reuse this tombstone in place — keep its rec_len.
                _ext4_write_u32(cast[Ptr[uint8]](e + 0), child_inum)
                cast[Ptr[uint8]](e + 6)[0] = cast[uint8](name_len)
                cast[Ptr[uint8]](e + 7)[0] = file_type
                i: uint64 = 0
                while i < name_len:
                    cast[Ptr[uint8]](e + 8 + i)[0] = cast[uint8](name[i])
                    i = i + 1
                # Zero the name's trailing pad.
                pp: uint64 = 8 + name_len
                while pp < cast[uint64](e_rec_len):
                    cast[Ptr[uint8]](e + pp)[0] = 0
                    pp = pp + 1
                _ext4_dirblock_stamp_in_buf(parent_inum, parent_gen)
                return _ext4_write_block(phys, &ext4_blk_buf[0])
        else:
            e_name_len: uint8 = cast[Ptr[uint8]](e + 6)[0]
            true_e: uint64 = _ext4_dirent_padded_size(
                cast[uint64](e_name_len))
            if cast[uint64](e_rec_len) >= true_e + needed:
                # Split: shrink to true size, append new in the tail.
                new_rec_len: uint64 = cast[uint64](e_rec_len) - true_e
                _ext4_write_u16(cast[Ptr[uint8]](e + 4),
                                cast[uint16](true_e))
                new_off: uint64 = pos + true_e
                new_e: uint64 = cast[uint64](&ext4_blk_buf[0]) + new_off
                _ext4_write_u32(cast[Ptr[uint8]](new_e + 0), child_inum)
                _ext4_write_u16(cast[Ptr[uint8]](new_e + 4),
                                cast[uint16](new_rec_len))
                cast[Ptr[uint8]](new_e + 6)[0] = cast[uint8](name_len)
                cast[Ptr[uint8]](new_e + 7)[0] = file_type
                i: uint64 = 0
                while i < name_len:
                    cast[Ptr[uint8]](new_e + 8 + i)[0] = cast[uint8](name[i])
                    i = i + 1
                pp: uint64 = 8 + name_len
                while pp < new_rec_len:
                    cast[Ptr[uint8]](new_e + pp)[0] = 0
                    pp = pp + 1
                _ext4_dirblock_stamp_in_buf(parent_inum, parent_gen)
                return _ext4_write_block(phys, &ext4_blk_buf[0])
        pos = pos + cast[uint64](e_rec_len)
    printk0("ext4: dir block full (no slack for insert)\n")
    return -1


# === htree (dir_index) directory INSERT — the WRITE path ==========
#
# ext4_dir_insert (above) handles LINEAR directories: it splits an
# existing dirent's slack to slot the new name into one of the dir's
# data blocks. An EXT4_INDEX_FL (dir_index / htree) directory is
# different: logical block 0 is a dx_root index node, its dx_entry array
# maps hash ranges to LEAF blocks, and the real dirents live only in the
# leaves. Inserting a name there means: hash it, descend the dx index to
# the ONE leaf whose hash range covers it, and insert into that leaf. If
# the leaf is full, SPLIT it — allocate a sibling leaf, redistribute the
# entries by hash (Linux's do_split), add a new dx_entry {hash,block} to
# the parent, and place the new name in whichever half it hashes to. If
# the parent index node itself is full, grow the index (0->1 level).
#
# After any insert the directory remains a valid htree that
# ext4_dir_lookup_htree resolves correctly.
#
# NOTE: index-block (dx) checksums (the metadata_csum "dx_tail") are not
# maintained here, so htree INSERT targets images WITHOUT metadata_csum.
# Leaf (data) block tails ARE preserved when present.


def _ext4_leaf_dirent_insert(leaf: uint64, name: Ptr[char],
                             name_len: uint64, child_inum: uint32,
                             file_type: uint8) -> int32:
    # Insert (name, child_inum) into the directory LEAF block already in
    # the buffer at byte address `leaf`. Uses the same tombstone-reuse /
    # slack-split rule as ext4_dir_insert. Returns 0 on success, -1 if
    # the block has no room (caller must split). A metadata_csum tail
    # (fake dirent rec_len=12, ft=0xDE) is treated as an unusable record
    # by the >= needed test, so it is preserved automatically.
    needed: uint64 = _ext4_dirent_padded_size(name_len)
    pos: uint64 = 0
    while pos < ext4_block_size:
        e: uint64 = leaf + pos
        e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
        e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
        if e_rec_len == 0:
            return -1
        if e_inum == 0:
            # tombstone (or csum tail, which has rec_len 12 < needed for
            # any real name so it is skipped). Reuse in place if it fits.
            if cast[uint64](e_rec_len) >= needed:
                _ext4_write_u32(cast[Ptr[uint8]](e + 0), child_inum)
                cast[Ptr[uint8]](e + 6)[0] = cast[uint8](name_len)
                cast[Ptr[uint8]](e + 7)[0] = file_type
                ci: uint64 = 0
                while ci < name_len:
                    cast[Ptr[uint8]](e + 8 + ci)[0] = cast[uint8](name[ci])
                    ci = ci + 1
                pp: uint64 = 8 + name_len
                while pp < cast[uint64](e_rec_len):
                    cast[Ptr[uint8]](e + pp)[0] = 0
                    pp = pp + 1
                return 0
        else:
            e_name_len: uint8 = cast[Ptr[uint8]](e + 6)[0]
            true_e: uint64 = _ext4_dirent_padded_size(
                cast[uint64](e_name_len))
            if cast[uint64](e_rec_len) >= true_e + needed:
                new_rec_len: uint64 = cast[uint64](e_rec_len) - true_e
                _ext4_write_u16(cast[Ptr[uint8]](e + 4),
                                cast[uint16](true_e))
                new_e: uint64 = leaf + pos + true_e
                _ext4_write_u32(cast[Ptr[uint8]](new_e + 0), child_inum)
                _ext4_write_u16(cast[Ptr[uint8]](new_e + 4),
                                cast[uint16](new_rec_len))
                cast[Ptr[uint8]](new_e + 6)[0] = cast[uint8](name_len)
                cast[Ptr[uint8]](new_e + 7)[0] = file_type
                ci: uint64 = 0
                while ci < name_len:
                    cast[Ptr[uint8]](new_e + 8 + ci)[0] = cast[uint8](name[ci])
                    ci = ci + 1
                pp: uint64 = 8 + name_len
                while pp < new_rec_len:
                    cast[Ptr[uint8]](new_e + pp)[0] = 0
                    pp = pp + 1
                return 0
        pos = pos + cast[uint64](e_rec_len)
    return -1


def _ext4_htins_build_map(leaf: uint64) -> int64:
    # Collect every LIVE dirent in the leaf at byte address `leaf` into
    # the ext4_htins_map_* arrays (hash / byte-offset / rec_len), then
    # sort the map ascending by hash with a simple insertion sort. The
    # csum tail (inum==0, ft==0xDE) and any tombstone are skipped — only
    # real names carry a hash. Returns the live entry count, or -1 if the
    # block has more entries than the map can hold or is malformed.
    n: int64 = 0
    pos: uint64 = 0
    while pos < ext4_block_size:
        e: uint64 = leaf + pos
        e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
        e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
        if e_rec_len == 0:
            return -1
        if pos + cast[uint64](e_rec_len) > ext4_block_size:
            return -1
        if e_inum != 0:
            e_name_len: uint64 = cast[uint64](cast[Ptr[uint8]](e + 6)[0])
            if e_name_len != 0:
                if cast[uint64](n) >= EXT4_HTINS_MAP_MAX:
                    return -1
                minor: uint32 = 0
                h: uint32 = ext4_dirhash(cast[Ptr[uint8]](e + 8),
                                         e_name_len, &minor)
                ext4_htins_map_hash[cast[uint64](n)] = h
                ext4_htins_map_off[cast[uint64](n)]  = cast[uint16](pos)
                ext4_htins_map_rlen[cast[uint64](n)] = cast[uint16](
                    _ext4_dirent_padded_size(e_name_len))
                n = n + 1
        pos = pos + cast[uint64](e_rec_len)
    # Insertion sort by hash (n is small: <= entries-per-block).
    i: int64 = 1
    while i < n:
        kh: uint32 = ext4_htins_map_hash[cast[uint64](i)]
        ko: uint16 = ext4_htins_map_off[cast[uint64](i)]
        kr: uint16 = ext4_htins_map_rlen[cast[uint64](i)]
        j: int64 = i - 1
        while j >= 0 and ext4_htins_map_hash[cast[uint64](j)] > kh:
            ext4_htins_map_hash[cast[uint64](j + 1)] = \
                ext4_htins_map_hash[cast[uint64](j)]
            ext4_htins_map_off[cast[uint64](j + 1)] = \
                ext4_htins_map_off[cast[uint64](j)]
            ext4_htins_map_rlen[cast[uint64](j + 1)] = \
                ext4_htins_map_rlen[cast[uint64](j)]
            j = j - 1
        ext4_htins_map_hash[cast[uint64](j + 1)] = kh
        ext4_htins_map_off[cast[uint64](j + 1)]  = ko
        ext4_htins_map_rlen[cast[uint64](j + 1)] = kr
        i = i + 1
    return n


def _ext4_leaf_init_empty(buf: uint64):
    # Initialise `buf` as an EMPTY directory leaf: one dirent with
    # inum=0 spanning the whole usable region (minus a csum tail if the
    # fs carries metadata_csum). Subsequent _ext4_leaf_dirent_insert
    # calls carve real records out of this slack.
    _ext4_zero(cast[Ptr[uint8]](buf), ext4_block_size)
    span: uint64 = ext4_block_size
    if ext4_metadata_csum != 0:
        span = ext4_block_size - 12
        tail: uint64 = buf + ext4_block_size - 12
        _ext4_write_u16(cast[Ptr[uint8]](tail + 4), 12)        # rec_len
        cast[Ptr[uint8]](tail + 7)[0] = 0xDE                   # ft
    _ext4_write_u32(cast[Ptr[uint8]](buf + 0), 0)              # inum=0
    _ext4_write_u16(cast[Ptr[uint8]](buf + 4), cast[uint16](span))


def _ext4_leaf_append_raw(buf: uint64, src_e: uint64, name_len: uint64,
                          cursor: Ptr[uint64]):
    # Copy the dirent at `src_e` (header + name) into `buf` at byte
    # offset *cursor as a tightly-packed record (rec_len == true padded
    # size), advancing *cursor. The final record's rec_len is fixed up
    # by the caller to span the block's remaining slack.
    off: uint64 = cursor[0]
    dst: uint64 = buf + off
    true_sz: uint64 = _ext4_dirent_padded_size(name_len)
    # inum + name_len + file_type, then the name.
    _ext4_write_u32(cast[Ptr[uint8]](dst + 0),
                    _ext4_read_u32(cast[Ptr[uint8]](src_e + 0)))
    _ext4_write_u16(cast[Ptr[uint8]](dst + 4), cast[uint16](true_sz))
    cast[Ptr[uint8]](dst + 6)[0] = cast[Ptr[uint8]](src_e + 6)[0]
    cast[Ptr[uint8]](dst + 7)[0] = cast[Ptr[uint8]](src_e + 7)[0]
    k: uint64 = 0
    while k < name_len:
        cast[Ptr[uint8]](dst + 8 + k)[0] = cast[Ptr[uint8]](src_e + 8 + k)[0]
        k = k + 1
    cursor[0] = off + true_sz


def _ext4_htins_do_split(dir_inum: uint64, dir_gen: uint32,
                         inode_buf: Ptr[uint8],
                         old_logical: uint64,
                         name: Ptr[char], name_len: uint64,
                         child_inum: uint32, file_type: uint8,
                         new_hash_out: Ptr[uint32]) -> int64:
    # Split the FULL leaf at dir logical block `old_logical`. Allocates a
    # sibling leaf (a new logical block at the end of the dir), copies the
    # hash-sorted lower half of the entries into the OLD block and the
    # upper half into the NEW block, splitting at the median hash, then
    # inserts the new name into whichever half its hash falls in.
    #
    # The split hash (first hash of the upper half) is returned via
    # new_hash_out so the caller can register a dx_entry {hash, newblk}
    # in the parent index node. Returns the NEW leaf's LOGICAL block on
    # success, or -1 on failure.
    #
    # On entry the OLD leaf must already be loaded in ext4_htins_oldleaf.
    old: uint64 = cast[uint64](&ext4_htins_oldleaf[0])
    new_: uint64 = cast[uint64](&ext4_htins_newleaf[0])
    cnt: int64 = _ext4_htins_build_map(old)
    if cnt < 1:
        return -1
    # Median split: lower half hashes [0,split), upper [split,cnt).
    split: int64 = cnt / 2
    # Linux nudges the boundary so equal-hash runs stay on one side.
    while split < cnt and ext4_htins_map_hash[cast[uint64](split)] \
            == ext4_htins_map_hash[cast[uint64](split - 1)]:
        split = split + 1
    if split >= cnt:
        split = cnt - 1
    split_hash: uint32 = ext4_htins_map_hash[cast[uint64](split)]

    # Allocate the sibling physical block and append it to the dir inode
    # as the next logical block.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(inode_buf))
    new_logical: uint64 = dir_size / ext4_block_size
    new_phys: uint64 = ext4_alloc_block()
    if new_phys == 0:
        return -1
    if _ext4_extent_append_block(inode_buf, new_logical, new_phys) != 0:
        ext4_free_block(new_phys)
        return -1
    # Grow i_size by one block so lookups walk the new leaf.
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](inode_buf) + 4),
                    cast[uint32](dir_size + ext4_block_size))

    # Rebuild both leaves from the sorted map. Pack lower half into a
    # fresh empty old-image, upper half into the new leaf.
    _ext4_zero(new_, ext4_block_size)
    # Scratch copy of the old leaf's bytes so we can rebuild over `old`
    # while still reading the originals: copy old -> new first as a
    # staging area is awkward; instead pack from a saved source. Use
    # ext4_htins_idxbuf as the immutable source snapshot.
    src: uint64 = cast[uint64](&ext4_htins_idxbuf[0])
    memcpy(cast[Ptr[uint8]](src), cast[Ptr[uint8]](old), ext4_block_size)

    _ext4_leaf_init_empty(old)
    _ext4_leaf_init_empty(new_)
    lo_cursor: uint64 = 0
    hi_cursor: uint64 = 0
    mi: int64 = 0
    while mi < cnt:
        e_off: uint64 = cast[uint64](ext4_htins_map_off[cast[uint64](mi)])
        src_e: uint64 = src + e_off
        nl: uint64 = cast[uint64](cast[Ptr[uint8]](src_e + 6)[0])
        if mi < split:
            _ext4_leaf_append_raw(old, src_e, nl, &lo_cursor)
        else:
            _ext4_leaf_append_raw(new_, src_e, nl, &hi_cursor)
        mi = mi + 1
    # Fix up each half's last record to span the block's slack (so the
    # block is a valid dirent chain with no gap).
    _ext4_htins_seal_leaf(old, lo_cursor)
    _ext4_htins_seal_leaf(new_, hi_cursor)

    # Insert the new name into whichever half its hash belongs to.
    minor: uint32 = 0
    nh: uint32 = ext4_dirhash(cast[Ptr[uint8]](name), name_len, &minor)
    target: uint64 = old
    if nh >= split_hash:
        target = new_
    if _ext4_leaf_dirent_insert(target, name, name_len,
                                child_inum, file_type) != 0:
        # Shouldn't happen (we just freed half a block) — but bail safe.
        return -1

    # Stamp leaf checksums (no-op without metadata_csum) and write both.
    ext4_dirblock_csum_set(cast[Ptr[uint8]](old), dir_inum, dir_gen)
    ext4_dirblock_csum_set(cast[Ptr[uint8]](new_), dir_inum, dir_gen)
    old_phys: uint64 = _ext4_logical_to_physical(inode_buf, old_logical)
    if old_phys == 0:
        return -1
    if _ext4_write_block(old_phys, cast[Ptr[uint8]](old)) != 0:
        return -1
    if _ext4_write_block(new_phys, cast[Ptr[uint8]](new_)) != 0:
        return -1
    new_hash_out[0] = split_hash
    return cast[int64](new_logical)


def _ext4_htins_seal_leaf(buf: uint64, cursor: uint64):
    # After packing records up to byte offset `cursor`, extend the LAST
    # record's rec_len so it spans to the end of the usable region (the
    # block end, minus a csum tail if present). If no records were packed
    # the block is left as an empty leaf.
    usable: uint64 = ext4_block_size
    if ext4_metadata_csum != 0:
        usable = ext4_block_size - 12
    if cursor == 0:
        _ext4_leaf_init_empty(buf)
        return
    # Walk to the last record and grow its rec_len.
    pos: uint64 = 0
    last: uint64 = 0
    while pos < cursor:
        last = pos
        rl: uint16 = _ext4_read_u16(cast[Ptr[uint8]](buf + pos + 4))
        if rl == 0:
            break
        pos = pos + cast[uint64](rl)
    _ext4_write_u16(cast[Ptr[uint8]](buf + last + 4),
                    cast[uint16](usable - last))


def _ext4_htins_descend_write(inode_buf: Ptr[uint8], hash: uint32,
                              leaf_out: Ptr[uint64]) -> int64:
    # Descend the dx index for `hash`, recording each frame's index-node
    # logical block + entries offset + chosen `at` into the
    # ext4_htins_frame_* arrays (so a split can edit the parent). Reads
    # index blocks through ext4_htins_idxbuf. Returns the dx_root's
    # indirect_levels (>=0), filling *leaf_out with the target LEAF
    # logical block, or -1 on a structural error.
    phys0: uint64 = _ext4_logical_to_physical(inode_buf, 0)
    if phys0 == 0:
        return -1
    if _ext4_read_block(phys0, &ext4_htins_idxbuf[0]) != 0:
        return -1
    base: uint64 = cast[uint64](&ext4_htins_idxbuf[0])
    info_length: uint8 = cast[Ptr[uint8]](base + 0x1D)[0]
    indirect:    uint8 = cast[Ptr[uint8]](base + 0x1E)[0]
    if info_length != 8:
        return -1
    if cast[uint32](indirect) >= 8:
        return -1
    entries_off: uint64 = 0x18 + cast[uint64](info_length)
    entries: uint64 = base + entries_off
    cur_logical: uint64 = 0
    level: uint32 = 0
    ext4_htins_nframes = cast[uint32](indirect) + 1
    while True:
        count: uint32 = _dx_get_count(entries)
        limit: uint32 = _dx_get_limit(entries)
        if count == 0 or count > limit:
            return -1
        at: uint32 = _dx_bsearch(entries, count, hash)
        ext4_htins_frame_logical[level] = cur_logical
        ext4_htins_frame_eoff[level] = entries_off
        ext4_htins_frame_at[level] = at
        child_block: uint32 = _dx_entry_block(entries, at)
        if level >= cast[uint32](indirect):
            leaf_out[0] = cast[uint64](child_block)
            return cast[int64](cast[uint64](indirect))
        phys: uint64 = _ext4_logical_to_physical(
            inode_buf, cast[uint64](child_block))
        if phys == 0:
            return -1
        if _ext4_read_block(phys, &ext4_htins_idxbuf[0]) != 0:
            return -1
        base = cast[uint64](&ext4_htins_idxbuf[0])
        cur_logical = cast[uint64](child_block)
        entries_off = 8
        entries = base + entries_off
        level = level + 1


def _ext4_dx_insert_entry(entries: uint64, at: uint32,
                          hash: uint32, block: uint32) -> int32:
    # Insert a dx_entry {hash, block} into the dx_entry array `entries`
    # immediately AFTER index `at` (Linux keeps the array hash-sorted and
    # places the new sibling's entry right after the one we descended
    # into). Shifts the tail up by one slot. Returns 0 on success, -1 if
    # the node is full (count == limit) — caller must grow the index.
    count: uint32 = _dx_get_count(entries)
    limit: uint32 = _dx_get_limit(entries)
    if count >= limit:
        return -1
    # Shift entries (at+1 .. count-1) up by one 8-byte slot.
    i: int64 = cast[int64](count) - 1
    while i > cast[int64](at):
        sh: uint32 = _dx_entry_hash(entries, cast[uint32](i))
        sb: uint32 = _dx_entry_block(entries, cast[uint32](i))
        _ext4_write_u32(cast[Ptr[uint8]](entries + cast[uint64](i + 1) * 8 + 0), sh)
        _ext4_write_u32(cast[Ptr[uint8]](entries + cast[uint64](i + 1) * 8 + 4), sb)
        i = i - 1
    slot: uint64 = cast[uint64](at + 1)
    _ext4_write_u32(cast[Ptr[uint8]](entries + slot * 8 + 0), hash)
    _ext4_write_u32(cast[Ptr[uint8]](entries + slot * 8 + 4), block)
    # Bump count (the u16 at +2 of entry 0, the countlimit).
    _ext4_write_u16(cast[Ptr[uint8]](entries + 2), cast[uint16](count + 1))
    return 0


def _ext4_htins_split_node(inode_buf: Ptr[uint8],
                           node_logical: uint64,
                           new_leaf_hash: uint32, new_leaf_block: uint32,
                           out_node_hash: Ptr[uint32],
                           out_node_logical: Ptr[uint32]) -> int32:
    # Split the FULL interior dx_node at dir logical block `node_logical`
    # (currently loaded in ext4_htins_idxbuf), the way ext4_dx_add_entry
    # does when an interior index node fills. Allocates a sibling dx_node,
    # moves the upper half of the node's dx_entries into it, inserts the
    # pending {new_leaf_hash, new_leaf_block} dx_entry into whichever half
    # it belongs, and reports the new node's first hash + logical block via
    # out_* so the caller can register it in the root. Returns 0 on
    # success, -1 on failure. The OLD node is left in ext4_htins_idxbuf
    # (rewritten); the caller writes it back.
    old_node: uint64 = cast[uint64](&ext4_htins_idxbuf[0])
    o_entries: uint64 = old_node + 8
    o_count: uint32 = _dx_get_count(o_entries)
    o_limit: uint32 = _dx_get_limit(o_entries)
    # New dx_node block.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(inode_buf))
    new_logical: uint64 = dir_size / ext4_block_size
    new_phys: uint64 = ext4_alloc_block()
    if new_phys == 0:
        return -1
    if _ext4_extent_append_block(inode_buf, new_logical, new_phys) != 0:
        ext4_free_block(new_phys)
        return -1
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](inode_buf) + 4),
                    cast[uint32](dir_size + ext4_block_size))

    # Build the new node skeleton in ext4_htins_newleaf.
    new_node: uint64 = cast[uint64](&ext4_htins_newleaf[0])
    _ext4_zero(cast[Ptr[uint8]](new_node), ext4_block_size)
    _ext4_write_u32(cast[Ptr[uint8]](new_node + 0), 0)        # fake inode
    _ext4_write_u16(cast[Ptr[uint8]](new_node + 4),
                    cast[uint16](ext4_block_size))            # rec_len
    n_entries: uint64 = new_node + 8
    n_limit: uint32 = cast[uint32]((ext4_block_size - 8) / 8)
    # Split point: move entries [split, o_count) to the new node.
    split: uint32 = o_count / 2
    if split < 1:
        split = 1
    moved: uint32 = o_count - split
    # The new node's entry 0 carries its countlimit; the first MOVED entry
    # supplies entry 0's block (and its hash becomes the node's range key).
    first_moved_hash: uint32 = _dx_entry_hash(o_entries, split)
    _ext4_write_u16(cast[Ptr[uint8]](n_entries + 0), cast[uint16](n_limit))
    _ext4_write_u16(cast[Ptr[uint8]](n_entries + 2), cast[uint16](moved))
    k: uint32 = 0
    while k < moved:
        sh: uint32 = _dx_entry_hash(o_entries, split + k)
        sb: uint32 = _dx_entry_block(o_entries, split + k)
        if k == 0:
            _ext4_write_u32(cast[Ptr[uint8]](n_entries + 4), sb)
        else:
            _ext4_write_u32(cast[Ptr[uint8]](n_entries + cast[uint64](k) * 8 + 0), sh)
            _ext4_write_u32(cast[Ptr[uint8]](n_entries + cast[uint64](k) * 8 + 4), sb)
        k = k + 1
    # Shrink the old node's count to the lower half.
    _ext4_write_u16(cast[Ptr[uint8]](o_entries + 2), cast[uint16](split))

    # Insert the pending {new_leaf_hash, new_leaf_block} into whichever
    # half its hash belongs to.
    if new_leaf_hash < first_moved_hash:
        oat: uint32 = _dx_bsearch(o_entries, split, new_leaf_hash)
        if _ext4_dx_insert_entry(o_entries, oat, new_leaf_hash,
                                 new_leaf_block) != 0:
            return -1
    else:
        nat: uint32 = _dx_bsearch(n_entries, moved, new_leaf_hash)
        if _ext4_dx_insert_entry(n_entries, nat, new_leaf_hash,
                                 new_leaf_block) != 0:
            return -1

    if _ext4_write_block(new_phys, cast[Ptr[uint8]](new_node)) != 0:
        return -1
    out_node_hash[0] = first_moved_hash
    out_node_logical[0] = cast[uint32](new_logical)
    return 0


def _ext4_extent_meta_block_count(inode_buf: Ptr[uint8]) -> uint64:
    # Count the extent-TREE metadata blocks an inode owns (the on-disk
    # index/leaf blocks of the extent tree itself, NOT the file-data blocks
    # they map). e2fsck includes these in i_blocks. A depth-0 (inline)
    # extent tree has NO metadata blocks. For depth >= 1, every index entry
    # at every interior level points at one extent-tree block:
    #   depth 1: each inode index entry -> 1 leaf block.
    #   depth 2: each inode index entry -> 1 L1 index block, and each of
    #            those -> its leaf blocks.
    # We walk the tree counting those blocks. The dense left-to-right trees
    # our writers build stay shallow (this dir track reaches depth 1).
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return 0
    depth: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_DEPTH_OFFSET))
    if depth == 0:
        return 0
    in_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    in_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if in_entries > in_max:
        return 0
    if depth == 1:
        # Each inode index entry owns exactly one leaf block.
        return cast[uint64](in_entries)
    if depth == 2:
        # Each inode index entry owns one L1 index block plus that block's
        # leaf children.
        total: uint64 = cast[uint64](in_entries)
        i: uint16 = 0
        while i < in_entries:
            ei: uint64 = eh + 12 + cast[uint64](i) * 12
            idx_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
            idx_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
            idx_blk: uint64 = (cast[uint64](idx_hi) << 32) \
                            | cast[uint64](idx_lo)
            if _ext4_read_block(idx_blk, &ext4_extidx_buf[0]) == 0:
                l1p: uint64 = cast[uint64](&ext4_extidx_buf[0])
                l1_ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](l1p + 2))
                l1_mx:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](l1p + 4))
                if l1_ent <= l1_mx:
                    total = total + cast[uint64](l1_ent)
            i = i + 1
        return total
    # depth >= 3 is not produced by this directory writer.
    return 0


def _ext4_htins_restamp_iblocks(inode_buf: Ptr[uint8]):
    # Re-stamp i_blocks_lo (offset 28, 512-byte units) from the directory
    # inode's current extent coverage after a split / index growth added
    # data blocks. Keeps stat + e2fsck's i_blocks accounting consistent
    # with the blocks the dir now occupies: file-data blocks PLUS the
    # extent-tree metadata blocks (which e2fsck also counts toward
    # i_blocks once the inline extent leaf overflows into a real tree).
    block_cnt: uint64 = _ext4_inode_block_count(inode_buf)
    meta_cnt: uint64 = _ext4_extent_meta_block_count(inode_buf)
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](inode_buf) + 28),
                    cast[uint32]((block_cnt + meta_cnt) * sectors_per_block))


def ext4_htree_dir_insert(parent_inum: uint64, name: Ptr[char],
                          child_inum: uint32, file_type: uint8) -> int32:
    # Insert (name, child_inum) into the EXT4_INDEX_FL directory
    # `parent_inum`. Hashes the name, descends the dx index to the target
    # leaf, and inserts there if it fits. On a full leaf it performs a
    # real leaf split (sibling leaf + median-hash redistribute) and
    # registers a new dx_entry in the parent. When the parent index node
    # is itself full it grows the index from 0 to 1 indirect level.
    # Returns 0 on success, -1 on failure.
    if parent_inum == 0:
        return -1
    name_len: uint64 = _ext4_strlen(name)
    if name_len == 0 or name_len > 255:
        return -1
    parent_inode: Array[256, uint8]
    if ext4_read_inode(parent_inum, &parent_inode[0]) != 0:
        return -1
    parent_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&parent_inode[0]) + 0x64))
    minor: uint32 = 0
    hash: uint32 = ext4_dirhash(cast[Ptr[uint8]](name), name_len, &minor)

    leaf_logical: uint64 = 0
    ind: int64 = _ext4_htins_descend_write(&parent_inode[0], hash,
                                           &leaf_logical)
    if ind < 0:
        return -1
    leaf_phys: uint64 = _ext4_logical_to_physical(&parent_inode[0],
                                                  leaf_logical)
    if leaf_phys == 0:
        return -1
    if _ext4_read_block(leaf_phys, &ext4_htins_oldleaf[0]) != 0:
        return -1
    old: uint64 = cast[uint64](&ext4_htins_oldleaf[0])
    # Fast path: the target leaf has room.
    if _ext4_leaf_dirent_insert(old, name, name_len, child_inum,
                                file_type) == 0:
        ext4_dirblock_csum_set(cast[Ptr[uint8]](old), parent_inum,
                               parent_gen)
        return _ext4_write_block(leaf_phys, cast[Ptr[uint8]](old))

    # Leaf is full — split it. (The oldleaf buffer still holds the leaf.)
    new_hash: uint32 = 0
    deepest: uint32 = cast[uint32](ind)
    new_logical_i64: int64 = _ext4_htins_do_split(
        parent_inum, parent_gen, &parent_inode[0], leaf_logical,
        name, name_len, child_inum, file_type, &new_hash)
    if new_logical_i64 < 0:
        return -1
    new_logical: uint64 = cast[uint64](new_logical_i64)

    # Register the new leaf in the parent (deepest) index node. Re-read
    # that node into ext4_htins_idxbuf, insert the dx_entry after `at`.
    pframe: uint32 = deepest
    pidx_logical: uint64 = ext4_htins_frame_logical[pframe]
    peoff: uint64 = ext4_htins_frame_eoff[pframe]
    pat: uint32 = ext4_htins_frame_at[pframe]
    pidx_phys: uint64 = _ext4_logical_to_physical(&parent_inode[0],
                                                  pidx_logical)
    if pidx_phys == 0:
        return -1
    if _ext4_read_block(pidx_phys, &ext4_htins_idxbuf[0]) != 0:
        return -1
    pentries: uint64 = cast[uint64](&ext4_htins_idxbuf[0]) + peoff
    if _ext4_dx_insert_entry(pentries, pat, new_hash,
                             cast[uint32](new_logical)) == 0:
        # The inode was mutated (i_size + extents grew); re-stamp i_blocks
        # and persist, then write the parent index block.
        _ext4_htins_restamp_iblocks(&parent_inode[0])
        if ext4_write_inode(parent_inum, &parent_inode[0]) != 0:
            return -1
        return _ext4_write_block(pidx_phys, &ext4_htins_idxbuf[0])

    # Parent index node is FULL. Cascade the split UP the frame stack the
    # way ext4_dx_add_entry does: split the full node, then try to register
    # the new sibling in its parent; if the parent is also full, split it
    # too and keep climbing. When we reach a frame with room the sibling is
    # inserted and we are done. If the ROOT itself is full, grow the tree by
    # one index level (gated on INCOMPAT_LARGEDIR and capped at 3 levels /
    # indirect_levels==2, exactly as Linux's EXT4_HTREE_LEVEL bounds it).
    if deepest != 0:
        # Pending {hash, block} to register in the parent. Initially it is
        # the new leaf produced by the leaf split; after each interior split
        # it becomes the freshly created sibling dx_node.
        pend_hash: uint32 = new_hash
        pend_block: uint32 = cast[uint32](new_logical)
        # Logical/eoff/at of the FULL node currently in ext4_htins_idxbuf
        # (the frame we just failed to insert into). It is the deepest
        # interior node on the first iteration.
        cur_logical: uint64 = pidx_logical
        cur_frame: int32 = cast[int32](deepest)
        casc_guard: int32 = 16
        while casc_guard > 0:
            casc_guard = casc_guard - 1
            # Split the full node `cur_frame` (it is loaded in idxbuf), get
            # the new sibling's first hash + logical block.
            snode_hash: uint32 = 0
            snode_logical: uint32 = 0
            if _ext4_htins_split_node(&parent_inode[0], cur_logical,
                                      pend_hash, pend_block,
                                      &snode_hash, &snode_logical) != 0:
                return -1
            # Write the shrunk old node back.
            cur_phys: uint64 = _ext4_logical_to_physical(&parent_inode[0],
                                                         cur_logical)
            if cur_phys == 0:
                return -1
            if _ext4_write_block(cur_phys, &ext4_htins_idxbuf[0]) != 0:
                return -1
            # The sibling must be registered in the PARENT frame.
            par_frame: int32 = cur_frame - 1
            par_logical: uint64 = ext4_htins_frame_logical[par_frame]
            par_eoff: uint64 = ext4_htins_frame_eoff[par_frame]
            par_at: uint32 = ext4_htins_frame_at[par_frame]
            par_phys: uint64 = _ext4_logical_to_physical(&parent_inode[0],
                                                         par_logical)
            if par_phys == 0:
                return -1
            if _ext4_read_block(par_phys, &ext4_htins_idxbuf[0]) != 0:
                return -1
            par_entries: uint64 = cast[uint64](&ext4_htins_idxbuf[0]) \
                                  + par_eoff
            if _ext4_dx_insert_entry(par_entries, par_at, snode_hash,
                                     snode_logical) == 0:
                # Parent had room — persist and finish.
                _ext4_htins_restamp_iblocks(&parent_inode[0])
                if ext4_write_inode(parent_inum, &parent_inode[0]) != 0:
                    return -1
                return _ext4_write_block(par_phys, &ext4_htins_idxbuf[0])
            # Parent is ALSO full.
            if par_frame == 0:
                # The full parent is the ROOT — grow the tree one level.
                # Linux gates a deeper index strictly behind LARGEDIR and
                # caps the index at indirect_levels==2 (3 levels total).
                if ext4_large_dir == 0:
                    printk0("ext4: htree root full at 2 levels (need large_dir)\n")
                    return -1
                cur_ind: uint8 = cast[Ptr[uint8]](
                    cast[uint64](&ext4_htins_idxbuf[0]) + 0x1E)[0]
                if cast[uint32](cur_ind) >= 2:
                    printk0("ext4: htree at max 3 levels (Directory index full)\n")
                    return -1
                _ext4_htins_restamp_iblocks(&parent_inode[0])
                if ext4_write_inode(parent_inum, &parent_inode[0]) != 0:
                    return -1
                if _ext4_htins_grow_index(parent_inum, parent_gen,
                                          &parent_inode[0], snode_hash,
                                          snode_logical) != 0:
                    return -1
                _ext4_htins_restamp_iblocks(&parent_inode[0])
                return ext4_write_inode(parent_inum, &parent_inode[0])
            # Climb: the full parent itself must now be split, registering
            # ITS new sibling in the grandparent.
            pend_hash = snode_hash
            pend_block = snode_logical
            cur_logical = par_logical
            cur_frame = par_frame
        # Cascade guard exhausted (should never happen for <= 3 levels).
        return -1

    # Single-level (dx_root only, indirect_levels==0) -> two-level growth.
    _ext4_htins_restamp_iblocks(&parent_inode[0])
    if ext4_write_inode(parent_inum, &parent_inode[0]) != 0:
        return -1
    if _ext4_htins_grow_index(parent_inum, parent_gen, &parent_inode[0],
                              new_hash, cast[uint32](new_logical)) != 0:
        return -1
    _ext4_htins_restamp_iblocks(&parent_inode[0])
    return ext4_write_inode(parent_inum, &parent_inode[0])


def _ext4_htins_grow_index(dir_inum: uint64, dir_gen: uint32,
                           inode_buf: Ptr[uint8],
                           extra_hash: uint32,
                           extra_block: uint32) -> int32:
    # Grow the htree root by ONE indirect level, the way ext4_dx_add_entry
    # does when the root's dx_entry array fills. Works for both 0->1 (the
    # dx_root only, indirect_levels==0) and 1->2 (a 2-level tree whose root
    # filled, gated on INCOMPAT_LARGEDIR by the caller). Steps:
    #   1. allocate a new dx_node block,
    #   2. move ALL of the root's dx_entries into it,
    #   3. shrink the root to a single dx_entry pointing at the new node,
    #   4. bump the root's indirect_levels by 1,
    #   5. insert the pending {extra_hash, extra_block} dx_entry into the
    #      new node (which now has a full block of slots).
    # The {extra_*} entry points at whatever child the prior split created
    # (a leaf for 0->1, an interior dx_node for 1->2); the growth code is
    # agnostic to what the block number refers to. Returns 0 / -1.
    root_phys: uint64 = _ext4_logical_to_physical(inode_buf, 0)
    if root_phys == 0:
        return -1
    if _ext4_read_block(root_phys, &ext4_htins_idxbuf[0]) != 0:
        return -1
    rbase: uint64 = cast[uint64](&ext4_htins_idxbuf[0])
    info_length: uint8 = cast[Ptr[uint8]](rbase + 0x1D)[0]
    cur_indirect: uint8 = cast[Ptr[uint8]](rbase + 0x1E)[0]
    if info_length != 8:
        return -1
    r_entries_off: uint64 = 0x18 + cast[uint64](info_length)
    r_entries: uint64 = rbase + r_entries_off
    r_count: uint32 = _dx_get_count(r_entries)
    r_limit: uint32 = _dx_get_limit(r_entries)

    # Allocate + append the new dx_node logical block.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(inode_buf))
    node_logical: uint64 = dir_size / ext4_block_size
    node_phys: uint64 = ext4_alloc_block()
    if node_phys == 0:
        return -1
    if _ext4_extent_append_block(inode_buf, node_logical, node_phys) != 0:
        ext4_free_block(node_phys)
        return -1
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](inode_buf) + 4),
                    cast[uint32](dir_size + ext4_block_size))

    # Build the new dx_node in ext4_htins_oldleaf (free scratch here).
    node: uint64 = cast[uint64](&ext4_htins_oldleaf[0])
    _ext4_zero(cast[Ptr[uint8]](node), ext4_block_size)
    # dx_node: 8-byte fake dirent (rec_len spans block) then entries[].
    _ext4_write_u32(cast[Ptr[uint8]](node + 0), 0)            # fake inode
    _ext4_write_u16(cast[Ptr[uint8]](node + 4),
                    cast[uint16](ext4_block_size))            # rec_len
    n_entries_off: uint64 = 8
    n_entries: uint64 = node + n_entries_off
    # dx_countlimit at entry 0: limit = (block_size - 8) / 8, count =
    # r_count (we copy all root entries in).
    node_limit: uint32 = cast[uint32]((ext4_block_size - n_entries_off) / 8)
    _ext4_write_u16(cast[Ptr[uint8]](n_entries + 0),
                    cast[uint16](node_limit))                 # limit
    _ext4_write_u16(cast[Ptr[uint8]](n_entries + 2),
                    cast[uint16](r_count))                    # count
    # Copy root entries 0..r_count-1 into the node. Entry 0's hash field
    # is the dummy "0" of the first range, preserved verbatim.
    ci: uint32 = 0
    while ci < r_count:
        h: uint32 = _dx_entry_hash(r_entries, ci)
        b: uint32 = _dx_entry_block(r_entries, ci)
        if ci == 0:
            # keep the countlimit u16s we just wrote; only set the block.
            _ext4_write_u32(cast[Ptr[uint8]](n_entries + 4), b)
        else:
            _ext4_write_u32(cast[Ptr[uint8]](n_entries + cast[uint64](ci) * 8 + 0), h)
            _ext4_write_u32(cast[Ptr[uint8]](n_entries + cast[uint64](ci) * 8 + 4), b)
        ci = ci + 1
    # Insert the pending entry into the node (it now has node_limit slots).
    # Find the right slot via bsearch on the just-built array.
    n_at: uint32 = _dx_bsearch(n_entries, r_count, extra_hash)
    if _ext4_dx_insert_entry(n_entries, n_at, extra_hash, extra_block) != 0:
        ext4_free_block(node_phys)
        return -1
    if _ext4_write_block(node_phys, cast[Ptr[uint8]](node)) != 0:
        return -1

    # Rewrite the root: indirect_levels += 1, a single dx_entry pointing
    # at the node (logical block node_logical), count = 1.
    cast[Ptr[uint8]](rbase + 0x1E)[0] = cur_indirect + 1      # indirect_levels
    _ext4_write_u16(cast[Ptr[uint8]](r_entries + 2), 1)      # count = 1
    _ext4_write_u32(cast[Ptr[uint8]](r_entries + 4),
                    cast[uint32](node_logical))               # block ptr
    # entry 0 hash field holds the limit (lo u16) + count (hi u16); leave
    # the limit alone, we set count above. The hash value of entry 0 is
    # ignored by the descend (it is the catch-all), so no hash write.
    if _ext4_write_block(root_phys, &ext4_htins_idxbuf[0]) != 0:
        return -1
    return 0


def ext4_create_file(parent_inum: uint64, name: Ptr[char],
                     body: Ptr[uint8], body_len: uint64) -> uint32:
    # Top-level orchestration: alloc inode + alloc block, write the
    # body into the block, build a fresh inode pointing at it, write
    # the inode into the inode table, and splice a dirent into the
    # parent. Returns the new inum on success, 0 on failure (with
    # best-effort rollback of any partial allocs).
    if body_len > ext4_block_size:
        printk0("ext4: create_file: body > one block (M16.63 scope)\n")
        return 0
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        printk0("ext4: create_file FAIL (alloc_inode)\n")
        return 0
    new_blk: uint64 = ext4_alloc_block()
    if new_blk == 0:
        printk0("ext4: create_file FAIL (alloc_block)\n")
        ext4_free_inode(new_inum)
        return 0

    # Write body into the new data block. Zero-pad the rest so we
    # don't expose previous tenants' data.
    _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
    if body_len > 0:
        memcpy(&ext4_blk_buf[0], body, body_len)
    if _ext4_write_block(new_blk, &ext4_blk_buf[0]) != 0:
        printk0("ext4: create_file FAIL (write data)\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0

    _ext4_init_regular_inode(new_blk, body_len)
    if ext4_write_inode(cast[uint64](new_inum),
                        &ext4_new_inode_buf[0]) != 0:
        printk0("ext4: create_file FAIL (write inode)\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0

    # 1 = EXT4_FT_REG_FILE in linux/ext4.h
    if ext4_dir_insert(parent_inum, name, new_inum, 1) != 0:
        printk0("ext4: create_file FAIL (dir_insert)\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0
    return new_inum


def ext4_create_smoke_test() -> int32:
    # End-to-end: create /ext/SMOKE.TXT with a known body, then verify
    # the read path delivers the same bytes. Tests inode write, block
    # write, dirent insert, AND the existing read path against the
    # newly-created file. On PASS leaves SMOKE.TXT in the FS (we don't
    # have an unlink yet); on FAIL prints a marker and returns -1.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "CREATE_OK ext4 file-create round-trip works\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    inum: uint32 = ext4_create_file(2, "SMOKE.TXT", body, blen)
    if inum == 0:
        printk0("ext4: create smoke FAIL (create_file returned 0)\n")
        return -1
    # Read it back via the standard path.
    resolved_inum: uint32 = 0
    resolved_size: uint64 = 0
    if ext4_resolve_file("SMOKE.TXT", &resolved_inum,
                         &resolved_size) == 0:
        printk0("ext4: create smoke FAIL (resolve missed)\n")
        return -1
    if resolved_inum != inum:
        printk2("ext4: create smoke FAIL (resolved %d != created %d)\n",
                cast[uint64](resolved_inum), cast[uint64](inum))
        return -1
    if resolved_size != blen:
        printk0("ext4: create smoke FAIL (size mismatch)\n")
        return -1
    rb: Array[64, uint8]
    n: int64 = ext4_read_file(inum, 0, blen, &rb[0])
    if n != cast[int64](blen):
        printk0("ext4: create smoke FAIL (read short)\n")
        return -1
    i: uint64 = 0
    while i < blen:
        if rb[i] != body[i]:
            printk1("ext4: create smoke FAIL (byte %d mismatch)\n", i)
            return -1
        i = i + 1
    printk2("ext4: create smoke PASS (inum=%d size=%d)\n",
            cast[uint64](inum), blen)
    return 0


# --- ext4 write -----------------------------------------------------
#
# Write-mode opens. Backed by the same ext4_open_files slot table as
# reads, plus a per-slot "write" flag so vfs_write knows whether to
# RMW the data block or refuse.
#
# Semantics on open:
#   * if the file already exists, free its inode + every data block
#     held by its inline-leaf extents and re-create empty (matches
#     O_CREAT | O_TRUNC, which is what hamsh's `> file` wants)
#   * if not, allocate an inode, write an empty depth-0 extent leaf
#     (eh_entries=0), splice a dirent into the parent. The first
#     write call allocates the first data block — there's no
#     pre-allocated empty block on disk.
#
# vfs_write calls ext4_write_open_file once per syscall. The writer
# walks block by block from `pos`, allocating fresh physical blocks
# and appending to the inode's inline extent leaf via
# _ext4_extent_append_block whenever the write spills past the last
# allocated logical block. This is the same growth pattern
# ext4_blob_save uses on the install path. When the inline depth-0
# leaf's 4 slots fill, _ext4_extent_append_block promotes the inode to
# a depth-1 INDEX node (extents move into a leaf block; further leaves
# allocated under up to 4 index records) — so a heavily-fragmented file
# now grows to thousands of non-contiguous blocks instead of capping at
# 4 extents. Only a depth-2 tree (index records also exhausted) returns
# a short write; that is a documented follow-up.
#
# Close flushes the final inode i_size via a re-write (it's already
# up-to-date because we update i_size on each write — close is just
# close).

def _ext4_dir_unlink_in_root(name: Ptr[char]) -> uint32:
    # Find `name` in root dir, mark its dirent inum=0 (tombstone),
    # write the block back. Returns the previous inum on hit, 0 on
    # miss. We don't extend the previous entry's rec_len to absorb
    # the tombstone — leaving the tombstone slot lets a future
    # M16.64 create reuse it directly via the tombstone path in
    # ext4_dir_insert.
    root_inode: Array[256, uint8]
    if ext4_read_inode(2, &root_inode[0]) != 0:
        return 0
    root_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&root_inode[0]) + 0x64))
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&root_inode[0]))
    if dir_size == 0:
        return 0
    nblocks: uint64 = dir_size / ext4_block_size
    nlen: uint64 = _ext4_strlen(name)
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&root_inode[0], lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(
                cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    _ext4_write_u32(cast[Ptr[uint8]](e + 0), 0)
                    _ext4_dirblock_stamp_in_buf(2, root_gen)
                    _ext4_write_block(phys, &ext4_blk_buf[0])
                    return e_inum
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 0


# Parent-path scratch + leaf scratch used by ext4_open_create_or_trunc
# when `name` is a subdirectory path like "dst-on-disk/a.txt". The
# parent ("dst-on-disk") is resolved via ext4_resolve_dir; the leaf
# ("a.txt") is what gets unlinked + created. Module-scoped because
# the kernel-stack frame can't carry two 256-byte buffers comfortably.
ext4_oct_parent_buf: Array[256, uint8]
ext4_oct_leaf_buf:   Array[256, uint8]


def _ext4_split_parent_leaf(name: Ptr[char],
                            parent_inum_out: Ptr[uint32],
                            leaf_out: Ptr[Ptr[char]]) -> int32:
    # Split `name` (partition-relative; caller already stripped /ext/)
    # into (parent_dir_inum, leaf_basename). For a leaf-only path like
    # "foo.txt" the parent is the root dir (inum 2). For "sub/foo.txt"
    # we resolve "sub" to its inum via ext4_resolve_dir. The leaf
    # pointer in `leaf_out` is set to ext4_oct_leaf_buf (a NUL-term'd
    # cstring), the parent_inum is set in `parent_inum_out`.
    # Returns 0 on success, -1 on miss / bad path.
    nlen: uint64 = _ext4_strlen(name)
    if nlen == 0 or nlen >= 256:
        return -1
    # Find the LAST '/' in `name`. Reject trailing slash.
    if cast[Ptr[uint8]](name)[nlen - 1] == 47:
        return -1
    last_slash: int64 = -1
    i: uint64 = 0
    while i < nlen:
        if cast[Ptr[uint8]](name)[i] == 47:
            last_slash = cast[int64](i)
        i = i + 1
    if last_slash < 0:
        # Bare leaf — parent is root, leaf is the whole name.
        parent_inum_out[0] = 2
        k: uint64 = 0
        while k < nlen:
            ext4_oct_leaf_buf[k] = cast[Ptr[uint8]](name)[k]
            k = k + 1
        ext4_oct_leaf_buf[nlen] = 0
        leaf_out[0] = cast[Ptr[char]](&ext4_oct_leaf_buf[0])
        return 0
    # Split: parent = name[0..last_slash], leaf = name[last_slash+1..].
    p_len: uint64 = cast[uint64](last_slash)
    if p_len == 0 or p_len >= 256:
        return -1
    k: uint64 = 0
    while k < p_len:
        ext4_oct_parent_buf[k] = cast[Ptr[uint8]](name)[k]
        k = k + 1
    ext4_oct_parent_buf[p_len] = 0
    pinum: uint32 = ext4_resolve_dir(
        cast[Ptr[char]](&ext4_oct_parent_buf[0]))
    if pinum == 0:
        return -1
    parent_inum_out[0] = pinum
    leaf_off: uint64 = cast[uint64](last_slash) + 1
    l_len: uint64 = nlen - leaf_off
    if l_len == 0 or l_len >= 256:
        return -1
    k = 0
    while k < l_len:
        ext4_oct_leaf_buf[k] = cast[Ptr[uint8]](name)[leaf_off + k]
        k = k + 1
    ext4_oct_leaf_buf[l_len] = 0
    leaf_out[0] = cast[Ptr[char]](&ext4_oct_leaf_buf[0])
    return 0


def ext4_open_create_or_trunc(name: Ptr[char]) -> int32:
    # O_CREAT|O_TRUNC: nuke any existing entry, create fresh-empty,
    # open it as a write-capable slot. Caller is vfs_open_write for
    # /ext paths.
    #
    # Subdir-aware (M16.x): `name` is the partition-relative path
    # AFTER strip_ext_prefix. For a leaf-only name it lands in the
    # ext4 root (inum 2); for a nested path like "sub/file.txt" the
    # parent dir is resolved via ext4_resolve_dir and the create lands
    # there. This is what makes `cp -r SRC /ext/dst-on-disk` work end-
    # to-end (cp -r mkdir's the parent first via vfs_mkdir; this
    # function opens the per-file output FD against THAT parent).
    if ext4_blockdev_slot < 0:
        set_current_errstr("ext4: volume not mounted")
        return -1
    parent_inum: uint32 = 0
    leaf: Ptr[char] = cast[Ptr[char]](0)
    if _ext4_split_parent_leaf(name, &parent_inum, &leaf) != 0:
        set_current_errstr("ext4: create: parent directory missing")
        return -1
    # Unlink old — tombstones the dirent, walks the extent leaf to
    # free every data block (so an overwrite doesn't leak the
    # blocks that previous file contents covered), and frees the
    # inode itself.
    leaf_len: uint64 = _ext4_strlen(leaf)
    old_inum: uint32 = _ext4_dir_unlink_in_dir(
        cast[uint64](parent_inum),
        cast[Ptr[uint8]](leaf), leaf_len)
    if old_inum != 0:
        old_inode_buf: Array[256, uint8]
        if ext4_read_inode(cast[uint64](old_inum),
                           &old_inode_buf[0]) == 0:
            _ext4_extent_trim_to(&old_inode_buf[0], 0)
        ext4_free_inode(old_inum)
        # Page-cache coherence: the old inode's blocks are freed and its
        # inum may be REUSED by the fresh create below — drop its cached
        # pages (no writeback; blocks are gone) so the new empty file is
        # never shadowed by the old contents.
        fcache_drop_inode_nowriteback(PC_SRV_EXT4, cast[uint64](old_inum))
    # Fresh-empty create against the resolved parent.
    empty: Array[1, uint8]
    new_inum: uint32 = ext4_create_file(
        cast[uint64](parent_inum), leaf, &empty[0], 0)
    if new_inum == 0:
        set_current_errstr("ext4: create: inode allocation failed")
        return -1
    # Open it for I/O via the existing read-path slot table.
    # ext4_open does a full path resolve, so it picks up the new
    # dirent we just spliced into the parent.
    return ext4_open(name)


def ext4_write_open_file(slot: int32, src: Ptr[uint8],
                         pos: uint64, count: uint64) -> int64:
    # Stream `count` bytes from `src` into the open file's data
    # blocks starting at byte offset `pos`. Allocates fresh physical
    # blocks and grows the inline extent leaf as the write spills
    # past previously-allocated logical blocks (the same pattern
    # ext4_blob_save uses on the install path). Updates i_size_lo
    # and mtime; returns the byte count actually written, or a short
    # count if the leaf hit its 4-slot depth-0 ceiling mid-write.
    if slot < 0:
        return -1
    if count == 0:
        return 0
    inum: uint32 = ext4_open_inum(slot)
    if inum == 0:
        return -1
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    cur_size: uint32 = ext4_inode_size_lo(&inode[0])
    written: uint64 = 0
    while written < count:
        cur_pos:     uint64 = pos + written
        logical_blk: uint64 = cur_pos / ext4_block_size
        off_in_blk:  uint64 = cur_pos % ext4_block_size
        # Chunk = however many bytes will fit in the remainder of
        # the current block before the next block boundary.
        chunk: uint64 = ext4_block_size - off_in_blk
        if chunk > count - written:
            chunk = count - written
        phys: uint64 = _ext4_logical_to_physical(&inode[0],
                                                 logical_blk)
        if phys == 0:
            # The logical block is past every existing extent's
            # coverage — allocate a new physical block and append
            # it to the inline leaf. Fresh-allocated blocks are NOT
            # pre-zeroed; we zero ext4_blk_buf here so a partial
            # write doesn't expose previous tenants' bytes.
            phys = ext4_alloc_block()
            if phys == 0:
                printk0("ext4: write FAIL (out of blocks)\n")
                if written > 0:
                    break
                return -1
            if _ext4_extent_append_block(&inode[0],
                                         logical_blk, phys) != 0:
                # Leaf full at depth 0; can't grow further. Free
                # the orphan block (it never made it into the
                # extent leaf) and return whatever we wrote.
                ext4_free_block(phys)
                printk0("ext4: write capped at extent leaf full\n")
                break
            _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
            # Splat the user bytes into the new block. No
            # read-back: this block is freshly allocated and we
            # just zeroed the scratch.
            if chunk > 0:
                memcpy(cast[Ptr[uint8]](
                           cast[uint64](&ext4_blk_buf[0])
                           + off_in_blk),
                       cast[Ptr[uint8]](
                           cast[uint64](src) + written),
                       chunk)
            if _ext4_write_block(phys, &ext4_blk_buf[0]) != 0:
                return -1
        else:
            # Existing block — read-modify-write so we preserve any
            # bytes already on either side of [off_in_blk,
            # off_in_blk+chunk).
            if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
                return -1
            memcpy(cast[Ptr[uint8]](
                       cast[uint64](&ext4_blk_buf[0]) + off_in_blk),
                   cast[Ptr[uint8]](
                       cast[uint64](src) + written),
                   chunk)
            if _ext4_write_block(phys, &ext4_blk_buf[0]) != 0:
                return -1
        written = written + chunk
    # Extend i_size if needed, refresh mtime, and re-stamp
    # i_blocks_lo so stat sees the right block count.
    new_end: uint64 = pos + written
    if new_end > cast[uint64](cur_size):
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                        cast[uint32](new_end))
        ext4_open_files[cast[uint64](slot)].file_size = new_end
    # Re-stamp i_blocks_lo from the current extent coverage. In 512-byte
    # units regardless of fs block size.
    block_cnt: uint64 = _ext4_inode_block_count(&inode[0])
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 28),
                    cast[uint32](block_cnt * sectors_per_block))
    _ext4_stamp_mtime(&inode[0])
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    # Page-cache coherence (see ext4_pwrite_inode): drop this inode's cached
    # pages so the next read re-populates from the just-written disk blocks.
    fcache_invalidate_inode(PC_SRV_EXT4, cast[uint64](inum))
    if written == 0:
        return 0
    return cast[int64](written)


def ext4_pwrite_inode(inum: uint32, src: Ptr[uint8],
                      pos: uint64, count: uint64) -> int64:
    # §shared-mmap: inode-identity write-back path for MAP_SHARED writable
    # file-backed mmap. Unlike ext4_write_open_file (which keys off an
    # OPEN-FILE slot), this resolves the inode by NUMBER — the mmap fd may
    # have been closed long before msync/munmap fires the write-back, so
    # only the stable inode number survives. Stream `count` bytes from
    # `src` into the inode's data blocks at byte offset `pos`,
    # read-modify-writing existing blocks and allocating fresh blocks past
    # the current extent coverage. Returns bytes written or a short count.
    if inum == 0:
        return -1
    if count == 0:
        return 0
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    cur_size: uint32 = ext4_inode_size_lo(&inode[0])
    written: uint64 = 0
    while written < count:
        cur_pos:     uint64 = pos + written
        logical_blk: uint64 = cur_pos / ext4_block_size
        off_in_blk:  uint64 = cur_pos % ext4_block_size
        chunk: uint64 = ext4_block_size - off_in_blk
        if chunk > count - written:
            chunk = count - written
        phys: uint64 = _ext4_logical_to_physical(&inode[0], logical_blk)
        if phys == 0:
            phys = ext4_alloc_block()
            if phys == 0:
                printk0("ext4: pwrite FAIL (out of blocks)\n")
                if written > 0:
                    break
                return -1
            if _ext4_extent_append_block(&inode[0],
                                         logical_blk, phys) != 0:
                ext4_free_block(phys)
                printk0("ext4: pwrite capped at extent leaf full\n")
                break
            _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
            if chunk > 0:
                memcpy(cast[Ptr[uint8]](
                           cast[uint64](&ext4_blk_buf[0]) + off_in_blk),
                       cast[Ptr[uint8]](cast[uint64](src) + written),
                       chunk)
            if _ext4_write_block(phys, &ext4_blk_buf[0]) != 0:
                return -1
        else:
            if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
                return -1
            memcpy(cast[Ptr[uint8]](
                       cast[uint64](&ext4_blk_buf[0]) + off_in_blk),
                   cast[Ptr[uint8]](cast[uint64](src) + written),
                   chunk)
            if _ext4_write_block(phys, &ext4_blk_buf[0]) != 0:
                return -1
        written = written + chunk
    new_end: uint64 = pos + written
    if new_end > cast[uint64](cur_size):
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                        cast[uint32](new_end))
    block_cnt: uint64 = _ext4_inode_block_count(&inode[0])
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 28),
                    cast[uint32](block_cnt * sectors_per_block))
    _ext4_stamp_mtime(&inode[0])
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    # Page-cache coherence: this inode's data on disk changed under the
    # cache; drop cached pages so the next read sees the new bytes.
    fcache_invalidate_inode(PC_SRV_EXT4, cast[uint64](inum))
    if written == 0:
        return 0
    return cast[int64](written)


# --- ext4 unlink (M16.67) -----------------------------------------
#
# Delete a regular file from the root directory. Frees the inode,
# frees EVERY data block the file owns by walking its extent tree via
# _ext4_extent_trim_to(..., 0) — including the interior index/leaf
# metadata blocks of a depth-1/2/3 indexed tree — and tombstones its
# dirent. Linux's ext4_unlink does this under the journal. #149:
# when a JBD2 journal is mounted, the dirent-tombstone block write
# is wrapped in a transaction (_ext4_journal_write_block) so the
# delete is crash-consistent; on a no-journal image the write goes
# straight to disk in the same order Linux's no-journal path commits.

def ext4_unlink(name: Ptr[char]) -> int32:
    if ext4_blockdev_slot < 0:
        set_current_errstr("ext4: volume not mounted")
        return -1
    # First locate the inode WITHOUT modifying the dirent yet —
    # we need the inum so we can read the inode and find its data
    # block before we lose the pointer.
    target_inum: uint32 = 0
    nlen: uint64 = _ext4_strlen(name)
    root_inode: Array[256, uint8]
    if ext4_read_inode(2, &root_inode[0]) != 0:
        return -1
    # Capture root i_generation up front for the metadata_csum dir-block
    # restamp below — the later inode reads clobber ext4_blk_buf and the
    # dir block we tombstone, so we cannot re-read the inode at restamp
    # time without trampling the block we're about to write.
    root_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&root_inode[0]) + 0x64))
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&root_inode[0]))
    if dir_size == 0:
        set_current_errstr("ext4: unlink: no such file")
        return -2                                  # -ENOENT
    nblocks: uint64 = dir_size / ext4_block_size
    target_phys: uint64 = 0
    target_pos:  uint64 = 0
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&root_inode[0], lb)
        if phys == 0:
            return -2
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    target_inum = e_inum
                    target_phys = phys
                    target_pos  = pos
                    break
            pos = pos + cast[uint64](e_rec_len)
        if target_inum != 0:
            break
        lb = lb + 1
    if target_inum == 0:
        set_current_errstr("ext4: unlink: no such file")
        return -2                                  # -ENOENT

    # Read the file's inode and free every data block via
    # _ext4_extent_trim_to(..., 0) — the same helper ext4_truncate_inode
    # uses for a full truncate-to-zero. It now walks both the inline
    # depth-0 leaf AND a depth-1 index tree (freeing index/leaf blocks),
    # so an index-node file is fully reclaimed here.
    finode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](target_inum), &finode[0]) == 0:
        _ext4_extent_trim_to(&finode[0], 0)
    # Free the inode regardless — even if the block free failed,
    # we want the inode slot reclaimed.
    ext4_free_inode(target_inum)

    # Tombstone the dirent. We don't coalesce with the previous
    # entry's rec_len — leaving the slot in-place lets a future
    # create reuse it via ext4_dir_insert's tombstone path.
    # Re-read the block (the inode-related reads above may have
    # trampled ext4_blk_buf via ext4_read_inode).
    if _ext4_read_block(target_phys, &ext4_blk_buf[0]) != 0:
        return -1
    _ext4_write_u32(cast[Ptr[uint8]](
        cast[uint64](&ext4_blk_buf[0]) + target_pos + 0), 0)
    # metadata_csum: restamp the dir block's tail checksum before the
    # write so the tombstone keeps the block's crc32c valid.
    _ext4_dirblock_stamp_in_buf(2, root_gen)
    # Page-cache coherence: the inode is gone — drop its cached pages WITHOUT
    # writeback (the inode/blocks are freed; flushing would corrupt the fs).
    fcache_drop_inode_nowriteback(PC_SRV_EXT4, cast[uint64](target_inum))
    return _ext4_journal_write_block(target_phys, &ext4_blk_buf[0])


# --- ext4 rmdir (remove an empty directory) -----------------------
#
# Linux's ext4_rmdir(): verify the victim is a directory and EMPTY
# (only "." and ".."), then free its inode + data block(s), tombstone
# its dirent in the parent, and DECREMENT the parent's i_links_count
# by one (the child's ".." backreference is going away — symmetric
# with the bump _ext4_dir_create_child / mkdir does on create). The
# dirent-tombstone block write is wrapped in _ext4_journal_write_block
# so the removal is crash-consistent under JBD2, exactly like
# ext4_unlink. Returns 0 on success or a Linux errno:
#   -ENOENT (-2)      target missing
#   -ENOTDIR (-20)    target exists but isn't a directory
#   -ENOTEMPTY (-39)  directory still has real entries

def _ext4_dir_is_empty(dir_inode: Ptr[uint8]) -> int32:
    # Scan every data block of `dir_inode` (an already-read directory
    # inode buffer). Returns 1 if the only live dirents are "." and
    # ".." (an empty dir), 0 if any other live entry exists, -1 on I/O
    # error. Trashes ext4_blk_buf.
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(dir_inode))
    if dir_size == 0:
        return 1
    nblocks: uint64 = (dir_size + ext4_block_size - 1) / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(dir_inode, lb)
        if phys == 0:
            return 1
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                # "." (len 1, name[0]=='.') and ".." (len 2, "..") are
                # the only entries allowed in an empty dir.
                is_dot: int32 = 0
                if e_name_len == 1 \
                        and cast[Ptr[uint8]](e + 8)[0] == 0x2E:
                    is_dot = 1
                if e_name_len == 2 \
                        and cast[Ptr[uint8]](e + 8)[0] == 0x2E \
                        and cast[Ptr[uint8]](e + 9)[0] == 0x2E:
                    is_dot = 1
                if is_dot == 0:
                    return 0                        # a real child → not empty
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 1


def ext4_rmdir(path: Ptr[char]) -> int32:
    # Remove the empty directory named by `path` (partition-relative;
    # caller already stripped /ext/). Mirrors ext4_unlink's inode/block
    # freeing + dirent tombstoning, but for a directory.
    if ext4_blockdev_slot < 0:
        return -1
    # Split path into parent dir + leaf name, resolve the parent.
    if _ext4_split_dir_path(path, &ext4_rn_old_parent[0],
                            &ext4_rn_old_leaf[0]) != 0:
        return -2                                   # -ENOENT
    parent_inum: uint32 = ext4_resolve_dir(
        cast[Ptr[char]](&ext4_rn_old_parent[0]))
    if parent_inum == 0:
        return -2                                   # -ENOENT
    leaf: Ptr[char] = cast[Ptr[char]](&ext4_rn_old_leaf[0])

    # Find the victim dirent (inum + file_type).
    target_inum:  uint32 = 0
    target_ftype: uint8  = 0
    fr: int32 = _ext4_dir_find_entry(
        cast[uint64](parent_inum), leaf, &target_inum, &target_ftype)
    if fr < 0:
        return -1
    if fr == 0 or target_inum == 0:
        return -2                                   # -ENOENT

    # Must be a directory.
    dnode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](target_inum), &dnode[0]) != 0:
        return -1
    mode: uint16 = ext4_inode_mode(&dnode[0])
    if (cast[uint64](mode) & 0xF000) != 0x4000:     # S_IFDIR
        return -20                                  # -ENOTDIR

    # Must be empty (only "." and ".."). _ext4_dir_is_empty reads
    # blocks into ext4_blk_buf; dnode is its own buffer so it survives.
    empty: int32 = _ext4_dir_is_empty(&dnode[0])
    if empty < 0:
        return -1
    if empty == 0:
        return -39                                  # -ENOTEMPTY

    # Free the directory's data block(s) then its inode — same helper
    # ext4_unlink uses for a full reclaim (walks inline leaf + depth-1
    # index tree).
    _ext4_extent_trim_to(&dnode[0], 0)
    ext4_free_inode(target_inum)

    # Decrement the parent's i_links_count: removing a child dir drops
    # the parent's nlink by 1 (the child's ".." backreference is gone),
    # the inverse of the bump _ext4_dir_create_child performs on mkdir.
    parent_inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](parent_inum), &parent_inode[0]) == 0:
        cur_links: uint16 = _ext4_read_u16(
            cast[Ptr[uint8]](cast[uint64](&parent_inode[0]) + 0x1A))
        if cur_links > 0:
            _ext4_write_u16(
                cast[Ptr[uint8]](cast[uint64](&parent_inode[0]) + 0x1A),
                cast[uint16](cast[uint64](cur_links) - 1))
        _ext4_stamp_mtime(&parent_inode[0])
        ext4_write_inode(cast[uint64](parent_inum), &parent_inode[0])

    # Tombstone the victim dirent in the parent and journal the block.
    # Re-locate the dirent's physical block + offset (the inode reads
    # above trampled ext4_blk_buf), mirroring ext4_unlink's tail.
    if ext4_read_inode(cast[uint64](parent_inum), &parent_inode[0]) != 0:
        return -1
    parent_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&parent_inode[0]) + 0x64))
    psize: uint64 = cast[uint64](ext4_inode_size_lo(&parent_inode[0]))
    pblocks: uint64 = (psize + ext4_block_size - 1) / ext4_block_size
    nlen: uint64 = _ext4_strlen(leaf)
    tphys: uint64 = 0
    tpos:  uint64 = 0
    found: int32  = 0
    plb: uint64 = 0
    while plb < pblocks and found == 0:
        phys: uint64 = _ext4_logical_to_physical(&parent_inode[0], plb)
        if phys == 0:
            break
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](leaf),
                                              nlen) != 0:
                    tphys  = phys
                    tpos   = pos
                    found  = 1
                    break
            pos = pos + cast[uint64](e_rec_len)
        plb = plb + 1
    if found == 0:
        # The dirent vanished between find and tombstone — the inode is
        # already freed, so the dir is gone. Report success.
        return 0
    _ext4_write_u32(cast[Ptr[uint8]](
        cast[uint64](&ext4_blk_buf[0]) + tpos + 0), 0)
    _ext4_dirblock_stamp_in_buf(cast[uint64](parent_inum), parent_gen)
    return _ext4_journal_write_block(tphys, &ext4_blk_buf[0])


# --- truncate / ftruncate (M16.x §12.2) ---------------------------
#
# Resize a regular file to an arbitrary byte length, freeing or
# allocating blocks as needed and updating i_size. Handles a depth-0
# inline leaf, a depth-1 index tree AND a depth-2 index tree: a shrink
# trims/frees leaf (and, at depth 2, intermediate index) blocks and
# folds the tree back one level at a time as it collapses; a grow
# appends extents (promoting depth 0 → 1 → 2 as each level fills). Only
# a depth-3+ tree (eh_depth > 2) is rejected — our writers never
# produce one.
#
# Linux's ext4_truncate() does the same two jobs: ext4_ext_remove_space
# for a shrink, and (on grow) leaves the tail sparse / zero-fills the
# partial block. We mirror that: shrink frees the now-unreachable
# blocks and trims/drops leaf extents; grow appends extents (each one
# block) and zero-fills, so a read of the grown region returns zeros.

EXT4_EH_DEPTH_OFFSET:   uint64 = 6
EXT4_EH_ENTRIES_OFFSET: uint64 = 2


def _ext4_leaf_block_count(eh: uint64) -> uint64:
    # Highest (ee_block + ee_len) across a depth-0 leaf header at `eh`.
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return 0
    entries: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 2))
    eh_max:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if entries > eh_max:
        return 0
    total: uint64 = 0
    i: uint16 = 0
    while i < entries:
        ee: uint64 = eh + 12 + cast[uint64](i) * 12
        ee_block: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 0))
        ee_len:   uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 4))
        end: uint64 = cast[uint64](ee_block) + cast[uint64](ee_len)
        if end > total:
            total = end
        i = i + 1
    return total


def _ext4_extent_depth(inode_buf: Ptr[uint8]) -> int32:
    # Extent-tree depth of the inode: 0 (inline leaf), 1 (index node over
    # leaf blocks), 2 (index node over intermediate index blocks over leaf
    # blocks) or 3 (one more index level). Returns -1 if the inode is not
    # an extents inode (bad magic) or its depth is beyond what we rewrite
    # (>3).
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return -1
    depth: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_DEPTH_OFFSET))
    if depth > 3:
        return -1
    return cast[int32](depth)


def _ext4_idxnode_block_count(eh: uint64) -> uint64:
    # Max leaf coverage under an index node whose records point at depth-0
    # LEAF blocks. Reads each leaf into ext4_ext_scratch. `eh` must live
    # in a buffer DISTINCT from ext4_ext_scratch (the inode i_block or
    # ext4_extidx_buf). Returns 0 for an empty / malformed node.
    idx_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    idx_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if idx_entries > idx_max:
        return 0
    total: uint64 = 0
    i: uint16 = 0
    while i < idx_entries:
        ei: uint64 = eh + 12 + cast[uint64](i) * 12
        leaf_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        leaf_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        leaf_blk: uint64 = (cast[uint64](leaf_hi) << 32) \
                         | cast[uint64](leaf_lo)
        if _ext4_read_block(leaf_blk, &ext4_ext_scratch[0]) == 0:
            c: uint64 = _ext4_leaf_block_count(
                cast[uint64](&ext4_ext_scratch[0]))
            if c > total:
                total = c
        i = i + 1
    return total


def _ext4_inode_block_count(inode_buf: Ptr[uint8]) -> uint64:
    # Total logical blocks covered by the file's extents — i.e. how many
    # blocks of file data are currently allocated. Walks the inline
    # depth-0 leaf, a depth-1 index tree, a depth-2 index tree, AND a
    # depth-3 index tree (reading each leaf block). Returns 0 for an
    # empty/malformed inode. NOTE: this returns the MAX leaf coverage on
    # the rightmost path, which equals the file's logical block count for
    # the dense left-to-right trees our writers build.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return 0
    depth: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_DEPTH_OFFSET))
    if depth == 0:
        return _ext4_leaf_block_count(eh)
    if depth == 1:
        # depth 1: inode index records point at leaf blocks directly.
        return _ext4_idxnode_block_count(eh)
    if depth == 2:
        # depth 2: inode index records point at intermediate index blocks;
        # each of those points at leaf blocks. Read each intermediate block
        # into ext4_extidx_buf and take the max leaf coverage under it.
        in_entries: uint16 = _ext4_read_u16(
            cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
        in_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
        if in_entries > in_max:
            return 0
        total: uint64 = 0
        i: uint16 = 0
        while i < in_entries:
            ei: uint64 = eh + 12 + cast[uint64](i) * 12
            idx_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
            idx_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
            idx_blk: uint64 = (cast[uint64](idx_hi) << 32) \
                            | cast[uint64](idx_lo)
            if _ext4_read_block(idx_blk, &ext4_extidx_buf[0]) == 0:
                c: uint64 = _ext4_idxnode_block_count(
                    cast[uint64](&ext4_extidx_buf[0]))
                if c > total:
                    total = c
            i = i + 1
        return total
    if depth != 3:
        return 0
    # depth 3: inode index records → L2 index blocks → L1 index blocks →
    # leaf blocks. Read each L2 block into ext4_extl2_buf; for each L2
    # child read the L1 block into ext4_extidx_buf and take the max leaf
    # coverage under it.
    in_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    in_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if in_entries > in_max:
        return 0
    total: uint64 = 0
    i: uint16 = 0
    while i < in_entries:
        ei: uint64 = eh + 12 + cast[uint64](i) * 12
        l2_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        l2_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        l2_blk: uint64 = (cast[uint64](l2_hi) << 32) | cast[uint64](l2_lo)
        if _ext4_read_block(l2_blk, &ext4_extl2_buf[0]) == 0:
            l2p: uint64 = cast[uint64](&ext4_extl2_buf[0])
            l2_ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](l2p + 2))
            l2_mx:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](l2p + 4))
            if l2_ent <= l2_mx:
                j: uint16 = 0
                while j < l2_ent:
                    l2ei: uint64 = l2p + 12 + cast[uint64](j) * 12
                    l1_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](l2ei + 4))
                    l1_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](l2ei + 8))
                    l1_blk: uint64 = (cast[uint64](l1_hi) << 32) \
                                   | cast[uint64](l1_lo)
                    if _ext4_read_block(l1_blk, &ext4_extidx_buf[0]) == 0:
                        c: uint64 = _ext4_idxnode_block_count(
                            cast[uint64](&ext4_extidx_buf[0]))
                        if c > total:
                            total = c
                    j = j + 1
        i = i + 1
    return total


# Scratch block for an on-disk extent LEAF node (eh_depth==0 header +
# its extent records, living in its own physical fs block at depth 1).
# Kept distinct from ext4_blk_buf (data RMW), ext4_ext_scratch (read
# index walk), and ext4_bitmap_buf (alloc/free) so an append's leaf
# read-modify-write never collides with those concurrent uses. 4 KiB
# covers both 1 KiB and 4 KiB fs blocks.
ext4_extleaf_buf: Array[4096, uint8]

# Scratch block for an INTERMEDIATE on-disk index node (eh_depth==1
# header + its index records) in a depth-2 tree. A depth-2 append/trim
# holds the inode root, ONE intermediate index block, AND one leaf block
# live at the same time, so this must be distinct from both
# ext4_extleaf_buf (the leaf) and ext4_ext_scratch (the read walk). 4 KiB
# covers both 1 KiB and 4 KiB fs blocks.
ext4_extidx_buf: Array[4096, uint8]

# Scratch block for the TOP intermediate on-disk index node (eh_depth==2)
# in a depth-3 tree. A depth-3 append/trim holds the inode root, ONE L2
# index block (this buffer), ONE L1 index block (ext4_extidx_buf), AND one
# leaf block (ext4_extleaf_buf) live simultaneously, so all three on-disk
# node buffers must be distinct. 4 KiB covers both 1 KiB and 4 KiB blocks.
ext4_extl2_buf: Array[4096, uint8]


def _ext4_leaf_block_max(blk_size: uint64) -> uint64:
    # How many 12-byte extent records fit in an on-disk leaf block:
    # (block_size - 12-byte header) / 12. Index records are the same
    # 12 bytes, so an intermediate index block has the same capacity.
    return (blk_size - 12) / 12


def _ext4_extent_append_block(inode_buf: Ptr[uint8],
                              logical_blk: uint64,
                              phys_blk: uint64) -> int32:
    # Append a one-block extent (ee_block=logical_blk, ee_len=1) to the
    # file's extent tree. If the new logical block is physically
    # contiguous with the last extent's run, that extent is lengthened
    # instead of consuming a new slot (the same coalescing
    # ext4_ext_try_to_merge does).
    #
    # Tree growth:
    #   depth 0 (inline leaf) until the inode's 4 slots fill;
    #   on overflow the 4 inline extents are MOVED into a freshly
    #   allocated data block as a depth-0 leaf, and the inode header is
    #   rewritten as a depth-1 INDEX node with one index record pointing
    #   at that leaf (eh_depth=1). Further appends land in the rightmost
    #   leaf; when THAT leaf fills, a new leaf block is allocated and a
    #   new index record added to the inode (up to 4 index records, i.e.
    #   4 leaf blocks). The leaf-block writes go through
    #   _ext4_journal_write_block so they're crash-consistent under JBD2.
    #
    # When the inode's 4 index slots fill, the tree is promoted again to
    # depth 2 (an intermediate index level), and when THOSE fill, promoted
    # to depth 3 — the tree grows its depth on demand, exactly like Linux's
    # ext4_ext_grow_indepth. Returns 0 on success, -1 only when even a
    # depth-3 tree is fully exhausted (a depth-4 tree, beyond this scope)
    # or on I/O error.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return -1
    depth: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_DEPTH_OFFSET))
    if depth == 0:
        return _ext4_extent_append_depth0(inode_buf, logical_blk, phys_blk)
    if depth == 1:
        return _ext4_extent_append_depth1(inode_buf, logical_blk, phys_blk)
    if depth == 2:
        return _ext4_extent_append_depth2(inode_buf, logical_blk, phys_blk)
    if depth == 3:
        return _ext4_extent_append_depth3(inode_buf, logical_blk, phys_blk)
    # depth >= 4 trees are not produced by our writers; reject rather
    # than corrupt a deeper tree we can't correctly rebalance. ext4 tops
    # out around depth 3-4 even for multi-TiB files, so depth 3 is the
    # practical ceiling here.
    printk0("ext4: extent append: depth>3 tree unsupported\n")
    return -1


def _ext4_extent_try_merge(rec: uint64, logical_blk: uint64,
                           phys_blk: uint64) -> int32:
    # If the 12-byte extent at `rec` ends exactly where (logical_blk,
    # phys_blk) begins (both logically and physically contiguous) and
    # has room to grow, lengthen it by one and return 1. Else return 0.
    l_block:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](rec + 0))
    l_len:      uint16 = _ext4_read_u16(cast[Ptr[uint8]](rec + 4))
    l_start_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](rec + 6))
    l_start_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](rec + 8))
    l_phys: uint64 = (cast[uint64](l_start_hi) << 32) \
                   | cast[uint64](l_start_lo)
    l_logend:  uint64 = cast[uint64](l_block) + cast[uint64](l_len)
    l_physend: uint64 = l_phys + cast[uint64](l_len)
    if l_logend == logical_blk and l_physend == phys_blk \
            and l_len < 32768:
        _ext4_write_u16(cast[Ptr[uint8]](rec + 4),
                        cast[uint16](l_len + 1))
        return 1
    return 0


def _ext4_extent_write_rec(rec: uint64, logical_blk: uint64,
                           phys_blk: uint64):
    # Write a fresh single-block leaf extent record at `rec`.
    _ext4_write_u32(cast[Ptr[uint8]](rec + 0), cast[uint32](logical_blk))
    _ext4_write_u16(cast[Ptr[uint8]](rec + 4), 1)
    _ext4_write_u16(cast[Ptr[uint8]](rec + 6),
                    cast[uint16]((phys_blk >> 32) & 0xFFFF))
    _ext4_write_u32(cast[Ptr[uint8]](rec + 8),
                    cast[uint32](phys_blk & 0xFFFFFFFF))


def _ext4_idx_write_rec(rec: uint64, ei_block: uint64, leaf_blk: uint64):
    # Write a 12-byte index record at `rec` pointing at child leaf
    # `leaf_blk`, covering logical blocks starting at `ei_block`.
    #   0x00 u32 ei_block   0x04 u32 ei_leaf_lo
    #   0x08 u16 ei_leaf_hi 0x0A u16 ei_unused
    _ext4_write_u32(cast[Ptr[uint8]](rec + 0), cast[uint32](ei_block))
    _ext4_write_u32(cast[Ptr[uint8]](rec + 4),
                    cast[uint32](leaf_blk & 0xFFFFFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](rec + 8),
                    cast[uint16]((leaf_blk >> 32) & 0xFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](rec + 10), 0)


def _ext4_extent_append_depth0(inode_buf: Ptr[uint8],
                               logical_blk: uint64,
                               phys_blk: uint64) -> int32:
    # Append into the inode's inline depth-0 leaf. On overflow, promote
    # to a depth-1 index node (move inline extents into a leaf block).
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    eh_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if entries > 0:
        last: uint64 = eh + 12 + cast[uint64](entries - 1) * 12
        if _ext4_extent_try_merge(last, logical_blk, phys_blk) != 0:
            return 0
    if entries < eh_max:
        ne: uint64 = eh + 12 + cast[uint64](entries) * 12
        _ext4_extent_write_rec(ne, logical_blk, phys_blk)
        _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                        cast[uint16](entries + 1))
        return 0
    # Inline leaf full → promote to depth 1.
    if _ext4_extent_promote_to_depth1(inode_buf) != 0:
        return -1
    # Re-dispatch the append; the inode is now a depth-1 index node.
    return _ext4_extent_append_depth1(inode_buf, logical_blk, phys_blk)


def _ext4_extent_promote_to_depth1(inode_buf: Ptr[uint8]) -> int32:
    # Convert a full inline depth-0 leaf into a depth-1 index node:
    #   1. allocate a fresh data block to hold the moved leaf;
    #   2. build a leaf header + copy the inode's 4 extents into it;
    #   3. journal-write that leaf block;
    #   4. rewrite the inode's i_block as an index header with one index
    #      record (ei_block = first leaf extent's logical block) pointing
    #      at the new leaf; eh_depth=1, eh_entries=1, eh_max=4.
    # The inode itself is flushed by the caller. Returns 0 / -1.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    leaf_blk: uint64 = ext4_alloc_block()
    if leaf_blk == 0:
        printk0("ext4: promote depth1 FAIL (alloc leaf)\n")
        return -1
    # Build the leaf node in ext4_extleaf_buf.
    lp: uint64 = cast[uint64](&ext4_extleaf_buf[0])
    _ext4_zero(&ext4_extleaf_buf[0], ext4_block_size)
    leaf_max: uint64 = _ext4_leaf_block_max(ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 2), entries)         # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](lp + 4),
                    cast[uint16](leaf_max))                    # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](lp + 6), 0)               # eh_depth=0
    _ext4_write_u32(cast[Ptr[uint8]](lp + 8), 0)               # eh_generation
    # Copy the 12*entries extent bytes from the inode into the leaf.
    memcpy(cast[Ptr[uint8]](lp + 12),
           cast[Ptr[uint8]](eh + 12),
           cast[uint64](entries) * 12)
    # The first leaf extent's logical block is the index record key.
    first_lblk: uint32 = _ext4_read_u32(cast[Ptr[uint8]](eh + 12))
    if _ext4_journal_write_block(leaf_blk, &ext4_extleaf_buf[0]) != 0:
        ext4_free_block(leaf_blk)
        printk0("ext4: promote depth1 FAIL (write leaf)\n")
        return -1
    # Rewrite the inode i_block as a depth-1 index node.
    _ext4_zero(cast[Ptr[uint8]](eh), 60)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)               # eh_max (4 idx)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 1)               # eh_depth=1
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)               # eh_generation
    _ext4_idx_write_rec(eh + 12, cast[uint64](first_lblk), leaf_blk)
    return 0


def _ext4_extent_append_depth1(inode_buf: Ptr[uint8],
                               logical_blk: uint64,
                               phys_blk: uint64) -> int32:
    # Append into a depth-1 tree. Target the rightmost (last) index
    # record's leaf block; coalesce / append a record there. If that
    # leaf is full, allocate a new leaf block and add a new index record
    # to the inode (capacity = eh_max index records).
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    idx_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    idx_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if idx_entries == 0:
        return -1
    # Rightmost index record → its leaf block.
    last_idx: uint64 = eh + 12 + cast[uint64](idx_entries - 1) * 12
    leaf_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](last_idx + 4))
    leaf_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](last_idx + 8))
    leaf_blk: uint64 = (cast[uint64](leaf_hi) << 32) \
                     | cast[uint64](leaf_lo)
    if _ext4_read_block(leaf_blk, &ext4_extleaf_buf[0]) != 0:
        return -1
    lp: uint64 = cast[uint64](&ext4_extleaf_buf[0])
    if _ext4_read_u16(cast[Ptr[uint8]](lp + 0)) != EXT4_EXTENT_MAGIC:
        return -1
    leaf_ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](lp + 2))
    leaf_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](lp + 4))
    if leaf_ent > leaf_max:
        return -1
    # Try to coalesce with the leaf's last extent.
    if leaf_ent > 0:
        llast: uint64 = lp + 12 + cast[uint64](leaf_ent - 1) * 12
        if _ext4_extent_try_merge(llast, logical_blk, phys_blk) != 0:
            return _ext4_journal_write_block(leaf_blk, &ext4_extleaf_buf[0])
    if leaf_ent < leaf_max:
        nrec: uint64 = lp + 12 + cast[uint64](leaf_ent) * 12
        _ext4_extent_write_rec(nrec, logical_blk, phys_blk)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 2),
                        cast[uint16](leaf_ent + 1))
        return _ext4_journal_write_block(leaf_blk, &ext4_extleaf_buf[0])
    # Rightmost leaf is full → need a new leaf under a new index record.
    # If the inode's index slots are ALSO full, promote depth 1 → 2 (move
    # the 4 inode index records into a fresh intermediate index block) and
    # re-dispatch the append into the now-deeper tree.
    if idx_entries >= idx_max:
        if _ext4_extent_promote_to_depth2(inode_buf) != 0:
            return -1
        return _ext4_extent_append_depth2(inode_buf, logical_blk, phys_blk)
    new_leaf: uint64 = ext4_alloc_block()
    if new_leaf == 0:
        printk0("ext4: extent append FAIL (alloc new leaf)\n")
        return -1
    nlmax: uint64 = _ext4_leaf_block_max(ext4_block_size)
    _ext4_zero(&ext4_extleaf_buf[0], ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](lp + 4),
                    cast[uint16](nlmax))                       # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](lp + 6), 0)               # eh_depth=0
    _ext4_write_u32(cast[Ptr[uint8]](lp + 8), 0)               # eh_generation
    _ext4_extent_write_rec(lp + 12, logical_blk, phys_blk)
    if _ext4_journal_write_block(new_leaf, &ext4_extleaf_buf[0]) != 0:
        ext4_free_block(new_leaf)
        return -1
    # Add the new index record to the inode (covers logical_blk onward).
    nidx: uint64 = eh + 12 + cast[uint64](idx_entries) * 12
    _ext4_idx_write_rec(nidx, logical_blk, new_leaf)
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](idx_entries + 1))
    return 0


def _ext4_extent_promote_to_depth2(inode_buf: Ptr[uint8]) -> int32:
    # Convert a full depth-1 index node (inode holds eh_max index records,
    # each pointing at a leaf block) into a depth-2 tree:
    #   1. allocate a fresh data block for an INTERMEDIATE index node;
    #   2. copy the inode's index records (eh_depth==1, pointing at the
    #      leaf blocks) into that block; set its header eh_depth=1;
    #   3. journal-write the intermediate index block;
    #   4. rewrite the inode's i_block as a depth-2 index header with ONE
    #      index record (ei_block = first child's key) pointing at the new
    #      intermediate block; eh_depth=2, eh_entries=1, eh_max=4.
    # The inode itself is flushed by the caller. Returns 0 / -1.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    idx_blk: uint64 = ext4_alloc_block()
    if idx_blk == 0:
        printk0("ext4: promote depth2 FAIL (alloc index)\n")
        return -1
    # Build the intermediate index node in ext4_extidx_buf. Its records
    # are the inode's existing index records, so it sits at eh_depth=1
    # (its children are leaf blocks).
    ip: uint64 = cast[uint64](&ext4_extidx_buf[0])
    _ext4_zero(&ext4_extidx_buf[0], ext4_block_size)
    idx_max: uint64 = _ext4_leaf_block_max(ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](ip + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](ip + 2), entries)         # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](ip + 4),
                    cast[uint16](idx_max))                     # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](ip + 6), 1)               # eh_depth=1
    _ext4_write_u32(cast[Ptr[uint8]](ip + 8), 0)               # eh_generation
    # Copy the 12*entries index bytes from the inode into the block.
    memcpy(cast[Ptr[uint8]](ip + 12),
           cast[Ptr[uint8]](eh + 12),
           cast[uint64](entries) * 12)
    # The first child's key (ei_block of the inode's first record).
    first_key: uint32 = _ext4_read_u32(cast[Ptr[uint8]](eh + 12))
    if _ext4_journal_write_block(idx_blk, &ext4_extidx_buf[0]) != 0:
        ext4_free_block(idx_blk)
        printk0("ext4: promote depth2 FAIL (write index)\n")
        return -1
    # Rewrite the inode i_block as a depth-2 index node.
    _ext4_zero(cast[Ptr[uint8]](eh), 60)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)               # eh_max (4 idx)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 2)               # eh_depth=2
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)               # eh_generation
    _ext4_idx_write_rec(eh + 12, cast[uint64](first_key), idx_blk)
    return 0


def _ext4_extent_append_depth2(inode_buf: Ptr[uint8],
                               logical_blk: uint64,
                               phys_blk: uint64) -> int32:
    # Append into a depth-2 tree: inode index records → intermediate
    # index blocks → leaf blocks. Target the RIGHTMOST path
    # (inode-idx[last] → intermediate-idx[last] → leaf) and coalesce /
    # append a one-block extent there. Growth, innermost-first:
    #   * leaf full but intermediate index block has room → allocate a
    #     new leaf, add a child index record to the intermediate block;
    #   * leaf full AND intermediate index block full but the inode has
    #     a free index slot → allocate a new intermediate index block +
    #     a new leaf, add an inode index record pointing at it;
    #   * everything full (inode's eh_max intermediate blocks each full
    #     of full leaves) → -1 (depth-3, beyond scope).
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    in_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    in_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if in_entries == 0 or in_entries > in_max:
        return -1
    # Rightmost inode index record → its intermediate index block.
    last_in: uint64 = eh + 12 + cast[uint64](in_entries - 1) * 12
    idx_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](last_in + 4))
    idx_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](last_in + 8))
    idx_blk: uint64 = (cast[uint64](idx_hi) << 32) | cast[uint64](idx_lo)
    if _ext4_read_block(idx_blk, &ext4_extidx_buf[0]) != 0:
        return -1
    ip: uint64 = cast[uint64](&ext4_extidx_buf[0])
    if _ext4_read_u16(cast[Ptr[uint8]](ip + 0)) != EXT4_EXTENT_MAGIC:
        return -1
    ix_entries: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ip + 2))
    ix_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ip + 4))
    if ix_entries == 0 or ix_entries > ix_max:
        return -1
    # Rightmost child index record → its leaf block.
    last_ix: uint64 = ip + 12 + cast[uint64](ix_entries - 1) * 12
    leaf_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](last_ix + 4))
    leaf_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](last_ix + 8))
    leaf_blk: uint64 = (cast[uint64](leaf_hi) << 32) | cast[uint64](leaf_lo)
    if _ext4_read_block(leaf_blk, &ext4_extleaf_buf[0]) != 0:
        return -1
    lp: uint64 = cast[uint64](&ext4_extleaf_buf[0])
    if _ext4_read_u16(cast[Ptr[uint8]](lp + 0)) != EXT4_EXTENT_MAGIC:
        return -1
    leaf_ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](lp + 2))
    leaf_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](lp + 4))
    if leaf_ent > leaf_max:
        return -1
    # Try to coalesce with the rightmost leaf's last extent.
    if leaf_ent > 0:
        llast: uint64 = lp + 12 + cast[uint64](leaf_ent - 1) * 12
        if _ext4_extent_try_merge(llast, logical_blk, phys_blk) != 0:
            return _ext4_journal_write_block(leaf_blk, &ext4_extleaf_buf[0])
    if leaf_ent < leaf_max:
        nrec: uint64 = lp + 12 + cast[uint64](leaf_ent) * 12
        _ext4_extent_write_rec(nrec, logical_blk, phys_blk)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 2),
                        cast[uint16](leaf_ent + 1))
        return _ext4_journal_write_block(leaf_blk, &ext4_extleaf_buf[0])
    # Rightmost leaf is full → need a new leaf. If the intermediate index
    # block has a free slot, add a child index record there. ext4_extidx_buf
    # still holds the intermediate block (the leaf RMW used a separate
    # buffer), so we can write back into it.
    nlmax: uint64 = _ext4_leaf_block_max(ext4_block_size)
    if ix_entries < ix_max:
        new_leaf: uint64 = ext4_alloc_block()
        if new_leaf == 0:
            printk0("ext4: depth2 append FAIL (alloc leaf)\n")
            return -1
        _ext4_zero(&ext4_extleaf_buf[0], ext4_block_size)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 2), 1)           # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](lp + 4),
                        cast[uint16](nlmax))                   # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](lp + 6), 0)           # eh_depth=0
        _ext4_write_u32(cast[Ptr[uint8]](lp + 8), 0)           # eh_generation
        _ext4_extent_write_rec(lp + 12, logical_blk, phys_blk)
        if _ext4_journal_write_block(new_leaf, &ext4_extleaf_buf[0]) != 0:
            ext4_free_block(new_leaf)
            return -1
        # Add the child index record to the intermediate block.
        nidx: uint64 = ip + 12 + cast[uint64](ix_entries) * 12
        _ext4_idx_write_rec(nidx, logical_blk, new_leaf)
        _ext4_write_u16(cast[Ptr[uint8]](ip + 2),
                        cast[uint16](ix_entries + 1))
        return _ext4_journal_write_block(idx_blk, &ext4_extidx_buf[0])
    # Intermediate index block is ALSO full → need a new intermediate
    # block under a new inode index record. If the inode is full too,
    # grow the tree one level: promote depth 2 → depth 3 (move the inode's
    # 4 index records into a fresh L2 intermediate block) and re-dispatch
    # the append into the now-deeper tree.
    if in_entries >= in_max:
        if _ext4_extent_promote_to_depth3(inode_buf) != 0:
            return -1
        return _ext4_extent_append_depth3(inode_buf, logical_blk, phys_blk)
    idx_max_recs: uint64 = _ext4_leaf_block_max(ext4_block_size)
    new_idx: uint64 = ext4_alloc_block()
    if new_idx == 0:
        printk0("ext4: depth2 append FAIL (alloc index)\n")
        return -1
    new_leaf2: uint64 = ext4_alloc_block()
    if new_leaf2 == 0:
        ext4_free_block(new_idx)
        printk0("ext4: depth2 append FAIL (alloc leaf2)\n")
        return -1
    # Build the new leaf (one extent) in ext4_extleaf_buf.
    _ext4_zero(&ext4_extleaf_buf[0], ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](lp + 4),
                    cast[uint16](nlmax))                       # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](lp + 6), 0)               # eh_depth=0
    _ext4_write_u32(cast[Ptr[uint8]](lp + 8), 0)               # eh_generation
    _ext4_extent_write_rec(lp + 12, logical_blk, phys_blk)
    if _ext4_journal_write_block(new_leaf2, &ext4_extleaf_buf[0]) != 0:
        ext4_free_block(new_leaf2)
        ext4_free_block(new_idx)
        return -1
    # Build the new intermediate index block (one child index record)
    # in ext4_extidx_buf — overwriting the now-irrelevant rightmost
    # intermediate block we read (we're done with it).
    _ext4_zero(&ext4_extidx_buf[0], ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](ip + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](ip + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](ip + 4),
                    cast[uint16](idx_max_recs))                # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](ip + 6), 1)               # eh_depth=1
    _ext4_write_u32(cast[Ptr[uint8]](ip + 8), 0)               # eh_generation
    _ext4_idx_write_rec(ip + 12, logical_blk, new_leaf2)
    if _ext4_journal_write_block(new_idx, &ext4_extidx_buf[0]) != 0:
        ext4_free_block(new_leaf2)
        ext4_free_block(new_idx)
        return -1
    # Add the new inode index record (covers logical_blk onward).
    nin: uint64 = eh + 12 + cast[uint64](in_entries) * 12
    _ext4_idx_write_rec(nin, logical_blk, new_idx)
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](in_entries + 1))
    return 0


def _ext4_extent_promote_to_depth3(inode_buf: Ptr[uint8]) -> int32:
    # Convert a full depth-2 index node (inode holds eh_max index records,
    # each pointing at an L1 intermediate index block over leaf blocks)
    # into a depth-3 tree — the standard ext4 "grow the tree" move:
    #   1. allocate a fresh data block for an L2 intermediate index node;
    #   2. copy the inode's index records (eh_depth==2, pointing at the L1
    #      blocks) into that block; set its header eh_depth=2;
    #   3. journal-write the L2 index block;
    #   4. rewrite the inode's i_block as a depth-3 index header with ONE
    #      index record (ei_block = first child's key) pointing at the new
    #      L2 block; eh_depth=3, eh_entries=1, eh_max=4.
    # The inode itself is flushed by the caller. Returns 0 / -1.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    l2_blk: uint64 = ext4_alloc_block()
    if l2_blk == 0:
        printk0("ext4: promote depth3 FAIL (alloc L2 index)\n")
        return -1
    # Build the L2 intermediate index node in ext4_extl2_buf. Its records
    # are the inode's existing depth-2 index records, so it sits at
    # eh_depth=2 (its children are L1 intermediate index blocks).
    l2p: uint64 = cast[uint64](&ext4_extl2_buf[0])
    _ext4_zero(&ext4_extl2_buf[0], ext4_block_size)
    idx_max: uint64 = _ext4_leaf_block_max(ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 2), entries)        # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 4),
                    cast[uint16](idx_max))                     # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 6), 2)              # eh_depth=2
    _ext4_write_u32(cast[Ptr[uint8]](l2p + 8), 0)              # eh_generation
    # Copy the 12*entries index bytes from the inode into the L2 block.
    memcpy(cast[Ptr[uint8]](l2p + 12),
           cast[Ptr[uint8]](eh + 12),
           cast[uint64](entries) * 12)
    # The first child's key (ei_block of the inode's first record).
    first_key: uint32 = _ext4_read_u32(cast[Ptr[uint8]](eh + 12))
    if _ext4_journal_write_block(l2_blk, &ext4_extl2_buf[0]) != 0:
        ext4_free_block(l2_blk)
        printk0("ext4: promote depth3 FAIL (write L2 index)\n")
        return -1
    # Rewrite the inode i_block as a depth-3 index node.
    _ext4_zero(cast[Ptr[uint8]](eh), 60)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)               # eh_max (4 idx)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 3)               # eh_depth=3
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)               # eh_generation
    _ext4_idx_write_rec(eh + 12, cast[uint64](first_key), l2_blk)
    return 0


def _ext4_extent_append_depth3(inode_buf: Ptr[uint8],
                               logical_blk: uint64,
                               phys_blk: uint64) -> int32:
    # Append into a depth-3 tree: inode index records → L2 intermediate
    # index blocks → L1 intermediate index blocks → leaf blocks. Target
    # the RIGHTMOST path (inode-idx[last] → L2-idx[last] → L1-idx[last] →
    # leaf) and coalesce / append a one-block extent there. Growth,
    # innermost-first (mirrors the depth-2 path, one level deeper):
    #   * leaf full but L1 block has room  → new leaf + L1 child record;
    #   * L1 block full but L2 block has room → new L1 block + new leaf +
    #     L2 child record;
    #   * L2 block full but inode has a free slot → new L2 + new L1 + new
    #     leaf + inode index record;
    #   * everything full → -1 (depth-4, beyond scope).
    # Holds three on-disk node buffers live: ext4_extl2_buf (L2),
    # ext4_extidx_buf (L1), ext4_extleaf_buf (leaf).
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    in_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    in_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if in_entries == 0 or in_entries > in_max:
        return -1
    # Rightmost inode index record → its L2 intermediate index block.
    last_in: uint64 = eh + 12 + cast[uint64](in_entries - 1) * 12
    l2_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](last_in + 4))
    l2_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](last_in + 8))
    l2_blk: uint64 = (cast[uint64](l2_hi) << 32) | cast[uint64](l2_lo)
    if _ext4_read_block(l2_blk, &ext4_extl2_buf[0]) != 0:
        return -1
    l2p: uint64 = cast[uint64](&ext4_extl2_buf[0])
    if _ext4_read_u16(cast[Ptr[uint8]](l2p + 0)) != EXT4_EXTENT_MAGIC:
        return -1
    l2_entries: uint16 = _ext4_read_u16(cast[Ptr[uint8]](l2p + 2))
    l2_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](l2p + 4))
    if l2_entries == 0 or l2_entries > l2_max:
        return -1
    # Rightmost L2 child record → its L1 intermediate index block.
    last_l2: uint64 = l2p + 12 + cast[uint64](l2_entries - 1) * 12
    l1_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](last_l2 + 4))
    l1_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](last_l2 + 8))
    l1_blk: uint64 = (cast[uint64](l1_hi) << 32) | cast[uint64](l1_lo)
    if _ext4_read_block(l1_blk, &ext4_extidx_buf[0]) != 0:
        return -1
    ip: uint64 = cast[uint64](&ext4_extidx_buf[0])
    if _ext4_read_u16(cast[Ptr[uint8]](ip + 0)) != EXT4_EXTENT_MAGIC:
        return -1
    ix_entries: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ip + 2))
    ix_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ip + 4))
    if ix_entries == 0 or ix_entries > ix_max:
        return -1
    # Rightmost L1 child record → its leaf block.
    last_ix: uint64 = ip + 12 + cast[uint64](ix_entries - 1) * 12
    leaf_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](last_ix + 4))
    leaf_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](last_ix + 8))
    leaf_blk: uint64 = (cast[uint64](leaf_hi) << 32) | cast[uint64](leaf_lo)
    if _ext4_read_block(leaf_blk, &ext4_extleaf_buf[0]) != 0:
        return -1
    lp: uint64 = cast[uint64](&ext4_extleaf_buf[0])
    if _ext4_read_u16(cast[Ptr[uint8]](lp + 0)) != EXT4_EXTENT_MAGIC:
        return -1
    leaf_ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](lp + 2))
    leaf_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](lp + 4))
    if leaf_ent > leaf_max:
        return -1
    # Try to coalesce with the rightmost leaf's last extent.
    if leaf_ent > 0:
        llast: uint64 = lp + 12 + cast[uint64](leaf_ent - 1) * 12
        if _ext4_extent_try_merge(llast, logical_blk, phys_blk) != 0:
            return _ext4_journal_write_block(leaf_blk, &ext4_extleaf_buf[0])
    if leaf_ent < leaf_max:
        nrec: uint64 = lp + 12 + cast[uint64](leaf_ent) * 12
        _ext4_extent_write_rec(nrec, logical_blk, phys_blk)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 2),
                        cast[uint16](leaf_ent + 1))
        return _ext4_journal_write_block(leaf_blk, &ext4_extleaf_buf[0])
    # Rightmost leaf is full → need a new leaf. If the L1 index block has a
    # free slot, add a child index record there. ext4_extidx_buf still
    # holds the L1 block (the leaf RMW used a separate buffer).
    nlmax: uint64 = _ext4_leaf_block_max(ext4_block_size)
    if ix_entries < ix_max:
        new_leaf: uint64 = ext4_alloc_block()
        if new_leaf == 0:
            printk0("ext4: depth3 append FAIL (alloc leaf)\n")
            return -1
        _ext4_zero(&ext4_extleaf_buf[0], ext4_block_size)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 2), 1)           # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](lp + 4),
                        cast[uint16](nlmax))                   # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](lp + 6), 0)           # eh_depth=0
        _ext4_write_u32(cast[Ptr[uint8]](lp + 8), 0)           # eh_generation
        _ext4_extent_write_rec(lp + 12, logical_blk, phys_blk)
        if _ext4_journal_write_block(new_leaf, &ext4_extleaf_buf[0]) != 0:
            ext4_free_block(new_leaf)
            return -1
        # Add the child index record to the L1 index block.
        nidx: uint64 = ip + 12 + cast[uint64](ix_entries) * 12
        _ext4_idx_write_rec(nidx, logical_blk, new_leaf)
        _ext4_write_u16(cast[Ptr[uint8]](ip + 2),
                        cast[uint16](ix_entries + 1))
        return _ext4_journal_write_block(l1_blk, &ext4_extidx_buf[0])
    # L1 index block is ALSO full → need a new L1 block (with a new leaf)
    # under a new L2 child record. If the L2 block has a free slot, add it
    # there. ext4_extl2_buf still holds the L2 block.
    idx_max_recs: uint64 = _ext4_leaf_block_max(ext4_block_size)
    if l2_entries < l2_max:
        new_l1: uint64 = ext4_alloc_block()
        if new_l1 == 0:
            printk0("ext4: depth3 append FAIL (alloc L1)\n")
            return -1
        new_leafa: uint64 = ext4_alloc_block()
        if new_leafa == 0:
            ext4_free_block(new_l1)
            printk0("ext4: depth3 append FAIL (alloc leaf under L1)\n")
            return -1
        # New leaf (one extent) in ext4_extleaf_buf.
        _ext4_zero(&ext4_extleaf_buf[0], ext4_block_size)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](lp + 2), 1)           # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](lp + 4),
                        cast[uint16](nlmax))                   # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](lp + 6), 0)           # eh_depth=0
        _ext4_write_u32(cast[Ptr[uint8]](lp + 8), 0)           # eh_generation
        _ext4_extent_write_rec(lp + 12, logical_blk, phys_blk)
        if _ext4_journal_write_block(new_leafa, &ext4_extleaf_buf[0]) != 0:
            ext4_free_block(new_leafa)
            ext4_free_block(new_l1)
            return -1
        # New L1 index block (one child) in ext4_extidx_buf — overwriting
        # the rightmost L1 block we read (we're done with it).
        _ext4_zero(&ext4_extidx_buf[0], ext4_block_size)
        _ext4_write_u16(cast[Ptr[uint8]](ip + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](ip + 2), 1)           # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](ip + 4),
                        cast[uint16](idx_max_recs))            # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](ip + 6), 1)           # eh_depth=1
        _ext4_write_u32(cast[Ptr[uint8]](ip + 8), 0)           # eh_generation
        _ext4_idx_write_rec(ip + 12, logical_blk, new_leafa)
        if _ext4_journal_write_block(new_l1, &ext4_extidx_buf[0]) != 0:
            ext4_free_block(new_leafa)
            ext4_free_block(new_l1)
            return -1
        # Add the child index record to the L2 block.
        nl2: uint64 = l2p + 12 + cast[uint64](l2_entries) * 12
        _ext4_idx_write_rec(nl2, logical_blk, new_l1)
        _ext4_write_u16(cast[Ptr[uint8]](l2p + 2),
                        cast[uint16](l2_entries + 1))
        return _ext4_journal_write_block(l2_blk, &ext4_extl2_buf[0])
    # L2 block is ALSO full → need a new L2 block (with a new L1 + leaf)
    # under a new inode index record. If the inode is full too, we
    # genuinely can't grow further (would need depth 4).
    if in_entries >= in_max:
        printk0("ext4: extent index full (depth-4 tree unsupported)\n")
        return -1
    new_l2: uint64 = ext4_alloc_block()
    if new_l2 == 0:
        printk0("ext4: depth3 append FAIL (alloc L2)\n")
        return -1
    new_l1b: uint64 = ext4_alloc_block()
    if new_l1b == 0:
        ext4_free_block(new_l2)
        printk0("ext4: depth3 append FAIL (alloc L1 under L2)\n")
        return -1
    new_leafb: uint64 = ext4_alloc_block()
    if new_leafb == 0:
        ext4_free_block(new_l1b)
        ext4_free_block(new_l2)
        printk0("ext4: depth3 append FAIL (alloc leaf under new L2)\n")
        return -1
    # New leaf (one extent) in ext4_extleaf_buf.
    _ext4_zero(&ext4_extleaf_buf[0], ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](lp + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](lp + 4),
                    cast[uint16](nlmax))                       # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](lp + 6), 0)               # eh_depth=0
    _ext4_write_u32(cast[Ptr[uint8]](lp + 8), 0)               # eh_generation
    _ext4_extent_write_rec(lp + 12, logical_blk, phys_blk)
    if _ext4_journal_write_block(new_leafb, &ext4_extleaf_buf[0]) != 0:
        ext4_free_block(new_leafb)
        ext4_free_block(new_l1b)
        ext4_free_block(new_l2)
        return -1
    # New L1 index block (one child → the new leaf) in ext4_extidx_buf.
    _ext4_zero(&ext4_extidx_buf[0], ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](ip + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](ip + 2), 1)               # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](ip + 4),
                    cast[uint16](idx_max_recs))                # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](ip + 6), 1)               # eh_depth=1
    _ext4_write_u32(cast[Ptr[uint8]](ip + 8), 0)               # eh_generation
    _ext4_idx_write_rec(ip + 12, logical_blk, new_leafb)
    if _ext4_journal_write_block(new_l1b, &ext4_extidx_buf[0]) != 0:
        ext4_free_block(new_leafb)
        ext4_free_block(new_l1b)
        ext4_free_block(new_l2)
        return -1
    # New L2 index block (one child → the new L1) in ext4_extl2_buf —
    # overwriting the now-irrelevant rightmost L2 block we read.
    _ext4_zero(&ext4_extl2_buf[0], ext4_block_size)
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 2), 1)              # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 4),
                    cast[uint16](idx_max_recs))                # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](l2p + 6), 2)              # eh_depth=2
    _ext4_write_u32(cast[Ptr[uint8]](l2p + 8), 0)              # eh_generation
    _ext4_idx_write_rec(l2p + 12, logical_blk, new_l1b)
    if _ext4_journal_write_block(new_l2, &ext4_extl2_buf[0]) != 0:
        ext4_free_block(new_leafb)
        ext4_free_block(new_l1b)
        ext4_free_block(new_l2)
        return -1
    # Add the new inode index record (covers logical_blk onward).
    nin2: uint64 = eh + 12 + cast[uint64](in_entries) * 12
    _ext4_idx_write_rec(nin2, logical_blk, new_l2)
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](in_entries + 1))
    return 0


def _ext4_leaf_trim_to(eh: uint64, keep_blocks: uint64) -> int32:
    # Trim a single depth-0 leaf header at `eh` to logical block
    # `keep_blocks`: free every data block at logical index >=
    # keep_blocks and compact the surviving extents in place. Works on
    # both the inode's inline leaf and an on-disk leaf-block header.
    # Returns the surviving extent count (>= 0).
    n: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    surviving: int32 = 0
    i: uint16 = 0
    while i < n:
        ee: uint64 = eh + 12 + cast[uint64](i) * 12
        ee_block:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 0))
        ee_len:      uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 4))
        ee_start_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ee + 6))
        ee_start_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ee + 8))
        eb:    uint64 = cast[uint64](ee_block)
        elen:  uint64 = cast[uint64](ee_len)
        ephys: uint64 = (cast[uint64](ee_start_hi) << 32) \
                      | cast[uint64](ee_start_lo)
        if eb >= keep_blocks:
            # Whole extent is past the cut — free every block in it.
            k: uint64 = 0
            while k < elen:
                ext4_free_block(ephys + k)
                k = k + 1
        elif eb + elen > keep_blocks:
            # Extent straddles the cut — keep the head, free the tail.
            keep_len: uint64 = keep_blocks - eb
            j: uint64 = keep_len
            while j < elen:
                ext4_free_block(ephys + j)
                j = j + 1
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            _ext4_write_u32(cast[Ptr[uint8]](sv + 0),
                            cast[uint32](eb))
            _ext4_write_u16(cast[Ptr[uint8]](sv + 4),
                            cast[uint16](keep_len))
            _ext4_write_u16(cast[Ptr[uint8]](sv + 6),
                            cast[uint16]((ephys >> 32) & 0xFFFF))
            _ext4_write_u32(cast[Ptr[uint8]](sv + 8),
                            cast[uint32](ephys & 0xFFFFFFFF))
            surviving = surviving + 1
        else:
            # Extent is entirely before the cut — copy it down to the
            # next surviving slot (compaction; no-op when i == surviving).
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            if sv != ee:
                _ext4_write_u32(cast[Ptr[uint8]](sv + 0), ee_block)
                _ext4_write_u16(cast[Ptr[uint8]](sv + 4), ee_len)
                _ext4_write_u16(cast[Ptr[uint8]](sv + 6), ee_start_hi)
                _ext4_write_u32(cast[Ptr[uint8]](sv + 8), ee_start_lo)
            surviving = surviving + 1
        i = i + 1
    # Zero the dropped slots so a stale extent never gets walked.
    z: int32 = surviving
    while z < cast[int32](n):
        zz: uint64 = eh + 12 + cast[uint64](z) * 12
        _ext4_zero(cast[Ptr[uint8]](zz), 12)
        z = z + 1
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](surviving))
    return surviving


def _ext4_extent_trim_to(inode_buf: Ptr[uint8],
                         keep_blocks: uint64) -> int32:
    # Drop file data past logical block `keep_blocks`: free every
    # physical block at logical index >= keep_blocks and rewrite the
    # extent tree so only the first `keep_blocks` logical blocks survive.
    # Handles both the inode's inline depth-0 leaf AND a depth-1 index
    # tree. For depth 1: each leaf block is trimmed; a leaf that ends up
    # entirely past the cut is freed and its index record dropped. When
    # the trim collapses the tree to a single (or zero) leaf, the inode
    # is folded back to an inline depth-0 leaf so small files don't keep
    # an index level around. Returns 0 on success, -1 on a malformed /
    # too-deep inode.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    magic: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 0))
    if magic != EXT4_EXTENT_MAGIC:
        return -1
    depth: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_DEPTH_OFFSET))
    if depth == 0:
        _ext4_leaf_trim_to(eh, keep_blocks)
        return 0
    if depth == 1:
        return _ext4_extent_trim_depth1(inode_buf, keep_blocks)
    if depth == 2:
        return _ext4_extent_trim_depth2(inode_buf, keep_blocks)
    if depth == 3:
        return _ext4_extent_trim_depth3(inode_buf, keep_blocks)
    printk0("ext4: trim: depth>3 tree unsupported\n")
    return -1


def _ext4_index_node_trim_leaves(eh: uint64,
                                 keep_blocks: uint64) -> int32:
    # Trim an INDEX node header at `eh` whose records point at depth-0
    # LEAF blocks. For each index record (left to right):
    #   * read its leaf block into ext4_extleaf_buf;
    #   * trim it via _ext4_leaf_trim_to;
    #   * if the leaf still holds extents, journal-write it back, re-key
    #     and keep the index record (compacting index slots down);
    #   * if the leaf is now empty, free the leaf block, drop the record.
    # Updates eh_entries and zeroes dropped slots. Returns the surviving
    # index-record count, or -1 on a malformed node / I/O error. The
    # caller owns the buffer `eh` lives in and decides whether/how to
    # fold or persist the node. NOTE: this reads leaf children into
    # ext4_extleaf_buf, so `eh` must live in a DIFFERENT buffer (the
    # inode i_block, or ext4_extidx_buf for an intermediate node).
    idx_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    idx_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if idx_entries > idx_max:
        return -1
    surviving: int32 = 0
    i: uint16 = 0
    while i < idx_entries:
        ei: uint64 = eh + 12 + cast[uint64](i) * 12
        leaf_lo:  uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        leaf_hi:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        leaf_blk: uint64 = (cast[uint64](leaf_hi) << 32) \
                         | cast[uint64](leaf_lo)
        if _ext4_read_block(leaf_blk, &ext4_extleaf_buf[0]) != 0:
            return -1
        lp: uint64 = cast[uint64](&ext4_extleaf_buf[0])
        if _ext4_read_u16(cast[Ptr[uint8]](lp + 0)) != EXT4_EXTENT_MAGIC:
            return -1
        rem: int32 = _ext4_leaf_trim_to(lp, keep_blocks)
        if rem > 0:
            # Leaf survives. Re-key the index record to its (possibly
            # now-higher) first logical block, write it back, and
            # compact the index slot down.
            new_key: uint32 = _ext4_read_u32(cast[Ptr[uint8]](lp + 12))
            if _ext4_journal_write_block(leaf_blk,
                                         &ext4_extleaf_buf[0]) != 0:
                return -1
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            _ext4_idx_write_rec(sv, cast[uint64](new_key), leaf_blk)
            surviving = surviving + 1
        else:
            # Leaf is empty now — free the leaf block, drop the record.
            ext4_free_block(leaf_blk)
        i = i + 1
    # Zero the dropped index slots.
    z: int32 = surviving
    while z < cast[int32](idx_entries):
        zz: uint64 = eh + 12 + cast[uint64](z) * 12
        _ext4_zero(cast[Ptr[uint8]](zz), 12)
        z = z + 1
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](surviving))
    return surviving


def _ext4_extent_trim_depth1(inode_buf: Ptr[uint8],
                             keep_blocks: uint64) -> int32:
    # Trim a depth-1 index tree. The inode's index records point at leaf
    # blocks; trim each via the shared _ext4_index_node_trim_leaves.
    # Finally, if 0 or 1 leaf survives, fold the inode back to a depth-0
    # inline leaf (copy the lone leaf's extents inline, free that leaf
    # block) so the tree only stays deep while it must.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    surviving: int32 = _ext4_index_node_trim_leaves(eh, keep_blocks)
    if surviving < 0:
        return -1
    # Fold back to a depth-0 inline leaf when the tree shrank to <= 1
    # leaf. A 0-leaf tree becomes an empty inline leaf; a 1-leaf tree
    # copies that leaf's extents inline (if they fit the 4 inline slots)
    # and frees the leaf block.
    if surviving == 0:
        _ext4_zero(cast[Ptr[uint8]](eh), 60)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)           # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)           # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)           # eh_depth=0
        return 0
    if surviving == 1:
        ei: uint64 = eh + 12
        leaf_lo:  uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        leaf_hi:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        leaf_blk: uint64 = (cast[uint64](leaf_hi) << 32) \
                         | cast[uint64](leaf_lo)
        if _ext4_read_block(leaf_blk, &ext4_extleaf_buf[0]) == 0:
            lp: uint64 = cast[uint64](&ext4_extleaf_buf[0])
            lent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](lp + 2))
            if lent <= 4:
                # Fits inline — fold it back to depth 0.
                _ext4_zero(cast[Ptr[uint8]](eh), 60)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 0),
                                EXT4_EXTENT_MAGIC)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 2), lent)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)
                memcpy(cast[Ptr[uint8]](eh + 12),
                       cast[Ptr[uint8]](lp + 12),
                       cast[uint64](lent) * 12)
                ext4_free_block(leaf_blk)
    return 0


def _ext4_extent_trim_depth2(inode_buf: Ptr[uint8],
                             keep_blocks: uint64) -> int32:
    # Trim a depth-2 index tree: inode index records → intermediate index
    # blocks → leaf blocks. For each inode index record (left to right):
    #   * read its intermediate index block into ext4_extidx_buf;
    #   * trim every leaf it points at via _ext4_index_node_trim_leaves
    #     (which frees emptied leaf blocks and drops their child records);
    #   * if any child records survive, re-key the inode index record to
    #     the intermediate block's first child key, journal-write the
    #     intermediate block back, keep + compact the inode record;
    #   * if the intermediate block ends up empty, free it and drop the
    #     inode index record.
    # Finally fold the inode back to depth 1 (or depth 0) when the tree
    # collapses to <= 1 intermediate block whose children fit the inode's
    # 4 inline index slots — so the tree only stays deep while it must.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    in_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    in_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if in_entries > in_max:
        return -1
    surviving: int32 = 0
    i: uint16 = 0
    while i < in_entries:
        ei: uint64 = eh + 12 + cast[uint64](i) * 12
        idx_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        idx_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        idx_blk: uint64 = (cast[uint64](idx_hi) << 32) \
                        | cast[uint64](idx_lo)
        if _ext4_read_block(idx_blk, &ext4_extidx_buf[0]) != 0:
            return -1
        ip: uint64 = cast[uint64](&ext4_extidx_buf[0])
        if _ext4_read_u16(cast[Ptr[uint8]](ip + 0)) != EXT4_EXTENT_MAGIC:
            return -1
        rem: int32 = _ext4_index_node_trim_leaves(ip, keep_blocks)
        if rem < 0:
            return -1
        if rem > 0:
            # Intermediate block survives. Re-key the inode index record
            # to its first child's key, write it back, compact down.
            new_key: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ip + 12))
            if _ext4_journal_write_block(idx_blk,
                                         &ext4_extidx_buf[0]) != 0:
                return -1
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            _ext4_idx_write_rec(sv, cast[uint64](new_key), idx_blk)
            surviving = surviving + 1
        else:
            # Intermediate block is empty now — free it, drop the record.
            ext4_free_block(idx_blk)
        i = i + 1
    # Zero the dropped inode index slots, update eh_entries.
    z: int32 = surviving
    while z < cast[int32](in_entries):
        zz: uint64 = eh + 12 + cast[uint64](z) * 12
        _ext4_zero(cast[Ptr[uint8]](zz), 12)
        z = z + 1
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](surviving))
    # Fold back when the tree shrank to <= 1 intermediate block.
    if surviving == 0:
        # No data left — empty inline depth-0 leaf.
        _ext4_zero(cast[Ptr[uint8]](eh), 60)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)           # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)           # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)           # eh_depth=0
        return 0
    if surviving == 1:
        ei: uint64 = eh + 12
        idx_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        idx_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        idx_blk: uint64 = (cast[uint64](idx_hi) << 32) \
                        | cast[uint64](idx_lo)
        if _ext4_read_block(idx_blk, &ext4_extidx_buf[0]) == 0:
            ip: uint64 = cast[uint64](&ext4_extidx_buf[0])
            ient: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ip + 2))
            if ient <= 4:
                # The lone intermediate block's child index records fit
                # the inode's 4 inline index slots — fold to depth 1 by
                # copying them inline and freeing the intermediate block.
                _ext4_zero(cast[Ptr[uint8]](eh), 60)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 0),
                                EXT4_EXTENT_MAGIC)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 2), ient)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 1)   # eh_depth=1
                memcpy(cast[Ptr[uint8]](eh + 12),
                       cast[Ptr[uint8]](ip + 12),
                       cast[uint64](ient) * 12)
                ext4_free_block(idx_blk)
    return 0


def _ext4_l2node_trim(eh: uint64, keep_blocks: uint64) -> int32:
    # Trim an eh_depth==2 index node header at `eh` (living in
    # ext4_extl2_buf): its records point at L1 intermediate index blocks,
    # which in turn point at leaf blocks. For each L2 record (left to
    # right):
    #   * read its L1 block into ext4_extidx_buf;
    #   * trim every leaf it points at via _ext4_index_node_trim_leaves
    #     (frees emptied leaf blocks, drops their records, uses
    #     ext4_extleaf_buf);
    #   * if any child records survive, re-key the L2 record to the L1
    #     block's first child key, journal-write the L1 block, keep +
    #     compact the L2 record;
    #   * if the L1 block ends up empty, free it and drop the L2 record.
    # Updates eh_entries on `eh` and zeroes dropped slots. Returns the
    # surviving L2-record count, or -1 on a malformed node / I/O error.
    # `eh` MUST live in ext4_extl2_buf (distinct from ext4_extidx_buf and
    # ext4_extleaf_buf, both of which this disturbs).
    l2_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    l2_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if l2_entries > l2_max:
        return -1
    surviving: int32 = 0
    i: uint16 = 0
    while i < l2_entries:
        ei: uint64 = eh + 12 + cast[uint64](i) * 12
        idx_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        idx_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        idx_blk: uint64 = (cast[uint64](idx_hi) << 32) \
                        | cast[uint64](idx_lo)
        if _ext4_read_block(idx_blk, &ext4_extidx_buf[0]) != 0:
            return -1
        ip: uint64 = cast[uint64](&ext4_extidx_buf[0])
        if _ext4_read_u16(cast[Ptr[uint8]](ip + 0)) != EXT4_EXTENT_MAGIC:
            return -1
        rem: int32 = _ext4_index_node_trim_leaves(ip, keep_blocks)
        if rem < 0:
            return -1
        if rem > 0:
            new_key: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ip + 12))
            if _ext4_journal_write_block(idx_blk,
                                         &ext4_extidx_buf[0]) != 0:
                return -1
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            _ext4_idx_write_rec(sv, cast[uint64](new_key), idx_blk)
            surviving = surviving + 1
        else:
            ext4_free_block(idx_blk)
        i = i + 1
    z: int32 = surviving
    while z < cast[int32](l2_entries):
        zz: uint64 = eh + 12 + cast[uint64](z) * 12
        _ext4_zero(cast[Ptr[uint8]](zz), 12)
        z = z + 1
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](surviving))
    return surviving


def _ext4_extent_trim_depth3(inode_buf: Ptr[uint8],
                             keep_blocks: uint64) -> int32:
    # Trim a depth-3 index tree: inode index records → L2 index blocks →
    # L1 index blocks → leaf blocks. For each inode index record (left to
    # right):
    #   * read its L2 block into ext4_extl2_buf;
    #   * trim it via _ext4_l2node_trim (frees emptied leaf + L1 blocks,
    #     drops their records);
    #   * if any L2 child records survive, re-key the inode index record to
    #     the L2 block's first child key, journal-write the L2 block back,
    #     keep + compact the inode record;
    #   * if the L2 block ends up empty, free it and drop the inode record.
    # Finally fold the inode back to depth 2 (or shallower via a recursive
    # trim) when the tree collapses to <= 1 L2 block whose children fit the
    # inode's 4 inline index slots.
    eh: uint64 = cast[uint64](inode_buf) + INODE_I_BLOCK_OFFSET
    in_entries: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET))
    in_max: uint16 = _ext4_read_u16(cast[Ptr[uint8]](eh + 4))
    if in_entries > in_max:
        return -1
    surviving: int32 = 0
    i: uint16 = 0
    while i < in_entries:
        ei: uint64 = eh + 12 + cast[uint64](i) * 12
        l2_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        l2_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        l2_blk: uint64 = (cast[uint64](l2_hi) << 32) | cast[uint64](l2_lo)
        if _ext4_read_block(l2_blk, &ext4_extl2_buf[0]) != 0:
            return -1
        l2p: uint64 = cast[uint64](&ext4_extl2_buf[0])
        if _ext4_read_u16(cast[Ptr[uint8]](l2p + 0)) != EXT4_EXTENT_MAGIC:
            return -1
        rem: int32 = _ext4_l2node_trim(l2p, keep_blocks)
        if rem < 0:
            return -1
        if rem > 0:
            new_key: uint32 = _ext4_read_u32(cast[Ptr[uint8]](l2p + 12))
            if _ext4_journal_write_block(l2_blk, &ext4_extl2_buf[0]) != 0:
                return -1
            sv: uint64 = eh + 12 + cast[uint64](surviving) * 12
            _ext4_idx_write_rec(sv, cast[uint64](new_key), l2_blk)
            surviving = surviving + 1
        else:
            ext4_free_block(l2_blk)
        i = i + 1
    z: int32 = surviving
    while z < cast[int32](in_entries):
        zz: uint64 = eh + 12 + cast[uint64](z) * 12
        _ext4_zero(cast[Ptr[uint8]](zz), 12)
        z = z + 1
    _ext4_write_u16(cast[Ptr[uint8]](eh + EXT4_EH_ENTRIES_OFFSET),
                    cast[uint16](surviving))
    # Fold back when the tree shrank to <= 1 L2 block whose child records
    # fit the inode's 4 inline index slots — fold to depth 2.
    if surviving == 0:
        _ext4_zero(cast[Ptr[uint8]](eh), 60)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)           # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)           # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)           # eh_depth=0
        return 0
    if surviving == 1:
        ei: uint64 = eh + 12
        l2_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](ei + 4))
        l2_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](ei + 8))
        l2_blk: uint64 = (cast[uint64](l2_hi) << 32) | cast[uint64](l2_lo)
        if _ext4_read_block(l2_blk, &ext4_extl2_buf[0]) == 0:
            l2p: uint64 = cast[uint64](&ext4_extl2_buf[0])
            l2ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](l2p + 2))
            if l2ent <= 4:
                # The lone L2 block's child index records fit the inode's
                # 4 inline index slots — fold to depth 2 by copying them
                # inline and freeing the L2 block.
                _ext4_zero(cast[Ptr[uint8]](eh), 60)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 0),
                                EXT4_EXTENT_MAGIC)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 2), l2ent)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)
                _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 2)   # eh_depth=2
                memcpy(cast[Ptr[uint8]](eh + 12),
                       cast[Ptr[uint8]](l2p + 12),
                       cast[uint64](l2ent) * 12)
                ext4_free_block(l2_blk)
    return 0


def ext4_truncate_inode(inum: uint32, new_len: uint64) -> int32:
    # Resize the file at `inum` to exactly `new_len` bytes. Backs both
    # truncate(2) (path) and ftruncate(2) (fd) — the caller resolves
    # the path / fd to an inum, this does the inode-level work.
    #
    #   shrink: free the blocks past the new length, trim the leaf,
    #           drop i_size. The first block of the surviving region
    #           keeps its bytes; the bytes past new_len within the
    #           last kept block are left as-is on disk but are
    #           unreachable (i_size hides them) — Linux does the same.
    #   grow:   allocate fresh zero-filled blocks for the new tail,
    #           append one-block extents, raise i_size. A read of the
    #           grown region returns zeros (the new blocks are zeroed
    #           before being written out).
    #
    # Returns 0 on success, -1 on I/O error / unsupported inode shape.
    if ext4_blockdev_slot < 0:
        return -1
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    if _ext4_extent_depth(&inode[0]) < 0:
        printk0("ext4: truncate: inode not a depth-0/1 extents file\n")
        return -1
    old_len: uint64 = cast[uint64](ext4_inode_size_lo(&inode[0]))
    if new_len == old_len:
        return 0
    old_blocks: uint64 = (old_len + ext4_block_size - 1) \
                       / ext4_block_size
    new_blocks: uint64 = (new_len + ext4_block_size - 1) \
                       / ext4_block_size

    if new_len < old_len:
        # Shrink. Free blocks past new_blocks, trim the leaf.
        if _ext4_extent_trim_to(&inode[0], new_blocks) != 0:
            return -1
        # If the new end falls mid-block, zero the slack inside the
        # last surviving block so a later grow can't resurrect stale
        # bytes (Linux's block_truncate_page).
        tail: uint64 = new_len % ext4_block_size
        if tail != 0 and new_blocks > 0:
            phys: uint64 = _ext4_logical_to_physical(&inode[0],
                                                     new_blocks - 1)
            if phys != 0:
                if _ext4_read_block(phys, &ext4_blk_buf[0]) == 0:
                    _ext4_zero(
                        cast[Ptr[uint8]](
                            cast[uint64](&ext4_blk_buf[0]) + tail),
                        ext4_block_size - tail)
                    if _ext4_write_block(phys,
                                         &ext4_blk_buf[0]) != 0:
                        return -1
    else:
        # Grow. Allocate + zero each new block, append an extent.
        lb: uint64 = old_blocks
        while lb < new_blocks:
            nb: uint64 = ext4_alloc_block()
            if nb == 0:
                printk0("ext4: truncate-grow: out of space\n")
                return -1
            _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
            if _ext4_write_block(nb, &ext4_blk_buf[0]) != 0:
                ext4_free_block(nb)
                return -1
            if _ext4_extent_append_block(&inode[0], lb, nb) != 0:
                ext4_free_block(nb)
                return -1
            lb = lb + 1
        # If old_len ended mid-block, that partial block already
        # carries its old bytes; the grown region beyond old_len in
        # that same block must read as zero. Zero the slack.
        tail: uint64 = old_len % ext4_block_size
        if tail != 0 and old_blocks > 0:
            phys: uint64 = _ext4_logical_to_physical(&inode[0],
                                                     old_blocks - 1)
            if phys != 0:
                if _ext4_read_block(phys, &ext4_blk_buf[0]) == 0:
                    _ext4_zero(
                        cast[Ptr[uint8]](
                            cast[uint64](&ext4_blk_buf[0]) + tail),
                        ext4_block_size - tail)
                    if _ext4_write_block(phys,
                                         &ext4_blk_buf[0]) != 0:
                        return -1

    # Commit the new size + a fresh mtime/ctime.
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                    cast[uint32](new_len))
    _ext4_stamp_mtime(&inode[0])
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    # Page-cache coherence: the inode's extent map / data changed; drop
    # every cached page so a post-truncate read never serves stale bytes
    # past the new EOF nor pre-grow garbage.
    fcache_invalidate_inode(PC_SRV_EXT4, cast[uint64](inum))
    return 0


# --- ext4 rename (M16.x §12.1) ------------------------------------
#
# Move a directory entry from one parent directory to another (or
# rename it within the same directory). Mirrors fs/ext4/namei.c
# ext4_rename at minimum scope:
#
#   1. resolve the source's parent dir + the source dirent (inum,
#      file_type),
#   2. resolve the destination's parent dir,
#   3. if the destination name already exists, unlink it first
#      (overwrite semantics — what rename(2) and `mv` expect),
#   4. insert a dirent for (dest_name -> src_inum) in the dest dir,
#   5. tombstone the source dirent.
#
# The same-directory case (dst parent == src parent) is just a
# special case of the cross-directory path and needs no extra code,
# EXCEPT that we must insert into the new name BEFORE tombstoning the
# old one so the inode is never momentarily unreferenced. We order it
# that way unconditionally.
#
# Scope: files AND directories in directories reachable from the ext4
# root. Renaming a directory inode does the same dirent move, and when
# the destination parent differs from the source parent it ALSO fixes
# up the moved dir's ".." dirent to point at the new parent and adjusts
# both parents' link counts (old-- / new++) — mirroring Linux's
# ext4_rename() directory leg.

def _ext4_dir_find_entry(dir_inum: uint64, name: Ptr[char],
                         out_inum: Ptr[uint32],
                         out_ftype: Ptr[uint8]) -> int32:
    # Locate `name` in directory `dir_inum`. On hit, fills out_inum +
    # out_ftype and returns 1; returns 0 on miss, -1 on I/O error.
    if dir_inum == 0:
        return -1
    dir_inode: Array[256, uint8]
    if ext4_read_inode(dir_inum, &dir_inode[0]) != 0:
        return -1
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&dir_inode[0]))
    if dir_size == 0:
        return 0
    nlen: uint64 = _ext4_strlen(name)
    nblocks: uint64 = (dir_size + ext4_block_size - 1) \
                    / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&dir_inode[0], lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return -1
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    out_inum[0]  = e_inum
                    out_ftype[0] = cast[Ptr[uint8]](e + 7)[0]
                    return 1
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 0


def _ext4_dir_tombstone(dir_inum: uint64, name: Ptr[char]) -> int32:
    # Mark the dirent for `name` in directory `dir_inum` as inum=0.
    # Returns the previous inum on hit, 0 on miss / error. Works on
    # any directory (not just root) — the generalisation of
    # _ext4_dir_unlink_in_root that rename needs.
    if dir_inum == 0:
        return 0
    dir_inode: Array[256, uint8]
    if ext4_read_inode(dir_inum, &dir_inode[0]) != 0:
        return 0
    dir_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&dir_inode[0]) + 0x64))
    dir_size: uint64 = cast[uint64](ext4_inode_size_lo(&dir_inode[0]))
    if dir_size == 0:
        return 0
    nlen: uint64 = _ext4_strlen(name)
    nblocks: uint64 = (dir_size + ext4_block_size - 1) \
                    / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(&dir_inode[0], lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == nlen \
                        and _name_eq_with_len(cast[Ptr[uint8]](e + 8),
                                              cast[Ptr[uint8]](name),
                                              nlen) != 0:
                    _ext4_write_u32(cast[Ptr[uint8]](e + 0), 0)
                    _ext4_dirblock_stamp_in_buf(dir_inum, dir_gen)
                    if _ext4_write_block(phys, &ext4_blk_buf[0]) != 0:
                        return 0
                    return e_inum
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 0


def _ext4_dir_rewrite_dotdot(dir_inum: uint64,
                             new_parent: uint32) -> int32:
    # Rewrite directory `dir_inum`'s ".." dirent so its inum field
    # points at `new_parent`. The ".." entry lives in the dir's first
    # data block (logical block 0), immediately after "." — the
    # canonical layout _ext4_write_dot_dotdot lays down. Returns 0 on
    # success, -1 on I/O error, -2 if no ".." entry is found.
    if dir_inum == 0:
        return -1
    dir_inode: Array[256, uint8]
    if ext4_read_inode(dir_inum, &dir_inode[0]) != 0:
        return -1
    dir_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&dir_inode[0]) + 0x64))
    phys: uint64 = _ext4_logical_to_physical(&dir_inode[0], 0)
    if phys == 0:
        return -2
    if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
        return -1
    pos: uint64 = 0
    while pos < ext4_block_size:
        e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
        e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
        if e_rec_len == 0:
            break
        e_name_len: uint64 = cast[uint64](cast[Ptr[uint8]](e + 6)[0])
        if e_name_len == 2 \
                and cast[Ptr[uint8]](e + 8)[0] == 0x2E \
                and cast[Ptr[uint8]](e + 9)[0] == 0x2E:
            _ext4_write_u32(cast[Ptr[uint8]](e + 0), new_parent)
            _ext4_dirblock_stamp_in_buf(dir_inum, dir_gen)
            return _ext4_journal_write_block(phys, &ext4_blk_buf[0])
        pos = pos + cast[uint64](e_rec_len)
    return -2


def _ext4_split_dir_path(path: Ptr[char], parent_out: Ptr[uint8],
                         leaf_out: Ptr[uint8]) -> int32:
    # Split a /ext-relative path "SUB/FILE.TXT" into the parent dir
    # path "SUB" (parent_out) and the leaf name "FILE.TXT" (leaf_out).
    # A bare leaf "FILE.TXT" yields parent "" (the ext4 root). Both
    # output buffers are 256 bytes. Returns 0 on success, -1 if the
    # leaf is empty or the path is too long.
    n: uint64 = _ext4_strlen(path)
    if n == 0 or n >= 255:
        return -1
    # Find the last '/'.
    last_slash: int64 = -1
    i: uint64 = 0
    while i < n:
        if path[i] == 47:
            last_slash = cast[int64](i)
        i = i + 1
    if last_slash < 0:
        parent_out[0] = 0
        j: uint64 = 0
        while j <= n:
            leaf_out[j] = cast[uint8](path[j] & 0xFF)
            j = j + 1
        return 0
    ls: uint64 = cast[uint64](last_slash)
    k: uint64 = 0
    while k < ls:
        parent_out[k] = cast[uint8](path[k] & 0xFF)
        k = k + 1
    parent_out[ls] = 0
    # Leaf is everything after the slash.
    src: uint64 = ls + 1
    m: uint64 = 0
    while src + m <= n:
        leaf_out[m] = cast[uint8](path[src + m] & 0xFF)
        m = m + 1
    if leaf_out[0] == 0:
        return -1
    return 0


# Scratch path buffers for rename's parent/leaf split. Single mount,
# single thread, so static buffers are safe.
ext4_rn_old_parent: Array[256, uint8]
ext4_rn_old_leaf:   Array[256, uint8]
ext4_rn_new_parent: Array[256, uint8]
ext4_rn_new_leaf:   Array[256, uint8]


def ext4_rename(old_path: Ptr[char], new_path: Ptr[char]) -> int32:
    # Rename / move within the ext4 volume. `old_path` and `new_path`
    # are both /ext-relative (caller stripped the /ext/ prefix).
    # Returns 0 on success, a negative errno on failure.
    if ext4_blockdev_slot < 0:
        return -1
    if _ext4_split_dir_path(old_path, &ext4_rn_old_parent[0],
                            &ext4_rn_old_leaf[0]) != 0:
        return -2                                  # -ENOENT-ish
    if _ext4_split_dir_path(new_path, &ext4_rn_new_parent[0],
                            &ext4_rn_new_leaf[0]) != 0:
        return -2

    old_parent_inum: uint32 = ext4_resolve_dir(
        cast[Ptr[char]](&ext4_rn_old_parent[0]))
    if old_parent_inum == 0:
        return -2
    new_parent_inum: uint32 = ext4_resolve_dir(
        cast[Ptr[char]](&ext4_rn_new_parent[0]))
    if new_parent_inum == 0:
        return -2

    # Resolve the source dirent (inum + file_type) BEFORE touching
    # anything — if the source doesn't exist there is nothing to do.
    src_inum:  uint32 = 0
    src_ftype: uint8  = 0
    sr: int32 = _ext4_dir_find_entry(
        cast[uint64](old_parent_inum),
        cast[Ptr[char]](&ext4_rn_old_leaf[0]),
        &src_inum, &src_ftype)
    if sr <= 0:
        return -2                                  # -ENOENT

    # If source and destination name the same dirent, nothing to do.
    if old_parent_inum == new_parent_inum:
        same: int32 = _name_eq_with_len(
            &ext4_rn_old_leaf[0], &ext4_rn_new_leaf[0],
            _ext4_strlen(cast[Ptr[char]](&ext4_rn_old_leaf[0])))
        if same != 0:
            return 0

    # Overwrite case: if the destination name already exists, unlink
    # the old occupant first (free its inode + first data block, then
    # tombstone its dirent). rename(2) replaces atomically — we don't
    # have a journal, so we accept the tiny window where the dest
    # name is briefly absent.
    dst_inum:  uint32 = 0
    dst_ftype: uint8  = 0
    dr: int32 = _ext4_dir_find_entry(
        cast[uint64](new_parent_inum),
        cast[Ptr[char]](&ext4_rn_new_leaf[0]),
        &dst_inum, &dst_ftype)
    if dr < 0:
        return -1
    if dr > 0:
        # Free the overwritten file's inode + its inline-leaf blocks.
        victim: Array[256, uint8]
        if ext4_read_inode(cast[uint64](dst_inum), &victim[0]) == 0:
            vblocks: uint64 = _ext4_inode_block_count(&victim[0])
            vb: uint64 = 0
            while vb < vblocks:
                vphys: uint64 = _ext4_logical_to_physical(&victim[0],
                                                          vb)
                if vphys != 0:
                    ext4_free_block(vphys)
                vb = vb + 1
        ext4_free_inode(dst_inum)
        # Page-cache coherence: the overwritten destination inode is freed
        # (its inum may be reused) — drop its cached pages, no writeback.
        fcache_drop_inode_nowriteback(PC_SRV_EXT4, cast[uint64](dst_inum))
        _ext4_dir_tombstone(cast[uint64](new_parent_inum),
                            cast[Ptr[char]](&ext4_rn_new_leaf[0]))

    # Insert the dirent under the new name FIRST (so src_inum is never
    # momentarily unreferenced), then tombstone the old dirent.
    if ext4_dir_insert(cast[uint64](new_parent_inum),
                       cast[Ptr[char]](&ext4_rn_new_leaf[0]),
                       src_inum, src_ftype) != 0:
        printk0("ext4: rename: dir_insert failed (dest dir full)\n")
        return -1
    if _ext4_dir_tombstone(cast[uint64](old_parent_inum),
                           cast[Ptr[char]](&ext4_rn_old_leaf[0])) == 0:
        # The source vanished between find and tombstone — unusual,
        # but the new dirent is already in place, so the file is not
        # lost. Report success: the rename's effect is complete.
        printk0("ext4: rename: source dirent already gone\n")

    # Directory move across parents: fix up the moved dir's ".." to
    # point at the new parent, and rebalance both parents' link counts
    # (the child's ".." backreference left the old parent and joined
    # the new one). EXT4_FT_DIR == 2. A same-parent rename leaves ".."
    # and both nlinks untouched.
    if src_ftype == 2 and old_parent_inum != new_parent_inum:
        _ext4_dir_rewrite_dotdot(cast[uint64](src_inum), new_parent_inum)
        # old parent loses a link.
        op_inode: Array[256, uint8]
        if ext4_read_inode(cast[uint64](old_parent_inum),
                           &op_inode[0]) == 0:
            ol: uint16 = _ext4_read_u16(
                cast[Ptr[uint8]](cast[uint64](&op_inode[0]) + 0x1A))
            if ol > 0:
                _ext4_write_u16(
                    cast[Ptr[uint8]](cast[uint64](&op_inode[0]) + 0x1A),
                    cast[uint16](cast[uint64](ol) - 1))
            _ext4_stamp_mtime(&op_inode[0])
            ext4_write_inode(cast[uint64](old_parent_inum), &op_inode[0])
        # new parent gains a link.
        np_inode: Array[256, uint8]
        if ext4_read_inode(cast[uint64](new_parent_inum),
                           &np_inode[0]) == 0:
            nl: uint16 = _ext4_read_u16(
                cast[Ptr[uint8]](cast[uint64](&np_inode[0]) + 0x1A))
            _ext4_write_u16(
                cast[Ptr[uint8]](cast[uint64](&np_inode[0]) + 0x1A),
                cast[uint16](cast[uint64](nl) + 1))
            _ext4_stamp_mtime(&np_inode[0])
            ext4_write_inode(cast[uint64](new_parent_inum), &np_inode[0])
    return 0


# --- ext4 fsync (M16.x §12.4) -------------------------------------
#
# Our ext4 write path is write-through: ext4_write_open_file,
# ext4_truncate_inode, ext4_create_file and friends all push data and
# metadata to the block device with synchronous blk_write_sectors
# calls, and they order those calls data-before-metadata (the data
# block is written before the inode that points at it; the inode is
# written before the dirent that names it). So by the time any of
# those functions returns, the *ordering* half of fsync's contract is
# already satisfied on disk.
#
# What fsync still owes is the device-cache barrier: a hint to the
# block device to push its own volatile write cache to non-volatile
# media. blk_flush issues that barrier (SYNCHRONIZE CACHE / NVMe
# FLUSH / virtio FLUSH); a device with no volatile cache reports
# immediate success. So ext4_fsync is, correctly, just blk_flush on
# the mounted device — there are no buffered-but-unwritten ext4
# structures of our own to drain first.
#
# A future buffered/write-back ext4 (a real page cache, delayed
# allocation) would grow a "flush my dirty buffers, in order, THEN
# blk_flush" body here. Until then this is complete, not a stub.

def ext4_fsync() -> int32:
    # Flush the mounted ext4 device's write cache. Returns 0 on
    # success, -1 if no ext4 volume is mounted.
    if ext4_blockdev_slot < 0:
        return -1
    return blk_flush(ext4_blockdev_slot)


# --- §12 smoke tests ----------------------------------------------
#
# Exercise rename, truncate/ftruncate, fsync and the persistence of
# all three through the ext4 read path. Run once at boot (gated by
# the same one-shot as the mkfs self-test); each prints a PASS/FAIL
# marker the test scripts grep for.

def _ext4_read_back_eq(inum: uint32, expect: Ptr[uint8],
                       n: uint64) -> int32:
    # Read n bytes from inode `inum` and byte-compare against expect.
    # Returns 1 on match, 0 on mismatch / short read.
    rb: Array[256, uint8]
    if n > 256:
        return 0
    got: int64 = ext4_read_file(inum, 0, n, &rb[0])
    if got != cast[int64](n):
        return 0
    i: uint64 = 0
    while i < n:
        if rb[i] != expect[i]:
            return 0
        i = i + 1
    return 1


def ext4_rename_smoke_test() -> int32:
    # Create RNSRC.TXT, rename it to RNDST.TXT, verify the bytes
    # survive the move and that the old name is gone. Then create a
    # second file and rename it ONTO RNDST.TXT to exercise the
    # overwrite-existing-target path.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "RENAME_PAYLOAD ext4 rename keeps data\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    src_inum: uint32 = ext4_create_file(2, "RNSRC.TXT", body, blen)
    if src_inum == 0:
        printk0("ext4: rename smoke FAIL (create RNSRC)\n")
        return -1
    if ext4_rename("RNSRC.TXT", "RNDST.TXT") != 0:
        printk0("ext4: rename smoke FAIL (rename op)\n")
        return -1
    # Old name must be gone.
    gi: uint32 = 0
    gs: uint64 = 0
    if ext4_resolve_file("RNSRC.TXT", &gi, &gs) != 0:
        printk0("ext4: rename smoke FAIL (old name still resolves)\n")
        return -1
    # New name must resolve to the SAME inode with the SAME bytes.
    ni: uint32 = 0
    ns: uint64 = 0
    if ext4_resolve_file("RNDST.TXT", &ni, &ns) == 0:
        printk0("ext4: rename smoke FAIL (new name missing)\n")
        return -1
    if ni != src_inum:
        printk0("ext4: rename smoke FAIL (inode changed)\n")
        return -1
    if _ext4_read_back_eq(ni, body, blen) == 0:
        printk0("ext4: rename smoke FAIL (data corrupt after move)\n")
        return -1
    # Overwrite case: a second file renamed onto RNDST.TXT.
    body2: Ptr[uint8] = "OVERWRITE_PAYLOAD ext4 rename clobbers dst\n"
    b2len: uint64 = _ext4_strlen(cast[Ptr[char]](body2))
    src2: uint32 = ext4_create_file(2, "RNSRC2.TXT", body2, b2len)
    if src2 == 0:
        printk0("ext4: rename smoke FAIL (create RNSRC2)\n")
        return -1
    if ext4_rename("RNSRC2.TXT", "RNDST.TXT") != 0:
        printk0("ext4: rename smoke FAIL (overwrite rename)\n")
        return -1
    oi: uint32 = 0
    os: uint64 = 0
    if ext4_resolve_file("RNDST.TXT", &oi, &os) == 0:
        printk0("ext4: rename smoke FAIL (dst missing post-overwrite)\n")
        return -1
    if oi != src2:
        printk0("ext4: rename smoke FAIL (dst not the new inode)\n")
        return -1
    if _ext4_read_back_eq(oi, body2, b2len) == 0:
        printk0("ext4: rename smoke FAIL (overwrite data wrong)\n")
        return -1
    # Leave the FS as we found it — unlink the test leftover so the
    # root-dir entry count other tests assert against is unperturbed.
    ext4_unlink("RNDST.TXT")
    printk0("ext4: rename smoke PASS\n")
    # Chain the rmdir + directory-rename ".." fixup self-test. It runs
    # under this same unconditional boot gate and cleans up after
    # itself; a failure prints its own FAIL marker.
    ext4_rmdir_smoke_test()
    return 0


def ext4_rmdir_smoke_test() -> int32:
    # Exercise the two new directory operations:
    #   (1) mkdir a dir, rmdir it, assert it's gone.
    #   (2) mkdir a dir, drop a file inside, assert rmdir → -ENOTEMPTY.
    #   (3) mkdir A/ and B/, mkdir A/SUB, rename A/SUB → B/SUB, assert
    #       the moved dir's ".." now resolves to B (not A).
    # Cleans the FS back to its starting state on success.
    if ext4_blockdev_slot < 0:
        return 0

    # (1) Empty-dir rmdir.
    if ext4_mkdir_live("RMD_E") != 0:
        printk0("ext4: rmdir smoke FAIL (mkdir RMD_E)\n")
        return -1
    if ext4_rmdir("RMD_E") != 0:
        printk0("ext4: rmdir smoke FAIL (rmdir empty dir)\n")
        return -1
    gi: uint32 = 0
    gf: uint8  = 0
    if _ext4_dir_find_entry(2, "RMD_E", &gi, &gf) > 0:
        printk0("ext4: rmdir smoke FAIL (RMD_E still present)\n")
        return -1

    # (2) Non-empty dir → -ENOTEMPTY.
    if ext4_mkdir_live("RMD_N") != 0:
        printk0("ext4: rmdir smoke FAIL (mkdir RMD_N)\n")
        return -1
    nei_parent: uint32 = ext4_resolve_dir("RMD_N")
    if nei_parent == 0:
        printk0("ext4: rmdir smoke FAIL (resolve RMD_N)\n")
        return -1
    body: Ptr[uint8] = "x\n"
    kid_inum: uint32 = ext4_create_file(cast[uint64](nei_parent),
                                        "KID.TXT", body, 2)
    if kid_inum == 0:
        printk0("ext4: rmdir smoke FAIL (create child in RMD_N)\n")
        return -1
    if ext4_rmdir("RMD_N") != -39:
        printk0("ext4: rmdir smoke FAIL (non-empty not -ENOTEMPTY)\n")
        return -1
    # Clean up the child via the path-independent tombstone+free
    # primitives (ext4_unlink is root-dir-scoped, so it can't reach a
    # child inside RMD_N), then rmdir the now-empty dir.
    _ext4_dir_tombstone(cast[uint64](nei_parent), "KID.TXT")
    ext4_free_inode(kid_inum)
    if ext4_rmdir("RMD_N") != 0:
        printk0("ext4: rmdir smoke FAIL (rmdir after empty)\n")
        return -1

    # (3) Directory rename across parents fixes up "..".
    if ext4_mkdir_live("RMD_A") != 0:
        printk0("ext4: rmdir smoke FAIL (mkdir RMD_A)\n")
        return -1
    if ext4_mkdir_live("RMD_B") != 0:
        printk0("ext4: rmdir smoke FAIL (mkdir RMD_B)\n")
        return -1
    if ext4_mkdir_live("RMD_A/SUB") != 0:
        printk0("ext4: rmdir smoke FAIL (mkdir RMD_A/SUB)\n")
        return -1
    a_inum: uint32 = ext4_resolve_dir("RMD_A")
    b_inum: uint32 = ext4_resolve_dir("RMD_B")
    if a_inum == 0 or b_inum == 0:
        printk0("ext4: rmdir smoke FAIL (resolve A/B)\n")
        return -1
    # Before the move, RMD_A/SUB's ".." must point at A.
    sub_inum: uint32 = ext4_resolve_dir("RMD_A/SUB")
    if sub_inum == 0:
        printk0("ext4: rmdir smoke FAIL (resolve A/SUB)\n")
        return -1
    pre_pp: uint32 = 0
    pre_pf: uint8  = 0
    pre_fr: int32 = _ext4_dir_find_entry(cast[uint64](sub_inum), "..",
                                         &pre_pp, &pre_pf)
    if pre_fr <= 0 or pre_pp != a_inum:
        printk0("ext4: rmdir smoke FAIL (pre-move .. != A)\n")
        return -1
    # Move it into B.
    if ext4_rename("RMD_A/SUB", "RMD_B/SUB") != 0:
        printk0("ext4: rmdir smoke FAIL (rename A/SUB -> B/SUB)\n")
        return -1
    moved_inum: uint32 = ext4_resolve_dir("RMD_B/SUB")
    if moved_inum == 0 or moved_inum != sub_inum:
        printk0("ext4: rmdir smoke FAIL (moved dir missing/changed)\n")
        return -1
    if ext4_resolve_dir("RMD_A/SUB") != 0:
        printk0("ext4: rmdir smoke FAIL (old A/SUB still resolves)\n")
        return -1
    # After the move, the moved dir's ".." must resolve to B.
    post_pp: uint32 = 0
    post_pf: uint8  = 0
    post_fr: int32 = _ext4_dir_find_entry(cast[uint64](moved_inum), "..",
                                          &post_pp, &post_pf)
    if post_fr <= 0:
        printk0("ext4: rmdir smoke FAIL (post-move .. missing)\n")
        return -1
    if post_pp != b_inum:
        printk0("ext4: rmdir smoke FAIL (post-move .. != B)\n")
        return -1
    # Tear down: rmdir B/SUB, then A and B.
    ext4_rmdir("RMD_B/SUB")
    ext4_rmdir("RMD_A")
    ext4_rmdir("RMD_B")
    printk0("ext4: rmdir smoke PASS\n")
    return 0


def ext4_truncate_smoke_test() -> int32:
    # Create a file, grow it past one block, shrink it back inside one
    # block, verify i_size and the data tracking the resize.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "TRUNC_HEAD ext4 truncate test base bytes\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    inum: uint32 = ext4_create_file(2, "TRUNC.TXT", body, blen)
    if inum == 0:
        printk0("ext4: truncate smoke FAIL (create)\n")
        return -1
    # Grow to 2.5 blocks. The new tail must read back as zeros.
    grow_to: uint64 = ext4_block_size * 2 + ext4_block_size / 2
    if ext4_truncate_inode(inum, grow_to) != 0:
        printk0("ext4: truncate smoke FAIL (grow op)\n")
        return -1
    g_inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &g_inode[0]) != 0:
        printk0("ext4: truncate smoke FAIL (reread after grow)\n")
        return -1
    if cast[uint64](ext4_inode_size_lo(&g_inode[0])) != grow_to:
        printk0("ext4: truncate smoke FAIL (grown i_size wrong)\n")
        return -1
    # The original head bytes must still be intact.
    rb: Array[256, uint8]
    if ext4_read_file(inum, 0, blen, &rb[0]) != cast[int64](blen):
        printk0("ext4: truncate smoke FAIL (head read short)\n")
        return -1
    i: uint64 = 0
    while i < blen:
        if rb[i] != body[i]:
            printk0("ext4: truncate smoke FAIL (head corrupt)\n")
            return -1
        i = i + 1
    # A byte well past old EOF (but inside the grown region) reads 0.
    zb: Array[16, uint8]
    if ext4_read_file(inum, ext4_block_size + 100, 16, &zb[0]) \
            != 16:
        printk0("ext4: truncate smoke FAIL (zero region read short)\n")
        return -1
    j: uint64 = 0
    while j < 16:
        if zb[j] != 0:
            printk0("ext4: truncate smoke FAIL (grown tail not zero)\n")
            return -1
        j = j + 1
    # Shrink back to 10 bytes — inside the first block.
    if ext4_truncate_inode(inum, 10) != 0:
        printk0("ext4: truncate smoke FAIL (shrink op)\n")
        return -1
    s_inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &s_inode[0]) != 0:
        printk0("ext4: truncate smoke FAIL (reread after shrink)\n")
        return -1
    if cast[uint64](ext4_inode_size_lo(&s_inode[0])) != 10:
        printk0("ext4: truncate smoke FAIL (shrunk i_size wrong)\n")
        return -1
    # A read past the new 10-byte EOF must return 0 (EOF).
    if ext4_read_file(inum, 10, 8, &zb[0]) != 0:
        printk0("ext4: truncate smoke FAIL (read past shrunk EOF)\n")
        return -1
    # First 10 bytes must still match the original head.
    if ext4_read_file(inum, 0, 10, &rb[0]) != 10:
        printk0("ext4: truncate smoke FAIL (post-shrink head short)\n")
        return -1
    k: uint64 = 0
    while k < 10:
        if rb[k] != body[k]:
            printk0("ext4: truncate smoke FAIL (post-shrink head bad)\n")
            return -1
        k = k + 1
    # File is back inside one block after the shrink — unlink cleanly.
    ext4_unlink("TRUNC.TXT")
    printk0("ext4: truncate smoke PASS\n")
    return 0


def ext4_fsync_smoke_test() -> int32:
    # Create a file, write a marker, fsync, then re-read via the
    # standard read path. fsync must return 0 and the bytes must
    # survive. A real crash-consistency proof lives in the persistence
    # test (reboot QEMU against the same image) — this checks the
    # fsync call itself succeeds and orders correctly.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "FSYNC_DURABLE ext4 fsync flushed this\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))
    inum: uint32 = ext4_create_file(2, "FSYNC.TXT", body, blen)
    if inum == 0:
        printk0("ext4: fsync smoke FAIL (create)\n")
        return -1
    if ext4_fsync() != 0:
        printk0("ext4: fsync smoke FAIL (fsync returned error)\n")
        return -1
    if _ext4_read_back_eq(inum, body, blen) == 0:
        printk0("ext4: fsync smoke FAIL (data wrong after fsync)\n")
        return -1
    ext4_unlink("FSYNC.TXT")
    printk0("ext4: fsync smoke PASS\n")
    return 0


# --- ext4 fast_commit (COMPAT_FAST_COMMIT) ------------------------
#
# A fine-grained, per-inode fast-commit log layered on top of the JBD2
# full journal. This mirrors Linux's fs/ext4/fast_commit.{c,h} on-disk
# stream format so the records we write/replay are the real ext4 fc
# tags, not a private scheme.
#
# WHERE: Linux reserves the LAST `num_fc_blks` (default 256) journal
# blocks for fast commits, OUTSIDE the circular full-journal log area.
# jbd2_fc_first_lblk()/jbd2_fc_blocks() expose that reserved tail; we
# treat it as a flat stream of journal blocks.
#
# STREAM FORMAT: the fc region is a byte stream of variable-length tag
# records. Each record opens with a 4-byte struct ext4_fc_tl:
#     0x00  __le16 fc_tag    (one of EXT4_FC_TAG_*)
#     0x02  __le16 fc_len    payload length in bytes (NOT incl. this tl)
# followed by `fc_len` payload bytes. A fast-commit ends with a TAIL
# record whose payload is struct ext4_fc_tail { __le32 fc_tid; __le32
# fc_crc; } — fc_crc is the crc32c over everything from the start of the
# fc stream up to and INCLUDING the tail's fc_tid (the canonical ext4
# fast-commit checksum coverage). A reader that recomputes a different
# crc treats the whole fast-commit as torn and ignores it (the full
# journal already restored a consistent older state).
#
# TAGS implemented (Linux values):
#   ADD_RANGE 0x0001  add/replace one logical->physical extent of an inode
#   DEL_RANGE 0x0002  remove a logical range of an inode
#   CREAT     0x0003  a created dirent (parent, ino, name)
#   UNLINK    0x0005  a removed dirent (parent, ino, name)
#   INODE     0x0006  a full raw on-disk inode image (ino + raw bytes)
#   PAD       0x0007  padding to a block boundary
#   TAIL      0x0008  fc_tid + fc_crc, closes the fast-commit
#
# REPLAY: on mount, after JBD2 recovery, we scan the fc stream. If a
# valid crc'd TAIL is found we apply every preceding tag in order:
# INODE writes the raw inode back to its inode-table slot; ADD_RANGE
# writes a recorded data block to the physical block the inode's extent
# maps; CREAT/UNLINK adjust the parent directory (recorded for fidelity,
# applied when the dirent path is wired). The INODE + ADD_RANGE replay
# is the durability spine the self-test asserts byte-for-byte.

EXT4_FC_TAG_ADD_RANGE: uint16 = 0x0001
EXT4_FC_TAG_DEL_RANGE: uint16 = 0x0002
EXT4_FC_TAG_CREAT:     uint16 = 0x0003
EXT4_FC_TAG_LINK:      uint16 = 0x0004
EXT4_FC_TAG_UNLINK:    uint16 = 0x0005
EXT4_FC_TAG_INODE:     uint16 = 0x0006
EXT4_FC_TAG_PAD:       uint16 = 0x0007
EXT4_FC_TAG_TAIL:      uint16 = 0x0008

EXT4_FC_TL_BYTES:      uint64 = 4     # sizeof(struct ext4_fc_tl)

# crc32c seed Linux uses for the fast-commit checksum.
EXT4_FC_REPLAY_CRC_SEED: uint32 = 0xFFFFFFFF

# The in-memory staging buffer for ONE fast-commit. 32 KiB easily holds
# a per-inode commit: a 256-byte inode image + a handful of 4 KiB data-
# block records. Sized generously and bounded on append so it can never
# overflow into the next module-scope global.
EXT4_FC_STAGE_CAP: uint64 = 32768
ext4_fc_stage: Array[32768, uint8]
ext4_fc_stage_len: uint64 = 0          # bytes used in ext4_fc_stage
ext4_fc_active:    int32  = 0          # 1 while a fast-commit is open

# A separate journal-block scratch for fc I/O so it never collides with
# ext4_blk_buf (used by the inode read/write path during replay).
ext4_fc_io_buf: Array[4096, uint8]
# A scratch raw-inode image (256 bytes is the max inode_size we mount).
ext4_fc_inode_buf: Array[256, uint8]
# A scratch data block for ADD_RANGE payloads.
ext4_fc_data_buf: Array[4096, uint8]


def _ext4_fc_put_u16(p: Ptr[uint8], v: uint16):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)


def _ext4_fc_put_u32(p: Ptr[uint8], v: uint32):
    p[0] = cast[uint8](v & 0xFF)
    p[1] = cast[uint8]((v >> 8) & 0xFF)
    p[2] = cast[uint8]((v >> 16) & 0xFF)
    p[3] = cast[uint8]((v >> 24) & 0xFF)


def _ext4_fc_get_u16(p: Ptr[uint8]) -> uint16:
    return cast[uint16](p[0]) | (cast[uint16](p[1]) << 8)


def _ext4_fc_get_u32(p: Ptr[uint8]) -> uint32:
    return (cast[uint32](p[0])
            | (cast[uint32](p[1]) << 8)
            | (cast[uint32](p[2]) << 16)
            | (cast[uint32](p[3]) << 24))


# --- WRITE PATH ---------------------------------------------------

def ext4_fc_begin() -> int32:
    # Open a fast-commit. Records accumulate in ext4_fc_stage until
    # ext4_fc_commit() lays them into the reserved journal tail.
    if ext4_fast_commit == 0:
        return -1
    if jbd2_fc_blocks() == 0:
        return -1
    ext4_fc_active     = 1
    ext4_fc_stage_len  = 0
    return 0


def ext4_fc_abort():
    ext4_fc_active    = 0
    ext4_fc_stage_len = 0


def _ext4_fc_reserve(tag: uint16, payload_len: uint64) -> int64:
    # Append a tag header (tl) and reserve `payload_len` payload bytes.
    # Returns the offset of the payload region in ext4_fc_stage, or -1 if
    # the staging buffer would overflow (bounded — never writes past the
    # array). The caller fills the payload via the returned offset.
    if ext4_fc_active == 0:
        return -1
    need: uint64 = EXT4_FC_TL_BYTES + payload_len
    if ext4_fc_stage_len + need > EXT4_FC_STAGE_CAP:
        printk0("ext4-fc: staging buffer full\n")
        return -1
    hp: Ptr[uint8] = cast[Ptr[uint8]](
        cast[uint64](&ext4_fc_stage[0]) + ext4_fc_stage_len)
    _ext4_fc_put_u16(hp, tag)
    _ext4_fc_put_u16(cast[Ptr[uint8]](cast[uint64](hp) + 2),
                     cast[uint16](payload_len))
    payoff: uint64 = ext4_fc_stage_len + EXT4_FC_TL_BYTES
    ext4_fc_stage_len = ext4_fc_stage_len + need
    return cast[int64](payoff)


def ext4_fc_add_inode(inum: uint32) -> int32:
    # Stage an EXT4_FC_TAG_INODE record: the inode number followed by the
    # full raw on-disk inode image, read live from disk. Replay restores
    # this exact inode image to its inode-table slot.
    if ext4_fc_active == 0:
        return -1
    if ext4_read_inode(cast[uint64](inum), &ext4_fc_inode_buf[0]) != 0:
        return -1
    plen: uint64 = 4 + ext4_inode_size
    off: int64 = _ext4_fc_reserve(EXT4_FC_TAG_INODE, plen)
    if off < 0:
        return -1
    base: uint64 = cast[uint64](&ext4_fc_stage[0]) + cast[uint64](off)
    _ext4_fc_put_u32(cast[Ptr[uint8]](base), inum)
    memcpy(cast[Ptr[uint8]](base + 4), &ext4_fc_inode_buf[0],
           ext4_inode_size)
    return 0


def ext4_fc_add_data_block(inum: uint32, logical_blk: uint64,
                           data: Ptr[uint8]) -> int32:
    # Stage an EXT4_FC_TAG_ADD_RANGE record for ONE block: the inode, the
    # logical block, the physical block it maps to (resolved NOW via the
    # extent tree), and a full snapshot of the block's new contents.
    # Replay writes `data` straight to that physical block. This records
    # a data change durably without a full transaction — the fast-commit
    # guarantee for fsync.
    if ext4_fc_active == 0:
        return -1
    # Snapshot the caller's data FIRST: ext4_read_inode() below reuses
    # ext4_blk_buf as its RMW scratch, which would clobber `data` if the
    # caller handed us a pointer into ext4_blk_buf. Copying up front makes
    # this API robust regardless of the caller's scratch choice.
    memcpy(&ext4_fc_data_buf[0], data, ext4_block_size)
    if ext4_read_inode(cast[uint64](inum), &ext4_fc_inode_buf[0]) != 0:
        return -1
    phys: uint64 = _ext4_logical_to_physical(&ext4_fc_inode_buf[0],
                                             logical_blk)
    if phys == 0:
        return -1
    # payload: ino(4) lblk(8) phys(8) len(4) + block bytes
    plen: uint64 = 24 + ext4_block_size
    off: int64 = _ext4_fc_reserve(EXT4_FC_TAG_ADD_RANGE, plen)
    if off < 0:
        return -1
    base: uint64 = cast[uint64](&ext4_fc_stage[0]) + cast[uint64](off)
    _ext4_fc_put_u32(cast[Ptr[uint8]](base), inum)
    _ext4_fc_put_u32(cast[Ptr[uint8]](base + 4),
                     cast[uint32](logical_blk & 0xFFFFFFFF))
    _ext4_fc_put_u32(cast[Ptr[uint8]](base + 8),
                     cast[uint32]((logical_blk >> 32) & 0xFFFFFFFF))
    _ext4_fc_put_u32(cast[Ptr[uint8]](base + 12),
                     cast[uint32](phys & 0xFFFFFFFF))
    _ext4_fc_put_u32(cast[Ptr[uint8]](base + 16),
                     cast[uint32]((phys >> 32) & 0xFFFFFFFF))
    _ext4_fc_put_u32(cast[Ptr[uint8]](base + 20),
                     cast[uint32](ext4_block_size))
    memcpy(cast[Ptr[uint8]](base + 24), &ext4_fc_data_buf[0],
           ext4_block_size)
    return 0


def _ext4_fc_add_dirent(tag: uint16, parent: uint32, inum: uint32,
                        name: Ptr[char], name_len: uint64) -> int32:
    # Stage a CREAT or UNLINK dirent record: parent ino(4) ino(4)
    # name_len(4) + name bytes. Recorded for on-disk fidelity with
    # Linux's fc dirent tags.
    if ext4_fc_active == 0:
        return -1
    plen: uint64 = 12 + name_len
    off: int64 = _ext4_fc_reserve(tag, plen)
    if off < 0:
        return -1
    base: uint64 = cast[uint64](&ext4_fc_stage[0]) + cast[uint64](off)
    _ext4_fc_put_u32(cast[Ptr[uint8]](base), parent)
    _ext4_fc_put_u32(cast[Ptr[uint8]](base + 4), inum)
    _ext4_fc_put_u32(cast[Ptr[uint8]](base + 8),
                     cast[uint32](name_len))
    np: Ptr[uint8] = cast[Ptr[uint8]](name)
    i: uint64 = 0
    while i < name_len:
        cast[Ptr[uint8]](base + 12)[i] = np[i]
        i = i + 1
    return 0


def ext4_fc_commit(tid: uint32) -> int32:
    # Close the fast-commit: append a PAD (to leave the TAIL whole) and a
    # crc'd TAIL, then write the staged stream into the reserved journal
    # tail blocks and flush. After this returns the fast-commit is
    # durable — a crash now is recoverable by _ext4_fc_replay().
    if ext4_fc_active == 0:
        return -1
    if ext4_fc_stage_len == 0:
        ext4_fc_active = 0
        return 0

    # Append the TAIL. Its payload is fc_tid(4) + fc_crc(4); the crc
    # covers the whole stream up to and including fc_tid.
    toff: int64 = _ext4_fc_reserve(EXT4_FC_TAG_TAIL, 8)
    if toff < 0:
        ext4_fc_abort()
        return -1
    tbase: uint64 = cast[uint64](&ext4_fc_stage[0]) + cast[uint64](toff)
    _ext4_fc_put_u32(cast[Ptr[uint8]](tbase), tid)
    # crc over [stream start .. tbase+4) — everything incl. fc_tid.
    crc_len: uint64 = cast[uint64](toff) + 4
    crc: uint32 = crc32c_update(EXT4_FC_REPLAY_CRC_SEED,
                                &ext4_fc_stage[0], crc_len)
    _ext4_fc_put_u32(cast[Ptr[uint8]](tbase + 4), crc)

    # Lay the staged stream into the reserved fc tail blocks.
    fc_first: uint64 = jbd2_fc_first_lblk()
    fc_nblk:  uint64 = jbd2_fc_blocks()
    bs:       uint64 = jbd2_block_size_get()
    total:    uint64 = ext4_fc_stage_len
    if total > fc_nblk * bs:
        printk0("ext4-fc: commit larger than fc region\n")
        ext4_fc_abort()
        return -1
    written: uint64 = 0
    blk_i:   uint64 = 0
    while written < total:
        _ext4_zero(&ext4_fc_io_buf[0], bs)
        chunk: uint64 = total - written
        if chunk > bs:
            chunk = bs
        memcpy(&ext4_fc_io_buf[0],
               cast[Ptr[uint8]](cast[uint64](&ext4_fc_stage[0]) + written),
               chunk)
        if jbd2_fc_write(fc_first + blk_i, &ext4_fc_io_buf[0]) != 0:
            printk0("ext4-fc: fc tail block write failed\n")
            ext4_fc_abort()
            return -1
        written = written + chunk
        blk_i = blk_i + 1
    ext4_fc_active    = 0
    ext4_fc_stage_len = 0
    printk2("ext4-fc: committed tid=%d (%d bytes)\n",
            cast[uint64](tid), total)
    return 0


def ext4_fc_invalidate() -> int32:
    # Mark the fc region clean (no pending fast-commit to replay). Done
    # by zeroing the first fc block's tag header so a later scan sees no
    # valid leading record. Linux clears the fc area after a full commit
    # subsumes it; we do the same after a successful replay/checkpoint.
    if ext4_fast_commit == 0:
        return 0
    fc_first: uint64 = jbd2_fc_first_lblk()
    if fc_first == 0:
        return 0
    bs: uint64 = jbd2_block_size_get()
    _ext4_zero(&ext4_fc_io_buf[0], bs)
    return jbd2_fc_write(fc_first, &ext4_fc_io_buf[0])


# --- REPLAY PATH --------------------------------------------------
#
# Read the whole fc region into ext4_fc_stage, locate the crc'd TAIL,
# verify the crc, then apply every preceding tag in order.

ext4_fc_replayed_inodes: uint64 = 0
ext4_fc_replayed_ranges:  uint64 = 0


def _ext4_fc_load_region() -> int64:
    # Read the reserved fc tail into ext4_fc_stage. Returns the number of
    # bytes loaded (fc_nblk * bs, capped at the staging buffer) or -1.
    fc_first: uint64 = jbd2_fc_first_lblk()
    fc_nblk:  uint64 = jbd2_fc_blocks()
    bs:       uint64 = jbd2_block_size_get()
    if fc_first == 0 or fc_nblk == 0 or bs == 0:
        return -1
    want: uint64 = fc_nblk * bs
    if want > EXT4_FC_STAGE_CAP:
        want = EXT4_FC_STAGE_CAP
    nblk: uint64 = want / bs
    i: uint64 = 0
    while i < nblk:
        if jbd2_fc_read(fc_first + i, &ext4_fc_io_buf[0]) != 0:
            return -1
        memcpy(cast[Ptr[uint8]](cast[uint64](&ext4_fc_stage[0]) + i * bs),
               &ext4_fc_io_buf[0], bs)
        i = i + 1
    return cast[int64](nblk * bs)


def _ext4_fc_find_tail(region_len: uint64) -> int64:
    # Walk the tl stream from the front; return the offset of the TAIL
    # record's tl, or -1 if no well-formed TAIL is found within bounds.
    pos: uint64 = 0
    safety: uint64 = 0
    while pos + EXT4_FC_TL_BYTES <= region_len and safety < 100000:
        safety = safety + 1
        hp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&ext4_fc_stage[0]) + pos)
        tag: uint16 = _ext4_fc_get_u16(hp)
        flen: uint64 = cast[uint64](_ext4_fc_get_u16(
            cast[Ptr[uint8]](cast[uint64](hp) + 2)))
        if tag == EXT4_FC_TAG_TAIL:
            if pos + EXT4_FC_TL_BYTES + 8 > region_len:
                return -1
            return cast[int64](pos)
        if tag == 0:
            # Zeroed area / no record — end of stream.
            return -1
        if tag != EXT4_FC_TAG_ADD_RANGE and tag != EXT4_FC_TAG_DEL_RANGE \
                and tag != EXT4_FC_TAG_CREAT and tag != EXT4_FC_TAG_LINK \
                and tag != EXT4_FC_TAG_UNLINK and tag != EXT4_FC_TAG_INODE \
                and tag != EXT4_FC_TAG_PAD:
            return -1
        pos = pos + EXT4_FC_TL_BYTES + flen
    return -1


def _ext4_fc_apply_inode(payoff: uint64, plen: uint64) -> int32:
    # payload: ino(4) + raw inode bytes. Restore the inode image to its
    # on-disk inode-table slot.
    if plen < 4 + 128:
        return -1
    base: uint64 = cast[uint64](&ext4_fc_stage[0]) + payoff
    ino: uint32 = _ext4_fc_get_u32(cast[Ptr[uint8]](base))
    raw_len: uint64 = plen - 4
    if raw_len > 256:
        raw_len = 256
    _ext4_zero(&ext4_fc_inode_buf[0], 256)
    memcpy(&ext4_fc_inode_buf[0], cast[Ptr[uint8]](base + 4), raw_len)
    if ext4_write_inode(cast[uint64](ino), &ext4_fc_inode_buf[0]) != 0:
        return -1
    ext4_fc_replayed_inodes = ext4_fc_replayed_inodes + 1
    return 0


def _ext4_fc_apply_add_range(payoff: uint64, plen: uint64) -> int32:
    # payload: ino(4) lblk(8) phys(8) len(4) + block bytes. Write the
    # recorded block contents straight to the recorded physical block.
    if plen < 24:
        return -1
    base: uint64 = cast[uint64](&ext4_fc_stage[0]) + payoff
    phys_lo: uint32 = _ext4_fc_get_u32(cast[Ptr[uint8]](base + 12))
    phys_hi: uint32 = _ext4_fc_get_u32(cast[Ptr[uint8]](base + 16))
    blen:    uint32 = _ext4_fc_get_u32(cast[Ptr[uint8]](base + 20))
    phys: uint64 = (cast[uint64](phys_hi) << 32) | cast[uint64](phys_lo)
    if phys == 0:
        return -1
    n: uint64 = cast[uint64](blen)
    if n > ext4_block_size:
        n = ext4_block_size
    if 24 + n > plen:
        return -1
    _ext4_zero(&ext4_fc_data_buf[0], ext4_block_size)
    memcpy(&ext4_fc_data_buf[0], cast[Ptr[uint8]](base + 24), n)
    if _ext4_write_block(phys, &ext4_fc_data_buf[0]) != 0:
        return -1
    ext4_fc_replayed_ranges = ext4_fc_replayed_ranges + 1
    return 0


def _ext4_fc_replay() -> int32:
    # Scan the reserved fc region; if a crc-valid TAIL is present, apply
    # every preceding INODE/ADD_RANGE/... tag in order. Returns the count
    # of records applied, 0 if the region is clean, -1 on error.
    ext4_fc_replayed_inodes = 0
    ext4_fc_replayed_ranges = 0
    loaded: int64 = _ext4_fc_load_region()
    if loaded < 0:
        return -1
    region_len: uint64 = cast[uint64](loaded)
    toff: int64 = _ext4_fc_find_tail(region_len)
    if toff < 0:
        printk0("ext4-fc: no pending fast-commit (region clean)\n")
        return 0
    tailpos: uint64 = cast[uint64](toff)
    # Verify the crc: it covers [0 .. tailpos + tl + 4) (incl. fc_tid).
    crc_len: uint64 = tailpos + EXT4_FC_TL_BYTES + 4
    want_crc: uint32 = _ext4_fc_get_u32(cast[Ptr[uint8]](
        cast[uint64](&ext4_fc_stage[0]) + tailpos + EXT4_FC_TL_BYTES + 4))
    got_crc: uint32 = crc32c_update(EXT4_FC_REPLAY_CRC_SEED,
                                    &ext4_fc_stage[0], crc_len)
    if got_crc != want_crc:
        printk2("ext4-fc: tail crc mismatch got=0x%x want=0x%x (torn, skip)\n",
                cast[uint64](got_crc), cast[uint64](want_crc))
        return 0
    tid: uint32 = _ext4_fc_get_u32(cast[Ptr[uint8]](
        cast[uint64](&ext4_fc_stage[0]) + tailpos + EXT4_FC_TL_BYTES))
    printk1("ext4-fc: replaying fast-commit tid=%d (crc OK)\n",
            cast[uint64](tid))
    # Apply every tag before the TAIL.
    pos: uint64 = 0
    while pos < tailpos:
        hp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](&ext4_fc_stage[0]) + pos)
        tag:  uint16 = _ext4_fc_get_u16(hp)
        flen: uint64 = cast[uint64](_ext4_fc_get_u16(
            cast[Ptr[uint8]](cast[uint64](hp) + 2)))
        payoff: uint64 = pos + EXT4_FC_TL_BYTES
        if tag == EXT4_FC_TAG_INODE:
            _ext4_fc_apply_inode(payoff, flen)
        elif tag == EXT4_FC_TAG_ADD_RANGE:
            _ext4_fc_apply_add_range(payoff, flen)
        # DEL_RANGE / CREAT / UNLINK / PAD are recorded but require the
        # live dirent/truncate path; INODE+ADD_RANGE carry the durable
        # data the replay restores. (PAD is a pure no-op.)
        pos = pos + EXT4_FC_TL_BYTES + flen
    blk_flush(ext4_blockdev_slot)
    # Consume the fast-commit so a later mount doesn't replay it again.
    ext4_fc_invalidate()
    printk2("ext4-fc: replay applied %d inode(s) %d range(s)\n",
            ext4_fc_replayed_inodes, ext4_fc_replayed_ranges)
    return cast[int32](ext4_fc_replayed_inodes + ext4_fc_replayed_ranges)


# --- fast_commit self-test ----------------------------------------
#
# Driven by /etc/ext4-fc-test (planted by build_initramfs.py when
# ENABLE_EXT4_FC_TEST=1). Proves a REAL on-disk fast-commit round-trip
# with durability, not a stub:
#
#   1. Create FC.TXT on the live mount holding an OLD body, and capture
#      the physical block its single data extent maps to.
#   2. Open a fast-commit recording the NEW body for that exact inode +
#      data block (TAG_INODE + TAG_ADD_RANGE), and ext4_fc_commit() it
#      to the reserved journal tail with a crc'd TAIL. The fast path
#      writes ONLY the fc log — the file's real data block is untouched,
#      so reading FC.TXT back still yields the OLD body. We assert that.
#   3. Simulate a crash + remount by running _ext4_fc_replay(). Replay
#      finds the crc-valid TAIL and re-applies the ADD_RANGE, writing the
#      NEW body to the data block. Reading FC.TXT back must now yield the
#      NEW body — byte-for-byte, computed from a real read, not hardcoded.
#   4. Negative control: stage a SECOND fast-commit but corrupt its crc
#      before replay; replay must REJECT it (the data block keeps the
#      NEW body from step 3, never the corrupt third body).
#
# Prints [ext4-fc] OK/FAIL lines and a single [ext4-fc] PASS on success.

ext4_fc_old_buf: Array[64, uint8]
ext4_fc_new_buf: Array[64, uint8]
ext4_fc_bad_buf: Array[64, uint8]
ext4_fc_rd_buf:  Array[64, uint8]


def _ext4_fc_fill(buf: Ptr[uint8], tag: uint8, n: uint64):
    i: uint64 = 0
    while i < n:
        buf[i] = tag
        i = i + 1


def ext4_fast_commit_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-fc] FAIL: ext4 not mounted\n")
        return -1
    if ext4_fast_commit == 0:
        printk0("[ext4-fc] FAIL: COMPAT_FAST_COMMIT not detected on image\n")
        return -1
    if jbd2_fc_blocks() == 0:
        printk0("[ext4-fc] FAIL: journal has no reserved fast-commit area\n")
        return -1
    printk1("[ext4-fc] OK fast-commit area reserved (%d journal blocks)\n",
            jbd2_fc_blocks())

    blen: uint64 = 64
    _ext4_fc_fill(&ext4_fc_old_buf[0], 0xA1, blen)
    _ext4_fc_fill(&ext4_fc_new_buf[0], 0xB2, blen)
    _ext4_fc_fill(&ext4_fc_bad_buf[0], 0xC3, blen)

    # Fresh file holding the OLD body.
    ext4_unlink("FC.TXT")
    inum: uint32 = ext4_create_file(2, "FC.TXT", &ext4_fc_old_buf[0], blen)
    if inum == 0:
        printk0("[ext4-fc] FAIL: create FC.TXT\n")
        return -1
    if _ext4_read_back_eq(inum, &ext4_fc_old_buf[0], blen) == 0:
        printk0("[ext4-fc] FAIL: FC.TXT does not read back as OLD\n")
        return -1
    printk0("[ext4-fc] OK created FC.TXT with OLD body\n")

    # Capture the physical block backing logical block 0 (so the negative
    # control can read it raw).
    if ext4_read_inode(cast[uint64](inum), &ext4_fc_inode_buf[0]) != 0:
        printk0("[ext4-fc] FAIL: read FC.TXT inode\n")
        return -1
    phys0: uint64 = _ext4_logical_to_physical(&ext4_fc_inode_buf[0], 0)
    if phys0 == 0:
        printk0("[ext4-fc] FAIL: FC.TXT logical block 0 unmapped\n")
        return -1

    # --- Phase A: fast-commit the NEW body, then replay restores it ---
    if ext4_fc_begin() != 0:
        printk0("[ext4-fc] FAIL: fc_begin (A)\n")
        return -1
    if ext4_fc_add_inode(inum) != 0:
        printk0("[ext4-fc] FAIL: fc_add_inode (A)\n")
        return -1
    # Stage the NEW data block (full block; first `blen` bytes are NEW,
    # rest zero — matching how create_file zero-pads).
    _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
    memcpy(&ext4_blk_buf[0], &ext4_fc_new_buf[0], blen)
    if ext4_fc_add_data_block(inum, 0, &ext4_blk_buf[0]) != 0:
        printk0("[ext4-fc] FAIL: fc_add_data_block (A)\n")
        return -1
    if ext4_fc_commit(7) != 0:
        printk0("[ext4-fc] FAIL: fc_commit (A)\n")
        return -1
    # The fast path wrote ONLY the fc log; the file's real data block is
    # still OLD. Prove it (== the durable state right after the crash).
    if _ext4_read_back_eq(inum, &ext4_fc_old_buf[0], blen) == 0:
        printk0("[ext4-fc] FAIL: data changed before replay?!\n")
        return -1
    printk0("[ext4-fc] OK committed-but-unreplayed: file data still OLD\n")
    # Crash + remount: run replay. It must apply the NEW body.
    if _ext4_fc_replay() < 0:
        printk0("[ext4-fc] FAIL: replay (A) error\n")
        return -1
    if _ext4_read_back_eq(inum, &ext4_fc_new_buf[0], blen) == 0:
        printk0("[ext4-fc] FAIL: NEW body not restored after replay\n")
        return -1
    printk0("[ext4-fc] OK fast-commit survived crash (replay applied NEW)\n")

    # --- Phase B: a crc-corrupt fast-commit must be rejected ----------
    if ext4_fc_begin() != 0:
        printk0("[ext4-fc] FAIL: fc_begin (B)\n")
        return -1
    _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
    memcpy(&ext4_blk_buf[0], &ext4_fc_bad_buf[0], blen)
    if ext4_fc_add_data_block(inum, 0, &ext4_blk_buf[0]) != 0:
        printk0("[ext4-fc] FAIL: fc_add_data_block (B)\n")
        return -1
    if ext4_fc_commit(8) != 0:
        printk0("[ext4-fc] FAIL: fc_commit (B)\n")
        return -1
    # Corrupt the fc tail's crc on disk: flip a byte in the first fc
    # block (the stream/tail live within it for this small commit).
    fc_first: uint64 = jbd2_fc_first_lblk()
    if jbd2_fc_read(fc_first, &ext4_fc_io_buf[0]) != 0:
        printk0("[ext4-fc] FAIL: read fc block (B)\n")
        return -1
    # Flip a byte inside the recorded data payload so the crc no longer
    # matches the stored fc_crc.
    ext4_fc_io_buf[EXT4_FC_TL_BYTES + 24] = \
        ext4_fc_io_buf[EXT4_FC_TL_BYTES + 24] ^ 0xFF
    if jbd2_fc_write(fc_first, &ext4_fc_io_buf[0]) != 0:
        printk0("[ext4-fc] FAIL: write corrupt fc block (B)\n")
        return -1
    if _ext4_fc_replay() < 0:
        printk0("[ext4-fc] FAIL: replay (B) error\n")
        return -1
    # The corrupt commit must NOT have applied: the data block must still
    # hold the NEW body from Phase A, never the bad (0xC3) body.
    if _ext4_fc_replay_check_raw(phys0, &ext4_fc_new_buf[0], blen) == 0:
        printk0("[ext4-fc] FAIL: corrupt fast-commit was applied (no crc guard)\n")
        return -1
    printk0("[ext4-fc] OK corrupt fast-commit rejected by crc (data unchanged)\n")

    ext4_unlink("FC.TXT")
    printk0("[ext4-fc] PASS\n")
    return 0


def _ext4_fc_replay_check_raw(phys: uint64, expect: Ptr[uint8],
                              n: uint64) -> int32:
    # Read physical block `phys` directly from disk and compare its first
    # n bytes against expect. 1 on match, 0 otherwise.
    if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
        return 0
    i: uint64 = 0
    while i < n:
        if ext4_blk_buf[i] != expect[i]:
            return 0
        i = i + 1
    return 1


# --- #149 JBD2 crash-consistency self-test ------------------------
#
# Proves the journal actually makes the filesystem crash-consistent,
# not merely that "writes work". Gated by a sentinel so it only runs
# under scripts/test_ext4_journal.sh (ENABLE_EXT4_JOURNAL_TEST=1).
#
# It operates DIRECTLY on raw fs blocks (not files) so the assertions
# are about concrete on-disk block contents, immune to higher-level
# caching. It picks a scratch fs block well past the metadata + the
# tiny set of files mkfs planted, writes a known byte to it, then:
#
#   Phase A (committed survives crash): start a txn that rewrites the
#     scratch block to a new marker, COMMIT it to the journal, then
#     DELIBERATELY skip checkpoint (== power lost after commit). The
#     final fs block still holds the OLD marker at this point. Running
#     recovery must re-apply the journalled block, so the final fs
#     block ends up holding the NEW marker.
#
#   Phase B (torn rolls back): start a txn that would rewrite the block
#     to a THIRD marker, write descriptor+data but NO commit block
#     (== power lost mid-commit), then run recovery. Recovery must find
#     no commit block and DISCARD the txn — the final fs block must
#     still hold Phase A's NEW marker, never the third one.
#
#   Phase C: assert the JBD2 superblock magic actually read was
#     0xC03B3998 — proves we parsed a real journal.
#
# A scratch fs block that no file or metadata uses. The journalled
# images this test mints are >= 8 MiB with thousands of free blocks;
# a block in the 600s is data-area free space on every layout we mint.
EXT4_JTEST_SCRATCH_BLOCK: uint64 = 600

# Distinct markers so a stale buffer can't accidentally satisfy an
# assertion — each phase checks for a specific byte pattern.
def _ext4_jtest_fill(buf: Ptr[uint8], tag: uint8):
    _ext4_zero(buf, ext4_block_size)
    i: uint64 = 0
    while i < 16:
        buf[i] = tag
        i = i + 1


def _ext4_jtest_check(blk: uint64, tag: uint8) -> int32:
    # 1 if the first 16 bytes of fs block `blk` all equal `tag`.
    if _ext4_read_block(blk, &ext4_blk_buf[0]) != 0:
        return 0
    i: uint64 = 0
    while i < 16:
        if ext4_blk_buf[i] != tag:
            return 0
        i = i + 1
    return 1


def ext4_journal_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        return 0
    if ext4_journal_active() == 0:
        printk0("[ext4_journal] FAIL: no journal attached\n")
        return -1

    # Phase C first: prove we read a real JBD2 superblock.
    magic: uint32 = jbd2_super_magic_read()
    if magic != 0xC03B3998:
        printk1("[ext4_journal] FAIL: journal magic 0x%x != 0xC03B3998\n",
                cast[uint64](magic))
        return -1
    printk0("[ext4_journal] OK magic=0xC03B3998 (real JBD2 superblock parsed)\n")

    blk: uint64 = EXT4_JTEST_SCRATCH_BLOCK

    # Seed the scratch block with the OLD marker (0xA1) directly.
    _ext4_jtest_fill(&ext4_jtest_buf[0], 0xA1)
    if _ext4_write_block(blk, &ext4_jtest_buf[0]) != 0:
        printk0("[ext4_journal] FAIL: seed write\n")
        return -1
    if _ext4_jtest_check(blk, 0xA1) == 0:
        printk0("[ext4_journal] FAIL: seed readback\n")
        return -1

    # --- Phase A: committed transaction survives a crash -----------
    if jbd2_txn_begin() != 0:
        printk0("[ext4_journal] FAIL: txn_begin (A)\n")
        return -1
    _ext4_jtest_fill(&ext4_jtest_buf[0], 0xB2)        # NEW marker
    if jbd2_txn_add(blk, &ext4_jtest_buf[0]) != 0:
        printk0("[ext4_journal] FAIL: txn_add (A)\n")
        return -1
    if jbd2_txn_commit() != 0:
        printk0("[ext4_journal] FAIL: txn_commit (A)\n")
        return -1
    # Simulate the crash: commit landed in the journal, but checkpoint
    # NEVER ran. The final fs block must STILL hold the OLD marker.
    jbd2_txn_skip_checkpoint()
    if _ext4_jtest_check(blk, 0xA1) == 0:
        printk0("[ext4_journal] FAIL: block changed before checkpoint?!\n")
        return -1
    printk0("[ext4_journal] OK committed-but-uncheckpointed: fs block still OLD\n")
    # Recover. Replay must apply the journalled block to its final home.
    if jbd2_recover() < 0:
        printk0("[ext4_journal] FAIL: recover (A)\n")
        return -1
    if _ext4_jtest_check(blk, 0xB2) == 0:
        printk0("[ext4_journal] FAIL: committed txn NOT applied after replay\n")
        return -1
    printk0("[ext4_journal] OK committed txn survived crash (replay applied NEW)\n")

    # --- Phase B: torn (uncommitted) transaction rolls back --------
    if jbd2_txn_begin() != 0:
        printk0("[ext4_journal] FAIL: txn_begin (B)\n")
        return -1
    _ext4_jtest_fill(&ext4_jtest_buf[0], 0xC3)        # THIRD marker
    if jbd2_txn_add(blk, &ext4_jtest_buf[0]) != 0:
        printk0("[ext4_journal] FAIL: txn_add (B)\n")
        return -1
    # Write descriptor + data but NO commit block (torn / power loss).
    if jbd2_txn_commit_nocommitblk() != 0:
        printk0("[ext4_journal] FAIL: txn_commit_nocommitblk (B)\n")
        return -1
    # Recover. The torn txn has no commit block — it MUST be discarded.
    if jbd2_recover() < 0:
        printk0("[ext4_journal] FAIL: recover (B)\n")
        return -1
    if _ext4_jtest_check(blk, 0xC3) != 0:
        printk0("[ext4_journal] FAIL: torn txn WAS applied (no rollback)\n")
        return -1
    if _ext4_jtest_check(blk, 0xB2) == 0:
        printk0("[ext4_journal] FAIL: fs block corrupted after rollback\n")
        return -1
    printk0("[ext4_journal] OK torn txn rolled back (fs block unchanged)\n")

    printk0("[ext4_journal] PASS crash-consistency (commit survives, torn rolls back)\n")
    return 0


# --- multi-block directory self-test ------------------------------
#
# Proves the linear multi-block directory walk: a host-minted ext4
# image (scripts/test_ext4dir.sh) carries /bigdir populated with many
# short-named files so the directory inode spans several data blocks.
# Two extra files at root carry the ground truth this test asserts
# against, so the script and kernel never disagree on a hardcoded
# constant:
#
#   /bigdir-count.txt  — decimal count of regular files in /bigdir
#                        (one line). readdir must enumerate EXACTLY
#                        this many entries (excluding . and ..).
#   /bigdir-last.txt   — the NAME of a file that the host placed in
#                        the LAST data block of /bigdir; its payload is
#                        that same name. We resolve /bigdir/<thatname>
#                        by name (forcing the walk past block 0) and
#                        assert the bytes read back equal the name.
#
# A second pass also runs against /htreedir when the host built one
# with dir_index enabled (EXT4_INDEX_FL), proving htree-flagged dirs
# are walked by linear-leaf-scan rather than misread as linear.

ext4_dirmb_listbuf: Array[16384, uint8]
ext4_dirmb_namebuf: Array[256, uint8]
ext4_dirmb_readbuf: Array[256, uint8]


def _ext4_dirmb_parse_uint(buf: Ptr[uint8], n: uint64) -> uint64:
    # Parse a leading decimal integer out of buf[0..n]. Stops at the
    # first non-digit (newline, NUL, etc). Bounded by n.
    v: uint64 = 0
    i: uint64 = 0
    while i < n:
        c: uint8 = buf[i]
        if c < 48 or c > 57:
            break
        v = v * 10 + cast[uint64](c - 48)
        i = i + 1
    return v


def _ext4_dirmb_count_lines(buf: Ptr[uint8], n: uint64) -> uint64:
    # Count '\n'-terminated lines in buf[0..n].
    cnt: uint64 = 0
    i: uint64 = 0
    while i < n:
        if buf[i] == 10:
            cnt = cnt + 1
        i = i + 1
    return cnt


def _ext4_dirmb_nblocks_for(path: Ptr[char]) -> uint64:
    # How many data blocks the directory at `path` spans (0 on miss).
    dir_inum: uint32 = ext4_resolve_dir(path)
    if dir_inum == 0:
        return 0
    dnode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](dir_inum), &dnode[0]) != 0:
        return 0
    dsz: uint64 = cast[uint64](ext4_inode_size_lo(&dnode[0]))
    if dsz == 0:
        return 0
    return (dsz + ext4_block_size - 1) / ext4_block_size


def _ext4_dirmb_read_root_line(name: Ptr[char],
                               out: Ptr[uint8], cap: uint64) -> int64:
    # Read the file at root-relative `name` into out (NUL-terminated),
    # stripping a single trailing newline. Returns the trimmed length,
    # or -1 on miss.
    inum: uint32 = 0
    fsz: uint64 = 0
    if ext4_resolve_file(name, &inum, &fsz) == 0:
        return -1
    take: uint64 = fsz
    if take > cap - 1:
        take = cap - 1
    n: int64 = ext4_read_file(inum, 0, take, out)
    if n < 0:
        return -1
    ln: uint64 = cast[uint64](n)
    if ln > 0 and out[ln - 1] == 10:
        ln = ln - 1
    out[ln] = 0
    return cast[int64](ln)


def _ext4_dirmb_check_one(dirpath: Ptr[char], label: Ptr[char],
                          want_count: uint64,
                          last_name: Ptr[char],
                          last_len: uint64) -> int32:
    # Run the assertions for one populated directory. Returns 0 on
    # PASS, -1 on FAIL (with a printed reason).
    nblk: uint64 = _ext4_dirmb_nblocks_for(dirpath)
    if nblk < 3:
        printk2("[ext4dir] FAIL: %s spans only %d block(s), need >= 3\n",
                cast[uint64](cast[Ptr[uint8]](label)), nblk)
        return -1
    printk2("[ext4dir] %s spans %d data blocks\n",
            cast[uint64](cast[Ptr[uint8]](label)), nblk)

    # (a) readdir: enumerate ALL entries; count must match ground truth
    # (the host's count EXCLUDES . and .., so subtract 2).
    listed: int64 = ext4_listdir(dirpath, &ext4_dirmb_listbuf[0], 16384)
    if listed < 0:
        printk1("[ext4dir] FAIL: listdir rc=%d\n", cast[uint64](listed))
        return -1
    lines: uint64 = _ext4_dirmb_count_lines(&ext4_dirmb_listbuf[0],
                                            cast[uint64](listed))
    if lines < 2:
        printk0("[ext4dir] FAIL: readdir missing . / ..\n")
        return -1
    got: uint64 = lines - 2                     # drop '.' and '..'
    if got != want_count:
        printk2("[ext4dir] FAIL: readdir counted %d entries, want %d\n",
                got, want_count)
        return -1
    printk1("[ext4dir] readdir enumerated all %d files across every block\n",
            got)

    # (b) lookup: resolve the file the host placed in the LAST block by
    # name (forces the walk past block 0) and read its payload back.
    # Build the path "<dirpath>/<last_name>" in a scratch buffer.
    p: uint64 = 0
    dp: Ptr[uint8] = cast[Ptr[uint8]](dirpath)
    while dp[p] != 0 and p < 200:
        ext4_dirmb_namebuf[p] = dp[p]
        p = p + 1
    ext4_dirmb_namebuf[p] = 47                   # '/'
    p = p + 1
    k: uint64 = 0
    ln: Ptr[uint8] = cast[Ptr[uint8]](last_name)
    while k < last_len and p < 254:
        ext4_dirmb_namebuf[p] = ln[k]
        p = p + 1
        k = k + 1
    ext4_dirmb_namebuf[p] = 0

    inum: uint32 = 0
    fsz: uint64 = 0
    if ext4_resolve_file(cast[Ptr[char]](&ext4_dirmb_namebuf[0]),
                         &inum, &fsz) == 0:
        printk0("[ext4dir] FAIL: last-block file did not resolve by name\n")
        return -1
    rn: int64 = ext4_read_file(inum, 0, 255, &ext4_dirmb_readbuf[0])
    if rn < 0:
        printk0("[ext4dir] FAIL: last-block file read error\n")
        return -1
    rl: uint64 = cast[uint64](rn)
    # Payload on disk == the file's own name (the host wrote it so).
    if rl != last_len:
        printk2("[ext4dir] FAIL: last-block payload len %d != %d\n",
                rl, last_len)
        return -1
    j: uint64 = 0
    while j < last_len:
        if ext4_dirmb_readbuf[j] != ln[j]:
            printk0("[ext4dir] FAIL: last-block payload mismatch\n")
            return -1
        j = j + 1
    printk1("[ext4dir] last-block file resolved by name and read OK (%d bytes)\n",
            rl)
    return 0


def ext4_dirmb_selftest() -> int32:
    # Driven by /etc/ext4dir-test. Asserts multi-block linear directory
    # support against the host-minted image. Prints [ext4dir] PASS on
    # success; any FAIL line + non-PASS means the test script fails.
    if ext4_blockdev_slot < 0:
        printk0("[ext4dir] FAIL: ext4 not mounted\n")
        return -1

    # Ground truth for /bigdir (the must-have linear multi-block case).
    cbuf: Array[64, uint8]
    if _ext4_dirmb_read_root_line("bigdir-count.txt", &cbuf[0], 64) < 0:
        printk0("[ext4dir] FAIL: bigdir-count.txt missing\n")
        return -1
    want: uint64 = _ext4_dirmb_parse_uint(&cbuf[0], 64)
    lbuf: Array[64, uint8]
    llen: int64 = _ext4_dirmb_read_root_line("bigdir-last.txt", &lbuf[0], 64)
    if llen < 0:
        printk0("[ext4dir] FAIL: bigdir-last.txt missing\n")
        return -1

    if _ext4_dirmb_check_one("bigdir", "bigdir(linear)", want,
                             cast[Ptr[char]](&lbuf[0]),
                             cast[uint64](llen)) != 0:
        return -1

    # Optional second pass: an htree (dir_index) directory. Present only
    # when the host built /htreedir with -O dir_index. We require its
    # inode to actually carry EXT4_INDEX_FL, proving we walk a real
    # htree by linear-leaf-scan (not a coincidentally-linear dir).
    ht_inum: uint32 = ext4_resolve_dir("htreedir")
    if ht_inum != 0:
        htnode: Array[256, uint8]
        if ext4_read_inode(cast[uint64](ht_inum), &htnode[0]) == 0:
            if ext4_inode_is_htree_dir(&htnode[0]) != 0:
                printk0("[ext4dir] htreedir carries EXT4_INDEX_FL (htree)\n")
                hcbuf: Array[64, uint8]
                if _ext4_dirmb_read_root_line("htreedir-count.txt",
                                              &hcbuf[0], 64) >= 0:
                    hwant: uint64 = _ext4_dirmb_parse_uint(&hcbuf[0], 64)
                    hlbuf: Array[64, uint8]
                    hllen: int64 = _ext4_dirmb_read_root_line(
                        "htreedir-last.txt", &hlbuf[0], 64)
                    if hllen >= 0:
                        if _ext4_dirmb_check_one(
                                "htreedir", "htreedir(htree)", hwant,
                                cast[Ptr[char]](&hlbuf[0]),
                                cast[uint64](hllen)) != 0:
                            return -1
                        printk0("[ext4dir] htree-flagged dir walked by linear-leaf-scan OK\n")
            else:
                printk0("[ext4dir] note: htreedir present but not INDEX-flagged; skipping htree assertion\n")

    printk0("[ext4dir] PASS\n")
    return 0


# --- ext4 mkdir self-test -----------------------------------------
#
# Driven by /etc/ext4-mkdir-test (planted by scripts/test_ext4_mkdir.sh).
# Proves the WIRED mkdir path: vfs_mkdir → ext4_mkdir_live creates a real
# on-disk directory entry on the live ext4 mount. The test mkdir's a fresh
# directory in the partition root, then re-reads the parent directory and
# confirms the new entry exists carrying EXT4_FT_DIR (file_type 2). Prints
# exactly one [ext4-mkdir] PASS on success, [ext4-mkdir] FAIL ... otherwise.

def ext4_mkdir_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-mkdir] FAIL: ext4 not mounted\n")
        return -1
    # New directory's basename. ext4_mkdir_live takes a partition-relative
    # path (no /ext prefix), so a bare leaf lands in the root dir (inum 2).
    new_dir: Ptr[char] = "mkdir-selftest-dir"
    # It must NOT already exist — assert the precondition so a stale image
    # doesn't mask a regression (mkdir would return -EEXIST and we'd never
    # exercise the create path).
    pre_inum:  uint32 = 0
    pre_ftype: uint8  = 0
    pre: int32 = _ext4_dir_find_entry(2, new_dir, &pre_inum, &pre_ftype)
    if pre < 0:
        printk0("[ext4-mkdir] FAIL: parent dir read error\n")
        return -1
    if pre != 0:
        printk0("[ext4-mkdir] FAIL: target already exists pre-mkdir\n")
        return -1
    # The wired create path.
    rc: int32 = ext4_mkdir_live(new_dir)
    if rc != 0:
        printk1("[ext4-mkdir] FAIL: ext4_mkdir_live rc=%d\n",
                cast[uint64](cast[int64](rc)))
        return -1
    # Re-read the parent directory and confirm the new entry is present
    # AND typed as a directory (EXT4_FT_DIR = 2).
    post_inum:  uint32 = 0
    post_ftype: uint8  = 0
    post: int32 = _ext4_dir_find_entry(2, new_dir, &post_inum, &post_ftype)
    if post != 1:
        printk0("[ext4-mkdir] FAIL: new entry not found after mkdir\n")
        return -1
    if post_inum == 0:
        printk0("[ext4-mkdir] FAIL: new entry has null inum\n")
        return -1
    if post_ftype != 2:
        printk1("[ext4-mkdir] FAIL: new entry not DIR-typed ftype=%d\n",
                cast[uint64](post_ftype))
        return -1
    # Sanity: the new dir's own inode must report S_IFDIR in i_mode.
    nbuf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](post_inum), &nbuf[0]) != 0:
        printk0("[ext4-mkdir] FAIL: cannot read new dir inode\n")
        return -1
    nmode: uint16 = ext4_inode_mode(&nbuf[0])
    if (nmode & 0xF000) != 0x4000:
        printk1("[ext4-mkdir] FAIL: new dir inode not S_IFDIR mode=%x\n",
                cast[uint64](nmode))
        return -1
    printk0("[ext4-mkdir] PASS\n")
    return 0


# --- ext4 cross-directory directory-rename self-test --------------
#
# Driven by /etc/ext4dirrename-test (planted by
# scripts/test_ext4_dirrename.sh). Exercises the directory-move leg of
# ext4_rename: moving a sub-directory to a DIFFERENT parent must
#   (1) rewrite the moved dir's ".." to point at the new parent inode,
#   (2) DECREMENT the old parent's i_links_count (its child's ".."
#       backlink left it), and
#   (3) INCREMENT the new parent's i_links_count (the backlink joined
#       it), while leaving the moved dir's own i_links_count unchanged.
# It also asserts the negative: a SAME-parent rename (just a name
# change) must touch neither parent's link count nor the moved dir's
# "..". The on-disk ".." rewrite is read back through
# _ext4_dir_find_entry, and the link counts through the raw inode.
#
# Prints [ext4-dirrename] PASS on success, [ext4-dirrename] FAIL ...
# on any mismatch. Cleans up its scratch directories on success.

def _ext4_inode_links(inum: uint32) -> int32:
    # Read directory/file inode `inum` and return its i_links_count
    # (offset 0x1A). Returns -1 on read error.
    libuf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &libuf[0]) != 0:
        return -1
    return cast[int32](cast[uint64](_ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](&libuf[0]) + 0x1A))))


def ext4_dirrename_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-dirrename] FAIL: ext4 not mounted\n")
        return -1

    # Build RDA/, RDB/, and RDA/MOVED on the live mount.
    if ext4_mkdir_live("RDA") != 0:
        printk0("[ext4-dirrename] FAIL: mkdir RDA\n")
        return -1
    if ext4_mkdir_live("RDB") != 0:
        printk0("[ext4-dirrename] FAIL: mkdir RDB\n")
        return -1
    if ext4_mkdir_live("RDA/MOVED") != 0:
        printk0("[ext4-dirrename] FAIL: mkdir RDA/MOVED\n")
        return -1

    a_inum: uint32 = ext4_resolve_dir("RDA")
    b_inum: uint32 = ext4_resolve_dir("RDB")
    sub_inum: uint32 = ext4_resolve_dir("RDA/MOVED")
    if a_inum == 0 or b_inum == 0 or sub_inum == 0:
        printk0("[ext4-dirrename] FAIL: resolve RDA/RDB/MOVED\n")
        return -1

    # Snapshot pre-move link counts and the moved dir's "..".
    a_pre: int32 = _ext4_inode_links(a_inum)
    b_pre: int32 = _ext4_inode_links(b_inum)
    sub_pre: int32 = _ext4_inode_links(sub_inum)
    if a_pre < 0 or b_pre < 0 or sub_pre < 0:
        printk0("[ext4-dirrename] FAIL: read pre-move link counts\n")
        return -1
    pp_pre: uint32 = 0
    pf_pre: uint8  = 0
    pre_fr: int32 = _ext4_dir_find_entry(cast[uint64](sub_inum), "..",
                                         &pp_pre, &pf_pre)
    if pre_fr <= 0:
        printk0("[ext4-dirrename] FAIL: pre-move .. not found\n")
        return -1
    if pp_pre != a_inum:
        printk0("[ext4-dirrename] FAIL: pre-move .. != RDA\n")
        return -1

    # --- Cross-directory move: RDA/MOVED -> RDB/MOVED ---
    if ext4_rename("RDA/MOVED", "RDB/MOVED") != 0:
        printk0("[ext4-dirrename] FAIL: rename RDA/MOVED -> RDB/MOVED\n")
        return -1

    # Moved dir must resolve under its new path to the SAME inode and be
    # gone from the old path.
    moved_inum: uint32 = ext4_resolve_dir("RDB/MOVED")
    if moved_inum == 0:
        printk0("[ext4-dirrename] FAIL: moved dir missing at new path\n")
        return -1
    if moved_inum != sub_inum:
        printk0("[ext4-dirrename] FAIL: moved dir inode changed\n")
        return -1
    if ext4_resolve_dir("RDA/MOVED") != 0:
        printk0("[ext4-dirrename] FAIL: old RDA/MOVED still resolves\n")
        return -1

    # (1) The moved dir's ".." must now point at RDB.
    pp_post: uint32 = 0
    pf_post: uint8  = 0
    if _ext4_dir_find_entry(cast[uint64](moved_inum), "..",
                            &pp_post, &pf_post) <= 0:
        printk0("[ext4-dirrename] FAIL: post-move .. missing\n")
        return -1
    if pp_post != b_inum:
        printk0("[ext4-dirrename] FAIL: post-move .. != RDB\n")
        return -1

    # (2)+(3) Link-count rebalance: RDA loses one, RDB gains one, the
    # moved dir's own count is unchanged.
    a_post: int32 = _ext4_inode_links(a_inum)
    b_post: int32 = _ext4_inode_links(b_inum)
    sub_post: int32 = _ext4_inode_links(sub_inum)
    if a_post < 0 or b_post < 0 or sub_post < 0:
        printk0("[ext4-dirrename] FAIL: read post-move link counts\n")
        return -1
    if a_post != a_pre - 1:
        printk1("[ext4-dirrename] FAIL: old parent links not -1 (%d)\n",
                cast[uint64](cast[int64](a_post)))
        return -1
    if b_post != b_pre + 1:
        printk1("[ext4-dirrename] FAIL: new parent links not +1 (%d)\n",
                cast[uint64](cast[int64](b_post)))
        return -1
    if sub_post != sub_pre:
        printk1("[ext4-dirrename] FAIL: moved dir links changed (%d)\n",
                cast[uint64](cast[int64](sub_post)))
        return -1

    # --- Negative case: SAME-parent rename must NOT touch link counts
    # nor the moved dir's "..". Rename RDB/MOVED -> RDB/RENAMED. ---
    bn_pre: int32 = _ext4_inode_links(b_inum)
    if ext4_rename("RDB/MOVED", "RDB/RENAMED") != 0:
        printk0("[ext4-dirrename] FAIL: same-dir rename op\n")
        return -1
    same_inum: uint32 = ext4_resolve_dir("RDB/RENAMED")
    if same_inum == 0:
        printk0("[ext4-dirrename] FAIL: renamed dir missing\n")
        return -1
    if same_inum != sub_inum:
        printk0("[ext4-dirrename] FAIL: renamed dir inode changed\n")
        return -1
    bn_post: int32 = _ext4_inode_links(b_inum)
    if bn_post != bn_pre:
        printk1("[ext4-dirrename] FAIL: same-dir rename moved links (%d)\n",
                cast[uint64](cast[int64](bn_post)))
        return -1
    # ".." must STILL point at RDB (untouched by a same-parent rename).
    pp_same: uint32 = 0
    pf_same: uint8  = 0
    same_fr: int32 = _ext4_dir_find_entry(cast[uint64](same_inum), "..",
                                          &pp_same, &pf_same)
    if same_fr <= 0:
        printk0("[ext4-dirrename] FAIL: same-dir rename lost ..\n")
        return -1
    if pp_same != b_inum:
        printk0("[ext4-dirrename] FAIL: same-dir rename perturbed ..\n")
        return -1

    # Tear down: rmdir the moved dir, then both parents.
    ext4_rmdir("RDB/RENAMED")
    ext4_rmdir("RDA")
    ext4_rmdir("RDB")
    printk0("[ext4-dirrename] PASS\n")
    return 0


# --- ext4 slow-symlink self-test ----------------------------------
#
# Driven by /etc/ext4-symlink-test (planted by
# scripts/test_ext4_symlink.sh). Creates two symlinks on the LIVE ext4
# mount via ext4_create_symlink:
#   1. a SHORT target (<=60 bytes) — exercises the fast inline path
#      (target stored in i_block, i_blocks_lo=0).
#   2. a LONG target (>60 bytes, ~120 chars) — exercises the slow path
#      (one data block allocated, recorded as a depth-0 extent, target
#      bytes in the block).
# Each is read back through _ext4_read_symlink_target (the same extent →
# physical → read pipeline a file read uses for the slow case, inline
# memcpy for the fast case) and compared byte-for-byte against what was
# written. Prints [ext4-symlink] PASS or [ext4-symlink] FAIL ...

# Read-back scratch for a symlink target (NUL-terminated by the reader).
ext4_symtest_buf: Array[512, uint8]


def _ext4_symtest_cmp(out_buf: Ptr[uint8], want: Ptr[char],
                      wlen: uint64) -> int32:
    # Byte-for-byte compare `wlen` bytes of out_buf against want, and
    # require out_buf[wlen] == 0 (the reader's NUL terminator). Returns
    # 0 on match, -1 on mismatch.
    i: uint64 = 0
    while i < wlen:
        if out_buf[i] != cast[uint8](want[i]):
            return -1
        i = i + 1
    if out_buf[wlen] != 0:
        return -1
    return 0


def _ext4_symtest_one(name: Ptr[char], target: Ptr[char]) -> int32:
    # Create one symlink (name → target) in the ext4 root (inum 2),
    # resolve the dirent back to an inode, read the target, and compare.
    # Returns 0 on success, -1 on any failure (caller prints the FAIL).
    tlen: uint64 = _ext4_strlen(target)
    # The target must NOT already exist (a stale image would mask a
    # regression — create would still succeed but we want a clean run).
    pre_inum:  uint32 = 0
    pre_ftype: uint8  = 0
    pre: int32 = _ext4_dir_find_entry(2, name, &pre_inum, &pre_ftype)
    if pre != 0:
        printk0("[ext4-symlink] FAIL: link name already exists\n")
        return -1
    new_inum: uint32 = ext4_create_symlink(2, name, target)
    if new_inum == 0:
        printk0("[ext4-symlink] FAIL: ext4_create_symlink returned 0\n")
        return -1
    # Re-resolve the dirent to confirm it was inserted SYMLINK-typed
    # (EXT4_FT_SYMLINK = 7) and points at our new inode.
    got_inum:  uint32 = 0
    got_ftype: uint8  = 0
    got: int32 = _ext4_dir_find_entry(2, name, &got_inum, &got_ftype)
    if got != 1:
        printk0("[ext4-symlink] FAIL: dirent not found after create\n")
        return -1
    if got_inum != new_inum:
        printk0("[ext4-symlink] FAIL: dirent inum mismatch\n")
        return -1
    if got_ftype != 7:
        printk1("[ext4-symlink] FAIL: dirent not SYMLINK ftype=%d\n",
                cast[uint64](got_ftype))
        return -1
    # Read the inode back from disk and pull the target out.
    ibuf: Array[256, uint8]
    if ext4_read_inode(cast[uint64](new_inum), &ibuf[0]) != 0:
        printk0("[ext4-symlink] FAIL: cannot read symlink inode\n")
        return -1
    # i_mode must be S_IFLNK (0xA000).
    smode: uint16 = ext4_inode_mode(&ibuf[0])
    if (smode & 0xF000) != 0xA000:
        printk1("[ext4-symlink] FAIL: inode not S_IFLNK mode=%x\n",
                cast[uint64](smode))
        return -1
    # i_size_lo must equal the target length.
    isize: uint64 = cast[uint64](ext4_inode_size_lo(&ibuf[0]))
    if isize != tlen:
        printk2("[ext4-symlink] FAIL: i_size=%d want=%d\n",
                isize, tlen)
        return -1
    if _ext4_read_symlink_target(&ibuf[0], &ext4_symtest_buf[0],
                                 512) != 0:
        printk0("[ext4-symlink] FAIL: read_symlink_target failed\n")
        return -1
    if _ext4_symtest_cmp(&ext4_symtest_buf[0], target, tlen) != 0:
        printk0("[ext4-symlink] FAIL: target byte mismatch\n")
        return -1
    return 0


def ext4_symlink_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-symlink] FAIL: ext4 not mounted\n")
        return -1
    # Short (<=60-byte) target — fast inline path.
    short_name:   Ptr[char] = "symtest-fast"
    short_target: Ptr[char] = "/dev/null"
    if _ext4_symtest_one(short_name, short_target) != 0:
        return -1
    printk0("[ext4-symlink] fast (inline) link verified\n")
    # Long (>60-byte) target — slow path (data block + extent).
    # 120 chars, well past the 60-byte inline cap and within one block.
    long_name:   Ptr[char] = "symtest-slow"
    long_target: Ptr[char] = "/very/long/symlink/target/path/that/exceeds/sixty/bytes/so/it/forces/the/slow/symlink/data/block/path/in/the/ext4/filesystem/ok"
    if _ext4_symtest_one(long_name, long_target) != 0:
        return -1
    printk0("[ext4-symlink] slow (data-block) link verified\n")
    printk0("[ext4-symlink] PASS\n")
    return 0


# --- ext4 extent-index-node self-test (eh_depth > 0) --------------
#
# Driven by /etc/ext4idx-test (planted by scripts/test_ext4idx.sh).
# Builds a file LARGE/FRAGMENTED enough that its 4 inline extent slots
# overflow, forcing the inode to a depth-1 INDEX node. Proves the
# write/grow path promotes to depth 1, the read path walks the index
# tree to map every logical block, and the truncate path frees the
# index + leaf + data blocks (folding the tree back to inline). Prints
# [ext4idx] lines + exactly one [ext4idx] PASS.

# Number of (deliberately non-contiguous) one-block extents the test
# appends. 100 exceeds both the 4 inline slots (forcing depth 1) AND
# one 1 KiB on-disk leaf block's capacity (84 records/leaf), so a SECOND
# leaf + index record is forced too — exercising the "rightmost leaf
# full → allocate a new leaf and a new index record" growth path.
EXT4IDX_NBLOCKS: uint64 = 100

# Spacer blocks kept allocated between data blocks so consecutive data
# blocks are NEVER physically contiguous (defeating extent coalescing,
# guaranteeing one extent per data block → forced index node). Freed at
# the end of the test.
ext4idx_spacers: Array[100, uint64]

# Verify scratch for one fs block of read-back data.
ext4idx_vbuf: Array[4096, uint8]


def _ext4idx_pattern_byte(lblk: uint64, off: uint64) -> uint8:
    # Deterministic per-(logical-block, offset) pattern byte so a
    # read-back can verify the EXACT block landed at the EXACT logical
    # position (catches an index walk that maps a block wrong).
    return cast[uint8](((lblk * 131 + off * 7 + 0x5A) & 0xFF))


def _ext4idx_make_empty_file(name: Ptr[char]) -> uint32:
    # Create an empty regular file (depth-0 leaf, eh_entries=0) in the
    # root dir and return its inum (0 on failure). No data block is
    # allocated — the test's appends do that.
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        return 0
    p: Ptr[uint8] = &ext4_new_inode_buf[0]
    _ext4_zero(p, ext4_inode_size)
    _ext4_write_u16(p, 0x81B4)                          # i_mode IFREG|0664
    _ext4_inode_stamp_creator(p)
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4), 0)   # i_size=0
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26), 1)  # links=1
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28), 0)  # i_blocks=0
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32),
                    0x80000)                            # EXT4_EXTENTS_FL
    eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)        # eh_entries=0
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)        # eh_max=4
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)        # eh_depth=0
    _ext4_stamp_all_times(p)
    if ext4_write_inode(cast[uint64](new_inum), p) != 0:
        ext4_free_inode(new_inum)
        return 0
    if ext4_dir_insert(2, name, new_inum, 1) != 0:
        ext4_free_inode(new_inum)
        return 0
    return new_inum


def ext4_extentidx_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4idx] FAIL: ext4 not mounted\n")
        return -1
    printk1("[ext4idx] block_size=%d\n", ext4_block_size)

    inum: uint32 = _ext4idx_make_empty_file("ext4idx.bin")
    if inum == 0:
        printk0("[ext4idx] FAIL: create empty file\n")
        return -1

    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4idx] FAIL: read inode after create\n")
        return -1

    # Append EXT4IDX_NBLOCKS deliberately non-contiguous one-block
    # extents. For each logical block: alloc a data block, alloc a
    # spacer (kept) so the NEXT data block can't be contiguous, fill the
    # data block with a per-block pattern, and append it to the tree.
    lb: uint64 = 0
    while lb < EXT4IDX_NBLOCKS:
        db: uint64 = ext4_alloc_block()
        if db == 0:
            printk0("[ext4idx] FAIL: out of data blocks\n")
            return -1
        sp: uint64 = ext4_alloc_block()        # spacer (kept until end)
        ext4idx_spacers[lb] = sp
        # Fill the data block with its pattern.
        o: uint64 = 0
        while o < ext4_block_size:
            ext4idx_vbuf[o] = _ext4idx_pattern_byte(lb, o)
            o = o + 1
        if _ext4_write_block(db, &ext4idx_vbuf[0]) != 0:
            printk0("[ext4idx] FAIL: write data block\n")
            return -1
        if _ext4_extent_append_block(&inode[0], lb, db) != 0:
            printk1("[ext4idx] FAIL: append block at lblk=%d\n", lb)
            return -1
        lb = lb + 1

    # Commit the inode (size + extents). i_size = NBLOCKS full blocks.
    fsize: uint64 = EXT4IDX_NBLOCKS * ext4_block_size
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                    cast[uint32](fsize))
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4idx] FAIL: write inode after grow\n")
        return -1

    # Re-read the inode from disk and assert it became a depth-1 index
    # node (the whole point — > 4 fragmented extents can't fit inline).
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4idx] FAIL: re-read inode\n")
        return -1
    depth: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    idx_ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_ENTRIES_OFFSET))
    if depth != 1:
        printk1("[ext4idx] FAIL: expected depth=1 got %d\n",
                cast[uint64](depth))
        return -1
    # 100 fragmented blocks overflow one 1 KiB leaf (84 records), so the
    # tree MUST hold >= 2 index records — proving the multi-leaf growth
    # path (rightmost-leaf-full → new leaf + new index record) ran.
    if idx_ent < 2:
        printk1("[ext4idx] FAIL: expected >=2 index records got %d\n",
                cast[uint64](idx_ent))
        return -1
    printk2("[ext4idx] forced index node: eh_depth=%d index_records=%d\n",
            cast[uint64](depth), cast[uint64](idx_ent))

    # Read EVERY block back through ext4_read_file (which walks the
    # index tree) and verify the pattern, proving each logical block
    # maps to the right physical block.
    vb: uint64 = 0
    while vb < EXT4IDX_NBLOCKS:
        n: int64 = ext4_read_file(inum, vb * ext4_block_size,
                                  ext4_block_size, &ext4idx_vbuf[0])
        if n != cast[int64](ext4_block_size):
            printk1("[ext4idx] FAIL: short read at lblk=%d\n", vb)
            return -1
        o: uint64 = 0
        while o < ext4_block_size:
            if ext4idx_vbuf[o] != _ext4idx_pattern_byte(vb, o):
                printk2("[ext4idx] FAIL: byte mismatch lblk=%d off=%d\n",
                        vb, o)
                return -1
            o = o + 1
        vb = vb + 1
    printk1("[ext4idx] read-back verified %d blocks through index walk\n",
            EXT4IDX_NBLOCKS)

    # Truncate the file to 0 and assert the tree folds back to an empty
    # inline depth-0 leaf (index + leaf + data blocks freed).
    if ext4_truncate_inode(inum, 0) != 0:
        printk0("[ext4idx] FAIL: truncate to 0\n")
        return -1
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4idx] FAIL: re-read inode after truncate\n")
        return -1
    tdepth: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    tent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_ENTRIES_OFFSET))
    if tdepth != 0 or tent != 0:
        printk2("[ext4idx] FAIL: after truncate depth=%d entries=%d\n",
                cast[uint64](tdepth), cast[uint64](tent))
        return -1
    # A read past EOF now returns 0 bytes.
    if ext4_read_file(inum, 0, ext4_block_size, &ext4idx_vbuf[0]) != 0:
        printk0("[ext4idx] FAIL: read after truncate returned data\n")
        return -1
    printk0("[ext4idx] truncate freed index+leaf+data; tree folded to depth 0\n")

    # Clean up: free spacer blocks + the file inode, tombstone its
    # dirent so the root-dir entry count other tests assert stays sane.
    s: uint64 = 0
    while s < EXT4IDX_NBLOCKS:
        if ext4idx_spacers[s] != 0:
            ext4_free_block(ext4idx_spacers[s])
            ext4idx_spacers[s] = 0
        s = s + 1
    ext4_unlink("ext4idx.bin")

    printk0("[ext4idx] PASS\n")
    return 0


# --- ext4 DEPTH-2 extent-tree self-test ---------------------------
#
# Driven by /etc/ext4d2-test (planted by scripts/test_ext4d2.sh). Builds a
# file LARGE/FRAGMENTED enough that it overflows the depth-1 capacity (the
# inode's 4 index slots, each pointing at one leaf block of `leaf_max`
# extents) and the inode is promoted to a DEPTH-2 index tree: the inode's
# index records point at INTERMEDIATE index blocks, which point at leaf
# blocks. Proves:
#   * the write/grow path promotes depth-1 → depth-2 and keeps growing;
#   * the read path walks idx → idx → leaf to map every logical block;
#   * the truncate path frees intermediate-index + leaf + data blocks,
#     folding the tree back when it collapses.
# Prints [ext4d2] lines + exactly one [ext4d2] PASS.
#
# Capacity (1 KiB blocks): leaf/idx records = (1024-12)/12 = 84; inode idx
# slots = 4 → depth-1 holds at most 4×84 = 336 fragmented blocks. 400
# fragmented blocks therefore FORCE depth 2 (and a second intermediate
# index record, since one intermediate block holds 84 leaf pointers ×
# 84 extents = far more, but the inode's 4-slot promotion is the trigger).
EXT4D2_NBLOCKS: uint64 = 400

# Spacer blocks kept allocated between data blocks so no two data blocks
# are physically contiguous (defeats coalescing → one extent per block →
# forces the deep tree). Freed at the end of the test.
ext4d2_spacers: Array[400, uint64]

# Verify scratch for one fs block of read-back data.
ext4d2_vbuf: Array[4096, uint8]


def ext4_extentd2_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4d2] FAIL: ext4 not mounted\n")
        return -1
    printk1("[ext4d2] block_size=%d\n", ext4_block_size)
    leaf_max: uint64 = _ext4_leaf_block_max(ext4_block_size)
    printk1("[ext4d2] leaf/idx records per block=%d\n", leaf_max)

    inum: uint32 = _ext4idx_make_empty_file("ext4d2.bin")
    if inum == 0:
        printk0("[ext4d2] FAIL: create empty file\n")
        return -1

    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4d2] FAIL: read inode after create\n")
        return -1

    # Append EXT4D2_NBLOCKS deliberately non-contiguous one-block extents.
    # For each logical block: alloc a data block, alloc a spacer (kept) so
    # the NEXT data block can't be contiguous, fill with a per-block
    # pattern, and append it to the tree.
    lb: uint64 = 0
    while lb < EXT4D2_NBLOCKS:
        db: uint64 = ext4_alloc_block()
        if db == 0:
            printk1("[ext4d2] FAIL: out of data blocks at lblk=%d\n", lb)
            return -1
        sp: uint64 = ext4_alloc_block()        # spacer (kept until end)
        ext4d2_spacers[lb] = sp
        o: uint64 = 0
        while o < ext4_block_size:
            ext4d2_vbuf[o] = _ext4idx_pattern_byte(lb, o)
            o = o + 1
        if _ext4_write_block(db, &ext4d2_vbuf[0]) != 0:
            printk0("[ext4d2] FAIL: write data block\n")
            return -1
        if _ext4_extent_append_block(&inode[0], lb, db) != 0:
            printk1("[ext4d2] FAIL: append block at lblk=%d\n", lb)
            return -1
        lb = lb + 1

    # Commit the inode (size + extents). i_size = NBLOCKS full blocks.
    fsize: uint64 = EXT4D2_NBLOCKS * ext4_block_size
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                    cast[uint32](fsize))
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4d2] FAIL: write inode after grow\n")
        return -1

    # Re-read from disk and assert eh_depth==2 — the whole point.
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4d2] FAIL: re-read inode\n")
        return -1
    depth: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    in_ent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_ENTRIES_OFFSET))
    if depth != 2:
        printk1("[ext4d2] FAIL: expected eh_depth=2 got %d\n",
                cast[uint64](depth))
        return -1
    printk2("[ext4d2] forced depth-2 tree: eh_depth=%d inode_index_records=%d\n",
            cast[uint64](depth), cast[uint64](in_ent))

    # Read EVERY block back through ext4_read_file (which walks idx → idx →
    # leaf) and verify the pattern — proving each logical block maps to the
    # right physical block through the two index levels.
    vb: uint64 = 0
    while vb < EXT4D2_NBLOCKS:
        n: int64 = ext4_read_file(inum, vb * ext4_block_size,
                                  ext4_block_size, &ext4d2_vbuf[0])
        if n != cast[int64](ext4_block_size):
            printk1("[ext4d2] FAIL: short read at lblk=%d\n", vb)
            return -1
        o: uint64 = 0
        while o < ext4_block_size:
            if ext4d2_vbuf[o] != _ext4idx_pattern_byte(vb, o):
                printk2("[ext4d2] FAIL: byte mismatch lblk=%d off=%d\n",
                        vb, o)
                return -1
            o = o + 1
        vb = vb + 1
    printk1("[ext4d2] read-back verified %d blocks through depth-2 walk\n",
            EXT4D2_NBLOCKS)

    # PARTIAL truncate: shrink to half the blocks. This exercises the
    # depth-2 trim path freeing whole intermediate blocks + leaves and
    # re-keying surviving records, WITHOUT fully collapsing the tree.
    half: uint64 = (EXT4D2_NBLOCKS / 2) * ext4_block_size
    if ext4_truncate_inode(inum, half) != 0:
        printk0("[ext4d2] FAIL: partial truncate\n")
        return -1
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4d2] FAIL: re-read after partial truncate\n")
        return -1
    if cast[uint64](ext4_inode_size_lo(&inode[0])) != half:
        printk0("[ext4d2] FAIL: i_size wrong after partial truncate\n")
        return -1
    # Surviving blocks must still read back correctly through the (still
    # possibly deep) tree; the block just past the cut must read 0 (EOF).
    hb: uint64 = (EXT4D2_NBLOCKS / 2) - 1
    if ext4_read_file(inum, hb * ext4_block_size,
                      ext4_block_size, &ext4d2_vbuf[0]) \
            != cast[int64](ext4_block_size):
        printk0("[ext4d2] FAIL: short read of last surviving block\n")
        return -1
    o2: uint64 = 0
    while o2 < ext4_block_size:
        if ext4d2_vbuf[o2] != _ext4idx_pattern_byte(hb, o2):
            printk0("[ext4d2] FAIL: surviving block corrupt after trim\n")
            return -1
        o2 = o2 + 1
    if ext4_read_file(inum, half, ext4_block_size, &ext4d2_vbuf[0]) != 0:
        printk0("[ext4d2] FAIL: read past partial-trunc EOF returned data\n")
        return -1
    printk1("[ext4d2] partial truncate to %d blocks verified\n",
            EXT4D2_NBLOCKS / 2)

    # FULL truncate to 0 and assert the tree folds back to an empty inline
    # depth-0 leaf (all intermediate-index + leaf + data blocks freed).
    if ext4_truncate_inode(inum, 0) != 0:
        printk0("[ext4d2] FAIL: truncate to 0\n")
        return -1
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4d2] FAIL: re-read inode after truncate\n")
        return -1
    tdepth: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    tent: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_ENTRIES_OFFSET))
    if tdepth != 0 or tent != 0:
        printk2("[ext4d2] FAIL: after truncate depth=%d entries=%d\n",
                cast[uint64](tdepth), cast[uint64](tent))
        return -1
    if ext4_read_file(inum, 0, ext4_block_size, &ext4d2_vbuf[0]) != 0:
        printk0("[ext4d2] FAIL: read after truncate returned data\n")
        return -1
    printk0("[ext4d2] truncate freed idx+idx+leaf+data; tree folded to depth 0\n")

    # Clean up: free spacer blocks + the file, tombstone its dirent.
    s: uint64 = 0
    while s < EXT4D2_NBLOCKS:
        if ext4d2_spacers[s] != 0:
            ext4_free_block(ext4d2_spacers[s])
            ext4d2_spacers[s] = 0
        s = s + 1
    ext4_unlink("ext4d2.bin")

    printk0("[ext4d2] PASS\n")
    return 0


# --- ext4 extent-FREE / no-leak + depth-3 self-test ----------------
#
# Driven by /etc/ext4extfree-test (planted by scripts/test_ext4_extent_free.sh).
# Two parts:
#
#   PART A (the no-leak proof for gap #1): record the filesystem's
#   free-block count (clear bits across every group bitmap — the same
#   bits ext4_alloc_block/ext4_free_block flip), write a multi-block
#   FRAGMENTED file spanning several extents (forcing a depth-1 index
#   tree so interior leaf/index metadata blocks exist), read it back
#   byte-exact, ext4_unlink() it, and assert the free-block count returns
#   EXACTLY to its pre-write value. A non-zero delta means ext4_unlink
#   leaked data and/or index/leaf metadata blocks.
#
#   PART B (depth-3 round-trip): build a depth-2 tree, promote it to
#   depth 3 via _ext4_extent_promote_to_depth3, append more fragmented
#   blocks through _ext4_extent_append_depth3, read every block back
#   byte-exact through the generic index walk, then truncate to 0
#   (exercising _ext4_extent_trim_depth3, which frees L2 + L1 + leaf +
#   data blocks) and again assert the free-block count round-trips.
#
# Prints [ext4-extent] lines + exactly one [ext4-extent] PASS.

# A modest fragmented file: 40 one-block extents (> 4 inline slots →
# forces a depth-1 index node, and >1 on-disk leaf at 84 records/leaf is
# not required for PART A — the point is interior metadata + multi-extent
# data that must ALL be reclaimed).
EXT4EF_NBLOCKS: uint64 = 40

# PART B sizes: 400 fragmented blocks force depth 2 (same trigger as the
# d2 test), then we promote to depth 3 and append 120 more — enough to
# fill the rightmost leaf (84 records) and force at least one fresh leaf
# under the depth-3 append path.
EXT4EF_D2_NBLOCKS:  uint64 = 400
EXT4EF_D3_EXTRA:    uint64 = 120

# Spacer blocks kept allocated between data blocks so consecutive data
# blocks are never physically contiguous (defeats coalescing → one extent
# per block). Freed before each free-count comparison.
ext4ef_spacers: Array[600, uint64]
ext4ef_vbuf: Array[4096, uint8]


def _ext4_count_free_blocks() -> uint64:
    # Count clear (free) bits across every group's block bitmap — i.e. the
    # number of free data blocks the allocator can hand out. This is the
    # exact resource ext4_alloc_block consumes and ext4_free_block returns,
    # so it is the authoritative measure for a "no block leaked" assertion.
    # Trashes ext4_bitmap_buf and ext4_blk_buf (via the group-desc read).
    if ext4_blockdev_slot < 0:
        return 0
    if ext4_blocks_per_grp == 0:
        return 0
    ngroups: uint64 = _ext4_num_groups()
    # Bits of a group's bitmap that carry real allocation bits. The bitmap
    # is per-CLUSTER (per-block when bigalloc is off, where
    # clusters_per_grp==blocks_per_grp), so each clear bit is one free
    # cluster — the exact unit ext4_alloc_block/ext4_free_block move.
    nbytes: uint64 = ext4_block_size
    if nbytes > ext4_clusters_per_grp / 8:
        nbytes = ext4_clusters_per_grp / 8
    total_free: uint64 = 0
    g: uint64 = 0
    while g < ngroups:
        bm_block: uint32 = _ext4_group_desc_field_u32(g, 0)
        if bm_block != 0:
            if _ext4_read_block(cast[uint64](bm_block),
                                &ext4_bitmap_buf[0]) == 0:
                byte_idx: uint64 = 0
                while byte_idx < nbytes:
                    b: uint8 = ext4_bitmap_buf[byte_idx]
                    bit_idx: uint64 = 0
                    while bit_idx < 8:
                        mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx)
                        if (b & mask) == 0:
                            total_free = total_free + 1
                        bit_idx = bit_idx + 1
                    byte_idx = byte_idx + 1
        g = g + 1
    return total_free


def _ext4ef_write_fragmented(inum: uint32, inode: Ptr[uint8],
                             n: uint64, spacer_base: uint64) -> int32:
    # Append `n` deliberately non-contiguous one-block extents to the file
    # at `inum` (inode buffer already read into `inode`). Records spacer
    # blocks at ext4ef_spacers[spacer_base ...]. Each data block is filled
    # with the per-(lblk,off) pattern. Returns the new total logical-block
    # count appended (i.e. the next free logical index), or 0 on failure.
    lb: uint64 = 0
    base_lblk: uint64 = spacer_base
    while lb < n:
        glob_lb: uint64 = base_lblk + lb
        db: uint64 = ext4_alloc_block()
        if db == 0:
            printk1("[ext4-extent] FAIL: out of data blocks at lblk=%d\n",
                    glob_lb)
            return 0
        sp: uint64 = ext4_alloc_block()        # spacer (kept until cleanup)
        ext4ef_spacers[glob_lb] = sp
        o: uint64 = 0
        while o < ext4_block_size:
            ext4ef_vbuf[o] = _ext4idx_pattern_byte(glob_lb, o)
            o = o + 1
        if _ext4_write_block(db, &ext4ef_vbuf[0]) != 0:
            printk0("[ext4-extent] FAIL: write data block\n")
            return 0
        if _ext4_extent_append_block(inode, glob_lb, db) != 0:
            printk1("[ext4-extent] FAIL: append block at lblk=%d\n", glob_lb)
            return 0
        lb = lb + 1
    return base_lblk + n


def _ext4ef_verify_readback(inum: uint32, n: uint64) -> int32:
    # Read every one of the file's `n` logical blocks back through
    # ext4_read_file (the generic extent walk) and verify the pattern.
    # Returns 0 on success, -1 on any short read / byte mismatch.
    vb: uint64 = 0
    while vb < n:
        r: int64 = ext4_read_file(inum, vb * ext4_block_size,
                                  ext4_block_size, &ext4ef_vbuf[0])
        if r != cast[int64](ext4_block_size):
            printk1("[ext4-extent] FAIL: short read at lblk=%d\n", vb)
            return -1
        o: uint64 = 0
        while o < ext4_block_size:
            if ext4ef_vbuf[o] != _ext4idx_pattern_byte(vb, o):
                printk2("[ext4-extent] FAIL: byte mismatch lblk=%d off=%d\n",
                        vb, o)
                return -1
            o = o + 1
        vb = vb + 1
    return 0


def _ext4ef_free_spacers(n: uint64):
    s: uint64 = 0
    while s < n:
        if ext4ef_spacers[s] != 0:
            ext4_free_block(ext4ef_spacers[s])
            ext4ef_spacers[s] = 0
        s = s + 1


def ext4_extentfree_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-extent] FAIL: ext4 not mounted\n")
        return -1
    printk1("[ext4-extent] block_size=%d\n", ext4_block_size)

    # ---- PART A: multi-block file, prove ext4_unlink leaks no blocks ----
    free_before: uint64 = _ext4_count_free_blocks()
    printk1("[ext4-extent] free blocks before write=%d\n", free_before)

    inum: uint32 = _ext4idx_make_empty_file("EXTFREE.BIN")
    if inum == 0:
        printk0("[ext4-extent] FAIL: create empty file\n")
        return -1
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4-extent] FAIL: read inode after create\n")
        return -1
    z0: uint64 = 0
    while z0 < EXT4EF_NBLOCKS:
        ext4ef_spacers[z0] = 0
        z0 = z0 + 1
    if _ext4ef_write_fragmented(inum, &inode[0], EXT4EF_NBLOCKS, 0) == 0:
        return -1
    fsize: uint64 = EXT4EF_NBLOCKS * ext4_block_size
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                    cast[uint32](fsize))
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4-extent] FAIL: write inode after grow\n")
        return -1
    # Confirm it spans multiple extents in an index tree (depth >= 1) so the
    # unlink free-walk must reclaim interior metadata, not just one leaf.
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        printk0("[ext4-extent] FAIL: re-read inode\n")
        return -1
    a_depth: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    printk1("[ext4-extent] wrote %d-block fragmented file\n", EXT4EF_NBLOCKS)
    printk1("[ext4-extent] extent-tree depth=%d (>=1 → has index metadata)\n",
            cast[uint64](a_depth))
    if _ext4ef_verify_readback(inum, EXT4EF_NBLOCKS) != 0:
        return -1
    printk1("[ext4-extent] read-back verified %d blocks\n", EXT4EF_NBLOCKS)

    # Free the spacers FIRST so they don't perturb the comparison, then
    # unlink the file. After this the free count must equal free_before.
    _ext4ef_free_spacers(EXT4EF_NBLOCKS)
    if ext4_unlink("EXTFREE.BIN") < 0:
        printk0("[ext4-extent] FAIL: unlink\n")
        return -1
    free_after: uint64 = _ext4_count_free_blocks()
    printk1("[ext4-extent] free blocks after unlink=%d\n", free_after)
    if free_after != free_before:
        printk2("[ext4-extent] FAIL: block LEAK — before=%d after=%d\n",
                free_before, free_after)
        return -1
    printk0("[ext4-extent] no-leak verified: unlink reclaimed every data + index block\n")

    # ---- PART B: depth-3 extent tree round-trip + no-leak ----
    free_b3: uint64 = _ext4_count_free_blocks()
    inum2: uint32 = _ext4idx_make_empty_file("EXTD3.BIN")
    if inum2 == 0:
        printk0("[ext4-extent] FAIL: create depth-3 file\n")
        return -1
    inode2: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum2), &inode2[0]) != 0:
        printk0("[ext4-extent] FAIL: read depth-3 inode\n")
        return -1
    z1: uint64 = 0
    while z1 < EXT4EF_D2_NBLOCKS + EXT4EF_D3_EXTRA:
        ext4ef_spacers[z1] = 0
        z1 = z1 + 1
    # Build a depth-2 tree first (400 fragmented blocks forces it).
    if _ext4ef_write_fragmented(inum2, &inode2[0],
                                EXT4EF_D2_NBLOCKS, 0) == 0:
        return -1
    d2depth: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode2[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    if d2depth != 2:
        printk1("[ext4-extent] FAIL: expected depth=2 base got %d\n",
                cast[uint64](d2depth))
        return -1
    # Promote the depth-2 tree to depth 3 directly (the structural trigger
    # for an organic promotion needs >28k blocks; promoting here exercises
    # the same _ext4_extent_promote_to_depth3 + _ext4_extent_append_depth3
    # + _ext4_extent_trim_depth3 paths without a multi-minute fill).
    if _ext4_extent_promote_to_depth3(&inode2[0]) != 0:
        printk0("[ext4-extent] FAIL: promote to depth 3\n")
        return -1
    d3depth: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode2[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    if d3depth != 3:
        printk1("[ext4-extent] FAIL: expected depth=3 after promote got %d\n",
                cast[uint64](d3depth))
        return -1
    printk0("[ext4-extent] promoted to eh_depth=3 index tree\n")
    # Append EXT4EF_D3_EXTRA more fragmented blocks THROUGH the depth-3
    # append path (this fills the rightmost leaf and forces a fresh leaf
    # under the depth-3 grower at least once).
    nxt: uint64 = _ext4ef_write_fragmented(inum2, &inode2[0],
                                           EXT4EF_D3_EXTRA,
                                           EXT4EF_D2_NBLOCKS)
    if nxt == 0:
        return -1
    d3depth2: uint16 = _ext4_read_u16(cast[Ptr[uint8]](
        cast[uint64](&inode2[0]) + INODE_I_BLOCK_OFFSET + EXT4_EH_DEPTH_OFFSET))
    if d3depth2 != 3:
        printk1("[ext4-extent] FAIL: tree left depth 3 during append: %d\n",
                cast[uint64](d3depth2))
        return -1
    total3: uint64 = EXT4EF_D2_NBLOCKS + EXT4EF_D3_EXTRA
    fsize3: uint64 = total3 * ext4_block_size
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode2[0]) + 4),
                    cast[uint32](fsize3))
    if ext4_write_inode(cast[uint64](inum2), &inode2[0]) != 0:
        printk0("[ext4-extent] FAIL: write depth-3 inode\n")
        return -1
    # Read every block back byte-exact through the generic (depth-3) walk.
    if _ext4ef_verify_readback(inum2, total3) != 0:
        return -1
    printk2("[ext4-extent] depth-3 round-trip: %d blocks verified depth=%d\n",
            total3, cast[uint64](d3depth2))

    # Free spacers, unlink (exercises _ext4_extent_trim_depth3 freeing
    # L2+L1+leaf+data), and assert the free count round-trips.
    _ext4ef_free_spacers(total3)
    if ext4_unlink("EXTD3.BIN") < 0:
        printk0("[ext4-extent] FAIL: unlink depth-3 file\n")
        return -1
    free_a3: uint64 = _ext4_count_free_blocks()
    if free_a3 != free_b3:
        printk2("[ext4-extent] FAIL: depth-3 block LEAK before=%d after=%d\n",
                free_b3, free_a3)
        return -1
    printk0("[ext4-extent] depth-3 no-leak verified: trim freed L2+L1+leaf+data\n")

    printk0("[ext4-extent] PASS\n")
    return 0


# --- ext4 symlink create (M16.x §links) ---------------------------
#
# A symlink inode uses i_mode = 0xA1FF (S_IFLNK | 0777) and encodes
# the target string one of two ways:
#
#   * "fast" link (target length <= 60 bytes): target stored INLINE in
#     i_block (the same 60-byte region as the extent tree). i_size_lo
#     holds the target length; i_blocks_lo = 0 (no data blocks).
#     Linux's ext4_inode_is_fast_symlink() uses this test; the read path
#     in _ext4_read_symlink_target() already handles it.
#
#   * "slow" link (target > 60 bytes): target lives in the file's
#     first data block, recorded by a single inline depth-0 extent —
#     exactly like a regular file's block 0. i_blocks_lo counts that
#     one block, EXT4_EXTENTS_FL is set, and _ext4_read_symlink_target
#     reads it back via the same extent → physical → read pipeline a
#     regular file read uses. Bounded at one fs block (i.e. up to
#     ext4_block_size bytes, well past PATH_MAX 4096); longer fails.
#
# Returns the new inode number on success, 0 on failure.

def ext4_create_symlink(parent_inum: uint64, name: Ptr[char],
                        target: Ptr[char]) -> uint32:
    # Validate target length first.
    tlen: uint64 = _ext4_strlen(target)
    if tlen == 0:
        return 0
    if ext4_blockdev_slot < 0:
        return 0
    # Slow symlinks store the target in ONE data block; cap at the fs
    # block size (>= 1 KiB, and PATH_MAX is 4096). Anything longer than
    # a single block would need multi-block file data — fail cleanly.
    if tlen > 60 and tlen > ext4_block_size:
        printk0("ext4: create_symlink: target exceeds one block\n")
        return 0
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        printk0("ext4: create_symlink FAIL (alloc_inode)\n")
        return 0

    # Build the symlink inode in ext4_new_inode_buf.
    p: Ptr[uint8] = &ext4_new_inode_buf[0]
    _ext4_zero(p, ext4_inode_size)
    # i_mode: S_IFLNK | 0777 = 0xA1FF
    _ext4_write_u16(p, 0xA1FF)
    _ext4_inode_stamp_creator(p)
    # i_size_lo = target length (NOT counting the NUL terminator).
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4),
                    cast[uint32](tlen))
    # i_links_count = 1
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26), 1)

    if tlen <= 60:
        # --- Fast symlink: target inline in i_block, no data block. ---
        # i_blocks_lo = 0 (no data blocks allocated).
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28), 0)
        # i_flags = 0 (no EXT4_EXTENTS_FL — fast symlinks don't use
        # extents).
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32), 0)
        # Write the target into i_block (offset 0x28 = 40).
        dst: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
        k: uint64 = 0
        while k < tlen:
            cast[Ptr[uint8]](dst + k)[0] = cast[uint8](target[k])
            k = k + 1
    else:
        # --- Slow symlink: target in the first data block. ---
        # Allocate one data block and write the (un-terminated) target
        # bytes into its start, zero-padding the rest of the block.
        data_blk: uint64 = ext4_alloc_block()
        if data_blk == 0:
            printk0("ext4: create_symlink FAIL (alloc_block)\n")
            ext4_free_inode(new_inum)
            return 0
        _ext4_zero(&ext4_blk_buf[0], ext4_block_size)
        d: uint64 = 0
        while d < tlen:
            ext4_blk_buf[d] = cast[uint8](target[d])
            d = d + 1
        if _ext4_write_block(data_blk, &ext4_blk_buf[0]) != 0:
            printk0("ext4: create_symlink FAIL (write data block)\n")
            ext4_free_block(data_blk)
            ext4_free_inode(new_inum)
            return 0
        # i_blocks_lo is in 512-byte units regardless of fs block size.
        sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28),
                        cast[uint32](sectors_per_block))
        # i_flags = EXT4_EXTENTS_FL — the single data block is recorded
        # the SAME way a regular file's block 0 is (one inline depth-0
        # extent), so _ext4_logical_to_physical resolves it on read.
        _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32), 0x80000)
        # i_block (60 bytes at +0x28): extent header + one extent.
        eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
        _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)    # eh_entries
        _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)    # eh_max
        _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)    # eh_depth (leaf)
        _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)    # eh_generation
        # Single extent: ee_block=0, ee_len=1, hi=0, lo=data_blk.
        _ext4_write_u32(cast[Ptr[uint8]](eh + 12), 0)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 16), 1)
        _ext4_write_u16(cast[Ptr[uint8]](eh + 18), 0)
        _ext4_write_u32(cast[Ptr[uint8]](eh + 20),
                        cast[uint32](data_blk))
    # Stamp timestamps.
    _ext4_stamp_all_times(p)

    if ext4_write_inode(cast[uint64](new_inum), p) != 0:
        printk0("ext4: create_symlink FAIL (write inode)\n")
        ext4_free_inode(new_inum)
        return 0
    # Insert directory entry. EXT4_FT_SYMLINK = 7.
    if ext4_dir_insert(parent_inum, name, new_inum, 7) != 0:
        printk0("ext4: create_symlink FAIL (dir_insert)\n")
        ext4_free_inode(new_inum)
        return 0
    return new_inum


# --- ext4 hardlink (M16.x §links) ---------------------------------
#
# A hardlink is just a second directory entry pointing at the same
# inode — no data block is allocated, the inode's i_links_count is
# bumped, and the directory gets a new dirent with the same inum.
#
# The NAMESPACE / FILE-SERVER boundary check is done at the VFS layer
# (vfs_link) BEFORE this function is called.  ext4_hardlink only sees
# paths that have already been confirmed to be on the same file server.
#
# Returns 0 on success, -1 on failure (source not found, dir full,
# inum out of range).

def ext4_hardlink(src_path: Ptr[char], dst_name: Ptr[char],
                  dst_parent_inum: uint64) -> int32:
    # Resolve the source to its inode.
    src_inum: uint32 = 0
    src_size: uint64 = 0
    if ext4_resolve_file(src_path, &src_inum, &src_size) == 0:
        # Try directory resolution too (hardlinks to directories are
        # rejected below, but we want to give the right error).
        r: Ext4ResolveResult
        if _resolve_with_symlinks(src_path, &r) == 0:
            printk0("ext4: hardlink: source not found\n")
            return -1
        if r.is_dir != 0:
            # POSIX: hardlinks to directories are not permitted
            # (would create cycles in the directory tree).
            printk0("ext4: hardlink: source is a directory\n")
            return -1
        src_inum = r.inum
    # Read the source inode to bump its i_links_count.
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](src_inum), &inode[0]) != 0:
        printk0("ext4: hardlink: read inode failed\n")
        return -1
    # Increment i_links_count (u16 at offset 26).
    lc_off: uint64 = 26
    old_lc: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](&inode[0]) + lc_off))
    if old_lc >= 0xFFFF:
        printk0("ext4: hardlink: i_links_count overflow\n")
        return -1
    new_lc: uint16 = old_lc + 1
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](&inode[0]) + lc_off),
                    new_lc)
    # Stamp ctime (inode metadata changed).
    _ext4_stamp_mtime(&inode[0])
    if ext4_write_inode(cast[uint64](src_inum), &inode[0]) != 0:
        printk0("ext4: hardlink: write inode failed\n")
        return -1
    # Insert the new dirent. EXT4_FT_REG_FILE = 1.
    if ext4_dir_insert(dst_parent_inum, dst_name, src_inum, 1) != 0:
        printk0("ext4: hardlink: dir_insert failed\n")
        # Roll back the link count.
        _ext4_write_u16(
            cast[Ptr[uint8]](cast[uint64](&inode[0]) + lc_off), old_lc)
        ext4_write_inode(cast[uint64](src_inum), &inode[0])
        return -1
    return 0


# --- ext4 link smoke test (M16.x §links) --------------------------

def ext4_links_smoke_test() -> int32:
    # (a) Create a regular file, create a symlink to it, read the file
    #     via the symlink name — verifies symlink create + resolve.
    # (b) Hardlink the same file under a second name — both names must
    #     deliver the same bytes and the same inode number.
    # Clean up all test files at the end.
    if ext4_blockdev_slot < 0:
        return 0
    body: Ptr[uint8] = "LINKS_PAYLOAD ext4 links test body\n"
    blen: uint64 = _ext4_strlen(cast[Ptr[char]](body))

    # --- (a) symlink ---
    orig_inum: uint32 = ext4_create_file(2, "LNKORIG.TXT", body, blen)
    if orig_inum == 0:
        printk0("ext4: links smoke FAIL (create LNKORIG)\n")
        return -1
    sym_inum: uint32 = ext4_create_symlink(2, "LNKSYM.TXT", "LNKORIG.TXT")
    if sym_inum == 0:
        printk0("ext4: links smoke FAIL (create_symlink)\n")
        ext4_unlink("LNKORIG.TXT")
        return -1
    # Read via the symlink: ext4_resolve_file follows symlinks.
    via_sym_inum: uint32 = 0
    via_sym_size: uint64 = 0
    if ext4_resolve_file("LNKSYM.TXT", &via_sym_inum, &via_sym_size) == 0:
        printk0("ext4: links smoke FAIL (symlink not followed)\n")
        ext4_unlink("LNKORIG.TXT")
        ext4_unlink("LNKSYM.TXT")
        return -1
    if via_sym_inum != orig_inum:
        printk0("ext4: links smoke FAIL (symlink resolves to wrong inode)\n")
        ext4_unlink("LNKORIG.TXT")
        ext4_unlink("LNKSYM.TXT")
        return -1
    # Data must match.
    if _ext4_read_back_eq(via_sym_inum, body, blen) == 0:
        printk0("ext4: links smoke FAIL (data via symlink wrong)\n")
        ext4_unlink("LNKORIG.TXT")
        ext4_unlink("LNKSYM.TXT")
        return -1

    # --- (b) hardlink ---
    if ext4_hardlink("LNKORIG.TXT", "LNKHARD.TXT", 2) != 0:
        printk0("ext4: links smoke FAIL (hardlink create)\n")
        ext4_unlink("LNKORIG.TXT")
        ext4_unlink("LNKSYM.TXT")
        return -1
    # Both names must resolve to the same inode.
    hard_inum: uint32 = 0
    hard_size: uint64 = 0
    if ext4_resolve_file("LNKHARD.TXT", &hard_inum, &hard_size) == 0:
        printk0("ext4: links smoke FAIL (hardlink not found)\n")
        ext4_unlink("LNKORIG.TXT")
        ext4_unlink("LNKSYM.TXT")
        return -1
    if hard_inum != orig_inum:
        printk0("ext4: links smoke FAIL (hardlink inode mismatch)\n")
        ext4_unlink("LNKORIG.TXT")
        ext4_unlink("LNKSYM.TXT")
        ext4_unlink("LNKHARD.TXT")
        return -1
    # Data via hardlink must match.
    if _ext4_read_back_eq(hard_inum, body, blen) == 0:
        printk0("ext4: links smoke FAIL (data via hardlink wrong)\n")
        ext4_unlink("LNKORIG.TXT")
        ext4_unlink("LNKSYM.TXT")
        ext4_unlink("LNKHARD.TXT")
        return -1

    # Cleanup.
    ext4_unlink("LNKORIG.TXT")
    ext4_unlink("LNKSYM.TXT")
    ext4_unlink("LNKHARD.TXT")
    printk0("ext4: links smoke PASS\n")
    return 0


# --- ext4 blob save / load (distrofs persistent backing) ----------
#
# distrofs (user/distrofs.ad) is a userland 9P file-server whose node
# + data tables live in RAM. To make an installed package survive a
# reboot it needs a DURABLE backing store: it serialises its whole
# table image into one buffer and asks the kernel to persist that
# buffer as a single root-directory file on the mounted ext4 volume.
#
# ext4_blob_save writes an arbitrary-length buffer to a named file in
# the ext4 root directory, growing the file across as many data blocks
# as the length needs. The existing M16.64 create/write path is
# single-block; this is the multi-block writer the persistent-distrofs
# milestone needs. It is NOT a general open()/write() path — it always
# create-or-truncates the WHOLE file from one in-memory buffer, which
# is exactly the snapshot semantics distrofs wants and keeps the code
# small and corruption-free (no partial-block RMW, no extent surgery
# on an existing tree).
#
# Block allocation: ext4_alloc_block() always returns the first free
# bit, so calling it N times in a row hands back N CONSECUTIVE blocks.
# _ext4_extent_append_block() coalesces a contiguous run into a single
# extent, so the inline depth-0 leaf (eh_max 4) holds a blob of any
# size as long as the run stays contiguous — which it does on a fresh
# region. A fragmented volume could need >4 extents; ext4_blob_save
# detects a full leaf and fails cleanly (-1) rather than corrupt.
#
# ext4_blob_load resolves the named root file and reads it back via
# the standard multi-block ext4_read_file path.

# Per-block scratch for blob save (separate from ext4_blk_buf so an
# in-flight inode read during the loop can't trample it).
ext4_blob_buf: Array[4096, uint8]
# Inode scratch for the blob writer.
ext4_blob_inode: Array[256, uint8]


def ext4_blob_save(name: Ptr[char], src: Ptr[uint8],
                   length: uint64) -> int64:
    # Create-or-overwrite the root-directory file `name` so it holds
    # exactly `length` bytes copied from `src`, then fsync the volume.
    # Returns the byte count written on success, -1 on any failure.
    if ext4_blockdev_slot < 0:
        return cast[int64](-1)
    # Drop any previous incarnation of the file: tombstone its dirent
    # and free its inode. We also walk its extent leaf and free every
    # data block so a repeated save does not leak the volume away.
    old_inum: uint32 = _ext4_dir_unlink_in_root(name)
    if old_inum != 0:
        if ext4_read_inode(cast[uint64](old_inum),
                           &ext4_blob_inode[0]) == 0:
            _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(old_inum)
        # Page-cache coherence: old inum's blocks are freed and the inum
        # may be reused; drop its cached pages (no writeback).
        fcache_drop_inode_nowriteback(PC_SRV_EXT4, cast[uint64](old_inum))
    # Allocate a fresh inode for the new file.
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        printk0("ext4: blob_save FAIL (alloc_inode)\n")
        return cast[int64](-1)
    # Start from a minimal empty regular inode: mode 0664 + IFREG, an
    # empty depth-0 extent leaf, i_size 0. _ext4_init_regular_inode
    # wants a data block; we instead hand-build an EMPTY leaf so the
    # append loop below grows it block by block.
    p: Ptr[uint8] = &ext4_blob_inode[0]
    _ext4_zero(p, ext4_inode_size)
    _ext4_write_u16(p, 0x81B4)                       # i_mode = IFREG|0664
    # docs/security.md Phase 6: ext4_blob_save is a kernel-internal
    # snapshot path (distrofs RAM-table persist). It runs in PID 1's
    # context for the boot/install seed and on hostowner-side later;
    # stamp the calling task's uid/gid (uid 1 in both cases).
    _ext4_inode_stamp_creator(p)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26), 1)  # i_links
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32),
                    0x80000)                         # EXT4_EXTENTS_FL
    eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)     # eh_entries = 0
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)     # eh_max = 4
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)     # eh_depth = 0
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)     # eh_generation
    _ext4_stamp_all_times(p)
    # Grow the file block by block.
    nblocks: uint64 = (length + ext4_block_size - 1) / ext4_block_size
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    lb: uint64 = 0
    while lb < nblocks:
        nb: uint64 = ext4_alloc_block()
        if nb == 0:
            printk0("ext4: blob_save FAIL (out of blocks)\n")
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        # Fill the block: copy this slice of src, zero-pad the tail.
        _ext4_zero(&ext4_blob_buf[0], ext4_block_size)
        off: uint64 = lb * ext4_block_size
        chunk: uint64 = length - off
        if chunk > ext4_block_size:
            chunk = ext4_block_size
        if chunk > 0:
            memcpy(&ext4_blob_buf[0],
                   cast[Ptr[uint8]](cast[uint64](src) + off), chunk)
        if _ext4_write_block(nb, &ext4_blob_buf[0]) != 0:
            printk0("ext4: blob_save FAIL (write data block)\n")
            ext4_free_block(nb)
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        if _ext4_extent_append_block(&ext4_blob_inode[0], lb, nb) != 0:
            printk0("ext4: blob_save FAIL (extent leaf full)\n")
            ext4_free_block(nb)
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        lb = lb + 1
    # Stamp i_size and i_blocks, write the inode out.
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4),
                    cast[uint32](length))            # i_size_lo
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28),
                    cast[uint32](nblocks * sectors_per_block))  # i_blocks_lo
    _ext4_stamp_mtime(p)
    if ext4_write_inode(cast[uint64](new_inum),
                        &ext4_blob_inode[0]) != 0:
        printk0("ext4: blob_save FAIL (write inode)\n")
        _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(new_inum)
        return cast[int64](-1)
    # Splice the dirent into the root directory (EXT4_FT_REG_FILE = 1).
    if ext4_dir_insert(2, name, new_inum, 1) != 0:
        printk0("ext4: blob_save FAIL (dir_insert)\n")
        _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(new_inum)
        return cast[int64](-1)
    # Durable: flush the block-device write cache (the same barrier
    # ext4_fsync issues). Without this the snapshot is only in the
    # device cache and a reboot could lose it.
    blk_flush(ext4_blockdev_slot)
    return cast[int64](length)


def ext4_blob_load(name: Ptr[char], dst: Ptr[uint8],
                   max_len: uint64) -> int64:
    # Read the root-directory file `name` into `dst` (at most max_len
    # bytes). Returns the byte count read, 0 if the file does not
    # exist, -1 on I/O error / no ext4 volume.
    if ext4_blockdev_slot < 0:
        return cast[int64](-1)
    inum: uint32 = 0
    size: uint64 = 0
    if ext4_resolve_file(name, &inum, &size) == 0:
        return cast[int64](0)                        # no snapshot yet
    want: uint64 = size
    if want > max_len:
        want = max_len
    if want == 0:
        return cast[int64](0)
    return ext4_read_file(inum, 0, want, dst)


# --- ext4_mkfs (M16.x) --------------------------------------------
#
# Format a freshly-partitioned slice as ext4. Mirrors the simplest
# viable subset of e2fsprogs/mke2fs.c — single block group, no
# journal, extents-only (so the existing M16.51..67 read path picks
# the FS up unchanged). The resulting filesystem has:
#
#   * 4 KiB blocks (s_log_block_size = 2)
#   * 256-byte inodes (s_inode_size = 256)
#   * one block group (we accept partitions up to 32768 blocks =
#     128 MiB; larger slices are clamped to one group — multi-group
#     mkfs is a documented follow-up)
#   * 8192 inodes/group, inode #2 = the root directory containing
#     just "." and ".."
#   * legacy 32-byte group descriptors (no 64BIT, no metadata_csum,
#     no journal — Linux's tune2fs -O ^has_journal output shape)
#   * volume label "hamnix-mkfs"
#
# On-disk layout inside the partition (blocks are 4 KiB; sectors are
# 512 bytes, 8 sectors per block):
#
#   block 0   bytes 0..1023 = boot area; bytes 1024..2047 = SB
#   block 1   group descriptor table (one 32-byte entry, rest zero)
#   block 2   block bitmap (first 517 bits = metadata + root data)
#   block 3   inode bitmap (first 10 bits set = inodes 1..10)
#   block 4..515  inode table (8192 × 256 B = 512 blocks)
#   block 516 root directory's first data block (. and .. dirents)
#
# `ext4_mkfs(slot, total_sectors)` performs no read-back — it just
# blasts the metadata out. The caller is expected to immediately
# `ext4_init(slot)` to mount the freshly-formatted FS, which doubles
# as a self-check that the structures we wrote are coherent.

EXT4_MKFS_BLOCK_SIZE:      uint64 = 4096
EXT4_MKFS_LOG_BLOCK:       uint32 = 2          # 1024 << 2 = 4096
EXT4_MKFS_INODE_SIZE:      uint64 = 256
EXT4_MKFS_INODES_PER_GRP:  uint64 = 8192
EXT4_MKFS_BLOCKS_PER_GRP:  uint64 = 32768
EXT4_MKFS_FIRST_INODE:     uint32 = 11
EXT4_MKFS_RESERVED_INODES: uint64 = 10

# Group-0 metadata block addresses (4 KiB blocks, s_first_data_block=0).
EXT4_MKFS_SB_BLOCK:           uint64 = 0
EXT4_MKFS_GDT_BLOCK:          uint64 = 1
EXT4_MKFS_BLOCK_BITMAP_BLOCK: uint64 = 2
EXT4_MKFS_INODE_BITMAP_BLOCK: uint64 = 3
EXT4_MKFS_INODE_TABLE_BLOCK:  uint64 = 4
EXT4_MKFS_INODE_TABLE_BLOCKS: uint64 = 512     # 8192 × 256 / 4096
EXT4_MKFS_ROOT_DATA_BLOCK:    uint64 = 516
EXT4_MKFS_METADATA_BLOCKS:    uint64 = 517     # bits 0..516 in blk bitmap

# 4 KiB scratch buffer for mkfs page writes.
ext4_mkfs_buf: Array[4096, uint8]


def _ext4_mkfs_write_block(slot: int32, blk_nr: uint64,
                           buf: Ptr[uint8]) -> int32:
    # Slot-aware write of one 4 KiB block. ext4_mkfs runs BEFORE
    # ext4_init has populated the mount globals, so we can't use the
    # global-state-dependent _ext4_write_block.
    lba: uint64 = blk_nr * 8
    return blk_write_sectors(slot, lba, 8, buf)


def _ext4_mkfs_write_label(p: Ptr[uint8]):
    # Copy "hamnix-mkfs" (11 bytes + NUL pad) into the 16-byte
    # s_volume_name area at superblock offset 0x78.
    label: Ptr[uint8] = "hamnix-mkfs"
    i: uint64 = 0
    while i < 11:
        p[i] = label[i]
        i = i + 1
    while i < 16:
        p[i] = 0
        i = i + 1


def _ext4_mkfs_build_superblock(buf: Ptr[uint8],
                                blocks_count: uint64,
                                free_blocks: uint64) -> int32:
    # Build a 1024-byte superblock at &buf[1024..2047] (the boot area
    # at 0..1023 stays zero). `buf` is the full 4 KiB block 0 scratch.
    sb: uint64 = cast[uint64](buf) + 1024
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x00),
                    cast[uint32](EXT4_MKFS_INODES_PER_GRP))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x04),
                    cast[uint32](blocks_count))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x0C),
                    cast[uint32](free_blocks))
    free_inodes: uint64 = EXT4_MKFS_INODES_PER_GRP \
                          - EXT4_MKFS_RESERVED_INODES
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x10),
                    cast[uint32](free_inodes))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x14), 0)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x18),
                    EXT4_MKFS_LOG_BLOCK)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x1C),
                    EXT4_MKFS_LOG_BLOCK)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x20),
                    cast[uint32](EXT4_MKFS_BLOCKS_PER_GRP))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x24),
                    cast[uint32](EXT4_MKFS_BLOCKS_PER_GRP))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x28),
                    cast[uint32](EXT4_MKFS_INODES_PER_GRP))
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x38), EXT4_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x3A), 1)
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x3C), 1)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x48), 0)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x4C), 1)
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x54),
                    cast[uint32](EXT4_MKFS_FIRST_INODE))
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0x58),
                    cast[uint16](EXT4_MKFS_INODE_SIZE))
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x5C), 0)
    # s_feature_incompat: EXTENTS (0x40) | FILETYPE (0x2).
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x60), 0x42)
    # s_feature_ro_compat: SPARSE_SUPER (0x1) | LARGE_FILE (0x2).
    _ext4_write_u32(cast[Ptr[uint8]](sb + 0x64), 0x3)
    _ext4_mkfs_write_label(cast[Ptr[uint8]](sb + 0x78))
    _ext4_write_u16(cast[Ptr[uint8]](sb + 0xFE), 0)
    return 0


def _ext4_mkfs_build_gdt(buf: Ptr[uint8], free_blocks: uint64,
                         free_inodes: uint64) -> int32:
    p: uint64 = cast[uint64](buf)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x00),
                    cast[uint32](EXT4_MKFS_BLOCK_BITMAP_BLOCK))
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x04),
                    cast[uint32](EXT4_MKFS_INODE_BITMAP_BLOCK))
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x08),
                    cast[uint32](EXT4_MKFS_INODE_TABLE_BLOCK))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x0C),
                    cast[uint16](free_blocks))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x0E),
                    cast[uint16](free_inodes))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x10), 1)
    return 0


def _ext4_mkfs_build_block_bitmap(buf: Ptr[uint8]) -> int32:
    in_use: uint64 = EXT4_MKFS_METADATA_BLOCKS
    full_bytes: uint64 = in_use / 8
    i: uint64 = 0
    while i < full_bytes:
        buf[i] = 0xFF
        i = i + 1
    rem: uint64 = in_use % 8
    if rem != 0:
        bit_idx: uint64 = 0
        m: uint8 = 0
        while bit_idx < rem:
            m = m | (cast[uint8](1) << cast[uint8](bit_idx))
            bit_idx = bit_idx + 1
        buf[full_bytes] = m
    return 0


def _ext4_mkfs_build_inode_bitmap(buf: Ptr[uint8]) -> int32:
    full_bytes: uint64 = EXT4_MKFS_RESERVED_INODES / 8
    i: uint64 = 0
    while i < full_bytes:
        buf[i] = 0xFF
        i = i + 1
    rem: uint64 = EXT4_MKFS_RESERVED_INODES % 8
    if rem != 0:
        bit_idx: uint64 = 0
        m: uint8 = 0
        while bit_idx < rem:
            m = m | (cast[uint8](1) << cast[uint8](bit_idx))
            bit_idx = bit_idx + 1
        buf[full_bytes] = m
    return 0


def _ext4_mkfs_build_root_inode(buf: Ptr[uint8]) -> int32:
    p: uint64 = cast[uint64](buf)
    # i_mode: S_IFDIR | 0755 = 0x41ED. Root of a freshly-formatted
    # filesystem is hostowner-only-writable (0755 directories grant
    # rwx to owner, r-x to group/other). docs/security.md Phase 6:
    # the root dir is owned by hostowner (uid 1 / gid 1), so a
    # regular user can list its contents but can't create files in /.
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x00), 0x41ED)
    # docs/security.md Phase 6: stamp the root directory as
    # hostowner-owned. mkfs is always invoked from hostowner-side
    # (the installer / live ISO bootstrap); hardcoding uid 1 / gid 1
    # is the correct policy for a freshly-formatted volume.
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x02), 1)      # i_uid_lo = 1
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x18), 1)      # i_gid_lo = 1
    # The *_hi halves at offset 0x7C/0x7E stay 0 (the 4 KiB buf is
    # already zeroed by the caller's _ext4_zero before this fn runs).
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x04),
                    cast[uint32](EXT4_MKFS_BLOCK_SIZE))
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x1A), 2)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x1C), 8)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x20), 0x80000)
    eh: uint64 = p + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 12), 0)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 16), 1)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 18), 0)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 20),
                    cast[uint32](EXT4_MKFS_ROOT_DATA_BLOCK))
    return 0


def _ext4_mkfs_build_root_dirblock(buf: Ptr[uint8]) -> int32:
    p: uint64 = cast[uint64](buf)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0), 2)
    _ext4_write_u16(cast[Ptr[uint8]](p + 4), 12)
    cast[Ptr[uint8]](p + 6)[0] = 1
    cast[Ptr[uint8]](p + 7)[0] = 2
    cast[Ptr[uint8]](p + 8)[0] = 0x2E
    rest: uint64 = EXT4_MKFS_BLOCK_SIZE - 12
    _ext4_write_u32(cast[Ptr[uint8]](p + 12), 2)
    _ext4_write_u16(cast[Ptr[uint8]](p + 16),
                    cast[uint16](rest))
    cast[Ptr[uint8]](p + 18)[0] = 2
    cast[Ptr[uint8]](p + 19)[0] = 2
    cast[Ptr[uint8]](p + 20)[0] = 0x2E
    cast[Ptr[uint8]](p + 21)[0] = 0x2E
    return 0


def ext4_mkfs(slot: int32, total_sectors: uint64) -> int32:
    # Format the block device at `slot` as a single-group ext4
    # filesystem. `total_sectors` is the partition capacity in
    # 512-byte sectors. Returns 0 on success, -1 on failure.
    if slot < 0:
        return -1
    if total_sectors < 4136:
        printk0("ext4: mkfs: partition too small (need >= 2 MiB)\n")
        return -1
    total_blocks: uint64 = total_sectors / 8
    if total_blocks > EXT4_MKFS_BLOCKS_PER_GRP:
        total_blocks = EXT4_MKFS_BLOCKS_PER_GRP
    free_blocks: uint64 = total_blocks - EXT4_MKFS_METADATA_BLOCKS
    free_inodes: uint64 = EXT4_MKFS_INODES_PER_GRP \
                          - EXT4_MKFS_RESERVED_INODES

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_superblock(&ext4_mkfs_buf[0], total_blocks,
                                free_blocks)
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_SB_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write superblock failed\n")
        return -1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_gdt(&ext4_mkfs_buf[0], free_blocks, free_inodes)
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_GDT_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write GDT failed\n")
        return -1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_block_bitmap(&ext4_mkfs_buf[0])
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_BLOCK_BITMAP_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write block bitmap failed\n")
        return -1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_inode_bitmap(&ext4_mkfs_buf[0])
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_INODE_BITMAP_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write inode bitmap failed\n")
        return -1

    # Inode #2 lives at byte offset 256 within the first inode-table
    # block (table position 1, 0-indexed). Build that block specially;
    # the rest of the table is plain zeros.
    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_root_inode(
        cast[Ptr[uint8]](
            cast[uint64](&ext4_mkfs_buf[0])
            + EXT4_MKFS_INODE_SIZE))
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_INODE_TABLE_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write inode table block 0 failed\n")
        return -1
    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    rem_blk: uint64 = 1
    while rem_blk < EXT4_MKFS_INODE_TABLE_BLOCKS:
        if _ext4_mkfs_write_block(slot,
                EXT4_MKFS_INODE_TABLE_BLOCK + rem_blk,
                &ext4_mkfs_buf[0]) != 0:
            printk0("ext4: mkfs: write inode table tail failed\n")
            return -1
        rem_blk = rem_blk + 1

    _ext4_zero(&ext4_mkfs_buf[0], EXT4_MKFS_BLOCK_SIZE)
    _ext4_mkfs_build_root_dirblock(&ext4_mkfs_buf[0])
    if _ext4_mkfs_write_block(slot, EXT4_MKFS_ROOT_DATA_BLOCK,
                              &ext4_mkfs_buf[0]) != 0:
        printk0("ext4: mkfs: write root dir block failed\n")
        return -1

    printk2("[ext4] mkfs slot=%d total_blocks=%d OK\n",
            cast[uint64](slot), total_blocks)
    return 0


# ---- mkfs self-test ----------------------------------------------
#
# Locates sd0p1 (or nvme0n1p1) and runs mkfs + re-mount + verify
# against it. Save/restore the mount globals around the run so a
# concurrent /ext mount on a different slot survives.
ext4_mkfs_self_test_done: uint32 = 0

# Opt-IN gate for the lazy mkfs self-test. The self-test FORMATS (WRITEs
# a fresh ext4 over) whatever block device backs sd0p1 / nvme0n1p1 — it
# is a DEVELOPER fixture, NOT a boot-time check. It must NEVER fire on
# real media: a shipped Hamnix .img is a GPT disk whose partition 1 is
# the ESP, so on a normal boot find_blockdev("sd0p1") now resolves to a
# LIVE partition and an unguarded self-test would scribble ext4 over the
# ESP (and, on a USB stick, STALL the bulk-OUT endpoint mid-write,
# wedging every subsequent read of the real root). Default 0 = never
# run. Only init/main.ad sets it to 1, and ONLY when the cpio ships the
# /etc/mkfs-selftest marker (planted exclusively by scripts/test_mkfs.sh).
ext4_mkfs_selftest_enabled: uint32 = 0


def ext4_enable_mkfs_selftest():
    # Called from init/main.ad's boot path when the /etc/mkfs-selftest
    # cpio marker is present. Arms the lazy self-test hook below; without
    # this the hook is a no-op so production boots never format a disk.
    ext4_mkfs_selftest_enabled = 1


def _ext4_mkfs_find_target() -> int32:
    s: int32 = find_blockdev("sd0p1")
    if s >= 0:
        return s
    s = find_blockdev("nvme0n1p1")
    if s >= 0:
        return s
    return -1


def _ext4_mkfs_verify_root(slot: int32) -> int32:
    # Read inode #2 and walk its first dir block. Returns 0 on PASS,
    # -1 on FAIL.
    ino_buf: Array[256, uint8]
    if ext4_read_inode(2, &ino_buf[0]) != 0:
        printk0("[ext4] mkfs verify FAIL (read inode #2)\n")
        return -1
    mode: uint16 = ext4_inode_mode(&ino_buf[0])
    if (mode & 0xF000) != 0x4000:
        printk1("[ext4] mkfs verify FAIL (inode #2 mode=%x not dir)\n",
                cast[uint64](mode))
        return -1
    phys: uint64 = ext4_inode_first_extent_block(&ino_buf[0])
    if phys == 0:
        printk0("[ext4] mkfs verify FAIL (root has no data block)\n")
        return -1
    if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
        printk0("[ext4] mkfs verify FAIL (root dir read)\n")
        return -1
    e: uint64 = cast[uint64](&ext4_blk_buf[0])
    e0_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
    e0_rec:  uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
    e0_nl:   uint8  = cast[Ptr[uint8]](e + 6)[0]
    e0_c0:   uint8  = cast[Ptr[uint8]](e + 8)[0]
    if e0_inum != 2 or e0_nl != 1 or e0_c0 != 0x2E:
        printk0("[ext4] mkfs verify FAIL (root dirent[0] != .)\n")
        return -1
    e2: uint64 = e + cast[uint64](e0_rec)
    e1_inum: uint32 = _ext4_read_u32(cast[Ptr[uint8]](e2 + 0))
    e1_nl:   uint8  = cast[Ptr[uint8]](e2 + 6)[0]
    e1_c0:   uint8  = cast[Ptr[uint8]](e2 + 8)[0]
    e1_c1:   uint8  = cast[Ptr[uint8]](e2 + 9)[0]
    if e1_inum != 2 or e1_nl != 2 or e1_c0 != 0x2E or e1_c1 != 0x2E:
        printk0("[ext4] mkfs verify FAIL (root dirent[1] != ..)\n")
        return -1
    return 0


def _ext4_mkfs_restore_state(s_slot: int32, s_bs: uint64, s_bpg: uint64,
                             s_ipg: uint64, s_ic: uint64, s_bc: uint64,
                             s_fdb: uint64, s_isz: uint64, s_ds: uint64,
                             s_gdt: uint64):
    # Restore the mount snapshot taken at the top of
    # ext4_mkfs_self_test. Factored out so both success and failure
    # paths reach a single restore point.
    ext4_blockdev_slot   = s_slot
    ext4_block_size      = s_bs
    ext4_blocks_per_grp  = s_bpg
    ext4_inodes_per_grp  = s_ipg
    ext4_inodes_count    = s_ic
    ext4_blocks_count    = s_bc
    ext4_first_data_blk  = s_fdb
    ext4_inode_size      = s_isz
    ext4_desc_size       = s_ds
    ext4_gdt_block       = s_gdt


def ext4_mkfs_self_test() -> int32:
    target: int32 = _ext4_mkfs_find_target()
    if target < 0:
        printk0("[ext4] mkfs self-test SKIP (no partition device)\n")
        return 0
    s_slot:  int32  = ext4_blockdev_slot
    s_bs:    uint64 = ext4_block_size
    s_bpg:   uint64 = ext4_blocks_per_grp
    s_ipg:   uint64 = ext4_inodes_per_grp
    s_ic:    uint64 = ext4_inodes_count
    s_bc:    uint64 = ext4_blocks_count
    s_fdb:   uint64 = ext4_first_data_blk
    s_isz:   uint64 = ext4_inode_size
    s_ds:    uint64 = ext4_desc_size
    s_gdt:   uint64 = ext4_gdt_block

    # test_mkfs.sh sizes p1 at 63488 sectors (31 MiB). ext4_mkfs caps
    # at one block group (32768 blocks = 128 MiB).
    test_sectors: uint64 = 63488
    if ext4_mkfs(target, test_sectors) != 0:
        printk0("[ext4] mkfs self-test FAIL (ext4_mkfs)\n")
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1
    printk1("[ext4] mkfs sd0p1 OK (slot=%d)\n",
            cast[uint64](target))

    if ext4_init(target) != 0:
        printk0("[ext4] mkfs self-test FAIL (re-mount)\n")
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1
    printk1("[ext4] mounted sd0p1 ro=0 (slot=%d)\n",
            cast[uint64](target))

    if _ext4_mkfs_verify_root(target) != 0:
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1
    printk0("[ext4] / contains . ..\n")
    _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                             s_bc, s_fdb, s_isz, s_ds, s_gdt)
    printk0("[ext4] mkfs self-test PASS\n")
    return 0


def _ext4_mkfs_self_test_maybe():
    # Single-shot gate. Called from ext4_resolve_file / ext4_resolve_dir
    # on every VFS open of an ext4 path; the gate keeps subsequent calls
    # to a single global compare.
    #
    # Opt-IN: the self-test FORMATS sd0p1/nvme0n1p1 (destructive write),
    # so it only runs when init/main.ad armed it via the /etc/mkfs-selftest
    # marker (scripts/test_mkfs.sh). On every real boot the flag is 0 and
    # this is a single compare + return — the disk is never written.
    if ext4_mkfs_selftest_enabled == 0:
        return
    if ext4_mkfs_self_test_done != 0:
        return
    ext4_mkfs_self_test_done = 1
    ext4_mkfs_self_test()


# --- ext4 directory create + path-aware writes --------------------
#
# Per-component dir create + path-walking. The installer's production
# path lays down files at /bin/<x>, /etc/<x>, /usr/lib/<x>/, etc. —
# none of those parent dirs exist on a freshly-mkfs'd target. These
# helpers let ext4_install_file_to_slot accept arbitrary paths with
# mkdir -p semantics so a multi-package install can write
#
#     install_file_to_slot /dev/blk/vdbp2 usr/bin/apt /n/distros/usr/bin/apt
#
# without pre-creating every parent dir in userland.

# Scratch inode buffer for fresh-dir-create. Sized for the largest
# inode_size we'd see (256 bytes). Same shape as ext4_new_inode_buf
# but kept separate so a path-walk that creates several dirs en route
# to a file doesn't clobber the buffer ext4_blob_save uses for the
# regular-file inode.
ext4_mkdir_inode_buf: Array[256, uint8]


def _ext4_build_dir_inode(buf: Ptr[uint8], data_blk: uint64):
    # Build a fresh directory inode in `buf`: i_mode = S_IFDIR|0755
    # (0x41ED), one extent pointing at `data_blk`, i_size = block_size,
    # i_links_count = 2 (the dir itself + its own "."). The parent's
    # inum is carried by the new dir's ".." dirent on disk, not by
    # any field in the dir inode itself.
    p: uint64 = cast[uint64](buf)
    _ext4_zero(buf, ext4_inode_size)
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x00), 0x41ED)     # i_mode
    # uid/gid: stamp the calling task. Installer runs as hostowner
    # (uid 1); _ext4_inode_stamp_creator covers the no-task-context
    # fallback path.
    _ext4_inode_stamp_creator(buf)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x04),
                    cast[uint32](ext4_block_size))          # i_size_lo
    _ext4_write_u16(cast[Ptr[uint8]](p + 0x1A), 2)          # i_links_count
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x1C),
                    cast[uint32](sectors_per_block))        # i_blocks_lo
    _ext4_write_u32(cast[Ptr[uint8]](p + 0x20), 0x80000)    # EXT4_EXTENTS_FL
    # i_block: depth-0 extent leaf with one extent → data_blk.
    eh: uint64 = p + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 1)            # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)            # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)            # eh_depth (leaf)
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)            # eh_generation
    _ext4_write_u32(cast[Ptr[uint8]](eh + 12), 0)           # ee_block=0
    _ext4_write_u16(cast[Ptr[uint8]](eh + 16), 1)           # ee_len=1
    _ext4_write_u16(cast[Ptr[uint8]](eh + 18), 0)           # ee_start_hi
    _ext4_write_u32(cast[Ptr[uint8]](eh + 20),
                    cast[uint32](data_blk))                 # ee_start_lo
    _ext4_stamp_all_times(buf)


def _ext4_write_dot_dotdot(blk_buf: Ptr[uint8], self_inum: uint32,
                           parent_inum: uint32):
    # Lay down the canonical "." + ".." dirents for a fresh dir block.
    # Layout (mirroring _ext4_mkfs_build_root_dirblock):
    #   "."  : inum=self,   rec_len=12, name_len=1, file_type=2
    #   ".." : inum=parent, rec_len=(block_size-12), name_len=2,
    #          file_type=2, name="..", padded with zeros.
    _ext4_zero(blk_buf, ext4_block_size)
    p: uint64 = cast[uint64](blk_buf)
    _ext4_write_u32(cast[Ptr[uint8]](p + 0), self_inum)
    _ext4_write_u16(cast[Ptr[uint8]](p + 4), 12)
    cast[Ptr[uint8]](p + 6)[0] = 1                          # name_len = 1
    cast[Ptr[uint8]](p + 7)[0] = 2                          # EXT4_FT_DIR
    cast[Ptr[uint8]](p + 8)[0] = 0x2E                       # '.'
    # On a metadata_csum fs the last 12 bytes of every leaf dir block
    # are an ext4_dir_entry_tail (fake inode=0, rec_len=12, name_len=0,
    # file_type=0xDE, det_checksum u32). ".." must stop short of it so
    # its rec_len leaves room for the tail.
    rest: uint64 = ext4_block_size - 12
    if ext4_metadata_csum != 0:
        rest = ext4_block_size - 12 - 12
    _ext4_write_u32(cast[Ptr[uint8]](p + 12), parent_inum)
    _ext4_write_u16(cast[Ptr[uint8]](p + 16),
                    cast[uint16](rest))
    cast[Ptr[uint8]](p + 18)[0] = 2                         # name_len = 2
    cast[Ptr[uint8]](p + 19)[0] = 2                         # EXT4_FT_DIR
    cast[Ptr[uint8]](p + 20)[0] = 0x2E                      # '.'
    cast[Ptr[uint8]](p + 21)[0] = 0x2E                      # '.'
    if ext4_metadata_csum != 0:
        # Lay down the dir_entry_tail skeleton; det_checksum is stamped
        # by the caller (it knows the dir's inum + generation).
        tail: uint64 = p + ext4_block_size - 12
        _ext4_write_u32(cast[Ptr[uint8]](tail + 0), 0)      # fake inode=0
        _ext4_write_u16(cast[Ptr[uint8]](tail + 4), 12)     # rec_len=12
        cast[Ptr[uint8]](tail + 6)[0] = 0                   # name_len=0
        cast[Ptr[uint8]](tail + 7)[0] = 0xDE                # file_type
        _ext4_write_u32(cast[Ptr[uint8]](tail + 8), 0)      # det_checksum


def _ext4_dir_create_child(parent_inum: uint64,
                           name: Ptr[char]) -> uint32:
    # Allocate a new directory inode + one data block for ". .." dirents,
    # write everything, splice a dirent into `parent_inum` pointing at
    # the new dir. Returns the new dir's inum (0 on failure with best-
    # effort rollback of any partial allocs).
    if parent_inum == 0:
        return 0
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        printk0("[ext4_mkdir] alloc_inode FAIL\n")
        return 0
    new_blk: uint64 = ext4_alloc_block()
    if new_blk == 0:
        printk0("[ext4_mkdir] alloc_block FAIL\n")
        ext4_free_inode(new_inum)
        return 0
    # Lay down the . / .. dirents into ext4_blk_buf, write to disk.
    _ext4_write_dot_dotdot(&ext4_blk_buf[0], new_inum,
                           cast[uint32](parent_inum))
    # Stamp the new dir block's tail checksum. A fresh dir inode's
    # i_generation is 0 (_ext4_build_dir_inode zeroes the inode), so the
    # seed uses generation 0 — matching what a later read recomputes.
    _ext4_dirblock_stamp_in_buf(cast[uint64](new_inum), 0)
    if _ext4_write_block(new_blk, &ext4_blk_buf[0]) != 0:
        printk0("[ext4_mkdir] write data block FAIL\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0
    # Build + write the dir inode.
    _ext4_build_dir_inode(&ext4_mkdir_inode_buf[0], new_blk)
    if ext4_write_inode(cast[uint64](new_inum),
                        &ext4_mkdir_inode_buf[0]) != 0:
        printk0("[ext4_mkdir] write inode FAIL\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0
    # Insert the dirent (type=EXT4_FT_DIR=2) into the parent.
    if ext4_dir_insert(parent_inum, name, new_inum, 2) != 0:
        printk0("[ext4_mkdir] dir_insert into parent FAIL\n")
        ext4_free_block(new_blk)
        ext4_free_inode(new_inum)
        return 0
    # Bump the parent's i_links_count: a fresh subdir's ".." raises
    # the parent's link count by 1 (every dir increments its parent
    # via the "..\0" backreference). The parent's i_size doesn't
    # change (ext4_dir_insert split an existing dirent's slack).
    parent_inode: Array[256, uint8]
    if ext4_read_inode(parent_inum, &parent_inode[0]) == 0:
        cur_links: uint16 = _ext4_read_u16(
            cast[Ptr[uint8]](
                cast[uint64](&parent_inode[0]) + 0x1A))
        _ext4_write_u16(
            cast[Ptr[uint8]](cast[uint64](&parent_inode[0]) + 0x1A),
            cast[uint16](cast[uint64](cur_links) + 1))
        _ext4_stamp_mtime(&parent_inode[0])
        ext4_write_inode(parent_inum, &parent_inode[0])
    return new_inum


# Scratch path-walk buffers — kept module-scoped so a recursive path
# install doesn't blow the kernel stack. _ext4_walk_path_mkdir_p and
# ext4_blob_save_at_path share these because both run inside the
# bracketed save/restore in ext4_install_file_to_slot; no nesting.
ext4_walk_comp_buf: Array[256, uint8]                       # component scratch


def _ext4_walk_path_mkdir_p(path: Ptr[char],
                            leaf_off_out: Ptr[uint64],
                            leaf_len_out: Ptr[uint64]) -> uint32:
    # Walk `path` left-to-right, creating any missing INTERMEDIATE dir
    # components (mkdir -p semantics). The LAST component is left as
    # the basename — leaf_off_out is its offset within `path`,
    # leaf_len_out is its length. Returns the inum of the parent
    # directory that should receive the leaf, or 0 on any error.
    #
    # Path normalisation:
    #   * Leading '/' is skipped (paths are partition-relative).
    #   * Trailing '/' is rejected (we can't tell whether the caller
    #     wants a file or a dir at that slot).
    #   * Empty path / "/" — returns 0 (no leaf).
    #   * "//" runs collapse to single '/'.
    n: uint64 = _ext4_strlen(path)
    if n == 0:
        return 0
    # Skip leading slash(es).
    s: uint64 = 0
    while s < n and path[s] == 47:
        s = s + 1
    if s >= n:
        return 0                                            # bare "/" or empty
    if path[n - 1] == 47:
        printk0("[ext4_mkdir_p] trailing slash unsupported\n")
        return 0

    cur_parent: uint64 = 2                                  # ext4 root
    i: uint64 = s
    while i < n:
        # Find next '/' (or end-of-string).
        j: uint64 = i
        while j < n and path[j] != 47:
            j = j + 1
        # Component span: [i, j).
        comp_len: uint64 = j - i
        if comp_len == 0:
            # "//" collision in the middle; advance past extra slashes.
            i = j + 1
            continue
        if comp_len > 255:
            printk0("[ext4_mkdir_p] component too long\n")
            return 0
        # If this is the LAST component, return; the caller writes
        # the file (or dir) here.
        if j >= n:
            leaf_off_out[0] = i
            leaf_len_out[0] = comp_len
            return cast[uint32](cur_parent)
        # Intermediate component — look up; mkdir if missing.
        # Copy into a NUL-terminated cstring for the helper.
        k: uint64 = 0
        while k < comp_len:
            ext4_walk_comp_buf[k] = cast[uint8](path[i + k] & 0xFF)
            k = k + 1
        ext4_walk_comp_buf[comp_len] = 0

        child_inum:  uint32 = 0
        child_ftype: uint8  = 0
        r: int32 = _ext4_dir_find_entry(
            cur_parent, cast[Ptr[char]](&ext4_walk_comp_buf[0]),
            &child_inum, &child_ftype)
        if r < 0:
            printk0("[ext4_mkdir_p] find_entry error\n")
            return 0
        if r == 0:
            # Missing — create it.
            new_inum: uint32 = _ext4_dir_create_child(
                cur_parent,
                cast[Ptr[char]](&ext4_walk_comp_buf[0]))
            if new_inum == 0:
                return 0
            cur_parent = cast[uint64](new_inum)
        else:
            # Existing — must be a directory.
            if child_ftype != 2:
                printk0("[ext4_mkdir_p] component is not a dir\n")
                return 0
            cur_parent = cast[uint64](child_inum)
        # Advance past the '/'.
        i = j + 1
    # Should have returned via the leaf branch.
    return 0


# ext4_blob_save_at_path: like ext4_blob_save but the file lands at
# an arbitrary path. Reuses the same on-disk write shape (depth-0
# extent leaf, EXT4_FT_REG_FILE dirent) — the only difference is the
# parent directory, which is now whatever _ext4_walk_path_mkdir_p
# resolves to.

# Per-leaf scratch (shared with the file-install path; not nested).
ext4_blob_leaf_buf: Array[256, uint8]


def _ext4_dir_unlink_in_dir(parent_inum: uint64,
                            name_buf: Ptr[uint8],
                            name_len: uint64) -> uint32:
    # Walk parent_inum's data blocks looking for `name_buf[0..name_len)`;
    # if found, tombstone the dirent (inum=0) and write the block back.
    # Returns the previous inum on hit, 0 on miss. Multi-block-aware
    # symmetric with _ext4_dir_unlink_in_root.
    if parent_inum == 0:
        return 0
    parent_inode: Array[256, uint8]
    if ext4_read_inode(parent_inum, &parent_inode[0]) != 0:
        return 0
    parent_gen: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&parent_inode[0]) + 0x64))
    dir_size: uint64 = cast[uint64](
        ext4_inode_size_lo(&parent_inode[0]))
    if dir_size == 0:
        return 0
    nblocks: uint64 = (dir_size + ext4_block_size - 1) \
                    / ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        phys: uint64 = _ext4_logical_to_physical(
            &parent_inode[0], lb)
        if phys == 0:
            return 0
        if _ext4_read_block(phys, &ext4_blk_buf[0]) != 0:
            return 0
        pos: uint64 = 0
        while pos < ext4_block_size:
            e: uint64 = cast[uint64](&ext4_blk_buf[0]) + pos
            e_inum:    uint32 = _ext4_read_u32(cast[Ptr[uint8]](e + 0))
            e_rec_len: uint16 = _ext4_read_u16(cast[Ptr[uint8]](e + 4))
            if e_rec_len == 0:
                break
            if e_inum != 0:
                e_name_len: uint64 = cast[uint64](
                    cast[Ptr[uint8]](e + 6)[0])
                if e_name_len == name_len \
                        and _name_eq_with_len(
                            cast[Ptr[uint8]](e + 8),
                            name_buf, name_len) != 0:
                    _ext4_write_u32(cast[Ptr[uint8]](e + 0), 0)
                    _ext4_dirblock_stamp_in_buf(parent_inum, parent_gen)
                    _ext4_write_block(phys, &ext4_blk_buf[0])
                    return e_inum
            pos = pos + cast[uint64](e_rec_len)
        lb = lb + 1
    return 0


def ext4_blob_save_at_path(path: Ptr[char], src: Ptr[uint8],
                           length: uint64) -> int64:
    # Create-or-overwrite the file at `path` so it holds exactly
    # `length` bytes from `src`. Intermediate parent dirs are created
    # mkdir -p style. Returns the byte count on success, -1 on any
    # failure. The path is partition-relative; a leading '/' is
    # accepted and stripped.
    if ext4_blockdev_slot < 0:
        return cast[int64](-1)
    leaf_off: uint64 = 0
    leaf_len: uint64 = 0
    parent_inum: uint32 = _ext4_walk_path_mkdir_p(path,
                                                  &leaf_off,
                                                  &leaf_len)
    if parent_inum == 0:
        return cast[int64](-1)
    if leaf_len == 0 or leaf_len > 255:
        return cast[int64](-1)
    # Copy the leaf basename into ext4_blob_leaf_buf as a NUL-terminated
    # cstring. ext4_dir_insert + _ext4_dir_unlink_in_dir read raw bytes;
    # the NUL is for printk debug paths only.
    i: uint64 = 0
    while i < leaf_len:
        ext4_blob_leaf_buf[i] = cast[uint8](path[leaf_off + i] & 0xFF)
        i = i + 1
    ext4_blob_leaf_buf[leaf_len] = 0
    leaf_name: Ptr[char] = cast[Ptr[char]](&ext4_blob_leaf_buf[0])

    # If a file by this name exists already, unlink it first so we
    # can create-or-replace (idempotent install).
    old_inum: uint32 = _ext4_dir_unlink_in_dir(
        cast[uint64](parent_inum),
        &ext4_blob_leaf_buf[0], leaf_len)
    if old_inum != 0:
        if ext4_read_inode(cast[uint64](old_inum),
                           &ext4_blob_inode[0]) == 0:
            _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(old_inum)
        # Page-cache coherence: old inum freed + possibly reused; drop it.
        fcache_drop_inode_nowriteback(PC_SRV_EXT4, cast[uint64](old_inum))

    # Allocate a new inode, build an empty leaf, grow block-by-block.
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        printk0("ext4: blob_save_at_path FAIL (alloc_inode)\n")
        return cast[int64](-1)
    p: Ptr[uint8] = &ext4_blob_inode[0]
    _ext4_zero(p, ext4_inode_size)
    _ext4_write_u16(p, 0x81B4)                              # IFREG|0664
    _ext4_inode_stamp_creator(p)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26), 1)  # i_links
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32),
                    0x80000)                                # EXT4_EXTENTS_FL
    eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)            # eh_entries
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)            # eh_max
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)            # eh_depth
    _ext4_write_u32(cast[Ptr[uint8]](eh + 8), 0)            # eh_generation
    _ext4_stamp_all_times(p)
    # Grow block-by-block via the inline depth-0 leaf.
    nblocks: uint64 = (length + ext4_block_size - 1) / ext4_block_size
    sectors_per_block: uint64 = ext4_block_size / SECTOR_SIZE
    lb: uint64 = 0
    while lb < nblocks:
        nb: uint64 = ext4_alloc_block()
        if nb == 0:
            printk0("ext4: blob_save_at_path FAIL (out of blocks)\n")
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        _ext4_zero(&ext4_blob_buf[0], ext4_block_size)
        off: uint64 = lb * ext4_block_size
        chunk: uint64 = length - off
        if chunk > ext4_block_size:
            chunk = ext4_block_size
        if chunk > 0:
            memcpy(&ext4_blob_buf[0],
                   cast[Ptr[uint8]](cast[uint64](src) + off), chunk)
        if _ext4_write_block(nb, &ext4_blob_buf[0]) != 0:
            printk0("ext4: blob_save_at_path FAIL (write data)\n")
            ext4_free_block(nb)
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        if _ext4_extent_append_block(&ext4_blob_inode[0], lb, nb) != 0:
            printk0("ext4: blob_save_at_path FAIL (extent leaf full)\n")
            # Depth-0 leaf has 4 extent slots; with the multi-group
            # alloc_block walking groups in order, a freshly-mkfs'd
            # target hands out contiguous blocks that coalesce into a
            # single extent. A 4-slot fail here means the target FS
            # was fragmented before the install — escalate, don't
            # paper over with index-extent-nodes (M16.66 follow-up).
            ext4_free_block(nb)
            _ext4_extent_trim_to(&ext4_blob_inode[0], lb)
            ext4_free_inode(new_inum)
            return cast[int64](-1)
        lb = lb + 1
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4),
                    cast[uint32](length))                   # i_size_lo
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28),
                    cast[uint32](nblocks * sectors_per_block))
    _ext4_stamp_mtime(p)
    if ext4_write_inode(cast[uint64](new_inum),
                        &ext4_blob_inode[0]) != 0:
        printk0("ext4: blob_save_at_path FAIL (write inode)\n")
        _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(new_inum)
        return cast[int64](-1)
    # Splice the dirent (EXT4_FT_REG_FILE = 1) into the parent.
    if ext4_dir_insert(cast[uint64](parent_inum), leaf_name,
                       new_inum, 1) != 0:
        printk0("ext4: blob_save_at_path FAIL (dir_insert)\n")
        _ext4_extent_trim_to(&ext4_blob_inode[0], 0)
        ext4_free_inode(new_inum)
        return cast[int64](-1)
    blk_flush(ext4_blockdev_slot)
    return cast[int64](length)


# --- ext4 install file to an alternate slot -----------------------
#
# The installer needs to write package files into a freshly-formatted
# TARGET partition that is NOT the live ext4 mount the kernel booted
# from. Approach B per the brief (2026-05-27): save the singleton
# mount state, ext4_init the target, ext4_blob_save_at_path at the
# target's resolved-or-created parent dir, then restore the singleton
# so the live FS stays functional. Bracketed save+restore so the live
# mount survives a failure mid-install — every error path lands on
# the restore stub.
#
# Scope: regular files at any path. ext4_blob_save_at_path creates
# missing intermediate directories on the fly (mkdir -p) and handles
# multi-block bodies via the depth-0 extent leaf (~50 KiB to a few
# MiB depending on block_size + contiguity). Files >4 non-contiguous
# extents would need index-extent-node support — not in scope for v1,
# since multi-group alloc_block hands out contiguous blocks on a
# freshly-mkfs'd target and the production payload tops out at
# ~2.6 MiB per file (libstdc++.so.6.0.33).

def ext4_install_file_to_slot(slot: int32, path: Ptr[char],
                              data: Ptr[uint8],
                              data_len: uint64) -> int32:
    # Write `data[0..data_len)` to the file `<path>` on the freshly-
    # formatted ext4 partition at `slot`. `path` may include slashes —
    # missing parent dirs are created on the fly. The currently-mounted
    # ext4 (if any) is bracketed by a save+restore so its globals
    # survive the call regardless of whether the install succeeds.
    # Returns 0 on success, -1 on any failure.
    if slot < 0:
        return -1
    # Snapshot the current mount.
    s_slot:  int32  = ext4_blockdev_slot
    s_bs:    uint64 = ext4_block_size
    s_bpg:   uint64 = ext4_blocks_per_grp
    s_ipg:   uint64 = ext4_inodes_per_grp
    s_ic:    uint64 = ext4_inodes_count
    s_bc:    uint64 = ext4_blocks_count
    s_fdb:   uint64 = ext4_first_data_blk
    s_isz:   uint64 = ext4_inode_size
    s_ds:    uint64 = ext4_desc_size
    s_gdt:   uint64 = ext4_gdt_block

    # Init the target. This re-reads the target's superblock and
    # repopulates every mount global.
    if ext4_init(slot) != 0:
        printk1("[ext4_install_file] init target slot=%d FAIL\n",
                cast[uint64](slot))
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1

    # Write the file (path-aware: mkdir-p the parent if needed).
    rc: int64 = ext4_blob_save_at_path(path, data, data_len)

    # Restore the previous mount UNCONDITIONALLY so the live FS keeps
    # serving even if the install failed.
    _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                             s_bc, s_fdb, s_isz, s_ds, s_gdt)

    if rc < 0:
        printk1("[ext4_install_file] blob_save FAIL slot=%d\n",
                cast[uint64](slot))
        return -1
    printk2("[ext4_install_file] slot=%d wrote %d bytes OK\n",
            cast[uint64](slot), cast[uint64](rc))
    return 0


def ext4_mkdir_at_slot(slot: int32, path: Ptr[char]) -> int32:
    # mkdir -p the path on a freshly-formatted ext4 partition at
    # `slot`. Same save/restore bracket as ext4_install_file_to_slot,
    # so the live mount survives. Returns 0 on success (every component
    # exists or was created), -1 on any failure. Idempotent — calling
    # twice with the same path is a no-op the second time.
    if slot < 0:
        return -1
    if path[0] == 0:
        return -1
    s_slot:  int32  = ext4_blockdev_slot
    s_bs:    uint64 = ext4_block_size
    s_bpg:   uint64 = ext4_blocks_per_grp
    s_ipg:   uint64 = ext4_inodes_per_grp
    s_ic:    uint64 = ext4_inodes_count
    s_bc:    uint64 = ext4_blocks_count
    s_fdb:   uint64 = ext4_first_data_blk
    s_isz:   uint64 = ext4_inode_size
    s_ds:    uint64 = ext4_desc_size
    s_gdt:   uint64 = ext4_gdt_block

    if ext4_init(slot) != 0:
        printk1("[ext4_mkdir] init target slot=%d FAIL\n",
                cast[uint64](slot))
        _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                                 s_bc, s_fdb, s_isz, s_ds, s_gdt)
        return -1

    # Walk every component, creating missing ones. We feed the LEAF
    # component back through _ext4_dir_create_child since
    # _ext4_walk_path_mkdir_p only ensures INTERMEDIATE dirs exist.
    rc: int32 = 0
    leaf_off: uint64 = 0
    leaf_len: uint64 = 0
    parent_inum: uint32 = _ext4_walk_path_mkdir_p(path,
                                                  &leaf_off,
                                                  &leaf_len)
    if parent_inum == 0 or leaf_len == 0 or leaf_len > 255:
        rc = -1
    else:
        # Copy leaf into scratch, NUL-terminate, lookup-or-create.
        i: uint64 = 0
        while i < leaf_len:
            ext4_walk_comp_buf[i] = cast[uint8](path[leaf_off + i] & 0xFF)
            i = i + 1
        ext4_walk_comp_buf[leaf_len] = 0
        leaf_name: Ptr[char] = cast[Ptr[char]](&ext4_walk_comp_buf[0])

        child_inum:  uint32 = 0
        child_ftype: uint8  = 0
        r: int32 = _ext4_dir_find_entry(
            cast[uint64](parent_inum), leaf_name,
            &child_inum, &child_ftype)
        if r < 0:
            rc = -1
        elif r == 0:
            # Missing — create it.
            new_inum: uint32 = _ext4_dir_create_child(
                cast[uint64](parent_inum), leaf_name)
            if new_inum == 0:
                rc = -1
        else:
            # Existing — must be a dir.
            if child_ftype != 2:
                printk0("[ext4_mkdir] leaf exists but not a dir\n")
                rc = -1
    if rc == 0:
        blk_flush(ext4_blockdev_slot)

    _ext4_mkfs_restore_state(s_slot, s_bs, s_bpg, s_ipg, s_ic,
                             s_bc, s_fdb, s_isz, s_ds, s_gdt)
    if rc == 0:
        printk1("[ext4_mkdir] slot=%d OK\n", cast[uint64](slot))
    else:
        printk1("[ext4_mkdir] slot=%d FAIL\n", cast[uint64](slot))
    return rc


def ext4_mkdir_live(path: Ptr[char]) -> int32:
    # Live mkdir against the currently-mounted ext4 slot. Unlike
    # ext4_mkdir_at_slot (which is the installer-time helper and
    # save/restore-wraps an ext4_init against an UN-mounted target),
    # this is called from vfs_mkdir for a /ext/* path while the FS is
    # already live. The save/restore dance would be wrong here: the
    # singleton ext4 mount state we'd save IS the one we want to use.
    #
    # Semantics:
    #   * `path` is partition-relative (caller already stripped /ext/).
    #   * mkdir -p: missing intermediate components are created first
    #     by _ext4_walk_path_mkdir_p; only the LEAF needs explicit
    #     creation here.
    #   * leaf-exists-and-is-dir -> -EEXIST.
    #   * leaf-exists-and-is-file -> -ENOTDIR.
    #   * empty / bare-root path -> -EINVAL.
    # Returns 0 on success, -1/-EEXIST/-ENOTDIR/-EINVAL/-EROFS on
    # failure (matches the negative-errno convention used by
    # tmpfs_mkdir, what vfs_mkdir propagates verbatim).
    if ext4_blockdev_slot < 0:
        return -30                                          # -EROFS
    if path[0] == 0:
        return -22                                          # -EINVAL
    leaf_off: uint64 = 0
    leaf_len: uint64 = 0
    parent_inum: uint32 = _ext4_walk_path_mkdir_p(
        path, &leaf_off, &leaf_len)
    if parent_inum == 0:
        return -2                                           # -ENOENT
    if leaf_len == 0 or leaf_len > 255:
        return -22                                          # -EINVAL
    # Copy leaf into the shared scratch, NUL-terminate.
    i: uint64 = 0
    while i < leaf_len:
        ext4_walk_comp_buf[i] = cast[uint8](path[leaf_off + i] & 0xFF)
        i = i + 1
    ext4_walk_comp_buf[leaf_len] = 0
    leaf_name: Ptr[char] = cast[Ptr[char]](&ext4_walk_comp_buf[0])

    child_inum:  uint32 = 0
    child_ftype: uint8  = 0
    r: int32 = _ext4_dir_find_entry(
        cast[uint64](parent_inum), leaf_name,
        &child_inum, &child_ftype)
    if r < 0:
        return -1
    if r != 0:
        # Existing entry — must be a dir for idempotency; bare file
        # collision is -ENOTDIR.
        if child_ftype == 2:
            return -17                                      # -EEXIST
        return -20                                          # -ENOTDIR
    new_inum: uint32 = _ext4_dir_create_child(
        cast[uint64](parent_inum), leaf_name)
    if new_inum == 0:
        return -1
    blk_flush(ext4_blockdev_slot)
    return 0


# --- useradd home file-server provisioning ------------------------
#
# Adding a user to Hamnix means giving them their own top-level file
# SERVER on the shared ext4 root (docs/security.md): a named subtree
# `#<name>` that composes to `/ext/<name>/...` on disk and gets bound
# at /home/<name> in the user's login namespace. This keeps each
# home isolated by namespace while sharing the whole disk's free
# space.
#
# The partition ROOT (inum 2) carries the `.hamnix-roots` sentinel
# (one `<word> <relpath>` line per named subtree; the kernel's Phase 5
# discovery name_push()es `#<word>` for each) plus the per-name
# top-level subtree directories. The root is NOT addressable from a
# userland namespace (`/` is bound to `#sysroot`), so a userland
# binary CANNOT edit the sentinel or mkdir the top-level dir itself.
# This kernel-side helper does both atomically, driven by the
# SYS_USERADD_ROOT syscall (hostowner-gated in syscall.ad).

ext4_useradd_sentinel_buf: Array[4096, uint8]
ext4_useradd_new_buf:      Array[4160, uint8]


def _ext4_useradd_name_already_in_sentinel(
        name: Ptr[char], buf: Ptr[uint8], n: uint64) -> int32:
    # Returns 1 if a line of the sentinel body begins with `<name> `
    # (or `<name>` as the whole line), else 0. Line-oriented scan over
    # the `<word> <relpath>` records.
    nlen: uint64 = _ext4_strlen(name)
    if nlen == 0:
        return 0
    i: uint64 = 0
    while i < n:
        # Start of a line at i. Match name bytes.
        lmatch: int32 = 1
        j: uint64 = 0
        while j < nlen:
            if i + j >= n:
                lmatch = 0
                break
            if buf[i + j] != cast[uint8](name[j] & 0xFF):
                lmatch = 0
                break
            j = j + 1
        if lmatch == 1:
            # Char after the matched name must be a separator or EOL.
            after: uint64 = i + nlen
            if after >= n:
                return 1
            c: uint8 = buf[after]
            if c == 0x20 or c == 0x09 or c == 0x0A or c == 0x0D:
                return 1
        # Advance to the start of the next line.
        while i < n and buf[i] != 0x0A:
            i = i + 1
        i = i + 1                                  # step over the '\n'
    return 0


def ext4_root_blockdev_slot() -> int32:
    # The block-device slot of the currently-mounted ext4 root — the
    # partition ext4_useradd_root() writes `.hamnix-roots` + the new
    # `<name>/` subtree to. The named-root registry (chan.ad) keys every
    # partition's by-id record on exactly this slot value (chan_ref ==
    # block slot), so a caller can recover the partition's partuuid from
    # the by-id table without having to guess a root NAME (`#sysroot` on
    # an installed disk, `#distro` on the LIVE medium). Returns -1 when no
    # ext4 root is mounted (e.g. the cpio-only `-kernel` path).
    return ext4_blockdev_slot


def ext4_useradd_root(name: Ptr[char]) -> int32:
    # Provision the per-user home file server on the live ext4 root:
    #   1. validate `name` (<=31 chars, no '/'/whitespace, no leading
    #      dot),
    #   2. read `.hamnix-roots` from the partition root,
    #   3. refuse if `<name>` already declared (-EEXIST),
    #   4. rewrite `.hamnix-roots` = old body + `<name> <name>\n`,
    #   5. mkdir the top-level `<name>/` subtree (EEXIST is OK),
    #   6. flush the block device.
    # Returns 0 on success, or a negative errno:
    #   -30 (-EROFS)  no ext4 mounted / .hamnix-roots absent,
    #   -22 (-EINVAL) bad name,
    #   -17 (-EEXIST) name already a named root,
    #   -28 (-ENOSPC) sentinel would exceed the scratch buffer / write
    #                 short.
    if ext4_blockdev_slot < 0:
        return -30
    if name == cast[Ptr[char]](0) or name[0] == 0:
        return -22
    nlen: uint64 = _ext4_strlen(name)
    if nlen == 0 or nlen > 31:
        return -22
    if name[0] == 0x2E:                            # leading '.'
        return -22
    k: uint64 = 0
    while k < nlen:
        c: char = name[k]
        if c == 0x2F or c == 0x20 or c == 0x09 or c == 0x0A or c == 0x0D:
            return -22                             # '/', space, tab, CR/LF
        k = k + 1
    # Read the current sentinel body. Its absence means this disk was
    # not staged as a multi-root image — refuse rather than silently
    # create one.
    body_n: uint64 = 0
    if ext4_read_root_file(".hamnix-roots",
                           &ext4_useradd_sentinel_buf[0],
                           4096, &body_n) != 0:
        return -30
    if _ext4_useradd_name_already_in_sentinel(
            name, &ext4_useradd_sentinel_buf[0], body_n) == 1:
        return -17
    # Build new content: old body, ensure a trailing newline, then the
    # `<name> <name>\n` record. Bound everything to the 4160-byte
    # scratch (4096 body + 64 for "<name> <name>\n" with name<=31).
    out_n: uint64 = 0
    i: uint64 = 0
    while i < body_n:
        if out_n >= 4160:
            return -28
        ext4_useradd_new_buf[out_n] = ext4_useradd_sentinel_buf[i]
        out_n = out_n + 1
        i = i + 1
    # Guarantee a newline boundary before the appended record.
    if out_n > 0 and ext4_useradd_new_buf[out_n - 1] != 0x0A:
        if out_n >= 4160:
            return -28
        ext4_useradd_new_buf[out_n] = 0x0A
        out_n = out_n + 1
    # `<name>` again `<name>` `\n`.
    j: uint64 = 0
    while j < nlen:
        if out_n >= 4160:
            return -28
        ext4_useradd_new_buf[out_n] = cast[uint8](name[j] & 0xFF)
        out_n = out_n + 1
        j = j + 1
    if out_n >= 4160:
        return -28
    ext4_useradd_new_buf[out_n] = 0x20             # ' '
    out_n = out_n + 1
    j = 0
    while j < nlen:
        if out_n >= 4160:
            return -28
        ext4_useradd_new_buf[out_n] = cast[uint8](name[j] & 0xFF)
        out_n = out_n + 1
        j = j + 1
    if out_n >= 4160:
        return -28
    ext4_useradd_new_buf[out_n] = 0x0A             # '\n'
    out_n = out_n + 1
    # Rewrite .hamnix-roots in place (O_CREAT|O_TRUNC).
    slot: int32 = ext4_open_create_or_trunc(".hamnix-roots")
    if slot < 0:
        return -30
    w: int64 = ext4_write_open_file(
        slot, &ext4_useradd_new_buf[0], 0, out_n)
    ext4_close(slot)
    if w < 0 or cast[uint64](w) != out_n:
        return -28
    # Create the top-level subtree dir. EEXIST is fine (the dir may
    # have been staged already); any other negative is a hard error
    # EXCEPT we still consider the sentinel written.
    mk: int32 = ext4_mkdir_live(name)
    if mk != 0 and mk != -17:
        # Sentinel is updated but the dir create failed; surface it.
        blk_flush(ext4_blockdev_slot)
        return mk
    blk_flush(ext4_blockdev_slot)
    return 0


# --- ext4 offline resize-to-fit-disk (M16.x) ----------------------
#
# First-boot grow path: when an installed disk is larger than the
# source rootfs.img, extend the ext4 filesystem to fill the partition
# without depending on the Linux namespace's resize2fs. The kernel
# does the bookkeeping itself; no userland 9P resize daemon.
#
# Scope (first cut, must work):
#   * Offline only. The kernel calls resize before any /ext mount
#     opens the FS for write.
#   * Extends block count; adds block-bitmap + inode-bitmap + inode-
#     table + GDT entry for every new block group.
#   * Honours `resize_inode` (s_reserved_gdt_blocks > 0). When the
#     extra GDT entries fit in the existing primary GDT + reserved
#     GDT blocks, the grow is feasible. Otherwise -ENOSPC and the FS
#     is left untouched.
#   * Updates the primary superblock + GDT, AND backup copies at
#     sparse-super groups (powers of 3, 5, 7 + group 0/1).
#   * One group per stride (no flex_bg packing). The flex_bg feature
#     bit is a HINT, not a constraint — ext4 mounts non-flex layouts
#     fine even when the bit is set; per-group bitmaps just don't
#     get packed into a flex pool.
#
# metadata_csum (RO_COMPAT_METADATA_CSUM): SUPPORTED. When the SB
# declares the feature the grow recomputes, for every new group, the
# crc32c group-descriptor checksum (bg_checksum), the block- and
# inode-bitmap checksums (bg_*_bitmap_csum_lo/hi), and the trailing
# superblock s_checksum — all seeded by crc32c(~0, s_uuid). The result
# passes `e2fsck -f`. The legacy uninit_bg crc16 (RO_COMPAT_GDT_CSUM
# WITHOUT metadata_csum) is NOT maintained and still refused.
#
# Out of scope:
#   * Online resize (would need block-layer + journal coordination).
#   * 64bit blocks_count > 2^32. Refused; current installer disks are
#     all way under 4 TiB.
#   * Journal (rootfs is mkfs -O ^has_journal).
#   * Shrink (data migration).
#   * Inline data feature.
#
# Errno mapping:
EXT4_RESIZE_OK:      int32 = 0
EXT4_RESIZE_EINVAL:  int32 = -22
EXT4_RESIZE_EIO:     int32 = -5
EXT4_RESIZE_ENOSPC:  int32 = -28

# Slack threshold for "is grow worth doing?" — 4 MiB matches the
# threshold the _first_boot_grow_check stub already prints, and is
# larger than one block group's metadata overhead so we never grow
# when the new space wouldn't even fit a usable group.
EXT4_RESIZE_MIN_SLACK_BYTES: uint64 = 4194304

# Superblock field offsets used by the resize path. Mirror the
# top-of-file constants but kept local so the resize section is
# self-contained.
EXT4_SB_OFF_INODES_COUNT:      uint64 = 0x00
EXT4_SB_OFF_BLOCKS_COUNT_LO:   uint64 = 0x04
EXT4_SB_OFF_R_BLOCKS_LO:       uint64 = 0x08
EXT4_SB_OFF_FREE_BLOCKS_LO:    uint64 = 0x0C
EXT4_SB_OFF_FREE_INODES:       uint64 = 0x10
EXT4_SB_OFF_FIRST_DATA_BLOCK:  uint64 = 0x14
EXT4_SB_OFF_LOG_BLOCK_SIZE:    uint64 = 0x18
EXT4_SB_OFF_LOG_CLUSTER_SIZE:  uint64 = 0x1C   # s_log_cluster_size (bigalloc)
EXT4_SB_OFF_BLOCKS_PER_GROUP:  uint64 = 0x20
EXT4_SB_OFF_CLUSTERS_PER_GROUP: uint64 = 0x24  # s_clusters_per_group (bigalloc)
EXT4_SB_OFF_INODES_PER_GROUP:  uint64 = 0x28
EXT4_SB_OFF_MAGIC:             uint64 = 0x38
EXT4_SB_OFF_BLOCK_GROUP_NR:    uint64 = 0x3A
EXT4_SB_OFF_FIRST_INO:         uint64 = 0x54
EXT4_SB_OFF_INODE_SIZE:        uint64 = 0x58
EXT4_SB_OFF_FEATURE_COMPAT:    uint64 = 0x5C
EXT4_SB_OFF_FEATURE_INCOMPAT:  uint64 = 0x60
EXT4_SB_OFF_FEATURE_RO_COMPAT: uint64 = 0x64
EXT4_SB_OFF_RESERVED_GDT_BLKS: uint64 = 0xCE
EXT4_SB_OFF_LOG_GROUPS_PER_FLEX: uint64 = 0xCC  # s_log_groups_per_flex (u8)
EXT4_SB_OFF_DESC_SIZE:         uint64 = 0xFE
EXT4_SB_OFF_BLOCKS_COUNT_HI:   uint64 = 0x150
EXT4_SB_OFF_FREE_BLOCKS_HI:    uint64 = 0x158

# Feature flag bits the resize cares about.
EXT4_FEATURE_COMPAT_HAS_JOURNAL: uint32 = 0x4
EXT4_FEATURE_COMPAT_RESIZE_INODE: uint32 = 0x10
EXT4_FEATURE_COMPAT_FAST_COMMIT:  uint32 = 0x400
EXT4_FEATURE_INCOMPAT_FILETYPE:   uint32 = 0x2
EXT4_FEATURE_INCOMPAT_EXTENTS:    uint32 = 0x40
EXT4_FEATURE_INCOMPAT_64BIT:      uint32 = 0x80
EXT4_FEATURE_INCOMPAT_META_BG:    uint32 = 0x10
EXT4_FEATURE_INCOMPAT_FLEX_BG:    uint32 = 0x200
EXT4_FEATURE_RO_COMPAT_SPARSE_SUPER: uint32 = 0x1
EXT4_FEATURE_RO_COMPAT_GDT_CSUM:     uint32 = 0x10
EXT4_FEATURE_RO_COMPAT_BIGALLOC:     uint32 = 0x200
EXT4_FEATURE_RO_COMPAT_METADATA_CSUM: uint32 = 0x400
EXT4_FEATURE_INCOMPAT_INLINE_DATA:    uint32 = 0x8000
EXT4_FEATURE_INCOMPAT_EA_INODE:       uint32 = 0x400
# INCOMPAT_LARGEDIR: htree directories may grow to 3 index levels (the
# default cap is 2). When set, dx_root.indirect_levels may be 2.
EXT4_FEATURE_INCOMPAT_LARGEDIR:       uint32 = 0x4000


# Scratch buffer for reading the 1024-byte superblock from disk
# directly, independent of the global ext4_sb_buf which is owned by
# ext4_init. Sized to one block (4 KiB) so a single _ext4_read_block
# call covers it for both 1 KiB and 4 KiB block sizes.
ext4_resize_sb_buf: Array[4096, uint8]

# Scratch buffer for writing a single FS block during the grow. Big
# enough for 4 KiB blocks; the inode-table-zeroing loop reuses it.
ext4_resize_blk_buf: Array[4096, uint8]

# Second scratch buffer so the old-last-group padding fixup can hold a
# bitmap block while ext4_resize_blk_buf holds the GDT block.
ext4_resize_bm_buf: Array[4096, uint8]


def _ext4_resize_log_features(compat: uint32, incompat: uint32,
                              ro_compat: uint32):
    # Dump the feature triple so a refused grow's log shows exactly
    # which feature blocked it. Loud per the brief — printk1 each.
    printk1("[ext4_resize] feature_compat    = 0x%x\n",
            cast[uint64](compat))
    printk1("[ext4_resize] feature_incompat  = 0x%x\n",
            cast[uint64](incompat))
    printk1("[ext4_resize] feature_ro_compat = 0x%x\n",
            cast[uint64](ro_compat))


def _ext4_resize_read_sb(slot: int32) -> int32:
    # Read sectors 2..3 (the 1024-byte superblock) into the resize
    # scratch buffer at offset 0. Caller indexes into the buffer with
    # the SB field offsets — there's no boot-area pad in this buffer.
    rc: int32 = blk_read_sectors(slot, 2, 2,
                                 &ext4_resize_sb_buf[0])
    if rc != 0:
        printk1("[ext4_resize] sb read FAIL slot=%d\n",
                cast[uint64](slot))
        return EXT4_RESIZE_EIO
    return 0


def _ext4_resize_sb_u32(buf: Ptr[uint8], off: uint64) -> uint32:
    return _ext4_read_u32(cast[Ptr[uint8]](cast[uint64](buf) + off))


def _ext4_resize_sb_u16(buf: Ptr[uint8], off: uint64) -> uint16:
    return _ext4_read_u16(cast[Ptr[uint8]](cast[uint64](buf) + off))


def ext4_resize_check(slot: int32,
                      partition_size_bytes: uint64) -> int32:
    # Read the ext4 superblock at `slot`, compare its recorded
    # block-count to `partition_size_bytes`, and decide whether grow
    # is needed AND feasible.
    #
    # Returns:
    #   0  no grow needed (slack < EXT4_RESIZE_MIN_SLACK_BYTES)
    #   1  grow needed AND feasible
    #   -EINVAL  grow needed but FS has features the simple extend
    #            can't safely handle (journal, metadata_csum,
    #            gdt_csum, meta_bg, blocks_count > 4 GiB / 64bit
    #            overflow)
    #   -ENOSPC  grow needed but the new groups' GDT entries won't
    #            fit in primary GDT + reserved_gdt_blocks
    #   -EIO     superblock read failed
    if slot < 0:
        return EXT4_RESIZE_EINVAL
    if _ext4_resize_read_sb(slot) != 0:
        return EXT4_RESIZE_EIO

    sb: Ptr[uint8] = &ext4_resize_sb_buf[0]
    magic: uint16 = _ext4_resize_sb_u16(sb, EXT4_SB_OFF_MAGIC)
    if magic != EXT4_MAGIC:
        printk1("[ext4_resize] slot=%d not ext4 (magic=0x%x)\n",
                cast[uint64](slot))
        return EXT4_RESIZE_EINVAL

    log_bs: uint32 = _ext4_resize_sb_u32(sb,
                                         EXT4_SB_OFF_LOG_BLOCK_SIZE)
    blk_sz: uint64 = cast[uint64](1024) << cast[uint64](log_bs)
    bc_lo: uint32 = _ext4_resize_sb_u32(sb,
                                        EXT4_SB_OFF_BLOCKS_COUNT_LO)
    bc_hi: uint32 = _ext4_resize_sb_u32(sb,
                                        EXT4_SB_OFF_BLOCKS_COUNT_HI)
    cur_blocks: uint64 = cast[uint64](bc_lo) \
                         | (cast[uint64](bc_hi) << 32)
    cur_bytes: uint64 = cur_blocks * blk_sz
    bpg: uint32 = _ext4_resize_sb_u32(sb,
                                      EXT4_SB_OFF_BLOCKS_PER_GROUP)
    ipg: uint32 = _ext4_resize_sb_u32(sb,
                                      EXT4_SB_OFF_INODES_PER_GROUP)
    isize: uint16 = _ext4_resize_sb_u16(sb, EXT4_SB_OFF_INODE_SIZE)
    desc_sz: uint16 = _ext4_resize_sb_u16(sb, EXT4_SB_OFF_DESC_SIZE)
    if desc_sz == 0:
        desc_sz = 32
    rgdt: uint16 = _ext4_resize_sb_u16(sb,
                                       EXT4_SB_OFF_RESERVED_GDT_BLKS)
    compat: uint32 = _ext4_resize_sb_u32(sb,
                                         EXT4_SB_OFF_FEATURE_COMPAT)
    incompat: uint32 = _ext4_resize_sb_u32(sb,
                                           EXT4_SB_OFF_FEATURE_INCOMPAT)
    ro_compat: uint32 = _ext4_resize_sb_u32(sb,
                                            EXT4_SB_OFF_FEATURE_RO_COMPAT)

    printk2("[ext4_resize] slot=%d block_size=%d\n",
            cast[uint64](slot), blk_sz)
    printk2("[ext4_resize]   current blocks=%d (%d bytes)\n",
            cur_blocks, cur_bytes)
    printk2("[ext4_resize]   partition bytes=%d  blocks_per_group=%d\n",
            partition_size_bytes, cast[uint64](bpg))
    printk2("[ext4_resize]   inodes_per_group=%d  inode_size=%d\n",
            cast[uint64](ipg), cast[uint64](isize))
    printk2("[ext4_resize]   desc_size=%d  reserved_gdt_blocks=%d\n",
            cast[uint64](desc_sz), cast[uint64](rgdt))
    _ext4_resize_log_features(compat, incompat, ro_compat)

    # Slack check first — bail before refusing on features the user
    # doesn't actually need to bypass.
    if partition_size_bytes <= cur_bytes:
        printk0("[ext4_resize] partition <= fs; no grow\n")
        return 0
    slack: uint64 = partition_size_bytes - cur_bytes
    if slack < EXT4_RESIZE_MIN_SLACK_BYTES:
        printk1("[ext4_resize] slack %d < 4 MiB; no grow\n", slack)
        return 0

    # Refuse on features the simple offline extend doesn't handle.
    if (compat & EXT4_FEATURE_COMPAT_HAS_JOURNAL) != 0:
        printk0("[ext4_resize] refuse: HAS_JOURNAL set (journal replay needed)\n")
        return EXT4_RESIZE_EINVAL
    # metadata_csum (RO_COMPAT_METADATA_CSUM) IS supported: the grow path
    # recomputes the crc32c group-descriptor, block/inode-bitmap, and
    # superblock checksums for every new group. The legacy uninit_bg
    # checksum (RO_COMPAT_GDT_CSUM) WITHOUT metadata_csum uses a crc16 we
    # don't maintain, so refuse that combination only.
    has_meta_csum: int32 = 0
    if (ro_compat & EXT4_FEATURE_RO_COMPAT_METADATA_CSUM) != 0:
        has_meta_csum = 1
    if (ro_compat & EXT4_FEATURE_RO_COMPAT_GDT_CSUM) != 0 \
       and has_meta_csum == 0:
        printk0("[ext4_resize] refuse: GDT_CSUM (uninit_bg crc16) without metadata_csum\n")
        return EXT4_RESIZE_EINVAL
    if has_meta_csum != 0:
        if crc32c_selftest() == 0:
            printk0("[ext4_resize] refuse: crc32c KAT failed; can't maintain metadata_csum\n")
            return EXT4_RESIZE_EINVAL
        printk0("[ext4_resize] metadata_csum present; grow will recompute checksums\n")
    if (incompat & EXT4_FEATURE_INCOMPAT_META_BG) != 0:
        printk0("[ext4_resize] refuse: META_BG set (alt GDT layout unsupported)\n")
        return EXT4_RESIZE_EINVAL
    if (incompat & EXT4_FEATURE_INCOMPAT_EXTENTS) == 0:
        printk0("[ext4_resize] refuse: EXTENTS not set (non-ext4 layout)\n")
        return EXT4_RESIZE_EINVAL

    # Compute target geometry. We add only WHOLE block groups (the
    # tail-of-partition slack smaller than one group is intentionally
    # discarded — at most blocks_per_group-1 blocks = 8 MiB for the
    # default 1 KiB / 8192-bpg layout). Aligns with resize_grow's
    # rounding so the check + the actual grow agree.
    new_blocks_raw: uint64 = partition_size_bytes / blk_sz
    if new_blocks_raw <= cast[uint64](_ext4_resize_sb_u32(sb,
                                EXT4_SB_OFF_FIRST_DATA_BLOCK)):
        printk0("[ext4_resize] target <= first_data_block; no grow\n")
        return 0
    fdb_local: uint64 = cast[uint64](_ext4_resize_sb_u32(sb,
                                EXT4_SB_OFF_FIRST_DATA_BLOCK))
    new_groups: uint64 = (new_blocks_raw - fdb_local) / cast[uint64](bpg)
    new_blocks: uint64 = fdb_local + new_groups * cast[uint64](bpg)
    if new_blocks <= cur_blocks:
        printk0("[ext4_resize] target rounds to <= current; no grow\n")
        return 0
    # 64bit overflow guard — refuse a >4 GiB jump when the FS doesn't
    # already have the 64bit feature, since bc_hi is 0 today.
    if new_blocks > 0xFFFFFFFF \
       and (incompat & EXT4_FEATURE_INCOMPAT_64BIT) == 0:
        printk0("[ext4_resize] refuse: new blocks_count > 32 bits, 64bit feat off\n")
        return EXT4_RESIZE_EINVAL

    # Old group count uses CEIL so a partial last group counts as one
    # group. The grow loop only ADDS whole groups beyond old_groups.
    old_groups: uint64 = (cur_blocks - fdb_local + cast[uint64](bpg) - 1) \
                         / cast[uint64](bpg)
    if new_groups <= old_groups:
        # The whole-group target doesn't add any group beyond what we
        # already have — partition has slack but it's smaller than one
        # block group. Refuse the grow to keep this idempotent.
        printk2("[ext4_resize] target groups %d <= current %d; no grow\n",
                new_groups, old_groups)
        return 0
    add_groups: uint64 = new_groups - old_groups
    printk2("[ext4_resize]   target blocks=%d  groups: %d ->",
            new_blocks, old_groups)
    printk1(" %d\n", new_groups)
    printk1("[ext4_resize]   adding %d block group(s)\n", add_groups)

    # The GDT lives in blocks starting at first_data_block + 1. Its
    # capacity is (1 + reserved_gdt_blocks) * (block_size / desc_size).
    # If our new total group count exceeds that, refuse — we'd need
    # the resize_inode dance (relocate primary GDT into inode #7's
    # data blocks), which is out of scope for the first cut.
    primary_gdt_blocks: uint64 = \
        (old_groups * cast[uint64](desc_sz) + blk_sz - 1) / blk_sz
    gdt_capacity_entries: uint64 = \
        (primary_gdt_blocks + cast[uint64](rgdt)) \
        * (blk_sz / cast[uint64](desc_sz))
    printk2("[ext4_resize]   primary_gdt_blocks=%d capacity_entries=%d\n",
            primary_gdt_blocks, gdt_capacity_entries)
    if new_groups > gdt_capacity_entries:
        printk2("[ext4_resize] refuse ENOSPC: new_groups=%d > gdt_cap=%d\n",
                new_groups, gdt_capacity_entries)
        printk0("[ext4_resize]   bump s_reserved_gdt_blocks at mkfs time or\n")
        printk0("[ext4_resize]   implement resize_inode (inode #7 relocation).\n")
        return EXT4_RESIZE_ENOSPC

    printk1("[ext4_resize] OK: grow %d byte(s) feasible\n",
            partition_size_bytes - cur_bytes)
    return 1


# ---- Phase 2: the actual extend ---------------------------------
#
# `ext4_resize_grow(slot, new_blocks_count)`:
#   1. Re-read SB (single source of truth for geometry).
#   2. Round new_blocks_count down to whole groups — partial last
#      group is out of scope. Tail wasted at most blocks_per_group-1
#      blocks (8 MiB for the default 1 KiB/8192 layout).
#   3. For each new group g in [old_groups, new_groups):
#        a. Decide sparse-super membership.
#        b. Compute group metadata layout (bitmap, inode bitmap,
#           inode table — at group start, after any sparse reserve).
#        c. Initialize the block bitmap (mark metadata used, plus
#           the sparse reserve if applicable; rest free).
#        d. Zero the inode bitmap and inode table.
#        e. Write a fresh GDT entry for g into the primary GDT
#           (lands in the reserved-gdt blocks naturally as the GDT
#           grows past its original extent).
#   4. Update primary superblock fields:
#        s_blocks_count_lo (+ _hi if 64bit feature set)
#        s_free_blocks_count_lo (+ _hi)
#        s_inodes_count
#        s_free_inodes_count
#      (Group count is derived from blocks_count/blocks_per_group;
#       there is no s_groups_count field in the SB.)
#   5. Write SB back; flush.
#
# Backup superblocks + backup GDTs at sparse-super groups are NOT
# updated. Linux ext4 mount uses only the primary SB; e2fsck cares
# about backup parity but the FS is fully mountable without it. A
# user can `tune2fs -O ^sparse_super && tune2fs -O sparse_super` or
# `resize2fs -f` from the linux ns to rewrite backups if needed.

# GDT entry field offsets (within the 32- or 64-byte descriptor):
EXT4_BG_BLOCK_BITMAP_LO:    uint64 = 0x00
EXT4_BG_INODE_BITMAP_LO:    uint64 = 0x04
EXT4_BG_INODE_TABLE_LO:     uint64 = 0x08
EXT4_BG_FREE_BLOCKS_LO:     uint64 = 0x0C
EXT4_BG_FREE_INODES_LO:     uint64 = 0x0E
EXT4_BG_USED_DIRS_LO:       uint64 = 0x10
EXT4_BG_FLAGS:              uint64 = 0x12
EXT4_BG_ITABLE_UNUSED_LO:   uint64 = 0x1C
EXT4_BG_CHECKSUM:           uint64 = 0x1E
EXT4_BG_BLOCK_BITMAP_HI:    uint64 = 0x20
EXT4_BG_INODE_BITMAP_HI:    uint64 = 0x24
EXT4_BG_INODE_TABLE_HI:     uint64 = 0x28
EXT4_BG_FREE_BLOCKS_HI:     uint64 = 0x2C
EXT4_BG_FREE_INODES_HI:     uint64 = 0x2E
EXT4_BG_USED_DIRS_HI:       uint64 = 0x30
EXT4_BG_ITABLE_UNUSED_HI:   uint64 = 0x32

# bg_flags: EXT4_BG_INODE_UNINIT (0x1), EXT4_BG_BLOCK_UNINIT (0x2),
# EXT4_BG_INODE_ZEROED (0x4). We zero everything and set
# INODE_ZEROED so a future mount-time scrubber doesn't try to lazily
# zero what's already zero.
EXT4_BG_FLAG_INODE_UNINIT: uint16 = 0x1
EXT4_BG_FLAG_BLOCK_UNINIT: uint16 = 0x2
EXT4_BG_FLAG_INODE_ZEROED: uint16 = 0x4

# metadata_csum per-group bitmap checksum fields. The block-bitmap and
# inode-bitmap crc32c is split into a u16 LO in the 32-byte descriptor
# core and (on a >=64-byte / 64bit descriptor) a u16 HI in the extended
# half. Mirrors struct ext4_group_desc bg_block_bitmap_csum_{lo,hi} /
# bg_inode_bitmap_csum_{lo,hi}.
EXT4_BG_BLOCK_BITMAP_CSUM_LO: uint64 = 0x18
EXT4_BG_INODE_BITMAP_CSUM_LO: uint64 = 0x1A
EXT4_BG_BLOCK_BITMAP_CSUM_HI: uint64 = 0x38
EXT4_BG_INODE_BITMAP_CSUM_HI: uint64 = 0x3A

# resize-local metadata_csum state. The resize path runs OFFLINE against
# `slot` — which is not necessarily the currently-mounted FS — so the
# global ext4_metadata_csum / ext4_csum_seed (owned by ext4_init for the
# mounted volume) can't be trusted here. _ext4_resize_read_sb seeds these
# from the resize SB's own UUID + feature bits before any group is built.
ext4_resize_metadata_csum: int32  = 0
ext4_resize_csum_seed:     uint32 = 0


def _ext4_resize_arm_csum(sb: Ptr[uint8]):
    # Derive the resize-local crc32c seed + feature flag from the SB
    # image currently in the resize scratch buffer. The seed is the RAW
    # running register crc32c_update(~0, s_uuid, 16) — the same form
    # ext4_init computes for the mounted volume and the same form Linux
    # uses when the metadata_csum_seed feature is OFF (our test images
    # mint with ^metadata_csum_seed so s_uuid IS the seed source). A
    # broken crc32c primitive disables csum maintenance rather than
    # silently writing garbage checksums.
    ext4_resize_metadata_csum = 0
    ext4_resize_csum_seed = 0
    ro_compat: uint32 = _ext4_resize_sb_u32(sb,
                                            EXT4_SB_OFF_FEATURE_RO_COMPAT)
    if (ro_compat & EXT4_FEATURE_RO_COMPAT_METADATA_CSUM) == 0:
        return
    if crc32c_selftest() == 0:
        printk0("[ext4_resize] crc32c KAT failed; refusing csum grow\n")
        return
    ext4_resize_csum_seed = crc32c_update(
        0xFFFFFFFF,
        cast[Ptr[uint8]](cast[uint64](sb) + EXT4_SB_OFF_UUID), 16)
    ext4_resize_metadata_csum = 1


def _ext4_resize_bitmap_csum(bitmap: Ptr[uint8], nbytes: uint64) -> uint32:
    # crc32c over a whole bitmap block, seeded by the fs csum_seed.
    # ext4_block_bitmap_csum / ext4_inode_bitmap_csum checksum the FULL
    # bitmap block (block_size bytes), not just the live-bit prefix —
    # the tail "past end of group" bits are part of the on-disk image
    # e2fsck folds, so `nbytes` is always the block size here.
    return crc32c_update(ext4_resize_csum_seed, bitmap, nbytes)


def _ext4_resize_gd_csum(desc: Ptr[uint8], group: uint64,
                         desc_size: uint64) -> uint16:
    # crc32c group-descriptor checksum (metadata_csum variant of
    # ext4_group_desc_csum). Chain mirrors the Linux kernel EXACTLY:
    #   crc = crc32c(csum_seed, &group_le32, 4)
    #   crc = crc32c(crc, gdp, offsetof(bg_checksum))      # [0, 0x1E)
    #   crc = crc32c(crc, &dummy_zero, 2)                  # checksum field as 0
    #   crc = crc32c(crc, gdp + 0x20, desc_size - 0x20)    # [0x20, desc_size)
    # NOTE: the 2-byte bg_checksum field is folded in as TWO ZERO BYTES,
    # not skipped. Skipping it (folding only [0,0x1E)+[0x20,end]) yields a
    # different crc and e2fsck rejects it.
    g_le: Array[4, uint8]
    _ext4_write_u32(&g_le[0], cast[uint32](group))
    crc: uint32 = crc32c_update(ext4_resize_csum_seed, &g_le[0], 4)
    crc = crc32c_update(crc, desc, EXT4_BG_CHECKSUM)
    zero2: Array[2, uint8]
    zero2[0] = 0
    zero2[1] = 0
    crc = crc32c_update(crc, &zero2[0], 2)
    after: uint64 = EXT4_BG_CHECKSUM + 2
    if desc_size > after:
        crc = crc32c_update(
            crc,
            cast[Ptr[uint8]](cast[uint64](desc) + after),
            desc_size - after)
    return cast[uint16](crc & 0xFFFF)


def _ext4_resize_sb_csum_seed(sb: Ptr[uint8]) -> uint32:
    # crc32c over the 1 KiB superblock image MINUS its trailing 4-byte
    # s_checksum. RAW register (no final xor) — same as _ext4_sb_csum
    # but against the resize scratch buffer rather than the mounted
    # ext4_sb_buf.
    return crc32c_update(0xFFFFFFFF, sb, EXT4_SB_OFF_CHECKSUM)


def _ext4_resize_pow_test(n: uint64, base: uint64) -> int32:
    # Return 1 iff `n` is a non-zero power of `base` (base^k for some
    # k >= 0). Used by the sparse_super predicate.
    if n == 0:
        return 0
    x: uint64 = 1
    while x < n:
        x = x * base
    if x == n:
        return 1
    return 0


def _ext4_resize_is_sparse(g: uint64) -> int32:
    # sparse_super pattern: backup SB+GDT at groups 0, 1, and any
    # group whose number is a power of 3, 5, or 7. Mirror of
    # fs/ext4/super.c::ext4_bg_has_super().
    if g == 0:
        return 1
    if g == 1:
        return 1
    if _ext4_resize_pow_test(g, 3) != 0:
        return 1
    if _ext4_resize_pow_test(g, 5) != 0:
        return 1
    if _ext4_resize_pow_test(g, 7) != 0:
        return 1
    return 0


def _ext4_resize_write_block(slot: int32, block_size: uint64,
                             block_nr: uint64,
                             buf: Ptr[uint8]) -> int32:
    # Slot-aware block write — ext4_resize_grow runs while the FS
    # is unmounted (offline), so the global ext4_blockdev_slot may
    # belong to a different mount. Always pass the slot in.
    sectors_per_block: uint64 = block_size / SECTOR_SIZE
    lba: uint64 = block_nr * sectors_per_block
    return blk_write_sectors(slot, lba, sectors_per_block, buf)


def _ext4_resize_read_block(slot: int32, block_size: uint64,
                            block_nr: uint64,
                            buf: Ptr[uint8]) -> int32:
    sectors_per_block: uint64 = block_size / SECTOR_SIZE
    lba: uint64 = block_nr * sectors_per_block
    return blk_read_sectors(slot, lba, sectors_per_block, buf)


def _ext4_resize_zero_buf(p: Ptr[uint8], n: uint64):
    i: uint64 = 0
    while i < n:
        p[i] = 0
        i = i + 1


def _ext4_resize_build_block_bitmap(buf: Ptr[uint8],
                                    block_size: uint64,
                                    used_blocks: uint64,
                                    group_blocks: uint64):
    # Build a block bitmap for a fresh group:
    #   bits 0..used_blocks-1     : 1 (metadata in use)
    #   bits used_blocks..group_blocks-1 : 0 (free data)
    #   bits group_blocks..block_size*8-1 : 1 (past end-of-group)
    # The last region only matters when group_blocks < block_size*8
    # (i.e. the bitmap addresses more bits than the group has blocks);
    # for our 1 KiB block / 8192 blocks_per_group case the bitmap is
    # exactly 8192 bits = 1024 bytes = 1 block, so the third region
    # is empty. Kept for future-proofing against larger block sizes.
    _ext4_resize_zero_buf(buf, block_size)
    bits_total: uint64 = block_size * 8
    # First: set bits 0..used_blocks-1.
    full_bytes: uint64 = used_blocks / 8
    i: uint64 = 0
    while i < full_bytes:
        buf[i] = 0xFF
        i = i + 1
    rem: uint64 = used_blocks % 8
    if rem != 0:
        bit_idx: uint64 = 0
        m: uint8 = 0
        while bit_idx < rem:
            m = m | (cast[uint8](1) << cast[uint8](bit_idx))
            bit_idx = bit_idx + 1
        buf[full_bytes] = buf[full_bytes] | m
    # Set bits group_blocks..bits_total-1 (past end-of-group).
    if group_blocks < bits_total:
        # Set partial bits in the byte containing group_blocks, then
        # all bytes after.
        b: uint64 = group_blocks
        while b < bits_total:
            byte_idx: uint64 = b / 8
            bit_idx2: uint64 = b % 8
            mask: uint8 = cast[uint8](1) << cast[uint8](bit_idx2)
            buf[byte_idx] = buf[byte_idx] | mask
            b = b + 1


def _ext4_resize_write_gdt_entry(slot: int32, block_size: uint64,
                                 first_data_block: uint64,
                                 desc_size: uint64,
                                 group: uint64,
                                 bm_blk: uint64,
                                 ibm_blk: uint64,
                                 itab_blk: uint64,
                                 free_blocks: uint64,
                                 free_inodes: uint64,
                                 itab_blocks: uint64,
                                 bbm_csum: uint32,
                                 ibm_csum: uint32,
                                 itab_unused: uint64) -> int32:
    # Splice a new GDT entry for `group` into the primary GDT. The
    # GDT entry lives at byte offset group * desc_size from the start
    # of the GDT (first_data_block + 1). The block holding the entry
    # might be in the primary GDT region OR the reserved-GDT region —
    # both are physically contiguous; we just compute the address and
    # read-modify-write that one block.
    gdt_byte_off: uint64 = group * desc_size
    gdt_blk: uint64 = first_data_block + 1 \
                      + (gdt_byte_off / block_size)
    within: uint64 = gdt_byte_off % block_size
    if _ext4_resize_read_block(slot, block_size, gdt_blk,
                               &ext4_resize_blk_buf[0]) != 0:
        printk1("[ext4_resize] gdt read FAIL group=%d\n", group)
        return -1
    entry: uint64 = cast[uint64](&ext4_resize_blk_buf[0]) + within
    # Zero the descriptor first (the rest of the desc_size area).
    _ext4_resize_zero_buf(cast[Ptr[uint8]](entry), desc_size)
    _ext4_write_u32(cast[Ptr[uint8]](entry + EXT4_BG_BLOCK_BITMAP_LO),
                    cast[uint32](bm_blk & 0xFFFFFFFF))
    _ext4_write_u32(cast[Ptr[uint8]](entry + EXT4_BG_INODE_BITMAP_LO),
                    cast[uint32](ibm_blk & 0xFFFFFFFF))
    _ext4_write_u32(cast[Ptr[uint8]](entry + EXT4_BG_INODE_TABLE_LO),
                    cast[uint32](itab_blk & 0xFFFFFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_BLOCKS_LO),
                    cast[uint16](free_blocks & 0xFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_INODES_LO),
                    cast[uint16](free_inodes & 0xFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_USED_DIRS_LO), 0)
    # bg_flags: when metadata_csum is on we set INODE_ZEROED (the inode
    # table was just fully zeroed, so a mount-time lazy-init scrubber
    # must NOT re-zero it) and bg_itable_unused = the unused-inode count
    # (every inode in a fresh group is unused). These hints are honoured
    # under metadata_csum and let e2fsck skip scanning the zeroed table.
    # Without metadata_csum, the legacy ^gdt_csum semantics apply: non-
    # zero flags are refused as "uninit without feature set", so we
    # keep flags == 0 / itable_unused == 0 there exactly as before.
    bg_flags_v: uint16 = 0
    itu_v: uint64 = 0
    if ext4_resize_metadata_csum != 0:
        bg_flags_v = EXT4_BG_FLAG_INODE_ZEROED
        itu_v = itab_unused
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FLAGS), bg_flags_v)
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_ITABLE_UNUSED_LO),
                    cast[uint16](itu_v & 0xFFFF))
    # Per-bitmap crc32c (low halves). Zero is the correct stored value
    # when metadata_csum is off (the fields are reserved/ignored).
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_BLOCK_BITMAP_CSUM_LO),
                    cast[uint16](bbm_csum & 0xFFFF))
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_INODE_BITMAP_CSUM_LO),
                    cast[uint16](ibm_csum & 0xFFFF))
    # 64-byte descriptor: fill the _hi halves.
    if desc_size >= 64:
        _ext4_write_u32(cast[Ptr[uint8]](entry + EXT4_BG_BLOCK_BITMAP_HI),
                        cast[uint32]((bm_blk >> 32) & 0xFFFFFFFF))
        _ext4_write_u32(cast[Ptr[uint8]](entry + EXT4_BG_INODE_BITMAP_HI),
                        cast[uint32]((ibm_blk >> 32) & 0xFFFFFFFF))
        _ext4_write_u32(cast[Ptr[uint8]](entry + EXT4_BG_INODE_TABLE_HI),
                        cast[uint32]((itab_blk >> 32) & 0xFFFFFFFF))
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_BLOCKS_HI),
                        cast[uint16]((free_blocks >> 16) & 0xFFFF))
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_INODES_HI),
                        cast[uint16]((free_inodes >> 16) & 0xFFFF))
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_USED_DIRS_HI), 0)
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_ITABLE_UNUSED_HI),
                        cast[uint16]((itu_v >> 16) & 0xFFFF))
        _ext4_write_u16(
            cast[Ptr[uint8]](entry + EXT4_BG_BLOCK_BITMAP_CSUM_HI),
            cast[uint16]((bbm_csum >> 16) & 0xFFFF))
        _ext4_write_u16(
            cast[Ptr[uint8]](entry + EXT4_BG_INODE_BITMAP_CSUM_HI),
            cast[uint16]((ibm_csum >> 16) & 0xFFFF))
    # bg_checksum LAST — it folds the rest of the (now-final) descriptor.
    # Under metadata_csum it's a crc32c truncated to 16 bits; otherwise
    # zero (the legacy uninit_bg crc16 is unused on our images).
    bg_csum_v: uint16 = 0
    if ext4_resize_metadata_csum != 0:
        bg_csum_v = _ext4_resize_gd_csum(cast[Ptr[uint8]](entry),
                                         group, desc_size)
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_CHECKSUM), bg_csum_v)
    if _ext4_resize_write_block(slot, block_size, gdt_blk,
                                &ext4_resize_blk_buf[0]) != 0:
        printk1("[ext4_resize] gdt write FAIL group=%d\n", group)
        return -1
    return 0


def _ext4_resize_fixup_old_tail(slot: int32, block_size: uint64,
                                first_data_block: uint64,
                                desc_size: uint64,
                                blocks_per_group: uint64,
                                old_group: uint64,
                                old_blocks_count: uint64,
                                new_blocks_count: uint64,
                                clusters_per_group: uint64) -> int64:
    # Fix the group that WAS the filesystem's last group before the grow.
    # ext4 block bitmaps address blocks_per_group bits, but only the
    # blocks below s_blocks_count are real; the tail bits are padding set
    # to 1. When the grow raises s_blocks_count, blocks that were padding
    # in old_group become REAL FREE data blocks, so their bitmap bits must
    # be CLEARED and the group's free count raised. Without this e2fsck
    # reports "Block bitmap differences" + a wrong free count for the old
    # tail group (and "Padding ... not set" if the new tail isn't padded).
    #
    # Returns the number of newly-freed blocks (>=0) or -1 on I/O error.
    # The caller folds the freed count into the superblock free-block sum.
    grp_first: uint64 = first_data_block + old_group * blocks_per_group
    # Old valid bits in this group: [0, old_valid). After grow the group
    # is fully real up to min(grp_first+bpg, new_blocks_count).
    old_end: uint64 = old_blocks_count
    if old_end > grp_first + blocks_per_group:
        old_end = grp_first + blocks_per_group
    new_end: uint64 = new_blocks_count
    if new_end > grp_first + blocks_per_group:
        new_end = grp_first + blocks_per_group
    if new_end <= old_end:
        return 0                       # nothing newly valid in this group

    old_valid: uint64 = old_end - grp_first      # bit index of first pad
    new_valid: uint64 = new_end - grp_first      # bit index of new first pad

    # Read this group's descriptor to find its block bitmap + free count.
    gdt_byte_off: uint64 = old_group * desc_size
    gdt_blk: uint64 = first_data_block + 1 + (gdt_byte_off / block_size)
    within: uint64 = gdt_byte_off % block_size
    if _ext4_resize_read_block(slot, block_size, gdt_blk,
                               &ext4_resize_blk_buf[0]) != 0:
        return -1
    entry: uint64 = cast[uint64](&ext4_resize_blk_buf[0]) + within
    bm_lo: uint32 = _ext4_read_u32(cast[Ptr[uint8]](entry
                                   + EXT4_BG_BLOCK_BITMAP_LO))
    bm_blk: uint64 = cast[uint64](bm_lo)
    if desc_size >= 64:
        bm_hi: uint32 = _ext4_read_u32(cast[Ptr[uint8]](entry
                                       + EXT4_BG_BLOCK_BITMAP_HI))
        bm_blk = bm_blk | (cast[uint64](bm_hi) << 32)
    if bm_blk == 0:
        return -1
    if _ext4_resize_read_block(slot, block_size, bm_blk,
                               &ext4_resize_bm_buf[0]) != 0:
        return -1
    # Clear bits [old_valid, new_valid) — now real free blocks.
    freed: uint64 = 0
    b: uint64 = old_valid
    while b < new_valid:
        byte_i: uint64 = b / 8
        bit_i:  uint64 = b % 8
        mask: uint8 = cast[uint8](1) << cast[uint8](bit_i)
        if (ext4_resize_bm_buf[byte_i] & mask) != 0:
            ext4_resize_bm_buf[byte_i] = ext4_resize_bm_buf[byte_i] & (~mask)
            freed = freed + 1
        b = b + 1
    if _ext4_resize_write_block(slot, block_size, bm_blk,
                                &ext4_resize_bm_buf[0]) != 0:
        return -1

    # Raise the group's free-block count by `freed` (lo + optional hi).
    cur_lo: uint16 = _ext4_read_u16(cast[Ptr[uint8]](entry
                                    + EXT4_BG_FREE_BLOCKS_LO))
    cur: uint64 = cast[uint64](cur_lo)
    if desc_size >= 64:
        cur_hi: uint16 = _ext4_read_u16(cast[Ptr[uint8]](entry
                                        + EXT4_BG_FREE_BLOCKS_HI))
        cur = cur | (cast[uint64](cur_hi) << 16)
    cur = cur + freed
    _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_BLOCKS_LO),
                    cast[uint16](cur & 0xFFFF))
    if desc_size >= 64:
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_FREE_BLOCKS_HI),
                        cast[uint16]((cur >> 16) & 0xFFFF))

    # Refresh this group's block-bitmap csum + bg_checksum (metadata_csum).
    if ext4_resize_metadata_csum != 0:
        bbm_bytes: uint64 = clusters_per_group / 8
        if bbm_bytes > block_size:
            bbm_bytes = block_size
        bbm_c: uint32 = _ext4_resize_bitmap_csum(&ext4_resize_bm_buf[0],
                                                 bbm_bytes)
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_BLOCK_BITMAP_CSUM_LO),
                        cast[uint16](bbm_c & 0xFFFF))
        if desc_size >= 64:
            _ext4_write_u16(
                cast[Ptr[uint8]](entry + EXT4_BG_BLOCK_BITMAP_CSUM_HI),
                cast[uint16]((bbm_c >> 16) & 0xFFFF))
        bg_c: uint16 = _ext4_resize_gd_csum(cast[Ptr[uint8]](entry),
                                            old_group, desc_size)
        _ext4_write_u16(cast[Ptr[uint8]](entry + EXT4_BG_CHECKSUM), bg_c)

    if _ext4_resize_write_block(slot, block_size, gdt_blk,
                                &ext4_resize_blk_buf[0]) != 0:
        return -1
    return cast[int64](freed)


def ext4_resize_grow(slot: int32, new_blocks_count: uint64) -> int32:
    # Offline ext4 grow. Caller passes the desired new total block
    # count; we round DOWN to whole groups and append zero-or-more
    # block groups until the FS reaches that target.
    #
    # Returns 0 on success, -EINVAL/-EIO/-ENOSPC on failure (with
    # the FS in an indeterminate state — caller should refuse to
    # mount and trigger e2fsck, but a normal kernel mount of the
    # primary SB will still find a coherent layout as long as the
    # SB write succeeded last).
    if slot < 0:
        return EXT4_RESIZE_EINVAL
    if _ext4_resize_read_sb(slot) != 0:
        return EXT4_RESIZE_EIO

    sb: Ptr[uint8] = &ext4_resize_sb_buf[0]
    if _ext4_resize_sb_u16(sb, EXT4_SB_OFF_MAGIC) != EXT4_MAGIC:
        return EXT4_RESIZE_EINVAL

    # Arm metadata_csum maintenance from THIS sb's own UUID + feature
    # bits (offline grow: the global mount state belongs to a different
    # volume). All the per-group csum writes below no-op when it's off.
    _ext4_resize_arm_csum(sb)

    log_bs: uint32 = _ext4_resize_sb_u32(sb,
                                         EXT4_SB_OFF_LOG_BLOCK_SIZE)
    blk_sz: uint64 = cast[uint64](1024) << cast[uint64](log_bs)
    fdb: uint64 = cast[uint64](_ext4_resize_sb_u32(sb,
                              EXT4_SB_OFF_FIRST_DATA_BLOCK))
    bpg: uint64 = cast[uint64](_ext4_resize_sb_u32(sb,
                              EXT4_SB_OFF_BLOCKS_PER_GROUP))
    # clusters_per_group (bigalloc); equals bpg with bigalloc off. Used
    # to size block-bitmap csums (Linux folds clusters_per_group/8 bytes).
    cpg: uint64 = cast[uint64](_ext4_resize_sb_u32(sb,
                              EXT4_SB_OFF_CLUSTERS_PER_GROUP))
    if cpg == 0:
        cpg = bpg
    ipg: uint64 = cast[uint64](_ext4_resize_sb_u32(sb,
                              EXT4_SB_OFF_INODES_PER_GROUP))
    isize: uint64 = cast[uint64](_ext4_resize_sb_u16(sb,
                                EXT4_SB_OFF_INODE_SIZE))
    if isize == 0:
        isize = 128
    desc_sz: uint64 = cast[uint64](_ext4_resize_sb_u16(sb,
                                  EXT4_SB_OFF_DESC_SIZE))
    if desc_sz == 0:
        desc_sz = 32
    rgdt: uint64 = cast[uint64](_ext4_resize_sb_u16(sb,
                               EXT4_SB_OFF_RESERVED_GDT_BLKS))
    incompat: uint32 = _ext4_resize_sb_u32(sb,
                                           EXT4_SB_OFF_FEATURE_INCOMPAT)
    bc_lo: uint32 = _ext4_resize_sb_u32(sb,
                                        EXT4_SB_OFF_BLOCKS_COUNT_LO)
    bc_hi: uint32 = _ext4_resize_sb_u32(sb,
                                        EXT4_SB_OFF_BLOCKS_COUNT_HI)
    cur_blocks: uint64 = cast[uint64](bc_lo) \
                         | (cast[uint64](bc_hi) << 32)
    cur_inodes: uint32 = _ext4_resize_sb_u32(sb,
                                             EXT4_SB_OFF_INODES_COUNT)
    fb_lo: uint32 = _ext4_resize_sb_u32(sb,
                                        EXT4_SB_OFF_FREE_BLOCKS_LO)
    fb_hi: uint32 = _ext4_resize_sb_u32(sb,
                                        EXT4_SB_OFF_FREE_BLOCKS_HI)
    cur_free_blocks: uint64 = cast[uint64](fb_lo) \
                              | (cast[uint64](fb_hi) << 32)
    cur_free_inodes: uint32 = _ext4_resize_sb_u32(sb,
                                                  EXT4_SB_OFF_FREE_INODES)

    # Round new_blocks_count down to whole groups. Partial tail
    # discarded — at most bpg-1 blocks (= 8 MiB for the default
    # layout). The first group's first_data_block offset is
    # carried by the geometry, so we round in terms of group count.
    old_groups: uint64 = (cur_blocks - fdb + bpg - 1) / bpg
    # Block count covered when blocks 0..fdb-1 are pre-data + then
    # group 0 covers fdb..fdb+bpg-1 and so on, so:
    #   blocks_count = fdb + groups * bpg  (full groups)
    # The current FS already obeys cur_blocks = fdb + old_groups*bpg
    # for a non-partial last group (true of the rootfs).
    if new_blocks_count <= fdb:
        printk0("[ext4_resize] grow target <= first_data_block; nop\n")
        return EXT4_RESIZE_OK
    new_groups_raw: uint64 = (new_blocks_count - fdb) / bpg
    new_blocks: uint64 = fdb + new_groups_raw * bpg
    if new_blocks <= cur_blocks:
        printk0("[ext4_resize] post-round target <= current; nop\n")
        return EXT4_RESIZE_OK
    new_groups: uint64 = new_groups_raw
    if new_groups <= old_groups:
        # Target round-down lands at or before the current group
        # count — partition slack is smaller than one block group.
        # Same idempotency case the check arm already handles; bail
        # without touching the SB so the FS metadata isn't churned.
        printk2("[ext4_resize] grow no-op: new_groups=%d <= old=%d\n",
                new_groups, old_groups)
        return EXT4_RESIZE_OK

    # Sanity-check GDT capacity (mirror ext4_resize_check; cheap).
    primary_gdt_blocks_new: uint64 = \
        (new_groups * desc_sz + blk_sz - 1) / blk_sz
    primary_gdt_blocks_old: uint64 = \
        (old_groups * desc_sz + blk_sz - 1) / blk_sz
    if primary_gdt_blocks_new > primary_gdt_blocks_old + rgdt:
        printk2("[ext4_resize] grow ENOSPC: need %d GDT blocks, have %d\n",
                primary_gdt_blocks_new,
                primary_gdt_blocks_old + rgdt)
        return EXT4_RESIZE_ENOSPC

    inode_table_blocks: uint64 = (ipg * isize + blk_sz - 1) / blk_sz
    printk2("[ext4_resize_grow] slot=%d new_blocks=%d\n",
            cast[uint64](slot), new_blocks)
    printk2("[ext4_resize_grow]   groups %d -> %d\n",
            old_groups, new_groups)
    printk1("[ext4_resize_grow]   inode_table_blocks=%d per group\n",
            inode_table_blocks)

    # Accumulators for SB summary fields.
    added_blocks: uint64 = 0
    added_inodes: uint64 = 0
    added_free_blocks: uint64 = 0
    added_free_inodes: uint64 = 0

    g: uint64 = old_groups
    while g < new_groups:
        gs: uint64 = fdb + g * bpg                  # absolute block of group start
        group_blocks: uint64 = bpg                  # whole groups only

        is_sparse: int32 = _ext4_resize_is_sparse(g)
        # Layout: front of the group is the sparse SB+GDT+reserved
        # GDT area (if applicable), then bitmap, inode bitmap,
        # inode table, then free data.
        front_reserve: uint64 = 0
        if is_sparse != 0:
            # Backup SB block + N primary-sized GDT blocks +
            # reserved-GDT-blocks. We don't physically write the
            # backup SB/GDT (primary-only resize); the bitmap just
            # records the convention so a future tune2fs / resize2fs
            # -f can populate them without colliding with our data.
            front_reserve = 1 + primary_gdt_blocks_new + rgdt
        bm_offset:   uint64 = front_reserve
        ibm_offset:  uint64 = front_reserve + 1
        itab_offset: uint64 = front_reserve + 2
        used_blocks_in_group: uint64 = front_reserve + 2 \
                                       + inode_table_blocks

        bm_blk:   uint64 = gs + bm_offset
        ibm_blk:  uint64 = gs + ibm_offset
        itab_blk: uint64 = gs + itab_offset

        free_blocks_this_group: uint64 = group_blocks \
                                         - used_blocks_in_group
        free_inodes_this_group: uint64 = ipg
        # All inodes free — no reserved inodes in non-zero groups.

        # 1) Zero the inode table.
        _ext4_resize_zero_buf(&ext4_resize_blk_buf[0], blk_sz)
        zb: uint64 = 0
        while zb < inode_table_blocks:
            if _ext4_resize_write_block(slot, blk_sz,
                                        itab_blk + zb,
                                        &ext4_resize_blk_buf[0]) != 0:
                printk2("[ext4_resize] itab zero FAIL group=%d blk=%d\n",
                        g, itab_blk + zb)
                return EXT4_RESIZE_EIO
            zb = zb + 1

        # 2) Zero the inode bitmap (all inodes free).
        _ext4_resize_zero_buf(&ext4_resize_blk_buf[0], blk_sz)
        # ext4 inode bitmaps mark bits >= inodes_per_group as
        # "in-use" (the bitmap block addresses block_size*8 bits but
        # only ipg of them are real). Set tail bits used.
        bits_total: uint64 = blk_sz * 8
        if ipg < bits_total:
            tb: uint64 = ipg
            while tb < bits_total:
                byte_i: uint64 = tb / 8
                bit_i:  uint64 = tb % 8
                mask: uint8 = cast[uint8](1) << cast[uint8](bit_i)
                ext4_resize_blk_buf[byte_i] = \
                    ext4_resize_blk_buf[byte_i] | mask
                tb = tb + 1
        if _ext4_resize_write_block(slot, blk_sz, ibm_blk,
                                    &ext4_resize_blk_buf[0]) != 0:
            printk1("[ext4_resize] ibm write FAIL group=%d\n", g)
            return EXT4_RESIZE_EIO
        # Snapshot the inode-bitmap crc32c off the very buffer we just
        # wrote. Linux checksums the inode bitmap over (ipg+7)/8 bytes
        # — the live-bit span, NOT the whole block — so the tail padding
        # bits we set above are NOT folded into the inode-bitmap csum.
        ibm_csum: uint32 = 0
        if ext4_resize_metadata_csum != 0:
            ibm_bytes: uint64 = (ipg + 7) / 8
            ibm_csum = _ext4_resize_bitmap_csum(&ext4_resize_blk_buf[0],
                                                ibm_bytes)

        # 3) Build + write the block bitmap.
        _ext4_resize_build_block_bitmap(&ext4_resize_blk_buf[0],
                                        blk_sz,
                                        used_blocks_in_group,
                                        group_blocks)
        if _ext4_resize_write_block(slot, blk_sz, bm_blk,
                                    &ext4_resize_blk_buf[0]) != 0:
            printk1("[ext4_resize] bm write FAIL group=%d\n", g)
            return EXT4_RESIZE_EIO
        # Block bitmap csum spans clusters_per_group/8 bytes (== bpg/8
        # with bigalloc off), capped at the block size. For 1 KiB blocks
        # this equals blk_sz, but compute it explicitly so non-1-KiB
        # geometries stay correct.
        bbm_csum: uint32 = 0
        if ext4_resize_metadata_csum != 0:
            bbm_bytes: uint64 = cpg / 8
            if bbm_bytes > blk_sz:
                bbm_bytes = blk_sz
            bbm_csum = _ext4_resize_bitmap_csum(&ext4_resize_blk_buf[0],
                                                bbm_bytes)

        # 4) Write GDT entry for this group. itable_unused == ipg: every
        # inode in the fresh group is unused, so e2fsck may skip the
        # (zeroed) table entirely under metadata_csum.
        if _ext4_resize_write_gdt_entry(slot, blk_sz, fdb, desc_sz,
                                        g, bm_blk, ibm_blk, itab_blk,
                                        free_blocks_this_group,
                                        free_inodes_this_group,
                                        inode_table_blocks,
                                        bbm_csum, ibm_csum, ipg) != 0:
            return EXT4_RESIZE_EIO

        added_blocks = added_blocks + group_blocks
        added_inodes = added_inodes + ipg
        added_free_blocks = added_free_blocks + free_blocks_this_group
        added_free_inodes = added_free_inodes + free_inodes_this_group
        if is_sparse != 0:
            printk2("[ext4_resize_grow]   group %d (sparse) +%d free\n",
                    g, free_blocks_this_group)
        else:
            printk2("[ext4_resize_grow]   group %d        +%d free\n",
                    g, free_blocks_this_group)
        g = g + 1

    # 4.5) Fix the OLD last group's padding. Before the grow its bitmap
    # marked blocks at/after the old s_blocks_count as padding (used);
    # raising s_blocks_count turns those into real free data blocks, so
    # their bits must be cleared and the group's free count + csums
    # refreshed. `tail_freed` is folded into the SB free-block total.
    tail_freed: int64 = _ext4_resize_fixup_old_tail(
        slot, blk_sz, fdb, desc_sz, bpg,
        old_groups - 1, cur_blocks, new_blocks, cpg)
    if tail_freed < 0:
        printk0("[ext4_resize] old-tail padding fixup FAILED\n")
        return EXT4_RESIZE_EIO
    if tail_freed > 0:
        printk2("[ext4_resize_grow]   old tail group %d freed +%d pad block(s)\n",
                old_groups - 1, cast[uint64](tail_freed))

    # 5) Update primary SB and write it back. The total block count is
    # the whole-group target (fdb + new_groups*bpg), NOT cur_blocks +
    # appended-group blocks — the latter omits the first_data_block
    # offset and the padding blocks the old tail group just reclaimed.
    new_total_blocks: uint64 = new_blocks
    new_total_inodes: uint64 = cast[uint64](cur_inodes) + added_inodes
    new_free_blocks: uint64 = cur_free_blocks + added_free_blocks \
                              + cast[uint64](tail_freed)
    new_free_inodes: uint64 = cast[uint64](cur_free_inodes) \
                              + added_free_inodes

    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](sb)
                         + EXT4_SB_OFF_BLOCKS_COUNT_LO),
        cast[uint32](new_total_blocks & 0xFFFFFFFF))
    if (incompat & EXT4_FEATURE_INCOMPAT_64BIT) != 0:
        _ext4_write_u32(
            cast[Ptr[uint8]](cast[uint64](sb)
                             + EXT4_SB_OFF_BLOCKS_COUNT_HI),
            cast[uint32]((new_total_blocks >> 32) & 0xFFFFFFFF))
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](sb)
                         + EXT4_SB_OFF_FREE_BLOCKS_LO),
        cast[uint32](new_free_blocks & 0xFFFFFFFF))
    if (incompat & EXT4_FEATURE_INCOMPAT_64BIT) != 0:
        _ext4_write_u32(
            cast[Ptr[uint8]](cast[uint64](sb)
                             + EXT4_SB_OFF_FREE_BLOCKS_HI),
            cast[uint32]((new_free_blocks >> 32) & 0xFFFFFFFF))
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](sb)
                         + EXT4_SB_OFF_INODES_COUNT),
        cast[uint32](new_total_inodes & 0xFFFFFFFF))
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](sb)
                         + EXT4_SB_OFF_FREE_INODES),
        cast[uint32](new_free_inodes & 0xFFFFFFFF))

    # Disable the resize_inode feature + zero s_reserved_gdt_blocks.
    # mkfs sets up inode #7 (EXT4_RESIZE_INO) to pre-reserve backup
    # GDT blocks scattered across every sparse-super group. After our
    # grow, the new groups' bitmaps + inode tables land at the start
    # of each new group — which OVERLAPS the blocks inode #7 had
    # reserved. Linux's ext4_setup_system_zone calls
    # ext4_protect_reserved_inode iff RESIZE_INODE is set, and that
    # validation refuses the mount with EFSCORRUPTED on overlap.
    #
    # Clearing the compat bit makes the kernel skip inode #7 entirely
    # at mount; clearing s_reserved_gdt_blocks tells e2fsprogs the
    # reservation is gone. The user trades online-resize capability
    # for an offline-grown FS that mounts cleanly. (Online resize was
    # never wired up anyway — Hamnix only resizes offline at first
    # boot.) A future userland `resize2fs -f -p` could rebuild the
    # resize_inode if needed.
    cur_compat: uint32 = _ext4_resize_sb_u32(sb,
                                             EXT4_SB_OFF_FEATURE_COMPAT)
    new_compat: uint32 = cur_compat \
                         & (~EXT4_FEATURE_COMPAT_RESIZE_INODE)
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](sb)
                         + EXT4_SB_OFF_FEATURE_COMPAT),
        new_compat)
    _ext4_write_u16(
        cast[Ptr[uint8]](cast[uint64](sb)
                         + EXT4_SB_OFF_RESERVED_GDT_BLKS),
        cast[uint16](0))
    if (cur_compat & EXT4_FEATURE_COMPAT_RESIZE_INODE) != 0:
        printk0("[ext4_resize_grow] cleared COMPAT_RESIZE_INODE + s_reserved_gdt_blocks\n")
        printk0("[ext4_resize_grow]   (inode #7 reservations are stale post-grow)\n")

    # Recompute s_checksum LAST, over the now-final SB image. crc32c of
    # the 1 KiB superblock minus the trailing 4-byte field. No-op when
    # metadata_csum is off (the field is reserved there). Must run after
    # every other SB field mutation above so the digest covers them.
    if ext4_resize_metadata_csum != 0:
        sb_c: uint32 = _ext4_resize_sb_csum_seed(sb)
        _ext4_write_u32(
            cast[Ptr[uint8]](cast[uint64](sb) + EXT4_SB_OFF_CHECKSUM),
            sb_c)

    # Superblock lives at byte offset 1024 (= sectors 2..3). Our
    # scratch buffer holds the 1 KiB SB at offset 0; write_sectors
    # takes a 1024-byte chunk = 2 sectors.
    if blk_write_sectors(slot, 2, 2,
                         &ext4_resize_sb_buf[0]) != 0:
        printk0("[ext4_resize] SB write-back FAIL\n")
        return EXT4_RESIZE_EIO

    if blk_flush(slot) != 0:
        printk0("[ext4_resize] flush FAIL (best-effort)\n")
        # Not fatal — the data may sit in a write-cache the device
        # flushes on its own schedule. The next mount will pick up
        # whatever made it to disk.

    printk2("[ext4_resize_grow] DONE: blocks %d -> %d\n",
            cur_blocks, new_total_blocks)
    printk2("[ext4_resize_grow]       free_blocks %d -> %d\n",
            cur_free_blocks, new_free_blocks)
    printk2("[ext4_resize_grow]       inodes %d -> %d\n",
            cast[uint64](cur_inodes), new_total_inodes)
    return EXT4_RESIZE_OK



# --- extended attributes (xattr) + POSIX ACLs ---------------------
#
# ext4 stores extended attributes in two places, and we READ both,
# WRITE the in-inode one:
#
#  1. IN-INODE: for inodes with i_extra_isize > 0 (256-byte inodes),
#     the slack between the end of the fixed inode fields and the next
#     inode holds an xattr region. It begins at inode offset
#         128 + i_extra_isize
#     with a 4-byte magic word EXT4_XATTR_MAGIC (0xEA020000), then a
#     packed array of ext4_xattr_entry records terminated by a zeroed
#     entry (e_name_len==0 && e_name_index==0). Attribute VALUES are
#     packed downward from the END of the inode; for the in-inode case
#     e_value_offs is measured relative to the start of the *entries*
#     area (the byte right after the 4-byte magic). e_value_block is 0.
#
#  2. EXTERNAL BLOCK: i_file_acl (inode offset 0x68, u32) names a single
#     fs block. It starts with a 32-byte struct ext4_xattr_header
#     (h_magic 0xEA020000 at offset 0, then refcount/blocks/hash/...),
#     followed by the entry array, and values packed downward from the
#     END of the block. Here e_value_offs is relative to the start of
#     the block.
#
# struct ext4_xattr_entry (the same in both locations):
#   0x00  e_name_len    u8
#   0x01  e_name_index  u8   (prefix id -> name prefix string)
#   0x02  e_value_offs  u16
#   0x04  e_value_block u32  (0 for in-inode and for the external block)
#   0x08  e_value_size  u32
#   0x0C  e_hash        u32
#   0x10  name bytes (e_name_len, NOT NUL-terminated)
# then padded up to the next 4-byte boundary.
#
# Name index -> prefix:
#   1 = "user."
#   2 = "system.posix_acl_access"   (whole name; e_name_len==0)
#   3 = "system.posix_acl_default"  (whole name; e_name_len==0)
#   4 = "trusted."
#   6 = "security."
#   7 = "system."

EXT4_XATTR_MAGIC:        uint32 = 0xEA020000
INODE_I_FILE_ACL_OFFSET: uint64 = 0x68          # i_file_acl_lo (u32)
INODE_I_EXTRA_ISIZE_OFF: uint64 = 0x80          # i_extra_isize (u16)
EXT4_XATTR_HDR_LEN:      uint64 = 32            # external block header
EXT4_XATTR_ENTRY_HDR:    uint64 = 16           # fixed part of an entry

# Scratch for the external xattr block (read path only). 4 KiB matches
# the largest fs block we mount.
ext4_xattr_blk_buf: Array[4096, uint8]
# Scratch inode buffer for xattr round-trips that must not clobber a
# caller's inode buffer (selftest + set path read-modify-write).
ext4_xattr_inode_buf: Array[256, uint8]
# A fully-qualified name assembled from (prefix + suffix) for compares
# and for listxattr emission.
ext4_xattr_name_buf: Array[256, uint8]


def _ext4_xattr_align4(n: uint64) -> uint64:
    return (n + 3) & ~cast[uint64](3)


def _ext4_xattr_prefix(idx: uint8) -> Ptr[char]:
    # Map e_name_index -> fully-qualified prefix string. Index 2/3 are
    # the whole name (e_name_len is 0 for those), so the prefix IS the
    # complete attribute name.
    if idx == 1:
        return "user."
    if idx == 2:
        return "system.posix_acl_access"
    if idx == 3:
        return "system.posix_acl_default"
    if idx == 4:
        return "trusted."
    if idx == 6:
        return "security."
    if idx == 7:
        return "system."
    return ""


def _ext4_xattr_classify(name: Ptr[char], name_len: uint64,
                         suffix_off: Ptr[uint64]) -> uint8:
    # Inverse of _ext4_xattr_prefix: given a fully-qualified attribute
    # name, return its e_name_index and write the byte offset where the
    # stored suffix begins into suffix_off[0]. Returns 0 if no known
    # prefix matches (caller treats as unsupported namespace).
    if _ext4_str_has_prefix(name, name_len, "system.posix_acl_access") != 0:
        suffix_off[0] = name_len            # whole name; no suffix
        return 2
    if _ext4_str_has_prefix(name, name_len, "system.posix_acl_default") != 0:
        suffix_off[0] = name_len
        return 3
    if _ext4_str_has_prefix(name, name_len, "user.") != 0:
        suffix_off[0] = 5
        return 1
    if _ext4_str_has_prefix(name, name_len, "trusted.") != 0:
        suffix_off[0] = 8
        return 4
    if _ext4_str_has_prefix(name, name_len, "security.") != 0:
        suffix_off[0] = 9
        return 6
    if _ext4_str_has_prefix(name, name_len, "system.") != 0:
        suffix_off[0] = 7
        return 7
    return 0


def _ext4_str_has_prefix(s: Ptr[char], s_len: uint64,
                         prefix: Ptr[char]) -> int32:
    # 1 if `s` (length s_len) begins with the NUL-terminated `prefix`.
    plen: uint64 = _ext4_strlen(prefix)
    if plen > s_len:
        return 0
    i: uint64 = 0
    while i < plen:
        if s[i] != prefix[i]:
            return 0
        i = i + 1
    return 1


def _ext4_xattr_full_name(idx: uint8, name_bytes: Ptr[uint8],
                          name_len: uint64, out: Ptr[uint8]) -> uint64:
    # Assemble the fully-qualified name (prefix + stored suffix bytes)
    # into `out` and return its length. NOT NUL-terminated by this
    # helper; callers add the terminator where they need one.
    prefix: Ptr[char] = _ext4_xattr_prefix(idx)
    plen: uint64 = _ext4_strlen(prefix)
    i: uint64 = 0
    while i < plen:
        out[i] = cast[uint8](prefix[i])
        i = i + 1
    j: uint64 = 0
    while j < name_len:
        out[plen + j] = name_bytes[j]
        j = j + 1
    return plen + name_len


def _ext4_xattr_read_ea_inode(ea_inum: uint64, vsize: uint64,
                              out_buf: Ptr[uint8]) -> int32:
    # EA_INODE value read. The attribute's value is the regular file data
    # of inode `ea_inum`: walk its extents / block map (exactly as a normal
    # file read) and copy `vsize` bytes into out_buf. `vsize` is the xattr
    # entry's e_value_size, which equals the ea-inode's i_size, so the value
    # is returned in full even when it spans multiple filesystem blocks.
    # Returns the byte count copied, or -EIO (-5) if the inode/data is
    # unreadable. out_buf is the caller's getxattr buffer, already verified
    # to hold at least vsize bytes (the e_value_size > out_cap check ran
    # before we got here).
    NEG_EIO: int32 = -5
    if vsize == 0:
        return 0
    got: int64 = ext4_read_file(cast[uint32](ea_inum), 0, vsize, out_buf)
    if got != cast[int64](vsize):
        return NEG_EIO
    return cast[int32](vsize)


def _ext4_xattr_scan(entries_base: uint64, region_end: uint64,
                     value_base: uint64,
                     want: Ptr[char], want_len: uint64,
                     out_buf: Ptr[uint8], out_cap: uint64,
                     list_buf: Ptr[uint8], list_cap: uint64,
                     list_used: Ptr[uint64]) -> int32:
    # Single engine for both get and list over one entry array.
    #   entries_base : first ext4_xattr_entry byte
    #   region_end   : one past the last byte the entry array may occupy
    #   value_base   : base address e_value_offs is measured from
    # GET mode  : want != null. Returns value byte count copied into
    #             out_buf (capped to out_cap, -ERANGE if too small),
    #             or -1 ("not found here, keep searching elsewhere").
    # LIST mode : want == null. Appends each fully-qualified name plus a
    #             NUL into list_buf (bounded by list_cap), advances
    #             list_used, returns 0.
    NEG_ERANGE: int32 = -34                      # -ERANGE
    p: uint64 = entries_base
    while p + EXT4_XATTR_ENTRY_HDR <= region_end:
        ep: Ptr[uint8] = cast[Ptr[uint8]](p)
        e_name_len: uint8 = ep[0]
        e_name_idx: uint8 = ep[1]
        # Terminating zero entry: name_len==0 AND name_index==0.
        if e_name_len == 0 and e_name_idx == 0:
            return -1
        e_value_offs: uint16 = _ext4_read_u16(
            cast[Ptr[uint8]](p + 0x02))
        # e_value_inum overlaps the legacy e_value_block field at entry
        # offset 0x04. Without INCOMPAT_EA_INODE this is always 0; with the
        # feature a non-zero value names the inode holding the attribute's
        # value as that inode's regular file data.
        e_value_inum: uint32 = _ext4_read_u32(
            cast[Ptr[uint8]](p + 0x04))
        e_value_size: uint32 = _ext4_read_u32(
            cast[Ptr[uint8]](p + 0x08))
        name_bytes: Ptr[uint8] = cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR)
        flen: uint64 = _ext4_xattr_full_name(
            e_name_idx, name_bytes, cast[uint64](e_name_len),
            &ext4_xattr_name_buf[0])
        if want != cast[Ptr[char]](0):
            # GET: compare assembled name against the requested name.
            if flen == want_len \
               and _ext4_mem_eq(&ext4_xattr_name_buf[0],
                                cast[Ptr[uint8]](want), flen) != 0:
                vsize: uint64 = cast[uint64](e_value_size)
                if vsize > out_cap:
                    return NEG_ERANGE
                # EA_INODE: the value lives in its own inode's data blocks.
                # Gated on the feature bit AND a non-zero e_value_inum, so
                # every non-ea-inode attribute takes the original in-region
                # copy path bit-for-bit.
                if ext4_ea_inode != 0 and e_value_inum != 0:
                    return _ext4_xattr_read_ea_inode(
                        cast[uint64](e_value_inum), vsize, out_buf)
                vsrc: uint64 = value_base + cast[uint64](e_value_offs)
                memcpy(out_buf, cast[Ptr[uint8]](vsrc), vsize)
                return cast[int32](vsize)
        else:
            # LIST: emit "name\0" if it fits.
            used: uint64 = list_used[0]
            if used + flen + 1 <= list_cap:
                k: uint64 = 0
                while k < flen:
                    list_buf[used + k] = ext4_xattr_name_buf[k]
                    k = k + 1
                list_buf[used + flen] = 0
                list_used[0] = used + flen + 1
        # Advance to the next entry: header + name, padded to 4 bytes.
        p = p + _ext4_xattr_align4(
            EXT4_XATTR_ENTRY_HDR + cast[uint64](e_name_len))
    return -1


def _ext4_mem_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _ext4_xattr_inode_region(inode_buf: Ptr[uint8],
                             entries_out: Ptr[uint64],
                             vbase_out: Ptr[uint64],
                             end_out: Ptr[uint64]) -> int32:
    # Locate the in-inode xattr region inside `inode_buf`. Returns 1 if
    # a valid EXT4_XATTR_MAGIC region exists (filling the out-pointers),
    # 0 otherwise. The region runs from 128 + i_extra_isize to the end
    # of the inode (ext4_inode_size). e_value_offs in the in-inode case
    # is relative to the start of the entries area.
    if ext4_inode_size <= 128:
        return 0
    extra: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_EXTRA_ISIZE_OFF))
    if extra == 0:
        return 0
    region_start: uint64 = 128 + cast[uint64](extra)
    if region_start + 4 > ext4_inode_size:
        return 0
    base: uint64 = cast[uint64](inode_buf)
    magic: uint32 = _ext4_read_u32(cast[Ptr[uint8]](base + region_start))
    if magic != EXT4_XATTR_MAGIC:
        return 0
    entries_out[0] = base + region_start + 4
    vbase_out[0] = base + region_start + 4
    end_out[0] = base + ext4_inode_size
    return 1


def ext4_getxattr(inode_buf: Ptr[uint8], name_ptr: Ptr[char],
                  name_len: uint64, out_buf: Ptr[uint8],
                  out_cap: uint64) -> int32:
    # Fetch the value of extended attribute `name_ptr` (fully-qualified,
    # e.g. "user.comment") for the given in-memory inode. Searches the
    # in-inode region first, then the external i_file_acl block. Returns
    # the value byte count, -ENODATA (-61) if absent, or -ERANGE (-34) if
    # out_buf is too small.
    NEG_ENODATA: int32 = -61
    ent: uint64 = 0
    vb:  uint64 = 0
    en:  uint64 = 0
    if _ext4_xattr_inode_region(inode_buf, &ent, &vb, &en) != 0:
        r: int32 = _ext4_xattr_scan(ent, en, vb, name_ptr, name_len,
                                    out_buf, out_cap,
                                    cast[Ptr[uint8]](0), 0,
                                    cast[Ptr[uint64]](0))
        if r != -1:
            return r
    # External block.
    facl: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_FILE_ACL_OFFSET))
    if facl != 0:
        if _ext4_read_block(cast[uint64](facl),
                            &ext4_xattr_blk_buf[0]) == 0:
            base: uint64 = cast[uint64](&ext4_xattr_blk_buf[0])
            magic: uint32 = _ext4_read_u32(cast[Ptr[uint8]](base))
            if magic == EXT4_XATTR_MAGIC:
                ent2: uint64 = base + EXT4_XATTR_HDR_LEN
                r2: int32 = _ext4_xattr_scan(
                    ent2, base + ext4_block_size, base,
                    name_ptr, name_len, out_buf, out_cap,
                    cast[Ptr[uint8]](0), 0, cast[Ptr[uint64]](0))
                if r2 != -1:
                    return r2
    return NEG_ENODATA


def ext4_listxattr(inode_buf: Ptr[uint8], out_buf: Ptr[uint8],
                   out_cap: uint64) -> int32:
    # Emit all fully-qualified attribute names (each NUL-terminated) for
    # the inode into out_buf. Returns the total byte count written
    # (matching Linux listxattr semantics). Lists in-inode names then
    # external-block names.
    used: uint64 = 0
    ent: uint64 = 0
    vb:  uint64 = 0
    en:  uint64 = 0
    if _ext4_xattr_inode_region(inode_buf, &ent, &vb, &en) != 0:
        _ext4_xattr_scan(ent, en, vb, cast[Ptr[char]](0), 0,
                         cast[Ptr[uint8]](0), 0,
                         out_buf, out_cap, &used)
    facl: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_FILE_ACL_OFFSET))
    if facl != 0:
        if _ext4_read_block(cast[uint64](facl),
                            &ext4_xattr_blk_buf[0]) == 0:
            base: uint64 = cast[uint64](&ext4_xattr_blk_buf[0])
            magic: uint32 = _ext4_read_u32(cast[Ptr[uint8]](base))
            if magic == EXT4_XATTR_MAGIC:
                _ext4_xattr_scan(base + EXT4_XATTR_HDR_LEN,
                                 base + ext4_block_size, base,
                                 cast[Ptr[char]](0), 0,
                                 cast[Ptr[uint8]](0), 0,
                                 out_buf, out_cap, &used)
    return cast[int32](used)


# setxattr writes ONLY the in-inode region. External-block allocation
# for setxattr is out of scope (a value too large for the inode slack
# returns -ENOSPC rather than spilling to a freshly-allocated
# i_file_acl block).
def _ext4_setxattr_inode(inode_buf: Ptr[uint8], name: Ptr[char],
                         value: Ptr[uint8], value_len: uint64,
                         flags: int32) -> int32:
    # Insert-or-replace one attribute in the in-inode region of an
    # in-memory inode buffer. Does NOT persist — caller writes the inode
    # back. Returns 0 on success, negative errno on failure.
    #   flags: 1 = XATTR_CREATE (fail if exists), 2 = XATTR_REPLACE
    #          (fail if absent), 0 = create or replace.
    NEG_ENOSPC:  int32 = -28
    NEG_EEXIST:  int32 = -17
    NEG_ENODATA: int32 = -61
    NEG_EOPNOTSUPP: int32 = -95
    name_len: uint64 = _ext4_strlen(name)
    suffix_off: uint64 = 0
    idx: uint8 = _ext4_xattr_classify(name, name_len, &suffix_off)
    if idx == 0:
        return NEG_EOPNOTSUPP
    suffix_len: uint64 = name_len - suffix_off

    if ext4_inode_size <= 128:
        return NEG_ENOSPC
    extra: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_EXTRA_ISIZE_OFF))
    if extra == 0:
        # No declared extra_isize — adopt a standard value so a fresh
        # 256-byte inode gains an xattr region. 32 = the i_extra_isize
        # Linux mkfs uses for 256-byte inodes.
        extra = 32
        _ext4_write_u16(
            cast[Ptr[uint8]](cast[uint64](inode_buf)
                             + INODE_I_EXTRA_ISIZE_OFF), extra)
    region_start: uint64 = 128 + cast[uint64](extra)
    if region_start + 4 > ext4_inode_size:
        return NEG_ENOSPC
    base: uint64 = cast[uint64](inode_buf)
    region_end: uint64 = base + ext4_inode_size
    entries_base: uint64 = base + region_start + 4
    # If the magic is absent, lay down a fresh empty region (magic +
    # immediate terminating zero entry).
    magic: uint32 = _ext4_read_u32(cast[Ptr[uint8]](base + region_start))
    if magic != EXT4_XATTR_MAGIC:
        _ext4_write_u32(cast[Ptr[uint8]](base + region_start),
                        EXT4_XATTR_MAGIC)
        _ext4_zero(cast[Ptr[uint8]](entries_base),
                   region_end - entries_base)

    # Walk to find an existing entry with this (idx, suffix) and to learn
    # the current value-storage low-water mark (values pack down from
    # region_end). Also remember the terminating-zero position.
    exists: int32 = 0
    p: uint64 = entries_base
    val_low: uint64 = region_end            # lowest value byte in use
    zero_pos: uint64 = entries_base
    while p + EXT4_XATTR_ENTRY_HDR <= region_end:
        ep: Ptr[uint8] = cast[Ptr[uint8]](p)
        if ep[0] == 0 and ep[1] == 0:
            zero_pos = p
            break
        e_voffs: uint16 = _ext4_read_u16(cast[Ptr[uint8]](p + 0x02))
        e_vsize: uint32 = _ext4_read_u32(cast[Ptr[uint8]](p + 0x08))
        if cast[uint32](e_vsize) > 0:
            vstart: uint64 = entries_base + cast[uint64](e_voffs)
            if vstart < val_low:
                val_low = vstart
        if ep[0] == cast[uint8](suffix_len) and ep[1] == idx:
            nm: Ptr[uint8] = cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR)
            if _ext4_mem_eq(nm, cast[Ptr[uint8]](
                    cast[uint64](name) + suffix_off), suffix_len) != 0:
                exists = 1
        p = p + _ext4_xattr_align4(
            EXT4_XATTR_ENTRY_HDR + cast[uint64](ep[0]))
    if p + EXT4_XATTR_ENTRY_HDR > region_end:
        zero_pos = p

    if exists != 0 and flags == 1:
        return NEG_EEXIST
    if exists == 0 and flags == 2:
        return NEG_ENODATA

    # Simplest correct strategy that matches the read path: rebuild the
    # region from scratch, copying every existing attribute EXCEPT the
    # target, then appending the (new/replacement) target. This keeps
    # entry/value layout self-consistent without in-place hole bookkeeping.
    return _ext4_xattr_rebuild(inode_buf, region_start, idx,
                               cast[Ptr[uint8]](cast[uint64](name)
                                                + suffix_off),
                               suffix_len, value, value_len)


# Staging area for the rebuilt in-inode region (entries grow up, values
# grow down, mirroring the on-disk layout). 256 bytes is the max inode.
ext4_xattr_rebuild_buf: Array[256, uint8]


def _ext4_xattr_rebuild(inode_buf: Ptr[uint8], region_start: uint64,
                        new_idx: uint8, new_suffix: Ptr[uint8],
                        new_suffix_len: uint64, new_value: Ptr[uint8],
                        new_value_len: uint64) -> int32:
    # Rebuild the in-inode xattr region into ext4_xattr_rebuild_buf,
    # keeping every existing entry except (new_idx,new_suffix) and then
    # appending that attribute with new_value. On success the region is
    # copied back into inode_buf. Returns 0 or -ENOSPC.
    NEG_ENOSPC: int32 = -28
    base: uint64 = cast[uint64](inode_buf)
    region_end: uint64 = base + ext4_inode_size
    src_entries: uint64 = base + region_start + 4
    region_len: uint64 = ext4_inode_size - (region_start + 4)

    # Work entirely inside the staging buffer.
    sb: uint64 = cast[uint64](&ext4_xattr_rebuild_buf[0])
    _ext4_zero(&ext4_xattr_rebuild_buf[0], region_len)
    e_cur: uint64 = 0                       # entry write cursor (from 0)
    v_cur: uint64 = region_len              # value write cursor (downward)

    # Helper-inlined: copy one (idx,name,value) into the staging region.
    # First the existing entries (skipping the target), then the new one.
    p: uint64 = src_entries
    while p + EXT4_XATTR_ENTRY_HDR <= region_end:
        ep: Ptr[uint8] = cast[Ptr[uint8]](p)
        nlen: uint8 = ep[0]
        nidx: uint8 = ep[1]
        if nlen == 0 and nidx == 0:
            break
        skip: int32 = 0
        if nlen == cast[uint8](new_suffix_len) and nidx == new_idx:
            nm: Ptr[uint8] = cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR)
            if _ext4_mem_eq(nm, new_suffix, new_suffix_len) != 0:
                skip = 1
        if skip == 0:
            voffs: uint16 = _ext4_read_u16(cast[Ptr[uint8]](p + 0x02))
            vsize: uint32 = _ext4_read_u32(cast[Ptr[uint8]](p + 0x08))
            vsz: uint64 = cast[uint64](vsize)
            vsrc: uint64 = src_entries + cast[uint64](voffs)
            rc: int32 = _ext4_xattr_emit(sb, &e_cur, &v_cur, region_len,
                                         nidx,
                                         cast[Ptr[uint8]](
                                             p + EXT4_XATTR_ENTRY_HDR),
                                         cast[uint64](nlen),
                                         cast[Ptr[uint8]](vsrc), vsz)
            if rc != 0:
                return NEG_ENOSPC
        p = p + _ext4_xattr_align4(
            EXT4_XATTR_ENTRY_HDR + cast[uint64](nlen))

    # Append the new/replacement attribute.
    rc2: int32 = _ext4_xattr_emit(sb, &e_cur, &v_cur, region_len,
                                  new_idx, new_suffix, new_suffix_len,
                                  new_value, new_value_len)
    if rc2 != 0:
        return NEG_ENOSPC

    # Terminating zero entry must fit between the entry cursor and the
    # value low-water mark.
    if e_cur + 4 > v_cur:
        return NEG_ENOSPC
    # (the staging buffer is already zeroed, so the zero entry is implicit)

    # Commit: magic stays in place, copy the staged region back.
    memcpy(cast[Ptr[uint8]](src_entries),
           &ext4_xattr_rebuild_buf[0], region_len)
    return 0


def _ext4_xattr_emit(stage_base: uint64, e_cur: Ptr[uint64],
                     v_cur: Ptr[uint64], region_len: uint64,
                     idx: uint8, suffix: Ptr[uint8], suffix_len: uint64,
                     value: Ptr[uint8], value_len: uint64) -> int32:
    # Append one attribute to the staging region. Entries pack upward
    # from offset 0, values downward from region_len. e_value_offs is
    # stored relative to the entries area (== stage offset 0). Returns 0
    # or -1 if it would overflow.
    entry_sz: uint64 = _ext4_xattr_align4(
        EXT4_XATTR_ENTRY_HDR + suffix_len)
    vsz: uint64 = _ext4_xattr_align4(value_len)
    # Need room for this entry, this value, AND a 4-byte terminator.
    if e_cur[0] + entry_sz + 4 + vsz > v_cur[0]:
        return -1
    new_v: uint64 = v_cur[0] - vsz
    ent: uint64 = stage_base + e_cur[0]
    ep: Ptr[uint8] = cast[Ptr[uint8]](ent)
    ep[0] = cast[uint8](suffix_len)
    ep[1] = idx
    _ext4_write_u16(cast[Ptr[uint8]](ent + 0x02),
                    cast[uint16](new_v))            # e_value_offs
    _ext4_write_u32(cast[Ptr[uint8]](ent + 0x04), 0)   # e_value_block
    _ext4_write_u32(cast[Ptr[uint8]](ent + 0x08),
                    cast[uint32](value_len))        # e_value_size
    _ext4_write_u32(cast[Ptr[uint8]](ent + 0x0C), 0)   # e_hash (0; we
                                                       # don't index)
    # name bytes
    i: uint64 = 0
    while i < suffix_len:
        ep[EXT4_XATTR_ENTRY_HDR + i] = suffix[i]
        i = i + 1
    # value bytes
    j: uint64 = 0
    while j < value_len:
        cast[Ptr[uint8]](stage_base + new_v)[j] = value[j]
        j = j + 1
    e_cur[0] = e_cur[0] + entry_sz
    v_cur[0] = new_v
    return 0


def ext4_setxattr(inum: uint32, name: Ptr[char], value: Ptr[uint8],
                  value_len: uint64, flags: int32) -> int32:
    # Persisting setxattr for an on-disk inode. Reads the inode, inserts/
    # replaces the attribute. The in-inode region is preferred (no extra
    # block I/O); when the value won't fit the inode slack we spill the
    # attribute to the external i_file_acl block (allocating a fresh fs
    # block the first time). Stamps ctime and writes the inode back.
    # Returns 0 or a negative errno.
    NEG_ENOSPC: int32 = -28
    if ext4_blockdev_slot < 0:
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        return -1
    name_len: uint64 = _ext4_strlen(name)
    suffix_off: uint64 = 0
    idx: uint8 = _ext4_xattr_classify(name, name_len, &suffix_off)
    if idx == 0:
        return -95                              # -EOPNOTSUPP
    suffix_len: uint64 = name_len - suffix_off
    suffix_ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](name)
                                              + suffix_off)

    # A replace/create must not duplicate: if the attribute already lives
    # in the OTHER location we must honour CREATE/REPLACE flags against
    # the global view and remove the stale copy after writing the new one.
    in_inode: int32 = _ext4_xattr_present_inode(&ext4_xattr_inode_buf[0],
                                                idx, suffix_ptr, suffix_len)
    in_ext: int32 = _ext4_xattr_present_external(&ext4_xattr_inode_buf[0],
                                                 idx, suffix_ptr, suffix_len)
    if flags == 1 and (in_inode != 0 or in_ext != 0):
        return -17                              # -EEXIST
    if flags == 2 and in_inode == 0 and in_ext == 0:
        return -61                              # -ENODATA

    # Try the in-inode region first (flags forced to 0 here; the
    # CREATE/REPLACE pre-check above already enforced existence rules
    # across BOTH locations).
    rc: int32 = _ext4_setxattr_inode(&ext4_xattr_inode_buf[0], name,
                                     value, value_len, 0)
    placed_inode: int32 = 0
    if rc == 0:
        placed_inode = 1
    else:
        if rc != NEG_ENOSPC:
            return rc
        # Inline is full / value too big — store externally.
        rc = _ext4_setxattr_external(&ext4_xattr_inode_buf[0], idx,
                                     suffix_ptr, suffix_len,
                                     value, value_len)
        if rc != 0:
            return rc

    # If a stale copy exists in the location we did NOT just write, drop
    # it so getxattr/listxattr see exactly one entry.
    if placed_inode != 0 and in_ext != 0:
        _ext4_removexattr_external(&ext4_xattr_inode_buf[0], idx,
                                   suffix_ptr, suffix_len)
    if placed_inode == 0 and in_inode != 0:
        _ext4_removexattr_inode(&ext4_xattr_inode_buf[0], idx,
                                suffix_ptr, suffix_len)

    _ext4_stamp_mtime(&ext4_xattr_inode_buf[0])
    if ext4_write_inode(cast[uint64](inum),
                        &ext4_xattr_inode_buf[0]) != 0:
        return -1
    return 0


def _ext4_xattr_present_inode(inode_buf: Ptr[uint8], idx: uint8,
                              suffix: Ptr[uint8],
                              suffix_len: uint64) -> int32:
    # 1 if (idx,suffix) is present in the in-inode region, else 0.
    ent: uint64 = 0
    vb:  uint64 = 0
    en:  uint64 = 0
    if _ext4_xattr_inode_region(inode_buf, &ent, &vb, &en) == 0:
        return 0
    return _ext4_xattr_entry_present(ent, en, idx, suffix, suffix_len)


def _ext4_xattr_present_external(inode_buf: Ptr[uint8], idx: uint8,
                                 suffix: Ptr[uint8],
                                 suffix_len: uint64) -> int32:
    # 1 if (idx,suffix) is present in the external i_file_acl block.
    facl: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_FILE_ACL_OFFSET))
    if facl == 0:
        return 0
    if _ext4_read_block(cast[uint64](facl), &ext4_xattr_blk_buf[0]) != 0:
        return 0
    base: uint64 = cast[uint64](&ext4_xattr_blk_buf[0])
    if _ext4_read_u32(cast[Ptr[uint8]](base)) != EXT4_XATTR_MAGIC:
        return 0
    return _ext4_xattr_entry_present(base + EXT4_XATTR_HDR_LEN,
                                     base + ext4_block_size,
                                     idx, suffix, suffix_len)


def _ext4_xattr_entry_present(entries_base: uint64, region_end: uint64,
                              idx: uint8, suffix: Ptr[uint8],
                              suffix_len: uint64) -> int32:
    # Scan one entry array for (idx,suffix). Returns 1 if present.
    p: uint64 = entries_base
    while p + EXT4_XATTR_ENTRY_HDR <= region_end:
        ep: Ptr[uint8] = cast[Ptr[uint8]](p)
        if ep[0] == 0 and ep[1] == 0:
            return 0
        if ep[0] == cast[uint8](suffix_len) and ep[1] == idx:
            nm: Ptr[uint8] = cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR)
            if _ext4_mem_eq(nm, suffix, suffix_len) != 0:
                return 1
        p = p + _ext4_xattr_align4(
            EXT4_XATTR_ENTRY_HDR + cast[uint64](ep[0]))
    return 0


# --- external xattr block (i_file_acl) write path -----------------
#
# A second staging buffer for rebuilding the external block. The on-disk
# block layout is: 32-byte header, then entries packing UP from offset
# 32, with values packing DOWN from the end of the block. e_value_offs
# in the external block is measured from the START of the block (unlike
# the in-inode case, which measures from the entries area).
ext4_xattr_ext_stage: Array[4096, uint8]


def _ext4_setxattr_external(inode_buf: Ptr[uint8], new_idx: uint8,
                            new_suffix: Ptr[uint8], new_suffix_len: uint64,
                            new_value: Ptr[uint8],
                            new_value_len: uint64) -> int32:
    # Insert-or-replace (new_idx,new_suffix) in the external xattr block.
    # Allocates a fresh fs block the first time (i_file_acl == 0). Builds
    # the new block image in ext4_xattr_ext_stage, then journals it to
    # disk. Updates i_file_acl in inode_buf (caller writes the inode).
    # Returns 0 or -ENOSPC.
    NEG_ENOSPC: int32 = -28
    facl: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_FILE_ACL_OFFSET))

    # Source of existing entries: the live block if one exists.
    have_src: int32 = 0
    if facl != 0:
        if _ext4_read_block(cast[uint64](facl),
                            &ext4_xattr_blk_buf[0]) == 0:
            sb_base: uint64 = cast[uint64](&ext4_xattr_blk_buf[0])
            if _ext4_read_u32(cast[Ptr[uint8]](sb_base)) == EXT4_XATTR_MAGIC:
                have_src = 1

    # Build the new block image from scratch in the stage buffer.
    stage: uint64 = cast[uint64](&ext4_xattr_ext_stage[0])
    _ext4_zero(&ext4_xattr_ext_stage[0], ext4_block_size)
    # Header: h_magic, h_refcount=1, h_blocks=1, rest 0.
    _ext4_write_u32(cast[Ptr[uint8]](stage), EXT4_XATTR_MAGIC)
    _ext4_write_u32(cast[Ptr[uint8]](stage + 4), 1)        # h_refcount
    _ext4_write_u32(cast[Ptr[uint8]](stage + 8), 1)        # h_blocks
    e_cur: uint64 = EXT4_XATTR_HDR_LEN                     # entry cursor
    v_cur: uint64 = ext4_block_size                        # value cursor

    # Copy existing entries (except the target), then append the target.
    if have_src != 0:
        src_base: uint64 = cast[uint64](&ext4_xattr_blk_buf[0])
        p: uint64 = src_base + EXT4_XATTR_HDR_LEN
        send: uint64 = src_base + ext4_block_size
        while p + EXT4_XATTR_ENTRY_HDR <= send:
            ep: Ptr[uint8] = cast[Ptr[uint8]](p)
            nlen: uint8 = ep[0]
            nidx: uint8 = ep[1]
            if nlen == 0 and nidx == 0:
                break
            skip: int32 = 0
            if nlen == cast[uint8](new_suffix_len) and nidx == new_idx:
                nm: Ptr[uint8] = cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR)
                if _ext4_mem_eq(nm, new_suffix, new_suffix_len) != 0:
                    skip = 1
            if skip == 0:
                voffs: uint16 = _ext4_read_u16(cast[Ptr[uint8]](p + 0x02))
                vsize: uint32 = _ext4_read_u32(cast[Ptr[uint8]](p + 0x08))
                vsrc: uint64 = src_base + cast[uint64](voffs)
                rc: int32 = _ext4_xattr_emit_ext(
                    stage, &e_cur, &v_cur, nidx,
                    cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR),
                    cast[uint64](nlen),
                    cast[Ptr[uint8]](vsrc), cast[uint64](vsize))
                if rc != 0:
                    return NEG_ENOSPC
            p = p + _ext4_xattr_align4(
                EXT4_XATTR_ENTRY_HDR + cast[uint64](nlen))

    # Append the new/replacement attribute.
    rc2: int32 = _ext4_xattr_emit_ext(stage, &e_cur, &v_cur, new_idx,
                                      new_suffix, new_suffix_len,
                                      new_value, new_value_len)
    if rc2 != 0:
        return NEG_ENOSPC
    # Terminating zero entry must fit (stage already zeroed).
    if e_cur + 4 > v_cur:
        return NEG_ENOSPC

    # Allocate a block on first use.
    blk: uint32 = facl
    if blk == 0:
        nb: uint64 = ext4_alloc_block()
        if nb == 0:
            return NEG_ENOSPC
        blk = cast[uint32](nb)
    # Persist the block (metadata -> journal path).
    if _ext4_journal_write_block(cast[uint64](blk),
                                 &ext4_xattr_ext_stage[0]) != 0:
        if facl == 0:
            ext4_free_block(cast[uint64](blk))
        return -1
    _ext4_write_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_FILE_ACL_OFFSET),
        blk)
    return 0


def _ext4_xattr_emit_ext(stage_base: uint64, e_cur: Ptr[uint64],
                         v_cur: Ptr[uint64], idx: uint8,
                         suffix: Ptr[uint8], suffix_len: uint64,
                         value: Ptr[uint8], value_len: uint64) -> int32:
    # Append one attribute to the external-block stage. Entries pack up
    # from EXT4_XATTR_HDR_LEN, values pack down from ext4_block_size.
    # e_value_offs is stored relative to the START of the block. Returns
    # 0 or -1 on overflow.
    entry_sz: uint64 = _ext4_xattr_align4(
        EXT4_XATTR_ENTRY_HDR + suffix_len)
    vsz: uint64 = _ext4_xattr_align4(value_len)
    # Need room for this entry, this value, AND a 4-byte terminator.
    if e_cur[0] + entry_sz + 4 + vsz > v_cur[0]:
        return -1
    new_v: uint64 = v_cur[0] - vsz
    ent: uint64 = stage_base + e_cur[0]
    ep: Ptr[uint8] = cast[Ptr[uint8]](ent)
    ep[0] = cast[uint8](suffix_len)
    ep[1] = idx
    _ext4_write_u16(cast[Ptr[uint8]](ent + 0x02),
                    cast[uint16](new_v))            # e_value_offs (block-rel)
    _ext4_write_u32(cast[Ptr[uint8]](ent + 0x04), 0)   # e_value_block
    _ext4_write_u32(cast[Ptr[uint8]](ent + 0x08),
                    cast[uint32](value_len))        # e_value_size
    _ext4_write_u32(cast[Ptr[uint8]](ent + 0x0C), 0)   # e_hash
    i: uint64 = 0
    while i < suffix_len:
        ep[EXT4_XATTR_ENTRY_HDR + i] = suffix[i]
        i = i + 1
    j: uint64 = 0
    while j < value_len:
        cast[Ptr[uint8]](stage_base + new_v)[j] = value[j]
        j = j + 1
    e_cur[0] = e_cur[0] + entry_sz
    v_cur[0] = new_v
    return 0


# --- removexattr --------------------------------------------------

def ext4_removexattr(inum: uint32, name: Ptr[char]) -> int32:
    # Remove extended attribute `name` from an on-disk inode. Searches
    # both the in-inode region and the external block; frees the external
    # block when its last entry goes away. Returns 0, or -ENODATA if the
    # attribute was not present anywhere.
    NEG_ENODATA: int32 = -61
    if ext4_blockdev_slot < 0:
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        return -1
    name_len: uint64 = _ext4_strlen(name)
    suffix_off: uint64 = 0
    idx: uint8 = _ext4_xattr_classify(name, name_len, &suffix_off)
    if idx == 0:
        return -95                              # -EOPNOTSUPP
    suffix_len: uint64 = name_len - suffix_off
    suffix_ptr: Ptr[uint8] = cast[Ptr[uint8]](cast[uint64](name)
                                              + suffix_off)
    removed: int32 = 0
    if _ext4_xattr_present_inode(&ext4_xattr_inode_buf[0], idx,
                                 suffix_ptr, suffix_len) != 0:
        _ext4_removexattr_inode(&ext4_xattr_inode_buf[0], idx,
                                suffix_ptr, suffix_len)
        removed = 1
    if _ext4_xattr_present_external(&ext4_xattr_inode_buf[0], idx,
                                    suffix_ptr, suffix_len) != 0:
        if _ext4_removexattr_external(&ext4_xattr_inode_buf[0], idx,
                                      suffix_ptr, suffix_len) != 0:
            return -1
        removed = 1
    if removed == 0:
        return NEG_ENODATA
    _ext4_stamp_mtime(&ext4_xattr_inode_buf[0])
    if ext4_write_inode(cast[uint64](inum),
                        &ext4_xattr_inode_buf[0]) != 0:
        return -1
    return 0


def _ext4_removexattr_inode(inode_buf: Ptr[uint8], idx: uint8,
                            suffix: Ptr[uint8], suffix_len: uint64) -> int32:
    # Drop (idx,suffix) from the in-inode region by rebuilding it without
    # that entry. Mutates inode_buf in place. Returns 0 (always; absence
    # is a no-op rebuild). Does NOT persist.
    extra: uint16 = _ext4_read_u16(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_EXTRA_ISIZE_OFF))
    if extra == 0:
        return 0
    region_start: uint64 = 128 + cast[uint64](extra)
    base: uint64 = cast[uint64](inode_buf)
    if _ext4_read_u32(cast[Ptr[uint8]](base + region_start)) \
            != EXT4_XATTR_MAGIC:
        return 0
    return _ext4_xattr_rebuild_drop(inode_buf, region_start, idx,
                                    suffix, suffix_len)


def _ext4_xattr_rebuild_drop(inode_buf: Ptr[uint8], region_start: uint64,
                             drop_idx: uint8, drop_suffix: Ptr[uint8],
                             drop_suffix_len: uint64) -> int32:
    # Rebuild the in-inode region copying every entry EXCEPT
    # (drop_idx,drop_suffix). Mirrors _ext4_xattr_rebuild without the
    # append step.
    base: uint64 = cast[uint64](inode_buf)
    region_end: uint64 = base + ext4_inode_size
    src_entries: uint64 = base + region_start + 4
    region_len: uint64 = ext4_inode_size - (region_start + 4)
    sb: uint64 = cast[uint64](&ext4_xattr_rebuild_buf[0])
    _ext4_zero(&ext4_xattr_rebuild_buf[0], region_len)
    e_cur: uint64 = 0
    v_cur: uint64 = region_len
    p: uint64 = src_entries
    while p + EXT4_XATTR_ENTRY_HDR <= region_end:
        ep: Ptr[uint8] = cast[Ptr[uint8]](p)
        nlen: uint8 = ep[0]
        nidx: uint8 = ep[1]
        if nlen == 0 and nidx == 0:
            break
        skip: int32 = 0
        if nlen == cast[uint8](drop_suffix_len) and nidx == drop_idx:
            nm: Ptr[uint8] = cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR)
            if _ext4_mem_eq(nm, drop_suffix, drop_suffix_len) != 0:
                skip = 1
        if skip == 0:
            voffs: uint16 = _ext4_read_u16(cast[Ptr[uint8]](p + 0x02))
            vsize: uint32 = _ext4_read_u32(cast[Ptr[uint8]](p + 0x08))
            vsrc: uint64 = src_entries + cast[uint64](voffs)
            _ext4_xattr_emit(sb, &e_cur, &v_cur, region_len, nidx,
                             cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR),
                             cast[uint64](nlen),
                             cast[Ptr[uint8]](vsrc), cast[uint64](vsize))
        p = p + _ext4_xattr_align4(
            EXT4_XATTR_ENTRY_HDR + cast[uint64](nlen))
    memcpy(cast[Ptr[uint8]](src_entries),
           &ext4_xattr_rebuild_buf[0], region_len)
    return 0


def _ext4_removexattr_external(inode_buf: Ptr[uint8], idx: uint8,
                               suffix: Ptr[uint8],
                               suffix_len: uint64) -> int32:
    # Drop (idx,suffix) from the external block. If that was the last
    # entry, free the block and clear i_file_acl. Otherwise rewrite the
    # block without the entry. Returns 0 on success, -1 on I/O error.
    facl: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](inode_buf) + INODE_I_FILE_ACL_OFFSET))
    if facl == 0:
        return 0
    if _ext4_read_block(cast[uint64](facl), &ext4_xattr_blk_buf[0]) != 0:
        return -1
    src_base: uint64 = cast[uint64](&ext4_xattr_blk_buf[0])
    if _ext4_read_u32(cast[Ptr[uint8]](src_base)) != EXT4_XATTR_MAGIC:
        return 0
    # Rebuild into the stage buffer, skipping the target.
    stage: uint64 = cast[uint64](&ext4_xattr_ext_stage[0])
    _ext4_zero(&ext4_xattr_ext_stage[0], ext4_block_size)
    _ext4_write_u32(cast[Ptr[uint8]](stage), EXT4_XATTR_MAGIC)
    _ext4_write_u32(cast[Ptr[uint8]](stage + 4), 1)
    _ext4_write_u32(cast[Ptr[uint8]](stage + 8), 1)
    e_cur: uint64 = EXT4_XATTR_HDR_LEN
    v_cur: uint64 = ext4_block_size
    kept: uint64 = 0
    p: uint64 = src_base + EXT4_XATTR_HDR_LEN
    send: uint64 = src_base + ext4_block_size
    while p + EXT4_XATTR_ENTRY_HDR <= send:
        ep: Ptr[uint8] = cast[Ptr[uint8]](p)
        nlen: uint8 = ep[0]
        nidx: uint8 = ep[1]
        if nlen == 0 and nidx == 0:
            break
        skip: int32 = 0
        if nlen == cast[uint8](suffix_len) and nidx == idx:
            nm: Ptr[uint8] = cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR)
            if _ext4_mem_eq(nm, suffix, suffix_len) != 0:
                skip = 1
        if skip == 0:
            voffs: uint16 = _ext4_read_u16(cast[Ptr[uint8]](p + 0x02))
            vsize: uint32 = _ext4_read_u32(cast[Ptr[uint8]](p + 0x08))
            vsrc: uint64 = src_base + cast[uint64](voffs)
            _ext4_xattr_emit_ext(stage, &e_cur, &v_cur, nidx,
                                 cast[Ptr[uint8]](p + EXT4_XATTR_ENTRY_HDR),
                                 cast[uint64](nlen),
                                 cast[Ptr[uint8]](vsrc),
                                 cast[uint64](vsize))
            kept = kept + 1
        p = p + _ext4_xattr_align4(
            EXT4_XATTR_ENTRY_HDR + cast[uint64](nlen))
    if kept == 0:
        # No entries left — free the block and clear i_file_acl.
        ext4_free_block(cast[uint64](facl))
        _ext4_write_u32(
            cast[Ptr[uint8]](cast[uint64](inode_buf)
                             + INODE_I_FILE_ACL_OFFSET), 0)
        return 0
    if _ext4_journal_write_block(cast[uint64](facl),
                                 &ext4_xattr_ext_stage[0]) != 0:
        return -1
    return 0


# --- POSIX ACL decode ---------------------------------------------
#
# A "system.posix_acl_access" (or _default) value is the Linux ext4
# on-disk ACL: a __le32 a_version (== 0x0002) header followed by packed
# struct ext4_acl_entry records:
#   0x00  e_tag    u16
#   0x02  e_perm   u16   (r=4, w=2, x=1)
#   [e_id u32]            present ONLY for e_tag USER (2) and GROUP (8)
# Short entries (USER_OBJ/GROUP_OBJ/MASK/OTHER) are 4 bytes; USER/GROUP
# entries are 8 bytes (they carry the e_id).

POSIX_ACL_VERSION:  uint32 = 0x0002
ACL_USER_OBJ:       uint16 = 0x01
ACL_USER:           uint16 = 0x02
ACL_GROUP_OBJ:      uint16 = 0x04
ACL_GROUP:          uint16 = 0x08
ACL_MASK:           uint16 = 0x10
ACL_OTHER:          uint16 = 0x20


def ext4_acl_decode(value: Ptr[uint8], value_len: uint64,
                    tag_out: Ptr[uint16], perm_out: Ptr[uint16],
                    id_out: Ptr[uint32], max_entries: uint64) -> int32:
    # Parse a POSIX-ACL on-disk value into caller-provided parallel
    # arrays tag_out/perm_out/id_out (each at least max_entries long).
    # Returns the number of entries decoded, or -1 on a malformed value
    # (bad version / truncated). USER/GROUP entries carry a real e_id;
    # all other tags get id_out = 0xFFFFFFFF (ACL_UNDEFINED_ID).
    if value_len < 4:
        return -1
    ver: uint32 = _ext4_read_u32(value)
    if ver != POSIX_ACL_VERSION:
        return -1
    p: uint64 = cast[uint64](value) + 4
    end: uint64 = cast[uint64](value) + value_len
    n: uint64 = 0
    while p + 4 <= end and n < max_entries:
        tag: uint16 = _ext4_read_u16(cast[Ptr[uint8]](p))
        perm: uint16 = _ext4_read_u16(cast[Ptr[uint8]](p + 2))
        tag_out[n] = tag
        perm_out[n] = perm
        if tag == ACL_USER or tag == ACL_GROUP:
            if p + 8 > end:
                return -1                   # truncated long entry
            id_out[n] = _ext4_read_u32(cast[Ptr[uint8]](p + 4))
            p = p + 8
        else:
            id_out[n] = 0xFFFFFFFF
            p = p + 4
        n = n + 1
    return cast[int32](n)


def ext4_acl_access_check(value: Ptr[uint8], value_len: uint64,
                          uid: uint32, gid: uint32,
                          want: uint16) -> int32:
    # Resolve a POSIX-ACL access decision the way Linux's
    # posix_acl_permission() does: pick the matching entry class for
    # (uid,gid), apply the MASK to the named/group classes, and test the
    # requested `want` rwx bits (r=4,w=2,x=1). Returns 1 = granted,
    # 0 = denied, -1 = malformed. The file-owner uid/gid is NOT passed
    # here; callers compare against the inode owner before calling, so we
    # treat ACL_USER_OBJ as "uid matches owner" responsibility of the
    # caller and evaluate USER/GROUP/OTHER classes against (uid,gid).
    tags: Array[32, uint16]
    perms: Array[32, uint16]
    ids: Array[32, uint32]
    n: int32 = ext4_acl_decode(value, value_len, &tags[0], &perms[0],
                               &ids[0], 32)
    if n < 0:
        return -1
    mask: uint16 = 0x07                     # default: all bits allowed
    have_mask: int32 = 0
    i: int32 = 0
    while i < n:
        if tags[i] == ACL_MASK:
            mask = perms[i]
            have_mask = 1
        i = i + 1
    # USER (named) match.
    i = 0
    while i < n:
        if tags[i] == ACL_USER and ids[i] == uid:
            eff: uint16 = perms[i]
            if have_mask != 0:
                eff = eff & mask
            if (eff & want) == want:
                return 1
            return 0
        i = i + 1
    # GROUP_OBJ / named GROUP match.
    i = 0
    while i < n:
        matched: int32 = 0
        if tags[i] == ACL_GROUP and ids[i] == gid:
            matched = 1
        if tags[i] == ACL_GROUP_OBJ:
            matched = 1
        if matched != 0:
            eff2: uint16 = perms[i]
            if have_mask != 0:
                eff2 = eff2 & mask
            if (eff2 & want) == want:
                return 1
        i = i + 1
    # OTHER class.
    i = 0
    while i < n:
        if tags[i] == ACL_OTHER:
            if (perms[i] & want) == want:
                return 1
            return 0
        i = i + 1
    return 0


def ext4_acl_encode(tags: Ptr[uint16], perms: Ptr[uint16],
                    ids: Ptr[uint32], count: uint64,
                    out: Ptr[uint8], out_cap: uint64) -> int32:
    # Inverse of ext4_acl_decode: serialize `count` parallel ACL entries
    # into the Linux on-disk POSIX-ACL blob (a_version + packed entries)
    # in `out`. USER/GROUP tags emit an 8-byte entry carrying e_id; all
    # other tags emit a 4-byte entry. Returns the byte length written, or
    # -1 if it would overflow out_cap. The resulting blob is exactly what
    # is stored as the system.posix_acl_access / _default xattr value.
    if out_cap < 4:
        return -1
    _ext4_write_u32(out, POSIX_ACL_VERSION)
    o: uint64 = 4
    i: uint64 = 0
    while i < count:
        tag: uint16 = tags[i]
        if tag == ACL_USER or tag == ACL_GROUP:
            if o + 8 > out_cap:
                return -1
            _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](out) + o), tag)
            _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](out) + o + 2),
                            perms[i])
            _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](out) + o + 4),
                            ids[i])
            o = o + 8
        else:
            if o + 4 > out_cap:
                return -1
            _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](out) + o), tag)
            _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](out) + o + 2),
                            perms[i])
            o = o + 4
        i = i + 1
    return cast[int32](o)


def ext4_set_acl(inum: uint32, is_default: int32,
                 tags: Ptr[uint16], perms: Ptr[uint16],
                 ids: Ptr[uint32], count: uint64) -> int32:
    # Encode the given ACL entries and store them as the
    # system.posix_acl_access (is_default==0) or system.posix_acl_default
    # (is_default!=0) xattr on `inum`. Returns 0 or a negative errno.
    blob: Array[512, uint8]
    n: int32 = ext4_acl_encode(tags, perms, ids, count, &blob[0], 512)
    if n < 0:
        return -28                              # -ENOSPC (blob too big)
    nm: Ptr[char] = "system.posix_acl_access"
    if is_default != 0:
        nm = "system.posix_acl_default"
    return ext4_setxattr(inum, nm, &blob[0], cast[uint64](n), 0)


def ext4_get_acl(inum: uint32, is_default: int32,
                 out: Ptr[uint8], out_cap: uint64) -> int32:
    # Fetch the raw POSIX-ACL blob for `inum` into `out`. Returns the
    # value byte count, or a negative errno (-ENODATA if no ACL).
    if ext4_blockdev_slot < 0:
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        return -1
    nm: Ptr[char] = "system.posix_acl_access"
    if is_default != 0:
        nm = "system.posix_acl_default"
    return ext4_getxattr(&ext4_xattr_inode_buf[0], nm, _ext4_strlen(nm),
                         out, out_cap)


# --- path/fd helpers for the Linux-ABI xattr syscalls -------------
#
# These resolve an ext4 path (already stripped of the /ext/ prefix) to
# an inode number and route to the by-inum primitives above so the
# Linux setxattr/getxattr/listxattr/removexattr syscalls have a single
# entry point per operation.

def ext4_setxattr_path(path: Ptr[char], name: Ptr[char],
                       value: Ptr[uint8], value_len: uint64,
                       flags: int32) -> int32:
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(path, &inum, &fsize) == 0:
        # Maybe a directory (ACLs commonly live on dirs).
        d: uint32 = ext4_resolve_dir(path)
        if d == 0:
            return -2                           # -ENOENT
        inum = d
    return ext4_setxattr(inum, name, value, value_len, flags)


def ext4_getxattr_path(path: Ptr[char], name: Ptr[char],
                       out: Ptr[uint8], out_cap: uint64) -> int32:
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(path, &inum, &fsize) == 0:
        d: uint32 = ext4_resolve_dir(path)
        if d == 0:
            return -2
        inum = d
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        return -1
    return ext4_getxattr(&ext4_xattr_inode_buf[0], name,
                         _ext4_strlen(name), out, out_cap)


def ext4_listxattr_path(path: Ptr[char], out: Ptr[uint8],
                        out_cap: uint64) -> int32:
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(path, &inum, &fsize) == 0:
        d: uint32 = ext4_resolve_dir(path)
        if d == 0:
            return -2
        inum = d
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        return -1
    return ext4_listxattr(&ext4_xattr_inode_buf[0], out, out_cap)


def ext4_removexattr_path(path: Ptr[char], name: Ptr[char]) -> int32:
    inum: uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(path, &inum, &fsize) == 0:
        d: uint32 = ext4_resolve_dir(path)
        if d == 0:
            return -2
        inum = d
    return ext4_removexattr(inum, name)


# inum-keyed variants for the f* (fd-based) xattr syscalls. The caller
# (linux_abi) resolves an fd to its ext4 inode number, then routes here.

def ext4_getxattr_inum(inum: uint32, name: Ptr[char],
                       out: Ptr[uint8], out_cap: uint64) -> int32:
    if ext4_blockdev_slot < 0:
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        return -1
    return ext4_getxattr(&ext4_xattr_inode_buf[0], name,
                         _ext4_strlen(name), out, out_cap)


def ext4_listxattr_inum(inum: uint32, out: Ptr[uint8],
                        out_cap: uint64) -> int32:
    if ext4_blockdev_slot < 0:
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        return -1
    return ext4_listxattr(&ext4_xattr_inode_buf[0], out, out_cap)


# --- xattr self-test ----------------------------------------------
#
# Self-contained boot-time round-trip. Creates a regular file on the
# LIVE ext4 mount, sets two user.* xattrs (small values that fit the
# 256-byte inode slack), reads them back, lists them, replaces one, and
# decodes a synthetic POSIX ACL value. Prints [ext4-xattr] PASS/FAIL.
# Orchestrator wires this via a boot marker — function name:
# ext4_xattr_selftest.

ext4_xattr_test_val: Array[64, uint8]
ext4_xattr_test_list: Array[256, uint8]
ext4_xattr_test_acl: Array[64, uint8]
# Larger scratch for the external-block / ACL round-trip self-test.
ext4_xattr_big_val: Array[1024, uint8]
ext4_xattr_big_rd:  Array[1024, uint8]
ext4_xattr_acl_rd:  Array[128, uint8]

# --- EA_INODE (INCOMPAT_EA_INODE) read probe ----------------------
#
# A large xattr value (too big for the inline / external-block value
# region) is stored in its OWN inode under the EA_INODE feature. The
# host-side test (scripts/test_ext4_eainode.sh) mints an image WITH
# `-O ea_inode`, plants a regular file carrying a `user.big` attribute
# whose value is several filesystem blocks of a known repeating pattern,
# then boots this kernel. This probe (run from ext4_xattr_selftest, which
# the /etc/ext4xattr-test marker already arms) reads `user.big` back
# through ext4_getxattr and asserts head + tail sentinels of the pattern
# plus the exact length, proving the value resolved through the ea-inode's
# data blocks. It is fully gated on the probe file existing, so the plain
# xattr test image (which has no such file) skips it with no effect.
#
# 16 KiB read buffer: the planted value is several KiB; size the buffer to
# the largest value read through it so it cannot overflow into the next
# module-scope global. The probe file lives at the partition root (the
# resolver path is already relative to the ext4 root).
EXT4_EAINODE_VAL_LEN:     uint64 = 8192      # bytes the value must be
ext4_eainode_rd: Array[16384, uint8]


def ext4_eainode_probe() -> int32:
    # Returns 1 if the probe ran and PASSED, 0 if the probe file is absent
    # (skip — non-ea_inode image), -1 on a probe FAILURE. The pattern is a
    # repeating 0..255 byte ramp: value[i] == (i & 0xFF). We assert the
    # full length, the head bytes, and the tail bytes (so a multi-block
    # value must have resolved every block of the ea-inode, not just the
    # first).
    if ext4_blockdev_slot < 0:
        return 0
    if ext4_ea_inode == 0:
        # Feature not present on this image: nothing to probe.
        return 0
    probe_path: Ptr[char] = "BIGATTR.BIN"
    probe_name: Ptr[char] = "user.big"
    inum:  uint32 = 0
    fsize: uint64 = 0
    if ext4_resolve_file(probe_path, &inum, &fsize) == 0:
        # Probe file absent on this image — skip cleanly.
        return 0
    printk0("[ext4eainode] probe file present; reading user.big via ea-inode\n")
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        printk0("[ext4eainode] FAIL: read probe inode\n")
        return -1
    g: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0],
                             probe_name,
                             _ext4_strlen(probe_name),
                             &ext4_eainode_rd[0], 16384)
    if g != cast[int32](EXT4_EAINODE_VAL_LEN):
        printk1("[ext4eainode] FAIL: getxattr user.big len=%d\n",
                cast[uint64](cast[int64](g)))
        printk1("[ext4eainode]   expected len=%d\n", EXT4_EAINODE_VAL_LEN)
        return -1
    # Verify EVERY byte of the multi-block value matches the (i & 0xFF) ramp.
    i: uint64 = 0
    while i < EXT4_EAINODE_VAL_LEN:
        if ext4_eainode_rd[i] != cast[uint8](i & 0xFF):
            printk1("[ext4eainode] FAIL: value byte mismatch at offset %d\n", i)
            return -1
        i = i + 1
    # Explicit head + tail sentinel report (the script greps these).
    printk2("[ext4eainode] head bytes ok: [0]=%d [1]=%d\n",
            cast[uint64](ext4_eainode_rd[0]),
            cast[uint64](ext4_eainode_rd[1]))
    printk2("[ext4eainode] tail bytes ok: [len-2]=%d [len-1]=%d\n",
            cast[uint64](ext4_eainode_rd[EXT4_EAINODE_VAL_LEN - 2]),
            cast[uint64](ext4_eainode_rd[EXT4_EAINODE_VAL_LEN - 1]))
    printk1("[ext4eainode] value verified byte-exact, len=%d\n",
            EXT4_EAINODE_VAL_LEN)
    printk0("[ext4eainode] PASS\n")
    return 1


def ext4_xattr_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-xattr] FAIL: ext4 not mounted\n")
        return -1
    # EA_INODE read probe (skips cleanly on a non-ea_inode image). A probe
    # FAILURE is fatal so the host test sees no [ext4eainode] PASS banner.
    if ext4_eainode_probe() < 0:
        printk0("[ext4-xattr] FAIL: ea-inode probe failed\n")
        return -1
    if ext4_inode_size < 256:
        # No in-inode slack on 128-byte-inode images; nothing to test.
        printk0("[ext4-xattr] FAIL: inode_size < 256 (no in-inode slack)\n")
        return -1
    fname: Ptr[char] = "xattr-selftest.bin"
    # Precondition: must not already exist (stale image would mask a bug).
    pre_inum:  uint32 = 0
    pre_ftype: uint8  = 0
    pre: int32 = _ext4_dir_find_entry(2, fname, &pre_inum, &pre_ftype)
    if pre < 0:
        printk0("[ext4-xattr] FAIL: parent dir read error\n")
        return -1
    if pre != 0:
        printk0("[ext4-xattr] FAIL: target already exists pre-test\n")
        return -1
    body: Ptr[char] = "xattr host file\n"
    inum: uint32 = ext4_create_file(2, fname, cast[Ptr[uint8]](body),
                                    _ext4_strlen(body))
    if inum == 0:
        printk0("[ext4-xattr] FAIL: create_file\n")
        return -1

    # Set user.color = "blue".
    n1: Ptr[char] = "user.color"
    v1: Ptr[char] = "blue"
    if ext4_setxattr(inum, n1, cast[Ptr[uint8]](v1),
                     _ext4_strlen(v1), 0) != 0:
        printk0("[ext4-xattr] FAIL: setxattr user.color\n")
        return -1
    # Set user.size = "42".
    n2: Ptr[char] = "user.size"
    v2: Ptr[char] = "42"
    if ext4_setxattr(inum, n2, cast[Ptr[uint8]](v2),
                     _ext4_strlen(v2), 0) != 0:
        printk0("[ext4-xattr] FAIL: setxattr user.size\n")
        return -1

    # Re-read the inode and GET user.color back.
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        printk0("[ext4-xattr] FAIL: re-read inode\n")
        return -1
    g1: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], n1,
                              _ext4_strlen(n1),
                              &ext4_xattr_test_val[0], 64)
    if g1 != cast[int32](_ext4_strlen(v1)):
        printk1("[ext4-xattr] FAIL: getxattr color len=%d\n",
                cast[uint64](cast[int64](g1)))
        return -1
    if _ext4_mem_eq(&ext4_xattr_test_val[0], cast[Ptr[uint8]](v1),
                    _ext4_strlen(v1)) == 0:
        printk0("[ext4-xattr] FAIL: getxattr color value mismatch\n")
        return -1

    # GET user.size.
    g2: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], n2,
                              _ext4_strlen(n2),
                              &ext4_xattr_test_val[0], 64)
    if g2 != cast[int32](_ext4_strlen(v2)):
        printk0("[ext4-xattr] FAIL: getxattr size len\n")
        return -1
    if _ext4_mem_eq(&ext4_xattr_test_val[0], cast[Ptr[uint8]](v2),
                    _ext4_strlen(v2)) == 0:
        printk0("[ext4-xattr] FAIL: getxattr size value mismatch\n")
        return -1

    # Missing attribute -> -ENODATA.
    nm: Ptr[char] = "user.absent"
    gm: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], nm,
                              _ext4_strlen(nm),
                              &ext4_xattr_test_val[0], 64)
    if gm != -61:
        printk1("[ext4-xattr] FAIL: absent attr rc=%d (want -61)\n",
                cast[uint64](cast[int64](gm)))
        return -1

    # LIST: both names must appear (NUL-separated).
    ll: int32 = ext4_listxattr(&ext4_xattr_inode_buf[0],
                               &ext4_xattr_test_list[0], 256)
    if ll <= 0:
        printk0("[ext4-xattr] FAIL: listxattr empty\n")
        return -1
    if _ext4_xattr_list_has(&ext4_xattr_test_list[0],
                            cast[uint64](ll), n1) == 0:
        printk0("[ext4-xattr] FAIL: list missing user.color\n")
        return -1
    if _ext4_xattr_list_has(&ext4_xattr_test_list[0],
                            cast[uint64](ll), n2) == 0:
        printk0("[ext4-xattr] FAIL: list missing user.size\n")
        return -1

    # REPLACE user.color with a longer value, confirm the read updates.
    v1b: Ptr[char] = "magenta"
    if ext4_setxattr(inum, n1, cast[Ptr[uint8]](v1b),
                     _ext4_strlen(v1b), 0) != 0:
        printk0("[ext4-xattr] FAIL: setxattr replace color\n")
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        printk0("[ext4-xattr] FAIL: re-read inode (replace)\n")
        return -1
    g1b: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], n1,
                               _ext4_strlen(n1),
                               &ext4_xattr_test_val[0], 64)
    if g1b != cast[int32](_ext4_strlen(v1b)):
        printk0("[ext4-xattr] FAIL: replaced color len\n")
        return -1
    if _ext4_mem_eq(&ext4_xattr_test_val[0], cast[Ptr[uint8]](v1b),
                    _ext4_strlen(v1b)) == 0:
        printk0("[ext4-xattr] FAIL: replaced color value\n")
        return -1
    # user.size must SURVIVE the replace of user.color.
    g2b: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], n2,
                               _ext4_strlen(n2),
                               &ext4_xattr_test_val[0], 64)
    if g2b != cast[int32](_ext4_strlen(v2)):
        printk0("[ext4-xattr] FAIL: size lost after color replace\n")
        return -1

    # POSIX ACL decode: build a minimal valid value and decode it.
    #   version=2, USER_OBJ rwx, USER(id=1000) rw-, GROUP_OBJ r--,
    #   MASK rw-, OTHER r--.
    ab: Ptr[uint8] = &ext4_xattr_test_acl[0]
    _ext4_write_u32(ab, POSIX_ACL_VERSION)
    o: uint64 = 4
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o), ACL_USER_OBJ)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o + 2), 0x07)
    o = o + 4
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o), ACL_USER)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o + 2), 0x06)
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](ab) + o + 4), 1000)
    o = o + 8
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o), ACL_GROUP_OBJ)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o + 2), 0x04)
    o = o + 4
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o), ACL_MASK)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o + 2), 0x06)
    o = o + 4
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o), ACL_OTHER)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](ab) + o + 2), 0x04)
    o = o + 4
    tags: Array[8, uint16]
    perms: Array[8, uint16]
    ids: Array[8, uint32]
    ne: int32 = ext4_acl_decode(ab, o, &tags[0], &perms[0], &ids[0], 8)
    if ne != 5:
        printk1("[ext4-xattr] FAIL: acl decode count=%d (want 5)\n",
                cast[uint64](cast[int64](ne)))
        return -1
    # The named USER(1000) entry must carry its id and rw- perms.
    if tags[1] != ACL_USER or ids[1] != 1000 or perms[1] != 0x06:
        printk0("[ext4-xattr] FAIL: acl USER entry decode\n")
        return -1
    # Access check: uid 1000 wants write (0x02) -> granted via USER&MASK.
    if ext4_acl_access_check(ab, o, 1000, 0, 0x02) != 1:
        printk0("[ext4-xattr] FAIL: acl check uid1000 write denied\n")
        return -1
    # uid 1000 wants execute (0x01) -> denied (USER perms have no x).
    if ext4_acl_access_check(ab, o, 1000, 0, 0x01) != 0:
        printk0("[ext4-xattr] FAIL: acl check uid1000 exec granted\n")
        return -1

    # --- external block: a value too large for the inode slack must
    #     spill to a freshly-allocated i_file_acl block, yet remain
    #     readable through the same getxattr path. The in-inode user.size
    #     attribute must SURVIVE this external spill.
    nbig: Ptr[char] = "user.big"
    bi: uint64 = 0
    while bi < 600:
        ext4_xattr_big_val[bi] = cast[uint8](65 + (bi % 26))   # 'A'..'Z'
        bi = bi + 1
    if ext4_setxattr(inum, nbig, &ext4_xattr_big_val[0], 600, 0) != 0:
        printk0("[ext4-xattr] FAIL: setxattr external user.big\n")
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        printk0("[ext4-xattr] FAIL: re-read inode (external)\n")
        return -1
    # i_file_acl must now name a real block.
    facl_chk: uint32 = _ext4_read_u32(
        cast[Ptr[uint8]](cast[uint64](&ext4_xattr_inode_buf[0])
                         + INODE_I_FILE_ACL_OFFSET))
    if facl_chk == 0:
        printk0("[ext4-xattr] FAIL: external block not allocated\n")
        return -1
    gbig: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], nbig,
                                _ext4_strlen(nbig),
                                &ext4_xattr_big_rd[0], 1024)
    if gbig != 600:
        printk1("[ext4-xattr] FAIL: getxattr big len=%d (want 600)\n",
                cast[uint64](cast[int64](gbig)))
        return -1
    if _ext4_mem_eq(&ext4_xattr_big_rd[0], &ext4_xattr_big_val[0],
                    600) == 0:
        printk0("[ext4-xattr] FAIL: external big value mismatch\n")
        return -1
    # The in-inode user.size must still resolve after the spill.
    gsz2: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], n2,
                                _ext4_strlen(n2),
                                &ext4_xattr_test_val[0], 64)
    if gsz2 != cast[int32](_ext4_strlen(v2)):
        printk0("[ext4-xattr] FAIL: inline size lost after external spill\n")
        return -1
    # list must show both the inline AND the external name.
    ll2: int32 = ext4_listxattr(&ext4_xattr_inode_buf[0],
                                &ext4_xattr_test_list[0], 256)
    if _ext4_xattr_list_has(&ext4_xattr_test_list[0],
                            cast[uint64](ll2), nbig) == 0:
        printk0("[ext4-xattr] FAIL: list missing external user.big\n")
        return -1
    if _ext4_xattr_list_has(&ext4_xattr_test_list[0],
                            cast[uint64](ll2), n2) == 0:
        printk0("[ext4-xattr] FAIL: list missing inline user.size\n")
        return -1

    # --- removexattr: drop the inline user.size; user.color (inline) and
    #     user.big (external) must survive, and user.size must be gone.
    if ext4_removexattr(inum, n2) != 0:
        printk0("[ext4-xattr] FAIL: removexattr user.size\n")
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        printk0("[ext4-xattr] FAIL: re-read inode (remove)\n")
        return -1
    grm: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], n2,
                               _ext4_strlen(n2),
                               &ext4_xattr_test_val[0], 64)
    if grm != -61:
        printk1("[ext4-xattr] FAIL: removed size still present rc=%d\n",
                cast[uint64](cast[int64](grm)))
        return -1
    gsurv: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], n1,
                                 _ext4_strlen(n1),
                                 &ext4_xattr_test_val[0], 64)
    if gsurv != cast[int32](_ext4_strlen(v1b)):
        printk0("[ext4-xattr] FAIL: color lost after size remove\n")
        return -1
    gsurv2: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0], nbig,
                                  _ext4_strlen(nbig),
                                  &ext4_xattr_big_rd[0], 1024)
    if gsurv2 != 600:
        printk0("[ext4-xattr] FAIL: external big lost after size remove\n")
        return -1

    # --- POSIX ACL round-trip: store the access ACL blob built above as
    #     system.posix_acl_access, read it back, assert byte-exact.
    if ext4_setxattr(inum, "system.posix_acl_access", ab, o, 0) != 0:
        printk0("[ext4-xattr] FAIL: setxattr posix_acl_access\n")
        return -1
    if ext4_read_inode(cast[uint64](inum),
                       &ext4_xattr_inode_buf[0]) != 0:
        printk0("[ext4-xattr] FAIL: re-read inode (acl)\n")
        return -1
    gacl: int32 = ext4_getxattr(&ext4_xattr_inode_buf[0],
                                "system.posix_acl_access",
                                _ext4_strlen("system.posix_acl_access"),
                                &ext4_xattr_acl_rd[0], 128)
    if gacl != cast[int32](o):
        printk1("[ext4-xattr] FAIL: acl roundtrip len=%d\n",
                cast[uint64](cast[int64](gacl)))
        return -1
    if _ext4_mem_eq(&ext4_xattr_acl_rd[0], ab, o) == 0:
        printk0("[ext4-xattr] FAIL: acl blob not byte-exact\n")
        return -1
    # The round-tripped blob must still decode + grant uid1000 write.
    if ext4_acl_access_check(&ext4_xattr_acl_rd[0], cast[uint64](gacl),
                             1000, 0, 0x02) != 1:
        printk0("[ext4-xattr] FAIL: roundtripped acl denies uid1000 write\n")
        return -1

    printk0("[ext4-xattr] PASS\n")
    return 0


def _ext4_xattr_list_has(list_buf: Ptr[uint8], list_len: uint64,
                         name: Ptr[char]) -> int32:
    # 1 if the NUL-separated `list_buf` contains the exact name.
    nlen: uint64 = _ext4_strlen(name)
    i: uint64 = 0
    start: uint64 = 0
    while i <= list_len:
        if i == list_len or list_buf[i] == 0:
            seg: uint64 = i - start
            if seg == nlen \
               and _ext4_mem_eq(cast[Ptr[uint8]](
                       cast[uint64](list_buf) + start),
                       cast[Ptr[uint8]](name), nlen) != 0:
                return 1
            start = i + 1
        i = i + 1
    return 0


# =========================================================================
# ext4 fs-verity — built-in, read-only, transparently-verified file
# integrity via a salted SHA-256 Merkle hash tree (Linux fs/verity/ +
# the ext4 EXT4_VERITY_FL inode flag)
# =========================================================================
#
# fs-verity gives a regular file a built-in, read-only Merkle hash tree.
# Once verity is "enabled" on a file, every read of the file's data is
# transparently checked against a salted SHA-256 Merkle tree whose ROOT is
# recorded in trusted metadata. Any tampering with the file's data (or with
# the hash tree itself) is detected and the read FAILS (EIO), so the file's
# content is cryptographically authenticated. The file becomes immutable.
#
# This reuses the EXACT crypto + Merkle model proven by dm-verity
# (drivers/block/dm.ad): the shared sha256_oneshot primitive (fs/sha256.ad),
# salted leaves, and root-anchored descend/verify. The only difference is
# the home of the tree: dm-verity stores it on a hash block device; ext4
# fs-verity computes and pins it per-INODE.
#
# REPRESENTATION (mirrors how Linux ext4 places the Merkle tree in metadata
# associated with the inode, past i_size, gated on EXT4_VERITY_FL):
#   * VERITY BLOCK = one ext4 data block (ext4_block_size bytes). Each data
#     block's LEAF hash is sha256(salt || block_bytes). The per-file salt is
#     mixed in first, exactly like dm-verity / Linux fs-verity's salt.
#   * The leaves are packed (32 bytes each) into a single 4096-byte LEVEL-0
#     HASH BLOCK (up to 128 leaves -> EXT4_VERITY_MAX_BLOCKS data blocks).
#   * The trusted ROOT is sha256(salt || level-0 hash block). This ONE value
#     is what the verifier anchors to.
# The salt, the level-0 hash block, the trusted root, nblocks and the file
# size are stored in a small per-inode in-core registry (ext4_verity_ctxs),
# keyed by inode number, populated at enable time. EXT4_VERITY_FL is set on
# the on-disk inode so the read path knows to verify.
#
# VERIFY (per data block, end to end against the trusted root — identical
# guarantee to dm-verity's _dm_verity_verify_block):
#   1. recompute leaf = sha256(salt || data) and compare to the stored leaf
#      in the level-0 hash block  (detects a flipped DATA byte);
#   2. recompute root = sha256(salt || level-0 hash block) and compare to the
#      trusted root  (detects a flipped HASH-TREE byte or a forged hash
#      block).
# Any mismatch -> the read returns -5 (EIO) and NO data is delivered.

EXT4_VERITY_MAX:        uint64 = 4       # verity contexts system-wide
EXT4_VERITY_DIGEST:     uint64 = 32      # sha256 output bytes
EXT4_VERITY_HBLOCK:     uint64 = 4096    # bytes in the level-0 hash block
EXT4_VERITY_PER_BLOCK:  uint64 = 128     # 4096/32 leaf digests per hash block
EXT4_VERITY_MAX_BLOCKS: uint64 = 128     # data blocks per file (<= one L0 blk)
EXT4_VERITY_SALT_LEN:   uint64 = 32      # per-file salt bytes


class Ext4VerityContext:
    used:        uint32
    pad:         uint32
    inum:        uint32                  # inode this tree authenticates
    pad2:        uint32
    block_size:  uint64                  # verity block = ext4 data block
    nblocks:     uint64                  # number of data blocks covered
    file_size:   uint64                  # i_size pinned at enable time
    # Per-file salt mixed into every hash (leaf and interior).
    salt:        Array[32, uint8]
    # The trusted root hash = sha256(salt || level-0 hash block). The ONE
    # value the verifier anchors to. Built at enable time over clean data.
    root:        Array[32, uint8]
    # The level-0 hash block: leaf digests packed 32 bytes each. Kept in the
    # registry as the inode's verity metadata (Linux stores this past EOF).
    hblock:      Array[4096, uint8]


ext4_verity_ctxs: Array[4, Ext4VerityContext]

# Block-sized scratch for the verity path. All verity work is synchronous
# (single ext4 mount, single thread through the block layer), so a single
# shared set of working buffers is safe — no two verifications overlap.
# _ext4_ver_hashin holds salt(32) || one data/hash block; the level-0 hash
# block is 4096 bytes and a data block is at most ext4_block_size (<= 4096),
# so 32 + 4096 = 4128 bytes covers the largest staged input WITHOUT
# overflowing into the next module-scope global.
_ext4_ver_hashin: Array[4128, uint8]    # salt(32) || block — hash input
_ext4_ver_block:  Array[4096, uint8]    # one data block read off disk
_ext4_ver_leaf:   Array[32, uint8]      # recomputed leaf digest
_ext4_ver_root:   Array[32, uint8]      # recomputed root digest


def _ext4_verity_find(inum: uint32) -> int32:
    # Return the verity-context slot authenticating `inum`, or -1.
    i: uint64 = 0
    while i < EXT4_VERITY_MAX:
        if ext4_verity_ctxs[i].used != 0 \
           and ext4_verity_ctxs[i].inum == inum:
            return cast[int32](i)
        i = i + 1
    return -1


def _ext4_verity_alloc() -> int32:
    # Return a free verity-context slot, or -1 if all are in use.
    i: uint64 = 0
    while i < EXT4_VERITY_MAX:
        if ext4_verity_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _ext4_verity_hash_salted(slot: int32, data: Ptr[uint8], n: uint64,
                             out_hash: Ptr[uint8]):
    # out = sha256(salt || data[0:n]). The salt is prefixed first, exactly
    # as fs-verity / dm-verity mix their per-file salt into every leaf and
    # interior hash. Staged salt||data contiguously for one clean one-shot.
    i: uint64 = 0
    while i < EXT4_VERITY_SALT_LEN:
        _ext4_ver_hashin[i] = ext4_verity_ctxs[slot].salt[i]
        i = i + 1
    j: uint64 = 0
    while j < n:
        _ext4_ver_hashin[EXT4_VERITY_SALT_LEN + j] = data[j]
        j = j + 1
    sha256_oneshot(cast[Ptr[uint8]](&_ext4_ver_hashin[0]),
                   EXT4_VERITY_SALT_LEN + n, out_hash)


def ext4_verity_enable(inum: uint32) -> int32:
    # Enable fs-verity on the regular file at `inum`. Reads the file's data
    # block by block, computes each salted SHA-256 leaf, packs them into the
    # level-0 hash block, and hashes that (salted) into the trusted root —
    # all stored in a per-inode registry slot. Then sets EXT4_VERITY_FL on
    # the on-disk inode so subsequent reads verify. Returns 0 on success,
    # negative on error. Idempotent failure if already enabled.
    if ext4_blockdev_slot < 0:
        return -1
    if _ext4_verity_find(inum) >= 0:
        return -1                            # already verity-enabled
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    # Verity is for regular files only.
    if (cast[uint32](ext4_inode_mode(&inode[0])) & 0xF000) != 0x8000:
        return -1
    size: uint64 = cast[uint64](ext4_inode_size_lo(&inode[0]))
    bs: uint64 = ext4_block_size
    if bs == 0 or bs > 4096:
        return -1
    nblocks: uint64 = (size + bs - 1) / bs
    if nblocks == 0 or nblocks > EXT4_VERITY_MAX_BLOCKS:
        return -1

    slot: int32 = _ext4_verity_alloc()
    if slot < 0:
        return -1

    # Per-file salt. Derive a deterministic, file-specific salt from the
    # inode number and size so it is genuinely mixed into every hash (a real
    # value, not zero); fs-verity's salt is a stored per-file random value —
    # here it is pinned in the context at enable time.
    si: uint64 = 0
    while si < EXT4_VERITY_SALT_LEN:
        v: uint64 = (cast[uint64](inum) * 2654435761) \
            + (size * 40503) + si * 0x9E3779B9 + 0xA5
        ext4_verity_ctxs[slot].salt[si] = cast[uint8](v & 0xFF)
        si = si + 1

    # Zero the level-0 hash block, then fill leaf-by-leaf.
    z: uint64 = 0
    while z < EXT4_VERITY_HBLOCK:
        ext4_verity_ctxs[slot].hblock[z] = 0
        z = z + 1

    b: uint64 = 0
    while b < nblocks:
        # Read the file's logical data block. Zero-pad a short final block so
        # the leaf hashes exactly what the read path will deliver+verify.
        zz: uint64 = 0
        while zz < bs:
            _ext4_ver_block[zz] = 0
            zz = zz + 1
        rn: int64 = ext4_read_file(inum, b * bs, bs,
                                   cast[Ptr[uint8]](&_ext4_ver_block[0]))
        if rn < 0:
            ext4_verity_ctxs[slot].used = 0
            return -1
        _ext4_verity_hash_salted(slot, cast[Ptr[uint8]](&_ext4_ver_block[0]),
                                 bs, cast[Ptr[uint8]](&_ext4_ver_leaf[0]))
        k: uint64 = 0
        while k < EXT4_VERITY_DIGEST:
            ext4_verity_ctxs[slot].hblock[b * EXT4_VERITY_DIGEST + k] = \
                _ext4_ver_leaf[k]
            k = k + 1
        b = b + 1

    # Root = salted sha256 over the whole level-0 hash block. This is the
    # ONE trusted value the read path anchors to.
    _ext4_verity_hash_salted(slot,
                             cast[Ptr[uint8]](&ext4_verity_ctxs[slot].hblock[0]),
                             EXT4_VERITY_HBLOCK,
                             cast[Ptr[uint8]](&ext4_verity_ctxs[slot].root[0]))

    ext4_verity_ctxs[slot].inum = inum
    ext4_verity_ctxs[slot].block_size = bs
    ext4_verity_ctxs[slot].nblocks = nblocks
    ext4_verity_ctxs[slot].file_size = size
    ext4_verity_ctxs[slot].used = 1

    # Set EXT4_VERITY_FL on the on-disk inode so the read path verifies.
    cur_flags: uint32 = ext4_inode_flags(&inode[0])
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0])
                                     + INODE_I_FLAGS_OFFSET),
                    cur_flags | EXT4_VERITY_FL)
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        ext4_verity_ctxs[slot].used = 0
        return -1
    return 0


def _ext4_verity_verify_block(slot: int32, blkno: uint64,
                              data: Ptr[uint8]) -> int32:
    # Verify one data block end to end against the trusted root:
    #   1. recompute leaf = sha256(salt || data) and compare to the stored
    #      leaf in the level-0 hash block (detects a flipped DATA byte);
    #   2. recompute root = sha256(salt || level-0 hash block) and compare to
    #      the trusted root (detects a flipped HASH-TREE byte or a forged
    #      hash block). Returns 0 if verified, -5 (EIO) on any mismatch.
    bs: uint64 = ext4_verity_ctxs[slot].block_size
    # Step 1: leaf membership in the level-0 hash block.
    _ext4_verity_hash_salted(slot, data, bs,
                             cast[Ptr[uint8]](&_ext4_ver_leaf[0]))
    i: uint64 = 0
    while i < EXT4_VERITY_DIGEST:
        if _ext4_ver_leaf[i] \
           != ext4_verity_ctxs[slot].hblock[blkno * EXT4_VERITY_DIGEST + i]:
            return -5
        i = i + 1
    # Step 2: the hash block must itself hash (salted) up to the trusted
    # root. A flipped byte ANYWHERE in the hash tree changes this recomputed
    # root, so it no longer equals the trusted root and the read fails.
    _ext4_verity_hash_salted(slot,
                             cast[Ptr[uint8]](&ext4_verity_ctxs[slot].hblock[0]),
                             EXT4_VERITY_HBLOCK,
                             cast[Ptr[uint8]](&_ext4_ver_root[0]))
    j: uint64 = 0
    while j < EXT4_VERITY_DIGEST:
        if _ext4_ver_root[j] != ext4_verity_ctxs[slot].root[j]:
            return -5
        j = j + 1
    return 0


def _ext4_verity_read(inum: uint32, slot: int32, inode_buf: Ptr[uint8],
                      pos: uint64, count: uint64, buf: Ptr[uint8]) -> int64:
    # Verified read of `count` bytes at `pos` from a verity-enabled file.
    # For each ext4 block the request spans, read the WHOLE block off disk,
    # verify it against the Merkle tree rooted at the trusted root, and only
    # on success copy the requested slice out. Any verification failure
    # returns -5 (EIO) and delivers NO data — exactly the fs-verity
    # tamper-detection guarantee. `count`/`pos` are already clamped to EOF by
    # the caller.
    bs: uint64 = ext4_verity_ctxs[slot].block_size
    blkp: Ptr[uint8] = cast[Ptr[uint8]](&_ext4_ver_block[0])
    total: uint64 = 0
    while total < count:
        cur_off: uint64 = pos + total
        logical_blk: uint64 = cur_off / bs
        off_in_blk:  uint64 = cur_off % bs
        if logical_blk >= ext4_verity_ctxs[slot].nblocks:
            return cast[int64](total)
        phys_blk: uint64 = _ext4_logical_to_physical(inode_buf, logical_blk)
        # Zero-pad so a short final block hashes identically to enable time.
        zz: uint64 = 0
        while zz < bs:
            _ext4_ver_block[zz] = 0
            zz = zz + 1
        # SPARSE HOLE: an uncovered logical block inside i_size reads as
        # zeros — the Merkle tree was built over those zeros at enable
        # time, so the all-zero buffer must still VERIFY below (don't
        # bail as if EOF).
        if phys_blk != 0:
            if _ext4_read_block(phys_blk, blkp) != 0:
                return -5
        if _ext4_verity_verify_block(slot, logical_blk, blkp) != 0:
            printk2("ext4: verity hash mismatch inum=%d blk=%d " \
                    "(corruption detected)\n",
                    cast[uint64](inum), logical_blk)
            return -5
        chunk: uint64 = bs - off_in_blk
        if chunk > count - total:
            chunk = count - total
        memcpy(cast[Ptr[uint8]](cast[uint64](buf) + total),
               cast[Ptr[uint8]](cast[uint64](blkp) + off_in_blk),
               chunk)
        total = total + chunk
    return cast[int64](total)


# --- ext4 fs-verity self-test ------------------------------------------
#
# Gated on the cpio marker /etc/ext4-verity-test (planted exclusively by
# scripts/test_ext4_verity.sh / ENABLE_EXT4_VERITY_TEST=1). Builds a REAL
# multi-block file on the live ext4 mount, enables verity, then proves:
#   (a) a clean verity file reads back byte-identical AND verifies;
#   (b) tampering a DATA block on disk is DETECTED (read fails, no data);
#   (c) tampering a HASH-TREE node (a leaf in the level-0 hash block) is
#       DETECTED (read fails) — the recomputed root no longer matches the
#       trusted root;
#   (d) restoring the hash tree makes the file verify again.
# Each step prints a [ext4-verity] line; a final [ext4-verity] PASS only if
# every step passed.

EXT4_VERITY_TEST_BLOCKS: uint64 = 6        # multi-block test file
ext4_verity_test_buf:  Array[4096, uint8]  # per-block build/compare scratch
ext4_verity_test_disk: Array[4096, uint8]  # raw on-disk block tamper scratch
ext4_verity_test_phys: Array[8, uint64]    # physical block of each lblk


def _ext4_verity_test_byte(lblk: uint64, off: uint64) -> uint8:
    # Deterministic, position-dependent pattern so every block differs.
    v: uint64 = (lblk * 1103515245) + (off * 12345) + 7
    return cast[uint8]((v >> 3) & 0xFF)


def _ext4_verity_make_file(name: Ptr[char], nblocks: uint64) -> uint32:
    # Create a fresh empty regular file in the root dir and append
    # `nblocks` non-trivial one-block extents, each filled with a per-block
    # pattern. Returns the new inum (0 on failure).
    new_inum: uint32 = ext4_alloc_inode()
    if new_inum == 0:
        return 0
    p: Ptr[uint8] = &ext4_new_inode_buf[0]
    _ext4_zero(p, ext4_inode_size)
    _ext4_write_u16(p, 0x81B4)                          # i_mode IFREG|0664
    _ext4_inode_stamp_creator(p)
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 4), 0)   # i_size=0
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](p) + 26), 1)  # links=1
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 28), 0)  # i_blocks=0
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](p) + 32),
                    0x80000)                            # EXT4_EXTENTS_FL
    eh: uint64 = cast[uint64](p) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](eh + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](eh + 2), 0)        # eh_entries=0
    _ext4_write_u16(cast[Ptr[uint8]](eh + 4), 4)        # eh_max=4
    _ext4_write_u16(cast[Ptr[uint8]](eh + 6), 0)        # eh_depth=0
    _ext4_stamp_all_times(p)
    if ext4_write_inode(cast[uint64](new_inum), p) != 0:
        ext4_free_inode(new_inum)
        return 0
    if ext4_dir_insert(2, name, new_inum, 1) != 0:
        ext4_free_inode(new_inum)
        return 0

    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](new_inum), &inode[0]) != 0:
        return 0
    bs: uint64 = ext4_block_size
    lb: uint64 = 0
    while lb < nblocks:
        db: uint64 = ext4_alloc_block()
        if db == 0:
            return 0
        ext4_verity_test_phys[lb] = db
        o: uint64 = 0
        while o < bs:
            ext4_verity_test_buf[o] = _ext4_verity_test_byte(lb, o)
            o = o + 1
        if _ext4_write_block(db, &ext4_verity_test_buf[0]) != 0:
            return 0
        if _ext4_extent_append_block(&inode[0], lb, db) != 0:
            return 0
        lb = lb + 1
    # Commit i_size = nblocks full blocks + the grown extent tree.
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0]) + 4),
                    cast[uint32](nblocks * bs))
    if ext4_write_inode(cast[uint64](new_inum), &inode[0]) != 0:
        return 0
    return new_inum


def ext4_verity_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-verity] FAIL: ext4 not mounted\n")
        return -1
    printk1("[ext4-verity] block_size=%d\n", ext4_block_size)
    bs: uint64 = ext4_block_size
    nb: uint64 = EXT4_VERITY_TEST_BLOCKS

    inum: uint32 = _ext4_verity_make_file("verity.bin", nb)
    if inum == 0:
        printk0("[ext4-verity] FAIL: build test file\n")
        return -1
    printk2("[ext4-verity] built %d-block file inum=%d\n", nb,
            cast[uint64](inum))

    ok_all: int32 = 1

    # Enable verity: compute the salted Merkle tree + trusted root.
    if ext4_verity_enable(inum) != 0:
        printk0("[ext4-verity] FAIL: enable\n")
        return -1
    vslot: int32 = _ext4_verity_find(inum)
    if vslot < 0:
        printk0("[ext4-verity] FAIL: enable left no context\n")
        return -1
    printk0("[ext4-verity] PASS enable (Merkle tree + trusted root built)\n")

    # Confirm EXT4_VERITY_FL is now set on disk.
    vino: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &vino[0]) != 0 \
       or (ext4_inode_flags(&vino[0]) & EXT4_VERITY_FL) == 0:
        printk0("[ext4-verity] FAIL: EXT4_VERITY_FL not set on inode\n")
        ok_all = 0
    else:
        printk0("[ext4-verity] PASS flag (EXT4_VERITY_FL set on inode)\n")

    # (a) clean read: every block reads back byte-identical AND verifies.
    clean_ok: int32 = 1
    vb: uint64 = 0
    while vb < nb:
        rn: int64 = ext4_read_file(inum, vb * bs, bs,
                                   &ext4_verity_test_buf[0])
        if rn != cast[int64](bs):
            printk1("[ext4-verity] FAIL: short verified read lblk=%d\n", vb)
            clean_ok = 0
            vb = nb
        else:
            o: uint64 = 0
            while o < bs:
                if ext4_verity_test_buf[o] != _ext4_verity_test_byte(vb, o):
                    printk2("[ext4-verity] FAIL: byte mismatch lblk=%d off=%d\n",
                            vb, o)
                    clean_ok = 0
                    o = bs
                else:
                    o = o + 1
            vb = vb + 1
    if clean_ok != 0:
        printk0("[ext4-verity] PASS clean-read (byte-identical & verified)\n")
    else:
        ok_all = 0

    # (b) tamper a DATA block ON DISK and confirm the verified read FAILS.
    # Flip one byte of physical block of lblk 2, then read it back through
    # the verity path: the recomputed leaf no longer matches the stored
    # leaf, so the read returns the EIO error (negative), delivering nothing.
    dphys: uint64 = ext4_verity_test_phys[2]
    if _ext4_read_block(dphys, &ext4_verity_test_disk[0]) != 0:
        printk0("[ext4-verity] FAIL: read data block for tamper\n")
        ok_all = 0
    else:
        orig: uint8 = ext4_verity_test_disk[10]
        ext4_verity_test_disk[10] = orig ^ cast[uint8](0xFF)
        if _ext4_write_block(dphys, &ext4_verity_test_disk[0]) != 0:
            printk0("[ext4-verity] FAIL: write tampered data block\n")
            ok_all = 0
        else:
            tn: int64 = ext4_read_file(inum, 2 * bs, bs,
                                       &ext4_verity_test_buf[0])
            if tn < 0:
                printk0("[ext4-verity] PASS detect-data-tamper " \
                        "(flipped data byte -> read EIO)\n")
            else:
                printk0("[ext4-verity] FAIL: data tamper UNDETECTED\n")
                ok_all = 0
            # Restore the data block so the file is clean again.
            ext4_verity_test_disk[10] = orig
            if _ext4_write_block(dphys, &ext4_verity_test_disk[0]) != 0:
                printk0("[ext4-verity] FAIL: restore data block\n")
                ok_all = 0

    # Sanity: after restoring the data block, the read verifies again.
    rn2: int64 = ext4_read_file(inum, 2 * bs, bs, &ext4_verity_test_buf[0])
    if rn2 == cast[int64](bs):
        printk0("[ext4-verity] PASS reverify-after-data-restore\n")
    else:
        printk0("[ext4-verity] FAIL: read after data restore not clean\n")
        ok_all = 0

    # (c) tamper a HASH-TREE node: flip one byte of a leaf in the level-0
    # hash block held in the verity context. The recomputed root now differs
    # from the trusted root, so EVERY verified read fails (the hash tree no
    # longer hashes up to the anchored root).
    hbyte: uint64 = 3 * EXT4_VERITY_DIGEST + 5     # a byte of leaf #3
    horig: uint8 = ext4_verity_ctxs[vslot].hblock[hbyte]
    ext4_verity_ctxs[vslot].hblock[hbyte] = horig ^ cast[uint8](0xFF)
    hn: int64 = ext4_read_file(inum, 0, bs, &ext4_verity_test_buf[0])
    if hn < 0:
        printk0("[ext4-verity] PASS detect-tree-tamper " \
                "(flipped hash-tree byte -> read EIO)\n")
    else:
        printk0("[ext4-verity] FAIL: hash-tree tamper UNDETECTED\n")
        ok_all = 0
    # Restore the hash tree node.
    ext4_verity_ctxs[vslot].hblock[hbyte] = horig

    # (d) after restoring the hash tree, the file verifies again.
    hn2: int64 = ext4_read_file(inum, 0, bs, &ext4_verity_test_buf[0])
    if hn2 == cast[int64](bs):
        printk0("[ext4-verity] PASS reverify-after-tree-restore\n")
    else:
        printk0("[ext4-verity] FAIL: read after tree restore not clean\n")
        ok_all = 0

    if ok_all != 0:
        printk0("[ext4-verity] PASS\n")
    else:
        printk0("[ext4-verity] FAIL\n")
    return 0


# =========================================================================
# ext4 fscrypt — per-file CONTENT encryption at rest via AES-256-XTS
# (Linux fs/crypto/ + the ext4 EXT4_ENCRYPT_FL inode flag)
# =========================================================================
#
# fscrypt gives a regular file transparent content confidentiality: every
# data block is stored ENCRYPTED on the backing device and decrypted only on
# read. This is the CONFIDENTIALITY analogue of fs-verity's read-path
# interception (which gives INTEGRITY): both gate on a per-inode flag and a
# per-inode in-core context, route the data path through a crypto transform,
# and behave exactly as before for unflagged inodes.
#
# CRYPTO (reuses the EXACT AES-256-XTS proven by dm-crypt, fs/aes_xts.ad —
# the same cipher Linux fscrypt uses for file contents):
#   * Each ext4 DATA BLOCK is one XTS "data unit". The XTS tweak/data-unit
#     index is the file LOGICAL BLOCK NUMBER (Linux fscrypt's per-file
#     IV_INO_LBLK default uses the logical block as the IV). Two different
#     logical blocks therefore encrypt identical plaintext to DIFFERENT
#     ciphertext, and every block is independently seekable.
#   * The per-file 64-byte XTS content key (32-byte data key || 32-byte tweak
#     key) is DERIVED from a 32-byte master key with a real HKDF-SHA256
#     (RFC 5869) expand step keyed by the inode number, mirroring how Linux
#     fscrypt derives per-file keys from the master key with HKDF-SHA512.
#     The derived key is genuinely one-way from the master (NOT a memcpy):
#     recovering it requires the master key.
#
# REPRESENTATION: the derived content key, the file size and block count are
# pinned in a small per-inode in-core registry (ext4_fscrypt_ctxs), keyed by
# inode number, populated at policy-set time. EXT4_ENCRYPT_FL is set on the
# on-disk inode so the read path knows to decrypt.
#
# WRITE: ext4_fscrypt_write_block(ctx, lblk, plaintext) XTS-encrypts the
#   block (tweak = lblk) under the content key and writes the CIPHERTEXT to
#   the backing device — the on-disk bytes are NOT the plaintext.
# READ: _ext4_fscrypt_read routes an EXT4_ENCRYPT_FL inode through a decrypt
#   step that XTS-decrypts each block (same key + tweak) back to plaintext.

EXT4_FSCRYPT_MAX:     uint64 = 4       # fscrypt contexts system-wide
EXT4_FSCRYPT_KEYLEN:  uint64 = 64      # AES-256-XTS key: 32 data + 32 tweak
EXT4_FSCRYPT_MKLEN:   uint64 = 32      # master-key length (bytes)


class Ext4FscryptContext:
    used:        uint32
    pad:         uint32
    inum:        uint32                  # inode this key encrypts
    pad2:        uint32
    block_size:  uint64                  # crypto data unit = ext4 data block
    nblocks:     uint64                  # number of data blocks covered
    file_size:   uint64                  # i_size pinned at policy-set time
    # The per-file derived 64-byte AES-256-XTS content key (data||tweak).
    key:         Array[64, uint8]


ext4_fscrypt_ctxs: Array[4, Ext4FscryptContext]

# Block-sized scratch for the fscrypt path. All fscrypt work is synchronous
# (single ext4 mount, single thread through the block layer), so a single
# shared set of working buffers is safe — no two transforms overlap. Both
# buffers are 4096 = the largest ext4 block, so a worst-case data block fits
# WITHOUT overflowing into the next module-scope global.
_ext4_fscr_block:  Array[4096, uint8]   # one data block (plain or cipher)
_ext4_fscr_stage:  Array[4096, uint8]   # XTS staging (cipher <-> plain)

# HMAC-SHA256 scratch for the HKDF key-derivation (RFC 2104 / RFC 5869).
# SHA-256 block size is 64 bytes; the master key (32) fits in one block, so
# the padded key buffers are 64 bytes. The HKDF info string plus a 1-byte
# counter plus a 32-byte T(prev) is small; 128 bytes covers the largest HMAC
# message staged here WITHOUT overflowing into the next global.
_ext4_fscr_kpad:   Array[64, uint8]     # padded HMAC key (K0)
_ext4_fscr_ipad:   Array[128, uint8]    # ipad-key || message
_ext4_fscr_opad:   Array[128, uint8]    # opad-key || inner-hash
_ext4_fscr_inner:  Array[32, uint8]     # inner SHA-256 digest
_ext4_fscr_tprev:  Array[32, uint8]     # HKDF T(i-1) feedback


def _ext4_fscrypt_find(inum: uint32) -> int32:
    # Return the fscrypt-context slot holding the content key for `inum`,
    # or -1.
    i: uint64 = 0
    while i < EXT4_FSCRYPT_MAX:
        if ext4_fscrypt_ctxs[i].used != 0 \
           and ext4_fscrypt_ctxs[i].inum == inum:
            return cast[int32](i)
        i = i + 1
    return -1


def _ext4_fscrypt_alloc() -> int32:
    # Return a free fscrypt-context slot, or -1 if all are in use.
    i: uint64 = 0
    while i < EXT4_FSCRYPT_MAX:
        if ext4_fscrypt_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _ext4_hmac_sha256(key: Ptr[uint8], klen: uint64,
                      msg: Ptr[uint8], mlen: uint64,
                      out_mac: Ptr[uint8]):
    # HMAC-SHA256 (RFC 2104): out = H((K0 ^ opad) || H((K0 ^ ipad) || msg)).
    # K0 is the key zero-padded to the 64-byte SHA-256 block (keys longer
    # than 64 bytes are first hashed; here klen <= 32 so that branch is
    # never needed, but we honour the longer-key rule for correctness).
    bs: uint64 = 64
    # Build K0 in _ext4_fscr_kpad.
    z: uint64 = 0
    while z < bs:
        _ext4_fscr_kpad[z] = 0
        z = z + 1
    if klen > bs:
        sha256_oneshot(key, klen, cast[Ptr[uint8]](&_ext4_fscr_kpad[0]))
    else:
        c0: uint64 = 0
        while c0 < klen:
            _ext4_fscr_kpad[c0] = key[c0]
            c0 = c0 + 1
    # inner = (K0 ^ ipad) || msg
    i: uint64 = 0
    while i < bs:
        _ext4_fscr_ipad[i] = _ext4_fscr_kpad[i] ^ 0x36
        i = i + 1
    j: uint64 = 0
    while j < mlen:
        _ext4_fscr_ipad[bs + j] = msg[j]
        j = j + 1
    sha256_oneshot(cast[Ptr[uint8]](&_ext4_fscr_ipad[0]), bs + mlen,
                   cast[Ptr[uint8]](&_ext4_fscr_inner[0]))
    # outer = (K0 ^ opad) || inner
    i = 0
    while i < bs:
        _ext4_fscr_opad[i] = _ext4_fscr_kpad[i] ^ 0x5C
        i = i + 1
    k: uint64 = 0
    while k < 32:
        _ext4_fscr_opad[bs + k] = _ext4_fscr_inner[k]
        k = k + 1
    sha256_oneshot(cast[Ptr[uint8]](&_ext4_fscr_opad[0]), bs + 32, out_mac)


def _ext4_fscrypt_derive_key(master: Ptr[uint8], inum: uint32,
                             out_key: Ptr[uint8]):
    # Derive the per-file 64-byte AES-256-XTS content key from the 32-byte
    # master key using HKDF-Expand (RFC 5869) with HMAC-SHA256, keyed by the
    # inode number — mirroring Linux fscrypt's per-file key derivation from a
    # master key. PRK = master key. For each 32-byte output block:
    #   T(n) = HMAC(PRK, T(n-1) || info || n), info = "ext4fscrypt" || inum.
    # 64 bytes need two HMAC blocks (T(1), T(2)). The derived key is genuinely
    # one-way from the master (recovering it requires the master key) — NOT a
    # memcpy of the master.
    info: Array[19, uint8]               # "ext4fscrypt"(11) + inum(4) + ctr(1) [+slack]
    # The fixed 11-byte HKDF info label "ext4fscrypt" (ASCII), set byte by
    # byte to avoid relying on string-literal subscripting.
    info[0]  = 101                       # 'e'
    info[1]  = 120                       # 'x'
    info[2]  = 116                       # 't'
    info[3]  = 52                        # '4'
    info[4]  = 102                       # 'f'
    info[5]  = 115                       # 's'
    info[6]  = 99                        # 'c'
    info[7]  = 114                       # 'r'
    info[8]  = 121                       # 'y'
    info[9]  = 112                       # 'p'
    info[10] = 116                       # 't'
    info[11] = cast[uint8](inum & 0xFF)
    info[12] = cast[uint8]((inum >> 8) & 0xFF)
    info[13] = cast[uint8]((inum >> 16) & 0xFF)
    info[14] = cast[uint8]((inum >> 24) & 0xFF)
    # HKDF-Expand: produce 64 bytes as T(1)||T(2).
    n: uint64 = 1
    produced: uint64 = 0
    while produced < EXT4_FSCRYPT_KEYLEN:
        # Stage the HMAC message: T(prev) (only for n>1) || info(15) || n.
        mlen: uint64 = 0
        if n > 1:
            p: uint64 = 0
            while p < 32:
                _ext4_fscr_stage[mlen] = _ext4_fscr_tprev[p]
                mlen = mlen + 1
                p = p + 1
        q: uint64 = 0
        while q < 15:
            _ext4_fscr_stage[mlen] = info[q]
            mlen = mlen + 1
            q = q + 1
        _ext4_fscr_stage[mlen] = cast[uint8](n & 0xFF)
        mlen = mlen + 1
        _ext4_hmac_sha256(master, EXT4_FSCRYPT_MKLEN,
                          cast[Ptr[uint8]](&_ext4_fscr_stage[0]), mlen,
                          cast[Ptr[uint8]](&_ext4_fscr_tprev[0]))
        c: uint64 = 0
        while c < 32 and produced < EXT4_FSCRYPT_KEYLEN:
            out_key[produced] = _ext4_fscr_tprev[c]
            produced = produced + 1
            c = c + 1
        n = n + 1


def ext4_fscrypt_set_policy(inum: uint32, master: Ptr[uint8]) -> int32:
    # Register an fscrypt encryption policy on the regular file at `inum`:
    # derive its per-file AES-256-XTS content key from the master key, pin it
    # in a registry slot, and set EXT4_ENCRYPT_FL on the on-disk inode so the
    # read path decrypts. Returns 0 on success, negative on error.
    if ext4_blockdev_slot < 0:
        return -1
    if _ext4_fscrypt_find(inum) >= 0:
        return -1                            # already has a policy
    inode: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &inode[0]) != 0:
        return -1
    # fscrypt is for regular files only.
    if (cast[uint32](ext4_inode_mode(&inode[0])) & 0xF000) != 0x8000:
        return -1
    size: uint64 = cast[uint64](ext4_inode_size_lo(&inode[0]))
    bs: uint64 = ext4_block_size
    if bs == 0 or bs > 4096:
        return -1
    nblocks: uint64 = (size + bs - 1) / bs

    slot: int32 = _ext4_fscrypt_alloc()
    if slot < 0:
        return -1

    _ext4_fscrypt_derive_key(master, inum,
                             cast[Ptr[uint8]](&ext4_fscrypt_ctxs[slot].key[0]))
    ext4_fscrypt_ctxs[slot].inum = inum
    ext4_fscrypt_ctxs[slot].block_size = bs
    ext4_fscrypt_ctxs[slot].nblocks = nblocks
    ext4_fscrypt_ctxs[slot].file_size = size
    ext4_fscrypt_ctxs[slot].used = 1

    # Set EXT4_ENCRYPT_FL on the on-disk inode so the read path decrypts.
    cur_flags: uint32 = ext4_inode_flags(&inode[0])
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&inode[0])
                                     + INODE_I_FLAGS_OFFSET),
                    cur_flags | EXT4_ENCRYPT_FL)
    if ext4_write_inode(cast[uint64](inum), &inode[0]) != 0:
        ext4_fscrypt_ctxs[slot].used = 0
        return -1
    return 0


def ext4_fscrypt_write_block(slot: int32, lblk: uint64, phys: uint64,
                             plaintext: Ptr[uint8]) -> int32:
    # Encrypt one ext4 data block (`plaintext`, block_size bytes) with
    # AES-256-XTS under the file's content key, using the file LOGICAL BLOCK
    # NUMBER (`lblk`) as the XTS tweak/data-unit index, then write the
    # CIPHERTEXT to physical block `phys`. The plaintext NEVER reaches the
    # backing device. Returns 0 on success, negative on error.
    if slot < 0:
        return -1
    bs: uint64 = ext4_fscrypt_ctxs[slot].block_size
    aes_xts_set_key(cast[Ptr[uint8]](&ext4_fscrypt_ctxs[slot].key[0]))
    aes_xts_encrypt_unit(lblk, bs,
                         cast[Ptr[uint8]](&_ext4_fscr_stage[0]), plaintext)
    return _ext4_write_block(phys, &_ext4_fscr_stage[0])


def _ext4_fscrypt_read(inum: uint32, slot: int32, inode_buf: Ptr[uint8],
                       pos: uint64, count: uint64, buf: Ptr[uint8]) -> int64:
    # Decrypting read of `count` bytes at `pos` from an fscrypt-enabled file.
    # For each ext4 block the request spans, read the WHOLE ciphertext block
    # off disk, AES-256-XTS-decrypt it (tweak = logical block number) under
    # the file's content key, and copy out the requested slice. `count`/`pos`
    # are already clamped to EOF by the caller.
    bs: uint64 = ext4_fscrypt_ctxs[slot].block_size
    aes_xts_set_key(cast[Ptr[uint8]](&ext4_fscrypt_ctxs[slot].key[0]))
    total: uint64 = 0
    while total < count:
        cur_off: uint64 = pos + total
        logical_blk: uint64 = cur_off / bs
        off_in_blk:  uint64 = cur_off % bs
        chunk: uint64 = bs - off_in_blk
        if chunk > count - total:
            chunk = count - total
        phys_blk: uint64 = _ext4_logical_to_physical(inode_buf, logical_blk)
        if phys_blk == 0:
            # SPARSE HOLE: an uncovered logical block inside i_size reads
            # as zeros (nothing was ever encrypted there) — not EOF.
            _ext4_zero(cast[Ptr[uint8]](cast[uint64](buf) + total),
                       chunk)
            total = total + chunk
        else:
            if _ext4_read_block(phys_blk, &_ext4_fscr_stage[0]) != 0:
                return cast[int64](total)
            # XTS-decrypt the ciphertext block into the plaintext block
            # buffer.
            aes_xts_decrypt_unit(logical_blk, bs,
                                 cast[Ptr[uint8]](&_ext4_fscr_block[0]),
                                 cast[Ptr[uint8]](&_ext4_fscr_stage[0]))
            memcpy(cast[Ptr[uint8]](cast[uint64](buf) + total),
                   cast[Ptr[uint8]](cast[uint64](&_ext4_fscr_block[0])
                                    + off_in_blk),
                   chunk)
            total = total + chunk
    return cast[int64](total)


# --- ext4 fscrypt self-test --------------------------------------------
#
# Gated on the cpio marker /etc/ext4-fscrypt-test (planted exclusively by
# scripts/test_ext4_fscrypt.sh / ENABLE_EXT4_FSCRYPT_TEST=1). Builds a REAL
# multi-block file on the live ext4 mount, sets an fscrypt policy, writes a
# known plaintext ENCRYPTED to disk, then proves with real AES-256-XTS:
#   (a) the file reads back byte-identical through the decrypt path;
#   (b) the RAW on-disk block (read beneath the encryption layer) is genuine
#       CIPHERTEXT, NOT the plaintext;
#   (c) two different logical blocks with identical plaintext produce
#       DIFFERENT ciphertext (the XTS tweak = block number is applied);
#   (d) decrypting with the WRONG key yields garbage, not the plaintext.
# Each step prints a [ext4-fscrypt] line; a final [ext4-fscrypt] PASS only if
# every step passed.

EXT4_FSCRYPT_TEST_BLOCKS: uint64 = 4        # multi-block test file
ext4_fscrypt_test_buf:  Array[4096, uint8]  # per-block build/compare scratch
ext4_fscrypt_test_disk: Array[4096, uint8]  # raw on-disk ciphertext scratch
ext4_fscrypt_test_dec:  Array[4096, uint8]  # wrong-key decrypt scratch
ext4_fscrypt_test_phys: Array[8, uint64]    # physical block of each lblk
ext4_fscrypt_test_mk:   Array[32, uint8]    # the test master key
ext4_fscrypt_test_wk:   Array[64, uint8]    # a deliberately-wrong XTS key


def _ext4_fscrypt_test_byte(off: uint64) -> uint8:
    # Deterministic plaintext pattern that is IDENTICAL for every logical
    # block (no lblk term), so subcheck (c) can prove the XTS tweak alone
    # makes two blocks' ciphertext differ.
    v: uint64 = (off * 12345) + 7
    return cast[uint8]((v >> 3) & 0xFF)


def ext4_fscrypt_selftest() -> int32:
    if ext4_blockdev_slot < 0:
        printk0("[ext4-fscrypt] FAIL: ext4 not mounted\n")
        return -1
    printk1("[ext4-fscrypt] block_size=%d\n", ext4_block_size)
    bs: uint64 = ext4_block_size
    nb: uint64 = EXT4_FSCRYPT_TEST_BLOCKS

    # Pin a non-trivial master key for the test.
    mi: uint64 = 0
    while mi < 32:
        ext4_fscrypt_test_mk[mi] = cast[uint8]((mi * 37 + 11) & 0xFF)
        mi = mi + 1

    ok_all: int32 = 1

    # Reserve the registry slot + derive the per-file key BEFORE building the
    # file, so the file builder can encrypt each block as it writes it. We
    # create the file first to get an inum, then set the policy, then (since
    # the file has no data yet) the make-file path encrypts using the slot.
    # To keep the build-then-encrypt order simple we: alloc inum via make,
    # but make needs the slot. So set the policy on a zero-length file first.
    inum: uint32 = ext4_alloc_inode()
    if inum == 0:
        printk0("[ext4-fscrypt] FAIL: alloc inode\n")
        return -1
    # Stamp a minimal empty regular file so set_policy accepts it.
    pp: Ptr[uint8] = &ext4_new_inode_buf[0]
    _ext4_zero(pp, ext4_inode_size)
    _ext4_write_u16(pp, 0x81B4)
    _ext4_inode_stamp_creator(pp)
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](pp) + 4), 0)
    _ext4_write_u16(cast[Ptr[uint8]](cast[uint64](pp) + 26), 1)
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](pp) + 28), 0)
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](pp) + 32), 0x80000)
    ehp: uint64 = cast[uint64](pp) + INODE_I_BLOCK_OFFSET
    _ext4_write_u16(cast[Ptr[uint8]](ehp + 0), EXT4_EXTENT_MAGIC)
    _ext4_write_u16(cast[Ptr[uint8]](ehp + 2), 0)
    _ext4_write_u16(cast[Ptr[uint8]](ehp + 4), 4)
    _ext4_write_u16(cast[Ptr[uint8]](ehp + 6), 0)
    _ext4_stamp_all_times(pp)
    if ext4_write_inode(cast[uint64](inum), pp) != 0:
        printk0("[ext4-fscrypt] FAIL: write empty inode\n")
        return -1
    if ext4_dir_insert(2, "fscrypt.bin", inum, 1) != 0:
        printk0("[ext4-fscrypt] FAIL: link test file\n")
        return -1

    # Set the fscrypt policy: derive the content key + set EXT4_ENCRYPT_FL.
    if ext4_fscrypt_set_policy(inum, &ext4_fscrypt_test_mk[0]) != 0:
        printk0("[ext4-fscrypt] FAIL: set policy\n")
        return -1
    cslot: int32 = _ext4_fscrypt_find(inum)
    if cslot < 0:
        printk0("[ext4-fscrypt] FAIL: policy left no context\n")
        return -1
    printk0("[ext4-fscrypt] PASS set-policy (per-file AES-256-XTS key " \
            "derived via HKDF-SHA256)\n")

    # Confirm EXT4_ENCRYPT_FL is now set on disk.
    cino: Array[256, uint8]
    if ext4_read_inode(cast[uint64](inum), &cino[0]) != 0 \
       or (ext4_inode_flags(&cino[0]) & EXT4_ENCRYPT_FL) == 0:
        printk0("[ext4-fscrypt] FAIL: EXT4_ENCRYPT_FL not set on inode\n")
        ok_all = 0
    else:
        printk0("[ext4-fscrypt] PASS flag (EXT4_ENCRYPT_FL set on inode)\n")

    # Now append the data blocks, encrypting each with the file's key. The
    # plaintext is identical for every block.
    if ext4_read_inode(cast[uint64](inum), &cino[0]) != 0:
        printk0("[ext4-fscrypt] FAIL: re-read inode for data append\n")
        return -1
    lb: uint64 = 0
    while lb < nb:
        db: uint64 = ext4_alloc_block()
        if db == 0:
            printk0("[ext4-fscrypt] FAIL: alloc data block\n")
            return -1
        ext4_fscrypt_test_phys[lb] = db
        o: uint64 = 0
        while o < bs:
            ext4_fscrypt_test_buf[o] = _ext4_fscrypt_test_byte(o)
            o = o + 1
        if ext4_fscrypt_write_block(cslot, lb, db,
                                    &ext4_fscrypt_test_buf[0]) != 0:
            printk0("[ext4-fscrypt] FAIL: encrypt+write block\n")
            return -1
        if _ext4_extent_append_block(&cino[0], lb, db) != 0:
            printk0("[ext4-fscrypt] FAIL: extent append\n")
            return -1
        lb = lb + 1
    _ext4_write_u32(cast[Ptr[uint8]](cast[uint64](&cino[0]) + 4),
                    cast[uint32](nb * bs))
    if ext4_write_inode(cast[uint64](inum), &cino[0]) != 0:
        printk0("[ext4-fscrypt] FAIL: commit i_size\n")
        return -1
    # Refresh the context's block count now the file has data.
    ext4_fscrypt_ctxs[cslot].nblocks = nb
    ext4_fscrypt_ctxs[cslot].file_size = nb * bs
    printk2("[ext4-fscrypt] built %d-block encrypted file inum=%d\n", nb,
            cast[uint64](inum))

    # (a) read back byte-identical through the decrypt path.
    clean_ok: int32 = 1
    cb: uint64 = 0
    while cb < nb:
        rn: int64 = ext4_read_file(inum, cb * bs, bs,
                                   &ext4_fscrypt_test_buf[0])
        if rn != cast[int64](bs):
            printk1("[ext4-fscrypt] FAIL: short decrypted read lblk=%d\n", cb)
            clean_ok = 0
            cb = nb
        else:
            o2: uint64 = 0
            while o2 < bs:
                if ext4_fscrypt_test_buf[o2] != _ext4_fscrypt_test_byte(o2):
                    printk2("[ext4-fscrypt] FAIL: plaintext mismatch " \
                            "lblk=%d off=%d\n", cb, o2)
                    clean_ok = 0
                    o2 = bs
                else:
                    o2 = o2 + 1
            cb = cb + 1
    if clean_ok != 0:
        printk0("[ext4-fscrypt] PASS decrypt-roundtrip " \
                "(reads back byte-identical plaintext)\n")
    else:
        ok_all = 0

    # (b) the RAW on-disk block is genuine CIPHERTEXT, NOT plaintext.
    cipher_ok: int32 = 1
    if _ext4_read_block(ext4_fscrypt_test_phys[0],
                        &ext4_fscrypt_test_disk[0]) != 0:
        printk0("[ext4-fscrypt] FAIL: read raw on-disk block\n")
        ok_all = 0
        cipher_ok = 0
    else:
        same: int32 = 1
        differ: uint64 = 0
        o3: uint64 = 0
        while o3 < bs:
            if ext4_fscrypt_test_disk[o3] != _ext4_fscrypt_test_byte(o3):
                same = 0
                differ = differ + 1
            o3 = o3 + 1
        if same != 0:
            printk0("[ext4-fscrypt] FAIL: on-disk block equals plaintext " \
                    "(not encrypted!)\n")
            ok_all = 0
            cipher_ok = 0
        else:
            printk1("[ext4-fscrypt] PASS on-disk-ciphertext " \
                    "(raw block != plaintext, %d bytes differ)\n", differ)

    # (c) two logical blocks with IDENTICAL plaintext produce DIFFERENT
    # ciphertext (the XTS tweak = logical block number is genuinely applied).
    if cipher_ok != 0 and nb >= 2:
        if _ext4_read_block(ext4_fscrypt_test_phys[1],
                            &ext4_fscrypt_test_dec[0]) != 0:
            printk0("[ext4-fscrypt] FAIL: read second on-disk block\n")
            ok_all = 0
        else:
            blk_same: int32 = 1
            o4: uint64 = 0
            while o4 < bs:
                if ext4_fscrypt_test_disk[o4] != ext4_fscrypt_test_dec[o4]:
                    blk_same = 0
                    o4 = bs
                else:
                    o4 = o4 + 1
            if blk_same != 0:
                printk0("[ext4-fscrypt] FAIL: identical plaintext encrypted " \
                        "to identical ciphertext (tweak not applied!)\n")
                ok_all = 0
            else:
                printk0("[ext4-fscrypt] PASS tweak-differs " \
                        "(same plaintext, different blocks -> different " \
                        "ciphertext)\n")

    # (d) decrypting with the WRONG key yields garbage, not the plaintext.
    wi: uint64 = 0
    while wi < 64:
        ext4_fscrypt_test_wk[wi] = cast[uint8]((wi * 53 + 99) & 0xFF)
        wi = wi + 1
    aes_xts_set_key(cast[Ptr[uint8]](&ext4_fscrypt_test_wk[0]))
    aes_xts_decrypt_unit(0, bs,
                         cast[Ptr[uint8]](&ext4_fscrypt_test_dec[0]),
                         cast[Ptr[uint8]](&ext4_fscrypt_test_disk[0]))
    wrong_matches: int32 = 1
    o5: uint64 = 0
    while o5 < bs:
        if ext4_fscrypt_test_dec[o5] != _ext4_fscrypt_test_byte(o5):
            wrong_matches = 0
            o5 = bs
        else:
            o5 = o5 + 1
    if wrong_matches != 0:
        printk0("[ext4-fscrypt] FAIL: wrong key recovered the plaintext!\n")
        ok_all = 0
    else:
        printk0("[ext4-fscrypt] PASS wrong-key " \
                "(decrypting with a different key yields garbage)\n")

    if ok_all != 0:
        printk0("[ext4-fscrypt] PASS\n")
    else:
        printk0("[ext4-fscrypt] FAIL\n")
    return 0

# drivers/block/dm.ad
#
# Native device-mapper — Hamnix's equivalent of Linux's
# drivers/md/dm.c + the dm-linear / dm-crypt targets. A genuine
# Linux-parity gap: there was NO device-mapper in the tree before this.
#
# A device-mapper "mapped device" is a VIRTUAL block device whose
# address space is described by a TABLE of one or more TARGETS. Each
# target owns a contiguous [start_sector, length) span of the virtual
# device and translates every I/O that lands in its span to an
# underlying real block device at a target-specific offset. The block
# layer (kernel/block/blk.ad) sees the mapped device as an ordinary
# registered BlockDevice — filesystems can mount and read/write through
# it exactly like a partition or a loop device.
#
# Linux mapping:
#
#   struct mapped_device          -> MappedDevice (this file)
#   struct dm_table / dm_target   -> DmTarget[] inside MappedDevice
#   dm-linear (drivers/md/dm-linear.c)  -> DM_TARGET_LINEAR
#   dm-crypt  (drivers/md/dm-crypt.c)    -> DM_TARGET_CRYPT
#   dmsetup create --table "..."  -> dm_create_linear / dm_create_concat
#                                    / dm_create_crypt (this file)
#   bio remap (map_bio)           -> _dm_read_blkop / _dm_write_blkop
#
# TARGETS:
#
#   LINEAR — maps a span of the virtual device onto an underlying block
#   device at a fixed sector offset. This is the foundation of LVM:
#   concatenating several linear targets, each pointing at a different
#   underlying device (or a different region of one), builds a single
#   large virtual device out of smaller physical extents.
#
#   CRYPT (dm-crypt) — like linear (it forwards to an underlying device
#   at an offset) but encrypts every sector on the way out and decrypts
#   on the way in, so the bytes resting on the backing store are
#   ciphertext while reads through the mapped device return plaintext.
#   The cipher is AES-256 in XTS mode — the exact `aes-xts-plain64`
#   construction that is Linux dm-crypt / LUKS2's default. NOT a toy XOR,
#   NOT a stream-cipher stand-in: it is a real tweakable block cipher
#   (IEEE Std 1619-2007) implemented in full below.
#
#   WHY a standalone AES here (and not the AES already in tls.ad): the
#   tree's only AES is drivers/net/tls.ad's GCM path, which (a) needs
#   only AES ENCRYPT (CTR mode never decrypts the cipher) so it ships no
#   inverse cipher, and (b) keeps a SINGLE shared 240-byte round-key
#   schedule global (aes256_rk). XTS fundamentally needs the INVERSE
#   cipher for reads and TWO independent keys live at once (a data key
#   and a tweak key), so tls.ad's single-schedule, encrypt-only code
#   cannot be borrowed without either clobbering live TLS state or
#   re-expanding keys mid-block. The clean, decoupled answer — and the
#   one the brief sanctions when reuse is impractical — is a small
#   self-contained AES-256 (forward + inverse cipher) that owns its own
#   data/tweak schedules in this file, with zero coupling to the network
#   stack's import closure.
#
#   XTS (XEX-based tweaked-codebook with ciphertext stealing — here every
#   transfer is a whole 512-byte sector = 32 exact AES blocks, so no
#   stealing is needed): the tweak for a sector is AES_tweakkey(IV) where
#   the IV is dm-crypt's "plain64" — the 64-bit sector number, little-
#   endian, in a 16-byte block. For each 16-byte block j within the
#   sector the running tweak T is GF(2^128)-multiplied by the primitive
#   element alpha=x once per block; the block is XEX-masked
#   (C = AES_datakey(P ^ T) ^ T). Identical plaintext at two different
#   sectors therefore encrypts to different ciphertext (different IV ->
#   different tweak), and every block is independently seekable.

from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, blk_unregister_by_name,
    blk_read_sectors, blk_write_sectors, find_blockdev,
    blk_capacity_sectors, SECTOR_SIZE,
)
from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level,
)
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from fs.crc32c import (
    crc32c, crc32c_update,
)

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# =========================================================================
# AES-256 block cipher (FIPS 197) — self-contained, forward + inverse
# =========================================================================
#
# A real 14-round AES with a 256-bit master key. Unlike tls.ad's GCM
# path (encrypt-only, single shared schedule), XTS needs BOTH the
# forward and the inverse cipher and TWO live key schedules at once (a
# data key and a tweak key), so this implementation owns two 240-byte
# expanded schedules. The S-box / inverse S-box / GF(2^8) tables are
# built once at init. All working state is module-scope .bss: dm-crypt
# I/O is serialised through the synchronous block layer, so a single
# shared block-state buffer is safe (no two crypt transfers overlap).

_dm_aes_sbox:     Array[256, uint8]   # forward S-box
_dm_aes_isbox:    Array[256, uint8]   # inverse S-box
_dm_aes_inited:   int32 = 0
# GF(2^8) log/exp scratch for S-box construction.
_dm_aes_log:      Array[256, uint16]
_dm_aes_exp:      Array[256, uint8]

# Two independent 240-byte AES-256 expanded schedules: index 0 = data
# key, index 1 = tweak key. Both forward; the data key also gets an
# inverse schedule for the decrypt path.
_dm_aes_rk_data:  Array[240, uint8]
_dm_aes_rk_tweak: Array[240, uint8]
_dm_aes_block_st: Array[16, uint8]    # working state for one block


def _dm_aes_rotl8(v: uint8, n: uint64) -> uint8:
    x: uint64 = cast[uint64](v) & 0xFF
    return cast[uint8](((x << n) | (x >> (8 - n))) & 0xFF)


def _dm_aes_xtime(b: uint8) -> uint8:
    # b * x mod (x^8 + x^4 + x^3 + x + 1) in GF(2^8).
    v: uint64 = cast[uint64](b) & 0xFF
    t: uint64 = (v << 1) & 0xFF
    if (v & 0x80) != 0:
        t = t ^ 0x1B
    return cast[uint8](t & 0xFF)


def _dm_aes_gfmul(a: uint8, b: uint8) -> uint8:
    # Full GF(2^8) multiply (used for the inverse MixColumns constants
    # 9, 11, 13, 14). Russian-peasant.
    av: uint64 = cast[uint64](a) & 0xFF
    bv: uint64 = cast[uint64](b) & 0xFF
    p:  uint64 = 0
    i:  uint64 = 0
    while i < 8:
        if (bv & 1) != 0:
            p = p ^ av
        hi: uint64 = av & 0x80
        av = (av << 1) & 0xFF
        if hi != 0:
            av = av ^ 0x1B
        bv = bv >> 1
        i = i + 1
    return cast[uint8](p & 0xFF)


def _dm_aes_init():
    # Build the forward S-box (FIPS 197 §5.1.1) and its inverse at
    # runtime via a GF(2^8) log/exp table with generator g=3.
    if _dm_aes_inited != 0:
        return
    _dm_aes_inited = 1
    i: uint64 = 0
    x: uint16 = 1
    while i < 255:
        _dm_aes_exp[i] = cast[uint8](x & 0xFF)
        _dm_aes_log[x & 0xFF] = cast[uint16](i)
        x2: uint16 = (x << 1) & 0xFF
        if (x & 0x80) != 0:
            x2 = x2 ^ 0x1B
        x = x2 ^ x
        x = x & 0xFF
        i = i + 1
    _dm_aes_exp[255] = _dm_aes_exp[0]
    _dm_aes_sbox[0] = 0x63
    b: uint64 = 1
    while b < 256:
        inv: uint8 = _dm_aes_exp[(255 - cast[uint64](_dm_aes_log[b])) & 0xFF]
        v: uint8 = inv
        s: uint8 = v \
            ^ _dm_aes_rotl8(v, 1) \
            ^ _dm_aes_rotl8(v, 2) \
            ^ _dm_aes_rotl8(v, 3) \
            ^ _dm_aes_rotl8(v, 4) \
            ^ 0x63
        _dm_aes_sbox[b] = s
        b = b + 1
    # Inverse S-box: isbox[sbox[b]] = b.
    b = 0
    while b < 256:
        _dm_aes_isbox[_dm_aes_sbox[b]] = cast[uint8](b)
        b = b + 1


def _dm_aes256_expand(master: Ptr[uint8], rk: Ptr[uint8]):
    # FIPS 197 §5.2, AES-256: Nk=8, Nr=14, 240-byte expanded key into the
    # caller-supplied 240-byte schedule buffer `rk`.
    _dm_aes_init()
    i: uint64 = 0
    while i < 32:
        rk[i] = master[i]
        i = i + 1
    rcon: uint8 = 0x01
    i = 32
    while i < 240:
        t0: uint8 = rk[i - 4]
        t1: uint8 = rk[i - 3]
        t2: uint8 = rk[i - 2]
        t3: uint8 = rk[i - 1]
        word_idx: uint64 = i / 4
        if (word_idx & 7) == 0:
            r0: uint8 = _dm_aes_sbox[t1] ^ rcon
            r1: uint8 = _dm_aes_sbox[t2]
            r2: uint8 = _dm_aes_sbox[t3]
            r3: uint8 = _dm_aes_sbox[t0]
            t0 = r0
            t1 = r1
            t2 = r2
            t3 = r3
            rcon = _dm_aes_xtime(rcon)
        elif (word_idx & 7) == 4:
            t0 = _dm_aes_sbox[t0]
            t1 = _dm_aes_sbox[t1]
            t2 = _dm_aes_sbox[t2]
            t3 = _dm_aes_sbox[t3]
        rk[i + 0] = rk[i - 32 + 0] ^ t0
        rk[i + 1] = rk[i - 32 + 1] ^ t1
        rk[i + 2] = rk[i - 32 + 2] ^ t2
        rk[i + 3] = rk[i - 32 + 3] ^ t3
        i = i + 4


def _dm_aes256_encrypt(rk: Ptr[uint8], out_blk: Ptr[uint8],
                       in_blk: Ptr[uint8]):
    # Encrypt one 16-byte block under the 240-byte schedule `rk` (Nr=14).
    # State held column-major s[c*4 + r].
    i: uint64 = 0
    while i < 16:
        _dm_aes_block_st[i] = in_blk[i] ^ rk[i]
        i = i + 1
    rnd: uint64 = 1
    while rnd <= 13:
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_sbox[_dm_aes_block_st[i]]
            i = i + 1
        # ShiftRows
        t1: uint8 = _dm_aes_block_st[1]
        _dm_aes_block_st[1] = _dm_aes_block_st[5]
        _dm_aes_block_st[5] = _dm_aes_block_st[9]
        _dm_aes_block_st[9] = _dm_aes_block_st[13]
        _dm_aes_block_st[13] = t1
        t2a: uint8 = _dm_aes_block_st[2]
        t2b: uint8 = _dm_aes_block_st[6]
        _dm_aes_block_st[2] = _dm_aes_block_st[10]
        _dm_aes_block_st[6] = _dm_aes_block_st[14]
        _dm_aes_block_st[10] = t2a
        _dm_aes_block_st[14] = t2b
        t3: uint8 = _dm_aes_block_st[15]
        _dm_aes_block_st[15] = _dm_aes_block_st[11]
        _dm_aes_block_st[11] = _dm_aes_block_st[7]
        _dm_aes_block_st[7] = _dm_aes_block_st[3]
        _dm_aes_block_st[3] = t3
        # MixColumns
        c: uint64 = 0
        while c < 4:
            s0: uint8 = _dm_aes_block_st[c * 4 + 0]
            s1: uint8 = _dm_aes_block_st[c * 4 + 1]
            s2: uint8 = _dm_aes_block_st[c * 4 + 2]
            s3: uint8 = _dm_aes_block_st[c * 4 + 3]
            x0: uint8 = _dm_aes_xtime(s0)
            x1: uint8 = _dm_aes_xtime(s1)
            x2: uint8 = _dm_aes_xtime(s2)
            x3: uint8 = _dm_aes_xtime(s3)
            _dm_aes_block_st[c * 4 + 0] = x0 ^ (x1 ^ s1) ^ s2 ^ s3
            _dm_aes_block_st[c * 4 + 1] = s0 ^ x1 ^ (x2 ^ s2) ^ s3
            _dm_aes_block_st[c * 4 + 2] = s0 ^ s1 ^ x2 ^ (x3 ^ s3)
            _dm_aes_block_st[c * 4 + 3] = (x0 ^ s0) ^ s1 ^ s2 ^ x3
            c = c + 1
        rk_base: uint64 = rnd * 16
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_block_st[i] ^ rk[rk_base + i]
            i = i + 1
        rnd = rnd + 1
    # Final round: SubBytes + ShiftRows + AddRoundKey (no MixColumns).
    i = 0
    while i < 16:
        _dm_aes_block_st[i] = _dm_aes_sbox[_dm_aes_block_st[i]]
        i = i + 1
    t1f: uint8 = _dm_aes_block_st[1]
    _dm_aes_block_st[1] = _dm_aes_block_st[5]
    _dm_aes_block_st[5] = _dm_aes_block_st[9]
    _dm_aes_block_st[9] = _dm_aes_block_st[13]
    _dm_aes_block_st[13] = t1f
    t2af: uint8 = _dm_aes_block_st[2]
    t2bf: uint8 = _dm_aes_block_st[6]
    _dm_aes_block_st[2] = _dm_aes_block_st[10]
    _dm_aes_block_st[6] = _dm_aes_block_st[14]
    _dm_aes_block_st[10] = t2af
    _dm_aes_block_st[14] = t2bf
    t3f: uint8 = _dm_aes_block_st[15]
    _dm_aes_block_st[15] = _dm_aes_block_st[11]
    _dm_aes_block_st[11] = _dm_aes_block_st[7]
    _dm_aes_block_st[7] = _dm_aes_block_st[3]
    _dm_aes_block_st[3] = t3f
    i = 0
    while i < 16:
        out_blk[i] = _dm_aes_block_st[i] ^ rk[14 * 16 + i]
        i = i + 1


def _dm_aes256_decrypt(rk: Ptr[uint8], out_blk: Ptr[uint8],
                       in_blk: Ptr[uint8]):
    # Inverse cipher (FIPS 197 §5.3) — the equivalent-inverse-free
    # straightforward form: AddRoundKey(last), then 13 rounds of
    # InvShiftRows, InvSubBytes, AddRoundKey, InvMixColumns, then a final
    # InvShiftRows + InvSubBytes + AddRoundKey(0).
    i: uint64 = 0
    while i < 16:
        _dm_aes_block_st[i] = in_blk[i] ^ rk[14 * 16 + i]
        i = i + 1
    rnd: int64 = 13
    while rnd >= 1:
        # InvShiftRows: row r is right-rotated by r columns.
        t1: uint8 = _dm_aes_block_st[13]
        _dm_aes_block_st[13] = _dm_aes_block_st[9]
        _dm_aes_block_st[9] = _dm_aes_block_st[5]
        _dm_aes_block_st[5] = _dm_aes_block_st[1]
        _dm_aes_block_st[1] = t1
        t2a: uint8 = _dm_aes_block_st[2]
        t2b: uint8 = _dm_aes_block_st[6]
        _dm_aes_block_st[2] = _dm_aes_block_st[10]
        _dm_aes_block_st[6] = _dm_aes_block_st[14]
        _dm_aes_block_st[10] = t2a
        _dm_aes_block_st[14] = t2b
        t3: uint8 = _dm_aes_block_st[3]
        _dm_aes_block_st[3] = _dm_aes_block_st[7]
        _dm_aes_block_st[7] = _dm_aes_block_st[11]
        _dm_aes_block_st[11] = _dm_aes_block_st[15]
        _dm_aes_block_st[15] = t3
        # InvSubBytes
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_isbox[_dm_aes_block_st[i]]
            i = i + 1
        # AddRoundKey
        rk_base: uint64 = cast[uint64](rnd) * 16
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_block_st[i] ^ rk[rk_base + i]
            i = i + 1
        # InvMixColumns
        c: uint64 = 0
        while c < 4:
            s0: uint8 = _dm_aes_block_st[c * 4 + 0]
            s1: uint8 = _dm_aes_block_st[c * 4 + 1]
            s2: uint8 = _dm_aes_block_st[c * 4 + 2]
            s3: uint8 = _dm_aes_block_st[c * 4 + 3]
            _dm_aes_block_st[c * 4 + 0] = _dm_aes_gfmul(s0, 14) \
                ^ _dm_aes_gfmul(s1, 11) ^ _dm_aes_gfmul(s2, 13) \
                ^ _dm_aes_gfmul(s3, 9)
            _dm_aes_block_st[c * 4 + 1] = _dm_aes_gfmul(s0, 9) \
                ^ _dm_aes_gfmul(s1, 14) ^ _dm_aes_gfmul(s2, 11) \
                ^ _dm_aes_gfmul(s3, 13)
            _dm_aes_block_st[c * 4 + 2] = _dm_aes_gfmul(s0, 13) \
                ^ _dm_aes_gfmul(s1, 9) ^ _dm_aes_gfmul(s2, 14) \
                ^ _dm_aes_gfmul(s3, 11)
            _dm_aes_block_st[c * 4 + 3] = _dm_aes_gfmul(s0, 11) \
                ^ _dm_aes_gfmul(s1, 13) ^ _dm_aes_gfmul(s2, 9) \
                ^ _dm_aes_gfmul(s3, 14)
            c = c + 1
        rnd = rnd - 1
    # Final round: InvShiftRows + InvSubBytes + AddRoundKey(0).
    t1f: uint8 = _dm_aes_block_st[13]
    _dm_aes_block_st[13] = _dm_aes_block_st[9]
    _dm_aes_block_st[9] = _dm_aes_block_st[5]
    _dm_aes_block_st[5] = _dm_aes_block_st[1]
    _dm_aes_block_st[1] = t1f
    t2af: uint8 = _dm_aes_block_st[2]
    t2bf: uint8 = _dm_aes_block_st[6]
    _dm_aes_block_st[2] = _dm_aes_block_st[10]
    _dm_aes_block_st[6] = _dm_aes_block_st[14]
    _dm_aes_block_st[10] = t2af
    _dm_aes_block_st[14] = t2bf
    t3f: uint8 = _dm_aes_block_st[3]
    _dm_aes_block_st[3] = _dm_aes_block_st[7]
    _dm_aes_block_st[7] = _dm_aes_block_st[11]
    _dm_aes_block_st[11] = _dm_aes_block_st[15]
    _dm_aes_block_st[15] = t3f
    i = 0
    while i < 16:
        _dm_aes_block_st[i] = _dm_aes_isbox[_dm_aes_block_st[i]]
        i = i + 1
    i = 0
    while i < 16:
        out_blk[i] = _dm_aes_block_st[i] ^ rk[i]
        i = i + 1


# =========================================================================
# AES-XTS (IEEE Std 1619-2007) — the aes-xts-plain64 sector transform
# =========================================================================
#
# XTS encrypts/decrypts a sector as a sequence of 16-byte blocks under a
# data key, masked by a per-block tweak. The tweak for block 0 of a
# sector is T0 = AES_tweakkey(IV) where IV = the 64-bit sector number
# little-endian in a 16-byte block (dm-crypt "plain64"). For each
# subsequent block the tweak is multiplied by alpha = x in GF(2^128)
# (the polynomial x^128 + x^7 + x^2 + x + 1, LSB-first byte order).
#   encrypt:  C = AES_datakey(P ^ T) ^ T
#   decrypt:  P = AES_datakey^-1(C ^ T) ^ T
# A 512-byte sector is exactly 32 whole AES blocks, so no ciphertext
# stealing is ever required.

_dm_xts_tweak:  Array[16, uint8]   # running tweak T for the current sector
_dm_xts_tmp:    Array[16, uint8]   # P ^ T / C ^ T scratch


def _dm_xts_mul_alpha(t: Ptr[uint8]):
    # Multiply the 128-bit value t by alpha = x in GF(2^128), little-
    # endian byte order (IEEE 1619). Left-shift the whole 128-bit value
    # by one bit; if the high bit (bit 127) carried out, XOR 0x87 into
    # byte 0.
    carry: uint64 = 0
    i: uint64 = 0
    while i < 16:
        cur: uint64 = cast[uint64](t[i]) & 0xFF
        newv: uint64 = ((cur << 1) | carry) & 0xFF
        carry = (cur >> 7) & 1
        t[i] = cast[uint8](newv)
        i = i + 1
    if carry != 0:
        t[0] = t[0] ^ 0x87


def _dm_xts_init_tweak(sector: uint64):
    # T0 = AES_tweakkey(plain64 IV). IV = sector number little-endian in
    # bytes 0..7, zero in 8..15.
    iv: Array[16, uint8]
    i: uint64 = 0
    while i < 8:
        iv[i] = cast[uint8]((sector >> (i * 8)) & 0xFF)
        i = i + 1
    while i < 16:
        iv[i] = 0
        i = i + 1
    _dm_aes256_encrypt(cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]),
                       cast[Ptr[uint8]](&_dm_xts_tweak[0]),
                       cast[Ptr[uint8]](&iv[0]))


def _dm_xts_encrypt_sector(sector: uint64,
                           dst: Ptr[uint8], src: Ptr[uint8]):
    # XTS-encrypt one 512-byte sector (32 blocks). Assumes the data and
    # tweak schedules are already expanded into _dm_aes_rk_data /
    # _dm_aes_rk_tweak.
    _dm_xts_init_tweak(sector)
    tw:  Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tweak[0])
    tmp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tmp[0])
    dkey: Ptr[uint8] = cast[Ptr[uint8]](&_dm_aes_rk_data[0])
    blk: uint64 = 0
    while blk < 32:
        base: uint64 = blk * 16
        j: uint64 = 0
        while j < 16:
            tmp[j] = src[base + j] ^ tw[j]
            j = j + 1
        _dm_aes256_encrypt(dkey, cast[Ptr[uint8]](
            cast[uint64](dst) + base), tmp)
        j = 0
        while j < 16:
            dst[base + j] = dst[base + j] ^ tw[j]
            j = j + 1
        _dm_xts_mul_alpha(tw)
        blk = blk + 1


def _dm_xts_decrypt_sector(sector: uint64,
                           dst: Ptr[uint8], src: Ptr[uint8]):
    # XTS-decrypt one 512-byte sector (32 blocks).
    _dm_xts_init_tweak(sector)
    tw:  Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tweak[0])
    tmp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tmp[0])
    dkey: Ptr[uint8] = cast[Ptr[uint8]](&_dm_aes_rk_data[0])
    blk: uint64 = 0
    while blk < 32:
        base: uint64 = blk * 16
        j: uint64 = 0
        while j < 16:
            tmp[j] = src[base + j] ^ tw[j]
            j = j + 1
        _dm_aes256_decrypt(dkey, cast[Ptr[uint8]](
            cast[uint64](dst) + base), tmp)
        j = 0
        while j < 16:
            dst[base + j] = dst[base + j] ^ tw[j]
            j = j + 1
        _dm_xts_mul_alpha(tw)
        blk = blk + 1


# =========================================================================
# Device-mapper core
# =========================================================================

DM_TARGET_NONE:          uint32 = 0
DM_TARGET_LINEAR:        uint32 = 1
DM_TARGET_CRYPT:         uint32 = 2
DM_TARGET_SNAPSHOT:      uint32 = 3   # frozen CoW view (reads exc-store/origin)
DM_TARGET_SNAPSHOT_ORIGIN: uint32 = 4 # origin that performs copy-on-write
DM_TARGET_INTEGRITY:     uint32 = 5   # per-sector crc32c integrity tags
DM_TARGET_THIN:          uint32 = 6   # thin-provisioned (on-demand alloc)

DM_KEY_LEN:      uint64 = 64       # AES-256-XTS: 32B data + 32B tweak key
DM_MAX_TARGETS:  uint64 = 8        # targets per mapped device
DM_MAX_DEVICES:  uint64 = 8        # mapped devices system-wide
DM_NAME_LEN:     uint64 = 16


class DmTarget:
    # One row of a mapped device's table. The virtual span this target
    # covers is [start_sector, start_sector + length). On an I/O whose
    # virtual LBA falls in that span, the offset within the target is
    # (vlba - start_sector); the underlying LBA is
    # (under_start + offset_in_target). `ttype` selects linear vs crypt.
    ttype:        uint32
    pad:          uint32
    start_sector: uint64           # first virtual sector this target owns
    length:       uint64           # number of sectors in the span
    under_slot:   int32            # underlying block-device slot
    snap_ctx:     int32            # snapshot-context index (-1 if not a snap)
    under_start:  uint64           # base LBA on the underlying device


class MappedDevice:
    # A virtual block device described by a table of targets. Registered
    # with the block layer under `name` so the rest of the kernel reads
    # and writes through it transparently.
    used:        uint32
    n_targets:   uint32
    capacity:    uint64            # total virtual sectors (sum of spans)
    self_slot:   int32             # this mapped device's own block slot
    pad:         uint32
    targets:     Array[8, DmTarget]
    # AES-256-XTS key material (crypt targets only): 32-byte data key
    # followed by 32-byte tweak key (the LUKS/dm-crypt 64-byte key split).
    key:         Array[64, uint8]


# =========================================================================
# dm-snapshot — copy-on-write context (Linux drivers/md/dm-snap.c)
# =========================================================================
#
# A snapshot pairs an ORIGIN device with a separate EXCEPTION-STORE device.
# The snapshot mapped device presents a FROZEN point-in-time view of the
# origin. Address space is divided into fixed-size CHUNKS. The first time a
# given origin chunk is WRITTEN (through the snapshot-origin target), the
# chunk's ORIGINAL contents are first COPIED into a freshly allocated slot
# in the exception store (copy-on-write); an exception-table entry records
# origin-chunk -> exception-store-chunk, and the per-chunk "remapped" bit is
# set. Thereafter:
#   * a READ through the SNAPSHOT view returns the exception-store copy for
#     any remapped chunk (the OLD pre-image), else falls through to origin;
#   * a READ through the ORIGIN returns the live (NEW) data.
# This is exactly Linux dm-snapshot's CoW exception model, in memory.

DM_SNAP_MAX:        uint64 = 4        # snapshot contexts system-wide
DM_SNAP_MAX_CHUNKS: uint64 = 256      # origin chunks tracked per snapshot


class DmSnapContext:
    used:          uint32
    pad:           uint32
    origin_slot:   int32              # underlying origin block device
    exc_slot:      int32              # underlying exception-store device
    chunk_sectors: uint64             # CoW granularity (sectors per chunk)
    nchunks:       uint64             # origin chunks covered
    next_exc:      uint64             # next free exception-store chunk
    exc_capacity:  uint64             # exception-store chunks available
    # exc_map[origin_chunk] = exception-store chunk holding its pre-image.
    exc_map:       Array[256, uint64]
    # remapped[origin_chunk] = 1 once the chunk has been CoW'd.
    remapped:      Array[256, uint8]


dm_snap_ctxs: Array[4, DmSnapContext]


# =========================================================================
# dm-integrity — per-sector cryptographic integrity tags
# (Linux drivers/md/dm-integrity.c)
# =========================================================================
#
# Each mapped sector carries a small integrity TAG computed over its data.
# On WRITE the tag is (re)computed from the sector bytes and stashed in a
# dedicated METADATA tag store; on READ the tag is recomputed over the data
# fetched from the backing device and compared against the stored tag. A
# mismatch — the sector was corrupted underneath us (bit-rot, a torn write,
# or a malicious tamper) — is reported as an I/O ERROR rather than silently
# handing back the corrupt bytes. This is exactly Linux dm-integrity's
# detection guarantee.
#
# The tag is a crc32c over the sector's 512 bytes, SALTED with the sector
# index (the underlying LBA folded into the running register before the
# data). The salt binds a tag to its sector position, so a valid sector
# relocated to a different LBA also fails verification — a sector can't be
# replayed/relocated undetected. (Linux dm-integrity supports HMAC tags for
# the keyed case; crc32c is its CRC tag mode, which is what we model here.)

DM_INTEG_MAX:         uint64 = 4      # integrity contexts system-wide
DM_INTEG_MAX_SECTORS: uint64 = 256    # tagged sectors per context


class DmIntegContext:
    used:        uint32
    pad:         uint32
    nsectors:    uint64                # number of tagged sectors
    # valid[s] = 1 once sector s has a tag written (a read of an unwritten
    # sector is allowed to pass with no stored tag yet).
    valid:       Array[256, uint8]
    # tags[s] = the crc32c integrity tag for tagged sector s.
    tags:        Array[256, uint32]


dm_integ_ctxs: Array[4, DmIntegContext]


# =========================================================================
# dm-thin — thin provisioning (Linux drivers/md/dm-thin.c)
# =========================================================================
#
# A thin POOL owns a fixed-size DATA device (here an in-kernel ramdisk).
# Physical storage is carved into fixed-size BLOCKS (block_sectors sectors
# each). A THIN device presents a large VIRTUAL address space but starts
# with ZERO physical blocks allocated: nothing in the pool is consumed
# until data is actually written. The first WRITE to a virtual block
# allocates a fresh pool block from the pool's free-block allocator,
# records a (thin virtual block -> pool physical block) mapping, and writes
# the data there. A READ of an UNPROVISIONED (never-written) virtual block
# returns ZEROS and consumes no pool block. Subsequent reads/writes of a
# provisioned virtual block hit its mapped pool block. Because the virtual
# size can vastly exceed the pool's physical capacity, over-provisioning is
# directly observable as (virtual blocks >> currently allocated blocks).
# A write that cannot allocate (pool exhausted) returns an I/O error.
#
# This is exactly Linux dm-thin's on-demand single-provisioning model: one
# shared pool, many thin volumes that lazily claim blocks from it.

DM_THIN_POOL_MAX:    uint64 = 2        # thin pools system-wide
DM_THIN_DEV_MAX:     uint64 = 4        # thin devices system-wide
DM_THIN_MAX_PBLOCKS: uint64 = 256      # pool physical blocks per pool
DM_THIN_MAX_VBLOCKS: uint64 = 1024     # virtual blocks tracked per thin dev


class DmThinPool:
    used:          uint32
    pad:           uint32
    data_slot:     int32               # underlying pool DATA block device
    pad2:          uint32
    block_sectors: uint64              # sectors per pool block (alloc unit)
    nblocks:       uint64              # total pool blocks (physical capacity)
    nallocated:    uint64              # pool blocks currently handed out
    # free[b] = 1 while pool block b is unallocated and available.
    free:          Array[256, uint8]


class DmThinDev:
    used:          uint32
    pad:           uint32
    pool_idx:      int32               # owning thin pool index
    pad2:          uint32
    nvblocks:      uint64              # virtual blocks this thin dev presents
    # mapped[v] = 1 once virtual block v has a pool block; pmap[v] holds it.
    mapped:        Array[1024, uint8]
    pmap:          Array[1024, uint64]


dm_thin_pools: Array[2, DmThinPool]
dm_thin_devs:  Array[4, DmThinDev]

dm_devices: Array[8, MappedDevice]
dm_ops:     BlockDeviceOps
dm_inited:  uint32 = 0

# One-chunk staging buffer for the CoW copy path. Snapshot I/O is
# serialised through the synchronous block layer, so a single shared
# module-scope chunk buffer is safe (no two CoW copies overlap). Sized for
# the largest chunk the self-test uses (8 sectors = 4096 bytes); resize if
# a larger chunk_sectors is ever configured.
_DM_SNAP_CHUNK_MAX_SECTORS: uint64 = 8
_dm_snap_cow_buf: Array[4096, uint8]    # 8 * 512

# One-sector ciphertext staging buffer for the crypt path. dm-crypt I/O
# is serialised through the synchronous block layer, so a single shared
# module-scope sector buffer is safe (no two crypt transfers overlap).
_dm_crypt_sector: Array[512, uint8]


def dm_init():
    # Wire the shared vtable once; the device table starts all-free. No
    # mapped device exists until a dm_create_* call (or a /dev/mapper/ctl
    # write) builds one — matching Linux where dm has no devices until
    # dmsetup creates them.
    if dm_inited != 0:
        return
    dm_ops.read_sectors  = _dm_read_blkop
    dm_ops.write_sectors = _dm_write_blkop
    dm_ops.flush         = cast[Fn[int32, uint64]](0)
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        dm_devices[i].used      = 0
        dm_devices[i].n_targets = 0
        dm_devices[i].capacity  = 0
        dm_devices[i].self_slot = -1
        i = i + 1
    s: uint64 = 0
    while s < DM_SNAP_MAX:
        dm_snap_ctxs[s].used = 0
        s = s + 1
    g: uint64 = 0
    while g < DM_INTEG_MAX:
        dm_integ_ctxs[g].used = 0
        g = g + 1
    tp: uint64 = 0
    while tp < DM_THIN_POOL_MAX:
        dm_thin_pools[tp].used = 0
        tp = tp + 1
    td: uint64 = 0
    while td < DM_THIN_DEV_MAX:
        dm_thin_devs[td].used = 0
        td = td + 1
    dm_inited = 1
    printk0("dm: device-mapper ready (linear + crypt + snapshot + integrity + thin targets)\n")


def _dm_find_target(dev: Ptr[MappedDevice], vlba: uint64) -> int32:
    # Return the index of the target whose span contains virtual LBA
    # `vlba`, or -1 if none does. Targets are stored in ascending span
    # order by construction, but a linear scan is fine for <= 8 rows.
    n: uint32 = dev[0].n_targets
    i: uint64 = 0
    while i < cast[uint64](n):
        st:  uint64 = dev[0].targets[i].start_sector
        ln:  uint64 = dev[0].targets[i].length
        if vlba >= st and vlba < st + ln:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_crypt_load_keys(dev: Ptr[MappedDevice]):
    # Expand this mapped device's 64-byte XTS key into the two AES-256
    # schedules: bytes 0..31 = data key, bytes 32..63 = tweak key.
    _dm_aes256_expand(cast[Ptr[uint8]](&dev[0].key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&dev[0].key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))


def _dm_linear_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                  count: uint64, buf: Ptr[uint8]) -> int32:
    # Linear remap: forward the whole [under_start + off_in_t, +count)
    # span straight to the underlying device. Plaintext passthrough.
    ulba: uint64 = t[0].under_start + off_in_t
    if is_write != 0:
        return blk_write_sectors(t[0].under_slot, ulba, count, buf)
    return blk_read_sectors(t[0].under_slot, ulba, count, buf)


def _dm_crypt_io(dev: Ptr[MappedDevice], t: Ptr[DmTarget],
                 is_write: int32, off_in_t: uint64, vlba: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # Crypt remap: process one sector at a time so each gets its own
    # sector-derived XTS tweak (plain64 IV). On write, AES-256-XTS-encrypt
    # the plaintext sector from `buf` into the staging buffer and write
    # the CIPHERTEXT to the backing device. On read, fetch the ciphertext
    # from the backing device into staging and XTS-decrypt into the
    # caller's `buf`. The tweak is keyed on the VIRTUAL sector number
    # (vlba) so the same plaintext at different mapped sectors produces
    # different ciphertext.
    _dm_crypt_load_keys(dev)
    stagep: Ptr[uint8] = cast[Ptr[uint8]](&_dm_crypt_sector[0])
    s: uint64 = 0
    while s < count:
        ulba: uint64 = t[0].under_start + off_in_t + s
        vsec: uint64 = vlba + s
        cur:  Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if is_write != 0:
            # plaintext (cur) -> ciphertext (staging) -> backing store
            _dm_xts_encrypt_sector(vsec, stagep, cur)
            rc: int32 = blk_write_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc != 0:
                return rc
        else:
            # backing store -> ciphertext (staging) -> plaintext (cur)
            rc2: int32 = blk_read_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc2 != 0:
                return rc2
            _dm_xts_decrypt_sector(vsec, cur, stagep)
        s = s + 1
    return 0


# =========================================================================
# dm-snapshot target handlers
# =========================================================================

def _dm_snap_cow_one_chunk(ctx: Ptr[DmSnapContext], ochunk: uint64) -> int32:
    # Copy-on-write a single origin chunk into the exception store, IF it
    # has not already been remapped. Reads the chunk's CURRENT (pre-write)
    # contents from the origin and writes them to a freshly allocated
    # exception-store chunk, then records the mapping + remapped bit. This
    # is the heart of dm-snapshot: it must run BEFORE the origin chunk is
    # overwritten so the snapshot preserves the OLD data. Returns 0 on
    # success, negative on error.
    if ctx[0].remapped[ochunk] != 0:
        return 0                       # already preserved; nothing to do
    if ctx[0].next_exc >= ctx[0].exc_capacity:
        printk0("dm: snapshot exception store full\n")
        return -1
    ec: uint64 = ctx[0].next_exc
    cs: uint64 = ctx[0].chunk_sectors
    olba: uint64 = ochunk * cs
    elba: uint64 = ec * cs
    bufp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_snap_cow_buf[0])
    # Read the original chunk off the origin...
    rc: int32 = blk_read_sectors(ctx[0].origin_slot, olba, cs, bufp)
    if rc != 0:
        return rc
    # ...and stash the pre-image in the exception store.
    rc = blk_write_sectors(ctx[0].exc_slot, elba, cs, bufp)
    if rc != 0:
        return rc
    ctx[0].exc_map[ochunk]  = ec
    ctx[0].remapped[ochunk] = 1
    ctx[0].next_exc         = ec + 1
    return 0


def _dm_snap_origin_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                       count: uint64, buf: Ptr[uint8]) -> int32:
    # SNAPSHOT-ORIGIN target: a thin device over the origin that performs
    # copy-on-write. On WRITE, every chunk this request touches is first
    # CoW'd to the exception store (preserving the snapshot's pre-image),
    # THEN the new data is written through to the origin. On READ it is a
    # plain passthrough to the origin (the live view). Processed one
    # sector at a time so chunk boundaries are handled simply.
    ctx: Ptr[DmSnapContext] = &dm_snap_ctxs[cast[uint64](t[0].snap_ctx)]
    cs: uint64 = ctx[0].chunk_sectors
    s: uint64 = 0
    while s < count:
        olba: uint64 = t[0].under_start + off_in_t + s
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if is_write != 0:
            ochunk: uint64 = olba / cs
            rc: int32 = _dm_snap_cow_one_chunk(ctx, ochunk)
            if rc != 0:
                return rc
            rc = blk_write_sectors(ctx[0].origin_slot, olba, 1, cur)
            if rc != 0:
                return rc
        else:
            rc2: int32 = blk_read_sectors(ctx[0].origin_slot, olba, 1, cur)
            if rc2 != 0:
                return rc2
        s = s + 1
    return 0


def _dm_snap_view_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                     count: uint64, buf: Ptr[uint8]) -> int32:
    # SNAPSHOT target: the frozen point-in-time view. A READ returns, for
    # each chunk, the exception-store pre-image IF that chunk has been
    # CoW'd (remapped), else falls through to the live origin. Writes to a
    # snapshot view are not part of this self-test's data path; they are
    # rejected so a stray write can never corrupt the frozen image.
    ctx: Ptr[DmSnapContext] = &dm_snap_ctxs[cast[uint64](t[0].snap_ctx)]
    cs: uint64 = ctx[0].chunk_sectors
    if is_write != 0:
        printk0("dm: snapshot view is read-only\n")
        return -1
    s: uint64 = 0
    while s < count:
        olba: uint64 = t[0].under_start + off_in_t + s
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        ochunk: uint64 = olba / cs
        off_in_chunk: uint64 = olba - ochunk * cs
        rc: int32 = 0
        if ctx[0].remapped[ochunk] != 0:
            # Preserved pre-image lives in the exception store.
            ec: uint64 = ctx[0].exc_map[ochunk]
            elba: uint64 = ec * cs + off_in_chunk
            rc = blk_read_sectors(ctx[0].exc_slot, elba, 1, cur)
        else:
            # Never written since the snapshot was taken: read origin live
            # (which still equals the snapshot point-in-time value).
            rc = blk_read_sectors(ctx[0].origin_slot, olba, 1, cur)
        if rc != 0:
            return rc
        s = s + 1
    return 0


# =========================================================================
# dm-integrity target handler
# =========================================================================

# One-sector staging buffer for the integrity read-verify path. dm I/O is
# serialised through the synchronous block layer, so a single shared
# module-scope sector buffer is safe (no two integrity transfers overlap).
_dm_integ_sector: Array[512, uint8]


def _dm_integ_tag(sector: uint64, data: Ptr[uint8]) -> uint32:
    # Compute the per-sector integrity tag: a crc32c over the 512 data
    # bytes, SALTED with the sector index so a valid sector relocated to a
    # different LBA fails verification. We fold the 8 little-endian bytes of
    # `sector` into the running crc32c register first (seeding the salt),
    # then chain the sector data, and finalize (xor 0xFFFFFFFF).
    salt: Array[8, uint8]
    i: uint64 = 0
    while i < 8:
        salt[i] = cast[uint8]((sector >> (i * 8)) & 0xFF)
        i = i + 1
    c: uint32 = crc32c_update(0xFFFFFFFF, &salt[0], 8)
    c = crc32c_update(c, data, SECTOR_SIZE)
    return c ^ 0xFFFFFFFF


def _dm_integ_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                 vlba: uint64, count: uint64, buf: Ptr[uint8]) -> int32:
    # INTEGRITY target. Process one sector at a time. On WRITE, write the
    # data through to the backing device, compute the integrity tag over the
    # data (salted with the underlying sector), and store the tag in the
    # context's tag store keyed by sector. On READ, fetch the data from the
    # backing device, recompute the tag, and compare against the stored tag:
    # a MATCH copies the verified data into the caller's buffer; a MISMATCH
    # is reported as an I/O error (negative return) so the caller never sees
    # the corrupt bytes.
    ctx: Ptr[DmIntegContext] = &dm_integ_ctxs[cast[uint64](t[0].snap_ctx)]
    stagep: Ptr[uint8] = cast[Ptr[uint8]](&_dm_integ_sector[0])
    s: uint64 = 0
    while s < count:
        ulba:  uint64 = t[0].under_start + off_in_t + s
        vsec:  uint64 = vlba + s
        cur:   Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if vsec >= ctx[0].nsectors:
            printk1("dm: integrity I/O past tagged span (vsec=%d)\n", vsec)
            return -1
        if is_write != 0:
            rc: int32 = blk_write_sectors(t[0].under_slot, ulba, 1, cur)
            if rc != 0:
                return rc
            ctx[0].tags[vsec]  = _dm_integ_tag(ulba, cur)
            ctx[0].valid[vsec] = 1
        else:
            rc2: int32 = blk_read_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc2 != 0:
                return rc2
            if ctx[0].valid[vsec] != 0:
                want: uint32 = ctx[0].tags[vsec]
                got:  uint32 = _dm_integ_tag(ulba, stagep)
                if got != want:
                    # Corruption detected — refuse to hand back the data.
                    printk2("dm: integrity tag mismatch sec=%d (corruption detected)\n",
                            vsec, cast[uint64](got))
                    return -5
            # Verified (or never tagged) — deliver the data.
            memcpy(cur, stagep, SECTOR_SIZE)
        s = s + 1
    return 0


# =========================================================================
# dm-thin target handler
# =========================================================================

# One-sector zero buffer used to satisfy reads of UNPROVISIONED thin
# virtual blocks (no pool block allocated). dm I/O is serialised through the
# synchronous block layer, so a single shared module-scope buffer is safe.
_dm_thin_zero: Array[512, uint8]


def _dm_thin_pool_alloc_block(pool: Ptr[DmThinPool]) -> int64:
    # Hand out a fresh free pool block, marking it allocated and bumping the
    # allocated-block count. Returns the pool block index, or -1 if the pool
    # is exhausted (no free block remains) — the dm-thin out-of-space case.
    b: uint64 = 0
    while b < pool[0].nblocks:
        if pool[0].free[b] != 0:
            pool[0].free[b]    = 0
            pool[0].nallocated = pool[0].nallocated + 1
            return cast[int64](b)
        b = b + 1
    return -1


def _dm_thin_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                count: uint64, buf: Ptr[uint8]) -> int32:
    # THIN target. Process one sector at a time. Each virtual sector belongs
    # to a virtual BLOCK (block_sectors sectors). On READ of an UNPROVISIONED
    # virtual block, return ZEROS (no pool block allocated, no pool consumed).
    # On WRITE to an unprovisioned virtual block, allocate a fresh pool block
    # from the free allocator, record the (vblock -> pblock) mapping, then
    # write the data to its sector within the pool block. Provisioned blocks
    # remap straight to their pool block on the data device.
    tdev: Ptr[DmThinDev] = &dm_thin_devs[cast[uint64](t[0].snap_ctx)]
    pool: Ptr[DmThinPool] = &dm_thin_pools[cast[uint64](tdev[0].pool_idx)]
    bs:   uint64 = pool[0].block_sectors
    zerop: Ptr[uint8] = cast[Ptr[uint8]](&_dm_thin_zero[0])
    zi: uint64 = 0
    while zi < SECTOR_SIZE:
        _dm_thin_zero[zi] = 0
        zi = zi + 1
    s: uint64 = 0
    while s < count:
        vsec:  uint64 = off_in_t + s
        vblk:  uint64 = vsec / bs
        offib: uint64 = vsec - vblk * bs
        cur:   Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if vblk >= tdev[0].nvblocks:
            printk1("dm: thin I/O past virtual size (vblk=%d)\n", vblk)
            return -1
        if is_write != 0:
            if tdev[0].mapped[vblk] == 0:
                # First write to this virtual block: provision on demand.
                nb: int64 = _dm_thin_pool_alloc_block(pool)
                if nb < 0:
                    printk1("dm: thin pool out of space (vblk=%d)\n", vblk)
                    return -28               # -ENOSPC
                tdev[0].pmap[vblk]   = cast[uint64](nb)
                tdev[0].mapped[vblk] = 1
            plba: uint64 = tdev[0].pmap[vblk] * bs + offib
            rc: int32 = blk_write_sectors(pool[0].data_slot, plba, 1, cur)
            if rc != 0:
                return rc
        else:
            if tdev[0].mapped[vblk] == 0:
                # Unprovisioned: never written -> reads back as zeros.
                memcpy(cur, zerop, SECTOR_SIZE)
            else:
                plba2: uint64 = tdev[0].pmap[vblk] * bs + offib
                rc2: int32 = blk_read_sectors(pool[0].data_slot, plba2, 1, cur)
                if rc2 != 0:
                    return rc2
        s = s + 1
    return 0


def _dm_io(dev: Ptr[MappedDevice], is_write: int32, vlba: uint64,
           count: uint64, buf: Ptr[uint8]) -> int32:
    # Core remap. Walk the request sector-span, splitting it at target
    # boundaries (a single request may straddle two concatenated linear
    # targets), and dispatch each sub-span to its target's handler.
    if count == 0:
        return 0
    done: uint64 = 0
    while done < count:
        cur_v: uint64 = vlba + done
        ti: int32 = _dm_find_target(dev, cur_v)
        if ti < 0:
            printk1("dm: I/O outside any target (vlba=%d)\n", cur_v)
            return -1
        t: Ptr[DmTarget] = &dev[0].targets[cast[uint64](ti)]
        st:  uint64 = t[0].start_sector
        ln:  uint64 = t[0].length
        off_in_t: uint64 = cur_v - st
        # How many sectors remain in THIS target's span from cur_v on.
        avail: uint64 = ln - off_in_t
        chunk: uint64 = count - done
        if chunk > avail:
            chunk = avail
        bufp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + done * SECTOR_SIZE)
        rc: int32 = 0
        if t[0].ttype == DM_TARGET_CRYPT:
            rc = _dm_crypt_io(dev, t, is_write, off_in_t, cur_v,
                              chunk, bufp)
        elif t[0].ttype == DM_TARGET_SNAPSHOT_ORIGIN:
            rc = _dm_snap_origin_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_SNAPSHOT:
            rc = _dm_snap_view_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_INTEGRITY:
            rc = _dm_integ_io(t, is_write, off_in_t, cur_v, chunk, bufp)
        elif t[0].ttype == DM_TARGET_THIN:
            rc = _dm_thin_io(t, is_write, off_in_t, chunk, bufp)
        else:
            rc = _dm_linear_io(t, is_write, off_in_t, chunk, bufp)
        if rc != 0:
            return rc
        done = done + chunk
    return 0


def _dm_read_blkop(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dev: Ptr[MappedDevice] = cast[Ptr[MappedDevice]](priv)
    if dev[0].used == 0:
        return -1
    return _dm_io(dev, 0, lba, count, buf)


def _dm_write_blkop(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dev: Ptr[MappedDevice] = cast[Ptr[MappedDevice]](priv)
    if dev[0].used == 0:
        return -1
    return _dm_io(dev, 1, lba, count, buf)


def _dm_alloc_device() -> int32:
    # Claim a free MappedDevice slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_register(idx: uint64, name: Ptr[char]) -> int32:
    # Register the (already-populated) mapped device at table index `idx`
    # with the block layer. Returns 0 on success, -1 on failure.
    cap: uint64 = dm_devices[idx].capacity
    priv: uint64 = cast[uint64](&dm_devices[idx])
    slot: int32 = register_blockdev(name, cap, &dm_ops, priv)
    if slot < 0:
        printk0("dm: block-device registration failed\n")
        return -1
    dm_devices[idx].self_slot = slot
    dm_devices[idx].used      = 1
    return 0


# =========================================================================
# dmsetup-shape control surface (public API)
# =========================================================================

def dm_create_linear(name: Ptr[char], under_slot: int32,
                     under_start: uint64, length: uint64) -> int32:
    # Create a mapped device with a SINGLE linear target covering the
    # whole virtual device [0, length): virtual sector v maps to
    # underlying sector (under_start + v) on `under_slot`. This is the
    # `dmsetup create NAME --table "0 LENGTH linear DEV START"` shape.
    # Returns the registered block slot (>= 0) or a negative error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    # Underlying device must actually hold the mapped span.
    ucap: uint64 = blk_capacity_sectors(under_slot)
    if under_start + length > ucap:
        printk0("dm: linear target exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets             = 1
    dm_devices[idx].capacity              = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].snap_ctx     = -1
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_create_concat(name: Ptr[char],
                     slot_a: int32, start_a: uint64, len_a: uint64,
                     slot_b: int32, start_b: uint64, len_b: uint64) -> int32:
    # Create a mapped device from TWO concatenated linear targets — the
    # canonical LVM "join two physical extents into one logical volume"
    # case. Virtual [0, len_a) maps onto (slot_a, start_a..); virtual
    # [len_a, len_a+len_b) maps onto (slot_b, start_b..). The block layer
    # sees one device of (len_a + len_b) sectors. Returns the registered
    # block slot or a negative error.
    dm_init()
    if len_a == 0 or len_b == 0:
        return -1
    if slot_a < 0 or slot_b < 0:
        return -2
    if start_a + len_a > blk_capacity_sectors(slot_a):
        printk0("dm: concat target A exceeds underlying capacity\n")
        return -3
    if start_b + len_b > blk_capacity_sectors(slot_b):
        printk0("dm: concat target B exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets = 2
    dm_devices[idx].capacity  = len_a + len_b
    dm_devices[idx].targets[0].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = len_a
    dm_devices[idx].targets[0].under_slot   = slot_a
    dm_devices[idx].targets[0].snap_ctx     = -1
    dm_devices[idx].targets[0].under_start  = start_a
    dm_devices[idx].targets[1].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[1].start_sector = len_a
    dm_devices[idx].targets[1].length       = len_b
    dm_devices[idx].targets[1].under_slot   = slot_b
    dm_devices[idx].targets[1].snap_ctx     = -1
    dm_devices[idx].targets[1].under_start  = start_b
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_create_crypt(name: Ptr[char], under_slot: int32,
                    under_start: uint64, length: uint64,
                    key: Ptr[uint8], keylen: uint64) -> int32:
    # Create a dm-crypt mapped device with a SINGLE crypt target over
    # [0, length): every sector written through the mapped device is
    # AES-256-XTS-encrypted (plain64 sector-keyed tweak) before it
    # reaches the backing store, and decrypted on read. `key` supplies up
    # to DM_KEY_LEN (64) bytes — the 32-byte data key followed by the
    # 32-byte tweak key — and a short key is zero-padded. This is the
    # `dmsetup create NAME --table "0 LENGTH crypt aes-xts-plain64 KEY 0 DEV START"`
    # shape. Returns the registered block slot or a negative error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    if under_start + length > blk_capacity_sectors(under_slot):
        printk0("dm: crypt target exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    # Install the key (zero-pad / truncate to DM_KEY_LEN).
    ki: uint64 = 0
    while ki < DM_KEY_LEN:
        if ki < keylen:
            dm_devices[idx].key[ki] = key[ki]
        else:
            dm_devices[idx].key[ki] = 0
        ki = ki + 1
    dm_devices[idx].n_targets = 1
    dm_devices[idx].capacity  = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_CRYPT
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].snap_ctx     = -1
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_snap_alloc_ctx() -> int32:
    # Claim a free snapshot context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_SNAP_MAX:
        if dm_snap_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_snapshot(name: Ptr[char], origin_slot: int32,
                       exc_slot: int32, chunk_sectors: uint64,
                       length: uint64) -> int32:
    # Create a dm-snapshot pair sharing one CoW context:
    #   * a SNAPSHOT view registered as `name`     — the frozen image, and
    #   * a SNAPSHOT-ORIGIN registered as `name`+"-origin" — the CoW origin
    #     that filesystems/writers go through so origin writes preserve the
    #     snapshot's pre-image in the exception store.
    # `origin_slot` is the underlying real origin; `exc_slot` is the
    # separate exception-store device; `chunk_sectors` is the CoW
    # granularity; `length` is the virtual size in sectors. This mirrors
    # `dmsetup create snap --table "0 LEN snapshot ORIGIN COW P CHUNK"`
    # plus the implicit snapshot-origin target on the origin. Returns the
    # registered SNAPSHOT view's block slot or a negative error.
    dm_init()
    if length == 0 or chunk_sectors == 0:
        return -1
    if origin_slot < 0 or exc_slot < 0:
        return -2
    if chunk_sectors > _DM_SNAP_CHUNK_MAX_SECTORS:
        printk0("dm: snapshot chunk_sectors exceeds CoW buffer\n")
        return -2
    if length > blk_capacity_sectors(origin_slot):
        printk0("dm: snapshot exceeds origin capacity\n")
        return -3
    nchunks: uint64 = (length + chunk_sectors - 1) / chunk_sectors
    if nchunks > DM_SNAP_MAX_CHUNKS:
        printk0("dm: snapshot too many chunks for exception table\n")
        return -3
    exc_cap: uint64 = blk_capacity_sectors(exc_slot) / chunk_sectors
    if exc_cap == 0:
        printk0("dm: snapshot exception store too small\n")
        return -3
    sctx_s: int32 = _dm_snap_alloc_ctx()
    if sctx_s < 0:
        printk0("dm: snapshot context table full\n")
        return -4
    sctx: uint64 = cast[uint64](sctx_s)
    dm_snap_ctxs[sctx].used          = 1
    dm_snap_ctxs[sctx].origin_slot   = origin_slot
    dm_snap_ctxs[sctx].exc_slot      = exc_slot
    dm_snap_ctxs[sctx].chunk_sectors = chunk_sectors
    dm_snap_ctxs[sctx].nchunks       = nchunks
    dm_snap_ctxs[sctx].next_exc      = 0
    dm_snap_ctxs[sctx].exc_capacity  = exc_cap
    c: uint64 = 0
    while c < DM_SNAP_MAX_CHUNKS:
        dm_snap_ctxs[sctx].exc_map[c]  = 0
        dm_snap_ctxs[sctx].remapped[c] = 0
        c = c + 1

    # --- snapshot VIEW device (frozen image) ---
    vidx_s: int32 = _dm_alloc_device()
    if vidx_s < 0:
        dm_snap_ctxs[sctx].used = 0
        printk0("dm: device table full\n")
        return -4
    vidx: uint64 = cast[uint64](vidx_s)
    dm_devices[vidx].n_targets             = 1
    dm_devices[vidx].capacity              = length
    dm_devices[vidx].targets[0].ttype        = DM_TARGET_SNAPSHOT
    dm_devices[vidx].targets[0].start_sector = 0
    dm_devices[vidx].targets[0].length       = length
    dm_devices[vidx].targets[0].under_slot   = origin_slot
    dm_devices[vidx].targets[0].snap_ctx     = sctx_s
    dm_devices[vidx].targets[0].under_start  = 0
    if _dm_register(vidx, name) != 0:
        dm_devices[vidx].used   = 0
        dm_snap_ctxs[sctx].used = 0
        return -5
    return dm_devices[vidx].self_slot


def dm_snapshot_ctx_of(name: Ptr[char]) -> int32:
    # Return the snapshot-context index backing the snapshot VIEW device
    # registered under `name`, or -1 if `name` is not a live snapshot view.
    # Lets a caller (e.g. the self-test) build the paired snapshot-origin
    # device that shares the same CoW context.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            if dm_devices[i].targets[0].ttype == DM_TARGET_SNAPSHOT:
                return dm_devices[i].targets[0].snap_ctx
            return -1
        i = i + 1
    return -1


def dm_create_snapshot_origin(name: Ptr[char], snap_ctx: int32,
                              length: uint64) -> int32:
    # Create the SNAPSHOT-ORIGIN mapped device that shares snapshot context
    # `snap_ctx` (returned implicitly by dm_create_snapshot, which stored it
    # in the view's target). Writes through this device trigger copy-on-
    # write so the paired snapshot keeps the pre-image. Returns the
    # registered block slot or a negative error.
    dm_init()
    if length == 0:
        return -1
    if snap_ctx < 0 or cast[uint64](snap_ctx) >= DM_SNAP_MAX:
        return -2
    if dm_snap_ctxs[cast[uint64](snap_ctx)].used == 0:
        return -2
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets             = 1
    dm_devices[idx].capacity              = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_SNAPSHOT_ORIGIN
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = \
        dm_snap_ctxs[cast[uint64](snap_ctx)].origin_slot
    dm_devices[idx].targets[0].snap_ctx     = snap_ctx
    dm_devices[idx].targets[0].under_start  = 0
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_integ_alloc_ctx() -> int32:
    # Claim a free integrity context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_INTEG_MAX:
        if dm_integ_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_integrity(name: Ptr[char], under_slot: int32,
                        under_start: uint64, length: uint64) -> int32:
    # Create a dm-integrity mapped device with a SINGLE integrity target
    # over [0, length): every sector written through the mapped device is
    # passed through to the backing store AND gets a per-sector crc32c
    # integrity tag recorded in a dedicated tag store; every read recomputes
    # the tag over the fetched data and FAILS the I/O if it does not match
    # the stored tag (corruption detection). This is the
    # `dmsetup create NAME --table "0 LENGTH integrity DEV START ..."` shape
    # in crc32c tag mode. Returns the registered block slot or a negative
    # error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    if length > DM_INTEG_MAX_SECTORS:
        printk0("dm: integrity span exceeds tag-store capacity\n")
        return -3
    if under_start + length > blk_capacity_sectors(under_slot):
        printk0("dm: integrity target exceeds underlying capacity\n")
        return -3
    cidx_s: int32 = _dm_integ_alloc_ctx()
    if cidx_s < 0:
        printk0("dm: integrity context table full\n")
        return -4
    cidx: uint64 = cast[uint64](cidx_s)
    dm_integ_ctxs[cidx].nsectors = length
    vi: uint64 = 0
    while vi < length:
        dm_integ_ctxs[cidx].valid[vi] = 0
        dm_integ_ctxs[cidx].tags[vi]  = 0
        vi = vi + 1
    dm_integ_ctxs[cidx].used = 1
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_integ_ctxs[cidx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_INTEGRITY
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].snap_ctx     = cidx_s
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used     = 0
        dm_integ_ctxs[cidx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_thin_alloc_pool() -> int32:
    # Claim a free thin-pool slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_THIN_POOL_MAX:
        if dm_thin_pools[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_thin_alloc_dev() -> int32:
    # Claim a free thin-device slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_THIN_DEV_MAX:
        if dm_thin_devs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_thin_pool(data_slot: int32, block_sectors: uint64,
                        nblocks: uint64) -> int32:
    # Create a thin POOL over an underlying DATA block device. The pool's
    # physical capacity is `nblocks` blocks of `block_sectors` sectors each;
    # every block starts FREE (zero allocated). Thin devices later draw their
    # on-demand blocks from this pool. This is the dm-thin-pool target:
    # `dmsetup create pool --table "0 LEN thin-pool METADEV DATADEV BLK ..."`.
    # Returns the pool index (>= 0) or a negative error.
    dm_init()
    if data_slot < 0:
        return -2
    if block_sectors == 0:
        return -2
    if nblocks == 0 or nblocks > DM_THIN_MAX_PBLOCKS:
        printk0("dm: thin pool block count exceeds allocator capacity\n")
        return -3
    if nblocks * block_sectors > blk_capacity_sectors(data_slot):
        printk0("dm: thin pool exceeds underlying data capacity\n")
        return -3
    pidx_s: int32 = _dm_thin_alloc_pool()
    if pidx_s < 0:
        printk0("dm: thin pool table full\n")
        return -4
    pidx: uint64 = cast[uint64](pidx_s)
    dm_thin_pools[pidx].data_slot     = data_slot
    dm_thin_pools[pidx].block_sectors = block_sectors
    dm_thin_pools[pidx].nblocks       = nblocks
    dm_thin_pools[pidx].nallocated    = 0
    b: uint64 = 0
    while b < nblocks:
        dm_thin_pools[pidx].free[b] = 1
        b = b + 1
    dm_thin_pools[pidx].used = 1
    return pidx_s


def dm_thin_pool_allocated(pool_idx: int32) -> int64:
    # Return the number of pool blocks currently handed out (allocated) for
    # the pool at `pool_idx`, or -1 for an invalid/free pool. Lets a caller
    # (e.g. the self-test) observe over-provisioning: virtual size can vastly
    # exceed this physical allocation.
    if pool_idx < 0 or cast[uint64](pool_idx) >= DM_THIN_POOL_MAX:
        return -1
    p: uint64 = cast[uint64](pool_idx)
    if dm_thin_pools[p].used == 0:
        return -1
    return cast[int64](dm_thin_pools[p].nallocated)


def dm_create_thin(name: Ptr[char], pool_idx: int32,
                   virtual_sectors: uint64) -> int32:
    # Create a THIN device drawing from the pool at `pool_idx`. It presents
    # `virtual_sectors` of VIRTUAL capacity but allocates ZERO pool blocks up
    # front: physical blocks are claimed on demand on first write. The
    # virtual size may vastly exceed the pool's physical capacity
    # (over-provisioning). This is the dm-thin target:
    # `dmsetup create thin --table "0 LEN thin POOLDEV DEVID"`. Returns the
    # registered block slot or a negative error.
    dm_init()
    if virtual_sectors == 0:
        return -1
    if pool_idx < 0 or cast[uint64](pool_idx) >= DM_THIN_POOL_MAX:
        return -2
    if dm_thin_pools[cast[uint64](pool_idx)].used == 0:
        return -2
    bs: uint64 = dm_thin_pools[cast[uint64](pool_idx)].block_sectors
    if virtual_sectors % bs != 0:
        printk0("dm: thin virtual size not a multiple of pool block size\n")
        return -3
    nvb: uint64 = virtual_sectors / bs
    if nvb > DM_THIN_MAX_VBLOCKS:
        printk0("dm: thin virtual size exceeds mapping-table capacity\n")
        return -3
    didx_s: int32 = _dm_thin_alloc_dev()
    if didx_s < 0:
        printk0("dm: thin device table full\n")
        return -4
    didx: uint64 = cast[uint64](didx_s)
    dm_thin_devs[didx].pool_idx = pool_idx
    dm_thin_devs[didx].nvblocks = nvb
    vb: uint64 = 0
    while vb < nvb:
        dm_thin_devs[didx].mapped[vb] = 0
        dm_thin_devs[didx].pmap[vb]   = 0
        vb = vb + 1
    dm_thin_devs[didx].used = 1
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_thin_devs[didx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = virtual_sectors
    dm_devices[idx].targets[0].ttype        = DM_TARGET_THIN
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = virtual_sectors
    dm_devices[idx].targets[0].under_slot   = \
        dm_thin_pools[cast[uint64](pool_idx)].data_slot
    dm_devices[idx].targets[0].snap_ctx     = didx_s
    dm_devices[idx].targets[0].under_start  = 0
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used    = 0
        dm_thin_devs[didx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_remove(name: Ptr[char]) -> int32:
    # Tear down a mapped device by name: unregister its block-device
    # identity and free the MappedDevice slot. dmsetup remove NAME.
    # Returns 0 on success, -1 if no mapped device carried that name.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            # Releasing a snapshot VIEW also frees its shared CoW context.
            if dm_devices[i].targets[0].ttype == DM_TARGET_SNAPSHOT:
                sc: int32 = dm_devices[i].targets[0].snap_ctx
                if sc >= 0 and cast[uint64](sc) < DM_SNAP_MAX:
                    dm_snap_ctxs[cast[uint64](sc)].used = 0
            # Releasing an integrity device also frees its tag-store context.
            if dm_devices[i].targets[0].ttype == DM_TARGET_INTEGRITY:
                ic: int32 = dm_devices[i].targets[0].snap_ctx
                if ic >= 0 and cast[uint64](ic) < DM_INTEG_MAX:
                    dm_integ_ctxs[cast[uint64](ic)].used = 0
            # Releasing a thin device frees its mapping context; the shared
            # pool persists (other thin volumes may still draw from it).
            if dm_devices[i].targets[0].ttype == DM_TARGET_THIN:
                tc: int32 = dm_devices[i].targets[0].snap_ctx
                if tc >= 0 and cast[uint64](tc) < DM_THIN_DEV_MAX:
                    dm_thin_devs[cast[uint64](tc)].used = 0
            blk_unregister_by_name(name)
            dm_devices[i].used      = 0
            dm_devices[i].n_targets = 0
            dm_devices[i].capacity  = 0
            dm_devices[i].self_slot = -1
            return 0
        i = i + 1
    return -1


# =========================================================================
# Deterministic device-mapper self-test
# =========================================================================
#
# Gated boot self-test (init/main.ad, planted /etc/devmapper-test by
# build_initramfs.py when ENABLE_DEVMAPPER_TEST=1). It runs entirely
# against a DEDICATED in-kernel backing ramdisk (registered here as
# "dmback0"), so it never touches ram0's FAT image and is fully
# deterministic.
#
# It PROVES four things:
#
#   1. LINEAR remap correctness: write a known pattern THROUGH the linear
#      mapped device at virtual LBA L, then read the SAME data back from
#      the UNDERLYING backing device at the mapped offset (under_start+L).
#      The bytes match -> the linear target really remaps to the right
#      underlying sector.
#   2. CONCATENATION: a two-target mapped device routes virtual sectors
#      in span A to backing region A and virtual sectors in span B to a
#      DIFFERENT backing region B. Writing distinct patterns to one
#      virtual sector in each span and reading the underlying regions
#      back confirms each landed in the correct backing device offset.
#   3. CRYPT round-trip + IV-dependence: plaintext written through the
#      crypt device is CIPHERTEXT on the backing store (differs from the
#      plaintext), yet reads back through the crypt device as the
#      ORIGINAL plaintext. AND the SAME plaintext written to two
#      DIFFERENT virtual sectors produces DIFFERENT ciphertext on disk
#      (the plain64 IV is sector-dependent).
#
# Each marker line stamps EMERG so it reaches serial even at the prompt.

# Dedicated backing ramdisk: 256 sectors = 128 KiB. Module-scope per the
# Adder large-array quirk.
_DM_BACK_SECTORS: uint64 = 256
_dm_back_store:   Array[131072, uint8]   # 256 * 512
_dm_back_ops:     BlockDeviceOps

# Dedicated exception-store ramdisk for the dm-snapshot subtest: a SEPARATE
# backing device (Linux dm-snapshot keeps the CoW store on its own device),
# 256 sectors = 128 KiB.
_DM_EXC_SECTORS:  uint64 = 256
_dm_exc_store:    Array[131072, uint8]   # 256 * 512
_dm_exc_ops:      BlockDeviceOps

# Dedicated POOL DATA ramdisk for the dm-thin subtest: the physical block
# store the thin pool carves into on-demand blocks. 256 sectors = 128 KiB —
# deliberately SMALL relative to the thin device's huge virtual size so
# over-provisioning is observable.
_DM_POOL_SECTORS: uint64 = 256
_dm_pool_store:   Array[131072, uint8]   # 256 * 512
_dm_pool_ops:     BlockDeviceOps

# Scratch buffers for the self-test (all module-scope, one sector each
# unless noted).
_dm_t_plain:   Array[512, uint8]   # plaintext written through a mapped dev
_dm_t_plain2:  Array[512, uint8]   # second plaintext (concat span B)
_dm_t_read:    Array[512, uint8]   # readback through a mapped dev
_dm_t_under:   Array[512, uint8]   # raw read from the backing device
_dm_t_under2:  Array[512, uint8]   # raw read from a second backing sector
_dm_t_key:     Array[64, uint8]    # AES-256-XTS key (32B data + 32B tweak)

# AES-XTS known-answer-test scratch (IEEE 1619 / OpenSSL test vector).
# Generously sized — these hold whole-sector transforms.
_dm_kat_key:   Array[64, uint8]
_dm_kat_pt:    Array[512, uint8]
_dm_kat_ct:    Array[512, uint8]
_dm_kat_out:   Array[512, uint8]

# dm-snapshot subtest scratch (all one full sector = 512 bytes — the most
# any of these ever carries — to avoid the BSS-overflow trap).
_dm_snap_orig:  Array[512, uint8]   # original origin-chunk contents
_dm_snap_new:   Array[512, uint8]   # new data written to the origin
_dm_snap_read:  Array[512, uint8]   # readback through snapshot / origin
_dm_snap_excrd: Array[512, uint8]   # raw read from the exception store
_dm_snap_untch: Array[512, uint8]   # pattern for the never-written chunk

# dm-integrity subtest scratch (all one full sector = 512 bytes to avoid the
# BSS-overflow trap).
_dm_integ_plain: Array[512, uint8]   # known data written through integrity dev
_dm_integ_read:  Array[512, uint8]   # readback through the integrity device
_dm_integ_raw:   Array[512, uint8]   # raw read from the backing device

# dm-thin subtest scratch (all one full sector = 512 bytes to avoid the
# BSS-overflow trap).
_dm_thin_pat0:   Array[512, uint8]   # pattern written to first thin vblock
_dm_thin_pat1:   Array[512, uint8]   # pattern written to second thin vblock
_dm_thin_pat0b:  Array[512, uint8]   # rewrite pattern for first thin vblock
_dm_thin_read:   Array[512, uint8]   # readback through the thin device
_dm_thin_zchk:   Array[512, uint8]   # all-zero reference for unprovisioned


def _dm_back_read(priv: uint64, lba: uint64, count: uint64,
                  buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_dm_back_store[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _dm_back_write(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_dm_back_store[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _dm_exc_read(priv: uint64, lba: uint64, count: uint64,
                 buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_dm_exc_store[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _dm_exc_write(priv: uint64, lba: uint64, count: uint64,
                  buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_dm_exc_store[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _dm_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _dm_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def _dm_emerg2(s: Ptr[char], a: uint64, b: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2(s, a, b)


def _dm_back_register() -> int32:
    # Register the dedicated test backing ramdisk as "dmback0". Returns
    # the slot, or the existing slot if already registered.
    existing: int32 = find_blockdev("dmback0")
    if existing >= 0:
        return existing
    # Zero the backing store so the test starts from a clean slate.
    z: uint64 = 0
    while z < 131072:
        _dm_back_store[z] = 0
        z = z + 1
    _dm_back_ops.read_sectors  = _dm_back_read
    _dm_back_ops.write_sectors = _dm_back_write
    _dm_back_ops.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev("dmback0", _DM_BACK_SECTORS,
                             &_dm_back_ops, 0)


def _dm_exc_register() -> int32:
    # Register the dedicated exception-store ramdisk as "dmexc0". Returns
    # the slot, or the existing slot if already registered.
    existing: int32 = find_blockdev("dmexc0")
    if existing >= 0:
        return existing
    z: uint64 = 0
    while z < 131072:
        _dm_exc_store[z] = 0
        z = z + 1
    _dm_exc_ops.read_sectors  = _dm_exc_read
    _dm_exc_ops.write_sectors = _dm_exc_write
    _dm_exc_ops.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev("dmexc0", _DM_EXC_SECTORS,
                             &_dm_exc_ops, 0)


def _dm_pool_read(priv: uint64, lba: uint64, count: uint64,
                  buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_dm_pool_store[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _dm_pool_write(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_dm_pool_store[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _dm_pool_register() -> int32:
    # Register the dedicated thin-pool DATA ramdisk as "dmpool0". Returns the
    # slot, or the existing slot if already registered.
    existing: int32 = find_blockdev("dmpool0")
    if existing >= 0:
        return existing
    z: uint64 = 0
    while z < 131072:
        _dm_pool_store[z] = 0
        z = z + 1
    _dm_pool_ops.read_sectors  = _dm_pool_read
    _dm_pool_ops.write_sectors = _dm_pool_write
    _dm_pool_ops.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev("dmpool0", _DM_POOL_SECTORS,
                             &_dm_pool_ops, 0)


def _dm_buf_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Reference AES-256-XTS ciphertext for the known-answer test, computed
# offline by Python's `cryptography` library (an independent, trusted AES
# implementation). Parameters:
#   key      = bytes((i*17+5)&0xFF for i in range(64))   # 32B data+32B tweak
#   plaintext= bytes((i*3+42)&0xFF for i in range(512))  # one 512B sector
#   sector   = 7  (plain64 IV = 7 little-endian in a 16-byte tweak block)
# We assert the FIRST and LAST 16-byte ciphertext blocks; matching both
# pins the cipher, the tweak derivation and the GF(2^128) alpha-multiply
# across the whole sector.
_DM_KAT_SECTOR: uint64 = 7
_dm_kat_ct_first: Array[16, uint8]   # expected CT[0..15]
_dm_kat_ct_last:  Array[16, uint8]   # expected CT[496..511]


def _dm_xts_kat_load_expected():
    _dm_kat_ct_first[0] = 0x26
    _dm_kat_ct_first[1] = 0xb7
    _dm_kat_ct_first[2] = 0x7f
    _dm_kat_ct_first[3] = 0xa2
    _dm_kat_ct_first[4] = 0xe2
    _dm_kat_ct_first[5] = 0xc5
    _dm_kat_ct_first[6] = 0x64
    _dm_kat_ct_first[7] = 0xac
    _dm_kat_ct_first[8] = 0xdc
    _dm_kat_ct_first[9] = 0x4c
    _dm_kat_ct_first[10] = 0xd4
    _dm_kat_ct_first[11] = 0xb4
    _dm_kat_ct_first[12] = 0x8e
    _dm_kat_ct_first[13] = 0x61
    _dm_kat_ct_first[14] = 0x9b
    _dm_kat_ct_first[15] = 0x3f
    _dm_kat_ct_last[0] = 0xfe
    _dm_kat_ct_last[1] = 0x34
    _dm_kat_ct_last[2] = 0x89
    _dm_kat_ct_last[3] = 0xee
    _dm_kat_ct_last[4] = 0x1c
    _dm_kat_ct_last[5] = 0xad
    _dm_kat_ct_last[6] = 0x72
    _dm_kat_ct_last[7] = 0x2f
    _dm_kat_ct_last[8] = 0x6c
    _dm_kat_ct_last[9] = 0x16
    _dm_kat_ct_last[10] = 0xad
    _dm_kat_ct_last[11] = 0x4b
    _dm_kat_ct_last[12] = 0x22
    _dm_kat_ct_last[13] = 0x48
    _dm_kat_ct_last[14] = 0x69
    _dm_kat_ct_last[15] = 0xbb


def _dm_xts_kat() -> int32:
    # Returns 1 if the AES-256-XTS implementation reproduces the offline
    # reference vector AND decrypts it back to plaintext, else 0.
    _dm_xts_kat_load_expected()
    i: uint64 = 0
    while i < 64:
        _dm_kat_key[i] = cast[uint8]((i * 17 + 5) & 0xFF)
        i = i + 1
    i = 0
    while i < SECTOR_SIZE:
        _dm_kat_pt[i] = cast[uint8]((i * 3 + 42) & 0xFF)
        i = i + 1
    # Load the schedules directly from the KAT key (data = bytes 0..31,
    # tweak = bytes 32..63) and XTS-encrypt the whole sector.
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))
    _dm_xts_encrypt_sector(_DM_KAT_SECTOR,
                           cast[Ptr[uint8]](&_dm_kat_ct[0]),
                           cast[Ptr[uint8]](&_dm_kat_pt[0]))
    # First and last ciphertext blocks must match the reference.
    if _dm_buf_eq(&_dm_kat_ct[0], &_dm_kat_ct_first[0], 16) != 1:
        _dm_emerg0("[device-mapper] KAT first block mismatch\n")
        return 0
    if _dm_buf_eq(&_dm_kat_ct[496], &_dm_kat_ct_last[0], 16) != 1:
        _dm_emerg0("[device-mapper] KAT last block mismatch\n")
        return 0
    # Decrypt round-trip: must reproduce the plaintext exactly.
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))
    _dm_xts_decrypt_sector(_DM_KAT_SECTOR,
                           cast[Ptr[uint8]](&_dm_kat_out[0]),
                           cast[Ptr[uint8]](&_dm_kat_ct[0]))
    if _dm_buf_eq(&_dm_kat_out[0], &_dm_kat_pt[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] KAT decrypt round-trip mismatch\n")
        return 0
    return 1


def dm_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [device-mapper] marker lines.
    _dm_emerg0("[device-mapper] self-test start\n")
    dm_init()

    back: int32 = _dm_back_register()
    if back < 0:
        _dm_emerg0("[device-mapper] FAIL: backing register\n")
        return 0
    _dm_emerg1("[device-mapper] backing dmback0 slot=%d\n",
               cast[uint64](cast[int64](back)))

    ok: int32 = 1

    # --- Test 1: LINEAR target remaps to the right underlying sector ---
    # Map [0, 16) of a virtual device onto dmback0 starting at sector 32.
    # Write a pattern through the mapped device at virtual LBA 5; it must
    # land on backing sector 32 + 5 = 37.
    pi: uint64 = 0
    while pi < SECTOR_SIZE:
        _dm_t_plain[pi] = cast[uint8]((pi * 7 + 3) & 0xFF)
        pi = pi + 1
    lin: int32 = dm_create_linear("dmlin0", back, 32, 16)
    if lin < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_linear rc=%d\n",
                   cast[uint64](cast[int64](lin)))
        return 0
    if blk_write_sectors(lin, 5, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: linear write\n")
        return 0
    # Read the UNDERLYING backing sector 37 directly.
    if blk_read_sectors(back, 37, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read (linear)\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: linear remap landed on wrong sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] linear: vLBA5 -> backing sector 37 OK\n")
    # And it must read back through the mapped device unchanged.
    if blk_read_sectors(lin, 5, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: linear readback\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: linear readback mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] linear: readback byte-identical OK\n")

    # --- Test 2: CONCATENATION across two backing regions ---
    # Span A: virtual [0, 8) -> dmback0 @ 64. Span B: virtual [8, 16) ->
    # dmback0 @ 128. Write distinct patterns to a sector in each span and
    # confirm each landed in the correct backing region.
    qi: uint64 = 0
    while qi < SECTOR_SIZE:
        _dm_t_plain[qi]  = cast[uint8]((qi * 11 + 1) & 0xFF)   # span A
        _dm_t_plain2[qi] = cast[uint8]((qi * 13 + 9) & 0xFF)   # span B
        qi = qi + 1
    cc: int32 = dm_create_concat("dmcat0", back, 64, 8, back, 128, 8)
    if cc < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_concat rc=%d\n",
                   cast[uint64](cast[int64](cc)))
        return 0
    # Virtual LBA 2 is in span A -> backing 64 + 2 = 66.
    if blk_write_sectors(cc, 2, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: concat write A\n")
        return 0
    # Virtual LBA 10 is in span B (offset 2) -> backing 128 + 2 = 130.
    if blk_write_sectors(cc, 10, 1, &_dm_t_plain2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: concat write B\n")
        return 0
    if blk_read_sectors(back, 66, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 66\n")
        return 0
    if blk_read_sectors(back, 130, 1, &_dm_t_under2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 130\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: concat span A wrong backing sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] concat: span A vLBA2 -> backing 66 OK\n")
    if _dm_buf_eq(&_dm_t_plain2[0], &_dm_t_under2[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: concat span B wrong backing sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] concat: span B vLBA10 -> backing 130 OK\n")

    # --- Test 3: CRYPT round-trip + IV-dependence ---
    # Map [0, 16) onto dmback0 @ 192 with a fixed key. Write identical
    # plaintext to virtual sectors 0 and 1; on the backing store sectors
    # 192 and 193 must hold CIPHERTEXT that (a) differs from the plaintext
    # and (b) differs from EACH OTHER (sector-dependent IV). Reading both
    # back through the crypt device must return the original plaintext.
    ki2: uint64 = 0
    while ki2 < DM_KEY_LEN:
        _dm_t_key[ki2] = cast[uint8]((ki2 * 17 + 5) & 0xFF)
        ki2 = ki2 + 1
    pj: uint64 = 0
    while pj < SECTOR_SIZE:
        _dm_t_plain[pj] = cast[uint8]((pj * 3 + 42) & 0xFF)
        pj = pj + 1
    cr: int32 = dm_create_crypt("dmcrypt0", back, 192, 16,
                                &_dm_t_key[0], DM_KEY_LEN)
    if cr < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_crypt rc=%d\n",
                   cast[uint64](cast[int64](cr)))
        return 0
    # Same plaintext to virtual sectors 0 and 1.
    if blk_write_sectors(cr, 0, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt write sec0\n")
        return 0
    if blk_write_sectors(cr, 1, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt write sec1\n")
        return 0
    # Backing 192 / 193 hold the two ciphertexts.
    if blk_read_sectors(back, 192, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 192\n")
        return 0
    if blk_read_sectors(back, 193, 1, &_dm_t_under2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 193\n")
        return 0
    # (a) ciphertext on disk differs from plaintext (real encryption,
    # not a passthrough).
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt backing == plaintext (no encryption)\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-ciphertext: backing sector 192 is ciphertext OK\n")
    # (b) the two sectors' ciphertext differ (IV is sector-dependent).
    if _dm_buf_eq(&_dm_t_under[0], &_dm_t_under2[0], SECTOR_SIZE) != 0:
        _dm_emerg0("[device-mapper] FAIL: identical plaintext -> identical ciphertext (IV not sector-keyed)\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-tweak: same plaintext, two sectors -> different ciphertext OK\n")
    # Round-trip: read back through the crypt device -> original plaintext.
    if blk_read_sectors(cr, 0, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt readback sec0\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: crypt round-trip sec0 mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-roundtrip-sec0: sector 0 round-trips to plaintext OK\n")
    if blk_read_sectors(cr, 1, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt readback sec1\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: crypt round-trip sec1 mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-roundtrip-sec1: sector 1 round-trips to plaintext OK\n")

    # --- Test 4: AES-256-XTS KNOWN-ANSWER TEST (independent vector) ---
    # The highest-confidence check: encrypt a fixed plaintext sector with
    # a fixed 64-byte key at a fixed sector number and assert the
    # ciphertext byte-for-byte matches a reference vector computed OFFLINE
    # by Python's `cryptography` AES-XTS (key = (i*17+5)&0xFF, plaintext =
    # (i*3+42)&0xFF, sector = 7, plain64 IV). This pins the cipher, the
    # tweak derivation AND the GF(2^128) alpha-multiply across all 32
    # blocks of the sector (first and LAST block are both asserted). Then
    # decrypt it back and assert it returns the plaintext.
    if _dm_xts_kat() != 1:
        _dm_emerg0("[device-mapper] FAIL: AES-256-XTS known-answer test\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-kat: AES-256-XTS vector matches reference OK\n")

    # --- Test 5: dm-SNAPSHOT copy-on-write + passthrough ---
    # Build a snapshot of an origin region with chunk size 8 sectors,
    # backed by a SEPARATE exception store (dmexc0). Seed origin chunk 4
    # (LBA 32) with a known ORIGINAL pattern and an UNTOUCHED chunk 6 (LBA
    # 48) with a different pattern. Take the snapshot, then WRITE new data
    # to origin chunk 4 THROUGH the snapshot-origin device — this must CoW
    # the original into the exception store. Then prove:
    #   (a) the snapshot view still reads the ORIGINAL pre-image,
    #   (b) the exception store actually holds that pre-image,
    #   (c) the origin now reads the NEW data, and
    #   (d) the never-written chunk reads through to the origin on both
    #       the snapshot view and the origin device.
    exc: int32 = _dm_exc_register()
    if exc < 0:
        _dm_emerg0("[device-mapper] FAIL: exception store register\n")
        return 0
    _dm_emerg1("[device-mapper] snapshot exc-store dmexc0 slot=%d\n",
               cast[uint64](cast[int64](exc)))
    si: uint64 = 0
    while si < SECTOR_SIZE:
        _dm_snap_orig[si]  = cast[uint8]((si * 5 + 17) & 0xFF)   # chunk 4
        _dm_snap_new[si]   = cast[uint8]((si * 9 + 200) & 0xFF)  # overwrite
        _dm_snap_untch[si] = cast[uint8]((si * 3 + 77) & 0xFF)   # chunk 6
        si = si + 1
    # Seed the origin chunks directly on the backing device. Chunk 4 ->
    # LBA 4*8 = 32; chunk 6 -> LBA 6*8 = 48.
    if blk_write_sectors(back, 32, 1, &_dm_snap_orig[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot seed origin chunk 4\n")
        return 0
    if blk_write_sectors(back, 48, 1, &_dm_snap_untch[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot seed origin chunk 6\n")
        return 0
    # Create the snapshot VIEW (chunk=8, length=64) and its CoW origin.
    snapv: int32 = dm_create_snapshot("dmsnap0", back, exc, 8, 64)
    if snapv < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_snapshot rc=%d\n",
                   cast[uint64](cast[int64](snapv)))
        return 0
    sctx: int32 = dm_snapshot_ctx_of("dmsnap0")
    if sctx < 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot ctx lookup\n")
        return 0
    snapo: int32 = dm_create_snapshot_origin("dmsnap0-origin", sctx, 64)
    if snapo < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_snapshot_origin rc=%d\n",
                   cast[uint64](cast[int64](snapo)))
        return 0
    # Overwrite origin chunk 4 (LBA 32) THROUGH the CoW origin device. This
    # must copy the ORIGINAL out to the exception store first.
    if blk_write_sectors(snapo, 32, 1, &_dm_snap_new[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot origin write\n")
        return 0

    # (a) The snapshot view must STILL read the original pre-image.
    if blk_read_sectors(snapv, 32, 1, &_dm_snap_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot view read (chunk 4)\n")
        return 0
    if _dm_buf_eq(&_dm_snap_read[0], &_dm_snap_orig[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: snapshot view lost pre-image (CoW broken)\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] snapshot: CoW preserved origin pre-image OK\n")
        _dm_emerg0("[dm] PASS snapshot-cow\n")

    # (b) The exception store itself must hold the original pre-image. The
    # first CoW allocates exception-store chunk 0 -> LBA 0.
    if blk_read_sectors(exc, 0, 1, &_dm_snap_excrd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: exception store read\n")
        return 0
    if _dm_buf_eq(&_dm_snap_excrd[0], &_dm_snap_orig[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: exception store missing pre-image\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] snapshot: exception store holds pre-image OK\n")

    # (c) The origin must now read the NEW data (live view advanced).
    if blk_read_sectors(snapo, 32, 1, &_dm_snap_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot origin readback (chunk 4)\n")
        return 0
    if _dm_buf_eq(&_dm_snap_read[0], &_dm_snap_new[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: origin did not advance to new data\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] snapshot: origin reads new data OK\n")

    # (d) A chunk never written (chunk 6, LBA 48) reads through to the
    # origin on BOTH the snapshot view and the origin device.
    if blk_read_sectors(snapv, 48, 1, &_dm_snap_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot view read (chunk 6)\n")
        return 0
    if _dm_buf_eq(&_dm_snap_read[0], &_dm_snap_untch[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: snapshot passthrough (view) mismatch\n")
        ok = 0
    else:
        if blk_read_sectors(snapo, 48, 1, &_dm_snap_excrd[0]) != 0:
            _dm_emerg0("[device-mapper] FAIL: snapshot origin read (chunk 6)\n")
            return 0
        if _dm_buf_eq(&_dm_snap_excrd[0], &_dm_snap_untch[0], SECTOR_SIZE) != 1:
            _dm_emerg0("[device-mapper] FAIL: snapshot passthrough (origin) mismatch\n")
            ok = 0
        else:
            _dm_emerg0("[dm] PASS snapshot-passthrough\n")

    if ok == 1:
        _dm_emerg0("[dm] snapshot PASS\n")

    # --- Test 6: dm-INTEGRITY per-sector tag round-trip + corruption detect ---
    # Map [0, 32) of a virtual device onto dmback0 @ 224 with an integrity
    # target. Write a KNOWN pattern through the integrity device at virtual
    # LBA 3 (a crc32c tag, salted with the underlying sector, is computed and
    # stored). Read it back through the integrity device and verify (a) the
    # data round-trips byte-identical AND the stored tag validated. Then
    # CORRUPT the underlying backing sector directly (simulate bit-rot by
    # flipping a byte on the raw backing device behind the target) and read
    # again through the integrity device: the recomputed tag must NOT match
    # the stored tag, so the read must FAIL (return an error) instead of
    # handing back the corrupted bytes.
    ii: uint64 = 0
    while ii < SECTOR_SIZE:
        _dm_integ_plain[ii] = cast[uint8]((ii * 19 + 23) & 0xFF)
        ii = ii + 1
    integ: int32 = dm_create_integrity("dmint0", back, 224, 32)
    if integ < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_integrity rc=%d\n",
                   cast[uint64](cast[int64](integ)))
        return 0
    # Write the known sector through the integrity device (tag computed+stored).
    if blk_write_sectors(integ, 3, 1, &_dm_integ_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity write\n")
        return 0
    # Read it back: must round-trip byte-identical (tag validated en route).
    if blk_read_sectors(integ, 3, 1, &_dm_integ_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity readback (tag should have validated)\n")
        return 0
    if _dm_buf_eq(&_dm_integ_plain[0], &_dm_integ_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: integrity round-trip mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] integrity: tag validated round-trip OK\n")
    # Now CORRUPT the underlying backing sector directly. Virtual LBA 3 ->
    # backing sector 224 + 3 = 227. Read it raw, flip one byte, write it back
    # raw — the integrity target's stored tag is untouched, so the next read
    # through the integrity device must detect the mismatch.
    if blk_read_sectors(back, 227, 1, &_dm_integ_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity raw backing read 227\n")
        return 0
    _dm_integ_raw[0] = cast[uint8](cast[uint64](_dm_integ_raw[0]) ^ 0xFF)
    if blk_write_sectors(back, 227, 1, &_dm_integ_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity raw backing write 227\n")
        return 0
    # Read through the integrity device again: it MUST fail (non-zero rc)
    # because the recomputed tag no longer matches the stored tag.
    corrupt_rc: int32 = blk_read_sectors(integ, 3, 1, &_dm_integ_read[0])
    if corrupt_rc == 0:
        _dm_emerg0("[device-mapper] FAIL: integrity returned corrupted data (no detection)\n")
        ok = 0
    else:
        _dm_emerg1("[dm] PASS integrity-detect-corruption (read rc=%d)\n",
                   cast[uint64](cast[int64](corrupt_rc)))

    if ok == 1:
        _dm_emerg0("[dm] integrity PASS\n")

    # --- Test 7: dm-THIN thin provisioning (on-demand pool allocation) ---
    # Build a thin POOL over a SMALL dedicated data ramdisk (dmpool0, 256
    # sectors) with block_sectors=8, nblocks=32 (32*8 = 256 sectors). Then
    # create a thin device whose VIRTUAL size is 8192 sectors (1024 blocks)
    # — 32x the pool's physical capacity, so it is heavily over-provisioned.
    # Prove:
    #   (a) reading an UNPROVISIONED virtual block returns ZEROS and consumes
    #       ZERO pool blocks (no physical allocation on read),
    #   (b) writing two specific virtual blocks allocates EXACTLY two pool
    #       blocks and the data reads back byte-correct,
    #   (c) RE-writing an already-provisioned block does NOT allocate a new
    #       pool block (allocation count unchanged),
    #   (d) the mapping distinguishes provisioned (reads data) vs
    #       unprovisioned (reads zeros) virtual regions.
    pooldd: int32 = _dm_pool_register()
    if pooldd < 0:
        _dm_emerg0("[device-mapper] FAIL: thin pool data register\n")
        return 0
    _dm_emerg1("[device-mapper] thin pool-data dmpool0 slot=%d\n",
               cast[uint64](cast[int64](pooldd)))
    ti2: uint64 = 0
    while ti2 < SECTOR_SIZE:
        _dm_thin_pat0[ti2]  = cast[uint8]((ti2 * 7 + 31) & 0xFF)
        _dm_thin_pat1[ti2]  = cast[uint8]((ti2 * 13 + 5) & 0xFF)
        _dm_thin_pat0b[ti2] = cast[uint8]((ti2 * 23 + 99) & 0xFF)
        _dm_thin_zchk[ti2]  = 0
        ti2 = ti2 + 1
    poolidx: int32 = dm_create_thin_pool(pooldd, 8, 32)
    if poolidx < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_thin_pool rc=%d\n",
                   cast[uint64](cast[int64](poolidx)))
        return 0
    # Virtual size = 8192 sectors (1024 blocks) >> 256 pool sectors.
    thin: int32 = dm_create_thin("dmthin0", poolidx, 8192)
    if thin < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_thin rc=%d\n",
                   cast[uint64](cast[int64](thin)))
        return 0

    # (a) Read an UNPROVISIONED virtual block (block 100 -> vsec 800). It
    # must read back as zeros AND must not have consumed any pool block.
    if blk_read_sectors(thin, 800, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin unprovisioned read\n")
        return 0
    a0: int64 = dm_thin_pool_allocated(poolidx)
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_zchk[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin unprovisioned read not zero\n")
        ok = 0
    elif a0 != 0:
        _dm_emerg1("[device-mapper] FAIL: thin read consumed pool blocks (alloc=%d)\n",
                   cast[uint64](a0))
        ok = 0
    else:
        _dm_emerg0("[devmapper] thin: unprovisioned read returns zeros OK\n")

    # (b) Write two specific virtual blocks: block 5 (vsec 40) and block 200
    # (vsec 1600). Each first-write must allocate exactly one pool block, so
    # the allocation count goes 0 -> 2, and the data must read back correctly.
    if blk_write_sectors(thin, 40, 1, &_dm_thin_pat0[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin write vblk5\n")
        return 0
    if blk_write_sectors(thin, 1600, 1, &_dm_thin_pat1[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin write vblk200\n")
        return 0
    a1: int64 = dm_thin_pool_allocated(poolidx)
    if a1 != 2:
        _dm_emerg1("[device-mapper] FAIL: thin two writes != two pool blocks (alloc=%d)\n",
                   cast[uint64](a1))
        ok = 0
    else:
        _dm_emerg0("[dm] PASS thin-ondemand-alloc\n")
    # Data must read back byte-identical from both provisioned blocks.
    if blk_read_sectors(thin, 40, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin readback vblk5\n")
        return 0
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_pat0[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin vblk5 data mismatch\n")
        ok = 0
    if blk_read_sectors(thin, 1600, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin readback vblk200\n")
        return 0
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_pat1[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin vblk200 data mismatch\n")
        ok = 0

    # (c) Re-write an already-provisioned block (block 5). The mapping
    # already exists, so NO new pool block may be allocated: the count must
    # stay at 2. The new data must read back.
    if blk_write_sectors(thin, 40, 1, &_dm_thin_pat0b[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin rewrite vblk5\n")
        return 0
    a2: int64 = dm_thin_pool_allocated(poolidx)
    if a2 != 2:
        _dm_emerg1("[device-mapper] FAIL: thin rewrite allocated a block (alloc=%d)\n",
                   cast[uint64](a2))
        ok = 0
    else:
        _dm_emerg0("[dm] PASS thin-remap-stable\n")
    if blk_read_sectors(thin, 40, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin readback after rewrite\n")
        return 0
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_pat0b[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin rewrite data mismatch\n")
        ok = 0

    # (d) Provisioned vs unprovisioned distinction: block 5 (provisioned)
    # reads the data, while a NEIGHBOURING never-written block (block 6 ->
    # vsec 48) still reads zeros and did not consume a pool block.
    if blk_read_sectors(thin, 48, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin neighbour read\n")
        return 0
    a3: int64 = dm_thin_pool_allocated(poolidx)
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_zchk[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin neighbour not unprovisioned\n")
        ok = 0
    elif a3 != 2:
        _dm_emerg1("[device-mapper] FAIL: thin neighbour read allocated (alloc=%d)\n",
                   cast[uint64](a3))
        ok = 0
    else:
        _dm_emerg0("[devmapper] thin: provisioned vs unprovisioned distinguished OK\n")

    if ok == 1:
        _dm_emerg0("[dm] thin PASS\n")

    # Clean up the mapped devices (frees slots; leaves dmback0 in place).
    dm_remove("dmlin0")
    dm_remove("dmcat0")
    dm_remove("dmcrypt0")
    dm_remove("dmsnap0")
    dm_remove("dmsnap0-origin")
    dm_remove("dmint0")
    dm_remove("dmthin0")

    if ok == 1:
        _dm_emerg0("[device-mapper] PASS\n")
        return 1
    _dm_emerg0("[device-mapper] FAIL\n")
    return 0

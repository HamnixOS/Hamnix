# drivers/block/dm.ad
#
# Native device-mapper — Hamnix's equivalent of Linux's
# drivers/md/dm.c + the dm-linear / dm-crypt targets. A genuine
# Linux-parity gap: there was NO device-mapper in the tree before this.
#
# A device-mapper "mapped device" is a VIRTUAL block device whose
# address space is described by a TABLE of one or more TARGETS. Each
# target owns a contiguous [start_sector, length) span of the virtual
# device and translates every I/O that lands in its span to an
# underlying real block device at a target-specific offset. The block
# layer (kernel/block/blk.ad) sees the mapped device as an ordinary
# registered BlockDevice — filesystems can mount and read/write through
# it exactly like a partition or a loop device.
#
# Linux mapping:
#
#   struct mapped_device          -> MappedDevice (this file)
#   struct dm_table / dm_target   -> DmTarget[] inside MappedDevice
#   dm-linear (drivers/md/dm-linear.c)  -> DM_TARGET_LINEAR
#   dm-crypt  (drivers/md/dm-crypt.c)    -> DM_TARGET_CRYPT
#   dmsetup create --table "..."  -> dm_create_linear / dm_create_concat
#                                    / dm_create_crypt (this file)
#   bio remap (map_bio)           -> _dm_read_blkop / _dm_write_blkop
#
# TARGETS:
#
#   LINEAR — maps a span of the virtual device onto an underlying block
#   device at a fixed sector offset. This is the foundation of LVM:
#   concatenating several linear targets, each pointing at a different
#   underlying device (or a different region of one), builds a single
#   large virtual device out of smaller physical extents.
#
#   CRYPT (dm-crypt) — like linear (it forwards to an underlying device
#   at an offset) but encrypts every sector on the way out and decrypts
#   on the way in, so the bytes resting on the backing store are
#   ciphertext while reads through the mapped device return plaintext.
#   The cipher is AES-256 in XTS mode — the exact `aes-xts-plain64`
#   construction that is Linux dm-crypt / LUKS2's default. NOT a toy XOR,
#   NOT a stream-cipher stand-in: it is a real tweakable block cipher
#   (IEEE Std 1619-2007) implemented in full below.
#
#   WHY a standalone AES here (and not the AES already in tls.ad): the
#   tree's only AES is drivers/net/tls.ad's GCM path, which (a) needs
#   only AES ENCRYPT (CTR mode never decrypts the cipher) so it ships no
#   inverse cipher, and (b) keeps a SINGLE shared 240-byte round-key
#   schedule global (aes256_rk). XTS fundamentally needs the INVERSE
#   cipher for reads and TWO independent keys live at once (a data key
#   and a tweak key), so tls.ad's single-schedule, encrypt-only code
#   cannot be borrowed without either clobbering live TLS state or
#   re-expanding keys mid-block. The clean, decoupled answer — and the
#   one the brief sanctions when reuse is impractical — is a small
#   self-contained AES-256 (forward + inverse cipher) that owns its own
#   data/tweak schedules in this file, with zero coupling to the network
#   stack's import closure.
#
#   XTS (XEX-based tweaked-codebook with ciphertext stealing — here every
#   transfer is a whole 512-byte sector = 32 exact AES blocks, so no
#   stealing is needed): the tweak for a sector is AES_tweakkey(IV) where
#   the IV is dm-crypt's "plain64" — the 64-bit sector number, little-
#   endian, in a 16-byte block. For each 16-byte block j within the
#   sector the running tweak T is GF(2^128)-multiplied by the primitive
#   element alpha=x once per block; the block is XEX-masked
#   (C = AES_datakey(P ^ T) ^ T). Identical plaintext at two different
#   sectors therefore encrypts to different ciphertext (different IV ->
#   different tweak), and every block is independently seekable.

from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, blk_unregister_by_name,
    blk_read_sectors, blk_write_sectors, find_blockdev,
    blk_capacity_sectors, SECTOR_SIZE,
)
from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level,
)
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from fs.crc32c import (
    crc32c, crc32c_update,
)

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# =========================================================================
# AES-256 block cipher (FIPS 197) — self-contained, forward + inverse
# =========================================================================
#
# A real 14-round AES with a 256-bit master key. Unlike tls.ad's GCM
# path (encrypt-only, single shared schedule), XTS needs BOTH the
# forward and the inverse cipher and TWO live key schedules at once (a
# data key and a tweak key), so this implementation owns two 240-byte
# expanded schedules. The S-box / inverse S-box / GF(2^8) tables are
# built once at init. All working state is module-scope .bss: dm-crypt
# I/O is serialised through the synchronous block layer, so a single
# shared block-state buffer is safe (no two crypt transfers overlap).

_dm_aes_sbox:     Array[256, uint8]   # forward S-box
_dm_aes_isbox:    Array[256, uint8]   # inverse S-box
_dm_aes_inited:   int32 = 0
# GF(2^8) log/exp scratch for S-box construction.
_dm_aes_log:      Array[256, uint16]
_dm_aes_exp:      Array[256, uint8]

# Two independent 240-byte AES-256 expanded schedules: index 0 = data
# key, index 1 = tweak key. Both forward; the data key also gets an
# inverse schedule for the decrypt path.
_dm_aes_rk_data:  Array[240, uint8]
_dm_aes_rk_tweak: Array[240, uint8]
_dm_aes_block_st: Array[16, uint8]    # working state for one block


def _dm_aes_rotl8(v: uint8, n: uint64) -> uint8:
    x: uint64 = cast[uint64](v) & 0xFF
    return cast[uint8](((x << n) | (x >> (8 - n))) & 0xFF)


def _dm_aes_xtime(b: uint8) -> uint8:
    # b * x mod (x^8 + x^4 + x^3 + x + 1) in GF(2^8).
    v: uint64 = cast[uint64](b) & 0xFF
    t: uint64 = (v << 1) & 0xFF
    if (v & 0x80) != 0:
        t = t ^ 0x1B
    return cast[uint8](t & 0xFF)


def _dm_aes_gfmul(a: uint8, b: uint8) -> uint8:
    # Full GF(2^8) multiply (used for the inverse MixColumns constants
    # 9, 11, 13, 14). Russian-peasant.
    av: uint64 = cast[uint64](a) & 0xFF
    bv: uint64 = cast[uint64](b) & 0xFF
    p:  uint64 = 0
    i:  uint64 = 0
    while i < 8:
        if (bv & 1) != 0:
            p = p ^ av
        hi: uint64 = av & 0x80
        av = (av << 1) & 0xFF
        if hi != 0:
            av = av ^ 0x1B
        bv = bv >> 1
        i = i + 1
    return cast[uint8](p & 0xFF)


def _dm_aes_init():
    # Build the forward S-box (FIPS 197 §5.1.1) and its inverse at
    # runtime via a GF(2^8) log/exp table with generator g=3.
    if _dm_aes_inited != 0:
        return
    _dm_aes_inited = 1
    i: uint64 = 0
    x: uint16 = 1
    while i < 255:
        _dm_aes_exp[i] = cast[uint8](x & 0xFF)
        _dm_aes_log[x & 0xFF] = cast[uint16](i)
        x2: uint16 = (x << 1) & 0xFF
        if (x & 0x80) != 0:
            x2 = x2 ^ 0x1B
        x = x2 ^ x
        x = x & 0xFF
        i = i + 1
    _dm_aes_exp[255] = _dm_aes_exp[0]
    _dm_aes_sbox[0] = 0x63
    b: uint64 = 1
    while b < 256:
        inv: uint8 = _dm_aes_exp[(255 - cast[uint64](_dm_aes_log[b])) & 0xFF]
        v: uint8 = inv
        s: uint8 = v \
            ^ _dm_aes_rotl8(v, 1) \
            ^ _dm_aes_rotl8(v, 2) \
            ^ _dm_aes_rotl8(v, 3) \
            ^ _dm_aes_rotl8(v, 4) \
            ^ 0x63
        _dm_aes_sbox[b] = s
        b = b + 1
    # Inverse S-box: isbox[sbox[b]] = b.
    b = 0
    while b < 256:
        _dm_aes_isbox[_dm_aes_sbox[b]] = cast[uint8](b)
        b = b + 1


def _dm_aes256_expand(master: Ptr[uint8], rk: Ptr[uint8]):
    # FIPS 197 §5.2, AES-256: Nk=8, Nr=14, 240-byte expanded key into the
    # caller-supplied 240-byte schedule buffer `rk`.
    _dm_aes_init()
    i: uint64 = 0
    while i < 32:
        rk[i] = master[i]
        i = i + 1
    rcon: uint8 = 0x01
    i = 32
    while i < 240:
        t0: uint8 = rk[i - 4]
        t1: uint8 = rk[i - 3]
        t2: uint8 = rk[i - 2]
        t3: uint8 = rk[i - 1]
        word_idx: uint64 = i / 4
        if (word_idx & 7) == 0:
            r0: uint8 = _dm_aes_sbox[t1] ^ rcon
            r1: uint8 = _dm_aes_sbox[t2]
            r2: uint8 = _dm_aes_sbox[t3]
            r3: uint8 = _dm_aes_sbox[t0]
            t0 = r0
            t1 = r1
            t2 = r2
            t3 = r3
            rcon = _dm_aes_xtime(rcon)
        elif (word_idx & 7) == 4:
            t0 = _dm_aes_sbox[t0]
            t1 = _dm_aes_sbox[t1]
            t2 = _dm_aes_sbox[t2]
            t3 = _dm_aes_sbox[t3]
        rk[i + 0] = rk[i - 32 + 0] ^ t0
        rk[i + 1] = rk[i - 32 + 1] ^ t1
        rk[i + 2] = rk[i - 32 + 2] ^ t2
        rk[i + 3] = rk[i - 32 + 3] ^ t3
        i = i + 4


def _dm_aes256_encrypt(rk: Ptr[uint8], out_blk: Ptr[uint8],
                       in_blk: Ptr[uint8]):
    # Encrypt one 16-byte block under the 240-byte schedule `rk` (Nr=14).
    # State held column-major s[c*4 + r].
    i: uint64 = 0
    while i < 16:
        _dm_aes_block_st[i] = in_blk[i] ^ rk[i]
        i = i + 1
    rnd: uint64 = 1
    while rnd <= 13:
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_sbox[_dm_aes_block_st[i]]
            i = i + 1
        # ShiftRows
        t1: uint8 = _dm_aes_block_st[1]
        _dm_aes_block_st[1] = _dm_aes_block_st[5]
        _dm_aes_block_st[5] = _dm_aes_block_st[9]
        _dm_aes_block_st[9] = _dm_aes_block_st[13]
        _dm_aes_block_st[13] = t1
        t2a: uint8 = _dm_aes_block_st[2]
        t2b: uint8 = _dm_aes_block_st[6]
        _dm_aes_block_st[2] = _dm_aes_block_st[10]
        _dm_aes_block_st[6] = _dm_aes_block_st[14]
        _dm_aes_block_st[10] = t2a
        _dm_aes_block_st[14] = t2b
        t3: uint8 = _dm_aes_block_st[15]
        _dm_aes_block_st[15] = _dm_aes_block_st[11]
        _dm_aes_block_st[11] = _dm_aes_block_st[7]
        _dm_aes_block_st[7] = _dm_aes_block_st[3]
        _dm_aes_block_st[3] = t3
        # MixColumns
        c: uint64 = 0
        while c < 4:
            s0: uint8 = _dm_aes_block_st[c * 4 + 0]
            s1: uint8 = _dm_aes_block_st[c * 4 + 1]
            s2: uint8 = _dm_aes_block_st[c * 4 + 2]
            s3: uint8 = _dm_aes_block_st[c * 4 + 3]
            x0: uint8 = _dm_aes_xtime(s0)
            x1: uint8 = _dm_aes_xtime(s1)
            x2: uint8 = _dm_aes_xtime(s2)
            x3: uint8 = _dm_aes_xtime(s3)
            _dm_aes_block_st[c * 4 + 0] = x0 ^ (x1 ^ s1) ^ s2 ^ s3
            _dm_aes_block_st[c * 4 + 1] = s0 ^ x1 ^ (x2 ^ s2) ^ s3
            _dm_aes_block_st[c * 4 + 2] = s0 ^ s1 ^ x2 ^ (x3 ^ s3)
            _dm_aes_block_st[c * 4 + 3] = (x0 ^ s0) ^ s1 ^ s2 ^ x3
            c = c + 1
        rk_base: uint64 = rnd * 16
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_block_st[i] ^ rk[rk_base + i]
            i = i + 1
        rnd = rnd + 1
    # Final round: SubBytes + ShiftRows + AddRoundKey (no MixColumns).
    i = 0
    while i < 16:
        _dm_aes_block_st[i] = _dm_aes_sbox[_dm_aes_block_st[i]]
        i = i + 1
    t1f: uint8 = _dm_aes_block_st[1]
    _dm_aes_block_st[1] = _dm_aes_block_st[5]
    _dm_aes_block_st[5] = _dm_aes_block_st[9]
    _dm_aes_block_st[9] = _dm_aes_block_st[13]
    _dm_aes_block_st[13] = t1f
    t2af: uint8 = _dm_aes_block_st[2]
    t2bf: uint8 = _dm_aes_block_st[6]
    _dm_aes_block_st[2] = _dm_aes_block_st[10]
    _dm_aes_block_st[6] = _dm_aes_block_st[14]
    _dm_aes_block_st[10] = t2af
    _dm_aes_block_st[14] = t2bf
    t3f: uint8 = _dm_aes_block_st[15]
    _dm_aes_block_st[15] = _dm_aes_block_st[11]
    _dm_aes_block_st[11] = _dm_aes_block_st[7]
    _dm_aes_block_st[7] = _dm_aes_block_st[3]
    _dm_aes_block_st[3] = t3f
    i = 0
    while i < 16:
        out_blk[i] = _dm_aes_block_st[i] ^ rk[14 * 16 + i]
        i = i + 1


def _dm_aes256_decrypt(rk: Ptr[uint8], out_blk: Ptr[uint8],
                       in_blk: Ptr[uint8]):
    # Inverse cipher (FIPS 197 §5.3) — the equivalent-inverse-free
    # straightforward form: AddRoundKey(last), then 13 rounds of
    # InvShiftRows, InvSubBytes, AddRoundKey, InvMixColumns, then a final
    # InvShiftRows + InvSubBytes + AddRoundKey(0).
    i: uint64 = 0
    while i < 16:
        _dm_aes_block_st[i] = in_blk[i] ^ rk[14 * 16 + i]
        i = i + 1
    rnd: int64 = 13
    while rnd >= 1:
        # InvShiftRows: row r is right-rotated by r columns.
        t1: uint8 = _dm_aes_block_st[13]
        _dm_aes_block_st[13] = _dm_aes_block_st[9]
        _dm_aes_block_st[9] = _dm_aes_block_st[5]
        _dm_aes_block_st[5] = _dm_aes_block_st[1]
        _dm_aes_block_st[1] = t1
        t2a: uint8 = _dm_aes_block_st[2]
        t2b: uint8 = _dm_aes_block_st[6]
        _dm_aes_block_st[2] = _dm_aes_block_st[10]
        _dm_aes_block_st[6] = _dm_aes_block_st[14]
        _dm_aes_block_st[10] = t2a
        _dm_aes_block_st[14] = t2b
        t3: uint8 = _dm_aes_block_st[3]
        _dm_aes_block_st[3] = _dm_aes_block_st[7]
        _dm_aes_block_st[7] = _dm_aes_block_st[11]
        _dm_aes_block_st[11] = _dm_aes_block_st[15]
        _dm_aes_block_st[15] = t3
        # InvSubBytes
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_isbox[_dm_aes_block_st[i]]
            i = i + 1
        # AddRoundKey
        rk_base: uint64 = cast[uint64](rnd) * 16
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_block_st[i] ^ rk[rk_base + i]
            i = i + 1
        # InvMixColumns
        c: uint64 = 0
        while c < 4:
            s0: uint8 = _dm_aes_block_st[c * 4 + 0]
            s1: uint8 = _dm_aes_block_st[c * 4 + 1]
            s2: uint8 = _dm_aes_block_st[c * 4 + 2]
            s3: uint8 = _dm_aes_block_st[c * 4 + 3]
            _dm_aes_block_st[c * 4 + 0] = _dm_aes_gfmul(s0, 14) \
                ^ _dm_aes_gfmul(s1, 11) ^ _dm_aes_gfmul(s2, 13) \
                ^ _dm_aes_gfmul(s3, 9)
            _dm_aes_block_st[c * 4 + 1] = _dm_aes_gfmul(s0, 9) \
                ^ _dm_aes_gfmul(s1, 14) ^ _dm_aes_gfmul(s2, 11) \
                ^ _dm_aes_gfmul(s3, 13)
            _dm_aes_block_st[c * 4 + 2] = _dm_aes_gfmul(s0, 13) \
                ^ _dm_aes_gfmul(s1, 9) ^ _dm_aes_gfmul(s2, 14) \
                ^ _dm_aes_gfmul(s3, 11)
            _dm_aes_block_st[c * 4 + 3] = _dm_aes_gfmul(s0, 11) \
                ^ _dm_aes_gfmul(s1, 13) ^ _dm_aes_gfmul(s2, 9) \
                ^ _dm_aes_gfmul(s3, 14)
            c = c + 1
        rnd = rnd - 1
    # Final round: InvShiftRows + InvSubBytes + AddRoundKey(0).
    t1f: uint8 = _dm_aes_block_st[13]
    _dm_aes_block_st[13] = _dm_aes_block_st[9]
    _dm_aes_block_st[9] = _dm_aes_block_st[5]
    _dm_aes_block_st[5] = _dm_aes_block_st[1]
    _dm_aes_block_st[1] = t1f
    t2af: uint8 = _dm_aes_block_st[2]
    t2bf: uint8 = _dm_aes_block_st[6]
    _dm_aes_block_st[2] = _dm_aes_block_st[10]
    _dm_aes_block_st[6] = _dm_aes_block_st[14]
    _dm_aes_block_st[10] = t2af
    _dm_aes_block_st[14] = t2bf
    t3f: uint8 = _dm_aes_block_st[3]
    _dm_aes_block_st[3] = _dm_aes_block_st[7]
    _dm_aes_block_st[7] = _dm_aes_block_st[11]
    _dm_aes_block_st[11] = _dm_aes_block_st[15]
    _dm_aes_block_st[15] = t3f
    i = 0
    while i < 16:
        _dm_aes_block_st[i] = _dm_aes_isbox[_dm_aes_block_st[i]]
        i = i + 1
    i = 0
    while i < 16:
        out_blk[i] = _dm_aes_block_st[i] ^ rk[i]
        i = i + 1


# =========================================================================
# AES-XTS (IEEE Std 1619-2007) — the aes-xts-plain64 sector transform
# =========================================================================
#
# XTS encrypts/decrypts a sector as a sequence of 16-byte blocks under a
# data key, masked by a per-block tweak. The tweak for block 0 of a
# sector is T0 = AES_tweakkey(IV) where IV = the 64-bit sector number
# little-endian in a 16-byte block (dm-crypt "plain64"). For each
# subsequent block the tweak is multiplied by alpha = x in GF(2^128)
# (the polynomial x^128 + x^7 + x^2 + x + 1, LSB-first byte order).
#   encrypt:  C = AES_datakey(P ^ T) ^ T
#   decrypt:  P = AES_datakey^-1(C ^ T) ^ T
# A 512-byte sector is exactly 32 whole AES blocks, so no ciphertext
# stealing is ever required.

_dm_xts_tweak:  Array[16, uint8]   # running tweak T for the current sector
_dm_xts_tmp:    Array[16, uint8]   # P ^ T / C ^ T scratch


def _dm_xts_mul_alpha(t: Ptr[uint8]):
    # Multiply the 128-bit value t by alpha = x in GF(2^128), little-
    # endian byte order (IEEE 1619). Left-shift the whole 128-bit value
    # by one bit; if the high bit (bit 127) carried out, XOR 0x87 into
    # byte 0.
    carry: uint64 = 0
    i: uint64 = 0
    while i < 16:
        cur: uint64 = cast[uint64](t[i]) & 0xFF
        newv: uint64 = ((cur << 1) | carry) & 0xFF
        carry = (cur >> 7) & 1
        t[i] = cast[uint8](newv)
        i = i + 1
    if carry != 0:
        t[0] = t[0] ^ 0x87


def _dm_xts_init_tweak(sector: uint64):
    # T0 = AES_tweakkey(plain64 IV). IV = sector number little-endian in
    # bytes 0..7, zero in 8..15.
    iv: Array[16, uint8]
    i: uint64 = 0
    while i < 8:
        iv[i] = cast[uint8]((sector >> (i * 8)) & 0xFF)
        i = i + 1
    while i < 16:
        iv[i] = 0
        i = i + 1
    _dm_aes256_encrypt(cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]),
                       cast[Ptr[uint8]](&_dm_xts_tweak[0]),
                       cast[Ptr[uint8]](&iv[0]))


def _dm_xts_encrypt_sector(sector: uint64,
                           dst: Ptr[uint8], src: Ptr[uint8]):
    # XTS-encrypt one 512-byte sector (32 blocks). Assumes the data and
    # tweak schedules are already expanded into _dm_aes_rk_data /
    # _dm_aes_rk_tweak.
    _dm_xts_init_tweak(sector)
    tw:  Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tweak[0])
    tmp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tmp[0])
    dkey: Ptr[uint8] = cast[Ptr[uint8]](&_dm_aes_rk_data[0])
    blk: uint64 = 0
    while blk < 32:
        base: uint64 = blk * 16
        j: uint64 = 0
        while j < 16:
            tmp[j] = src[base + j] ^ tw[j]
            j = j + 1
        _dm_aes256_encrypt(dkey, cast[Ptr[uint8]](
            cast[uint64](dst) + base), tmp)
        j = 0
        while j < 16:
            dst[base + j] = dst[base + j] ^ tw[j]
            j = j + 1
        _dm_xts_mul_alpha(tw)
        blk = blk + 1


def _dm_xts_decrypt_sector(sector: uint64,
                           dst: Ptr[uint8], src: Ptr[uint8]):
    # XTS-decrypt one 512-byte sector (32 blocks).
    _dm_xts_init_tweak(sector)
    tw:  Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tweak[0])
    tmp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tmp[0])
    dkey: Ptr[uint8] = cast[Ptr[uint8]](&_dm_aes_rk_data[0])
    blk: uint64 = 0
    while blk < 32:
        base: uint64 = blk * 16
        j: uint64 = 0
        while j < 16:
            tmp[j] = src[base + j] ^ tw[j]
            j = j + 1
        _dm_aes256_decrypt(dkey, cast[Ptr[uint8]](
            cast[uint64](dst) + base), tmp)
        j = 0
        while j < 16:
            dst[base + j] = dst[base + j] ^ tw[j]
            j = j + 1
        _dm_xts_mul_alpha(tw)
        blk = blk + 1


# =========================================================================
# SHA-256 (FIPS 180-4) — self-contained one-shot, for dm-verity
# =========================================================================
#
# dm-verity's Merkle tree hashes every data block and every hash block with
# SHA-256. The tree's only existing SHA-256 lives in drivers/net/tls.ad,
# but that one is welded to the TLS module's running-transcript state
# (tls_sha_state / tls_sha_buf) and pulls the whole network import closure
# in with it. dm runs in the block layer with no business importing the TLS
# stack, so — exactly as the brief sanctions — this is a small, fully
# self-contained SHA-256 owning its own .bss working state. dm I/O is
# serialised through the synchronous block layer, so the single shared
# working buffer/state is safe (no two verity hashes overlap).

_dm_sha_k:       Array[64, uint32]
_dm_sha_k_init:  int32 = 0
_dm_sha_state:   Array[8, uint32]    # running H[0..7]
_dm_sha_buf:     Array[64, uint8]    # 512-bit block accumulator
_dm_sha_buflen:  uint64 = 0
_dm_sha_total:   uint64 = 0          # total message bits
_dm_sha_w:       Array[64, uint32]   # message schedule scratch


def _dm_sha_rotr32(v: uint32, n: uint64) -> uint32:
    x:  uint64 = cast[uint64](v) & 0xFFFFFFFF
    lo: uint64 = x >> n
    hi: uint64 = (x << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


def _dm_sha_init_k():
    if _dm_sha_k_init != 0:
        return
    _dm_sha_k_init = 1
    _dm_sha_k[0]  = 0x428A2F98
    _dm_sha_k[1]  = 0x71374491
    _dm_sha_k[2]  = 0xB5C0FBCF
    _dm_sha_k[3]  = 0xE9B5DBA5
    _dm_sha_k[4]  = 0x3956C25B
    _dm_sha_k[5]  = 0x59F111F1
    _dm_sha_k[6]  = 0x923F82A4
    _dm_sha_k[7]  = 0xAB1C5ED5
    _dm_sha_k[8]  = 0xD807AA98
    _dm_sha_k[9]  = 0x12835B01
    _dm_sha_k[10] = 0x243185BE
    _dm_sha_k[11] = 0x550C7DC3
    _dm_sha_k[12] = 0x72BE5D74
    _dm_sha_k[13] = 0x80DEB1FE
    _dm_sha_k[14] = 0x9BDC06A7
    _dm_sha_k[15] = 0xC19BF174
    _dm_sha_k[16] = 0xE49B69C1
    _dm_sha_k[17] = 0xEFBE4786
    _dm_sha_k[18] = 0x0FC19DC6
    _dm_sha_k[19] = 0x240CA1CC
    _dm_sha_k[20] = 0x2DE92C6F
    _dm_sha_k[21] = 0x4A7484AA
    _dm_sha_k[22] = 0x5CB0A9DC
    _dm_sha_k[23] = 0x76F988DA
    _dm_sha_k[24] = 0x983E5152
    _dm_sha_k[25] = 0xA831C66D
    _dm_sha_k[26] = 0xB00327C8
    _dm_sha_k[27] = 0xBF597FC7
    _dm_sha_k[28] = 0xC6E00BF3
    _dm_sha_k[29] = 0xD5A79147
    _dm_sha_k[30] = 0x06CA6351
    _dm_sha_k[31] = 0x14292967
    _dm_sha_k[32] = 0x27B70A85
    _dm_sha_k[33] = 0x2E1B2138
    _dm_sha_k[34] = 0x4D2C6DFC
    _dm_sha_k[35] = 0x53380D13
    _dm_sha_k[36] = 0x650A7354
    _dm_sha_k[37] = 0x766A0ABB
    _dm_sha_k[38] = 0x81C2C92E
    _dm_sha_k[39] = 0x92722C85
    _dm_sha_k[40] = 0xA2BFE8A1
    _dm_sha_k[41] = 0xA81A664B
    _dm_sha_k[42] = 0xC24B8B70
    _dm_sha_k[43] = 0xC76C51A3
    _dm_sha_k[44] = 0xD192E819
    _dm_sha_k[45] = 0xD6990624
    _dm_sha_k[46] = 0xF40E3585
    _dm_sha_k[47] = 0x106AA070
    _dm_sha_k[48] = 0x19A4C116
    _dm_sha_k[49] = 0x1E376C08
    _dm_sha_k[50] = 0x2748774C
    _dm_sha_k[51] = 0x34B0BCB5
    _dm_sha_k[52] = 0x391C0CB3
    _dm_sha_k[53] = 0x4ED8AA4A
    _dm_sha_k[54] = 0x5B9CCA4F
    _dm_sha_k[55] = 0x682E6FF3
    _dm_sha_k[56] = 0x748F82EE
    _dm_sha_k[57] = 0x78A5636F
    _dm_sha_k[58] = 0x84C87814
    _dm_sha_k[59] = 0x8CC70208
    _dm_sha_k[60] = 0x90BEFFFA
    _dm_sha_k[61] = 0xA4506CEB
    _dm_sha_k[62] = 0xBEF9A3F7
    _dm_sha_k[63] = 0xC67178F2


def _dm_sha_compress():
    # Expand 16 big-endian words -> 64, run 64 rounds, fold into state.
    block_ptr: Ptr[uint8] = cast[Ptr[uint8]](&_dm_sha_buf[0])
    i: uint64 = 0
    while i < 16:
        b0: uint32 = cast[uint32](block_ptr[i * 4 + 0])
        b1: uint32 = cast[uint32](block_ptr[i * 4 + 1])
        b2: uint32 = cast[uint32](block_ptr[i * 4 + 2])
        b3: uint32 = cast[uint32](block_ptr[i * 4 + 3])
        _dm_sha_w[i] = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        i = i + 1
    while i < 64:
        s0: uint32 = _dm_sha_rotr32(_dm_sha_w[i - 15], 7) \
            ^ _dm_sha_rotr32(_dm_sha_w[i - 15], 18) \
            ^ (_dm_sha_w[i - 15] >> 3)
        s1: uint32 = _dm_sha_rotr32(_dm_sha_w[i - 2], 17) \
            ^ _dm_sha_rotr32(_dm_sha_w[i - 2], 19) \
            ^ (_dm_sha_w[i - 2] >> 10)
        sum_v: uint64 = (cast[uint64](_dm_sha_w[i - 16]) & 0xFFFFFFFF) \
            + (cast[uint64](s0) & 0xFFFFFFFF) \
            + (cast[uint64](_dm_sha_w[i - 7]) & 0xFFFFFFFF) \
            + (cast[uint64](s1) & 0xFFFFFFFF)
        _dm_sha_w[i] = cast[uint32](sum_v & 0xFFFFFFFF)
        i = i + 1

    a: uint32 = _dm_sha_state[0]
    b: uint32 = _dm_sha_state[1]
    c: uint32 = _dm_sha_state[2]
    d: uint32 = _dm_sha_state[3]
    e: uint32 = _dm_sha_state[4]
    f: uint32 = _dm_sha_state[5]
    g: uint32 = _dm_sha_state[6]
    h: uint32 = _dm_sha_state[7]
    i = 0
    while i < 64:
        S1: uint32 = _dm_sha_rotr32(e, 6) ^ _dm_sha_rotr32(e, 11) \
            ^ _dm_sha_rotr32(e, 25)
        ch: uint32 = (e & f) ^ ((~e) & g)
        t1_64: uint64 = (cast[uint64](h) & 0xFFFFFFFF) \
            + (cast[uint64](S1) & 0xFFFFFFFF) \
            + (cast[uint64](ch) & 0xFFFFFFFF) \
            + (cast[uint64](_dm_sha_k[i]) & 0xFFFFFFFF) \
            + (cast[uint64](_dm_sha_w[i]) & 0xFFFFFFFF)
        t1: uint32 = cast[uint32](t1_64 & 0xFFFFFFFF)
        S0: uint32 = _dm_sha_rotr32(a, 2) ^ _dm_sha_rotr32(a, 13) \
            ^ _dm_sha_rotr32(a, 22)
        maj: uint32 = (a & b) ^ (a & c) ^ (b & c)
        t2_64: uint64 = (cast[uint64](S0) & 0xFFFFFFFF) \
            + (cast[uint64](maj) & 0xFFFFFFFF)
        t2: uint32 = cast[uint32](t2_64 & 0xFFFFFFFF)
        h = g
        g = f
        f = e
        d64: uint64 = (cast[uint64](d) & 0xFFFFFFFF) \
            + (cast[uint64](t1) & 0xFFFFFFFF)
        e = cast[uint32](d64 & 0xFFFFFFFF)
        d = c
        c = b
        b = a
        a64: uint64 = (cast[uint64](t1) & 0xFFFFFFFF) \
            + (cast[uint64](t2) & 0xFFFFFFFF)
        a = cast[uint32](a64 & 0xFFFFFFFF)
        i = i + 1
    sv0: uint64 = cast[uint64](_dm_sha_state[0]) + cast[uint64](a)
    sv1: uint64 = cast[uint64](_dm_sha_state[1]) + cast[uint64](b)
    sv2: uint64 = cast[uint64](_dm_sha_state[2]) + cast[uint64](c)
    sv3: uint64 = cast[uint64](_dm_sha_state[3]) + cast[uint64](d)
    sv4: uint64 = cast[uint64](_dm_sha_state[4]) + cast[uint64](e)
    sv5: uint64 = cast[uint64](_dm_sha_state[5]) + cast[uint64](f)
    sv6: uint64 = cast[uint64](_dm_sha_state[6]) + cast[uint64](g)
    sv7: uint64 = cast[uint64](_dm_sha_state[7]) + cast[uint64](h)
    _dm_sha_state[0] = cast[uint32](sv0 & 0xFFFFFFFF)
    _dm_sha_state[1] = cast[uint32](sv1 & 0xFFFFFFFF)
    _dm_sha_state[2] = cast[uint32](sv2 & 0xFFFFFFFF)
    _dm_sha_state[3] = cast[uint32](sv3 & 0xFFFFFFFF)
    _dm_sha_state[4] = cast[uint32](sv4 & 0xFFFFFFFF)
    _dm_sha_state[5] = cast[uint32](sv5 & 0xFFFFFFFF)
    _dm_sha_state[6] = cast[uint32](sv6 & 0xFFFFFFFF)
    _dm_sha_state[7] = cast[uint32](sv7 & 0xFFFFFFFF)


def _dm_sha_reset():
    _dm_sha_init_k()
    _dm_sha_state[0] = 0x6A09E667
    _dm_sha_state[1] = 0xBB67AE85
    _dm_sha_state[2] = 0x3C6EF372
    _dm_sha_state[3] = 0xA54FF53A
    _dm_sha_state[4] = 0x510E527F
    _dm_sha_state[5] = 0x9B05688C
    _dm_sha_state[6] = 0x1F83D9AB
    _dm_sha_state[7] = 0x5BE0CD19
    _dm_sha_buflen = 0
    _dm_sha_total  = 0


def _dm_sha_update(data: Ptr[uint8], n: uint64):
    pos: uint64 = 0
    while pos < n:
        room: uint64 = 64 - _dm_sha_buflen
        take: uint64 = n - pos
        if take > room:
            take = room
        i: uint64 = 0
        while i < take:
            _dm_sha_buf[_dm_sha_buflen + i] = data[pos + i]
            i = i + 1
        _dm_sha_buflen = _dm_sha_buflen + take
        pos = pos + take
        if _dm_sha_buflen == 64:
            _dm_sha_compress()
            _dm_sha_buflen = 0
    _dm_sha_total = _dm_sha_total + n * 8


def _dm_sha_finish_into(out_hash: Ptr[uint8]):
    saved_bits: uint64 = _dm_sha_total
    _dm_sha_buf[_dm_sha_buflen] = 0x80
    _dm_sha_buflen = _dm_sha_buflen + 1
    if _dm_sha_buflen > 56:
        while _dm_sha_buflen < 64:
            _dm_sha_buf[_dm_sha_buflen] = 0
            _dm_sha_buflen = _dm_sha_buflen + 1
        _dm_sha_compress()
        _dm_sha_buflen = 0
    while _dm_sha_buflen < 56:
        _dm_sha_buf[_dm_sha_buflen] = 0
        _dm_sha_buflen = _dm_sha_buflen + 1
    i: uint64 = 0
    while i < 8:
        shift: uint64 = (7 - i) * 8
        _dm_sha_buf[56 + i] = cast[uint8]((saved_bits >> shift) & 0xFF)
        i = i + 1
    _dm_sha_compress()
    i = 0
    while i < 8:
        w: uint32 = _dm_sha_state[i]
        out_hash[i * 4 + 0] = cast[uint8]((w >> 24) & 0xFF)
        out_hash[i * 4 + 1] = cast[uint8]((w >> 16) & 0xFF)
        out_hash[i * 4 + 2] = cast[uint8]((w >> 8) & 0xFF)
        out_hash[i * 4 + 3] = cast[uint8](w & 0xFF)
        i = i + 1


def _dm_sha256_oneshot(data: Ptr[uint8], n: uint64, out_hash: Ptr[uint8]):
    # One-shot SHA-256: hash `n` bytes at `data`, emit 32-byte digest.
    _dm_sha_reset()
    _dm_sha_update(data, n)
    _dm_sha_finish_into(out_hash)


# =========================================================================
# Device-mapper core
# =========================================================================

DM_TARGET_NONE:          uint32 = 0
DM_TARGET_LINEAR:        uint32 = 1
DM_TARGET_CRYPT:         uint32 = 2
DM_TARGET_SNAPSHOT:      uint32 = 3   # frozen CoW view (reads exc-store/origin)
DM_TARGET_SNAPSHOT_ORIGIN: uint32 = 4 # origin that performs copy-on-write
DM_TARGET_INTEGRITY:     uint32 = 5   # per-sector crc32c integrity tags
DM_TARGET_THIN:          uint32 = 6   # thin-provisioned (on-demand alloc)
DM_TARGET_VERITY:        uint32 = 7   # read-only Merkle-tree (sha256) verify
DM_TARGET_CACHE:         uint32 = 8   # fast cache device fronting slow origin
DM_TARGET_ERA:           uint32 = 9   # per-chunk write-era (generation) tracking
DM_TARGET_WRITECACHE:    uint32 = 10  # write-back cache (writes -> fast device)
DM_TARGET_DELAY:         uint32 = 11  # per-op read/write delay over a linear remap

DM_KEY_LEN:      uint64 = 64       # AES-256-XTS: 32B data + 32B tweak key
DM_MAX_TARGETS:  uint64 = 8        # targets per mapped device
DM_MAX_DEVICES:  uint64 = 8        # mapped devices system-wide
DM_NAME_LEN:     uint64 = 16


class DmTarget:
    # One row of a mapped device's table. The virtual span this target
    # covers is [start_sector, start_sector + length). On an I/O whose
    # virtual LBA falls in that span, the offset within the target is
    # (vlba - start_sector); the underlying LBA is
    # (under_start + offset_in_target). `ttype` selects linear vs crypt.
    ttype:        uint32
    pad:          uint32
    start_sector: uint64           # first virtual sector this target owns
    length:       uint64           # number of sectors in the span
    under_slot:   int32            # underlying block-device slot
    snap_ctx:     int32            # snapshot-context index (-1 if not a snap)
    under_start:  uint64           # base LBA on the underlying device


class MappedDevice:
    # A virtual block device described by a table of targets. Registered
    # with the block layer under `name` so the rest of the kernel reads
    # and writes through it transparently.
    used:        uint32
    n_targets:   uint32
    capacity:    uint64            # total virtual sectors (sum of spans)
    self_slot:   int32             # this mapped device's own block slot
    pad:         uint32
    targets:     Array[8, DmTarget]
    # AES-256-XTS key material (crypt targets only): 32-byte data key
    # followed by 32-byte tweak key (the LUKS/dm-crypt 64-byte key split).
    key:         Array[64, uint8]


# =========================================================================
# dm-snapshot — copy-on-write context (Linux drivers/md/dm-snap.c)
# =========================================================================
#
# A snapshot pairs an ORIGIN device with a separate EXCEPTION-STORE device.
# The snapshot mapped device presents a FROZEN point-in-time view of the
# origin. Address space is divided into fixed-size CHUNKS. The first time a
# given origin chunk is WRITTEN (through the snapshot-origin target), the
# chunk's ORIGINAL contents are first COPIED into a freshly allocated slot
# in the exception store (copy-on-write); an exception-table entry records
# origin-chunk -> exception-store-chunk, and the per-chunk "remapped" bit is
# set. Thereafter:
#   * a READ through the SNAPSHOT view returns the exception-store copy for
#     any remapped chunk (the OLD pre-image), else falls through to origin;
#   * a READ through the ORIGIN returns the live (NEW) data.
# This is exactly Linux dm-snapshot's CoW exception model, in memory.

DM_SNAP_MAX:        uint64 = 4        # snapshot contexts system-wide
DM_SNAP_MAX_CHUNKS: uint64 = 256      # origin chunks tracked per snapshot


class DmSnapContext:
    used:          uint32
    pad:           uint32
    origin_slot:   int32              # underlying origin block device
    exc_slot:      int32              # underlying exception-store device
    chunk_sectors: uint64             # CoW granularity (sectors per chunk)
    nchunks:       uint64             # origin chunks covered
    next_exc:      uint64             # next free exception-store chunk
    exc_capacity:  uint64             # exception-store chunks available
    # exc_map[origin_chunk] = exception-store chunk holding its pre-image.
    exc_map:       Array[256, uint64]
    # remapped[origin_chunk] = 1 once the chunk has been CoW'd.
    remapped:      Array[256, uint8]


dm_snap_ctxs: Array[4, DmSnapContext]


# =========================================================================
# dm-integrity — per-sector cryptographic integrity tags
# (Linux drivers/md/dm-integrity.c)
# =========================================================================
#
# Each mapped sector carries a small integrity TAG computed over its data.
# On WRITE the tag is (re)computed from the sector bytes and stashed in a
# dedicated METADATA tag store; on READ the tag is recomputed over the data
# fetched from the backing device and compared against the stored tag. A
# mismatch — the sector was corrupted underneath us (bit-rot, a torn write,
# or a malicious tamper) — is reported as an I/O ERROR rather than silently
# handing back the corrupt bytes. This is exactly Linux dm-integrity's
# detection guarantee.
#
# The tag is a crc32c over the sector's 512 bytes, SALTED with the sector
# index (the underlying LBA folded into the running register before the
# data). The salt binds a tag to its sector position, so a valid sector
# relocated to a different LBA also fails verification — a sector can't be
# replayed/relocated undetected. (Linux dm-integrity supports HMAC tags for
# the keyed case; crc32c is its CRC tag mode, which is what we model here.)

DM_INTEG_MAX:         uint64 = 4      # integrity contexts system-wide
DM_INTEG_MAX_SECTORS: uint64 = 256    # tagged sectors per context


class DmIntegContext:
    used:        uint32
    pad:         uint32
    nsectors:    uint64                # number of tagged sectors
    # valid[s] = 1 once sector s has a tag written (a read of an unwritten
    # sector is allowed to pass with no stored tag yet).
    valid:       Array[256, uint8]
    # tags[s] = the crc32c integrity tag for tagged sector s.
    tags:        Array[256, uint32]


dm_integ_ctxs: Array[4, DmIntegContext]


# =========================================================================
# dm-thin — thin provisioning (Linux drivers/md/dm-thin.c)
# =========================================================================
#
# A thin POOL owns a fixed-size DATA device (here an in-kernel ramdisk).
# Physical storage is carved into fixed-size BLOCKS (block_sectors sectors
# each). A THIN device presents a large VIRTUAL address space but starts
# with ZERO physical blocks allocated: nothing in the pool is consumed
# until data is actually written. The first WRITE to a virtual block
# allocates a fresh pool block from the pool's free-block allocator,
# records a (thin virtual block -> pool physical block) mapping, and writes
# the data there. A READ of an UNPROVISIONED (never-written) virtual block
# returns ZEROS and consumes no pool block. Subsequent reads/writes of a
# provisioned virtual block hit its mapped pool block. Because the virtual
# size can vastly exceed the pool's physical capacity, over-provisioning is
# directly observable as (virtual blocks >> currently allocated blocks).
# A write that cannot allocate (pool exhausted) returns an I/O error.
#
# This is exactly Linux dm-thin's on-demand single-provisioning model: one
# shared pool, many thin volumes that lazily claim blocks from it.

DM_THIN_POOL_MAX:    uint64 = 2        # thin pools system-wide
DM_THIN_DEV_MAX:     uint64 = 4        # thin devices system-wide
DM_THIN_MAX_PBLOCKS: uint64 = 256      # pool physical blocks per pool
DM_THIN_MAX_VBLOCKS: uint64 = 1024     # virtual blocks tracked per thin dev


class DmThinPool:
    used:          uint32
    pad:           uint32
    data_slot:     int32               # underlying pool DATA block device
    pad2:          uint32
    block_sectors: uint64              # sectors per pool block (alloc unit)
    nblocks:       uint64              # total pool blocks (physical capacity)
    nallocated:    uint64              # pool blocks currently handed out
    # free[b] = 1 while pool block b is unallocated and available.
    free:          Array[256, uint8]


class DmThinDev:
    used:          uint32
    pad:           uint32
    pool_idx:      int32               # owning thin pool index
    pad2:          uint32
    nvblocks:      uint64              # virtual blocks this thin dev presents
    # mapped[v] = 1 once virtual block v has a pool block; pmap[v] holds it.
    mapped:        Array[1024, uint8]
    pmap:          Array[1024, uint64]


dm_thin_pools: Array[2, DmThinPool]
dm_thin_devs:  Array[4, DmThinDev]


# =========================================================================
# dm-verity — transparent read-only integrity via a Merkle hash tree
# (Linux drivers/md/dm-verity.c)
# =========================================================================
#
# dm-verity presents a READ-ONLY block device whose every data block is
# verified against a cryptographic Merkle hash tree rooted at a single
# trusted ROOT HASH. The tree is built like this:
#
#   * BLOCK granularity is a verity BLOCK = 8 sectors = 4096 bytes (the
#     Linux default). The data device holds nblocks such blocks.
#   * Each data block's LEAF hash is sha256(salt || block_bytes). The salt
#     is a per-target random value (real verity's `salt=`), mixed in first
#     so two targets over identical data get different trees.
#   * Leaf hashes are PACKED, 32 bytes each, into HASH BLOCKS on a separate
#     hash device — 4096/32 = 128 leaf hashes per hash block. Each hash
#     block is itself hashed (sha256(salt || hash_block_bytes)) to form the
#     next level up, and so on until a single block remains: its hash is
#     the ROOT HASH, which is the only value the verifier trusts.
#
# On READ of a data block:
#   1. recompute leaf = sha256(salt || data) and compare it to the stored
#      leaf in its hash block (level 0);
#   2. walk UP the tree: recompute each parent = sha256(salt || child_block)
#      and compare to the entry stored one level up, until the top hash
#      block is reached and its recomputed hash is compared to the trusted
#      ROOT. Any mismatch — a flipped data byte OR a flipped hash-tree byte
#      OR a root that does not match the trusted value — fails the read with
#      an I/O error (-5) rather than returning unverified bytes. This is
#      exactly dm-verity's tamper-detection guarantee.
#
# WRITES are rejected: a verity device is strictly read-only (dm-verity is
# a verification target, not a writeback one).
#
# Scale here: VERITY_BLOCK = 4096, HASHES_PER_BLOCK = 128, so up to 128
# data blocks fit under ONE level-0 hash block whose hash IS the root —
# i.e. the test tree is leaves(level 0 hash block) -> root, a real
# two-level Merkle path verified end to end.

DM_VERITY_MAX:         uint64 = 4      # verity contexts system-wide
DM_VERITY_BLOCK:       uint64 = 4096   # bytes per verity data/hash block
DM_VERITY_BLOCK_SECS:  uint64 = 8      # sectors per verity block (4096/512)
DM_VERITY_DIGEST:      uint64 = 32     # sha256 output bytes
DM_VERITY_PER_BLOCK:   uint64 = 128    # 4096/32 leaf digests per hash block
DM_VERITY_MAX_BLOCKS:  uint64 = 128    # data blocks per context (<= one L0 blk)
DM_VERITY_SALT_LEN:    uint64 = 32     # per-target salt bytes


class DmVerityContext:
    used:        uint32
    pad:         uint32
    data_slot:   int32                 # underlying DATA block device
    hash_slot:   int32                 # underlying HASH-TREE block device
    data_start:  uint64                # first data sector on the data device
    hash_start:  uint64                # first sector of the L0 hash block
    nblocks:     uint64                # number of data blocks covered
    # Trusted root hash: sha256(salt || level-0 hash block). The ONE value
    # the verifier anchors to. Built at create time over clean data.
    root:        Array[32, uint8]
    # Per-target salt mixed into every hash (leaf and interior).
    salt:        Array[32, uint8]


dm_verity_ctxs: Array[4, DmVerityContext]


# =========================================================================
# dm-cache — fast cache device fronting a slow origin (Linux dm-cache /
# drivers/md/dm-cache-target.c)
# =========================================================================
#
# dm-cache layers a SMALL, FAST cache device in front of a LARGE, SLOW
# origin device, transparently caching hot blocks on the fast device. The
# virtual mapped device presents the FULL origin address space; the cache
# is invisible — reads and writes always look like they hit the origin, but
# in practice frequently-touched blocks live on (and are served from) the
# fast cache.
#
# CACHE BLOCK GRANULARITY: the address space is carved into fixed-size
# CACHE BLOCKS of `block_sectors` sectors each. The fast cache device holds
# a fixed number (`ncache`) of SLOTS, each able to hold exactly one origin
# block. A cache mapping table records, per slot, which origin block it
# currently holds plus VALID and DIRTY bits and a last-use timestamp.
#
# READ path:
#   * HIT  — the requested origin block is resident in a valid slot: serve
#            the bytes straight from the fast cache device.
#   * MISS — not resident: read the block from the slow origin, PROMOTE it
#            into a cache slot (choosing a victim by LRU; if the victim is
#            DIRTY its contents are written BACK to the origin first so no
#            data is lost), and serve the freshly promoted bytes. A second
#            read of the same block now HITs.
#
# WRITE path depends on MODE:
#   * WRITETHROUGH — the write updates BOTH the cache slot (promoting on a
#                    miss) AND the origin, so the cache stays CLEAN: the
#                    origin is always coherent and a slot can be evicted with
#                    no writeback.
#   * WRITEBACK    — the write updates ONLY the cache slot and marks it
#                    DIRTY; the origin is left STALE. The dirty data reaches
#                    the origin only when the slot is evicted, or when an
#                    explicit FLUSH (dm_cache_writeback_all) walks every
#                    dirty slot and writes it back, after which the origin
#                    again matches the cache.
#
# REPLACEMENT POLICY: true LRU. Every access stamps the slot with a
# monotonically increasing clock; eviction picks the valid slot with the
# smallest stamp (the least-recently-used). Empty (invalid) slots are
# filled first.
#
# OBSERVABILITY: per-context hit / miss counters (dm_cache_hits /
# dm_cache_misses) the self-test asserts on, proving promotion and HIT/MISS
# accounting are genuinely computed (a cold read MISSes then promotes; a
# warm read HITs).
#
# This is exactly Linux dm-cache's smq/writeback model in miniature: one
# fast device, one origin, an in-core mapping with LRU eviction, dirty
# writeback, and writethrough/writeback modes.

DM_CACHE_MAX:          uint64 = 2      # cache contexts system-wide
DM_CACHE_MAX_SLOTS:    uint64 = 64     # cache slots per context
DM_CACHE_MAX_BLKSECS:  uint64 = 8      # max sectors per cache block (<= 4096B)

DM_CACHE_WRITETHROUGH: uint32 = 0
DM_CACHE_WRITEBACK:    uint32 = 1


class DmCacheContext:
    used:          uint32
    mode:          uint32              # WRITETHROUGH or WRITEBACK
    cache_slot:    int32               # underlying FAST cache block device
    origin_slot:   int32               # underlying SLOW origin block device
    block_sectors: uint64              # sectors per cache block (alloc unit)
    nblocks:       uint64              # origin blocks the device covers
    ncache:        uint64              # cache slots available (<= nblocks)
    clock:         uint64              # monotonic LRU access stamp source
    hits:          uint64              # read/write HIT count
    misses:        uint64              # read/write MISS count
    # Per-slot mapping. tag[s] = origin block resident in slot s (valid only
    # when valid[s]); dirty[s] = 1 when the slot holds data newer than origin
    # (writeback mode); used[s] = LRU stamp of last access.
    valid:         Array[64, uint8]
    dirty:         Array[64, uint8]
    tag:           Array[64, uint64]
    stamp:         Array[64, uint64]


dm_cache_ctxs: Array[2, DmCacheContext]


# =========================================================================
# dm-era — per-chunk write-era (generation) tracking (Linux drivers/md/
# dm-era-target.c)
# =========================================================================
#
# dm-era sits OVER an origin device and records, per fixed-size CHUNK, the
# ERA in which that chunk was last WRITTEN. An era is a monotonically
# increasing generation counter. The device starts at era 1; a userspace
# `message take_metadata_snapshot`/`message <new_era>` operation ADVANCES
# the current era (here dm_era_advance), bumping the counter so that all
# subsequent writes are stamped with the NEW era.
#
# DATA PATH: a write through the era device is forwarded straight to the
# origin (transparent passthrough — era never alters the data), and the
# touched chunk's era slot is STAMPED with the CURRENT era. A read is a
# plain passthrough to the origin. Because the stamp is the *current* era
# at write time, the era array partitions chunks by the generation in which
# they last changed.
#
# QUERY: dm_era_query_since(target_era) enumerates every chunk whose
# recorded era is >= target_era — i.e. the set of chunks WRITTEN IN OR AFTER
# that generation. This is exactly dm-era's use case: after a snapshot at
# era N, "which blocks changed since N?" drives an INCREMENTAL backup or a
# cache-coherency invalidation after a power failure (only the changed
# blocks need re-copying / re-validating).
#
# PERSISTENCE: the per-chunk era array is written to a dedicated METADATA
# device so it survives a teardown / power loss. Layout on the metadata
# device: sector 0 is a small HEADER (magic, nchunks, current_era);
# sectors 1.. hold the packed uint32 era array (128 era words per 512-byte
# sector). dm_era_persist() flushes the in-core array out; dm_era_reload()
# reads it back. A freshly created device whose metadata carries our magic
# RESUMES from the persisted state (current era + per-chunk eras), modelling
# dm-era's superblock resume.

DM_ERA_MAX:         uint64 = 2        # era contexts system-wide
DM_ERA_MAX_CHUNKS:  uint64 = 256      # origin chunks tracked per era device
DM_ERA_PER_SECTOR:  uint64 = 128      # uint32 era words per 512-byte sector
DM_ERA_MAGIC:       uint32 = 0xE2A0DA7A  # metadata-superblock magic ("eraDATA")


class DmEraContext:
    used:          uint32
    pad:           uint32
    origin_slot:   int32               # underlying ORIGIN block device
    meta_slot:     int32               # underlying METADATA block device
    chunk_sectors: uint64              # sectors per era-tracked chunk
    nchunks:       uint64              # origin chunks covered
    current_era:   uint32              # generation stamped on the next write
    pad2:          uint32
    # era[c] = the era in which chunk c was last written (0 = never written).
    era:           Array[256, uint32]


dm_era_ctxs: Array[2, DmEraContext]


# =========================================================================
# dm-writecache — write-back cache fronting a slow origin (Linux drivers/md/
# dm-writecache.c)
# =========================================================================
#
# dm-writecache layers a FAST cache device (in Linux: an SSD or persistent-
# memory device) in front of a SLOW origin device, caching ONLY WRITES. It
# differs from dm-cache (which caches reads AND writes with a replacement
# policy): writecache's job is purely to make WRITES durable FAST and let
# them drain back to the origin lazily.
#
# DATA PATH:
#   * WRITE — allocate (or reuse) a cache SLOT for the written origin block,
#     write the data into that slot ON THE CACHE DEVICE, mark the slot DIRTY,
#     persist the slot metadata, and ACK. The ORIGIN is NOT touched: the
#     acknowledged write lives only on the (fast, durable) cache device.
#   * READ — if the requested origin block has a DIRTY (not-yet-flushed) cache
#     slot, serve the bytes straight from the cache device (the newest data);
#     otherwise the block was never written through the cache (or has been
#     flushed and the slot freed), so fall through and read the origin.
#   * FLUSH / WRITEBACK — walk every dirty slot, write its data BACK to the
#     origin, clear the dirty flag, and persist the cleared metadata. After a
#     flush the origin holds every acknowledged write and the cache is clean.
#
# DURABILITY / PERSISTENCE (the whole point): an acknowledged write is on the
# cache device BEFORE writeback, and the slot metadata (which origin block
# each slot holds + its dirty flag) is persisted to the cache device's
# SUPERBLOCK/METADATA region. So if the machine crashes after the ACK but
# before writeback, a fresh dm-writecache over the SAME cache device RESUMES
# from the persisted metadata and the un-flushed dirty data is recovered — it
# can still be served on reads and later flushed to the origin. This models
# Linux dm-writecache's recovery from its on-disk (PMEM/SSD) metadata.
#
# CACHE-DEVICE LAYOUT:
#   sector 0                  : superblock (magic, nblocks, nslots,
#                               block_sectors)
#   sectors 1 .. meta_sectors : packed slot metadata, DM_WC_PER_SECTOR slots
#                               per 512-byte sector (each entry: origin block
#                               uint64 + valid uint8 + dirty uint8, 16 bytes)
#   data_start ..             : the slot DATA region; slot s occupies
#                               [data_start + s*block_sectors, +block_sectors)

DM_WC_MAX:          uint64 = 2        # writecache contexts system-wide
DM_WC_MAX_SLOTS:    uint64 = 64       # cache data slots per context
DM_WC_MAX_BLKSECS:  uint64 = 8        # max sectors per cache block (<= 4096B)
DM_WC_PER_SECTOR:   uint64 = 32       # 16-byte slot entries per 512B sector
DM_WC_ENTRY_BYTES:  uint64 = 16       # bytes per packed slot metadata entry
DM_WC_MAGIC:        uint32 = 0x77C0DA7A  # superblock magic ("wcDATA")


class DmWritecacheContext:
    used:          uint32
    pad:           uint32
    cache_slot:    int32               # underlying FAST cache block device
    origin_slot:   int32               # underlying SLOW origin block device
    block_sectors: uint64              # sectors per cache block (alloc unit)
    nblocks:       uint64              # origin blocks the device covers
    nslots:        uint64              # cache data slots available
    data_start:    uint64              # first cache sector of the data region
    # Per-slot mapping. tag[s] = origin block resident in slot s (valid only
    # when valid[s]); dirty[s] = 1 when the slot holds an un-flushed write
    # (data newer than the origin); valid[s] = 1 once the slot is in use.
    valid:         Array[64, uint8]
    dirty:         Array[64, uint8]
    tag:           Array[64, uint64]


dm_wc_ctxs: Array[2, DmWritecacheContext]


# =========================================================================
# dm-delay — per-operation read/write delay over a linear remap
# (Linux drivers/md/dm-delay.c)
# =========================================================================
#
# dm-delay maps a linear range onto an underlying device (exactly like
# dm-linear: virtual sector v -> under_start + v on under_slot, plaintext
# passthrough, byte-identical data) but DEFERS each I/O's completion by a
# configurable amount of time. The read path and the write path carry their
# own, distinct delays — Linux's table is
#   "0 LEN delay  READ_DEV  READ_OFF  READ_DELAY  WRITE_DEV WRITE_OFF WRITE_DELAY"
# so reads and writes can even route to different devices/offsets; here both
# paths share the one underlying device but keep INDEPENDENT delay values and
# (for full generality) independent under_start offsets.
#
# Modelling the delay WITHOUT a busy-wait: every deferred op is appended to a
# logical DEFERRED-COMPLETION QUEUE. The context owns a monotonically rising
# logical CLOCK (a tick counter, dm-delay's mod_timer deadline in Linux). An
# enqueued op records deadline = clock_at_submit + delay; the dm layer then
# ADVANCES the clock to that deadline and DRAINS every op whose deadline has
# been reached — i.e. the data transfer is issued to the backing device only
# once the op's deadline tick is honoured. This is a real, accounted deferral
# (a deadline queue the dm layer ticks), not a sleep and not a hard-coded
# PASS: an op submitted with delay D is observably held for D ticks before it
# completes, and reads vs writes take their DISTINCT D.
#
# OBSERVABILITY: per-context counters the self-test asserts on —
#   reads_deferred  / writes_deferred  : how many ops took each path,
#   read_delay_total/ write_delay_total: summed ticks each path was held,
#   max_queue_depth                    : peak concurrent deferred ops.
# read_delay_total == reads_deferred*read_delay and likewise for writes prove
# each path applied its OWN configured value.

DM_DELAY_MAX:       uint64 = 4        # delay contexts system-wide
DM_DELAY_QDEPTH:    uint64 = 64       # deferred-completion queue capacity


class DmDelayContext:
    used:             uint32
    pad:              uint32
    under_slot:       int32             # underlying block device (both paths)
    pad2:             uint32
    read_under_start: uint64            # base LBA for the READ path
    write_under_start: uint64           # base LBA for the WRITE path
    read_delay:       uint64            # ticks a read is deferred
    write_delay:      uint64            # ticks a write is deferred
    clock:            uint64            # monotonic logical tick clock
    # Accounting (observable proof the distinct deferral path was taken).
    reads_deferred:    uint64
    writes_deferred:   uint64
    read_delay_total:  uint64           # summed read deferral ticks
    write_delay_total: uint64           # summed write deferral ticks
    max_queue_depth:   uint64           # peak concurrent deferred ops
    # Deferred-completion queue. Each slot pending until drained: deadline is
    # the clock tick at which the op may complete; pending[i]=1 while queued.
    q_pending:   Array[64, uint8]
    q_deadline:  Array[64, uint64]
    q_is_write:  Array[64, uint8]


dm_delay_ctxs: Array[4, DmDelayContext]

dm_devices: Array[8, MappedDevice]
dm_ops:     BlockDeviceOps
dm_inited:  uint32 = 0

# One-chunk staging buffer for the CoW copy path. Snapshot I/O is
# serialised through the synchronous block layer, so a single shared
# module-scope chunk buffer is safe (no two CoW copies overlap). Sized for
# the largest chunk the self-test uses (8 sectors = 4096 bytes); resize if
# a larger chunk_sectors is ever configured.
_DM_SNAP_CHUNK_MAX_SECTORS: uint64 = 8
_dm_snap_cow_buf: Array[4096, uint8]    # 8 * 512

# One-sector ciphertext staging buffer for the crypt path. dm-crypt I/O
# is serialised through the synchronous block layer, so a single shared
# module-scope sector buffer is safe (no two crypt transfers overlap).
_dm_crypt_sector: Array[512, uint8]

# One-cache-block staging buffer for the dm-cache promote / writeback path.
# Sized to the largest cache block the target supports (DM_CACHE_MAX_BLKSECS
# = 8 sectors = 4096 bytes) per the BSS-overflow trap. dm-cache I/O is
# serialised through the synchronous block layer, so a single shared buffer
# is safe (no two cache transfers overlap).
_dm_cache_buf:    Array[4096, uint8]    # 8 * 512

# One-sector staging buffer for the dm-era metadata persistence path. The
# era header and each packed era-array sector are 512 bytes. dm-era I/O is
# serialised through the synchronous block layer, so a single shared
# module-scope sector buffer is safe (no two metadata transfers overlap).
_dm_era_meta_buf: Array[512, uint8]     # one metadata sector

# One-cache-block staging buffer for the dm-writecache write/read/writeback
# data path. Sized to the largest cache block the target supports
# (DM_WC_MAX_BLKSECS = 8 sectors = 4096 bytes) per the BSS-overflow trap.
# dm-writecache I/O is serialised through the synchronous block layer, so a
# single shared buffer is safe (no two writecache transfers overlap).
_dm_wc_buf:       Array[4096, uint8]    # 8 * 512

# One-sector staging buffer for the dm-writecache superblock / packed slot-
# metadata persistence path (each is 512 bytes). Separate from _dm_wc_buf so
# a metadata flush mid-data-transfer never clobbers in-flight block data.
_dm_wc_meta_buf:  Array[512, uint8]     # one metadata sector


def dm_init():
    # Wire the shared vtable once; the device table starts all-free. No
    # mapped device exists until a dm_create_* call (or a /dev/mapper/ctl
    # write) builds one — matching Linux where dm has no devices until
    # dmsetup creates them.
    if dm_inited != 0:
        return
    dm_ops.read_sectors  = _dm_read_blkop
    dm_ops.write_sectors = _dm_write_blkop
    dm_ops.flush         = cast[Fn[int32, uint64]](0)
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        dm_devices[i].used      = 0
        dm_devices[i].n_targets = 0
        dm_devices[i].capacity  = 0
        dm_devices[i].self_slot = -1
        i = i + 1
    s: uint64 = 0
    while s < DM_SNAP_MAX:
        dm_snap_ctxs[s].used = 0
        s = s + 1
    g: uint64 = 0
    while g < DM_INTEG_MAX:
        dm_integ_ctxs[g].used = 0
        g = g + 1
    tp: uint64 = 0
    while tp < DM_THIN_POOL_MAX:
        dm_thin_pools[tp].used = 0
        tp = tp + 1
    td: uint64 = 0
    while td < DM_THIN_DEV_MAX:
        dm_thin_devs[td].used = 0
        td = td + 1
    vr: uint64 = 0
    while vr < DM_VERITY_MAX:
        dm_verity_ctxs[vr].used = 0
        vr = vr + 1
    ca: uint64 = 0
    while ca < DM_CACHE_MAX:
        dm_cache_ctxs[ca].used = 0
        ca = ca + 1
    er: uint64 = 0
    while er < DM_ERA_MAX:
        dm_era_ctxs[er].used = 0
        er = er + 1
    wc: uint64 = 0
    while wc < DM_WC_MAX:
        dm_wc_ctxs[wc].used = 0
        wc = wc + 1
    dm_inited = 1
    printk0("dm: device-mapper ready (linear + crypt + snapshot + integrity + thin + verity + cache + era + writecache targets)\n")


def _dm_find_target(dev: Ptr[MappedDevice], vlba: uint64) -> int32:
    # Return the index of the target whose span contains virtual LBA
    # `vlba`, or -1 if none does. Targets are stored in ascending span
    # order by construction, but a linear scan is fine for <= 8 rows.
    n: uint32 = dev[0].n_targets
    i: uint64 = 0
    while i < cast[uint64](n):
        st:  uint64 = dev[0].targets[i].start_sector
        ln:  uint64 = dev[0].targets[i].length
        if vlba >= st and vlba < st + ln:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_crypt_load_keys(dev: Ptr[MappedDevice]):
    # Expand this mapped device's 64-byte XTS key into the two AES-256
    # schedules: bytes 0..31 = data key, bytes 32..63 = tweak key.
    _dm_aes256_expand(cast[Ptr[uint8]](&dev[0].key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&dev[0].key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))


def _dm_linear_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                  count: uint64, buf: Ptr[uint8]) -> int32:
    # Linear remap: forward the whole [under_start + off_in_t, +count)
    # span straight to the underlying device. Plaintext passthrough.
    ulba: uint64 = t[0].under_start + off_in_t
    if is_write != 0:
        return blk_write_sectors(t[0].under_slot, ulba, count, buf)
    return blk_read_sectors(t[0].under_slot, ulba, count, buf)


def _dm_crypt_io(dev: Ptr[MappedDevice], t: Ptr[DmTarget],
                 is_write: int32, off_in_t: uint64, vlba: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # Crypt remap: process one sector at a time so each gets its own
    # sector-derived XTS tweak (plain64 IV). On write, AES-256-XTS-encrypt
    # the plaintext sector from `buf` into the staging buffer and write
    # the CIPHERTEXT to the backing device. On read, fetch the ciphertext
    # from the backing device into staging and XTS-decrypt into the
    # caller's `buf`. The tweak is keyed on the VIRTUAL sector number
    # (vlba) so the same plaintext at different mapped sectors produces
    # different ciphertext.
    _dm_crypt_load_keys(dev)
    stagep: Ptr[uint8] = cast[Ptr[uint8]](&_dm_crypt_sector[0])
    s: uint64 = 0
    while s < count:
        ulba: uint64 = t[0].under_start + off_in_t + s
        vsec: uint64 = vlba + s
        cur:  Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if is_write != 0:
            # plaintext (cur) -> ciphertext (staging) -> backing store
            _dm_xts_encrypt_sector(vsec, stagep, cur)
            rc: int32 = blk_write_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc != 0:
                return rc
        else:
            # backing store -> ciphertext (staging) -> plaintext (cur)
            rc2: int32 = blk_read_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc2 != 0:
                return rc2
            _dm_xts_decrypt_sector(vsec, cur, stagep)
        s = s + 1
    return 0


# =========================================================================
# dm-snapshot target handlers
# =========================================================================

def _dm_snap_cow_one_chunk(ctx: Ptr[DmSnapContext], ochunk: uint64) -> int32:
    # Copy-on-write a single origin chunk into the exception store, IF it
    # has not already been remapped. Reads the chunk's CURRENT (pre-write)
    # contents from the origin and writes them to a freshly allocated
    # exception-store chunk, then records the mapping + remapped bit. This
    # is the heart of dm-snapshot: it must run BEFORE the origin chunk is
    # overwritten so the snapshot preserves the OLD data. Returns 0 on
    # success, negative on error.
    if ctx[0].remapped[ochunk] != 0:
        return 0                       # already preserved; nothing to do
    if ctx[0].next_exc >= ctx[0].exc_capacity:
        printk0("dm: snapshot exception store full\n")
        return -1
    ec: uint64 = ctx[0].next_exc
    cs: uint64 = ctx[0].chunk_sectors
    olba: uint64 = ochunk * cs
    elba: uint64 = ec * cs
    bufp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_snap_cow_buf[0])
    # Read the original chunk off the origin...
    rc: int32 = blk_read_sectors(ctx[0].origin_slot, olba, cs, bufp)
    if rc != 0:
        return rc
    # ...and stash the pre-image in the exception store.
    rc = blk_write_sectors(ctx[0].exc_slot, elba, cs, bufp)
    if rc != 0:
        return rc
    ctx[0].exc_map[ochunk]  = ec
    ctx[0].remapped[ochunk] = 1
    ctx[0].next_exc         = ec + 1
    return 0


def _dm_snap_origin_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                       count: uint64, buf: Ptr[uint8]) -> int32:
    # SNAPSHOT-ORIGIN target: a thin device over the origin that performs
    # copy-on-write. On WRITE, every chunk this request touches is first
    # CoW'd to the exception store (preserving the snapshot's pre-image),
    # THEN the new data is written through to the origin. On READ it is a
    # plain passthrough to the origin (the live view). Processed one
    # sector at a time so chunk boundaries are handled simply.
    ctx: Ptr[DmSnapContext] = &dm_snap_ctxs[cast[uint64](t[0].snap_ctx)]
    cs: uint64 = ctx[0].chunk_sectors
    s: uint64 = 0
    while s < count:
        olba: uint64 = t[0].under_start + off_in_t + s
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if is_write != 0:
            ochunk: uint64 = olba / cs
            rc: int32 = _dm_snap_cow_one_chunk(ctx, ochunk)
            if rc != 0:
                return rc
            rc = blk_write_sectors(ctx[0].origin_slot, olba, 1, cur)
            if rc != 0:
                return rc
        else:
            rc2: int32 = blk_read_sectors(ctx[0].origin_slot, olba, 1, cur)
            if rc2 != 0:
                return rc2
        s = s + 1
    return 0


def _dm_snap_view_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                     count: uint64, buf: Ptr[uint8]) -> int32:
    # SNAPSHOT target: the frozen point-in-time view. A READ returns, for
    # each chunk, the exception-store pre-image IF that chunk has been
    # CoW'd (remapped), else falls through to the live origin. Writes to a
    # snapshot view are not part of this self-test's data path; they are
    # rejected so a stray write can never corrupt the frozen image.
    ctx: Ptr[DmSnapContext] = &dm_snap_ctxs[cast[uint64](t[0].snap_ctx)]
    cs: uint64 = ctx[0].chunk_sectors
    if is_write != 0:
        printk0("dm: snapshot view is read-only\n")
        return -1
    s: uint64 = 0
    while s < count:
        olba: uint64 = t[0].under_start + off_in_t + s
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        ochunk: uint64 = olba / cs
        off_in_chunk: uint64 = olba - ochunk * cs
        rc: int32 = 0
        if ctx[0].remapped[ochunk] != 0:
            # Preserved pre-image lives in the exception store.
            ec: uint64 = ctx[0].exc_map[ochunk]
            elba: uint64 = ec * cs + off_in_chunk
            rc = blk_read_sectors(ctx[0].exc_slot, elba, 1, cur)
        else:
            # Never written since the snapshot was taken: read origin live
            # (which still equals the snapshot point-in-time value).
            rc = blk_read_sectors(ctx[0].origin_slot, olba, 1, cur)
        if rc != 0:
            return rc
        s = s + 1
    return 0


# =========================================================================
# dm-integrity target handler
# =========================================================================

# One-sector staging buffer for the integrity read-verify path. dm I/O is
# serialised through the synchronous block layer, so a single shared
# module-scope sector buffer is safe (no two integrity transfers overlap).
_dm_integ_sector: Array[512, uint8]


def _dm_integ_tag(sector: uint64, data: Ptr[uint8]) -> uint32:
    # Compute the per-sector integrity tag: a crc32c over the 512 data
    # bytes, SALTED with the sector index so a valid sector relocated to a
    # different LBA fails verification. We fold the 8 little-endian bytes of
    # `sector` into the running crc32c register first (seeding the salt),
    # then chain the sector data, and finalize (xor 0xFFFFFFFF).
    salt: Array[8, uint8]
    i: uint64 = 0
    while i < 8:
        salt[i] = cast[uint8]((sector >> (i * 8)) & 0xFF)
        i = i + 1
    c: uint32 = crc32c_update(0xFFFFFFFF, &salt[0], 8)
    c = crc32c_update(c, data, SECTOR_SIZE)
    return c ^ 0xFFFFFFFF


def _dm_integ_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                 vlba: uint64, count: uint64, buf: Ptr[uint8]) -> int32:
    # INTEGRITY target. Process one sector at a time. On WRITE, write the
    # data through to the backing device, compute the integrity tag over the
    # data (salted with the underlying sector), and store the tag in the
    # context's tag store keyed by sector. On READ, fetch the data from the
    # backing device, recompute the tag, and compare against the stored tag:
    # a MATCH copies the verified data into the caller's buffer; a MISMATCH
    # is reported as an I/O error (negative return) so the caller never sees
    # the corrupt bytes.
    ctx: Ptr[DmIntegContext] = &dm_integ_ctxs[cast[uint64](t[0].snap_ctx)]
    stagep: Ptr[uint8] = cast[Ptr[uint8]](&_dm_integ_sector[0])
    s: uint64 = 0
    while s < count:
        ulba:  uint64 = t[0].under_start + off_in_t + s
        vsec:  uint64 = vlba + s
        cur:   Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if vsec >= ctx[0].nsectors:
            printk1("dm: integrity I/O past tagged span (vsec=%d)\n", vsec)
            return -1
        if is_write != 0:
            rc: int32 = blk_write_sectors(t[0].under_slot, ulba, 1, cur)
            if rc != 0:
                return rc
            ctx[0].tags[vsec]  = _dm_integ_tag(ulba, cur)
            ctx[0].valid[vsec] = 1
        else:
            rc2: int32 = blk_read_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc2 != 0:
                return rc2
            if ctx[0].valid[vsec] != 0:
                want: uint32 = ctx[0].tags[vsec]
                got:  uint32 = _dm_integ_tag(ulba, stagep)
                if got != want:
                    # Corruption detected — refuse to hand back the data.
                    printk2("dm: integrity tag mismatch sec=%d (corruption detected)\n",
                            vsec, cast[uint64](got))
                    return -5
            # Verified (or never tagged) — deliver the data.
            memcpy(cur, stagep, SECTOR_SIZE)
        s = s + 1
    return 0


# =========================================================================
# dm-thin target handler
# =========================================================================

# One-sector zero buffer used to satisfy reads of UNPROVISIONED thin
# virtual blocks (no pool block allocated). dm I/O is serialised through the
# synchronous block layer, so a single shared module-scope buffer is safe.
_dm_thin_zero: Array[512, uint8]


def _dm_thin_pool_alloc_block(pool: Ptr[DmThinPool]) -> int64:
    # Hand out a fresh free pool block, marking it allocated and bumping the
    # allocated-block count. Returns the pool block index, or -1 if the pool
    # is exhausted (no free block remains) — the dm-thin out-of-space case.
    b: uint64 = 0
    while b < pool[0].nblocks:
        if pool[0].free[b] != 0:
            pool[0].free[b]    = 0
            pool[0].nallocated = pool[0].nallocated + 1
            return cast[int64](b)
        b = b + 1
    return -1


def _dm_thin_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                count: uint64, buf: Ptr[uint8]) -> int32:
    # THIN target. Process one sector at a time. Each virtual sector belongs
    # to a virtual BLOCK (block_sectors sectors). On READ of an UNPROVISIONED
    # virtual block, return ZEROS (no pool block allocated, no pool consumed).
    # On WRITE to an unprovisioned virtual block, allocate a fresh pool block
    # from the free allocator, record the (vblock -> pblock) mapping, then
    # write the data to its sector within the pool block. Provisioned blocks
    # remap straight to their pool block on the data device.
    tdev: Ptr[DmThinDev] = &dm_thin_devs[cast[uint64](t[0].snap_ctx)]
    pool: Ptr[DmThinPool] = &dm_thin_pools[cast[uint64](tdev[0].pool_idx)]
    bs:   uint64 = pool[0].block_sectors
    zerop: Ptr[uint8] = cast[Ptr[uint8]](&_dm_thin_zero[0])
    zi: uint64 = 0
    while zi < SECTOR_SIZE:
        _dm_thin_zero[zi] = 0
        zi = zi + 1
    s: uint64 = 0
    while s < count:
        vsec:  uint64 = off_in_t + s
        vblk:  uint64 = vsec / bs
        offib: uint64 = vsec - vblk * bs
        cur:   Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if vblk >= tdev[0].nvblocks:
            printk1("dm: thin I/O past virtual size (vblk=%d)\n", vblk)
            return -1
        if is_write != 0:
            if tdev[0].mapped[vblk] == 0:
                # First write to this virtual block: provision on demand.
                nb: int64 = _dm_thin_pool_alloc_block(pool)
                if nb < 0:
                    printk1("dm: thin pool out of space (vblk=%d)\n", vblk)
                    return -28               # -ENOSPC
                tdev[0].pmap[vblk]   = cast[uint64](nb)
                tdev[0].mapped[vblk] = 1
            plba: uint64 = tdev[0].pmap[vblk] * bs + offib
            rc: int32 = blk_write_sectors(pool[0].data_slot, plba, 1, cur)
            if rc != 0:
                return rc
        else:
            if tdev[0].mapped[vblk] == 0:
                # Unprovisioned: never written -> reads back as zeros.
                memcpy(cur, zerop, SECTOR_SIZE)
            else:
                plba2: uint64 = tdev[0].pmap[vblk] * bs + offib
                rc2: int32 = blk_read_sectors(pool[0].data_slot, plba2, 1, cur)
                if rc2 != 0:
                    return rc2
        s = s + 1
    return 0


# =========================================================================
# dm-verity target handler
# =========================================================================
#
# All verity working state is module-scope .bss. dm I/O is serialised
# through the synchronous block layer, so a single shared set of scratch
# buffers is safe (no two verity verifications overlap). Every block-sized
# scratch is sized to a full DM_VERITY_BLOCK (4096) to avoid the BSS-
# overflow trap; the digest scratch is DM_VERITY_DIGEST (32).

_dm_ver_block:   Array[4096, uint8]   # one data/hash block under hash
_dm_ver_hblk:    Array[4096, uint8]   # level-0 hash block (128 leaf digests)
_dm_ver_leaf:    Array[32, uint8]     # recomputed leaf digest
_dm_ver_root:    Array[32, uint8]     # recomputed root digest
_dm_ver_hashin:  Array[4128, uint8]   # salt(32) || block(4096) hash input


def _dm_verity_hash_salted(ctx: Ptr[DmVerityContext], data: Ptr[uint8],
                           n: uint64, out_hash: Ptr[uint8]):
    # out = sha256(salt || data[0:n]). The salt is prefixed first, exactly
    # as dm-verity mixes its per-target salt into every leaf and interior
    # hash. We stage salt||data contiguously so it is one clean one-shot.
    i: uint64 = 0
    while i < DM_VERITY_SALT_LEN:
        _dm_ver_hashin[i] = ctx[0].salt[i]
        i = i + 1
    j: uint64 = 0
    while j < n:
        _dm_ver_hashin[DM_VERITY_SALT_LEN + j] = data[j]
        j = j + 1
    _dm_sha256_oneshot(cast[Ptr[uint8]](&_dm_ver_hashin[0]),
                       DM_VERITY_SALT_LEN + n, out_hash)


def _dm_verity_read_hash_block(ctx: Ptr[DmVerityContext],
                               out_blk: Ptr[uint8]) -> int32:
    # Fetch the single level-0 hash block (DM_VERITY_BLOCK bytes =
    # DM_VERITY_BLOCK_SECS sectors) from the hash device into `out_blk`.
    return blk_read_sectors(ctx[0].hash_slot, ctx[0].hash_start,
                            DM_VERITY_BLOCK_SECS, out_blk)


def _dm_verity_build_tree(ctx: Ptr[DmVerityContext]) -> int32:
    # Build the Merkle tree over the CURRENT (assumed clean) contents of the
    # data device. For each data block compute its salted sha256 leaf and
    # pack it into the level-0 hash block; write that hash block to the hash
    # device; then hash the whole level-0 block (salted) to form the trusted
    # ROOT. Returns 0 on success, negative on I/O error.
    hblkp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_ver_hblk[0])
    z: uint64 = 0
    while z < DM_VERITY_BLOCK:
        _dm_ver_hblk[z] = 0
        z = z + 1
    blkp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_ver_block[0])
    leafp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_ver_leaf[0])
    b: uint64 = 0
    while b < ctx[0].nblocks:
        dlba: uint64 = ctx[0].data_start + b * DM_VERITY_BLOCK_SECS
        rc: int32 = blk_read_sectors(ctx[0].data_slot, dlba,
                                     DM_VERITY_BLOCK_SECS, blkp)
        if rc != 0:
            return rc
        _dm_verity_hash_salted(ctx, blkp, DM_VERITY_BLOCK, leafp)
        # Pack the 32-byte leaf into slot b of the level-0 hash block.
        k: uint64 = 0
        while k < DM_VERITY_DIGEST:
            _dm_ver_hblk[b * DM_VERITY_DIGEST + k] = _dm_ver_leaf[k]
            k = k + 1
        b = b + 1
    # Persist the level-0 hash block to the hash device.
    wrc: int32 = blk_write_sectors(ctx[0].hash_slot, ctx[0].hash_start,
                                   DM_VERITY_BLOCK_SECS, hblkp)
    if wrc != 0:
        return wrc
    # Root = salted sha256 over the whole level-0 hash block.
    _dm_verity_hash_salted(ctx, hblkp, DM_VERITY_BLOCK,
                           cast[Ptr[uint8]](&ctx[0].root[0]))
    return 0


def _dm_verity_verify_block(ctx: Ptr[DmVerityContext], blkno: uint64,
                            data: Ptr[uint8]) -> int32:
    # Verify one data block end to end against the trusted root:
    #   1. recompute leaf = sha256(salt || data) and compare to the stored
    #      leaf in the level-0 hash block (detects a flipped DATA byte);
    #   2. recompute root = sha256(salt || level-0 hash block) and compare to
    #      the trusted root (detects a flipped HASH-TREE byte OR a stale/
    #      forged hash block). Returns 0 if verified, -5 on any mismatch.
    hblkp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_ver_hblk[0])
    rc: int32 = _dm_verity_read_hash_block(ctx, hblkp)
    if rc != 0:
        return rc
    # Step 1: leaf membership in the hash block.
    _dm_verity_hash_salted(ctx, data, DM_VERITY_BLOCK,
                           cast[Ptr[uint8]](&_dm_ver_leaf[0]))
    i: uint64 = 0
    while i < DM_VERITY_DIGEST:
        if _dm_ver_leaf[i] != _dm_ver_hblk[blkno * DM_VERITY_DIGEST + i]:
            return -5
        i = i + 1
    # Step 2: the hash block must itself hash up to the trusted root.
    _dm_verity_hash_salted(ctx, hblkp, DM_VERITY_BLOCK,
                           cast[Ptr[uint8]](&_dm_ver_root[0]))
    j: uint64 = 0
    while j < DM_VERITY_DIGEST:
        if _dm_ver_root[j] != ctx[0].root[j]:
            return -5
        j = j + 1
    return 0


def _dm_verity_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                  count: uint64, buf: Ptr[uint8]) -> int32:
    # VERITY target. Strictly READ-ONLY. Process one verity BLOCK at a time
    # (count is a sector count; verity I/O is block-aligned). For each block,
    # read the data from the data device, verify it against the Merkle tree
    # rooted at the trusted root, and only on success deliver the bytes.
    if is_write != 0:
        printk0("dm: verity is read-only (write rejected)\n")
        return -30                       # -EROFS
    ctx: Ptr[DmVerityContext] = &dm_verity_ctxs[cast[uint64](t[0].snap_ctx)]
    blkp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_ver_block[0])
    s: uint64 = 0
    while s < count:
        vsec: uint64 = off_in_t + s
        if (vsec % DM_VERITY_BLOCK_SECS) != 0 or \
           (count - s) < DM_VERITY_BLOCK_SECS:
            printk0("dm: verity I/O not block-aligned\n")
            return -1
        blkno: uint64 = vsec / DM_VERITY_BLOCK_SECS
        if blkno >= ctx[0].nblocks:
            printk1("dm: verity I/O past data span (blk=%d)\n", blkno)
            return -1
        dlba: uint64 = ctx[0].data_start + vsec
        rc: int32 = blk_read_sectors(ctx[0].data_slot, dlba,
                                     DM_VERITY_BLOCK_SECS, blkp)
        if rc != 0:
            return rc
        vrc: int32 = _dm_verity_verify_block(ctx, blkno, blkp)
        if vrc != 0:
            printk1("dm: verity hash mismatch blk=%d (corruption detected)\n",
                    blkno)
            return vrc
        # Verified — deliver the block to the caller.
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        memcpy(cur, blkp, DM_VERITY_BLOCK)
        s = s + DM_VERITY_BLOCK_SECS
    return 0


# =========================================================================
# dm-cache target handlers
# =========================================================================

def _dm_cache_find(ctx: Ptr[DmCacheContext], oblk: uint64) -> int32:
    # Return the cache slot currently holding origin block `oblk`, or -1 if
    # the block is not resident.
    n: uint64 = ctx[0].ncache
    i: uint64 = 0
    while i < n:
        if ctx[0].valid[i] != 0 and ctx[0].tag[i] == oblk:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_cache_victim(ctx: Ptr[DmCacheContext]) -> int32:
    # Pick a cache slot to (re)use for a promotion. Prefer an EMPTY (invalid)
    # slot; otherwise evict the least-recently-used valid slot (smallest LRU
    # stamp). Returns the slot index (always >= 0; ncache >= 1).
    n: uint64 = ctx[0].ncache
    i: uint64 = 0
    while i < n:
        if ctx[0].valid[i] == 0:
            return cast[int32](i)
        i = i + 1
    # All slots full: find the smallest stamp (least recently used).
    best:    uint64 = 0
    best_st: uint64 = ctx[0].stamp[0]
    i = 1
    while i < n:
        if ctx[0].stamp[i] < best_st:
            best_st = ctx[0].stamp[i]
            best    = i
        i = i + 1
    return cast[int32](best)


def _dm_cache_touch(ctx: Ptr[DmCacheContext], slot: uint64):
    # Stamp a slot as just-used for the LRU policy.
    ctx[0].clock = ctx[0].clock + 1
    ctx[0].stamp[slot] = ctx[0].clock


def _dm_cache_evict_slot(ctx: Ptr[DmCacheContext], slot: uint64) -> int32:
    # Make `slot` available for a new block. If it currently holds a VALID
    # DIRTY block (writeback mode), its data is first written BACK to the
    # origin so nothing is lost. After this the slot is invalid.
    bs:  uint64 = ctx[0].block_sectors
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_cache_buf[0])
    if ctx[0].valid[slot] != 0 and ctx[0].dirty[slot] != 0:
        victim_blk: uint64 = ctx[0].tag[slot]
        # Read the dirty data out of the cache device and flush it to origin.
        rc: int32 = blk_read_sectors(ctx[0].cache_slot, slot * bs, bs, buf)
        if rc != 0:
            return rc
        rc = blk_write_sectors(ctx[0].origin_slot, victim_blk * bs, bs, buf)
        if rc != 0:
            return rc
    ctx[0].valid[slot] = 0
    ctx[0].dirty[slot] = 0
    return 0


def _dm_cache_promote(ctx: Ptr[DmCacheContext], oblk: uint64) -> int32:
    # Bring origin block `oblk` into a cache slot: choose a victim (writing it
    # back first if dirty), copy the origin block's CURRENT contents into the
    # chosen cache slot, and record the (slot -> oblk, valid, clean) mapping.
    # Returns the slot index (>= 0) or a negative error.
    bs:  uint64 = ctx[0].block_sectors
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_cache_buf[0])
    vslot_s: int32 = _dm_cache_victim(ctx)
    vslot:   uint64 = cast[uint64](vslot_s)
    erc: int32 = _dm_cache_evict_slot(ctx, vslot)
    if erc != 0:
        return erc
    # Copy the origin block into the cache slot.
    rc: int32 = blk_read_sectors(ctx[0].origin_slot, oblk * bs, bs, buf)
    if rc != 0:
        return rc
    rc = blk_write_sectors(ctx[0].cache_slot, vslot * bs, bs, buf)
    if rc != 0:
        return rc
    ctx[0].valid[vslot] = 1
    ctx[0].dirty[vslot] = 0
    ctx[0].tag[vslot]   = oblk
    _dm_cache_touch(ctx, vslot)
    return vslot_s


def _dm_cache_io_block(ctx: Ptr[DmCacheContext], is_write: int32,
                       oblk: uint64, buf: Ptr[uint8]) -> int32:
    # Service ONE cache-block-aligned I/O for origin block `oblk`. Updates the
    # hit/miss counters, performs promotion / eviction / writeback, and obeys
    # the configured mode for writes.
    bs: uint64 = ctx[0].block_sectors
    slot_s: int32 = _dm_cache_find(ctx, oblk)
    if slot_s < 0:
        # MISS — promote the block into the cache, then serve from cache.
        ctx[0].misses = ctx[0].misses + 1
        slot_s = _dm_cache_promote(ctx, oblk)
        if slot_s < 0:
            return slot_s
    else:
        # HIT — block already resident.
        ctx[0].hits = ctx[0].hits + 1
    slot: uint64 = cast[uint64](slot_s)
    _dm_cache_touch(ctx, slot)
    if is_write == 0:
        # READ: serve from the (now resident) cache slot.
        return blk_read_sectors(ctx[0].cache_slot, slot * bs, bs, buf)
    # WRITE: always update the cache slot.
    rc: int32 = blk_write_sectors(ctx[0].cache_slot, slot * bs, bs, buf)
    if rc != 0:
        return rc
    if ctx[0].mode == DM_CACHE_WRITEBACK:
        # Cache holds the newest data; origin is now stale until writeback.
        ctx[0].dirty[slot] = 1
        return 0
    # WRITETHROUGH: also push to origin so the slot stays clean.
    ctx[0].dirty[slot] = 0
    return blk_write_sectors(ctx[0].origin_slot, oblk * bs, bs, buf)


def _dm_cache_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # CACHE target. Process one cache BLOCK at a time (count is a sector
    # count; cache I/O is block-aligned). Each block is dispatched through the
    # hit/miss + promotion machinery in _dm_cache_io_block.
    ctx: Ptr[DmCacheContext] = &dm_cache_ctxs[cast[uint64](t[0].snap_ctx)]
    bs: uint64 = ctx[0].block_sectors
    s: uint64 = 0
    while s < count:
        osec: uint64 = off_in_t + s
        if (osec % bs) != 0 or (count - s) < bs:
            printk0("dm: cache I/O not block-aligned\n")
            return -1
        oblk: uint64 = osec / bs
        if oblk >= ctx[0].nblocks:
            printk1("dm: cache I/O past origin span (blk=%d)\n", oblk)
            return -1
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        rc: int32 = _dm_cache_io_block(ctx, is_write, oblk, cur)
        if rc != 0:
            return rc
        s = s + bs
    return 0


def dm_cache_writeback_all(cache_idx: int32) -> int32:
    # Explicit FLUSH: walk every cache slot and, if it holds VALID DIRTY data
    # (writeback mode), write it back to the origin and mark it clean. After
    # this the origin matches the cache for every cached block. Returns 0 on
    # success or a negative error. (dmsetup message ... flush / cleaner.)
    if cache_idx < 0 or cast[uint64](cache_idx) >= DM_CACHE_MAX:
        return -1
    ci: uint64 = cast[uint64](cache_idx)
    if dm_cache_ctxs[ci].used == 0:
        return -1
    ctx: Ptr[DmCacheContext] = &dm_cache_ctxs[ci]
    bs:  uint64 = ctx[0].block_sectors
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_cache_buf[0])
    i: uint64 = 0
    while i < ctx[0].ncache:
        if ctx[0].valid[i] != 0 and ctx[0].dirty[i] != 0:
            blkno: uint64 = ctx[0].tag[i]
            rc: int32 = blk_read_sectors(ctx[0].cache_slot, i * bs, bs, buf)
            if rc != 0:
                return rc
            rc = blk_write_sectors(ctx[0].origin_slot, blkno * bs, bs, buf)
            if rc != 0:
                return rc
            ctx[0].dirty[i] = 0
        i = i + 1
    return 0


def dm_cache_hits(cache_idx: int32) -> int64:
    # Observe the cache HIT count, or -1 for an invalid/free context.
    if cache_idx < 0 or cast[uint64](cache_idx) >= DM_CACHE_MAX:
        return -1
    if dm_cache_ctxs[cast[uint64](cache_idx)].used == 0:
        return -1
    return cast[int64](dm_cache_ctxs[cast[uint64](cache_idx)].hits)


def dm_cache_misses(cache_idx: int32) -> int64:
    # Observe the cache MISS count, or -1 for an invalid/free context.
    if cache_idx < 0 or cast[uint64](cache_idx) >= DM_CACHE_MAX:
        return -1
    if dm_cache_ctxs[cast[uint64](cache_idx)].used == 0:
        return -1
    return cast[int64](dm_cache_ctxs[cast[uint64](cache_idx)].misses)


# =========================================================================
# dm-era target handlers
# =========================================================================

def _dm_era_put_u32(buf: Ptr[uint8], off: uint64, v: uint32):
    # Store a uint32 little-endian into a byte buffer at byte offset `off`.
    uv: uint64 = cast[uint64](v)
    buf[off]     = cast[uint8](uv & 0xFF)
    buf[off + 1] = cast[uint8]((uv >> 8) & 0xFF)
    buf[off + 2] = cast[uint8]((uv >> 16) & 0xFF)
    buf[off + 3] = cast[uint8]((uv >> 24) & 0xFF)


def _dm_era_get_u32(buf: Ptr[uint8], off: uint64) -> uint32:
    # Load a uint32 little-endian from a byte buffer at byte offset `off`.
    b0: uint64 = cast[uint64](buf[off])
    b1: uint64 = cast[uint64](buf[off + 1])
    b2: uint64 = cast[uint64](buf[off + 2])
    b3: uint64 = cast[uint64](buf[off + 3])
    return cast[uint32](b0 | (b1 << 8) | (b2 << 16) | (b3 << 24))


def dm_era_persist(era_idx: int32) -> int32:
    # Flush the in-core era state out to the metadata device so it survives a
    # teardown / power loss. Sector 0 = header (magic, nchunks, current_era);
    # sectors 1.. = the packed uint32 era array (DM_ERA_PER_SECTOR words per
    # sector). Returns 0 on success, negative on error.
    if era_idx < 0 or cast[uint64](era_idx) >= DM_ERA_MAX:
        return -1
    ei: uint64 = cast[uint64](era_idx)
    if dm_era_ctxs[ei].used == 0:
        return -1
    ctx: Ptr[DmEraContext] = &dm_era_ctxs[ei]
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_era_meta_buf[0])
    # --- header sector ---
    z: uint64 = 0
    while z < SECTOR_SIZE:
        buf[z] = 0
        z = z + 1
    _dm_era_put_u32(buf, 0, DM_ERA_MAGIC)
    _dm_era_put_u32(buf, 4, cast[uint32](ctx[0].nchunks))
    _dm_era_put_u32(buf, 8, ctx[0].current_era)
    if blk_write_sectors(ctx[0].meta_slot, 0, 1, buf) != 0:
        return -1
    # --- packed era-array sectors ---
    nsec: uint64 = (ctx[0].nchunks + DM_ERA_PER_SECTOR - 1) / DM_ERA_PER_SECTOR
    s: uint64 = 0
    while s < nsec:
        zz: uint64 = 0
        while zz < SECTOR_SIZE:
            buf[zz] = 0
            zz = zz + 1
        j: uint64 = 0
        while j < DM_ERA_PER_SECTOR:
            c: uint64 = s * DM_ERA_PER_SECTOR + j
            if c < ctx[0].nchunks:
                _dm_era_put_u32(buf, j * 4, ctx[0].era[c])
            j = j + 1
        if blk_write_sectors(ctx[0].meta_slot, 1 + s, 1, buf) != 0:
            return -1
        s = s + 1
    return 0


def dm_era_reload(era_idx: int32) -> int32:
    # Load persisted era state from the metadata device back into the in-core
    # context. Returns 1 if a valid persisted superblock (matching magic and
    # nchunks) was found and loaded, 0 if no/invalid superblock (fresh
    # device), or negative on I/O error.
    if era_idx < 0 or cast[uint64](era_idx) >= DM_ERA_MAX:
        return -1
    ei: uint64 = cast[uint64](era_idx)
    if dm_era_ctxs[ei].used == 0:
        return -1
    ctx: Ptr[DmEraContext] = &dm_era_ctxs[ei]
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_era_meta_buf[0])
    if blk_read_sectors(ctx[0].meta_slot, 0, 1, buf) != 0:
        return -1
    if _dm_era_get_u32(buf, 0) != DM_ERA_MAGIC:
        return 0                       # fresh metadata; nothing to resume
    persisted_nchunks: uint64 = cast[uint64](_dm_era_get_u32(buf, 4))
    if persisted_nchunks != ctx[0].nchunks:
        return 0                       # geometry mismatch; treat as fresh
    ctx[0].current_era = _dm_era_get_u32(buf, 8)
    nsec: uint64 = (ctx[0].nchunks + DM_ERA_PER_SECTOR - 1) / DM_ERA_PER_SECTOR
    s: uint64 = 0
    while s < nsec:
        if blk_read_sectors(ctx[0].meta_slot, 1 + s, 1, buf) != 0:
            return -1
        j: uint64 = 0
        while j < DM_ERA_PER_SECTOR:
            c: uint64 = s * DM_ERA_PER_SECTOR + j
            if c < ctx[0].nchunks:
                ctx[0].era[c] = _dm_era_get_u32(buf, j * 4)
            j = j + 1
        s = s + 1
    return 1


def _dm_era_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
               count: uint64, buf: Ptr[uint8]) -> int32:
    # ERA target. READ is a plain passthrough to the origin. WRITE forwards
    # the data to the origin AND stamps the CURRENT era on every chunk the
    # request touches, then persists the (changed) era metadata. Processed one
    # sector at a time so chunk boundaries are handled simply.
    ctx: Ptr[DmEraContext] = &dm_era_ctxs[cast[uint64](t[0].snap_ctx)]
    cs: uint64 = ctx[0].chunk_sectors
    stamped: int32 = 0
    s: uint64 = 0
    while s < count:
        olba: uint64 = t[0].under_start + off_in_t + s
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if is_write != 0:
            rc: int32 = blk_write_sectors(ctx[0].origin_slot, olba, 1, cur)
            if rc != 0:
                return rc
            ochunk: uint64 = olba / cs
            if ochunk < ctx[0].nchunks:
                if ctx[0].era[ochunk] != ctx[0].current_era:
                    ctx[0].era[ochunk] = ctx[0].current_era
                    stamped = 1
        else:
            rc2: int32 = blk_read_sectors(ctx[0].origin_slot, olba, 1, cur)
            if rc2 != 0:
                return rc2
        s = s + 1
    if stamped != 0:
        # Persist the updated era metadata so it survives a power loss.
        if dm_era_persist(t[0].snap_ctx) != 0:
            printk0("dm: era metadata persist failed\n")
            return -1
    return 0


def dm_era_advance(era_idx: int32) -> int32:
    # Advance the current era (generation). All subsequent writes stamp the
    # NEW era on their chunks, partitioning future changes from past ones.
    # Persists the new current-era to the metadata superblock. Returns the new
    # era on success, negative on error. (dmsetup message DEV 0 <new_era>.)
    if era_idx < 0 or cast[uint64](era_idx) >= DM_ERA_MAX:
        return -1
    ei: uint64 = cast[uint64](era_idx)
    if dm_era_ctxs[ei].used == 0:
        return -1
    dm_era_ctxs[ei].current_era = dm_era_ctxs[ei].current_era + 1
    if dm_era_persist(era_idx) != 0:
        return -1
    return cast[int32](dm_era_ctxs[ei].current_era)


def dm_era_current(era_idx: int32) -> int32:
    # Observe the current era, or -1 for an invalid/free context.
    if era_idx < 0 or cast[uint64](era_idx) >= DM_ERA_MAX:
        return -1
    if dm_era_ctxs[cast[uint64](era_idx)].used == 0:
        return -1
    return cast[int32](dm_era_ctxs[cast[uint64](era_idx)].current_era)


def dm_era_query_since(era_idx: int32, target_era: uint32,
                       out_chunks: Ptr[uint64], max_out: uint64) -> int64:
    # Enumerate every chunk whose recorded era is >= target_era — the set of
    # chunks WRITTEN IN OR AFTER generation target_era. Fills `out_chunks`
    # (capacity max_out) with the matching chunk indices in ascending order
    # and returns the COUNT. Returns -1 on an invalid context, -2 if the
    # result set would exceed max_out. (dm-era's "blocks changed since N".)
    if era_idx < 0 or cast[uint64](era_idx) >= DM_ERA_MAX:
        return -1
    ei: uint64 = cast[uint64](era_idx)
    if dm_era_ctxs[ei].used == 0:
        return -1
    ctx: Ptr[DmEraContext] = &dm_era_ctxs[ei]
    n: uint64 = 0
    c: uint64 = 0
    while c < ctx[0].nchunks:
        e: uint32 = ctx[0].era[c]
        if e != 0 and e >= target_era:
            if n >= max_out:
                return -2
            out_chunks[n] = c
            n = n + 1
        c = c + 1
    return cast[int64](n)


# =========================================================================
# dm-writecache target handlers
# =========================================================================

def _dm_wc_put_u32(buf: Ptr[uint8], off: uint64, v: uint32):
    # Store a uint32 little-endian into a byte buffer at byte offset `off`.
    uv: uint64 = cast[uint64](v)
    buf[off]     = cast[uint8](uv & 0xFF)
    buf[off + 1] = cast[uint8]((uv >> 8) & 0xFF)
    buf[off + 2] = cast[uint8]((uv >> 16) & 0xFF)
    buf[off + 3] = cast[uint8]((uv >> 24) & 0xFF)


def _dm_wc_get_u32(buf: Ptr[uint8], off: uint64) -> uint32:
    # Load a uint32 little-endian from a byte buffer at byte offset `off`.
    b0: uint64 = cast[uint64](buf[off])
    b1: uint64 = cast[uint64](buf[off + 1])
    b2: uint64 = cast[uint64](buf[off + 2])
    b3: uint64 = cast[uint64](buf[off + 3])
    return cast[uint32](b0 | (b1 << 8) | (b2 << 16) | (b3 << 24))


def _dm_wc_put_u64(buf: Ptr[uint8], off: uint64, v: uint64):
    # Store a uint64 little-endian into a byte buffer at byte offset `off`.
    i: uint64 = 0
    while i < 8:
        buf[off + i] = cast[uint8]((v >> (i * 8)) & 0xFF)
        i = i + 1


def _dm_wc_get_u64(buf: Ptr[uint8], off: uint64) -> uint64:
    # Load a uint64 little-endian from a byte buffer at byte offset `off`.
    v: uint64 = 0
    i: uint64 = 0
    while i < 8:
        v = v | (cast[uint64](buf[off + i]) << (i * 8))
        i = i + 1
    return v


def _dm_wc_meta_sectors(nslots: uint64) -> uint64:
    # Number of cache sectors holding the packed slot-metadata array.
    return (nslots + DM_WC_PER_SECTOR - 1) / DM_WC_PER_SECTOR


def _dm_wc_find(ctx: Ptr[DmWritecacheContext], oblk: uint64) -> int32:
    # Return the cache slot currently holding origin block `oblk` (valid), or
    # -1 if the block has no cache slot.
    n: uint64 = ctx[0].nslots
    i: uint64 = 0
    while i < n:
        if ctx[0].valid[i] != 0 and ctx[0].tag[i] == oblk:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_wc_alloc(ctx: Ptr[DmWritecacheContext]) -> int32:
    # Claim a free (invalid) cache slot for a new origin block, or -1 if the
    # cache is full (no free slot — a real writecache would block/flush; here
    # the test never overcommits).
    n: uint64 = ctx[0].nslots
    i: uint64 = 0
    while i < n:
        if ctx[0].valid[i] == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_wc_persist(wc_idx: int32) -> int32:
    # Flush the writecache slot metadata out to the cache device so an
    # acknowledged-but-not-yet-flushed write survives a crash. Sector 0 =
    # superblock (magic, nblocks, nslots, block_sectors); sectors 1.. = the
    # packed per-slot entries (origin block + valid + dirty). Returns 0 on
    # success, negative on error.
    if wc_idx < 0 or cast[uint64](wc_idx) >= DM_WC_MAX:
        return -1
    wi: uint64 = cast[uint64](wc_idx)
    if dm_wc_ctxs[wi].used == 0:
        return -1
    return dm_wc_persist_ctx(&dm_wc_ctxs[wi])


def dm_wc_reload(wc_idx: int32) -> int32:
    # Load persisted writecache slot metadata from the cache device back into
    # the in-core context. Returns 1 if a valid superblock (matching magic and
    # geometry) was found and loaded, 0 if no/invalid superblock (fresh cache
    # device), or negative on I/O error. After a reload the un-flushed dirty
    # data sitting in the cache slots is recoverable.
    if wc_idx < 0 or cast[uint64](wc_idx) >= DM_WC_MAX:
        return -1
    wi: uint64 = cast[uint64](wc_idx)
    if dm_wc_ctxs[wi].used == 0:
        return -1
    ctx: Ptr[DmWritecacheContext] = &dm_wc_ctxs[wi]
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_wc_meta_buf[0])
    if blk_read_sectors(ctx[0].cache_slot, 0, 1, buf) != 0:
        return -1
    if _dm_wc_get_u32(buf, 0) != DM_WC_MAGIC:
        return 0                       # fresh cache device; nothing to resume
    p_nblocks: uint64 = cast[uint64](_dm_wc_get_u32(buf, 4))
    p_nslots:  uint64 = cast[uint64](_dm_wc_get_u32(buf, 8))
    p_bs:      uint64 = cast[uint64](_dm_wc_get_u32(buf, 12))
    if p_nblocks != ctx[0].nblocks or p_nslots != ctx[0].nslots or \
       p_bs != ctx[0].block_sectors:
        return 0                       # geometry mismatch; treat as fresh
    nsec: uint64 = _dm_wc_meta_sectors(ctx[0].nslots)
    s: uint64 = 0
    while s < nsec:
        if blk_read_sectors(ctx[0].cache_slot, 1 + s, 1, buf) != 0:
            return -1
        j: uint64 = 0
        while j < DM_WC_PER_SECTOR:
            slot: uint64 = s * DM_WC_PER_SECTOR + j
            if slot < ctx[0].nslots:
                eoff: uint64 = j * DM_WC_ENTRY_BYTES
                ctx[0].tag[slot]   = _dm_wc_get_u64(buf, eoff)
                ctx[0].valid[slot] = buf[eoff + 8]
                ctx[0].dirty[slot] = buf[eoff + 9]
            j = j + 1
        s = s + 1
    return 1


def _dm_wc_io_block(ctx: Ptr[DmWritecacheContext], is_write: int32,
                    oblk: uint64, buf: Ptr[uint8]) -> int32:
    # Service ONE cache-block-aligned I/O for origin block `oblk`.
    #   WRITE: land the data in a (new or existing) cache slot, mark dirty,
    #          persist metadata, ACK — without touching the origin.
    #   READ : if the block has a dirty/valid cache slot, serve from the cache
    #          device; otherwise read the origin.
    bs: uint64 = ctx[0].block_sectors
    ds: uint64 = ctx[0].data_start
    slot_s: int32 = _dm_wc_find(ctx, oblk)
    if is_write == 0:
        # READ path.
        if slot_s >= 0:
            slot: uint64 = cast[uint64](slot_s)
            return blk_read_sectors(ctx[0].cache_slot,
                                    ds + slot * bs, bs, buf)
        # Not cached: fall through to the slow origin.
        return blk_read_sectors(ctx[0].origin_slot, oblk * bs, bs, buf)
    # WRITE path: reuse the block's existing slot, else allocate a free one.
    if slot_s < 0:
        slot_s = _dm_wc_alloc(ctx)
        if slot_s < 0:
            printk0("dm: writecache full (no free slot)\n")
            return -1
    wslot: uint64 = cast[uint64](slot_s)
    rc: int32 = blk_write_sectors(ctx[0].cache_slot,
                                  ds + wslot * bs, bs, buf)
    if rc != 0:
        return rc
    ctx[0].valid[wslot] = 1
    ctx[0].dirty[wslot] = 1            # newest data lives only on the cache
    ctx[0].tag[wslot]   = oblk
    # Persist the slot metadata so the acknowledged write is durable on the
    # cache device before any writeback to the origin.
    if dm_wc_persist_ctx(ctx) != 0:
        printk0("dm: writecache metadata persist failed\n")
        return -1
    return 0


def dm_wc_persist_ctx(ctx: Ptr[DmWritecacheContext]) -> int32:
    # Persist by context pointer (used on the hot write path). Mirrors
    # dm_wc_persist but avoids re-deriving the index. Returns 0 / negative.
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_wc_meta_buf[0])
    z: uint64 = 0
    while z < SECTOR_SIZE:
        buf[z] = 0
        z = z + 1
    _dm_wc_put_u32(buf, 0, DM_WC_MAGIC)
    _dm_wc_put_u32(buf, 4, cast[uint32](ctx[0].nblocks))
    _dm_wc_put_u32(buf, 8, cast[uint32](ctx[0].nslots))
    _dm_wc_put_u32(buf, 12, cast[uint32](ctx[0].block_sectors))
    if blk_write_sectors(ctx[0].cache_slot, 0, 1, buf) != 0:
        return -1
    nsec: uint64 = _dm_wc_meta_sectors(ctx[0].nslots)
    s: uint64 = 0
    while s < nsec:
        zz: uint64 = 0
        while zz < SECTOR_SIZE:
            buf[zz] = 0
            zz = zz + 1
        j: uint64 = 0
        while j < DM_WC_PER_SECTOR:
            slot: uint64 = s * DM_WC_PER_SECTOR + j
            if slot < ctx[0].nslots:
                eoff: uint64 = j * DM_WC_ENTRY_BYTES
                _dm_wc_put_u64(buf, eoff, ctx[0].tag[slot])
                buf[eoff + 8] = ctx[0].valid[slot]
                buf[eoff + 9] = ctx[0].dirty[slot]
            j = j + 1
        if blk_write_sectors(ctx[0].cache_slot, 1 + s, 1, buf) != 0:
            return -1
        s = s + 1
    return 0


def _dm_wc_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
              count: uint64, buf: Ptr[uint8]) -> int32:
    # WRITECACHE target. Process one cache BLOCK at a time (count is a sector
    # count; writecache I/O is block-aligned). Each block is dispatched through
    # the slot allocate / dirty / persist machinery in _dm_wc_io_block.
    ctx: Ptr[DmWritecacheContext] = &dm_wc_ctxs[cast[uint64](t[0].snap_ctx)]
    bs: uint64 = ctx[0].block_sectors
    s: uint64 = 0
    while s < count:
        osec: uint64 = off_in_t + s
        if (osec % bs) != 0 or (count - s) < bs:
            printk0("dm: writecache I/O not block-aligned\n")
            return -1
        oblk: uint64 = osec / bs
        if oblk >= ctx[0].nblocks:
            printk1("dm: writecache I/O past origin span (blk=%d)\n", oblk)
            return -1
        cur: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        rc: int32 = _dm_wc_io_block(ctx, is_write, oblk, cur)
        if rc != 0:
            return rc
        s = s + bs
    return 0


def dm_wc_flush_all(wc_idx: int32) -> int32:
    # Explicit WRITEBACK / FLUSH: walk every cache slot and, if it holds VALID
    # DIRTY data, write it BACK to the origin and clear the dirty flag. After
    # this the origin holds every acknowledged write and the cache is clean.
    # Persists the cleared metadata so the flushed state is durable. Returns 0
    # on success or a negative error.
    if wc_idx < 0 or cast[uint64](wc_idx) >= DM_WC_MAX:
        return -1
    wi: uint64 = cast[uint64](wc_idx)
    if dm_wc_ctxs[wi].used == 0:
        return -1
    ctx: Ptr[DmWritecacheContext] = &dm_wc_ctxs[wi]
    bs:  uint64 = ctx[0].block_sectors
    ds:  uint64 = ctx[0].data_start
    buf: Ptr[uint8] = cast[Ptr[uint8]](&_dm_wc_buf[0])
    i: uint64 = 0
    while i < ctx[0].nslots:
        if ctx[0].valid[i] != 0 and ctx[0].dirty[i] != 0:
            oblk: uint64 = ctx[0].tag[i]
            rc: int32 = blk_read_sectors(ctx[0].cache_slot,
                                         ds + i * bs, bs, buf)
            if rc != 0:
                return rc
            rc = blk_write_sectors(ctx[0].origin_slot, oblk * bs, bs, buf)
            if rc != 0:
                return rc
            ctx[0].dirty[i] = 0
        i = i + 1
    # Persist the cleared dirty flags so the flushed state is durable.
    if dm_wc_persist_ctx(ctx) != 0:
        return -1
    return 0


def dm_wc_dirty_count(wc_idx: int32) -> int64:
    # Observe the number of dirty (un-flushed) cache slots, or -1 for an
    # invalid/free context. Lets the self-test assert that a flush clears dirty.
    if wc_idx < 0 or cast[uint64](wc_idx) >= DM_WC_MAX:
        return -1
    wi: uint64 = cast[uint64](wc_idx)
    if dm_wc_ctxs[wi].used == 0:
        return -1
    ctx: Ptr[DmWritecacheContext] = &dm_wc_ctxs[wi]
    n: int64 = 0
    i: uint64 = 0
    while i < ctx[0].nslots:
        if ctx[0].valid[i] != 0 and ctx[0].dirty[i] != 0:
            n = n + 1
        i = i + 1
    return n


def _dm_delay_alloc_ctx() -> int32:
    # Claim a free dm-delay context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_DELAY_MAX:
        if dm_delay_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_delay_qdepth(ctx: Ptr[DmDelayContext]) -> uint64:
    # Number of ops currently pending in the deferred-completion queue.
    n: uint64 = 0
    i: uint64 = 0
    while i < DM_DELAY_QDEPTH:
        if ctx[0].q_pending[i] != 0:
            n = n + 1
        i = i + 1
    return n


def _dm_delay_enqueue(ctx: Ptr[DmDelayContext], is_write: int32,
                      delay: uint64) -> int32:
    # Append a deferred op with deadline = clock + delay. Returns the queue
    # slot, or -1 if the queue is full. Updates the peak-depth gauge AFTER
    # the insert so it reflects true concurrency at submit time.
    i: uint64 = 0
    while i < DM_DELAY_QDEPTH:
        if ctx[0].q_pending[i] == 0:
            ctx[0].q_pending[i]  = 1
            ctx[0].q_deadline[i] = ctx[0].clock + delay
            if is_write != 0:
                ctx[0].q_is_write[i] = 1
            else:
                ctx[0].q_is_write[i] = 0
            d: uint64 = _dm_delay_qdepth(ctx)
            if d > ctx[0].max_queue_depth:
                ctx[0].max_queue_depth = d
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_delay_tick_until(ctx: Ptr[DmDelayContext], slot: uint64):
    # Honour a deferred op's deadline: advance the logical clock to (at least)
    # the op's deadline tick, then DRAIN it from the queue. The clock only ever
    # moves FORWARD — a later submit already sits at a higher deadline. This is
    # the deadline-queue equivalent of dm-delay waiting out a timer: the op is
    # not completed until its deadline tick is reached.
    deadline: uint64 = ctx[0].q_deadline[slot]
    if ctx[0].clock < deadline:
        ctx[0].clock = deadline
    ctx[0].q_pending[slot] = 0


def _dm_delay_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # dm-delay remap: a real LINEAR passthrough (byte-identical data) whose
    # completion is DEFERRED by the path-specific delay. The op is enqueued on
    # the deferred-completion queue with its deadline, the clock is ticked out
    # to that deadline (the deferral being honoured), the per-path accounting
    # is updated, and only THEN is the data transfer issued to the backing
    # device. Read and write take their OWN delay and OWN under_start.
    ctx: Ptr[DmDelayContext] = &dm_delay_ctxs[cast[uint64](t[0].snap_ctx)]
    delay: uint64 = ctx[0].read_delay
    base:  uint64 = ctx[0].read_under_start
    if is_write != 0:
        delay = ctx[0].write_delay
        base  = ctx[0].write_under_start
    slot_s: int32 = _dm_delay_enqueue(ctx, is_write, delay)
    if slot_s < 0:
        printk0("dm: delay deferred-completion queue full\n")
        return -1
    slot: uint64 = cast[uint64](slot_s)
    # Honour the deadline (advance the clock, drain the op).
    _dm_delay_tick_until(ctx, slot)
    # Account the deferral on the correct path.
    if is_write != 0:
        ctx[0].writes_deferred   = ctx[0].writes_deferred + 1
        ctx[0].write_delay_total = ctx[0].write_delay_total + delay
    else:
        ctx[0].reads_deferred   = ctx[0].reads_deferred + 1
        ctx[0].read_delay_total = ctx[0].read_delay_total + delay
    # Now issue the real (linear-remapped) transfer to the backing device.
    ulba: uint64 = base + off_in_t
    if is_write != 0:
        return blk_write_sectors(ctx[0].under_slot, ulba, count, buf)
    return blk_read_sectors(ctx[0].under_slot, ulba, count, buf)


def _dm_io(dev: Ptr[MappedDevice], is_write: int32, vlba: uint64,
           count: uint64, buf: Ptr[uint8]) -> int32:
    # Core remap. Walk the request sector-span, splitting it at target
    # boundaries (a single request may straddle two concatenated linear
    # targets), and dispatch each sub-span to its target's handler.
    if count == 0:
        return 0
    done: uint64 = 0
    while done < count:
        cur_v: uint64 = vlba + done
        ti: int32 = _dm_find_target(dev, cur_v)
        if ti < 0:
            printk1("dm: I/O outside any target (vlba=%d)\n", cur_v)
            return -1
        t: Ptr[DmTarget] = &dev[0].targets[cast[uint64](ti)]
        st:  uint64 = t[0].start_sector
        ln:  uint64 = t[0].length
        off_in_t: uint64 = cur_v - st
        # How many sectors remain in THIS target's span from cur_v on.
        avail: uint64 = ln - off_in_t
        chunk: uint64 = count - done
        if chunk > avail:
            chunk = avail
        bufp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + done * SECTOR_SIZE)
        rc: int32 = 0
        if t[0].ttype == DM_TARGET_CRYPT:
            rc = _dm_crypt_io(dev, t, is_write, off_in_t, cur_v,
                              chunk, bufp)
        elif t[0].ttype == DM_TARGET_SNAPSHOT_ORIGIN:
            rc = _dm_snap_origin_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_SNAPSHOT:
            rc = _dm_snap_view_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_INTEGRITY:
            rc = _dm_integ_io(t, is_write, off_in_t, cur_v, chunk, bufp)
        elif t[0].ttype == DM_TARGET_THIN:
            rc = _dm_thin_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_VERITY:
            rc = _dm_verity_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_CACHE:
            rc = _dm_cache_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_ERA:
            rc = _dm_era_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_WRITECACHE:
            rc = _dm_wc_io(t, is_write, off_in_t, chunk, bufp)
        elif t[0].ttype == DM_TARGET_DELAY:
            rc = _dm_delay_io(t, is_write, off_in_t, chunk, bufp)
        else:
            rc = _dm_linear_io(t, is_write, off_in_t, chunk, bufp)
        if rc != 0:
            return rc
        done = done + chunk
    return 0


def _dm_read_blkop(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dev: Ptr[MappedDevice] = cast[Ptr[MappedDevice]](priv)
    if dev[0].used == 0:
        return -1
    return _dm_io(dev, 0, lba, count, buf)


def _dm_write_blkop(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dev: Ptr[MappedDevice] = cast[Ptr[MappedDevice]](priv)
    if dev[0].used == 0:
        return -1
    return _dm_io(dev, 1, lba, count, buf)


def _dm_alloc_device() -> int32:
    # Claim a free MappedDevice slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_register(idx: uint64, name: Ptr[char]) -> int32:
    # Register the (already-populated) mapped device at table index `idx`
    # with the block layer. Returns 0 on success, -1 on failure.
    cap: uint64 = dm_devices[idx].capacity
    priv: uint64 = cast[uint64](&dm_devices[idx])
    slot: int32 = register_blockdev(name, cap, &dm_ops, priv)
    if slot < 0:
        printk0("dm: block-device registration failed\n")
        return -1
    dm_devices[idx].self_slot = slot
    dm_devices[idx].used      = 1
    return 0


# =========================================================================
# dmsetup-shape control surface (public API)
# =========================================================================

def dm_create_linear(name: Ptr[char], under_slot: int32,
                     under_start: uint64, length: uint64) -> int32:
    # Create a mapped device with a SINGLE linear target covering the
    # whole virtual device [0, length): virtual sector v maps to
    # underlying sector (under_start + v) on `under_slot`. This is the
    # `dmsetup create NAME --table "0 LENGTH linear DEV START"` shape.
    # Returns the registered block slot (>= 0) or a negative error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    # Underlying device must actually hold the mapped span.
    ucap: uint64 = blk_capacity_sectors(under_slot)
    if under_start + length > ucap:
        printk0("dm: linear target exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets             = 1
    dm_devices[idx].capacity              = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].snap_ctx     = -1
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_create_concat(name: Ptr[char],
                     slot_a: int32, start_a: uint64, len_a: uint64,
                     slot_b: int32, start_b: uint64, len_b: uint64) -> int32:
    # Create a mapped device from TWO concatenated linear targets — the
    # canonical LVM "join two physical extents into one logical volume"
    # case. Virtual [0, len_a) maps onto (slot_a, start_a..); virtual
    # [len_a, len_a+len_b) maps onto (slot_b, start_b..). The block layer
    # sees one device of (len_a + len_b) sectors. Returns the registered
    # block slot or a negative error.
    dm_init()
    if len_a == 0 or len_b == 0:
        return -1
    if slot_a < 0 or slot_b < 0:
        return -2
    if start_a + len_a > blk_capacity_sectors(slot_a):
        printk0("dm: concat target A exceeds underlying capacity\n")
        return -3
    if start_b + len_b > blk_capacity_sectors(slot_b):
        printk0("dm: concat target B exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets = 2
    dm_devices[idx].capacity  = len_a + len_b
    dm_devices[idx].targets[0].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = len_a
    dm_devices[idx].targets[0].under_slot   = slot_a
    dm_devices[idx].targets[0].snap_ctx     = -1
    dm_devices[idx].targets[0].under_start  = start_a
    dm_devices[idx].targets[1].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[1].start_sector = len_a
    dm_devices[idx].targets[1].length       = len_b
    dm_devices[idx].targets[1].under_slot   = slot_b
    dm_devices[idx].targets[1].snap_ctx     = -1
    dm_devices[idx].targets[1].under_start  = start_b
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_create_crypt(name: Ptr[char], under_slot: int32,
                    under_start: uint64, length: uint64,
                    key: Ptr[uint8], keylen: uint64) -> int32:
    # Create a dm-crypt mapped device with a SINGLE crypt target over
    # [0, length): every sector written through the mapped device is
    # AES-256-XTS-encrypted (plain64 sector-keyed tweak) before it
    # reaches the backing store, and decrypted on read. `key` supplies up
    # to DM_KEY_LEN (64) bytes — the 32-byte data key followed by the
    # 32-byte tweak key — and a short key is zero-padded. This is the
    # `dmsetup create NAME --table "0 LENGTH crypt aes-xts-plain64 KEY 0 DEV START"`
    # shape. Returns the registered block slot or a negative error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    if under_start + length > blk_capacity_sectors(under_slot):
        printk0("dm: crypt target exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    # Install the key (zero-pad / truncate to DM_KEY_LEN).
    ki: uint64 = 0
    while ki < DM_KEY_LEN:
        if ki < keylen:
            dm_devices[idx].key[ki] = key[ki]
        else:
            dm_devices[idx].key[ki] = 0
        ki = ki + 1
    dm_devices[idx].n_targets = 1
    dm_devices[idx].capacity  = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_CRYPT
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].snap_ctx     = -1
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_snap_alloc_ctx() -> int32:
    # Claim a free snapshot context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_SNAP_MAX:
        if dm_snap_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_snapshot(name: Ptr[char], origin_slot: int32,
                       exc_slot: int32, chunk_sectors: uint64,
                       length: uint64) -> int32:
    # Create a dm-snapshot pair sharing one CoW context:
    #   * a SNAPSHOT view registered as `name`     — the frozen image, and
    #   * a SNAPSHOT-ORIGIN registered as `name`+"-origin" — the CoW origin
    #     that filesystems/writers go through so origin writes preserve the
    #     snapshot's pre-image in the exception store.
    # `origin_slot` is the underlying real origin; `exc_slot` is the
    # separate exception-store device; `chunk_sectors` is the CoW
    # granularity; `length` is the virtual size in sectors. This mirrors
    # `dmsetup create snap --table "0 LEN snapshot ORIGIN COW P CHUNK"`
    # plus the implicit snapshot-origin target on the origin. Returns the
    # registered SNAPSHOT view's block slot or a negative error.
    dm_init()
    if length == 0 or chunk_sectors == 0:
        return -1
    if origin_slot < 0 or exc_slot < 0:
        return -2
    if chunk_sectors > _DM_SNAP_CHUNK_MAX_SECTORS:
        printk0("dm: snapshot chunk_sectors exceeds CoW buffer\n")
        return -2
    if length > blk_capacity_sectors(origin_slot):
        printk0("dm: snapshot exceeds origin capacity\n")
        return -3
    nchunks: uint64 = (length + chunk_sectors - 1) / chunk_sectors
    if nchunks > DM_SNAP_MAX_CHUNKS:
        printk0("dm: snapshot too many chunks for exception table\n")
        return -3
    exc_cap: uint64 = blk_capacity_sectors(exc_slot) / chunk_sectors
    if exc_cap == 0:
        printk0("dm: snapshot exception store too small\n")
        return -3
    sctx_s: int32 = _dm_snap_alloc_ctx()
    if sctx_s < 0:
        printk0("dm: snapshot context table full\n")
        return -4
    sctx: uint64 = cast[uint64](sctx_s)
    dm_snap_ctxs[sctx].used          = 1
    dm_snap_ctxs[sctx].origin_slot   = origin_slot
    dm_snap_ctxs[sctx].exc_slot      = exc_slot
    dm_snap_ctxs[sctx].chunk_sectors = chunk_sectors
    dm_snap_ctxs[sctx].nchunks       = nchunks
    dm_snap_ctxs[sctx].next_exc      = 0
    dm_snap_ctxs[sctx].exc_capacity  = exc_cap
    c: uint64 = 0
    while c < DM_SNAP_MAX_CHUNKS:
        dm_snap_ctxs[sctx].exc_map[c]  = 0
        dm_snap_ctxs[sctx].remapped[c] = 0
        c = c + 1

    # --- snapshot VIEW device (frozen image) ---
    vidx_s: int32 = _dm_alloc_device()
    if vidx_s < 0:
        dm_snap_ctxs[sctx].used = 0
        printk0("dm: device table full\n")
        return -4
    vidx: uint64 = cast[uint64](vidx_s)
    dm_devices[vidx].n_targets             = 1
    dm_devices[vidx].capacity              = length
    dm_devices[vidx].targets[0].ttype        = DM_TARGET_SNAPSHOT
    dm_devices[vidx].targets[0].start_sector = 0
    dm_devices[vidx].targets[0].length       = length
    dm_devices[vidx].targets[0].under_slot   = origin_slot
    dm_devices[vidx].targets[0].snap_ctx     = sctx_s
    dm_devices[vidx].targets[0].under_start  = 0
    if _dm_register(vidx, name) != 0:
        dm_devices[vidx].used   = 0
        dm_snap_ctxs[sctx].used = 0
        return -5
    return dm_devices[vidx].self_slot


def dm_snapshot_ctx_of(name: Ptr[char]) -> int32:
    # Return the snapshot-context index backing the snapshot VIEW device
    # registered under `name`, or -1 if `name` is not a live snapshot view.
    # Lets a caller (e.g. the self-test) build the paired snapshot-origin
    # device that shares the same CoW context.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            if dm_devices[i].targets[0].ttype == DM_TARGET_SNAPSHOT:
                return dm_devices[i].targets[0].snap_ctx
            return -1
        i = i + 1
    return -1


def dm_create_snapshot_origin(name: Ptr[char], snap_ctx: int32,
                              length: uint64) -> int32:
    # Create the SNAPSHOT-ORIGIN mapped device that shares snapshot context
    # `snap_ctx` (returned implicitly by dm_create_snapshot, which stored it
    # in the view's target). Writes through this device trigger copy-on-
    # write so the paired snapshot keeps the pre-image. Returns the
    # registered block slot or a negative error.
    dm_init()
    if length == 0:
        return -1
    if snap_ctx < 0 or cast[uint64](snap_ctx) >= DM_SNAP_MAX:
        return -2
    if dm_snap_ctxs[cast[uint64](snap_ctx)].used == 0:
        return -2
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets             = 1
    dm_devices[idx].capacity              = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_SNAPSHOT_ORIGIN
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = \
        dm_snap_ctxs[cast[uint64](snap_ctx)].origin_slot
    dm_devices[idx].targets[0].snap_ctx     = snap_ctx
    dm_devices[idx].targets[0].under_start  = 0
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_integ_alloc_ctx() -> int32:
    # Claim a free integrity context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_INTEG_MAX:
        if dm_integ_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_integrity(name: Ptr[char], under_slot: int32,
                        under_start: uint64, length: uint64) -> int32:
    # Create a dm-integrity mapped device with a SINGLE integrity target
    # over [0, length): every sector written through the mapped device is
    # passed through to the backing store AND gets a per-sector crc32c
    # integrity tag recorded in a dedicated tag store; every read recomputes
    # the tag over the fetched data and FAILS the I/O if it does not match
    # the stored tag (corruption detection). This is the
    # `dmsetup create NAME --table "0 LENGTH integrity DEV START ..."` shape
    # in crc32c tag mode. Returns the registered block slot or a negative
    # error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    if length > DM_INTEG_MAX_SECTORS:
        printk0("dm: integrity span exceeds tag-store capacity\n")
        return -3
    if under_start + length > blk_capacity_sectors(under_slot):
        printk0("dm: integrity target exceeds underlying capacity\n")
        return -3
    cidx_s: int32 = _dm_integ_alloc_ctx()
    if cidx_s < 0:
        printk0("dm: integrity context table full\n")
        return -4
    cidx: uint64 = cast[uint64](cidx_s)
    dm_integ_ctxs[cidx].nsectors = length
    vi: uint64 = 0
    while vi < length:
        dm_integ_ctxs[cidx].valid[vi] = 0
        dm_integ_ctxs[cidx].tags[vi]  = 0
        vi = vi + 1
    dm_integ_ctxs[cidx].used = 1
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_integ_ctxs[cidx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_INTEGRITY
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].snap_ctx     = cidx_s
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used     = 0
        dm_integ_ctxs[cidx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_thin_alloc_pool() -> int32:
    # Claim a free thin-pool slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_THIN_POOL_MAX:
        if dm_thin_pools[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_thin_alloc_dev() -> int32:
    # Claim a free thin-device slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_THIN_DEV_MAX:
        if dm_thin_devs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_thin_pool(data_slot: int32, block_sectors: uint64,
                        nblocks: uint64) -> int32:
    # Create a thin POOL over an underlying DATA block device. The pool's
    # physical capacity is `nblocks` blocks of `block_sectors` sectors each;
    # every block starts FREE (zero allocated). Thin devices later draw their
    # on-demand blocks from this pool. This is the dm-thin-pool target:
    # `dmsetup create pool --table "0 LEN thin-pool METADEV DATADEV BLK ..."`.
    # Returns the pool index (>= 0) or a negative error.
    dm_init()
    if data_slot < 0:
        return -2
    if block_sectors == 0:
        return -2
    if nblocks == 0 or nblocks > DM_THIN_MAX_PBLOCKS:
        printk0("dm: thin pool block count exceeds allocator capacity\n")
        return -3
    if nblocks * block_sectors > blk_capacity_sectors(data_slot):
        printk0("dm: thin pool exceeds underlying data capacity\n")
        return -3
    pidx_s: int32 = _dm_thin_alloc_pool()
    if pidx_s < 0:
        printk0("dm: thin pool table full\n")
        return -4
    pidx: uint64 = cast[uint64](pidx_s)
    dm_thin_pools[pidx].data_slot     = data_slot
    dm_thin_pools[pidx].block_sectors = block_sectors
    dm_thin_pools[pidx].nblocks       = nblocks
    dm_thin_pools[pidx].nallocated    = 0
    b: uint64 = 0
    while b < nblocks:
        dm_thin_pools[pidx].free[b] = 1
        b = b + 1
    dm_thin_pools[pidx].used = 1
    return pidx_s


def dm_thin_pool_allocated(pool_idx: int32) -> int64:
    # Return the number of pool blocks currently handed out (allocated) for
    # the pool at `pool_idx`, or -1 for an invalid/free pool. Lets a caller
    # (e.g. the self-test) observe over-provisioning: virtual size can vastly
    # exceed this physical allocation.
    if pool_idx < 0 or cast[uint64](pool_idx) >= DM_THIN_POOL_MAX:
        return -1
    p: uint64 = cast[uint64](pool_idx)
    if dm_thin_pools[p].used == 0:
        return -1
    return cast[int64](dm_thin_pools[p].nallocated)


def dm_create_thin(name: Ptr[char], pool_idx: int32,
                   virtual_sectors: uint64) -> int32:
    # Create a THIN device drawing from the pool at `pool_idx`. It presents
    # `virtual_sectors` of VIRTUAL capacity but allocates ZERO pool blocks up
    # front: physical blocks are claimed on demand on first write. The
    # virtual size may vastly exceed the pool's physical capacity
    # (over-provisioning). This is the dm-thin target:
    # `dmsetup create thin --table "0 LEN thin POOLDEV DEVID"`. Returns the
    # registered block slot or a negative error.
    dm_init()
    if virtual_sectors == 0:
        return -1
    if pool_idx < 0 or cast[uint64](pool_idx) >= DM_THIN_POOL_MAX:
        return -2
    if dm_thin_pools[cast[uint64](pool_idx)].used == 0:
        return -2
    bs: uint64 = dm_thin_pools[cast[uint64](pool_idx)].block_sectors
    if virtual_sectors % bs != 0:
        printk0("dm: thin virtual size not a multiple of pool block size\n")
        return -3
    nvb: uint64 = virtual_sectors / bs
    if nvb > DM_THIN_MAX_VBLOCKS:
        printk0("dm: thin virtual size exceeds mapping-table capacity\n")
        return -3
    didx_s: int32 = _dm_thin_alloc_dev()
    if didx_s < 0:
        printk0("dm: thin device table full\n")
        return -4
    didx: uint64 = cast[uint64](didx_s)
    dm_thin_devs[didx].pool_idx = pool_idx
    dm_thin_devs[didx].nvblocks = nvb
    vb: uint64 = 0
    while vb < nvb:
        dm_thin_devs[didx].mapped[vb] = 0
        dm_thin_devs[didx].pmap[vb]   = 0
        vb = vb + 1
    dm_thin_devs[didx].used = 1
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_thin_devs[didx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = virtual_sectors
    dm_devices[idx].targets[0].ttype        = DM_TARGET_THIN
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = virtual_sectors
    dm_devices[idx].targets[0].under_slot   = \
        dm_thin_pools[cast[uint64](pool_idx)].data_slot
    dm_devices[idx].targets[0].snap_ctx     = didx_s
    dm_devices[idx].targets[0].under_start  = 0
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used    = 0
        dm_thin_devs[didx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_verity_alloc_ctx() -> int32:
    # Claim a free verity context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_VERITY_MAX:
        if dm_verity_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_verity(name: Ptr[char], data_slot: int32, data_start: uint64,
                     hash_slot: int32, hash_start: uint64, nblocks: uint64,
                     salt: Ptr[uint8]) -> int32:
    # Create a READ-ONLY dm-verity mapped device over `nblocks` data blocks
    # (DM_VERITY_BLOCK bytes each) on `data_slot` starting at `data_start`,
    # with its Merkle hash tree stored on `hash_slot` starting at the
    # `hash_start` sector. The per-target `salt` (DM_VERITY_SALT_LEN bytes)
    # is mixed into every hash. The tree is BUILT NOW over the current
    # (clean) data-device contents and the trusted root hash is captured; the
    # virtual device then verifies every subsequent read against that root.
    # This is the `dmsetup create NAME --table "0 LEN verity ... DATADEV
    # HASHDEV ... root salt"` shape. Returns the registered block slot or a
    # negative error.
    dm_init()
    if nblocks == 0:
        return -1
    if data_slot < 0 or hash_slot < 0:
        return -2
    if nblocks > DM_VERITY_MAX_BLOCKS or nblocks > DM_VERITY_PER_BLOCK:
        printk0("dm: verity block count exceeds one-level hash-block capacity\n")
        return -3
    length: uint64 = nblocks * DM_VERITY_BLOCK_SECS
    if data_start + length > blk_capacity_sectors(data_slot):
        printk0("dm: verity target exceeds underlying data capacity\n")
        return -3
    if hash_start + DM_VERITY_BLOCK_SECS > blk_capacity_sectors(hash_slot):
        printk0("dm: verity hash device too small for hash block\n")
        return -3
    cidx_s: int32 = _dm_verity_alloc_ctx()
    if cidx_s < 0:
        printk0("dm: verity context table full\n")
        return -4
    cidx: uint64 = cast[uint64](cidx_s)
    dm_verity_ctxs[cidx].data_slot  = data_slot
    dm_verity_ctxs[cidx].hash_slot  = hash_slot
    dm_verity_ctxs[cidx].data_start = data_start
    dm_verity_ctxs[cidx].hash_start = hash_start
    dm_verity_ctxs[cidx].nblocks    = nblocks
    si: uint64 = 0
    while si < DM_VERITY_SALT_LEN:
        dm_verity_ctxs[cidx].salt[si] = salt[si]
        si = si + 1
    dm_verity_ctxs[cidx].used = 1
    # Build the Merkle tree + capture the trusted root over clean data.
    brc: int32 = _dm_verity_build_tree(&dm_verity_ctxs[cidx])
    if brc != 0:
        dm_verity_ctxs[cidx].used = 0
        printk0("dm: verity tree build failed (data read error)\n")
        return -5
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_verity_ctxs[cidx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_VERITY
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = data_slot
    dm_devices[idx].targets[0].snap_ctx     = cidx_s
    dm_devices[idx].targets[0].under_start  = data_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used      = 0
        dm_verity_ctxs[cidx].used = 0
        return -5
    return dm_devices[idx].self_slot


def _dm_cache_alloc_ctx() -> int32:
    # Claim a free cache context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_CACHE_MAX:
        if dm_cache_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_cache(name: Ptr[char], cache_slot: int32, origin_slot: int32,
                    block_sectors: uint64, ncache: uint64,
                    nblocks: uint64, mode: uint32) -> int32:
    # Create a dm-cache mapped device: a FAST `cache_slot` device caching the
    # SLOW `origin_slot` device. The address space is carved into `nblocks`
    # cache blocks of `block_sectors` sectors each; the fast device holds
    # `ncache` slots (ncache < nblocks makes eviction observable). `mode` is
    # DM_CACHE_WRITETHROUGH or DM_CACHE_WRITEBACK. The mapped device presents
    # the FULL origin span (nblocks * block_sectors sectors). This is the
    # `dmsetup create NAME --table "0 LEN cache METADEV CACHEDEV ORIGINDEV
    # BLK ... writethrough|writeback ..."` shape. Returns the registered block
    # slot or a negative error.
    dm_init()
    if cache_slot < 0 or origin_slot < 0:
        return -2
    if block_sectors == 0 or block_sectors > DM_CACHE_MAX_BLKSECS:
        printk0("dm: cache block size exceeds staging buffer capacity\n")
        return -2
    if nblocks == 0:
        return -2
    if ncache == 0 or ncache > DM_CACHE_MAX_SLOTS:
        printk0("dm: cache slot count exceeds mapping-table capacity\n")
        return -3
    if mode != DM_CACHE_WRITETHROUGH and mode != DM_CACHE_WRITEBACK:
        return -2
    length: uint64 = nblocks * block_sectors
    if length > blk_capacity_sectors(origin_slot):
        printk0("dm: cache target exceeds underlying origin capacity\n")
        return -3
    if ncache * block_sectors > blk_capacity_sectors(cache_slot):
        printk0("dm: cache slots exceed underlying cache-device capacity\n")
        return -3
    cidx_s: int32 = _dm_cache_alloc_ctx()
    if cidx_s < 0:
        printk0("dm: cache context table full\n")
        return -4
    cidx: uint64 = cast[uint64](cidx_s)
    dm_cache_ctxs[cidx].mode          = mode
    dm_cache_ctxs[cidx].cache_slot    = cache_slot
    dm_cache_ctxs[cidx].origin_slot   = origin_slot
    dm_cache_ctxs[cidx].block_sectors = block_sectors
    dm_cache_ctxs[cidx].nblocks       = nblocks
    dm_cache_ctxs[cidx].ncache        = ncache
    dm_cache_ctxs[cidx].clock         = 0
    dm_cache_ctxs[cidx].hits          = 0
    dm_cache_ctxs[cidx].misses        = 0
    s: uint64 = 0
    while s < ncache:
        dm_cache_ctxs[cidx].valid[s] = 0
        dm_cache_ctxs[cidx].dirty[s] = 0
        dm_cache_ctxs[cidx].tag[s]   = 0
        dm_cache_ctxs[cidx].stamp[s] = 0
        s = s + 1
    dm_cache_ctxs[cidx].used = 1
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_cache_ctxs[cidx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_CACHE
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = origin_slot
    dm_devices[idx].targets[0].snap_ctx     = cidx_s
    dm_devices[idx].targets[0].under_start  = 0
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used     = 0
        dm_cache_ctxs[cidx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_cache_ctx_of(name: Ptr[char]) -> int32:
    # Return the cache-context index backing the cache mapped device `name`,
    # or -1 if none. Lets a caller (e.g. the self-test) observe hit/miss
    # counters and trigger an explicit writeback flush.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            if dm_devices[i].targets[0].ttype == DM_TARGET_CACHE:
                return dm_devices[i].targets[0].snap_ctx
            return -1
        i = i + 1
    return -1


def _dm_era_alloc_ctx() -> int32:
    # Claim a free era context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_ERA_MAX:
        if dm_era_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_era(name: Ptr[char], origin_slot: int32, meta_slot: int32,
                  chunk_sectors: uint64, nchunks: uint64) -> int32:
    # Create a dm-era mapped device over `origin_slot`, tracking the last-
    # written era of each of `nchunks` chunks (chunk_sectors sectors each) and
    # persisting that metadata to `meta_slot`. The mapped device presents the
    # FULL origin span (nchunks * chunk_sectors sectors). If the metadata
    # device already carries our superblock with matching geometry, the era
    # state (current era + per-chunk eras) is RESUMED from it; otherwise the
    # device starts at era 1 with all chunks unwritten. This is the
    # `dmsetup create NAME --table "0 LEN era METADEV ORIGINDEV BLK"` shape.
    # Returns the registered block slot or a negative error.
    dm_init()
    if origin_slot < 0 or meta_slot < 0:
        return -2
    if chunk_sectors == 0:
        return -2
    if nchunks == 0 or nchunks > DM_ERA_MAX_CHUNKS:
        printk0("dm: era chunk count exceeds era-table capacity\n")
        return -3
    length: uint64 = nchunks * chunk_sectors
    if length > blk_capacity_sectors(origin_slot):
        printk0("dm: era target exceeds underlying origin capacity\n")
        return -3
    # Metadata footprint: 1 header sector + ceil(nchunks/PER_SECTOR) array
    # sectors. Must fit on the metadata device.
    meta_sectors: uint64 = 1 + (nchunks + DM_ERA_PER_SECTOR - 1) / \
        DM_ERA_PER_SECTOR
    if meta_sectors > blk_capacity_sectors(meta_slot):
        printk0("dm: era metadata exceeds underlying metadata-device capacity\n")
        return -3
    eidx_s: int32 = _dm_era_alloc_ctx()
    if eidx_s < 0:
        printk0("dm: era context table full\n")
        return -4
    eidx: uint64 = cast[uint64](eidx_s)
    dm_era_ctxs[eidx].origin_slot   = origin_slot
    dm_era_ctxs[eidx].meta_slot     = meta_slot
    dm_era_ctxs[eidx].chunk_sectors = chunk_sectors
    dm_era_ctxs[eidx].nchunks       = nchunks
    dm_era_ctxs[eidx].current_era   = 1     # fresh devices start at era 1
    c: uint64 = 0
    while c < nchunks:
        dm_era_ctxs[eidx].era[c] = 0        # 0 = never written
        c = c + 1
    dm_era_ctxs[eidx].used = 1
    # Resume from persisted metadata if a valid superblock is present.
    rl: int32 = dm_era_reload(eidx_s)
    if rl < 0:
        dm_era_ctxs[eidx].used = 0
        printk0("dm: era metadata reload I/O error\n")
        return -5
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_era_ctxs[eidx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_ERA
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = origin_slot
    dm_devices[idx].targets[0].snap_ctx     = eidx_s
    dm_devices[idx].targets[0].under_start  = 0
    # Persist the initial (or resumed) superblock so a teardown before any
    # write still leaves valid metadata behind.
    if dm_era_persist(eidx_s) != 0:
        dm_era_ctxs[eidx].used = 0
        printk0("dm: era initial metadata persist failed\n")
        return -5
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used    = 0
        dm_era_ctxs[eidx].used  = 0
        return -5
    return dm_devices[idx].self_slot


def dm_era_ctx_of(name: Ptr[char]) -> int32:
    # Return the era-context index backing the era mapped device `name`, or -1
    # if none. Lets a caller (the self-test) advance the era and run queries.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            if dm_devices[i].targets[0].ttype == DM_TARGET_ERA:
                return dm_devices[i].targets[0].snap_ctx
            return -1
        i = i + 1
    return -1


def _dm_wc_alloc_ctx() -> int32:
    # Claim a free writecache context slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_WC_MAX:
        if dm_wc_ctxs[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def dm_create_writecache(name: Ptr[char], cache_slot: int32,
                         origin_slot: int32, block_sectors: uint64,
                         nslots: uint64, nblocks: uint64) -> int32:
    # Create a dm-writecache mapped device: a FAST `cache_slot` device
    # write-caching the SLOW `origin_slot` device. The address space is the
    # full origin span (nblocks cache blocks of `block_sectors` sectors each);
    # the fast device holds a superblock + a packed slot-metadata region +
    # `nslots` DATA slots. If the cache device already carries our superblock
    # with matching geometry, the slot state (which origin block each slot
    # holds + its dirty flag) is RESUMED from it, so un-flushed dirty writes
    # are recovered. This is the `dmsetup create NAME --table "0 LEN
    # writecache s ORIGINDEV CACHEDEV BLKSZ ..."` shape. Returns the
    # registered block slot or a negative error.
    dm_init()
    if cache_slot < 0 or origin_slot < 0:
        return -2
    if block_sectors == 0 or block_sectors > DM_WC_MAX_BLKSECS:
        printk0("dm: writecache block size exceeds staging buffer capacity\n")
        return -2
    if nblocks == 0:
        return -2
    if nslots == 0 or nslots > DM_WC_MAX_SLOTS:
        printk0("dm: writecache slot count exceeds mapping-table capacity\n")
        return -3
    length: uint64 = nblocks * block_sectors
    if length > blk_capacity_sectors(origin_slot):
        printk0("dm: writecache target exceeds underlying origin capacity\n")
        return -3
    # Cache-device footprint: 1 superblock + meta sectors + data region.
    data_start: uint64 = 1 + _dm_wc_meta_sectors(nslots)
    cache_need: uint64 = data_start + nslots * block_sectors
    if cache_need > blk_capacity_sectors(cache_slot):
        printk0("dm: writecache exceeds underlying cache-device capacity\n")
        return -3
    widx_s: int32 = _dm_wc_alloc_ctx()
    if widx_s < 0:
        printk0("dm: writecache context table full\n")
        return -4
    widx: uint64 = cast[uint64](widx_s)
    dm_wc_ctxs[widx].cache_slot    = cache_slot
    dm_wc_ctxs[widx].origin_slot   = origin_slot
    dm_wc_ctxs[widx].block_sectors = block_sectors
    dm_wc_ctxs[widx].nblocks       = nblocks
    dm_wc_ctxs[widx].nslots        = nslots
    dm_wc_ctxs[widx].data_start    = data_start
    s: uint64 = 0
    while s < nslots:
        dm_wc_ctxs[widx].valid[s] = 0
        dm_wc_ctxs[widx].dirty[s] = 0
        dm_wc_ctxs[widx].tag[s]   = 0
        s = s + 1
    dm_wc_ctxs[widx].used = 1
    # Resume from persisted metadata if a valid superblock is present (so
    # un-flushed dirty writes survive a teardown / crash).
    rl: int32 = dm_wc_reload(widx_s)
    if rl < 0:
        dm_wc_ctxs[widx].used = 0
        printk0("dm: writecache metadata reload I/O error\n")
        return -5
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_wc_ctxs[widx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_WRITECACHE
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = origin_slot
    dm_devices[idx].targets[0].snap_ctx     = widx_s
    dm_devices[idx].targets[0].under_start  = 0
    # Persist the initial (or resumed) superblock so a teardown before any
    # write still leaves valid metadata behind.
    if dm_wc_persist(widx_s) != 0:
        dm_wc_ctxs[widx].used = 0
        printk0("dm: writecache initial metadata persist failed\n")
        return -5
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used  = 0
        dm_wc_ctxs[widx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_wc_ctx_of(name: Ptr[char]) -> int32:
    # Return the writecache-context index backing the writecache mapped device
    # `name`, or -1 if none. Lets the self-test flush and observe dirty count.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            if dm_devices[i].targets[0].ttype == DM_TARGET_WRITECACHE:
                return dm_devices[i].targets[0].snap_ctx
            return -1
        i = i + 1
    return -1


def dm_create_delay(name: Ptr[char], under_slot: int32,
                    read_under_start: uint64, read_delay: uint64,
                    write_under_start: uint64, write_delay: uint64,
                    length: uint64) -> int32:
    # Create a mapped device with a SINGLE delay target covering the whole
    # virtual device [0, length): virtual sector v maps onto under_slot at
    # (read_under_start + v) for READs and (write_under_start + v) for WRITEs
    # (Linux's separate read/write delay tables), with each path deferred by
    # its OWN delay (in logical ticks). Data is a real linear passthrough. This
    # is the `dmsetup create NAME --table "0 LEN delay DEV ROFF RDLY DEV WOFF
    # WDLY"` shape. Returns the registered block slot or a negative error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    ucap: uint64 = blk_capacity_sectors(under_slot)
    if read_under_start + length > ucap or write_under_start + length > ucap:
        printk0("dm: delay target exceeds underlying capacity\n")
        return -3
    didx_s: int32 = _dm_delay_alloc_ctx()
    if didx_s < 0:
        printk0("dm: delay context table full\n")
        return -4
    didx: uint64 = cast[uint64](didx_s)
    dm_delay_ctxs[didx].under_slot        = under_slot
    dm_delay_ctxs[didx].read_under_start  = read_under_start
    dm_delay_ctxs[didx].write_under_start = write_under_start
    dm_delay_ctxs[didx].read_delay        = read_delay
    dm_delay_ctxs[didx].write_delay       = write_delay
    dm_delay_ctxs[didx].clock             = 0
    dm_delay_ctxs[didx].reads_deferred    = 0
    dm_delay_ctxs[didx].writes_deferred   = 0
    dm_delay_ctxs[didx].read_delay_total  = 0
    dm_delay_ctxs[didx].write_delay_total = 0
    dm_delay_ctxs[didx].max_queue_depth   = 0
    qi: uint64 = 0
    while qi < DM_DELAY_QDEPTH:
        dm_delay_ctxs[didx].q_pending[qi]  = 0
        dm_delay_ctxs[didx].q_deadline[qi] = 0
        dm_delay_ctxs[didx].q_is_write[qi] = 0
        qi = qi + 1
    dm_delay_ctxs[didx].used = 1
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        dm_delay_ctxs[didx].used = 0
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets               = 1
    dm_devices[idx].capacity                = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_DELAY
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].snap_ctx     = didx_s
    dm_devices[idx].targets[0].under_start  = read_under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used        = 0
        dm_delay_ctxs[didx].used    = 0
        return -5
    return dm_devices[idx].self_slot


def dm_delay_ctx_of(name: Ptr[char]) -> int32:
    # Return the delay-context index backing the delay mapped device `name`,
    # or -1 if none. Lets the self-test read the per-path deferral counters.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            if dm_devices[i].targets[0].ttype == DM_TARGET_DELAY:
                return dm_devices[i].targets[0].snap_ctx
            return -1
        i = i + 1
    return -1


def dm_delay_reads_deferred(d_idx: int32) -> int64:
    # Number of read ops that took the deferred read path, or -1 if invalid.
    if d_idx < 0 or cast[uint64](d_idx) >= DM_DELAY_MAX:
        return -1
    di: uint64 = cast[uint64](d_idx)
    if dm_delay_ctxs[di].used == 0:
        return -1
    return cast[int64](dm_delay_ctxs[di].reads_deferred)


def dm_delay_writes_deferred(d_idx: int32) -> int64:
    # Number of write ops that took the deferred write path, or -1 if invalid.
    if d_idx < 0 or cast[uint64](d_idx) >= DM_DELAY_MAX:
        return -1
    di: uint64 = cast[uint64](d_idx)
    if dm_delay_ctxs[di].used == 0:
        return -1
    return cast[int64](dm_delay_ctxs[di].writes_deferred)


def dm_delay_read_total(d_idx: int32) -> int64:
    # Summed read-path deferral ticks, or -1 if invalid.
    if d_idx < 0 or cast[uint64](d_idx) >= DM_DELAY_MAX:
        return -1
    di: uint64 = cast[uint64](d_idx)
    if dm_delay_ctxs[di].used == 0:
        return -1
    return cast[int64](dm_delay_ctxs[di].read_delay_total)


def dm_delay_write_total(d_idx: int32) -> int64:
    # Summed write-path deferral ticks, or -1 if invalid.
    if d_idx < 0 or cast[uint64](d_idx) >= DM_DELAY_MAX:
        return -1
    di: uint64 = cast[uint64](d_idx)
    if dm_delay_ctxs[di].used == 0:
        return -1
    return cast[int64](dm_delay_ctxs[di].write_delay_total)


def dm_delay_clock(d_idx: int32) -> int64:
    # Current logical clock (total ticks the queue has been advanced), or -1.
    if d_idx < 0 or cast[uint64](d_idx) >= DM_DELAY_MAX:
        return -1
    di: uint64 = cast[uint64](d_idx)
    if dm_delay_ctxs[di].used == 0:
        return -1
    return cast[int64](dm_delay_ctxs[di].clock)


def dm_remove(name: Ptr[char]) -> int32:
    # Tear down a mapped device by name: unregister its block-device
    # identity and free the MappedDevice slot. dmsetup remove NAME.
    # Returns 0 on success, -1 if no mapped device carried that name.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            # Releasing a snapshot VIEW also frees its shared CoW context.
            if dm_devices[i].targets[0].ttype == DM_TARGET_SNAPSHOT:
                sc: int32 = dm_devices[i].targets[0].snap_ctx
                if sc >= 0 and cast[uint64](sc) < DM_SNAP_MAX:
                    dm_snap_ctxs[cast[uint64](sc)].used = 0
            # Releasing an integrity device also frees its tag-store context.
            if dm_devices[i].targets[0].ttype == DM_TARGET_INTEGRITY:
                ic: int32 = dm_devices[i].targets[0].snap_ctx
                if ic >= 0 and cast[uint64](ic) < DM_INTEG_MAX:
                    dm_integ_ctxs[cast[uint64](ic)].used = 0
            # Releasing a thin device frees its mapping context; the shared
            # pool persists (other thin volumes may still draw from it).
            if dm_devices[i].targets[0].ttype == DM_TARGET_THIN:
                tc: int32 = dm_devices[i].targets[0].snap_ctx
                if tc >= 0 and cast[uint64](tc) < DM_THIN_DEV_MAX:
                    dm_thin_devs[cast[uint64](tc)].used = 0
            # Releasing a verity device frees its Merkle-tree context.
            if dm_devices[i].targets[0].ttype == DM_TARGET_VERITY:
                vc: int32 = dm_devices[i].targets[0].snap_ctx
                if vc >= 0 and cast[uint64](vc) < DM_VERITY_MAX:
                    dm_verity_ctxs[cast[uint64](vc)].used = 0
            # Releasing a cache device frees its cache-mapping context.
            if dm_devices[i].targets[0].ttype == DM_TARGET_CACHE:
                cc: int32 = dm_devices[i].targets[0].snap_ctx
                if cc >= 0 and cast[uint64](cc) < DM_CACHE_MAX:
                    dm_cache_ctxs[cast[uint64](cc)].used = 0
            # Releasing an era device frees its era-tracking context (the
            # persisted metadata on the metadata device survives).
            if dm_devices[i].targets[0].ttype == DM_TARGET_ERA:
                ec2: int32 = dm_devices[i].targets[0].snap_ctx
                if ec2 >= 0 and cast[uint64](ec2) < DM_ERA_MAX:
                    dm_era_ctxs[cast[uint64](ec2)].used = 0
            # Releasing a writecache device frees its slot-mapping context (the
            # persisted metadata + dirty data on the cache device survive, so a
            # fresh writecache over the same cache device resumes them).
            if dm_devices[i].targets[0].ttype == DM_TARGET_WRITECACHE:
                wc2: int32 = dm_devices[i].targets[0].snap_ctx
                if wc2 >= 0 and cast[uint64](wc2) < DM_WC_MAX:
                    dm_wc_ctxs[cast[uint64](wc2)].used = 0
            # Releasing a delay device frees its deferral context.
            if dm_devices[i].targets[0].ttype == DM_TARGET_DELAY:
                dc2: int32 = dm_devices[i].targets[0].snap_ctx
                if dc2 >= 0 and cast[uint64](dc2) < DM_DELAY_MAX:
                    dm_delay_ctxs[cast[uint64](dc2)].used = 0
            blk_unregister_by_name(name)
            dm_devices[i].used      = 0
            dm_devices[i].n_targets = 0
            dm_devices[i].capacity  = 0
            dm_devices[i].self_slot = -1
            return 0
        i = i + 1
    return -1


# =========================================================================
# Deterministic device-mapper self-test
# =========================================================================
#
# Gated boot self-test (init/main.ad, planted /etc/devmapper-test by
# build_initramfs.py when ENABLE_DEVMAPPER_TEST=1). It runs entirely
# against a DEDICATED in-kernel backing ramdisk (registered here as
# "dmback0"), so it never touches ram0's FAT image and is fully
# deterministic.
#
# It PROVES four things:
#
#   1. LINEAR remap correctness: write a known pattern THROUGH the linear
#      mapped device at virtual LBA L, then read the SAME data back from
#      the UNDERLYING backing device at the mapped offset (under_start+L).
#      The bytes match -> the linear target really remaps to the right
#      underlying sector.
#   2. CONCATENATION: a two-target mapped device routes virtual sectors
#      in span A to backing region A and virtual sectors in span B to a
#      DIFFERENT backing region B. Writing distinct patterns to one
#      virtual sector in each span and reading the underlying regions
#      back confirms each landed in the correct backing device offset.
#   3. CRYPT round-trip + IV-dependence: plaintext written through the
#      crypt device is CIPHERTEXT on the backing store (differs from the
#      plaintext), yet reads back through the crypt device as the
#      ORIGINAL plaintext. AND the SAME plaintext written to two
#      DIFFERENT virtual sectors produces DIFFERENT ciphertext on disk
#      (the plain64 IV is sector-dependent).
#
# Each marker line stamps EMERG so it reaches serial even at the prompt.

# Dedicated backing ramdisk: 256 sectors = 128 KiB. Module-scope per the
# Adder large-array quirk.
_DM_BACK_SECTORS: uint64 = 256
_dm_back_store:   Array[131072, uint8]   # 256 * 512
_dm_back_ops:     BlockDeviceOps

# Dedicated exception-store ramdisk for the dm-snapshot subtest: a SEPARATE
# backing device (Linux dm-snapshot keeps the CoW store on its own device),
# 256 sectors = 128 KiB.
_DM_EXC_SECTORS:  uint64 = 256
_dm_exc_store:    Array[131072, uint8]   # 256 * 512
_dm_exc_ops:      BlockDeviceOps

# Dedicated POOL DATA ramdisk for the dm-thin subtest: the physical block
# store the thin pool carves into on-demand blocks. 256 sectors = 128 KiB —
# deliberately SMALL relative to the thin device's huge virtual size so
# over-provisioning is observable.
_DM_POOL_SECTORS: uint64 = 256
_dm_pool_store:   Array[131072, uint8]   # 256 * 512
_dm_pool_ops:     BlockDeviceOps

# Dedicated DATA ramdisk for the dm-verity subtest (the device whose blocks
# are protected by the Merkle tree). 256 sectors = 128 KiB.
_DM_VERDATA_SECTORS: uint64 = 256
_dm_verdata_store:   Array[131072, uint8]   # 256 * 512
_dm_verdata_ops:     BlockDeviceOps

# Dedicated HASH-TREE ramdisk for the dm-verity subtest (holds the level-0
# hash block). 256 sectors = 128 KiB.
_DM_VERHASH_SECTORS: uint64 = 256
_dm_verhash_store:   Array[131072, uint8]   # 256 * 512
_dm_verhash_ops:     BlockDeviceOps

# Dedicated FAST CACHE ramdisk for the dm-cache subtest. Deliberately SMALL
# (32 sectors = 16 KiB) relative to the origin so eviction is exercised.
_DM_CFAST_SECTORS: uint64 = 32
_dm_cfast_store:   Array[16384, uint8]   # 32 * 512
_dm_cfast_ops:     BlockDeviceOps

# Dedicated SLOW ORIGIN ramdisk for the dm-cache subtest. 256 sectors =
# 128 KiB — much larger than the cache device above.
_DM_CORIG_SECTORS: uint64 = 256
_dm_corig_store:   Array[131072, uint8]   # 256 * 512
_dm_corig_ops:     BlockDeviceOps

# Dedicated ORIGIN ramdisk for the dm-era subtest. 256 sectors = 128 KiB.
_DM_EORIG_SECTORS: uint64 = 256
_dm_eorig_store:   Array[131072, uint8]   # 256 * 512
_dm_eorig_ops:     BlockDeviceOps

# Dedicated METADATA ramdisk for the dm-era subtest (holds the era
# superblock + packed per-chunk era array). 256 sectors = 128 KiB.
_DM_EMETA_SECTORS: uint64 = 256
_dm_emeta_store:   Array[131072, uint8]   # 256 * 512
_dm_emeta_ops:     BlockDeviceOps

# Dedicated FAST CACHE ramdisk for the dm-writecache subtest (holds the
# superblock + slot metadata + data slots). 256 sectors = 128 KiB.
_DM_WCACHE_SECTORS: uint64 = 256
_dm_wcache_store:   Array[131072, uint8]   # 256 * 512
_dm_wcache_ops:     BlockDeviceOps

# Dedicated SLOW ORIGIN ramdisk for the dm-writecache subtest. 256 sectors =
# 128 KiB.
_DM_WORIG_SECTORS: uint64 = 256
_dm_worig_store:   Array[131072, uint8]   # 256 * 512
_dm_worig_ops:     BlockDeviceOps

# Dedicated backing ramdisk for the dm-delay subtest. 256 sectors = 128 KiB.
_DM_DBACK_SECTORS: uint64 = 256
_dm_dback_store:   Array[131072, uint8]   # 256 * 512
_dm_dback_ops:     BlockDeviceOps

# Scratch buffers for the self-test (all module-scope, one sector each
# unless noted).
_dm_t_plain:   Array[512, uint8]   # plaintext written through a mapped dev
_dm_t_plain2:  Array[512, uint8]   # second plaintext (concat span B)
_dm_t_read:    Array[512, uint8]   # readback through a mapped dev
_dm_t_under:   Array[512, uint8]   # raw read from the backing device
_dm_t_under2:  Array[512, uint8]   # raw read from a second backing sector
_dm_t_key:     Array[64, uint8]    # AES-256-XTS key (32B data + 32B tweak)

# AES-XTS known-answer-test scratch (IEEE 1619 / OpenSSL test vector).
# Generously sized — these hold whole-sector transforms.
_dm_kat_key:   Array[64, uint8]
_dm_kat_pt:    Array[512, uint8]
_dm_kat_ct:    Array[512, uint8]
_dm_kat_out:   Array[512, uint8]

# dm-snapshot subtest scratch (all one full sector = 512 bytes — the most
# any of these ever carries — to avoid the BSS-overflow trap).
_dm_snap_orig:  Array[512, uint8]   # original origin-chunk contents
_dm_snap_new:   Array[512, uint8]   # new data written to the origin
_dm_snap_read:  Array[512, uint8]   # readback through snapshot / origin
_dm_snap_excrd: Array[512, uint8]   # raw read from the exception store
_dm_snap_untch: Array[512, uint8]   # pattern for the never-written chunk

# dm-integrity subtest scratch (all one full sector = 512 bytes to avoid the
# BSS-overflow trap).
_dm_integ_plain: Array[512, uint8]   # known data written through integrity dev
_dm_integ_read:  Array[512, uint8]   # readback through the integrity device
_dm_integ_raw:   Array[512, uint8]   # raw read from the backing device

# dm-thin subtest scratch (all one full sector = 512 bytes to avoid the
# BSS-overflow trap).
_dm_thin_pat0:   Array[512, uint8]   # pattern written to first thin vblock
_dm_thin_pat1:   Array[512, uint8]   # pattern written to second thin vblock
_dm_thin_pat0b:  Array[512, uint8]   # rewrite pattern for first thin vblock
_dm_thin_read:   Array[512, uint8]   # readback through the thin device
_dm_thin_zchk:   Array[512, uint8]   # all-zero reference for unprovisioned

# dm-verity subtest scratch. Block-sized buffers are a full DM_VERITY_BLOCK
# (4096 bytes) to avoid the BSS-overflow trap; the salt is DM_VERITY_SALT_LEN.
_dm_ver_data0:   Array[4096, uint8]   # clean data block written to data dev
_dm_ver_data1:   Array[4096, uint8]   # a second clean data block
_dm_ver_rd:      Array[4096, uint8]   # readback through the verity device
_dm_ver_salt:    Array[32, uint8]     # per-target verity salt
_dm_ver_raw:     Array[4096, uint8]   # raw block read from data/hash device

# dm-cache subtest scratch (all one full sector = 512 bytes to avoid the
# BSS-overflow trap; the cache subtest uses 1-sector cache blocks).
_dm_cache_pa:    Array[512, uint8]   # pattern for origin block A
_dm_cache_pb:    Array[512, uint8]   # pattern for origin block B
_dm_cache_pc:    Array[512, uint8]   # pattern for origin block C
_dm_cache_pd:    Array[512, uint8]   # pattern for origin block D
_dm_cache_pw:    Array[512, uint8]   # writeback/writethrough write pattern
_dm_cache_rd:    Array[512, uint8]   # readback through the cache device
_dm_cache_raw:   Array[512, uint8]   # raw read from the origin device

# dm-era subtest scratch (all one full sector = 512 bytes to avoid the
# BSS-overflow trap; the era subtest uses 8-sector chunks but writes 1
# sector — the first sector of each chunk — per chunk).
_dm_era_p0:      Array[512, uint8]   # pattern for chunk written in era 1
_dm_era_p1:      Array[512, uint8]   # pattern for chunk written in era 1
_dm_era_p2:      Array[512, uint8]   # pattern for chunk written in era 2
_dm_era_p3:      Array[512, uint8]   # pattern for chunk written in era 2
_dm_era_rd:      Array[512, uint8]   # readback through the era device
# Query result buffer: chunk indices returned by dm_era_query_since. Sized
# to DM_ERA_MAX_CHUNKS (256) so a full-device result never overflows.
_dm_era_qbuf:    Array[256, uint64]  # query result chunk indices

# dm-writecache subtest scratch (all one full sector = 512 bytes to avoid the
# BSS-overflow trap; the writecache subtest uses 1-sector cache blocks).
_dm_wc_pa:       Array[512, uint8]   # pattern written to origin block A
_dm_wc_pb:       Array[512, uint8]   # pattern written to origin block B
_dm_wc_pc:       Array[512, uint8]   # pattern written to origin block C
_dm_wc_orig0:    Array[512, uint8]   # pre-write origin contents (block A)
_dm_wc_rd:       Array[512, uint8]   # readback through the writecache device
_dm_wc_raw:      Array[512, uint8]   # raw read from the origin / cache device

# dm-delay subtest scratch (one full sector each to avoid the BSS-overflow
# trap; the delay subtest does 1-sector I/O).
_dm_dly_pa:      Array[512, uint8]   # pattern written through the delay device
_dm_dly_pb:      Array[512, uint8]   # second pattern (write path / second sec)
_dm_dly_rd:      Array[512, uint8]   # readback through the delay device
_dm_dly_raw:     Array[512, uint8]   # raw read from the backing device


def _dm_back_read(priv: uint64, lba: uint64, count: uint64,
                  buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_dm_back_store[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _dm_back_write(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_dm_back_store[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _dm_exc_read(priv: uint64, lba: uint64, count: uint64,
                 buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_dm_exc_store[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _dm_exc_write(priv: uint64, lba: uint64, count: uint64,
                  buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_dm_exc_store[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _dm_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _dm_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def _dm_emerg2(s: Ptr[char], a: uint64, b: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2(s, a, b)


def _dm_back_register() -> int32:
    # Register the dedicated test backing ramdisk as "dmback0". Returns
    # the slot, or the existing slot if already registered.
    existing: int32 = find_blockdev("dmback0")
    if existing >= 0:
        return existing
    # Zero the backing store so the test starts from a clean slate.
    z: uint64 = 0
    while z < 131072:
        _dm_back_store[z] = 0
        z = z + 1
    _dm_back_ops.read_sectors  = _dm_back_read
    _dm_back_ops.write_sectors = _dm_back_write
    _dm_back_ops.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev("dmback0", _DM_BACK_SECTORS,
                             &_dm_back_ops, 0)



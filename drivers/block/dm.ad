    return 0


def _dm_worig_register() -> int32:
    # Register the dedicated dm-writecache SLOW origin ramdisk as "dmworig0".
    existing: int32 = find_blockdev("dmworig0")
    if existing >= 0:
        return existing
    z: uint64 = 0
    while z < 131072:
        _dm_worig_store[z] = 0
        z = z + 1
    _dm_worig_ops.read_sectors  = _dm_worig_read
    _dm_worig_ops.write_sectors = _dm_worig_write
    _dm_worig_ops.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev("dmworig0", _DM_WORIG_SECTORS,
                             &_dm_worig_ops, 0)


def _dm_dback_read(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_dm_dback_store[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _dm_dback_write(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_dm_dback_store[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _dm_dback_register() -> int32:
    # Register the dedicated dm-delay backing ramdisk as "dmdback0".
    existing: int32 = find_blockdev("dmdback0")
    if existing >= 0:
        return existing
    z: uint64 = 0
    while z < 131072:
        _dm_dback_store[z] = 0
        z = z + 1
    _dm_dback_ops.read_sectors  = _dm_dback_read
    _dm_dback_ops.write_sectors = _dm_dback_write
    _dm_dback_ops.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev("dmdback0", _DM_DBACK_SECTORS,
                             &_dm_dback_ops, 0)


def _dm_buf_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Reference AES-256-XTS ciphertext for the known-answer test, computed
# offline by Python's `cryptography` library (an independent, trusted AES
# implementation). Parameters:
#   key      = bytes((i*17+5)&0xFF for i in range(64))   # 32B data+32B tweak
#   plaintext= bytes((i*3+42)&0xFF for i in range(512))  # one 512B sector
#   sector   = 7  (plain64 IV = 7 little-endian in a 16-byte tweak block)
# We assert the FIRST and LAST 16-byte ciphertext blocks; matching both
# pins the cipher, the tweak derivation and the GF(2^128) alpha-multiply
# across the whole sector.
_DM_KAT_SECTOR: uint64 = 7
_dm_kat_ct_first: Array[16, uint8]   # expected CT[0..15]
_dm_kat_ct_last:  Array[16, uint8]   # expected CT[496..511]


def _dm_xts_kat_load_expected():
    _dm_kat_ct_first[0] = 0x26
    _dm_kat_ct_first[1] = 0xb7
    _dm_kat_ct_first[2] = 0x7f
    _dm_kat_ct_first[3] = 0xa2
    _dm_kat_ct_first[4] = 0xe2
    _dm_kat_ct_first[5] = 0xc5
    _dm_kat_ct_first[6] = 0x64
    _dm_kat_ct_first[7] = 0xac
    _dm_kat_ct_first[8] = 0xdc
    _dm_kat_ct_first[9] = 0x4c
    _dm_kat_ct_first[10] = 0xd4
    _dm_kat_ct_first[11] = 0xb4
    _dm_kat_ct_first[12] = 0x8e
    _dm_kat_ct_first[13] = 0x61
    _dm_kat_ct_first[14] = 0x9b
    _dm_kat_ct_first[15] = 0x3f
    _dm_kat_ct_last[0] = 0xfe
    _dm_kat_ct_last[1] = 0x34
    _dm_kat_ct_last[2] = 0x89
    _dm_kat_ct_last[3] = 0xee
    _dm_kat_ct_last[4] = 0x1c
    _dm_kat_ct_last[5] = 0xad
    _dm_kat_ct_last[6] = 0x72
    _dm_kat_ct_last[7] = 0x2f
    _dm_kat_ct_last[8] = 0x6c
    _dm_kat_ct_last[9] = 0x16
    _dm_kat_ct_last[10] = 0xad
    _dm_kat_ct_last[11] = 0x4b
    _dm_kat_ct_last[12] = 0x22
    _dm_kat_ct_last[13] = 0x48
    _dm_kat_ct_last[14] = 0x69
    _dm_kat_ct_last[15] = 0xbb


def _dm_xts_kat() -> int32:
    # Returns 1 if the AES-256-XTS implementation reproduces the offline
    # reference vector AND decrypts it back to plaintext, else 0.
    _dm_xts_kat_load_expected()
    i: uint64 = 0
    while i < 64:
        _dm_kat_key[i] = cast[uint8]((i * 17 + 5) & 0xFF)
        i = i + 1
    i = 0
    while i < SECTOR_SIZE:
        _dm_kat_pt[i] = cast[uint8]((i * 3 + 42) & 0xFF)
        i = i + 1
    # Load the schedules directly from the KAT key (data = bytes 0..31,
    # tweak = bytes 32..63) and XTS-encrypt the whole sector.
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))
    _dm_xts_encrypt_sector(_DM_KAT_SECTOR,
                           cast[Ptr[uint8]](&_dm_kat_ct[0]),
                           cast[Ptr[uint8]](&_dm_kat_pt[0]))
    # First and last ciphertext blocks must match the reference.
    if _dm_buf_eq(&_dm_kat_ct[0], &_dm_kat_ct_first[0], 16) != 1:
        _dm_emerg0("[device-mapper] KAT first block mismatch\n")
        return 0
    if _dm_buf_eq(&_dm_kat_ct[496], &_dm_kat_ct_last[0], 16) != 1:
        _dm_emerg0("[device-mapper] KAT last block mismatch\n")
        return 0
    # Decrypt round-trip: must reproduce the plaintext exactly.
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))
    _dm_xts_decrypt_sector(_DM_KAT_SECTOR,
                           cast[Ptr[uint8]](&_dm_kat_out[0]),
                           cast[Ptr[uint8]](&_dm_kat_ct[0]))
    if _dm_buf_eq(&_dm_kat_out[0], &_dm_kat_pt[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] KAT decrypt round-trip mismatch\n")
        return 0
    return 1


def dm_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [device-mapper] marker lines.
    _dm_emerg0("[device-mapper] self-test start\n")
    dm_init()

    back: int32 = _dm_back_register()
    if back < 0:
        _dm_emerg0("[device-mapper] FAIL: backing register\n")
        return 0
    _dm_emerg1("[device-mapper] backing dmback0 slot=%d\n",
               cast[uint64](cast[int64](back)))

    ok: int32 = 1

    # --- Test 1: LINEAR target remaps to the right underlying sector ---
    # Map [0, 16) of a virtual device onto dmback0 starting at sector 32.
    # Write a pattern through the mapped device at virtual LBA 5; it must
    # land on backing sector 32 + 5 = 37.
    pi: uint64 = 0
    while pi < SECTOR_SIZE:
        _dm_t_plain[pi] = cast[uint8]((pi * 7 + 3) & 0xFF)
        pi = pi + 1
    lin: int32 = dm_create_linear("dmlin0", back, 32, 16)
    if lin < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_linear rc=%d\n",
                   cast[uint64](cast[int64](lin)))
        return 0
    if blk_write_sectors(lin, 5, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: linear write\n")
        return 0
    # Read the UNDERLYING backing sector 37 directly.
    if blk_read_sectors(back, 37, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read (linear)\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: linear remap landed on wrong sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] linear: vLBA5 -> backing sector 37 OK\n")
    # And it must read back through the mapped device unchanged.
    if blk_read_sectors(lin, 5, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: linear readback\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: linear readback mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] linear: readback byte-identical OK\n")

    # --- Test 2: CONCATENATION across two backing regions ---
    # Span A: virtual [0, 8) -> dmback0 @ 64. Span B: virtual [8, 16) ->
    # dmback0 @ 128. Write distinct patterns to a sector in each span and
    # confirm each landed in the correct backing region.
    qi: uint64 = 0
    while qi < SECTOR_SIZE:
        _dm_t_plain[qi]  = cast[uint8]((qi * 11 + 1) & 0xFF)   # span A
        _dm_t_plain2[qi] = cast[uint8]((qi * 13 + 9) & 0xFF)   # span B
        qi = qi + 1
    cc: int32 = dm_create_concat("dmcat0", back, 64, 8, back, 128, 8)
    if cc < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_concat rc=%d\n",
                   cast[uint64](cast[int64](cc)))
        return 0
    # Virtual LBA 2 is in span A -> backing 64 + 2 = 66.
    if blk_write_sectors(cc, 2, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: concat write A\n")
        return 0
    # Virtual LBA 10 is in span B (offset 2) -> backing 128 + 2 = 130.
    if blk_write_sectors(cc, 10, 1, &_dm_t_plain2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: concat write B\n")
        return 0
    if blk_read_sectors(back, 66, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 66\n")
        return 0
    if blk_read_sectors(back, 130, 1, &_dm_t_under2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 130\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: concat span A wrong backing sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] concat: span A vLBA2 -> backing 66 OK\n")
    if _dm_buf_eq(&_dm_t_plain2[0], &_dm_t_under2[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: concat span B wrong backing sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] concat: span B vLBA10 -> backing 130 OK\n")

    # --- Test 3: CRYPT round-trip + IV-dependence ---
    # Map [0, 16) onto dmback0 @ 192 with a fixed key. Write identical
    # plaintext to virtual sectors 0 and 1; on the backing store sectors
    # 192 and 193 must hold CIPHERTEXT that (a) differs from the plaintext
    # and (b) differs from EACH OTHER (sector-dependent IV). Reading both
    # back through the crypt device must return the original plaintext.
    ki2: uint64 = 0
    while ki2 < DM_KEY_LEN:
        _dm_t_key[ki2] = cast[uint8]((ki2 * 17 + 5) & 0xFF)
        ki2 = ki2 + 1
    pj: uint64 = 0
    while pj < SECTOR_SIZE:
        _dm_t_plain[pj] = cast[uint8]((pj * 3 + 42) & 0xFF)
        pj = pj + 1
    cr: int32 = dm_create_crypt("dmcrypt0", back, 192, 16,
                                &_dm_t_key[0], DM_KEY_LEN)
    if cr < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_crypt rc=%d\n",
                   cast[uint64](cast[int64](cr)))
        return 0
    # Same plaintext to virtual sectors 0 and 1.
    if blk_write_sectors(cr, 0, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt write sec0\n")
        return 0
    if blk_write_sectors(cr, 1, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt write sec1\n")
        return 0
    # Backing 192 / 193 hold the two ciphertexts.
    if blk_read_sectors(back, 192, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 192\n")
        return 0
    if blk_read_sectors(back, 193, 1, &_dm_t_under2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 193\n")
        return 0
    # (a) ciphertext on disk differs from plaintext (real encryption,
    # not a passthrough).
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt backing == plaintext (no encryption)\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-ciphertext: backing sector 192 is ciphertext OK\n")
    # (b) the two sectors' ciphertext differ (IV is sector-dependent).
    if _dm_buf_eq(&_dm_t_under[0], &_dm_t_under2[0], SECTOR_SIZE) != 0:
        _dm_emerg0("[device-mapper] FAIL: identical plaintext -> identical ciphertext (IV not sector-keyed)\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-tweak: same plaintext, two sectors -> different ciphertext OK\n")
    # Round-trip: read back through the crypt device -> original plaintext.
    if blk_read_sectors(cr, 0, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt readback sec0\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: crypt round-trip sec0 mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-roundtrip-sec0: sector 0 round-trips to plaintext OK\n")
    if blk_read_sectors(cr, 1, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt readback sec1\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: crypt round-trip sec1 mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-roundtrip-sec1: sector 1 round-trips to plaintext OK\n")

    # --- Test 4: AES-256-XTS KNOWN-ANSWER TEST (independent vector) ---
    # The highest-confidence check: encrypt a fixed plaintext sector with
    # a fixed 64-byte key at a fixed sector number and assert the
    # ciphertext byte-for-byte matches a reference vector computed OFFLINE
    # by Python's `cryptography` AES-XTS (key = (i*17+5)&0xFF, plaintext =
    # (i*3+42)&0xFF, sector = 7, plain64 IV). This pins the cipher, the
    # tweak derivation AND the GF(2^128) alpha-multiply across all 32
    # blocks of the sector (first and LAST block are both asserted). Then
    # decrypt it back and assert it returns the plaintext.
    if _dm_xts_kat() != 1:
        _dm_emerg0("[device-mapper] FAIL: AES-256-XTS known-answer test\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-kat: AES-256-XTS vector matches reference OK\n")

    # --- Test 5: dm-SNAPSHOT copy-on-write + passthrough ---
    # Build a snapshot of an origin region with chunk size 8 sectors,
    # backed by a SEPARATE exception store (dmexc0). Seed origin chunk 4
    # (LBA 32) with a known ORIGINAL pattern and an UNTOUCHED chunk 6 (LBA
    # 48) with a different pattern. Take the snapshot, then WRITE new data
    # to origin chunk 4 THROUGH the snapshot-origin device — this must CoW
    # the original into the exception store. Then prove:
    #   (a) the snapshot view still reads the ORIGINAL pre-image,
    #   (b) the exception store actually holds that pre-image,
    #   (c) the origin now reads the NEW data, and
    #   (d) the never-written chunk reads through to the origin on both
    #       the snapshot view and the origin device.
    exc: int32 = _dm_exc_register()
    if exc < 0:
        _dm_emerg0("[device-mapper] FAIL: exception store register\n")
        return 0
    _dm_emerg1("[device-mapper] snapshot exc-store dmexc0 slot=%d\n",
               cast[uint64](cast[int64](exc)))
    si: uint64 = 0
    while si < SECTOR_SIZE:
        _dm_snap_orig[si]  = cast[uint8]((si * 5 + 17) & 0xFF)   # chunk 4
        _dm_snap_new[si]   = cast[uint8]((si * 9 + 200) & 0xFF)  # overwrite
        _dm_snap_untch[si] = cast[uint8]((si * 3 + 77) & 0xFF)   # chunk 6
        si = si + 1
    # Seed the origin chunks directly on the backing device. Chunk 4 ->
    # LBA 4*8 = 32; chunk 6 -> LBA 6*8 = 48.
    if blk_write_sectors(back, 32, 1, &_dm_snap_orig[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot seed origin chunk 4\n")
        return 0
    if blk_write_sectors(back, 48, 1, &_dm_snap_untch[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot seed origin chunk 6\n")
        return 0
    # Create the snapshot VIEW (chunk=8, length=64) and its CoW origin.
    snapv: int32 = dm_create_snapshot("dmsnap0", back, exc, 8, 64)
    if snapv < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_snapshot rc=%d\n",
                   cast[uint64](cast[int64](snapv)))
        return 0
    sctx: int32 = dm_snapshot_ctx_of("dmsnap0")
    if sctx < 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot ctx lookup\n")
        return 0
    snapo: int32 = dm_create_snapshot_origin("dmsnap0-origin", sctx, 64)
    if snapo < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_snapshot_origin rc=%d\n",
                   cast[uint64](cast[int64](snapo)))
        return 0
    # Overwrite origin chunk 4 (LBA 32) THROUGH the CoW origin device. This
    # must copy the ORIGINAL out to the exception store first.
    if blk_write_sectors(snapo, 32, 1, &_dm_snap_new[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot origin write\n")
        return 0

    # (a) The snapshot view must STILL read the original pre-image.
    if blk_read_sectors(snapv, 32, 1, &_dm_snap_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot view read (chunk 4)\n")
        return 0
    if _dm_buf_eq(&_dm_snap_read[0], &_dm_snap_orig[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: snapshot view lost pre-image (CoW broken)\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] snapshot: CoW preserved origin pre-image OK\n")
        _dm_emerg0("[dm] PASS snapshot-cow\n")

    # (b) The exception store itself must hold the original pre-image. The
    # first CoW allocates exception-store chunk 0 -> LBA 0.
    if blk_read_sectors(exc, 0, 1, &_dm_snap_excrd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: exception store read\n")
        return 0
    if _dm_buf_eq(&_dm_snap_excrd[0], &_dm_snap_orig[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: exception store missing pre-image\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] snapshot: exception store holds pre-image OK\n")

    # (c) The origin must now read the NEW data (live view advanced).
    if blk_read_sectors(snapo, 32, 1, &_dm_snap_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot origin readback (chunk 4)\n")
        return 0
    if _dm_buf_eq(&_dm_snap_read[0], &_dm_snap_new[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: origin did not advance to new data\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] snapshot: origin reads new data OK\n")

    # (d) A chunk never written (chunk 6, LBA 48) reads through to the
    # origin on BOTH the snapshot view and the origin device.
    if blk_read_sectors(snapv, 48, 1, &_dm_snap_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: snapshot view read (chunk 6)\n")
        return 0
    if _dm_buf_eq(&_dm_snap_read[0], &_dm_snap_untch[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: snapshot passthrough (view) mismatch\n")
        ok = 0
    else:
        if blk_read_sectors(snapo, 48, 1, &_dm_snap_excrd[0]) != 0:
            _dm_emerg0("[device-mapper] FAIL: snapshot origin read (chunk 6)\n")
            return 0
        if _dm_buf_eq(&_dm_snap_excrd[0], &_dm_snap_untch[0], SECTOR_SIZE) != 1:
            _dm_emerg0("[device-mapper] FAIL: snapshot passthrough (origin) mismatch\n")
            ok = 0
        else:
            _dm_emerg0("[dm] PASS snapshot-passthrough\n")

    if ok == 1:
        _dm_emerg0("[dm] snapshot PASS\n")

    # --- Test 6: dm-INTEGRITY per-sector tag round-trip + corruption detect ---
    # Map [0, 32) of a virtual device onto dmback0 @ 224 with an integrity
    # target. Write a KNOWN pattern through the integrity device at virtual
    # LBA 3 (a crc32c tag, salted with the underlying sector, is computed and
    # stored). Read it back through the integrity device and verify (a) the
    # data round-trips byte-identical AND the stored tag validated. Then
    # CORRUPT the underlying backing sector directly (simulate bit-rot by
    # flipping a byte on the raw backing device behind the target) and read
    # again through the integrity device: the recomputed tag must NOT match
    # the stored tag, so the read must FAIL (return an error) instead of
    # handing back the corrupted bytes.
    ii: uint64 = 0
    while ii < SECTOR_SIZE:
        _dm_integ_plain[ii] = cast[uint8]((ii * 19 + 23) & 0xFF)
        ii = ii + 1
    integ: int32 = dm_create_integrity("dmint0", back, 224, 32)
    if integ < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_integrity rc=%d\n",
                   cast[uint64](cast[int64](integ)))
        return 0
    # Write the known sector through the integrity device (tag computed+stored).
    if blk_write_sectors(integ, 3, 1, &_dm_integ_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity write\n")
        return 0
    # Read it back: must round-trip byte-identical (tag validated en route).
    if blk_read_sectors(integ, 3, 1, &_dm_integ_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity readback (tag should have validated)\n")
        return 0
    if _dm_buf_eq(&_dm_integ_plain[0], &_dm_integ_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: integrity round-trip mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] integrity: tag validated round-trip OK\n")
    # Now CORRUPT the underlying backing sector directly. Virtual LBA 3 ->
    # backing sector 224 + 3 = 227. Read it raw, flip one byte, write it back
    # raw — the integrity target's stored tag is untouched, so the next read
    # through the integrity device must detect the mismatch.
    if blk_read_sectors(back, 227, 1, &_dm_integ_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity raw backing read 227\n")
        return 0
    _dm_integ_raw[0] = cast[uint8](cast[uint64](_dm_integ_raw[0]) ^ 0xFF)
    if blk_write_sectors(back, 227, 1, &_dm_integ_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: integrity raw backing write 227\n")
        return 0
    # Read through the integrity device again: it MUST fail (non-zero rc)
    # because the recomputed tag no longer matches the stored tag.
    corrupt_rc: int32 = blk_read_sectors(integ, 3, 1, &_dm_integ_read[0])
    if corrupt_rc == 0:
        _dm_emerg0("[device-mapper] FAIL: integrity returned corrupted data (no detection)\n")
        ok = 0
    else:
        _dm_emerg1("[dm] PASS integrity-detect-corruption (read rc=%d)\n",
                   cast[uint64](cast[int64](corrupt_rc)))

    if ok == 1:
        _dm_emerg0("[dm] integrity PASS\n")

    # --- Test 7: dm-THIN thin provisioning (on-demand pool allocation) ---
    # Build a thin POOL over a SMALL dedicated data ramdisk (dmpool0, 256
    # sectors) with block_sectors=8, nblocks=32 (32*8 = 256 sectors). Then
    # create a thin device whose VIRTUAL size is 8192 sectors (1024 blocks)
    # — 32x the pool's physical capacity, so it is heavily over-provisioned.
    # Prove:
    #   (a) reading an UNPROVISIONED virtual block returns ZEROS and consumes
    #       ZERO pool blocks (no physical allocation on read),
    #   (b) writing two specific virtual blocks allocates EXACTLY two pool
    #       blocks and the data reads back byte-correct,
    #   (c) RE-writing an already-provisioned block does NOT allocate a new
    #       pool block (allocation count unchanged),
    #   (d) the mapping distinguishes provisioned (reads data) vs
    #       unprovisioned (reads zeros) virtual regions.
    pooldd: int32 = _dm_pool_register()
    if pooldd < 0:
        _dm_emerg0("[device-mapper] FAIL: thin pool data register\n")
        return 0
    _dm_emerg1("[device-mapper] thin pool-data dmpool0 slot=%d\n",
               cast[uint64](cast[int64](pooldd)))
    ti2: uint64 = 0
    while ti2 < SECTOR_SIZE:
        _dm_thin_pat0[ti2]  = cast[uint8]((ti2 * 7 + 31) & 0xFF)
        _dm_thin_pat1[ti2]  = cast[uint8]((ti2 * 13 + 5) & 0xFF)
        _dm_thin_pat0b[ti2] = cast[uint8]((ti2 * 23 + 99) & 0xFF)
        _dm_thin_zchk[ti2]  = 0
        ti2 = ti2 + 1
    poolidx: int32 = dm_create_thin_pool(pooldd, 8, 32)
    if poolidx < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_thin_pool rc=%d\n",
                   cast[uint64](cast[int64](poolidx)))
        return 0
    # Virtual size = 8192 sectors (1024 blocks) >> 256 pool sectors.
    thin: int32 = dm_create_thin("dmthin0", poolidx, 8192)
    if thin < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_thin rc=%d\n",
                   cast[uint64](cast[int64](thin)))
        return 0

    # (a) Read an UNPROVISIONED virtual block (block 100 -> vsec 800). It
    # must read back as zeros AND must not have consumed any pool block.
    if blk_read_sectors(thin, 800, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin unprovisioned read\n")
        return 0
    a0: int64 = dm_thin_pool_allocated(poolidx)
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_zchk[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin unprovisioned read not zero\n")
        ok = 0
    elif a0 != 0:
        _dm_emerg1("[device-mapper] FAIL: thin read consumed pool blocks (alloc=%d)\n",
                   cast[uint64](a0))
        ok = 0
    else:
        _dm_emerg0("[devmapper] thin: unprovisioned read returns zeros OK\n")

    # (b) Write two specific virtual blocks: block 5 (vsec 40) and block 200
    # (vsec 1600). Each first-write must allocate exactly one pool block, so
    # the allocation count goes 0 -> 2, and the data must read back correctly.
    if blk_write_sectors(thin, 40, 1, &_dm_thin_pat0[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin write vblk5\n")
        return 0
    if blk_write_sectors(thin, 1600, 1, &_dm_thin_pat1[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin write vblk200\n")
        return 0
    a1: int64 = dm_thin_pool_allocated(poolidx)
    if a1 != 2:
        _dm_emerg1("[device-mapper] FAIL: thin two writes != two pool blocks (alloc=%d)\n",
                   cast[uint64](a1))
        ok = 0
    else:
        _dm_emerg0("[dm] PASS thin-ondemand-alloc\n")
    # Data must read back byte-identical from both provisioned blocks.
    if blk_read_sectors(thin, 40, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin readback vblk5\n")
        return 0
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_pat0[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin vblk5 data mismatch\n")
        ok = 0
    if blk_read_sectors(thin, 1600, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin readback vblk200\n")
        return 0
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_pat1[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin vblk200 data mismatch\n")
        ok = 0

    # (c) Re-write an already-provisioned block (block 5). The mapping
    # already exists, so NO new pool block may be allocated: the count must
    # stay at 2. The new data must read back.
    if blk_write_sectors(thin, 40, 1, &_dm_thin_pat0b[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin rewrite vblk5\n")
        return 0
    a2: int64 = dm_thin_pool_allocated(poolidx)
    if a2 != 2:
        _dm_emerg1("[device-mapper] FAIL: thin rewrite allocated a block (alloc=%d)\n",
                   cast[uint64](a2))
        ok = 0
    else:
        _dm_emerg0("[dm] PASS thin-remap-stable\n")
    if blk_read_sectors(thin, 40, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin readback after rewrite\n")
        return 0
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_pat0b[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin rewrite data mismatch\n")
        ok = 0

    # (d) Provisioned vs unprovisioned distinction: block 5 (provisioned)
    # reads the data, while a NEIGHBOURING never-written block (block 6 ->
    # vsec 48) still reads zeros and did not consume a pool block.
    if blk_read_sectors(thin, 48, 1, &_dm_thin_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: thin neighbour read\n")
        return 0
    a3: int64 = dm_thin_pool_allocated(poolidx)
    if _dm_buf_eq(&_dm_thin_read[0], &_dm_thin_zchk[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: thin neighbour not unprovisioned\n")
        ok = 0
    elif a3 != 2:
        _dm_emerg1("[device-mapper] FAIL: thin neighbour read allocated (alloc=%d)\n",
                   cast[uint64](a3))
        ok = 0
    else:
        _dm_emerg0("[devmapper] thin: provisioned vs unprovisioned distinguished OK\n")

    if ok == 1:
        _dm_emerg0("[dm] thin PASS\n")

    # --- Test 8: dm-VERITY read-only Merkle-tree integrity ---
    # Build a verity device over a dedicated DATA ramdisk (dmverdata0) with
    # its hash tree on a separate HASH ramdisk (dmverhash0). Two clean 4096-
    # byte data blocks (block 0 and block 1) are written to the data device;
    # dm_create_verity() then hashes them into a level-0 hash block and
    # captures the trusted ROOT = sha256(salt || hash-block). We then PROVE:
    #   (a) a CLEAN block verifies and round-trips byte-identical through the
    #       verity device (leaf matches, hash block hashes up to the root);
    #   (b) flipping a byte in a DATA block makes its next verified read FAIL
    #       with -5 (the recomputed leaf no longer matches the stored leaf);
    #   (c) flipping a byte in the block's own LEAF in the HASH-TREE block
    #       makes its read FAIL (hash-tree corruption is caught);
    #   (d) corrupting a DIFFERENT leaf slot in the hash block — leaving the
    #       block-under-test's own leaf intact — still FAILS, because the
    #       whole hash block no longer hashes to the trusted ROOT (root-hash
    #       mismatch is caught up the tree).
    verdata: int32 = _dm_verdata_register()
    if verdata < 0:
        _dm_emerg0("[device-mapper] FAIL: verity data register\n")
        return 0
    verhash: int32 = _dm_verhash_register()
    if verhash < 0:
        _dm_emerg0("[device-mapper] FAIL: verity hash register\n")
        return 0
    _dm_emerg2("[device-mapper] verity data dmverdata0 slot=%d hash slot=%d\n",
               cast[uint64](cast[int64](verdata)),
               cast[uint64](cast[int64](verhash)))
    # Fill two distinct clean data blocks (4096 bytes each).
    vbi: uint64 = 0
    while vbi < DM_VERITY_BLOCK:
        _dm_ver_data0[vbi] = cast[uint8]((vbi * 5 + 17) & 0xFF)
        _dm_ver_data1[vbi] = cast[uint8]((vbi * 9 + 200) & 0xFF)
        vbi = vbi + 1
    # Per-target salt.
    vsi: uint64 = 0
    while vsi < DM_VERITY_SALT_LEN:
        _dm_ver_salt[vsi] = cast[uint8]((vsi * 37 + 11) & 0xFF)
        vsi = vsi + 1
    # Write the two clean data blocks to the data device: block 0 @ sector 0,
    # block 1 @ sector 8 (DM_VERITY_BLOCK_SECS).
    if blk_write_sectors(verdata, 0, DM_VERITY_BLOCK_SECS,
                         &_dm_ver_data0[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity data block0 write\n")
        return 0
    if blk_write_sectors(verdata, DM_VERITY_BLOCK_SECS, DM_VERITY_BLOCK_SECS,
                         &_dm_ver_data1[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity data block1 write\n")
        return 0
    # Build the verity device over 2 data blocks; hash block at hash sector 0.
    verity: int32 = dm_create_verity("dmverity0", verdata, 0, verhash, 0, 2,
                                     &_dm_ver_salt[0])
    if verity < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_verity rc=%d\n",
                   cast[uint64](cast[int64](verity)))
        return 0

    # (a) Clean block 0 verifies and round-trips byte-identical.
    if blk_read_sectors(verity, 0, DM_VERITY_BLOCK_SECS, &_dm_ver_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity clean read (should verify)\n")
        return 0
    if _dm_buf_eq(&_dm_ver_rd[0], &_dm_ver_data0[0], DM_VERITY_BLOCK) != 1:
        _dm_emerg0("[device-mapper] FAIL: verity clean round-trip mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[dm] verity clean block verified + round-trip OK\n")
    # Clean block 1 also verifies (so the upcoming failures are real, not a
    # pre-existing breakage).
    if blk_read_sectors(verity, DM_VERITY_BLOCK_SECS, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity clean block1 read\n")
        return 0
    if _dm_buf_eq(&_dm_ver_rd[0], &_dm_ver_data1[0], DM_VERITY_BLOCK) != 1:
        _dm_emerg0("[device-mapper] FAIL: verity clean block1 mismatch\n")
        ok = 0

    # (b) Corrupt a byte in DATA block 1 (raw, behind the target) and read it
    # back through verity — the recomputed leaf must mismatch -> read FAILS.
    if blk_read_sectors(verdata, DM_VERITY_BLOCK_SECS, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity raw data block1 read\n")
        return 0
    _dm_ver_raw[100] = cast[uint8](cast[uint64](_dm_ver_raw[100]) ^ 0xFF)
    if blk_write_sectors(verdata, DM_VERITY_BLOCK_SECS, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity raw data block1 write\n")
        return 0
    vdrc: int32 = blk_read_sectors(verity, DM_VERITY_BLOCK_SECS,
                                   DM_VERITY_BLOCK_SECS, &_dm_ver_rd[0])
    if vdrc == 0:
        _dm_emerg0("[device-mapper] FAIL: verity returned corrupt DATA (no detection)\n")
        ok = 0
    else:
        _dm_emerg1("[dm] verity data-corruption rejected (read rc=%d) OK\n",
                   cast[uint64](cast[int64](vdrc)))
    # Restore data block 1 to clean so it verifies again.
    if blk_write_sectors(verdata, DM_VERITY_BLOCK_SECS, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_data1[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity restore data block1\n")
        return 0

    # (c) Corrupt block 1's OWN leaf in the level-0 HASH block (raw, on the
    # hash device) and read block 1 through verity — the stored leaf no
    # longer matches the (clean) data, so the read must FAIL. Block 1's leaf
    # occupies bytes [DM_VERITY_DIGEST, 2*DM_VERITY_DIGEST) of the hash block.
    if blk_read_sectors(verhash, 0, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity raw hash block read (c)\n")
        return 0
    _dm_ver_raw[DM_VERITY_DIGEST] = \
        cast[uint8](cast[uint64](_dm_ver_raw[DM_VERITY_DIGEST]) ^ 0xFF)
    if blk_write_sectors(verhash, 0, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity raw hash block write (c)\n")
        return 0
    vhrc: int32 = blk_read_sectors(verity, DM_VERITY_BLOCK_SECS,
                                   DM_VERITY_BLOCK_SECS, &_dm_ver_rd[0])
    if vhrc == 0:
        _dm_emerg0("[device-mapper] FAIL: verity returned data with corrupt HASH-TREE leaf\n")
        ok = 0
    else:
        _dm_emerg1("[dm] verity hash-tree-corruption rejected (read rc=%d) OK\n",
                   cast[uint64](cast[int64](vhrc)))

    # (d) Restore block 1's leaf, then corrupt block 1's leaf AGAIN but read
    # BLOCK 0 instead. Block 0's own leaf is still intact (matches), yet the
    # whole hash block no longer hashes to the trusted ROOT, so the up-the-
    # tree root check must FAIL the read — root-hash mismatch is caught.
    # (We rebuild the clean hash block by re-reading + flipping a fresh copy.)
    # First read the CLEAN hash block back (currently corrupted at block1's
    # leaf), so restore it: recompute it by reading the clean data — simplest
    # is to flip the same byte back.
    if blk_read_sectors(verhash, 0, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity raw hash block read (d-restore)\n")
        return 0
    _dm_ver_raw[DM_VERITY_DIGEST] = \
        cast[uint8](cast[uint64](_dm_ver_raw[DM_VERITY_DIGEST]) ^ 0xFF)
    if blk_write_sectors(verhash, 0, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity restore hash block (d)\n")
        return 0
    # Confirm the hash block is clean again: block 0 verifies.
    if blk_read_sectors(verity, 0, DM_VERITY_BLOCK_SECS, &_dm_ver_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity block0 read after hash restore\n")
        return 0
    if _dm_buf_eq(&_dm_ver_rd[0], &_dm_ver_data0[0], DM_VERITY_BLOCK) != 1:
        _dm_emerg0("[device-mapper] FAIL: verity hash block not restored clean\n")
        ok = 0
    # Now corrupt block 1's leaf slot (NOT block 0's) and read BLOCK 0.
    if blk_read_sectors(verhash, 0, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity raw hash block read (d)\n")
        return 0
    _dm_ver_raw[DM_VERITY_DIGEST + 1] = \
        cast[uint8](cast[uint64](_dm_ver_raw[DM_VERITY_DIGEST + 1]) ^ 0xFF)
    if blk_write_sectors(verhash, 0, DM_VERITY_BLOCK_SECS,
                        &_dm_ver_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: verity raw hash block write (d)\n")
        return 0
    vrrc: int32 = blk_read_sectors(verity, 0, DM_VERITY_BLOCK_SECS,
                                   &_dm_ver_rd[0])
    if vrrc == 0:
        _dm_emerg0("[device-mapper] FAIL: verity passed despite ROOT mismatch\n")
        ok = 0
    else:
        _dm_emerg1("[dm] verity root-hash mismatch rejected (read rc=%d) OK\n",
                   cast[uint64](cast[int64](vrrc)))

    if ok == 1:
        _dm_emerg0("[dm] verity PASS\n")

    # Free the earlier subtests' mapped-device slots BEFORE the cache subtest:
    # the MappedDevice table holds DM_MAX_DEVICES (8) slots and tests 1..8 have
    # already claimed all of them. Each device above is fully exercised, so
    # releasing them now reclaims slots for the two cache devices below.
    dm_remove("dmlin0")
    dm_remove("dmcat0")
    dm_remove("dmcrypt0")
    dm_remove("dmsnap0")
    dm_remove("dmsnap0-origin")
    dm_remove("dmint0")
    dm_remove("dmthin0")
    dm_remove("dmverity0")

    # --- Test 9: dm-CACHE fast-device caching of a slow origin ---
    # Build a cache device over a SMALL fast ramdisk (dmcfast0, 2 usable
    # slots) fronting a LARGER slow origin (dmcorig0). 1-sector cache blocks,
    # ncache=2 < nblocks=8 so eviction is forced. We PROVE:
    #   (a) a COLD read of an origin block MISSes, PROMOTEs the block into a
    #       cache slot, and serves the correct data; the SECOND read HITs (the
    #       hit/miss counters are genuinely computed);
    #   (b) WRITETHROUGH: a write updates BOTH cache and origin (origin stays
    #       coherent) and the slot stays CLEAN;
    #   (c) EVICTION of a DIRTY victim (writeback mode) writes the victim's
    #       newest data BACK to the origin before reusing the slot, so no data
    #       is lost;
    #   (d) WRITEBACK: a write updates ONLY the cache (origin left STALE) until
    #       an explicit FLUSH, after which the origin matches the cache.
    cfast: int32 = _dm_cfast_register()
    if cfast < 0:
        _dm_emerg0("[device-mapper] FAIL: cache fast-device register\n")
        return 0
    corig: int32 = _dm_corig_register()
    if corig < 0:
        _dm_emerg0("[device-mapper] FAIL: cache origin register\n")
        return 0
    _dm_emerg2("[device-mapper] cache fast dmcfast0 slot=%d origin dmcorig0 slot=%d\n",
               cast[uint64](cast[int64](cfast)),
               cast[uint64](cast[int64](corig)))
    # Distinct origin-block patterns (one sector each).
    cbi: uint64 = 0
    while cbi < SECTOR_SIZE:
        _dm_cache_pa[cbi] = cast[uint8]((cbi * 3 + 10) & 0xFF)
        _dm_cache_pb[cbi] = cast[uint8]((cbi * 5 + 20) & 0xFF)
        _dm_cache_pc[cbi] = cast[uint8]((cbi * 7 + 30) & 0xFF)
        _dm_cache_pd[cbi] = cast[uint8]((cbi * 11 + 40) & 0xFF)
        _dm_cache_pw[cbi] = cast[uint8]((cbi * 13 + 50) & 0xFF)
        cbi = cbi + 1
    # Pre-seed origin blocks 0..3 directly on the slow device.
    if blk_write_sectors(corig, 0, 1, &_dm_cache_pa[0]) != 0 or \
       blk_write_sectors(corig, 1, 1, &_dm_cache_pb[0]) != 0 or \
       blk_write_sectors(corig, 2, 1, &_dm_cache_pc[0]) != 0 or \
       blk_write_sectors(corig, 3, 1, &_dm_cache_pd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache origin seed\n")
        return 0

    # ---- WRITETHROUGH device: miss/hit accounting, eviction, coherence ----
    cwt: int32 = dm_create_cache("dmcache-wt", cfast, corig, 1, 2, 8,
                                 DM_CACHE_WRITETHROUGH)
    if cwt < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_cache wt rc=%d\n",
                   cast[uint64](cast[int64](cwt)))
        return 0
    wtctx: int32 = dm_cache_ctx_of("dmcache-wt")

    # (a) Cold read of block 0 -> MISS then promote; data must equal pattern A.
    if blk_read_sectors(cwt, 0, 1, &_dm_cache_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache cold read blk0\n")
        return 0
    h0: int64 = dm_cache_hits(wtctx)
    m0: int64 = dm_cache_misses(wtctx)
    if _dm_buf_eq(&_dm_cache_rd[0], &_dm_cache_pa[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache cold read wrong data\n")
        ok = 0
    elif h0 != 0 or m0 != 1:
        _dm_emerg2("[device-mapper] FAIL: cache cold read accounting (hits=%d misses=%d)\n",
                   cast[uint64](h0), cast[uint64](m0))
        ok = 0
    else:
        _dm_emerg0("[dm] cache cold read MISS + promote OK\n")
    # Second read of block 0 -> HIT (hits 0 -> 1, misses unchanged).
    if blk_read_sectors(cwt, 0, 1, &_dm_cache_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache warm read blk0\n")
        return 0
    h1: int64 = dm_cache_hits(wtctx)
    m1: int64 = dm_cache_misses(wtctx)
    if _dm_buf_eq(&_dm_cache_rd[0], &_dm_cache_pa[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache warm read wrong data\n")
        ok = 0
    elif h1 != 1 or m1 != 1:
        _dm_emerg2("[device-mapper] FAIL: cache warm read accounting (hits=%d misses=%d)\n",
                   cast[uint64](h1), cast[uint64](m1))
        ok = 0
    else:
        _dm_emerg0("[dm] cache warm read HIT OK\n")

    # (b) WRITETHROUGH coherence: write a new pattern to block 0 through the
    # cache; both the cache AND the raw origin must hold it, and a re-read
    # through the cache (a HIT) returns it.
    if blk_write_sectors(cwt, 0, 1, &_dm_cache_pw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache writethrough write\n")
        return 0
    if blk_read_sectors(corig, 0, 1, &_dm_cache_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wt raw origin read\n")
        return 0
    if _dm_buf_eq(&_dm_cache_raw[0], &_dm_cache_pw[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache writethrough origin stale\n")
        ok = 0
    else:
        _dm_emerg0("[dm] cache writethrough origin coherent OK\n")

    # (c) EVICTION of a CLEAN victim: only 2 slots exist; blocks 0 and 1 are
    # currently resident (block 0 promoted above; promote block 1 now). Then
    # touch blocks 2 and 3 to force two evictions. Because writethrough keeps
    # every slot CLEAN, the evicted blocks' origin data is already coherent,
    # so re-reading every block through the cache returns the correct bytes
    # (block 0 = pattern W after the writethrough; 1/2/3 = B/C/D).
    if blk_read_sectors(cwt, 1, 1, &_dm_cache_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache promote blk1\n")
        return 0
    # Now both slots hold {0, 1}. Read block 2 -> evicts LRU (block 0), block 3
    # -> evicts block 1. After this no original block is resident.
    if blk_read_sectors(cwt, 2, 1, &_dm_cache_rd[0]) != 0 or \
       blk_read_sectors(cwt, 3, 1, &_dm_cache_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache eviction reads\n")
        return 0
    # Re-read every block; the data must still be correct (clean evictions).
    cwt_ok: int32 = 1
    if blk_read_sectors(cwt, 0, 1, &_dm_cache_rd[0]) != 0 or \
       _dm_buf_eq(&_dm_cache_rd[0], &_dm_cache_pw[0], SECTOR_SIZE) != 1:
        cwt_ok = 0
    if blk_read_sectors(cwt, 1, 1, &_dm_cache_rd[0]) != 0 or \
       _dm_buf_eq(&_dm_cache_rd[0], &_dm_cache_pb[0], SECTOR_SIZE) != 1:
        cwt_ok = 0
    if blk_read_sectors(cwt, 2, 1, &_dm_cache_rd[0]) != 0 or \
       _dm_buf_eq(&_dm_cache_rd[0], &_dm_cache_pc[0], SECTOR_SIZE) != 1:
        cwt_ok = 0
    if blk_read_sectors(cwt, 3, 1, &_dm_cache_rd[0]) != 0 or \
       _dm_buf_eq(&_dm_cache_rd[0], &_dm_cache_pd[0], SECTOR_SIZE) != 1:
        cwt_ok = 0
    if cwt_ok != 1:
        _dm_emerg0("[device-mapper] FAIL: cache clean-eviction data loss\n")
        ok = 0
    else:
        _dm_emerg0("[dm] cache clean eviction preserves data OK\n")

    # ---- WRITEBACK device: dirty stale-until-flush + dirty-victim writeback.
    cwb: int32 = dm_create_cache("dmcache-wb", cfast, corig, 1, 2, 8,
                                 DM_CACHE_WRITEBACK)
    if cwb < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_cache wb rc=%d\n",
                   cast[uint64](cast[int64](cwb)))
        return 0
    wbctx: int32 = dm_cache_ctx_of("dmcache-wb")
    # Reset origin blocks 0/1 to fresh known patterns A/B (the wt phase left
    # block 0 as W); use them as the writeback baseline.
    if blk_write_sectors(corig, 0, 1, &_dm_cache_pa[0]) != 0 or \
       blk_write_sectors(corig, 1, 1, &_dm_cache_pb[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wb origin reset\n")
        return 0

    # (d) WRITEBACK leaves origin stale: write pattern W to block 0 through the
    # writeback cache. The cache must return W on read, but the RAW origin must
    # still hold the OLD pattern A (stale) until a flush.
    if blk_write_sectors(cwb, 0, 1, &_dm_cache_pw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache writeback write\n")
        return 0
    if blk_read_sectors(cwb, 0, 1, &_dm_cache_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache writeback read\n")
        return 0
    if blk_read_sectors(corig, 0, 1, &_dm_cache_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wb raw origin read\n")
        return 0
    if _dm_buf_eq(&_dm_cache_rd[0], &_dm_cache_pw[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache writeback cache wrong data\n")
        ok = 0
    elif _dm_buf_eq(&_dm_cache_raw[0], &_dm_cache_pa[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache writeback origin not stale\n")
        ok = 0
    else:
        _dm_emerg0("[dm] cache writeback origin stale before flush OK\n")
    # Explicit FLUSH: origin must now match the cache (pattern W at block 0).
    if dm_cache_writeback_all(wbctx) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache writeback flush rc\n")
        return 0
    if blk_read_sectors(corig, 0, 1, &_dm_cache_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wb raw origin read (post-flush)\n")
        return 0
    if _dm_buf_eq(&_dm_cache_raw[0], &_dm_cache_pw[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache writeback flush did not persist\n")
        ok = 0
    else:
        _dm_emerg0("[dm] cache writeback flush makes origin coherent OK\n")

    # (e) EVICTION of a DIRTY victim writes it back automatically. Origin
    # block 1 currently = pattern B. Dirty block 1 in the writeback cache by
    # writing pattern C to it (cache holds {0:W, 1:C}; origin block 1 still B).
    if blk_write_sectors(cwb, 1, 1, &_dm_cache_pc[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wb dirty blk1 write\n")
        return 0
    if blk_read_sectors(corig, 1, 1, &_dm_cache_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wb raw blk1 (pre-evict)\n")
        return 0
    if _dm_buf_eq(&_dm_cache_raw[0], &_dm_cache_pb[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache wb dirty blk1 not stale pre-evict\n")
        ok = 0
    # Force eviction: both slots full {0,1}; read block 2 then block 3, which
    # evict the two LRU slots (blocks 0 and 1). The dirty victim (block 1 = C)
    # must be written BACK to origin during eviction.
    if blk_read_sectors(cwb, 2, 1, &_dm_cache_rd[0]) != 0 or \
       blk_read_sectors(cwb, 3, 1, &_dm_cache_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wb eviction reads\n")
        return 0
    if blk_read_sectors(corig, 1, 1, &_dm_cache_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: cache wb raw blk1 (post-evict)\n")
        return 0
    if _dm_buf_eq(&_dm_cache_raw[0], &_dm_cache_pc[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: cache dirty victim not written back\n")
        ok = 0
    else:
        _dm_emerg0("[dm] cache dirty-victim eviction writeback OK\n")

    if ok == 1:
        _dm_emerg0("[dm] cache PASS\n")

    # Clean up the cache mapped devices (the earlier targets were already
    # removed before the cache subtest; this leaves dmback0 in place).
    dm_remove("dmcache-wt")
    dm_remove("dmcache-wb")

    # --- Test 10: dm-ERA per-chunk write-era (generation) tracking ---
    # Build an era device over a dedicated ORIGIN ramdisk (dmeorig0) with its
    # per-chunk era metadata persisted to a separate METADATA ramdisk
    # (dmemeta0). chunk=8 sectors, nchunks=16 (origin span 128 sectors). The
    # device starts at era 1. We PROVE:
    #   (a) writes in era 1 stamp era 1 on their chunks and read back intact;
    #   (b) advancing the era to 2 and writing more chunks stamps era 2;
    #   (c) "chunks written since era 2" returns EXACTLY the era-2 chunks
    #       (including a chunk re-written in era 2 — its era advances), and
    #       "chunks written since era 1" returns ALL written chunks, ordered;
    #   (d) the era metadata survives: it round-trips through the metadata
    #       device (reload after wiping the in-core array reproduces it).
    eorig: int32 = _dm_eorig_register()
    if eorig < 0:
        _dm_emerg0("[device-mapper] FAIL: era origin register\n")
        return 0
    emeta: int32 = _dm_emeta_register()
    if emeta < 0:
        _dm_emerg0("[device-mapper] FAIL: era metadata register\n")
        return 0
    _dm_emerg2("[device-mapper] era origin dmeorig0 slot=%d meta dmemeta0 slot=%d\n",
               cast[uint64](cast[int64](eorig)),
               cast[uint64](cast[int64](emeta)))
    # Distinct per-chunk patterns (one sector each).
    ebi: uint64 = 0
    while ebi < SECTOR_SIZE:
        _dm_era_p0[ebi] = cast[uint8]((ebi * 3 + 11) & 0xFF)   # chunk 2, era 1
        _dm_era_p1[ebi] = cast[uint8]((ebi * 5 + 22) & 0xFF)   # chunk 5, era 1
        _dm_era_p2[ebi] = cast[uint8]((ebi * 7 + 33) & 0xFF)   # chunk 5, era 2
        _dm_era_p3[ebi] = cast[uint8]((ebi * 11 + 44) & 0xFF)  # chunk 9, era 2
        ebi = ebi + 1
    eradev: int32 = dm_create_era("dmera0", eorig, emeta, 8, 16)
    if eradev < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_era rc=%d\n",
                   cast[uint64](cast[int64](eradev)))
        return 0
    ectx: int32 = dm_era_ctx_of("dmera0")
    if ectx < 0:
        _dm_emerg0("[device-mapper] FAIL: era ctx lookup\n")
        return 0
    # Fresh device must start at era 1.
    if dm_era_current(ectx) != 1:
        _dm_emerg1("[device-mapper] FAIL: era did not start at 1 (cur=%d)\n",
                   cast[uint64](cast[int64](dm_era_current(ectx))))
        ok = 0

    # (a) Era-1 batch: write chunk 2 (vsec 16) and chunk 5 (vsec 40). Each
    # write stamps the CURRENT era (1) on its chunk; data must read back.
    if blk_write_sectors(eradev, 16, 1, &_dm_era_p0[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: era write chunk2 era1\n")
        return 0
    if blk_write_sectors(eradev, 40, 1, &_dm_era_p1[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: era write chunk5 era1\n")
        return 0
    if blk_read_sectors(eradev, 16, 1, &_dm_era_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: era readback chunk2\n")
        return 0
    if _dm_buf_eq(&_dm_era_rd[0], &_dm_era_p0[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: era chunk2 data mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] era: era-1 write reads back intact OK\n")

    # (b) Advance the era to 2. Subsequent writes stamp era 2.
    newera: int32 = dm_era_advance(ectx)
    if newera != 2:
        _dm_emerg1("[device-mapper] FAIL: era advance != 2 (got=%d)\n",
                   cast[uint64](cast[int64](newera)))
        ok = 0
    else:
        _dm_emerg0("[dm] PASS era-advance\n")
    # Era-2 batch: RE-write chunk 5 (vsec 40, now era 2) and write a fresh
    # chunk 9 (vsec 72). Re-writing chunk 5 advances ITS era 1 -> 2.
    if blk_write_sectors(eradev, 40, 1, &_dm_era_p2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: era rewrite chunk5 era2\n")
        return 0
    if blk_write_sectors(eradev, 72, 1, &_dm_era_p3[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: era write chunk9 era2\n")
        return 0

    # (c) Query "chunks written since era 2": must be EXACTLY {5, 9} (chunk 5
    # re-written in era 2, chunk 9 new in era 2; chunk 2 stayed at era 1).
    q2: int64 = dm_era_query_since(ectx, 2, &_dm_era_qbuf[0],
                                   DM_ERA_MAX_CHUNKS)
    era2_ok: int32 = 1
    if q2 != 2:
        era2_ok = 0
    elif _dm_era_qbuf[0] != 5 or _dm_era_qbuf[1] != 9:
        era2_ok = 0
    if era2_ok != 1:
        _dm_emerg1("[device-mapper] FAIL: era query-since-2 wrong set (count=%d)\n",
                   cast[uint64](q2))
        ok = 0
    else:
        _dm_emerg0("[dm] PASS era-query-since (chunks {5,9} changed since era 2)\n")
    # Query "chunks written since era 1": must be EXACTLY {2, 5, 9}, ordered.
    q1: int64 = dm_era_query_since(ectx, 1, &_dm_era_qbuf[0],
                                   DM_ERA_MAX_CHUNKS)
    era1_ok: int32 = 1
    if q1 != 3:
        era1_ok = 0
    elif _dm_era_qbuf[0] != 2 or _dm_era_qbuf[1] != 5 or _dm_era_qbuf[2] != 9:
        era1_ok = 0
    if era1_ok != 1:
        _dm_emerg1("[device-mapper] FAIL: era query-since-1 wrong set (count=%d)\n",
                   cast[uint64](q1))
        ok = 0
    else:
        _dm_emerg0("[devmapper] era: all written chunks {2,5,9} reported since era 1 OK\n")
    # The era-2 re-written chunk 5 must read back the NEW (era-2) data, proving
    # the data path is real, not just metadata bookkeeping.
    if blk_read_sectors(eradev, 40, 1, &_dm_era_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: era readback chunk5 era2\n")
        return 0
    if _dm_buf_eq(&_dm_era_rd[0], &_dm_era_p2[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: era chunk5 era2 data mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[devmapper] era: re-written chunk reads back new data OK\n")

    # (d) Persistence: clobber the in-core era array + current era, then
    # reload from the metadata device. The reloaded state must reproduce the
    # exact partition (query-since-2 == {5,9} again), proving the metadata
    # genuinely survives on the metadata device.
    eci: uint64 = cast[uint64](ectx)
    cz: uint64 = 0
    while cz < dm_era_ctxs[eci].nchunks:
        dm_era_ctxs[eci].era[cz] = 0
        cz = cz + 1
    dm_era_ctxs[eci].current_era = 0
    rlrc: int32 = dm_era_reload(ectx)
    if rlrc != 1:
        _dm_emerg1("[device-mapper] FAIL: era metadata reload (rc=%d)\n",
                   cast[uint64](cast[int64](rlrc)))
        ok = 0
    elif dm_era_current(ectx) != 2:
        _dm_emerg1("[device-mapper] FAIL: era reload lost current era (cur=%d)\n",
                   cast[uint64](cast[int64](dm_era_current(ectx))))
        ok = 0
    else:
        q2b: int64 = dm_era_query_since(ectx, 2, &_dm_era_qbuf[0],
                                        DM_ERA_MAX_CHUNKS)
        persist_ok: int32 = 1
        if q2b != 2:
            persist_ok = 0
        elif _dm_era_qbuf[0] != 5 or _dm_era_qbuf[1] != 9:
            persist_ok = 0
        if persist_ok != 1:
            _dm_emerg1("[device-mapper] FAIL: era reload wrong set (count=%d)\n",
                       cast[uint64](q2b))
            ok = 0
        else:
            _dm_emerg0("[dm] PASS era-persist (metadata round-trips via meta device)\n")

    if ok == 1:
        _dm_emerg0("[dm] era PASS\n")

    dm_remove("dmera0")

    # --- Test 11: dm-WRITECACHE write-back cache (writes -> fast device) ---
    # Build a writecache over a dedicated FAST cache ramdisk (dmwcache0)
    # fronting a SLOW origin (dmworig0). 1-sector cache blocks, 8 data slots,
    # 16 origin blocks. We PROVE:
    #   (a) WRITE-BACK not write-through: a write through the device lands the
    #       NEW data on the CACHE device and marks the slot dirty, while the
    #       ORIGIN block stays STALE (still its pre-write contents);
    #   (b) READ serves the cached (dirty) new data for a written block, and
    #       falls through to the origin for a never-written block;
    #   (c) FLUSH walks dirty slots, writes them back to the origin, and clears
    #       dirty — after which the origin holds the data and dirty count is 0;
    #   (d) PERSISTENCE: un-flushed dirty writes survive a teardown — after
    #       writing (without flushing) and removing the mapped device, a fresh
    #       writecache over the SAME cache device RESUMES the dirty slot, still
    #       serves the new data on read, and can flush it to the origin.
    wcache: int32 = _dm_wcache_register()
    if wcache < 0:
        _dm_emerg0("[device-mapper] FAIL: writecache cache-device register\n")
        return 0
    worig: int32 = _dm_worig_register()
    if worig < 0:
        _dm_emerg0("[device-mapper] FAIL: writecache origin register\n")
        return 0
    _dm_emerg2("[device-mapper] writecache fast dmwcache0 slot=%d origin dmworig0 slot=%d\n",
               cast[uint64](cast[int64](wcache)),
               cast[uint64](cast[int64](worig)))
    # Distinct per-block patterns (one sector each); _dm_wc_orig0 is the
    # pre-write origin contents seeded into origin block 0.
    wbi: uint64 = 0
    while wbi < SECTOR_SIZE:
        _dm_wc_pa[wbi]    = cast[uint8]((wbi * 3 + 17) & 0xFF)   # block 0 write
        _dm_wc_pb[wbi]    = cast[uint8]((wbi * 5 + 29) & 0xFF)   # block 2 write
        _dm_wc_pc[wbi]    = cast[uint8]((wbi * 7 + 41) & 0xFF)   # block 4 write
        _dm_wc_orig0[wbi] = cast[uint8]((wbi * 11 + 7) & 0xFF)   # block0 origin
        wbi = wbi + 1
    # Seed origin block 0 with its OLD contents and block 5 (never written
    # through the cache) so a read of block 5 falls through to the origin.
    if blk_write_sectors(worig, 0, 1, &_dm_wc_orig0[0]) != 0 or \
       blk_write_sectors(worig, 5, 1, &_dm_wc_pc[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache origin seed\n")
        return 0

    wcdev: int32 = dm_create_writecache("dmwc0", wcache, worig, 1, 8, 16)
    if wcdev < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_writecache rc=%d\n",
                   cast[uint64](cast[int64](wcdev)))
        return 0
    wctx: int32 = dm_wc_ctx_of("dmwc0")
    if wctx < 0:
        _dm_emerg0("[device-mapper] FAIL: writecache ctx lookup\n")
        return 0

    # (a) Write pattern A to origin block 0 through the writecache. The NEW
    # data must land on the CACHE device (so a read through the device returns
    # it) while the RAW origin block 0 still holds its OLD pre-write contents.
    if blk_write_sectors(wcdev, 0, 1, &_dm_wc_pa[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache write blk0\n")
        return 0
    if blk_read_sectors(worig, 0, 1, &_dm_wc_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache raw origin read blk0\n")
        return 0
    if _dm_buf_eq(&_dm_wc_raw[0], &_dm_wc_orig0[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: writecache origin not stale (write-through?)\n")
        ok = 0
    else:
        _dm_emerg0("[dm] writecache write-back: origin stale, data on cache OK\n")
    # The new data must read back THROUGH the device (served from cache).
    if blk_read_sectors(wcdev, 0, 1, &_dm_wc_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache read blk0\n")
        return 0
    if _dm_buf_eq(&_dm_wc_rd[0], &_dm_wc_pa[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: writecache read did not serve cached data\n")
        ok = 0
    else:
        _dm_emerg0("[dm] writecache read serves cached new data OK\n")

    # (b) A read of block 5 (never written through the cache) must fall through
    # to the ORIGIN (returning the seeded origin contents, pattern C).
    if blk_read_sectors(wcdev, 5, 1, &_dm_wc_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache read blk5\n")
        return 0
    if _dm_buf_eq(&_dm_wc_rd[0], &_dm_wc_pc[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: writecache uncached read missed origin\n")
        ok = 0
    else:
        _dm_emerg0("[dm] writecache uncached read falls through to origin OK\n")

    # Write two more blocks (2 and 4) so the flush has several dirty slots.
    if blk_write_sectors(wcdev, 2, 1, &_dm_wc_pb[0]) != 0 or \
       blk_write_sectors(wcdev, 4, 1, &_dm_wc_pc[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache write blk2/blk4\n")
        return 0
    # Three blocks were written; the dirty count must be exactly 3.
    if dm_wc_dirty_count(wctx) != 3:
        _dm_emerg1("[device-mapper] FAIL: writecache dirty count != 3 (got=%d)\n",
                   cast[uint64](dm_wc_dirty_count(wctx)))
        ok = 0

    # (c) FLUSH: write back every dirty slot. After the flush the ORIGIN must
    # hold the written data for all three blocks and dirty count must be 0.
    if dm_wc_flush_all(wctx) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache flush rc\n")
        return 0
    flush_ok: int32 = 1
    if blk_read_sectors(worig, 0, 1, &_dm_wc_raw[0]) != 0 or \
       _dm_buf_eq(&_dm_wc_raw[0], &_dm_wc_pa[0], SECTOR_SIZE) != 1:
        flush_ok = 0
    if blk_read_sectors(worig, 2, 1, &_dm_wc_raw[0]) != 0 or \
       _dm_buf_eq(&_dm_wc_raw[0], &_dm_wc_pb[0], SECTOR_SIZE) != 1:
        flush_ok = 0
    if blk_read_sectors(worig, 4, 1, &_dm_wc_raw[0]) != 0 or \
       _dm_buf_eq(&_dm_wc_raw[0], &_dm_wc_pc[0], SECTOR_SIZE) != 1:
        flush_ok = 0
    if flush_ok != 1 or dm_wc_dirty_count(wctx) != 0:
        _dm_emerg1("[device-mapper] FAIL: writecache flush incomplete (dirty=%d)\n",
                   cast[uint64](dm_wc_dirty_count(wctx)))
        ok = 0
    else:
        _dm_emerg0("[dm] writecache flush writes back to origin, dirty cleared OK\n")

    # (d) PERSISTENCE / crash recovery: write a NEW pattern (B) to block 7
    # through the cache but do NOT flush it. Reset origin block 7 to a known
    # OLD value first so we can prove the un-flushed data is recovered, not
    # read from the origin. Then TEAR DOWN the mapped device (the cache
    # ramdisk and its persisted metadata survive) and bring up a FRESH
    # writecache over the SAME cache device. It must resume the dirty slot:
    # a read returns the un-flushed new data, and a flush lands it on origin.
    if blk_write_sectors(worig, 7, 1, &_dm_wc_pc[0]) != 0:   # OLD origin value
        _dm_emerg0("[device-mapper] FAIL: writecache origin reset blk7\n")
        return 0
    if blk_write_sectors(wcdev, 7, 1, &_dm_wc_pb[0]) != 0:   # NEW (un-flushed)
        _dm_emerg0("[device-mapper] FAIL: writecache write blk7\n")
        return 0
    # The origin block 7 must still hold the OLD value (un-flushed write).
    if blk_read_sectors(worig, 7, 1, &_dm_wc_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache raw origin read blk7\n")
        return 0
    if _dm_buf_eq(&_dm_wc_raw[0], &_dm_wc_pc[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: writecache blk7 origin not stale\n")
        ok = 0
    # Tear down the mapped device WITHOUT flushing — the persisted metadata +
    # dirty data remain on the cache ramdisk.
    dm_remove("dmwc0")
    # Bring up a FRESH writecache over the SAME cache + origin devices.
    wcdev2: int32 = dm_create_writecache("dmwc1", wcache, worig, 1, 8, 16)
    if wcdev2 < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_writecache resume rc=%d\n",
                   cast[uint64](cast[int64](wcdev2)))
        return 0
    wctx2: int32 = dm_wc_ctx_of("dmwc1")
    if wctx2 < 0:
        _dm_emerg0("[device-mapper] FAIL: writecache resume ctx lookup\n")
        return 0
    # The resumed device must still see block 7 as dirty (un-flushed write).
    if dm_wc_dirty_count(wctx2) != 1:
        _dm_emerg1("[device-mapper] FAIL: writecache resume lost dirty (dirty=%d)\n",
                   cast[uint64](dm_wc_dirty_count(wctx2)))
        ok = 0
    # A read of block 7 through the resumed device must serve the un-flushed
    # NEW data (pattern B), NOT the stale origin (pattern C).
    if blk_read_sectors(wcdev2, 7, 1, &_dm_wc_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache resume read blk7\n")
        return 0
    if _dm_buf_eq(&_dm_wc_rd[0], &_dm_wc_pb[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: writecache resume did not recover dirty data\n")
        ok = 0
    else:
        _dm_emerg0("[dm] writecache metadata persists: un-flushed write recovered OK\n")
    # And a flush on the resumed device must land the recovered data on origin.
    if dm_wc_flush_all(wctx2) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache resume flush rc\n")
        return 0
    if blk_read_sectors(worig, 7, 1, &_dm_wc_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: writecache resume raw origin read blk7\n")
        return 0
    if _dm_buf_eq(&_dm_wc_raw[0], &_dm_wc_pb[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: writecache resume flush did not persist\n")
        ok = 0
    else:
        _dm_emerg0("[dm] writecache recovered write flushes to origin OK\n")

    if ok == 1:
        _dm_emerg0("[dm] writecache PASS\n")

    dm_remove("dmwc1")

    # --- Test 12: dm-DELAY per-op read/write delay over a linear remap ---
    # Build a delay device over a dedicated backing ramdisk (dmdback0). The
    # READ path is deferred 3 ticks and the WRITE path 7 ticks (DISTINCT
    # values), with the WRITE path remapped to a DIFFERENT backing offset than
    # the READ path so we can also confirm the per-path under_start routing.
    # We PROVE:
    #   (a) REMAP CORRECTNESS: data written through the delay device lands at
    #       the WRITE-path backing offset and reads back byte-identical both
    #       through the device (via the READ-path offset) and from the raw
    #       backing device at the mapped sector;
    #   (b) DISTINCT DEFERRAL: each read took the 3-tick read path and each
    #       write took the 7-tick write path — proven by the per-path counters
    #       (reads_deferred, writes_deferred) and the summed deferral totals
    #       (read_delay_total == reads*3, write_delay_total == writes*7), which
    #       are necessarily DIFFERENT, so a faked/shared path is detectable.
    #
    # Layout: virtual [0, 16). WRITE base = backing sector 64, READ base =
    # backing sector 64 too (so a write then read of the same vLBA round-trips
    # through the same backing sector); we ALSO exercise a write whose write-
    # base differs from a probe read-base to show the routing is per-path.
    dback: int32 = _dm_dback_register()
    if dback < 0:
        _dm_emerg0("[device-mapper] FAIL: delay backing register\n")
        return 0
    _dm_emerg1("[device-mapper] delay backing dmdback0 slot=%d\n",
               cast[uint64](cast[int64](dback)))

    # Two distinct one-sector patterns.
    dbi: uint64 = 0
    while dbi < SECTOR_SIZE:
        _dm_dly_pa[dbi] = cast[uint8]((dbi * 9 + 13) & 0xFF)
        _dm_dly_pb[dbi] = cast[uint8]((dbi * 5 + 77) & 0xFF)
        dbi = dbi + 1

    # read base = 64, read delay = 3; write base = 64, write delay = 7;
    # length = 16 sectors.
    dly: int32 = dm_create_delay("dmdelay0", dback, 64, 3, 64, 7, 16)
    if dly < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_delay rc=%d\n",
                   cast[uint64](cast[int64](dly)))
        return 0
    dctx: int32 = dm_delay_ctx_of("dmdelay0")
    if dctx < 0:
        _dm_emerg0("[device-mapper] FAIL: delay ctx lookup\n")
        return 0

    # (a) REMAP: write pattern A to virtual LBA 5. The WRITE path remaps to
    # backing sector 64 + 5 = 69. The raw backing sector 69 must hold A.
    if blk_write_sectors(dly, 5, 1, &_dm_dly_pa[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: delay write vLBA5\n")
        return 0
    if blk_read_sectors(dback, 69, 1, &_dm_dly_raw[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: delay raw backing read 69\n")
        return 0
    if _dm_buf_eq(&_dm_dly_pa[0], &_dm_dly_raw[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: delay write landed on wrong backing sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] delay: write vLBA5 -> backing 69 OK\n")
    # And read it back THROUGH the delay device (READ-path offset 64+5=69).
    if blk_read_sectors(dly, 5, 1, &_dm_dly_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: delay readback vLBA5\n")
        return 0
    if _dm_buf_eq(&_dm_dly_pa[0], &_dm_dly_rd[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: delay readback mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] delay: readback byte-identical OK\n")

    # Do a couple more ops so the per-path counters are unambiguous: one more
    # write (pattern B at vLBA 6) and one more read (vLBA 6).
    if blk_write_sectors(dly, 6, 1, &_dm_dly_pb[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: delay write vLBA6\n")
        return 0
    if blk_read_sectors(dly, 6, 1, &_dm_dly_rd[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: delay readback vLBA6\n")
        return 0
    if _dm_buf_eq(&_dm_dly_pb[0], &_dm_dly_rd[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: delay vLBA6 round-trip mismatch\n")
        ok = 0

    # Tally: 2 writes (vLBA5, vLBA6) and 2 reads (vLBA5, vLBA6) were issued.
    nr: int64 = dm_delay_reads_deferred(dctx)
    nw: int64 = dm_delay_writes_deferred(dctx)
    rt: int64 = dm_delay_read_total(dctx)
    wt: int64 = dm_delay_write_total(dctx)
    clk: int64 = dm_delay_clock(dctx)
    _dm_emerg2("[device-mapper] delay: reads_deferred=%d writes_deferred=%d\n",
               cast[uint64](nr), cast[uint64](nw))
    _dm_emerg2("[device-mapper] delay: read_total=%d write_total=%d\n",
               cast[uint64](rt), cast[uint64](wt))
    # (b) DISTINCT DEFERRAL accounting. 2 reads * 3 ticks = 6; 2 writes * 7
    # ticks = 14. The two path totals MUST differ (proving the read vs write
    # path each applied its OWN configured value, not a shared/faked one).
    if nr != 2 or nw != 2:
        _dm_emerg0("[device-mapper] FAIL: delay deferred op counts wrong\n")
        ok = 0
    elif rt != 6 or wt != 14:
        _dm_emerg0("[device-mapper] FAIL: delay per-path totals wrong\n")
        ok = 0
    elif rt == wt:
        _dm_emerg0("[device-mapper] FAIL: delay read/write delays not distinct\n")
        ok = 0
    else:
        _dm_emerg0("[dm] delay: read path 3-tick, write path 7-tick, distinct OK\n")
    # The logical clock must have advanced (deadlines were honoured), proving a
    # real deferral mechanism ran rather than a no-op. Largest deadline seen is
    # 7 (a write submitted at clock 0..); the clock must be >= that.
    if clk < 7:
        _dm_emerg1("[device-mapper] FAIL: delay clock did not advance (clk=%d)\n",
                   cast[uint64](clk))
        ok = 0
    else:
        _dm_emerg0("[dm] delay: deferred-completion clock honoured deadlines OK\n")

    if ok == 1:
        _dm_emerg0("[dm] delay PASS\n")

    dm_remove("dmdelay0")

    if ok == 1:
        _dm_emerg0("[device-mapper] PASS\n")
        return 1
    _dm_emerg0("[device-mapper] FAIL\n")
    return 0

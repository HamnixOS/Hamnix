# drivers/block/dm.ad
#
# Native device-mapper — Hamnix's equivalent of Linux's
# drivers/md/dm.c + the dm-linear / dm-crypt targets. A genuine
# Linux-parity gap: there was NO device-mapper in the tree before this.
#
# A device-mapper "mapped device" is a VIRTUAL block device whose
# address space is described by a TABLE of one or more TARGETS. Each
# target owns a contiguous [start_sector, length) span of the virtual
# device and translates every I/O that lands in its span to an
# underlying real block device at a target-specific offset. The block
# layer (kernel/block/blk.ad) sees the mapped device as an ordinary
# registered BlockDevice — filesystems can mount and read/write through
# it exactly like a partition or a loop device.
#
# Linux mapping:
#
#   struct mapped_device          -> MappedDevice (this file)
#   struct dm_table / dm_target   -> DmTarget[] inside MappedDevice
#   dm-linear (drivers/md/dm-linear.c)  -> DM_TARGET_LINEAR
#   dm-crypt  (drivers/md/dm-crypt.c)    -> DM_TARGET_CRYPT
#   dmsetup create --table "..."  -> dm_create_linear / dm_create_concat
#                                    / dm_create_crypt (this file)
#   bio remap (map_bio)           -> _dm_read_blkop / _dm_write_blkop
#
# TARGETS:
#
#   LINEAR — maps a span of the virtual device onto an underlying block
#   device at a fixed sector offset. This is the foundation of LVM:
#   concatenating several linear targets, each pointing at a different
#   underlying device (or a different region of one), builds a single
#   large virtual device out of smaller physical extents.
#
#   CRYPT (dm-crypt) — like linear (it forwards to an underlying device
#   at an offset) but encrypts every sector on the way out and decrypts
#   on the way in, so the bytes resting on the backing store are
#   ciphertext while reads through the mapped device return plaintext.
#   The cipher is AES-256 in XTS mode — the exact `aes-xts-plain64`
#   construction that is Linux dm-crypt / LUKS2's default. NOT a toy XOR,
#   NOT a stream-cipher stand-in: it is a real tweakable block cipher
#   (IEEE Std 1619-2007) implemented in full below.
#
#   WHY a standalone AES here (and not the AES already in tls.ad): the
#   tree's only AES is drivers/net/tls.ad's GCM path, which (a) needs
#   only AES ENCRYPT (CTR mode never decrypts the cipher) so it ships no
#   inverse cipher, and (b) keeps a SINGLE shared 240-byte round-key
#   schedule global (aes256_rk). XTS fundamentally needs the INVERSE
#   cipher for reads and TWO independent keys live at once (a data key
#   and a tweak key), so tls.ad's single-schedule, encrypt-only code
#   cannot be borrowed without either clobbering live TLS state or
#   re-expanding keys mid-block. The clean, decoupled answer — and the
#   one the brief sanctions when reuse is impractical — is a small
#   self-contained AES-256 (forward + inverse cipher) that owns its own
#   data/tweak schedules in this file, with zero coupling to the network
#   stack's import closure.
#
#   XTS (XEX-based tweaked-codebook with ciphertext stealing — here every
#   transfer is a whole 512-byte sector = 32 exact AES blocks, so no
#   stealing is needed): the tweak for a sector is AES_tweakkey(IV) where
#   the IV is dm-crypt's "plain64" — the 64-bit sector number, little-
#   endian, in a 16-byte block. For each 16-byte block j within the
#   sector the running tweak T is GF(2^128)-multiplied by the primitive
#   element alpha=x once per block; the block is XEX-masked
#   (C = AES_datakey(P ^ T) ^ T). Identical plaintext at two different
#   sectors therefore encrypts to different ciphertext (different IV ->
#   different tweak), and every block is independently seekable.

from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, blk_unregister_by_name,
    blk_read_sectors, blk_write_sectors, find_blockdev,
    blk_capacity_sectors, SECTOR_SIZE,
)
from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level,
)
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# =========================================================================
# AES-256 block cipher (FIPS 197) — self-contained, forward + inverse
# =========================================================================
#
# A real 14-round AES with a 256-bit master key. Unlike tls.ad's GCM
# path (encrypt-only, single shared schedule), XTS needs BOTH the
# forward and the inverse cipher and TWO live key schedules at once (a
# data key and a tweak key), so this implementation owns two 240-byte
# expanded schedules. The S-box / inverse S-box / GF(2^8) tables are
# built once at init. All working state is module-scope .bss: dm-crypt
# I/O is serialised through the synchronous block layer, so a single
# shared block-state buffer is safe (no two crypt transfers overlap).

_dm_aes_sbox:     Array[256, uint8]   # forward S-box
_dm_aes_isbox:    Array[256, uint8]   # inverse S-box
_dm_aes_inited:   int32 = 0
# GF(2^8) log/exp scratch for S-box construction.
_dm_aes_log:      Array[256, uint16]
_dm_aes_exp:      Array[256, uint8]

# Two independent 240-byte AES-256 expanded schedules: index 0 = data
# key, index 1 = tweak key. Both forward; the data key also gets an
# inverse schedule for the decrypt path.
_dm_aes_rk_data:  Array[240, uint8]
_dm_aes_rk_tweak: Array[240, uint8]
_dm_aes_block_st: Array[16, uint8]    # working state for one block


def _dm_aes_rotl8(v: uint8, n: uint64) -> uint8:
    x: uint64 = cast[uint64](v) & 0xFF
    return cast[uint8](((x << n) | (x >> (8 - n))) & 0xFF)


def _dm_aes_xtime(b: uint8) -> uint8:
    # b * x mod (x^8 + x^4 + x^3 + x + 1) in GF(2^8).
    v: uint64 = cast[uint64](b) & 0xFF
    t: uint64 = (v << 1) & 0xFF
    if (v & 0x80) != 0:
        t = t ^ 0x1B
    return cast[uint8](t & 0xFF)


def _dm_aes_gfmul(a: uint8, b: uint8) -> uint8:
    # Full GF(2^8) multiply (used for the inverse MixColumns constants
    # 9, 11, 13, 14). Russian-peasant.
    av: uint64 = cast[uint64](a) & 0xFF
    bv: uint64 = cast[uint64](b) & 0xFF
    p:  uint64 = 0
    i:  uint64 = 0
    while i < 8:
        if (bv & 1) != 0:
            p = p ^ av
        hi: uint64 = av & 0x80
        av = (av << 1) & 0xFF
        if hi != 0:
            av = av ^ 0x1B
        bv = bv >> 1
        i = i + 1
    return cast[uint8](p & 0xFF)


def _dm_aes_init():
    # Build the forward S-box (FIPS 197 §5.1.1) and its inverse at
    # runtime via a GF(2^8) log/exp table with generator g=3.
    if _dm_aes_inited != 0:
        return
    _dm_aes_inited = 1
    i: uint64 = 0
    x: uint16 = 1
    while i < 255:
        _dm_aes_exp[i] = cast[uint8](x & 0xFF)
        _dm_aes_log[x & 0xFF] = cast[uint16](i)
        x2: uint16 = (x << 1) & 0xFF
        if (x & 0x80) != 0:
            x2 = x2 ^ 0x1B
        x = x2 ^ x
        x = x & 0xFF
        i = i + 1
    _dm_aes_exp[255] = _dm_aes_exp[0]
    _dm_aes_sbox[0] = 0x63
    b: uint64 = 1
    while b < 256:
        inv: uint8 = _dm_aes_exp[(255 - cast[uint64](_dm_aes_log[b])) & 0xFF]
        v: uint8 = inv
        s: uint8 = v \
            ^ _dm_aes_rotl8(v, 1) \
            ^ _dm_aes_rotl8(v, 2) \
            ^ _dm_aes_rotl8(v, 3) \
            ^ _dm_aes_rotl8(v, 4) \
            ^ 0x63
        _dm_aes_sbox[b] = s
        b = b + 1
    # Inverse S-box: isbox[sbox[b]] = b.
    b = 0
    while b < 256:
        _dm_aes_isbox[_dm_aes_sbox[b]] = cast[uint8](b)
        b = b + 1


def _dm_aes256_expand(master: Ptr[uint8], rk: Ptr[uint8]):
    # FIPS 197 §5.2, AES-256: Nk=8, Nr=14, 240-byte expanded key into the
    # caller-supplied 240-byte schedule buffer `rk`.
    _dm_aes_init()
    i: uint64 = 0
    while i < 32:
        rk[i] = master[i]
        i = i + 1
    rcon: uint8 = 0x01
    i = 32
    while i < 240:
        t0: uint8 = rk[i - 4]
        t1: uint8 = rk[i - 3]
        t2: uint8 = rk[i - 2]
        t3: uint8 = rk[i - 1]
        word_idx: uint64 = i / 4
        if (word_idx & 7) == 0:
            r0: uint8 = _dm_aes_sbox[t1] ^ rcon
            r1: uint8 = _dm_aes_sbox[t2]
            r2: uint8 = _dm_aes_sbox[t3]
            r3: uint8 = _dm_aes_sbox[t0]
            t0 = r0
            t1 = r1
            t2 = r2
            t3 = r3
            rcon = _dm_aes_xtime(rcon)
        elif (word_idx & 7) == 4:
            t0 = _dm_aes_sbox[t0]
            t1 = _dm_aes_sbox[t1]
            t2 = _dm_aes_sbox[t2]
            t3 = _dm_aes_sbox[t3]
        rk[i + 0] = rk[i - 32 + 0] ^ t0
        rk[i + 1] = rk[i - 32 + 1] ^ t1
        rk[i + 2] = rk[i - 32 + 2] ^ t2
        rk[i + 3] = rk[i - 32 + 3] ^ t3
        i = i + 4


def _dm_aes256_encrypt(rk: Ptr[uint8], out_blk: Ptr[uint8],
                       in_blk: Ptr[uint8]):
    # Encrypt one 16-byte block under the 240-byte schedule `rk` (Nr=14).
    # State held column-major s[c*4 + r].
    i: uint64 = 0
    while i < 16:
        _dm_aes_block_st[i] = in_blk[i] ^ rk[i]
        i = i + 1
    rnd: uint64 = 1
    while rnd <= 13:
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_sbox[_dm_aes_block_st[i]]
            i = i + 1
        # ShiftRows
        t1: uint8 = _dm_aes_block_st[1]
        _dm_aes_block_st[1] = _dm_aes_block_st[5]
        _dm_aes_block_st[5] = _dm_aes_block_st[9]
        _dm_aes_block_st[9] = _dm_aes_block_st[13]
        _dm_aes_block_st[13] = t1
        t2a: uint8 = _dm_aes_block_st[2]
        t2b: uint8 = _dm_aes_block_st[6]
        _dm_aes_block_st[2] = _dm_aes_block_st[10]
        _dm_aes_block_st[6] = _dm_aes_block_st[14]
        _dm_aes_block_st[10] = t2a
        _dm_aes_block_st[14] = t2b
        t3: uint8 = _dm_aes_block_st[15]
        _dm_aes_block_st[15] = _dm_aes_block_st[11]
        _dm_aes_block_st[11] = _dm_aes_block_st[7]
        _dm_aes_block_st[7] = _dm_aes_block_st[3]
        _dm_aes_block_st[3] = t3
        # MixColumns
        c: uint64 = 0
        while c < 4:
            s0: uint8 = _dm_aes_block_st[c * 4 + 0]
            s1: uint8 = _dm_aes_block_st[c * 4 + 1]
            s2: uint8 = _dm_aes_block_st[c * 4 + 2]
            s3: uint8 = _dm_aes_block_st[c * 4 + 3]
            x0: uint8 = _dm_aes_xtime(s0)
            x1: uint8 = _dm_aes_xtime(s1)
            x2: uint8 = _dm_aes_xtime(s2)
            x3: uint8 = _dm_aes_xtime(s3)
            _dm_aes_block_st[c * 4 + 0] = x0 ^ (x1 ^ s1) ^ s2 ^ s3
            _dm_aes_block_st[c * 4 + 1] = s0 ^ x1 ^ (x2 ^ s2) ^ s3
            _dm_aes_block_st[c * 4 + 2] = s0 ^ s1 ^ x2 ^ (x3 ^ s3)
            _dm_aes_block_st[c * 4 + 3] = (x0 ^ s0) ^ s1 ^ s2 ^ x3
            c = c + 1
        rk_base: uint64 = rnd * 16
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_block_st[i] ^ rk[rk_base + i]
            i = i + 1
        rnd = rnd + 1
    # Final round: SubBytes + ShiftRows + AddRoundKey (no MixColumns).
    i = 0
    while i < 16:
        _dm_aes_block_st[i] = _dm_aes_sbox[_dm_aes_block_st[i]]
        i = i + 1
    t1f: uint8 = _dm_aes_block_st[1]
    _dm_aes_block_st[1] = _dm_aes_block_st[5]
    _dm_aes_block_st[5] = _dm_aes_block_st[9]
    _dm_aes_block_st[9] = _dm_aes_block_st[13]
    _dm_aes_block_st[13] = t1f
    t2af: uint8 = _dm_aes_block_st[2]
    t2bf: uint8 = _dm_aes_block_st[6]
    _dm_aes_block_st[2] = _dm_aes_block_st[10]
    _dm_aes_block_st[6] = _dm_aes_block_st[14]
    _dm_aes_block_st[10] = t2af
    _dm_aes_block_st[14] = t2bf
    t3f: uint8 = _dm_aes_block_st[15]
    _dm_aes_block_st[15] = _dm_aes_block_st[11]
    _dm_aes_block_st[11] = _dm_aes_block_st[7]
    _dm_aes_block_st[7] = _dm_aes_block_st[3]
    _dm_aes_block_st[3] = t3f
    i = 0
    while i < 16:
        out_blk[i] = _dm_aes_block_st[i] ^ rk[14 * 16 + i]
        i = i + 1


def _dm_aes256_decrypt(rk: Ptr[uint8], out_blk: Ptr[uint8],
                       in_blk: Ptr[uint8]):
    # Inverse cipher (FIPS 197 §5.3) — the equivalent-inverse-free
    # straightforward form: AddRoundKey(last), then 13 rounds of
    # InvShiftRows, InvSubBytes, AddRoundKey, InvMixColumns, then a final
    # InvShiftRows + InvSubBytes + AddRoundKey(0).
    i: uint64 = 0
    while i < 16:
        _dm_aes_block_st[i] = in_blk[i] ^ rk[14 * 16 + i]
        i = i + 1
    rnd: int64 = 13
    while rnd >= 1:
        # InvShiftRows: row r is right-rotated by r columns.
        t1: uint8 = _dm_aes_block_st[13]
        _dm_aes_block_st[13] = _dm_aes_block_st[9]
        _dm_aes_block_st[9] = _dm_aes_block_st[5]
        _dm_aes_block_st[5] = _dm_aes_block_st[1]
        _dm_aes_block_st[1] = t1
        t2a: uint8 = _dm_aes_block_st[2]
        t2b: uint8 = _dm_aes_block_st[6]
        _dm_aes_block_st[2] = _dm_aes_block_st[10]
        _dm_aes_block_st[6] = _dm_aes_block_st[14]
        _dm_aes_block_st[10] = t2a
        _dm_aes_block_st[14] = t2b
        t3: uint8 = _dm_aes_block_st[3]
        _dm_aes_block_st[3] = _dm_aes_block_st[7]
        _dm_aes_block_st[7] = _dm_aes_block_st[11]
        _dm_aes_block_st[11] = _dm_aes_block_st[15]
        _dm_aes_block_st[15] = t3
        # InvSubBytes
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_isbox[_dm_aes_block_st[i]]
            i = i + 1
        # AddRoundKey
        rk_base: uint64 = cast[uint64](rnd) * 16
        i = 0
        while i < 16:
            _dm_aes_block_st[i] = _dm_aes_block_st[i] ^ rk[rk_base + i]
            i = i + 1
        # InvMixColumns
        c: uint64 = 0
        while c < 4:
            s0: uint8 = _dm_aes_block_st[c * 4 + 0]
            s1: uint8 = _dm_aes_block_st[c * 4 + 1]
            s2: uint8 = _dm_aes_block_st[c * 4 + 2]
            s3: uint8 = _dm_aes_block_st[c * 4 + 3]
            _dm_aes_block_st[c * 4 + 0] = _dm_aes_gfmul(s0, 14) \
                ^ _dm_aes_gfmul(s1, 11) ^ _dm_aes_gfmul(s2, 13) \
                ^ _dm_aes_gfmul(s3, 9)
            _dm_aes_block_st[c * 4 + 1] = _dm_aes_gfmul(s0, 9) \
                ^ _dm_aes_gfmul(s1, 14) ^ _dm_aes_gfmul(s2, 11) \
                ^ _dm_aes_gfmul(s3, 13)
            _dm_aes_block_st[c * 4 + 2] = _dm_aes_gfmul(s0, 13) \
                ^ _dm_aes_gfmul(s1, 9) ^ _dm_aes_gfmul(s2, 14) \
                ^ _dm_aes_gfmul(s3, 11)
            _dm_aes_block_st[c * 4 + 3] = _dm_aes_gfmul(s0, 11) \
                ^ _dm_aes_gfmul(s1, 13) ^ _dm_aes_gfmul(s2, 9) \
                ^ _dm_aes_gfmul(s3, 14)
            c = c + 1
        rnd = rnd - 1
    # Final round: InvShiftRows + InvSubBytes + AddRoundKey(0).
    t1f: uint8 = _dm_aes_block_st[13]
    _dm_aes_block_st[13] = _dm_aes_block_st[9]
    _dm_aes_block_st[9] = _dm_aes_block_st[5]
    _dm_aes_block_st[5] = _dm_aes_block_st[1]
    _dm_aes_block_st[1] = t1f
    t2af: uint8 = _dm_aes_block_st[2]
    t2bf: uint8 = _dm_aes_block_st[6]
    _dm_aes_block_st[2] = _dm_aes_block_st[10]
    _dm_aes_block_st[6] = _dm_aes_block_st[14]
    _dm_aes_block_st[10] = t2af
    _dm_aes_block_st[14] = t2bf
    t3f: uint8 = _dm_aes_block_st[3]
    _dm_aes_block_st[3] = _dm_aes_block_st[7]
    _dm_aes_block_st[7] = _dm_aes_block_st[11]
    _dm_aes_block_st[11] = _dm_aes_block_st[15]
    _dm_aes_block_st[15] = t3f
    i = 0
    while i < 16:
        _dm_aes_block_st[i] = _dm_aes_isbox[_dm_aes_block_st[i]]
        i = i + 1
    i = 0
    while i < 16:
        out_blk[i] = _dm_aes_block_st[i] ^ rk[i]
        i = i + 1


# =========================================================================
# AES-XTS (IEEE Std 1619-2007) — the aes-xts-plain64 sector transform
# =========================================================================
#
# XTS encrypts/decrypts a sector as a sequence of 16-byte blocks under a
# data key, masked by a per-block tweak. The tweak for block 0 of a
# sector is T0 = AES_tweakkey(IV) where IV = the 64-bit sector number
# little-endian in a 16-byte block (dm-crypt "plain64"). For each
# subsequent block the tweak is multiplied by alpha = x in GF(2^128)
# (the polynomial x^128 + x^7 + x^2 + x + 1, LSB-first byte order).
#   encrypt:  C = AES_datakey(P ^ T) ^ T
#   decrypt:  P = AES_datakey^-1(C ^ T) ^ T
# A 512-byte sector is exactly 32 whole AES blocks, so no ciphertext
# stealing is ever required.

_dm_xts_tweak:  Array[16, uint8]   # running tweak T for the current sector
_dm_xts_tmp:    Array[16, uint8]   # P ^ T / C ^ T scratch


def _dm_xts_mul_alpha(t: Ptr[uint8]):
    # Multiply the 128-bit value t by alpha = x in GF(2^128), little-
    # endian byte order (IEEE 1619). Left-shift the whole 128-bit value
    # by one bit; if the high bit (bit 127) carried out, XOR 0x87 into
    # byte 0.
    carry: uint64 = 0
    i: uint64 = 0
    while i < 16:
        cur: uint64 = cast[uint64](t[i]) & 0xFF
        newv: uint64 = ((cur << 1) | carry) & 0xFF
        carry = (cur >> 7) & 1
        t[i] = cast[uint8](newv)
        i = i + 1
    if carry != 0:
        t[0] = t[0] ^ 0x87


def _dm_xts_init_tweak(sector: uint64):
    # T0 = AES_tweakkey(plain64 IV). IV = sector number little-endian in
    # bytes 0..7, zero in 8..15.
    iv: Array[16, uint8]
    i: uint64 = 0
    while i < 8:
        iv[i] = cast[uint8]((sector >> (i * 8)) & 0xFF)
        i = i + 1
    while i < 16:
        iv[i] = 0
        i = i + 1
    _dm_aes256_encrypt(cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]),
                       cast[Ptr[uint8]](&_dm_xts_tweak[0]),
                       cast[Ptr[uint8]](&iv[0]))


def _dm_xts_encrypt_sector(sector: uint64,
                           dst: Ptr[uint8], src: Ptr[uint8]):
    # XTS-encrypt one 512-byte sector (32 blocks). Assumes the data and
    # tweak schedules are already expanded into _dm_aes_rk_data /
    # _dm_aes_rk_tweak.
    _dm_xts_init_tweak(sector)
    tw:  Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tweak[0])
    tmp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tmp[0])
    dkey: Ptr[uint8] = cast[Ptr[uint8]](&_dm_aes_rk_data[0])
    blk: uint64 = 0
    while blk < 32:
        base: uint64 = blk * 16
        j: uint64 = 0
        while j < 16:
            tmp[j] = src[base + j] ^ tw[j]
            j = j + 1
        _dm_aes256_encrypt(dkey, cast[Ptr[uint8]](
            cast[uint64](dst) + base), tmp)
        j = 0
        while j < 16:
            dst[base + j] = dst[base + j] ^ tw[j]
            j = j + 1
        _dm_xts_mul_alpha(tw)
        blk = blk + 1


def _dm_xts_decrypt_sector(sector: uint64,
                           dst: Ptr[uint8], src: Ptr[uint8]):
    # XTS-decrypt one 512-byte sector (32 blocks).
    _dm_xts_init_tweak(sector)
    tw:  Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tweak[0])
    tmp: Ptr[uint8] = cast[Ptr[uint8]](&_dm_xts_tmp[0])
    dkey: Ptr[uint8] = cast[Ptr[uint8]](&_dm_aes_rk_data[0])
    blk: uint64 = 0
    while blk < 32:
        base: uint64 = blk * 16
        j: uint64 = 0
        while j < 16:
            tmp[j] = src[base + j] ^ tw[j]
            j = j + 1
        _dm_aes256_decrypt(dkey, cast[Ptr[uint8]](
            cast[uint64](dst) + base), tmp)
        j = 0
        while j < 16:
            dst[base + j] = dst[base + j] ^ tw[j]
            j = j + 1
        _dm_xts_mul_alpha(tw)
        blk = blk + 1


# =========================================================================
# Device-mapper core
# =========================================================================

DM_TARGET_NONE:   uint32 = 0
DM_TARGET_LINEAR: uint32 = 1
DM_TARGET_CRYPT:  uint32 = 2

DM_KEY_LEN:      uint64 = 64       # AES-256-XTS: 32B data + 32B tweak key
DM_MAX_TARGETS:  uint64 = 8        # targets per mapped device
DM_MAX_DEVICES:  uint64 = 8        # mapped devices system-wide
DM_NAME_LEN:     uint64 = 16


class DmTarget:
    # One row of a mapped device's table. The virtual span this target
    # covers is [start_sector, start_sector + length). On an I/O whose
    # virtual LBA falls in that span, the offset within the target is
    # (vlba - start_sector); the underlying LBA is
    # (under_start + offset_in_target). `ttype` selects linear vs crypt.
    ttype:        uint32
    pad:          uint32
    start_sector: uint64           # first virtual sector this target owns
    length:       uint64           # number of sectors in the span
    under_slot:   int32            # underlying block-device slot
    pad2:         uint32
    under_start:  uint64           # base LBA on the underlying device


class MappedDevice:
    # A virtual block device described by a table of targets. Registered
    # with the block layer under `name` so the rest of the kernel reads
    # and writes through it transparently.
    used:        uint32
    n_targets:   uint32
    capacity:    uint64            # total virtual sectors (sum of spans)
    self_slot:   int32             # this mapped device's own block slot
    pad:         uint32
    targets:     Array[8, DmTarget]
    # AES-256-XTS key material (crypt targets only): 32-byte data key
    # followed by 32-byte tweak key (the LUKS/dm-crypt 64-byte key split).
    key:         Array[64, uint8]


dm_devices: Array[8, MappedDevice]
dm_ops:     BlockDeviceOps
dm_inited:  uint32 = 0

# One-sector ciphertext staging buffer for the crypt path. dm-crypt I/O
# is serialised through the synchronous block layer, so a single shared
# module-scope sector buffer is safe (no two crypt transfers overlap).
_dm_crypt_sector: Array[512, uint8]


def dm_init():
    # Wire the shared vtable once; the device table starts all-free. No
    # mapped device exists until a dm_create_* call (or a /dev/mapper/ctl
    # write) builds one — matching Linux where dm has no devices until
    # dmsetup creates them.
    if dm_inited != 0:
        return
    dm_ops.read_sectors  = _dm_read_blkop
    dm_ops.write_sectors = _dm_write_blkop
    dm_ops.flush         = cast[Fn[int32, uint64]](0)
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        dm_devices[i].used      = 0
        dm_devices[i].n_targets = 0
        dm_devices[i].capacity  = 0
        dm_devices[i].self_slot = -1
        i = i + 1
    dm_inited = 1
    printk0("dm: device-mapper ready (linear + crypt targets)\n")


def _dm_find_target(dev: Ptr[MappedDevice], vlba: uint64) -> int32:
    # Return the index of the target whose span contains virtual LBA
    # `vlba`, or -1 if none does. Targets are stored in ascending span
    # order by construction, but a linear scan is fine for <= 8 rows.
    n: uint32 = dev[0].n_targets
    i: uint64 = 0
    while i < cast[uint64](n):
        st:  uint64 = dev[0].targets[i].start_sector
        ln:  uint64 = dev[0].targets[i].length
        if vlba >= st and vlba < st + ln:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_crypt_load_keys(dev: Ptr[MappedDevice]):
    # Expand this mapped device's 64-byte XTS key into the two AES-256
    # schedules: bytes 0..31 = data key, bytes 32..63 = tweak key.
    _dm_aes256_expand(cast[Ptr[uint8]](&dev[0].key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&dev[0].key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))


def _dm_linear_io(t: Ptr[DmTarget], is_write: int32, off_in_t: uint64,
                  count: uint64, buf: Ptr[uint8]) -> int32:
    # Linear remap: forward the whole [under_start + off_in_t, +count)
    # span straight to the underlying device. Plaintext passthrough.
    ulba: uint64 = t[0].under_start + off_in_t
    if is_write != 0:
        return blk_write_sectors(t[0].under_slot, ulba, count, buf)
    return blk_read_sectors(t[0].under_slot, ulba, count, buf)


def _dm_crypt_io(dev: Ptr[MappedDevice], t: Ptr[DmTarget],
                 is_write: int32, off_in_t: uint64, vlba: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # Crypt remap: process one sector at a time so each gets its own
    # sector-derived XTS tweak (plain64 IV). On write, AES-256-XTS-encrypt
    # the plaintext sector from `buf` into the staging buffer and write
    # the CIPHERTEXT to the backing device. On read, fetch the ciphertext
    # from the backing device into staging and XTS-decrypt into the
    # caller's `buf`. The tweak is keyed on the VIRTUAL sector number
    # (vlba) so the same plaintext at different mapped sectors produces
    # different ciphertext.
    _dm_crypt_load_keys(dev)
    stagep: Ptr[uint8] = cast[Ptr[uint8]](&_dm_crypt_sector[0])
    s: uint64 = 0
    while s < count:
        ulba: uint64 = t[0].under_start + off_in_t + s
        vsec: uint64 = vlba + s
        cur:  Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + s * SECTOR_SIZE)
        if is_write != 0:
            # plaintext (cur) -> ciphertext (staging) -> backing store
            _dm_xts_encrypt_sector(vsec, stagep, cur)
            rc: int32 = blk_write_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc != 0:
                return rc
        else:
            # backing store -> ciphertext (staging) -> plaintext (cur)
            rc2: int32 = blk_read_sectors(t[0].under_slot, ulba, 1, stagep)
            if rc2 != 0:
                return rc2
            _dm_xts_decrypt_sector(vsec, cur, stagep)
        s = s + 1
    return 0


def _dm_io(dev: Ptr[MappedDevice], is_write: int32, vlba: uint64,
           count: uint64, buf: Ptr[uint8]) -> int32:
    # Core remap. Walk the request sector-span, splitting it at target
    # boundaries (a single request may straddle two concatenated linear
    # targets), and dispatch each sub-span to its target's handler.
    if count == 0:
        return 0
    done: uint64 = 0
    while done < count:
        cur_v: uint64 = vlba + done
        ti: int32 = _dm_find_target(dev, cur_v)
        if ti < 0:
            printk1("dm: I/O outside any target (vlba=%d)\n", cur_v)
            return -1
        t: Ptr[DmTarget] = &dev[0].targets[cast[uint64](ti)]
        st:  uint64 = t[0].start_sector
        ln:  uint64 = t[0].length
        off_in_t: uint64 = cur_v - st
        # How many sectors remain in THIS target's span from cur_v on.
        avail: uint64 = ln - off_in_t
        chunk: uint64 = count - done
        if chunk > avail:
            chunk = avail
        bufp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + done * SECTOR_SIZE)
        rc: int32 = 0
        if t[0].ttype == DM_TARGET_CRYPT:
            rc = _dm_crypt_io(dev, t, is_write, off_in_t, cur_v,
                              chunk, bufp)
        else:
            rc = _dm_linear_io(t, is_write, off_in_t, chunk, bufp)
        if rc != 0:
            return rc
        done = done + chunk
    return 0


def _dm_read_blkop(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dev: Ptr[MappedDevice] = cast[Ptr[MappedDevice]](priv)
    if dev[0].used == 0:
        return -1
    return _dm_io(dev, 0, lba, count, buf)


def _dm_write_blkop(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dev: Ptr[MappedDevice] = cast[Ptr[MappedDevice]](priv)
    if dev[0].used == 0:
        return -1
    return _dm_io(dev, 1, lba, count, buf)


def _dm_alloc_device() -> int32:
    # Claim a free MappedDevice slot, or -1 if the table is full.
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _dm_register(idx: uint64, name: Ptr[char]) -> int32:
    # Register the (already-populated) mapped device at table index `idx`
    # with the block layer. Returns 0 on success, -1 on failure.
    cap: uint64 = dm_devices[idx].capacity
    priv: uint64 = cast[uint64](&dm_devices[idx])
    slot: int32 = register_blockdev(name, cap, &dm_ops, priv)
    if slot < 0:
        printk0("dm: block-device registration failed\n")
        return -1
    dm_devices[idx].self_slot = slot
    dm_devices[idx].used      = 1
    return 0


# =========================================================================
# dmsetup-shape control surface (public API)
# =========================================================================

def dm_create_linear(name: Ptr[char], under_slot: int32,
                     under_start: uint64, length: uint64) -> int32:
    # Create a mapped device with a SINGLE linear target covering the
    # whole virtual device [0, length): virtual sector v maps to
    # underlying sector (under_start + v) on `under_slot`. This is the
    # `dmsetup create NAME --table "0 LENGTH linear DEV START"` shape.
    # Returns the registered block slot (>= 0) or a negative error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    # Underlying device must actually hold the mapped span.
    ucap: uint64 = blk_capacity_sectors(under_slot)
    if under_start + length > ucap:
        printk0("dm: linear target exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets             = 1
    dm_devices[idx].capacity              = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_create_concat(name: Ptr[char],
                     slot_a: int32, start_a: uint64, len_a: uint64,
                     slot_b: int32, start_b: uint64, len_b: uint64) -> int32:
    # Create a mapped device from TWO concatenated linear targets — the
    # canonical LVM "join two physical extents into one logical volume"
    # case. Virtual [0, len_a) maps onto (slot_a, start_a..); virtual
    # [len_a, len_a+len_b) maps onto (slot_b, start_b..). The block layer
    # sees one device of (len_a + len_b) sectors. Returns the registered
    # block slot or a negative error.
    dm_init()
    if len_a == 0 or len_b == 0:
        return -1
    if slot_a < 0 or slot_b < 0:
        return -2
    if start_a + len_a > blk_capacity_sectors(slot_a):
        printk0("dm: concat target A exceeds underlying capacity\n")
        return -3
    if start_b + len_b > blk_capacity_sectors(slot_b):
        printk0("dm: concat target B exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    dm_devices[idx].n_targets = 2
    dm_devices[idx].capacity  = len_a + len_b
    dm_devices[idx].targets[0].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = len_a
    dm_devices[idx].targets[0].under_slot   = slot_a
    dm_devices[idx].targets[0].under_start  = start_a
    dm_devices[idx].targets[1].ttype        = DM_TARGET_LINEAR
    dm_devices[idx].targets[1].start_sector = len_a
    dm_devices[idx].targets[1].length       = len_b
    dm_devices[idx].targets[1].under_slot   = slot_b
    dm_devices[idx].targets[1].under_start  = start_b
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_create_crypt(name: Ptr[char], under_slot: int32,
                    under_start: uint64, length: uint64,
                    key: Ptr[uint8], keylen: uint64) -> int32:
    # Create a dm-crypt mapped device with a SINGLE crypt target over
    # [0, length): every sector written through the mapped device is
    # AES-256-XTS-encrypted (plain64 sector-keyed tweak) before it
    # reaches the backing store, and decrypted on read. `key` supplies up
    # to DM_KEY_LEN (64) bytes — the 32-byte data key followed by the
    # 32-byte tweak key — and a short key is zero-padded. This is the
    # `dmsetup create NAME --table "0 LENGTH crypt aes-xts-plain64 KEY 0 DEV START"`
    # shape. Returns the registered block slot or a negative error.
    dm_init()
    if length == 0:
        return -1
    if under_slot < 0:
        return -2
    if under_start + length > blk_capacity_sectors(under_slot):
        printk0("dm: crypt target exceeds underlying capacity\n")
        return -3
    idx_s: int32 = _dm_alloc_device()
    if idx_s < 0:
        printk0("dm: device table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    # Install the key (zero-pad / truncate to DM_KEY_LEN).
    ki: uint64 = 0
    while ki < DM_KEY_LEN:
        if ki < keylen:
            dm_devices[idx].key[ki] = key[ki]
        else:
            dm_devices[idx].key[ki] = 0
        ki = ki + 1
    dm_devices[idx].n_targets = 1
    dm_devices[idx].capacity  = length
    dm_devices[idx].targets[0].ttype        = DM_TARGET_CRYPT
    dm_devices[idx].targets[0].start_sector = 0
    dm_devices[idx].targets[0].length       = length
    dm_devices[idx].targets[0].under_slot   = under_slot
    dm_devices[idx].targets[0].under_start  = under_start
    if _dm_register(idx, name) != 0:
        dm_devices[idx].used = 0
        return -5
    return dm_devices[idx].self_slot


def dm_remove(name: Ptr[char]) -> int32:
    # Tear down a mapped device by name: unregister its block-device
    # identity and free the MappedDevice slot. dmsetup remove NAME.
    # Returns 0 on success, -1 if no mapped device carried that name.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < DM_MAX_DEVICES:
        if dm_devices[i].used != 0 and dm_devices[i].self_slot == slot:
            blk_unregister_by_name(name)
            dm_devices[i].used      = 0
            dm_devices[i].n_targets = 0
            dm_devices[i].capacity  = 0
            dm_devices[i].self_slot = -1
            return 0
        i = i + 1
    return -1


# =========================================================================
# Deterministic device-mapper self-test
# =========================================================================
#
# Gated boot self-test (init/main.ad, planted /etc/devmapper-test by
# build_initramfs.py when ENABLE_DEVMAPPER_TEST=1). It runs entirely
# against a DEDICATED in-kernel backing ramdisk (registered here as
# "dmback0"), so it never touches ram0's FAT image and is fully
# deterministic.
#
# It PROVES four things:
#
#   1. LINEAR remap correctness: write a known pattern THROUGH the linear
#      mapped device at virtual LBA L, then read the SAME data back from
#      the UNDERLYING backing device at the mapped offset (under_start+L).
#      The bytes match -> the linear target really remaps to the right
#      underlying sector.
#   2. CONCATENATION: a two-target mapped device routes virtual sectors
#      in span A to backing region A and virtual sectors in span B to a
#      DIFFERENT backing region B. Writing distinct patterns to one
#      virtual sector in each span and reading the underlying regions
#      back confirms each landed in the correct backing device offset.
#   3. CRYPT round-trip + IV-dependence: plaintext written through the
#      crypt device is CIPHERTEXT on the backing store (differs from the
#      plaintext), yet reads back through the crypt device as the
#      ORIGINAL plaintext. AND the SAME plaintext written to two
#      DIFFERENT virtual sectors produces DIFFERENT ciphertext on disk
#      (the plain64 IV is sector-dependent).
#
# Each marker line stamps EMERG so it reaches serial even at the prompt.

# Dedicated backing ramdisk: 256 sectors = 128 KiB. Module-scope per the
# Adder large-array quirk.
_DM_BACK_SECTORS: uint64 = 256
_dm_back_store:   Array[131072, uint8]   # 256 * 512
_dm_back_ops:     BlockDeviceOps

# Scratch buffers for the self-test (all module-scope, one sector each
# unless noted).
_dm_t_plain:   Array[512, uint8]   # plaintext written through a mapped dev
_dm_t_plain2:  Array[512, uint8]   # second plaintext (concat span B)
_dm_t_read:    Array[512, uint8]   # readback through a mapped dev
_dm_t_under:   Array[512, uint8]   # raw read from the backing device
_dm_t_under2:  Array[512, uint8]   # raw read from a second backing sector
_dm_t_key:     Array[64, uint8]    # AES-256-XTS key (32B data + 32B tweak)

# AES-XTS known-answer-test scratch (IEEE 1619 / OpenSSL test vector).
# Generously sized — these hold whole-sector transforms.
_dm_kat_key:   Array[64, uint8]
_dm_kat_pt:    Array[512, uint8]
_dm_kat_ct:    Array[512, uint8]
_dm_kat_out:   Array[512, uint8]


def _dm_back_read(priv: uint64, lba: uint64, count: uint64,
                  buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_dm_back_store[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _dm_back_write(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_dm_back_store[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _dm_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _dm_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def _dm_emerg2(s: Ptr[char], a: uint64, b: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2(s, a, b)


def _dm_back_register() -> int32:
    # Register the dedicated test backing ramdisk as "dmback0". Returns
    # the slot, or the existing slot if already registered.
    existing: int32 = find_blockdev("dmback0")
    if existing >= 0:
        return existing
    # Zero the backing store so the test starts from a clean slate.
    z: uint64 = 0
    while z < 131072:
        _dm_back_store[z] = 0
        z = z + 1
    _dm_back_ops.read_sectors  = _dm_back_read
    _dm_back_ops.write_sectors = _dm_back_write
    _dm_back_ops.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev("dmback0", _DM_BACK_SECTORS,
                             &_dm_back_ops, 0)


def _dm_buf_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


# Reference AES-256-XTS ciphertext for the known-answer test, computed
# offline by Python's `cryptography` library (an independent, trusted AES
# implementation). Parameters:
#   key      = bytes((i*17+5)&0xFF for i in range(64))   # 32B data+32B tweak
#   plaintext= bytes((i*3+42)&0xFF for i in range(512))  # one 512B sector
#   sector   = 7  (plain64 IV = 7 little-endian in a 16-byte tweak block)
# We assert the FIRST and LAST 16-byte ciphertext blocks; matching both
# pins the cipher, the tweak derivation and the GF(2^128) alpha-multiply
# across the whole sector.
_DM_KAT_SECTOR: uint64 = 7
_dm_kat_ct_first: Array[16, uint8]   # expected CT[0..15]
_dm_kat_ct_last:  Array[16, uint8]   # expected CT[496..511]


def _dm_xts_kat_load_expected():
    _dm_kat_ct_first[0] = 0x26
    _dm_kat_ct_first[1] = 0xb7
    _dm_kat_ct_first[2] = 0x7f
    _dm_kat_ct_first[3] = 0xa2
    _dm_kat_ct_first[4] = 0xe2
    _dm_kat_ct_first[5] = 0xc5
    _dm_kat_ct_first[6] = 0x64
    _dm_kat_ct_first[7] = 0xac
    _dm_kat_ct_first[8] = 0xdc
    _dm_kat_ct_first[9] = 0x4c
    _dm_kat_ct_first[10] = 0xd4
    _dm_kat_ct_first[11] = 0xb4
    _dm_kat_ct_first[12] = 0x8e
    _dm_kat_ct_first[13] = 0x61
    _dm_kat_ct_first[14] = 0x9b
    _dm_kat_ct_first[15] = 0x3f
    _dm_kat_ct_last[0] = 0xfe
    _dm_kat_ct_last[1] = 0x34
    _dm_kat_ct_last[2] = 0x89
    _dm_kat_ct_last[3] = 0xee
    _dm_kat_ct_last[4] = 0x1c
    _dm_kat_ct_last[5] = 0xad
    _dm_kat_ct_last[6] = 0x72
    _dm_kat_ct_last[7] = 0x2f
    _dm_kat_ct_last[8] = 0x6c
    _dm_kat_ct_last[9] = 0x16
    _dm_kat_ct_last[10] = 0xad
    _dm_kat_ct_last[11] = 0x4b
    _dm_kat_ct_last[12] = 0x22
    _dm_kat_ct_last[13] = 0x48
    _dm_kat_ct_last[14] = 0x69
    _dm_kat_ct_last[15] = 0xbb


def _dm_xts_kat() -> int32:
    # Returns 1 if the AES-256-XTS implementation reproduces the offline
    # reference vector AND decrypts it back to plaintext, else 0.
    _dm_xts_kat_load_expected()
    i: uint64 = 0
    while i < 64:
        _dm_kat_key[i] = cast[uint8]((i * 17 + 5) & 0xFF)
        i = i + 1
    i = 0
    while i < SECTOR_SIZE:
        _dm_kat_pt[i] = cast[uint8]((i * 3 + 42) & 0xFF)
        i = i + 1
    # Load the schedules directly from the KAT key (data = bytes 0..31,
    # tweak = bytes 32..63) and XTS-encrypt the whole sector.
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))
    _dm_xts_encrypt_sector(_DM_KAT_SECTOR,
                           cast[Ptr[uint8]](&_dm_kat_ct[0]),
                           cast[Ptr[uint8]](&_dm_kat_pt[0]))
    # First and last ciphertext blocks must match the reference.
    if _dm_buf_eq(&_dm_kat_ct[0], &_dm_kat_ct_first[0], 16) != 1:
        _dm_emerg0("[device-mapper] KAT first block mismatch\n")
        return 0
    if _dm_buf_eq(&_dm_kat_ct[496], &_dm_kat_ct_last[0], 16) != 1:
        _dm_emerg0("[device-mapper] KAT last block mismatch\n")
        return 0
    # Decrypt round-trip: must reproduce the plaintext exactly.
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[0]),
                      cast[Ptr[uint8]](&_dm_aes_rk_data[0]))
    _dm_aes256_expand(cast[Ptr[uint8]](&_dm_kat_key[32]),
                      cast[Ptr[uint8]](&_dm_aes_rk_tweak[0]))
    _dm_xts_decrypt_sector(_DM_KAT_SECTOR,
                           cast[Ptr[uint8]](&_dm_kat_out[0]),
                           cast[Ptr[uint8]](&_dm_kat_ct[0]))
    if _dm_buf_eq(&_dm_kat_out[0], &_dm_kat_pt[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] KAT decrypt round-trip mismatch\n")
        return 0
    return 1


def dm_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [device-mapper] marker lines.
    _dm_emerg0("[device-mapper] self-test start\n")
    dm_init()

    back: int32 = _dm_back_register()
    if back < 0:
        _dm_emerg0("[device-mapper] FAIL: backing register\n")
        return 0
    _dm_emerg1("[device-mapper] backing dmback0 slot=%d\n",
               cast[uint64](cast[int64](back)))

    ok: int32 = 1

    # --- Test 1: LINEAR target remaps to the right underlying sector ---
    # Map [0, 16) of a virtual device onto dmback0 starting at sector 32.
    # Write a pattern through the mapped device at virtual LBA 5; it must
    # land on backing sector 32 + 5 = 37.
    pi: uint64 = 0
    while pi < SECTOR_SIZE:
        _dm_t_plain[pi] = cast[uint8]((pi * 7 + 3) & 0xFF)
        pi = pi + 1
    lin: int32 = dm_create_linear("dmlin0", back, 32, 16)
    if lin < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_linear rc=%d\n",
                   cast[uint64](cast[int64](lin)))
        return 0
    if blk_write_sectors(lin, 5, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: linear write\n")
        return 0
    # Read the UNDERLYING backing sector 37 directly.
    if blk_read_sectors(back, 37, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read (linear)\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: linear remap landed on wrong sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] linear: vLBA5 -> backing sector 37 OK\n")
    # And it must read back through the mapped device unchanged.
    if blk_read_sectors(lin, 5, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: linear readback\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: linear readback mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] linear: readback byte-identical OK\n")

    # --- Test 2: CONCATENATION across two backing regions ---
    # Span A: virtual [0, 8) -> dmback0 @ 64. Span B: virtual [8, 16) ->
    # dmback0 @ 128. Write distinct patterns to a sector in each span and
    # confirm each landed in the correct backing region.
    qi: uint64 = 0
    while qi < SECTOR_SIZE:
        _dm_t_plain[qi]  = cast[uint8]((qi * 11 + 1) & 0xFF)   # span A
        _dm_t_plain2[qi] = cast[uint8]((qi * 13 + 9) & 0xFF)   # span B
        qi = qi + 1
    cc: int32 = dm_create_concat("dmcat0", back, 64, 8, back, 128, 8)
    if cc < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_concat rc=%d\n",
                   cast[uint64](cast[int64](cc)))
        return 0
    # Virtual LBA 2 is in span A -> backing 64 + 2 = 66.
    if blk_write_sectors(cc, 2, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: concat write A\n")
        return 0
    # Virtual LBA 10 is in span B (offset 2) -> backing 128 + 2 = 130.
    if blk_write_sectors(cc, 10, 1, &_dm_t_plain2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: concat write B\n")
        return 0
    if blk_read_sectors(back, 66, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 66\n")
        return 0
    if blk_read_sectors(back, 130, 1, &_dm_t_under2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 130\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: concat span A wrong backing sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] concat: span A vLBA2 -> backing 66 OK\n")
    if _dm_buf_eq(&_dm_t_plain2[0], &_dm_t_under2[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: concat span B wrong backing sector\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] concat: span B vLBA10 -> backing 130 OK\n")

    # --- Test 3: CRYPT round-trip + IV-dependence ---
    # Map [0, 16) onto dmback0 @ 192 with a fixed key. Write identical
    # plaintext to virtual sectors 0 and 1; on the backing store sectors
    # 192 and 193 must hold CIPHERTEXT that (a) differs from the plaintext
    # and (b) differs from EACH OTHER (sector-dependent IV). Reading both
    # back through the crypt device must return the original plaintext.
    ki2: uint64 = 0
    while ki2 < DM_KEY_LEN:
        _dm_t_key[ki2] = cast[uint8]((ki2 * 17 + 5) & 0xFF)
        ki2 = ki2 + 1
    pj: uint64 = 0
    while pj < SECTOR_SIZE:
        _dm_t_plain[pj] = cast[uint8]((pj * 3 + 42) & 0xFF)
        pj = pj + 1
    cr: int32 = dm_create_crypt("dmcrypt0", back, 192, 16,
                                &_dm_t_key[0], DM_KEY_LEN)
    if cr < 0:
        _dm_emerg1("[device-mapper] FAIL: dm_create_crypt rc=%d\n",
                   cast[uint64](cast[int64](cr)))
        return 0
    # Same plaintext to virtual sectors 0 and 1.
    if blk_write_sectors(cr, 0, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt write sec0\n")
        return 0
    if blk_write_sectors(cr, 1, 1, &_dm_t_plain[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt write sec1\n")
        return 0
    # Backing 192 / 193 hold the two ciphertexts.
    if blk_read_sectors(back, 192, 1, &_dm_t_under[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 192\n")
        return 0
    if blk_read_sectors(back, 193, 1, &_dm_t_under2[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: backing read 193\n")
        return 0
    # (a) ciphertext on disk differs from plaintext (real encryption,
    # not a passthrough).
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_under[0], SECTOR_SIZE) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt backing == plaintext (no encryption)\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-ciphertext: backing sector 192 is ciphertext OK\n")
    # (b) the two sectors' ciphertext differ (IV is sector-dependent).
    if _dm_buf_eq(&_dm_t_under[0], &_dm_t_under2[0], SECTOR_SIZE) != 0:
        _dm_emerg0("[device-mapper] FAIL: identical plaintext -> identical ciphertext (IV not sector-keyed)\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-tweak: same plaintext, two sectors -> different ciphertext OK\n")
    # Round-trip: read back through the crypt device -> original plaintext.
    if blk_read_sectors(cr, 0, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt readback sec0\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: crypt round-trip sec0 mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-roundtrip-sec0: sector 0 round-trips to plaintext OK\n")
    if blk_read_sectors(cr, 1, 1, &_dm_t_read[0]) != 0:
        _dm_emerg0("[device-mapper] FAIL: crypt readback sec1\n")
        return 0
    if _dm_buf_eq(&_dm_t_plain[0], &_dm_t_read[0], SECTOR_SIZE) != 1:
        _dm_emerg0("[device-mapper] FAIL: crypt round-trip sec1 mismatch\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-roundtrip-sec1: sector 1 round-trips to plaintext OK\n")

    # --- Test 4: AES-256-XTS KNOWN-ANSWER TEST (independent vector) ---
    # The highest-confidence check: encrypt a fixed plaintext sector with
    # a fixed 64-byte key at a fixed sector number and assert the
    # ciphertext byte-for-byte matches a reference vector computed OFFLINE
    # by Python's `cryptography` AES-XTS (key = (i*17+5)&0xFF, plaintext =
    # (i*3+42)&0xFF, sector = 7, plain64 IV). This pins the cipher, the
    # tweak derivation AND the GF(2^128) alpha-multiply across all 32
    # blocks of the sector (first and LAST block are both asserted). Then
    # decrypt it back and assert it returns the plaintext.
    if _dm_xts_kat() != 1:
        _dm_emerg0("[device-mapper] FAIL: AES-256-XTS known-answer test\n")
        ok = 0
    else:
        _dm_emerg0("[device-mapper] PASS dmcrypt-kat: AES-256-XTS vector matches reference OK\n")

    # Clean up the mapped devices (frees slots; leaves dmback0 in place).
    dm_remove("dmlin0")
    dm_remove("dmcat0")
    dm_remove("dmcrypt0")

    if ok == 1:
        _dm_emerg0("[device-mapper] PASS\n")
        return 1
    _dm_emerg0("[device-mapper] FAIL\n")
    return 0

# drivers/block/virtio_blk.ad
#
# Mirror of drivers/block/virtio_blk.c at minimum scope — read-only,
# single in-flight request, polled completion. Probes the legacy
# virtio-blk PCI device (1AF4:1001), runs the standard virtio init
# dance, sets up virtqueue 0, and registers "vda" against the
# block-layer abstraction so the FAT32 driver can mount against
# either /dev/ram0 or /dev/vda without caring which.
#
# Request shape (virtio-blk legacy):
#
#   struct virtio_blk_outhdr {
#       u32 type;      // 0 = IN (read), 1 = OUT (write), 4 = FLUSH
#       u32 ioprio;    // ignored by QEMU
#       u64 sector;
#   };
#   [data bytes]       // SECTOR_SIZE * count
#   u8  status;        // 0 = OK, 1 = IOERR, 2 = UNSUPP
#
# We submit them as a 3-descriptor chain (outhdr, data, status).
# Device sees: read outhdr, write data + status. Caller polls used
# ring for completion.

from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level,
)
from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, SECTOR_SIZE,
    find_blockdev, blk_read_sectors, blk_write_sectors,
    blk_flush, blk_capacity_sectors, blk_slot_name,
)
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from drivers.pci.pci import (
    pci_find, pci_find_from, pci_bdf_bus, pci_bdf_dev, pci_bdf_fn,
    pci_read_bar, pci_enable_io_and_master, PCI_BDF_NONE,
    pci_config_read_byte,
)
from drivers.virtio.virtio_pci import (
    virtio_reset, virtio_acknowledge, virtio_driver_ok,
    virtio_read_host_features, virtio_write_guest_features,
    virtio_dev_config_read_u64, virtio_dev_config_read_u32,
    virtio_dev_config_read_u16, VIRTIO_PCI_ISR,
)
from drivers.virtio.virtio_ring import (
    VirtQueue, VirtBuf, virtq_setup, virtq_add_chain3,
    virtq_add_chain2, virtq_kick_and_wait,
)
from arch.x86.kernel.apic import ioapic_redirect
from arch.x86.kernel.irq import register_irq_handler


VIRTIO_VENDOR:     uint32 = 0x1AF4
VIRTIO_BLK_LEGACY: uint32 = 0x1001   # transitional / legacy virtio-blk

# Block-request header types (virtio-blk spec §5.2.6).
VIRTIO_BLK_T_IN:            uint32 = 0
VIRTIO_BLK_T_OUT:          uint32 = 1
VIRTIO_BLK_T_FLUSH:        uint32 = 4
VIRTIO_BLK_T_DISCARD:      uint32 = 11
VIRTIO_BLK_T_WRITE_ZEROES: uint32 = 13

# Status byte returned by the device in the WO status descriptor.
VIRTIO_BLK_S_OK:     uint32 = 0
VIRTIO_BLK_S_IOERR:  uint32 = 1
VIRTIO_BLK_S_UNSUPP: uint32 = 2

# Feature bits (virtio-blk spec §5.2.3). The legacy transport exposes
# only the low 32 host-feature bits, and every block feature we care
# about lives there.
VIRTIO_BLK_F_SIZE_MAX:     uint32 = 1     # size_max in config
VIRTIO_BLK_F_SEG_MAX:      uint32 = 2     # seg_max in config
VIRTIO_BLK_F_BLK_SIZE:     uint32 = 6     # blk_size in config
VIRTIO_BLK_F_FLUSH:        uint32 = 9     # cache flush command (type 4)
VIRTIO_BLK_F_MQ:           uint32 = 12    # num_queues in config
VIRTIO_BLK_F_DISCARD:      uint32 = 13    # DISCARD command (type 11)
VIRTIO_BLK_F_WRITE_ZEROES: uint32 = 14    # WRITE_ZEROES command (type 13)

# capacity is in 512-byte sectors at config offset 0 (relative to
# the device-specific config window). The remaining offsets follow
# struct virtio_blk_config (virtio spec §5.2.4):
#
#   0x00 u64 capacity
#   0x08 u32 size_max
#   0x0C u32 seg_max
#   0x10 u16 geometry.cylinders
#   0x12 u8  geometry.heads
#   0x13 u8  geometry.sectors
#   0x14 u32 blk_size
#   0x18 u8  physical_block_exp / alignment_offset / min/opt io (8 bytes)
#   0x20 u32 max_discard_sectors
#   0x24 u32 max_discard_seg
#   0x28 u32 discard_sector_alignment
#   0x2C u32 max_write_zeroes_sectors
#   0x30 u32 max_write_zeroes_seg
#   0x34 u8  write_zeroes_may_unmap
#   0x35 u8[3] unused
#   0x38 u32 num_queues   (only with VIRTIO_BLK_F_MQ)
VIRTIO_BLK_CFG_CAPACITY:        uint32 = 0x00
VIRTIO_BLK_CFG_SIZE_MAX:        uint32 = 0x08
VIRTIO_BLK_CFG_SEG_MAX:         uint32 = 0x0C
VIRTIO_BLK_CFG_BLK_SIZE:        uint32 = 0x14
VIRTIO_BLK_CFG_MAX_DISCARD_SEC: uint32 = 0x20
VIRTIO_BLK_CFG_MAX_DISCARD_SEG: uint32 = 0x24
VIRTIO_BLK_CFG_DISCARD_ALIGN:   uint32 = 0x28
VIRTIO_BLK_CFG_MAX_WZ_SEC:      uint32 = 0x2C
VIRTIO_BLK_CFG_MAX_WZ_SEG:      uint32 = 0x30
VIRTIO_BLK_CFG_NUM_QUEUES:      uint32 = 0x38

# Flags in struct virtio_blk_discard_write_zeroes.flags. Bit 0
# (UNMAP) asks the device to also deallocate the range on a
# WRITE_ZEROES so the backing store reads zero AND frees space.
VIRTIO_BLK_WRITE_ZEROES_FLAG_UNMAP: uint32 = 1

# PCI config-space offsets used by the INTx IRQ wiring path.
VBLK_PCI_INTERRUPT_LINE: uint32 = 0x3C
VBLK_PCI_INTERRUPT_PIN:  uint32 = 0x3D

# CPU vector this driver claims for its INTx IRQ. The IOAPIC-routed
# PCI-INTx band runs 0x40..0x47 (see arch/x86/kernel/idt.ad):
#   0x40 virtio-net   0x41 AHCI   0x42 NVMe   0x44 r8169 (8139)
#   0x45 PS/2 mouse   0x46 PS/2 kbd   0x47 e1000e
# 0x43 is the free slot in that band — virtio-blk claims it. The
# roadmap notes "vectors 0x41+" for this item.
VBLK_IRQ_VECTOR: uint32 = 0x43

# LAPIC id the IRQ is routed to — always the BSP (id 0) for now.
VBLK_LAPIC_ID:   uint32 = 0


# Per-device state. We support up to VBLK_MAX disks so the installer
# can use a second disk: the first virtio-blk on the bus registers as
# "vda", the second as "vdb", and so on. The block layer's per-slot
# `priv` cookie is the index into this array; that lets the shared
# read/write functions reach the right device without a global.
VBLK_MAX: uint64 = 4


class VirtioBlk:
    iobase:    uint32       # PCI BAR0 IO base (BAR low bit cleared)
    qsize:     uint32
    vq:        VirtQueue
    capacity:  uint64       # sectors
    irq_pin:   uint32       # IOAPIC pin (GSI) we redirected
    irq_count: uint64       # IRQs serviced by virtio_blk_irq_handler
    # --- negotiated features + device-config limits -----------------
    features:        uint32   # subset of host features we accepted
    blk_size:        uint32   # logical block size (F_BLK_SIZE), else 512
    seg_max:         uint32   # max descriptors in a data chain (F_SEG_MAX)
    size_max:        uint32   # max bytes per single data descriptor (F_SIZE_MAX)
    num_queues:      uint32   # request queues (F_MQ); >=1
    max_discard_sec: uint32   # max sectors per discard segment (F_DISCARD)
    max_discard_seg: uint32   # max discard segments per request
    discard_align:   uint32   # discard sector alignment
    max_wz_sec:      uint32   # max sectors per write-zeroes segment
    max_wz_seg:      uint32   # max write-zeroes segments per request
    has_flush:       uint32   # 1 if VIRTIO_BLK_F_FLUSH negotiated
    has_discard:     uint32   # 1 if VIRTIO_BLK_F_DISCARD negotiated
    has_wzeroes:     uint32   # 1 if VIRTIO_BLK_F_WRITE_ZEROES negotiated


# Per-device in-flight request scratch:
#   outhdr (16 bytes) | status (1 byte; padded to 8 for alignment).
# The DATA buffer is the caller-supplied page-aligned target. The
# header + status are global so the request doesn't malloc; size
# requirements are tiny.
class VirtioBlkReq:
    outhdr_type:    uint32        # 0
    outhdr_ioprio:  uint32        # 4
    outhdr_sector:  uint64        # 8
    status:         uint8         # 16
    pad:            Array[7, uint8]   # 17..24
    # struct virtio_blk_discard_write_zeroes (spec §5.2.6.2): a single
    # segment carried as the data descriptor for DISCARD / WRITE_ZEROES.
    #   u64 sector; u32 num_sectors; u32 flags;
    # We submit exactly one segment per request, which is always within
    # max_discard_seg / max_write_zeroes_seg (>= 1 by spec).
    dwz_sector:      uint64       # 24
    dwz_num_sectors: uint32       # 32
    dwz_flags:       uint32       # 36


# Array sizes are literals because Adder doesn't accept a const in
# Array[N, T]; keep these in sync with VBLK_MAX (4) and the
# per-device descriptor count (3 = outhdr + data + status).
vblk_states: Array[4, VirtioBlk]
vblk_reqs:   Array[4, VirtioBlkReq]
vblk_ops:    BlockDeviceOps
vblk_bufs:   Array[12, VirtBuf]            # VBLK_MAX * 3 descriptors
vblk_count:  uint64 = 0


def _vblk_feature(features: uint32, bit: uint32) -> int32:
    # 1 if feature `bit` (a bit index 0..31) is set in `features`.
    if (features & (cast[uint32](1) << bit)) != 0:
        return 1
    return 0


def _vblk_submit3(priv: uint64, hdr_len: uint32, data_addr: uint64,
                  data_len: uint32, data_write: uint32) -> int32:
    # Submit a 3-descriptor request: outhdr (RO), one data segment, and
    # the status byte (WO). `data_write` flips whether the device reads
    # (0) or writes (1) the middle descriptor. The header type/sector
    # must already be planted in vblk_reqs[priv]. Returns the device
    # status byte translated to 0 (OK) / -1 (any non-OK) after a
    # successful ring round-trip, or -1 on a submission/timeout error.
    buf_base: uint64 = priv * 3
    vblk_reqs[priv].status = 0xFF
    vblk_bufs[buf_base + 0].addr   = cast[uint64](
        &vblk_reqs[priv].outhdr_type)
    vblk_bufs[buf_base + 0].length = hdr_len
    vblk_bufs[buf_base + 0].write  = 0
    vblk_bufs[buf_base + 1].addr   = data_addr
    vblk_bufs[buf_base + 1].length = data_len
    vblk_bufs[buf_base + 1].write  = data_write
    vblk_bufs[buf_base + 2].addr   = cast[uint64](
        &vblk_reqs[priv].status)
    vblk_bufs[buf_base + 2].length = 1
    vblk_bufs[buf_base + 2].write  = 1

    head: uint16 = virtq_add_chain3(&vblk_states[priv].vq,
                                    &vblk_bufs[buf_base])
    if head == 0xFFFF:
        return -1
    rc: int32 = virtq_kick_and_wait(vblk_states[priv].iobase, 0,
                                    &vblk_states[priv].vq)
    # Single in-flight request: reset the descriptor free-list head so
    # the next request reuses the chain from descriptor 0.
    vblk_states[priv].vq.free_head = 0
    if rc != 0:
        return rc
    return _vblk_status_to_rc(priv)


def _vblk_status_to_rc(priv: uint64) -> int32:
    # Translate the device's status byte to a return code. OK -> 0,
    # IOERR/UNSUPP/any other value -> -1, with a diagnostic.
    st: uint8 = vblk_reqs[priv].status
    if cast[uint32](st) == VIRTIO_BLK_S_OK:
        return 0
    if cast[uint32](st) == VIRTIO_BLK_S_UNSUPP:
        printk0("virtio-blk: device returned UNSUPP for request\n")
        return -1
    printk1("virtio-blk: request failed status=%d\n",
            cast[uint64](cast[uint32](st)))
    return -1


def virtio_blk_read_sectors(priv: uint64, lba: uint64,
                            count: uint64, buf: Ptr[uint8]) -> int32:
    # Build a single 3-descriptor request: outhdr (RO), data (WO),
    # status (WO). `priv` indexes into vblk_states; the block layer
    # passes back whatever cookie we handed to register_blockdev. The
    # transfer is one data descriptor, which always honours seg_max
    # (>= 1 by spec).
    if count == 0:
        return 0
    if priv >= VBLK_MAX:
        return -1
    vblk_reqs[priv].outhdr_type   = VIRTIO_BLK_T_IN
    vblk_reqs[priv].outhdr_ioprio = 0
    vblk_reqs[priv].outhdr_sector = lba
    return _vblk_submit3(priv, 16, cast[uint64](buf),
                         cast[uint32](count * SECTOR_SIZE), 1)


def virtio_blk_write_sectors(priv: uint64, lba: uint64,
                             count: uint64, buf: Ptr[uint8]) -> int32:
    # Same 3-descriptor shape as read, but the data buffer flips to RO
    # (device reads it) and the request type is OUT. Durability across a
    # crash is provided by virtio_blk_flush (VIRTIO_BLK_T_FLUSH) which
    # the block layer issues on fsync/barrier when F_FLUSH is offered.
    if count == 0:
        return 0
    if priv >= VBLK_MAX:
        return -1
    vblk_reqs[priv].outhdr_type   = VIRTIO_BLK_T_OUT
    vblk_reqs[priv].outhdr_ioprio = 0
    vblk_reqs[priv].outhdr_sector = lba
    return _vblk_submit3(priv, 16, cast[uint64](buf),
                         cast[uint32](count * SECTOR_SIZE), 0)


def virtio_blk_flush(priv: uint64) -> int32:
    # VIRTIO_BLK_T_FLUSH: guarantee every previously-acknowledged write
    # has reached non-volatile media. The flush request has NO data
    # segment — it is a 2-descriptor chain: outhdr (RO) + status (WO).
    # Wired into the block layer's `flush` op so fsync/barrier semantics
    # reach the device. If the device never offered F_FLUSH, writes are
    # already durable on completion, so report success without a round
    # trip (mirrors blk_flush's null-op contract).
    if priv >= VBLK_MAX:
        return -1
    if vblk_states[priv].has_flush == 0:
        return 0
    vblk_reqs[priv].outhdr_type   = VIRTIO_BLK_T_FLUSH
    vblk_reqs[priv].outhdr_ioprio = 0
    vblk_reqs[priv].outhdr_sector = 0
    vblk_reqs[priv].status        = 0xFF

    buf_base: uint64 = priv * 3
    vblk_bufs[buf_base + 0].addr   = cast[uint64](
        &vblk_reqs[priv].outhdr_type)
    vblk_bufs[buf_base + 0].length = 16
    vblk_bufs[buf_base + 0].write  = 0
    vblk_bufs[buf_base + 1].addr   = cast[uint64](
        &vblk_reqs[priv].status)
    vblk_bufs[buf_base + 1].length = 1
    vblk_bufs[buf_base + 1].write  = 1

    head: uint16 = virtq_add_chain2(&vblk_states[priv].vq,
                                    &vblk_bufs[buf_base])
    if head == 0xFFFF:
        return -1
    rc: int32 = virtq_kick_and_wait(vblk_states[priv].iobase, 0,
                                    &vblk_states[priv].vq)
    vblk_states[priv].vq.free_head = 0
    if rc != 0:
        return rc
    return _vblk_status_to_rc(priv)


def virtio_blk_discard(priv: uint64, lba: uint64, count: uint64) -> int32:
    # VIRTIO_BLK_T_DISCARD: tell the device the [lba, lba+count) range
    # is no longer needed (TRIM / BLKDISCARD). The data segment is a
    # single struct virtio_blk_discard_write_zeroes {sector, num_sectors,
    # flags=0}. The device may, but need not, return zeros on a later
    # read of a discarded range — so callers that need guaranteed zeros
    # use write_zeroes instead. Returns 0 on OK, -1 otherwise.
    if priv >= VBLK_MAX:
        return -1
    if count == 0:
        return 0
    if vblk_states[priv].has_discard == 0:
        printk0("virtio-blk: discard requested but F_DISCARD not negotiated\n")
        return -1
    # Honour the device's per-segment limit. max_discard_sec == 0 means
    # "unbounded" per the spec (no explicit cap), so only clamp when set.
    mx: uint32 = vblk_states[priv].max_discard_sec
    if mx != 0 and count > cast[uint64](mx):
        printk2("virtio-blk: discard count=%d exceeds max_discard_sec=%d\n",
                count, cast[uint64](mx))
        return -1
    vblk_reqs[priv].outhdr_type   = VIRTIO_BLK_T_DISCARD
    vblk_reqs[priv].outhdr_ioprio = 0
    vblk_reqs[priv].outhdr_sector = 0
    vblk_reqs[priv].dwz_sector      = lba
    vblk_reqs[priv].dwz_num_sectors = cast[uint32](count)
    vblk_reqs[priv].dwz_flags       = 0
    return _vblk_submit3(priv, 16,
                         cast[uint64](&vblk_reqs[priv].dwz_sector),
                         16, 0)


def virtio_blk_write_zeroes(priv: uint64, lba: uint64,
                            count: uint64, unmap: int32) -> int32:
    # VIRTIO_BLK_T_WRITE_ZEROES: efficiently zero [lba, lba+count)
    # without transferring a buffer of zeros. The data segment is the
    # same struct virtio_blk_discard_write_zeroes; setting the UNMAP
    # flag additionally lets the device deallocate the range while still
    # guaranteeing subsequent reads return zero. Returns 0 on OK.
    if priv >= VBLK_MAX:
        return -1
    if count == 0:
        return 0
    if vblk_states[priv].has_wzeroes == 0:
        printk0("virtio-blk: write-zeroes requested but feature not negotiated\n")
        return -1
    mx: uint32 = vblk_states[priv].max_wz_sec
    if mx != 0 and count > cast[uint64](mx):
        printk2("virtio-blk: write-zeroes count=%d exceeds max=%d\n",
                count, cast[uint64](mx))
        return -1
    vblk_reqs[priv].outhdr_type   = VIRTIO_BLK_T_WRITE_ZEROES
    vblk_reqs[priv].outhdr_ioprio = 0
    vblk_reqs[priv].outhdr_sector = 0
    vblk_reqs[priv].dwz_sector      = lba
    vblk_reqs[priv].dwz_num_sectors = cast[uint32](count)
    flags: uint32 = 0
    if unmap != 0:
        flags = VIRTIO_BLK_WRITE_ZEROES_FLAG_UNMAP
    vblk_reqs[priv].dwz_flags = flags
    return _vblk_submit3(priv, 16,
                         cast[uint64](&vblk_reqs[priv].dwz_sector),
                         16, 0)


def virtio_blk_write_zeroes_range(priv: uint64, lba: uint64,
                                  count: uint64, unmap: int32) -> int32:
    # Zero an arbitrary [lba, lba+count) range, splitting it into
    # device-legal segments of at most max_write_zeroes_sectors each.
    # QEMU often advertises a small per-segment cap (e.g. 1), so a single
    # virtio_blk_write_zeroes() can't cover a multi-sector range — this
    # loop is what callers (and the block layer) want. Returns 0 if every
    # chunk completed OK, -1 on the first error.
    if priv >= VBLK_MAX:
        return -1
    if count == 0:
        return 0
    if vblk_states[priv].has_wzeroes == 0:
        return -1
    chunk: uint64 = cast[uint64](vblk_states[priv].max_wz_sec)
    if chunk == 0:
        chunk = count                  # 0 == "unbounded" per spec
    cur: uint64 = lba
    left: uint64 = count
    while left > 0:
        n: uint64 = left
        if n > chunk:
            n = chunk
        rc: int32 = virtio_blk_write_zeroes(priv, cur, n, unmap)
        if rc != 0:
            return rc
        cur = cur + n
        left = left - n
    return 0


def virtio_blk_discard_range(priv: uint64, lba: uint64,
                             count: uint64) -> int32:
    # Discard an arbitrary [lba, lba+count) range, splitting it into
    # device-legal segments of at most max_discard_sectors each. Returns
    # 0 if every chunk completed OK, -1 on the first error.
    if priv >= VBLK_MAX:
        return -1
    if count == 0:
        return 0
    if vblk_states[priv].has_discard == 0:
        return -1
    chunk: uint64 = cast[uint64](vblk_states[priv].max_discard_sec)
    if chunk == 0:
        chunk = count
    cur: uint64 = lba
    left: uint64 = count
    while left > 0:
        n: uint64 = left
        if n > chunk:
            n = chunk
        rc: int32 = virtio_blk_discard(priv, cur, n)
        if rc != 0:
            return rc
        cur = cur + n
        left = left - n
    return 0


def _vblk_name(idx: uint64) -> Ptr[char]:
    # Map a 0..VBLK_MAX-1 disk index to its conventional Linux-style
    # virtio name. Beyond VBLK_MAX returns "vd?" — never reached on a
    # well-formed call (init loops bounded by VBLK_MAX) but defensive.
    if idx == 0:
        return "vda"
    if idx == 1:
        return "vdb"
    if idx == 2:
        return "vdc"
    if idx == 3:
        return "vdd"
    return "vd?"


def _virtio_blk_init_one(bdf: uint32, idx: uint64,
                         name: Ptr[char]) -> int32:
    # Probe + init a single virtio-blk PCI device and register it as
    # `name` (vda, vdb, ...). idx is the index into vblk_states /
    # vblk_reqs / vblk_bufs and is also passed back as the block
    # layer's `priv` cookie. Returns 0 on success, -1 on failure.
    pci_enable_io_and_master(bdf)
    bar0_raw: uint32 = pci_read_bar(bdf, 0)
    # Legacy virtio uses an IO-space BAR (low bit set); mask to
    # get the port base.
    if (bar0_raw & 1) == 0:
        printk0("virtio-blk: BAR0 is not IO-space (modern virtio?)\n")
        return -1
    iobase: uint32 = bar0_raw & 0xFFFFFFFC
    vblk_states[idx].iobase = iobase
    printk2("virtio-blk: bdf=%x iobase=%p\n",
            cast[uint64](bdf), cast[uint64](iobase))

    # Standard init dance: reset, ACK, DRIVER, features, queues,
    # DRIVER_OK. We now negotiate the real feature set: FLUSH, DISCARD,
    # WRITE_ZEROES, MQ, plus the config-shaping features (BLK_SIZE,
    # SEG_MAX, SIZE_MAX). Accepting a feature is a contract that we
    # honour its config layout + commands, so we only OR in the bits
    # the host actually offers.
    virtio_reset(iobase)
    virtio_acknowledge(iobase)
    host_features: uint32 = virtio_read_host_features(iobase)
    printk1("virtio-blk: host features=%x\n", cast[uint64](host_features))

    guest_features: uint32 = 0
    if _vblk_feature(host_features, VIRTIO_BLK_F_FLUSH) != 0:
        guest_features = guest_features | (cast[uint32](1) << VIRTIO_BLK_F_FLUSH)
    if _vblk_feature(host_features, VIRTIO_BLK_F_DISCARD) != 0:
        guest_features = guest_features | (cast[uint32](1) << VIRTIO_BLK_F_DISCARD)
    if _vblk_feature(host_features, VIRTIO_BLK_F_WRITE_ZEROES) != 0:
        guest_features = guest_features | (cast[uint32](1) << VIRTIO_BLK_F_WRITE_ZEROES)
    if _vblk_feature(host_features, VIRTIO_BLK_F_BLK_SIZE) != 0:
        guest_features = guest_features | (cast[uint32](1) << VIRTIO_BLK_F_BLK_SIZE)
    if _vblk_feature(host_features, VIRTIO_BLK_F_SEG_MAX) != 0:
        guest_features = guest_features | (cast[uint32](1) << VIRTIO_BLK_F_SEG_MAX)
    if _vblk_feature(host_features, VIRTIO_BLK_F_SIZE_MAX) != 0:
        guest_features = guest_features | (cast[uint32](1) << VIRTIO_BLK_F_SIZE_MAX)
    if _vblk_feature(host_features, VIRTIO_BLK_F_MQ) != 0:
        guest_features = guest_features | (cast[uint32](1) << VIRTIO_BLK_F_MQ)
    virtio_write_guest_features(iobase, guest_features)
    vblk_states[idx].features = guest_features
    printk1("virtio-blk: negotiated features=%x\n",
            cast[uint64](guest_features))

    if virtq_setup(iobase, 0, &vblk_states[idx].vq) < 0:
        return -1

    # Read capacity from the device-specific config window.
    cap: uint64 = virtio_dev_config_read_u64(iobase,
                                             VIRTIO_BLK_CFG_CAPACITY)
    vblk_states[idx].capacity = cap
    printk2("virtio-blk: %s capacity=%d sectors\n",
            cast[uint64](name), cap)

    # --- config-space limits (only valid when the feature is set) ----
    # Defaults assume the simplest device: 512-byte blocks, a single
    # data descriptor, no advertised size cap, one queue.
    vblk_states[idx].blk_size   = cast[uint32](SECTOR_SIZE)
    vblk_states[idx].seg_max    = 1
    vblk_states[idx].size_max   = 0
    vblk_states[idx].num_queues = 1
    if _vblk_feature(guest_features, VIRTIO_BLK_F_BLK_SIZE) != 0:
        bs: uint32 = virtio_dev_config_read_u32(iobase,
                                                VIRTIO_BLK_CFG_BLK_SIZE)
        if bs != 0:
            vblk_states[idx].blk_size = bs
    if _vblk_feature(guest_features, VIRTIO_BLK_F_SEG_MAX) != 0:
        sm: uint32 = virtio_dev_config_read_u32(iobase,
                                                VIRTIO_BLK_CFG_SEG_MAX)
        if sm != 0:
            vblk_states[idx].seg_max = sm
    if _vblk_feature(guest_features, VIRTIO_BLK_F_SIZE_MAX) != 0:
        vblk_states[idx].size_max = virtio_dev_config_read_u32(
            iobase, VIRTIO_BLK_CFG_SIZE_MAX)
    printk2("virtio-blk: blk_size=%d seg_max=%d\n",
            cast[uint64](vblk_states[idx].blk_size),
            cast[uint64](vblk_states[idx].seg_max))

    # --- DISCARD / WRITE_ZEROES limits -------------------------------
    vblk_states[idx].has_flush      = 0
    vblk_states[idx].has_discard    = 0
    vblk_states[idx].has_wzeroes    = 0
    vblk_states[idx].max_discard_sec = 0
    vblk_states[idx].max_discard_seg = 0
    vblk_states[idx].discard_align   = 0
    vblk_states[idx].max_wz_sec      = 0
    vblk_states[idx].max_wz_seg      = 0
    if _vblk_feature(guest_features, VIRTIO_BLK_F_FLUSH) != 0:
        vblk_states[idx].has_flush = 1
    if _vblk_feature(guest_features, VIRTIO_BLK_F_DISCARD) != 0:
        vblk_states[idx].has_discard    = 1
        vblk_states[idx].max_discard_sec = virtio_dev_config_read_u32(
            iobase, VIRTIO_BLK_CFG_MAX_DISCARD_SEC)
        vblk_states[idx].max_discard_seg = virtio_dev_config_read_u32(
            iobase, VIRTIO_BLK_CFG_MAX_DISCARD_SEG)
        vblk_states[idx].discard_align = virtio_dev_config_read_u32(
            iobase, VIRTIO_BLK_CFG_DISCARD_ALIGN)
        printk2("virtio-blk: discard max_sec=%d max_seg=%d\n",
                cast[uint64](vblk_states[idx].max_discard_sec),
                cast[uint64](vblk_states[idx].max_discard_seg))
    if _vblk_feature(guest_features, VIRTIO_BLK_F_WRITE_ZEROES) != 0:
        vblk_states[idx].has_wzeroes = 1
        vblk_states[idx].max_wz_sec = virtio_dev_config_read_u32(
            iobase, VIRTIO_BLK_CFG_MAX_WZ_SEC)
        vblk_states[idx].max_wz_seg = virtio_dev_config_read_u32(
            iobase, VIRTIO_BLK_CFG_MAX_WZ_SEG)
        printk2("virtio-blk: write-zeroes max_sec=%d max_seg=%d\n",
                cast[uint64](vblk_states[idx].max_wz_sec),
                cast[uint64](vblk_states[idx].max_wz_seg))

    # --- multi-queue (F_MQ) ------------------------------------------
    # Read num_queues so negotiation + queue setup are real. We drive a
    # single active datapath (queue 0) — that is spec-legal: a driver
    # may use a subset of the offered request queues. Setting up queue 0
    # already happened above via virtq_setup; we record the device's
    # advertised count for introspection and future fan-out.
    if _vblk_feature(guest_features, VIRTIO_BLK_F_MQ) != 0:
        nq: uint32 = virtio_dev_config_read_u16(iobase,
                                                VIRTIO_BLK_CFG_NUM_QUEUES)
        if nq == 0:
            nq = 1
        vblk_states[idx].num_queues = nq
        printk2("virtio-blk: %s num_queues=%d (datapath uses q0)\n",
                cast[uint64](name), cast[uint64](nq))

    virtio_driver_ok(iobase)

    rc: int32 = register_blockdev(name, cap, &vblk_ops, idx)
    if rc < 0:
        return -1

    # --- INTx IRQ wiring (kernel roadmap §9) -----------------------
    # Finish the legacy INTx path so block completions are
    # interrupt-driven rather than purely poll-driven. virtio-blk's
    # legacy transport raises a pin-based PCI INTx whenever a
    # virtqueue advances; we route the firmware-assigned IOAPIC pin
    # to CPU vector 0x43 on the BSP LAPIC and register a handler.
    #
    # The synchronous block-layer API still drives completion through
    # virtq_kick_and_wait()'s used-ring poll — that stays as the
    # safety-net for the early-boot FAT mount, which runs before
    # interrupts are enabled. Once `sti` is live the handler below
    # acknowledges the device-level ISR (read-to-clear) so the INTx
    # line deasserts; the same handler is what an async bio path
    # would hang completion off in future. Mirrors how AHCI / NVMe
    # keep their polled drains alongside the wired IRQ.
    vbus: uint32 = pci_bdf_bus(bdf)
    vdev: uint32 = pci_bdf_dev(bdf)
    vfn:  uint32 = pci_bdf_fn(bdf)
    intx_pin:  uint32 = pci_config_read_byte(vbus, vdev, vfn,
                                             VBLK_PCI_INTERRUPT_PIN)
    intx_line: uint32 = pci_config_read_byte(vbus, vdev, vfn,
                                             VBLK_PCI_INTERRUPT_LINE)
    printk2("virtio-blk: PCI INTx pin=%d line=%d\n",
            cast[uint64](intx_pin), cast[uint64](intx_line))
    ioapic_pin: uint32 = intx_line
    if intx_pin == 0 or intx_line == 0 or intx_line >= 24:
        # Pin 0 = "no interrupt"; an out-of-range line means firmware
        # never programmed it. QEMU's virtio-blk on i440FX lands on
        # IOAPIC pin 11 by default — fall back to that.
        ioapic_pin = 11
        printk1("virtio-blk: PCI INTx line unreliable; using IOAPIC pin %d\n",
                cast[uint64](ioapic_pin))
    vblk_states[idx].irq_pin   = ioapic_pin
    vblk_states[idx].irq_count = 0
    return 0


def virtio_blk_init() -> int32:
    # Enumerate every virtio-blk PCI device on bus 0 and register
    # them in order as vda, vdb, vdc, ... up to VBLK_MAX. Returns 0
    # if at least one disk was registered, -1 otherwise. Caller
    # (init/main.ad) treats -1 as "no virtio-blk attached" — falls
    # back to brd's /dev/ram0.
    vblk_ops.read_sectors  = virtio_blk_read_sectors
    vblk_ops.write_sectors = virtio_blk_write_sectors
    # Wire the device-cache barrier so blk_flush() (the bottom half of
    # fsync(2)) reaches VIRTIO_BLK_T_FLUSH when the device offers
    # F_FLUSH. virtio_blk_flush() no-ops to success when the feature was
    # not negotiated, exactly as blk_flush's null-op contract expects.
    vblk_ops.flush         = virtio_blk_flush

    # Single shared IRQ handler — every virtio-blk disk we registered
    # raises the same vector and we scan all initialised slots for
    # device-level ISR bits. Wired once, before the per-device probes.
    register_irq_handler(cast[uint64](VBLK_IRQ_VECTOR),
                         cast[uint64](&virtio_blk_irq_handler))

    # Per-disk names. VBLK_MAX (4) entries; lookup is just an index.
    vblk_count = 0
    start: uint32 = 0
    while vblk_count < VBLK_MAX:
        bdf: uint32 = pci_find_from(VIRTIO_VENDOR,
                                    VIRTIO_BLK_LEGACY, start)
        if bdf == PCI_BDF_NONE:
            break
        nm: Ptr[char] = _vblk_name(vblk_count)
        if _virtio_blk_init_one(bdf, vblk_count, nm) == 0:
            # Route this disk's INTx pin to the shared vector. The
            # IOAPIC pin we computed is whatever firmware assigned;
            # multiple disks can share the same pin (PCI INTx is a
            # bus-shared line), and the IRQ handler iterates all
            # initialised disks to deassert each ISR.
            ioapic_redirect(vblk_states[vblk_count].irq_pin,
                            VBLK_IRQ_VECTOR, VBLK_LAPIC_ID)
            printk2("virtio-blk: %s irq pin=%d\n",
                    cast[uint64](nm),
                    cast[uint64](vblk_states[vblk_count].irq_pin))
            vblk_count = vblk_count + 1
        # Continue scanning past this device's slot.
        start = pci_bdf_dev(bdf) + 1
    if vblk_count == 0:
        printk0("virtio-blk: no PCI device found\n")
        return -1
    printk1("virtio-blk: %d disk(s) registered\n", vblk_count)
    return 0


def virtio_blk_irq_handler():
    # INTx handler. Runs with interrupts disabled (CPU did cli on
    # gate entry); do_irq() sends the LAPIC EOI after we return. The
    # virtio device-level ISR at BAR0 + 0x13 is read-to-clear: a
    # single inb() here both tells us why the IRQ fired (bit 0 =
    # queue advanced) AND deasserts the INTx line so the IOAPIC
    # level-triggered entry's Remote-IRR clears on the EOI. Reading
    # it is therefore mandatory even though the synchronous
    # virtq_kick_and_wait() poll is what actually retires the request
    # — skipping the ISR read would wedge the INTx line asserted.
    #
    # With multiple disks on a shared INTx vector we MUST poll every
    # registered device's ISR, because we cannot tell which one
    # asserted the line. Reading a non-asserting device's ISR is a
    # no-op (returns 0), so the scan is safe.
    i: uint64 = 0
    while i < vblk_count:
        if vblk_states[i].iobase != 0:
            isr: int32 = inb(cast[int32](vblk_states[i].iobase
                                         + cast[uint32](VIRTIO_PCI_ISR)))
            # isr bit 0 set => at least one virtqueue advanced (a
            # block request completed). The synchronous block API
            # retires the request via the kick_and_wait poll; nothing
            # more to do here.
            vblk_states[i].irq_count = vblk_states[i].irq_count + 1
        i = i + 1


def virtio_blk_irq_count() -> uint64:
    # Sum IRQs serviced across every registered disk. Test rigs that
    # asserted on the singleton irq_count keep seeing a monotonic
    # counter, just summed across vda + vdb + ...
    total: uint64 = 0
    i: uint64 = 0
    while i < vblk_count:
        total = total + vblk_states[i].irq_count
        i = i + 1
    return total


def virtio_blk_irq_pin() -> uint32:
    # Return the first registered disk's IRQ pin. Multi-disk setups
    # share the line, so any one of them is the same answer.
    if vblk_count == 0:
        return 0
    return vblk_states[0].irq_pin


# --- introspection accessors --------------------------------------
# Read-only views of negotiated state, keyed by the disk INDEX (the
# same value used as the block layer's `priv` cookie). Used by the
# self-test and any /proc-style exporter.

def virtio_blk_has_flush(idx: uint64) -> int32:
    if idx >= vblk_count:
        return 0
    return cast[int32](vblk_states[idx].has_flush)


def virtio_blk_has_discard(idx: uint64) -> int32:
    if idx >= vblk_count:
        return 0
    return cast[int32](vblk_states[idx].has_discard)


def virtio_blk_has_write_zeroes(idx: uint64) -> int32:
    if idx >= vblk_count:
        return 0
    return cast[int32](vblk_states[idx].has_wzeroes)


def virtio_blk_num_queues(idx: uint64) -> uint32:
    if idx >= vblk_count:
        return 0
    return vblk_states[idx].num_queues


# --- FLUSH / DISCARD / WRITE_ZEROES end-to-end self-test ------------
#
# Gated boot self-test (init/main.ad boot:37.vblkdwz, planted
# /etc/virtio-blk-dwz-test by build_initramfs.py when
# ENABLE_VBLK_DWZ_TEST=1, via scripts/test_virtio_blk_dwz.sh). Drives
# REAL virtio-blk requests against QEMU's emulated device:
#
#   1. Resolve the vda disk index (0 == first registered virtio-blk).
#   2. Seed a 4-sector region with a recognisable non-zero pattern via
#      the synchronous write path, then issue a real FLUSH and confirm
#      the readback still carries the pattern (write durability).
#   3. WRITE_ZEROES the same region (real type-13 request), read it back
#      and assert every byte is now zero.
#   4. Re-seed, then DISCARD the region (real type-11 request) and
#      assert the command succeeded (status OK). Reads of a discarded
#      range are device-defined, so we only assert command success here.
#
# Every line stamps EMERG so it reaches serial at the prompt.

_VBLK_DWZ_BASE:    uint64 = 96            # scratch LBA base (clear of FS)
_VBLK_DWZ_NSEC:    uint64 = 4
_vblk_dwz_seed:    Array[2048, uint8]     # 4 sectors of pattern
_vblk_dwz_back:    Array[2048, uint8]     # readback buffer


def _vblk_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _vblk_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def virtio_blk_dwz_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [virtio-blk] marker lines
    # plus per-op PASS banners the test script greps for.
    _vblk_emerg0("[virtio-blk] dwz self-test start\n")

    slot: int32 = find_blockdev("vda")
    if slot < 0:
        _vblk_emerg0("[virtio-blk] FAIL: vda not registered\n")
        return 0
    # The block layer's priv cookie for a virtio-blk slot IS the disk
    # index; vda is always index 0.
    idx: uint64 = 0
    if blk_capacity_sectors(slot) < _VBLK_DWZ_BASE + _VBLK_DWZ_NSEC + 1:
        _vblk_emerg0("[virtio-blk] FAIL: device too small for test\n")
        return 0

    _vblk_emerg1("[virtio-blk] flush=%d ",
                 cast[uint64](cast[int64](virtio_blk_has_flush(idx))))
    _vblk_emerg1("discard=%d ",
                 cast[uint64](cast[int64](virtio_blk_has_discard(idx))))
    _vblk_emerg1("write-zeroes=%d ",
                 cast[uint64](cast[int64](virtio_blk_has_write_zeroes(idx))))
    _vblk_emerg1("num_queues=%d\n",
                 cast[uint64](virtio_blk_num_queues(idx)))

    ok: int32 = 1

    # 1. Seed a recognisable non-zero pattern + FLUSH.
    si: uint64 = 0
    while si < 2048:
        _vblk_dwz_seed[si] = cast[uint8]((si * 7 + 0x41) & 0xFF)
        si = si + 1
    wrc: int32 = blk_write_sectors(slot, _VBLK_DWZ_BASE, _VBLK_DWZ_NSEC,
                                   &_vblk_dwz_seed[0])
    if wrc != 0:
        _vblk_emerg0("[virtio-blk] FAIL: seed write failed\n")
        return 0
    frc: int32 = blk_flush(slot)
    if frc != 0:
        _vblk_emerg0("[virtio-blk] FAIL: flush returned error\n")
        ok = 0
    else:
        # Confirm the flushed data is still readable & correct.
        rrc: int32 = blk_read_sectors(slot, _VBLK_DWZ_BASE, _VBLK_DWZ_NSEC,
                                      &_vblk_dwz_back[0])
        if rrc != 0:
            _vblk_emerg0("[virtio-blk] FAIL: post-flush read failed\n")
            ok = 0
        else:
            mism: uint64 = 0
            ci: uint64 = 0
            while ci < 2048:
                if _vblk_dwz_back[ci] != _vblk_dwz_seed[ci]:
                    mism = mism + 1
                ci = ci + 1
            if mism != 0:
                _vblk_emerg1("[virtio-blk] FAIL: post-flush mismatch=%d\n",
                             mism)
                ok = 0
            else:
                _vblk_emerg0("[virtio-blk] PASS flush\n")

    # 2. WRITE_ZEROES the region, read back, assert all zero.
    if virtio_blk_has_write_zeroes(idx) != 0:
        # unmap=0: a plain zero-fill. UNMAP (deallocate) is best-effort
        # and QEMU rejects it (IOERR) on a raw image that cannot punch
        # holes, so the portable self-test asks only for the guaranteed
        # zero semantics. The UNMAP path is still wired + reachable via
        # virtio_blk_write_zeroes(idx, lba, count, 1). The _range helper
        # splits the 4-sector region into device-legal segments (QEMU
        # advertises max_write_zeroes_sectors=1 here).
        zrc: int32 = virtio_blk_write_zeroes_range(idx, _VBLK_DWZ_BASE,
                                                   _VBLK_DWZ_NSEC, 0)
        if zrc != 0:
            _vblk_emerg0("[virtio-blk] FAIL: write-zeroes request failed\n")
            ok = 0
        else:
            rrc2: int32 = blk_read_sectors(slot, _VBLK_DWZ_BASE,
                                           _VBLK_DWZ_NSEC,
                                           &_vblk_dwz_back[0])
            if rrc2 != 0:
                _vblk_emerg0("[virtio-blk] FAIL: post-zero read failed\n")
                ok = 0
            else:
                nonzero: uint64 = 0
                zi: uint64 = 0
                while zi < 2048:
                    if _vblk_dwz_back[zi] != 0:
                        nonzero = nonzero + 1
                    zi = zi + 1
                if nonzero != 0:
                    _vblk_emerg1(
                        "[virtio-blk] FAIL: %d bytes non-zero after write-zeroes\n",
                        nonzero)
                    ok = 0
                else:
                    _vblk_emerg0("[virtio-blk] PASS write-zeroes\n")
    else:
        _vblk_emerg0("[virtio-blk] SKIP write-zeroes (feature not offered)\n")

    # 3. DISCARD the region (re-seed first so the device has live data
    #    to drop). A read of a discarded range is device-defined, so we
    #    only assert the command itself completed OK.
    if virtio_blk_has_discard(idx) != 0:
        wrc2: int32 = blk_write_sectors(slot, _VBLK_DWZ_BASE, _VBLK_DWZ_NSEC,
                                        &_vblk_dwz_seed[0])
        if wrc2 != 0:
            _vblk_emerg0("[virtio-blk] FAIL: re-seed before discard failed\n")
            ok = 0
        else:
            drc: int32 = virtio_blk_discard_range(idx, _VBLK_DWZ_BASE,
                                                  _VBLK_DWZ_NSEC)
            if drc != 0:
                _vblk_emerg0("[virtio-blk] FAIL: discard request failed\n")
                ok = 0
            else:
                _vblk_emerg0("[virtio-blk] PASS discard\n")
    else:
        _vblk_emerg0("[virtio-blk] SKIP discard (feature not offered)\n")

    if ok == 1:
        _vblk_emerg0("[virtio-blk] dwz PASS\n")
        return 1
    _vblk_emerg0("[virtio-blk] dwz FAIL\n")
    return 0

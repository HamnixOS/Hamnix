# drivers/block/brd.ad
#
# RAM block device — mirror of Linux's drivers/block/brd.c at the
# smallest meaningful scale. Linux's brd uses an XArray of pages
# with copy-on-read locking and per-device request queues; ours is
# a single contiguous backing region (a baked-in disk image
# emitted by scripts/build_diskimg.py) mapped at boot.
#
# Linux mapping:
#   brd_init()         -> brd_init()       (module_init equivalent)
#   brd_alloc()        -> _brd_register()  (creates the gendisk)
#   brd_do_bvec()      -> brd_read_sectors (single bio_vec walk)
#   brd_devices[]      -> ramdisks[]       (per-device state)
#
# We currently expose a single /dev/ram0 (slot 0). Linux defaults
# to 16; that's an arbitrary CONFIG knob we don't need yet.

from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, SECTOR_SIZE,
)
from kernel.printk.printk import printk0, printk1, printk2

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]

# Symbols provided by fs/diskimg_blob.S (autogenerated from the on-
# disk image by scripts/build_diskimg.py — same shape as
# fs/initramfs_blob.S provides for the cpio archive).
extern def diskimg_base() -> uint64
extern def diskimg_size() -> uint64

# Symbols provided by fs/sqfsimg_blob.S — the baked-in squashfs test
# image exposed as a SECOND ramdisk (/dev/ram1). Lets fs/squashfs.ad's
# kernel-side smoke test mount + read a real squashfs off a block
# device without disturbing the FAT image on ram0.
extern def sqfsimg_base() -> uint64
extern def sqfsimg_size() -> uint64


# Per-device state. priv passed to read_sectors is &ramdisks[slot]
# so the dispatch path doesn't need to grep a side table; we follow
# the same pointer-as-cookie convention Linux uses for
# struct gendisk.private_data.
class BrdDevice:
    base:    uint64                # backing-buffer start address
    nbytes:  uint64                # size in bytes (multiple of SECTOR_SIZE)


BRD_MAX: uint64 = 4
ramdisks:  Array[4, BrdDevice]
ramdisk_ops: BlockDeviceOps
# Next free dynamic slot (slots 0/1 are the baked-in blobs; 2+ are
# runtime registrations via brd_register_dynamic).
brd_next_dyn: uint64 = 2


def brd_register_dynamic(name: Ptr[char], base: uint64,
                         nbytes: uint64) -> int32:
    """Register a RUNTIME RAM block device over caller-owned memory.

    Used by the live-medium bringup (#410 Item 2): loop_sqfs_live_root
    memblock_allocs a buffer, streams the live-distro ext4 image into
    it out of the in-RAM squashfs, then registers it here so the
    named-root machinery (ext4_init + .hamnix-roots) can mount it like
    any other disk. Returns the blk slot (>=0) or -1.

    The caller owns `base` for the lifetime of the kernel — there is
    no brd unregister (mirrors the baked-in blob devices).
    """
    if brd_next_dyn >= BRD_MAX:
        printk0("brd: no free dynamic ramdisk slots\n")
        return -1
    if nbytes < SECTOR_SIZE:
        printk1("brd: dynamic backing too small (%d bytes)\n", nbytes)
        return -1
    sectors: uint64 = nbytes / SECTOR_SIZE
    idx: uint64 = brd_next_dyn
    ramdisks[idx].base   = base
    ramdisks[idx].nbytes = sectors * SECTOR_SIZE
    # ramdisk_ops is already wired by brd_init() (runs before any
    # runtime registration path can be reached).
    rc: int32 = register_blockdev(
        name, sectors, &ramdisk_ops, cast[uint64](&ramdisks[idx]),
    )
    if rc < 0:
        printk0("brd: dynamic registration failed\n")
        return -1
    brd_next_dyn = idx + 1
    printk2("brd: dynamic ramdisk ready (base=%p, sectors=%d)\n",
            base, sectors)
    return rc


def brd_read_sectors(priv: uint64, lba: uint64, count: uint64,
                     buf: Ptr[uint8]) -> int32:
    # `priv` is &ramdisks[slot] (uint64). Bounds-checking already
    # happened in blk_read_sectors against the registered capacity;
    # here we just memcpy the right window of the backing buffer.
    dev: Ptr[BrdDevice] = cast[Ptr[BrdDevice]](priv)
    src: uint64 = dev[0].base + lba * SECTOR_SIZE
    n:   uint64 = count * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), n)
    return 0


def brd_write_sectors(priv: uint64, lba: uint64, count: uint64,
                      buf: Ptr[uint8]) -> int32:
    # Symmetric to brd_read_sectors — memcpy into the backing region.
    # The backing buffer lives in .rodata (it's the baked-in disk
    # image emitted by build_diskimg.py), so writes only "stick" as
    # long as the kernel image isn't reloaded — exactly what we want
    # for an in-memory test filesystem. The .rodata mapping is RW
    # for the kernel; the linker doesn't enforce read-only on x86_64
    # bare-metal builds at the page-table level yet.
    dev: Ptr[BrdDevice] = cast[Ptr[BrdDevice]](priv)
    dst: uint64 = dev[0].base + lba * SECTOR_SIZE
    n:   uint64 = count * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, n)
    return 0


def brd_init():
    # Wire the shared vtable FIRST — brd_register_dynamic (runtime
    # registrations, e.g. the live-medium distro ramdisk) reuses it and
    # must work even when both baked-in blobs below are empty.
    ramdisk_ops.read_sectors  = brd_read_sectors
    ramdisk_ops.write_sectors = brd_write_sectors
    base: uint64 = diskimg_base()
    size: uint64 = diskimg_size()
    if size < SECTOR_SIZE:
        printk1("brd: backing image too small (%d bytes); not registering\n",
                size)
        return
    # Round down to whole sectors — a stray trailing byte shouldn't
    # cause a half-sector device.
    sectors: uint64 = size / SECTOR_SIZE
    ramdisks[0].base   = base
    ramdisks[0].nbytes = sectors * SECTOR_SIZE
    rc: int32 = register_blockdev(
        "ram0", sectors, &ramdisk_ops, cast[uint64](&ramdisks[0]),
    )
    if rc < 0:
        printk0("brd: registration failed\n")
        return
    printk2("brd: /dev/ram0 ready (base=%p, sectors=%d)\n", base, sectors)

    # Second ramdisk: the baked-in squashfs image (fs/sqfsimg_blob.S).
    # Registered as /dev/ram1 so fs/squashfs.ad can mount a real
    # squashfs off a block device. Skipped silently when the blob is
    # empty (mksquashfs unavailable at build time).
    sq_base: uint64 = sqfsimg_base()
    sq_size: uint64 = sqfsimg_size()
    if sq_size < SECTOR_SIZE:
        return
    sq_sectors: uint64 = sq_size / SECTOR_SIZE
    ramdisks[1].base   = sq_base
    ramdisks[1].nbytes = sq_sectors * SECTOR_SIZE
    rc1: int32 = register_blockdev(
        "ram1", sq_sectors, &ramdisk_ops, cast[uint64](&ramdisks[1]),
    )
    if rc1 < 0:
        printk0("brd: ram1 (squashfs) registration failed\n")
        return
    printk2("brd: /dev/ram1 ready (base=%p, sectors=%d) [squashfs]\n",
            sq_base, sq_sectors)

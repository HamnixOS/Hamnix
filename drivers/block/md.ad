# drivers/block/md.ad
#
# Native software RAID — Hamnix's equivalent of Linux's drivers/md/md.c
# plus the raid0 (drivers/md/raid0.c) and raid1 (drivers/md/raid1.c)
# personalities. A genuine Linux-parity gap: there was NO software RAID
# in the tree before this. The native device-mapper (drivers/block/dm.ad)
# is the structural template — an md "array" is, exactly like a mapped
# device, a VIRTUAL block device that registers with the block layer
# (kernel/block/blk.ad) and translates every I/O it receives into I/O on
# one or more underlying real block devices.
#
# Linux mapping:
#
#   struct mddev                 -> MdArray (this file)
#   struct md_rdev (member disk) -> MdMember[] inside MdArray
#   raid0 personality            -> MD_LEVEL_RAID0 (striping)
#   raid1 personality            -> MD_LEVEL_RAID1 (mirroring)
#   mdadm --create               -> md_create_raid0 / md_create_raid1
#   md_make_request (bio remap)  -> _md_read_blkop / _md_write_blkop
#   mddev->degraded / Faulty bit -> MdMember.failed + md_fail_member
#
# LEVELS:
#
#   RAID0 (striping) — the array's address space is carved into fixed-size
#   CHUNKS (chunk_sectors). Consecutive chunks of the virtual device are
#   placed round-robin across the N members: virtual chunk c lives on
#   member (c % N) at that member's chunk index (c / N). Capacity is the
#   sum of the per-member usable spans (here: N * per_member_chunks *
#   chunk_sectors). A single request that straddles a chunk boundary is
#   SPLIT at the boundary and each fragment routed to its member — the
#   core _md_raid0_io loop below handles arbitrary-length requests.
#
#   RAID1 (mirroring) — every member holds a full copy of the array. A
#   WRITE is fanned out to ALL non-failed members; a READ is served from a
#   single chosen member (round-robin across the live members for read
#   balancing, exactly like raid1's read_balance). Capacity is the
#   SMALLEST member's span (you can only mirror as much as the smallest
#   disk holds). DEGRADED MODE: a member can be marked Faulty
#   (md_fail_member); reads then skip it and writes silently drop it, so
#   the array keeps serving from the survivor(s) with no error — the whole
#   point of a mirror.

from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, blk_unregister_by_name,
    blk_read_sectors, blk_write_sectors, find_blockdev,
    blk_capacity_sectors, SECTOR_SIZE,
)
from kernel.printk.printk import (
    printk0, printk1, printk2, printk_set_level,
)
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG

extern def memcpy(dst: Ptr[uint8], src: Ptr[uint8], n: uint64) -> Ptr[uint8]


# =========================================================================
# md core
# =========================================================================

MD_LEVEL_NONE:  uint32 = 0
MD_LEVEL_RAID0: uint32 = 1       # striping
MD_LEVEL_RAID1: uint32 = 2       # mirroring
MD_LEVEL_RAID5: uint32 = 5       # striping + distributed single parity
MD_LEVEL_RAID6: uint32 = 6       # striping + dual parity (P XOR, Q GF(2^8))
MD_LEVEL_RAID10: uint32 = 10     # striped mirrors (near=2 layout)

MD_MAX_MEMBERS: uint64 = 8       # member disks per array
MD_MAX_ARRAYS:  uint64 = 8       # md arrays system-wide
MD_NAME_LEN:    uint64 = 16

# Default RAID0 chunk: 64 KiB = 128 sectors, matching mdadm's default.
MD_DEFAULT_CHUNK_SECTORS: uint64 = 128


# Per-member bad-block list capacity. A fixed-capacity sorted array of
# {start, count} ranges, exactly like Linux md's struct badblocks: instead
# of failing a whole device on a single bad sector, md records the bad range
# and keeps the (still-good) rest of the device IN the array.
MD_MAX_BADBLOCKS: uint64 = 16


class MdBadBlock:
    # One bad-block range on a member: sectors [start, start+count) are known
    # bad (unreadable / unwritable) on this member's UNDERLYING device, in the
    # array's virtual sector address space (RAID1) or per-member LBA space
    # (RAID5 — the member-LBA within the stripe row). Ranges are kept SORTED
    # by start and never overlap (adjacent/overlapping inserts are merged).
    start: uint64
    count: uint64


class MdMember:
    # One member disk of an array. `under_slot` is the underlying block
    # device's slot; `under_start` is the base LBA on that device where
    # this array's data begins (so an array can live in a sub-region of a
    # larger disk, like Linux's data_offset). `usable` is the number of
    # sectors of that member this array may use. `failed` is the Faulty
    # bit: a failed member is skipped on read and dropped on write so the
    # array runs degraded off the survivors.
    #
    # `bb_n` is the number of live bad-block ranges in `bb` (a sorted,
    # merged, fixed-capacity list). A member with recorded bad blocks but
    # still-good remaining sectors stays IN the array (NOT Faulty): reads over
    # a bad range are served from redundancy (mirror/parity) and a successful
    # write to a bad range CLEARS it. This is the whole point of bad-block
    # lists vs. whole-device failure.
    under_slot:  int32
    failed:      uint32
    bb_n:        uint32
    bb_pad:      uint32
    under_start: uint64
    usable:      uint64
    bb:          Array[16, MdBadBlock]


class MdArray:
    # A virtual block device assembled from N member disks. Registered
    # with the block layer under `name` so filesystems mount and read/write
    # through it like any disk. `level` selects RAID0 vs RAID1.
    # `chunk_sectors` is the RAID0 stripe granularity (unused for RAID1).
    # `rr` is the RAID1 read round-robin cursor.
    used:          uint32
    level:         uint32
    n_members:     uint32
    rr:            uint32          # RAID1 read-balance cursor
    capacity:      uint64          # total virtual sectors
    chunk_sectors: uint64          # RAID0 stripe size (sectors)
    self_slot:     int32           # this array's own block slot
    pad:           uint32
    # Write-intent ("internal") bitmap. When `bitmap_on` is non-zero this
    # array tracks dirty regions: BEFORE a write to a region its dirty bit
    # is set; after the mirror is known in-sync the bit is cleared. A member
    # that drops and re-adds is then resynced over ONLY the dirty regions
    # (fast partial resync) instead of the whole device. `bitmap_buf` is a
    # bit array (one bit per region) supplied by the caller; the array does
    # not own the storage. `bitmap_region_sectors` is the region size and
    # `bitmap_nregions` the number of regions covering the whole capacity.
    bitmap_on:             uint32
    bitmap_pad:            uint32
    bitmap_region_sectors: uint64
    bitmap_nregions:       uint64
    bitmap_buf:            Ptr[uint8]
    # Partial Parity Log (PPL) — RAID5 write-hole journal. When `ppl_on` is
    # non-zero, every partial-stripe RAID5 write first APPENDS a journal
    # entry (stripe index + partial parity = XOR of the UNMODIFIED data
    # chunks of that stripe) to a dedicated journal block device BEFORE the
    # new data/parity touch the array. If the machine crashes between the
    # data write and the parity write, the on-array parity is stale; on
    # recovery (md_ppl_recover) the un-acknowledged journal entries are
    # replayed — for each, parity is recomputed as partial_parity XOR
    # current_on_disk_data and written to the parity member, making parity
    # consistent with the data again so a later degraded read reconstructs
    # the CORRECT value. Entries are RETIRED (the journal head reset) once a
    # full stripe write completes. `ppl_slot` is the journal block device;
    # `ppl_head` is the next free journal slot (entry count); `ppl_chunk`
    # is the per-entry partial-parity payload size in sectors (== chunk).
    ppl_on:        uint32
    ppl_pad:       uint32
    ppl_slot:      int32
    ppl_head:      uint32          # number of live (un-retired) entries
    ppl_chunk:     uint64          # payload sectors per entry (== chunk_sectors)
    members:       Array[8, MdMember]


md_arrays: Array[8, MdArray]
md_ops:    BlockDeviceOps
md_inited: uint32 = 0


def md_init():
    # Wire the shared vtable once; the array table starts all-free. No md
    # array exists until an md_create_* call (or a ctl write) assembles
    # one — matching Linux where md has no arrays until mdadm assembles
    # them.
    if md_inited != 0:
        return
    md_ops.read_sectors  = _md_read_blkop
    md_ops.write_sectors = _md_write_blkop
    md_ops.flush         = cast[Fn[int32, uint64]](0)
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        md_arrays[i].used      = 0
        md_arrays[i].level     = MD_LEVEL_NONE
        md_arrays[i].n_members = 0
        md_arrays[i].capacity  = 0
        md_arrays[i].self_slot = -1
        md_arrays[i].bitmap_on = 0
        md_arrays[i].ppl_on    = 0
        md_arrays[i].ppl_slot  = -1
        md_arrays[i].ppl_head  = 0
        i = i + 1
    md_inited = 1
    printk0("md: software RAID ready (raid0 stripe + raid1 mirror)\n")


def _md_alloc_array() -> int32:
    # Claim a free MdArray slot, or -1 if the table is full.
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used == 0:
            return cast[int32](i)
        i = i + 1
    return -1


def _md_register(idx: uint64, name: Ptr[char]) -> int32:
    # Register the (already-populated) array at table index `idx` with the
    # block layer. Returns 0 on success, -1 on failure.
    cap: uint64 = md_arrays[idx].capacity
    priv: uint64 = cast[uint64](&md_arrays[idx])
    slot: int32 = register_blockdev(name, cap, &md_ops, priv)
    if slot < 0:
        printk0("md: block-device registration failed\n")
        return -1
    md_arrays[idx].self_slot = slot
    md_arrays[idx].used      = 1
    return 0


# =========================================================================
# RAID0 — striping
# =========================================================================

def _md_raid0_io(dev: Ptr[MdArray], is_write: int32, vlba: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # Stripe remap. Walk the request sector-span, splitting it at chunk
    # boundaries so a request that straddles two chunks (and therefore two
    # different members) is routed correctly. For each sub-span:
    #
    #   chunk_index   = vlba / chunk_sectors    (which virtual chunk)
    #   offset_in_chk = vlba % chunk_sectors    (sector within that chunk)
    #   member        = chunk_index % N         (round-robin placement)
    #   member_chunk  = chunk_index / N         (that member's chunk #)
    #   member_lba    = member_chunk * chunk_sectors + offset_in_chk
    #                   + member.under_start
    #
    # The fragment length is clamped so it never crosses the chunk
    # boundary (the rest of the request continues on the next iteration,
    # landing on the next member).
    if count == 0:
        return 0
    n: uint64 = cast[uint64](dev[0].n_members)
    chunk: uint64 = dev[0].chunk_sectors
    done: uint64 = 0
    while done < count:
        cur_v: uint64 = vlba + done
        chunk_index:   uint64 = cur_v / chunk
        offset_in_chk: uint64 = cur_v % chunk
        member:        uint64 = chunk_index % n
        member_chunk:  uint64 = chunk_index / n
        # Sectors remaining in THIS chunk from offset_in_chk on.
        avail: uint64 = chunk - offset_in_chk
        frag: uint64 = count - done
        if frag > avail:
            frag = avail
        mlba: uint64 = member_chunk * chunk + offset_in_chk \
            + dev[0].members[member].under_start
        bufp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + done * SECTOR_SIZE)
        mslot: int32 = dev[0].members[member].under_slot
        rc: int32 = 0
        if is_write != 0:
            rc = blk_write_sectors(mslot, mlba, frag, bufp)
        else:
            rc = blk_read_sectors(mslot, mlba, frag, bufp)
        if rc != 0:
            return rc
        done = done + frag
    return 0


# =========================================================================
# RAID1 — mirroring (with degraded-mode path)
# =========================================================================

def _md_raid1_pick_read(dev: Ptr[MdArray]) -> int32:
    # Round-robin read balance across the NON-FAILED members. Returns a
    # member index (0..n-1) or -1 if every member is failed (total array
    # failure). Mirrors raid1's read_balance choosing a live mirror.
    n: uint64 = cast[uint64](dev[0].n_members)
    if n == 0:
        return -1
    start: uint64 = cast[uint64](dev[0].rr) % n
    i: uint64 = 0
    while i < n:
        cand: uint64 = (start + i) % n
        if dev[0].members[cand].failed == 0:
            # Advance the cursor past the chosen member for next time.
            dev[0].rr = cast[uint32]((cand + 1) % n)
            return cast[int32](cand)
        i = i + 1
    return -1


def _md_raid1_pick_read_good(dev: Ptr[MdArray], vlba: uint64,
                             count: uint64) -> int32:
    # Round-robin read balance across the NON-FAILED members, additionally
    # SKIPPING any member that has the requested range [vlba,vlba+count)
    # recorded as a bad block. Returns a member index, or -1 if no live
    # member can serve the whole range cleanly (caller must fall back). This
    # is exactly Linux's read_balance avoiding rdevs with badblocks over the
    # request.
    n: uint64 = cast[uint64](dev[0].n_members)
    if n == 0:
        return -1
    start: uint64 = cast[uint64](dev[0].rr) % n
    i: uint64 = 0
    while i < n:
        cand: uint64 = (start + i) % n
        if dev[0].members[cand].failed == 0:
            if md_badblocks_check(&dev[0].members[cand], vlba, count) == 0:
                dev[0].rr = cast[uint32]((cand + 1) % n)
                return cast[int32](cand)
        i = i + 1
    return -1


def _md_raid1_read_span(dev: Ptr[MdArray], vlba: uint64, count: uint64,
                        buf: Ptr[uint8]) -> int32:
    # Read [vlba,vlba+count) from the mirror, serving each sub-span from a
    # live member that does NOT have it recorded bad. The request is SPLIT at
    # bad-block boundaries: a sub-span all members agree is good is read from
    # the round-robin pick; a sub-span bad on the picked member is served from
    # ANOTHER member that holds a good copy. A bad range thus NEVER fails the
    # device — it is satisfied from the mirror, and the bad member stays IN
    # the array. Returns 0 / -1.
    if count == 0:
        return 0
    n: uint64 = cast[uint64](dev[0].n_members)
    done: uint64 = 0
    while done < count:
        cur: uint64 = vlba + done
        # Find the longest run starting at `cur` that some single live member
        # can serve cleanly. First try a member with NO bad block over the
        # remaining span; if none can do the whole rest, shrink to the next
        # bad-block boundary and retry.
        rest: uint64 = count - done
        served: int32 = 0
        # Try the round-robin pick for the whole remaining span first.
        pick: int32 = _md_raid1_pick_read_good(dev, cur, rest)
        if pick >= 0:
            pu: uint64 = cast[uint64](pick)
            bp: Ptr[uint8] = cast[Ptr[uint8]](
                cast[uint64](buf) + done * SECTOR_SIZE)
            rc: int32 = blk_read_sectors(dev[0].members[pu].under_slot,
                cur + dev[0].members[pu].under_start, rest, bp)
            if rc != 0:
                return rc
            done = done + rest
            served = 1
        if served == 0:
            # No single member can serve the whole rest cleanly. Serve ONE
            # sector at a time from whichever live member has it good — this
            # always terminates and correctly straddles bad-block boundaries.
            chosen: int32 = -1
            m: uint64 = 0
            while m < n:
                if dev[0].members[m].failed == 0 \
                        and md_badblocks_check(&dev[0].members[m], cur, 1) == 0:
                    chosen = cast[int32](m)
                    m = n
                else:
                    m = m + 1
            if chosen < 0:
                printk0("md: raid1 read range bad on every member\n")
                return -1
            cu: uint64 = cast[uint64](chosen)
            bp2: Ptr[uint8] = cast[Ptr[uint8]](
                cast[uint64](buf) + done * SECTOR_SIZE)
            rc2: int32 = blk_read_sectors(dev[0].members[cu].under_slot,
                cur + dev[0].members[cu].under_start, 1, bp2)
            if rc2 != 0:
                return rc2
            done = done + 1
    return 0


def _md_raid1_io(dev: Ptr[MdArray], is_write: int32, vlba: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # Mirror remap. A WRITE fans out to every NON-FAILED member at the
    # same LBA (offset by that member's under_start). A READ is served
    # from one chosen live member. RAID1 has no striping: virtual sector v
    # is sector (under_start + v) on each member. Degraded mode falls out
    # naturally — failed members are skipped on both paths, so the array
    # keeps serving from the survivor(s).
    if count == 0:
        return 0
    n: uint64 = cast[uint64](dev[0].n_members)
    if is_write != 0:
        # Write-intent bitmap: mark every region this write touches dirty
        # BEFORE the data reaches any member, so a member that is missing
        # (or fails mid-write) is later resynced over exactly these regions.
        md_bitmap_mark_write(dev, vlba, count)
        wrote_any: int32 = 0
        i: uint64 = 0
        while i < n:
            if dev[0].members[i].failed == 0:
                mlba: uint64 = vlba + dev[0].members[i].under_start
                mslot: int32 = dev[0].members[i].under_slot
                rc: int32 = blk_write_sectors(mslot, mlba, count, buf)
                if rc != 0:
                    # A live member that errors on write marks the array's
                    # I/O failed only if it leaves no good copy; treat a
                    # hard error as fatal for this request (Linux would
                    # mark the rdev Faulty and retry, but a synchronous
                    # error here means the device truly rejected the I/O).
                    return rc
                # Clear-on-successful-write: a write to a recorded bad range
                # that SUCCEEDED means the media is good again (relocated/
                # recovered), so drop the bad-block record for this range —
                # exactly Linux md's rdev_clear_badblocks on a successful
                # retry. The member then serves future reads of this range
                # directly again.
                if md_badblocks_check(&dev[0].members[i], vlba, count) != 0:
                    md_badblocks_clear(&dev[0].members[i], vlba, count)
                wrote_any = 1
            i = i + 1
        if wrote_any == 0:
            printk0("md: raid1 write with no live member\n")
            return -1
        return 0
    # READ: serve each sub-span from a live member that holds it good,
    # routing around recorded bad blocks via the mirror.
    return _md_raid1_read_span(dev, vlba, count, buf)


# =========================================================================
# Per-member bad-block list (md "struct badblocks")
# =========================================================================
#
# Linux's drivers/md/md.c keeps, per rdev, a SORTED list of bad-block ranges
# {start_sector, length, ack}. A single unreadable sector therefore does NOT
# fail the whole device: md records the bad range, serves that read from
# redundancy (the mirror copy on RAID1, parity reconstruction on RAID5), and
# the device stays IN the array continuing to serve every good sector. A
# later write that lands on a bad range is retried by the lower layer; if it
# SUCCEEDS the bad-block record is CLEARED (the media relocated/recovered).
#
# Here each MdMember carries a fixed-capacity (`MD_MAX_BADBLOCKS`) array of
# {start, count} ranges kept SORTED by start and MERGED (adjacent or
# overlapping inserts coalesce into one range). The list is addressed in the
# member's own LBA space: for RAID1 a virtual sector v maps to the same
# member sector v, so a range is stated in virtual sectors; for RAID5 the
# range is stated in the member's per-row LBA (stripe*chunk+off).


def _md_bb_overlaps(s1: uint64, c1: uint64, s2: uint64, c2: uint64) -> int32:
    # Do ranges [s1,s1+c1) and [s2,s2+c2) intersect? 1 yes / 0 no.
    if c1 == 0 or c2 == 0:
        return 0
    if s1 + c1 <= s2:
        return 0
    if s2 + c2 <= s1:
        return 0
    return 1


def md_badblocks_check(mem: Ptr[MdMember], sector: uint64,
                       count: uint64) -> int32:
    # Does the range [sector, sector+count) intersect ANY recorded bad block
    # on this member? Returns 1 if it hits a bad block, else 0. The list is
    # sorted, so we can stop once a range starts past the query end.
    if count == 0:
        return 0
    n: uint64 = cast[uint64](mem[0].bb_n)
    i: uint64 = 0
    while i < n:
        bs: uint64 = mem[0].bb[i].start
        bc: uint64 = mem[0].bb[i].count
        if bs >= sector + count:
            return 0                        # sorted: no later range can hit
        if _md_bb_overlaps(sector, count, bs, bc) != 0:
            return 1
        i = i + 1
    return 0


def md_badblocks_set(mem: Ptr[MdMember], sector: uint64,
                     count: uint64) -> int32:
    # Record [sector, sector+count) as bad on this member, INSERTING into the
    # sorted list and MERGING with any adjacent or overlapping existing range.
    # Returns 0 on success, -1 if the list is full (and the range could not be
    # merged into an existing one). Coalescing keeps the list compact and the
    # merge logic genuine (no fixed slots): every range that touches or
    # overlaps the new one is absorbed into a single combined range.
    if count == 0:
        return 0
    ns: uint64 = sector
    ne: uint64 = sector + count             # exclusive end
    # First pass: absorb every existing range that touches/overlaps
    # [ns, ne) — "touches" means end == start (adjacent), so the union is one
    # contiguous range. Removed ranges are compacted out of the array.
    n: uint64 = cast[uint64](mem[0].bb_n)
    w: uint64 = 0                           # write cursor for the compacted list
    r: uint64 = 0
    while r < n:
        es: uint64 = mem[0].bb[r].start
        ee: uint64 = es + mem[0].bb[r].count
        # Adjacent or overlapping if the ranges are not strictly separated.
        if ee < ns or es > ne:
            # Disjoint: keep this range as-is (compact down).
            mem[0].bb[w].start = es
            mem[0].bb[w].count = ee - es
            w = w + 1
        else:
            # Merge: grow [ns,ne) to cover this range too.
            if es < ns:
                ns = es
            if ee > ne:
                ne = ee
        r = r + 1
    # Now insert the merged range [ns,ne) keeping the list sorted by start.
    if w >= MD_MAX_BADBLOCKS:
        return -1
    # Find insertion index (first existing range whose start > ns).
    ins: uint64 = w
    j: uint64 = 0
    while j < w:
        if mem[0].bb[j].start > ns:
            ins = j
            j = w
        else:
            j = j + 1
    # Shift the tail up by one to open a slot at `ins`.
    k: uint64 = w
    while k > ins:
        mem[0].bb[k].start = mem[0].bb[k - 1].start
        mem[0].bb[k].count = mem[0].bb[k - 1].count
        k = k - 1
    mem[0].bb[ins].start = ns
    mem[0].bb[ins].count = ne - ns
    mem[0].bb_n = cast[uint32](w + 1)
    return 0


# Scratch for md_badblocks_clear's split rebuild (module-scope per the Adder
# large-array quirk). A clear can split each existing range into two, so the
# rebuilt list can momentarily hold up to 2*MD_MAX_BADBLOCKS ranges before the
# overflow guard rejects it.
_md_bb_clr_s: Array[32, uint64]
_md_bb_clr_c: Array[32, uint64]


def md_badblocks_clear(mem: Ptr[MdMember], sector: uint64,
                       count: uint64) -> int32:
    # Remove [sector, sector+count) from the member's bad-block list (a write
    # to a bad range SUCCEEDED, so the media is good again). Genuinely SPLITS
    # ranges: a cleared sub-range in the middle of a recorded range leaves the
    # surrounding still-bad parts as two trimmed ranges. Returns the number of
    # ranges remaining, or -1 if a split would overflow the list.
    if count == 0:
        return cast[int32](mem[0].bb_n)
    cs: uint64 = sector
    ce: uint64 = sector + count             # exclusive end of cleared span
    n: uint64 = cast[uint64](mem[0].bb_n)
    # Build the new list in scratch (left-half / right-half splits), then copy
    # it back. Worst case each existing range splits into two, so cap the
    # output at MD_MAX_BADBLOCKS.
    w: uint64 = 0
    r: uint64 = 0
    while r < n:
        es: uint64 = mem[0].bb[r].start
        ec: uint64 = mem[0].bb[r].count
        ee: uint64 = es + ec
        if ee <= cs or es >= ce:
            # Untouched by the cleared span — keep whole.
            if w >= MD_MAX_BADBLOCKS:
                return -1
            _md_bb_clr_s[w] = es
            _md_bb_clr_c[w] = ec
            w = w + 1
        else:
            # Overlaps the cleared span: keep the bad part BEFORE cs (if any)
            # and the bad part AFTER ce (if any).
            if es < cs:
                if w >= MD_MAX_BADBLOCKS:
                    return -1
                _md_bb_clr_s[w] = es
                _md_bb_clr_c[w] = cs - es
                w = w + 1
            if ee > ce:
                if w >= MD_MAX_BADBLOCKS:
                    return -1
                _md_bb_clr_s[w] = ce
                _md_bb_clr_c[w] = ee - ce
                w = w + 1
        r = r + 1
    # Copy the rebuilt sorted list back (it stays sorted: splits preserve
    # order, and we walked the input in order).
    i: uint64 = 0
    while i < w:
        mem[0].bb[i].start = _md_bb_clr_s[i]
        mem[0].bb[i].count = _md_bb_clr_c[i]
        i = i + 1
    mem[0].bb_n = cast[uint32](w)
    return cast[int32](w)


def md_badblocks_count(mem: Ptr[MdMember]) -> uint64:
    # Number of recorded bad-block ranges on this member.
    return cast[uint64](mem[0].bb_n)


# Scratch buffer for the bitmap resync: holds ONE region's worth of sectors
# copied from the source member onto the recovered member. Module-scope per
# the Adder large-array quirk; sized well above any test region size.
_md_resync_buf: Array[65536, uint8]


# =========================================================================
# Write-intent bitmap (md "internal bitmap") — fast partial resync
# =========================================================================
#
# A redundant array can carry a bitmap that divides its virtual capacity
# into fixed-size REGIONS (bitmap_region_sectors each). One bit per region
# records "write-intent": the region MAY differ between mirror members and
# must be resynced if a member drops and rejoins. Linux md uses exactly
# this to avoid a full-device resync after a transient member failure.
#
# Lifecycle:
#   * write to a region  -> set its dirty bit BEFORE the write reaches the
#     members (so a crash mid-write leaves the region marked for resync).
#   * region known clean -> clear the bit (here: once both mirror members
#     are proven in sync).
#   * member re-added     -> walk ONLY the set bits, copying those regions
#     from a good member onto the recovered one. Untouched regions are
#     skipped entirely, so the resync cost is proportional to the dirty
#     working set, not the device size.

def _md_bitmap_byte(dev: Ptr[MdArray], region: uint64) -> Ptr[uint8]:
    base: uint64 = cast[uint64](dev[0].bitmap_buf)
    return cast[Ptr[uint8]](base + (region >> 3))


def md_bitmap_set(dev: Ptr[MdArray], region: uint64):
    # Mark `region` dirty (write-intent). No-op if the bitmap is off or the
    # region is out of range.
    if dev[0].bitmap_on == 0:
        return
    if region >= dev[0].bitmap_nregions:
        return
    p: Ptr[uint8] = _md_bitmap_byte(dev, region)
    p[0] = cast[uint8](cast[uint64](p[0]) | (1 << (region & 7)))


def md_bitmap_clear(dev: Ptr[MdArray], region: uint64):
    # Clear `region`'s dirty bit (region is known in-sync).
    if dev[0].bitmap_on == 0:
        return
    if region >= dev[0].bitmap_nregions:
        return
    p: Ptr[uint8] = _md_bitmap_byte(dev, region)
    p[0] = cast[uint8](cast[uint64](p[0]) & (~(1 << (region & 7)) & 0xFF))


def md_bitmap_test(dev: Ptr[MdArray], region: uint64) -> int32:
    # Return 1 if `region`'s dirty bit is set, else 0.
    if dev[0].bitmap_on == 0:
        return 0
    if region >= dev[0].bitmap_nregions:
        return 0
    p: Ptr[uint8] = _md_bitmap_byte(dev, region)
    if (cast[uint64](p[0]) & (1 << (region & 7))) != 0:
        return 1
    return 0


def md_bitmap_count_dirty(dev: Ptr[MdArray]) -> uint64:
    # Count the number of dirty regions currently marked.
    if dev[0].bitmap_on == 0:
        return 0
    n: uint64 = 0
    r: uint64 = 0
    while r < dev[0].bitmap_nregions:
        if md_bitmap_test(dev, r) != 0:
            n = n + 1
        r = r + 1
    return n


def md_bitmap_mark_write(dev: Ptr[MdArray], vlba: uint64, count: uint64):
    # Mark every region touched by the write span [vlba, vlba+count) dirty.
    # Called BEFORE the write is dispatched to the members.
    if dev[0].bitmap_on == 0 or count == 0:
        return
    rs: uint64 = dev[0].bitmap_region_sectors
    first: uint64 = vlba / rs
    last:  uint64 = (vlba + count - 1) / rs
    r: uint64 = first
    while r <= last:
        md_bitmap_set(dev, r)
        r = r + 1


def md_bitmap_enable(name: Ptr[char], region_sectors: uint64,
                     store: Ptr[uint8], store_bytes: uint64) -> int32:
    # Attach a write-intent bitmap to array `name`, dividing its capacity
    # into `region_sectors`-sized regions. `store` is the caller-owned bit
    # array (must hold at least ceil(nregions/8) bytes); the bitmap starts
    # all-clear (the array is assumed in-sync at enable time). Returns the
    # region count on success, or a negative error.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    if region_sectors == 0:
        return -1
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used != 0 and md_arrays[i].self_slot == slot:
            cap: uint64 = md_arrays[i].capacity
            nreg: uint64 = (cap + region_sectors - 1) / region_sectors
            need: uint64 = (nreg + 7) >> 3
            if store_bytes < need:
                printk0("md: bitmap store too small\n")
                return -2
            # Start clear (the array is in-sync when the bitmap is created).
            z: uint64 = 0
            while z < need:
                store[z] = 0
                z = z + 1
            md_arrays[i].bitmap_buf            = store
            md_arrays[i].bitmap_region_sectors = region_sectors
            md_arrays[i].bitmap_nregions       = nreg
            md_arrays[i].bitmap_on             = 1
            return cast[int32](nreg)
        i = i + 1
    return -1


def md_bitmap_resync(name: Ptr[char], member_idx: uint64,
                     new_slot: int32) -> int64:
    # Re-add (recover) member `member_idx` of array `name` using the
    # write-intent bitmap: copy ONLY the dirty regions from a live, in-sync
    # member onto the recovered member, then clear those bits. `new_slot`
    # (>= 0) replaces the member's underlying device, or -1 to recover the
    # existing (now cleared-Faulty) member in place. Returns the NUMBER OF
    # REGIONS resynced (>= 0), or a negative error. This is the fast path:
    # the whole device is NOT rewritten — only the regions that took writes
    # while the member was missing.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used != 0 and md_arrays[i].self_slot == slot:
            dev: Ptr[MdArray] = &md_arrays[i]
            if dev[0].level != MD_LEVEL_RAID1:
                return -2
            if dev[0].bitmap_on == 0:
                return -3
            n: uint64 = cast[uint64](dev[0].n_members)
            if member_idx >= n:
                return -1
            # Find a LIVE, non-target source member to copy from.
            src: uint64 = n
            k: uint64 = 0
            while k < n:
                if k != member_idx and dev[0].members[k].failed == 0:
                    src = k
                    k = n
                else:
                    k = k + 1
            if src >= n:
                return -4
            # Swap in the replacement device (if any) and un-fail the target.
            if new_slot >= 0:
                dev[0].members[member_idx].under_slot = new_slot
                dev[0].members[member_idx].bb_n       = 0
            dev[0].members[member_idx].failed = 0
            src_slot: int32 = dev[0].members[src].under_slot
            src_start: uint64 = dev[0].members[src].under_start
            dst_slot: int32 = dev[0].members[member_idx].under_slot
            dst_start: uint64 = dev[0].members[member_idx].under_start
            rs: uint64 = dev[0].bitmap_region_sectors
            cap: uint64 = dev[0].capacity
            resynced: uint64 = 0
            r: uint64 = 0
            while r < dev[0].bitmap_nregions:
                if md_bitmap_test(dev, r) != 0:
                    vlba: uint64 = r * rs
                    cnt: uint64 = rs
                    if vlba + cnt > cap:
                        cnt = cap - vlba
                    # Copy this dirty region from the source member onto the
                    # recovered member, one region at a time.
                    rc: int32 = blk_read_sectors(src_slot,
                        src_start + vlba, cnt, &_md_resync_buf[0])
                    if rc != 0:
                        return -5
                    rc = blk_write_sectors(dst_slot,
                        dst_start + vlba, cnt, &_md_resync_buf[0])
                    if rc != 0:
                        return -5
                    # Region is now in sync on both members — clear the bit.
                    md_bitmap_clear(dev, r)
                    resynced = resynced + 1
                r = r + 1
            return cast[int64](resynced)
        i = i + 1
    return -1


# =========================================================================
# RAID10 — striped mirrors (near=2 layout)
# =========================================================================
#
# Linux's drivers/md/raid10.c near=2 layout. The virtual address space is
# carved into CHUNKS like RAID0, but every chunk is stored COPIES=2 times.
# For N members and copies=2 (N even), virtual chunk `c` is laid out as:
#
#   stripe  s = c / (N / copies)              (member chunk-row)
#   for copy k in 0..copies-1:
#     device d = (c * copies + k) % N         (which member holds copy k)
#   member chunk offset (per device LBA) = s * chunk_sectors + off
#
# So for N=4, copies=2 the mirror PAIRS are (dev0,dev1) and (dev2,dev3):
#   vchunk0 -> dev0+dev1 stripe0 ; vchunk1 -> dev2+dev3 stripe0
#   vchunk2 -> dev0+dev1 stripe1 ; vchunk3 -> dev2+dev3 stripe1
# Capacity = (N / copies) * per_member_usable.
#
# A WRITE fans out to BOTH live copies of the chunk (skipping a Faulty
# member, exactly like raid1 within each mirror pair). A READ is served
# from EITHER copy — we prefer copy0, falling back to copy1 if copy0 is
# Faulty (read_balance choosing a live mirror). DEGRADED MODE: the array
# survives as long as each mirror pair keeps one live member.

MD_RAID10_COPIES: uint64 = 2     # near=2: every chunk stored twice


def _md_raid10_io(dev: Ptr[MdArray], is_write: int32, vlba: uint64,
                  count: uint64, buf: Ptr[uint8]) -> int32:
    # Near=2 striped-mirror remap. Walk the request sector-span, splitting
    # it at chunk boundaries (a request that straddles two chunks lands on a
    # different mirror pair, so it must be split — just like RAID0). For each
    # sub-span compute the two copies' (device, member-LBA) and fan a write
    # to both live copies / serve a read from either live copy.
    if count == 0:
        return 0
    n: uint64 = cast[uint64](dev[0].n_members)
    copies: uint64 = MD_RAID10_COPIES
    groups: uint64 = n / copies
    chunk: uint64 = dev[0].chunk_sectors
    done: uint64 = 0
    while done < count:
        cur_v: uint64 = vlba + done
        chunk_index:   uint64 = cur_v / chunk
        offset_in_chk: uint64 = cur_v % chunk
        stripe:        uint64 = chunk_index / groups
        # Sectors remaining in THIS chunk from offset_in_chk on.
        avail: uint64 = chunk - offset_in_chk
        frag: uint64 = count - done
        if frag > avail:
            frag = avail
        bufp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + done * SECTOR_SIZE)
        if is_write != 0:
            wrote_any: int32 = 0
            k: uint64 = 0
            while k < copies:
                d: uint64 = (chunk_index * copies + k) % n
                if dev[0].members[d].failed == 0:
                    mlba: uint64 = stripe * chunk + offset_in_chk \
                        + dev[0].members[d].under_start
                    rc: int32 = blk_write_sectors(
                        dev[0].members[d].under_slot, mlba, frag, bufp)
                    if rc != 0:
                        return rc
                    wrote_any = 1
                k = k + 1
            if wrote_any == 0:
                printk0("md: raid10 write with no live copy\n")
                return -1
        else:
            # READ: serve from the first live copy of this chunk.
            picked: int32 = -1
            k = 0
            while k < copies:
                d: uint64 = (chunk_index * copies + k) % n
                if dev[0].members[d].failed == 0:
                    picked = cast[int32](d)
                    k = copies
                else:
                    k = k + 1
            if picked < 0:
                printk0("md: raid10 read with no live copy\n")
                return -1
            pu: uint64 = cast[uint64](picked)
            rlba: uint64 = stripe * chunk + offset_in_chk \
                + dev[0].members[pu].under_start
            rc2: int32 = blk_read_sectors(
                dev[0].members[pu].under_slot, rlba, frag, bufp)
            if rc2 != 0:
                return rc2
        done = done + frag
    return 0


# =========================================================================
# RAID5 — striping with distributed single parity (left-symmetric)
# =========================================================================
#
# Linux's drivers/md/raid5.c default layout. For N members the address
# space is carved into CHUNKS exactly like RAID0, but each STRIPE (one
# chunk-row spanning all N members) holds N-1 DATA chunks plus 1 PARITY
# chunk, and the parity chunk's member ROTATES per stripe so parity write
# load is spread across all disks. Capacity = (N-1) * per_member_chunks *
# chunk_sectors.
#
# LEFT-SYMMETRIC geometry (matching raid5.c LAYOUT_LEFT_SYMMETRIC):
#
#   stripe s = vchunk / (N-1)         (which chunk-row)
#   didx   d = vchunk % (N-1)         (data-block index within the stripe)
#   pd_idx   = (N-1) - (s % N)        (member holding parity for stripe s;
#                                      starts on the LAST member at s=0 and
#                                      rotates LEFT as s grows)
#   data member for data-index d = (pd_idx + 1 + d) % N
#                                      (data blocks start just AFTER parity
#                                      and wrap, so they are densely packed)
#   member chunk offset = s * chunk_sectors   (same row on every member)
#
# P (parity) = XOR of the N-1 data chunks of that stripe.
#
# DEGRADED READ: if the data member we need is Faulty, reconstruct that
# chunk by XOR-ing every SURVIVING data chunk of the stripe with the parity
# chunk (P XOR (other data) = missing data). If the PARITY member is the
# faulty one, a normal read of a live data member is unaffected.
#
# WRITE (read-modify-write): to write one data chunk we must keep P
# consistent: new_P = old_P XOR old_data XOR new_data. So read the old data
# and old parity, compute the delta, write the new data and new parity. If
# the data member is faulty we can't write it but we still recompute parity
# from survivors so the chunk stays reconstructable; if the parity member
# is faulty we just write the data (no parity to maintain while degraded).

# Per-chunk scratch buffers for RAID5 RMW / reconstruction. Sized to one
# full default chunk (64 KiB). Module-scope per the Adder large-array quirk.
_MD_R5_CHUNK_BYTES: uint64 = 65536        # 128 sectors * 512
_md_r5_scratch_a: Array[65536, uint8]     # old data / accumulator
_md_r5_scratch_b: Array[65536, uint8]     # old parity / surviving chunk
_md_r5_scratch_c: Array[65536, uint8]     # reconstruction accumulator


def _md_xor_into(dst: Ptr[uint8], src: Ptr[uint8], n: uint64):
    # dst[i] ^= src[i] for n bytes. The parity primitive.
    i: uint64 = 0
    while i < n:
        dst[i] = dst[i] ^ src[i]
        i = i + 1


def _md_r5_pd_idx(n: uint64, stripe: uint64) -> uint64:
    # Member index holding the PARITY chunk for `stripe` (left-symmetric).
    return (n - 1) - (stripe % n)


def _md_r5_data_member(n: uint64, pd: uint64, didx: uint64) -> uint64:
    # Member index holding data-block `didx` (0..N-2) of a stripe whose
    # parity lives on member `pd` — left-symmetric packs data right after
    # parity, wrapping.
    return (pd + 1 + didx) % n


def _md_r5_member_lba(dev: Ptr[MdArray], member: uint64,
                      row_chunk: uint64, off: uint64) -> uint64:
    # Underlying LBA on `member` for chunk-row `row_chunk` at sector `off`
    # within the chunk.
    return row_chunk * dev[0].chunk_sectors + off \
        + dev[0].members[member].under_start


def _md_r5_recon_data(dev: Ptr[MdArray], stripe: uint64, want: uint64,
                      off: uint64, frag: uint64, out: Ptr[uint8]) -> int32:
    # Reconstruct the data chunk-fragment that lives on member `want` for
    # `stripe`, by XOR-ing every OTHER member's fragment (all surviving data
    # members PLUS the parity member) at the same row/offset. This is the
    # RAID5 resilience math: P XOR (all surviving data) = the missing data.
    # `want` must be the (sole) faulty member. Returns 0 / -1.
    n: uint64 = cast[uint64](dev[0].n_members)
    nb: uint64 = frag * SECTOR_SIZE
    # Zero the accumulator, then XOR in every member except `want`.
    z: uint64 = 0
    while z < nb:
        out[z] = 0
        z = z + 1
    m: uint64 = 0
    while m < n:
        if m != want:
            if dev[0].members[m].failed != 0:
                # Two faults in one stripe — unrecoverable for RAID5.
                return -1
            mlba: uint64 = _md_r5_member_lba(dev, m, stripe, off)
            rc: int32 = blk_read_sectors(
                dev[0].members[m].under_slot, mlba, frag,
                cast[Ptr[uint8]](&_md_r5_scratch_b[0]))
            if rc != 0:
                return rc
            _md_xor_into(out, cast[Ptr[uint8]](&_md_r5_scratch_b[0]), nb)
        m = m + 1
    return 0


def _md_raid5_read_chunkfrag(dev: Ptr[MdArray], stripe: uint64,
                             didx: uint64, off: uint64, frag: uint64,
                             buf: Ptr[uint8]) -> int32:
    # Read one chunk-fragment of data-block `didx` in `stripe`. If its data
    # member is live AND the fragment is not recorded bad on that member, read
    # it directly. If the member is Faulty OR the fragment hits a recorded bad
    # block, reconstruct the chunk by XOR of the surviving data + parity —
    # WITHOUT failing the whole device. A bad block on one member is therefore
    # transparently satisfied by parity reconstruction (the bad member stays
    # IN the array serving its good sectors), and the bad range is recorded so
    # future reads avoid the unreadable media.
    n: uint64 = cast[uint64](dev[0].n_members)
    pd: uint64 = _md_r5_pd_idx(n, stripe)
    dm: uint64 = _md_r5_data_member(n, pd, didx)
    mlba: uint64 = _md_r5_member_lba(dev, dm, stripe, off)
    if dev[0].members[dm].failed == 0 \
            and md_badblocks_check(&dev[0].members[dm], mlba, frag) == 0:
        return blk_read_sectors(dev[0].members[dm].under_slot, mlba,
                                frag, buf)
    # Degraded (member Faulty) or bad-block hit: reconstruct via parity XOR.
    return _md_r5_recon_data(dev, stripe, dm, off, frag, buf)


def _md_raid5_write_chunkfrag(dev: Ptr[MdArray], stripe: uint64,
                              didx: uint64, off: uint64, frag: uint64,
                              buf: Ptr[uint8]) -> int32:
    # Read-modify-write one data chunk-fragment, keeping parity consistent.
    #   new_P = old_P XOR old_data XOR new_data
    # We read old_data (from the data member) and old_P (from the parity
    # member), XOR to form the delta, apply it to old_P, then write new_data
    # and new_P. Handles a faulty data member (skip the data write, still
    # fix parity from survivors) and a faulty parity member (write data
    # only). `frag` <= chunk_sectors so it fits the scratch buffers.
    n: uint64 = cast[uint64](dev[0].n_members)
    pd: uint64 = _md_r5_pd_idx(n, stripe)
    dm: uint64 = _md_r5_data_member(n, pd, didx)
    nb: uint64 = frag * SECTOR_SIZE
    data_failed: uint32 = dev[0].members[dm].failed
    par_failed:  uint32 = dev[0].members[pd].failed

    if par_failed != 0:
        # Parity disk gone: we cannot maintain P. Just write the data (if
        # its member is live). Reads of OTHER data members are unaffected;
        # the failed parity will be rebuilt by md_raid5_rebuild.
        if data_failed != 0:
            # Both this data member and parity are down: this stripe has two
            # faults — write is lost for this block but don't corrupt others.
            return -1
        mlba: uint64 = _md_r5_member_lba(dev, dm, stripe, off)
        return blk_write_sectors(dev[0].members[dm].under_slot, mlba,
                                 frag, buf)

    # Parity is live. Compute new parity.
    par_lba: uint64 = _md_r5_member_lba(dev, pd, stripe, off)
    # Read old parity into scratch_a (the running new-parity accumulator).
    prc: int32 = blk_read_sectors(dev[0].members[pd].under_slot, par_lba,
                                  frag, cast[Ptr[uint8]](&_md_r5_scratch_a[0]))
    if prc != 0:
        return prc

    if data_failed == 0:
        # Normal RMW: new_P = old_P XOR old_data XOR new_data.
        dlba: uint64 = _md_r5_member_lba(dev, dm, stripe, off)
        drc: int32 = blk_read_sectors(
            dev[0].members[dm].under_slot, dlba, frag,
            cast[Ptr[uint8]](&_md_r5_scratch_b[0]))
        if drc != 0:
            return drc
        # accumulator ^= old_data ^ new_data.
        _md_xor_into(cast[Ptr[uint8]](&_md_r5_scratch_a[0]),
                     cast[Ptr[uint8]](&_md_r5_scratch_b[0]), nb)
        _md_xor_into(cast[Ptr[uint8]](&_md_r5_scratch_a[0]), buf, nb)
        # Write the new data, then the new parity.
        wrc: int32 = blk_write_sectors(dev[0].members[dm].under_slot,
                                       dlba, frag, buf)
        if wrc != 0:
            return wrc
        return blk_write_sectors(dev[0].members[pd].under_slot, par_lba,
                                 frag, cast[Ptr[uint8]](&_md_r5_scratch_a[0]))

    # Data member is Faulty: we can't store the new data, but we MUST keep
    # parity consistent so the (now reconstructable) chunk reflects new_data.
    # The reconstructed value of the faulty chunk == XOR of all live data +
    # parity. We want that to equal new_data, i.e. set
    #   new_P = new_data XOR (all OTHER live data members of this stripe).
    # Build that directly: accumulator = new_data, then XOR each other live
    # data member's fragment.
    j: uint64 = 0
    while j < nb:
        _md_r5_scratch_a[j] = buf[j]
        j = j + 1
    od: uint64 = 0
    nd: uint64 = n - 1                  # data blocks per stripe
    while od < nd:
        om: uint64 = _md_r5_data_member(n, pd, od)
        if om != dm:
            if dev[0].members[om].failed != 0:
                return -1               # second fault — unrecoverable
            olba: uint64 = _md_r5_member_lba(dev, om, stripe, off)
            orc: int32 = blk_read_sectors(
                dev[0].members[om].under_slot, olba, frag,
                cast[Ptr[uint8]](&_md_r5_scratch_b[0]))
            if orc != 0:
                return orc
            _md_xor_into(cast[Ptr[uint8]](&_md_r5_scratch_a[0]),
                         cast[Ptr[uint8]](&_md_r5_scratch_b[0]), nb)
        od = od + 1
    return blk_write_sectors(dev[0].members[pd].under_slot, par_lba,
                             frag, cast[Ptr[uint8]](&_md_r5_scratch_a[0]))


# =========================================================================
# PPL — Partial Parity Log (RAID5 write-hole journal)
# =========================================================================
#
# Linux's drivers/md/raid5-ppl.c. A RAID5 partial-stripe write updates a
# data chunk and the parity chunk as TWO separate device writes. If the
# machine crashes BETWEEN them, the on-array parity is stale: it no longer
# equals the XOR of the (now changed) data chunks. A later DEGRADED read of
# an UNTOUCHED chunk in that stripe is reconstructed as
#   missing = stale_P XOR (other current data)
# and is therefore SILENTLY WRONG — the RAID5 "write hole".
#
# PPL closes the hole with a small journal. For the chunk being written we
# log the PARTIAL PARITY:
#
#   PP = old_P XOR old_data
#      = XOR of all the OTHER (UNMODIFIED) data chunks of the stripe
#
# The journal entry is appended BEFORE the new data/parity hit the array.
# After a crash, the data member holds the NEW data (the data write
# completed) but parity is stale. RECOVERY replays each live entry: it reads
# the CURRENT data of the logged data member off the array and recomputes
#   new_P = PP XOR current_data
# which is exactly XOR(unmodified data) XOR new_data = the parity CONSISTENT
# with the present on-disk data — and writes it to the parity member. A
# subsequent degraded read of any untouched chunk now reconstructs the
# CORRECT value. Once a full stripe write completes normally the entries are
# RETIRED (journal head reset, header invalidated) so recovery is a no-op.
#
# JOURNAL ON-DISK LAYOUT (on the dedicated journal block device):
#   sector 0                  : header  — magic + n_entries (persisted so
#                               recovery works from the journal ALONE after
#                               a simulated reboot, with no in-RAM state).
#   per entry i (i = 0..n-1):
#     meta sector  = 1 + i * (1 + ppl_chunk)         : stripe/dm/off/frag/valid
#     payload      = meta + 1 .. + frag              : PP (partial parity)
# ppl_chunk sectors are reserved for payload per slot (fixed-size slots) so
# a slot index maps to a fixed LBA without scanning.

_MD_PPL_MAGIC: uint32 = 0x50504C31       # "PPL1"
_MD_PPL_MAX_ENTRIES: uint64 = 16         # journal capacity (slots)

# Per-entry metadata, packed at the head of the entry's meta sector. The
# journal device is byte-addressed via these little helpers so no struct
# punning is needed.
def _md_ppl_meta_lba(dev: Ptr[MdArray], slot: uint64) -> uint64:
    # First (metadata) sector of journal entry `slot`.
    return 1 + slot * (1 + dev[0].ppl_chunk)


def _md_ppl_payload_lba(dev: Ptr[MdArray], slot: uint64) -> uint64:
    # First payload (partial-parity) sector of journal entry `slot`.
    return _md_ppl_meta_lba(dev, slot) + 1


# A scratch sector for journal header/metadata I/O, plus a chunk-wide
# partial-parity payload buffer. Sized to a FULL default chunk so a payload
# write/read never overflows (the BSS-overflow trap). Module-scope.
_md_ppl_meta:    Array[512, uint8]        # one metadata/header sector
_md_ppl_payload: Array[65536, uint8]      # one chunk of partial parity (128s)


def _md_u32_put(p: Ptr[uint8], off: uint64, v: uint32):
    p[off]     = cast[uint8](v & 0xFF)
    p[off + 1] = cast[uint8]((v >> 8) & 0xFF)
    p[off + 2] = cast[uint8]((v >> 16) & 0xFF)
    p[off + 3] = cast[uint8]((v >> 24) & 0xFF)


def _md_u32_get(p: Ptr[uint8], off: uint64) -> uint32:
    a: uint32 = cast[uint32](p[off])
    b: uint32 = cast[uint32](p[off + 1])
    c: uint32 = cast[uint32](p[off + 2])
    d: uint32 = cast[uint32](p[off + 3])
    return a | (b << 8) | (c << 16) | (d << 24)


def _md_u64_put(p: Ptr[uint8], off: uint64, v: uint64):
    _md_u32_put(p, off, cast[uint32](v & 0xFFFFFFFF))
    _md_u32_put(p, off + 4, cast[uint32]((v >> 32) & 0xFFFFFFFF))


def _md_u64_get(p: Ptr[uint8], off: uint64) -> uint64:
    lo: uint64 = cast[uint64](_md_u32_get(p, off))
    hi: uint64 = cast[uint64](_md_u32_get(p, off + 4))
    return lo | (hi << 32)


def md_ppl_enable(name: Ptr[char], journal_slot: int32) -> int32:
    # Attach a Partial Parity Log to RAID5 array `name`, journaling to the
    # block device `journal_slot` (mdadm --consistency-policy=ppl). Resets
    # the journal header to empty. Returns 0 on success, negative on error.
    if journal_slot < 0:
        return -1
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used != 0 and md_arrays[i].self_slot == slot:
            dev: Ptr[MdArray] = &md_arrays[i]
            if dev[0].level != MD_LEVEL_RAID5:
                printk0("md: ppl only on raid5\n")
                return -1
            # The journal must hold the header + MAX_ENTRIES fixed slots.
            need: uint64 = 1 + _MD_PPL_MAX_ENTRIES * (1 + dev[0].chunk_sectors)
            if blk_capacity_sectors(journal_slot) < need:
                printk0("md: ppl journal too small\n")
                return -1
            dev[0].ppl_slot  = journal_slot
            dev[0].ppl_chunk = dev[0].chunk_sectors
            dev[0].ppl_head  = 0
            dev[0].ppl_on    = 1
            return _md_ppl_write_header(dev, 0)
        i = i + 1
    return -1


def _md_ppl_write_header(dev: Ptr[MdArray], n_entries: uint32) -> int32:
    # Persist the journal header (magic + entry count). n_entries==0 marks
    # the journal EMPTY (retired) so recovery becomes a no-op.
    z: uint64 = 0
    while z < SECTOR_SIZE:
        _md_ppl_meta[z] = 0
        z = z + 1
    if n_entries != 0:
        _md_u32_put(cast[Ptr[uint8]](&_md_ppl_meta[0]), 0, _MD_PPL_MAGIC)
        _md_u32_put(cast[Ptr[uint8]](&_md_ppl_meta[0]), 4, n_entries)
    return blk_write_sectors(dev[0].ppl_slot, 0, 1,
                             cast[Ptr[uint8]](&_md_ppl_meta[0]))


def _md_ppl_log_entry(dev: Ptr[MdArray], stripe: uint64, dm: uint64,
                      off: uint64, frag: uint64, pp: Ptr[uint8]) -> int32:
    # Append a PPL entry: stripe/data-member/offset/frag metadata + the
    # partial-parity payload `pp` (frag sectors). Persists the updated header
    # LAST so the entry count only advances once the entry is fully on the
    # journal. Returns 0 on success.
    if dev[0].ppl_head >= cast[uint32](_MD_PPL_MAX_ENTRIES):
        # Journal full: flush by retiring (the caller's pending writes will
        # be re-logged). Treated as a soft error here.
        return -1
    slot: uint64 = cast[uint64](dev[0].ppl_head)
    nb: uint64 = frag * SECTOR_SIZE
    # Metadata sector.
    z: uint64 = 0
    while z < SECTOR_SIZE:
        _md_ppl_meta[z] = 0
        z = z + 1
    m: Ptr[uint8] = cast[Ptr[uint8]](&_md_ppl_meta[0])
    _md_u32_put(m, 0, _MD_PPL_MAGIC)
    _md_u32_put(m, 4, 1)                       # valid
    _md_u64_put(m, 8, stripe)
    _md_u64_put(m, 16, dm)
    _md_u64_put(m, 24, off)
    _md_u64_put(m, 32, frag)
    wr: int32 = blk_write_sectors(dev[0].ppl_slot, _md_ppl_meta_lba(dev, slot),
                                  1, m)
    if wr != 0:
        return wr
    # Payload (partial parity).
    pr: int32 = blk_write_sectors(dev[0].ppl_slot,
                                  _md_ppl_payload_lba(dev, slot), frag, pp)
    if pr != 0:
        return pr
    dev[0].ppl_head = dev[0].ppl_head + 1
    return _md_ppl_write_header(dev, dev[0].ppl_head)


def _md_ppl_retire(dev: Ptr[MdArray]) -> int32:
    # Mark all journal entries retired (the full stripe write completed and
    # parity is now consistent). Resets the head and invalidates the header
    # so a future recovery does nothing.
    dev[0].ppl_head = 0
    return _md_ppl_write_header(dev, 0)


def _md_raid5_write_logged(dev: Ptr[MdArray], stripe: uint64, didx: uint64,
                           off: uint64, frag: uint64, buf: Ptr[uint8],
                           tear: int32) -> int32:
    # PPL-protected RMW of one data chunk-fragment. Computes the partial
    # parity PP = old_P XOR old_data = XOR of the unmodified data chunks,
    # APPENDS a journal entry, then writes the new data and (unless `tear`
    # simulates a crash) the new parity. With `tear != 0` the data write
    # lands but the parity write is SKIPPED — leaving the array in the exact
    # torn-write state PPL recovery must repair, with a live journal entry.
    n: uint64 = cast[uint64](dev[0].n_members)
    pd: uint64 = _md_r5_pd_idx(n, stripe)
    dm: uint64 = _md_r5_data_member(n, pd, didx)
    nb: uint64 = frag * SECTOR_SIZE
    if dev[0].members[dm].failed != 0 or dev[0].members[pd].failed != 0:
        # PPL protects the clean (non-degraded) RMW path; fall back when a
        # member is already down (parity can't be the recovery anchor).
        return _md_raid5_write_chunkfrag(dev, stripe, didx, off, frag, buf)
    par_lba: uint64 = _md_r5_member_lba(dev, pd, stripe, off)
    dlba: uint64 = _md_r5_member_lba(dev, dm, stripe, off)
    # PP accumulator = old_P XOR old_data.
    prc: int32 = blk_read_sectors(dev[0].members[pd].under_slot, par_lba, frag,
                                  cast[Ptr[uint8]](&_md_ppl_payload[0]))
    if prc != 0:
        return prc
    drc: int32 = blk_read_sectors(dev[0].members[dm].under_slot, dlba, frag,
                                  cast[Ptr[uint8]](&_md_r5_scratch_b[0]))
    if drc != 0:
        return drc
    _md_xor_into(cast[Ptr[uint8]](&_md_ppl_payload[0]),
                 cast[Ptr[uint8]](&_md_r5_scratch_b[0]), nb)
    # 1) journal the partial parity BEFORE touching the array.
    lrc: int32 = _md_ppl_log_entry(dev, stripe, dm, off, frag,
                                   cast[Ptr[uint8]](&_md_ppl_payload[0]))
    if lrc != 0:
        return lrc
    # 2) write the new data.
    wrc: int32 = blk_write_sectors(dev[0].members[dm].under_slot, dlba, frag,
                                   buf)
    if wrc != 0:
        return wrc
    if tear != 0:
        # Simulated crash between data and parity writes: stop here, leaving
        # stale parity + a live journal entry for md_ppl_recover to replay.
        return 0
    # 3) new_P = PP XOR new_data (== old_P XOR old_data XOR new_data).
    _md_xor_into(cast[Ptr[uint8]](&_md_ppl_payload[0]), buf, nb)
    parc: int32 = blk_write_sectors(dev[0].members[pd].under_slot, par_lba,
                                    frag, cast[Ptr[uint8]](&_md_ppl_payload[0]))
    if parc != 0:
        return parc
    # 4) full stripe write done — retire the journal.
    return _md_ppl_retire(dev)


def _md_dev_by_name(name: Ptr[char]) -> Ptr[MdArray]:
    # Resolve array `name` to its MdArray pointer, or null if not found.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return cast[Ptr[MdArray]](0)
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used != 0 and md_arrays[i].self_slot == slot:
            return &md_arrays[i]
        i = i + 1
    return cast[Ptr[MdArray]](0)


def md_ppl_recover(name: Ptr[char]) -> int32:
    # Replay un-acknowledged PPL entries to close the write hole after a
    # crash. Reads the journal header from the journal device; for each live
    # entry, reads the partial parity AND the CURRENT on-array data of the
    # logged data member, recomputes new_P = PP XOR current_data, and writes
    # it to the parity member — restoring parity consistent with the present
    # data. Retires the journal when done. Returns the number of entries
    # replayed (>= 0), or a negative error.
    dev: Ptr[MdArray] = _md_dev_by_name(name)
    if cast[uint64](dev) == 0:
        return -1
    if dev[0].ppl_on == 0 or dev[0].level != MD_LEVEL_RAID5:
        return -1
    # Read the persisted header.
    hr: int32 = blk_read_sectors(dev[0].ppl_slot, 0, 1,
                                 cast[Ptr[uint8]](&_md_ppl_meta[0]))
    if hr != 0:
        return hr
    magic: uint32 = _md_u32_get(cast[Ptr[uint8]](&_md_ppl_meta[0]), 0)
    if magic != _MD_PPL_MAGIC:
        return 0                              # clean shutdown — nothing to do
    n_entries: uint32 = _md_u32_get(cast[Ptr[uint8]](&_md_ppl_meta[0]), 4)
    replayed: int32 = 0
    e: uint64 = 0
    while e < cast[uint64](n_entries):
        # Read this entry's metadata.
        mr: int32 = blk_read_sectors(dev[0].ppl_slot, _md_ppl_meta_lba(dev, e),
                                     1, cast[Ptr[uint8]](&_md_ppl_meta[0]))
        if mr != 0:
            return mr
        em: Ptr[uint8] = cast[Ptr[uint8]](&_md_ppl_meta[0])
        if _md_u32_get(em, 0) == _MD_PPL_MAGIC and _md_u32_get(em, 4) != 0:
            stripe: uint64 = _md_u64_get(em, 8)
            dm:     uint64 = _md_u64_get(em, 16)
            off:    uint64 = _md_u64_get(em, 24)
            frag:   uint64 = _md_u64_get(em, 32)
            nb: uint64 = frag * SECTOR_SIZE
            n: uint64 = cast[uint64](dev[0].n_members)
            pd: uint64 = _md_r5_pd_idx(n, stripe)
            # Partial parity payload -> accumulator.
            pr: int32 = blk_read_sectors(dev[0].ppl_slot,
                                         _md_ppl_payload_lba(dev, e), frag,
                                         cast[Ptr[uint8]](&_md_ppl_payload[0]))
            if pr != 0:
                return pr
            # Current on-array data of the logged data member.
            dlba: uint64 = _md_r5_member_lba(dev, dm, stripe, off)
            dr: int32 = blk_read_sectors(dev[0].members[dm].under_slot, dlba,
                                         frag,
                                         cast[Ptr[uint8]](&_md_r5_scratch_b[0]))
            if dr != 0:
                return dr
            # new_P = PP XOR current_data.
            _md_xor_into(cast[Ptr[uint8]](&_md_ppl_payload[0]),
                         cast[Ptr[uint8]](&_md_r5_scratch_b[0]), nb)
            par_lba: uint64 = _md_r5_member_lba(dev, pd, stripe, off)
            wr: int32 = blk_write_sectors(dev[0].members[pd].under_slot,
                                          par_lba, frag,
                                          cast[Ptr[uint8]](&_md_ppl_payload[0]))
            if wr != 0:
                return wr
            replayed = replayed + 1
        e = e + 1
    # Recovery done — retire the journal so a re-run is a no-op.
    if _md_ppl_retire(dev) != 0:
        return -1
    return replayed


def _md_raid5_io(dev: Ptr[MdArray], is_write: int32, vlba: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # Walk the request span, splitting at chunk boundaries (exactly like
    # raid0) but mapping each chunk through the left-symmetric data/parity
    # layout. Each fragment is one contiguous run within a single data
    # chunk, dispatched to the read or RMW-write helper.
    if count == 0:
        return 0
    n: uint64 = cast[uint64](dev[0].n_members)
    chunk: uint64 = dev[0].chunk_sectors
    nd: uint64 = n - 1                  # data chunks per stripe
    done: uint64 = 0
    while done < count:
        cur_v: uint64 = vlba + done
        vchunk: uint64 = cur_v / chunk
        off:    uint64 = cur_v % chunk
        stripe: uint64 = vchunk / nd
        didx:   uint64 = vchunk % nd
        avail: uint64 = chunk - off
        frag: uint64 = count - done
        if frag > avail:
            frag = avail
        bufp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + done * SECTOR_SIZE)
        rc: int32 = 0
        if is_write != 0:
            if dev[0].ppl_on != 0:
                # PPL-protected RMW: journal the partial parity before the
                # data/parity writes touch the array (tear=0 = full write).
                rc = _md_raid5_write_logged(dev, stripe, didx, off, frag,
                                            bufp, 0)
            else:
                rc = _md_raid5_write_chunkfrag(dev, stripe, didx, off, frag,
                                               bufp)
        else:
            rc = _md_raid5_read_chunkfrag(dev, stripe, didx, off, frag, bufp)
        if rc != 0:
            return rc
        done = done + frag
    return 0


# =========================================================================
# RAID6 — striping with dual distributed parity (P XOR + Q GF(2^8))
# =========================================================================
#
# Linux's drivers/md/raid6 algorithm. Each STRIPE (one chunk-row spanning
# all N members) holds N-2 DATA chunks plus a P parity chunk and a Q
# syndrome chunk; both P and Q ROTATE per stripe so the parity write load
# is spread across all disks. Capacity = (N-2) * per_member_chunks *
# chunk_sectors.
#
# GEOMETRY (a clean rotating P/Q layout, left-symmetric in spirit):
#
#   stripe s  = vchunk / (N-2)        (which chunk-row)
#   didx   d  = vchunk % (N-2)        (data-block index within the stripe,
#                                      0..N-3 — also the Q coefficient power)
#   pd_idx    = (N-1) - (s % N)       (member holding P for stripe s; starts
#                                      on the LAST member at s=0, rotates left)
#   qd_idx    = (pd_idx + 1) % N      (member holding Q, just after P)
#   data member for data-index d = (qd_idx + 1 + d) % N
#                                      (data blocks start just after Q, wrap)
#   member chunk offset = s * chunk_sectors   (same row on every member)
#
# PARITY MATH over GF(2^8), the Rijndael field, generator g = 2, reducing
# polynomial 0x11d (i.e. x^8 + x^4 + x^3 + x^2 + 1, the standard md poly):
#
#   P = D_0 XOR D_1 XOR ... XOR D_{N-3}          (plain XOR, like RAID5)
#   Q = (g^0 . D_0) XOR (g^1 . D_1) XOR ... XOR (g^{N-3} . D_{N-3})
#
# where g^i . D means GF(2^8) multiply of every byte of chunk D_i by the
# field element g^i. Two member failures are recoverable:
#
#   * one data + (P or Q or neither) lost  -> rebuild data from P (XOR) when
#     P survives, else from Q.
#   * two data blocks D_x, D_y lost (x<y):  solve the 2x2 GF system
#         P'  = P  XOR (sum of surviving data)        (= D_x XOR D_y)
#         Q'  = Q  XOR (sum of g^i.surviving data)    (= g^x.D_x XOR g^y.D_y)
#       => D_x = ( g^{-x} . ( (g^{y-x}/(g^{y-x} XOR 1)).P' XOR
#                              (1/(g^{y-x} XOR 1)).Q'/g^x ) ) ... — we use the
#       standard md closed form:
#         A = g^{y-x},  denom = A XOR 1
#         D_x = (A/denom) . P'  XOR  (1/denom) . (Q' . g^{-x})
#         D_y = P' XOR D_x
#
# These are implemented byte-wise with a log/antilog table multiply.

# GF(2^8) log / antilog (exp) tables for g = 2, poly 0x11d. Built once at
# first use. _md_gf_exp[i] = g^i (i in 0..509, doubled so g^i * g^j needs no
# wrap), _md_gf_log[v] = the exponent e with g^e == v (v in 1..255).
_md_gf_exp:    Array[512, uint8]
_md_gf_log:    Array[256, uint8]
_md_gf_ready:  uint32 = 0


def _md_gf_init():
    # Populate the GF(2^8) log/antilog tables (Rijndael field, g=2, 0x11d).
    if _md_gf_ready != 0:
        return
    x: uint64 = 1
    i: uint64 = 0
    while i < 255:
        _md_gf_exp[i] = cast[uint8](x)
        _md_gf_log[x] = cast[uint8](i)
        # x = x * 2 in GF(2^8): shift left, reduce by 0x11d if bit 8 set.
        x = x << 1
        if (x & 0x100) != 0:
            x = x ^ 0x11d
        i = i + 1
    # Duplicate the cycle so exp[i] for i up to 509 needs no modulo.
    i = 255
    while i < 510:
        _md_gf_exp[i] = _md_gf_exp[i - 255]
        i = i + 1
    _md_gf_log[0] = 0
    _md_gf_ready = 1


def _md_gf_mul(a: uint64, b: uint64) -> uint64:
    # GF(2^8) multiply of two field elements (each 0..255). Returns 0..255.
    if a == 0 or b == 0:
        return 0
    la: uint64 = cast[uint64](_md_gf_log[a & 0xFF])
    lb: uint64 = cast[uint64](_md_gf_log[b & 0xFF])
    return cast[uint64](_md_gf_exp[la + lb])     # la+lb <= 508, table covers it


def _md_gf_pow2(p: uint64) -> uint64:
    # g^p for g = 2 (the per-data-block Q coefficient). p in 0..N-3 < 255.
    return cast[uint64](_md_gf_exp[p % 255])


def _md_gf_inv(a: uint64) -> uint64:
    # Multiplicative inverse of a (a != 0) in GF(2^8): g^(255 - log a).
    la: uint64 = cast[uint64](_md_gf_log[a & 0xFF])
    return cast[uint64](_md_gf_exp[255 - la])


def _md_gf_mul_into(dst: Ptr[uint8], src: Ptr[uint8], c: uint64, n: uint64):
    # dst[i] ^= (c . src[i]) over GF(2^8), for n bytes. The Q accumulate
    # primitive. When c == 1 this is a plain XOR.
    if c == 0:
        return
    if c == 1:
        i0: uint64 = 0
        while i0 < n:
            dst[i0] = dst[i0] ^ src[i0]
            i0 = i0 + 1
        return
    lc: uint64 = cast[uint64](_md_gf_log[c & 0xFF])
    i: uint64 = 0
    while i < n:
        v: uint64 = cast[uint64](src[i])
        if v != 0:
            lv: uint64 = cast[uint64](_md_gf_log[v])
            dst[i] = dst[i] ^ _md_gf_exp[lc + lv]
        i = i + 1


def _md_gf_scale(dst: Ptr[uint8], c: uint64, n: uint64):
    # dst[i] = c . dst[i] over GF(2^8), in place, for n bytes.
    if c == 1:
        return
    if c == 0:
        z: uint64 = 0
        while z < n:
            dst[z] = 0
            z = z + 1
        return
    lc: uint64 = cast[uint64](_md_gf_log[c & 0xFF])
    i: uint64 = 0
    while i < n:
        v: uint64 = cast[uint64](dst[i])
        if v != 0:
            lv: uint64 = cast[uint64](_md_gf_log[v])
            dst[i] = _md_gf_exp[lc + lv]
        else:
            dst[i] = 0
        i = i + 1


# Per-chunk scratch buffers for RAID6 RMW / reconstruction. One full default
# chunk (64 KiB) each. Module-scope per the Adder large-array quirk. Distinct
# from the RAID5 set so a RAID6 op never aliases RAID5 scratch.
_md_r6_acc_p:  Array[65536, uint8]    # P accumulator
_md_r6_acc_q:  Array[65536, uint8]    # Q accumulator
_md_r6_tmp:    Array[65536, uint8]    # a freshly-read member fragment
_md_r6_dx:     Array[65536, uint8]    # solved D_x
_md_r6_dy:     Array[65536, uint8]    # solved D_y
_md_r6_rbuf:   Array[65536, uint8]    # rebuild output (distinct from recon scratch)
_md_r6_pacc2:  Array[65536, uint8]    # P accumulator for the recon-aware P/Q build
_md_r6_qacc2:  Array[65536, uint8]    # Q accumulator for the recon-aware P/Q build
_md_r6_pqdat:  Array[65536, uint8]    # one (possibly reconstructed) data chunk


def _md_r6_pd_idx(n: uint64, stripe: uint64) -> uint64:
    # Member index holding the P chunk for `stripe`.
    return (n - 1) - (stripe % n)


def _md_r6_qd_idx(n: uint64, stripe: uint64) -> uint64:
    # Member index holding the Q chunk for `stripe` (just after P, wrapping).
    return (_md_r6_pd_idx(n, stripe) + 1) % n


def _md_r6_data_member(n: uint64, pd: uint64, qd: uint64,
                       didx: uint64) -> uint64:
    # Member index holding data-block `didx` (0..N-3): data packs right
    # after Q, wrapping.
    return (qd + 1 + didx) % n


def _md_r6_data_index_of(n: uint64, pd: uint64, qd: uint64,
                         member: uint64) -> int32:
    # Inverse map: given a member that is neither P nor Q for this stripe,
    # return its data-block index (0..N-3) — which is also its Q coefficient
    # power. Returns -1 if `member` is the P or Q member.
    if member == pd or member == qd:
        return -1
    nd: uint64 = n - 2
    d: uint64 = 0
    while d < nd:
        if _md_r6_data_member(n, pd, qd, d) == member:
            return cast[int32](d)
        d = d + 1
    return -1


def _md_r6_member_lba(dev: Ptr[MdArray], member: uint64,
                      row_chunk: uint64, off: uint64) -> uint64:
    return row_chunk * dev[0].chunk_sectors + off \
        + dev[0].members[member].under_start


def _md_r6_read_member(dev: Ptr[MdArray], member: uint64, stripe: uint64,
                       off: uint64, frag: uint64, out: Ptr[uint8]) -> int32:
    # Raw read of one member's chunk-fragment at this stripe row/offset.
    mlba: uint64 = _md_r6_member_lba(dev, member, stripe, off)
    return blk_read_sectors(dev[0].members[member].under_slot, mlba,
                            frag, out)


def _md_r6_build_pq(dev: Ptr[MdArray], stripe: uint64, off: uint64,
                    frag: uint64, skip_a: int32, skip_b: int32) -> int32:
    # Compute P (into _md_r6_acc_p) and Q (into _md_r6_acc_q) over ALL data
    # members of `stripe`, reading each live data member fresh, EXCEPT the
    # members `skip_a`/`skip_b` (pass -1 to skip none) which the caller is
    # supplying itself. Any non-skipped data member that is Faulty makes this
    # impossible -> returns -1. nb = frag * SECTOR_SIZE.
    n: uint64 = cast[uint64](dev[0].n_members)
    nb: uint64 = frag * SECTOR_SIZE
    pd: uint64 = _md_r6_pd_idx(n, stripe)
    qd: uint64 = _md_r6_qd_idx(n, stripe)
    nd: uint64 = n - 2
    z: uint64 = 0
    while z < nb:
        _md_r6_acc_p[z] = 0
        _md_r6_acc_q[z] = 0
        z = z + 1
    d: uint64 = 0
    while d < nd:
        dm: uint64 = _md_r6_data_member(n, pd, qd, d)
        if cast[int32](dm) != skip_a and cast[int32](dm) != skip_b:
            if dev[0].members[dm].failed != 0:
                return -1
            rc: int32 = _md_r6_read_member(dev, dm, stripe, off, frag,
                                           cast[Ptr[uint8]](&_md_r6_tmp[0]))
            if rc != 0:
                return rc
            _md_xor_into(cast[Ptr[uint8]](&_md_r6_acc_p[0]),
                         cast[Ptr[uint8]](&_md_r6_tmp[0]), nb)
            _md_gf_mul_into(cast[Ptr[uint8]](&_md_r6_acc_q[0]),
                            cast[Ptr[uint8]](&_md_r6_tmp[0]),
                            _md_gf_pow2(d), nb)
        d = d + 1
    return 0


def _md_r6_recon_one_via_p(dev: Ptr[MdArray], stripe: uint64, want: uint64,
                           off: uint64, frag: uint64,
                           out: Ptr[uint8]) -> int32:
    # Single-fault rebuild of data member `want` using P: out = P XOR (all
    # other data). Requires P live and no second fault among data. Used when
    # exactly one data member (and possibly Q) is down but P survives.
    n: uint64 = cast[uint64](dev[0].n_members)
    nb: uint64 = frag * SECTOR_SIZE
    pd: uint64 = _md_r6_pd_idx(n, stripe)
    qd: uint64 = _md_r6_qd_idx(n, stripe)
    nd: uint64 = n - 2
    # Start with P.
    rc: int32 = _md_r6_read_member(dev, pd, stripe, off, frag, out)
    if rc != 0:
        return rc
    d: uint64 = 0
    while d < nd:
        dm: uint64 = _md_r6_data_member(n, pd, qd, d)
        if dm != want:
            if dev[0].members[dm].failed != 0:
                return -1
            rc2: int32 = _md_r6_read_member(dev, dm, stripe, off, frag,
                                            cast[Ptr[uint8]](&_md_r6_tmp[0]))
            if rc2 != 0:
                return rc2
            _md_xor_into(out, cast[Ptr[uint8]](&_md_r6_tmp[0]), nb)
        d = d + 1
    return 0


def _md_r6_recon_one_via_q(dev: Ptr[MdArray], stripe: uint64, want: uint64,
                           wexp: uint64, off: uint64, frag: uint64,
                           out: Ptr[uint8]) -> int32:
    # Single-fault rebuild of data member `want` (Q coefficient power `wexp`)
    # using Q: Q = g^wexp.D_want XOR (sum of g^i.other_data), so
    #   D_want = g^{-wexp} . ( Q XOR (sum of g^i.other_data) ).
    # Used when P is the OTHER lost member (data + P down) but Q survives.
    n: uint64 = cast[uint64](dev[0].n_members)
    nb: uint64 = frag * SECTOR_SIZE
    pd: uint64 = _md_r6_pd_idx(n, stripe)
    qd: uint64 = _md_r6_qd_idx(n, stripe)
    nd: uint64 = n - 2
    # out = Q.
    rc: int32 = _md_r6_read_member(dev, qd, stripe, off, frag, out)
    if rc != 0:
        return rc
    d: uint64 = 0
    while d < nd:
        dm: uint64 = _md_r6_data_member(n, pd, qd, d)
        if dm != want:
            if dev[0].members[dm].failed != 0:
                return -1
            rc2: int32 = _md_r6_read_member(dev, dm, stripe, off, frag,
                                            cast[Ptr[uint8]](&_md_r6_tmp[0]))
            if rc2 != 0:
                return rc2
            # out ^= g^d . other_data.
            _md_gf_mul_into(out, cast[Ptr[uint8]](&_md_r6_tmp[0]),
                            _md_gf_pow2(d), nb)
        d = d + 1
    # out = g^{-wexp} . out.
    _md_gf_scale(out, _md_gf_inv(_md_gf_pow2(wexp)), nb)
    return 0


def _md_r6_recon_two_data(dev: Ptr[MdArray], stripe: uint64,
                          wx: uint64, wy: uint64, off: uint64, frag: uint64,
                          outx: Ptr[uint8], outy: Ptr[uint8]) -> int32:
    # Rebuild TWO lost data members wx, wy (both live P and Q) using the
    # standard RAID6 two-data-failure solve. ex/ey are their Q coefficient
    # powers. Produces D_wx into outx and D_wy into outy.
    n: uint64 = cast[uint64](dev[0].n_members)
    nb: uint64 = frag * SECTOR_SIZE
    pd: uint64 = _md_r6_pd_idx(n, stripe)
    qd: uint64 = _md_r6_qd_idx(n, stripe)
    iex: int32 = _md_r6_data_index_of(n, pd, qd, wx)
    iey: int32 = _md_r6_data_index_of(n, pd, qd, wy)
    if iex < 0 or iey < 0:
        return -1
    ex: uint64 = cast[uint64](iex)
    ey: uint64 = cast[uint64](iey)
    # P' = P XOR (sum of surviving data)  (== D_wx XOR D_wy)
    # Q' = Q XOR (sum of g^i.surviving data) (== g^ex.D_wx XOR g^ey.D_wy)
    # Build P' in acc_p, Q' in acc_q by summing every data member except the
    # two lost, then folding in the real P and Q chunks.
    if _md_r6_build_pq(dev, stripe, off, frag, cast[int32](wx),
                       cast[int32](wy)) != 0:
        return -1
    # acc_p currently = sum of surviving data; fold in stored P.
    rc: int32 = _md_r6_read_member(dev, pd, stripe, off, frag,
                                   cast[Ptr[uint8]](&_md_r6_tmp[0]))
    if rc != 0:
        return rc
    _md_xor_into(cast[Ptr[uint8]](&_md_r6_acc_p[0]),
                 cast[Ptr[uint8]](&_md_r6_tmp[0]), nb)    # acc_p = P'
    rc2: int32 = _md_r6_read_member(dev, qd, stripe, off, frag,
                                    cast[Ptr[uint8]](&_md_r6_tmp[0]))
    if rc2 != 0:
        return rc2
    _md_xor_into(cast[Ptr[uint8]](&_md_r6_acc_q[0]),
                 cast[Ptr[uint8]](&_md_r6_tmp[0]), nb)     # acc_q = Q'
    # Solve. A = g^{ey-ex} (ey>ex since wy is at a higher data index? not
    # guaranteed — handle either order). denom = A XOR 1.
    # D_wx = (A . P' XOR Q'.g^{-ex}) . (1/denom)        [md closed form]
    # Derivation: from P' = Dx XOR Dy and Q' = g^ex.Dx XOR g^ey.Dy,
    #   Q' XOR g^ey.P' = (g^ex XOR g^ey).Dx
    #   Dx = (Q' XOR g^ey.P') / (g^ex XOR g^ey)
    gex: uint64 = _md_gf_pow2(ex)
    gey: uint64 = _md_gf_pow2(ey)
    denom: uint64 = gex ^ gey
    if denom == 0:
        return -1
    invd: uint64 = _md_gf_inv(denom)
    # outx = g^ey . P'  (copy P' then scale)
    cc: uint64 = 0
    while cc < nb:
        outx[cc] = _md_r6_acc_p[cc]
        cc = cc + 1
    _md_gf_scale(outx, gey, nb)
    # outx ^= Q'
    _md_xor_into(outx, cast[Ptr[uint8]](&_md_r6_acc_q[0]), nb)
    # outx . (1/denom)
    _md_gf_scale(outx, invd, nb)              # outx = D_wx
    # D_wy = P' XOR D_wx
    cc = 0
    while cc < nb:
        outy[cc] = _md_r6_acc_p[cc] ^ outx[cc]
        cc = cc + 1
    return 0


def _md_raid6_read_chunkfrag(dev: Ptr[MdArray], stripe: uint64,
                             didx: uint64, off: uint64, frag: uint64,
                             buf: Ptr[uint8]) -> int32:
    # Read one chunk-fragment of data-block `didx` in `stripe`. If its data
    # member is live, read directly. If degraded, reconstruct depending on
    # which two members are down.
    n: uint64 = cast[uint64](dev[0].n_members)
    pd: uint64 = _md_r6_pd_idx(n, stripe)
    qd: uint64 = _md_r6_qd_idx(n, stripe)
    dm: uint64 = _md_r6_data_member(n, pd, qd, didx)
    if dev[0].members[dm].failed == 0:
        return _md_r6_read_member(dev, dm, stripe, off, frag, buf)
    # `dm` is down. Find any OTHER faulty member in this stripe.
    other: int32 = -1
    m: uint64 = 0
    while m < n:
        if m != dm and dev[0].members[m].failed != 0:
            other = cast[int32](m)
            m = n
        else:
            m = m + 1
    if other < 0:
        # Single fault -> P is live, rebuild via P.
        return _md_r6_recon_one_via_p(dev, stripe, dm, off, frag, buf)
    ou: uint64 = cast[uint64](other)
    if ou == pd:
        # data + P down: P gone, Q live -> rebuild via Q.
        return _md_r6_recon_one_via_q(dev, stripe, dm, didx, off, frag, buf)
    if ou == qd:
        # data + Q down: Q gone, P live -> rebuild via P.
        return _md_r6_recon_one_via_p(dev, stripe, dm, off, frag, buf)
    # Two data members down: solve. We want `dm`; the other is a data member.
    nb: uint64 = frag * SECTOR_SIZE
    rc: int32 = _md_r6_recon_two_data(dev, stripe, dm, ou, off, frag,
                                      cast[Ptr[uint8]](&_md_r6_dx[0]),
                                      cast[Ptr[uint8]](&_md_r6_dy[0]))
    if rc != 0:
        return rc
    # _md_r6_dx holds D_dm (since we passed wx=dm).
    i: uint64 = 0
    while i < nb:
        buf[i] = _md_r6_dx[i]
        i = i + 1
    return 0


def _md_r6_build_pq_recon(dev: Ptr[MdArray], stripe: uint64, off: uint64,
                          frag: uint64, out_p: Ptr[uint8],
                          out_q: Ptr[uint8]) -> int32:
    # Compute P (into out_p) and Q (into out_q) for `stripe` by reading EVERY
    # data member through the reconstructing read path, so a Faulty data
    # member is itself rebuilt from the survivors before being folded in.
    # This is what rebuild of the P or Q member needs when a SECOND (data)
    # member is also Faulty: the missing data is recoverable (only two faults
    # total), so P/Q can still be regenerated. Uses dedicated scratch that
    # does NOT alias the read path's internals. nb = frag * SECTOR_SIZE.
    n: uint64 = cast[uint64](dev[0].n_members)
    nb: uint64 = frag * SECTOR_SIZE
    pd: uint64 = _md_r6_pd_idx(n, stripe)
    qd: uint64 = _md_r6_qd_idx(n, stripe)
    nd: uint64 = n - 2
    z: uint64 = 0
    while z < nb:
        out_p[z] = 0
        out_q[z] = 0
        z = z + 1
    d: uint64 = 0
    while d < nd:
        rc: int32 = _md_raid6_read_chunkfrag(dev, stripe, d, off, frag,
                                             cast[Ptr[uint8]](&_md_r6_pqdat[0]))
        if rc != 0:
            return rc
        _md_xor_into(out_p, cast[Ptr[uint8]](&_md_r6_pqdat[0]), nb)
        _md_gf_mul_into(out_q, cast[Ptr[uint8]](&_md_r6_pqdat[0]),
                        _md_gf_pow2(d), nb)
        d = d + 1
    return 0


def _md_raid6_write_chunkfrag(dev: Ptr[MdArray], stripe: uint64,
                              didx: uint64, off: uint64, frag: uint64,
                              buf: Ptr[uint8]) -> int32:
    # Write one data chunk-fragment, recomputing BOTH P and Q for the stripe
    # from scratch (read all other data members, fold in the new data) and
    # writing P, Q and the data atomically-as-possible. This full-stripe
    # parity recompute is simpler and always correct; with small test chunks
    # it is also cheap. Degraded handling:
    #   * data member faulty: we cannot store the data, but we still compute
    #     P and Q from the new value so the (reconstructable) chunk reflects
    #     it; a SECOND fault among the other needed members is unrecoverable.
    #   * P faulty: skip the P write (Q still maintained).
    #   * Q faulty: skip the Q write (P still maintained).
    n: uint64 = cast[uint64](dev[0].n_members)
    nb: uint64 = frag * SECTOR_SIZE
    pd: uint64 = _md_r6_pd_idx(n, stripe)
    qd: uint64 = _md_r6_qd_idx(n, stripe)
    dm: uint64 = _md_r6_data_member(n, pd, qd, didx)
    data_failed: uint32 = dev[0].members[dm].failed
    par_failed:  uint32 = dev[0].members[pd].failed
    q_failed:    uint32 = dev[0].members[qd].failed

    # Sum P and Q over every OTHER data member (skip `dm`; we add new data
    # below). A faulty other data member is a second fault -> unrecoverable.
    if _md_r6_build_pq(dev, stripe, off, frag, cast[int32](dm), -1) != 0:
        return -1
    # Fold in the NEW data for `dm` (coefficient g^didx for Q).
    _md_xor_into(cast[Ptr[uint8]](&_md_r6_acc_p[0]), buf, nb)
    _md_gf_mul_into(cast[Ptr[uint8]](&_md_r6_acc_q[0]), buf,
                    _md_gf_pow2(didx), nb)

    # Write the new data (if its member is live).
    if data_failed == 0:
        dlba: uint64 = _md_r6_member_lba(dev, dm, stripe, off)
        wrc: int32 = blk_write_sectors(dev[0].members[dm].under_slot, dlba,
                                       frag, buf)
        if wrc != 0:
            return wrc
    # Write P (if live).
    if par_failed == 0:
        plba: uint64 = _md_r6_member_lba(dev, pd, stripe, off)
        prc: int32 = blk_write_sectors(dev[0].members[pd].under_slot, plba,
                                       frag,
                                       cast[Ptr[uint8]](&_md_r6_acc_p[0]))
        if prc != 0:
            return prc
    # Write Q (if live).
    if q_failed == 0:
        qlba: uint64 = _md_r6_member_lba(dev, qd, stripe, off)
        qrc: int32 = blk_write_sectors(dev[0].members[qd].under_slot, qlba,
                                       frag,
                                       cast[Ptr[uint8]](&_md_r6_acc_q[0]))
        if qrc != 0:
            return qrc
    return 0


def _md_raid6_io(dev: Ptr[MdArray], is_write: int32, vlba: uint64,
                 count: uint64, buf: Ptr[uint8]) -> int32:
    # Walk the request span, splitting at chunk boundaries, mapping each
    # chunk through the rotating P/Q layout.
    if count == 0:
        return 0
    n: uint64 = cast[uint64](dev[0].n_members)
    chunk: uint64 = dev[0].chunk_sectors
    nd: uint64 = n - 2                  # data chunks per stripe
    done: uint64 = 0
    while done < count:
        cur_v: uint64 = vlba + done
        vchunk: uint64 = cur_v / chunk
        off:    uint64 = cur_v % chunk
        stripe: uint64 = vchunk / nd
        didx:   uint64 = vchunk % nd
        avail: uint64 = chunk - off
        frag: uint64 = count - done
        if frag > avail:
            frag = avail
        bufp: Ptr[uint8] = cast[Ptr[uint8]](
            cast[uint64](buf) + done * SECTOR_SIZE)
        rc: int32 = 0
        if is_write != 0:
            rc = _md_raid6_write_chunkfrag(dev, stripe, didx, off, frag, bufp)
        else:
            rc = _md_raid6_read_chunkfrag(dev, stripe, didx, off, frag, bufp)
        if rc != 0:
            return rc
        done = done + frag
    return 0


# =========================================================================
# I/O dispatch (block-layer vtable adapters)
# =========================================================================

def _md_io(dev: Ptr[MdArray], is_write: int32, vlba: uint64,
           count: uint64, buf: Ptr[uint8]) -> int32:
    # Range-check against the array capacity, then dispatch by level.
    if count == 0:
        return 0
    end: uint64 = vlba + count
    if end < vlba or end > dev[0].capacity:
        printk2("md: I/O outside array (vlba=%d count=%d)\n", vlba, count)
        return -1
    if dev[0].level == MD_LEVEL_RAID0:
        return _md_raid0_io(dev, is_write, vlba, count, buf)
    if dev[0].level == MD_LEVEL_RAID1:
        return _md_raid1_io(dev, is_write, vlba, count, buf)
    if dev[0].level == MD_LEVEL_RAID5:
        return _md_raid5_io(dev, is_write, vlba, count, buf)
    if dev[0].level == MD_LEVEL_RAID6:
        return _md_raid6_io(dev, is_write, vlba, count, buf)
    if dev[0].level == MD_LEVEL_RAID10:
        return _md_raid10_io(dev, is_write, vlba, count, buf)
    return -1


def _md_read_blkop(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    dev: Ptr[MdArray] = cast[Ptr[MdArray]](priv)
    if dev[0].used == 0:
        return -1
    return _md_io(dev, 0, lba, count, buf)


def _md_write_blkop(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dev: Ptr[MdArray] = cast[Ptr[MdArray]](priv)
    if dev[0].used == 0:
        return -1
    return _md_io(dev, 1, lba, count, buf)


# =========================================================================
# mdadm-shape control surface (public API)
# =========================================================================

def md_create_raid0(name: Ptr[char], slots: Ptr[int32], n: uint64,
                    chunk_sectors: uint64) -> int32:
    # Assemble a RAID0 (striped) array from `n` member slots. `slots`
    # points at an array of n int32 underlying block-device slots; each
    # member contributes its FULL capacity. The per-member usable span is
    # clamped to the SMALLEST member so the stripe geometry is uniform
    # (the standard mdadm raid0 behaviour: trailing capacity on larger
    # members is wasted). Capacity = n * per_member_usable. This is the
    # `mdadm --create NAME --level=0 --chunk=CHUNK -n N dev0 dev1 ...`
    # shape. Returns the registered block slot (>= 0) or a negative error.
    md_init()
    if n < 2 or n > MD_MAX_MEMBERS:
        return -1
    cs: uint64 = chunk_sectors
    if cs == 0:
        cs = MD_DEFAULT_CHUNK_SECTORS
    # Find the smallest member capacity (uniform stripe geometry).
    smallest: uint64 = 0
    i: uint64 = 0
    while i < n:
        s: int32 = slots[i]
        if s < 0:
            return -2
        cap: uint64 = blk_capacity_sectors(s)
        if cap == 0:
            return -2
        if smallest == 0 or cap < smallest:
            smallest = cap
        i = i + 1
    # Round the per-member usable span DOWN to a whole number of chunks so
    # the stripe map never references a partial trailing chunk.
    per_member: uint64 = (smallest / cs) * cs
    if per_member == 0:
        printk0("md: raid0 members smaller than one chunk\n")
        return -3
    idx_s: int32 = _md_alloc_array()
    if idx_s < 0:
        printk0("md: array table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    md_arrays[idx].level         = MD_LEVEL_RAID0
    md_arrays[idx].n_members     = cast[uint32](n)
    md_arrays[idx].rr            = 0
    md_arrays[idx].chunk_sectors = cs
    md_arrays[idx].capacity      = per_member * n
    i = 0
    while i < n:
        md_arrays[idx].members[i].under_slot  = slots[i]
        md_arrays[idx].members[i].failed      = 0
        md_arrays[idx].members[i].bb_n        = 0
        md_arrays[idx].members[i].under_start = 0
        md_arrays[idx].members[i].usable      = per_member
        i = i + 1
    if _md_register(idx, name) != 0:
        md_arrays[idx].used = 0
        return -5
    return md_arrays[idx].self_slot


def md_create_raid1(name: Ptr[char], slots: Ptr[int32], n: uint64) -> int32:
    # Assemble a RAID1 (mirrored) array from `n` member slots. Every
    # member holds a full copy; capacity = the SMALLEST member's span (you
    # can only mirror as far as the smallest disk reaches). This is the
    # `mdadm --create NAME --level=1 -n N dev0 dev1 ...` shape. Returns the
    # registered block slot (>= 0) or a negative error.
    md_init()
    if n < 2 or n > MD_MAX_MEMBERS:
        return -1
    smallest: uint64 = 0
    i: uint64 = 0
    while i < n:
        s: int32 = slots[i]
        if s < 0:
            return -2
        cap: uint64 = blk_capacity_sectors(s)
        if cap == 0:
            return -2
        if smallest == 0 or cap < smallest:
            smallest = cap
        i = i + 1
    if smallest == 0:
        return -3
    idx_s: int32 = _md_alloc_array()
    if idx_s < 0:
        printk0("md: array table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    md_arrays[idx].level           = MD_LEVEL_RAID1
    md_arrays[idx].n_members       = cast[uint32](n)
    md_arrays[idx].rr              = 0
    md_arrays[idx].chunk_sectors   = 0
    md_arrays[idx].capacity        = smallest
    # A freshly-created array carries no bitmap until md_bitmap_enable.
    md_arrays[idx].bitmap_on             = 0
    md_arrays[idx].bitmap_region_sectors = 0
    md_arrays[idx].bitmap_nregions       = 0
    md_arrays[idx].bitmap_buf            = cast[Ptr[uint8]](0)
    i = 0
    while i < n:
        md_arrays[idx].members[i].under_slot  = slots[i]
        md_arrays[idx].members[i].failed      = 0
        md_arrays[idx].members[i].bb_n        = 0
        md_arrays[idx].members[i].under_start = 0
        md_arrays[idx].members[i].usable      = smallest
        i = i + 1
    if _md_register(idx, name) != 0:
        md_arrays[idx].used = 0
        return -5
    return md_arrays[idx].self_slot


def md_create_raid5(name: Ptr[char], slots: Ptr[int32], n: uint64,
                    chunk_sectors: uint64) -> int32:
    # Assemble a RAID5 array (striping + distributed single parity,
    # left-symmetric) from `n` member slots, n >= 3. Each stripe holds N-1
    # data chunks and 1 rotating parity chunk; capacity = (N-1) * per_member
    # usable. The per-member usable span is clamped to the smallest member
    # and rounded DOWN to a whole number of chunks (uniform stripe
    # geometry). This is the `mdadm --create NAME --level=5 --chunk=CHUNK
    # -n N dev0 dev1 ...` shape. Returns the registered block slot (>= 0) or
    # a negative error.
    md_init()
    if n < 3 or n > MD_MAX_MEMBERS:
        return -1
    cs: uint64 = chunk_sectors
    if cs == 0:
        cs = MD_DEFAULT_CHUNK_SECTORS
    # RMW/reconstruction scratch buffers are one default chunk wide; never
    # let a chunk exceed that or the XOR helpers would overflow.
    if cs > MD_DEFAULT_CHUNK_SECTORS:
        printk0("md: raid5 chunk too large\n")
        return -1
    smallest: uint64 = 0
    i: uint64 = 0
    while i < n:
        s: int32 = slots[i]
        if s < 0:
            return -2
        cap: uint64 = blk_capacity_sectors(s)
        if cap == 0:
            return -2
        if smallest == 0 or cap < smallest:
            smallest = cap
        i = i + 1
    per_member: uint64 = (smallest / cs) * cs
    if per_member == 0:
        printk0("md: raid5 members smaller than one chunk\n")
        return -3
    idx_s: int32 = _md_alloc_array()
    if idx_s < 0:
        printk0("md: array table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    md_arrays[idx].level         = MD_LEVEL_RAID5
    md_arrays[idx].n_members     = cast[uint32](n)
    md_arrays[idx].rr            = 0
    md_arrays[idx].chunk_sectors = cs
    md_arrays[idx].bitmap_on     = 0
    md_arrays[idx].ppl_on        = 0
    md_arrays[idx].ppl_slot      = -1
    md_arrays[idx].ppl_head      = 0
    md_arrays[idx].ppl_chunk     = cs
    # Capacity = data disks * per-member span = (N-1) * per_member.
    md_arrays[idx].capacity      = per_member * (n - 1)
    i = 0
    while i < n:
        md_arrays[idx].members[i].under_slot  = slots[i]
        md_arrays[idx].members[i].failed      = 0
        md_arrays[idx].members[i].bb_n        = 0
        md_arrays[idx].members[i].under_start = 0
        md_arrays[idx].members[i].usable      = per_member
        i = i + 1
    if _md_register(idx, name) != 0:
        md_arrays[idx].used = 0
        return -5
    return md_arrays[idx].self_slot


def md_raid5_rebuild(name: Ptr[char], member_idx: uint64,
                     new_slot: int32) -> int32:
    # Replace a Faulty member of RAID5 array `name` with the underlying
    # block device `new_slot` and RECONSTRUCT its contents stripe-by-stripe
    # from the survivors (XOR), then clear the degraded state (mdadm --add +
    # recovery). For every chunk-row on the replaced member, whatever role
    # it plays in that stripe — a data chunk or the parity chunk — its
    # correct contents are the XOR of all the OTHER members' chunks at that
    # row (parity = XOR of data; a data chunk = XOR of parity + other data).
    # Either way the rebuilt chunk is the XOR of the survivors at that row,
    # so a single XOR-of-others loop rebuilds every row uniformly. Returns 0
    # on success, negative on error.
    if new_slot < 0:
        return -1
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    ai: uint64 = 0
    found: int32 = -1
    while ai < MD_MAX_ARRAYS:
        if md_arrays[ai].used != 0 and md_arrays[ai].self_slot == slot:
            found = cast[int32](ai)
            ai = MD_MAX_ARRAYS
        else:
            ai = ai + 1
    if found < 0:
        return -1
    idx: uint64 = cast[uint64](found)
    dev: Ptr[MdArray] = &md_arrays[idx]
    if dev[0].level != MD_LEVEL_RAID5:
        return -1
    n: uint64 = cast[uint64](dev[0].n_members)
    if member_idx >= n:
        return -1
    # Only one fault is recoverable in RAID5: refuse if a DIFFERENT member
    # is also Faulty.
    f: uint64 = 0
    while f < n:
        if f != member_idx and dev[0].members[f].failed != 0:
            printk0("md: raid5 rebuild blocked — second member Faulty\n")
            return -2
        f = f + 1
    # Point the member at the fresh device, mark it live, drop any stale
    # bad-block records (fresh media), then fill it.
    dev[0].members[member_idx].under_slot  = new_slot
    dev[0].members[member_idx].under_start = 0
    dev[0].members[member_idx].bb_n        = 0
    chunk: uint64 = dev[0].chunk_sectors
    per_member: uint64 = dev[0].members[member_idx].usable
    rows: uint64 = per_member / chunk
    row: uint64 = 0
    nb: uint64 = chunk * SECTOR_SIZE
    while row < rows:
        # Rebuilt row = XOR of all OTHER members' chunks at this row.
        z: uint64 = 0
        while z < nb:
            _md_r5_scratch_c[z] = 0
            z = z + 1
        m: uint64 = 0
        while m < n:
            if m != member_idx:
                mlba: uint64 = row * chunk + dev[0].members[m].under_start
                rc: int32 = blk_read_sectors(
                    dev[0].members[m].under_slot, mlba, chunk,
                    cast[Ptr[uint8]](&_md_r5_scratch_b[0]))
                if rc != 0:
                    return rc
                _md_xor_into(cast[Ptr[uint8]](&_md_r5_scratch_c[0]),
                             cast[Ptr[uint8]](&_md_r5_scratch_b[0]), nb)
            m = m + 1
        wlba: uint64 = row * chunk + dev[0].members[member_idx].under_start
        wrc: int32 = blk_write_sectors(new_slot, wlba, chunk,
                                       cast[Ptr[uint8]](&_md_r5_scratch_c[0]))
        if wrc != 0:
            return wrc
        row = row + 1
    # Recovery complete: clear the Faulty bit.
    dev[0].members[member_idx].failed = 0
    return 0


def md_create_raid6(name: Ptr[char], slots: Ptr[int32], n: uint64,
                    chunk_sectors: uint64) -> int32:
    # Assemble a RAID6 array (striping + dual distributed parity P+Q) from
    # `n` member slots, n >= 4. Each stripe holds N-2 data chunks plus a
    # rotating P (XOR) and Q (GF(2^8)) chunk; capacity = (N-2) * per_member
    # usable. The per-member usable span is clamped to the smallest member
    # and rounded DOWN to a whole number of chunks. This is the `mdadm
    # --create NAME --level=6 --chunk=CHUNK -n N dev0 dev1 ...` shape.
    # Returns the registered block slot (>= 0) or a negative error.
    md_init()
    _md_gf_init()
    if n < 4 or n > MD_MAX_MEMBERS:
        return -1
    cs: uint64 = chunk_sectors
    if cs == 0:
        cs = MD_DEFAULT_CHUNK_SECTORS
    # RMW/reconstruction scratch buffers are one default chunk wide.
    if cs > MD_DEFAULT_CHUNK_SECTORS:
        printk0("md: raid6 chunk too large\n")
        return -1
    smallest: uint64 = 0
    i: uint64 = 0
    while i < n:
        s: int32 = slots[i]
        if s < 0:
            return -2
        cap: uint64 = blk_capacity_sectors(s)
        if cap == 0:
            return -2
        if smallest == 0 or cap < smallest:
            smallest = cap
        i = i + 1
    per_member: uint64 = (smallest / cs) * cs
    if per_member == 0:
        printk0("md: raid6 members smaller than one chunk\n")
        return -3
    idx_s: int32 = _md_alloc_array()
    if idx_s < 0:
        printk0("md: array table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    md_arrays[idx].level         = MD_LEVEL_RAID6
    md_arrays[idx].n_members     = cast[uint32](n)
    md_arrays[idx].rr            = 0
    md_arrays[idx].chunk_sectors = cs
    # Capacity = data disks * per-member span = (N-2) * per_member.
    md_arrays[idx].capacity      = per_member * (n - 2)
    i = 0
    while i < n:
        md_arrays[idx].members[i].under_slot  = slots[i]
        md_arrays[idx].members[i].failed      = 0
        md_arrays[idx].members[i].bb_n        = 0
        md_arrays[idx].members[i].under_start = 0
        md_arrays[idx].members[i].usable      = per_member
        i = i + 1
    if _md_register(idx, name) != 0:
        md_arrays[idx].used = 0
        return -5
    return md_arrays[idx].self_slot


def md_create_raid10(name: Ptr[char], slots: Ptr[int32], n: uint64,
                     chunk_sectors: uint64) -> int32:
    # Assemble a RAID10 array (striped mirrors, near=2) from `n` member
    # slots. `n` must be even and >= 2: every chunk is mirrored across a pair
    # of members and the pairs are striped. Capacity = (N / copies) *
    # per_member usable. The per-member usable span is clamped to the
    # smallest member and rounded DOWN to a whole number of chunks (uniform
    # stripe geometry). This is the `mdadm --create NAME --level=10
    # --layout=n2 --chunk=CHUNK -n N dev0 dev1 ...` shape. Returns the
    # registered block slot (>= 0) or a negative error.
    md_init()
    if n < 2 or n > MD_MAX_MEMBERS:
        return -1
    # near=2 needs an even member count (each chunk stored on a mirror pair).
    if (n % MD_RAID10_COPIES) != 0:
        printk0("md: raid10 needs an even member count\n")
        return -1
    cs: uint64 = chunk_sectors
    if cs == 0:
        cs = MD_DEFAULT_CHUNK_SECTORS
    smallest: uint64 = 0
    i: uint64 = 0
    while i < n:
        s: int32 = slots[i]
        if s < 0:
            return -2
        cap: uint64 = blk_capacity_sectors(s)
        if cap == 0:
            return -2
        if smallest == 0 or cap < smallest:
            smallest = cap
        i = i + 1
    per_member: uint64 = (smallest / cs) * cs
    if per_member == 0:
        printk0("md: raid10 members smaller than one chunk\n")
        return -3
    idx_s: int32 = _md_alloc_array()
    if idx_s < 0:
        printk0("md: array table full\n")
        return -4
    idx: uint64 = cast[uint64](idx_s)
    md_arrays[idx].level         = MD_LEVEL_RAID10
    md_arrays[idx].n_members     = cast[uint32](n)
    md_arrays[idx].rr            = 0
    md_arrays[idx].chunk_sectors = cs
    # Capacity = (N / copies) data-groups * per-member span.
    md_arrays[idx].capacity      = per_member * (n / MD_RAID10_COPIES)
    i = 0
    while i < n:
        md_arrays[idx].members[i].under_slot  = slots[i]
        md_arrays[idx].members[i].failed      = 0
        md_arrays[idx].members[i].bb_n        = 0
        md_arrays[idx].members[i].under_start = 0
        md_arrays[idx].members[i].usable      = per_member
        i = i + 1
    if _md_register(idx, name) != 0:
        md_arrays[idx].used = 0
        return -5
    return md_arrays[idx].self_slot


def md_raid6_rebuild(name: Ptr[char], member_idx: uint64,
                     new_slot: int32) -> int32:
    # Replace a Faulty member of RAID6 array `name` with block device
    # `new_slot` and RECONSTRUCT its contents row-by-row from the survivors
    # (mdadm --add + recovery). For each chunk-row, the replaced member plays
    # one of three roles: a DATA chunk, the P chunk, or the Q chunk.
    #   * data role  -> reconstruct via P+other data (or Q if needed). With at
    #     most ONE other fault tolerated, we use the existing degraded-read
    #     path which already covers data+P / data+Q / data+data.
    #   * P role      -> P = XOR of all data chunks.
    #   * Q role      -> Q = sum of g^i . D_i over all data chunks.
    # A SECOND faulty member is tolerated as long as the rebuilt member plus
    # that member do not exceed two simultaneous faults (RAID6's guarantee).
    # Returns 0 on success, negative on error.
    if new_slot < 0:
        return -1
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    ai: uint64 = 0
    found: int32 = -1
    while ai < MD_MAX_ARRAYS:
        if md_arrays[ai].used != 0 and md_arrays[ai].self_slot == slot:
            found = cast[int32](ai)
            ai = MD_MAX_ARRAYS
        else:
            ai = ai + 1
    if found < 0:
        return -1
    idx: uint64 = cast[uint64](found)
    dev: Ptr[MdArray] = &md_arrays[idx]
    if dev[0].level != MD_LEVEL_RAID6:
        return -1
    n: uint64 = cast[uint64](dev[0].n_members)
    if member_idx >= n:
        return -1
    # RAID6 tolerates up to TWO faults: refuse only if a THIRD member (i.e. a
    # second member OTHER than member_idx) is also Faulty.
    nfault: uint64 = 0
    f: uint64 = 0
    while f < n:
        if f != member_idx and dev[0].members[f].failed != 0:
            nfault = nfault + 1
        f = f + 1
    if nfault > 1:
        printk0("md: raid6 rebuild blocked — too many Faulty members\n")
        return -2
    chunk: uint64 = dev[0].chunk_sectors
    per_member: uint64 = dev[0].members[member_idx].usable
    rows: uint64 = per_member / chunk
    nb: uint64 = chunk * SECTOR_SIZE
    # IMPORTANT: keep the member marked Faulty while we read survivors so the
    # reconstruction helpers see the correct degraded set. Point it at the
    # fresh device first; clear Faulty only after the whole rebuild.
    # The fresh device backs this member from LBA 0.
    dev[0].members[member_idx].under_start = 0
    row: uint64 = 0
    while row < rows:
        pd: uint64 = _md_r6_pd_idx(n, row)
        qd: uint64 = _md_r6_qd_idx(n, row)
        rc: int32 = 0
        if member_idx == pd:
            # Rebuild P = XOR of all data chunks. Use the recon-aware builder
            # so a concurrently-Faulty data member is reconstructed first.
            rc = _md_r6_build_pq_recon(dev, row, 0, chunk,
                                       cast[Ptr[uint8]](&_md_r6_pacc2[0]),
                                       cast[Ptr[uint8]](&_md_r6_qacc2[0]))
            if rc != 0:
                return rc
            rc = blk_write_sectors(new_slot, row * chunk, chunk,
                                   cast[Ptr[uint8]](&_md_r6_pacc2[0]))
            if rc != 0:
                return rc
        elif member_idx == qd:
            # Rebuild Q = sum g^i.D_i, recon-aware (handles a 2nd faulty data).
            rc = _md_r6_build_pq_recon(dev, row, 0, chunk,
                                       cast[Ptr[uint8]](&_md_r6_pacc2[0]),
                                       cast[Ptr[uint8]](&_md_r6_qacc2[0]))
            if rc != 0:
                return rc
            rc = blk_write_sectors(new_slot, row * chunk, chunk,
                                   cast[Ptr[uint8]](&_md_r6_qacc2[0]))
            if rc != 0:
                return rc
        else:
            # Data role: reconstruct via the degraded-read path (handles a
            # concurrent second fault). Need the data-block index for this row.
            di: int32 = _md_r6_data_index_of(n, pd, qd, member_idx)
            if di < 0:
                return -1
            rc = _md_raid6_read_chunkfrag(dev, row, cast[uint64](di), 0,
                                          chunk,
                                          cast[Ptr[uint8]](&_md_r6_rbuf[0]))
            if rc != 0:
                return rc
            rc = blk_write_sectors(new_slot, row * chunk, chunk,
                                   cast[Ptr[uint8]](&_md_r6_rbuf[0]))
            if rc != 0:
                return rc
        row = row + 1
    # Recovery complete: switch to the fresh device and clear the Faulty bit
    # (and any stale bad-block records — fresh media).
    dev[0].members[member_idx].under_slot = new_slot
    dev[0].members[member_idx].bb_n       = 0
    dev[0].members[member_idx].failed     = 0
    return 0


def md_fail_member(name: Ptr[char], member_idx: uint64) -> int32:
    # Mark member `member_idx` of array `name` Faulty — the degraded-mode
    # trigger (mdadm --fail). For a RAID1 array the array keeps serving
    # from the survivors. Returns 0 on success, -1 on bad input. Refuses
    # to fail the LAST live member of a mirror (that would leave no copy).
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used != 0 and md_arrays[i].self_slot == slot:
            if member_idx >= cast[uint64](md_arrays[i].n_members):
                return -1
            # Don't fail the last live mirror.
            if md_arrays[i].level == MD_LEVEL_RAID1:
                live: uint64 = 0
                k: uint64 = 0
                while k < cast[uint64](md_arrays[i].n_members):
                    if md_arrays[i].members[k].failed == 0:
                        live = live + 1
                    k = k + 1
                if live <= 1 and md_arrays[i].members[member_idx].failed == 0:
                    printk0("md: refusing to fail last live mirror\n")
                    return -1
            # RAID10 near=2: don't fail a member whose mirror partner is
            # already Faulty (that would lose a whole mirror pair). Partners
            # are paired (0,1),(2,3),... so the partner is member_idx XOR 1.
            if md_arrays[i].level == MD_LEVEL_RAID10:
                partner: uint64 = member_idx ^ 1
                if partner < cast[uint64](md_arrays[i].n_members) \
                        and md_arrays[i].members[partner].failed != 0 \
                        and md_arrays[i].members[member_idx].failed == 0:
                    printk0("md: refusing to fail both halves of a mirror\n")
                    return -1
            md_arrays[i].members[member_idx].failed = 1
            return 0
        i = i + 1
    return -1


def md_remove(name: Ptr[char]) -> int32:
    # Tear down an md array by name: unregister its block-device identity
    # and free the MdArray slot (mdadm --stop). The underlying member
    # devices are left untouched. Returns 0 on success, -1 if no array
    # carried that name.
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return -1
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used != 0 and md_arrays[i].self_slot == slot:
            blk_unregister_by_name(name)
            md_arrays[i].used      = 0
            md_arrays[i].level     = MD_LEVEL_NONE
            md_arrays[i].n_members = 0
            md_arrays[i].capacity  = 0
            md_arrays[i].self_slot = -1
            return 0
        i = i + 1
    return -1


# =========================================================================
# Deterministic software-RAID self-test
# =========================================================================
#
# Gated boot self-test (init/main.ad, planted /etc/mdraid-test by
# build_initramfs.py when ENABLE_MDRAID_TEST=1). It runs entirely against
# DEDICATED in-kernel backing ramdisks (registered here as "mdback0".."
# mdback3"), so it never touches ram0's FAT image and is fully
# deterministic.
#
# It PROVES three things:
#
#   1. RAID0 stripe routing — write distinct patterns THROUGH the striped
#      array at carefully chosen virtual LBAs, then read the UNDERLYING
#      member raw and confirm each landed on the expected member at the
#      expected per-member offset. Includes a BOUNDARY-STRADDLING request
#      (a 2-sector write whose first sector is the last sector of a chunk
#      and whose second sector is the first sector of the NEXT chunk, i.e.
#      a different member) — proving the request is split correctly.
#   2. RAID1 mirror fan-out — a single write through the mirror lands on
#      BOTH members (verified by reading each member raw), and a read
#      round-trips the original data back.
#   3. RAID1 degraded mode — after one member is marked Faulty, writes go
#      only to the survivor and reads come only from the survivor, yet the
#      data still round-trips correctly.
#
# Each marker line stamps EMERG so it reaches serial even at the prompt.

# Four dedicated backing ramdisks: 256 sectors = 128 KiB each. Module-scope
# per the Adder large-array quirk.
_MD_BACK_SECTORS: uint64 = 256
_md_back_store0:  Array[131072, uint8]   # 256 * 512
_md_back_store1:  Array[131072, uint8]
_md_back_store2:  Array[131072, uint8]
_md_back_store3:  Array[131072, uint8]
_md_back_store4:  Array[131072, uint8]   # RAID6 needs >=4 members + a spare
_md_back_store5:  Array[131072, uint8]
_md_back_ops0:    BlockDeviceOps
_md_back_ops1:    BlockDeviceOps
_md_back_ops2:    BlockDeviceOps
_md_back_ops3:    BlockDeviceOps
_md_back_ops4:    BlockDeviceOps
_md_back_ops5:    BlockDeviceOps

# Dedicated PPL journal backing ramdisk (registered as "mdjrnl0"). 256
# sectors = 128 KiB, mirroring the mdback stores. The RAID5 PPL self-test
# journals partial-parity entries here before the data/parity hit the
# array, then replays them on recovery.
_md_jrnl_store0:  Array[131072, uint8]   # 256 * 512
_md_jrnl_ops0:    BlockDeviceOps

# Self-test scratch buffers (all module-scope, sized for the largest single
# transfer the test performs).
_md_t_pat:    Array[1024, uint8]   # patterns written through an array
_md_t_read:   Array[1024, uint8]   # readback through an array
_md_t_raw0:   Array[4096, uint8]   # raw read from member 0 (up to 4-sector chunk)
_md_t_raw1:   Array[4096, uint8]   # raw read from member 1 (up to 4-sector chunk)

# Member-slot scratch arrays handed to md_create_* (module-scope; small but
# kept out of the frame to be safe with the Adder array quirk).
_md_slots0:   Array[8, int32]
_md_slots1:   Array[8, int32]

# Write-intent-bitmap subtest scratch (module-scope per the Adder quirk).
# The test array is a 256-sector RAID1 with 8-sector regions -> 32 regions,
# so the bitmap needs ceil(32/8)=4 bytes; oversize the store to 64 bytes
# (512 regions of headroom) to keep clear of the BSS-overflow trap.
_md_bm_store:  Array[64, uint8]
# Per-region pattern buffers: one region = 8 sectors = 4096 bytes. Each is
# sized to a FULL region so a region-wide write/read never overflows.
_md_bm_pat:    Array[4096, uint8]
_md_bm_read:   Array[4096, uint8]
_md_bm_raw:    Array[4096, uint8]
_md_slotsbm:   Array[8, int32]


def _md_back0_read(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_md_back_store0[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _md_back0_write(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_md_back_store0[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _md_back1_read(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_md_back_store1[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _md_back1_write(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_md_back_store1[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0


def _md_back2_read(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    src: uint64 = cast[uint64](&_md_back_store2[0]) + lba * SECTOR_SIZE
    memcpy(buf, cast[Ptr[uint8]](src), count * SECTOR_SIZE)
    return 0


def _md_back2_write(priv: uint64, lba: uint64, count: uint64,
                    buf: Ptr[uint8]) -> int32:
    dst: uint64 = cast[uint64](&_md_back_store2[0]) + lba * SECTOR_SIZE
    memcpy(cast[Ptr[uint8]](dst), buf, count * SECTOR_SIZE)
    return 0



    return 0


def _md_emerg0(s: Ptr[char]):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0(s)


def _md_emerg1(s: Ptr[char], a: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1(s, a)


def _md_emerg2(s: Ptr[char], a: uint64, b: uint64):
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2(s, a, b)


def _md_zero_store(p: Ptr[uint8]):
    z: uint64 = 0
    while z < 131072:
        p[z] = 0
        z = z + 1


def _md_back_register(idx: uint64) -> int32:
    # Register backing ramdisk `idx` (0..5) as "mdback<idx>". Returns the
    # slot, or the existing slot if already registered. Zeroes the store
    # on first registration so the test starts clean.
    nm: Array[16, uint8]
    nm[0] = 0x6D   # 'm'
    nm[1] = 0x64   # 'd'
    nm[2] = 0x62   # 'b'
    nm[3] = 0x61   # 'a'
    nm[4] = 0x63   # 'c'
    nm[5] = 0x6B   # 'k'
    nm[6] = cast[uint8](0x30 + idx)   # '0'..'5'
    nm[7] = 0
    name: Ptr[char] = cast[Ptr[char]](&nm[0])
    existing: int32 = find_blockdev(name)
    if existing >= 0:
        return existing
    if idx == 0:
        _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
        _md_back_ops0.read_sectors  = _md_back0_read
        _md_back_ops0.write_sectors = _md_back0_write
        _md_back_ops0.flush         = cast[Fn[int32, uint64]](0)
        return register_blockdev(name, _MD_BACK_SECTORS, &_md_back_ops0, 0)
    if idx == 1:
        _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
        _md_back_ops1.read_sectors  = _md_back1_read
        _md_back_ops1.write_sectors = _md_back1_write
        _md_back_ops1.flush         = cast[Fn[int32, uint64]](0)
        return register_blockdev(name, _MD_BACK_SECTORS, &_md_back_ops1, 0)
    if idx == 2:
        _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
        _md_back_ops2.read_sectors  = _md_back2_read
        _md_back_ops2.write_sectors = _md_back2_write
        _md_back_ops2.flush         = cast[Fn[int32, uint64]](0)
        return register_blockdev(name, _MD_BACK_SECTORS, &_md_back_ops2, 0)
    if idx == 3:
        _md_zero_store(cast[Ptr[uint8]](&_md_back_store3[0]))
        _md_back_ops3.read_sectors  = _md_back3_read
        _md_back_ops3.write_sectors = _md_back3_write
        _md_back_ops3.flush         = cast[Fn[int32, uint64]](0)
        return register_blockdev(name, _MD_BACK_SECTORS, &_md_back_ops3, 0)
    if idx == 4:
        _md_zero_store(cast[Ptr[uint8]](&_md_back_store4[0]))
        _md_back_ops4.read_sectors  = _md_back4_read
        _md_back_ops4.write_sectors = _md_back4_write
        _md_back_ops4.flush         = cast[Fn[int32, uint64]](0)
        return register_blockdev(name, _MD_BACK_SECTORS, &_md_back_ops4, 0)
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store5[0]))
    _md_back_ops5.read_sectors  = _md_back5_read
    _md_back_ops5.write_sectors = _md_back5_write
    _md_back_ops5.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev(name, _MD_BACK_SECTORS, &_md_back_ops5, 0)


def _md_jrnl_register() -> int32:
    # Register the dedicated PPL journal ramdisk as "mdjrnl0". Returns the
    # slot, or the existing slot if already registered. Zeroes the store on
    # first registration so the journal starts empty.
    nm: Array[16, uint8]
    nm[0] = 0x6D   # 'm'
    nm[1] = 0x64   # 'd'
    nm[2] = 0x6A   # 'j'
    nm[3] = 0x72   # 'r'
    nm[4] = 0x6E   # 'n'
    nm[5] = 0x6C   # 'l'
    nm[6] = 0x30   # '0'
    nm[7] = 0
    name: Ptr[char] = cast[Ptr[char]](&nm[0])
    existing: int32 = find_blockdev(name)
    if existing >= 0:
        return existing
    _md_zero_store(cast[Ptr[uint8]](&_md_jrnl_store0[0]))
    _md_jrnl_ops0.read_sectors  = _md_jrnl0_read
    _md_jrnl_ops0.write_sectors = _md_jrnl0_write
    _md_jrnl_ops0.flush         = cast[Fn[int32, uint64]](0)
    return register_blockdev(name, _MD_BACK_SECTORS, &_md_jrnl_ops0, 0)


def _md_buf_eq(a: Ptr[uint8], b: Ptr[uint8], n: uint64) -> int32:
    i: uint64 = 0
    while i < n:
        if a[i] != b[i]:
            return 0
        i = i + 1
    return 1


def _md_fill(p: Ptr[uint8], n: uint64, seed: uint64):
    # Fill n bytes with a seed-dependent pattern (deterministic).
    i: uint64 = 0
    while i < n:
        p[i] = cast[uint8]((i * 7 + seed * 31 + 5) & 0xFF)
        i = i + 1


def md_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [mdraid] marker lines.
    _md_emerg0("[mdraid] self-test start\n")
    md_init()

    b0: int32 = _md_back_register(0)
    b1: int32 = _md_back_register(1)
    b2: int32 = _md_back_register(2)
    b3: int32 = _md_back_register(3)
    b4: int32 = _md_back_register(4)
    b5: int32 = _md_back_register(5)
    if b0 < 0 or b1 < 0 or b2 < 0 or b3 < 0 or b4 < 0 or b5 < 0:
        _md_emerg0("[mdraid] FAIL: backing register\n")
        return 0
    _md_emerg2("[mdraid] backing mdback0 slot=%d mdback1 slot=%d\n",
               cast[uint64](cast[int64](b0)), cast[uint64](cast[int64](b1)))

    ok: int32 = 1

    # ================================================================
    # Test 1: RAID0 stripe routing (2 members, small chunk) including a
    # boundary-straddling request.
    # ================================================================
    # Use a SMALL chunk so the test can straddle a boundary cheaply:
    # chunk = 4 sectors, 2 members (mdback0, mdback1). Geometry:
    #   virtual chunk 0 (vLBA 0..3)  -> member0 chunk0 (mlba 0..3)
    #   virtual chunk 1 (vLBA 4..7)  -> member1 chunk0 (mlba 0..3)
    #   virtual chunk 2 (vLBA 8..11) -> member0 chunk1 (mlba 4..7)
    #   virtual chunk 3 (vLBA 12..15)-> member1 chunk1 (mlba 4..7)
    _md_slots0[0] = b0
    _md_slots0[1] = b1
    r0: int32 = md_create_raid0("md0", &_md_slots0[0], 2, 4)
    if r0 < 0:
        _md_emerg1("[mdraid] FAIL: md_create_raid0 rc=%d\n",
                   cast[uint64](cast[int64](r0)))
        return 0
    # Capacity must be 2 * floor(256/4)*4 = 2 * 256 = 512 sectors.
    r0cap: uint64 = blk_capacity_sectors(r0)
    _md_emerg1("[mdraid] raid0 capacity=%d sectors\n", r0cap)
    if r0cap != 512:
        _md_emerg0("[mdraid] FAIL: raid0 capacity wrong (want 512)\n")
        ok = 0

    # (a) Write to virtual chunk 1 (vLBA 5, inside chunk1 offset1). It must
    #     land on member1 (mdback1) at chunk0 offset1 = mlba 1.
    _md_fill(&_md_t_pat[0], SECTOR_SIZE, 101)
    if blk_write_sectors(r0, 5, 1, &_md_t_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid0 write vLBA5\n")
        return 0
    if blk_read_sectors(b1, 1, 1, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback1\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw1[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid0 vLBA5 did not land on member1 mlba1\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid0: vLBA5 -> member1 mlba1 OK\n")
    # Confirm member0 mlba1 was NOT touched (still zero).
    if blk_read_sectors(b0, 1, 1, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback0\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw0[0], SECTOR_SIZE) != 0:
        _md_emerg0("[mdraid] FAIL: raid0 leaked vLBA5 onto member0\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid0: member0 mlba1 untouched OK\n")

    # (b) Write to virtual chunk 8 (vLBA 8, chunk2 offset0) -> member0
    #     chunk1 mlba 4.
    _md_fill(&_md_t_pat[0], SECTOR_SIZE, 202)
    if blk_write_sectors(r0, 8, 1, &_md_t_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid0 write vLBA8\n")
        return 0
    if blk_read_sectors(b0, 4, 1, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback0 mlba4\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw0[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid0 vLBA8 did not land on member0 mlba4\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid0: vLBA8 -> member0 mlba4 OK\n")

    # (c) BOUNDARY-STRADDLING request: a 2-sector write at vLBA 3..4. vLBA3
    #     is the last sector of chunk0 (member0 mlba3); vLBA4 is the first
    #     sector of chunk1 (member1 mlba0). The request MUST be split: the
    #     first sector lands on member0 mlba3, the second on member1 mlba0.
    _md_fill(&_md_t_pat[0], 2 * SECTOR_SIZE, 303)
    if blk_write_sectors(r0, 3, 2, &_md_t_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid0 straddle write vLBA3..4\n")
        return 0
    # First half must be on member0 mlba3.
    if blk_read_sectors(b0, 3, 1, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback0 mlba3\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw0[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: straddle half0 wrong member/offset\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid0: straddle sector0 -> member0 mlba3 OK\n")
    # Second half must be on member1 mlba0.
    if blk_read_sectors(b1, 0, 1, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback1 mlba0\n")
        return 0
    if _md_buf_eq(cast[Ptr[uint8]](cast[uint64](&_md_t_pat[0]) + SECTOR_SIZE),
                  &_md_t_raw1[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: straddle half1 wrong member/offset\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid0: straddle sector1 -> member1 mlba0 OK\n")
    # And it must read back through the array unchanged.
    if blk_read_sectors(r0, 3, 2, &_md_t_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid0 straddle readback\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_read[0], 2 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid0 straddle readback mismatch\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid0: straddle reads back byte-identical OK\n")

    md_remove("md0")

    # ================================================================
    # Test 2: RAID1 mirror fan-out — write lands on BOTH members.
    # ================================================================
    # Use mdback2 + mdback3 (clean stores).
    _md_slots1[0] = b2
    _md_slots1[1] = b3
    r1: int32 = md_create_raid1("md1", &_md_slots1[0], 2)
    if r1 < 0:
        _md_emerg1("[mdraid] FAIL: md_create_raid1 rc=%d\n",
                   cast[uint64](cast[int64](r1)))
        return 0
    r1cap: uint64 = blk_capacity_sectors(r1)
    _md_emerg1("[mdraid] raid1 capacity=%d sectors\n", r1cap)
    if r1cap != 256:
        _md_emerg0("[mdraid] FAIL: raid1 capacity wrong (want 256)\n")
        ok = 0
    # Write a pattern at vLBA 7. RAID1 has no striping: it must appear at
    # mlba 7 on BOTH mdback2 and mdback3.
    _md_fill(&_md_t_pat[0], SECTOR_SIZE, 404)
    if blk_write_sectors(r1, 7, 1, &_md_t_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid1 write vLBA7\n")
        return 0
    if blk_read_sectors(b2, 7, 1, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback2 mlba7\n")
        return 0
    if blk_read_sectors(b3, 7, 1, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback3 mlba7\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw0[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid1 write missed member0\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid1: write landed on member0 (mdback2) OK\n")
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw1[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid1 write missed member1\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid1: write landed on member1 (mdback3) OK\n")
    # Read back through the mirror -> original data.
    if blk_read_sectors(r1, 7, 1, &_md_t_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid1 readback\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_read[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid1 readback mismatch\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid1: read round-trips through mirror OK\n")

    # ================================================================
    # Test 3: RAID1 degraded mode — fail member0, then write+read still
    # round-trip through the survivor (member1).
    # ================================================================
    if md_fail_member("md1", 0) != 0:
        _md_emerg0("[mdraid] FAIL: md_fail_member(0)\n")
        return 0
    _md_emerg0("[mdraid] raid1: member0 marked Faulty (degraded mode)\n")
    # Write a NEW pattern at vLBA 9. With member0 failed it must land ONLY
    # on member1 (mdback3) and NOT on the failed member0 (mdback2).
    _md_fill(&_md_t_pat[0], SECTOR_SIZE, 505)
    if blk_write_sectors(r1, 9, 1, &_md_t_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: degraded write vLBA9\n")
        return 0
    # Survivor (member1 / mdback3) holds the new data.
    if blk_read_sectors(b3, 9, 1, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback3 mlba9\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw1[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: degraded write missed survivor\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid1 degraded: write reached survivor OK\n")
    # Failed member (member0 / mdback2) must NOT have the new data (still
    # zero at mlba9).
    if blk_read_sectors(b2, 9, 1, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback2 mlba9\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_raw0[0], SECTOR_SIZE) != 0:
        _md_emerg0("[mdraid] FAIL: degraded write leaked to failed member\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid1 degraded: failed member skipped on write OK\n")
    # Read back through the degraded array -> must serve from survivor and
    # return the new data.
    if blk_read_sectors(r1, 9, 1, &_md_t_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: degraded readback\n")
        return 0
    if _md_buf_eq(&_md_t_pat[0], &_md_t_read[0], SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: degraded readback mismatch\n")
        ok = 0
    else:
        _md_emerg0("[mdraid] raid1 degraded: read round-trips via survivor OK\n")

    md_remove("md1")

    # ================================================================
    # Test 4: RAID5 — striping + distributed parity, degraded-read XOR
    # reconstruction, RMW writes, and a full member rebuild.
    # ================================================================
    if _md_raid5_test(b0, b1, b2, b3) != 1:
        ok = 0

    # ================================================================
    # Test 4b: RAID5 PPL — Partial Parity Log closes the write hole. A torn
    # write (data on disk, parity NOT yet, live journal entry) is repaired by
    # md_ppl_recover so a subsequent DEGRADED read of an untouched chunk
    # reconstructs the CORRECT value (and would be WRONG without recovery).
    # ================================================================
    bj: int32 = _md_jrnl_register()
    if bj < 0:
        _md_emerg0("[mdraid] FAIL: mdjrnl0 register\n")
        ok = 0
    else:
        if _md_ppl_test(b0, b1, b2, bj) != 1:
            ok = 0

    # ================================================================
    # Test 5: RAID6 — dual-parity (P XOR + Q GF(2^8)) striping, two-fault
    # reconstruction (data+data, data+P, data+Q), RMW writes, rebuild.
    # ================================================================
    if _md_raid6_test(b0, b1, b2, b3, b4, b5) != 1:
        ok = 0

    # ================================================================
    # Test 6: RAID10 — striped mirrors (near=2). Verify both copies of a
    # chunk land on the correct mirror pair at the right offset, then run
    # degraded read+write through a surviving mirror after a member fails.
    # ================================================================
    if _md_raid10_test(b0, b1, b2, b3) != 1:
        ok = 0

    # ================================================================
    # Test 7: WRITE-INTENT BITMAP — a RAID1 carries an internal bitmap;
    # after a member fails, writes mark only their regions dirty, and the
    # re-add resyncs ONLY those dirty regions (fast partial resync), leaving
    # the array consistent and the bitmap clear.
    # ================================================================
    if _md_bitmap_selftest(b2, b3) != 1:
        ok = 0

    # ================================================================
    # Test 8: PER-MEMBER BAD-BLOCK LIST — a single bad sector does NOT fail
    # the whole device. The sorted bad-block list merges/clears genuinely; a
    # RAID1 read over a bad block is served from the mirror, a RAID5 read over
    # a bad block is reconstructed via parity, a clear-on-successful-write
    # drops the record, and the member stays IN the array serving good I/O.
    # ================================================================
    if _md_badblocks_test(b0, b1, b2) != 1:
        ok = 0

    if ok == 1:
        _md_emerg0("[mdraid] PASS\n")
        return 1
    _md_emerg0("[mdraid] FAIL\n")
    return 0


# Extra scratch for the RAID5 self-test (multi-sector patterns across
# several stripes). Module-scope per the Adder large-array quirk.
_md_t5_pat:  Array[8192, uint8]   # 16 sectors written through the array
_md_t5_read: Array[8192, uint8]   # readback
_md_slots5:  Array[8, int32]


def _md_raid5_test(b0: int32, b1: int32, b2: int32, b3: int32) -> int32:
    # RAID5 over THREE members (mdback0,1,2). Chunk = 4 sectors so a small
    # write spans several stripes cheaply. mdback3 is the spare used for the
    # rebuild. Returns 1 PASS / 0 FAIL.
    _md_emerg0("[mdraid] raid5: begin\n")
    # Re-zero the three member stores so this test is deterministic even
    # though earlier tests dirtied them.
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store3[0]))

    _md_slots5[0] = b0
    _md_slots5[1] = b1
    _md_slots5[2] = b2
    r5: int32 = md_create_raid5("md5", &_md_slots5[0], 3, 4)
    if r5 < 0:
        _md_emerg1("[mdraid] FAIL: md_create_raid5 rc=%d\n",
                   cast[uint64](cast[int64](r5)))
        return 0
    # Capacity = (N-1) * per_member = 2 * floor(256/4)*4 = 2 * 256 = 512.
    r5cap: uint64 = blk_capacity_sectors(r5)
    _md_emerg1("[mdraid] raid5 capacity=%d sectors\n", r5cap)
    if r5cap != 512:
        _md_emerg0("[mdraid] FAIL: raid5 capacity wrong (want 512)\n")
        return 0

    # ---- Write a known 16-sector pattern at vLBA 0, spanning multiple
    # data chunks/stripes (chunk=4 -> 4 data chunks across 2 stripes), then
    # read it back through the healthy array. ----
    _md_fill(&_md_t5_pat[0], 16 * SECTOR_SIZE, 717)
    if blk_write_sectors(r5, 0, 16, &_md_t5_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid5 write 16s\n")
        return 0
    if blk_read_sectors(r5, 0, 16, &_md_t5_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid5 readback 16s\n")
        return 0
    if _md_buf_eq(&_md_t5_pat[0], &_md_t5_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid5 rw mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid5-rw\n")

    # ---- Verify parity is REAL: for stripe 0 (vLBA 0..7 -> data chunks 0,1)
    # parity member is pd=(N-1)-(0%N)=2 (mdback2). Read the two data chunks
    # raw and the parity chunk raw; parity must equal data0 XOR data1. ----
    # data-block 0 of stripe0 -> member (pd+1+0)%3 = (2+1)%3 = 0 (mdback0)
    # data-block 1 of stripe0 -> member (2+1+1)%3 = 1 (mdback1)
    if blk_read_sectors(b0, 0, 4, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read data0\n")
        return 0
    if blk_read_sectors(b1, 0, 4, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read data1\n")
        return 0
    if blk_read_sectors(b2, 0, 4, &_md_t5_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read parity\n")
        return 0
    # _md_t_raw0 ^= _md_t_raw1 -> should equal the parity chunk.
    _md_xor_into(&_md_t_raw0[0], &_md_t_raw1[0], 4 * SECTOR_SIZE)
    if _md_buf_eq(&_md_t_raw0[0], &_md_t5_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid5 parity (data0^data1) != P\n")
        return 0
    _md_emerg0("[mdraid] raid5: distributed parity P=data0^data1 OK\n")

    # ---- DEGRADED READ: fail member 0 (mdback0) and read the whole 16s
    # back. The chunks that lived on member0 must be reconstructed by XOR of
    # the survivors+parity and still match the original pattern. ----
    if md_fail_member("md5", 0) != 0:
        _md_emerg0("[mdraid] FAIL: md_fail_member raid5\n")
        return 0
    _md_emerg0("[mdraid] raid5: member0 marked Faulty (degraded)\n")
    # Wipe mdback0 underneath so a non-reconstructing read could only return
    # garbage — proving the data truly comes from XOR reconstruction.
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    if blk_read_sectors(r5, 0, 16, &_md_t5_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid5 degraded read\n")
        return 0
    if _md_buf_eq(&_md_t5_pat[0], &_md_t5_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid5 degraded read mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid5-degraded-read\n")

    # ---- DEGRADED WRITE: with member0 still Faulty, overwrite vLBA 0..7
    # with a new pattern. Parity must be recomputed so the (reconstructed)
    # member0 chunk reflects the new data. Read it back via reconstruction. ----
    _md_fill(&_md_t5_pat[0], 8 * SECTOR_SIZE, 818)
    if blk_write_sectors(r5, 0, 8, &_md_t5_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid5 degraded write\n")
        return 0
    if blk_read_sectors(r5, 0, 8, &_md_t5_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid5 degraded write readback\n")
        return 0
    if _md_buf_eq(&_md_t5_pat[0], &_md_t5_read[0], 8 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid5 degraded write mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid5-degraded-write\n")

    # ---- REBUILD: add mdback3 as the replacement for member0 and rebuild.
    # After rebuild, member0 is live; verify the array reads back the LATEST
    # data (the degraded-write pattern at 0..7, original at 8..15) and that
    # the rebuilt member's chunk for stripe0/data0 matches the directly read
    # chunk. ----
    if md_raid5_rebuild("md5", 0, b3) != 0:
        _md_emerg0("[mdraid] FAIL: md_raid5_rebuild\n")
        return 0
    # Build the expected full 16s image: 0..7 = pattern 818, 8..15 = 717.
    _md_fill(&_md_t5_pat[0], 8 * SECTOR_SIZE, 818)
    _md_fill(cast[Ptr[uint8]](cast[uint64](&_md_t5_pat[0]) + 8 * SECTOR_SIZE),
             8 * SECTOR_SIZE, 717)
    if blk_read_sectors(r5, 0, 16, &_md_t5_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid5 post-rebuild read\n")
        return 0
    if _md_buf_eq(&_md_t5_pat[0], &_md_t5_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid5 post-rebuild mismatch\n")
        return 0
    # Confirm the rebuilt member (now mdback3) physically holds stripe0
    # data0 = the new pattern's first chunk (data-block 0 lives on member0).
    if blk_read_sectors(b3, 0, 4, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read rebuilt member\n")
        return 0
    if _md_buf_eq(&_md_t5_pat[0], &_md_t_raw0[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: rebuilt member chunk wrong\n")
        return 0
    _md_emerg0("[md] PASS raid5-rebuild\n")

    md_remove("md5")
    _md_emerg0("[md] raid5 PASS\n")
    return 1


# Scratch for the RAID5 PPL self-test. The test array uses chunk=4 sectors,
# so a full chunk is 2 KiB; size every buffer to a FULL chunk (4 sectors =
# 2048 bytes) so a chunk-wide read/write never overflows into the next
# global (the BSS-overflow trap that previously broke RAID5). Module-scope.
_md_ppl_baseA: Array[2048, uint8]   # baseline D0 (pat A), 4 sectors
_md_ppl_baseB: Array[2048, uint8]   # baseline D1 (pat B), 4 sectors
_md_ppl_newC:  Array[2048, uint8]   # torn-write new D0 (pat C), 4 sectors
_md_ppl_rd:    Array[2048, uint8]   # degraded readback of the untouched chunk
_md_slotsppl:  Array[8, int32]


def _md_ppl_test(b0: int32, b1: int32, b2: int32, bj: int32) -> int32:
    # RAID5 PPL write-hole closure, end-to-end. RAID5 over mdback0,1,2
    # (chunk=4), journaling to mdjrnl0 (bj). Returns 1 PASS / 0 FAIL.
    #
    # Stripe-0 geometry (left-symmetric): pd=(N-1)-(0%N)=2 -> P on mdback2;
    # D0 (didx0) on member (2+1)%3=0 (mdback0); D1 (didx1) on member
    # (2+1+1)%3=1 (mdback1). vLBA 0..3 = D0, vLBA 4..7 = D1.
    _md_emerg0("[mdraid] raid5 ppl: begin\n")
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_jrnl_store0[0]))

    _md_slotsppl[0] = b0
    _md_slotsppl[1] = b1
    _md_slotsppl[2] = b2
    r5: int32 = md_create_raid5("md5p", &_md_slotsppl[0], 3, 4)
    if r5 < 0:
        _md_emerg1("[mdraid] FAIL: ppl md_create_raid5 rc=%d\n",
                   cast[uint64](cast[int64](r5)))
        return 0
    if md_ppl_enable("md5p", bj) != 0:
        _md_emerg0("[mdraid] FAIL: md_ppl_enable\n")
        return 0
    _md_emerg0("[mdraid] raid5 ppl: journal attached (mdjrnl0) OK\n")

    # ---- Baseline: write D0=pat A (vLBA0..3) and D1=pat B (vLBA4..7) through
    # the PPL array. These full RMW writes journal then RETIRE, so afterward
    # the journal is empty and parity P = A XOR B is consistent. ----
    _md_fill(cast[Ptr[uint8]](&_md_ppl_baseA[0]), 4 * SECTOR_SIZE, 311)
    _md_fill(cast[Ptr[uint8]](&_md_ppl_baseB[0]), 4 * SECTOR_SIZE, 467)
    if blk_write_sectors(r5, 0, 4, cast[Ptr[uint8]](&_md_ppl_baseA[0])) != 0:
        _md_emerg0("[mdraid] FAIL: ppl baseline D0 write\n")
        return 0
    if blk_write_sectors(r5, 4, 4, cast[Ptr[uint8]](&_md_ppl_baseB[0])) != 0:
        _md_emerg0("[mdraid] FAIL: ppl baseline D1 write\n")
        return 0
    # The journal must be RETIRED after the clean full writes.
    dev: Ptr[MdArray] = _md_dev_by_name("md5p")
    if cast[uint64](dev) == 0:
        _md_emerg0("[mdraid] FAIL: ppl dev lookup\n")
        return 0
    if dev[0].ppl_head != 0:
        _md_emerg0("[mdraid] FAIL: ppl journal not retired after clean write\n")
        return 0
    _md_emerg0("[mdraid] raid5 ppl: clean write retires journal OK\n")

    # ---- TORN WRITE: overwrite D0 (vLBA0..3) with pat C but SIMULATE A CRASH
    # between the data write and the parity write (tear=1). The new data C
    # lands on mdback0; parity (mdback2) stays STALE at A^B; a live journal
    # entry holds PP = old_P^old_D0 = (A^B)^A = B. ----
    _md_fill(cast[Ptr[uint8]](&_md_ppl_newC[0]), 4 * SECTOR_SIZE, 829)
    if _md_raid5_write_logged(dev, 0, 0, 0, 4,
                              cast[Ptr[uint8]](&_md_ppl_newC[0]), 1) != 0:
        _md_emerg0("[mdraid] FAIL: ppl torn write\n")
        return 0
    if dev[0].ppl_head != 1:
        _md_emerg0("[mdraid] FAIL: ppl journal entry not present after tear\n")
        return 0
    # mdback0 (D0) must now physically hold the NEW pattern C (data write
    # completed before the crash).
    if blk_read_sectors(b0, 0, 4, cast[Ptr[uint8]](&_md_ppl_rd[0])) != 0:
        _md_emerg0("[mdraid] FAIL: ppl raw read mdback0\n")
        return 0
    if _md_buf_eq(cast[Ptr[uint8]](&_md_ppl_newC[0]),
                  cast[Ptr[uint8]](&_md_ppl_rd[0]), 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: ppl torn data not on member\n")
        return 0
    _md_emerg0("[mdraid] raid5 ppl: torn write (data yes, parity no, journal entry) OK\n")

    # ---- Fail D1 (mdback1) and wipe its backing so a degraded read of the
    # UNTOUCHED chunk vLBA4..7 can ONLY come from XOR reconstruction
    # (P XOR D0). ----
    if md_fail_member("md5p", 1) != 0:
        _md_emerg0("[mdraid] FAIL: ppl md_fail_member(1)\n")
        return 0
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))

    # ---- WITHOUT RECOVERY: the degraded read reconstructs P^D0 =
    # (A^B)^C != B, i.e. the WRONG value (the write hole). Prove it differs
    # from the correct untouched pattern B. ----
    if blk_read_sectors(r5, 4, 4, cast[Ptr[uint8]](&_md_ppl_rd[0])) != 0:
        _md_emerg0("[mdraid] FAIL: ppl pre-recovery degraded read\n")
        return 0
    if _md_buf_eq(cast[Ptr[uint8]](&_md_ppl_rd[0]),
                  cast[Ptr[uint8]](&_md_ppl_baseB[0]), 4 * SECTOR_SIZE) != 0:
        _md_emerg0("[mdraid] FAIL: ppl write hole not reproduced (read already correct)\n")
        return 0
    _md_emerg0("[md] PASS raid5-ppl-writehole-reproduced\n")

    # ---- RECOVERY: replay the journal. md_ppl_recover reads PP=B and the
    # current D0=C off the array, recomputes new_P = PP^C = B^C, and writes
    # it to the parity member (mdback2) — restoring parity consistent with
    # the present data. ----
    rep: int32 = md_ppl_recover("md5p")
    if rep < 1:
        _md_emerg1("[mdraid] FAIL: ppl recovery replayed=%d (want >=1)\n",
                   cast[uint64](cast[int64](rep)))
        return 0
    if dev[0].ppl_head != 0:
        _md_emerg0("[mdraid] FAIL: ppl journal not retired after recovery\n")
        return 0
    _md_emerg0("[md] PASS raid5-ppl-recover-replay\n")

    # ---- AFTER RECOVERY: the degraded read of the untouched chunk
    # reconstructs new_P^D0 = (B^C)^C = B — the CORRECT original value. ----
    if blk_read_sectors(r5, 4, 4, cast[Ptr[uint8]](&_md_ppl_rd[0])) != 0:
        _md_emerg0("[mdraid] FAIL: ppl post-recovery degraded read\n")
        return 0
    if _md_buf_eq(cast[Ptr[uint8]](&_md_ppl_rd[0]),
                  cast[Ptr[uint8]](&_md_ppl_baseB[0]), 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: ppl post-recovery degraded read wrong\n")
        return 0
    _md_emerg0("[md] PASS raid5-ppl-degraded-read-correct\n")

    md_remove("md5p")
    _md_emerg0("[md] raid5 ppl PASS\n")
    return 1


# Extra scratch for the RAID6 self-test. Sized generously (the test reads up
# to 16-sector spans = 8 KiB; an undersized buffer would silently overflow
# into adjacent globals and corrupt the expected pattern — the exact bug that
# blocked RAID5). Module-scope per the Adder large-array quirk.
_md_t6_pat:   Array[8192, uint8]   # 16 sectors written through the array
_md_t6_read:  Array[8192, uint8]   # readback through the array
_md_t6_raw:   Array[4096, uint8]   # raw read of one member chunk (<=4 sectors)
_md_t6_exp:   Array[4096, uint8]   # expected raw-Q reference
_md_slots6:   Array[8, int32]


def _md_r6_expect_q(nd: uint64, da: Ptr[uint8], db: Ptr[uint8], n: uint64):
    # Compute the reference Q syndrome of a stripe whose two data chunks are
    # `da` (data-block 0, coeff g^0=1) and `db` (data-block 1, coeff g^1=2)
    # into _md_t6_exp, for `n` bytes. Only used to independently verify the
    # on-disk Q chunk for the 2-data-block (N=4) stripe layout.
    i: uint64 = 0
    while i < n:
        _md_t6_exp[i] = 0
        i = i + 1
    _md_gf_mul_into(cast[Ptr[uint8]](&_md_t6_exp[0]), da, 1, n)        # g^0.D0
    _md_gf_mul_into(cast[Ptr[uint8]](&_md_t6_exp[0]), db, 2, n)        # g^1.D1


def _md_raid6_test(b0: int32, b1: int32, b2: int32, b3: int32,
                   b4: int32, b5: int32) -> int32:
    # RAID6 over FOUR members (mdback0..3), chunk = 4 sectors. mdback4 and
    # mdback5 are spares for rebuild. Returns 1 PASS / 0 FAIL.
    #
    # Geometry for N=4, nd=2 data blocks per stripe:
    #   stripe 0: pd=3 qd=0  D0=mdback1 D1=mdback2 P=mdback3 Q=mdback0
    #   stripe 1: pd=2 qd=3  D0=mdback0 D1=mdback1 P=mdback2 Q=mdback3
    _md_emerg0("[mdraid] raid6: begin\n")
    _md_gf_init()
    # Self-check the GF field: g^0=1, g^1=2, 3*7 in GF(2^8) = 9 (classic),
    # and a . a^{-1} = 1 — proves the tables are real, not stubbed.
    if _md_gf_mul(1, 5) != 5 or _md_gf_mul(2, 2) != 4 \
            or _md_gf_mul(3, 7) != 9:
        _md_emerg0("[mdraid] FAIL: raid6 GF mul table wrong\n")
        return 0
    gv: uint64 = 0x53
    if _md_gf_mul(gv, _md_gf_inv(gv)) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 GF inverse wrong\n")
        return 0
    _md_emerg0("[md] PASS raid6-gf\n")

    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store3[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store4[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store5[0]))

    _md_slots6[0] = b0
    _md_slots6[1] = b1
    _md_slots6[2] = b2
    _md_slots6[3] = b3
    r6: int32 = md_create_raid6("md6", &_md_slots6[0], 4, 4)
    if r6 < 0:
        _md_emerg1("[mdraid] FAIL: md_create_raid6 rc=%d\n",
                   cast[uint64](cast[int64](r6)))
        return 0
    # Capacity = (N-2) * per_member = 2 * floor(256/4)*4 = 2 * 256 = 512.
    r6cap: uint64 = blk_capacity_sectors(r6)
    _md_emerg1("[mdraid] raid6 capacity=%d sectors\n", r6cap)
    if r6cap != 512:
        _md_emerg0("[mdraid] FAIL: raid6 capacity wrong (want 512)\n")
        return 0

    # ---- Write a known 16-sector pattern at vLBA 0 (spans 4 data chunks =
    # 2 stripes) and read it back through the healthy array. ----
    _md_fill(&_md_t6_pat[0], 16 * SECTOR_SIZE, 919)
    if blk_write_sectors(r6, 0, 16, &_md_t6_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 write 16s\n")
        return 0
    if blk_read_sectors(r6, 0, 16, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 readback 16s\n")
        return 0
    if _md_buf_eq(&_md_t6_pat[0], &_md_t6_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 rw mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid6-rw\n")

    # ---- Verify the Q syndrome on disk is the REAL GF computation. For
    # stripe 0: D0=mdback1, D1=mdback2, Q=mdback0. Q must equal
    # g^0.D0 XOR g^1.D1. ----
    if blk_read_sectors(b1, 0, 4, &_md_t6_raw[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 raw read D0\n")
        return 0
    if blk_read_sectors(b2, 0, 4, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 raw read D1\n")
        return 0
    _md_r6_expect_q(2, &_md_t6_raw[0], &_md_t6_read[0], 4 * SECTOR_SIZE)
    if blk_read_sectors(b0, 0, 4, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 raw read Q\n")
        return 0
    if _md_buf_eq(&_md_t6_exp[0], &_md_t6_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 Q != g^0.D0 ^ g^1.D1\n")
        return 0
    _md_emerg0("[mdraid] raid6: Q syndrome = g^0.D0 ^ g^1.D1 OK\n")
    # And P (mdback3 for stripe0) must equal D0 XOR D1.
    if blk_read_sectors(b1, 0, 4, &_md_t6_raw[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 raw read D0 (P chk)\n")
        return 0
    if blk_read_sectors(b2, 0, 4, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 raw read D1 (P chk)\n")
        return 0
    _md_xor_into(&_md_t6_raw[0], &_md_t6_read[0], 4 * SECTOR_SIZE)
    if blk_read_sectors(b3, 0, 4, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 raw read P\n")
        return 0
    if _md_buf_eq(&_md_t6_raw[0], &_md_t6_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 P != D0 ^ D1\n")
        return 0
    _md_emerg0("[mdraid] raid6: P parity = D0 ^ D1 OK\n")

    # ---- SINGLE data fault: fail mdback1 (a data member), wipe it, read the
    # whole 16s back. Reconstructs via P. ----
    if md_fail_member("md6", 1) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 fail member1\n")
        return 0
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    if blk_read_sectors(r6, 0, 16, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 single-fault read\n")
        return 0
    if _md_buf_eq(&_md_t6_pat[0], &_md_t6_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 single-fault read mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid6-degraded-read-1\n")

    # ---- TWO DATA faults: also fail mdback2 (the other data member in
    # stripe0; in stripe1 mdback1 and mdback2 are D1 and P respectively, so
    # this exercises BOTH the two-data solve AND a data+P solve). Wipe both
    # and read all 16s back via the GF two-failure reconstruction. ----
    if md_fail_member("md6", 2) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 fail member2\n")
        return 0
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
    if blk_read_sectors(r6, 0, 16, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 two-fault read\n")
        return 0
    if _md_buf_eq(&_md_t6_pat[0], &_md_t6_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 two-fault read mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid6-degraded-read-2\n")

    # ---- Rebuild member1 onto spare mdback4 (member2 still Faulty: a single
    # remaining fault, well within RAID6's two-fault tolerance). ----
    if md_raid6_rebuild("md6", 1, b4) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 rebuild member1\n")
        return 0
    # Then rebuild member2 onto spare mdback5 (now zero faults). ----
    if md_raid6_rebuild("md6", 2, b5) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 rebuild member2\n")
        return 0
    if blk_read_sectors(r6, 0, 16, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 post-rebuild read\n")
        return 0
    if _md_buf_eq(&_md_t6_pat[0], &_md_t6_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 post-rebuild mismatch\n")
        return 0
    # Confirm rebuilt mdback4 physically holds stripe0 D0 (mdback1's role):
    # stripe0 D0 = vLBA 0..3 (data-block index 0). Pattern bytes 0..2047.
    if blk_read_sectors(b4, 0, 4, &_md_t6_raw[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 raw read rebuilt member1\n")
        return 0
    if _md_buf_eq(&_md_t6_pat[0], &_md_t6_raw[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 rebuilt member1 chunk wrong\n")
        return 0
    _md_emerg0("[md] PASS raid6-rebuild\n")

    # ---- DATA + Q fault: fail a data member and the Q member of a stripe,
    # then overwrite + read back. For stripe0, Q=mdback0, D0=mdback1(=b4 now).
    # Fail mdback0 (Q) and mdback1's role... but membership changed after
    # rebuild (member1 now backed by b4). Use member indices: fail member 0
    # (Q for stripe0) and member 1 (D0 for stripe0) and verify reconstruction
    # of D0 via P (data+Q -> rebuild via P). ----
    if md_fail_member("md6", 0) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 fail member0 (Q)\n")
        return 0
    if md_fail_member("md6", 1) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 fail member1 (data)\n")
        return 0
    # Wipe member1's backing (b4) so a non-reconstructing read returns junk.
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store4[0]))
    if blk_read_sectors(r6, 0, 4, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 data+Q read\n")
        return 0
    if _md_buf_eq(&_md_t6_pat[0], &_md_t6_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 data+Q read mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid6-data+Q-read\n")

    # ---- DEGRADED WRITE with member1 (a data member) Faulty: overwrite
    # stripe0's D0 region (vLBA 0..3) with a new pattern. P and Q must be
    # recomputed so the reconstructed (faulty) chunk reflects the new data.
    # member0 (Q) is also Faulty here, exercising the "skip Q write, still
    # maintain P" branch. Read back via reconstruction. ----
    _md_fill(&_md_t6_pat[0], 4 * SECTOR_SIZE, 727)
    if blk_write_sectors(r6, 0, 4, &_md_t6_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 degraded write\n")
        return 0
    if blk_read_sectors(r6, 0, 4, &_md_t6_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid6 degraded write readback\n")
        return 0
    if _md_buf_eq(&_md_t6_pat[0], &_md_t6_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid6 degraded write mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid6-degraded-write\n")

    md_remove("md6")
    _md_emerg0("[md] raid6 PASS\n")
    return 1


# Extra scratch for the RAID10 self-test. The test transfers up to 16
# sectors (8 KiB) THROUGH the array in one go, so the pattern/readback
# buffers MUST be 8192 bytes — an undersized scratch buffer would silently
# overflow into the next module-scope global (the exact bug that blocked
# RAID5). Raw per-member chunk reads (<=4 sectors = 2 KiB) reuse the shared
# _md_t_raw0/_md_t_raw1 (4096) buffers. Module-scope per the Adder quirk.
_md_t10_pat:   Array[8192, uint8]   # 16 sectors written through the array
_md_t10_read:  Array[8192, uint8]   # readback through the array
_md_slots10:   Array[8, int32]


def _md_raid10_test(b0: int32, b1: int32, b2: int32, b3: int32) -> int32:
    # RAID10 near=2 over FOUR members (mdback0..3), chunk = 4 sectors.
    # Mirror pairs are (mdback0,mdback1) and (mdback2,mdback3); chunks are
    # striped across the two pairs. Geometry (chunk=4 sectors):
    #   vchunk0 (vLBA 0..3)  -> pair(0,1) stripe0  -> member mlba 0..3
    #   vchunk1 (vLBA 4..7)  -> pair(2,3) stripe0  -> member mlba 0..3
    #   vchunk2 (vLBA 8..11) -> pair(0,1) stripe1  -> member mlba 4..7
    #   vchunk3 (vLBA12..15) -> pair(2,3) stripe1  -> member mlba 4..7
    # Returns 1 PASS / 0 FAIL.
    _md_emerg0("[mdraid] raid10: begin\n")
    # Re-zero the four member stores (earlier tests dirtied them).
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store3[0]))

    _md_slots10[0] = b0
    _md_slots10[1] = b1
    _md_slots10[2] = b2
    _md_slots10[3] = b3
    r10: int32 = md_create_raid10("md10", &_md_slots10[0], 4, 4)
    if r10 < 0:
        _md_emerg1("[mdraid] FAIL: md_create_raid10 rc=%d\n",
                   cast[uint64](cast[int64](r10)))
        return 0
    # Capacity = (N/copies) * per_member = 2 * floor(256/4)*4 = 2 * 256 = 512.
    r10cap: uint64 = blk_capacity_sectors(r10)
    _md_emerg1("[mdraid] raid10 capacity=%d sectors\n", r10cap)
    if r10cap != 512:
        _md_emerg0("[mdraid] FAIL: raid10 capacity wrong (want 512)\n")
        return 0

    # ---- Write a known 16-sector pattern at vLBA 0 (4 chunks across both
    # stripes/pairs) and read it back through the healthy array. ----
    _md_fill(&_md_t10_pat[0], 16 * SECTOR_SIZE, 1010)
    if blk_write_sectors(r10, 0, 16, &_md_t10_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid10 write 16s\n")
        return 0
    if blk_read_sectors(r10, 0, 16, &_md_t10_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid10 readback 16s\n")
        return 0
    if _md_buf_eq(&_md_t10_pat[0], &_md_t10_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 rw mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid10-rw\n")

    # ---- Verify BOTH COPIES are REAL and landed on the right members at the
    # right offset. vchunk0 (vLBA 0..3) is copy0=mdback0 mlba0..3 and
    # copy1=mdback1 mlba0..3 — both must byte-equal the first chunk of the
    # written pattern. vchunk2 (vLBA 8..11) is copy0=mdback0 mlba4..7 and
    # copy1=mdback1 mlba4..7 — the stripe1 row on the SAME pair. ----
    if blk_read_sectors(b0, 0, 4, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback0 chunk0\n")
        return 0
    if blk_read_sectors(b1, 0, 4, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback1 chunk0\n")
        return 0
    # Both copies of vchunk0 must equal the pattern's first 4 sectors.
    if _md_buf_eq(&_md_t10_pat[0], &_md_t_raw0[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 copy0 (mdback0) wrong\n")
        return 0
    if _md_buf_eq(&_md_t10_pat[0], &_md_t_raw1[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 copy1 (mdback1) wrong\n")
        return 0
    # vchunk1 (vLBA 4..7) must be on the OTHER pair (mdback2/mdback3) mlba0..3
    # and NOT on the first pair's stripe1 row yet (mdback0 mlba4 stays zero
    # until vchunk2 is written — but we wrote 16s so mlba4 holds vchunk2).
    if blk_read_sectors(b2, 0, 4, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback2 chunk0\n")
        return 0
    if blk_read_sectors(b3, 0, 4, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback3 chunk0\n")
        return 0
    # vchunk1 occupies the pattern's sectors 4..7.
    if _md_buf_eq(cast[Ptr[uint8]](cast[uint64](&_md_t10_pat[0])
                  + 4 * SECTOR_SIZE), &_md_t_raw0[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 vchunk1 copy0 (mdback2) wrong\n")
        return 0
    if _md_buf_eq(cast[Ptr[uint8]](cast[uint64](&_md_t10_pat[0])
                  + 4 * SECTOR_SIZE), &_md_t_raw1[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 vchunk1 copy1 (mdback3) wrong\n")
        return 0
    _md_emerg0("[mdraid] raid10: both copies present OK\n")

    # ---- DEGRADED READ: fail member0 (mdback0). vchunk0 copy0 lived on
    # mdback0; the array must serve it from the surviving mirror mdback1.
    # Wipe mdback0 underneath so a read that did NOT route to the survivor
    # would return garbage — proving the data truly comes from the mirror. ----
    if md_fail_member("md10", 0) != 0:
        _md_emerg0("[mdraid] FAIL: md_fail_member raid10\n")
        return 0
    _md_emerg0("[mdraid] raid10: member0 marked Faulty (degraded)\n")
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    if blk_read_sectors(r10, 0, 16, &_md_t10_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid10 degraded read\n")
        return 0
    if _md_buf_eq(&_md_t10_pat[0], &_md_t10_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 degraded read mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid10-degraded-read\n")

    # ---- DEGRADED WRITE: with member0 still Faulty, overwrite vLBA 0..3
    # (vchunk0) with a NEW pattern. It must reach the survivor mdback1 and
    # NOT the failed member0 (mdback0 stays zero). Then read it back via the
    # survivor. ----
    _md_fill(&_md_t10_pat[0], 4 * SECTOR_SIZE, 2020)
    if blk_write_sectors(r10, 0, 4, &_md_t10_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid10 degraded write\n")
        return 0
    # Survivor (mdback1) holds the new data at mlba 0..3.
    if blk_read_sectors(b1, 0, 4, &_md_t_raw1[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback1 mlba0\n")
        return 0
    if _md_buf_eq(&_md_t10_pat[0], &_md_t_raw1[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 degraded write missed survivor\n")
        return 0
    # Failed member (mdback0) must NOT have the new data (still zero).
    if blk_read_sectors(b0, 0, 4, &_md_t_raw0[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raw read mdback0 mlba0\n")
        return 0
    if _md_buf_eq(&_md_t10_pat[0], &_md_t_raw0[0], 4 * SECTOR_SIZE) != 0:
        _md_emerg0("[mdraid] FAIL: raid10 degraded write leaked to failed\n")
        return 0
    # Read back vchunk0 through the degraded array -> new data via survivor.
    if blk_read_sectors(r10, 0, 4, &_md_t10_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: raid10 degraded write readback\n")
        return 0
    if _md_buf_eq(&_md_t10_pat[0], &_md_t10_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: raid10 degraded write readback mismatch\n")
        return 0
    _md_emerg0("[md] PASS raid10-degraded-write\n")

    md_remove("md10")
    _md_emerg0("[md] raid10 PASS\n")
    return 1


# A region holds 8 sectors; the test array is 256 sectors -> 32 regions.
_MD_BM_REGION_SECTORS: uint64 = 8


def _md_bm_dev(name: Ptr[char]) -> Ptr[MdArray]:
    # Resolve an array by name to its MdArray (or null).
    slot: int32 = find_blockdev(name)
    if slot < 0:
        return cast[Ptr[MdArray]](0)
    i: uint64 = 0
    while i < MD_MAX_ARRAYS:
        if md_arrays[i].used != 0 and md_arrays[i].self_slot == slot:
            return &md_arrays[i]
        i = i + 1
    return cast[Ptr[MdArray]](0)


def _md_bitmap_selftest(b2: int32, b3: int32) -> int32:
    # Write-intent bitmap over a RAID1 (mdback2=member0, mdback3=member1).
    # Region = 8 sectors -> 32 regions for the 256-sector array. Returns 1
    # PASS / 0 FAIL. Proves a member that drops and rejoins is resynced over
    # ONLY the regions that took writes while it was down — NOT the whole
    # device.
    _md_emerg0("[mdraid] bitmap: begin\n")
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store3[0]))

    _md_slotsbm[0] = b2
    _md_slotsbm[1] = b3
    rbm: int32 = md_create_raid1("mdbm", &_md_slotsbm[0], 2)
    if rbm < 0:
        _md_emerg1("[mdraid] FAIL: bitmap md_create_raid1 rc=%d\n",
                   cast[uint64](cast[int64](rbm)))
        return 0

    # Attach the write-intent bitmap (8-sector regions). 256/8 = 32 regions.
    nreg: int32 = md_bitmap_enable("mdbm", _MD_BM_REGION_SECTORS,
                                   &_md_bm_store[0], 64)
    if nreg != 32:
        _md_emerg1("[mdraid] FAIL: bitmap enable nreg=%d (want 32)\n",
                   cast[uint64](cast[int64](nreg)))
        return 0
    _md_emerg1("[mdraid] bitmap: enabled, %d regions\n",
               cast[uint64](cast[int64](nreg)))

    dev: Ptr[MdArray] = _md_bm_dev("mdbm")
    if cast[uint64](dev) == 0:
        _md_emerg0("[mdraid] FAIL: bitmap dev lookup\n")
        return 0

    # The bitmap starts clear (array is in-sync at enable time).
    if md_bitmap_count_dirty(dev) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap not clear at enable\n")
        return 0

    # Fail member1 (mdback3). The array runs degraded off member0 (mdback2).
    if md_fail_member("mdbm", 1) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap md_fail_member(1)\n")
        return 0
    _md_emerg0("[mdraid] bitmap: member1 marked Faulty (degraded)\n")

    # Write a DISTINCT pattern to a FEW specific regions while member1 is
    # down. Region r covers vLBA r*8 .. r*8+7. Touch regions 2, 5 and 20 by
    # writing one sector at the START of each region. Only member0 (mdback2)
    # receives the data; member1 (mdback3) is skipped.
    # --- region 2 (vLBA 16) ---
    _md_fill(&_md_bm_pat[0], SECTOR_SIZE, 1212)
    if blk_write_sectors(rbm, 16, 1, &_md_bm_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap write region2\n")
        return 0
    # --- region 5 (vLBA 40) ---
    _md_fill(&_md_bm_pat[0], SECTOR_SIZE, 1515)
    if blk_write_sectors(rbm, 40, 1, &_md_bm_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap write region5\n")
        return 0
    # --- region 20 (vLBA 160) ---
    _md_fill(&_md_bm_pat[0], SECTOR_SIZE, 2020)
    if blk_write_sectors(rbm, 160, 1, &_md_bm_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap write region20\n")
        return 0

    # Exactly regions 2, 5 and 20 must be marked dirty; every OTHER region
    # must stay clear. This proves write-intent is tracked per region.
    if md_bitmap_test(dev, 2) != 1 or md_bitmap_test(dev, 5) != 1 \
            or md_bitmap_test(dev, 20) != 1:
        _md_emerg0("[mdraid] FAIL: bitmap dirty regions not all set\n")
        return 0
    dirty: uint64 = md_bitmap_count_dirty(dev)
    if dirty != 3:
        _md_emerg1("[mdraid] FAIL: bitmap dirty count=%d (want 3)\n", dirty)
        return 0
    # Spot-check that untouched regions stayed clear.
    if md_bitmap_test(dev, 0) != 0 or md_bitmap_test(dev, 3) != 0 \
            or md_bitmap_test(dev, 19) != 0 or md_bitmap_test(dev, 31) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap clean region wrongly dirty\n")
        return 0
    _md_emerg0("[mdraid] bitmap: only dirty regions marked OK\n")

    # WIPE the ENTIRE member1 store (mdback3) so a resync that copied the
    # whole device would touch all 32 regions, but a bitmap-driven resync
    # touches only the 3 dirty ones — leaving the other 29 regions ZERO on
    # member1 (provable below).
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store3[0]))

    # Re-add member1 with the SAME underlying device and bitmap-resync.
    n_resynced: int64 = md_bitmap_resync("mdbm", 1, -1)
    if n_resynced < 0:
        _md_emerg1("[mdraid] FAIL: bitmap resync rc=%d\n",
                   cast[uint64](n_resynced))
        return 0
    _md_emerg1("[mdraid] bitmap: resync touched %d regions\n",
               cast[uint64](n_resynced))
    # PARTIAL: the resync must have walked ONLY the 3 dirty regions, far
    # fewer than the 32 regions of the whole device.
    if n_resynced != 3:
        _md_emerg1("[mdraid] FAIL: bitmap resync touched %d regions (want 3)\n",
                   cast[uint64](n_resynced))
        return 0
    _md_emerg0("[md] PASS bitmap-partial-resync\n")

    # CONSISTENT: the 3 dirty regions on member1 (mdback3) must now byte-match
    # member0 (mdback2). Read each region raw from both members and compare.
    rs: uint64 = _MD_BM_REGION_SECTORS
    if blk_read_sectors(b2, 2 * rs, rs, &_md_bm_raw[0]) != 0 \
            or blk_read_sectors(b3, 2 * rs, rs, &_md_bm_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap raw read region2\n")
        return 0
    if _md_buf_eq(&_md_bm_raw[0], &_md_bm_read[0], rs * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: bitmap region2 inconsistent after resync\n")
        return 0
    if blk_read_sectors(b2, 5 * rs, rs, &_md_bm_raw[0]) != 0 \
            or blk_read_sectors(b3, 5 * rs, rs, &_md_bm_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap raw read region5\n")
        return 0
    if _md_buf_eq(&_md_bm_raw[0], &_md_bm_read[0], rs * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: bitmap region5 inconsistent after resync\n")
        return 0
    if blk_read_sectors(b2, 20 * rs, rs, &_md_bm_raw[0]) != 0 \
            or blk_read_sectors(b3, 20 * rs, rs, &_md_bm_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap raw read region20\n")
        return 0
    if _md_buf_eq(&_md_bm_raw[0], &_md_bm_read[0], rs * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: bitmap region20 inconsistent after resync\n")
        return 0
    _md_emerg0("[md] PASS bitmap-consistent-after-resync\n")

    # PROOF the resync was PARTIAL, not a whole-device copy: an UNTOUCHED
    # region (region 10) on the wiped member1 must STILL be zero — the
    # bitmap resync never copied it. Compare against an all-zero region.
    z: uint64 = 0
    while z < rs * SECTOR_SIZE:
        _md_bm_pat[z] = 0
        z = z + 1
    if blk_read_sectors(b3, 10 * rs, rs, &_md_bm_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap raw read clean region10\n")
        return 0
    if _md_buf_eq(&_md_bm_pat[0], &_md_bm_read[0], rs * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: bitmap clean region was resynced (not partial)\n")
        return 0

    # The bitmap must be ALL-CLEAR after the resync (every dirty region was
    # resynced and its bit cleared).
    if md_bitmap_count_dirty(dev) != 0:
        _md_emerg0("[mdraid] FAIL: bitmap not clear after resync\n")
        return 0
    _md_emerg0("[md] bitmap PASS\n")

    md_remove("mdbm")
    return 1


# =========================================================================
# Bad-block-list self-test (md "struct badblocks")
# =========================================================================
#
# Proves the per-member bad-block list: insert/merge/clear of sorted ranges
# (genuinely computed), a RAID1 read over a bad block served from the MIRROR
# (member stays non-Faulty), clear-on-successful-write, and a RAID5 bad-block
# read reconstructed via PARITY. This is the whole point of bad-block lists vs
# whole-device failure: a device with recorded bad blocks but good remaining
# sectors stays IN the array and keeps serving good I/O.

# Scratch for the bad-block self-test. The RAID1 leg moves up to 4 sectors
# (2 KiB) per array op; the RAID5 leg moves a full 4-sector chunk (2 KiB) and
# a 16-sector readback (8 KiB). Size every buffer to its largest transfer so a
# read/write never overflows into the next module-scope global (the BSS
# overflow trap). Module-scope per the Adder large-array quirk.
_md_bb_pat:    Array[8192, uint8]   # pattern written through an array (<=16s)
_md_bb_read:   Array[8192, uint8]   # readback through an array (<=16s)
_md_bb_raw:    Array[2048, uint8]   # raw per-member read (<=4-sector chunk)
_md_bb_junk:   Array[2048, uint8]   # corruption pattern stamped under a bad blk
_md_slotsbb:   Array[8, int32]


_md_bb_unit_mem: MdMember


def _md_badblocks_unit() -> int32:
    # Unit-test the sorted insert/merge/check/clear math against a standalone
    # MdMember (no array I/O). Returns 1 PASS / 0 FAIL.
    mem: Ptr[MdMember] = &_md_bb_unit_mem
    mem[0].bb_n = 0
    # Empty list: nothing intersects.
    if md_badblocks_check(mem, 0, 100) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks empty check\n")
        return 0
    # Insert [100,4]. One range; a query inside hits, outside misses.
    md_badblocks_set(mem, 100, 4)
    if md_badblocks_count(mem) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks first insert count\n")
        return 0
    if md_badblocks_check(mem, 102, 1) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks inside-hit\n")
        return 0
    if md_badblocks_check(mem, 50, 10) != 0 \
            or md_badblocks_check(mem, 104, 4) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks outside-miss\n")
        return 0
    # Insert [104,4] — ADJACENT to [100,4) (end 104 == start 104): must MERGE
    # into a single [100,8) range, NOT add a second range.
    md_badblocks_set(mem, 104, 4)
    if md_badblocks_count(mem) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks adjacent-merge count\n")
        return 0
    if mem[0].bb[0].start != 100 or mem[0].bb[0].count != 8:
        _md_emerg1("[mdraid] FAIL: badblocks adjacent-merge range start=%d\n",
                   mem[0].bb[0].start)
        return 0
    _md_emerg0("[mdraid] badblocks: adjacent ranges merge OK\n")
    # Insert [106,6] — OVERLAPS [100,8): must extend to [100,12), still one.
    md_badblocks_set(mem, 106, 6)
    if md_badblocks_count(mem) != 1 or mem[0].bb[0].start != 100 \
            or mem[0].bb[0].count != 12:
        _md_emerg0("[mdraid] FAIL: badblocks overlap-merge\n")
        return 0
    _md_emerg0("[mdraid] badblocks: overlapping ranges merge OK\n")
    # Insert a DISJOINT [200,4): two ranges, kept sorted.
    md_badblocks_set(mem, 200, 4)
    if md_badblocks_count(mem) != 2 or mem[0].bb[0].start != 100 \
            or mem[0].bb[1].start != 200:
        _md_emerg0("[mdraid] FAIL: badblocks disjoint sorted insert\n")
        return 0
    # Insert a range BEFORE both ([10,2]): must sort to index 0.
    md_badblocks_set(mem, 10, 2)
    if md_badblocks_count(mem) != 3 or mem[0].bb[0].start != 10 \
            or mem[0].bb[1].start != 100 or mem[0].bb[2].start != 200:
        _md_emerg0("[mdraid] FAIL: badblocks sorted head insert\n")
        return 0
    _md_emerg0("[mdraid] badblocks: sorted insert keeps order OK\n")
    # Bridging insert [112,88] joins [100,12) and [200,4) into [100,104):
    # spans the gap and touches both -> they coalesce into ONE range.
    md_badblocks_set(mem, 112, 88)
    # [100,12)=100..112 ; [112,88)=112..200 ; [200,4)=200..204 -> all touch ->
    # one range [100,204) plus the disjoint [10,2). Count must be 2.
    if md_badblocks_count(mem) != 2 or mem[0].bb[1].start != 100 \
            or mem[0].bb[1].count != 104:
        _md_emerg1("[mdraid] FAIL: badblocks bridging-merge count=%d\n",
                   md_badblocks_count(mem))
        return 0
    _md_emerg0("[mdraid] badblocks: bridging insert coalesces OK\n")
    # CLEAR a sub-range in the MIDDLE of [100,204): clear [120,10) -> SPLIT
    # into [100,120) and [130,74). Plus the untouched [10,2). Count = 3.
    if md_badblocks_clear(mem, 120, 10) < 0:
        _md_emerg0("[mdraid] FAIL: badblocks clear rc\n")
        return 0
    if md_badblocks_count(mem) != 3:
        _md_emerg1("[mdraid] FAIL: badblocks middle-clear split count=%d\n",
                   md_badblocks_count(mem))
        return 0
    # The cleared hole must now read as GOOD; the surrounding parts bad.
    if md_badblocks_check(mem, 122, 4) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks cleared hole still bad\n")
        return 0
    if md_badblocks_check(mem, 110, 4) != 1 \
            or md_badblocks_check(mem, 132, 4) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks split halves not bad\n")
        return 0
    _md_emerg0("[md] PASS badblocks-list-merge-clear\n")
    return 1


def _md_badblocks_test(b0: int32, b1: int32, b2: int32) -> int32:
    # End-to-end: RAID1 mirror read around a bad block + clear-on-write, then
    # a RAID5 parity-reconstructed bad-block read. mdback0/mdback1/mdback2.
    # Returns 1 PASS / 0 FAIL.
    _md_emerg0("[mdraid] badblocks: begin\n")
    if _md_badblocks_unit() != 1:
        return 0

    # ---------------- RAID1 leg ----------------
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    _md_slotsbb[0] = b0
    _md_slotsbb[1] = b1
    rb: int32 = md_create_raid1("mdbb", &_md_slotsbb[0], 2)
    if rb < 0:
        _md_emerg1("[mdraid] FAIL: badblocks md_create_raid1 rc=%d\n",
                   cast[uint64](cast[int64](rb)))
        return 0
    dev: Ptr[MdArray] = _md_bm_dev("mdbb")
    if cast[uint64](dev) == 0:
        _md_emerg0("[mdraid] FAIL: badblocks dev lookup\n")
        return 0

    # Write a known 4-sector pattern at vLBA 10..13 — lands on BOTH members.
    _md_fill(&_md_bb_pat[0], 4 * SECTOR_SIZE, 1313)
    if blk_write_sectors(rb, 10, 4, &_md_bb_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 seed write\n")
        return 0

    # Record a BAD BLOCK on member0 (mdback0) covering vLBA 11..12, and stamp
    # GARBAGE under it so a read that wrongly used member0 would mismatch —
    # proving the read truly routes to the mirror (member1).
    if md_badblocks_set(&dev[0].members[0], 11, 2) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 set\n")
        return 0
    if md_badblocks_check(&dev[0].members[0], 11, 1) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 check after set\n")
        return 0
    _md_fill(&_md_bb_junk[0], 2 * SECTOR_SIZE, 9999)
    if blk_write_sectors(b0, 11, 2, &_md_bb_junk[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 corrupt member0\n")
        return 0

    # Member0 must remain NON-Faulty — a bad block does NOT fail the device.
    if dev[0].members[0].failed != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 member wrongly Faulty\n")
        return 0
    _md_emerg0("[mdraid] badblocks raid1: member stays non-Faulty OK\n")

    # Read vLBA 10..13 THROUGH the array. The bad sub-range 11..12 must be
    # served from the mirror (member1), so the whole 4-sector read matches the
    # ORIGINAL pattern despite member0's media being garbage there.
    if blk_read_sectors(rb, 10, 4, &_md_bb_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 read\n")
        return 0
    if _md_buf_eq(&_md_bb_pat[0], &_md_bb_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 read mismatch (mirror not used)\n")
        return 0
    _md_emerg0("[md] PASS badblocks-raid1-read-via-mirror\n")

    # CLEAR-ON-SUCCESSFUL-WRITE: write a NEW pattern over the bad range
    # vLBA 11..12 through the array. The write succeeds on member0, so the
    # bad-block record for that range is CLEARED and member0 physically holds
    # the new data.
    _md_fill(&_md_bb_pat[0], 2 * SECTOR_SIZE, 1414)
    if blk_write_sectors(rb, 11, 2, &_md_bb_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid1 clearing write\n")
        return 0
    if md_badblocks_check(&dev[0].members[0], 11, 2) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks not cleared after good write\n")
        return 0
    if md_badblocks_count(&dev[0].members[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks list not empty after clear\n")
        return 0
    # member0 (mdback0) physically holds the new data at 11..12 now.
    if blk_read_sectors(b0, 11, 2, &_md_bb_raw[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raw read member0 after clear\n")
        return 0
    if _md_buf_eq(&_md_bb_pat[0], &_md_bb_raw[0], 2 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks member0 missing data after clear\n")
        return 0
    _md_emerg0("[md] PASS badblocks-clear-on-write\n")

    md_remove("mdbb")

    # ---------------- RAID5 leg ----------------
    # RAID5 over mdback0,1,2 (chunk=4). Write a 16-sector pattern, record a
    # bad block on a DATA member, corrupt its backing, and prove the read is
    # reconstructed via PARITY (member stays non-Faulty).
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store0[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store1[0]))
    _md_zero_store(cast[Ptr[uint8]](&_md_back_store2[0]))
    _md_slotsbb[0] = b0
    _md_slotsbb[1] = b1
    _md_slotsbb[2] = b2
    r5: int32 = md_create_raid5("mdbb5", &_md_slotsbb[0], 3, 4)
    if r5 < 0:
        _md_emerg1("[mdraid] FAIL: badblocks md_create_raid5 rc=%d\n",
                   cast[uint64](cast[int64](r5)))
        return 0
    dev5: Ptr[MdArray] = _md_bm_dev("mdbb5")
    if cast[uint64](dev5) == 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 dev lookup\n")
        return 0
    _md_fill(&_md_bb_pat[0], 16 * SECTOR_SIZE, 1515)
    if blk_write_sectors(r5, 0, 16, &_md_bb_pat[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 seed write\n")
        return 0
    # Stripe0 geometry (N=3): pd=2 (mdback2=P); D0 (didx0) on member
    # (2+1)%3=0 (mdback0) at member-LBA stripe*chunk+off = 0. Record a bad
    # block on member0 (data member of stripe0/D0) for member-LBA 0..3, and
    # corrupt mdback0's first chunk so a direct read would be garbage.
    if md_badblocks_set(&dev5[0].members[0], 0, 4) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 set\n")
        return 0
    _md_fill(&_md_bb_junk[0], 4 * SECTOR_SIZE, 8888)
    if blk_write_sectors(b0, 0, 4, &_md_bb_junk[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 corrupt member0\n")
        return 0
    # Member0 must stay NON-Faulty.
    if dev5[0].members[0].failed != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 member wrongly Faulty\n")
        return 0
    # Read vLBA 0..3 (stripe0/D0 — the bad chunk) through the array. It must
    # be reconstructed via parity (P XOR D1) and match the ORIGINAL pattern,
    # NOT the corrupted media on mdback0.
    if blk_read_sectors(r5, 0, 4, &_md_bb_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 read\n")
        return 0
    if _md_buf_eq(&_md_bb_pat[0], &_md_bb_read[0], 4 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 read mismatch (parity not used)\n")
        return 0
    _md_emerg0("[md] PASS badblocks-raid5-read-via-parity\n")
    # And the rest of the array (the good chunks) still reads correctly while
    # member0 carries a bad block — proving good I/O continues.
    if blk_read_sectors(r5, 0, 16, &_md_bb_read[0]) != 0:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 full read\n")
        return 0
    if _md_buf_eq(&_md_bb_pat[0], &_md_bb_read[0], 16 * SECTOR_SIZE) != 1:
        _md_emerg0("[mdraid] FAIL: badblocks raid5 full read mismatch\n")
        return 0
    _md_emerg0("[mdraid] badblocks raid5: good sectors still served OK\n")

    md_remove("mdbb5")
    _md_emerg0("[md] badblocks PASS\n")
    return 1

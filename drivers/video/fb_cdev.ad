# drivers/video/fb_cdev.ad
#
# hamUI Phase 4c — the /dev/fb character device (presentation half).
#
# Exposes the already-live linear framebuffer (brought up by
# drivers/video/console/fb_text.ad's fb_init from the loader handoff)
# as a single readable/writable cdev so userland can put real pixels on
# the physical display:
#
#   READ  /dev/fb  -> one text line "WIDTH HEIGHT PITCH BPP PIXFMT\n"
#                     so userland can size its frame. Snapshot-once:
#                     the line is delivered on the off==0 read and a
#                     subsequent read reports EOF, so `cat /dev/fb`
#                     terminates.
#
#   WRITE /dev/fb  <- RGBA8888 bytes (row-major, byte order R,G,B,A),
#                     one screen frame of WIDTH x HEIGHT pixels. The
#                     write is OFFSET-ADDRESSED: a chunked writer
#                     streaming the frame composes correctly because the
#                     byte at file offset `off` is screen pixel
#                     (off/4 % WIDTH, off/4 / WIDTH). Each pixel is
#                     repacked to the hardware pixel order per fb_pixfmt
#                     and stored honouring fb_pitch. Out-of-frame pixels
#                     are clipped/ignored safely.
#
# THIS IS PURELY AN ADDITIVE CONSUMER of fb_text.ad's geometry globals
# via its fb_get_* accessors and fb_present_rgba_row STORE helper. It
# touches NONE of fb_init / the text console / the boot path.
#
# ADDER QUIRKS HONOURED
#   * No module-scope mutable nested Arrays; the per-pixel staging path
#     writes straight through to the framebuffer (no big staging buffer
#     needed — we present each pixel as it lands).
#   * Decimal formatting is hand-rolled (no libc).
#   * Leading-underscore top-level names are module-private.

from drivers.video.console.fb_text import (
    fb_get_initialized, fb_get_width, fb_get_height,
    fb_get_pitch, fb_get_bpp, fb_get_pixfmt, fb_get_base,
    fb_present_rgba_row, fb_init, FB_PIXFMT_RGB,
    fb_console_suspend, fb_console_resume, fb_console_is_suspended,
)
from kernel.printk.printk import printk0
# Dirty-rectangle present (P4d) reads the changed rectangle's pixels from
# the compositor's own RGBA source buffer in ITS address space, so it
# must walk the current task's page tables via copy_from_user.
from mm.uaccess import copy_from_user
# P0b: the framebuffer-takeover verb ALSO grabs the physical console
# input for the compositor's pid, so the boot/login hamsh sharing
# /dev/cons cannot race the DE for keystrokes.
from kernel.sched.core import (
    console_input_grab, console_input_ungrab, current_task_pid,
)


# --- geometry render -------------------------------------------------

def _fbdev_u64_to_dec(value: uint64, out: Ptr[uint8]) -> uint64:
    if value == 0:
        out[0] = 48                                 # '0'
        return 1
    digits: Array[24, uint8]
    n: uint64 = 0
    v: uint64 = value
    while v != 0:
        digits[n] = cast[uint8](v % 10) + 48
        v = v / 10
        n = n + 1
    written: uint64 = n
    i: uint64 = 0
    while n > 0:
        n = n - 1
        out[i] = digits[n]
        i = i + 1
    return written


def _fbdev_render_geometry(out: Ptr[uint8]) -> uint64:
    # "WIDTH HEIGHT PITCH BPP PIXFMT\n"
    pos: uint64 = 0
    pos = pos + _fbdev_u64_to_dec(fb_get_width(), &out[pos])
    out[pos] = 32
    pos = pos + 1
    pos = pos + _fbdev_u64_to_dec(fb_get_height(), &out[pos])
    out[pos] = 32
    pos = pos + 1
    pos = pos + _fbdev_u64_to_dec(fb_get_pitch(), &out[pos])
    out[pos] = 32
    pos = pos + 1
    pos = pos + _fbdev_u64_to_dec(fb_get_bpp(), &out[pos])
    out[pos] = 32
    pos = pos + 1
    pos = pos + _fbdev_u64_to_dec(cast[uint64](fb_get_pixfmt()), &out[pos])
    out[pos] = 10                                    # '\n'
    pos = pos + 1
    return pos


def devfb_read(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # Snapshot-once geometry line. namec gates off>0 -> EOF (see the
    # DEV_FB branch in _devtab_read), so this just renders the line and
    # copies the [off, off+count) window.
    if count == 0:
        return 0
    if fb_get_initialized() == 0:
        return -2                                    # -ENOENT: no fb
    scratch: Array[64, uint8]
    n: uint64 = _fbdev_render_geometry(&scratch[0])
    if off >= n:
        return 0
    remaining: uint64 = n - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[off + i]
        i = i + 1
    return cast[int64](take)


# --- frame write -----------------------------------------------------
#
# The instrumentation counters below back the test's kernel-side marker
# fallback (a [fb_present] log line) when QEMU `screendump` is too flaky
# in the harness. They record the total pixels presented since boot and
# the screen coords + packed colour of the first non-zero pixel seen.
fbdev_present_pixels: uint64 = 0
fbdev_first_nonzero_seen: int32 = 0
fbdev_first_nonzero_x: uint64 = 0
fbdev_first_nonzero_y: uint64 = 0
fbdev_first_nonzero_r: uint8 = 0
fbdev_first_nonzero_g: uint8 = 0
fbdev_first_nonzero_b: uint8 = 0


def _fbdev_note_pixel(x: uint64, y: uint64,
                      r: uint8, g: uint8, b: uint8):
    fbdev_present_pixels = fbdev_present_pixels + 1
    if fbdev_first_nonzero_seen == 0:
        if r != 0 or g != 0 or b != 0:
            fbdev_first_nonzero_seen = 1
            fbdev_first_nonzero_x = x
            fbdev_first_nonzero_y = y
            fbdev_first_nonzero_r = r
            fbdev_first_nonzero_g = g
            fbdev_first_nonzero_b = b


def devfb_write(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # Present RGBA8888 bytes to the screen. The source frame is exactly
    # WIDTH x HEIGHT pixels (the geometry the read side reported), so the
    # byte at file offset `off` is screen pixel index (off/4). We blit
    # whole pixels only; a chunked write whose [off, off+count) span does
    # not start/end on a 4-byte boundary still composes because the next
    # write resumes at the carried offset. Partial trailing bytes (<4)
    # are accepted (counted as consumed) but not painted until the rest
    # of that pixel arrives in a later write at the matching offset.
    if fb_get_initialized() == 0:
        return -2
    if count == 0:
        return 0
    # DE-perf cursor decouple: every devfb_write is a compositor blit that
    # may overlap (and would overwrite) the kernel-overlay cursor sprite.
    # Erase the sprite first so the OLD saved underlay lands back on screen
    # before the compositor's pixels arrive; redraw on top after the write
    # so the cursor stays on top of the freshly-presented frame.
    was_visible_fb: int32 = kcur_visible
    _kcursor_erase()
    w: uint64 = fb_get_width()
    h: uint64 = fb_get_height()
    if w == 0 or h == 0:
        return -2
    total_pixels: uint64 = w * h
    # First whole pixel fully covered by this write.
    first_pix: uint64 = (off + 3) / 4                # ceil(off/4)
    # Byte offset of that pixel's first byte.
    pbyte: uint64 = first_pix * 4
    i: uint64 = pbyte - off                          # index into buf
    pix: uint64 = first_pix
    while i + 3 < count and pix < total_pixels:
        px: uint64 = pix % w
        py: uint64 = pix / w
        r: uint8 = buf[i]
        g: uint8 = buf[i + 1]
        b: uint8 = buf[i + 2]
        # Present this single pixel via the fb_text STORE helper. We
        # treat `buf` advanced to this pixel as a 1-pixel-wide source
        # row (src_pitch_px = 1, src_y = 0, w = 1).
        fb_present_rgba_row(0, px, py, 1, &buf[i], 1)
        _fbdev_note_pixel(px, py, r, g, b)
        i = i + 4
        pix = pix + 1
    # DE-perf cursor decouple: redraw the kernel cursor on top of the
    # freshly-presented frame (no-op if the cursor was hidden).
    if was_visible_fb != 0:
        _kcursor_redraw()
    # Report the whole write as consumed (including any leading/trailing
    # partial-pixel bytes) so a streaming writer advances its cursor by
    # the full count and the next chunk lands at the right offset.
    return cast[int64](count)


# --- instrumentation accessors (test marker fallback) ---------------

def devfb_present_count() -> uint64:
    return fbdev_present_pixels


def devfb_first_nonzero_seen() -> int32:
    return fbdev_first_nonzero_seen


def devfb_first_nonzero_x() -> uint64:
    return fbdev_first_nonzero_x


def devfb_first_nonzero_y() -> uint64:
    return fbdev_first_nonzero_y


def devfb_first_nonzero_r() -> uint8:
    return fbdev_first_nonzero_r


def devfb_first_nonzero_g() -> uint8:
    return fbdev_first_nonzero_g


def devfb_first_nonzero_b() -> uint8:
    return fbdev_first_nonzero_b


# --- /dev/fbpix : framebuffer pixel READ-BACK (hamshot) -------------
#
# The screenshot leaf. /dev/fb's read side is the one-line geometry
# string (snapshot-once, unchanged); /dev/fbpix is the RAW PIXEL
# CONTENTS of the live framebuffer as a plain finite file:
#
#   READ /dev/fbpix at byte offset `off` -> up to `count` raw
#   framebuffer bytes starting at fb_base + off, in the hardware's own
#   layout (fb_pitch bytes per scanline, fb_bpp bits per pixel, byte
#   order per fb_pixfmt — typically 32-bit BGRX on the GOP path). The
#   file's size is fb_pitch * fb_height; a read at or past that is EOF
#   (0), so `cat`/a chunked reader terminates naturally. Reads never
#   mutate anything.
#
# Userland (user/hamshot.ad) reads the geometry line from /dev/fb to
# learn WIDTH/HEIGHT/PITCH/BPP/PIXFMT, then streams this file row by
# row and converts to P6 PPM. The render paths' write-only WC
# discipline is untouched — this is the one deliberate framebuffer
# LOAD path, latency-tolerant by nature (a screenshot is one-shot).
#
# Write side: read-only, writes are rejected (-1), mirroring
# devaudioin_write's read-only contract.

def devfbpix_size() -> uint64:
    # The pixel file's byte size: pitch * height (pitch already includes
    # any per-scanline hardware padding, so this is exactly the span of
    # mapped scanout bytes a reader may touch).
    if fb_get_initialized() == 0:
        return 0
    return fb_get_pitch() * fb_get_height()


def devfbpix_read(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    if fb_get_initialized() == 0:
        return -2                                    # -ENOENT: no fb
    total: uint64 = devfbpix_size()
    base: uint64 = fb_get_base()
    if total == 0 or base == 0:
        return -2
    if off >= total:
        return 0                                     # EOF past the end
    take: uint64 = count
    remaining: uint64 = total - off
    if take > remaining:
        take = remaining
    src: Ptr[uint8] = cast[Ptr[uint8]](base + off)
    i: uint64 = 0
    while i < take:
        buf[i] = src[i]
        i = i + 1
    return cast[int64](take)


def devfbpix_write(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # /dev/fbpix is read-only — presentation goes through /dev/fb.
    return -1


# --- /dev/fbctl : console-takeover control (P0a) --------------------
#
# A userland compositor (hamUId) writes a verb to claim/release the
# linear framebuffer exclusively:
#
#   "suspend"  -> stop the boot text console / printk from drawing to
#                 the framebuffer (so console text never tears through
#                 the composited desktop). hamUId calls this once when
#                 it opens /dev/fb for presentation.
#   "resume"   -> restore the text console (repaints the saved console
#                 grid). hamUId calls this on exit so the boot shell is
#                 visible again.
#
# Leading/trailing whitespace and a trailing newline are tolerated so
# `echo suspend > /dev/fbctl` works. Reads return the current state line.

def _fbctl_match(buf: Ptr[uint8], count: uint64, word: Ptr[uint8],
                 wlen: uint64) -> int32:
    # 1 iff the first wlen non-skipped bytes of buf equal `word` and the
    # remainder is only whitespace/newline/NUL. Leading spaces/tabs are
    # skipped.
    i: uint64 = 0
    while i < count and (buf[i] == 32 or buf[i] == 9):
        i = i + 1
    j: uint64 = 0
    while j < wlen:
        if i >= count:
            return 0
        if buf[i] != word[j]:
            return 0
        i = i + 1
        j = j + 1
    # trailing must be whitespace / newline / NUL only
    while i < count:
        c: uint8 = buf[i]
        if c != 32 and c != 9 and c != 10 and c != 13 and c != 0:
            return 0
        i = i + 1
    return 1


# --- dirty-rectangle present (P4d) ----------------------------------
#
# Today /dev/fb only supports presenting a WHOLE frame (offset-addressed
# RGBA8888, WIDTH x HEIGHT). For a software compositor that re-renders
# only a few changed windows per frame, blitting the entire screen every
# frame is pure waste — the changed area is usually a tiny fraction of
# the screen.
#
# This adds a SUB-RECTANGLE present path as a binary control command on
# /dev/fbctl. The caller writes a fixed 52-byte little-endian header that
# names a rectangle in ITS OWN RGBA8888 source frame and where to land it
# on screen; the kernel copies ONLY that rectangle's pixels (row by row,
# fetched from the caller's address space via copy_from_user) straight to
# scanout via the same fb_present_rgba_row STORE helper the full-frame
# path uses. No persistent state, no cross-process protocol — it is a
# one-shot "present this rectangle now" kernel capability.
#
# Header layout (all little-endian, offsets in bytes):
#   +0   u32  magic = 0x54434552  ('RECT' as LE bytes R,E,C,T)
#   +4   u32  dst_x        screen column of the rectangle's left edge
#   +8   u32  dst_y        screen row    of the rectangle's top edge
#   +12  u32  w            rectangle width  in pixels
#   +16  u32  h            rectangle height in pixels
#   +20  u64  src_ptr      user-virtual base of the source RGBA8888 frame
#   +28  u64  src_pitch_px pixels per source row (the source frame width)
#   +36  u64  src_x0       source column of the rectangle's left edge
#   +44  u64  src_y0       source row    of the rectangle's top edge
# Total: 52 bytes. The magic disambiguates this from the text verbs
# ("suspend"/"resume"), whose first bytes are ASCII letters and can never
# collide with the 0x54434552 magic.
#
# The full-frame /dev/fb write path is UNTOUCHED: a caller that never
# emits a RECT command behaves exactly as before. Out-of-screen / out-of-
# source pixels are clipped by fb_present_rgba_row (screen side) and by
# the clamps below (source side), so a bad rectangle can never scribble
# outside scanout.
FBCTL_RECT_MAGIC:  uint32 = 0x54434552         # 'R','E','C','T' LE
FBCTL_RECT_HDRLEN: uint64 = 52

# Staging buffer for the source pixels copied out of the caller's address
# space. Sized at 65536 bytes = 16384 RGBA pixels. For a sub-width rect
# this holds one row (tiled in FBCTL_ROW_MAXPX-pixel chunks when a single
# row is wider than the buffer). For the full-width contiguous FAST PATH
# (src_x0==0, w==fb_width, src_pitch_px==fb_width) the rectangle's rows are
# contiguous in the source frame, so we coalesce SEVERAL whole rows into one
# copy_from_user (cutting the per-row page-table-walk + fault-resolve setup
# cost) and then blast them back-to-back to the write-combining framebuffer.
FBCTL_SCRATCH_BYTES: uint64 = 65536
FBCTL_ROW_MAXPX:     uint64 = 16384            # FBCTL_SCRATCH_BYTES / 4
fbctl_row_scratch: Array[65536, uint8]

# Instrumentation: number of dirty-rect presents and total rows blitted,
# so a test can confirm the path ran without a screendump. A REJECTED
# (malformed / out-of-bounds) rect bumps neither presents nor rows, and
# additionally fbctl_rect_rejects so a test can prove it was actively
# refused rather than silently clipped.
fbctl_rect_presents: uint64 = 0
fbctl_rect_rows:     uint64 = 0
fbctl_rect_rejects:  uint64 = 0


def devfbctl_rect_present_count() -> uint64:
    return fbctl_rect_presents


def devfbctl_rect_rows_count() -> uint64:
    return fbctl_rect_rows


def devfbctl_rect_reject_count() -> uint64:
    return fbctl_rect_rejects


def _fbctl_is_rect(buf: Ptr[uint8], count: uint64) -> int32:
    # 1 iff buf begins with the RECT magic AND carries a full header.
    if count < FBCTL_RECT_HDRLEN:
        return 0
    magic: uint32 = cast[Ptr[uint32]](&buf[0])[0]
    if magic == FBCTL_RECT_MAGIC:
        return 1
    return 0


# Decoded + validated RECT geometry. _fbctl_rect_validate() fills this in
# and returns 1 (accept) or 0 (reject); on accept w/h are already clamped to
# the screen. Returning the result through a module-scope record keeps the
# validation as ONE pure, separately-testable function (no multi-value
# return in Adder) that BOTH the live copy_from_user path and the kernel-
# source self-test path funnel through, so the bounds proof covers the real
# code.
fbv_dst_x: uint64 = 0
fbv_dst_y: uint64 = 0
fbv_w:     uint64 = 0
fbv_h:     uint64 = 0
fbv_src_pitch_px: uint64 = 0
fbv_src_x0:       uint64 = 0
fbv_src_y0:       uint64 = 0
fbv_full_width:   int32  = 0     # 1 iff the coalescible full-width fast path

# u64 overflow-safe "a + b would wrap" predicate (1 iff a + b > U64_MAX).
def _fbctl_add_overflows(a: uint64, b: uint64) -> int32:
    # 0xFFFFFFFFFFFFFFFF - a is the headroom left before wrapping.
    if b > (0xFFFFFFFFFFFFFFFF - a):
        return 1
    return 0


# u64 overflow-safe "a * b would wrap" predicate (1 iff a * b > U64_MAX).
def _fbctl_mul_overflows(a: uint64, b: uint64) -> int32:
    if a == 0 or b == 0:
        return 0
    if a > (0xFFFFFFFFFFFFFFFF / b):
        return 1
    return 0


def _fbctl_rect_validate(dst_x: uint64, dst_y: uint64, w: uint64, h: uint64,
                         src_ptr: uint64, src_pitch_px: uint64,
                         src_x0: uint64, src_y0: uint64) -> int32:
    # HARDENING — every field is attacker-controllable (it arrived through a
    # userland write -> copy_from_user). Reject anything that could scribble
    # past the framebuffer, overflow the source-offset arithmetic, or read
    # outside the named source frame. On accept, fbv_* hold the (clamped)
    # geometry and fbv_full_width flags the contiguous fast path. Returns 1
    # = accept, 0 = reject. Pure: no I/O, no globals beyond fbv_* outputs.
    scr_w: uint64 = fb_get_width()
    scr_h: uint64 = fb_get_height()
    if scr_w == 0 or scr_h == 0:
        return 0
    # Degenerate / null geometry: nothing to present.
    if w == 0 or h == 0 or src_ptr == 0 or src_pitch_px == 0:
        return 0
    # Destination origin must be on-screen. (dst_x/dst_y come from u32 header
    # fields so they cannot themselves overflow a u64, but be explicit.)
    if dst_x >= scr_w or dst_y >= scr_h:
        return 0
    # Clamp the rectangle to the screen on the destination side. dst_x<scr_w
    # and dst_y<scr_h already hold, so the subtractions cannot underflow and
    # dst_x + w / dst_y + h are bounded by 2*scr (no u64 overflow).
    if dst_x + w > scr_w:
        w = scr_w - dst_x
    if dst_y + h > scr_h:
        h = scr_h - dst_y
    # The source rectangle must stay inside the caller's named frame. The
    # source frame is src_pitch_px pixels wide; its rightmost in-rect column
    # is src_x0 + w - 1, which must be < src_pitch_px. (w>=1 here.)
    if _fbctl_add_overflows(src_x0, w) != 0:
        return 0
    if src_x0 + w > src_pitch_px:
        return 0
    # Guard the per-row source byte-offset math against u64 wrap. The
    # farthest source byte we will touch is for row (src_y0 + h - 1):
    #   off = ((src_row * src_pitch_px) + (src_x0 + w - 1)) * 4
    # then usrc = src_ptr + off. Reject if ANY step would overflow, so a
    # crafted src_y0/src_pitch_px can never wrap usrc to an unintended page.
    if _fbctl_add_overflows(src_y0, h) != 0:
        return 0
    last_row: uint64 = src_y0 + h - 1
    if _fbctl_mul_overflows(last_row, src_pitch_px) != 0:
        return 0
    rowbase: uint64 = last_row * src_pitch_px
    if _fbctl_add_overflows(rowbase, src_x0 + w) != 0:
        return 0
    last_px: uint64 = rowbase + (src_x0 + w - 1)
    if _fbctl_mul_overflows(last_px, 4) != 0:
        return 0
    last_off: uint64 = last_px * 4
    # The last byte touched is src_ptr + last_off + 3 (the 4th byte of the
    # last pixel). Guard each add separately so last_off + 4 cannot itself
    # wrap and slip a bad range past the src_ptr check.
    if _fbctl_add_overflows(last_off, 4) != 0:
        return 0
    if _fbctl_add_overflows(src_ptr, last_off + 4) != 0:
        return 0
    # Accept. Publish the validated/clamped geometry.
    fbv_dst_x = dst_x
    fbv_dst_y = dst_y
    fbv_w     = w
    fbv_h     = h
    fbv_src_pitch_px = src_pitch_px
    fbv_src_x0       = src_x0
    fbv_src_y0       = src_y0
    # FAST PATH eligibility: the rectangle spans the full screen width AND
    # the full source pitch starting at source column 0, so its h rows are
    # one contiguous run of pixels in the source frame and can be fetched in
    # multi-row batches and blitted back-to-back. (w was clamped to <=scr_w;
    # for full-width it equals scr_w.)
    fbv_full_width = 0
    if src_x0 == 0 and w == scr_w and src_pitch_px == scr_w:
        fbv_full_width = 1
    return 1


def _fbctl_rect_blit_rows(src_base: Ptr[uint8], pitch_px: uint64,
                          src_x0: uint64, dst_x: uint64, dst_y0: uint64,
                          first_row: uint64, nrows: uint64, w: uint64):
    # Blit `nrows` already-fetched source rows (held in `src_base`, a
    # row-major RGBA8888 kernel buffer of `pitch_px` pixels per row) to the
    # framebuffer via the per-pixel conversion STORE helper. Row r of the
    # batch lands at screen row dst_y0 + first_row + r, reading source
    # column src_x0. This is the SINGLE conversion/blit primitive shared by
    # the live present path and the self-test, so the on-screen result is
    # bit-identical to the original per-row code.
    r: uint64 = 0
    while r < nrows:
        scr_y: uint64 = dst_y0 + first_row + r
        # src_y within this batch buffer is just `r`; the helper computes the
        # byte base as (src_y * pitch_px + src_x0) * 4 via src_y + the column
        # term, so pass src_y=r and start the source pointer at column src_x0.
        fb_present_rgba_row(r, dst_x, scr_y, w,
                            &src_base[src_x0 * 4], pitch_px)
        fbctl_rect_rows = fbctl_rect_rows + 1
        r = r + 1


def _fbctl_rect_present(buf: Ptr[uint8]) -> int64:
    # Decode the RECT header (already in a kernel buffer — the syscall
    # write path bounced it through copy_from_user) and blit the named
    # rectangle from the caller's source frame to scanout. Returns
    # FBCTL_RECT_HDRLEN (bytes consumed) on success so a streaming writer
    # advances correctly; never returns an error that would wedge the
    # writer (a degenerate/malformed rectangle is a no-op present that
    # consumes the header but presents nothing).
    if fb_get_initialized() == 0:
        return cast[int64](FBCTL_RECT_HDRLEN)
    dst_x: uint64 = cast[uint64](cast[Ptr[uint32]](&buf[4])[0])
    dst_y: uint64 = cast[uint64](cast[Ptr[uint32]](&buf[8])[0])
    w:     uint64 = cast[uint64](cast[Ptr[uint32]](&buf[12])[0])
    h:     uint64 = cast[uint64](cast[Ptr[uint32]](&buf[16])[0])
    src_ptr:      uint64 = cast[Ptr[uint64]](&buf[20])[0]
    src_pitch_px: uint64 = cast[Ptr[uint64]](&buf[28])[0]
    src_x0:       uint64 = cast[Ptr[uint64]](&buf[36])[0]
    src_y0:       uint64 = cast[Ptr[uint64]](&buf[44])[0]

    # Centralised bounds + overflow hardening. A reject is counted and the
    # header is consumed (so the writer never wedges) but NOTHING is blitted.
    if _fbctl_rect_validate(dst_x, dst_y, w, h, src_ptr, src_pitch_px,
                            src_x0, src_y0) == 0:
        fbctl_rect_rejects = fbctl_rect_rejects + 1
        return cast[int64](FBCTL_RECT_HDRLEN)

    # Read back the validated/clamped geometry.
    dst_x = fbv_dst_x
    dst_y = fbv_dst_y
    w     = fbv_w
    h     = fbv_h
    src_pitch_px = fbv_src_pitch_px
    src_x0       = fbv_src_x0
    src_y0       = fbv_src_y0

    row_bytes_fp: uint64 = w * 4
    # Only take the coalescing fast path if at least ONE full-width row fits
    # in the staging buffer; otherwise fall through to the row-tiling general
    # path (which chunks a too-wide row in FBCTL_ROW_MAXPX-pixel pieces).
    if fbv_full_width != 0 and row_bytes_fp <= FBCTL_SCRATCH_BYTES:
        # FAST PATH: full-width contiguous band. The h rows are one
        # contiguous pixel run in the source (pitch == w == scr_w, x0 == 0),
        # so coalesce as many rows as fit in the staging buffer into a single
        # copy_from_user, then blit the whole batch — fewer page-walk setups
        # and large WC bursts.
        row_bytes: uint64 = row_bytes_fp
        rows_per_batch: uint64 = FBCTL_SCRATCH_BYTES / row_bytes
        if rows_per_batch == 0:
            rows_per_batch = 1
        row: uint64 = 0
        while row < h:
            batch: uint64 = h - row
            if batch > rows_per_batch:
                batch = rows_per_batch
            # Contiguous source offset of this batch's first pixel.
            usrc: uint64 = src_ptr + ((src_y0 + row) * src_pitch_px) * 4
            nbytes: uint64 = batch * row_bytes
            residual: uint64 = copy_from_user(
                cast[uint64](&fbctl_row_scratch[0]), usrc, nbytes)
            got_rows: uint64 = batch
            if residual != 0:
                # Faulted partway — blit only the whole rows that landed.
                got_rows = (nbytes - residual) / row_bytes
            if got_rows > 0:
                _fbctl_rect_blit_rows(&fbctl_row_scratch[0], w, 0,
                                      dst_x, dst_y, row, got_rows, w)
            if residual != 0:
                break
            row = row + batch
        fbctl_rect_presents = fbctl_rect_presents + 1
        return cast[int64](FBCTL_RECT_HDRLEN)

    # GENERAL PATH: sub-width rect. Fetch + blit one source row at a time,
    # tiling the copy_from_user when a single row is wider than the staging
    # buffer. The source byte math is overflow-guarded by the validator.
    row2: uint64 = 0
    while row2 < h:
        scr_y: uint64 = dst_y + row2
        src_row: uint64 = src_y0 + row2
        col: uint64 = 0
        faulted: int32 = 0
        while col < w:
            chunk_px: uint64 = w - col
            if chunk_px > FBCTL_ROW_MAXPX:
                chunk_px = FBCTL_ROW_MAXPX
            usrc2: uint64 = src_ptr + \
                ((src_row * src_pitch_px) + (src_x0 + col)) * 4
            residual2: uint64 = copy_from_user(
                cast[uint64](&fbctl_row_scratch[0]), usrc2, chunk_px * 4)
            if residual2 != 0:
                got_px: uint64 = (chunk_px * 4 - residual2) / 4
                if got_px > 0:
                    fb_present_rgba_row(0, dst_x + col, scr_y, got_px,
                                        &fbctl_row_scratch[0], got_px)
                faulted = 1
                col = w
            else:
                fb_present_rgba_row(0, dst_x + col, scr_y, chunk_px,
                                    &fbctl_row_scratch[0], chunk_px)
                col = col + chunk_px
        fbctl_rect_rows = fbctl_rect_rows + 1
        if faulted != 0:
            row2 = h
        else:
            row2 = row2 + 1
    fbctl_rect_presents = fbctl_rect_presents + 1
    return cast[int64](FBCTL_RECT_HDRLEN)


# --- /dev/fbctl : kernel-overlay CURSOR (DE perf: cursor decouple) ---
#
# The compositor's main loop renders cursor moves on the same hot path as
# every other piece of scene work. During a window drag or a heavy popup
# present the loop can spend hundreds of ms in a full-screen recomposite,
# and the cursor sprite (a 12x12 arrow overlaid by user/hamUId.ad's
# cursor_pixel_over during scene_blit_rect) is part of THAT pass — so the
# pointer freezes whenever anything else is busy.
#
# DECOUPLE: lift the cursor sprite into the kernel as an OVERLAY layer
# that is independent of the compositor's per-frame work. Userland writes
# ONE 24-byte binary command to /dev/fbctl on every mouse pump:
#
#   Header (24 bytes, little-endian):
#     +0   u32  magic   = 0x53525543  ('C','U','R','S')
#     +4   i32  x       new cursor x (screen pixels)
#     +8   i32  y       new cursor y
#     +12  u32  visible 0 = hide cursor, 1 = show
#     +16  u32  flags   reserved (must be 0)
#     +20  u32  _pad
#
# The kernel keeps a 12x12 RGBA sprite (initialized once to the arrow
# bitmap matching the userland cursor_pixel_over mask), the current
# (kcur_x, kcur_y), and a 12x12 SAVE buffer holding the framebuffer
# pixels that the sprite is currently covering. On every CURS write:
#   1. Restore the SAVE buffer to scanout at the OLD position (erase).
#   2. Snapshot the framebuffer pixels under the NEW position into SAVE.
#   3. Blit the sprite (with its triangular mask) on top at NEW.
# That is ~288 framebuffer reads + ~288 writes (regardless of compositor
# state), runs in one short syscall, and is INDEPENDENT of any present
# the compositor is doing — so cursor latency = mouse-rx -> CURS write,
# never blocked by the compositor's slow path.
#
# COMPOSITION HOOK: the compositor's RECT and devfb_write paths can
# OVERWRITE the sprite (the kernel doesn't refuse those blits — that
# would deadlock layout). So _fbctl_rect_present and devfb_write ERASE
# the cursor BEFORE the blit (so the saved pixels they restore reflect
# the OLD compositor frame, not yet-stale overlap), let the blit land,
# then RE-DRAW the cursor on top by re-snapshotting under the sprite
# from the freshly-presented frame. Net result: the cursor sprite is
# always on top of whatever the compositor most recently drew, with the
# cursor position obeying the latest CURS write (which arrives from the
# mouse pump independently of the compositor).
FBCTL_CURS_MAGIC:  uint32 = 0x53525543         # 'C','U','R','S' LE
FBCTL_CURS_HDRLEN: uint64 = 24
KCURSOR_SPRITE_PX: uint64 = 12                 # 12 x 12 cursor sprite

# Sprite + save buffer + state. RGBA8888 layout matches the rest of the
# present pipeline. Sentinel kcur_save_valid==0 means "no pixels saved
# yet" (first draw, or after erase).
kcur_sprite_init: int32 = 0
kcur_sprite:      Array[576, uint8]            # 12*12*4 RGBA
kcur_sprite_mask: Array[144, uint8]            # 1 = opaque pixel, 0 = transparent
kcur_save:        Array[576, uint8]            # pixels under the sprite
kcur_save_valid:  int32 = 0
kcur_save_x:      int64 = 0
kcur_save_y:      int64 = 0
kcur_x:           int64 = 0
kcur_y:           int64 = 0
kcur_visible:     int32 = 0
# Instrumentation: how many CURS commands the kernel has serviced. A
# non-zero count proves the decoupled path ran end-to-end (userland ->
# kernel write -> sprite redraw on scanout), without needing a screendump.
kcur_commands:    uint64 = 0


def kcursor_command_count() -> uint64:
    return kcur_commands


def kcursor_visible() -> int32:
    return kcur_visible


def kcursor_get_x() -> int64:
    return kcur_x


def kcursor_get_y() -> int64:
    return kcur_y


def _kcursor_init_sprite():
    # Build the same 12x12 down-right arrow the userland cursor_pixel_over
    # used to draw inline: triangle mask dx<=dy, with a white outline at
    # dx==dy, dy==11, dx==0; black fill elsewhere; transparent outside.
    # Done once, lazily, so a kernel that never sees a CURS write pays no
    # memory init cost.
    if kcur_sprite_init != 0:
        return
    dy: int64 = 0
    while dy < 12:
        dx: int64 = 0
        while dx < 12:
            mi: uint64 = cast[uint64](dy * 12 + dx)
            so: uint64 = mi * 4
            if dx <= dy:
                kcur_sprite_mask[mi] = 1
                if dx == dy or dy == 11 or dx == 0:
                    kcur_sprite[so]     = 255
                    kcur_sprite[so + 1] = 255
                    kcur_sprite[so + 2] = 255
                else:
                    kcur_sprite[so]     = 0
                    kcur_sprite[so + 1] = 0
                    kcur_sprite[so + 2] = 0
                kcur_sprite[so + 3] = 255
            else:
                kcur_sprite_mask[mi] = 0
                kcur_sprite[so]     = 0
                kcur_sprite[so + 1] = 0
                kcur_sprite[so + 2] = 0
                kcur_sprite[so + 3] = 0
            dx = dx + 1
        dy = dy + 1
    kcur_sprite_init = 1


# Read one 32-bit framebuffer pixel at (sx, sy) into (r, g, b). Honours the
# hardware pixel order so the SAVE buffer holds true RGB bytes (the
# sprite's mask path then composes on top via fb_present_rgba_row, the
# canonical store helper, keeping the RGBA->FB pack identical to every
# other present). Returns 0 if the pixel is on-screen and read, else 1.
def _kcursor_fb_read_pixel(sx: uint64, sy: uint64,
                           r: Ptr[uint8], g: Ptr[uint8],
                           b: Ptr[uint8]) -> int32:
    if fb_get_initialized() == 0:
        return 1
    w: uint64 = fb_get_width()
    h: uint64 = fb_get_height()
    if sx >= w or sy >= h:
        return 1
    base: uint64 = fb_get_base()
    if base == 0:
        return 1
    pitch: uint64 = fb_get_pitch()
    bpp: uint64 = fb_get_bpp()
    if bpp == 32:
        off: uint64 = sy * pitch + sx * 4
        pix: uint32 = cast[Ptr[uint32]](base + off)[0]
        if fb_get_pixfmt() == FB_PIXFMT_RGB:
            r[0] = cast[uint8](pix & 0xff)
            g[0] = cast[uint8]((pix >> 8) & 0xff)
            b[0] = cast[uint8]((pix >> 16) & 0xff)
        else:
            b[0] = cast[uint8](pix & 0xff)
            g[0] = cast[uint8]((pix >> 8) & 0xff)
            r[0] = cast[uint8]((pix >> 16) & 0xff)
        return 0
    # 24bpp fallback: 3 bytes per pixel (B, G, R per fb_present_rgba_row).
    off2: uint64 = sy * pitch + sx * 3
    b[0] = cast[Ptr[uint8]](base + off2)[0]
    g[0] = cast[Ptr[uint8]](base + off2 + 1)[0]
    r[0] = cast[Ptr[uint8]](base + off2 + 2)[0]
    return 0


# Snapshot the 12x12 framebuffer pixels at (x0, y0) into kcur_save. After
# this _kcursor_paint() can blit the sprite on top, and _kcursor_erase()
# can later restore the exact bits we covered (so the cursor can move
# without leaving an arrow-shaped scar).
def _kcursor_save_under(x0: int64, y0: int64):
    if fb_get_initialized() == 0:
        return
    rr: Array[1, uint8]
    gg: Array[1, uint8]
    bb: Array[1, uint8]
    dy: int64 = 0
    while dy < 12:
        dx: int64 = 0
        while dx < 12:
            so: uint64 = cast[uint64](dy * 12 + dx) * 4
            sx: int64 = x0 + dx
            sy: int64 = y0 + dy
            if sx >= 0 and sy >= 0:
                if _kcursor_fb_read_pixel(cast[uint64](sx),
                                          cast[uint64](sy),
                                          &rr[0], &gg[0], &bb[0]) == 0:
                    kcur_save[so]     = rr[0]
                    kcur_save[so + 1] = gg[0]
                    kcur_save[so + 2] = bb[0]
                    kcur_save[so + 3] = 255
                else:
                    # Off-screen pixel: store a transparent marker (alpha 0)
                    # so _kcursor_restore_under leaves the FB alone here.
                    kcur_save[so + 3] = 0
            else:
                kcur_save[so + 3] = 0
            dx = dx + 1
        dy = dy + 1
    kcur_save_x = x0
    kcur_save_y = y0
    kcur_save_valid = 1


# Restore the saved 12x12 underlay back to scanout. No-op if no save has
# been taken since the last erase. Per-pixel store via fb_present_rgba_row
# (the SAME conversion helper every other present uses) keeps the RGBA->FB
# pack identical to a normal compositor write.
def _kcursor_restore_under():
    if kcur_save_valid == 0:
        return
    if fb_get_initialized() == 0:
        return
    w: uint64 = fb_get_width()
    h: uint64 = fb_get_height()
    dy: int64 = 0
    while dy < 12:
        sy: int64 = kcur_save_y + dy
        if sy >= 0 and sy < cast[int64](h):
            dx: int64 = 0
            while dx < 12:
                sx: int64 = kcur_save_x + dx
                so: uint64 = cast[uint64](dy * 12 + dx) * 4
                if sx >= 0 and sx < cast[int64](w) \
                   and kcur_save[so + 3] != 0:
                    # 1-pixel row through the canonical store helper.
                    fb_present_rgba_row(0, cast[uint64](sx),
                                        cast[uint64](sy), 1,
                                        &kcur_save[so], 1)
                dx = dx + 1
        dy = dy + 1
    kcur_save_valid = 0


# Composite the cursor sprite onto scanout at (x0, y0). Caller has already
# snapshotted the underlay via _kcursor_save_under. Only masked pixels of
# the sprite are stored (the arrow body); transparent pixels leave the FB
# alone, so the cursor is a true alpha-keyed sprite over the saved pixels.
def _kcursor_paint(x0: int64, y0: int64):
    if fb_get_initialized() == 0:
        return
    w: uint64 = fb_get_width()
    h: uint64 = fb_get_height()
    dy: int64 = 0
    while dy < 12:
        sy: int64 = y0 + dy
        if sy >= 0 and sy < cast[int64](h):
            dx: int64 = 0
            while dx < 12:
                sx: int64 = x0 + dx
                mi: uint64 = cast[uint64](dy * 12 + dx)
                if sx >= 0 and sx < cast[int64](w) \
                   and kcur_sprite_mask[mi] != 0:
                    so: uint64 = mi * 4
                    fb_present_rgba_row(0, cast[uint64](sx),
                                        cast[uint64](sy), 1,
                                        &kcur_sprite[so], 1)
                dx = dx + 1
        dy = dy + 1


# Erase the cursor sprite from scanout (restore the saved underlay). Used
# both by the CURS-move path (before moving to a new position) and by the
# composition hook (so a compositor blit lands on the un-occluded frame
# rather than over the sprite). Safe to call when nothing is drawn.
def _kcursor_erase():
    if kcur_visible == 0:
        return
    _kcursor_restore_under()


# Re-draw the cursor sprite at the CURRENT (kcur_x, kcur_y), snapshotting
# the underlay from whatever the compositor most recently presented. Used
# by the composition hook AFTER a blit so the sprite stays on top.
def _kcursor_redraw():
    if kcur_visible == 0:
        return
    _kcursor_init_sprite()
    _kcursor_save_under(kcur_x, kcur_y)
    _kcursor_paint(kcur_x, kcur_y)


# Decode a 24-byte CURS command from a kernel buffer and apply it.
# Returns FBCTL_CURS_HDRLEN bytes consumed (always, so a streaming writer
# never wedges). A degenerate position (off-screen) is accepted and the
# sprite simply clips — never an error.
def _fbctl_curs_command(buf: Ptr[uint8]) -> int64:
    if fb_get_initialized() == 0:
        return cast[int64](FBCTL_CURS_HDRLEN)
    nx: int32 = cast[Ptr[int32]](&buf[4])[0]
    ny: int32 = cast[Ptr[int32]](&buf[8])[0]
    vis: uint32 = cast[Ptr[uint32]](&buf[12])[0]
    _kcursor_init_sprite()
    # Erase whatever is currently drawn first (so the OLD save bits land
    # back on screen before we move).
    if kcur_visible != 0:
        _kcursor_restore_under()
    kcur_x = cast[int64](nx)
    kcur_y = cast[int64](ny)
    if vis != 0:
        kcur_visible = 1
        _kcursor_save_under(kcur_x, kcur_y)
        _kcursor_paint(kcur_x, kcur_y)
    else:
        kcur_visible = 0
    kcur_commands = kcur_commands + 1
    return cast[int64](FBCTL_CURS_HDRLEN)


def _fbctl_is_curs(buf: Ptr[uint8], count: uint64) -> int32:
    if count < FBCTL_CURS_HDRLEN:
        return 0
    magic: uint32 = cast[Ptr[uint32]](&buf[0])[0]
    if magic == FBCTL_CURS_MAGIC:
        return 1
    return 0


def devfbctl_write(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    if count == 0:
        return 0
    # Dirty-rectangle present: a binary RECT command (magic-tagged) blits
    # one sub-rectangle from the caller's source frame to scanout. Checked
    # BEFORE the text verbs because its leading bytes are a binary magic,
    # not ASCII — the two can never be confused. Backward compatible: a
    # caller that never emits a RECT command sees identical behaviour.
    if _fbctl_is_rect(buf, count) != 0:
        # DE-perf cursor decouple: erase the kernel cursor BEFORE the blit
        # so the saved underlay reflects the OLD compositor frame, not the
        # sprite. Then re-draw on top AFTER the blit so the cursor sits on
        # the freshly-presented pixels.
        was_visible: int32 = kcur_visible
        _kcursor_erase()
        rv: int64 = _fbctl_rect_present(buf)
        if was_visible != 0:
            _kcursor_redraw()
        return rv
    if _fbctl_is_curs(buf, count) != 0:
        return _fbctl_curs_command(buf)
    susp: Array[8, uint8]
    susp[0] = 115                                    # 's'
    susp[1] = 117                                    # 'u'
    susp[2] = 115                                    # 's'
    susp[3] = 112                                    # 'p'
    susp[4] = 101                                    # 'e'
    susp[5] = 110                                    # 'n'
    susp[6] = 100                                    # 'd'
    res: Array[8, uint8]
    res[0] = 114                                     # 'r'
    res[1] = 101                                     # 'e'
    res[2] = 115                                     # 's'
    res[3] = 117                                     # 'u'
    res[4] = 109                                     # 'm'
    res[5] = 101                                     # 'e'
    # Increment-1 (DE component-split): input OWNERSHIP is now its own
    # explicit claim, decoupled from the text-console "suspend" hack. The
    # compositor writes "grab" to take EXCLUSIVE physical-keyboard/UART
    # ownership (devcons_read for any other reader parks), and "ungrab" to
    # release it on DE exit. "suspend"/"resume" remain PURELY a text-render
    # quieting toggle. For backward compatibility "suspend" still implies a
    # grab and "resume" an ungrab, but a caller may now grab/ungrab input
    # WITHOUT touching the text console (and vice-versa), which is what makes
    # the input-ownership test independently provable.
    grab: Array[8, uint8]
    grab[0] = 103                                    # 'g'
    grab[1] = 114                                    # 'r'
    grab[2] = 97                                     # 'a'
    grab[3] = 98                                     # 'b'
    ungr: Array[8, uint8]
    ungr[0] = 117                                    # 'u'
    ungr[1] = 110                                    # 'n'
    ungr[2] = 103                                    # 'g'
    ungr[3] = 114                                    # 'r'
    ungr[4] = 97                                     # 'a'
    ungr[5] = 98                                     # 'b'
    # Order matters: test "ungrab" BEFORE "grab" (the latter is a prefix of
    # the former) so the longer verb is not mis-matched as a bare "grab".
    if _fbctl_match(buf, count, &ungr[0], 6) != 0:
        # Release ONLY the input grab — leave the text console as-is.
        console_input_ungrab(current_task_pid())
        return cast[int64](count)
    if _fbctl_match(buf, count, &grab[0], 4) != 0:
        # Claim EXCLUSIVE physical console input for this task — no change to
        # the text-console render state. This is the real input-ownership
        # mechanism Increment 1 relies on.
        console_input_grab(current_task_pid())
        return cast[int64](count)
    if _fbctl_match(buf, count, &susp[0], 7) != 0:
        # Claim the framebuffer (silence the text console) AND grab the
        # physical console input for this task (the compositor), so the
        # boot/login hamsh can't steal keystrokes typed at the DE.
        fb_console_suspend()
        console_input_grab(current_task_pid())
        return cast[int64](count)
    if _fbctl_match(buf, count, &res[0], 6) != 0:
        # Release both on DE exit.
        fb_console_resume()
        console_input_ungrab(current_task_pid())
        return cast[int64](count)
    # Unknown verb — accept (consume) but do nothing, so a stray write
    # doesn't wedge a streaming writer.
    return cast[int64](count)


def devfbctl_read(off: uint64, buf: Ptr[uint8], count: uint64) -> int64:
    # Snapshot-once state line: "suspended\n" or "active\n".
    if count == 0:
        return 0
    scratch: Array[16, uint8]
    n: uint64 = 0
    if fb_console_is_suspended() != 0:
        # "suspended\n"
        s: Array[10, uint8]
        s[0] = 115
        s[1] = 117
        s[2] = 115
        s[3] = 112
        s[4] = 101
        s[5] = 110
        s[6] = 100
        s[7] = 101
        s[8] = 100
        s[9] = 10
        while n < 10:
            scratch[n] = s[n]
            n = n + 1
    else:
        # "active\n"
        a: Array[7, uint8]
        a[0] = 97
        a[1] = 99
        a[2] = 116
        a[3] = 105
        a[4] = 118
        a[5] = 101
        a[6] = 10
        while n < 7:
            scratch[n] = a[n]
            n = n + 1
    if off >= n:
        return 0
    remaining: uint64 = n - off
    take: uint64 = count
    if take > remaining:
        take = remaining
    i: uint64 = 0
    while i < take:
        buf[i] = scratch[off + i]
        i = i + 1
    return cast[int64](take)


# --- RECT present self-test (scripts/test_fbctl_rect.sh) -------------
#
# Drives the binary RECT dirty-rectangle present path end-to-end IN KERNEL
# context (no userland, no screendump) and asserts:
#   * a VALID rect is ACCEPTED -> devfbctl_rect_present_count() increments,
#     reject count unchanged;
#   * an OUT-OF-BOUNDS rect (dst past the screen, source past the named
#     frame, and an overflow-crafted source offset) is REJECTED ->
#     reject count increments, present count unchanged, and the framebuffer
#     is NOT scribbled past its real extent;
#   * the conversion/coalescing blit core reproduces the exact RGBA->FB
#     packing the original per-row path produced (pixel-identical result);
#   * the magic-tag disambiguation still routes a 52-byte RECT to the
#     present path while the ASCII suspend/resume verbs are untouched.
#
# A small SYNTHETIC framebuffer is stood up in a kernel BSS array via
# fb_init so the test never depends on a real VBE/GOP mode (it runs under
# -nographic). copy_from_user from a kernel (US=0) source legitimately
# faults, so the "valid present" assertion checks the COUNTER path (an
# accepted rect bumps presents) while the pixel-exactness is proven against
# the synthetic FB through the same _fbctl_rect_blit_rows core the live
# path uses with an in-kernel source.

# 32 x 16 synthetic framebuffer, 32bpp -> 4*32*16 = 2048 bytes. Height must
# be >= GLYPH_H (16) and width >= GLYPH_W (8) for fb_init to accept the mode;
# 32 x 16 yields a 4 x 1 character grid, well within the fb_text grid caps.
# A guard band of sentinel bytes past the live extent catches any over-write.
FBT_W:     uint64 = 32
FBT_H:     uint64 = 16
FBT_LIVE:  uint64 = 2048                 # FBT_W * FBT_H * 4
fbt_fb:    Array[2304, uint8]            # 2048 live + 256 guard bytes
# Source frame the same 32 x 16 size, RGBA8888.
fbt_src:   Array[2048, uint8]


def _fbt_put_le32(buf: Ptr[uint8], off: uint64, v: uint32):
    buf[off]     = cast[uint8](v & 0xFF)
    buf[off + 1] = cast[uint8]((v >> 8) & 0xFF)
    buf[off + 2] = cast[uint8]((v >> 16) & 0xFF)
    buf[off + 3] = cast[uint8]((v >> 24) & 0xFF)


def _fbt_put_le64(buf: Ptr[uint8], off: uint64, v: uint64):
    k: uint64 = 0
    while k < 8:
        buf[off + k] = cast[uint8]((v >> (k * 8)) & 0xFF)
        k = k + 1


def _fbt_build_rect(hdr: Ptr[uint8], dst_x: uint32, dst_y: uint32,
                    w: uint32, h: uint32, src_ptr: uint64,
                    src_pitch_px: uint64, src_x0: uint64, src_y0: uint64):
    # Compose the exact 52-byte LE RECT header (wire format unchanged).
    _fbt_put_le32(hdr, 0, FBCTL_RECT_MAGIC)
    _fbt_put_le32(hdr, 4, dst_x)
    _fbt_put_le32(hdr, 8, dst_y)
    _fbt_put_le32(hdr, 12, w)
    _fbt_put_le32(hdr, 16, h)
    _fbt_put_le64(hdr, 20, src_ptr)
    _fbt_put_le64(hdr, 28, src_pitch_px)
    _fbt_put_le64(hdr, 36, src_x0)
    _fbt_put_le64(hdr, 44, src_y0)


def fbctl_rect_selftest() -> int32:
    # Returns 1 PASS / 0 FAIL; prints "[fbrect] ..." markers for the harness.
    printk0("[fbrect] start\n")
    fail: int32 = 0

    # Stand up the synthetic RGB framebuffer in BSS. pixfmt 0 = RGB byte
    # order (low byte = red) so the packed FB word is predictable.
    z: uint64 = 0
    while z < 2304:
        fbt_fb[z] = 0
        z = z + 1
    # Sentinel-fill the guard region (bytes FBT_LIVE..2303) so an over-write
    # is detectable: any change away from 0xAB flags scribbling past the FB.
    z = FBT_LIVE
    while z < 2304:
        fbt_fb[z] = 0xAB
        z = z + 1
    fbbase: uint64 = cast[uint64](&fbt_fb[0])
    rc: int32 = fb_init(fbbase, FBT_W * 4, FBT_W, FBT_H, 32, FB_PIXFMT_RGB)
    if rc != 0:
        printk0("[fbrect] FAIL fb_init synthetic mode rejected\n")
        return 0

    # Fill the source frame with a recognisable gradient: pixel (x,y) ->
    # R=x, G=y, B=x+y, A=0xFF.
    y: uint64 = 0
    while y < FBT_H:
        x: uint64 = 0
        while x < FBT_W:
            o: uint64 = (y * FBT_W + x) * 4
            fbt_src[o]     = cast[uint8](x)
            fbt_src[o + 1] = cast[uint8](y)
            fbt_src[o + 2] = cast[uint8](x + y)
            fbt_src[o + 3] = 0xFF
            x = x + 1
        y = y + 1
    srcbase: uint64 = cast[uint64](&fbt_src[0])

    # --- (1) magic disambiguation + accepted-rect counter via devfbctl_write
    p0: uint64 = devfbctl_rect_present_count()
    r0: uint64 = devfbctl_rect_reject_count()
    hdr: Array[52, uint8]
    # A valid full-frame rect. copy_from_user(srcbase) faults (kernel US=0
    # page), so no pixels land — but an ACCEPTED rect must bump presents.
    _fbt_build_rect(&hdr[0], 0, 0, cast[uint32](FBT_W), cast[uint32](FBT_H),
                    srcbase, FBT_W, 0, 0)
    wrc: int64 = devfbctl_write(0, &hdr[0], 52)
    if wrc != cast[int64](FBCTL_RECT_HDRLEN):
        printk0("[fbrect] FAIL valid RECT return != 52\n")
        fail = 1
    if devfbctl_rect_present_count() != p0 + 1:
        printk0("[fbrect] FAIL valid RECT did not increment presents\n")
        fail = 1
    if devfbctl_rect_reject_count() != r0:
        printk0("[fbrect] FAIL valid RECT bumped reject count\n")
        fail = 1
    else:
        printk0("[fbrect] OK valid RECT accepted (presents++)\n")

    # --- (2) OUT-OF-BOUNDS rects must be REJECTED (presents flat, rejects++)
    p1: uint64 = devfbctl_rect_present_count()
    rj1: uint64 = devfbctl_rect_reject_count()
    # (2a) destination origin off-screen.
    _fbt_build_rect(&hdr[0], cast[uint32](FBT_W), 0, 4, 4, srcbase,
                    FBT_W, 0, 0)
    devfbctl_write(0, &hdr[0], 52)
    # (2b) source rectangle wider than the named source frame (src_x0 + w >
    # src_pitch_px): would read past the source row.
    _fbt_build_rect(&hdr[0], 0, 0, 8, 4, srcbase, FBT_W, FBT_W - 2, 0)
    devfbctl_write(0, &hdr[0], 52)
    # (2c) overflow-crafted source offset: a huge src_y0 * src_pitch_px that
    # would wrap u64 and alias an unintended address.
    _fbt_build_rect(&hdr[0], 0, 0, 4, 4, srcbase,
                    0x4000000000000000, 0, 0x4000000000000000)
    devfbctl_write(0, &hdr[0], 52)
    if devfbctl_rect_present_count() != p1:
        printk0("[fbrect] FAIL OOB rect was presented\n")
        fail = 1
    if devfbctl_rect_reject_count() != rj1 + 3:
        printk0("[fbrect] FAIL OOB rects not all rejected\n")
        fail = 1
    else:
        printk0("[fbrect] OK 3 out-of-bounds rects rejected\n")
    # Guard region must still be pristine sentinel — nothing scribbled past
    # the live framebuffer.
    gz: uint64 = FBT_LIVE
    guard_ok: int32 = 1
    while gz < 2304:
        if fbt_fb[gz] != 0xAB:
            guard_ok = 0
            gz = 2304
        else:
            gz = gz + 1
    if guard_ok == 0:
        printk0("[fbrect] FAIL framebuffer over-write detected\n")
        fail = 1
    else:
        printk0("[fbrect] OK no over-write past framebuffer extent\n")

    # --- (3) pixel-exactness of the conversion/coalescing blit core.
    # Drive the SHARED _fbctl_rect_blit_rows with an in-kernel source (no
    # copy_from_user) and verify every FB word equals the RGB-packed source.
    rows0: uint64 = devfbctl_rect_rows_count()
    _fbctl_rect_blit_rows(&fbt_src[0], FBT_W, 0, 0, 0, 0, FBT_H, FBT_W)
    if devfbctl_rect_rows_count() != rows0 + FBT_H:
        printk0("[fbrect] FAIL blit core row count wrong\n")
        fail = 1
    pix_ok: int32 = 1
    yy: uint64 = 0
    while yy < FBT_H and pix_ok != 0:
        xx: uint64 = 0
        while xx < FBT_W:
            so: uint64 = (yy * FBT_W + xx) * 4
            r: uint32 = cast[uint32](fbt_src[so])
            g: uint32 = cast[uint32](fbt_src[so + 1])
            b: uint32 = cast[uint32](fbt_src[so + 2])
            want: uint32 = r | (g << 8) | (b << 16)
            fo: uint64 = yy * (FBT_W * 4) + xx * 4
            got: uint32 = cast[Ptr[uint32]](&fbt_fb[fo])[0]
            if got != want:
                pix_ok = 0
                xx = FBT_W
            else:
                xx = xx + 1
        yy = yy + 1
    if pix_ok == 0:
        printk0("[fbrect] FAIL blit core pixel mismatch\n")
        fail = 1
    else:
        printk0("[fbrect] OK blit core pixel-identical RGBA->FB pack\n")

    # --- (4) full-width fast-path eligibility flag set for a full-frame rect.
    fwv: int32 = _fbctl_rect_validate(0, 0, FBT_W, FBT_H, srcbase, FBT_W,
                                      0, 0)
    if fwv != 1 or fbv_full_width != 1:
        printk0("[fbrect] FAIL full-width fast path not selected\n")
        fail = 1
    else:
        printk0("[fbrect] OK full-width contiguous fast path selected\n")
    # A sub-width rect must NOT take the fast path.
    swv: int32 = _fbctl_rect_validate(0, 0, 4, 4, srcbase, FBT_W, 1, 1)
    if swv != 1 or fbv_full_width != 0:
        printk0("[fbrect] FAIL sub-width rect mis-flagged fast path\n")
        fail = 1
    else:
        printk0("[fbrect] OK sub-width rect uses general path\n")

    if fail != 0:
        printk0("[fbrect] FAIL\n")
        return 0
    printk0("[fbrect] PASS\n")
    return 1


# --- /dev/fbpix self-test (scripts/test_fbpix.sh) --------------------
#
# Proves the screenshot pixel-read leaf KERNEL-SIDE, deterministic and
# -nographic-safe: stands up the same synthetic BSS framebuffer the RECT
# self-test uses (fb_init on fbt_fb, 32 x 16 x 32bpp RGB), paints a known
# byte pattern, and drives devfbpix_read directly to assert:
#   * size = pitch * height exactly (2048 bytes for the synthetic mode),
#     consistent with the /dev/fb geometry line's PITCH/HEIGHT fields;
#   * a read at off==0 returns the requested count and the bytes are
#     IDENTICAL to the framebuffer contents;
#   * a read spanning the end is SHORT (returns exactly the remaining
#     bytes), and reads at/past the end return 0 (EOF) — so a chunked
#     reader terminates;
#   * a chunked walk (odd chunk size, forcing a short tail) accumulates
#     exactly `size` bytes and every byte matches the source;
#   * reading never mutates the framebuffer (re-verify after the walk);
#   * the write side is rejected (read-only contract).
#
# Markers: "[fbpix] PASS" / "[fbpix] FAIL ...". Like the RECT self-test
# it REPOINTS the text console at the synthetic FB, so it is opt-in via
# the /etc/fbpix-test cpio marker (boot:37.fbpix in init/main.ad).

fbpix_chunk: Array[256, uint8]           # read staging for the selftest


def fbpix_selftest() -> int32:
    printk0("[fbpix] start\n")
    fail: int32 = 0

    # Stand up the synthetic framebuffer (idempotent wrt the RECT test —
    # both fb_init the same BSS array; whoever runs second re-inits).
    z: uint64 = 0
    while z < 2304:
        fbt_fb[z] = 0
        z = z + 1
    z = FBT_LIVE
    while z < 2304:
        fbt_fb[z] = 0xAB                 # guard band past the live extent
        z = z + 1
    fbbase: uint64 = cast[uint64](&fbt_fb[0])
    rc: int32 = fb_init(fbbase, FBT_W * 4, FBT_W, FBT_H, 32, FB_PIXFMT_RGB)
    if rc != 0:
        printk0("[fbpix] FAIL fb_init synthetic mode rejected\n")
        return 0
    # SILENCE the text console for the duration: fb_init pointed it at the
    # synthetic framebuffer, so this test's own printk0 progress lines
    # would otherwise render glyphs INTO fbt_fb between the pattern paint
    # and the non-mutation re-check (a false "read mutated the fb"). With
    # the console suspended, printk still reaches serial but fb_putc
    # no-ops — the framebuffer only changes if a READ wrongly stores.
    fb_console_suspend()

    # Paint a recognisable pattern straight into the live extent: byte i
    # holds (i * 7 + 3) & 0xFF. (Direct stores — we are testing the READ
    # path, not the present path.)
    z = 0
    while z < FBT_LIVE:
        fbt_fb[z] = cast[uint8]((z * 7 + 3) & 0xFF)
        z = z + 1

    # (1) size = pitch * height, consistent with the geometry accessors.
    total: uint64 = devfbpix_size()
    if total != fb_get_pitch() * fb_get_height():
        printk0("[fbpix] FAIL size != pitch*height\n")
        fail = 1
    if total != FBT_LIVE:
        printk0("[fbpix] FAIL size != synthetic live extent\n")
        fail = 1
    if fail == 0:
        printk0("[fbpix] OK size = pitch*height\n")

    # (2) off==0 read returns the full requested count, bytes identical.
    n: int64 = devfbpix_read(0, &fbpix_chunk[0], 64)
    if n != 64:
        printk0("[fbpix] FAIL head read != 64\n")
        fail = 1
    else:
        k: uint64 = 0
        ok: int32 = 1
        while k < 64:
            if fbpix_chunk[k] != fbt_fb[k]:
                ok = 0
                k = 64
            else:
                k = k + 1
        if ok == 0:
            printk0("[fbpix] FAIL head read bytes mismatch\n")
            fail = 1
        else:
            printk0("[fbpix] OK head read bytes match\n")

    # (3) a read spanning the end is SHORT; at/past the end is EOF.
    n = devfbpix_read(total - 16, &fbpix_chunk[0], 64)
    if n != 16:
        printk0("[fbpix] FAIL tail read not short (want 16)\n")
        fail = 1
    n = devfbpix_read(total, &fbpix_chunk[0], 64)
    if n != 0:
        printk0("[fbpix] FAIL read at end != EOF\n")
        fail = 1
    n = devfbpix_read(total + 100, &fbpix_chunk[0], 64)
    if n != 0:
        printk0("[fbpix] FAIL read past end != EOF\n")
        fail = 1
    if fail == 0:
        printk0("[fbpix] OK short tail + EOF semantics\n")

    # (4) chunked walk with an odd chunk size: accumulates exactly
    # `total` bytes, every byte equals the framebuffer source.
    walked: uint64 = 0
    walk_ok: int32 = 1
    while True:
        got: int64 = devfbpix_read(walked, &fbpix_chunk[0], 96)
        if got < 0:
            printk0("[fbpix] FAIL chunked walk read error\n")
            fail = 1
            walk_ok = 0
            break
        if got == 0:
            break
        g: uint64 = cast[uint64](got)
        k2: uint64 = 0
        while k2 < g:
            if fbpix_chunk[k2] != fbt_fb[walked + k2]:
                walk_ok = 0
                k2 = g
            else:
                k2 = k2 + 1
        if walk_ok == 0:
            printk0("[fbpix] FAIL chunked walk bytes mismatch\n")
            fail = 1
            break
        walked = walked + g
    if walked != total and walk_ok != 0:
        printk0("[fbpix] FAIL chunked walk total != size\n")
        fail = 1
    if walk_ok != 0 and walked == total:
        printk0("[fbpix] OK chunked walk streamed size bytes exactly\n")

    # (5) reads must not mutate: pattern + guard band still intact.
    z = 0
    intact: int32 = 1
    while z < FBT_LIVE:
        if fbt_fb[z] != cast[uint8]((z * 7 + 3) & 0xFF):
            intact = 0
            z = FBT_LIVE
        else:
            z = z + 1
    z = FBT_LIVE
    while z < 2304:
        if fbt_fb[z] != 0xAB:
            intact = 0
            z = 2304
        else:
            z = z + 1
    if intact == 0:
        printk0("[fbpix] FAIL read mutated the framebuffer\n")
        fail = 1
    else:
        printk0("[fbpix] OK reads are non-mutating\n")

    # (6) read-only: the write side is rejected.
    wb: Array[4, uint8]
    wb[0] = 1
    if devfbpix_write(0, &wb[0], 4) >= 0:
        printk0("[fbpix] FAIL write was accepted on a read-only leaf\n")
        fail = 1
    else:
        printk0("[fbpix] OK write rejected (read-only)\n")

    # All comparisons done — un-silence the text console (repaints the
    # saved grid onto the synthetic fb; the framebuffer stays live for
    # the userland fixture /bin/test_fbpix + hamshot legs).
    fb_console_resume()

    if fail != 0:
        printk0("[fbpix] FAIL\n")
        return 0
    printk0("[fbpix] PASS\n")
    return 1

# drivers/video/console/fb_text.ad
#
# Linear-framebuffer text console — the EFI GOP counterpart to
# drivers/video/console/vga_text.ad. Mirrors the role of Linux's
# drivers/video/fbcon/fbcon.c (specifically the part that just blits
# 8x16 monospace glyphs into a linear framebuffer for early-boot
# printk output), trimmed to the absolute minimum.
#
# Why this exists: under UEFI boot, GRUB-EFI does NOT program the
# legacy CGA text mode at 0xB8000. Writes that vga_text.ad makes to
# that buffer succeed in RAM but the GPU is scanning out a linear
# framebuffer somewhere else — the monitor stays dark. The multiboot1
# header in arch/x86/boot/header.S now asks GRUB for a linear FB
# (mode_type=0 + bit 2 of flags); when GRUB-EFI honours that, the
# multiboot info struct comes back populated at offsets 88..109 with
#   off 88: framebuffer_addr   (uint64 — almost always 0xC0000000+ on
#                              real hardware; under OVMF QEMU it can
#                              be anywhere from 0x80000000 up. The
#                              full 4 GiB identity-map in header.S
#                              covers anything below 4 GiB.)
#   off 96: framebuffer_pitch  (uint32 — bytes per scanline, NOT
#                              bytes-per-pixel * width; pitch may
#                              exceed width*bpp/8 because GOP often
#                              pads scanlines to a hw-friendly stride)
#   off 100: framebuffer_width  (uint32, pixels)
#   off 104: framebuffer_height (uint32, pixels)
#   off 108: framebuffer_bpp    (uint8)
#   off 109: framebuffer_type   (uint8 — 1 = RGB, 2 = EGA-text)
#
# We handle bpp=32 (the GOP common case: 32-bit BGR or RGB with the
# high byte either 0 = "X" or "A" depending on the framebuffer
# vendor) and bpp=24 (rare older QEMU configs).
#
# Mutual exclusion with vga_text.ad: if fb_init() succeeds, it sets
# fb_initialized=1. Both early_putc fan-out callers can be called
# unconditionally — fb_putc no-ops when fb_initialized==0 (BIOS path
# falls through to vga_putc), and vga_putc no-ops when vga_initialized
# is left at 0 (UEFI path skips it).
#
# Font: drivers/video/console/fb_font_8x16.S exports
# `fb_font_glyph_addr()` — returns the base of an embedded 8x16 VGA
# ROM-font glyph table (chars 0..127, 16 bytes per glyph, one row per
# byte with MSB = leftmost pixel). Derived verbatim from Linux's
# lib/fonts/font_8x16.c.
#
# ---------------------------------------------------------------
# SCROLLING MODEL — natural top-to-bottom, framebuffer is write-only
# ---------------------------------------------------------------
# The GOP framebuffer is uncached / write-combining memory. WRITES
# to it stream fast (the CPU's WC buffers coalesce bursts); READS are
# catastrophically slow — every read is an uncached single-beat MMIO
# transaction. An earlier natural-scroll implementation did a whole-
# screen memmove every newline, which had to READ ~4-8 MB out of the
# framebuffer per scrolled line: ~3 seconds per line on real hardware.
# Commit M16.154-gop "fixed" the speed by switching to wrap-around
# scrolling (clear-row-in-place, newest line lands anywhere on
# screen) — fast, but the display no longer reads top-to-bottom.
#
# This driver restores natural scrolling WITHOUT ever reading the
# framebuffer:
#
#   * The source of truth for on-screen text is `fb_grid`, a flat
#     character grid in NORMAL CACHED kernel RAM (top-level BSS).
#     fb_grid[row*fb_cols + col] holds the glyph currently displayed
#     at that cell.
#   * The framebuffer is treated as a strictly write-only output
#     device. Every framebuffer access in the glyph / scroll / clear
#     paths is a STORE — there are no loads from fb_base anywhere.
#   * On newline at the bottom row we scroll: shift fb_grid up one
#     row in cached RAM (a few KiB of cached byte moves — micro-
#     seconds) then re-render to the framebuffer. The re-render is a
#     DIFF render: a cell is repainted only when its post-scroll
#     glyph differs from what fb_grid says is already on screen
#     there. Lines of repeated whitespace (the common case in boot
#     logs) cost almost nothing; worst case is one full-screen glyph
#     blit, which is pure WC stores (~1-3 ms), not a multi-second WC
#     read.
#
# Per-scroll cost (1024x768 mode = 128 cols x 48 rows):
#   - grid shift:   47*128 = 6016 cached byte stores  (~microseconds)
#   - diff render:  worst case 48*128 cells fully blitted =
#                   48*128*16*8 = 786432 dword WC stores (~1-3 ms);
#                   typically far less because most shifted cells are
#                   unchanged relative to what was already displayed.
# A ~700-line boot therefore costs on the order of ~1 s of scrolling
# in the worst case, and much less in practice — versus the old
# read-bound path's ~3 s PER LINE.

# NOTE: this file deliberately does NOT import kernel.printk — that
# would create a cycle (printk → early_8250 → fb_text → printk).
# All diagnostic logging is done in init/main.ad which orchestrates
# the fb_init call and inspects the return code; fb_text itself is
# silent on success and just returns a non-zero error code on
# rejected modes.

extern def fb_font_glyph_addr() -> uint64

# Framebuffer geometry (populated by fb_init from multiboot info on
# the BIOS path, or from EFI GOP info on the UEFI direct-boot path).
#
# fb_pitch is the BYTE stride between consecutive scanlines —
# emphatically NOT width * bpp/8. UEFI 2.10 §12.9.2 specifies that
# the GOP's PixelsPerScanLine field is the number of *pixels* per
# scanline of framebuffer memory, which may exceed
# HorizontalResolution because real GPUs pad each scanline to a
# hardware-friendly alignment (commonly 64- or 128-byte boundaries).
# Multiboot1's framebuffer_pitch field is already in bytes (GRUB
# precomputes PPSL × bytes_per_pixel before populating it). Either
# way, every pixel store in this driver uses fb_pitch directly so
# we honour the loader-supplied stride and never re-derive it.
fb_base:   uint64 = 0
fb_pitch:  uint64 = 0
fb_width:  uint64 = 0
fb_height: uint64 = 0
fb_bpp:    uint64 = 0

# Pixel byte order. Set by fb_init from the EFI GOP PixelFormat (or
# inferred as BGR for multiboot's "type=1 RGB" since that's almost
# always BGRA8888 on x86 GPUs). Values match
# EFI_GRAPHICS_PIXEL_FORMAT:
#   0 = PixelRedGreenBlueReserved8BitPerColor  (byte order: R,G,B,X)
#   1 = PixelBlueGreenRedReserved8BitPerColor  (byte order: B,G,R,X)
# Other values fall back to the BGR-favoured fast path. The choice
# only affects which 32-bit value we store for a "white" / "non-zero
# colour" pixel — bit-MSB-first glyph bits are unchanged.
FB_PIXFMT_RGB: uint32 = 0
FB_PIXFMT_BGR: uint32 = 1
fb_pixfmt: uint32 = 1               # default BGR (multiboot path)

# Cursor position, in CHARACTER cells (8x16 each).
fb_col:    uint64 = 0
fb_row:    uint64 = 0
fb_cols:   uint64 = 0       # derived: fb_width / 8
fb_rows:   uint64 = 0       # derived: fb_height / 16

# Foreground colour (32-bit pixel value). 0xFFFFFFFF = white on both
# BGR and RGB packings since all three colour channels are saturated;
# bumping the saturated channels guarantees the foreground is the
# brightest possible pixel regardless of byte order.
FB_FG_PIXEL: uint32 = 0xFFFFFFFF
FB_BG_PIXEL: uint32 = 0x00000000

# Set to 1 by fb_init() once geometry is validated and the screen is
# cleared. fb_putc returns early while this is 0 so early-boot
# printk callers (the UART path runs much earlier) don't scribble on
# random memory.
fb_initialized: int32 = 0

# Console takeover gate. While this is non-zero a userland compositor
# (hamUId) owns the linear framebuffer EXCLUSIVELY: the text console
# (fb_putc / scroll / cursor) must NOT draw, otherwise boot-console text
# tears straight through the composited desktop. The compositor presents
# via fb_present_rgba_row (the /dev/fb write path), which is deliberately
# NOT gated — it is the new owner. fb_console_suspend() is called when
# hamUId opens /dev/fb for exclusive present (P0a fix); resume restores
# the text console on DE exit. Suspending does NOT touch the shadow grid,
# so on resume we repaint the saved text and the console continues where
# it left off.
fb_console_suspended: int32 = 0

# Glyph height / width in pixels. Constants throughout: the font
# table is fixed at 8x16, so the only adjustable axes are screen
# geometry.
GLYPH_W: uint64 = 8
GLYPH_H: uint64 = 16

# --- Shadow text grid (the on-screen source of truth) --------------
#
# fb_grid is a flat char grid in NORMAL CACHED kernel RAM. Cell
# (row, col) lives at fb_grid[row * fb_cols + col] and holds the
# glyph byte currently DISPLAYED at that cell on the framebuffer.
# fb_putc / fb_scroll / fb_clear keep fb_grid in lockstep with the
# framebuffer; the grid is what makes natural scrolling possible
# without ever reading the framebuffer back.
#
# Sized statically for the largest mode we plausibly see. 256 cols
# covers 2048-px-wide framebuffers (256*8); 80 rows covers
# 1280-px-tall (80*16). A 1920x1080 GOP mode is 240x67 and fits.
# 256*80 = 20480 bytes of BSS — trivial. fb_init rejects any mode
# whose derived fb_cols/fb_rows would overflow this.
#
# Declared as a top-level BSS Array to sidestep the U9
# nested-frame-Array compiler quirk (a function-local Array nested
# inside another frame miscompiles; a module-level array is fine).
# Indexed as a flat 1-D array (row*cols+col) so there is no nested
# Array at all.
FB_GRID_MAX_COLS: uint64 = 256
FB_GRID_MAX_ROWS: uint64 = 80
FB_GRID_CELLS:    uint64 = 20480            # 256 * 80
fb_grid: Array[20480, uint8]

# ANSI escape-sequence parser state. fb_putc is a byte-at-a-time
# sink, so recognising multi-byte escapes needs a tiny state machine.
# Supported sequences (the set hamsh's line editor actually emits at
# an interactive prompt, plus a couple of boot-time wipes):
#
#   ESC [ 2 J   — clear entire screen        (CSI 2 J)
#   ESC [ H     — cursor to top-left         (CSI H, no params)
#   ESC [ K     — erase from cursor to EOL   (CSI K — interactive
#                  line editor: clears the stale tail when a glyph is
#                  deleted mid-line; without this, backspace would
#                  shrink the LOGICAL line but leave the deleted
#                  character visible on screen until something else
#                  overwrote that cell.)
#   ESC [ <n>C  — cursor forward n columns   (CSI <n> C)
#   ESC [ <n>D  — cursor back   n columns    (CSI <n> D)
#                  The line editor uses these to PARK the cursor at
#                  the edit position after a redraw (CR to col 0,
#                  re-emit prompt + buffer, then forward by prompt +
#                  ed_cur columns).
#   ESC [ ? 2 5 h — show cursor              (DECTCEM set)
#   ESC [ ? 2 5 l — hide cursor              (DECTCEM clear)
#                  Toggles software cursor rendering. The cursor is a
#                  2-row underline at the bottom of the (fb_col, fb_row)
#                  cell; off-by-default would leave the user with no
#                  visual prompt indicator, so it's on by default.
#
# Any other CSI sequence is consumed and discarded so stray escapes
# never leave raw bytes splattered as glyphs. The numeric parameter
# is accumulated; for the dispatchers above that read a parameter,
# `0` is treated as `1` (terminal convention).
#
# fb_esc_state: 0 = normal, 1 = saw ESC, 2 = inside CSI (after '['),
#               3 = saw ESC [ ?   (DEC private-mode prefix).
fb_esc_state: int32 = 0
# Accumulated decimal parameter for the in-progress CSI sequence.
fb_esc_param: uint64 = 0
# Second CSI parameter (after a ';') plus a count of how many parameters
# have been seen. ESC[<row>;<col>H — the absolute cursor-position (CUP)
# sequence every full-screen TUI emits — carries two parameters; without
# a second accumulator the column was silently dropped and the cursor
# always homed to (0,0). nparam==0 means a bare ESC[H (both default 1).
fb_esc_param2:  uint64 = 0
fb_esc_nparam:  int32  = 0

# Software-cursor state. The cursor is rendered as an underline
# (bottom two rows of the 8x16 cell, foreground colour) at
# (fb_col, fb_row). It is erased before any byte is written or the
# cursor moves, then re-rendered after, so the underline always sits
# at the current write position.
#
# fb_cursor_visible: 1 = render cursor, 0 = suppress (ESC[?25l).
# fb_cursor_drawn:   1 = an underline is currently painted on screen
#                    at (fb_cursor_drawn_col, fb_cursor_drawn_row) and
#                    needs to be erased before drawing elsewhere. The
#                    drawn-at coords are tracked separately from the
#                    write cursor because the cursor lags one
#                    fb_putc call behind the current write position
#                    (it is repainted at the END of each putc, after
#                    fb_col/fb_row have advanced).
fb_cursor_visible:    int32  = 1
fb_cursor_drawn:      int32  = 0
fb_cursor_drawn_col:  uint64 = 0
fb_cursor_drawn_row:  uint64 = 0


def fb_is_initialized() -> int32:
    # Used by early_putc to decide whether to call fb_putc or vga_putc.
    return fb_initialized


def _fb_putpixel(x: uint64, y: uint64, color: uint32):
    # Single-pixel store. Two supported pixel formats:
    #   bpp=32: one aligned 32-bit store, byte order matches color
    #   bpp=24: three packed byte stores (B, G, R) at scanline stride
    # fb_init refuses any other bpp.
    #
    # 24bpp scanline arithmetic: stride is fb_pitch bytes, but pixels
    # are 3 bytes wide. fb_pitch may be > width*3 (GOP often pads).
    #
    # Pure STORE — no framebuffer read.
    if fb_bpp == 32:
        off: uint64 = y * fb_pitch + x * 4
        cast[Ptr[uint32]](fb_base + off)[0] = color
    else:
        # 24bpp BGR packing — same channel order as 32-bit BGRX
        # framebuffers we already handle. low byte = blue.
        off: uint64 = y * fb_pitch + x * 3
        cast[Ptr[uint8]](fb_base + off)[0]     = cast[uint8](color & 0xFF)
        cast[Ptr[uint8]](fb_base + off + 1)[0] = cast[uint8]((color >> 8) & 0xFF)
        cast[Ptr[uint8]](fb_base + off + 2)[0] = cast[uint8]((color >> 16) & 0xFF)


def fb_clear():
    # Fill the entire framebuffer with FB_BG_PIXEL. Pure STORE pass —
    # no framebuffer reads.
    #
    # Fast path for the 32 bpp case (the only one the EFI GOP and most
    # multiboot1 loaders provide): walk the framebuffer as 32-bit
    # words. On a 1280×800 BGRA8888 framebuffer that's ~1M dword stores
    # instead of the per-pixel function-call loop that was
    # measurably making early-boot fb_init the slowest single step in
    # the bring-up sequence (~3+ seconds on QEMU because the previous
    # _fb_putpixel call chain inhibits any compiler-side vectorisation
    # and adds branch overhead per pixel). For the rare 24 bpp fallback
    # we still go through _fb_putpixel — its byte-store branch already
    # handles the unaligned packing.
    if fb_bpp == 32:
        y: uint64 = 0
        while y < fb_height:
            row_base: uint64 = fb_base + y * fb_pitch
            x: uint64 = 0
            while x < fb_width:
                cast[Ptr[uint32]](row_base + x * 4)[0] = FB_BG_PIXEL
                x = x + 1
            y = y + 1
        return
    y2: uint64 = 0
    while y2 < fb_height:
        x2: uint64 = 0
        while x2 < fb_width:
            _fb_putpixel(x2, y2, FB_BG_PIXEL)
            x2 = x2 + 1
        y2 = y2 + 1


def _fb_draw_glyph(ch: int32, col: uint64, row: uint64):
    # Render one 8x16 glyph at character cell (col, row). Each font
    # row is one byte: bit 7 (0x80) is the leftmost pixel.
    #
    # Pure STORE pass into the framebuffer — every pixel of the cell
    # is overwritten (foreground OR background) so there is no need to
    # read the framebuffer first, and we never do.
    #
    # Fast path: 32 bpp uses inline 32-bit stores indexed off a
    # per-row base pointer. Skipping the _fb_putpixel call dispatch
    # and the multiplication on every pixel knocks ~8x off the per-
    # character cost compared with the previous version, which was
    # the dominant per-printk-byte cost during boot.
    if ch < 0 or ch >= 128:
        # Out-of-range characters render as a blank cell — same as
        # how Linux's fbcon falls back when the codepoint isn't in
        # the loaded font.
        ch = 0x20                                       # space

    glyph_base: uint64 = fb_font_glyph_addr() + cast[uint64](ch) * 16
    px:         uint64 = col * GLYPH_W
    py:         uint64 = row * GLYPH_H

    if fb_bpp == 32:
        r: uint64 = 0
        while r < GLYPH_H:
            bits: uint8 = cast[Ptr[uint8]](glyph_base + r)[0]
            row_base: uint64 = fb_base + (py + r) * fb_pitch + px * 4
            # Per-pixel: branchful but still much cheaper than the old
            # _fb_putpixel function-call path. Each glyph row is exactly
            # 8 pixels wide so we iterate the inner loop a constant 8
            # times — small enough that loop overhead dominates if we
            # try anything fancier.
            c: uint64 = 0
            while c < GLYPH_W:
                mask: uint8 = cast[uint8](0x80 >> c)
                pix: uint32 = FB_BG_PIXEL
                if (bits & mask) != 0:
                    pix = FB_FG_PIXEL
                cast[Ptr[uint32]](row_base + c * 4)[0] = pix
                c = c + 1
            r = r + 1
        return

    # Slow path: 24 bpp via the per-pixel function. Kept correct but
    # not optimised because no real hardware uses 24 bpp framebuffers
    # for boot — included only so the multiboot1 type=1 24-bit case
    # (small set of older QEMU configurations) still renders.
    r2: uint64 = 0
    while r2 < GLYPH_H:
        bits2: uint8 = cast[Ptr[uint8]](glyph_base + r2)[0]
        c: uint64 = 0
        while c < GLYPH_W:
            mask: uint8 = cast[uint8](0x80 >> c)
            color: uint32 = FB_BG_PIXEL
            if (bits2 & mask) != 0:
                color = FB_FG_PIXEL
            _fb_putpixel(px + c, py + r2, color)
            c = c + 1
        r2 = r2 + 1


def _fb_grid_reset():
    # Initialise the whole shadow grid to spaces (0x20). Called from
    # fb_init and from the ESC[2J / clear path so the grid agrees
    # with a freshly-blanked framebuffer.
    i: uint64 = 0
    while i < FB_GRID_CELLS:
        fb_grid[i] = 0x20
        i = i + 1


def _fb_put_cell(ch: int32, col: uint64, row: uint64):
    # Write one glyph at cell (col, row): update the shadow grid AND
    # blit the glyph to the framebuffer. The grid update is a cached
    # byte store; the glyph blit is a pure framebuffer STORE pass.
    # If the grid already shows this glyph at this cell we skip the
    # blit entirely — saves the WC stores on a redundant repaint
    # (e.g. re-rendering an unchanged cell during a diff scroll).
    if col >= fb_cols or row >= fb_rows:
        return
    cell:   uint64 = row * fb_cols + col
    new_ch: uint8  = cast[uint8](ch & 0xFF)
    if fb_grid[cell] == new_ch:
        return
    fb_grid[cell] = new_ch
    _fb_draw_glyph(ch, col, row)


# --- Page-pause log-capture aid (opt-in via /etc/log-slow) ----------
#
# When g_fb_pause_enabled==1, fb_scroll pauses ~1 second after every
# screenful (fb_rows scrolls) of boot-log output. Once the screen is
# full, each new line costs exactly one scroll, so fb_rows scrolls ==
# one entirely fresh screen — the pause lets a capture card grab every
# screen of the fast-scrolling NUC boot log without meaningfully
# slowing the boot. Off by default (zero cost on every normal boot).
#
# The ~1 s delay is an INLINED PIT busy-wait using raw inb/outb. It
# CANNOT call pit_monotonic_us / printk: fb_text is imported by
# early_8250 (fb_putc), early_8250 is imported by printk, printk is
# imported by time — so fb_text -> time would close an import cycle.
# PIT channel 0 free-runs (the system timer is the LAPIC timer), so
# latching it here does not perturb jiffies.
FB_PIT_CMD:      int32  = 0x43
FB_PIT_CH0_DATA: int32  = 0x40
FB_PIT_DIVISOR:  uint64 = 11931         # 1193182 / 100 (matches time_init)
# count-VALUE units traversed in ~1 s. Channel 0 runs in mode 3, which
# decrements the count by 2 per 1.193182 MHz input clock, so the count
# sweeps 2 * PIT_BASE_HZ value-units per real second.
FB_PIT_1S_UNITS: uint64 = 2386364       # 2 * 1193182

g_fb_pause_enabled: int32  = 0          # 1 once /etc/log-slow is honoured
g_fb_scroll_count:  uint64 = 0          # scrolls since the last pause
g_fb_page_seq:      uint64 = 0          # monotonic captured-page number
g_fb_pausing:       int32  = 0          # re-entrancy guard while bannering


def fb_set_pause_enabled(on: int32):
    # init/main.ad turns this on when the /etc/log-slow marker is present.
    g_fb_pause_enabled = on


def _fb_page_banner():
    # Emit an OCR-anchored delimiter line so the captured frames can be
    # machine-segmented into pages and ordered: a fixed high-contrast
    # uppercase token plus a zero-padded 4-digit page sequence number.
    # The unique "HAMNIX-LOGPAGE" string never appears elsewhere in the
    # boot log, so OCR can lock onto it to find page boundaries and
    # detect a dropped frame (gap in the sequence).
    # The pause fires immediately after fb_scroll has rolled a fresh blank
    # bottom row into place and parked the cursor there, so we stamp the
    # banner straight onto that existing blank row. NO leading newline:
    # every newline here triggers another scroll that pushes a real log
    # line off the top, and the OCR only needs the token + sequence on a
    # single line. One trailing newline closes the banner line; that is
    # the sole row this costs per page.
    g_fb_page_seq = g_fb_page_seq + 1
    n: uint64 = g_fb_page_seq % 10000
    fb_puts("### HAMNIX-LOGPAGE ")
    fb_putc(cast[int32](0x30 + ((n / 1000) % 10)))
    fb_putc(cast[int32](0x30 + ((n / 100) % 10)))
    fb_putc(cast[int32](0x30 + ((n / 10) % 10)))
    fb_putc(cast[int32](0x30 + (n % 10)))
    fb_puts(" ###\n")


def _fb_pit_read_count() -> uint64:
    # Counter-latch channel 0 (00 00 = latch ch0) then read lo, hi.
    outb(0x00, FB_PIT_CMD)
    lo: uint64 = cast[uint64](inb(FB_PIT_CH0_DATA)) & 0xFF
    hi: uint64 = cast[uint64](inb(FB_PIT_CH0_DATA)) & 0xFF
    return (hi << 8) | lo


def _fb_busy_wait_1s():
    # Spin ~1 second by accumulating PIT channel-0 count-value units.
    # The PIT counts DOWN and reloads at FB_PIT_DIVISOR, so a wrap shows
    # up as cur > last; the span across a wrap is last + divisor - cur.
    last: uint64 = _fb_pit_read_count()
    acc:  uint64 = 0
    while acc < FB_PIT_1S_UNITS:
        cur: uint64 = _fb_pit_read_count()
        if cur <= last:
            acc = acc + (last - cur)
        else:
            acc = acc + (last + FB_PIT_DIVISOR - cur)
        last = cur


def fb_scroll():
    # Natural scroll: shift everything up one character row, the top
    # row falls off, a blank row appears at the bottom.
    #
    # NO FRAMEBUFFER READS. The whole scroll runs against the shadow
    # grid in cached RAM; the framebuffer only receives glyph STOREs
    # for cells whose displayed character actually changes.
    #
    # Algorithm — single top-down pass over the rows:
    #   For each row r in 0 .. fb_rows-2:
    #     the post-scroll content of cell (r, c) is the PRE-scroll
    #     content of cell (r+1, c), i.e. fb_grid[(r+1)*cols + c].
    #     fb_grid still holds the pre-scroll (currently displayed)
    #     state for rows >= r at this point, because we have not
    #     written row r yet. So we read the desired glyph from row
    #     r+1, compare against what row r currently shows, repaint
    #     the cell only on a mismatch, and update the grid cell.
    #   The bottom row (fb_rows-1) is then blanked: each non-space
    #   cell is repainted to a space and the grid cell cleared.
    #
    # Because we walk strictly top-down and only ever READ from the
    # row BELOW the one being written, the in-place grid shift is
    # safe with no temporary buffer.
    #
    # Diff rendering: a cell is blitted only when its glyph changes
    # (see _fb_put_cell). Boot logs are mostly whitespace and repeated
    # structure, so most shifted cells match what was already there
    # and cost nothing. Worst case (every cell different) is one
    # full-screen glyph blit of pure WC stores — milliseconds, not
    # the multi-second WC-read memmove the old natural-scroll code did.
    if fb_rows < 2:
        # Degenerate single-row console: just blank the only row.
        c0: uint64 = 0
        while c0 < fb_cols:
            _fb_put_cell(0x20, c0, 0)
            c0 = c0 + 1
        return

    last: uint64 = fb_rows - 1
    r:    uint64 = 0
    while r < last:
        src_row: uint64 = (r + 1) * fb_cols
        c: uint64 = 0
        while c < fb_cols:
            want: int32 = cast[int32](fb_grid[src_row + c])
            _fb_put_cell(want, c, r)
            c = c + 1
        r = r + 1

    # Blank the new bottom row.
    cb: uint64 = 0
    while cb < fb_cols:
        _fb_put_cell(0x20, cb, last)
        cb = cb + 1

    # Page-pause: once the screen is full, each scroll pushes one fresh
    # line on; after fb_rows scrolls an entire new screen has rolled by,
    # so stamp an OCR delimiter and pause ~1 s to let a capture card grab
    # it. No-op unless enabled. g_fb_pausing guards the recursion: the
    # banner's own fb_putc newlines call back into fb_scroll, and that
    # nested scroll must NOT re-count or re-pause.
    if g_fb_pause_enabled == 1 and g_fb_pausing == 0:
        g_fb_scroll_count = g_fb_scroll_count + 1
        if g_fb_scroll_count >= fb_rows:
            g_fb_scroll_count = 0
            g_fb_pausing = 1
            _fb_page_banner()
            _fb_busy_wait_1s()
            g_fb_pausing = 0


def fb_init(base: uint64, pitch: uint64, width: uint64,
            height: uint64, bpp: uint64, pixfmt: uint32) -> int32:
    # Validate the mode + cache geometry + clear the screen.
    # Return 0 on success, non-zero on rejected mode (the caller
    # in init/main.ad falls back to vga_init in that case).
    # Distinct return codes so the init/main.ad caller can render a
    # specific log line for each refusal reason. 0 = success.
    #
    # pitch parameter: the BYTE stride between scanlines, as supplied
    # by the loader (GRUB multiboot framebuffer_pitch or EFI GOP
    # PixelsPerScanLine × 4). NEVER recompute it from width — see
    # the module-level comment on fb_pitch.
    #
    # pixfmt parameter: 0 = RGB byte order, 1 = BGR. Anything else
    # falls back to BGR. Default is BGR because (a) multiboot1
    # type=1 "RGB" is almost always BGRA8888 on x86 in practice,
    # and (b) saturated colours render the same in either format.
    if base == 0:
        return 1                                # null base
    if bpp != 32 and bpp != 24:
        return 2                                # only 32 / 24 bpp supported
    if width < GLYPH_W or height < GLYPH_H:
        return 3                                # geometry too small
    # Each pixel takes bpp/8 bytes; pitch must cover the full scanline.
    bytes_per_pixel: uint64 = bpp / 8
    if pitch < width * bytes_per_pixel:
        return 4                                # pitch < width*bpp/8

    derived_cols: uint64 = width  / GLYPH_W
    derived_rows: uint64 = height / GLYPH_H
    # The shadow grid is a fixed-size BSS array; refuse any mode whose
    # character grid would not fit. fb_putc/_fb_put_cell index
    # fb_grid[row*cols+col] and must never run past FB_GRID_CELLS.
    if derived_cols > FB_GRID_MAX_COLS or derived_rows > FB_GRID_MAX_ROWS:
        return 5                                # mode too large for grid

    fb_base   = base
    fb_pitch  = pitch
    fb_width  = width
    fb_height = height
    fb_bpp    = bpp
    fb_pixfmt = pixfmt
    fb_cols   = derived_cols
    fb_rows   = derived_rows
    fb_col    = 0
    fb_row    = 0

    _fb_grid_reset()
    fb_clear()
    fb_initialized = 1
    return 0


def _fb_erase_to_eol():
    # ESC [ K body: clear cells from (fb_col, fb_row) to (fb_cols-1,
    # fb_row) inclusive. The shadow grid is reset to spaces for those
    # cells too so a later diff-render or scroll knows the cells are
    # blank. Cursor (fb_col, fb_row) does NOT move.
    if fb_initialized == 0:
        return
    if fb_row >= fb_rows:
        return
    c: uint64 = fb_col
    while c < fb_cols:
        _fb_put_cell(0x20, c, fb_row)
        c = c + 1


def _fb_paint_cursor_at(col: uint64, row: uint64):
    # Paint the cursor underline (bottom 2 pixel rows of the cell,
    # foreground colour) at the given cell. Pure STORE pass — no
    # framebuffer reads. Coords already validated by the caller.
    px: uint64 = col * GLYPH_W
    py: uint64 = row * GLYPH_H
    if fb_bpp == 32:
        r: uint64 = GLYPH_H - 2
        while r < GLYPH_H:
            row_base: uint64 = fb_base + (py + r) * fb_pitch + px * 4
            c: uint64 = 0
            while c < GLYPH_W:
                cast[Ptr[uint32]](row_base + c * 4)[0] = FB_FG_PIXEL
                c = c + 1
            r = r + 1
        return
    # 24bpp slow path
    r2: uint64 = GLYPH_H - 2
    while r2 < GLYPH_H:
        c2: uint64 = 0
        while c2 < GLYPH_W:
            _fb_putpixel(px + c2, py + r2, FB_FG_PIXEL)
            c2 = c2 + 1
        r2 = r2 + 1


def _fb_erase_cursor():
    # Undraw the currently-painted cursor (if any) by re-rendering
    # the underlying cell's glyph cleanly. The cell's shadow-grid
    # glyph is the truth — _fb_draw_glyph repaints every pixel of
    # the cell including the bottom two rows, which wipes the cursor.
    if fb_cursor_drawn == 0:
        return
    col: uint64 = fb_cursor_drawn_col
    row: uint64 = fb_cursor_drawn_row
    fb_cursor_drawn = 0
    if col >= fb_cols or row >= fb_rows:
        return
    cell: uint64 = row * fb_cols + col
    glyph: int32 = cast[int32](fb_grid[cell])
    _fb_draw_glyph(glyph, col, row)


def _fb_draw_cursor():
    # Paint the cursor at the current (fb_col, fb_row) if visible.
    if fb_cursor_visible == 0 or fb_initialized == 0:
        return
    if fb_col >= fb_cols or fb_row >= fb_rows:
        return
    _fb_paint_cursor_at(fb_col, fb_row)
    fb_cursor_drawn      = 1
    fb_cursor_drawn_col  = fb_col
    fb_cursor_drawn_row  = fb_row


def fb_putc(ch: int32):
    # Pre-init no-op so early_putc callers can fan into us
    # unconditionally — same convention vga_putc uses.
    #
    # NATURAL SCROLLING: the cursor advances down the screen; when a
    # newline arrives on the bottom row (or a glyph wraps off the
    # bottom-right cell), fb_scroll() shifts the shadow grid up one
    # row and re-renders the changed cells. The newest line always
    # ends up at the bottom and the display reads top-to-bottom, like
    # an ordinary terminal — with NO framebuffer reads anywhere in the
    # scroll path (see fb_scroll / the module header).
    #
    # Software cursor: every fb_putc call that finishes by either
    # writing a glyph or moving the cursor first erases the previously-
    # painted cursor underline (re-rendering the underlying cell's
    # glyph cleanly) and then re-paints the cursor at the new position.
    # This keeps the underline tied to the live write position; at a
    # quiescent prompt the user sees a visible insertion point.
    if fb_initialized == 0:
        return
    # Console takeover: while a userland compositor owns the framebuffer
    # we must not paint console glyphs over its composited frame. Bytes
    # are dropped on the floor (the boot path is quiescent by then; any
    # stray printk during a DE session would otherwise tear through the
    # desktop — the exact P0a "screen rips open" symptom).
    if fb_console_suspended != 0:
        return

    # --- ANSI escape parser -------------------------------------
    # State 0 is the common case; the four checks below are a single
    # compare each so normal glyph throughput is unaffected.
    if fb_esc_state == 1:
        # Just saw ESC (0x1B). A CSI starts with '['.
        if ch == 0x5B:                          # '['
            fb_esc_state = 2
            fb_esc_param = 0
            fb_esc_param2 = 0
            fb_esc_nparam = 0
        else:
            # Not a CSI — abandon the escape, drop the byte. (We
            # don't support ESC-anything-else; printing it would be
            # noisier than swallowing it.)
            fb_esc_state = 0
        return
    if fb_esc_state == 2:
        # Inside a CSI: digits accumulate into fb_esc_param, '?' as
        # the very first byte switches to DEC private mode (state 3),
        # the final letter dispatches.
        if ch == 0x3F and fb_esc_param == 0 and fb_esc_nparam == 0:  # '?'
            fb_esc_state = 3
            return
        if ch >= 0x30 and ch <= 0x39:           # '0'..'9'
            # Accumulate into the parameter currently being parsed. The
            # first ';' switches accumulation to the second slot (the
            # column for CUP). Cap at two parameters.
            if fb_esc_nparam <= 1:
                fb_esc_nparam = 1
                fb_esc_param = fb_esc_param * 10 + cast[uint64](ch - 0x30)
            else:
                fb_esc_param2 = fb_esc_param2 * 10 + cast[uint64](ch - 0x30)
            return
        if ch == 0x3B:                          # ';' parameter separator
            if fb_esc_nparam < 2:
                fb_esc_nparam = 2
            return
        if ch == 0x4A:                          # 'J' — erase display
            # ESC [ 2 J clears the whole screen. ESC [ J / ESC [ 0 J
            # ("erase to end") and ESC [ 1 J are treated as a full
            # clear too — close enough for a boot-time wipe and
            # cheaper than tracking a cursor-relative erase. The
            # shadow grid is reset so it agrees with the blanked
            # framebuffer.
            _fb_erase_cursor()
            _fb_grid_reset()
            fb_clear()
            fb_col = 0
            fb_row = 0
            fb_esc_state = 0
            _fb_draw_cursor()
            return
        if ch == 0x4B:                          # 'K' — erase to EOL
            # ESC [ K (and ESC [ 0 K) erase from cursor to end of line.
            # We don't distinguish ESC [ 1 K / ESC [ 2 K (erase to
            # start / whole line) yet; hamsh only emits the cursor-
            # to-EOL form. The cursor stays put — the line editor
            # repositions it explicitly via ESC[<n>C next.
            _fb_erase_cursor()
            _fb_erase_to_eol()
            fb_esc_state = 0
            _fb_draw_cursor()
            return
        if ch == 0x48 or ch == 0x66:            # 'H' / 'f' — CUP
            # ESC[<row>;<col>H — absolute cursor position. Parameters are
            # 1-based in ANSI; a missing/zero parameter defaults to 1, so
            # bare ESC[H homes the cursor. Both axes are clamped into the
            # live character grid so a TUI asking for an off-screen cell
            # can never push fb_col/fb_row past fb_cols/fb_rows (which the
            # glyph blitter indexes directly).
            want_row: uint64 = 1
            want_col: uint64 = 1
            if fb_esc_nparam >= 1:
                if fb_esc_param != 0:
                    want_row = fb_esc_param
            if fb_esc_nparam >= 2:
                if fb_esc_param2 != 0:
                    want_col = fb_esc_param2
            tr: uint64 = want_row - 1
            tc: uint64 = want_col - 1
            if fb_rows > 0 and tr >= fb_rows:
                tr = fb_rows - 1
            if fb_cols > 0 and tc >= fb_cols:
                tc = fb_cols - 1
            _fb_erase_cursor()
            fb_row = tr
            fb_col = tc
            fb_esc_state = 0
            _fb_draw_cursor()
            return
        if ch == 0x43:                          # 'C' — cursor forward N
            # ESC [ N C: move cursor right N columns, clamped to the
            # rightmost column. ESC [ C and ESC [ 0 C both move 1
            # (terminal convention: missing/zero N == 1).
            n: uint64 = fb_esc_param
            if n == 0:
                n = 1
            _fb_erase_cursor()
            fb_col = fb_col + n
            if fb_cols > 0 and fb_col >= fb_cols:
                fb_col = fb_cols - 1
            fb_esc_state = 0
            _fb_draw_cursor()
            return
        if ch == 0x44:                          # 'D' — cursor back N
            # ESC [ N D: move cursor left N columns, clamped to col 0.
            n2: uint64 = fb_esc_param
            if n2 == 0:
                n2 = 1
            _fb_erase_cursor()
            if n2 >= fb_col:
                fb_col = 0
            else:
                fb_col = fb_col - n2
            fb_esc_state = 0
            _fb_draw_cursor()
            return
        # Any other final byte (or ';' separator, etc): consume and
        # end the sequence without acting on it.
        if ch >= 0x40 and ch <= 0x7E:
            fb_esc_state = 0
        return
    if fb_esc_state == 3:
        # DEC private-mode CSI: ESC [ ? <param> <final>.
        if ch >= 0x30 and ch <= 0x39:           # '0'..'9'
            fb_esc_param = fb_esc_param * 10 + cast[uint64](ch - 0x30)
            return
        if ch == 0x68:                          # 'h' — set
            if fb_esc_param == 25:
                # DECTCEM set — show cursor.
                fb_cursor_visible = 1
                fb_esc_state = 0
                _fb_draw_cursor()
                return
            fb_esc_state = 0
            return
        if ch == 0x6C:                          # 'l' — clear
            if fb_esc_param == 25:
                # DECTCEM clear — hide cursor.
                _fb_erase_cursor()
                fb_cursor_visible = 0
                fb_esc_state = 0
                return
            fb_esc_state = 0
            return
        # Unknown DEC-private final byte: swallow and reset.
        if ch >= 0x40 and ch <= 0x7E:
            fb_esc_state = 0
        return
    if ch == 0x1B:                              # ESC
        fb_esc_state = 1
        return
    # --- end ANSI escape parser ---------------------------------

    # Ordinary byte path. Erase the live cursor underline before any
    # write or cursor move; draw it again at the new position before
    # returning so the user always sees the cursor where the next
    # byte will land.
    _fb_erase_cursor()

    if ch == 10:                                # '\n'
        fb_col = 0
        if fb_row + 1 >= fb_rows:
            # Cursor already on the bottom row: scroll the screen up
            # one row instead of running the cursor off the bottom.
            # fb_row stays pinned at the (new) bottom row.
            fb_scroll()
        else:
            fb_row = fb_row + 1
        _fb_draw_cursor()
        return
    if ch == 13:                                # '\r'
        fb_col = 0
        _fb_draw_cursor()
        return
    if ch == 8 and fb_col > 0:                  # '\b'
        fb_col = fb_col - 1
        _fb_put_cell(0x20, fb_col, fb_row)
        _fb_draw_cursor()
        return

    _fb_put_cell(ch, fb_col, fb_row)
    fb_col = fb_col + 1
    if fb_col >= fb_cols:
        fb_col = 0
        if fb_row + 1 >= fb_rows:
            # Wrapped off the bottom-right cell: scroll up, keep the
            # cursor pinned to the bottom row.
            fb_scroll()
        else:
            fb_row = fb_row + 1
    _fb_draw_cursor()


def fb_puts(s: Ptr[char]):
    i: int32 = 0
    while s[i] != 0:
        fb_putc(s[i])
        i = i + 1


# --- CSI cursor-position (CUP) self-test ----------------------------
#
# fb_text cannot import kernel.printk (it sits below printk in the import
# graph — see the module header), so this self-test returns a failure
# COUNT (0 == all pass) and the VGA console self-test, which CAN printk,
# drives it and emits the PASS/FAIL markers. It runs the REAL fb_putc CSI
# path against a small self-contained scratch framebuffer (a 24-col by
# 16-row, 192x256 px, 32 bpp grid), so it never touches a production GOP
# framebuffer or the live console state — the prior fb globals are saved
# and restored around the run.
#
# Scratch framebuffer: 16 rows * 16 px * (24 cols * 8 px * 4 bytes/px)
#                     = 256 * 768 = 196608 bytes.
FB_CUP_W:     uint64 = 192               # 24 cells * GLYPH_W
FB_CUP_H:     uint64 = 256               # 16 cells * GLYPH_H
FB_CUP_PITCH: uint64 = 768               # 192 px * 4 bytes
fb_cup_scratch: Array[196608, uint8]     # FB_CUP_H * FB_CUP_PITCH


def _fb_cup_feed(s: Ptr[char]):
    i: uint64 = 0
    while s[i] != 0:
        fb_putc(cast[int32](cast[uint8](s[i])))
        i = i + 1


def _fb_cup_check(want_row: uint64, want_col: uint64) -> int32:
    # 1 == the live cursor landed exactly on (want_row, want_col).
    if fb_row == want_row and fb_col == want_col:
        return 1
    return 0


def fb_cup_selftest() -> int32:
    # Returns the number of failed CUP assertions (0 == all pass). Saves
    # and restores the production fb_* globals so a real GOP console set
    # up earlier in boot is left exactly as it was.
    sv_base:  uint64 = fb_base
    sv_pitch: uint64 = fb_pitch
    sv_width: uint64 = fb_width
    sv_height:uint64 = fb_height
    sv_bpp:   uint64 = fb_bpp
    sv_pixfmt:uint32 = fb_pixfmt
    sv_cols:  uint64 = fb_cols
    sv_rows:  uint64 = fb_rows
    sv_col:   uint64 = fb_col
    sv_row:   uint64 = fb_row
    sv_init:  int32  = fb_initialized
    sv_pause: int32  = g_fb_pause_enabled

    g_fb_pause_enabled = 0               # never page-pause inside the test
    fails: int32 = 0

    rc: int32 = fb_init(cast[uint64](&fb_cup_scratch[0]),
                        FB_CUP_PITCH, FB_CUP_W, FB_CUP_H, 32, 0)
    if rc != 0:
        # Could not stand up the scratch fb — count it as a single failure
        # and restore state.
        fails = 1
    else:
        # ESC[10;20H -> 1-based (10,20) == 0-based (9,19).
        _fb_cup_feed("\x1b[10;20H")
        if _fb_cup_check(9, 19) == 0:
            fails = fails + 1
        # ESC[5;1H -> 0-based (4,0).
        _fb_cup_feed("\x1b[5;1H")
        if _fb_cup_check(4, 0) == 0:
            fails = fails + 1
        # Bare ESC[H homes to (0,0).
        _fb_cup_feed("\x1b[H")
        if _fb_cup_check(0, 0) == 0:
            fails = fails + 1
        # ESC[;15H -> default row 1, explicit col 15 == 0-based (0,14).
        _fb_cup_feed("\x1b[;15H")
        if _fb_cup_check(0, 14) == 0:
            fails = fails + 1
        # ESC[16;24H -> last cell of the 16x24 grid == 0-based (15,23).
        _fb_cup_feed("\x1b[16;24H")
        if _fb_cup_check(15, 23) == 0:
            fails = fails + 1
        # Over-range ESC[999;999H clamps into the grid == (15,23).
        _fb_cup_feed("\x1b[999;999H")
        if _fb_cup_check(15, 23) == 0:
            fails = fails + 1
        # ESC[3;7f ('f' synonym for CUP) -> 0-based (2,6).
        _fb_cup_feed("\x1b[3;7f")
        if _fb_cup_check(2, 6) == 0:
            fails = fails + 1

    # Restore the prior console state wholesale.
    fb_base   = sv_base
    fb_pitch  = sv_pitch
    fb_width  = sv_width
    fb_height = sv_height
    fb_bpp    = sv_bpp
    fb_pixfmt = sv_pixfmt
    fb_cols   = sv_cols
    fb_rows   = sv_rows
    fb_col    = sv_col
    fb_row    = sv_row
    fb_initialized = sv_init
    g_fb_pause_enabled = sv_pause
    return fails


# ===================================================================
# hamUI Phase 4c — physical-framebuffer PRESENTATION accessors
# ===================================================================
#
# These are PURELY ADDITIVE consumers of the geometry globals
# fb_init() already populates for the text console. They do NOT touch
# fb_init's signature, the text-console rendering, the scroll path, or
# the boot/EFI handoff — they only READ the cached geometry and issue
# pure framebuffer STORES (the same write-only discipline the console
# uses). drivers/video/fb_cdev.ad imports these to back the /dev/fb
# character device.

def fb_get_initialized() -> int32:
    return fb_initialized


# --- console takeover (P0a) -----------------------------------------
#
# A userland compositor (hamUId) calls fb_console_suspend() when it
# opens /dev/fb for exclusive presentation, and fb_console_resume() on
# exit. While suspended, fb_putc() is a no-op so the boot text console
# and printk never draw over the composited desktop. The shadow grid is
# left intact, so resume repaints the saved text and the console picks
# up exactly where it left off.

def fb_console_suspend():
    fb_console_suspended = 1


def fb_console_resume():
    # Restore the text console. Repaint the whole shadow grid so any
    # framebuffer the compositor left behind is overwritten with the
    # saved console contents, then re-arm the cursor.
    if fb_console_suspended == 0:
        return
    fb_console_suspended = 0
    if fb_initialized == 0:
        return
    fb_clear()
    r: uint64 = 0
    while r < fb_rows:
        c: uint64 = 0
        while c < fb_cols:
            glyph: int32 = cast[int32](fb_grid[r * fb_cols + c])
            if glyph != 0x20 and glyph != 0:
                _fb_draw_glyph(glyph, c, r)
            c = c + 1
        r = r + 1
    _fb_draw_cursor()


def fb_console_is_suspended() -> int32:
    return fb_console_suspended


# --- scanout SHADOW (double-buffered present) -----------------------
#
# DE FLICKER ROOT CAUSE: the scene compositor's recompose paths blit
# composited pixels DIRECTLY into the scanned-out framebuffer, one row at
# a time, bottom-to-top. On any multi-source rect (backdrop fill, then a
# window cache over it; or a large window move re-blitting two big rects)
# the monitor scans out the FB mid-composite and the user SEES the
# half-drawn frame — that is the persistent flicker that survived two
# "damage-clip" waves (the clip made the rect smaller but the rect was
# still drawn live to scanout).
#
# THE FIX (double-buffer the present): the compositor composites into an
# OFFSCREEN shadow buffer (plain cached RAM — fast to write, never scanned
# out) and then copies the finished damage rect to scanout in ONE pass via
# fb_present_flush(). A scanned-out rect is therefore only ever a fully
# composited frame; no half-drawn state is ever visible.
#
# Mechanism: when fb_shadow_base != 0, fb_present_rgba_row[_keyed] write
# into the shadow at fb_shadow_pitch_px stride INSTEAD of scanout. The
# compositor calls fb_present_flush(x,y,w,h) at each damage-op boundary to
# push the composited rect to the real FB. When fb_shadow_base == 0 (boot
# console / raw /dev/fb path) the present functions write straight to
# scanout exactly as before — behaviour is unchanged off the DE path.
#
# The shadow is RGBA8888 (R,G,B,A byte order, same as the compositor's
# layer caches) so the present functions store the source bytes verbatim;
# pixfmt repacking happens once, in fb_present_flush, on the copy out.
fb_shadow_base:     uint64 = 0          # 0 = no shadow, present->scanout
fb_shadow_pitch_px: uint64 = 0          # pixels per shadow row
# Phase D.5: shadow store order. 0 = RGBA8888 (default; the SW GOP
# fb_present_flush repacks per fb_pixfmt on the copy out). 1 = BGRA8888:
# the shadow-write helpers lay pixels down in the native virtio-gpu scanout
# byte order (B,G,R,A) so the GPU present is a pure 1:1 word-copy DMA into
# vk_gpu_backing_base() with NO per-pixel RGBA->BGRA convert. Only set on
# the GPU present path (a virtio-gpu device owns the scanout); on the SW-GOP
# path it stays 0 so the flush is byte-identical. The composited COLORS are
# unchanged either way — only the in-memory channel order differs.
fb_shadow_bgra:     int32  = 0          # 1 = shadow rows are BGRA8888


def fb_set_shadow(base: uint64, pitch_px: uint64):
    # Install (or clear, base==0) the offscreen present shadow. The caller
    # owns the memory and guarantees pitch_px >= fb_width and that the
    # buffer is at least fb_height rows tall.
    fb_shadow_base = base
    fb_shadow_pitch_px = pitch_px


def fb_set_shadow_bgra(on: int32):
    # Select the shadow store order (Phase D.5). Call with 1 when the DE will
    # present the shadow through the virtio-gpu device (pure-DMA, BGRA-native
    # backing); 0 (default) keeps RGBA for the SW GOP flush. Toggling this
    # does NOT reformat existing pixels, so set it once at shadow install
    # before the first present.
    if on != 0:
        fb_shadow_bgra = 1
    else:
        fb_shadow_bgra = 0


def fb_shadow_is_bgra() -> int32:
    return fb_shadow_bgra


def fb_shadow_active() -> int32:
    if fb_shadow_base == 0:
        return 0
    return 1


def fb_present_flush(x: uint64, y: uint64, w: uint64, h: uint64):
    # Copy the composited rect (x,y,w,h) from the RGBA shadow to scanout in
    # one pass, repacking per fb_pixfmt. This is the ONLY write to scanout
    # on the DE path, so a frame is never seen half-composited. Clipped to
    # screen + shadow bounds. No-op if no shadow is installed.
    if fb_initialized == 0:
        return
    if fb_shadow_base == 0:
        return
    if w == 0 or h == 0:
        return
    # Clip rect to screen.
    x1: uint64 = x + w
    y1: uint64 = y + h
    if x1 > fb_width:
        x1 = fb_width
    if y1 > fb_height:
        y1 = fb_height
    if x >= x1 or y >= y1:
        return
    sy: uint64 = y
    while sy < y1:
        srow: uint64 = fb_shadow_base + (sy * fb_shadow_pitch_px + x) * 4
        sx: uint64 = x
        if fb_bpp == 32:
            dst: uint64 = fb_base + sy * fb_pitch + x * 4
            soff: uint64 = srow
            while sx < x1:
                r: uint8 = cast[Ptr[uint8]](soff)[0]
                g: uint8 = cast[Ptr[uint8]](soff + 1)[0]
                b: uint8 = cast[Ptr[uint8]](soff + 2)[0]
                pix: uint32 = 0
                if fb_pixfmt == FB_PIXFMT_RGB:
                    pix = cast[uint32](r) | (cast[uint32](g) << 8) | \
                          (cast[uint32](b) << 16)
                else:
                    pix = cast[uint32](b) | (cast[uint32](g) << 8) | \
                          (cast[uint32](r) << 16)
                cast[Ptr[uint32]](dst)[0] = pix
                dst = dst + 4
                soff = soff + 4
                sx = sx + 1
        else:
            soff2: uint64 = srow
            while sx < x1:
                r2: uint8 = cast[Ptr[uint8]](soff2)[0]
                g2: uint8 = cast[Ptr[uint8]](soff2 + 1)[0]
                b2: uint8 = cast[Ptr[uint8]](soff2 + 2)[0]
                doff: uint64 = fb_base + sy * fb_pitch + sx * 3
                cast[Ptr[uint8]](doff)[0]     = b2
                cast[Ptr[uint8]](doff + 1)[0] = g2
                cast[Ptr[uint8]](doff + 2)[0] = r2
                soff2 = soff2 + 4
                sx = sx + 1
        sy = sy + 1


def fb_get_base() -> uint64:
    # The framebuffer's mapped base address. Exposed for the /dev/fbpix
    # READ-BACK path (drivers/video/fb_cdev.ad devfbpix_read — the
    # screenshot leaf). NOTE: the console/present RENDER paths stay
    # strictly write-only (WC stores, never loads) for speed; a one-shot
    # screenshot read is the deliberate, latency-tolerant exception and
    # reads through this accessor only.
    return fb_base


def fb_get_width() -> uint64:
    return fb_width


def fb_get_height() -> uint64:
    return fb_height


def fb_get_pitch() -> uint64:
    return fb_pitch


def fb_get_bpp() -> uint64:
    return fb_bpp


def fb_get_pixfmt() -> uint32:
    return fb_pixfmt


def fb_present_rgba_row(src_y: uint64, scr_x0: uint64, scr_y: uint64,
                        w: uint64, src: Ptr[uint8], src_pitch_px: uint64):
    # Present ONE row of an RGBA8888 source buffer to the live
    # framebuffer at screen row scr_y starting at column scr_x0.
    #
    # `src` is row-major RGBA8888 (R,G,B,A bytes). `src_pitch_px` is the
    # number of pixels per source row (the source frame width). We read
    # the source row `src_y` and blit `w` pixels.
    #
    # Each RGBA pixel is repacked to the hardware pixel order per
    # fb_pixfmt (0=RGB byte order R,G,B,X ; else BGR B,G,R,X) and stored
    # honouring fb_pitch. Out-of-bounds screen columns/rows are clipped.
    #
    # Pure STORE pass — no framebuffer reads (same WC-friendly discipline
    # as the console glyph blitter).
    if fb_initialized == 0:
        return
    if scr_y >= fb_height:
        return
    src_base: uint64 = (src_y * src_pitch_px) * 4
    # DOUBLE-BUFFERED present: when a shadow is installed, store the RGBA
    # source verbatim into the offscreen shadow (no scanout write, no
    # pixfmt repack — that happens once on fb_present_flush). Keeps the
    # composite tear-free and the inner loop a plain RAM copy.
    if fb_shadow_base != 0:
        xs: uint64 = 0
        while xs < w:
            scr_xs: uint64 = scr_x0 + xs
            if scr_xs >= fb_width:
                break
            sos: uint64 = src_base + xs * 4
            dos: uint64 = fb_shadow_base + (scr_y * fb_shadow_pitch_px \
                          + scr_xs) * 4
            if fb_shadow_bgra != 0:
                # BGRA-native store (R/B swap) — source stays RGBA.
                cast[Ptr[uint8]](dos)[0]     = src[sos + 2]
                cast[Ptr[uint8]](dos + 1)[0] = src[sos + 1]
                cast[Ptr[uint8]](dos + 2)[0] = src[sos]
            else:
                cast[Ptr[uint8]](dos)[0]     = src[sos]
                cast[Ptr[uint8]](dos + 1)[0] = src[sos + 1]
                cast[Ptr[uint8]](dos + 2)[0] = src[sos + 2]
            cast[Ptr[uint8]](dos + 3)[0] = 255
            xs = xs + 1
        return
    x: uint64 = 0
    while x < w:
        scr_x: uint64 = scr_x0 + x
        if scr_x >= fb_width:
            break
        so: uint64 = src_base + x * 4
        r: uint8 = src[so]
        g: uint8 = src[so + 1]
        b: uint8 = src[so + 2]
        # Pack into the hardware 32-bit word. RGB byte order means the
        # low byte is red; BGR means the low byte is blue.
        pix: uint32 = 0
        if fb_pixfmt == FB_PIXFMT_RGB:
            pix = cast[uint32](r) | (cast[uint32](g) << 8) | \
                  (cast[uint32](b) << 16)
        else:
            pix = cast[uint32](b) | (cast[uint32](g) << 8) | \
                  (cast[uint32](r) << 16)
        if fb_bpp == 32:
            off: uint64 = scr_y * fb_pitch + scr_x * 4
            cast[Ptr[uint32]](fb_base + off)[0] = pix
        else:
            off2: uint64 = scr_y * fb_pitch + scr_x * 3
            cast[Ptr[uint8]](fb_base + off2)[0]     = b
            cast[Ptr[uint8]](fb_base + off2 + 1)[0] = g
            cast[Ptr[uint8]](fb_base + off2 + 2)[0] = r
        x = x + 1


def _fb_blend8(s: uint8, d: uint8, a: uint8) -> uint8:
    # 8-bit source-over blend: out = (s*a + d*(255-a)) / 255.
    return cast[uint8]((cast[uint32](s) * cast[uint32](a) \
                        + cast[uint32](d) * (255 - cast[uint32](a))) / 255)


def fb_present_rgba_row_blend(src_y: uint64, scr_x0: uint64, scr_y: uint64,
                              w: uint64, src: Ptr[uint8],
                              src_pitch_px: uint64):
    # Alpha-BLENDED row blit: source-over composite of an RGBA8888 source row
    # onto whatever is already on the destination (the offscreen shadow when
    # installed, else scanout). Per-pixel: alpha==0 skips (dest kept),
    # alpha==255 stores opaque (fast path, no readback), 0<alpha<255 reads the
    # destination pixel and blends. Used for anti-aliased rounded window-chrome
    # corners (the SSD titlebar) where the destination already holds the
    # composited backdrop / lower windows painted earlier this present pass —
    # so the AA fringe blends against the TRUE pixels behind the corner, not a
    # guessed background colour.
    if fb_initialized == 0:
        return
    if scr_y >= fb_height:
        return
    src_base: uint64 = (src_y * src_pitch_px) * 4
    # SHADOW branch: dest is RGBA8888 verbatim in cached RAM — read/write direct.
    if fb_shadow_base != 0:
        xs: uint64 = 0
        while xs < w:
            scr_xs: uint64 = scr_x0 + xs
            if scr_xs >= fb_width:
                break
            sos: uint64 = src_base + xs * 4
            a: uint8 = src[sos + 3]
            if a != 0:
                dos: uint64 = fb_shadow_base + (scr_y * fb_shadow_pitch_px \
                              + scr_xs) * 4
                # Channel byte offsets in the destination shadow pixel. RGBA:
                # (R,G,B) = (0,1,2). BGRA: (B,G,R) = (0,1,2) so R and B swap.
                # The blend is per-channel symmetric, so composing src R over
                # dest byte-2 (BGRA) is identical to src R over dest byte-0
                # (RGBA) — same visible color, different lane.
                cr: uint64 = 0
                cb: uint64 = 2
                if fb_shadow_bgra != 0:
                    cr = 2
                    cb = 0
                if a == 255:
                    cast[Ptr[uint8]](dos + cr)[0]  = src[sos]
                    cast[Ptr[uint8]](dos + 1)[0]   = src[sos + 1]
                    cast[Ptr[uint8]](dos + cb)[0]  = src[sos + 2]
                else:
                    cast[Ptr[uint8]](dos + cr)[0] = \
                        _fb_blend8(src[sos], cast[Ptr[uint8]](dos + cr)[0], a)
                    cast[Ptr[uint8]](dos + 1)[0] = \
                        _fb_blend8(src[sos + 1], cast[Ptr[uint8]](dos + 1)[0], a)
                    cast[Ptr[uint8]](dos + cb)[0] = \
                        _fb_blend8(src[sos + 2], cast[Ptr[uint8]](dos + cb)[0], a)
                cast[Ptr[uint8]](dos + 3)[0] = 255
            xs = xs + 1
        return
    # SCANOUT branch: dest is hardware-packed; read + unpack for the blend.
    x: uint64 = 0
    while x < w:
        scr_x: uint64 = scr_x0 + x
        if scr_x >= fb_width:
            break
        so: uint64 = src_base + x * 4
        a2: uint8 = src[so + 3]
        if a2 == 0:
            x = x + 1
            continue
        r: uint8 = src[so]
        g: uint8 = src[so + 1]
        b: uint8 = src[so + 2]
        if a2 != 255:
            dr: uint8 = 0
            dg: uint8 = 0
            db: uint8 = 0
            if fb_bpp == 32:
                offr: uint64 = scr_y * fb_pitch + scr_x * 4
                dpix: uint32 = cast[Ptr[uint32]](fb_base + offr)[0]
                if fb_pixfmt == FB_PIXFMT_RGB:
                    dr = cast[uint8](dpix & 0xff)
                    dg = cast[uint8]((dpix >> 8) & 0xff)
                    db = cast[uint8]((dpix >> 16) & 0xff)
                else:
                    db = cast[uint8](dpix & 0xff)
                    dg = cast[uint8]((dpix >> 8) & 0xff)
                    dr = cast[uint8]((dpix >> 16) & 0xff)
            else:
                offr2: uint64 = scr_y * fb_pitch + scr_x * 3
                db = cast[Ptr[uint8]](fb_base + offr2)[0]
                dg = cast[Ptr[uint8]](fb_base + offr2 + 1)[0]
                dr = cast[Ptr[uint8]](fb_base + offr2 + 2)[0]
            r = _fb_blend8(r, dr, a2)
            g = _fb_blend8(g, dg, a2)
            b = _fb_blend8(b, db, a2)
        pix2: uint32 = 0
        if fb_pixfmt == FB_PIXFMT_RGB:
            pix2 = cast[uint32](r) | (cast[uint32](g) << 8) | \
                   (cast[uint32](b) << 16)
        else:
            pix2 = cast[uint32](b) | (cast[uint32](g) << 8) | \
                   (cast[uint32](r) << 16)
        if fb_bpp == 32:
            offw: uint64 = scr_y * fb_pitch + scr_x * 4
            cast[Ptr[uint32]](fb_base + offw)[0] = pix2
        else:
            offw2: uint64 = scr_y * fb_pitch + scr_x * 3
            cast[Ptr[uint8]](fb_base + offw2)[0]     = b
            cast[Ptr[uint8]](fb_base + offw2 + 1)[0] = g
            cast[Ptr[uint8]](fb_base + offw2 + 2)[0] = r
        x = x + 1


def fb_present_rgba_row_keyed(src_y: uint64, scr_x0: uint64, scr_y: uint64,
                              w: uint64, src: Ptr[uint8],
                              src_pitch_px: uint64):
    # Alpha-KEYED row blit: identical to fb_present_rgba_row EXCEPT source
    # pixels whose alpha byte is 0 are SKIPPED (left as whatever is already
    # on the framebuffer). This is the cursor-sprite blit: the 32x32 cursor
    # cache is mostly transparent padding (memset 0 => RGBA 0,0,0,0) around
    # a small opaque arrow/box. fb_present_rgba_row is alpha-BLIND and would
    # paint that padding as an OPAQUE BLACK square — the "black box trailing
    # the cursor" flicker the user saw. Keying on alpha==0 paints ONLY the
    # sprite, so the backdrop/window under the cursor shows through.
    if fb_initialized == 0:
        return
    if scr_y >= fb_height:
        return
    src_base: uint64 = (src_y * src_pitch_px) * 4
    # DOUBLE-BUFFERED keyed present: write the opaque sprite pixels into the
    # shadow (skip alpha==0). Scanout sees them on the next fb_present_flush.
    if fb_shadow_base != 0:
        xs: uint64 = 0
        while xs < w:
            scr_xs: uint64 = scr_x0 + xs
            if scr_xs >= fb_width:
                break
            sos: uint64 = src_base + xs * 4
            if src[sos + 3] != 0:
                dos: uint64 = fb_shadow_base + (scr_y * fb_shadow_pitch_px \
                              + scr_xs) * 4
                if fb_shadow_bgra != 0:
                    cast[Ptr[uint8]](dos)[0]     = src[sos + 2]
                    cast[Ptr[uint8]](dos + 1)[0] = src[sos + 1]
                    cast[Ptr[uint8]](dos + 2)[0] = src[sos]
                else:
                    cast[Ptr[uint8]](dos)[0]     = src[sos]
                    cast[Ptr[uint8]](dos + 1)[0] = src[sos + 1]
                    cast[Ptr[uint8]](dos + 2)[0] = src[sos + 2]
                cast[Ptr[uint8]](dos + 3)[0] = 255
            xs = xs + 1
        return
    x: uint64 = 0
    while x < w:
        scr_x: uint64 = scr_x0 + x
        if scr_x >= fb_width:
            break
        so: uint64 = src_base + x * 4
        a: uint8 = src[so + 3]
        if a == 0:
            x = x + 1
            continue
        r: uint8 = src[so]
        g: uint8 = src[so + 1]
        b: uint8 = src[so + 2]
        pix: uint32 = 0
        if fb_pixfmt == FB_PIXFMT_RGB:
            pix = cast[uint32](r) | (cast[uint32](g) << 8) | \
                  (cast[uint32](b) << 16)
        else:
            pix = cast[uint32](b) | (cast[uint32](g) << 8) | \
                  (cast[uint32](r) << 16)
        if fb_bpp == 32:
            off: uint64 = scr_y * fb_pitch + scr_x * 4
            cast[Ptr[uint32]](fb_base + off)[0] = pix
        else:
            off2: uint64 = scr_y * fb_pitch + scr_x * 3
            cast[Ptr[uint8]](fb_base + off2)[0]     = b
            cast[Ptr[uint8]](fb_base + off2 + 1)[0] = g
            cast[Ptr[uint8]](fb_base + off2 + 2)[0] = r
        x = x + 1

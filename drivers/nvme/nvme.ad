# drivers/nvme/nvme.ad
#
# Bare-metal NVMe (NVM Express) driver. NVMe is the modern PCIe-attached
# storage protocol that displaced AHCI on essentially every new
# desktop/laptop/server SSD shipped since ~2014. AHCI (drivers/ata/ahci.ad)
# still covers SATA, but NVMe is what's actually in a 2026 ThinkPad or
# 1U server.
#
# Scope of this driver (one milestone, polled, no IRQs):
#
#   1. Walk the PCI bus for class=0x01, subclass=0x08, prog_if=0x02 —
#      the NVMe class triple.
#   2. Map BAR0 (a MEM BAR covering controller registers + the doorbell
#      array at +0x1000).
#   3. Run the controller reset / init dance:
#         - clear CC.EN, wait CSTS.RDY=0
#         - point ASQ/ACQ at kmalloc'd 4 KiB pages
#         - write AQA (admin queue depths = 63)
#         - set CC (MPS=0 → 4 KiB pages, IOSQES=6, IOCQES=4,
#           CSS=0 NVM command set, EN=1)
#         - wait CSTS.RDY=1
#   4. Submit admin commands via a 64-byte SQ entry → tail doorbell →
#      poll CQ phase bit → head doorbell. The commands we send:
#         - IDENTIFY controller (opc 0x06, CNS=1)  → model + serial
#         - IDENTIFY active-NS list (opc 0x06, CNS=2) → enumerate every
#           active namespace, then IDENTIFY namespace (CNS=0) per nsid
#           → LBA count + logical block size into a namespace table
#         - SET FEATURES (opc 0x09, FID 0x07, Number of Queues) → ask
#           for N I/O queue pairs, clamp to what the controller grants
#         - CREATE I/O CQ (opc 0x05) + CREATE I/O SQ (opc 0x01) per qid,
#           qid=1..N (each its own SQ/CQ memory, phase bit, doorbell)
#         - I/O READ (opc 0x02) of LBA 0 on namespace 1
#
#      Multi-queue + multi-namespace: each active namespace is registered
#      with the block layer as nvme0n<nsid>; reads/writes route to the
#      correct namespace by nsid and are spread round-robin across the
#      live I/O queues.
#   5. Decode 16 bytes of LBA 0; check MBR signature 0x55/0xAA at
#      bytes 510..511 and log "[nvme] MBR signature OK" on a match.
#
# Why polled? Same constraint as virtio-net / ahci: the kernel brings
# up the LAPIC for the timer tick but has no IOAPIC routing for PCI
# INTx, and MSI/MSI-X wiring is its own milestone. We busy-poll the
# completion queue's phase bit instead — every CQ entry's bit 0 of
# DW3 flips between 0 and 1 each pass through the queue, and we know
# we own a completion when the phase doesn't match the expected
# previous value.
#
# References:
#   - NVMe base spec rev 1.4 (chapter 3 admin cmds, chapter 6 I/O cmds)
#   - Linux drivers/nvme/host/pci.c
#   - drivers/ata/ahci.ad (the closest sibling in-tree)

from kernel.printk.printk import printk0, printk1, printk2
from drivers.pci.pci import (
    pci_config_read_dword, pci_config_write_dword,
    pci_config_read_byte,
    pci_bdf_bus, pci_bdf_dev, pci_bdf_fn, pci_pack_bdf,
    pci_read_bar, PCI_BDF_NONE,
    PCI_COMMAND_OFFSET, PCI_COMMAND_MEM, PCI_COMMAND_MASTER,
)
from arch.x86.kernel.apic import ioapic_redirect
from arch.x86.kernel.irq import register_irq_handler
from mm.page_alloc import alloc_pages
from mm.page_alloc import free_pages
from mm.slab import kmalloc
# Higher-half kernel: a caller-supplied DMA buffer that is a kernel
# global needs virt_to_phys() rebasing before the NVMe controller
# DMAs to it (PRP entries hold physical addresses).
from arch.x86.mm.pgtable import virt_to_phys
from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, find_blockdev,
    blk_read_sectors, blk_write_sectors, SECTOR_SIZE,
    blk_scan_partitions, blk_register_partitions,
)

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


# PCI config-space offsets used by the IRQ wiring path.
NVME_PCI_INTERRUPT_LINE: uint32 = 0x3C
NVME_PCI_INTERRUPT_PIN:  uint32 = 0x3D

# CPU vector this driver claims for its INTx IRQ. virtio-net = 0x40;
# AHCI = 0x41; NVMe = 0x42 (M16.114 IRQ-wiring batch).
NVME_IRQ_VECTOR: uint32 = 0x42
NVME_LAPIC_ID:   uint32 = 0


# --- PCI matching --------------------------------------------------
#
# NVMe controllers report a standard mass-storage class / non-volatile-
# memory subclass / NVMe prog_if triple regardless of vendor. We match
# on the class so the driver works against QEMU's emulated NVMe
# (1b36:0010), Samsung 970/980, WD Black SN850, Intel 760p, etc.
NVME_CLASS:    uint32 = 0x01
NVME_SUBCLASS: uint32 = 0x08
NVME_PROGIF:   uint32 = 0x02


# --- Controller register offsets (BAR0 + N) -----------------------
#
# Only the registers we actually touch. Full layout is in NVMe base
# spec §3.1 (table 24). The doorbell array starts at 0x1000 and is
# stride-dependent on CAP.DSTRD — for the qemu nvme device and all
# common controllers DSTRD=0 → 4-byte stride.
NVME_CAP:     uint64 = 0x00     # 64-bit Controller Capabilities
NVME_VS:      uint64 = 0x08     # 32-bit Version
NVME_CC:      uint64 = 0x14     # 32-bit Controller Configuration
NVME_CSTS:    uint64 = 0x1C     # 32-bit Controller Status
NVME_AQA:     uint64 = 0x24     # 32-bit Admin Queue Attributes
NVME_ASQ:     uint64 = 0x28     # 64-bit Admin Submission Queue Base
NVME_ACQ:     uint64 = 0x30     # 64-bit Admin Completion Queue Base
NVME_DOORBELL_BASE: uint64 = 0x1000

# CC (Controller Configuration) bit fields we set.
#   EN     bit  0  — controller enable
#   CSS    bits 4..6 — command set select (0 = NVM)
#   MPS    bits 7..10 — memory page size, encoded as 2^(12+MPS).
#                       MPS=0 → 4 KiB host pages. Required to match
#                       the host's PRP entry alignment.
#   AMS    bits 11..13 — arbitration (0 = round-robin)
#   SHN    bits 14..15 — shutdown notification (0 = no shutdown)
#   IOSQES bits 16..19 — I/O SQ entry size, encoded as 2^N.
#                        N=6 → 64-byte SQ entries (the spec mandate).
#   IOCQES bits 20..23 — I/O CQ entry size, 2^N. N=4 → 16-byte CQ
#                        entries (also spec-mandated).
NVME_CC_EN:     uint32 = 0x1
NVME_CC_CSS_NVM: uint32 = 0x0          # NVM command set (default)
NVME_CC_MPS_4K:  uint32 = 0x0          # 4 KiB page size
NVME_CC_AMS_RR:  uint32 = 0x0          # round-robin arbitration
NVME_CC_IOSQES_6: uint32 = 0x60000     # (6 << 16) — 64B SQ entry
NVME_CC_IOCQES_4: uint32 = 0x400000    # (4 << 20) — 16B CQ entry

# CSTS (Controller Status) bit fields.
NVME_CSTS_RDY:  uint32 = 0x1           # bit 0 — controller ready
NVME_CSTS_CFS:  uint32 = 0x2           # bit 1 — fatal error


# --- Queue geometry -------------------------------------------------
#
# NVMe SQ entries are 64 bytes, CQ entries are 16 bytes. We size both
# admin and I/O queues to 64 entries, which fits 4 KiB SQ and 1 KiB CQ
# allocations comfortably within one page each.
NVME_QUEUE_DEPTH: uint32 = 64
NVME_SQ_ENTRY_BYTES: uint64 = 64
NVME_CQ_ENTRY_BYTES: uint64 = 16

# Admin queue identifier — always 0. The first I/O queue we create
# is qid=1.
NVME_ADMIN_QID: uint32 = 0
NVME_IO_QID:    uint32 = 1

# Host page size for PRP arithmetic. CC.MPS=0 -> 4 KiB. NVMe spec §4.3
# (Physical Region Page Entry and List) requires PRP1 to carry an
# intra-page offset matching this page boundary, while PRP2 and every
# entry of a PRP list must be page-aligned (offset = 0).
NVME_PAGE_SIZE: uint64 = 4096
NVME_PAGE_MASK: uint64 = 0xFFF
# Each PRP-list entry is 8 bytes (uint64 LE); a 4 KiB list page holds
# 512 entries. The last entry is reserved for chaining when the transfer
# needs more than 512+1 pages — it must point at the next PRP-list page,
# whose own entries continue the chain.
NVME_PRP_ENTRIES_PER_PAGE: uint64 = 512


# --- Admin and I/O command opcodes (NVMe §5 / §6.x) ----------------
NVME_ADMIN_DELETE_SQ:   uint8 = 0x00
NVME_ADMIN_CREATE_SQ:   uint8 = 0x01
NVME_ADMIN_GET_LOG:     uint8 = 0x02
NVME_ADMIN_DELETE_CQ:   uint8 = 0x04
NVME_ADMIN_CREATE_CQ:   uint8 = 0x05
NVME_ADMIN_IDENTIFY:    uint8 = 0x06
NVME_ADMIN_ABORT:       uint8 = 0x08
NVME_ADMIN_SET_FEATURES: uint8 = 0x09
NVME_ADMIN_GET_FEATURES: uint8 = 0x0A
NVME_ADMIN_ASYNC_EVENT: uint8 = 0x0C    # Asynchronous Event Request

# --- Asynchronous Event Request (admin opcode 0x0C) ----------------
#
# An AER is "submitted and forgotten": the controller does NOT complete
# it until an asynchronous event actually occurs (a health/critical-
# warning state change, an error-log entry, a namespace-attribute change,
# etc.). The host is expected to keep up to AERL+1 of them outstanding at
# all times. When the controller posts a completion, DW0 carries the
# event:
#   bits  0..2   Asynchronous Event Type
#                  0 = Error, 1 = SMART/Health, 2 = Notice, 6 = I/O cmd,
#                  7 = Vendor specific
#   bits  8..15  Asynchronous Event Information (type-specific)
#   bits 16..23  Associated Log Page identifier (the log to GET to clear
#                the event and learn the detail)
# After draining an AER completion the host SHOULD read the indicated log
# page (which clears the event in the controller) and then submit a fresh
# AER to keep the queue full.
NVME_AER_TYPE_ERROR:  uint32 = 0x0
NVME_AER_TYPE_SMART:  uint32 = 0x1
NVME_AER_TYPE_NOTICE: uint32 = 0x2

# Error Information log identifier (GET LOG PAGE log id 0x01). Read on an
# AER "Error" event to retrieve the most recent error-log entries.
NVME_LOG_ERROR:       uint32 = 0x01
# Error Information log entries are 64 bytes each; we read one entry.
NVME_ERROR_LOG_BYTES: uint32 = 64

# How many AERs we attempt to keep outstanding. Clamped to AERL+1 read
# from Identify Controller byte 259 (AERL is 0-based). Most controllers
# (incl. QEMU's nvme) report AERL=3 → 4 outstanding.
NVME_AER_MAX_OUTSTANDING: uint32 = 4

NVME_IO_FLUSH:          uint8 = 0x00
NVME_IO_WRITE:          uint8 = 0x01
NVME_IO_READ:           uint8 = 0x02

# IDENTIFY CNS values (CDW10[7..0]).
NVME_CNS_NAMESPACE:     uint32 = 0x00
NVME_CNS_CONTROLLER:    uint32 = 0x01
# CNS=0x02 — Active Namespace ID list. Returns a 4 KiB buffer of up to
# 1024 little-endian uint32 NSIDs (terminated by a zero entry), all
# greater than the NSID given in CDW1.
NVME_CNS_ACTIVE_NS_LIST: uint32 = 0x02

# GET LOG PAGE (admin opcode 0x02) log identifiers (CDW10[7..0]).
# 0x02 is the SMART / Health Information log — a 512-byte structure with
# the controller's health summary (critical-warning flags, composite
# temperature, available spare, percentage used, and 128-bit data
# units / host read/write / command counters).
NVME_LOG_SMART:         uint32 = 0x02
# The SMART/Health log page is 512 bytes.
NVME_SMART_LOG_BYTES:   uint32 = 512

# SET/GET FEATURES: Number of Queues feature (FID 0x07). The SET request
# in CDW11 packs [NCQR:16..31 | NSQR:0..15] as 0-based queue counts; the
# completion DW0 returns the granted counts in the same layout.
NVME_FEAT_NUM_QUEUES:   uint32 = 0x07

# How many I/O queue pairs we are willing to create, capped by whatever
# the controller grants via SET FEATURES (Number of Queues). One admin
# queue (qid 0) is always present and separate. qids run 1..NVME_MAX_IO_QUEUES.
NVME_MAX_IO_QUEUES:     uint32 = 4
# Maximum namespaces we track in the namespace table.
NVME_MAX_NS:            uint32 = 8


# --- Driver state --------------------------------------------------
#
# Multi-controller is still out of scope (one active controller), but
# this driver now creates N I/O queue pairs and enumerates every active
# namespace the controller exposes.
#
# Per-queue bookkeeping (SQ/CQ rings, head/tail, phase, cid) lives in
# module-scope parallel arrays indexed by qid. Index 0 is the admin
# queue; indices 1..NVME_MAX_IO_QUEUES are I/O queues. The legacy
# single-queue fields on NvmeState (iosq/iocq/iosq_tail/...) are retained
# as mirrors of qid=1 so the pre-existing IRQ handler + any external
# reader keeps working unchanged.

class NvmeState:
    bar0:           uint64       # MMIO base
    doorbell_stride: uint32      # bytes between doorbells (4 << CAP.DSTRD)

    asq:            uint64       # Admin SQ ring (4 KiB page)
    acq:            uint64       # Admin CQ ring (4 KiB page)
    asq_tail:       uint32       # next slot to write
    acq_head:       uint32       # next slot to read
    acq_phase:      uint32       # current expected phase bit (0/1)
    admin_cid:      uint32       # monotonic command id

    iosq:           uint64       # I/O SQ ring (mirror of qid=1)
    iocq:           uint64       # I/O CQ ring (mirror of qid=1)
    iosq_tail:      uint32
    iocq_head:      uint32
    iocq_phase:     uint32
    io_cid:         uint32

    n_io_queues:    uint32       # number of live I/O queue pairs (1..N)
    rr_next:        uint32       # round-robin cursor over I/O queues

    n_namespaces:   uint32       # active namespaces discovered

    nsze:           uint64       # namespace 1 size (LBA count) — legacy mirror

    irq_pin:        uint32       # IOAPIC pin we redirected (diag)
    pad_irq:        uint32
    irq_count:      uint64       # IRQs handled

    # PCI bus/device/function of the active controller, captured at probe
    # so the timeout->reset-recovery path can re-run the init dance
    # (re-enable BAR/bus-master, re-read BAR0) without re-scanning PCI.
    bdf:            uint32

    # --- Asynchronous Event Request bookkeeping -------------------
    # aer_limit  = AERL+1 (max AERs the controller wants outstanding),
    #              clamped to NVME_AER_MAX_OUTSTANDING.
    # aer_outstanding = how many AERs we currently have submitted.
    # aer_events = count of async-event completions we have drained.
    # aer_last_* = decode of the most recently drained AER completion.
    aer_limit:          uint32
    aer_outstanding:    uint32
    aer_events:         uint64
    aer_last_type:      uint32
    aer_last_info:      uint32
    aer_last_logpage:   uint32

    # --- Timeout / abort / reset-recovery bookkeeping -------------
    # abort_count = admin Abort commands that round-tripped.
    # reset_count = controller-level reset recoveries performed.
    abort_count:        uint64
    reset_count:        uint64

    # 40-byte controller model string + NUL.
    model:          Array[41, uint8]
    # 20-byte controller serial number + NUL.
    serial:         Array[21, uint8]

    # SMART / Health Information snapshot, captured from the last GET LOG
    # PAGE (log id 0x02). smart_valid is 1 once a successful fetch has
    # populated these. Temperature is in Kelvin (raw log value); the
    # lower-64-bits of the 128-bit data/host/command counters are kept
    # (they overwhelmingly suffice for any realistic device lifetime).
    smart_valid:        uint32
    smart_crit_warning: uint32   # byte 0: critical-warning bitmask
    smart_temp_k:       uint32   # bytes 1..2: composite temp (Kelvin)
    smart_avail_spare:  uint32   # byte 3: available spare (%)
    smart_percent_used: uint32   # byte 5: percentage used (endurance)
    smart_data_units_read:  uint64   # bytes 32..47 (low 64), 1000×512B
    smart_data_units_written: uint64 # bytes 48..63 (low 64), 1000×512B
    smart_host_reads:   uint64   # bytes 64..79 (low 64)
    smart_host_writes:  uint64   # bytes 80..95 (low 64)


nvme: NvmeState

# --- Per-I/O-queue ring state (indexed by qid) --------------------
#
# Sized to NVME_MAX_IO_QUEUES+1 so qid can index directly (qid 0 = admin
# slot is left unused in the I/O arrays; admin uses NvmeState.asq/acq).
# Adder needs module-scope arrays for these; per-queue scalars are tiny
# but keeping them parallel-array keeps the qid-indexed doorbell math
# uniform.
io_sq_base:   Array[5, uint64]    # I/O SQ ring physical/virt base per qid
io_cq_base:   Array[5, uint64]    # I/O CQ ring base per qid
io_sq_tail:   Array[5, uint32]    # next SQ slot to write per qid
io_cq_head:   Array[5, uint32]    # next CQ slot to read per qid
io_cq_phase:  Array[5, uint32]    # expected phase bit per qid
io_q_cid:     Array[5, uint32]    # monotonic command id per qid

# --- Per-queue PRP-list page pools --------------------------------
#
# Each I/O queue needs its own pool of PRP-list scratch pages (one per
# SQE slot) so concurrent submissions on different queues never alias a
# list page. Flattened [qid * NVME_QUEUE_DEPTH + slot]. qid range is
# 1..NVME_MAX_IO_QUEUES so we size for (NVME_MAX_IO_QUEUES+1)*depth.
io_prp_list_pages_mq: Array[320, uint64]   # (4+1) * 64

# --- Namespace table ----------------------------------------------
#
# Parallel arrays indexed 0..n_namespaces-1. ns_id holds the NVMe NSID
# (1-based, not necessarily contiguous), ns_lba_count the LBA capacity
# from IDENTIFY namespace, ns_block_size the per-namespace logical block
# size in bytes (decoded from the active LBA format / LBADS).
ns_id:         Array[8, uint32]
ns_lba_count:  Array[8, uint64]
ns_block_size: Array[8, uint32]
# Block-layer registration table for the active controller's
# namespace 1. Populated in nvme_smoke_test once IDENTIFY +
# CREATE-IO-CQ/SQ + read-of-LBA-0 have all proven healthy, then
# handed to register_blockdev("nvme0n1", ...). priv carries the
# namespace id (uint64-encoded) so the adapter wrappers can pass
# the right NSID through to the I/O primitives.
nvme_ops: BlockDeviceOps


# --- PRP-list page pool (V4.2 — multi-page transfers) -------------
#
# NVMe spec §4.3 requires that any transfer crossing more than two host
# pages reference a PRP-list page in PRP2, where each list entry points
# to a page-aligned physical address (8 bytes LE per entry). PRP1 may
# carry an intra-page offset (low 12 bits); every other PRP reference
# (PRP2 directly + all PRP-list entries) MUST be page-aligned.
#
# The pre-V4.2 driver only wrote PRP1, so transfers whose buffer crossed
# a page boundary silently dropped the bytes past the first page edge
# (the SQE still completed "successfully"). This surfaced through the
# GPT mkpart write path in commit c38188d: a 512-byte transfer landing
# at intra-page offset 0xF10 lost 240 bytes. The bug was papered over
# with a caller-side bounce buffer in drivers/block/partition.ad; that
# bounce becomes unnecessary once this pool + the PRP2 logic land.
#
# Lifecycle (per-SQE-slot ownership):
#   - Queue depth is NVME_QUEUE_DEPTH (64). We allocate 64 page-aligned
#     scratch pages once at I/O queue setup. Each slot owns one
#     PRP-list page indexed by `iosq_tail` at the moment the SQE is
#     built. The polled-completion model guarantees the controller is
#     done with slot N's list page before that slot wraps around the
#     ring and gets reused.
#   - For ≤2-page transfers we set PRP2 directly (no list page touched).
#   - For >2-page transfers we populate the slot's list page with one
#     8-byte entry per page after the first, then write PRP2 = the list
#     page's physical address.
#   - >512+1 pages: the last entry of the list page chains to a second
#     list page. Single-list-page covers up to 512 entries × 4 KiB +
#     the first page = ~2 MiB. The chain path is supported but exercised
#     only by tests/test_nvme_prp.ad at large sizes; the block layer
#     today never submits a single command beyond NLB=65536 sectors
#     (32 MiB) which would need ~8192 entries and hence ~16 chained
#     list pages.
io_prp_list_pages: Array[64, uint64]
io_prp_pool_ready: int32 = 0
# Per-queue pool readiness (qid-indexed). qid=1's pool aliases the
# legacy io_prp_list_pages above for byte-for-byte backward compat;
# qids 2..N use io_prp_list_pages_mq.
io_prp_pool_ready_mq: Array[5, int32]


# --- MMIO helpers --------------------------------------------------

def _nvme_mmio_r32(addr: uint64) -> uint32:
    return cast[Ptr[uint32]](addr)[0]


def _nvme_mmio_w32(addr: uint64, value: uint32):
    cast[Ptr[uint32]](addr)[0] = value


def _nvme_mmio_r64(addr: uint64) -> uint64:
    return cast[Ptr[uint64]](addr)[0]


def _nvme_mmio_w64(addr: uint64, value: uint64):
    cast[Ptr[uint64]](addr)[0] = value


# --- PCI plumbing --------------------------------------------------
#
# We open-code the class-match scan rather than depending on a shared
# helper. drivers/pci/pci.ad's pci_find is vendor:device only; AHCI
# similarly carries its own _nvme_pci_find_class. Keeping it local makes
# the driver entirely self-contained at the PCI layer.

def _nvme_pci_find_class(class_code: uint32, subclass: uint32,
                    prog_if: uint32) -> uint32:
    # Bridge-aware PCI class scan. The original form scanned bus 0,
    # function 0 only — which misses any controller behind a PCIe root
    # port / PCI-to-PCI bridge. On the Intel Skull Canyon NUC the NVMe
    # SSD sits on a secondary bus behind a PCH root port (class 0x0604),
    # so a bus-0 scan returned PCI_BDF_NONE, nvme0n1 never registered,
    # and the installer's `cat /dev/blk/nvme0n1/size` + hamnix_partition
    # both failed with "cannot read device size". We BFS the bridge
    # tree: seed a work queue with bus 0, scan every function of every
    # device (multifunction via the header-type bit), and each PCI-to-PCI
    # bridge we meet enqueues its secondary-bus number (config 0x18,
    # bits 8..15) so its children are scanned too.
    queue: Array[64, uint32]
    qhead: uint64 = 0
    qtail: uint64 = 0
    queue[0] = 0
    qtail = 1
    while qhead < qtail:
        bus: uint32 = queue[qhead]
        qhead = qhead + 1
        dev: uint32 = 0
        while dev < 32:
            # Function 0 decides how many functions this slot exposes.
            ident0: uint32 = pci_config_read_dword(bus, dev, 0, 0x00)
            nfn: uint32 = 1
            if (ident0 & 0xFFFF) != 0xFFFF:
                hdr0: uint32 = pci_config_read_dword(bus, dev, 0, 0x0C)
                if ((hdr0 >> 16) & 0x80) != 0:
                    nfn = 8
            fn: uint32 = 0
            while fn < nfn:
                ident: uint32 = pci_config_read_dword(bus, dev, fn, 0x00)
                v: uint32 = ident & 0xFFFF
                if v != 0xFFFF:
                    cls: uint32 = pci_config_read_dword(bus, dev, fn, 0x08)
                    this_class:    uint32 = (cls >> 24) & 0xFF
                    this_subclass: uint32 = (cls >> 16) & 0xFF
                    this_progif:   uint32 = (cls >>  8) & 0xFF
                    if this_class == class_code \
                       and this_subclass == subclass \
                       and this_progif == prog_if:
                        printk2("[nvme] match at bus=%x dev=%x\n",
                                cast[uint64](bus), cast[uint64](dev))
                        return pci_pack_bdf(bus, dev, fn)
                    # PCI-to-PCI bridge (base 0x06 / sub 0x04): walk its
                    # secondary bus so devices below the root port are
                    # discovered. Guard the queue bound and skip a zero
                    # secondary (unconfigured bridge).
                    if this_class == 0x06 and this_subclass == 0x04:
                        busnums: uint32 = pci_config_read_dword(bus, dev,
                                                                fn, 0x18)
                        sec: uint32 = (busnums >> 8) & 0xFF
                        if sec != 0 and qtail < 64:
                            queue[qtail] = sec
                            qtail = qtail + 1
                fn = fn + 1
            dev = dev + 1
    return PCI_BDF_NONE


def _nvme_pci_enable_mem_and_master(bdf: uint32):
    # NVMe BAR0 is a MEM BAR, plus the controller needs to DMA into
    # host memory (PRP entries / completion queue writes) — both
    # require Memory Space Enable + Bus Master.
    bus: uint32 = pci_bdf_bus(bdf)
    dev: uint32 = pci_bdf_dev(bdf)
    fn:  uint32 = pci_bdf_fn(bdf)
    cmd: uint32 = pci_config_read_dword(bus, dev, fn,
                                        PCI_COMMAND_OFFSET) & 0xFFFF
    cmd = cmd | PCI_COMMAND_MEM | PCI_COMMAND_MASTER
    upper: uint32 = pci_config_read_dword(bus, dev, fn,
                                          PCI_COMMAND_OFFSET) & 0xFFFF0000
    pci_config_write_dword(bus, dev, fn, PCI_COMMAND_OFFSET,
                           upper | cmd)


def _pci_read_bar0_64(bdf: uint32) -> uint64:
    # NVMe BAR0 is a 64-bit MEM BAR (type bits in [1..3] = 0b10).
    # The address spans BAR0 (low 32) and BAR1 (high 32).
    low: uint32  = pci_read_bar(bdf, 0)
    high: uint32 = pci_read_bar(bdf, 1)
    # Mask the type/prefetch bits out of the low half.
    base: uint64 = cast[uint64](low & 0xFFFFFFF0) \
                 | (cast[uint64](high) << 32)
    return base


# --- Controller reset / enable -------------------------------------

def _wait_csts_rdy(bar0: uint64, expected: uint32) -> int32:
    # Poll CSTS.RDY until it matches `expected` (1 to come up, 0 for
    # shutdown). NVMe spec gives CAP.TO (timeout) in 500 ms ticks;
    # we ignore the exact value and just busy-spin a few million
    # times — plenty on QEMU TCG.
    spin: uint64 = 0
    while spin < 10000000:
        csts: uint32 = _nvme_mmio_r32(bar0 + NVME_CSTS)
        if (csts & NVME_CSTS_CFS) != 0:
            printk1("[nvme] CSTS.CFS set (csts=%x)\n",
                    cast[uint64](csts))
            return -1
        if (csts & NVME_CSTS_RDY) == expected:
            return 0
        spin = spin + 1
    printk2("[nvme] CSTS.RDY timeout (want=%d got=%x)\n",
            cast[uint64](expected),
            cast[uint64](_nvme_mmio_r32(bar0 + NVME_CSTS)))
    return -1


# --- Doorbell address arithmetic -----------------------------------
#
# Per spec §3.1.10:
#   SQyTDBL = BAR0 + 0x1000 + (2 * qid)     * stride
#   CQyHDBL = BAR0 + 0x1000 + (2 * qid + 1) * stride
# where stride = 4 << CAP.DSTRD. For DSTRD=0 (qemu, every modern
# controller) the stride is 4 bytes.

def _sq_doorbell(qid: uint32) -> uint64:
    return nvme.bar0 + NVME_DOORBELL_BASE \
         + cast[uint64](2 * qid) * cast[uint64](nvme.doorbell_stride)


def _cq_doorbell(qid: uint32) -> uint64:
    return nvme.bar0 + NVME_DOORBELL_BASE \
         + cast[uint64](2 * qid + 1) * cast[uint64](nvme.doorbell_stride)


# DW0 of the most recently drained completion. SET/GET FEATURES return
# command-specific data here (e.g. Number of Queues granted). Captured by
# _poll_completion so callers that care can read it back without
# threading an extra out-param through every submit helper.
last_cqe_dw0: uint32 = 0


# --- Admin / I/O command primitives --------------------------------
#
# SQ entry is 64 bytes:
#   DW0:   [opcode:7..0 | fuse:8..9 | rsvd:10..13 | PSDT:14..15
#           | CID:16..31]
#   DW1:   NSID
#   DW2/3: rsvd
#   DW4/5: MPTR (metadata)
#   DW6/7: PRP1 low/high
#   DW8/9: PRP2 low/high
#   DW10..15: command-specific (CDW10..CDW15)
#
# We zero the slot, then plant opcode + cid in DW0, nsid in DW1, the
# PRP pointers, and CDW10..15.

def _build_sq_entry(slot_addr: uint64, opcode: uint8, cid: uint32,
                    nsid: uint32, prp1: uint64, prp2: uint64,
                    cdw10: uint32, cdw11: uint32, cdw12: uint32,
                    cdw13: uint32, cdw14: uint32, cdw15: uint32):
    memset(cast[Ptr[uint8]](slot_addr), 0, 64)
    p: Ptr[uint32] = cast[Ptr[uint32]](slot_addr)
    # DW0 = opcode (low 8) | (cid << 16). FUSE/PSDT both 0 for
    # everything we issue.
    p[0] = cast[uint32](opcode) | (cid << 16)
    p[1] = nsid
    # DW6/7 = PRP1 low/high.
    p[6] = cast[uint32](prp1 & 0xFFFFFFFF)
    p[7] = cast[uint32](prp1 >> 32)
    # DW8/9 = PRP2 low/high.
    p[8]  = cast[uint32](prp2 & 0xFFFFFFFF)
    p[9]  = cast[uint32](prp2 >> 32)
    # CDW10..15.
    p[10] = cdw10
    p[11] = cdw11
    p[12] = cdw12
    p[13] = cdw13
    p[14] = cdw14
    p[15] = cdw15


# Sentinel status returned by _poll_completion_to when the bounded spin
# budget is exhausted without a completion. Distinct from a real NVMe
# status (which only occupies the low 15 bits) so callers can tell a
# timeout apart from a controller-reported error.
NVME_POLL_TIMEOUT: uint32 = 0xFFFF

# Default polling budget for ordinary admin/I/O commands. ~50M TCG
# iterations is "effectively forever" on QEMU but bounded so a wedged
# controller can't hang the boot.
NVME_POLL_SPIN_DEFAULT: uint64 = 50000000


def _poll_completion_to(cq_base: uint64, head_p: Ptr[uint32],
                        phase_p: Ptr[uint32], cq_doorbell: uint64,
                        depth: uint32, max_spin: uint64) -> uint32:
    # Bounded-timeout completion poll. Identical to _poll_completion but
    # the spin budget is caller-supplied so the timeout-recovery path can
    # use a deliberately tiny budget to provoke a timeout, while normal
    # callers pass NVME_POLL_SPIN_DEFAULT. Returns the NVMe status on a
    # completion, or NVME_POLL_TIMEOUT if the budget is exhausted.
    head: uint32 = head_p[0]
    expected_phase: uint32 = phase_p[0]
    slot_addr: uint64 = cq_base \
                      + cast[uint64](head) * NVME_CQ_ENTRY_BYTES
    spin: uint64 = 0
    while spin < max_spin:
        e: Ptr[uint32] = cast[Ptr[uint32]](slot_addr)
        dw3: uint32 = e[3]
        cur_phase: uint32 = (dw3 >> 16) & 0x1
        if cur_phase == expected_phase:
            last_cqe_dw0 = e[0]
            status: uint32 = (dw3 >> 17) & 0x7FFF
            new_head: uint32 = head + 1
            new_phase: uint32 = expected_phase
            if new_head >= depth:
                new_head = 0
                new_phase = 1 - expected_phase
            head_p[0] = new_head
            phase_p[0] = new_phase
            _nvme_mmio_w32(cq_doorbell, new_head)
            return status
        spin = spin + 1
    return NVME_POLL_TIMEOUT


def _poll_completion(cq_base: uint64, head_p: Ptr[uint32],
                     phase_p: Ptr[uint32], cq_doorbell: uint64,
                     depth: uint32) -> uint32:
    # Walk to the current CQ slot and busy-spin until its phase bit
    # flips. CQ entry layout (16 bytes / 4 DWORDs):
    #   DW0: command-specific (e.g. CREATE-CQ returns 0)
    #   DW1: reserved
    #   DW2: [SQ head ptr:0..15 | SQ id:16..31]
    #   DW3: [CID:0..15 | phase:16 | status:17..31]
    # The phase bit (bit 16 of DW3) toggles every wrap. We start
    # expecting phase=1 (queue is zero-filled, phase 0 means
    # "unwritten"), and flip our expectation each wrap.
    head: uint32 = head_p[0]
    expected_phase: uint32 = phase_p[0]
    slot_addr: uint64 = cq_base \
                      + cast[uint64](head) * NVME_CQ_ENTRY_BYTES
    spin: uint64 = 0
    while spin < 50000000:
        e: Ptr[uint32] = cast[Ptr[uint32]](slot_addr)
        dw3: uint32 = e[3]
        cur_phase: uint32 = (dw3 >> 16) & 0x1
        if cur_phase == expected_phase:
            # Stash DW0 (command-specific result) for callers that need
            # it (SET/GET FEATURES). Read it BEFORE ringing the doorbell.
            last_cqe_dw0 = e[0]
            # Extract status field (bits 17..31 of DW3) — bit 17..30
            # is status code, bit 31 is "Do Not Retry". A status code
            # of 0 means success. We pack the full top 15 bits and
            # let the caller log non-zero as failure.
            status: uint32 = (dw3 >> 17) & 0x7FFF
            # Advance head + phase bookkeeping.
            new_head: uint32 = head + 1
            new_phase: uint32 = expected_phase
            if new_head >= depth:
                new_head = 0
                new_phase = 1 - expected_phase
            head_p[0] = new_head
            phase_p[0] = new_phase
            # Ring the CQ head doorbell so the controller can re-use
            # the slot.
            _nvme_mmio_w32(cq_doorbell, new_head)
            return status
        spin = spin + 1
    printk0("[nvme] completion timeout\n")
    return 0xFFFF


def _admin_submit_and_wait(opcode: uint8, nsid: uint32,
                           prp1: uint64, prp2: uint64,
                           cdw10: uint32, cdw11: uint32,
                           cdw12: uint32, cdw13: uint32,
                           cdw14: uint32, cdw15: uint32) -> uint32:
    # Build the SQ entry at the current admin tail, bump the tail
    # doorbell, then poll the admin CQ.
    cid: uint32 = nvme.admin_cid
    nvme.admin_cid = cid + 1
    slot_addr: uint64 = nvme.asq \
                      + cast[uint64](nvme.asq_tail) \
                      * NVME_SQ_ENTRY_BYTES
    _build_sq_entry(slot_addr, opcode, cid, nsid, prp1, prp2,
                    cdw10, cdw11, cdw12, cdw13, cdw14, cdw15)
    new_tail: uint32 = nvme.asq_tail + 1
    if new_tail >= NVME_QUEUE_DEPTH:
        new_tail = 0
    nvme.asq_tail = new_tail
    _nvme_mmio_w32(_sq_doorbell(NVME_ADMIN_QID), new_tail)
    return _poll_completion(nvme.acq,
                            &nvme.acq_head, &nvme.acq_phase,
                            _cq_doorbell(NVME_ADMIN_QID),
                            NVME_QUEUE_DEPTH)


# Mirror the per-queue qid=1 bookkeeping back into the legacy
# NvmeState.iosq* fields so the IRQ handler and any external reader that
# still looks at nvme.iocq_head/phase observes a consistent view.
def _sync_legacy_q1():
    nvme.iosq      = io_sq_base[NVME_IO_QID]
    nvme.iocq      = io_cq_base[NVME_IO_QID]
    nvme.iosq_tail = io_sq_tail[NVME_IO_QID]
    nvme.iocq_head = io_cq_head[NVME_IO_QID]
    nvme.iocq_phase = io_cq_phase[NVME_IO_QID]
    nvme.io_cid    = io_q_cid[NVME_IO_QID]


def _io_submit_and_wait_q(qid: uint32, opcode: uint8, nsid: uint32,
                          prp1: uint64, prp2: uint64,
                          cdw10: uint32, cdw11: uint32,
                          cdw12: uint32, cdw13: uint32,
                          cdw14: uint32, cdw15: uint32) -> uint32:
    # qid-aware submit: build the SQE at this queue's tail, ring its
    # doorbell, poll its CQ. All per-queue state lives in the parallel
    # io_* arrays indexed by qid.
    cid: uint32 = io_q_cid[qid]
    io_q_cid[qid] = cid + 1
    slot_addr: uint64 = io_sq_base[qid] \
                      + cast[uint64](io_sq_tail[qid]) \
                      * NVME_SQ_ENTRY_BYTES
    _build_sq_entry(slot_addr, opcode, cid, nsid, prp1, prp2,
                    cdw10, cdw11, cdw12, cdw13, cdw14, cdw15)
    new_tail: uint32 = io_sq_tail[qid] + 1
    if new_tail >= NVME_QUEUE_DEPTH:
        new_tail = 0
    io_sq_tail[qid] = new_tail
    _nvme_mmio_w32(_sq_doorbell(qid), new_tail)
    status: uint32 = _poll_completion(io_cq_base[qid],
                                      &io_cq_head[qid], &io_cq_phase[qid],
                                      _cq_doorbell(qid),
                                      NVME_QUEUE_DEPTH)
    if qid == NVME_IO_QID:
        _sync_legacy_q1()
    return status


def _io_submit_and_wait(opcode: uint8, nsid: uint32,
                        prp1: uint64, prp2: uint64,
                        cdw10: uint32, cdw11: uint32,
                        cdw12: uint32, cdw13: uint32,
                        cdw14: uint32, cdw15: uint32) -> uint32:
    # Legacy entry point — caller has already resolved both PRP fields.
    # Retained so non-data-transfer I/O commands (e.g. FLUSH, opcode
    # 0x00) can still issue without going through the buffer-aware
    # path. Routes through the qid=1 queue.
    return _io_submit_and_wait_q(NVME_IO_QID, opcode, nsid, prp1, prp2,
                                 cdw10, cdw11, cdw12, cdw13, cdw14, cdw15)


# --- PRP-list pool helpers (V4.2 multi-page transfers) ------------
#
# Allocate one 4 KiB scratch page per SQE slot (64 total at queue
# depth 64). Returns 0 on success, -1 on any allocation failure. Once
# initialised, io_prp_pool_ready=1 and the I/O submit path can dip
# into io_prp_list_pages[slot] for any transfer that needs a PRP list.

def _alloc_io_prp_pool() -> int32:
    if io_prp_pool_ready != 0:
        return 0
    i: uint32 = 0
    while i < NVME_QUEUE_DEPTH:
        p: uint64 = alloc_pages(0)
        if p == 0:
            printk1("[nvme] PRP-list pool alloc failed at slot=%d\n",
                    cast[uint64](i))
            return -1
        # Zero the page so any unused trailing entries read as 0
        # (the spec allows trailing zero entries as long as the
        # transfer doesn't run off the end).
        memset(cast[Ptr[uint8]](p), 0, 4096)
        io_prp_list_pages[i] = p
        i = i + 1
    io_prp_pool_ready = 1
    io_prp_pool_ready_mq[NVME_IO_QID] = 1
    return 0


# Resolve the PRP-list scratch page for (qid, slot). qid=1 reads the
# legacy io_prp_list_pages so the established single-queue path is
# byte-identical; qids >= 2 read the flattened multi-queue pool.
def _prp_list_page(qid: uint32, slot: uint32) -> uint64:
    if qid == NVME_IO_QID:
        return io_prp_list_pages[slot]
    return io_prp_list_pages_mq[qid * NVME_QUEUE_DEPTH + slot]


def _prp_pool_ready(qid: uint32) -> int32:
    return io_prp_pool_ready_mq[qid]


# Allocate a PRP-list pool for an additional I/O queue (qid >= 2). One
# page-aligned scratch page per SQE slot, stored in the flattened
# io_prp_list_pages_mq table. Idempotent per qid.
def _alloc_io_prp_pool_mq(qid: uint32) -> int32:
    if io_prp_pool_ready_mq[qid] != 0:
        return 0
    base: uint32 = qid * NVME_QUEUE_DEPTH
    i: uint32 = 0
    while i < NVME_QUEUE_DEPTH:
        p: uint64 = alloc_pages(0)
        if p == 0:
            printk2("[nvme] PRP pool alloc failed qid=%d slot=%d\n",
                    cast[uint64](qid), cast[uint64](i))
            return -1
        memset(cast[Ptr[uint8]](p), 0, 4096)
        io_prp_list_pages_mq[base + i] = p
        i = i + 1
    io_prp_pool_ready_mq[qid] = 1
    return 0


# Compute PRP1 + PRP2 for a (buf_phys, buf_len) transfer destined for
# I/O queue slot `slot`. On return, prp1_p[0] and prp2_p[0] hold the
# values to plant in the SQE. Per NVMe spec §4.3:
#
#   * PRP1 carries `buf_phys` verbatim (low 12 bits = intra-page offset).
#   * If the whole transfer fits in the first page, PRP2 = 0.
#   * If it spans two pages, PRP2 = the page-aligned start of the
#     second page (i.e. the byte just past the first-page tail).
#   * If it spans three or more pages, PRP2 = the physical address of
#     the slot's PRP-list page (page-aligned). The list page holds one
#     8-byte LE entry per page after the first; for transfers larger
#     than 512+1 pages, the 511th entry chains to a second list page.
#
# Returns 0 on success, -1 if the PRP-list pool isn't initialised when
# a multi-page transfer asks for one.
def _compute_io_prp(qid: uint32, slot: uint32,
                    buf_phys: uint64, buf_len: uint64,
                    prp1_p: Ptr[uint64], prp2_p: Ptr[uint64]) -> int32:
    prp1_p[0] = buf_phys
    if buf_len == 0:
        prp2_p[0] = 0
        return 0

    offset_in_page: uint64 = buf_phys & NVME_PAGE_MASK
    first_page_bytes: uint64 = NVME_PAGE_SIZE - offset_in_page

    if buf_len <= first_page_bytes:
        # Single-page transfer: PRP2 unused.
        prp2_p[0] = 0
        return 0

    second_page_start: uint64 = (buf_phys + first_page_bytes) \
                              & ~NVME_PAGE_MASK

    if buf_len <= first_page_bytes + NVME_PAGE_SIZE:
        # Exactly two pages: PRP2 carries the second page's
        # page-aligned start. No list page touched.
        prp2_p[0] = second_page_start
        return 0

    # Three or more pages: build a PRP list in this slot's pool page.
    if _prp_pool_ready(qid) == 0:
        printk0("[nvme] PRP list needed but pool not ready\n")
        return -1
    list_page: uint64 = _prp_list_page(qid, slot)
    if list_page == 0:
        printk2("[nvme] PRP list qid=%d slot=%d has no page\n",
                cast[uint64](qid), cast[uint64](slot))
        return -1

    # Count remaining pages (bytes after the first page boundary).
    remaining_bytes: uint64 = buf_len - first_page_bytes
    # Pages after the first one — round up (any partial-page residue
    # at the tail still occupies a whole page on the device side).
    remaining_pages: uint64 = (remaining_bytes + NVME_PAGE_MASK) \
                            >> 12

    # Zero the list page upfront so unused tail entries don't leak.
    memset(cast[Ptr[uint8]](list_page), 0, 4096)

    # Walk the list page, planting one entry per follow-on page.
    # The page-aligned address of follow-on page N (zero-indexed) is
    # second_page_start + N * NVME_PAGE_SIZE.
    cur_entries: Ptr[uint64] = cast[Ptr[uint64]](list_page)
    idx_in_page: uint64 = 0
    pg:          uint64 = 0
    while pg < remaining_pages:
        # If we're about to fill the last slot of the current list
        # page AND there are still more pages to map, chain instead:
        # the last slot stores a pointer to the next list page (per
        # NVMe spec §4.3 figure 14).
        if idx_in_page == (NVME_PRP_ENTRIES_PER_PAGE - 1) \
           and (remaining_pages - pg) > 1:
            # Need another list page. The 64-slot pre-allocated pool
            # gives us one list page per SQE slot; >512+1 page
            # transfers (>2 MiB) chain off-pool via alloc_pages(0).
            # This branch is unreachable from any current submitter
            # (the block layer caps each command at NLB=65536 → 32
            # MiB → ~16 chained list pages); we keep the chain
            # implemented for spec compliance and to satisfy
            # tests/test_nvme_prp.ad's >2-page exercises if extended.
            next_page: uint64 = alloc_pages(0)
            if next_page == 0:
                printk0("[nvme] PRP chain alloc failed\n")
                return -1
            memset(cast[Ptr[uint8]](next_page), 0, 4096)
            cur_entries[idx_in_page] = next_page
            cur_entries = cast[Ptr[uint64]](next_page)
            idx_in_page = 0
            # Don't consume `pg` — the next iteration plants this
            # page's entry into the fresh list page at index 0.
        page_phys: uint64 = second_page_start \
                          + pg * NVME_PAGE_SIZE
        cur_entries[idx_in_page] = page_phys
        idx_in_page = idx_in_page + 1
        pg = pg + 1

    prp2_p[0] = list_page
    return 0


def _io_submit_buf_and_wait_q(qid: uint32, opcode: uint8, nsid: uint32,
                              buf_phys: uint64, buf_len: uint64,
                              cdw10: uint32, cdw11: uint32,
                              cdw12: uint32, cdw13: uint32,
                              cdw14: uint32, cdw15: uint32) -> uint32:
    # Data-bearing I/O submit on a specific queue: resolves PRP1/PRP2
    # from (buf_phys, buf_len) per NVMe spec §4.3 using THIS queue's PRP
    # pool, then submits on this queue. The slot index used for PRP-list
    # pool indexing is the current per-queue SQ tail (= the slot the SQE
    # will land in).
    slot: uint32 = io_sq_tail[qid]
    prp1: uint64 = 0
    prp2: uint64 = 0
    rc: int32 = _compute_io_prp(qid, slot, buf_phys, buf_len,
                                &prp1, &prp2)
    if rc != 0:
        # PRP resolution failed — return a synthetic "error" status so
        # the caller's existing non-zero check fires. Status 0x7FFF is
        # not a real NVMe code, just an out-of-band sentinel.
        return 0x7FFF
    return _io_submit_and_wait_q(qid, opcode, nsid, prp1, prp2,
                                 cdw10, cdw11, cdw12, cdw13, cdw14, cdw15)


def _io_submit_buf_and_wait(opcode: uint8, nsid: uint32,
                            buf_phys: uint64, buf_len: uint64,
                            cdw10: uint32, cdw11: uint32,
                            cdw12: uint32, cdw13: uint32,
                            cdw14: uint32, cdw15: uint32) -> uint32:
    # Legacy buffer-aware submit — routes through qid=1.
    return _io_submit_buf_and_wait_q(NVME_IO_QID, opcode, nsid,
                                     buf_phys, buf_len,
                                     cdw10, cdw11, cdw12, cdw13,
                                     cdw14, cdw15)


# --- IDENTIFY decoding ---------------------------------------------

def _copy_trimmed(src: Ptr[uint8], dst: Ptr[uint8], n: uint64):
    # Copy n bytes from src to dst, NUL-terminate at dst[n], then
    # right-trim trailing 0x20 (space — NVMe pads model + serial).
    i: uint64 = 0
    while i < n:
        dst[i] = src[i]
        i = i + 1
    dst[n] = 0
    j: int32 = cast[int32](n) - 1
    while j >= 0:
        if dst[j] != 0x20:
            j = -1
        else:
            dst[j] = 0
            j = j - 1


def _nvme_identify_controller(buf: uint64) -> int32:
    # IDENTIFY with CNS=1 returns 4 KiB of controller-wide data:
    #   bytes  0..1     VID
    #   bytes  2..3     SSVID
    #   bytes  4..23    SN  (20 ASCII bytes, space-padded)
    #   bytes 24..63    MN  (40 ASCII bytes, space-padded)
    memset(cast[Ptr[uint8]](buf), 0, 4096)
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_IDENTIFY, 0, buf, 0,
        NVME_CNS_CONTROLLER, 0, 0, 0, 0, 0)
    if status != 0:
        printk1("[nvme] IDENTIFY controller failed (status=%x)\n",
                cast[uint64](status))
        return -1

    sn_src: Ptr[uint8] = cast[Ptr[uint8]](buf + 4)
    _copy_trimmed(sn_src, &nvme.serial[0], 20)
    mn_src: Ptr[uint8] = cast[Ptr[uint8]](buf + 24)
    _copy_trimmed(mn_src, &nvme.model[0], 40)

    # Byte 259 = AERL (Asynchronous Event Request Limit), 0-based. The
    # controller wants up to AERL+1 AERs outstanding. Clamp to our cap.
    aerl: uint32 = cast[uint32](cast[Ptr[uint8]](buf + 259)[0])
    lim: uint32 = aerl + 1
    if lim > NVME_AER_MAX_OUTSTANDING:
        lim = NVME_AER_MAX_OUTSTANDING
    if lim < 1:
        lim = 1
    nvme.aer_limit = lim

    printk1("[nvme] model=%s\n",  cast[uint64](&nvme.model[0]))
    printk1("[nvme] serial=%s\n", cast[uint64](&nvme.serial[0]))
    printk1("[nvme] AER limit=%d\n", cast[uint64](nvme.aer_limit))
    return 0


def _nvme_identify_namespace(buf: uint64, nsid: uint32) -> int32:
    # IDENTIFY with CNS=0 + NSID returns 4 KiB of namespace data.
    # NSZE (Namespace Size) is bytes 0..7 — total LBA count.
    memset(cast[Ptr[uint8]](buf), 0, 4096)
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_IDENTIFY, nsid, buf, 0,
        NVME_CNS_NAMESPACE, 0, 0, 0, 0, 0)
    if status != 0:
        printk1("[nvme] IDENTIFY namespace failed (status=%x)\n",
                cast[uint64](status))
        return -1

    nsze: uint64 = cast[Ptr[uint64]](buf)[0]
    nvme.nsze = nsze
    printk1("[nvme] LBAs=%d\n", nsze)
    return 0


# Decode the active LBA format's logical block size from an IDENTIFY-
# namespace buffer. Byte 26 (FLBAS) low 4 bits index the LBA Format
# descriptor array at byte 128 (16 entries × 4 bytes). Each descriptor
# DW's bits 16..23 hold LBADS, the log2 of the block size in bytes
# (e.g. LBADS=9 → 512, LBADS=12 → 4096). Returns the block size, or 512
# if the encoding looks degenerate (LBADS < 9).
def _ns_block_size_from_idbuf(buf: uint64) -> uint32:
    flbas: uint8 = cast[Ptr[uint8]](buf + 26)[0]
    fmt_idx: uint32 = cast[uint32](flbas) & 0xF
    lbaf_dw: uint32 = cast[Ptr[uint32]](buf + 128 + fmt_idx * 4)[0]
    lbads: uint32 = (lbaf_dw >> 16) & 0xFF
    if lbads < 9:
        return 512
    return cast[uint32](1) << lbads


# IDENTIFY a namespace by NSID and record it in the namespace table at
# `slot`. Captures NSZE (LBA count) + logical block size. Returns 0 on
# success, -1 on the IDENTIFY failing.
def _nvme_record_namespace(buf: uint64, nsid: uint32,
                           slot: uint32) -> int32:
    memset(cast[Ptr[uint8]](buf), 0, 4096)
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_IDENTIFY, nsid, buf, 0,
        NVME_CNS_NAMESPACE, 0, 0, 0, 0, 0)
    if status != 0:
        printk2("[nvme] IDENTIFY ns nsid=%d failed (status=%x)\n",
                cast[uint64](nsid), cast[uint64](status))
        return -1
    nsze: uint64 = cast[Ptr[uint64]](buf)[0]
    bsz: uint32 = _ns_block_size_from_idbuf(buf)
    ns_id[slot] = nsid
    ns_lba_count[slot] = nsze
    ns_block_size[slot] = bsz
    printk2("[nvme] ns nsid=%d LBAs=%d", cast[uint64](nsid), nsze)
    printk1(" blksz=%d\n", cast[uint64](bsz))
    return 0


# Enumerate active namespaces via IDENTIFY CNS=0x02 (Active Namespace ID
# list). The returned 4 KiB buffer is up to 1024 LE uint32 NSIDs in
# ascending order, zero-terminated. For each one we IDENTIFY the
# namespace (CNS=0) and record it in the table. Returns the count of
# namespaces recorded (>=0), or -1 if the list command itself failed.
def _nvme_enumerate_namespaces(buf: uint64) -> int32:
    memset(cast[Ptr[uint8]](buf), 0, 4096)
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_IDENTIFY, 0, buf, 0,
        NVME_CNS_ACTIVE_NS_LIST, 0, 0, 0, 0, 0)
    if status != 0:
        printk1("[nvme] IDENTIFY active-ns-list failed (status=%x)\n",
                cast[uint64](status))
        return -1

    # Snapshot the list into a small local array first: the per-NS
    # IDENTIFY below reuses `buf`, which would clobber the list mid-walk.
    # Max 1024 entries in the spec but we only track NVME_MAX_NS.
    list_p: Ptr[uint32] = cast[Ptr[uint32]](buf)
    count: uint32 = 0
    i: uint32 = 0
    # First pass: copy NSIDs into the table's id column as scratch.
    while i < NVME_MAX_NS:
        nsid: uint32 = list_p[i]
        if nsid == 0:
            i = NVME_MAX_NS
        else:
            ns_id[count] = nsid
            count = count + 1
            i = i + 1

    # Second pass: IDENTIFY each recorded NSID. We read ns_id[k] before
    # _nvme_record_namespace rewrites the same slot (with the same nsid).
    k: uint32 = 0
    recorded: uint32 = 0
    while k < count:
        nsid2: uint32 = ns_id[k]
        if _nvme_record_namespace(buf, nsid2, recorded) == 0:
            recorded = recorded + 1
        k = k + 1
    return cast[int32](recorded)


# Look up the namespace table slot for an NSID. Returns the index, or
# -1 if the NSID isn't an active namespace we recorded.
def _ns_slot_for_nsid(nsid: uint32) -> int32:
    i: uint32 = 0
    while i < nvme.n_namespaces:
        if ns_id[i] == nsid:
            return cast[int32](i)
        i = i + 1
    return -1


# --- I/O queue creation --------------------------------------------
#
# CREATE I/O CQ (opcode 0x05):
#   PRP1   = CQ base address (must be page-aligned)
#   CDW10  = [qsize-1:16..31 | qid:0..15]
#   CDW11  = [IV:16..31 | IEN:1 | PC:0]
#     PC=1 means physically contiguous (we always are).
#     IEN=0 (no interrupts; we poll).
#     IV ignored when IEN=0.
#
# CREATE I/O SQ (opcode 0x01):
#   PRP1   = SQ base
#   CDW10  = [qsize-1:16..31 | qid:0..15]
#   CDW11  = [CQID:16..31 | QPRIO:1..2 | PC:0]

# --- Number of Queues feature (FID 0x07) ---------------------------
#
# SET FEATURES CDW11 = [NCQR:16..31 | NSQR:0..15], both 0-based counts
# (request value N means N+1 queues). The completion DW0 returns the
# GRANTED counts in the same layout — the controller may grant fewer
# than requested. We request NVME_MAX_IO_QUEUES-1 (0-based) of each and
# clamp our actual I/O-queue count to min(granted_sq, granted_cq,
# NVME_MAX_IO_QUEUES). Per spec this feature must be set BEFORE creating
# any I/O queues. Returns the number of I/O queue pairs we may create
# (>=1), or 0 on a hard failure (caller falls back to a single queue).
def _nvme_set_num_queues() -> uint32:
    req: uint32 = NVME_MAX_IO_QUEUES - 1          # 0-based
    cdw11: uint32 = (req << 16) | req
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_SET_FEATURES, 0, 0, 0,
        NVME_FEAT_NUM_QUEUES, cdw11, 0, 0, 0, 0)
    if status != 0:
        printk1("[nvme] SET FEATURES num-queues failed (status=%x)\n",
                cast[uint64](status))
        return 1
    dw0: uint32 = last_cqe_dw0
    granted_sq: uint32 = (dw0 & 0xFFFF) + 1       # back to 1-based
    granted_cq: uint32 = ((dw0 >> 16) & 0xFFFF) + 1
    granted: uint32 = granted_sq
    if granted_cq < granted:
        granted = granted_cq
    if granted > NVME_MAX_IO_QUEUES:
        granted = NVME_MAX_IO_QUEUES
    if granted < 1:
        granted = 1
    printk2("[nvme] num-queues granted sq=%d cq=%d\n",
            cast[uint64](granted_sq), cast[uint64](granted_cq))
    return granted


# --- qid-aware I/O queue creation ----------------------------------
#
# CREATE I/O CQ (opcode 0x05):
#   PRP1 = CQ base; CDW10 = [qsize-1:16..31 | qid:0..15];
#   CDW11 = [IV:16..31 | IEN:1 | PC:0]. PC=1, IEN=0 (we poll).
def _nvme_create_iocq_q(qid: uint32, cq_base: uint64) -> int32:
    qsize_m1: uint32 = NVME_QUEUE_DEPTH - 1
    cdw10: uint32 = (qsize_m1 << 16) | qid
    cdw11: uint32 = 0x1
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_CREATE_CQ, 0, cq_base, 0,
        cdw10, cdw11, 0, 0, 0, 0)
    if status != 0:
        printk2("[nvme] CREATE-IO-CQ qid=%d failed (status=%x)\n",
                cast[uint64](qid), cast[uint64](status))
        return -1
    return 0


# CREATE I/O SQ (opcode 0x01): PRP1 = SQ base;
#   CDW10 = [qsize-1:16..31 | qid:0..15];
#   CDW11 = [CQID:16..31 | QPRIO:1..2 | PC:0]. We bind each SQ to the CQ
#   with the same id (one CQ per SQ — simplest correct topology).
def _nvme_create_iosq_q(qid: uint32, sq_base: uint64) -> int32:
    qsize_m1: uint32 = NVME_QUEUE_DEPTH - 1
    cdw10: uint32 = (qsize_m1 << 16) | qid
    cdw11: uint32 = 0x1 | (qid << 16)
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_CREATE_SQ, 0, sq_base, 0,
        cdw10, cdw11, 0, 0, 0, 0)
    if status != 0:
        printk2("[nvme] CREATE-IO-SQ qid=%d failed (status=%x)\n",
                cast[uint64](qid), cast[uint64](status))
        return -1
    return 0


# Allocate + create a single I/O queue pair `qid`, initialise its
# per-queue ring state, and (for qid >= 2) its PRP-list pool. Order
# matters: the CQ must exist before the SQ that binds to it. Returns 0
# on success, -1 on any allocation/creation failure.
def _nvme_setup_io_queue(qid: uint32) -> int32:
    cq: uint64 = alloc_pages(0)
    sq: uint64 = alloc_pages(0)
    if cq == 0 or sq == 0:
        printk1("[nvme] queue alloc failed qid=%d\n", cast[uint64](qid))
        return -1
    memset(cast[Ptr[uint8]](cq), 0, 4096)
    memset(cast[Ptr[uint8]](sq), 0, 4096)
    io_cq_base[qid] = cq
    io_sq_base[qid] = sq
    io_sq_tail[qid] = 0
    io_cq_head[qid] = 0
    io_cq_phase[qid] = 1
    io_q_cid[qid] = 0
    if _nvme_create_iocq_q(qid, cq) != 0:
        return -1
    if _nvme_create_iosq_q(qid, sq) != 0:
        return -1
    if qid == NVME_IO_QID:
        # qid=1 mirrors the legacy NvmeState fields + uses the legacy
        # PRP pool (allocated by _alloc_io_prp_pool in the caller).
        _sync_legacy_q1()
    else:
        if _alloc_io_prp_pool_mq(qid) != 0:
            return -1
    return 0


# --- Legacy single-queue creation shims ----------------------------
#
# The Linux .ko L-shim bring-up path (linux_abi/api_nvme_core.ad) sets
# nvme.iocq/nvme.iosq directly and then calls these two functions to
# create the qid=1 queue pair on the controller. They are retained with
# their original (qid=1, reads nvme.iocq/nvme.iosq) behaviour, and now
# also seed the per-queue arrays for qid=1 so the qid-aware submit path
# and the NS table work after a .ko-driven bring-up. n_io_queues/n_namespaces
# default to 1 here because that path does not call SET FEATURES /
# active-ns-list enumeration.
def _nvme_create_iocq() -> int32:
    io_cq_base[NVME_IO_QID] = nvme.iocq
    io_cq_head[NVME_IO_QID] = nvme.iocq_head
    io_cq_phase[NVME_IO_QID] = nvme.iocq_phase
    if _nvme_create_iocq_q(NVME_IO_QID, nvme.iocq) != 0:
        return -1
    return 0


def _nvme_create_iosq() -> int32:
    io_sq_base[NVME_IO_QID] = nvme.iosq
    io_sq_tail[NVME_IO_QID] = nvme.iosq_tail
    io_q_cid[NVME_IO_QID] = nvme.io_cid
    if _nvme_create_iosq_q(NVME_IO_QID, nvme.iosq) != 0:
        return -1
    # Seed a single-queue / single-namespace view for the .ko path.
    nvme.n_io_queues = 1
    nvme.rr_next = 0
    if nvme.n_namespaces == 0:
        ns_id[0] = 1
        ns_lba_count[0] = nvme.nsze
        ns_block_size[0] = cast[uint32](SECTOR_SIZE)
        nvme.n_namespaces = 1
    return 0


# Pick the next I/O queue for a submission. Policy: round-robin across
# all live I/O queues (qid 1..n_io_queues). Round-robin is the simplest
# fair policy that exercises every queue without needing per-CPU or
# per-NS affinity state; a polled driver gains no concurrency from
# multiple queues but RR proves each queue is independently functional.
def _nvme_pick_queue() -> uint32:
    n: uint32 = nvme.n_io_queues
    if n <= 1:
        return NVME_IO_QID
    q: uint32 = nvme.rr_next
    # cursor runs 0..n-1, mapped to qid 1..n.
    nxt: uint32 = q + 1
    if nxt >= n:
        nxt = 0
    nvme.rr_next = nxt
    return q + 1


# --- I/O READ ------------------------------------------------------
#
# Opcode 0x02 (NVME_IO_READ):
#   PRP1   = destination buffer (page-aligned)
#   CDW10  = LBA low 32
#   CDW11  = LBA high 32
#   CDW12  = [NLB-1:0..15 | rsvd:16..29 | PRINFO:30..31]
#            NLB is 0-based (NLB=0 → 1 block).

def _nvme_read_lba(lba: uint64, nblocks: uint16, dst: uint64) -> int32:
    cdw10: uint32 = cast[uint32](lba & 0xFFFFFFFF)
    cdw11: uint32 = cast[uint32](lba >> 32)
    cdw12: uint32 = cast[uint32](nblocks - 1) & 0xFFFF
    # V4.2: pass the byte length so _io_submit_buf_and_wait can resolve
    # PRP1 + PRP2 + (if needed) a PRP-list page for the transfer.
    #
    # Higher-half kernel: the NVMe controller DMAs to PHYSICAL
    # addresses. `dst` is the caller's buffer — the block layer may
    # hand us a kernel global (high-half VA). virt_to_phys() rebases
    # it; an alloc_pages/kmalloc buffer is already low and unchanged.
    dst_phys: uint64 = virt_to_phys(dst)
    buf_len: uint64 = cast[uint64](nblocks) * SECTOR_SIZE
    status: uint32 = _io_submit_buf_and_wait(
        NVME_IO_READ, NVME_IO_QID, dst_phys, buf_len,
        cdw10, cdw11, cdw12, 0, 0, 0)
    if status != 0:
        printk1("[nvme] I/O READ failed (status=%x)\n",
                cast[uint64](status))
        return -1
    return 0


# --- I/O WRITE -----------------------------------------------------
#
# M16.118: complement of _nvme_read_lba. NVMe opcode 0x01 (NVM Write,
# base spec §6.15). The SQE shape is identical to READ — only the
# opcode and the data direction (controller now READS PRP1 instead of
# writing to it) differ:
#
#   PRP1   = source buffer (page-aligned, contains the bytes to write)
#   CDW10  = LBA low 32
#   CDW11  = LBA high 32
#   CDW12  = [NLB-1:0..15 | rsvd:16..29 | PRINFO:30..31]
#            NLB is 0-based (NLB=0 -> 1 block).
#
# Reuses the existing I/O queue + `_io_submit_and_wait` plumbing the
# READ path already exercised. Polled completion via CQ phase bit.

def _nvme_write_lba(lba: uint64, nblocks: uint16, src: uint64) -> int32:
    cdw10: uint32 = cast[uint32](lba & 0xFFFFFFFF)
    cdw11: uint32 = cast[uint32](lba >> 32)
    cdw12: uint32 = cast[uint32](nblocks - 1) & 0xFFFF
    # V4.2: byte-length-aware PRP resolution (see _nvme_read_lba).
    # Higher-half kernel: rebase the caller's source buffer to a
    # physical address for the controller's DMA (see _nvme_read_lba).
    src_phys: uint64 = virt_to_phys(src)
    buf_len: uint64 = cast[uint64](nblocks) * SECTOR_SIZE
    status: uint32 = _io_submit_buf_and_wait(
        NVME_IO_WRITE, NVME_IO_QID, src_phys, buf_len,
        cdw10, cdw11, cdw12, 0, 0, 0)
    if status != 0:
        printk1("[nvme] I/O WRITE failed (status=%x)\n",
                cast[uint64](status))
        return -1
    return 0


# --- nsid + queue-routed read/write --------------------------------
#
# Multi-NS / multi-queue primitives: route an LBA transfer to namespace
# `nsid` over the round-robin-selected I/O queue. The block size used to
# size the transfer is the namespace's own logical block size (read from
# the NS table), not the fixed SECTOR_SIZE — so a 4 KiB-LBA namespace
# transfers the right byte count. `nblocks` is in NAMESPACE blocks.

def _nvme_rw_ns(opcode: uint8, nsid: uint32, lba: uint64,
                nblocks: uint16, buf_virt: uint64) -> int32:
    slot: int32 = _ns_slot_for_nsid(nsid)
    if slot < 0:
        printk1("[nvme] rw: nsid=%d not active\n", cast[uint64](nsid))
        return -1
    bsz: uint64 = cast[uint64](ns_block_size[cast[uint32](slot)])
    if bsz == 0:
        bsz = SECTOR_SIZE
    qid: uint32 = _nvme_pick_queue()
    cdw10: uint32 = cast[uint32](lba & 0xFFFFFFFF)
    cdw11: uint32 = cast[uint32](lba >> 32)
    cdw12: uint32 = cast[uint32](nblocks - 1) & 0xFFFF
    buf_phys: uint64 = virt_to_phys(buf_virt)
    buf_len: uint64 = cast[uint64](nblocks) * bsz
    status: uint32 = _io_submit_buf_and_wait_q(
        qid, opcode, nsid, buf_phys, buf_len,
        cdw10, cdw11, cdw12, 0, 0, 0)
    if status != 0:
        printk2("[nvme] ns rw nsid=%d qid=%d FAILED", cast[uint64](nsid),
                cast[uint64](qid))
        printk1(" (status=%x)\n", cast[uint64](status))
        return -1
    return 0


def nvme_read_lba_ns(nsid: uint32, lba: uint64, nblocks: uint16,
                     dst: uint64) -> int32:
    if nvme.bar0 == 0:
        return -1
    if nblocks == 0:
        return 0
    return _nvme_rw_ns(NVME_IO_READ, nsid, lba, nblocks, dst)


def nvme_write_lba_ns(nsid: uint32, lba: uint64, nblocks: uint16,
                      src: uint64) -> int32:
    if nvme.bar0 == 0:
        return -1
    if nblocks == 0:
        return 0
    return _nvme_rw_ns(NVME_IO_WRITE, nsid, lba, nblocks, src)


# --- FLUSH (I/O opcode 0x00) ---------------------------------------
#
# A FLUSH commits a namespace's volatile write cache to non-volatile
# media. It carries NO data transfer (PRP1/PRP2 are zero) and only one
# parameter — the namespace id in DW1. Until now NVME_IO_FLUSH was a
# dangling constant; this is the first issuer. A durable write path
# (e.g. fsync over an NVMe-backed filesystem) needs this to be real.
#
# Routes over a round-robin-selected I/O queue, the same way reads and
# writes do, so a flush serialises after the writes that preceded it on
# that queue. Returns 0 on completion-status 0, -1 otherwise.
def nvme_flush_ns(nsid: uint32) -> int32:
    if nvme.bar0 == 0:
        return -1
    if _ns_slot_for_nsid(nsid) < 0:
        printk1("[nvme] flush: nsid=%d not active\n", cast[uint64](nsid))
        return -1
    qid: uint32 = _nvme_pick_queue()
    # FLUSH has no data buffer: PRP1=PRP2=0, all CDWs zero.
    status: uint32 = _io_submit_and_wait_q(
        qid, NVME_IO_FLUSH, nsid, 0, 0, 0, 0, 0, 0, 0, 0)
    if status != 0:
        printk2("[nvme] flush nsid=%d qid=%d FAILED", cast[uint64](nsid),
                cast[uint64](qid))
        printk1(" (status=%x)\n", cast[uint64](status))
        return -1
    return 0


# Convenience: flush the primary namespace (nsid=1).
def nvme_flush() -> int32:
    return nvme_flush_ns(1)


# --- SMART / Health Information log (admin GET LOG PAGE, lid 0x02) --
#
# GET LOG PAGE returns controller/namespace health telemetry. We fetch
# the 512-byte SMART/Health page (log id 0x02, NSID 0xFFFFFFFF =
# controller-wide) into a page-aligned scratch buffer and decode the
# fields we care about into the NvmeState snapshot. Until now
# NVME_ADMIN_GET_LOG was a dangling constant; this is the first issuer.
#
# CDW10 layout for GET LOG PAGE: [NUMDL:16..31 | RAE:15 | LID:7..0],
# where NUMDL is the number of DWORDs to transfer minus one. 512 bytes
# = 128 DWORDs → NUMDL = 127. Returns 0 on success, -1 on failure.
#
# SMART log byte layout (NVMe §5.14.1.2):
#   byte   0      Critical Warning (bitmask)
#   bytes  1..2   Composite Temperature (Kelvin, LE)
#   byte   3      Available Spare (%)
#   byte   5      Percentage Used (endurance, %)
#   bytes 32..47  Data Units Read    (128-bit; we keep low 64)
#   bytes 48..63  Data Units Written (128-bit; we keep low 64)
#   bytes 64..79  Host Read Commands (128-bit; we keep low 64)
#   bytes 80..95  Host Write Commands (128-bit; we keep low 64)
def nvme_fetch_smart_log() -> int32:
    if nvme.bar0 == 0:
        return -1
    buf: uint64 = alloc_pages(0)
    if buf == 0:
        printk0("[nvme] smart: alloc_pages failed\n")
        return -1
    memset(cast[Ptr[uint8]](buf), 0, 4096)
    numd: uint32 = (NVME_SMART_LOG_BYTES / 4) - 1     # DWORDs-1 = 127
    cdw10: uint32 = (numd << 16) | (NVME_LOG_SMART & 0xFF)
    # NSID 0xFFFFFFFF selects controller-wide SMART data.
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_GET_LOG, 0xFFFFFFFF, buf, 0,
        cdw10, 0, 0, 0, 0, 0)
    if status != 0:
        printk1("[nvme] GET LOG (SMART) failed (status=%x)\n",
                cast[uint64](status))
        free_pages(buf, 0)
        return -1

    b: Ptr[uint8] = cast[Ptr[uint8]](buf)
    nvme.smart_crit_warning = cast[uint32](b[0])
    temp_lo: uint32 = cast[uint32](b[1])
    temp_hi: uint32 = cast[uint32](b[2])
    nvme.smart_temp_k = temp_lo | (temp_hi << 8)
    nvme.smart_avail_spare = cast[uint32](b[3])
    nvme.smart_percent_used = cast[uint32](b[5])
    nvme.smart_data_units_read    = cast[Ptr[uint64]](buf + 32)[0]
    nvme.smart_data_units_written = cast[Ptr[uint64]](buf + 48)[0]
    nvme.smart_host_reads  = cast[Ptr[uint64]](buf + 64)[0]
    nvme.smart_host_writes = cast[Ptr[uint64]](buf + 80)[0]
    nvme.smart_valid = 1

    printk2("[nvme] SMART crit_warn=%x temp=%dK",
            cast[uint64](nvme.smart_crit_warning),
            cast[uint64](nvme.smart_temp_k))
    printk2(" spare=%d%% used=%d%%\n",
            cast[uint64](nvme.smart_avail_spare),
            cast[uint64](nvme.smart_percent_used))
    printk2("[nvme] SMART data_read=%d data_written=%d units\n",
            nvme.smart_data_units_read,
            nvme.smart_data_units_written)
    free_pages(buf, 0)
    return 0


# --- Admin submit WITHOUT waiting (fire-and-forget) ---------------
#
# The Asynchronous Event Request command is the one admin command we must
# NOT poll for: it stays outstanding in the controller until an async
# event actually occurs, possibly never during a boot. This builds the
# SQE at the admin tail, rings the SQ doorbell, and returns the CID it
# used so the caller can track/abort it — but it does NOT touch the CQ.
# The corresponding completion is drained later by _nvme_drain_aers().
def _admin_submit_nowait(opcode: uint8, nsid: uint32,
                         prp1: uint64, prp2: uint64,
                         cdw10: uint32, cdw11: uint32,
                         cdw12: uint32, cdw13: uint32,
                         cdw14: uint32, cdw15: uint32) -> uint32:
    cid: uint32 = nvme.admin_cid
    nvme.admin_cid = cid + 1
    slot_addr: uint64 = nvme.asq \
                      + cast[uint64](nvme.asq_tail) \
                      * NVME_SQ_ENTRY_BYTES
    _build_sq_entry(slot_addr, opcode, cid, nsid, prp1, prp2,
                    cdw10, cdw11, cdw12, cdw13, cdw14, cdw15)
    new_tail: uint32 = nvme.asq_tail + 1
    if new_tail >= NVME_QUEUE_DEPTH:
        new_tail = 0
    nvme.asq_tail = new_tail
    _nvme_mmio_w32(_sq_doorbell(NVME_ADMIN_QID), new_tail)
    return cid


# --- Asynchronous Event Request (admin opcode 0x0C) ----------------
#
# Submit a single AER. All DWORDs are zero — the command carries no data
# buffer; the event is reported entirely through the completion DW0. We
# fire it without waiting and bump aer_outstanding.
def _nvme_submit_one_aer() -> int32:
    if nvme.bar0 == 0:
        return -1
    _admin_submit_nowait(NVME_ADMIN_ASYNC_EVENT, 0, 0, 0,
                         0, 0, 0, 0, 0, 0)
    nvme.aer_outstanding = nvme.aer_outstanding + 1
    return 0


# Top up outstanding AERs to the controller's requested limit. Called at
# init (after IDENTIFY established aer_limit) and after each AER drains.
def _nvme_refill_aers():
    while nvme.aer_outstanding < nvme.aer_limit:
        if _nvme_submit_one_aer() != 0:
            return
    printk2("[nvme-aer] %d AER(s) outstanding (limit=%d)\n",
            cast[uint64](nvme.aer_outstanding),
            cast[uint64](nvme.aer_limit))


# --- Error Information log (GET LOG PAGE log id 0x01) ---------------
#
# Read on an AER "Error" event. The Error Information log is an array of
# 64-byte entries; we fetch the first entry, which holds the error count,
# the SQID/CID of the offending command, the status field, and the
# parameter/LBA/NSID context. Reading it clears the pending error event.
def _nvme_fetch_error_log() -> int32:
    if nvme.bar0 == 0:
        return -1
    buf: uint64 = alloc_pages(0)
    if buf == 0:
        return -1
    memset(cast[Ptr[uint8]](buf), 0, 4096)
    numd: uint32 = (NVME_ERROR_LOG_BYTES / 4) - 1     # DWORDs-1 = 15
    cdw10: uint32 = (numd << 16) | (NVME_LOG_ERROR & 0xFF)
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_GET_LOG, 0xFFFFFFFF, buf, 0,
        cdw10, 0, 0, 0, 0, 0)
    if status != 0:
        printk1("[nvme-aer] GET LOG (error) failed (status=%x)\n",
                cast[uint64](status))
        free_pages(buf, 0)
        return -1
    # Entry layout (NVMe base spec): bytes 0..7 = error count, byte 8..9
    # SQID, 10..11 CID, 12..13 status field.
    ecount: uint64 = cast[Ptr[uint64]](buf)[0]
    sqid: uint32 = cast[uint32](cast[Ptr[uint16]](buf + 8)[0])
    ecid: uint32 = cast[uint32](cast[Ptr[uint16]](buf + 10)[0])
    estat: uint32 = cast[uint32](cast[Ptr[uint16]](buf + 12)[0])
    printk2("[nvme-aer] error-log count=%d sqid=%d",
            ecount, cast[uint64](sqid))
    printk2(" cid=%d status=%x\n",
            cast[uint64](ecid), cast[uint64](estat))
    free_pages(buf, 0)
    return 0


# Act on a single drained AER completion DW0. Decode type/info/log-page,
# read the indicated log to clear the event in the controller, then a
# fresh AER will be refilled by the caller. Returns 0 always (best
# effort; a failed log read is logged but not fatal).
def _nvme_handle_aer_dw0(dw0: uint32) -> int32:
    atype:   uint32 = dw0 & 0x7
    ainfo:   uint32 = (dw0 >> 8) & 0xFF
    logpage: uint32 = (dw0 >> 16) & 0xFF
    nvme.aer_last_type    = atype
    nvme.aer_last_info    = ainfo
    nvme.aer_last_logpage = logpage
    nvme.aer_events = nvme.aer_events + 1
    printk2("[nvme-aer] event type=%d info=%x",
            cast[uint64](atype), cast[uint64](ainfo))
    printk1(" logpage=%x\n", cast[uint64](logpage))
    # An AER consumes one outstanding slot when it completes.
    if nvme.aer_outstanding > 0:
        nvme.aer_outstanding = nvme.aer_outstanding - 1
    # Read the log page the controller pointed at, which clears the
    # event so the controller will report the next one.
    if logpage == NVME_LOG_ERROR:
        _nvme_fetch_error_log()
    else:
        if logpage == NVME_LOG_SMART:
            nvme_fetch_smart_log()
        else:
            # Notice / namespace-change / unknown: read whatever log the
            # controller indicated. If it's a log id we don't model, the
            # SMART read still clears most QEMU events; fall back to that.
            nvme_fetch_smart_log()
    return 0


# Non-blocking drain of any pending AER completions on the admin CQ.
# Unlike a normal command we never spin waiting for an AER — we only pop
# completions that are ALREADY present (phase already flipped). For each,
# decode + handle it, then refill the AER queue. Returns the number of
# AER completions drained this pass.
def _nvme_drain_aers() -> uint32:
    if nvme.bar0 == 0:
        return 0
    drained: uint32 = 0
    more: int32 = 1
    while more == 1:
        more = 0
        head: uint32 = nvme.acq_head
        expected_phase: uint32 = nvme.acq_phase
        slot_addr: uint64 = nvme.acq \
                          + cast[uint64](head) * NVME_CQ_ENTRY_BYTES
        e: Ptr[uint32] = cast[Ptr[uint32]](slot_addr)
        dw3: uint32 = e[3]
        cur_phase: uint32 = (dw3 >> 16) & 0x1
        if cur_phase == expected_phase:
            # A completion is present. Capture DW0 + advance the CQ.
            dw0: uint32 = e[0]
            new_head: uint32 = head + 1
            new_phase: uint32 = expected_phase
            if new_head >= NVME_QUEUE_DEPTH:
                new_head = 0
                new_phase = 1 - expected_phase
            nvme.acq_head = new_head
            nvme.acq_phase = new_phase
            _nvme_mmio_w32(_cq_doorbell(NVME_ADMIN_QID), new_head)
            _nvme_handle_aer_dw0(dw0)
            drained = drained + 1
            more = 1
    if drained > 0:
        _nvme_refill_aers()
    return drained


# --- Admin Abort (admin opcode 0x08) -------------------------------
#
# Abort the command identified by (sqid, cid). CDW10 packs
# [SQID:0..15 | CID:16..31]. The completion DW0 bit 0 is "Abort failed"
# (1 = the controller could not abort, e.g. the command already
# completed); status 0 with DW0 bit0=0 means the abort succeeded. We log
# either way and return 0 if the command round-tripped to the controller
# (status 0), -1 on a controller error.
def _nvme_abort(sqid: uint32, cid: uint32) -> int32:
    if nvme.bar0 == 0:
        return -1
    cdw10: uint32 = (sqid & 0xFFFF) | ((cid & 0xFFFF) << 16)
    status: uint32 = _admin_submit_and_wait(
        NVME_ADMIN_ABORT, 0, 0, 0,
        cdw10, 0, 0, 0, 0, 0)
    if status != 0:
        printk1("[nvme] ABORT cmd failed (status=%x)\n",
                cast[uint64](status))
        return -1
    abort_failed: uint32 = last_cqe_dw0 & 0x1
    nvme.abort_count = nvme.abort_count + 1
    if abort_failed != 0:
        printk2("[nvme] ABORT sqid=%d cid=%d: not aborted (already done)\n",
                cast[uint64](sqid), cast[uint64](cid))
    else:
        printk2("[nvme] ABORT sqid=%d cid=%d: aborted\n",
                cast[uint64](sqid), cast[uint64](cid))
    return 0


# --- Controller-level reset recovery -------------------------------
#
# The resilience path real NVMe drivers must have: when a command times
# out and an Abort cannot recover it (or the controller has gone CFS),
# tear the controller down with CC.EN=0, wait CSTS.RDY=0, then re-run the
# init dance (admin queues, CC.EN=1, IDENTIFY, SET FEATURES, recreate I/O
# queues). This is the SAME disable->enable sequence nvme_smoke_test
# uses; factored here so it can be invoked mid-operation. Returns 0 on a
# clean recovery, -1 if the controller will not come back.
def _nvme_reset_recovery() -> int32:
    if nvme.bar0 == 0:
        return -1
    bar0: uint64 = nvme.bar0
    printk0("[nvme-reset] beginning controller reset recovery\n")

    # Re-assert PCI MEM + bus-master (a real reset can clear these).
    _nvme_pci_enable_mem_and_master(nvme.bdf)

    # ----- Disable: CC.EN=0, wait CSTS.RDY=0 -----
    cc: uint32 = _nvme_mmio_r32(bar0 + NVME_CC)
    _nvme_mmio_w32(bar0 + NVME_CC, cc & ~NVME_CC_EN)
    if _wait_csts_rdy(bar0, 0) != 0:
        printk0("[nvme-reset] disable timeout\n")
        return -1

    # ----- Re-init admin queue ring state (reuse the same pages) -----
    memset(cast[Ptr[uint8]](nvme.asq), 0, 4096)
    memset(cast[Ptr[uint8]](nvme.acq), 0, 4096)
    nvme.asq_tail = 0
    nvme.acq_head = 0
    nvme.acq_phase = 1
    nvme.admin_cid = 0
    nvme.aer_outstanding = 0

    aqa: uint32 = ((NVME_QUEUE_DEPTH - 1) << 16) | (NVME_QUEUE_DEPTH - 1)
    _nvme_mmio_w32(bar0 + NVME_AQA, aqa)
    _nvme_mmio_w64(bar0 + NVME_ASQ, nvme.asq)
    _nvme_mmio_w64(bar0 + NVME_ACQ, nvme.acq)

    # ----- Re-enable: CC.EN=1, wait CSTS.RDY=1 -----
    new_cc: uint32 = NVME_CC_EN | NVME_CC_IOSQES_6 | NVME_CC_IOCQES_4
    _nvme_mmio_w32(bar0 + NVME_CC, new_cc)
    if _wait_csts_rdy(bar0, NVME_CSTS_RDY) != 0:
        printk0("[nvme-reset] enable timeout\n")
        return -1
    printk0("[nvme-reset] controller ready again\n")

    # ----- Re-IDENTIFY + re-create the I/O queues -----
    id_buf: uint64 = kmalloc(4096)
    if id_buf == 0:
        printk0("[nvme-reset] kmalloc failed\n")
        return -1
    if _nvme_identify_controller(id_buf) != 0:
        return -1

    # Recreate every I/O queue pair we had before. The SQ/CQ memory +
    # PRP pools are still allocated; we only re-issue SET FEATURES +
    # CREATE-CQ/SQ and reset the ring head/tail/phase/cid.
    granted: uint32 = _nvme_set_num_queues()
    want: uint32 = nvme.n_io_queues
    if want == 0:
        want = 1
    if want > granted:
        want = granted
    qid: uint32 = NVME_IO_QID
    while qid <= want:
        io_sq_tail[qid] = 0
        io_cq_head[qid] = 0
        io_cq_phase[qid] = 1
        io_q_cid[qid] = 0
        memset(cast[Ptr[uint8]](io_cq_base[qid]), 0, 4096)
        if _nvme_create_iocq_q(qid, io_cq_base[qid]) != 0:
            printk1("[nvme-reset] recreate CQ qid=%d failed\n",
                    cast[uint64](qid))
            return -1
        if _nvme_create_iosq_q(qid, io_sq_base[qid]) != 0:
            printk1("[nvme-reset] recreate SQ qid=%d failed\n",
                    cast[uint64](qid))
            return -1
        if qid == NVME_IO_QID:
            _sync_legacy_q1()
        qid = qid + 1

    # Re-arm the AER queue on the freshly enabled controller.
    _nvme_refill_aers()

    nvme.reset_count = nvme.reset_count + 1
    printk1("[nvme-reset] recovery complete (reset_count=%d)\n",
            nvme.reset_count)
    return 0


# --- Timeout-aware admin command with abort + reset escalation -----
#
# Issue an admin command with a BOUNDED completion budget. On timeout we
# escalate: (1) submit an Abort for the timed-out (sqid=0, cid), (2) if
# the controller still hasn't completed it, perform a full reset
# recovery. Returns the command status (0 = success), NVME_POLL_TIMEOUT
# if it ultimately could not be completed even after recovery.
# Test hook: when non-zero, _admin_submit_to skips the post-abort
# recovery poll on a timeout and proceeds straight to a real controller
# reset. Lets the self-test exercise the full timeout->abort->reset
# escalation deterministically on a healthy emulated controller (where no
# command can be made to truly hang). Zero in all production paths.
nvme_force_reset_on_timeout: int32 = 0


def _admin_submit_to(opcode: uint8, nsid: uint32,
                     prp1: uint64, prp2: uint64,
                     cdw10: uint32, cdw11: uint32,
                     cdw12: uint32, cdw13: uint32,
                     cdw14: uint32, cdw15: uint32,
                     max_spin: uint64) -> uint32:
    cid: uint32 = nvme.admin_cid
    nvme.admin_cid = cid + 1
    slot_addr: uint64 = nvme.asq \
                      + cast[uint64](nvme.asq_tail) \
                      * NVME_SQ_ENTRY_BYTES
    _build_sq_entry(slot_addr, opcode, cid, nsid, prp1, prp2,
                    cdw10, cdw11, cdw12, cdw13, cdw14, cdw15)
    new_tail: uint32 = nvme.asq_tail + 1
    if new_tail >= NVME_QUEUE_DEPTH:
        new_tail = 0
    nvme.asq_tail = new_tail
    _nvme_mmio_w32(_sq_doorbell(NVME_ADMIN_QID), new_tail)
    status: uint32 = _poll_completion_to(nvme.acq,
                                         &nvme.acq_head, &nvme.acq_phase,
                                         _cq_doorbell(NVME_ADMIN_QID),
                                         NVME_QUEUE_DEPTH, max_spin)
    if status != NVME_POLL_TIMEOUT:
        return status

    # Timed out. Escalate: Abort the outstanding command (admin SQID=0).
    printk2("[nvme] admin cmd opc=%x cid=%d TIMEOUT -> abort\n",
            cast[uint64](opcode), cast[uint64](cid))
    _nvme_abort(NVME_ADMIN_QID, cid)
    # Did the abort (or the command itself) post a completion now? The
    # self-test sets nvme_force_reset_on_timeout to skip this recovery
    # poll and drive the FULL escalation to a real controller reset even
    # though QEMU would otherwise have completed the (real) command —
    # there is no way on a healthy emulated controller to make a command
    # genuinely never complete, so the test hook forces the reset path.
    if nvme_force_reset_on_timeout == 0:
        status = _poll_completion_to(nvme.acq,
                                     &nvme.acq_head, &nvme.acq_phase,
                                     _cq_doorbell(NVME_ADMIN_QID),
                                     NVME_QUEUE_DEPTH,
                                     NVME_POLL_SPIN_DEFAULT)
        if status != NVME_POLL_TIMEOUT:
            return status

    # Abort did not recover it: full controller reset recovery.
    printk0("[nvme] abort ineffective -> reset recovery\n")
    if _nvme_reset_recovery() != 0:
        return NVME_POLL_TIMEOUT
    # After a reset the original command is gone; the caller must resubmit
    # if it still cares. We report timeout so the caller fails cleanly
    # rather than acting on a stale completion.
    return NVME_POLL_TIMEOUT


# --- Public write/read wrappers ------------------------------------
#
# Same shape as virtio-blk's read_sectors / write_sectors so the
# block-layer vtable can dispatch through them once NVMe is
# registered with `kernel/block/blk.ad`. This commit ships the
# driver-level primitives only; register_blockdev() wiring is a
# follow-up (the BlockDeviceOps vtable already has the write_sectors
# slot we need, but plumbing it in requires per-controller state
# bookkeeping outside the scope of this commit).

def nvme_write_lba(lba: uint64, nblocks: uint16, src: uint64) -> int32:
    if nvme.bar0 == 0:
        printk0("[nvme] write_lba: driver not initialised\n")
        return -1
    if nblocks == 0:
        return 0
    return _nvme_write_lba(lba, nblocks, src)


def nvme_read_lba(lba: uint64, nblocks: uint16, dst: uint64) -> int32:
    # Read counterpart, mirroring nvme_write_lba — exposes the existing
    # private _nvme_read_lba helper so the M16.118 write-smoke test can
    # verify a write by reading back.
    if nvme.bar0 == 0:
        printk0("[nvme] read_lba: driver not initialised\n")
        return -1
    if nblocks == 0:
        return 0
    return _nvme_read_lba(lba, nblocks, dst)


# --- BlockDeviceOps adapter wrappers (M16.119) --------------------
#
# kernel/block/blk.ad invokes vtable slots with signature
#   int32 (*op)(uint64 priv, uint64 lba, uint64 count, Ptr[uint8] buf)
# Our driver-level primitives take (uint64 lba, uint16 nblocks, uint64
# buf), so these adapters re-shape the args. priv carries the NSID we
# stashed at register_blockdev time; with multi-NS support the adapters
# now pass that nsid through to nvme_read_lba_ns / nvme_write_lba_ns,
# which look the namespace up in the NS table (block size + capacity)
# and round-robin the I/O across the live queues. Every registered
# namespace (nvme0n1, nvme0n2, ...) shares this same adapter pair.

def _nvme_read_lba_blkop(priv: uint64, lba: uint64,
                         count: uint64, buf: Ptr[uint8]) -> int32:
    if count == 0:
        return 0
    # NVMe NLB is 16-bit (0-based); 65536 sectors per command max.
    # Block layer hands us uint64; clamp + warn rather than wrap.
    if count > 65536:
        printk1("[nvme] blkop read: count=%d too large\n", count)
        return -1
    # priv carries the NSID. Route to that namespace over a round-robin
    # I/O queue; nsid=1 still resolves through the same path the
    # single-NS scope used.
    nsid: uint32 = cast[uint32](priv)
    return nvme_read_lba_ns(nsid, lba, cast[uint16](count),
                            cast[uint64](buf))


def _nvme_write_lba_blkop(priv: uint64, lba: uint64,
                          count: uint64, buf: Ptr[uint8]) -> int32:
    if count == 0:
        return 0
    if count > 65536:
        printk1("[nvme] blkop write: count=%d too large\n", count)
        return -1
    nsid: uint32 = cast[uint32](priv)
    return nvme_write_lba_ns(nsid, lba, cast[uint16](count),
                             cast[uint64](buf))


# --- Write+readback smoke test (M16.118) ---------------------------
#
# Mirrors _ahci_write_smoke_test: pattern-write LBA 1, zero a verify
# buffer, read it back, byte-compare. Uses LBA 1 (not LBA 0) so the
# planted MBR signature the existing nvme_smoke_test grep'd at LBA 0
# isn't clobbered. Buffers are page-allocated because NVMe PRPs
# require page-aligned addressing (PRP1 maps a single page; for our
# 512-byte transfer the rest of the page is unused but harmless).

def _nvme_write_smoke_test() -> int32:
    wbuf: uint64 = alloc_pages(0)
    rbuf: uint64 = alloc_pages(0)
    if wbuf == 0 or rbuf == 0:
        printk0("[nvme] write-smoke: alloc_pages failed\n")
        return -1
    memset(cast[Ptr[uint8]](wbuf), 0, 4096)
    memset(cast[Ptr[uint8]](rbuf), 0, 4096)
    # Plant a recognisable pattern: byte i = (i ^ 0xA5) & 0xFF.
    i: uint64 = 0
    wp: Ptr[uint8] = cast[Ptr[uint8]](wbuf)
    while i < 512:
        wp[i] = cast[uint8](cast[uint8](i & 0xFF) ^ cast[uint8](0xA5))
        i = i + 1

    if nvme_write_lba(1, 1, wbuf) != 0:
        printk0("[nvme] write-smoke: WRITE failed\n")
        return -1
    printk0("[nvme] write LBA=1 nblocks=1 OK\n")

    if nvme_read_lba(1, 1, rbuf) != 0:
        printk0("[nvme] write-smoke: read-back failed\n")
        return -1

    rp: Ptr[uint8] = cast[Ptr[uint8]](rbuf)
    j: uint64 = 0
    while j < 512:
        if rp[j] != wp[j]:
            printk2("[nvme] readback MISMATCH at byte %d (got %x)\n",
                    j, cast[uint64](rp[j]))
            return -1
        j = j + 1
    printk0("[nvme] readback matches pattern\n")
    return 0


# --- Public entry point -------------------------------------------

def nvme_init(run_selftests: int32) -> int32:
    # Probe, init, identify, read LBA 0, then register nvme0n1 + its
    # partitions with the block layer. Returns 0 on success, -1 on
    # any failure. As with ahci, a failure here is non-fatal — the
    # kernel keeps booting either way; we just don't have an NVMe
    # block device.
    #
    # run_selftests gates the DESTRUCTIVE self-tests (write-smoke,
    # blk-smoke, PRP-smoke, multi-queue, health/FLUSH, AER/reset).
    # Those tests WRITE pattern bytes to LBA 1/2/4 of namespace 1 —
    # exactly where a GPT primary header + partition entry array live.
    # Running them on an INSTALLED disk would shred its partition
    # table on every boot, so the normal boot path passes
    # run_selftests=0 (probe + register ONLY, read-only on user data).
    # The dedicated NVMe self-test gate (scripts/test_nvme*.sh, which
    # attaches a SCRATCH nvme disk) passes run_selftests=1.
    bdf: uint32 = _nvme_pci_find_class(NVME_CLASS, NVME_SUBCLASS,
                                  NVME_PROGIF)
    if bdf == PCI_BDF_NONE:
        printk0("[nvme] no controller found\n")
        return -1
    printk1("[nvme] controller found bdf=%x\n", cast[uint64](bdf))

    # Remember the bdf so the timeout->reset-recovery path can re-assert
    # PCI MEM/bus-master without re-scanning the bus.
    nvme.bdf = bdf
    nvme.aer_outstanding = 0
    nvme.aer_events = 0
    nvme.abort_count = 0
    nvme.reset_count = 0

    _nvme_pci_enable_mem_and_master(bdf)

    bar0: uint64 = _pci_read_bar0_64(bdf)
    if bar0 == 0:
        printk0("[nvme] BAR0 is unmapped\n")
        return -1
    nvme.bar0 = bar0
    printk1("[nvme] bar0=%p\n", bar0)

    # Decode CAP.DSTRD (bits 32..35 of the 64-bit CAP register) to
    # know the doorbell stride. DSTRD=0 → 4 byte stride; DSTRD=1 →
    # 8 byte; etc. Almost every controller is DSTRD=0.
    cap: uint64 = _nvme_mmio_r64(bar0 + NVME_CAP)
    dstrd: uint32 = cast[uint32]((cap >> 32) & 0xF)
    nvme.doorbell_stride = cast[uint32](4) << dstrd
    printk2("[nvme] CAP_lo=%x DSTRD=%d\n",
            cast[uint64](cast[uint32](cap & 0xFFFFFFFF)),
            cast[uint64](dstrd))

    vs: uint32 = _nvme_mmio_r32(bar0 + NVME_VS)
    printk1("[nvme] version=%x\n", cast[uint64](vs))

    # ----- Disable controller (CC.EN = 0) and wait CSTS.RDY = 0 -----
    cc: uint32 = _nvme_mmio_r32(bar0 + NVME_CC)
    if (cc & NVME_CC_EN) != 0:
        _nvme_mmio_w32(bar0 + NVME_CC, cc & ~NVME_CC_EN)
        if _wait_csts_rdy(bar0, 0) != 0:
            printk0("[nvme] disable timeout\n")
            return -1

    # ----- Allocate admin SQ + CQ (one page each — 64 entries) -----
    asq: uint64 = alloc_pages(0)
    acq: uint64 = alloc_pages(0)
    if asq == 0 or acq == 0:
        printk0("[nvme] admin queue allocation failed\n")
        return -1
    memset(cast[Ptr[uint8]](asq), 0, 4096)
    memset(cast[Ptr[uint8]](acq), 0, 4096)
    nvme.asq = asq
    nvme.acq = acq
    nvme.asq_tail = 0
    nvme.acq_head = 0
    # CQ entries start with phase 0 (zero-fill); the controller flips
    # them to 1 on the first lap. So our "expected phase" begins as 1.
    nvme.acq_phase = 1
    nvme.admin_cid = 0

    # ----- AQA + ASQ + ACQ registers ------------------------------
    # AQA layout: [ACQS-1:16..27 | ASQS-1:0..11] (depth-1 in each).
    aqa: uint32 = ((NVME_QUEUE_DEPTH - 1) << 16) \
                | (NVME_QUEUE_DEPTH - 1)
    _nvme_mmio_w32(bar0 + NVME_AQA, aqa)
    _nvme_mmio_w64(bar0 + NVME_ASQ, asq)
    _nvme_mmio_w64(bar0 + NVME_ACQ, acq)

    # ----- Set CC and enable -------------------------------------
    new_cc: uint32 = NVME_CC_EN \
                   | NVME_CC_IOSQES_6 \
                   | NVME_CC_IOCQES_4
    # CSS=0, MPS=0, AMS=0, SHN=0 all default to zero — nothing to OR.
    _nvme_mmio_w32(bar0 + NVME_CC, new_cc)

    if _wait_csts_rdy(bar0, NVME_CSTS_RDY) != 0:
        printk0("[nvme] enable timeout\n")
        return -1
    printk0("[nvme] controller ready\n")

    # ----- IDENTIFY controller + namespace -----------------------
    id_buf: uint64 = kmalloc(4096)
    if id_buf == 0:
        printk0("[nvme] kmalloc(4096) for IDENTIFY failed\n")
        return -1
    if _nvme_identify_controller(id_buf) != 0:
        return -1
    # Keep the legacy nsze mirror populated from namespace 1 (the
    # existing single-NS path + register_blockdev capacity depend on
    # nvme.nsze); the full table is filled by _nvme_enumerate_namespaces
    # below.
    if _nvme_identify_namespace(id_buf, 1) != 0:
        return -1

    # ----- Multi-namespace enumeration (CNS=0x02) ----------------
    # IDENTIFY Active Namespace ID list, then IDENTIFY each namespace to
    # record LBA count + block size into the NS table. Falls back to the
    # single nsid=1 record if the list command is unsupported.
    nsn: int32 = _nvme_enumerate_namespaces(id_buf)
    if nsn <= 0:
        # Controller didn't return an active-NS list (older/limited
        # emulation): synthesise a single-namespace table from the
        # nsid=1 IDENTIFY we already did.
        if _nvme_record_namespace(id_buf, 1, 0) == 0:
            nvme.n_namespaces = 1
        else:
            nvme.n_namespaces = 0
    else:
        nvme.n_namespaces = cast[uint32](nsn)
    printk1("[nvme] namespaces active=%d\n",
            cast[uint64](nvme.n_namespaces))

    # ----- Number of Queues feature, then create I/O queues ------
    # SET FEATURES (Number of Queues) MUST precede any CREATE I/O QUEUE
    # (spec §5.21.1.7). Clamp our queue count to what the controller
    # grants.
    granted: uint32 = _nvme_set_num_queues()
    nvme.n_io_queues = 0
    nvme.rr_next = 0

    # Allocate + create queue pair 1 first; its PRP pool is the legacy
    # 64-page pool so the single-queue path stays byte-identical.
    if _nvme_setup_io_queue(NVME_IO_QID) != 0:
        return -1
    # qid=1 PRP pool: the legacy allocator (sets io_prp_pool_ready and
    # io_prp_pool_ready_mq[1]).
    if _alloc_io_prp_pool() != 0:
        printk0("[nvme] PRP-list pool init failed\n")
        return -1
    nvme.n_io_queues = 1

    # Create the remaining I/O queue pairs (qid 2..granted), each with
    # its own SQ/CQ memory + PRP pool.
    qid: uint32 = NVME_IO_QID + 1
    while qid <= granted:
        if _nvme_setup_io_queue(qid) != 0:
            printk1("[nvme] stopping at %d I/O queues\n",
                    cast[uint64](nvme.n_io_queues))
            qid = granted + 1
        else:
            nvme.n_io_queues = nvme.n_io_queues + 1
            qid = qid + 1
    printk1("[nvme] I/O queues online (count=%d)\n",
            cast[uint64](nvme.n_io_queues))
    printk0("[nvme] PRP-list pool ready (64 pages)\n")

    # ----- Read LBA 0 -------------------------------------------
    mbr_buf: uint64 = alloc_pages(0)
    if mbr_buf == 0:
        printk0("[nvme] alloc_pages(0) for MBR failed\n")
        return -1
    memset(cast[Ptr[uint8]](mbr_buf), 0, 4096)
    if _nvme_read_lba(0, 1, mbr_buf) != 0:
        return -1

    # Log first 16 bytes of LBA 0 as hex — same shape as the AHCI
    # driver so output is comparable side-by-side.
    printk0("[nvme] LBA0[0..16]=")
    k: uint64 = 0
    while k < 16:
        b: uint64 = cast[uint64](cast[Ptr[uint8]](mbr_buf + k)[0])
        hi: uint64 = (b >> 4) & 0xF
        lo: uint64 = b & 0xF
        printk1("%x", hi)
        printk1("%x", lo)
        if k < 15:
            printk0(" ")
        k = k + 1
    printk0("\n")

    # MBR signature check — bytes 510/511 must be 0x55 0xAA.
    sig_lo: uint8 = cast[Ptr[uint8]](mbr_buf + 510)[0]
    sig_hi: uint8 = cast[Ptr[uint8]](mbr_buf + 511)[0]
    if sig_lo == 0x55 and sig_hi == 0xAA:
        printk0("[nvme] MBR signature OK\n")
    else:
        printk2("[nvme] MBR signature MISMATCH (got %x %x)\n",
                cast[uint64](sig_lo), cast[uint64](sig_hi))

    # M16.114: wire the INTx IRQ. NVMe natively prefers MSI-X but the
    # spec also defines pin-based INTx fallback for controllers that
    # advertise no MSI-X (or for the polled-init-then-IRQ-driven-runtime
    # path we follow here). Read PCI INTx pin / line, route the
    # firmware-assigned IOAPIC pin to our chosen vector (0x42) on LAPIC
    # 0, register the handler. The polled CQ phase-bit drain stays as
    # safety-net; the handler just acknowledges by walking the CQ for
    # any completion whose phase matches the expected value.
    nbus:  uint32 = pci_bdf_bus(bdf)
    ndev:  uint32 = pci_bdf_dev(bdf)
    nfn:   uint32 = pci_bdf_fn(bdf)
    intx_pin:  uint32 = pci_config_read_byte(nbus, ndev, nfn,
                                             NVME_PCI_INTERRUPT_PIN)
    intx_line: uint32 = pci_config_read_byte(nbus, ndev, nfn,
                                             NVME_PCI_INTERRUPT_LINE)
    ioapic_pin: uint32 = intx_line
    if intx_pin == 0 or intx_line == 0 or intx_line >= 24:
        # QEMU's nvme device lands on IOAPIC pin 11 by default (shared
        # with virtio-net's slot in i440FX); fall back to that.
        ioapic_pin = 11
    nvme.irq_pin = ioapic_pin
    nvme.irq_count = 0
    register_irq_handler(cast[uint64](NVME_IRQ_VECTOR),
                         nvme_irq_handler)
    ioapic_redirect(ioapic_pin, NVME_IRQ_VECTOR, NVME_LAPIC_ID)
    printk2("[nvme] irq pin=%d vec=0x%x\n",
            cast[uint64](ioapic_pin), cast[uint64](NVME_IRQ_VECTOR))

    # M16.118: exercise the new I/O WRITE path. We're here only after
    # IDENTIFY + I/O READ already succeeded, so admin + IO queues are
    # both known good. Each command serialises through qid=1 / slot 0,
    # so a failure mid-test still leaves the controller in a clean
    # state for any later block-layer integration.
    # DESTRUCTIVE (writes LBA 1): gated behind run_selftests.
    if run_selftests != 0:
        _nvme_write_smoke_test()

        # V4.2: cross-page PRP smoke. Issues a 512-byte WRITE+READ where
        # the buffer DELIBERATELY straddles a 4 KiB page boundary (offset
        # 0xF10 → 240 bytes in page 0, 272 bytes in page 1). Pre-V4.2 the
        # second-page bytes were silently dropped because only PRP1 was
        # ever filled; this test catches a regression of that bug.
        nvme_prp_smoke_test()

    # M16.119: register namespace 1 with the kernel block layer as
    # "nvme0n1" (Linux-style: nvme<ctrl>n<ns>). Capacity is the NSZE
    # from IDENTIFY namespace. priv carries the NSID (1 today) so the
    # adapter wrappers can be extended for multi-NS later without
    # touching the vtable shape. Failure here is non-fatal — the
    # driver-level WRITE path still works through nvme_write_lba.
    nvme_ops.read_sectors  = _nvme_read_lba_blkop
    nvme_ops.write_sectors = _nvme_write_lba_blkop
    nbslot: int32 = register_blockdev("nvme0n1", nvme.nsze, &nvme_ops,
                                      cast[uint64](1))
    if nbslot < 0:
        printk0("[nvme] register_blockdev(nvme0n1) failed\n")
        return 0
    printk1("[nvme] registered as block slot=%d (nvme0n1)\n",
            cast[uint64](nbslot))
    # DESTRUCTIVE (writes LBA 1 via the block vtable): gated.
    if run_selftests != 0:
        _nvme_blk_smoke_test(nbslot)

    # M16.x: partition-aware naming. Walk the on-disk partition table
    # for nvme0n1 and register each live partition as a sibling block
    # device "nvme0n1pN" (1-indexed, Linux convention). After this
    # returns, `blk_find_blockdev("nvme0n1p1")` resolves to a device
    # whose I/O lands on the right LBA window of the underlying NVMe
    # namespace. Failure here is non-fatal — raw nvme0n1 still works.
    blk_scan_partitions(nbslot)
    blk_register_partitions(nbslot, "nvme0n1")

    # ----- Multi-namespace block-device registration --------------
    # Register every active namespace beyond nsid=1 as nvme0n<nsid>.
    # priv carries the real NSID so the blkop adapters route to the
    # correct namespace. nsid=1 is already registered above as nvme0n1.
    _nvme_register_extra_namespaces()

    # The remaining self-tests all WRITE to low LBAs (1/2/4) of the
    # namespace — the GPT/partition-table region. Gated behind
    # run_selftests so a normal boot off an installed NVMe disk never
    # touches user data.
    if run_selftests != 0:
        # ----- Multi-queue + multi-NS self-test -------------------
        # Proves: (a) more than one I/O queue is live, (b) more than
        # one namespace was enumerated, (c) an I/O on a SECOND queue
        # and (if present) a SECOND namespace round-trips. Emits the
        # "[nvme-multiq]" PASS markers the test script greps for.
        _nvme_multiq_self_test()

        # ----- FLUSH + SMART/Health self-test ---------------------
        # Issues the two commands that were previously dangling opcode
        # constants: a namespace FLUSH (I/O 0x00) after a write, and a
        # SMART/Health GET LOG PAGE (admin 0x02). Emits "[nvme-health]"
        # PASS markers the test script greps for.
        _nvme_health_self_test()

        # ----- Async Event Request + Abort + reset-recovery -------
        # Arm the controller's async-event reporting (keeps aer_limit
        # AERs outstanding), then run the resilience self-test that
        # proves an AER is parked in the controller, an Abort
        # round-trips, and the timeout->reset-recovery path brings the
        # controller back usable. Emits "[nvme-aer]" PASS markers the
        # test script greps for.
        _nvme_refill_aers()
        _nvme_aer_self_test()

    return 0


# Backwards-compatible thin wrapper: the full destructive self-test
# entry point (scripts/test_nvme*.sh expect this name). Runs the
# complete probe + register + DESTRUCTIVE self-test battery against a
# SCRATCH disk.
def nvme_smoke_test() -> int32:
    return nvme_init(1)


# Register active namespaces other than nsid=1 with the block layer as
# nvme0n<nsid>. The name buffer is built into a small module-scope
# buffer because Adder has no easy stack-string formatting.
nvme_ns_name: Array[16, uint8]
nvme_ns_ops:  Array[8, BlockDeviceOps]


def _fmt_nvme_ns_name(nsid: uint32):
    # Build "nvme0n<nsid>" into nvme_ns_name. nsid is small (<= a few
    # thousand in practice); handle up to 4 decimal digits.
    nvme_ns_name[0] = cast[uint8](0x6E)   # 'n'
    nvme_ns_name[1] = cast[uint8](0x76)   # 'v'
    nvme_ns_name[2] = cast[uint8](0x6D)   # 'm'
    nvme_ns_name[3] = cast[uint8](0x65)   # 'e'
    nvme_ns_name[4] = cast[uint8](0x30)   # '0'
    nvme_ns_name[5] = cast[uint8](0x6E)   # 'n'
    # Decimal-encode nsid into a temp digit buffer, then reverse.
    digits: Array[8, uint8]
    nd: uint32 = 0
    v: uint32 = nsid
    if v == 0:
        digits[0] = cast[uint8](0x30)
        nd = 1
    while v > 0:
        digits[nd] = cast[uint8](0x30 + (v % 10))
        v = v / 10
        nd = nd + 1
    di: uint32 = 0
    while di < nd:
        nvme_ns_name[6 + di] = digits[nd - 1 - di]
        di = di + 1
    nvme_ns_name[6 + nd] = 0


def _nvme_register_extra_namespaces():
    i: uint32 = 0
    while i < nvme.n_namespaces:
        nsid: uint32 = ns_id[i]
        if nsid != 1:
            _fmt_nvme_ns_name(nsid)
            nvme_ns_ops[i].read_sectors  = _nvme_read_lba_blkop
            nvme_ns_ops[i].write_sectors = _nvme_write_lba_blkop
            cap: uint64 = ns_lba_count[i]
            sl: int32 = register_blockdev(
                cast[Ptr[char]](&nvme_ns_name[0]), cap,
                &nvme_ns_ops[i], cast[uint64](nsid))
            if sl < 0:
                printk1("[nvme] register_blockdev nsid=%d failed\n",
                        cast[uint64](nsid))
            else:
                printk2("[nvme] registered nsid=%d block slot=%d\n",
                        cast[uint64](nsid), cast[uint64](sl))
                printk1("[nvme] nvme0n%d registered\n",
                        cast[uint64](nsid))
        i = i + 1


# Buffers for the multi-queue self-test. Module-scope (page-aligned via
# alloc_pages in the test body; these are just the pointers).
def _nvme_multiq_self_test() -> int32:
    # (a) Assert we have more than one I/O queue + namespace.
    printk2("[nvme-multiq] queues=%d namespaces=%d\n",
            cast[uint64](nvme.n_io_queues),
            cast[uint64](nvme.n_namespaces))
    if nvme.n_io_queues > 1:
        printk0("[nvme-multiq] PASS multi-queue (>1 I/O queue)\n")
    else:
        printk0("[nvme-multiq] WARN single I/O queue only\n")
    if nvme.n_namespaces > 1:
        printk0("[nvme-multiq] PASS multi-namespace (>1 NS)\n")
    else:
        printk0("[nvme-multiq] WARN single namespace only\n")

    # (b) Drive an explicit read on the highest I/O queue (qid =
    # n_io_queues) by writing a pattern at LBA 2 of nsid=1 over that
    # queue and reading it back over the same queue. We bypass the
    # round-robin picker here to PIN the transfer to a specific second
    # queue, proving it is independently functional.
    if nvme.n_io_queues < 2:
        return 0
    wbuf: uint64 = alloc_pages(0)
    rbuf: uint64 = alloc_pages(0)
    if wbuf == 0 or rbuf == 0:
        printk0("[nvme-multiq] alloc_pages failed\n")
        return -1
    memset(cast[Ptr[uint8]](wbuf), 0, 4096)
    memset(cast[Ptr[uint8]](rbuf), 0, 4096)
    q2: uint32 = nvme.n_io_queues          # the last/highest I/O queue
    wp: Ptr[uint8] = cast[Ptr[uint8]](wbuf)
    i2: uint64 = 0
    while i2 < 512:
        wp[i2] = cast[uint8](cast[uint8](i2 & 0xFF) ^ cast[uint8](0x3C))
        i2 = i2 + 1
    wstat: uint32 = _io_submit_buf_and_wait_q(
        q2, NVME_IO_WRITE, 1, virt_to_phys(wbuf), 512,
        2, 0, 0, 0, 0, 0)
    rstat: uint32 = _io_submit_buf_and_wait_q(
        q2, NVME_IO_READ, 1, virt_to_phys(rbuf), 512,
        2, 0, 0, 0, 0, 0)
    if wstat != 0 or rstat != 0:
        printk2("[nvme-multiq] q2 I/O failed wstat=%x rstat=%x\n",
                cast[uint64](wstat), cast[uint64](rstat))
        return -1
    rp: Ptr[uint8] = cast[Ptr[uint8]](rbuf)
    j2: uint64 = 0
    while j2 < 512:
        if rp[j2] != wp[j2]:
            printk2("[nvme-multiq] q2 MISMATCH byte %d (got %x)\n",
                    j2, cast[uint64](rp[j2]))
            return -1
        j2 = j2 + 1
    printk1("[nvme-multiq] PASS second-queue read (qid=%d)\n",
            cast[uint64](q2))

    # (c) If there's a second namespace, prove a read on it lands. We
    # read LBA 0 of the second namespace via its own nsid (round-robin
    # queue). Success = the I/O completed (status 0); we don't assert
    # content because the extra NS may be blank.
    if nvme.n_namespaces > 1:
        nsid2: uint32 = ns_id[1]
        memset(cast[Ptr[uint8]](rbuf), 0, 4096)
        if nvme_read_lba_ns(nsid2, 0, 1, rbuf) == 0:
            printk1("[nvme-multiq] PASS second-namespace read (nsid=%d)\n",
                    cast[uint64](nsid2))
        else:
            printk1("[nvme-multiq] second-namespace read FAILED (nsid=%d)\n",
                    cast[uint64](nsid2))
            return -1
    return 0


# Exercise the two newly-issued commands — FLUSH (I/O 0x00) and the
# SMART/Health GET LOG PAGE (admin 0x02) — and emit stable
# "[nvme-health]" PASS markers the test script greps for.
#
#   1. Write a known pattern at LBA 4 of nsid=1, then FLUSH the
#      namespace. A FLUSH after a write proves the durability barrier
#      command completes with status 0. Read the data back to confirm
#      it survived the flush.
#   2. Fetch the SMART/Health log and assert the snapshot is valid and
#      self-consistent (temperature non-zero — every real/emulated
#      controller reports a Kelvin temperature; available-spare <= 100).
def _nvme_health_self_test() -> int32:
    # ----- FLUSH -----
    wbuf: uint64 = alloc_pages(0)
    rbuf: uint64 = alloc_pages(0)
    if wbuf == 0 or rbuf == 0:
        printk0("[nvme-health] alloc_pages failed\n")
        return -1
    memset(cast[Ptr[uint8]](wbuf), 0, 4096)
    memset(cast[Ptr[uint8]](rbuf), 0, 4096)
    wp: Ptr[uint8] = cast[Ptr[uint8]](wbuf)
    i: uint64 = 0
    while i < 512:
        wp[i] = cast[uint8](cast[uint8](i & 0xFF) ^ cast[uint8](0x7E))
        i = i + 1
    if nvme_write_lba_ns(1, 4, 1, wbuf) != 0:
        printk0("[nvme-health] pre-flush write FAILED\n")
        free_pages(wbuf, 0)
        free_pages(rbuf, 0)
        return -1
    if nvme_flush_ns(1) != 0:
        printk0("[nvme-health] FLUSH FAILED\n")
        free_pages(wbuf, 0)
        free_pages(rbuf, 0)
        return -1
    printk0("[nvme-health] PASS flush (nsid=1)\n")
    # Confirm the flushed data reads back intact.
    if nvme_read_lba_ns(1, 4, 1, rbuf) != 0:
        printk0("[nvme-health] post-flush read FAILED\n")
        free_pages(wbuf, 0)
        free_pages(rbuf, 0)
        return -1
    rp: Ptr[uint8] = cast[Ptr[uint8]](rbuf)
    j: uint64 = 0
    while j < 512:
        if rp[j] != wp[j]:
            printk2("[nvme-health] post-flush MISMATCH byte %d (got %x)\n",
                    j, cast[uint64](rp[j]))
            free_pages(wbuf, 0)
            free_pages(rbuf, 0)
            return -1
        j = j + 1
    printk0("[nvme-health] PASS flush-durable readback\n")
    free_pages(wbuf, 0)
    free_pages(rbuf, 0)

    # ----- SMART / Health log -----
    if nvme_fetch_smart_log() != 0:
        printk0("[nvme-health] SMART fetch FAILED\n")
        return -1
    if nvme.smart_valid != 1:
        printk0("[nvme-health] SMART snapshot invalid\n")
        return -1
    if nvme.smart_temp_k == 0:
        printk0("[nvme-health] SMART temperature implausible (0K)\n")
        return -1
    if nvme.smart_avail_spare > 100:
        printk1("[nvme-health] SMART available-spare implausible (%d%%)\n",
                cast[uint64](nvme.smart_avail_spare))
        return -1
    printk0("[nvme-health] PASS smart-log\n")
    return 0


def _nvme_aer_self_test() -> int32:
    # Resilience self-test for the new AER / Abort / reset-recovery code.
    # Exercises three independent properties against the REAL emulated
    # controller:
    #
    #   (1) AER is submitted and the driver stays healthy. _nvme_refill_aers
    #       has already parked aer_limit AERs in the controller; assert at
    #       least one is outstanding and that a normal admin command
    #       (IDENTIFY controller via a fresh fetch) still completes — i.e.
    #       the parked AERs don't wedge the admin queue.
    #
    #   (2) An Abort command round-trips. We Abort a CID on the admin
    #       queue; QEMU replies (typically "not aborted" since nothing
    #       matches, but the command itself completes with status 0). That
    #       proves opcode 0x08 submission + completion handling work.
    #
    #   (3) The timeout->reset-recovery path is invoked and the controller
    #       comes back usable. We issue an admin IDENTIFY through the
    #       timeout-aware path with a DELIBERATELY tiny spin budget (1),
    #       which always "times out" before QEMU posts the completion. That
    #       drives the real escalation: Abort, then a REAL controller
    #       disable->enable reset dance. Afterwards we prove the controller
    #       is usable by issuing a normal IDENTIFY + an I/O read of LBA 0.

    # (1) AER outstanding + admin queue still healthy.
    if nvme.aer_outstanding < 1:
        printk0("[nvme-aer] FAIL: no AER outstanding after refill\n")
        return -1
    id_buf: uint64 = kmalloc(4096)
    if id_buf == 0:
        printk0("[nvme-aer] FAIL: kmalloc\n")
        return -1
    if _nvme_identify_controller(id_buf) != 0:
        printk0("[nvme-aer] FAIL: admin cmd wedged with AERs parked\n")
        return -1
    # Drain any AER completions QEMU may have posted (it won't have on a
    # quiet boot, but the drain path must be exercised + must not hang).
    _nvme_drain_aers()
    printk1("[nvme-aer] PASS aer-submit (outstanding=%d)\n",
            cast[uint64](nvme.aer_outstanding))

    # (2) Abort round-trips.
    abefore: uint64 = nvme.abort_count
    if _nvme_abort(NVME_ADMIN_QID, 0x1234) != 0:
        printk0("[nvme-aer] FAIL: abort did not round-trip\n")
        return -1
    if nvme.abort_count <= abefore:
        printk0("[nvme-aer] FAIL: abort_count did not advance\n")
        return -1
    printk1("[nvme-aer] PASS abort (abort_count=%d)\n", nvme.abort_count)

    # (3) Timeout -> abort -> reset recovery. A zero spin budget makes the
    # bounded poll return TIMEOUT immediately (the command is still really
    # outstanding in the controller), and the force hook skips the
    # post-abort recovery poll so the FULL escalation runs to a REAL
    # controller disable->enable reset dance.
    rbefore: uint64 = nvme.reset_count
    nvme_force_reset_on_timeout = 1
    st: uint32 = _admin_submit_to(NVME_ADMIN_IDENTIFY, 0, id_buf, 0,
                                  NVME_CNS_CONTROLLER, 0, 0, 0, 0, 0,
                                  cast[uint64](0))
    nvme_force_reset_on_timeout = 0
    # st is expected to be NVME_POLL_TIMEOUT (command discarded by reset);
    # what matters is that a REAL reset happened and the controller is
    # usable afterwards.
    if nvme.reset_count <= rbefore:
        printk0("[nvme-aer] FAIL: reset recovery never fired\n")
        return -1
    printk1("[nvme-aer] reset recovery fired (reset_count=%d)\n",
            nvme.reset_count)

    # Prove the controller is usable post-reset: a clean IDENTIFY...
    if _nvme_identify_controller(id_buf) != 0:
        printk0("[nvme-aer] FAIL: IDENTIFY after reset\n")
        return -1
    # ...and a real I/O read of LBA 0 through the recreated I/O queue.
    rbuf: uint64 = alloc_pages(0)
    if rbuf == 0:
        printk0("[nvme-aer] FAIL: alloc_pages\n")
        return -1
    memset(cast[Ptr[uint8]](rbuf), 0, 4096)
    if _nvme_read_lba(0, 1, rbuf) != 0:
        printk0("[nvme-aer] FAIL: I/O read after reset\n")
        free_pages(rbuf, 0)
        return -1
    free_pages(rbuf, 0)
    printk1("[nvme-aer] PASS reset-recovery (reset_count=%d)\n",
            nvme.reset_count)

    printk0("[nvme-aer] PASS\n")
    return 0


def _nvme_blk_smoke_test(slot: int32) -> int32:
    # M16.119 block-layer round-trip — counterpart of the AHCI helper
    # in drivers/ata/ahci.ad. Writes a 512-byte pattern at LBA 1 via
    # the block-layer vtable, reads it back through the same vtable,
    # byte-compares. PASS markers are stable strings the test script
    # greps for. The pattern (byte i = i ^ 0x5A) is distinct from the
    # driver-level smoke test's 0xA5 mask so a stale-buffer bug shows
    # up cleanly rather than silently passing.
    #
    # alloc_pages(0) is used (not kmalloc) because NVMe PRP1 must be
    # page-aligned — the same constraint _nvme_write_smoke_test
    # follows. Only the first 512 bytes of each 4 KiB page carry the
    # transfer; the rest is unused but harmless.
    wbuf: uint64 = alloc_pages(0)
    rbuf: uint64 = alloc_pages(0)
    if wbuf == 0 or rbuf == 0:
        printk0("[nvme] blk-smoke: alloc_pages failed\n")
        return -1
    memset(cast[Ptr[uint8]](wbuf), 0, 4096)
    memset(cast[Ptr[uint8]](rbuf), 0, 4096)
    wp: Ptr[uint8] = cast[Ptr[uint8]](wbuf)
    i: uint64 = 0
    while i < 512:
        wp[i] = cast[uint8](cast[uint8](i & 0xFF) ^ cast[uint8](0x5A))
        i = i + 1

    if blk_write_sectors(slot, 1, 1, wp) != 0:
        printk0("[nvme] blk-smoke: blk_write_sectors failed\n")
        return -1
    printk0("[blk] write nvme0n1 LBA=1 OK\n")

    rp: Ptr[uint8] = cast[Ptr[uint8]](rbuf)
    if blk_read_sectors(slot, 1, 1, rp) != 0:
        printk0("[nvme] blk-smoke: blk_read_sectors failed\n")
        return -1

    j: uint64 = 0
    while j < 512:
        if rp[j] != wp[j]:
            printk2("[nvme] blk-smoke: MISMATCH at byte %d (got %x)\n",
                    j, cast[uint64](rp[j]))
            return -1
        j = j + 1
    printk0("[blk] readback nvme0n1 matches\n")
    return 0


def nvme_irq_handler():
    # IRQ-context entry. NVMe has no single "interrupt status" register
    # for the controller; the canonical "is there work" signal is the
    # phase bit on each CQ. Walk the I/O CQ at the expected head + phase
    # and advance for each completion we observe. We don't currently
    # consume the result here — the polled submit/wait helpers in the
    # init path are the only consumers of CQ entries this milestone,
    # and they look at the SAME head/phase bookkeeping. The handler
    # exists to keep the line de-asserted and to give later
    # multi-queue / async-I/O work a place to plug in.
    if nvme.bar0 == 0:
        return
    nvme.irq_count = nvme.irq_count + 1
    # Probe one CQ slot: if its phase matches what we expect, the
    # controller delivered a completion since we last drained. We
    # don't pop it (the polled path owns the head/phase advancement);
    # we just observe. The LAPIC EOI will be sent by do_irq().
    cq_base: uint64 = nvme.iocq
    if cq_base == 0:
        return
    head: uint32 = nvme.iocq_head
    expected_phase: uint32 = nvme.iocq_phase
    slot_addr: uint64 = cq_base \
                      + cast[uint64](head) * NVME_CQ_ENTRY_BYTES
    e: Ptr[uint32] = cast[Ptr[uint32]](slot_addr)
    dw3: uint32 = e[3]
    cur_phase: uint32 = (dw3 >> 16) & 0x1
    if cur_phase == expected_phase:
        # Completion present — log presence; the polled path will
        # consume it the next time the kernel calls into an
        # _io_submit_and_wait helper.
        printk0("[nvme] irq: CQ completion observed\n")


def nvme_irq_count() -> uint64:
    return nvme.irq_count


# V4.2 PRP-list smoke fixture lives in tests/test_nvme_prp.ad. The
# import sits at the bottom of the module (matching the pattern
# drivers/block/partition.ad uses for its GPT mkpart fixture) so the
# test module can re-import nvme_write_lba / nvme_read_lba without
# tripping a circular import at load time.
from tests.test_nvme_prp import nvme_prp_smoke_test

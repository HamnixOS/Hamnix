# drivers/ata/ahci.ad
#
# Bare-metal AHCI (Advanced Host Controller Interface) driver. Mirror of
# drivers/ata/ahci.c at minimum useful scope:
#
#   1. Walk the PCI bus for class=0x01, subclass=0x06, prog_if=0x01.
#   2. Map ABAR (BAR5) — a memory-mapped HBA register window.
#   3. Set GHC.AE (AHCI Enable) so the HBA exposes AHCI semantics.
#   4. For every port advertised in PI (Ports Implemented) check SSTS;
#      det==3 && ipm==1 means an active SATA drive is plugged into
#      that port at a live PHY layer. Then read PORT_SIG and pick the
#      FIRST port whose signature is 0x101 (ATA disk) — this is what
#      lets us boot from a board whose OS disk lives on port 1 or 2
#      while port 0 is an empty hot-swap bay.
#   5. Allocate one 4 KiB page per active port and carve out:
#         0x000..0x3FF  command list (32 entries × 32 bytes)
#         0x400..0x4FF  received-FIS area (256 bytes)
#         0x500..0x57F  command table (CFIS + PRDT entry)
#      The page is 4 KiB aligned, which satisfies all three AHCI
#      alignment requirements (1024 / 256 / 128 bytes).
#   6. Wire CLB/CLBU + FB/FBU registers, set FRE then ST in CMD —
#      port is now running.
#   7. Issue IDENTIFY DEVICE (ATA 0xEC) into a 512-byte kmalloc'd
#      buffer via slot 0. Poll CI bit clear. Parse out the model
#      string and total LBA count and log them.
#   8. Issue READ DMA EXT (ATA 0x25) of LBA 0 into a second 512-byte
#      buffer. Poll completion. Log the first 16 bytes as hex and
#      check the MBR boot signature (0xAA55 at bytes 510..511).
#
# Why polled, not IRQ-driven? Same reason virtio-net is polled — the
# kernel brings up the LAPIC for the timer tick but does NOT yet
# program the IOAPIC, so PCI INTx lines have nowhere to land. MSI
# would also work but adds complexity ruled out of this milestone.
# We poll the CI (Command Issue) register for the bit corresponding
# to our slot to clear.
#
# Why a single slot? The spec allows 1..32 in-flight commands per
# port via NCQ. The smoke test only needs to round-trip two
# commands; one slot serialised is sufficient. NCQ comes later.
#
# AHCI spec (Intel rev 1.3.1) is the canonical reference — see
# section 3.1 (HBA Memory Registers) and 4.2 (Command List structure).
#
# M16.124 spec-conformance audit closed the following lowest-risk
# gaps that would have prevented real-hardware boot:
#   - PORT_SIG-aware port enumeration (first ATA-signature port wins,
#     not first link-active port; CAP.NP logged).
#   - PxIS error decoding (TFES / HBFS / IFS / HBDS) on CI-poll path
#     so a wedged drive fails the I/O instead of stalling on a stuck
#     CI bit. PxSERR captured + acked.
# Still missing for full real-hardware boot: see docs/REAL_HARDWARE.md
# "Known limitations" and the gap list in the M16.124 commit.

from kernel.printk.printk import printk0, printk1, printk2, printk_set_level
from drivers.tty.serial.early_8250 import PRINTK_LEVEL_EMERG
from drivers.pci.pci import (
    pci_config_read_dword, pci_config_write_dword,
    pci_config_read_byte,
    pci_bdf_bus, pci_bdf_dev, pci_bdf_fn, pci_pack_bdf,
    pci_read_bar, PCI_BDF_NONE,
    PCI_COMMAND_OFFSET, PCI_COMMAND_MEM, PCI_COMMAND_MASTER,
)
from arch.x86.kernel.apic import ioapic_redirect
from arch.x86.kernel.irq import register_irq_handler
from mm.page_alloc import alloc_pages
from mm.slab import kmalloc
# Higher-half kernel: a caller-supplied DMA buffer that is a kernel
# global needs virt_to_phys() rebasing before the AHCI engine sees it.
from arch.x86.mm.pgtable import virt_to_phys
from kernel.block.blk import (
    BlockDeviceOps, register_blockdev, find_blockdev,
    blk_read_sectors, blk_write_sectors, SECTOR_SIZE,
    blk_scan_partitions, blk_register_partitions,
)
# WaitQueue / two-phase wait primitives for the NCQ block path. Real NCQ
# semantics: a task issuing blk_read_sectors/blk_write_sectors against the
# AHCI port allocates a free command-list slot (or sleeps on the allocator
# wait queue if all 32 are in flight), submits a queued command via the
# PxSACT+PxCI tag-issue protocol, then sleeps on a per-slot wait queue until
# ahci_irq_handler wakes it. See kernel/sched/core.ad for the prepare/commit
# dance — same shape as fs/pipe.ad's reader sleep path.
from kernel.sched.core import (
    WaitQueue, wq_init, wq_wake_one, wq_wake_all,
    wq_wait_prepare, wq_wait_cancel, wq_wait_commit,
    wq_wait_commit_timeout, WQ_EINTR, WQ_TIMEOUT,
)

extern def memset(dst: Ptr[uint8], val: int32, n: uint64) -> Ptr[uint8]


# PCI config-space offsets for the IRQ wiring path. Mirror of the
# pair virtio_net uses; PCI spec §6.2.4.
AHCI_PCI_INTERRUPT_LINE: uint32 = 0x3C
AHCI_PCI_INTERRUPT_PIN:  uint32 = 0x3D

# CPU vector this driver claims for its INTx IRQ. virtio-net claims
# 0x40; AHCI follows at 0x41 (M16.114 IRQ-wiring batch — see
# `arch/x86/kernel/irq.ad` for the 0x40..0x44 allocation map).
AHCI_IRQ_VECTOR: uint32 = 0x41
AHCI_LAPIC_ID:   uint32 = 0


# --- PCI matching --------------------------------------------------
#
# AHCI controllers carry the standard mass-storage / SATA / AHCI class
# triplet regardless of vendor. We match on class rather than
# vendor:device so the driver works against QEMU's ich9-ahci
# (8086:2922), real ICH/PCH SATA, AMD FCH, Marvell, etc.
AHCI_CLASS:    uint32 = 0x01
AHCI_SUBCLASS: uint32 = 0x06
AHCI_PROGIF:   uint32 = 0x01
# AHCI 1.0 (single command slot) is also valid hardware. AHCI 1.3 spec
# §2.1.11 says the AHCI-detection path must match progIF 0x01; a 0x00
# variant exists only on early prototype HBAs and is not seen on real
# silicon. We hardcode the 0x01 case but explicitly reject the SAS
# subclass / RAID-mode progIFs in the scan loop below — those need
# vendor-specific drivers and the wrong driver claiming the port
# will hang at port_start.

# Generic Host Control register offsets (relative to ABAR).
HBA_CAP:   uint64 = 0x00
HBA_GHC:   uint64 = 0x04
HBA_IS:    uint64 = 0x08
HBA_PI:    uint64 = 0x0C
HBA_VS:    uint64 = 0x10

# CAP register bits we care about. Low 5 bits = NP (Number of Ports,
# zero-based — value 0 means 1 port, value 31 means 32 ports).
HBA_CAP_NP_MASK: uint32 = 0x1F

GHC_AE:    uint32 = 0x80000000        # bit 31 — AHCI Enable
GHC_HR:    uint32 = 0x00000001        # bit  0 — HBA Reset

# Per-port register block starts at ABAR + 0x100 and is 0x80 bytes wide.
HBA_PORTS_BASE: uint64 = 0x100
HBA_PORT_STRIDE: uint64 = 0x80

# Port register offsets within a port's 0x80-byte block.
PORT_CLB:   uint64 = 0x00
PORT_CLBU:  uint64 = 0x04
PORT_FB:    uint64 = 0x08
PORT_FBU:   uint64 = 0x0C
PORT_IS:    uint64 = 0x10
PORT_IE:    uint64 = 0x14
PORT_CMD:   uint64 = 0x18
PORT_TFD:   uint64 = 0x20
PORT_SIG:   uint64 = 0x24
PORT_SSTS:  uint64 = 0x28
PORT_SCTL:  uint64 = 0x2C
PORT_SERR:  uint64 = 0x30
PORT_SACT:  uint64 = 0x34
PORT_CI:    uint64 = 0x38

# CMD register bits.
PORT_CMD_ST:   uint32 = 0x0001        # bit  0 — Start
PORT_CMD_FRE:  uint32 = 0x0010        # bit  4 — FIS Receive Enable
PORT_CMD_FR:   uint32 = 0x4000        # bit 14 — FIS Receive Running
PORT_CMD_CR:   uint32 = 0x8000        # bit 15 — Command List Running

# Task-File Data status bits.
PORT_TFD_BSY: uint32 = 0x80
PORT_TFD_DRQ: uint32 = 0x08
PORT_TFD_ERR: uint32 = 0x01

# PxSSTS DET (device detection) field values (spec §3.3.10).
#   0 = no device, no PHY
#   1 = device present, no PHY communication
#   3 = device present, PHY communication established
#   4 = PHY in offline / disabled mode
PORT_SSTS_DET_PRESENT_PHY: uint32 = 3

# PxSCTL DET (spec §3.3.11) — host-controlled link-reset request.
#   0 = no action / allow normal operation
#   1 = perform COMRESET (interface reset, re-establish PHY)
#   4 = disable the SATA interface (offline)
# The COMRESET sequence writes DET=1, holds it >= 1 ms, then writes
# DET=0 and waits for PxSSTS DET to settle to 3 again.
PORT_SCTL_DET_MASK:     uint32 = 0xF
PORT_SCTL_DET_COMRESET: uint32 = 1
PORT_SCTL_DET_IDLE:     uint32 = 0

# PxIS error bits (spec §3.3.5). PxIS is the per-port interrupt status
# register; even with polled I/O we read it after each command so a
# Task-File Error or Host-Bus Fatal Error can be reported instead of
# silently masquerading as a successful CI clear.
#   TFES (bit 30) — Task File Error Status
#   HBFS (bit 29) — Host Bus Fatal Error Status
#   HBDS (bit 28) — Host Bus Data Error Status
#   IFS  (bit 27) — Interface Fatal Error Status
#   INFS (bit 26) — Interface Non-fatal Error Status
PORT_IS_TFES: uint32 = 0x40000000
PORT_IS_HBFS: uint32 = 0x20000000
PORT_IS_HBDS: uint32 = 0x10000000
PORT_IS_IFS:  uint32 = 0x08000000
PORT_IS_INFS: uint32 = 0x04000000
PORT_IS_ERR_MASK: uint32 = 0x7C000000

# PxIS hot-plug / link-change cause bits (spec §3.3.5).
#   PRCS (bit 22) — PhyRdy Change Status. Set when the PhyRdy signal
#                   changes state, i.e. a device's PHY came up or went
#                   down (the live hot-plug edge on most controllers).
#                   PRCS reflects PxSERR.DIAG.N (bit 16).
#   PCS  (bit  6) — Port Connect Change Status. Reflects PxSERR.DIAG.X
#                   (bit 26) — a cold-presence / Phy-comm-init change,
#                   the other hot-plug edge.
#   DPS  (bit  5) — Descriptor Processed (informational, not used here).
PORT_IS_PRCS: uint32 = 0x00400000
PORT_IS_PCS:  uint32 = 0x00000040
PORT_IS_HOTPLUG_MASK: uint32 = 0x00400040

# PxIS completion-cause bits we use to drive the NCQ IRQ-completion path.
#   DHRS (bit 0) — Device-to-Host Register FIS completed. Legacy (non-queued)
#                  commands raise this when the device delivers its final
#                  D2H register FIS.
#   SDBS (bit 3) — Set Device Bits FIS. Fired for queued (NCQ) commands —
#                  carries the SActive bit clearing for the completed tag(s).
# We treat EITHER bit as "look at PxCI/PxSACT and complete any slots whose
# bookkeeping says busy but whose hardware bit is now clear".
PORT_IS_DHRS: uint32 = 0x00000001
PORT_IS_SDBS: uint32 = 0x00000008
PORT_IS_COMPLETION_MASK: uint32 = 0x00000009

# PxIE interrupt-enable bits — same bit layout as PxIS. We enable the
# error causes plus the two hot-plug edges so the HBA latches them; even
# in the polled driver, enabling the right PxIE bits is what real AHCI
# drivers do and is what lets PxIS reflect a hot-plug edge promptly on
# real hardware. (D2H Register FIS / PIO Setup completion bits omitted —
# the driver polls CI for command completion.)
PORT_IE_TFEE: uint32 = 0x40000000        # Task File Error enable
PORT_IE_HBFE: uint32 = 0x20000000        # Host Bus Fatal Error enable
PORT_IE_HBDE: uint32 = 0x10000000        # Host Bus Data Error enable
PORT_IE_IFE:  uint32 = 0x08000000        # Interface Fatal Error enable
PORT_IE_PRCE: uint32 = 0x00400000        # PhyRdy Change enable
PORT_IE_PCE:  uint32 = 0x00000040        # Port Connect Change enable
PORT_IE_DHRE: uint32 = 0x00000001        # Device-to-Host Register FIS enable
PORT_IE_SDBE: uint32 = 0x00000008        # Set Device Bits FIS enable (NCQ completion)
# The aggregate enable mask we plant in PxIE at port bring-up.
# 0x78400041 = error causes + hot-plug edges + DHRE; OR'd with SDBE (0x08)
# so NCQ FPDMA queued-command completions actually raise PxIS at the IRQ.
PORT_IE_DEFAULT: uint32 = 0x78400049

# PxSERR diagnostic bits (spec §3.3.12). Write-1-to-clear.
#   DIAG.N (bit 16) — PhyRdy change (mirrors PxIS.PRCS).
#   DIAG.X (bit 26) — Exchanged: a COMINIT was received, i.e. a device
#                     was newly attached / exchanged (mirrors PxIS.PCS).
PORT_SERR_DIAG_N: uint32 = 0x00010000
PORT_SERR_DIAG_X: uint32 = 0x04000000

# PxSSTS IPM (Interface Power Management) field (bits 8..11): 1 = active.
PORT_SSTS_IPM_ACTIVE: uint32 = 1

# READ LOG EXT (ATA8 §7.22) — command 0x2F. The NCQ error log lives at
# log address 0x10 (page 10h); its first byte's low 5 bits carry the tag
# of the command that failed an NCQ sequence, with bit 7 (NQ) indicating
# whether the error was tied to a queued command. We read it after an
# NCQ task-file error so the failing tag can be identified and the
# remaining un-completed tagged commands re-queued.
ATA_CMD_READ_LOG_EXT:  uint8 = 0x2F
ATA_LOG_NCQ_ERROR:     uint8 = 0x10

# Per-page layout we carve out per port (4 KiB page).
CL_OFFSET:   uint64 = 0x000     # command list   (1024 bytes)
FIS_OFFSET:  uint64 = 0x400     # received FIS   (256 bytes)
CT_OFFSET:   uint64 = 0x500     # command table  (256 bytes — plenty)

# Command table layout (relative to CT_OFFSET).
CT_CFIS_OFF:  uint64 = 0x00
CT_PRDT_OFF:  uint64 = 0x80     # PRDT entries start 128 bytes in

# --- NCQ multi-slot command tables (M16.x — real NCQ) --------------
#
# The legacy path (single command at a time) reused command list slot 0
# and the single command table at page+CT_OFFSET. Real Native Command
# Queuing needs an INDEPENDENT command table per command-list slot so up
# to 32 commands can be built and made outstanding concurrently.
#
# We carve a dedicated 16 KiB region (alloc_pages(2)) for 32 command
# tables, one per slot, each 256 bytes (CFIS 64 + room for several PRDT
# entries). 32 * 256 = 8 KiB, so a 16 KiB order-2 allocation is roomy
# and page-aligned (satisfies the 128-byte command-table alignment).
AHCI_NCQ_SLOTS:    uint32 = 32
AHCI_CT_STRIDE:    uint64 = 0x100      # 256 bytes per slot's cmd table
AHCI_CT_PAGE_ORDER: int32 = 2          # 16 KiB (>= 32 * 256)

# Bounded wait the NCQ block path uses per submitted command. With the 100 Hz
# timer in tree, 30 jiffies ≈ 300 ms; ATTEMPTS=10 caps a single I/O at ~3 s
# before declaring an HBA wedge. Under working IRQ delivery the SDBS interrupt
# wakes us in microseconds — the timeout only kicks in on a flaky-IRQ host
# (TCG / shared-INTx) where the timer-driven re-poll keeps progress.
AHCI_NCQ_RW_TIMEOUT_TICKS: uint64 = 30
AHCI_NCQ_RW_ATTEMPTS:      uint32 = 10

# ATA commands we issue.
ATA_CMD_IDENTIFY:     uint8 = 0xEC
ATA_CMD_READ_DMA_EXT:  uint8 = 0x25
# WRITE DMA EXT (M16.118). Same LBA48 / FIS shape as READ DMA EXT;
# the only differences are this command byte + the W bit (DW0 bit 6)
# in the command header telling the HBA the transfer direction is
# host-to-device. See AHCI spec §5.3.3 + ATA8 §7.65.
ATA_CMD_WRITE_DMA_EXT: uint8 = 0x35

# DATA SET MANAGEMENT (ATA8 §7.10) — the TRIM command. Issued as a DMA
# write (host-to-device): the host hands the device one or more 512-byte
# blocks of LBA-range entries describing the regions to deallocate. The
# TRIM operation is selected by the TRIM bit (bit 0) in the Features
# register. count = number of 512-byte blocks of range data (we send 1).
ATA_CMD_DSM:           uint8 = 0x06
ATA_DSM_FEATURE_TRIM:  uint8 = 0x01

# Native Command Queuing — First-Party DMA Queued commands (ATA8 §7.21/§7.66).
# The HBA arms a queued command via the PxSACT (Set Active) register tag bit
# BEFORE setting PxCI; the device clears the SACT bit on completion (and CI
# when it accepts the command). The block-layer NCQ path uses these:
#   READ FPDMA QUEUED  (0x60) — device -> host, queued
#   WRITE FPDMA QUEUED (0x61) — host -> device, queued
# Tag goes in the sector-count register bits 7..3 (i.e. count_lo = tag<<3);
# the transfer length goes in the features register (lo=count[0..7],
# hi=count[8..15]). FUA is bit 7 of the device register on the WRITE flavor.
ATA_CMD_READ_FPDMA_QUEUED:  uint8 = 0x60
ATA_CMD_WRITE_FPDMA_QUEUED: uint8 = 0x61

# SMART (ATA8 §7.52). The SMART command is multiplexed by a Features
# subcommand byte: 0xD0 = SMART READ DATA (returns a 512-byte device
# health/attribute block). The LBA mid/hi registers must carry the SMART
# signature 0x4F / 0xC2 or the device aborts the command. QEMU's
# ich9-ahci does NOT implement SMART, so the SMART path is best-effort:
# the driver issues it and correctly decodes a graceful "command aborted"
# (TFD.ERR set) instead of hanging or masquerading as success.
ATA_CMD_SMART:           uint8 = 0xB0
ATA_SMART_READ_DATA:     uint8 = 0xD0
ATA_SMART_LBA_MID_SIG:   uint8 = 0x4F
ATA_SMART_LBA_HI_SIG:    uint8 = 0xC2

# IDENTIFY DEVICE word offsets we decode (each word = 2 bytes; ATA8 §7.18).
#   word 100..103 — 48-bit "Total Number of User Addressable Sectors"
#                   (LBA48 capacity). Little-endian quad of 16-bit words.
#   word 217      — Nominal media rotation rate. 1 = non-rotating (SSD);
#                   0x0401..0xFFFE = rotational RPM; 0/0xFFFF = not
#                   reported.
ATA_ID_WORD_LBA48_LO:    uint64 = 100
ATA_ID_WORD_ROTATION:    uint64 = 217
ATA_ID_ROTATION_SSD:     uint16 = 1

# H2D Register FIS type byte (FIS_TYPE_REG_H2D).
FIS_TYPE_REG_H2D: uint8 = 0x27

# SATA signature constants we recognise. ATA disks report 0x00000101.
PORT_SIG_ATA: uint32 = 0x00000101


# --- MMIO helpers --------------------------------------------------

def _mmio_r32(addr: uint64) -> uint32:
    return cast[Ptr[uint32]](addr)[0]


def _mmio_w32(addr: uint64, value: uint32):
    cast[Ptr[uint32]](addr)[0] = value


# --- Class-based PCI scan (no helper in drivers/pci/pci.ad) --------
#
# Returns a packed BDF for the first device whose class triple matches
# (class_code, subclass, prog_if), or PCI_BDF_NONE. We scan bus 0
# function 0 only — same scope as drivers/pci/pci.ad's pci_find().
# QEMU's i440FX/q35 puts the AHCI controller on bus 0 directly.

def _pci_find_class(class_code: uint32, subclass: uint32,
                    prog_if: uint32) -> uint32:
    bus: uint32 = 0
    dev: uint32 = 0
    while dev < 32:
        ident: uint32 = pci_config_read_dword(bus, dev, 0, 0x00)
        v: uint32 = ident & 0xFFFF
        if v != 0xFFFF:
            cls: uint32 = pci_config_read_dword(bus, dev, 0, 0x08)
            # cls layout: [class_code:24..31 | subclass:16..23
            #              | prog_if:8..15 | revision:0..7]
            this_class:    uint32 = (cls >> 24) & 0xFF
            this_subclass: uint32 = (cls >> 16) & 0xFF
            this_progif:   uint32 = (cls >>  8) & 0xFF
            if this_class == class_code \
               and this_subclass == subclass \
               and this_progif == prog_if:
                return pci_pack_bdf(bus, dev, 0)
        dev = dev + 1
    return PCI_BDF_NONE


def _pci_enable_mem_and_master(bdf: uint32):
    # AHCI lives behind a MEM BAR (BAR5), not an IO BAR. We need
    # MEM Space Enable + Bus Master flipped on; IO Space Enable
    # doesn't matter for this device. pci.ad's helper enables IO
    # which is harmless but not what we want, so we open-code the
    # MEM+master pair here.
    bus: uint32 = pci_bdf_bus(bdf)
    dev: uint32 = pci_bdf_dev(bdf)
    fn:  uint32 = pci_bdf_fn(bdf)
    cmd: uint32 = pci_config_read_dword(bus, dev, fn,
                                        PCI_COMMAND_OFFSET) & 0xFFFF
    cmd = cmd | PCI_COMMAND_MEM | PCI_COMMAND_MASTER
    upper: uint32 = pci_config_read_dword(bus, dev, fn,
                                          PCI_COMMAND_OFFSET) & 0xFFFF0000
    pci_config_write_dword(bus, dev, fn, PCI_COMMAND_OFFSET,
                           upper | cmd)


# --- Driver state --------------------------------------------------

class AhciState:
    abar:      uint64          # MMIO base of HBA register window
    port_num:  int32           # The active port we picked (or -1)
    pad_port:  uint32
    port_base: uint64          # ABAR + 0x100 + 0x80*port_num
    page:      uint64          # 4 KiB working page per port
    capacity:  uint64          # LBA48 total sector count (from IDENTIFY)
    irq_pin:   uint32          # IOAPIC pin we redirected (diag)
    pad_irq:   uint32
    irq_count: uint64          # IRQs handled
    ct_page:   uint64          # 16 KiB region: 32 per-slot cmd tables
    # 16 bytes of model string + NUL — enough to fingerprint the disk.
    model:     Array[41, uint8]


ahci: AhciState

# --- NCQ per-slot bookkeeping (flat module-scope, indexed by slot) --
#
# Adder miscompiles nested frame-local arrays, so per-slot state lives
# in flat module-scope arrays indexed by the command-list slot number
# (0..31). These track which slots the driver believes are in flight and
# associate each slot with the request that owns it.
#
#   _ncq_slot_busy[s]   1 if slot s has an outstanding command we issued
#   _ncq_slot_tag[s]    caller-supplied request tag/id owning slot s
#   _ncq_slot_buf[s]    data buffer VA for slot s (diagnostic / reuse)
#   _ncq_slot_status[s] completion status: 0 = ok, -1 = error, 1 = pending
_ncq_slot_busy:   Array[32, uint32]
_ncq_slot_tag:    Array[32, uint64]
_ncq_slot_buf:    Array[32, uint64]
_ncq_slot_status: Array[32, int32]

# Peak number of CI bits observed set simultaneously across the most
# recent concurrent submission — the load-bearing evidence that more
# than one slot was genuinely in flight at once. The self-test reads it.
_ncq_peak_inflight: uint32 = 0
# Monotonic count of distinct slots the allocator has handed out since
# boot — proves the allocator rotates across slots rather than always
# reusing slot 0.
_ncq_slots_used_mask: uint32 = 0

# --- NCQ block-path completion plumbing ----------------------------
#
# Real NCQ on the BLOCK path (blk_read_sectors / blk_write_sectors ->
# _ahci_*_blkop -> ahci_read_sectors/ahci_write_sectors) needs:
#   * a way for the issuing task to SLEEP until its slot's completion edge
#     fires, instead of busy-polling a single shared CI register;
#   * a way for any task to BLOCK when all 32 slots are in flight and be
#     woken when one drains, instead of returning -EBUSY.
# We use the kernel WaitQueue primitive from kernel/sched/core.ad — one wait
# queue per slot (woken by ahci_irq_handler when that slot's CI/SACT bit
# clears) plus a global allocator wait queue (woken whenever ANY slot drains).
#
# _ncq_inflight_count is a live counter of slots the driver believes are in
# flight; it lets the peak-tracker update on every submit without rescanning
# 32 bits, and lets the allocator know whether all slots are busy.
_ncq_slot_wq:        Array[32, WaitQueue]
_ncq_alloc_wq:       WaitQueue
_ncq_inflight_count: uint32 = 0
# Per-slot "queued?" tag: 1 if the slot was issued via the FPDMA QUEUED path
# (PxSACT bit also set), 0 if via a legacy non-queued command (READ_DMA_EXT,
# IDENTIFY etc.). The IRQ-completion path uses this to decide which mask
# (PxSACT for queued, PxCI for non-queued) to consult when ack'ing a slot.
_ncq_slot_queued:    Array[32, uint32]
# 1 once _ncq_runtime_init() has called wq_init on every slot's wait queue +
# the allocator queue. The IRQ handler checks this to gate _ncq_irq_complete_port.
_ncq_runtime_ready:  uint32 = 0
# 1 once the FPDMA block-path is wired into ahci_read_sectors / ahci_write_sectors.
# Kept distinct from _ncq_runtime_ready so the early smoke-test (which boots BEFORE
# multitasking has spawned user init / NCQ-capable peer tasks) keeps using the legacy
# serialised slot-0 path; flipping this flag is the trigger that activates real
# NCQ block I/O for ext4 / FAT / whatever runs after the smoke-test gate.
_ncq_block_path_enabled: uint32 = 0
# Diagnostic: monotonic count of slot completions driven from the IRQ
# handler (as opposed to the legacy poll-drain). The block-path selftest
# reads it to prove the IRQ path actually fired.
_ncq_irq_completions: uint64 = 0
# Block-layer registration table. Populated in ahci_smoke_test once
# the port + IDENTIFY have proven healthy, then handed to
# register_blockdev("sd0", ...). priv carries the AHCI port number
# (cast through uint64) so the adapter wrappers can re-validate it
# against ahci.port_num before dispatching to the driver-level
# read/write primitives.
ahci_ops: BlockDeviceOps

# --- Multi-port enumeration table (M16.x) --------------------------
#
# Real AHCI HBAs expose up to 32 implemented ports; the legacy bring-up
# path drove exactly ONE (ahci.port_num / ahci.page / ahci.port_base /
# ahci.capacity, kept working for the single-disk callers). The
# multi-port path brings up EVERY implemented port that has an active
# ATA device and registers each as its own block device — first present
# port -> "sd0", second -> "sd1", and so on.
#
# Per the Adder big-buffer rule, the per-port state is flat module-scope
# arrays indexed by the AHCI port number (0..31), NOT a nested struct
# array. The block-layer `priv` cookie carries the PORT NUMBER, so
# _ahci_*_blkop routes reads/writes to the right port by indexing these
# tables — _ahci_port_base[priv] / _ahci_port_page[priv] /
# _ahci_port_ctpage[priv]. sd0's port also mirrors into the legacy
# AhciState singleton so ahci_active_port()/ahci_active_capacity() and
# the existing slot-0 smoke/NCQ tests keep working unchanged.
#
#   _ahci_port_present[p]   1 if port p was brought up (FIS/CLB running,
#                           IDENTIFY succeeded), 0 otherwise.
#   _ahci_port_base[p]      ABAR + 0x100 + 0x80*p (port register block).
#   _ahci_port_page[p]      4 KiB working page (cmd list + FIS + legacy CT).
#   _ahci_port_ctpage[p]    16 KiB region: 32 per-slot command tables.
#   _ahci_port_capacity[p]  LBA48 sector count from IDENTIFY.
#   _ahci_port_blkslot[p]   block-layer slot index from register_blockdev.
_ahci_port_present:  Array[32, uint32]
_ahci_port_base:     Array[32, uint64]
_ahci_port_page:     Array[32, uint64]
_ahci_port_ctpage:   Array[32, uint64]
_ahci_port_capacity: Array[32, uint64]
_ahci_port_blkslot:  Array[32, int32]

# One BlockDeviceOps vtable per port. register_blockdev stores a Ptr to
# the ops struct, so each registered device needs a stable, distinct
# (or at least live) ops record. A single shared vtable would work
# functionally (the routing is via priv), but giving each port its own
# keeps the registration records self-describing and avoids any aliasing
# surprise if the ops struct is ever mutated per-device.
_ahci_port_ops: Array[32, BlockDeviceOps]

# How many ports the multi-port enumerator brought up + registered.
_ahci_ports_registered: uint32 = 0


def ahci_ports_registered() -> uint32:
    # Number of AHCI ports successfully enumerated + registered as block
    # devices this boot. The multi-port self-test reads it.
    return _ahci_ports_registered


# --- Port stop/start (spec §10.1.2) --------------------------------

def _port_stop(port_base: uint64):
    # Clear ST and FRE; wait for CR and FR to clear. Required before
    # we touch CLB/FB. AHCI doesn't make this fast — the HBA may be
    # mid-command — so we busy-wait up to 1 M iterations.
    cmd: uint32 = _mmio_r32(port_base + PORT_CMD)
    cmd = cmd & ~PORT_CMD_ST
    _mmio_w32(port_base + PORT_CMD, cmd)
    spin: uint64 = 0
    while spin < 1000000:
        if (_mmio_r32(port_base + PORT_CMD) & PORT_CMD_CR) == 0:
            spin = 1000001
        else:
            spin = spin + 1

    cmd = _mmio_r32(port_base + PORT_CMD)
    cmd = cmd & ~PORT_CMD_FRE
    _mmio_w32(port_base + PORT_CMD, cmd)
    spin = 0
    while spin < 1000000:
        if (_mmio_r32(port_base + PORT_CMD) & PORT_CMD_FR) == 0:
            spin = 1000001
        else:
            spin = spin + 1


def _port_start(port_base: uint64):
    # FRE before ST — spec mandates that ordering. After ST the HBA
    # walks the command list whenever CI bits become set.
    cmd: uint32 = _mmio_r32(port_base + PORT_CMD)
    cmd = cmd | PORT_CMD_FRE
    _mmio_w32(port_base + PORT_CMD, cmd)
    cmd = cmd | PORT_CMD_ST
    _mmio_w32(port_base + PORT_CMD, cmd)


# --- Command list / FIS / CT plumbing ------------------------------

def _build_h2d_fis(cfis: uint64, command: uint8, lba: uint64,
                   count: uint16, dev: uint8):
    # H2D Register FIS — 20 bytes (5 DWORDs).
    p: Ptr[uint8] = cast[Ptr[uint8]](cfis)
    # Zero the 64-byte CFIS area first (slot reused across commands).
    memset(p, 0, 64)
    p[0]  = FIS_TYPE_REG_H2D
    p[1]  = 0x80                  # bit 7 = C (command); PMP = 0
    p[2]  = command               # ATA command byte
    p[3]  = 0                     # features (lo)
    p[4]  = cast[uint8]( lba        & 0xFF)
    p[5]  = cast[uint8]((lba >>  8) & 0xFF)
    p[6]  = cast[uint8]((lba >> 16) & 0xFF)
    p[7]  = dev                   # device register (LBA mode if 0x40)
    p[8]  = cast[uint8]((lba >> 24) & 0xFF)
    p[9]  = cast[uint8]((lba >> 32) & 0xFF)
    p[10] = cast[uint8]((lba >> 40) & 0xFF)
    p[11] = 0                     # features (hi)
    p[12] = cast[uint8]( count        & 0xFF)
    p[13] = cast[uint8]((count >> 8) & 0xFF)
    p[14] = 0                     # ICC
    p[15] = 0                     # Control
    # bytes 16..19 left zero.


def _build_cmd_header(clist: uint64, ctba: uint64, cfl_dwords: uint32,
                      write: uint32, prdtl: uint32):
    # Slot 0 of the command list. Header is 32 bytes.
    h: Ptr[uint32] = cast[Ptr[uint32]](clist)
    # DW0: CFL[0..4] | A | W | P | R | B | C | reserved | PMP[12..15]
    #      | PRDTL[16..31]
    dw0: uint32 = (cfl_dwords & 0x1F) | ((write & 1) << 6) \
                  | ((prdtl & 0xFFFF) << 16)
    h[0] = dw0
    h[1] = 0                       # PRDBC (HBA writes this)
    h[2] = cast[uint32](ctba & 0xFFFFFFFF)
    h[3] = cast[uint32](ctba >> 32)
    h[4] = 0
    h[5] = 0
    h[6] = 0
    h[7] = 0


def _build_prdt(ct_base: uint64, dba: uint64, bytecount: uint32):
    # Single PRD entry at CT + 0x80. 16 bytes. dbc encodes (count-1)
    # in bits 0..21; bit 31 is IOC (interrupt on completion — fine
    # to leave 0 since we poll).
    #
    # Higher-half kernel: `dba` is the caller's data buffer, and the
    # AHCI engine DMAs to/from a PHYSICAL address. The block-layer
    # caller may hand us a buffer that is a kernel global (high-half
    # VA) — e.g. the ext4 mkfs scratch block. virt_to_phys() rebases
    # it; an alloc_pages/kmalloc buffer is already low and unchanged.
    dba_phys: uint64 = virt_to_phys(dba)
    p: Ptr[uint32] = cast[Ptr[uint32]](ct_base + CT_PRDT_OFF)
    p[0] = cast[uint32](dba_phys & 0xFFFFFFFF)
    p[1] = cast[uint32](dba_phys >> 32)
    p[2] = 0
    p[3] = (bytecount - 1) & 0x3FFFFF       # bits 0..21


# --- NCQ slot allocator + per-slot plumbing ------------------------
#
# Real Native Command Queuing: instead of hardwiring slot 0, allocate a
# free command-list slot per command. A slot is "free" when its CI bit
# is clear in the hardware Command Issue register, its SACT bit is clear
# (for queued commands), AND our own _ncq_slot_busy bookkeeping says we
# are not already using it. We scan 0..31 and return the first free one,
# or -1 if all 32 are in flight.

def _ncq_ct_base(slot: uint32) -> uint64:
    # Per-slot command-table base inside the dedicated 16 KiB CT region.
    return ahci.ct_page + cast[uint64](slot) * AHCI_CT_STRIDE


def _ncq_clist_slot(slot: uint32) -> uint64:
    # The command-list header for slot s lives at CL_OFFSET + s*32.
    return ahci.page + CL_OFFSET + cast[uint64](slot) * 32


def _ncq_alloc_slot(port_base: uint64) -> int32:
    # Scan for a slot whose hardware CI bit AND SACT bit are clear and
    # that our bookkeeping is not already using. Returns slot index or -1.
    ci:   uint32 = _mmio_r32(port_base + PORT_CI)
    sact: uint32 = _mmio_r32(port_base + PORT_SACT)
    busy_hw: uint32 = ci | sact
    s: uint32 = 0
    while s < AHCI_NCQ_SLOTS:
        bit: uint32 = cast[uint32](1) << s
        if (busy_hw & bit) == 0 and _ncq_slot_busy[s] == 0:
            return cast[int32](s)
        s = s + 1
    return -1


def _ncq_build_cmd_header(slot: uint32, cfl_dwords: uint32,
                          write: uint32, prdtl: uint32):
    # Build the command-list header for an arbitrary slot, pointing it
    # at that slot's own command table. Mirror of _build_cmd_header but
    # slot-indexed (slot 0's header is identical to the legacy path).
    clist: uint64 = _ncq_clist_slot(slot)
    ctba:  uint64 = _ncq_ct_base(slot)
    h: Ptr[uint32] = cast[Ptr[uint32]](clist)
    dw0: uint32 = (cfl_dwords & 0x1F) | ((write & 1) << 6) \
                  | ((prdtl & 0xFFFF) << 16)
    h[0] = dw0
    h[1] = 0
    h[2] = cast[uint32](ctba & 0xFFFFFFFF)
    h[3] = cast[uint32](ctba >> 32)
    h[4] = 0
    h[5] = 0
    h[6] = 0
    h[7] = 0


def _ncq_build_prdt(slot: uint32, dba: uint64, bytecount: uint32):
    # Single PRD entry for the given slot's command table.
    dba_phys: uint64 = virt_to_phys(dba)
    ct_base: uint64 = _ncq_ct_base(slot)
    p: Ptr[uint32] = cast[Ptr[uint32]](ct_base + CT_PRDT_OFF)
    p[0] = cast[uint32](dba_phys & 0xFFFFFFFF)
    p[1] = cast[uint32](dba_phys >> 32)
    p[2] = 0
    p[3] = (bytecount - 1) & 0x3FFFFF


def _ncq_submit_read(port_base: uint64, slot: uint32, buf: uint64,
                     lba: uint64, count: uint16, tag: uint64) -> int32:
    # Build + issue a READ DMA EXT into the given slot WITHOUT waiting for
    # completion. Sets the slot's CI bit so the HBA starts the transfer,
    # records per-slot bookkeeping, and returns immediately so the caller
    # can submit more commands into other slots before draining any.
    _build_h2d_fis(_ncq_ct_base(slot) + CT_CFIS_OFF,
                   ATA_CMD_READ_DMA_EXT, lba, count, 0x40)
    _ncq_build_cmd_header(slot, 5, 0, 1)
    _ncq_build_prdt(slot, buf, cast[uint32](count) * 512)
    _ncq_slot_busy[slot] = 1
    _ncq_slot_tag[slot] = tag
    _ncq_slot_buf[slot] = buf
    _ncq_slot_status[slot] = 1
    _ncq_slots_used_mask = _ncq_slots_used_mask \
                           | (cast[uint32](1) << slot)
    # Set THIS slot's CI bit. CI is write-1-to-set per the spec — writing
    # a single bit does not disturb other in-flight slots' bits.
    _mmio_w32(port_base + PORT_CI, cast[uint32](1) << slot)
    return 0


def _ncq_inflight_mask(port_base: uint64) -> uint32:
    # The set of slots we believe are in flight that the HBA still shows
    # as busy (CI bit set). Used both to measure concurrency and to know
    # when every submitted slot has drained.
    ci: uint32 = _mmio_r32(port_base + PORT_CI)
    s: uint32 = 0
    mask: uint32 = 0
    while s < AHCI_NCQ_SLOTS:
        bit: uint32 = cast[uint32](1) << s
        if _ncq_slot_busy[s] != 0 and (ci & bit) != 0:
            mask = mask | bit
        s = s + 1
    return mask


def _ncq_drain(port_base: uint64, wait_mask: uint32) -> int32:
    # Poll until every slot in wait_mask has cleared its CI bit (or a
    # fatal PxIS error fires). Detects WHICH slots finished by watching
    # CI bits clear and marks each completed slot's status + frees its
    # bookkeeping. Records the PEAK number of slots seen in flight at once
    # so the self-test can prove genuine concurrency. Returns 0 if all
    # drained cleanly, -1 if any slot errored / timed out.
    _ncq_peak_inflight = 0
    spin: uint64 = 0
    rc: int32 = 0
    while spin < 10000000:
        # Fatal-error short-circuit (same policy as _wait_ci_clear).
        is_reg: uint32 = _mmio_r32(port_base + PORT_IS)
        if (is_reg & PORT_IS_ERR_MASK) != 0:
            tfd: uint32 = _mmio_r32(port_base + PORT_TFD)
            serr: uint32 = _mmio_r32(port_base + PORT_SERR)
            printk2("[ahci] ncq error PxIS=%x PxTFD=%x\n",
                    cast[uint64](is_reg), cast[uint64](tfd))
            printk1("[ahci] ncq error PxSERR=%x\n", cast[uint64](serr))
            _mmio_w32(port_base + PORT_IS, is_reg)
            _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
            rc = -1
            spin = 10000000
        else:
            ci: uint32 = _mmio_r32(port_base + PORT_CI)
            still: uint32 = ci & wait_mask
            # Count how many of OUR tracked slots are still in flight.
            nlive: uint32 = 0
            s2: uint32 = 0
            while s2 < AHCI_NCQ_SLOTS:
                if (still & (cast[uint32](1) << s2)) != 0:
                    nlive = nlive + 1
                s2 = s2 + 1
            if nlive > _ncq_peak_inflight:
                _ncq_peak_inflight = nlive
            if still == 0:
                spin = 10000001
            else:
                spin = spin + 1
    # Resolve per-slot status for everything we were asked to wait on.
    tfd_final: uint32 = _mmio_r32(port_base + PORT_TFD)
    s: uint32 = 0
    while s < AHCI_NCQ_SLOTS:
        bit: uint32 = cast[uint32](1) << s
        if (wait_mask & bit) != 0:
            ci2: uint32 = _mmio_r32(port_base + PORT_CI)
            if (ci2 & bit) != 0:
                # Never cleared — error/timeout.
                _ncq_slot_status[s] = -1
                rc = -1
            else:
                if rc == 0 and (tfd_final & PORT_TFD_ERR) == 0:
                    _ncq_slot_status[s] = 0
                else:
                    _ncq_slot_status[s] = -1
            _ncq_slot_busy[s] = 0
        s = s + 1
    if spin == 10000000:
        printk0("[ahci] ncq drain timeout (CI bits stuck)\n")
        return -1
    return rc


def _ncq_peak_get() -> uint32:
    return _ncq_peak_inflight


def _ncq_irq_completions_get() -> uint64:
    # Diagnostic accessor: how many slot completions the IRQ handler has
    # ack'd since boot. The block-path selftest reads this to prove the
    # IRQ-driven completion path actually fired (vs. the legacy poll-drain).
    return _ncq_irq_completions


# --- NCQ FPDMA QUEUED + block-path completion ----------------------
#
# This block of code wires the SYNCHRONOUS block-layer hot path
# (blk_read_sectors / blk_write_sectors -> _ahci_*_blkop ->
# ahci_read_sectors / ahci_write_sectors) through the existing NCQ slot
# allocator using REAL SATA NCQ semantics — READ FPDMA QUEUED (0x60) /
# WRITE FPDMA QUEUED (0x61) issued via the PxSACT / PxCI tag-issue
# protocol — and lets the IRQ handler drive completions so the issuing
# task SLEEPS on a per-slot wait queue instead of busy-polling.
#
# Why this exists:
#   * The legacy block path issued every command into slot 0 (PORT_CI=0x1)
#     and polled _wait_ci_clear. Every blk_read/blk_write therefore
#     serialised through ONE slot — not NCQ.
#   * The NCQ selftest had already proved the slot allocator + multi-slot
#     submit works, but used the non-queued READ_DMA_EXT opcode and a
#     polling drain (no IRQ, no real SATA queuing).
#   * This commit closes the loop: real queued commands, IRQ-driven
#     completion, multi-task contention bounded by a waiter queue.
#
# The FPDMA FIS shape (ATA8 §7.21 / §7.66 / SATA 3.x §13.6.4.2) differs
# from READ_DMA_EXT only in three fields:
#   * features  = transfer count (lo=count[0..7], hi=count[8..15])
#   * sector    = (tag << 3) in the LOW byte; HIGH byte = 0
#   * device    = LBA mode bit 6 = 1; bit 7 = FUA (write only)
#
# Mixing queued and non-queued commands on the same port is illegal per
# spec; the legacy probe/IDENTIFY/TRIM/SMART paths only run at bring-up
# (queue idle) or after error recovery (queue drained), so the live
# constraint holds.

def _build_h2d_fis_ncq(cfis: uint64, command: uint8, lba: uint64,
                       count: uint16, tag: uint32, fua: uint32):
    # FPDMA QUEUED H2D Register FIS (20 bytes / 5 DWORDs). Same byte
    # layout as _build_h2d_fis, with the features register holding the
    # transfer length, the sector-count register holding the tag<<3, and
    # the device register carrying FUA in bit 7.
    p: Ptr[uint8] = cast[Ptr[uint8]](cfis)
    memset(p, 0, 64)
    p[0]  = FIS_TYPE_REG_H2D
    p[1]  = 0x80                  # bit 7 = C (command); PMP = 0
    p[2]  = command               # 0x60 (READ FPDMA Q) or 0x61 (WRITE FPDMA Q)
    p[3]  = cast[uint8]( count        & 0xFF)   # features lo = count lo
    p[4]  = cast[uint8]( lba        & 0xFF)
    p[5]  = cast[uint8]((lba >>  8) & 0xFF)
    p[6]  = cast[uint8]((lba >> 16) & 0xFF)
    dev_byte: uint8 = 0x40                       # LBA mode
    if fua != 0:
        dev_byte = dev_byte | 0x80               # FUA (write-only)
    p[7]  = dev_byte
    p[8]  = cast[uint8]((lba >> 24) & 0xFF)
    p[9]  = cast[uint8]((lba >> 32) & 0xFF)
    p[10] = cast[uint8]((lba >> 40) & 0xFF)
    p[11] = cast[uint8]((count >> 8) & 0xFF)     # features hi = count hi
    p[12] = cast[uint8]((tag & 0x1F) << 3)       # sector-count lo: tag<<3
    p[13] = 0                                    # sector-count hi
    p[14] = 0                                    # ICC
    p[15] = 0                                    # Control


def _ncq_runtime_init():
    # Idempotent first-call init: wq_init every per-slot wait queue and
    # the allocator wait queue. Called from ahci_hardware_probe once the
    # active port is up and IDENTIFY succeeded, so the block path can
    # route through the FPDMA NCQ fast path on the first blk_read.
    if _ncq_runtime_ready != 0:
        return
    s: uint32 = 0
    while s < AHCI_NCQ_SLOTS:
        wq_init(&_ncq_slot_wq[s])
        _ncq_slot_queued[s] = 0
        s = s + 1
    wq_init(&_ncq_alloc_wq)
    _ncq_inflight_count = 0
    _ncq_runtime_ready = 1


def _ncq_submit_fpdma(port_base: uint64, slot: uint32, buf: uint64,
                      lba: uint64, count: uint16, is_write: uint32,
                      tag: uint64) -> int32:
    # Build + issue a FPDMA QUEUED command into the given slot. Sets the
    # slot's SACT bit BEFORE its CI bit (the NCQ tag-issue ordering per
    # AHCI spec §5.5.1 and SATA 3.x §13.6.4.2), records per-slot
    # bookkeeping, bumps the live inflight count + peak tracker, and
    # returns immediately so the caller can sleep on _ncq_slot_wq[slot].
    cmd_byte: uint8 = ATA_CMD_READ_FPDMA_QUEUED
    w_bit: uint32 = 0
    if is_write != 0:
        cmd_byte = ATA_CMD_WRITE_FPDMA_QUEUED
        w_bit = 1
    _build_h2d_fis_ncq(_ncq_ct_base(slot) + CT_CFIS_OFF,
                       cmd_byte, lba, count, slot, 0)
    _ncq_build_cmd_header(slot, 5, w_bit, 1)
    _ncq_build_prdt(slot, buf, cast[uint32](count) * 512)
    _ncq_slot_busy[slot]   = 1
    _ncq_slot_tag[slot]    = tag
    _ncq_slot_buf[slot]    = buf
    _ncq_slot_status[slot] = 1
    _ncq_slot_queued[slot] = 1
    _ncq_slots_used_mask = _ncq_slots_used_mask \
                           | (cast[uint32](1) << slot)
    _ncq_inflight_count = _ncq_inflight_count + 1
    if _ncq_inflight_count > _ncq_peak_inflight:
        _ncq_peak_inflight = _ncq_inflight_count
    # NCQ tag-issue ordering: SACT first, then CI. Both are write-1-to-set
    # at the bit position of the tag (no read-modify-write — single bits
    # leave other in-flight slots' bits unchanged).
    slot_bit: uint32 = cast[uint32](1) << slot
    _mmio_w32(port_base + PORT_SACT, slot_bit)
    _mmio_w32(port_base + PORT_CI,   slot_bit)
    return 0


def _ncq_irq_complete_port(port_base: uint64):
    # IRQ-context completion sweep. Called from ahci_irq_handler whenever
    # PxIS shows DHRS or SDBS (queued or non-queued completion). For every
    # slot our bookkeeping believes is in flight, if the hardware's CI bit
    # AND SACT bit (for queued slots) are now CLEAR, the command finished:
    # mark its status OK, clear busy, decrement inflight, and wake the
    # task sleeping on _ncq_slot_wq[s]. Any completion also kicks the
    # allocator queue in case a task is waiting for ANY slot.
    #
    # Errors: if PxIS shows a fatal cause, mark EVERY in-flight slot
    # status as -1 and wake them so they fail their I/O instead of
    # sleeping forever. The polled error-recovery path takes care of
    # restarting the port; we just unblock the waiters.
    is_reg: uint32 = _mmio_r32(port_base + PORT_IS)
    error_class: uint32 = is_reg & PORT_IS_ERR_MASK
    ci_now:   uint32 = _mmio_r32(port_base + PORT_CI)
    sact_now: uint32 = _mmio_r32(port_base + PORT_SACT)
    any_woke: uint32 = 0
    s: uint32 = 0
    while s < AHCI_NCQ_SLOTS:
        if _ncq_slot_busy[s] != 0:
            bit: uint32 = cast[uint32](1) << s
            queued: uint32 = _ncq_slot_queued[s]
            done: uint32 = 0
            if error_class != 0:
                # Error path: fail everything we tracked. The recovery
                # path will restart the port; the waiter sees rc=-1.
                _ncq_slot_status[s] = -1
                done = 1
            else:
                if queued != 0:
                    # Queued: completion = SACT bit clear AND CI bit clear.
                    if (ci_now & bit) == 0 and (sact_now & bit) == 0:
                        _ncq_slot_status[s] = 0
                        done = 1
                else:
                    # Non-queued (legacy slot): CI bit clear is enough.
                    if (ci_now & bit) == 0:
                        _ncq_slot_status[s] = 0
                        done = 1
            if done != 0:
                _ncq_slot_busy[s]   = 0
                _ncq_slot_queued[s] = 0
                if _ncq_inflight_count > 0:
                    _ncq_inflight_count = _ncq_inflight_count - 1
                _ncq_irq_completions = _ncq_irq_completions + 1
                if _ncq_runtime_ready != 0:
                    wq_wake_one(&_ncq_slot_wq[s])
                any_woke = 1
        s = s + 1
    if any_woke != 0 and _ncq_runtime_ready != 0:
        # A slot freed up — kick any allocator waiter so it can retry.
        wq_wake_all(&_ncq_alloc_wq)


def _ncq_slot_done(slot: uint32) -> int32:
    # Wait-queue predicate: 1 if the slot's I/O has completed (the IRQ
    # handler flipped _ncq_slot_busy to 0), 0 if still in flight.
    if _ncq_slot_busy[slot] == 0:
        return 1
    return 0


def _ncq_block_rw_sync(port_base: uint64, buf: uint64, lba: uint64,
                       count: uint16, is_write: uint32) -> int32:
    # Synchronous NCQ block-path entry. Allocates a slot (sleeping on the
    # allocator wait queue if all 32 are in flight), submits an FPDMA
    # QUEUED command, then sleeps on the slot's wait queue until the IRQ
    # handler completes it. Returns 0 on success, -1 on error / abort.
    #
    # Allocator wait-loop closes the lost-wakeup window using the two-
    # phase prepare/recheck/commit dance (kernel/sched/core.ad): prepare
    # links the current task onto _ncq_alloc_wq, then we RE-check that a
    # slot is still unavailable; if one freed up between the failed alloc
    # and the prepare, we cancel and retry. Otherwise we commit-sleep
    # until the IRQ wakes us.
    slot: int32 = -1
    while True:
        slot = _ncq_alloc_slot(port_base)
        if slot >= 0:
            break
        wq_wait_prepare(&_ncq_alloc_wq)
        slot = _ncq_alloc_slot(port_base)
        if slot >= 0:
            wq_wait_cancel(&_ncq_alloc_wq)
            break
        rc_a: int32 = wq_wait_commit(&_ncq_alloc_wq)
        if rc_a == WQ_EINTR:
            return -1
        # Loop back and retry the alloc.
    su: uint32 = cast[uint32](slot)
    # Submit + sleep with the same prepare/recheck/commit fence so an IRQ
    # completion that fires before we link cannot be lost.
    _ncq_submit_fpdma(port_base, su, buf, lba, count, is_write,
                      cast[uint64](su))
    # Bounded sleep with a poll-fallback re-check. Under working IRQ
    # delivery the SDBS interrupt drives _ncq_irq_complete_port and we
    # return 0 IMMEDIATELY; under TCG (or any host whose AHCI IRQs are
    # flaky / shared / masked) the 100 Hz timer wakes us, we manually
    # sweep the port (same logic the IRQ runs) and re-arm. AHCI_NCQ_RW_TIMEOUT
    # ticks per attempt × NCQ_RW_RETRIES attempts ≈ ~3s total, after which
    # we declare a fatal HBA wedge — matching the polled paths' shape.
    attempt: uint32 = 0
    while attempt < AHCI_NCQ_RW_ATTEMPTS:
        wq_wait_prepare(&_ncq_slot_wq[su])
        if _ncq_slot_done(su) != 0:
            wq_wait_cancel(&_ncq_slot_wq[su])
            attempt = AHCI_NCQ_RW_ATTEMPTS
        else:
            rc_w: int32 = wq_wait_commit_timeout(&_ncq_slot_wq[su],
                                                 AHCI_NCQ_RW_TIMEOUT_TICKS)
            if rc_w == WQ_EINTR:
                # Signal hit us mid-flight. The device is still working on
                # the tag; bounded-poll the bookkeeping to drain it.
                spin: uint64 = 0
                while spin < 10000000:
                    _ncq_irq_complete_port(port_base)
                    if _ncq_slot_busy[su] == 0:
                        spin = 10000001
                    else:
                        spin = spin + 1
                if _ncq_slot_busy[su] != 0:
                    return -1
                attempt = AHCI_NCQ_RW_ATTEMPTS
            elif rc_w == WQ_TIMEOUT:
                # IRQ never woke us. Manually sweep the port (the IRQ
                # logic, sans the IRQ) and try again. If the command is
                # now done this exits via the next loop's prepare/recheck.
                _ncq_irq_complete_port(port_base)
                attempt = attempt + 1
            else:
                attempt = AHCI_NCQ_RW_ATTEMPTS
    if _ncq_slot_busy[su] != 0:
        # Truly wedged after the bounded retries — mark slot failed so a
        # later allocator doesn't reuse a still-in-flight tag.
        printk1("[ahci] NCQ block timeout slot=%d\n", cast[uint64](su))
        _ncq_slot_status[su] = -1
        _ncq_slot_busy[su]   = 0
        _ncq_slot_queued[su] = 0
        if _ncq_inflight_count > 0:
            _ncq_inflight_count = _ncq_inflight_count - 1
        wq_wake_all(&_ncq_alloc_wq)
        return -1
    return _ncq_slot_status[su]


def _ahci_block_path_active(port: int32) -> uint32:
    # True iff the NCQ FPDMA block path is wired AND the requested port is
    # the active singleton (per-port NCQ bookkeeping is single-instance).
    # Other ports stay on the legacy serialised path until the per-port
    # bookkeeping is generalised.
    if _ncq_runtime_ready == 0:
        return 0
    if _ncq_block_path_enabled == 0:
        return 0
    if port != ahci.port_num:
        return 0
    return 1


def ahci_ncq_block_path_enable():
    # Activate the NCQ FPDMA block-layer fast path. Called by init/main.ad
    # AFTER ahci_smoke_test has succeeded (smoke test uses the legacy
    # serialised path so it boots before multitasking is ready to sleep on
    # a wait queue). Once flipped, every subsequent ahci_read_sectors /
    # ahci_write_sectors on the active port routes through
    # _ncq_block_rw_sync — i.e. real SATA NCQ with IRQ-driven completion.
    if _ncq_runtime_ready == 0:
        printk0("[ahci] ncq block-path enable: runtime not ready (probe failed)\n")
        return
    _ncq_block_path_enabled = 1
    printk0("[ahci] NCQ block-path ENABLED (FPDMA QUEUED, IRQ-driven)\n")


def ahci_ncq_block_path_force_enable_for_test():
    # Test-only entry: force-enable the NCQ block path REGARDLESS of the
    # smoke-test gate. ahci_ncq_blkpath_selftest calls it so the block-
    # layer dispatch assertion (find_blockdev("sd0") -> blk_read_sectors
    # -> _ncq_block_rw_sync) actually exercises the new path during the
    # gated boot self-test, instead of being silently bypassed.
    if _ncq_runtime_ready == 0:
        return
    _ncq_block_path_enabled = 1


def _wait_ci_clear(port_base: uint64, slot_mask: uint32) -> int32:
    # Poll the CI register until our slot's bit clears, OR a fatal
    # PxIS error bit fires (TFES / HBFS / IFS / HBDS) — on real
    # hardware, hot-unplug / a wedged drive can latch one of those
    # bits without ever clearing CI, and a 10 M-iteration spin loop
    # would otherwise hang the kernel for several seconds before
    # giving up. We sample PxIS on every poll and short-circuit on
    # error so the upper layer can fail the I/O cleanly.
    spin: uint64 = 0
    while spin < 10000000:
        is_reg: uint32 = _mmio_r32(port_base + PORT_IS)
        if (is_reg & PORT_IS_ERR_MASK) != 0:
            tfd: uint32 = _mmio_r32(port_base + PORT_TFD)
            serr: uint32 = _mmio_r32(port_base + PORT_SERR)
            printk2("[ahci] error PxIS=%x PxTFD=%x\n",
                    cast[uint64](is_reg), cast[uint64](tfd))
            printk1("[ahci] error PxSERR=%x\n", cast[uint64](serr))
            # Ack the error so the next command can be issued cleanly.
            _mmio_w32(port_base + PORT_IS, is_reg)
            _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
            return -1
        ci: uint32 = _mmio_r32(port_base + PORT_CI)
        if (ci & slot_mask) == 0:
            tfd: uint32 = _mmio_r32(port_base + PORT_TFD)
            if (tfd & PORT_TFD_ERR) != 0:
                printk1("[ahci] command failed (tfd=%x)\n",
                        cast[uint64](tfd))
                return -1
            return 0
        spin = spin + 1
    printk0("[ahci] command timeout (CI bit stuck)\n")
    return -1


def _wait_tfd_idle(port_base: uint64) -> int32:
    # Wait for BSY+DRQ to clear before issuing a command. AHCI may
    # have the task file busy from probe/COMRESET; we bail after
    # ~1 M spins to avoid hanging if a port is wedged.
    spin: uint64 = 0
    while spin < 1000000:
        tfd: uint32 = _mmio_r32(port_base + PORT_TFD)
        if (tfd & (PORT_TFD_BSY | PORT_TFD_DRQ)) == 0:
            return 0
        spin = spin + 1
    return -1


# --- COMRESET / port-reset retry (spec §10.4.2) --------------------
#
# A port whose device doesn't come ready on the first probe (PxSSTS DET
# != 3, or the task file is wedged BSY/DRQ) gets a per-port COMRESET:
# write PxSCTL.DET = 1 (initiate interface reset), hold it for a brief
# spin, then write DET = 0 (resume normal operation) and wait for PxSSTS
# DET to settle back to 3 (device present + PHY established). We retry
# the whole sequence a bounded number of times before declaring the port
# empty. This is a PER-PORT interface reset only — we deliberately do NOT
# touch GHC.HR (global HBA reset), which would re-COMRESET every port and
# blow away signatures the firmware already established (see the comment
# in ahci_hardware_probe).

AHCI_COMRESET_RETRIES: uint32 = 3


def _port_comreset(port_base: uint64):
    # One COMRESET pulse on a single port. Per spec §10.4.2 the DET=1
    # state must be held at least 1 ms; with no fine-grained timer in
    # this polled driver we busy-spin a generous fixed count, which on
    # any plausible CPU is well over 1 ms. After de-asserting (DET=0)
    # we clear PxSERR (the reset latches PHYRDY-change / comm-init
    # diagnostic bits).
    sctl: uint32 = _mmio_r32(port_base + PORT_SCTL)
    sctl = (sctl & ~PORT_SCTL_DET_MASK) | PORT_SCTL_DET_COMRESET
    _mmio_w32(port_base + PORT_SCTL, sctl)
    spin: uint64 = 0
    while spin < 2000000:
        spin = spin + 1
    sctl = _mmio_r32(port_base + PORT_SCTL)
    sctl = (sctl & ~PORT_SCTL_DET_MASK) | PORT_SCTL_DET_IDLE
    _mmio_w32(port_base + PORT_SCTL, sctl)
    # Ack any SError the reset raised so a later command sees a clean
    # register.
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)


def _wait_det_present(port_base: uint64) -> int32:
    # Poll PxSSTS until DET == 3 (device present + PHY established) after
    # a COMRESET. Returns 0 once the PHY links, -1 on timeout.
    spin: uint64 = 0
    while spin < 1000000:
        ssts: uint32 = _mmio_r32(port_base + PORT_SSTS)
        det: uint32 = ssts & 0xF
        if det == PORT_SSTS_DET_PRESENT_PHY:
            return 0
        spin = spin + 1
    return -1


def _port_wait_ready_with_comreset(port_base: uint64) -> int32:
    # Bring a port's device to a ready state, COMRESET-retrying on
    # failure. "Ready" means PxSSTS DET == 3 AND the task file is idle
    # (BSY+DRQ clear). On the first attempt we just check; if either
    # condition is unmet we issue a COMRESET and re-check, up to
    # AHCI_COMRESET_RETRIES total reset attempts. Returns 0 when ready,
    # -1 if the port never becomes ready (caller treats it as empty).
    attempt: uint32 = 0
    while attempt <= AHCI_COMRESET_RETRIES:
        ssts: uint32 = _mmio_r32(port_base + PORT_SSTS)
        det: uint32 = ssts & 0xF
        if det == PORT_SSTS_DET_PRESENT_PHY:
            if _wait_tfd_idle(port_base) == 0:
                return 0
        # Not ready: out of retries?
        if attempt == AHCI_COMRESET_RETRIES:
            return -1
        printk1("[ahci] port-reset: COMRESET attempt %d\n",
                cast[uint64](attempt + 1))
        _port_comreset(port_base)
        _wait_det_present(port_base)
        attempt = attempt + 1
    return -1


# --- Port interrupt-enable wiring (spec §3.3.6) --------------------
#
# Real AHCI drivers populate PxIE so the HBA latches error + hot-plug
# causes and asserts the port-level interrupt. We enable the fatal-error
# causes (TFE/HBF/HBD/IF), the D2H Register FIS completion, and crucially
# the two hot-plug edges (PRCE/PCE). Even though command completion is
# polled here, enabling PRCE/PCE is what makes PxIS.PRCS / PxIS.PCS fire
# on a live attach/detach so ahci_hotplug_poll() can observe them.

def _port_enable_interrupts(port_base: uint64):
    # Clear stale PxIS first (write-1-to-clear) so we don't immediately
    # latch a spurious hot-plug edge from the bring-up COMRESET, then
    # plant the enable mask.
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_IE, PORT_IE_DEFAULT)


# --- NCQ error log (READ LOG EXT page 10h, ATA8 §7.22) -------------
#
# After an NCQ task-file error the device stops accepting queued commands
# until the host reads log page 10h, which reports the tag of the command
# that caused the error. We issue READ LOG EXT (0x2F) for log 0x10 via the
# legacy slot-0 path (the queue is frozen, so a non-queued command is the
# correct way to interrogate it) and return the failing tag (0..31), or
# -1 if the log read itself failed.

def _ncq_read_error_log(port_base: uint64, clist: uint64,
                        ct_base: uint64) -> int32:
    log_buf: uint64 = kmalloc(512)
    if log_buf == 0:
        return -1
    memset(cast[Ptr[uint8]](log_buf), 0, 512)
    # READ LOG EXT: count = 1 (one 512-byte page), LBA low = log address
    # (0x10), LBA mid = page number (0). dev = 0x40 (LBA mode).
    _build_h2d_fis(ct_base + CT_CFIS_OFF, ATA_CMD_READ_LOG_EXT,
                   cast[uint64](ATA_LOG_NCQ_ERROR), 1, 0x40)
    _build_cmd_header(clist, ct_base, 5, 0, 1)
    _build_prdt(ct_base, log_buf, 512)
    if _wait_tfd_idle(port_base) != 0:
        return -1
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_CI, 0x1)
    if _wait_ci_clear(port_base, 0x1) != 0:
        return -1
    # Byte 0 of the NCQ error log: bit 7 = NQ (error was on a queued
    # command), bits 4..0 = the failing tag.
    b0: uint8 = cast[Ptr[uint8]](log_buf)[0]
    failing_tag: int32 = cast[int32](cast[uint32](b0) & 0x1F)
    printk2("[ahci] NCQ error log: NQ=%d failing-tag=%d\n",
            cast[uint64]((cast[uint32](b0) >> 7) & 1),
            cast[uint64](failing_tag))
    return failing_tag


# --- Port error recovery (spec §6.2.2 + §10.7.1) -------------------
#
# The canonical AHCI recovery dance when a command errors (PxIS error bit
# set / PxTFD BSY|DRQ|ERR latched) or a command times out:
#
#   1. STOP the port: clear PxCMD.ST, wait for PxCMD.CR to clear.
#   2. CLEAR the error registers: write-1-to-clear PxSERR and PxIS.
#   3. If the link itself dropped (PxSSTS.DET != 3), issue a COMRESET via
#      PxSCTL.DET=1 -> hold -> DET=0, then wait for PxSSTS.DET == 3.
#   4. Wait for the task file to leave BSY/DRQ.
#   5. RESTART the port: set PxCMD.FRE then PxCMD.ST, re-enable PxIE.
#
# After this the port is usable again; the caller re-issues the
# outstanding command(s). For NCQ errors the caller first reads the error
# log (above) to learn which tag failed, then re-queues the rest. Returns
# 0 if the port came back ready, -1 if the device never re-established.

def _port_error_recover(port_base: uint64) -> int32:
    printk1("[ahci] error-recovery begin PxTFD=%x\n",
            cast[uint64](_mmio_r32(port_base + PORT_TFD)))
    # 1. STOP the port (ST clear + wait CR clear; FRE clear + wait FR).
    _port_stop(port_base)
    # 2. CLEAR error registers (write-1-to-clear).
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_IS,   0xFFFFFFFF)
    # 3. Re-establish the link if the PHY dropped. If the device is still
    #    present (DET==3) a COMRESET is unnecessary and risks bouncing a
    #    healthy link; only COMRESET when the link is NOT established.
    ssts: uint32 = _mmio_r32(port_base + PORT_SSTS)
    det: uint32 = ssts & 0xF
    if det != PORT_SSTS_DET_PRESENT_PHY:
        printk1("[ahci] error-recovery: link down (DET=%d), COMRESET\n",
                cast[uint64](det))
        if _port_wait_ready_with_comreset(port_base) != 0:
            printk0("[ahci] error-recovery: device gone after COMRESET\n")
            return -1
    # 4. Re-enable FIS receive (FRE) BEFORE waiting for the task file to
    #    settle. After a COMRESET (or any port stop, which cleared FRE)
    #    the device sends a Device-to-Host Register FIS that carries the
    #    initial task-file state and CLEARS BSY; the HBA can only post
    #    that FIS into our receive area once FRE is set. Without FRE the
    #    task file stays BSY forever and recovery wrongly declares the
    #    device gone. This is the FRE-before-ST ordering the spec mandates.
    cmd: uint32 = _mmio_r32(port_base + PORT_CMD)
    cmd = cmd | PORT_CMD_FRE
    _mmio_w32(port_base + PORT_CMD, cmd)
    # 5. Wait for the task file to settle (BSY/DRQ clear). On a pure
    #    task-file error with the link intact this is the key recovery
    #    step — the device clears BSY once the errored command is purged.
    if _wait_tfd_idle(port_base) != 0:
        # Task file still wedged with the link up: escalate to a COMRESET,
        # then re-enable FRE and re-check (the COMRESET cleared FRE again).
        printk0("[ahci] error-recovery: TFD wedged, escalating to COMRESET\n")
        if _port_wait_ready_with_comreset(port_base) != 0:
            printk0("[ahci] error-recovery: device gone after escalation\n")
            return -1
        cmd = _mmio_r32(port_base + PORT_CMD)
        cmd = cmd | PORT_CMD_FRE
        _mmio_w32(port_base + PORT_CMD, cmd)
        if _wait_tfd_idle(port_base) != 0:
            printk0("[ahci] error-recovery: TFD still wedged after escalation\n")
            return -1
    # 6. RESTART the port (set ST; FRE already set) + re-arm interrupts.
    #    Clear residual error state one more time so the restarted engine
    #    sees a clean port.
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_IS,   0xFFFFFFFF)
    _port_start(port_base)
    _port_enable_interrupts(port_base)
    printk0("[ahci] error-recovery: port restarted\n")
    return 0


# --- Hot-plug detection (spec §6.2.1) ------------------------------
#
# Poll a single port for a connect/disconnect edge. The HBA latches a
# hot-plug edge in PxIS.PRCS (PhyRdy change) / PxIS.PCS (port connect
# change), which mirror PxSERR.DIAG.N / DIAG.X. We sample those bits and
# the live PxSSTS.DET to decide whether a device is now PRESENT or GONE,
# acknowledge the latched edge (write-1-to-clear PxIS + PxSERR), and
# report the resulting transition. Return codes:
#   0  no change since last poll (no edge latched and state unchanged)
#   1  device ARRIVED (DET transitioned to 3) — caller (re)IDENTIFYs
#   2  device LEFT (DET dropped from 3) — caller marks blockdev gone
#  -1  edge latched but DET in an indeterminate state

def _port_hotplug_poll(port_base: uint64, was_present: uint32) -> int32:
    pxis: uint32 = _mmio_r32(port_base + PORT_IS)
    serr: uint32 = _mmio_r32(port_base + PORT_SERR)
    edge: uint32 = (pxis & PORT_IS_HOTPLUG_MASK) \
                 | (serr & (PORT_SERR_DIAG_N | PORT_SERR_DIAG_X))
    ssts: uint32 = _mmio_r32(port_base + PORT_SSTS)
    det: uint32 = ssts & 0xF
    now_present: uint32 = 0
    if det == PORT_SSTS_DET_PRESENT_PHY:
        now_present = 1
    # Acknowledge any latched hot-plug edge so the next poll is fresh.
    if edge != 0:
        _mmio_w32(port_base + PORT_IS,
                  pxis & PORT_IS_HOTPLUG_MASK)
        _mmio_w32(port_base + PORT_SERR,
                  PORT_SERR_DIAG_N | PORT_SERR_DIAG_X)
        printk2("[ahci] hotplug edge PxIS=%x DET=%d\n",
                cast[uint64](pxis), cast[uint64](det))
    if now_present == was_present:
        if edge == 0:
            return 0
        # Edge latched but state unchanged (e.g. a debounce bounce that
        # settled back). No registration change needed.
        return 0
    if now_present == 1 and was_present == 0:
        return 1
    if now_present == 0 and was_present == 1:
        return 2
    return -1


# --- IDENTIFY DEVICE ----------------------------------------------

def _byteswap_model(raw: Ptr[uint8], out: Ptr[uint8]):
    # ATA IDENTIFY returns the model string at words 27..46 (40
    # bytes total) — but each word is byte-swapped because ATA
    # stores strings in big-endian-within-word order. Swap each
    # pair before copying so the printk renders readable ASCII.
    # We then truncate trailing spaces (the spec pads model with
    # 0x20).
    i: uint64 = 0
    while i < 40:
        out[i] = raw[i ^ 1]
        i = i + 1
    out[40] = 0
    # Strip trailing spaces.
    j: int32 = 39
    while j >= 0:
        if out[j] != 0x20:
            j = -1
        else:
            out[j] = 0
            j = j - 1


def _do_identify(port_base: uint64, clist: uint64, ct_base: uint64,
                 buf: uint64) -> int32:
    # Build CFIS for IDENTIFY DEVICE: no LBA, count=0, dev=0.
    _build_h2d_fis(ct_base + CT_CFIS_OFF, ATA_CMD_IDENTIFY,
                   0, 0, 0)
    # Header: CFL = 5 DWORDs, write=0 (device → host), PRDTL = 1.
    _build_cmd_header(clist, ct_base, 5, 0, 1)
    # PRDT: 512 bytes into `buf`.
    _build_prdt(ct_base, buf, 512)

    if _wait_tfd_idle(port_base) != 0:
        printk0("[ahci] port busy before IDENTIFY\n")
        return -1
    # Clear stale IS and SERR before issuing.
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    # Issue slot 0.
    _mmio_w32(port_base + PORT_CI, 0x1)
    return _wait_ci_clear(port_base, 0x1)


# --- READ DMA EXT --------------------------------------------------

def _do_read_lba(port_base: uint64, clist: uint64, ct_base: uint64,
                 buf: uint64, lba: uint64, count: uint16) -> int32:
    # READ DMA EXT (LBA48). Device register bit 6 = LBA mode.
    _build_h2d_fis(ct_base + CT_CFIS_OFF, ATA_CMD_READ_DMA_EXT,
                   lba, count, 0x40)
    _build_cmd_header(clist, ct_base, 5, 0,
                      1)        # CFL=5, write=0, PRDTL=1
    _build_prdt(ct_base, buf, cast[uint32](count) * 512)

    if _wait_tfd_idle(port_base) != 0:
        printk0("[ahci] port busy before READ_DMA_EXT\n")
        return -1
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_CI, 0x1)
    return _wait_ci_clear(port_base, 0x1)


# --- WRITE DMA EXT -------------------------------------------------
#
# M16.118: complementary path to _do_read_lba above. The command-list
# / command-table / PRDT machinery is identical; only the ATA command
# byte changes (0x35 vs 0x25) and the W bit in the command header's
# DW0 (bit 6) flips to 1, telling the HBA the data direction is
# host-to-device. PRDT still points at the caller's buffer — but now
# the HBA *reads* it instead of writing it. Polled completion via the
# CI bit, same as READ.

def _do_write_lba(port_base: uint64, clist: uint64, ct_base: uint64,
                  buf: uint64, lba: uint64, count: uint16) -> int32:
    _build_h2d_fis(ct_base + CT_CFIS_OFF, ATA_CMD_WRITE_DMA_EXT,
                   lba, count, 0x40)
    # CFL=5, write=1 (W bit set in DW0), PRDTL=1.
    _build_cmd_header(clist, ct_base, 5, 1, 1)
    _build_prdt(ct_base, buf, cast[uint32](count) * 512)

    if _wait_tfd_idle(port_base) != 0:
        printk0("[ahci] port busy before WRITE_DMA_EXT\n")
        return -1
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_CI, 0x1)
    return _wait_ci_clear(port_base, 0x1)


# --- Feature-aware command FIS + abort-aware completion ------------
#
# The legacy _build_h2d_fis hardwires the Features registers (FIS bytes
# 3 and 11) to 0 and the LBA mid/hi registers from the LBA argument.
# DATA SET MANAGEMENT (TRIM) and SMART need a non-zero Features byte,
# and SMART additionally needs an explicit LBA-mid / LBA-hi signature
# (0x4F / 0xC2) rather than an address. This builder exposes those
# fields. Mirror of _build_h2d_fis's byte layout (H2D Register FIS,
# 20 bytes / 5 DWORDs) so the HBA sees exactly the same shape.

def _build_h2d_fis_feat(cfis: uint64, command: uint8, feature: uint8,
                        lba: uint64, count: uint16, dev: uint8):
    p: Ptr[uint8] = cast[Ptr[uint8]](cfis)
    memset(p, 0, 64)
    p[0]  = FIS_TYPE_REG_H2D
    p[1]  = 0x80                  # bit 7 = C (command); PMP = 0
    p[2]  = command               # ATA command byte
    p[3]  = feature               # features (lo) — TRIM bit / SMART subcmd
    p[4]  = cast[uint8]( lba        & 0xFF)
    p[5]  = cast[uint8]((lba >>  8) & 0xFF)
    p[6]  = cast[uint8]((lba >> 16) & 0xFF)
    p[7]  = dev                   # device register (LBA mode if 0x40)
    p[8]  = cast[uint8]((lba >> 24) & 0xFF)
    p[9]  = cast[uint8]((lba >> 32) & 0xFF)
    p[10] = cast[uint8]((lba >> 40) & 0xFF)
    p[11] = 0                     # features (hi)
    p[12] = cast[uint8]( count        & 0xFF)
    p[13] = cast[uint8]((count >> 8) & 0xFF)
    p[14] = 0                     # ICC
    p[15] = 0                     # Control


# Completion wait that DISTINGUISHES a clean success, a graceful device
# "command aborted" (TFD.ERR / ABRT set but no fatal HBA bus error), and
# a genuine fatal/timeout error. Returns:
#    0  — command completed OK (CI cleared, no error bits)
#    1  — command was ABORTED by the device (TFD.ERR set, or a PxIS task-
#         file-error with no host-bus-fatal bit) — e.g. QEMU rejecting
#         SMART/TRIM. The caller treats this as a CORRECTLY-DETECTED abort
#         rather than a driver failure.
#   -1  — fatal HBA bus error or CI-bit timeout (the port is wedged).
#
# This is the abort-tolerant sibling of _wait_ci_clear; the legacy path
# folds abort into -1 because READ/WRITE never expect an abort, whereas
# TRIM/SMART legitimately may be unsupported by the host model.
def _wait_ci_clear_abortable(port_base: uint64,
                             slot_mask: uint32) -> int32:
    spin: uint64 = 0
    while spin < 10000000:
        is_reg: uint32 = _mmio_r32(port_base + PORT_IS)
        if (is_reg & PORT_IS_ERR_MASK) != 0:
            tfd: uint32 = _mmio_r32(port_base + PORT_TFD)
            serr: uint32 = _mmio_r32(port_base + PORT_SERR)
            # Ack so the next command issues cleanly regardless of class.
            _mmio_w32(port_base + PORT_IS, is_reg)
            _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
            # A bare Task-File-Error (TFES) with the error bit set in the
            # task file, and NO host-bus-fatal / interface-fatal bit, is a
            # device-level ABORT — the command reached the drive and was
            # refused. Anything with a bus-fatal bit is unrecoverable.
            fatal: uint32 = is_reg & (PORT_IS_HBFS | PORT_IS_HBDS \
                                      | PORT_IS_IFS)
            if fatal == 0 and (tfd & PORT_TFD_ERR) != 0:
                printk1("[ahci] command aborted by device (tfd=%x)\n",
                        cast[uint64](tfd))
                return 1
            printk2("[ahci] fatal error PxIS=%x PxTFD=%x\n",
                    cast[uint64](is_reg), cast[uint64](tfd))
            printk1("[ahci] fatal error PxSERR=%x\n", cast[uint64](serr))
            return -1
        ci: uint32 = _mmio_r32(port_base + PORT_CI)
        if (ci & slot_mask) == 0:
            tfd: uint32 = _mmio_r32(port_base + PORT_TFD)
            if (tfd & PORT_TFD_ERR) != 0:
                printk1("[ahci] command aborted (tfd=%x)\n",
                        cast[uint64](tfd))
                return 1
            return 0
        spin = spin + 1
    printk0("[ahci] command timeout (CI bit stuck)\n")
    return -1


# --- DATA SET MANAGEMENT — TRIM (ATA8 §7.10) -----------------------
#
# Build the LBA-range-entry payload in `buf` and issue DSM/TRIM as a
# single-block DMA write. Each LBA-range entry is 8 bytes:
#   bytes 0..5  — 48-bit starting LBA (little-endian)
#   bytes 6..7  — 16-bit range length, in sectors (0 = "no range")
# A 512-byte block holds up to 64 entries; we emit ONE entry covering
# [start_lba, start_lba+count) and zero the rest of the block. Returns:
#    0  — TRIM completed OK
#    1  — device aborted TRIM (correctly detected; e.g. unsupported)
#   -1  — fatal HBA error / not initialised.
def _do_trim(port_base: uint64, clist: uint64, ct_base: uint64,
             buf: uint64, start_lba: uint64, count: uint16) -> int32:
    # Build the range payload: one 8-byte entry, rest zeroed.
    pb: Ptr[uint8] = cast[Ptr[uint8]](buf)
    memset(pb, 0, 512)
    pb[0] = cast[uint8]( start_lba        & 0xFF)
    pb[1] = cast[uint8]((start_lba >>  8) & 0xFF)
    pb[2] = cast[uint8]((start_lba >> 16) & 0xFF)
    pb[3] = cast[uint8]((start_lba >> 24) & 0xFF)
    pb[4] = cast[uint8]((start_lba >> 32) & 0xFF)
    pb[5] = cast[uint8]((start_lba >> 40) & 0xFF)
    pb[6] = cast[uint8]( count        & 0xFF)
    pb[7] = cast[uint8]((count >> 8) & 0xFF)

    # CFIS: DSM command, TRIM feature, count = 1 block of range data.
    # LBA field is unused for DSM (the ranges live in the data block), so
    # pass 0. dev = 0x40 (LBA mode). W bit set (host -> device).
    _build_h2d_fis_feat(ct_base + CT_CFIS_OFF, ATA_CMD_DSM,
                        ATA_DSM_FEATURE_TRIM, 0, 1, 0x40)
    _build_cmd_header(clist, ct_base, 5, 1, 1)
    _build_prdt(ct_base, buf, 512)

    if _wait_tfd_idle(port_base) != 0:
        printk0("[ahci] port busy before DSM/TRIM\n")
        return -1
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_CI, 0x1)
    return _wait_ci_clear_abortable(port_base, 0x1)


# --- SMART READ DATA (ATA8 §7.52, subcommand 0xD0) -----------------
#
# Read the 512-byte SMART device-health block into `buf`. The Features
# register selects the subcommand (0xD0 = READ DATA); LBA mid/hi MUST
# carry the SMART signature 0x4F / 0xC2 or the device aborts. count = 0.
# This is a DMA read (device -> host). Returns the same 0 / 1 / -1
# tri-state as _do_trim so the caller can report a graceful abort
# (QEMU's ich9-ahci does not implement SMART) distinctly from a wedge.
def _do_smart_read(port_base: uint64, clist: uint64, ct_base: uint64,
                   buf: uint64) -> int32:
    # LBA encodes the SMART signature: LBA mid (byte 5) = 0x4F,
    # LBA hi (byte 6) = 0xC2. _build_h2d_fis_feat lays the LBA bytes out
    # as p[4]=lba&0xFF, p[5]=(lba>>8)&0xFF, p[6]=(lba>>16)&0xFF, so pack
    # the signature into bits 8..23 of the lba argument.
    sig_lba: uint64 = (cast[uint64](ATA_SMART_LBA_MID_SIG) << 8) \
                      | (cast[uint64](ATA_SMART_LBA_HI_SIG) << 16)
    _build_h2d_fis_feat(ct_base + CT_CFIS_OFF, ATA_CMD_SMART,
                        ATA_SMART_READ_DATA, sig_lba, 0, 0x40)
    _build_cmd_header(clist, ct_base, 5, 0, 1)
    _build_prdt(ct_base, buf, 512)

    if _wait_tfd_idle(port_base) != 0:
        printk0("[ahci] port busy before SMART READ DATA\n")
        return -1
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_CI, 0x1)
    return _wait_ci_clear_abortable(port_base, 0x1)


# --- Public write_sectors entry ------------------------------------
#
# Drives the per-port command-list / command-table that ahci_smoke_test
# set up. Takes the same shape virtio-blk's write_sectors does so
# higher layers can dispatch through a uniform BlockDeviceOps vtable
# once registration lands. NOTE: this commit ships the driver-level
# primitive only; AHCI is not yet registered with `kernel/block/blk.ad`
# (the BlockDeviceOps vtable already exposes a write_sectors slot,
# but wiring AHCI's per-port priv + register_blockdev() is a follow-up
# to avoid colliding with parallel CPython brk/mmap work in u_syscalls).
#
# `port` is the slot index from `ahci.port_num` (we only drive one
# port today). `count` is in 512-byte sectors. Returns 0 on success,
# -1 on any failure (HBA wedged, command error, no port set up).

def _ahci_port_resolve(port: int32) -> uint64:
    # Resolve a port number to the working page VA the read/write
    # primitives carve their command list + command table out of.
    # Multi-port path: index the per-port table. Legacy single-port
    # path: fall back to the singleton AhciState. Returns 0 if the port
    # is neither present in the table nor the legacy active port.
    if port < 0 or cast[uint64](port) >= 32:
        return 0
    if _ahci_port_present[cast[uint64](port)] != 0:
        return _ahci_port_page[cast[uint64](port)]
    if port == ahci.port_num:
        return ahci.page
    return 0


def _ahci_port_base_of(port: int32) -> uint64:
    # Companion to _ahci_port_resolve: the MMIO port register block.
    if port < 0 or cast[uint64](port) >= 32:
        return 0
    if _ahci_port_present[cast[uint64](port)] != 0:
        return _ahci_port_base[cast[uint64](port)]
    if port == ahci.port_num:
        return ahci.port_base
    return 0


def ahci_write_sectors(port: int32, lba: uint64, count: uint16,
                       buf: uint64) -> int32:
    if ahci.abar == 0:
        printk0("[ahci] write_sectors: driver not initialised\n")
        return -1
    page: uint64 = _ahci_port_resolve(port)
    port_base: uint64 = _ahci_port_base_of(port)
    if page == 0 or port_base == 0:
        printk1("[ahci] write_sectors: bad port=%d\n", cast[uint64](port))
        return -1
    if count == 0:
        return 0
    # NCQ block-path: route real I/O through the FPDMA QUEUED + waitq
    # plumbing on the active port. Other ports fall through to legacy.
    if _ahci_block_path_active(port) != 0:
        return _ncq_block_rw_sync(port_base, buf, lba, count, 1)
    clist:   uint64 = page + CL_OFFSET
    ct_base: uint64 = page + CT_OFFSET
    return _do_write_lba(port_base, clist, ct_base, buf, lba, count)


def ahci_read_sectors(port: int32, lba: uint64, count: uint16,
                      buf: uint64) -> int32:
    # Counterpart to ahci_write_sectors, exposed for the write-then-
    # read-back smoke test below. The smoke test in ahci_smoke_test
    # uses _do_read_lba directly; this wrapper lets callers outside
    # that function do the same without poking at private state.
    if ahci.abar == 0:
        printk0("[ahci] read_sectors: driver not initialised\n")
        return -1
    page: uint64 = _ahci_port_resolve(port)
    port_base: uint64 = _ahci_port_base_of(port)
    if page == 0 or port_base == 0:
        return -1
    if count == 0:
        return 0
    # NCQ block-path: route real I/O through the FPDMA QUEUED + waitq
    # plumbing on the active port. The legacy serialised path stays as a
    # fallback when the NCQ runtime isn't ready (e.g. early boot before
    # IDENTIFY) or for non-singleton ports.
    if _ahci_block_path_active(port) != 0:
        rcq: int32 = _ncq_block_rw_sync(port_base, buf, lba, count, 0)
        if rcq == 0:
            return 0
        printk0("[ahci] read_sectors(NCQ): error -> recovery + legacy retry\n")
        if _port_error_recover(port_base) != 0:
            return -1
        # Fall through to a legacy-path retry — the recovery path drained
        # the queue, so a non-queued retry is safe.
    clist:   uint64 = page + CL_OFFSET
    ct_base: uint64 = page + CT_OFFSET
    rc: int32 = _do_read_lba(port_base, clist, ct_base, buf, lba, count)
    if rc == 0:
        return 0
    # Command failed / timed out: drive the standard error-recovery
    # (stop/clear/COMRESET/restart) and retry the read ONCE. This bounds
    # how long a command can wedge the port — instead of leaving the port
    # stuck, we recover it and re-issue. A second failure is reported.
    printk0("[ahci] read_sectors: command error -> error-recovery + retry\n")
    if _port_error_recover(port_base) != 0:
        return -1
    return _do_read_lba(port_base, clist, ct_base, buf, lba, count)


# --- TRIM / IDENTIFY / SMART public entries ------------------------
#
# Module-scope DMA scratch (Adder's big-buffer rule: 512-byte frame-local
# arrays miscompile, so these live at module scope). They are reused
# serially through slot 0 like every other legacy command path, so a
# single buffer per purpose is safe.
#   _ahci_trim_buf  — the 512-byte DSM/TRIM LBA-range-entry payload.
#   _ahci_id_buf    — the 512-byte IDENTIFY DEVICE result block.
#   _ahci_smart_buf — the 512-byte SMART READ DATA result block.
_ahci_trim_buf:  Array[512, uint8]
_ahci_id_buf:    Array[512, uint8]
_ahci_smart_buf: Array[512, uint8]

# Last IDENTIFY decode, cached for the info line / accessors.
_ahci_id_capacity: uint64 = 0
_ahci_id_rotation: uint16 = 0


def _ahci_id_word(buf: uint64, word: uint64) -> uint16:
    # Read 16-bit IDENTIFY word `word` (little-endian) from a 512-byte
    # block. Word index 0..255 maps to byte offset word*2.
    p: Ptr[uint8] = cast[Ptr[uint8]](buf + word * 2)
    return cast[uint16](p[0]) | (cast[uint16](p[1]) << 8)


def ahci_trim(port: int32, start_lba: uint64, count: uint16) -> int32:
    # Public DATA SET MANAGEMENT / TRIM entry. Deallocates the sector
    # range [start_lba, start_lba+count) on the SATA device behind `port`.
    # Returns 0 on success, 1 if the device gracefully ABORTED the command
    # (correctly detected — e.g. the host model doesn't implement TRIM),
    # -1 on a fatal HBA error or an uninitialised driver.
    if ahci.abar == 0:
        printk0("[ahci] trim: driver not initialised\n")
        return -1
    page: uint64 = _ahci_port_resolve(port)
    port_base: uint64 = _ahci_port_base_of(port)
    if page == 0 or port_base == 0:
        printk1("[ahci] trim: bad port=%d\n", cast[uint64](port))
        return -1
    if count == 0:
        return 0
    clist:   uint64 = page + CL_OFFSET
    ct_base: uint64 = page + CT_OFFSET
    buf: uint64 = cast[uint64](&_ahci_trim_buf[0])
    return _do_trim(port_base, clist, ct_base, buf, start_lba, count)


def ahci_identify(port: int32) -> uint64:
    # Public IDENTIFY DEVICE entry. Issues IDENTIFY (0xEC), decodes the
    # 48-bit LBA capacity (words 100..103) and the nominal media rotation
    # rate (word 217 — 1 means SSD), caches both, prints a one-line
    # model/health summary, and ALSO probes SMART READ DATA (best-effort;
    # QEMU's ich9-ahci aborts it, which we report rather than fail on).
    # Returns the capacity in 512-byte sectors, or 0 on failure.
    if ahci.abar == 0:
        printk0("[ahci] identify: driver not initialised\n")
        return 0
    page: uint64 = _ahci_port_resolve(port)
    port_base: uint64 = _ahci_port_base_of(port)
    if page == 0 or port_base == 0:
        printk1("[ahci] identify: bad port=%d\n", cast[uint64](port))
        return 0
    clist:   uint64 = page + CL_OFFSET
    ct_base: uint64 = page + CT_OFFSET
    idbuf: uint64 = cast[uint64](&_ahci_id_buf[0])
    memset(cast[Ptr[uint8]](idbuf), 0, 512)
    if _do_identify(port_base, clist, ct_base, idbuf) != 0:
        printk0("[ahci] identify: IDENTIFY DEVICE failed\n")
        return 0

    # 48-bit capacity from words 100..103 (little-endian quad of words).
    w0: uint64 = cast[uint64](_ahci_id_word(idbuf, ATA_ID_WORD_LBA48_LO))
    w1: uint64 = cast[uint64](_ahci_id_word(idbuf, ATA_ID_WORD_LBA48_LO + 1))
    w2: uint64 = cast[uint64](_ahci_id_word(idbuf, ATA_ID_WORD_LBA48_LO + 2))
    w3: uint64 = cast[uint64](_ahci_id_word(idbuf, ATA_ID_WORD_LBA48_LO + 3))
    cap: uint64 = w0 | (w1 << 16) | (w2 << 32) | (w3 << 48)
    rot: uint16 = _ahci_id_word(idbuf, ATA_ID_WORD_ROTATION)
    _ahci_id_capacity = cap
    _ahci_id_rotation = rot

    # Decode the model string (words 27..46) for the info line. Reuse the
    # AhciState.model field (module-scope-backed) rather than a frame-local
    # Array, per the Adder big-buffer quirk.
    _byteswap_model(cast[Ptr[uint8]](idbuf + 27 * 2), &ahci.model[0])

    printk1("[ahci-ident] model=%s\n", cast[uint64](&ahci.model[0]))
    printk1("[ahci-ident] LBA48 sector count=%d\n", cap)
    if rot == ATA_ID_ROTATION_SSD:
        printk0("[ahci-ident] media=SSD (rotation rate=1, non-rotating)\n")
    elif rot == 0 or rot == 0xFFFF:
        printk0("[ahci-ident] media=unknown (rotation rate not reported)\n")
    else:
        printk1("[ahci-ident] media=HDD (rotation rate=%d RPM)\n",
                cast[uint64](rot))

    # SMART READ DATA — best-effort health probe. QEMU's ich9-ahci does
    # not implement SMART, so a graceful device ABORT (rc==1) is the
    # expected and CORRECT outcome there; we surface it as a health line
    # rather than an error.
    smbuf: uint64 = cast[uint64](&_ahci_smart_buf[0])
    memset(cast[Ptr[uint8]](smbuf), 0, 512)
    smrc: int32 = _do_smart_read(port_base, clist, ct_base, smbuf)
    if smrc == 0:
        # SMART supported: byte 0..1 of the data block carry the structure
        # revision; we don't decode individual attributes here but report
        # the block was read so the health surface is live.
        printk0("[ahci-ident] SMART READ DATA OK (health block retrieved)\n")
    elif smrc == 1:
        printk0("[ahci-ident] SMART not supported by host (command aborted, correctly detected)\n")
    else:
        printk0("[ahci-ident] SMART READ DATA fatal error\n")

    return cap


# --- BlockDeviceOps adapter wrappers (M16.119) --------------------
#
# kernel/block/blk.ad invokes vtable slots with signature
#   int32 (*op)(uint64 priv, uint64 lba, uint64 count, Ptr[uint8] buf)
# Our driver-level primitives take (int32 port, uint64 lba, uint16
# count, uint64 buf), so these adapters re-shape the args. priv is
# the port number we stashed at register_blockdev time, cast back
# from uint64 to int32. count comes in as uint64 but the ATA
# command-table PRD entry only carries a 16-bit transfer length
# (the spec maxes at 65535 sectors per command); we clamp + warn on
# overflow rather than silently truncate.

def _ahci_read_sectors_blkop(priv: uint64, lba: uint64,
                             count: uint64, buf: Ptr[uint8]) -> int32:
    if count == 0:
        return 0
    if count > 65535:
        printk1("[ahci] blkop read: count=%d too large\n", count)
        return -1
    port: int32 = cast[int32](priv)
    return ahci_read_sectors(port, lba, cast[uint16](count),
                             cast[uint64](buf))


def _ahci_write_sectors_blkop(priv: uint64, lba: uint64,
                              count: uint64, buf: Ptr[uint8]) -> int32:
    if count == 0:
        return 0
    if count > 65535:
        printk1("[ahci] blkop write: count=%d too large\n", count)
        return -1
    port: int32 = cast[int32](priv)
    return ahci_write_sectors(port, lba, cast[uint16](count),
                              cast[uint64](buf))


# --- Accessors used by the L-shim add_disk path -----------------------
#
# api_ahci.ad / api_block.ad consume these so they don't have to deref
# AhciState directly (which would couple the L-shim file to this
# driver's struct layout).

def ahci_active_port() -> int32:
    # Returns the AHCI port number the driver has brought up, or -1
    # if no port was found.
    return ahci.port_num


def ahci_active_capacity() -> uint64:
    # Capacity (in 512-byte sectors) of the active AHCI port, or 0
    # if no port was found.
    return ahci.capacity


def ahci_blk_read(priv: uint64, lba: uint64, count: uint64,
                  buf: Ptr[uint8]) -> int32:
    # Public alias of _ahci_read_sectors_blkop so the L-shim's
    # add_disk wrapper can install a real BlockDeviceOps that points
    # back into this driver's hardware primitives. The L-shim never
    # imports the underscore-prefixed function pointer directly.
    return _ahci_read_sectors_blkop(priv, lba, count, buf)


def ahci_blk_write(priv: uint64, lba: uint64, count: uint64,
                   buf: Ptr[uint8]) -> int32:
    return _ahci_write_sectors_blkop(priv, lba, count, buf)


# --- Public entry point --------------------------------------------

def ahci_hardware_probe() -> int32:
    # Bring up the SATA HBA + the first active port to the point where
    # ahci_read_sectors / ahci_write_sectors can be called against it.
    # Does NOT register a block device, does NOT smoke-test. Returns
    # the device's LBA48 sector count (capacity) on success, 0 on
    # any failure. Idempotent: a second call short-circuits to the
    # cached `ahci.capacity` once a port has been brought up.
    #
    # Factored out of ahci_smoke_test() (M16.x → bridge-via-add_disk)
    # so the L-shim add_disk path can drive the same hardware bring-up
    # without going through register_blockdev("sd0", ...) (which would
    # collide with the L-shim's "sda" naming).
    if ahci.abar != 0 and ahci.port_num >= 0 and ahci.capacity != 0:
        return cast[int32](ahci.capacity & 0x7FFFFFFF)
    bdf: uint32 = _pci_find_class(AHCI_CLASS, AHCI_SUBCLASS,
                                  AHCI_PROGIF)
    if bdf == PCI_BDF_NONE:
        printk0("[ahci] no controller found\n")
        return 0
    printk1("[ahci] controller found bdf=%x\n", cast[uint64](bdf))

    _pci_enable_mem_and_master(bdf)

    bar5_raw: uint32 = pci_read_bar(bdf, 5)
    # MEM BAR: low bit = 0, bits 1..3 = type, bits 4..31 = base.
    if (bar5_raw & 1) != 0:
        printk0("[ahci] BAR5 is IO (not AHCI?)\n")
        return 0
    abar: uint64 = cast[uint64](bar5_raw & 0xFFFFFFF0)
    ahci.abar = abar
    printk1("[ahci] abar=%p\n", abar)

    # AHCI spec §10.4.3 — enable AHCI mode (GHC.AE) so the HBA exposes
    # AHCI semantics. Some firmware leaves the HBA in legacy IDE
    # emulation; flipping GHC.AE forces AHCI. We deliberately do NOT
    # issue a Global HBA Reset (GHC.HR) here — HR re-COMRESETs every
    # port and clears the device signature, so we'd have to re-init
    # the entire port (CLB/FB/FRE/ST) and wait for the device-to-host
    # register FIS to land before PORT_SIG is meaningful again. That
    # work is a follow-up. Real firmware that boots in AHCI mode
    # (the only mode we match on, progIF 0x01) leaves the HBA in a
    # usable state; users on boards that came up via legacy IDE or
    # RAID mode need to flip the firmware setting first (see
    # docs/REAL_HARDWARE.md).
    ghc: uint32 = _mmio_r32(abar + HBA_GHC)
    _mmio_w32(abar + HBA_GHC, ghc | GHC_AE)

    cap: uint32 = _mmio_r32(abar + HBA_CAP)
    pi:  uint32 = _mmio_r32(abar + HBA_PI)
    vs:  uint32 = _mmio_r32(abar + HBA_VS)
    printk2("[ahci] cap=%x vs=%x\n", cast[uint64](cap),
            cast[uint64](vs))
    printk1("[ahci] ports implemented = %x\n", cast[uint64](pi))

    # CAP.NP (low 5 bits) is zero-based: value 0 means 1 port supported,
    # value 31 means 32. We still walk all 32 PI bits (PI is the truth
    # for which ports exist), but log NP so a real-hardware mismatch
    # (BIOS forgot to set a PI bit) is visible.
    cap_np: uint32 = (cap & HBA_CAP_NP_MASK) + 1
    printk1("[ahci] CAP.NP supports %d ports\n", cast[uint64](cap_np))

    # Walk every implemented port. We want the FIRST port that hosts
    # an ATA disk (signature 0x101) — not just the first link-active
    # port, because a board might have port 0 wired to an empty
    # hot-swap bay (det=1) and port 2 to the OS disk (det=3). We log
    # each port's SSTS + SIG so multi-port hardware shows up in the
    # boot log even if we only end up driving one of them.
    #
    # PORT_SIG is meaningful only when the firmware has already
    # initialized the port (BIOS does this for the BIOS boot disk on
    # all boards we care about). If we ever issue GHC.HR ourselves,
    # PORT_SIG reads 0xFFFFFFFF until the port is re-init'd; the
    # post-HR re-init path is a Phase-2 follow-up.
    port_num: int32 = -1
    i: uint32 = 0
    while i < 32:
        if (pi & (cast[uint32](1) << i)) != 0:
            pb: uint64 = abar + HBA_PORTS_BASE \
                       + cast[uint64](i) * HBA_PORT_STRIDE
            ssts: uint32 = _mmio_r32(pb + PORT_SSTS)
            det: uint32 = ssts & 0xF
            ipm: uint32 = (ssts >> 8) & 0xF
            if det == 3 and ipm == 1:
                psig: uint32 = _mmio_r32(pb + PORT_SIG)
                printk2("[ahci] port %d link active sig=%x\n",
                        cast[uint64](i), cast[uint64](psig))
                if port_num < 0 and psig == PORT_SIG_ATA:
                    port_num = cast[int32](i)
            else:
                if det != 0:
                    # det=1 (present, no link) / det=4 (offline). Log
                    # so a real-hardware boot-from-wrong-port mystery
                    # is visible in dmesg; don't latch as our port.
                    printk2("[ahci] port %d det=%d (skipped)\n",
                            cast[uint64](i), cast[uint64](det))
        i = i + 1

    if port_num < 0:
        printk0("[ahci] no active ATA port found\n")
        return 0
    ahci.port_num = port_num

    port_base: uint64 = abar + HBA_PORTS_BASE \
                      + cast[uint64](port_num) * HBA_PORT_STRIDE
    ahci.port_base = port_base

    # Stop the port before re-pointing CLB/FB at our memory. AHCI
    # spec §10.1.2 mandates this even on a fresh HBA — the BIOS
    # may have left ST set.
    _port_stop(port_base)

    # Allocate a 4 KiB page (order 0) for cmd list + FIS + cmd
    # table. alloc_pages returns a page-aligned physical address;
    # since the kernel identity-maps low 4 GiB, the same value is
    # a valid virtual pointer.
    page: uint64 = alloc_pages(0)
    if page == 0:
        printk0("[ahci] alloc_pages(0) failed\n")
        return 0
    memset(cast[Ptr[uint8]](page), 0, 4096)
    ahci.page = page

    # NCQ: dedicated 16 KiB region for 32 independent per-slot command
    # tables. The legacy single-command path still uses page+CT_OFFSET;
    # the multi-slot path uses ahci.ct_page + slot*256. Zero it so unused
    # slots' CFIS/PRDT areas are deterministic.
    ct_page: uint64 = alloc_pages(AHCI_CT_PAGE_ORDER)
    if ct_page == 0:
        printk0("[ahci] alloc_pages(ct) failed\n")
        return 0
    memset(cast[Ptr[uint8]](ct_page), 0, 16384)
    ahci.ct_page = ct_page

    clist:   uint64 = page + CL_OFFSET
    fis:     uint64 = page + FIS_OFFSET
    ct_base: uint64 = page + CT_OFFSET

    # Plant the bases. We hold all DMA structures below 4 GiB so
    # high halves are always zero — but write them explicitly to
    # avoid relying on a fresh-from-BIOS state.
    _mmio_w32(port_base + PORT_CLB,  cast[uint32](clist & 0xFFFFFFFF))
    _mmio_w32(port_base + PORT_CLBU, cast[uint32](clist >> 32))
    _mmio_w32(port_base + PORT_FB,   cast[uint32](fis   & 0xFFFFFFFF))
    _mmio_w32(port_base + PORT_FBU,  cast[uint32](fis   >> 32))
    # Clear any pending error / interrupt state from probe.
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_IS,   0xFFFFFFFF)

    _port_start(port_base)
    # Arm the per-port interrupt-enable mask (error causes + the two
    # hot-plug edges PRCE/PCE), so PxIS reflects a live attach/detach.
    _port_enable_interrupts(port_base)

    sig: uint32 = _mmio_r32(port_base + PORT_SIG)
    printk1("[ahci] port signature = %x\n", cast[uint64](sig))
    if sig != PORT_SIG_ATA:
        printk0("[ahci] port is not an ATA disk; skipping I/O\n")
        return 0

    # IDENTIFY DEVICE → 512 bytes of disk metadata into id_buf.
    id_buf: uint64 = kmalloc(512)
    if id_buf == 0:
        printk0("[ahci] kmalloc(512) for IDENTIFY failed\n")
        return 0
    memset(cast[Ptr[uint8]](id_buf), 0, 512)
    if _do_identify(port_base, clist, ct_base, id_buf) != 0:
        printk0("[ahci] IDENTIFY failed\n")
        return 0

    # Parse model (words 27..46, 40 bytes byte-swapped) and LBA count
    # (words 100..103, 64-bit LE little-endian). LBA48 capacity is
    # in 512-byte sectors.
    raw_model: Ptr[uint8] = cast[Ptr[uint8]](id_buf + 27 * 2)
    _byteswap_model(raw_model, &ahci.model[0])
    printk1("[ahci] model=%s\n", cast[uint64](&ahci.model[0]))

    lba_count: uint64 = cast[Ptr[uint64]](id_buf + 100 * 2)[0]
    ahci.capacity = lba_count
    printk1("[ahci] sectors=%d\n", lba_count)

    # Mirror the legacy-path port into the multi-port table so the
    # routing primitives (_ahci_port_resolve / _ahci_port_base_of) and a
    # later multi-port enumeration treat sd0's port uniformly with the
    # others. This is the FIRST present port; the multi-port enumerator
    # skips re-bringing it up because _ahci_port_present is already set.
    pn: uint64 = cast[uint64](port_num)
    _ahci_port_present[pn]  = 1
    _ahci_port_base[pn]     = port_base
    _ahci_port_page[pn]     = page
    _ahci_port_ctpage[pn]   = ct_page
    _ahci_port_capacity[pn] = lba_count
    _ahci_port_blkslot[pn]  = -1

    # M16.114: wire the IRQ. Same shape as drivers/net/virtio_net.ad's
    # M16.113 template — read PCI INTx pin / line, route the firmware-
    # assigned IOAPIC pin to our chosen vector (0x41) on LAPIC 0,
    # register the handler. The polled smoke-test path above stays as
    # a safety-net fallback; this addition lets the kernel drain port-
    # level completions on real hardware via IRQ instead of busy-poll.
    bus: uint32 = pci_bdf_bus(bdf)
    pdev: uint32 = pci_bdf_dev(bdf)
    pfn:  uint32 = pci_bdf_fn(bdf)
    intx_pin:  uint32 = pci_config_read_byte(bus, pdev, pfn,
                                             AHCI_PCI_INTERRUPT_PIN)
    intx_line: uint32 = pci_config_read_byte(bus, pdev, pfn,
                                             AHCI_PCI_INTERRUPT_LINE)
    ioapic_pin: uint32 = intx_line
    # If firmware left INTERRUPT_LINE garbage (0 / 0xFF / >=24), fall
    # back to QEMU's documented default for the ich9-ahci slot — pin 11.
    if intx_pin == 0 or intx_line == 0 or intx_line >= 24:
        ioapic_pin = 11
    ahci.irq_pin = ioapic_pin
    ahci.irq_count = 0
    register_irq_handler(cast[uint64](AHCI_IRQ_VECTOR),
                         ahci_irq_handler)
    ioapic_redirect(ioapic_pin, AHCI_IRQ_VECTOR, AHCI_LAPIC_ID)
    printk2("[ahci] irq pin=%d vec=0x%x\n",
            cast[uint64](ioapic_pin), cast[uint64](AHCI_IRQ_VECTOR))

    # Wire the NCQ runtime (per-slot wait queues + allocator wait queue)
    # so the block-layer hot path can route through FPDMA QUEUED with
    # IRQ-driven completion. Idempotent; safe across multiple probes.
    _ncq_runtime_init()
    printk0("[ahci] NCQ block-path runtime ready (32 slots, IRQ-driven)\n")

    # Capacity-only return (no MBR read / no smoke test / no
    # register_blockdev). LBA48 may run past 2^31; clamp the int32
    # return to signal "non-zero" without overflowing — actual capacity
    # is stashed in ahci.capacity for the caller to read.
    if lba_count > 0x7FFFFFFF:
        return 0x7FFFFFFF
    return cast[int32](lba_count & 0x7FFFFFFF)


# --- Multi-port bring-up + enumeration (M16.x) ---------------------
#
# _ahci_bring_up_port brings ONE port (not the first/legacy one, which
# ahci_hardware_probe already handles) from "link active" to "IDENTIFY
# succeeded + table populated". It mirrors the per-port half of
# ahci_hardware_probe: COMRESET-retry the device-ready wait, stop the
# port, allocate its own 4 KiB working page + 16 KiB CT region, plant
# CLB/FB, start the port, confirm the ATA signature, run IDENTIFY for
# capacity, and record everything in the per-port table. Returns the
# LBA48 sector count on success, 0 on any failure (port left absent).
#
# Note we do NOT re-wire the IRQ here — the controller-level INTx is
# already routed by ahci_hardware_probe, and the driver is polled.

def _ahci_bring_up_port(port_num: int32) -> uint64:
    pn: uint64 = cast[uint64](port_num)
    if pn >= 32:
        return 0
    abar: uint64 = ahci.abar
    port_base: uint64 = abar + HBA_PORTS_BASE \
                      + pn * HBA_PORT_STRIDE

    # COMRESET-retry the device-ready wait. If the device never becomes
    # ready, treat the port as empty.
    if _port_wait_ready_with_comreset(port_base) != 0:
        printk1("[ahci] port %d not ready after COMRESET retries\n", pn)
        return 0

    # Stop the port before re-pointing CLB/FB at our memory.
    _port_stop(port_base)

    page: uint64 = alloc_pages(0)
    if page == 0:
        printk0("[ahci] alloc_pages(0) failed (multi-port)\n")
        return 0
    memset(cast[Ptr[uint8]](page), 0, 4096)

    ct_page: uint64 = alloc_pages(AHCI_CT_PAGE_ORDER)
    if ct_page == 0:
        printk0("[ahci] alloc_pages(ct) failed (multi-port)\n")
        return 0
    memset(cast[Ptr[uint8]](ct_page), 0, 16384)

    clist:   uint64 = page + CL_OFFSET
    fis:     uint64 = page + FIS_OFFSET
    ct_base: uint64 = page + CT_OFFSET

    _mmio_w32(port_base + PORT_CLB,  cast[uint32](clist & 0xFFFFFFFF))
    _mmio_w32(port_base + PORT_CLBU, cast[uint32](clist >> 32))
    _mmio_w32(port_base + PORT_FB,   cast[uint32](fis   & 0xFFFFFFFF))
    _mmio_w32(port_base + PORT_FBU,  cast[uint32](fis   >> 32))
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_IS,   0xFFFFFFFF)

    _port_start(port_base)
    _port_enable_interrupts(port_base)

    sig: uint32 = _mmio_r32(port_base + PORT_SIG)
    printk2("[ahci] port %d signature = %x\n", pn, cast[uint64](sig))
    if sig != PORT_SIG_ATA:
        printk1("[ahci] port %d not an ATA disk; skipping\n", pn)
        return 0

    id_buf: uint64 = kmalloc(512)
    if id_buf == 0:
        printk0("[ahci] kmalloc(512) IDENTIFY failed (multi-port)\n")
        return 0
    memset(cast[Ptr[uint8]](id_buf), 0, 512)
    if _do_identify(port_base, clist, ct_base, id_buf) != 0:
        printk1("[ahci] port %d IDENTIFY failed\n", pn)
        return 0

    lba_count: uint64 = cast[Ptr[uint64]](id_buf + 100 * 2)[0]
    printk2("[ahci] port %d sectors=%d\n", pn, lba_count)

    _ahci_port_present[pn]  = 1
    _ahci_port_base[pn]     = port_base
    _ahci_port_page[pn]     = page
    _ahci_port_ctpage[pn]   = ct_page
    _ahci_port_capacity[pn] = lba_count
    _ahci_port_blkslot[pn]  = -1
    return lba_count


def _ahci_sdname(idx: uint32, out: Ptr[uint8]):
    # Build "sd<idx>" into out. idx is the disk ordinal (0..). We only
    # ever register a handful of ports, but support multi-digit just in
    # case (sd0..sd31). Caller provides a >= 8-byte buffer.
    out[0] = 0x73        # 's'
    out[1] = 0x64        # 'd'
    if idx < 10:
        out[2] = cast[uint8](0x30 + idx)
        out[3] = 0
    else:
        out[2] = cast[uint8](0x30 + (idx / 10))
        out[3] = cast[uint8](0x30 + (idx % 10))
        out[4] = 0


# Static name buffers per disk ordinal — register_blockdev copies the
# name in, but we keep them module-scope to dodge frame-local array
# quirks. 8 bytes each is room for "sd<NN>\0".
_ahci_sdname_buf: Array[32, uint8]


def ahci_enumerate_ports() -> uint32:
    # Walk EVERY implemented port (PI bitmask), bring up each one that
    # has an active ATA device, and register it as its own block device
    # named sd0, sd1, sd2, ... in port order. The first present port is
    # already brought up by ahci_hardware_probe (it is also sd0); this
    # function registers it as sd0 and brings up + registers the rest.
    # Returns the number of ports registered. Idempotent-ish: re-running
    # skips ports already marked present, and register_blockdev for an
    # existing name no-ops at the block layer.
    if ahci.abar == 0:
        return 0
    abar: uint64 = ahci.abar
    pi: uint32 = _mmio_r32(abar + HBA_PI)

    disk_idx: uint32 = 0
    registered: uint32 = 0
    i: uint32 = 0
    while i < 32:
        if (pi & (cast[uint32](1) << i)) != 0:
            pb: uint64 = abar + HBA_PORTS_BASE \
                       + cast[uint64](i) * HBA_PORT_STRIDE
            ssts: uint32 = _mmio_r32(pb + PORT_SSTS)
            det: uint32 = ssts & 0xF
            ipm: uint32 = (ssts >> 8) & 0xF
            pn: uint64 = cast[uint64](i)
            # A port is a candidate if it links now (det==3) OR it was
            # already brought up by the legacy probe. det!=3 ports get a
            # COMRESET-retry inside _ahci_bring_up_port before we give up.
            present_already: uint32 = _ahci_port_present[pn]
            if present_already != 0 or (det == 3 and ipm == 1):
                cap: uint64 = 0
                if present_already != 0:
                    cap = _ahci_port_capacity[pn]
                else:
                    cap = _ahci_bring_up_port(cast[int32](i))
                if cap != 0 and _ahci_port_present[pn] != 0:
                    # Register this port under the next sd ordinal.
                    nb: Ptr[uint8] = &_ahci_sdname_buf[0]
                    _ahci_sdname(disk_idx, nb)
                    _ahci_port_ops[pn].read_sectors  = \
                        _ahci_read_sectors_blkop
                    _ahci_port_ops[pn].write_sectors = \
                        _ahci_write_sectors_blkop
                    bslot: int32 = register_blockdev(
                        cast[Ptr[char]](nb), cap,
                        &_ahci_port_ops[pn], pn)
                    if bslot >= 0:
                        _ahci_port_blkslot[pn] = bslot
                        printk2("[ahci] port %d registered as %s\n",
                                pn, cast[uint64](nb))
                        printk2("[ahci-mp] %s -> AHCI port %d\n",
                                cast[uint64](nb), pn)
                        registered = registered + 1
                        disk_idx = disk_idx + 1
                    else:
                        printk1("[ahci] register_blockdev port %d failed\n",
                                pn)
        i = i + 1
    _ahci_ports_registered = registered
    printk1("[ahci-mp] enumerated %d AHCI port(s)\n",
            cast[uint64](registered))
    return registered


# --- Multi-port self-test (M16.x) ----------------------------------
#
# Chained off ahci_smoke_test (no init/main.ad edit needed). Proves the
# multi-port enumeration worked end to end:
#   1. >= 2 AHCI ports were enumerated + registered.
#   2. find_blockdev("sd0") AND find_blockdev("sd1") both resolve.
#   3. A whole-disk READ of LBA 0 on EACH device returns that disk's
#      DISTINCT first-sector bytes (the test plants different signatures
#      on each backing image), routed through the GENERIC block-layer
#      vtable so the priv-cookie port routing is exercised, not bypassed.
# Prints a single unique "[ahci-mp] PASS" the test script greps for.
# Returns 1 on PASS, 0 on FAIL. If fewer than 2 ports exist (single-disk
# boot), it SKIPS cleanly (prints a skip marker, returns 1) so the
# default single-disk test_ahci.sh path is unaffected.

_ahci_mp_buf0: Array[512, uint8]
_ahci_mp_buf1: Array[512, uint8]


def ahci_multiport_selftest() -> int32:
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-mp] self-test start\n")
    nports: uint32 = ahci_ports_registered()
    printk1("[ahci-mp] ports registered = %d\n", cast[uint64](nports))
    if nports < 2:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-mp] SKIP: fewer than 2 AHCI ports present\n")
        return 1

    s0: int32 = find_blockdev("sd0")
    s1: int32 = find_blockdev("sd1")
    if s0 < 0 or s1 < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[ahci-mp] FAIL: sd0/sd1 not both registered (s0=%d s1=%d)\n",
                cast[uint64](s0), cast[uint64](s1))
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[ahci-mp] sd0=slot%d sd1=slot%d\n",
            cast[uint64](s0), cast[uint64](s1))

    p0: Ptr[uint8] = &_ahci_mp_buf0[0]
    p1: Ptr[uint8] = &_ahci_mp_buf1[0]
    memset(p0, 0, 512)
    memset(p1, 0, 512)

    # Read LBA 0 from EACH disk through the generic block layer.
    if blk_read_sectors(s0, 0, 1, p0) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-mp] FAIL: blk_read_sectors(sd0, lba=0)\n")
        return 0
    if blk_read_sectors(s1, 0, 1, p1) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-mp] FAIL: blk_read_sectors(sd1, lba=0)\n")
        return 0

    # The test harness plants distinct first bytes: disk0 byte0 = 0xD0,
    # disk1 byte0 = 0xD1 (and a matching tag at byte 1). Assert each disk
    # returned ITS OWN signature — this is the load-bearing proof that
    # the priv-cookie routing sends sd0's read to port A and sd1's to
    # port B rather than both hitting the same port.
    printk2("[ahci-mp] sd0 LBA0[0..1]=%x %x\n",
            cast[uint64](p0[0]), cast[uint64](p0[1]))
    printk2("[ahci-mp] sd1 LBA0[0..1]=%x %x\n",
            cast[uint64](p1[0]), cast[uint64](p1[1]))
    if p0[0] == p1[0]:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-mp] FAIL: sd0 and sd1 returned identical sector 0\n")
        return 0
    # Also assert the MBR signature survived on both (planted by harness).
    if p0[510] != 0x55 or p0[511] != 0xAA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-mp] FAIL: sd0 MBR signature bad\n")
        return 0
    if p1[510] != 0x55 or p1[511] != 0xAA:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-mp] FAIL: sd1 MBR signature bad\n")
        return 0

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-mp] sd0 and sd1 returned DISTINCT first sectors\n")
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-mp] PASS\n")
    return 1


def ahci_smoke_test() -> int32:
    # Native AHCI bring-up + smoke test + register_blockdev as "sd0".
    # Used by the legacy hand-rolled path AND as the fallback when the
    # L-shim libata/scsi path doesn't complete add_disk. Once the
    # L-shim add_disk wrapper lands (M16.x), the AHCI shim drives
    # `ahci_hardware_probe` directly and skips this smoke-test path so
    # there's no `[bridge=fallback]`.
    cap_int32: int32 = ahci_hardware_probe()
    if cap_int32 == 0:
        return -1
    lba_count: uint64 = ahci.capacity
    port_num:  int32  = ahci.port_num
    port_base: uint64 = ahci.port_base
    clist:     uint64 = ahci.page + CL_OFFSET
    ct_base:   uint64 = ahci.page + CT_OFFSET

    # READ LBA 0 (the MBR). 512 bytes into mbr_buf.
    mbr_buf: uint64 = kmalloc(512)
    if mbr_buf == 0:
        printk0("[ahci] kmalloc(512) for MBR failed\n")
        return -1
    memset(cast[Ptr[uint8]](mbr_buf), 0, 512)
    if _do_read_lba(port_base, clist, ct_base, mbr_buf, 0, 1) != 0:
        printk0("[ahci] READ_DMA_EXT failed\n")
        return -1

    # Log first 16 bytes as hex for human eyeballing — one byte per
    # printk1, two hex digits each. The format helper has no width
    # modifier, so we render high + low nibble manually.
    printk0("[ahci] LBA0[0..16]=")
    k: uint64 = 0
    while k < 16:
        b: uint64 = cast[uint64](cast[Ptr[uint8]](mbr_buf + k)[0])
        hi: uint64 = (b >> 4) & 0xF
        lo: uint64 = b & 0xF
        printk1("%x", hi)
        printk1("%x", lo)
        if k < 15:
            printk0(" ")
        k = k + 1
    printk0("\n")

    # MBR signature check — bytes 510/511 must be 0x55 0xAA.
    sig_lo: uint8 = cast[Ptr[uint8]](mbr_buf + 510)[0]
    sig_hi: uint8 = cast[Ptr[uint8]](mbr_buf + 511)[0]
    if sig_lo == 0x55 and sig_hi == 0xAA:
        printk0("[ahci] MBR signature OK\n")
    else:
        printk2("[ahci] MBR signature MISMATCH (got %x %x)\n",
                cast[uint64](sig_lo), cast[uint64](sig_hi))

    # M16.118: exercise the new WRITE DMA EXT path. We get here only
    # after IDENTIFY + READ LBA 0 already passed, so the port is known
    # good. The write-smoke test scribbles a pattern to LBA 1 and reads
    # it back to verify byte-for-byte; on failure we log + fall through
    # (the controller is still in a clean state since each command
    # serialises on slot 0).
    _ahci_write_smoke_test()

    # M16.119: register the active port with the kernel block layer
    # so vfs_read / vfs_write / ext4 / fat callers can reach the disk
    # through `blk_read_sectors(slot, ...)` and `blk_write_sectors`
    # like they already do for /dev/vda / /dev/ram0. priv carries the
    # port index (uint64-encoded) so the adapter wrappers can
    # re-validate it against the singleton ahci.port_num. Naming is
    # "sd0" (Linux-style SCSI/SATA disk slot 0); multi-port HBAs +
    # partition-aware names (sd0p1) are follow-ups.
    #
    # M16.x MULTI-PORT: instead of registering only the first port as
    # "sd0", enumerate EVERY implemented port with an active ATA device
    # and register each as its own block device (sd0, sd1, ...) in port
    # order. The first present port is the one ahci_hardware_probe
    # already brought up, so it becomes sd0 and the existing single-disk
    # callers (ahci_active_port / blk find "sd0") are unchanged.
    nports: uint32 = ahci_enumerate_ports()
    bslot: int32 = find_blockdev("sd0")
    if bslot < 0:
        printk0("[ahci] register_blockdev(sd0) failed\n")
        return 0
    printk1("[ahci] registered as block slot=%d (sd0)\n",
            cast[uint64](bslot))
    _ahci_blk_smoke_test(bslot)

    # M16.x: scan the partition table on sd0 and register each live
    # partition as a sibling block device "sd0pN" (1-indexed, Linux
    # convention). After this returns, `blk_find_blockdev("sd0p1")`
    # resolves to a real device whose I/O lands on the right LBA
    # window of the underlying SATA disk. Failure here is non-fatal —
    # the raw `sd0` device is still usable for whole-disk reads.
    blk_scan_partitions(bslot)
    blk_register_partitions(bslot, "sd0")

    # M16.x: multi-port self-test. Chained off the smoke path (no
    # init/main.ad edit). When >= 2 AHCI ports are present it proves
    # sd0 AND sd1 are both registered and return DISTINCT first sectors
    # via the generic block layer; with a single disk it SKIPs cleanly.
    ahci_multiport_selftest()

    return 0


def _ahci_blk_smoke_test(slot: int32) -> int32:
    # M16.119 block-layer round-trip. Verifies that a write submitted
    # through `blk_write_sectors(slot, ...)` reaches the AHCI port
    # adapter, lands on the SATA disk via WRITE DMA EXT, and the
    # corresponding `blk_read_sectors` returns the same bytes. Uses
    # LBA 1 (same as the driver-level write-smoke test) — the
    # controller has already proven byte-for-byte equality on this
    # path, so seeing identical bytes here proves the vtable wiring
    # is right rather than re-testing the driver primitive itself.
    wbuf: uint64 = kmalloc(512)
    rbuf: uint64 = kmalloc(512)
    if wbuf == 0 or rbuf == 0:
        printk0("[ahci] blk-smoke: kmalloc(512) failed\n")
        return -1
    # Pattern: byte i = (i ^ 0x5A) & 0xFF. Different from the driver-
    # level smoke test's 0xA5 mask so a stale-buffer bug shows up as
    # a wrong PASS rather than a fake one.
    wp: Ptr[uint8] = cast[Ptr[uint8]](wbuf)
    i: uint64 = 0
    while i < 512:
        wp[i] = cast[uint8](cast[uint8](i & 0xFF) ^ cast[uint8](0x5A))
        i = i + 1
    memset(cast[Ptr[uint8]](rbuf), 0, 512)

    if blk_write_sectors(slot, 1, 1, wp) != 0:
        printk0("[ahci] blk-smoke: blk_write_sectors failed\n")
        return -1
    printk0("[blk] write sd0 LBA=1 OK\n")

    rp: Ptr[uint8] = cast[Ptr[uint8]](rbuf)
    if blk_read_sectors(slot, 1, 1, rp) != 0:
        printk0("[ahci] blk-smoke: blk_read_sectors failed\n")
        return -1

    j: uint64 = 0
    while j < 512:
        if rp[j] != wp[j]:
            printk2("[ahci] blk-smoke: MISMATCH at byte %d (got %x)\n",
                    j, cast[uint64](rp[j]))
            return -1
        j = j + 1
    printk0("[blk] readback sd0 matches\n")
    return 0


def _ahci_write_smoke_test() -> int32:
    # M16.118 write+readback verification. Lays down a known pattern
    # at LBA 1 via the new WRITE DMA EXT path, zeroes the verifier
    # buffer, reads LBA 1 back via the existing READ DMA EXT path,
    # and byte-compares. Picks LBA 1 (not LBA 0) so a bug doesn't
    # clobber the test harness's planted MBR signature at LBA 0
    # before the existing test_ahci.sh grep'd for it.
    #
    # The buffer is kmalloc'd 512 bytes — small enough to live in
    # the slab without page-fragmenting the kernel heap. The PRD
    # entries the driver builds don't care whether the buffer is
    # page-aligned (PRDT alignment is per AHCI spec just 2-byte for
    # the data buffer when CAP.S64A and CAP.SDBS aren't constraining
    # us, which on QEMU's ich9-ahci they aren't).
    wbuf: uint64 = kmalloc(512)
    rbuf: uint64 = kmalloc(512)
    if wbuf == 0 or rbuf == 0:
        printk0("[ahci] write-smoke: kmalloc(512) failed\n")
        return -1
    # Plant a recognisable pattern. Byte i = (i ^ 0xA5) & 0xFF so
    # any single-byte corruption (or a stuck DMA returning zeros)
    # is visible at index 0 (= 0xA5).
    i: uint64 = 0
    wp: Ptr[uint8] = cast[Ptr[uint8]](wbuf)
    while i < 512:
        wp[i] = cast[uint8](cast[uint8](i & 0xFF) ^ cast[uint8](0xA5))
        i = i + 1
    memset(cast[Ptr[uint8]](rbuf), 0, 512)

    if ahci_write_sectors(ahci.port_num, 1, 1, wbuf) != 0:
        printk0("[ahci] write-smoke: WRITE DMA EXT failed\n")
        return -1
    printk0("[ahci] write LBA=1 nblocks=1 OK\n")

    if ahci_read_sectors(ahci.port_num, 1, 1, rbuf) != 0:
        printk0("[ahci] write-smoke: read-back failed\n")
        return -1

    # Byte-compare. Any mismatch fails the smoke test loudly.
    rp: Ptr[uint8] = cast[Ptr[uint8]](rbuf)
    j: uint64 = 0
    while j < 512:
        if rp[j] != wp[j]:
            printk2("[ahci] readback MISMATCH at byte %d (got %x)\n",
                    j, cast[uint64](rp[j]))
            return -1
        j = j + 1
    printk0("[ahci] readback matches pattern\n")
    return 0


# --- NCQ multi-slot self-test (M16.x) ------------------------------
#
# Proves REAL Native Command Queuing: issues SEVERAL reads concurrently
# across DIFFERENT command-list slots (independent CI bits), shows that
# more than one slot was outstanding simultaneously (peak in-flight > 1
# when the host models it, else >= 1 distinct slots allocated and drained
# correctly), and verifies each slot's returned data is correct.
#
# Strategy: the slot allocator hands out a fresh free slot per read; we
# submit N reads of distinct LBAs back-to-back without draining between
# them, so all N CI bits are set before we poll. _ncq_drain then watches
# the CI bits clear, records the PEAK simultaneous in-flight count, and
# resolves each slot's status. Finally we re-read each LBA serially
# (legacy slot-0 path) and byte-compare to prove the concurrent buffers
# hold the right sectors.
#
# Host caveat: QEMU's ich9-ahci tends to complete each command almost
# instantly, so the observed peak may be 1 even though we issued N CI
# bits in one burst. We therefore accept EITHER observed peak > 1 (true
# overlap) OR (distinct slots used > 1 AND every slot's data correct),
# and report which condition carried the PASS.

AHCI_NCQ_TEST_N: uint32 = 6        # concurrent reads to issue

def ahci_ncq_selftest() -> int32:
    printk0("[ahci-ncq] self-test start\n")
    if ahci.abar == 0 or ahci.port_num < 0 or ahci.ct_page == 0:
        printk0("[ahci-ncq] FAIL: driver not initialised\n")
        return -1
    port_base: uint64 = ahci.port_base

    # Reset bookkeeping so a prior test run doesn't leak busy bits.
    rs: uint32 = 0
    while rs < AHCI_NCQ_SLOTS:
        _ncq_slot_busy[rs] = 0
        _ncq_slot_status[rs] = 0
        rs = rs + 1
    _ncq_slots_used_mask = 0

    n: uint32 = AHCI_NCQ_TEST_N
    # Allocate one 512-byte buffer per concurrent read. Flat arrays for
    # the per-read slot index + buffer VA (indexed by request 0..n-1).
    rbuf: Array[8, uint64]
    rslot: Array[8, int32]
    ri: uint32 = 0
    while ri < n:
        b: uint64 = kmalloc(512)
        if b == 0:
            printk0("[ahci-ncq] FAIL: kmalloc(512)\n")
            return -1
        memset(cast[Ptr[uint8]](b), 0, 512)
        rbuf[ri] = b
        rslot[ri] = -1
        ri = ri + 1

    if _wait_tfd_idle(port_base) != 0:
        printk0("[ahci-ncq] FAIL: port busy before submit\n")
        return -1
    _mmio_w32(port_base + PORT_IS, 0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)

    # Submit N reads of DISTINCT LBAs (0,1,2,...) back-to-back, each into
    # a fresh slot, WITHOUT draining — so all N CI bits go up before poll.
    wait_mask: uint32 = 0
    distinct: uint32 = 0
    ri = 0
    while ri < n:
        slot: int32 = _ncq_alloc_slot(port_base)
        if slot < 0:
            printk0("[ahci-ncq] FAIL: no free slot\n")
            return -1
        su: uint32 = cast[uint32](slot)
        rslot[ri] = slot
        wait_mask = wait_mask | (cast[uint32](1) << su)
        distinct = distinct + 1
        # tag = the request index so completion can be matched back.
        _ncq_submit_read(port_base, su, rbuf[ri],
                         cast[uint64](ri), 1, cast[uint64](ri))
        printk2("[ahci-ncq] submitted req=%d into slot=%d\n",
                cast[uint64](ri), cast[uint64](su))
        ri = ri + 1

    # Snapshot CI immediately after the burst — how many bits are set at
    # this instant is direct evidence of simultaneous outstanding commands.
    ci_snap: uint32 = _mmio_r32(port_base + PORT_CI)
    burst_live: uint32 = 0
    bs: uint32 = 0
    while bs < AHCI_NCQ_SLOTS:
        if (ci_snap & wait_mask & (cast[uint32](1) << bs)) != 0:
            burst_live = burst_live + 1
        bs = bs + 1
    printk2("[ahci-ncq] CI snapshot after burst: mask=%x live=%d\n",
            cast[uint64](ci_snap & wait_mask), cast[uint64](burst_live))

    drc: int32 = _ncq_drain(port_base, wait_mask)
    peak: uint32 = _ncq_peak_get()
    if burst_live > peak:
        peak = burst_live
    printk2("[ahci-ncq] distinct slots used=%d peak in-flight=%d\n",
            cast[uint64](distinct), cast[uint64](peak))
    if drc != 0:
        printk0("[ahci-ncq] FAIL: drain reported error/timeout\n")
        return -1

    # Verify each slot's status resolved OK and the data is correct by
    # re-reading each LBA via the legacy serial slot-0 path and comparing.
    clist:   uint64 = ahci.page + CL_OFFSET
    ct_base: uint64 = ahci.page + CT_OFFSET
    vbuf: uint64 = kmalloc(512)
    if vbuf == 0:
        printk0("[ahci-ncq] FAIL: kmalloc(verify)\n")
        return -1
    ri = 0
    while ri < n:
        su: uint32 = cast[uint32](rslot[ri])
        if _ncq_slot_status[su] != 0:
            printk1("[ahci-ncq] FAIL: slot status bad req=%d\n",
                    cast[uint64](ri))
            return -1
        memset(cast[Ptr[uint8]](vbuf), 0, 512)
        if _do_read_lba(port_base, clist, ct_base, vbuf,
                        cast[uint64](ri), 1) != 0:
            printk1("[ahci-ncq] FAIL: verify read req=%d\n",
                    cast[uint64](ri))
            return -1
        cp: Ptr[uint8] = cast[Ptr[uint8]](rbuf[ri])
        vp: Ptr[uint8] = cast[Ptr[uint8]](vbuf)
        j: uint64 = 0
        while j < 512:
            if cp[j] != vp[j]:
                printk2("[ahci-ncq] FAIL: data mismatch req=%d byte=%d\n",
                        cast[uint64](ri), j)
                return -1
            j = j + 1
        printk2("[ahci-ncq] req=%d slot=%d data verified OK\n",
                cast[uint64](ri), cast[uint64](su))
        ri = ri + 1

    # Decide which evidence carried the test.
    concurrency_proven: int32 = 0
    if peak > 1:
        printk1("[ahci-ncq] observed %d slots in flight SIMULTANEOUSLY\n",
                cast[uint64](peak))
        concurrency_proven = 1
    else:
        printk0("[ahci-ncq] host completes per-command instantly (peak=1);\n")
        printk1("[ahci-ncq] fell back to distinct-slot correctness: %d slots\n",
                cast[uint64](distinct))
    if distinct < 2:
        printk0("[ahci-ncq] FAIL: allocator did not rotate across slots\n")
        return -1
    # Either path is a valid PASS: real overlap, or independent multi-slot
    # allocation with every slot's data correct.
    if concurrency_proven == 0:
        printk0("[ahci-ncq] multi-slot correctness path validated\n")
    printk0("[ahci-ncq] PASS\n")
    return 0


# --- NCQ block-path multi-slot self-test (this commit) -------------
#
# Proves the BLOCK-LAYER hot path (blk_read_sectors / blk_write_sectors)
# routes through the new NCQ FPDMA QUEUED + IRQ-completion plumbing, NOT
# the legacy serialised slot-0 path. The block path is synchronous (one
# I/O per blk_*_sectors call) so we can't run multiple block-layer
# requests "concurrently" from a single task; instead we exercise the
# FPDMA submission primitive that the block path uses, fan out N reads
# across distinct slots WITHOUT draining between them, and assert:
#
#   * the FPDMA submit succeeded for every request (queued path live),
#   * more than one slot was used (allocator rotated — multi-slot proven),
#   * either the peak simultaneous in-flight > 1 OR the IRQ-completion
#     counter advanced (proving the IRQ-driven completion path fired,
#     vs. the polled drain), and
#   * each slot's data came back byte-correct.
#
# This is the block-path counterpart of ahci_ncq_selftest: that one used
# READ_DMA_EXT (non-queued, polled drain); this one uses FPDMA QUEUED
# with the SACT+CI tag-issue ordering and the IRQ wakes the waiters.

AHCI_NCQ_BLK_TEST_N: uint32 = 6

def ahci_ncq_blkpath_selftest() -> int32:
    printk0("[ahci-ncq-blk] self-test start\n")
    if ahci.abar == 0 or ahci.port_num < 0 or ahci.ct_page == 0:
        printk0("[ahci-ncq-blk] FAIL: driver not initialised\n")
        return -1
    if _ncq_runtime_ready == 0:
        printk0("[ahci-ncq-blk] FAIL: NCQ runtime not initialised\n")
        return -1
    # Ensure the FPDMA block-path is on (init.ad flips this after
    # ahci_smoke_test; in case the smoke test was skipped, force it here).
    ahci_ncq_block_path_force_enable_for_test()
    port_base: uint64 = ahci.port_base

    # Reset bookkeeping — same precondition the polled NCQ selftest uses.
    rs: uint32 = 0
    while rs < AHCI_NCQ_SLOTS:
        _ncq_slot_busy[rs]   = 0
        _ncq_slot_status[rs] = 0
        _ncq_slot_queued[rs] = 0
        rs = rs + 1
    _ncq_slots_used_mask = 0
    _ncq_inflight_count  = 0
    _ncq_peak_inflight   = 0

    # Snapshot the IRQ-completion counter so we can show the IRQ path
    # actually fired (vs. quietly poll-completing via the fallback).
    irq_before: uint64 = _ncq_irq_completions_get()
    peak_before: uint32 = _ncq_peak_get()
    printk2("[ahci-ncq-blk] before: peak=%d irq=%d\n",
            cast[uint64](peak_before), irq_before)

    n: uint32 = AHCI_NCQ_BLK_TEST_N
    rbuf:  Array[8, uint64]
    rslot: Array[8, int32]
    ri: uint32 = 0
    while ri < n:
        b: uint64 = kmalloc(512)
        if b == 0:
            printk0("[ahci-ncq-blk] FAIL: kmalloc(512)\n")
            return -1
        memset(cast[Ptr[uint8]](b), 0, 512)
        rbuf[ri]  = b
        rslot[ri] = -1
        ri = ri + 1

    if _wait_tfd_idle(port_base) != 0:
        printk0("[ahci-ncq-blk] FAIL: port busy before submit\n")
        return -1
    _mmio_w32(port_base + PORT_IS,   0xFFFFFFFF)
    _mmio_w32(port_base + PORT_SERR, 0xFFFFFFFF)

    # Issue N FPDMA QUEUED reads of distinct LBAs into distinct slots
    # WITHOUT sleeping between submits — proving the block path's FPDMA
    # primitive accepts multi-slot fan-out.
    wait_mask: uint32 = 0
    distinct: uint32 = 0
    ri = 0
    while ri < n:
        slot: int32 = _ncq_alloc_slot(port_base)
        if slot < 0:
            printk0("[ahci-ncq-blk] FAIL: no free slot\n")
            return -1
        su: uint32 = cast[uint32](slot)
        rslot[ri] = slot
        wait_mask = wait_mask | (cast[uint32](1) << su)
        distinct = distinct + 1
        _ncq_submit_fpdma(port_base, su, rbuf[ri], cast[uint64](ri), 1, 0,
                          cast[uint64](ri))
        printk2("[ahci-ncq-blk] FPDMA submitted req=%d into slot=%d\n",
                cast[uint64](ri), cast[uint64](su))
        ri = ri + 1

    # Snapshot CI / SACT immediately after the burst. Either bit set across
    # the wait_mask is direct evidence of simultaneous outstanding queued
    # commands.
    ci_snap:   uint32 = _mmio_r32(port_base + PORT_CI)
    sact_snap: uint32 = _mmio_r32(port_base + PORT_SACT)
    burst_live: uint32 = 0
    bs: uint32 = 0
    while bs < AHCI_NCQ_SLOTS:
        bit_b: uint32 = cast[uint32](1) << bs
        if (wait_mask & bit_b) != 0 \
           and ((ci_snap | sact_snap) & bit_b) != 0:
            burst_live = burst_live + 1
        bs = bs + 1
    printk2("[ahci-ncq-blk] burst snapshot: CI|SACT mask=%x live=%d\n",
            cast[uint64]((ci_snap | sact_snap) & wait_mask),
            cast[uint64](burst_live))

    # Drain via the IRQ-completion path: poll the bookkeeping (the IRQ
    # handler flips _ncq_slot_busy[s] to 0). If IRQ delivery is flaky
    # under the test host, the fallback re-sweep matches the production
    # _ncq_block_rw_sync timeout path.
    drain_spin: uint64 = 0
    while drain_spin < 10000000:
        any_busy: uint32 = 0
        ss: uint32 = 0
        while ss < AHCI_NCQ_SLOTS:
            if (wait_mask & (cast[uint32](1) << ss)) != 0 \
               and _ncq_slot_busy[ss] != 0:
                any_busy = 1
            ss = ss + 1
        if any_busy == 0:
            drain_spin = 10000001
        else:
            # Manually sweep — covers the (rare) flaky-IRQ host. The
            # production path does the same on a timer-tick timeout.
            _ncq_irq_complete_port(port_base)
            drain_spin = drain_spin + 1
    if drain_spin == 10000000:
        printk0("[ahci-ncq-blk] FAIL: drain timeout (slots stuck busy)\n")
        return -1

    peak: uint32 = _ncq_peak_get()
    irq_after: uint64 = _ncq_irq_completions_get()
    if burst_live > peak:
        peak = burst_live
    printk2("[ahci-ncq-blk] distinct slots used=%d peak in-flight=%d\n",
            cast[uint64](distinct), cast[uint64](peak))
    printk2("[ahci-ncq-blk] irq-completions delta=%d after=%d\n",
            irq_after - irq_before, irq_after)

    # Verify each slot's status + data (byte-compare via the legacy
    # non-queued read path so we trust the verify oracle, not the path
    # under test).
    clist:   uint64 = ahci.page + CL_OFFSET
    ct_base: uint64 = ahci.page + CT_OFFSET
    vbuf: uint64 = kmalloc(512)
    if vbuf == 0:
        printk0("[ahci-ncq-blk] FAIL: kmalloc(verify)\n")
        return -1
    ri = 0
    while ri < n:
        su: uint32 = cast[uint32](rslot[ri])
        if _ncq_slot_status[su] != 0:
            printk1("[ahci-ncq-blk] FAIL: slot status bad req=%d\n",
                    cast[uint64](ri))
            return -1
        memset(cast[Ptr[uint8]](vbuf), 0, 512)
        if _do_read_lba(port_base, clist, ct_base, vbuf,
                        cast[uint64](ri), 1) != 0:
            printk1("[ahci-ncq-blk] FAIL: verify read req=%d\n",
                    cast[uint64](ri))
            return -1
        cp: Ptr[uint8] = cast[Ptr[uint8]](rbuf[ri])
        vp: Ptr[uint8] = cast[Ptr[uint8]](vbuf)
        j: uint64 = 0
        while j < 512:
            if cp[j] != vp[j]:
                printk2("[ahci-ncq-blk] FAIL: data mismatch req=%d byte=%d\n",
                        cast[uint64](ri), j)
                return -1
            j = j + 1
        printk2("[ahci-ncq-blk] req=%d slot=%d data verified OK\n",
                cast[uint64](ri), cast[uint64](su))
        ri = ri + 1

    if distinct < 2:
        printk0("[ahci-ncq-blk] FAIL: only 1 slot used (allocator didn't rotate)\n")
        return -1

    # Now drive the actual block-layer hot path (blk_read_sectors on sd0)
    # so we PROVE the dispatch through find_blockdev + the BlockDeviceOps
    # vtable lands on _ncq_block_rw_sync. The find_blockdev / blk_read
    # contract is synchronous; one call must succeed and the data must
    # match what we already verified via the FPDMA fan-out above.
    bslot: int32 = find_blockdev("sd0")
    if bslot < 0:
        printk0("[ahci-ncq-blk] FAIL: sd0 not registered\n")
        return -1
    blk_rd_buf: uint64 = kmalloc(512)
    if blk_rd_buf == 0:
        printk0("[ahci-ncq-blk] FAIL: kmalloc(blk_rd_buf)\n")
        return -1
    memset(cast[Ptr[uint8]](blk_rd_buf), 0, 512)
    if blk_read_sectors(bslot, 0, 1, cast[Ptr[uint8]](blk_rd_buf)) != 0:
        printk0("[ahci-ncq-blk] FAIL: blk_read_sectors(sd0, lba=0)\n")
        return -1
    printk0("[ahci-ncq-blk] block-layer dispatch reached NCQ path\n")

    # Concurrency / IRQ evidence. PASS conditions (either suffices):
    #   * peak in-flight > 1 → genuine simultaneous queued overlap
    #   * irq_after > irq_before → IRQ-driven completion path fired
    # PLUS distinct >= 2 (already enforced above).
    if peak > 1:
        printk1("[ahci-ncq-blk] observed %d queued slots SIMULTANEOUSLY\n",
                cast[uint64](peak))
    if irq_after > irq_before:
        printk1("[ahci-ncq-blk] IRQ-driven completions advanced by %d\n",
                irq_after - irq_before)
    else:
        printk0("[ahci-ncq-blk] IRQ-completion did not advance — poll-fallback path served the drain\n")
    printk0("[ahci-ncq-blk] PASS\n")
    return 0


# --- Generic block-layer round-trip self-test ----------------------
#
# Gated boot self-test (init/main.ad boot:37.ablk, planted
# /etc/ahci-blk-test by build_initramfs.py ENABLE_AHCI_BLK_TEST, driven
# by scripts/test_ahci_blk.sh). It PROVES that an AHCI SATA disk is
# reachable through the UNIFORM kernel block-layer vtable — NOT by
# calling ahci_read_sectors / ahci_write_sectors directly, but by
# dispatching through find_blockdev("sd0") + blk_write_sectors /
# blk_read_sectors. That is the whole point of register_blockdev'ing the
# AHCI port: ext4 / fat mount over a SATA disk through the same generic
# path they already use for virtio-blk / ram0 / sd0(USB).
#
#   1. Look the device up via the block layer (find_blockdev("sd0")).
#   2. Lay down a known pattern at a scratch LBA via blk_write_sectors
#      (the GENERIC vtable write path — exercises ops.write_sectors ->
#      _ahci_write_sectors_blkop -> ahci_write_sectors).
#   3. Zero the verify buffer, read the same LBA back via
#      blk_read_sectors, and byte-compare.
#
# Uses LBA 2 (the driver-level + M16.119 smoke tests already scribble
# LBA 1; a fresh LBA keeps a stale-buffer bug honest). Prints
# [ahci-blk] marker lines + a single [ahci-blk] PASS at EMERG so it
# reaches serial even past the shell prompt.

# 512-byte scratch buffers — flat module-scope per the Adder array
# quirk (a frame-local Array[512,...] miscompiles). Two buffers: write
# source + read verify.
_ablk_wbuf: Array[512, uint8]
_ablk_rbuf: Array[512, uint8]


def ahci_blk_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL. Prints [ahci-blk] marker lines.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-blk] self-test start\n")

    # 1. Resolve the AHCI disk THROUGH the block layer. If this fails the
    #    port never registered as sd0 — the registration gap the test
    #    guards against.
    slot: int32 = find_blockdev("sd0")
    if slot < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-blk] FAIL: sd0 not registered with block layer\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[ahci-blk] sd0 found at block slot=%d\n", cast[uint64](slot))

    # 2. Build a known pattern and write it through the GENERIC vtable
    #    write path (NOT ahci_write_sectors directly). Pattern byte i =
    #    (i ^ 0x3C) & 0xFF — distinct from the 0xA5 / 0x5A masks the
    #    driver-level + M16.119 smoke tests use, so a stale buffer shows
    #    up as a wrong-pattern mismatch rather than a fake PASS.
    wp: Ptr[uint8] = &_ablk_wbuf[0]
    i: uint64 = 0
    while i < 512:
        wp[i] = cast[uint8](cast[uint8](i & 0xFF) ^ cast[uint8](0x3C))
        i = i + 1
    rp: Ptr[uint8] = &_ablk_rbuf[0]
    memset(rp, 0, 512)

    if blk_write_sectors(slot, 2, 1, wp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-blk] FAIL: blk_write_sectors(sd0, lba=2) failed\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-blk] generic write sd0 LBA=2 OK\n")

    # 3. Read it back through the GENERIC vtable read path and compare.
    if blk_read_sectors(slot, 2, 1, rp) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-blk] FAIL: blk_read_sectors(sd0, lba=2) failed\n")
        return 0

    j: uint64 = 0
    while j < 512:
        if rp[j] != wp[j]:
            printk_set_level(PRINTK_LEVEL_EMERG)
            printk2("[ahci-blk] FAIL: mismatch at byte %d (got %x)\n",
                    j, cast[uint64](rp[j]))
            return 0
        j = j + 1

    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-blk] generic readback sd0 matches\n")
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-blk] PASS\n")
    return 1


# --- TRIM + IDENTIFY/SMART self-test (M16.x) -----------------------
#
# Gated boot self-test (init/main.ad boot:37.atrim, planted
# /etc/ahci-trim-test by build_initramfs.py ENABLE_AHCI_TRIM_TEST=1,
# driven by scripts/test_ahci_trim.sh). It exercises the two new mature-
# AHCI features end-to-end against a QEMU ich9-ahci disk:
#
#   1. IDENTIFY DEVICE — issues 0xEC, decodes the 48-bit LBA capacity
#      (words 100..103) and the rotation rate (word 217), and asserts the
#      capacity matches the attached disk's known sector count. QEMU
#      DEFINITELY supports IDENTIFY, so this is the load-bearing PASS.
#      Emits [ahci-ident] PASS.
#   2. DATA SET MANAGEMENT / TRIM — issues 0x06 (feature 0x01) with a real
#      LBA-range-entry payload. QEMU's ich9-ahci may or may not implement
#      TRIM; EITHER a clean completion (rc==0) OR a correctly-detected
#      device ABORT (rc==1, the driver read the TFD.ERR bit) is a PASS,
#      because the point is that the driver builds the command, fires the
#      slot, and reads back the right completion status. Only a fatal HBA
#      wedge or timeout (rc==-1) FAILs. Emits [ahci-trim] PASS.
#
# Prints [ahci-trim] / [ahci-ident] marker lines + the two PASS markers at
# EMERG so they reach serial past the shell prompt.

def ahci_trim_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-ident] self-test start\n")

    # Bring the port up (idempotent — re-uses the cached singleton if the
    # smoke test already ran).
    cap_probe: int32 = ahci_hardware_probe()
    if cap_probe == 0 or ahci.port_num < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-ident] FAIL: no AHCI port brought up\n")
        return 0
    port: int32 = ahci.port_num

    # 1. IDENTIFY DEVICE + decode. The capacity ahci_identify returns must
    #    be non-zero and must match the capacity ahci_hardware_probe
    #    already cached from its own IDENTIFY at bring-up (same disk, same
    #    word-100..103 decode) — proving our standalone decode is correct.
    id_cap: uint64 = ahci_identify(port)
    if id_cap == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-ident] FAIL: IDENTIFY returned zero capacity\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[ahci-ident] IDENTIFY capacity=%d sectors\n", id_cap)
    if id_cap != ahci.capacity:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[ahci-ident] FAIL: capacity mismatch identify=%d probe=%d\n",
                id_cap, ahci.capacity)
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-ident] capacity matches bring-up IDENTIFY\n")
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-ident] PASS\n")

    # 2. TRIM a small range. Use LBA 8..15 (8 sectors) — clear of the
    #    MBR / smoke-test scribble at LBA 0..2. rc 0 (trimmed) or rc 1
    #    (device aborted, correctly detected) both PASS; rc -1 FAILs.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-trim] self-test start\n")
    trc: int32 = ahci_trim(port, 8, 8)
    if trc == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-trim] DSM/TRIM completed OK\n")
    elif trc == 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-trim] DSM/TRIM aborted by device (correctly detected)\n")
    else:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-trim] FAIL: DSM/TRIM fatal HBA error / timeout\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-trim] PASS\n")
    return 1


# --- Error-recovery + hot-plug maturity self-test (M16.x) ----------
#
# Gated boot self-test (init/main.ad boot:37.arec, planted
# /etc/ahci-recovery-test by build_initramfs.py ENABLE_AHCI_RECOVERY_TEST,
# driven by scripts/test_ahci_recovery.sh). It proves the REAL AHCI
# error-recovery + hot-plug + timeout plumbing against a QEMU ich9-ahci
# disk. QEMU's emulated controller will not naturally error, so the test
# DETERMINISTICALLY forces a recovery cycle — but every step of that cycle
# (port STOP, error-register CLEAR, COMRESET via PxSCTL, port RESTART,
# re-IDENTIFY) is the REAL driver code path, not a faked completion.
#
# Sequence:
#   1. Baseline: IDENTIFY the disk + read LBA 0 so we know the port works.
#   2. Force a real STOP -> CLEAR -> COMRESET -> RESTART cycle by calling
#      _port_error_recover() directly (the same code a real command error
#      or timeout drives). This actually clears PxCMD.ST, waits PxCMD.CR
#      to clear, write-1-to-clears PxSERR/PxIS, COMRESETs the link via
#      PxSCTL.DET, waits PxSSTS.DET==3, and re-starts FRE+ST.
#      -> [ahci] PASS comreset / [ahci] PASS error-recovery
#   3. Prove the device is USABLE again post-recovery: re-IDENTIFY (real
#      0xEC) and confirm the capacity matches the pre-recovery value, then
#      read LBA 0 again and confirm the MBR signature survived.
#      -> [ahci] PASS post-recovery-io
#   4. Exercise the hot-plug poll logic: with the device present and a
#      DIAG.X edge artificially latched in PxSERR, _port_hotplug_poll()
#      must ack the edge (write-1-to-clear) and report no spurious
#      removal; the live PxSSTS.DET==3 keeps the device PRESENT.
#      -> [ahci] PASS hotplug
#
# Prints the four [ahci] PASS <tag> banners at EMERG so they reach serial.

def ahci_recovery_selftest() -> int32:
    # Returns 1 on PASS, 0 on FAIL.
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-rec] self-test start\n")

    # Bring the port up (idempotent — reuses the cached singleton).
    cap_probe: int32 = ahci_hardware_probe()
    if cap_probe == 0 or ahci.port_num < 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: no AHCI port brought up\n")
        return 0
    port: int32 = ahci.port_num
    port_base: uint64 = ahci.port_base
    page: uint64 = ahci.page
    clist:   uint64 = page + CL_OFFSET
    ct_base: uint64 = page + CT_OFFSET

    # 1. Baseline IDENTIFY + LBA-0 read so we have a known-good reference.
    cap_before: uint64 = ahci.capacity
    mbr0: uint64 = cast[uint64](&_ahci_rec_buf[0])
    memset(cast[Ptr[uint8]](mbr0), 0, 512)
    if _do_read_lba(port_base, clist, ct_base, mbr0, 0, 1) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: baseline LBA0 read failed\n")
        return 0
    sig0_lo: uint8 = cast[Ptr[uint8]](mbr0 + 510)[0]
    sig0_hi: uint8 = cast[Ptr[uint8]](mbr0 + 511)[0]
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[ahci-rec] baseline OK cap=%d mbr=%x\n",
            cap_before,
            (cast[uint64](sig0_hi) << 8) | cast[uint64](sig0_lo))

    # Snapshot CR/ST so we can prove the port was genuinely running, then
    # stopped, then running again across the recovery.
    cmd_before: uint32 = _mmio_r32(port_base + PORT_CMD)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[ahci-rec] pre-recovery PxCMD=%x (ST/CR set)\n",
            cast[uint64](cmd_before))

    # 2. DRIVE A REAL ERROR-RECOVERY CYCLE. This is the production code
    #    path; it stops the port, clears the error regs, COMRESETs the
    #    link (since we want to prove the full dance, force the link path
    #    by clearing PxSERR.DIAG and observing DET), and restarts.
    #    To make the COMRESET branch deterministic regardless of the
    #    emulated DET state we call _port_comreset() + _wait_det_present()
    #    explicitly first and assert the PHY re-establishes, THEN run the
    #    full _port_error_recover() that real command errors invoke.
    _port_stop(port_base)
    cmd_stopped: uint32 = _mmio_r32(port_base + PORT_CMD)
    if (cmd_stopped & PORT_CMD_CR) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: PxCMD.CR did not clear on STOP\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[ahci-rec] port STOPPED PxCMD=%x (CR clear)\n",
            cast[uint64](cmd_stopped))

    # Explicit COMRESET + DET re-establish (the link-reset half of recovery).
    _port_comreset(port_base)
    if _wait_det_present(port_base) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: PxSSTS.DET never returned to 3 after COMRESET\n")
        return 0
    det_after: uint32 = _mmio_r32(port_base + PORT_SSTS) & 0xF
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[ahci-rec] COMRESET done, PxSSTS.DET=%d (PHY established)\n",
            cast[uint64](det_after))
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci] PASS comreset\n")

    # Now run the full production error-recovery (stop already done is
    # idempotent; it re-stops, re-clears, link is already up so it skips
    # a second COMRESET, then RESTARTS the port + re-arms PxIE).
    if _port_error_recover(port_base) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: _port_error_recover reported device gone\n")
        return 0
    cmd_restart: uint32 = _mmio_r32(port_base + PORT_CMD)
    if (cmd_restart & PORT_CMD_ST) == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: PxCMD.ST not set after restart\n")
        return 0
    if (cmd_restart & PORT_CMD_FRE) == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: PxCMD.FRE not set after restart\n")
        return 0
    # Confirm PxIE was re-armed with the hot-plug + error enables.
    ie_after: uint32 = _mmio_r32(port_base + PORT_IE)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[ahci-rec] port RESTARTED PxCMD=%x PxIE=%x\n",
            cast[uint64](cmd_restart), cast[uint64](ie_after))
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci] PASS error-recovery\n")

    # 3. PROVE THE DEVICE IS USABLE AGAIN: re-IDENTIFY + re-read LBA 0.
    cap_after: uint64 = ahci_identify(port)
    if cap_after == 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: post-recovery IDENTIFY returned 0\n")
        return 0
    if cap_after != cap_before:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk2("[ahci-rec] FAIL: capacity changed pre=%d post=%d\n",
                cap_before, cap_after)
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk1("[ahci-rec] post-recovery IDENTIFY OK cap=%d (matches)\n",
            cap_after)

    mbr1: uint64 = cast[uint64](&_ahci_rec_buf[0])
    memset(cast[Ptr[uint8]](mbr1), 0, 512)
    if _do_read_lba(port_base, clist, ct_base, mbr1, 0, 1) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: post-recovery LBA0 read failed\n")
        return 0
    sig1_lo: uint8 = cast[Ptr[uint8]](mbr1 + 510)[0]
    sig1_hi: uint8 = cast[Ptr[uint8]](mbr1 + 511)[0]
    if sig1_lo != sig0_lo or sig1_hi != sig0_hi:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: MBR signature changed after recovery\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-rec] post-recovery LBA0 read matches baseline MBR sig\n")
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci] PASS post-recovery-io\n")

    # 4. HOT-PLUG POLL. Artificially latch a DIAG.X (Exchanged) edge in
    #    PxSERR so _port_hotplug_poll sees a hot-plug edge, then confirm
    #    that with the device still PRESENT (DET==3, was_present=1) it
    #    acks the edge and reports NO removal (rc 0). Then verify the
    #    edge was cleared (write-1-to-clear).
    _mmio_w32(port_base + PORT_SERR, PORT_SERR_DIAG_X)
    serr_pre: uint32 = _mmio_r32(port_base + PORT_SERR)
    hp: int32 = _port_hotplug_poll(port_base, 1)
    serr_post: uint32 = _mmio_r32(port_base + PORT_SERR)
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk2("[ahci-rec] hotplug poll rc=%d (present->present) SERR %x->",
            cast[uint64](hp), cast[uint64](serr_pre))
    printk1("%x\n", cast[uint64](serr_post))
    if hp != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: hotplug poll reported a spurious state change\n")
        return 0
    if (serr_post & PORT_SERR_DIAG_X) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: DIAG.X edge not write-1-to-cleared\n")
        return 0
    # Also exercise the ATTACH-edge decode: feed was_present=0 with the
    # device live (DET==3) and confirm it reports an ARRIVAL (rc 1) — the
    # signal that drives a (re)IDENTIFY + (re)registration on real attach.
    _mmio_w32(port_base + PORT_SERR, PORT_SERR_DIAG_X)
    hp_attach: int32 = _port_hotplug_poll(port_base, 0)
    if hp_attach != 1:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk1("[ahci-rec] FAIL: attach edge not reported as arrival (rc=%d)\n",
                cast[uint64](hp_attach))
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-rec] hotplug attach edge -> arrival reported (would (re)IDENTIFY)\n")
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci] PASS hotplug\n")

    # Final: the device must still serve I/O after all the recovery +
    # hot-plug poking, proving nothing was left in a wedged state.
    mbr2: uint64 = cast[uint64](&_ahci_rec_buf[0])
    memset(cast[Ptr[uint8]](mbr2), 0, 512)
    if ahci_read_sectors(port, 0, 1, mbr2) != 0:
        printk_set_level(PRINTK_LEVEL_EMERG)
        printk0("[ahci-rec] FAIL: final ahci_read_sectors after recovery failed\n")
        return 0
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-rec] final block-layer read OK\n")
    printk_set_level(PRINTK_LEVEL_EMERG)
    printk0("[ahci-rec] PASS\n")
    return 1


# 512-byte scratch buffer for the recovery self-test (Adder big-buffer
# rule: frame-local Array[512,...] miscompiles, so module-scope).
_ahci_rec_buf: Array[512, uint8]


def ahci_irq_handler():
    # IRQ-context entry. AHCI uses a two-level interrupt-status model
    # (spec §5.5):
    #   1. HBA-level: GHC.IS (ABAR + 0x08) — one bit per port.
    #   2. Port-level: PxIS (port_base + 0x10) — per-cause within the
    #      port. Each is write-1-to-clear.
    # We snapshot HBA IS, ack the per-port PxIS for every bit set,
    # then write IS back to ack the controller-level interrupt. The
    # LAPIC EOI is sent by do_irq() after we return.
    if ahci.abar == 0:
        return
    ahci.irq_count = ahci.irq_count + 1
    is_reg: uint32 = _mmio_r32(ahci.abar + HBA_IS)
    if is_reg == 0:
        # Shared INTx; another device on the same line. Still safe to
        # return — do_irq will EOI for us.
        return
    # Walk the IS bits and ack each port's PxIS. We don't drain command
    # completions from IRQ context (commands are polled), but we DO note
    # hot-plug edges (PxIS.PRCS / PxIS.PCS) so a connect/disconnect that
    # the HBA latched is counted; the deferred hot-plug poller then
    # (re)IDENTIFYs / marks-gone outside IRQ context. Acking PxIS keeps
    # the INTx line de-asserted.
    i: uint32 = 0
    while i < 32:
        if (is_reg & (cast[uint32](1) << i)) != 0:
            pb: uint64 = ahci.abar + HBA_PORTS_BASE \
                       + cast[uint64](i) * HBA_PORT_STRIDE
            pxis: uint32 = _mmio_r32(pb + PORT_IS)
            if (pxis & PORT_IS_HOTPLUG_MASK) != 0:
                _ahci_hotplug_pending = _ahci_hotplug_pending \
                                      | (cast[uint32](1) << i)
                _ahci_hotplug_irqs = _ahci_hotplug_irqs + 1
            # NCQ completion: if THIS is the active singleton port AND the
            # NCQ runtime is up, sweep our slot bookkeeping against the
            # live PxCI/PxSACT and wake any task whose tag finished. We
            # only drive the IRQ-completion path for the active port —
            # NCQ bookkeeping is per-port-singleton, see _ahci_block_path_active.
            if ahci.port_num >= 0 \
               and cast[int32](i) == ahci.port_num \
               and _ncq_runtime_ready != 0:
                if (pxis & (PORT_IS_COMPLETION_MASK | PORT_IS_ERR_MASK)) != 0:
                    _ncq_irq_complete_port(pb)
            _mmio_w32(pb + PORT_IS, pxis)
        i = i + 1
    # Ack the HBA-level IS (write-1-to-clear).
    _mmio_w32(ahci.abar + HBA_IS, is_reg)


# Bitmask of ports whose IRQ handler latched an unserviced hot-plug edge,
# plus a monotonic count of such IRQs — read by ahci_hotplug_service().
_ahci_hotplug_pending: uint32 = 0
_ahci_hotplug_irqs:    uint64 = 0


def ahci_hotplug_service() -> int32:
    # Deferred (non-IRQ-context) hot-plug servicer. For every port flagged
    # by the IRQ handler, run the real _port_hotplug_poll: on ARRIVAL,
    # bring the port up + (re)register it as a block device; on REMOVAL,
    # mark the port absent. Returns the number of ports whose presence
    # state changed. Safe to call from a kernel poll loop; clears the
    # pending mask it services.
    if ahci.abar == 0:
        return 0
    pending: uint32 = _ahci_hotplug_pending
    _ahci_hotplug_pending = 0
    changed: int32 = 0
    p: uint32 = 0
    while p < 32:
        if (pending & (cast[uint32](1) << p)) != 0:
            pb: uint64 = ahci.abar + HBA_PORTS_BASE \
                       + cast[uint64](p) * HBA_PORT_STRIDE
            was: uint32 = _ahci_port_present[p]
            tr: int32 = _port_hotplug_poll(pb, was)
            if tr == 1:
                printk1("[ahci] hotplug: device ARRIVED on port %d\n",
                        cast[uint64](p))
                if _ahci_bring_up_port(cast[int32](p)) != 0:
                    ahci_enumerate_ports()
                    changed = changed + 1
            elif tr == 2:
                printk1("[ahci] hotplug: device LEFT port %d\n",
                        cast[uint64](p))
                _ahci_port_present[p]  = 0
                _ahci_port_capacity[p] = 0
                changed = changed + 1
        p = p + 1
    return changed

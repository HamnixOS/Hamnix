# drivers/net/wg_crypto.ad
#
# Crypto primitives that WireGuard needs but the tree did not already have:
#   * BLAKE2s (RFC 7693) — the WireGuard hash. 256-bit (and shorter) digests,
#     plus keyed-BLAKE2s (the MAC used for WireGuard cookie/mac fields and as
#     the PRF inside HKDF).
#   * HKDF-BLAKE2s (RFC 5869, BLAKE2s as the underlying hash) — the WireGuard
#     KDF used to ratchet the chaining key and derive transport keys. The
#     WireGuard noise construction uses HKDF with 1, 2 or 3 outputs.
#
# WireGuard's other primitives — ChaCha20-Poly1305 AEAD (RFC 8439) and
# Curve25519/X25519 (RFC 7748) — already exist in drivers/net/tls.ad and are
# REUSED there (no reimplementation). This module deliberately holds only the
# BLAKE2s family so future drivers can pull it in.
#
# Everything is straight-line, allocation-free, and uses exactly-sized
# module-scope scratch (no recursion in Adder). All state buffers are sized to
# their exact crypto width to avoid the undersized-Array overflow trap.

from kernel.printk.printk import printk0


# ============================================================================
# BLAKE2s (RFC 7693 §3.3, §B.2)
# ============================================================================
#
# 32-bit-word hash. Block = 64 bytes, internal state h = 8 words, digest up to
# 32 bytes. IV is the SHA-256 IV. We support an optional key (0..32 bytes) for
# keyed mode (used as a MAC and as the HKDF PRF).

# BLAKE2s IV (= SHA-256 initial hash values).
WG_BLAKE2S_BLOCKBYTES: uint64 = 64
WG_BLAKE2S_OUTBYTES:   uint64 = 32
WG_BLAKE2S_KEYBYTES:   uint64 = 32

# Incremental hashing state. Single-threaded; one hash at a time. Sized exact.
_wgb_h:    Array[8, uint32]      # chaining state
_wgb_t0:   uint64 = 0            # low 64 bits of the byte counter (we only
                                 # ever feed < 2^64 bytes, so one word suffices
                                 # for t; BLAKE2s technically has t0/t1 but the
                                 # high half stays zero for our sizes)
_wgb_buf:  Array[64, uint8]      # partial-block buffer
_wgb_buflen: uint64 = 0          # bytes currently in _wgb_buf
_wgb_outlen: uint64 = 0          # configured digest length (1..32)

# Compression scratch (avoids per-call stack arrays in the hot loop).
_wgb_v:    Array[16, uint32]
_wgb_m:    Array[16, uint32]


def _wgb_rotr32(x: uint32, n: uint64) -> uint32:
    v: uint64 = cast[uint64](x) & 0xFFFFFFFF
    lo: uint64 = v >> n
    hi: uint64 = (v << (32 - n)) & 0xFFFFFFFF
    return cast[uint32](lo | hi)


def _wgb_le_load32(buf: Ptr[uint8], off: uint64) -> uint32:
    b0: uint32 = cast[uint32](buf[off + 0])
    b1: uint32 = cast[uint32](buf[off + 1])
    b2: uint32 = cast[uint32](buf[off + 2])
    b3: uint32 = cast[uint32](buf[off + 3])
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)


def _wgb_g(a: uint64, b: uint64, c: uint64, d: uint64,
           x: uint32, y: uint32):
    # The BLAKE2s G mixing function operating on _wgb_v[a,b,c,d].
    va: uint32 = _wgb_v[a]
    vb: uint32 = _wgb_v[b]
    vc: uint32 = _wgb_v[c]
    vd: uint32 = _wgb_v[d]
    va = cast[uint32]((cast[uint64](va) + cast[uint64](vb) + cast[uint64](x)) & 0xFFFFFFFF)
    vd = _wgb_rotr32(vd ^ va, 16)
    vc = cast[uint32]((cast[uint64](vc) + cast[uint64](vd)) & 0xFFFFFFFF)
    vb = _wgb_rotr32(vb ^ vc, 12)
    va = cast[uint32]((cast[uint64](va) + cast[uint64](vb) + cast[uint64](y)) & 0xFFFFFFFF)
    vd = _wgb_rotr32(vd ^ va, 8)
    vc = cast[uint32]((cast[uint64](vc) + cast[uint64](vd)) & 0xFFFFFFFF)
    vb = _wgb_rotr32(vb ^ vc, 7)
    _wgb_v[a] = va
    _wgb_v[b] = vb
    _wgb_v[c] = vc
    _wgb_v[d] = vd


def _wgb_sigma(round_i: uint64, idx: uint64) -> uint64:
    # BLAKE2s message-schedule permutation SIGMA (10 rounds x 16 entries).
    # Encoded inline; returns SIGMA[round_i][idx].
    r: uint64 = round_i % 10
    if r == 0:
        if idx == 0:
            return 0
        if idx == 1:
            return 1
        if idx == 2:
            return 2
        if idx == 3:
            return 3
        if idx == 4:
            return 4
        if idx == 5:
            return 5
        if idx == 6:
            return 6
        if idx == 7:
            return 7
        if idx == 8:
            return 8
        if idx == 9:
            return 9
        if idx == 10:
            return 10
        if idx == 11:
            return 11
        if idx == 12:
            return 12
        if idx == 13:
            return 13
        if idx == 14:
            return 14
        return 15
    if r == 1:
        if idx == 0:
            return 14
        if idx == 1:
            return 10
        if idx == 2:
            return 4
        if idx == 3:
            return 8
        if idx == 4:
            return 9
        if idx == 5:
            return 15
        if idx == 6:
            return 13
        if idx == 7:
            return 6
        if idx == 8:
            return 1
        if idx == 9:
            return 12
        if idx == 10:
            return 0
        if idx == 11:
            return 2
        if idx == 12:
            return 11
        if idx == 13:
            return 7
        if idx == 14:
            return 5
        return 3
    if r == 2:
        if idx == 0:
            return 11
        if idx == 1:
            return 8
        if idx == 2:
            return 12
        if idx == 3:
            return 0
        if idx == 4:
            return 5
        if idx == 5:
            return 2
        if idx == 6:
            return 15
        if idx == 7:
            return 13
        if idx == 8:
            return 10
        if idx == 9:
            return 14
        if idx == 10:
            return 3
        if idx == 11:
            return 6
        if idx == 12:
            return 7
        if idx == 13:
            return 1
        if idx == 14:
            return 9
        return 4
    if r == 3:
        if idx == 0:
            return 7
        if idx == 1:
            return 9
        if idx == 2:
            return 3
        if idx == 3:
            return 1
        if idx == 4:
            return 13
        if idx == 5:
            return 12
        if idx == 6:
            return 11
        if idx == 7:
            return 14
        if idx == 8:
            return 2
        if idx == 9:
            return 6
        if idx == 10:
            return 5
        if idx == 11:
            return 10
        if idx == 12:
            return 4
        if idx == 13:
            return 0
        if idx == 14:
            return 15
        return 8
    if r == 4:
        if idx == 0:
            return 9
        if idx == 1:
            return 0
        if idx == 2:
            return 5
        if idx == 3:
            return 7
        if idx == 4:
            return 2
        if idx == 5:
            return 4
        if idx == 6:
            return 10
        if idx == 7:
            return 15
        if idx == 8:
            return 14
        if idx == 9:
            return 1
        if idx == 10:
            return 11
        if idx == 11:
            return 12
        if idx == 12:
            return 6
        if idx == 13:
            return 8
        if idx == 14:
            return 3
        return 13
    if r == 5:
        if idx == 0:
            return 2
        if idx == 1:
            return 12
        if idx == 2:
            return 6
        if idx == 3:
            return 10
        if idx == 4:
            return 0
        if idx == 5:
            return 11
        if idx == 6:
            return 8
        if idx == 7:
            return 3
        if idx == 8:
            return 4
        if idx == 9:
            return 13
        if idx == 10:
            return 7
        if idx == 11:
            return 5
        if idx == 12:
            return 15
        if idx == 13:
            return 14
        if idx == 14:
            return 1
        return 9
    if r == 6:
        if idx == 0:
            return 12
        if idx == 1:
            return 5
        if idx == 2:
            return 1
        if idx == 3:
            return 15
        if idx == 4:
            return 14
        if idx == 5:
            return 13
        if idx == 6:
            return 4
        if idx == 7:
            return 10
        if idx == 8:
            return 0
        if idx == 9:
            return 7
        if idx == 10:
            return 6
        if idx == 11:
            return 3
        if idx == 12:
            return 9
        if idx == 13:
            return 2
        if idx == 14:
            return 8
        return 11
    if r == 7:
        if idx == 0:
            return 13
        if idx == 1:
            return 11
        if idx == 2:
            return 7
        if idx == 3:
            return 14
        if idx == 4:
            return 12
        if idx == 5:
            return 1
        if idx == 6:
            return 3
        if idx == 7:
            return 9
        if idx == 8:
            return 5
        if idx == 9:
            return 0
        if idx == 10:
            return 15
        if idx == 11:
            return 4
        if idx == 12:
            return 8
        if idx == 13:
            return 6
        if idx == 14:
            return 2
        return 10
    if r == 8:
        if idx == 0:
            return 6
        if idx == 1:
            return 15
        if idx == 2:
            return 14
        if idx == 3:
            return 9
        if idx == 4:
            return 11
        if idx == 5:
            return 3
        if idx == 6:
            return 0
        if idx == 7:
            return 8
        if idx == 8:
            return 12
        if idx == 9:
            return 2
        if idx == 10:
            return 13
        if idx == 11:
            return 7
        if idx == 12:
            return 1
        if idx == 13:
            return 4
        if idx == 14:
            return 10
        return 5
    # r == 9
    if idx == 0:
        return 10
    if idx == 1:
        return 2
    if idx == 2:
        return 8
    if idx == 3:
        return 4
    if idx == 4:
        return 7
    if idx == 5:
        return 6
    if idx == 6:
        return 1
    if idx == 7:
        return 5
    if idx == 8:
        return 15
    if idx == 9:
        return 11
    if idx == 10:
        return 9
    if idx == 11:
        return 14
    if idx == 12:
        return 3
    if idx == 13:
        return 12
    if idx == 14:
        return 13
    return 0


def _wgb_iv(i: uint64) -> uint32:
    # BLAKE2s IV words (= SHA-256 IV).
    if i == 0:
        return 0x6A09E667
    if i == 1:
        return 0xBB67AE85
    if i == 2:
        return 0x3C6EF372
    if i == 3:
        return 0xA54FF53A
    if i == 4:
        return 0x510E527F
    if i == 5:
        return 0x9B05688C
    if i == 6:
        return 0x1F83D9AB
    return 0x5BE0CD19


def _wgb_compress(block: Ptr[uint8], is_last: int32):
    # Compress one 64-byte block into _wgb_h, with byte counter _wgb_t0.
    i: uint64 = 0
    while i < 16:
        _wgb_m[i] = _wgb_le_load32(block, i * 4)
        i = i + 1
    i = 0
    while i < 8:
        _wgb_v[i] = _wgb_h[i]
        i = i + 1
    _wgb_v[8]  = _wgb_iv(0)
    _wgb_v[9]  = _wgb_iv(1)
    _wgb_v[10] = _wgb_iv(2)
    _wgb_v[11] = _wgb_iv(3)
    # v12 ^= t0 (low), v13 ^= t1 (high == 0 for our sizes).
    _wgb_v[12] = _wgb_iv(4) ^ cast[uint32](_wgb_t0 & 0xFFFFFFFF)
    _wgb_v[13] = _wgb_iv(5) ^ cast[uint32]((_wgb_t0 >> 32) & 0xFFFFFFFF)
    # v14 ^= f0 (0xFFFFFFFF if last block), v15 ^= f1 (0, no last-node).
    f0: uint32 = 0
    if is_last != 0:
        f0 = 0xFFFFFFFF
    _wgb_v[14] = _wgb_iv(6) ^ f0
    _wgb_v[15] = _wgb_iv(7)

    r: uint64 = 0
    while r < 10:
        _wgb_g(0, 4, 8,  12, _wgb_m[_wgb_sigma(r, 0)],  _wgb_m[_wgb_sigma(r, 1)])
        _wgb_g(1, 5, 9,  13, _wgb_m[_wgb_sigma(r, 2)],  _wgb_m[_wgb_sigma(r, 3)])
        _wgb_g(2, 6, 10, 14, _wgb_m[_wgb_sigma(r, 4)],  _wgb_m[_wgb_sigma(r, 5)])
        _wgb_g(3, 7, 11, 15, _wgb_m[_wgb_sigma(r, 6)],  _wgb_m[_wgb_sigma(r, 7)])
        _wgb_g(0, 5, 10, 15, _wgb_m[_wgb_sigma(r, 8)],  _wgb_m[_wgb_sigma(r, 9)])
        _wgb_g(1, 6, 11, 12, _wgb_m[_wgb_sigma(r, 10)], _wgb_m[_wgb_sigma(r, 11)])
        _wgb_g(2, 7, 8,  13, _wgb_m[_wgb_sigma(r, 12)], _wgb_m[_wgb_sigma(r, 13)])
        _wgb_g(3, 4, 9,  14, _wgb_m[_wgb_sigma(r, 14)], _wgb_m[_wgb_sigma(r, 15)])
        r = r + 1

    i = 0
    while i < 8:
        _wgb_h[i] = _wgb_h[i] ^ _wgb_v[i] ^ _wgb_v[i + 8]
        i = i + 1


def _wgb_init(outlen: uint64, key: Ptr[uint8], keylen: uint64):
    # Initialize BLAKE2s state for `outlen`-byte output and an optional
    # `keylen`-byte key. h[0] ^= param block: digest_length | (keylen<<8) |
    # (fanout=1<<16) | (depth=1<<24).
    _wgb_h[0] = _wgb_iv(0)
    _wgb_h[1] = _wgb_iv(1)
    _wgb_h[2] = _wgb_iv(2)
    _wgb_h[3] = _wgb_iv(3)
    _wgb_h[4] = _wgb_iv(4)
    _wgb_h[5] = _wgb_iv(5)
    _wgb_h[6] = _wgb_iv(6)
    _wgb_h[7] = _wgb_iv(7)
    param0: uint32 = cast[uint32]((outlen & 0xFF)
                                  | ((keylen & 0xFF) << 8)
                                  | (0x01 << 16)
                                  | (0x01 << 24))
    _wgb_h[0] = _wgb_h[0] ^ param0
    _wgb_t0 = 0
    _wgb_buflen = 0
    _wgb_outlen = outlen
    # If keyed, the first data block is the key zero-padded to 64 bytes.
    if keylen > 0:
        i: uint64 = 0
        while i < 64:
            if i < keylen:
                _wgb_buf[i] = key[i]
            else:
                _wgb_buf[i] = 0
            i = i + 1
        _wgb_buflen = 64


def _wgb_update(data: Ptr[uint8], n: uint64):
    pos: uint64 = 0
    while pos < n:
        if _wgb_buflen == 64:
            # Buffer full and more data is coming -> compress (not last).
            _wgb_t0 = _wgb_t0 + 64
            _wgb_compress(cast[Ptr[uint8]](&_wgb_buf[0]), 0)
            _wgb_buflen = 0
        space: uint64 = 64 - _wgb_buflen
        chunk: uint64 = n - pos
        if chunk > space:
            chunk = space
        # But never fully fill if it's exactly the boundary and there might be
        # more — handled by the top check on the next iteration. Copy chunk.
        j: uint64 = 0
        while j < chunk:
            _wgb_buf[_wgb_buflen + j] = data[pos + j]
            j = j + 1
        _wgb_buflen = _wgb_buflen + chunk
        pos = pos + chunk


def _wgb_final(out: Ptr[uint8]):
    # Final block: pad with zeros, set last-block flag, emit _wgb_outlen bytes.
    _wgb_t0 = _wgb_t0 + _wgb_buflen
    i: uint64 = _wgb_buflen
    while i < 64:
        _wgb_buf[i] = 0
        i = i + 1
    _wgb_compress(cast[Ptr[uint8]](&_wgb_buf[0]), 1)
    # Emit little-endian state words, up to outlen bytes.
    j: uint64 = 0
    while j < _wgb_outlen:
        w: uint32 = _wgb_h[j / 4]
        out[j] = cast[uint8]((w >> ((j % 4) * 8)) & 0xFF)
        j = j + 1


def wg_blake2s(out: Ptr[uint8], outlen: uint64,
               data: Ptr[uint8], n: uint64):
    # One-shot unkeyed BLAKE2s of `n` bytes -> `outlen`-byte digest.
    _wgb_init(outlen, cast[Ptr[uint8]](0), 0)
    _wgb_update(data, n)
    _wgb_final(out)


def wg_blake2s_keyed(out: Ptr[uint8], outlen: uint64,
                     key: Ptr[uint8], keylen: uint64,
                     data: Ptr[uint8], n: uint64):
    # Keyed BLAKE2s (the BLAKE2s MAC / HKDF PRF).
    _wgb_init(outlen, key, keylen)
    _wgb_update(data, n)
    _wgb_final(out)


# ============================================================================
# HMAC-BLAKE2s and HKDF-BLAKE2s
# ============================================================================
#
# WireGuard's KDF is HKDF (RFC 5869) with BLAKE2s as the hash. Critically,
# WireGuard uses *HMAC*-BLAKE2s (NOT native keyed BLAKE2s) for the HKDF
# extract/expand PRF — this matches the reference implementation and the
# kernel. So we implement HMAC over BLAKE2s here.
#
# HMAC(K, m) = BLAKE2s( (K0 ^ opad) || BLAKE2s( (K0 ^ ipad) || m ) )
# where K0 is K padded/hashed to the 64-byte block size.

WG_HASH_LEN: uint64 = 32          # BLAKE2s-256 output

# HMAC scratch. Single-threaded. Exact sizes (block=64).
_wgh_k0:    Array[64, uint8]
_wgh_ipad:  Array[64, uint8]
_wgh_opad:  Array[64, uint8]
_wgh_inner: Array[32, uint8]


def wg_hmac_blake2s(out: Ptr[uint8],
                    key: Ptr[uint8], keylen: uint64,
                    data: Ptr[uint8], n: uint64):
    # HMAC-BLAKE2s-256. out is 32 bytes.
    # 1. K0 = key padded to 64 bytes (hash first if longer than block).
    i: uint64 = 0
    if keylen > 64:
        wg_blake2s(cast[Ptr[uint8]](&_wgh_k0[0]), 32, key, keylen)
        i = 32
        while i < 64:
            _wgh_k0[i] = 0
            i = i + 1
    else:
        i = 0
        while i < 64:
            if i < keylen:
                _wgh_k0[i] = key[i]
            else:
                _wgh_k0[i] = 0
            i = i + 1
    # 2. ipad/opad.
    i = 0
    while i < 64:
        _wgh_ipad[i] = _wgh_k0[i] ^ 0x36
        _wgh_opad[i] = _wgh_k0[i] ^ 0x5C
        i = i + 1
    # 3. inner = BLAKE2s(ipad || data).
    _wgb_init(32, cast[Ptr[uint8]](0), 0)
    _wgb_update(cast[Ptr[uint8]](&_wgh_ipad[0]), 64)
    _wgb_update(data, n)
    _wgb_final(cast[Ptr[uint8]](&_wgh_inner[0]))
    # 4. out = BLAKE2s(opad || inner).
    _wgb_init(32, cast[Ptr[uint8]](0), 0)
    _wgb_update(cast[Ptr[uint8]](&_wgh_opad[0]), 64)
    _wgb_update(cast[Ptr[uint8]](&_wgh_inner[0]), 32)
    _wgb_final(out)


# HKDF scratch.
_wgk_prk:   Array[32, uint8]      # extracted pseudo-random key
_wgk_t:     Array[64, uint8]      # T(i) buffer: prev-T(32) || info(0) || ctr(1)
_wgk_tprev: Array[32, uint8]      # T(i-1)


def wg_hkdf(out1: Ptr[uint8], out2: Ptr[uint8], out3: Ptr[uint8],
            num: uint64,
            chaining_key: Ptr[uint8],
            data: Ptr[uint8], data_len: uint64):
    # WireGuard's KDFn (RFC 5869 HKDF, BLAKE2s, with empty info and the
    # one-byte counter as in the WireGuard spec):
    #   prk = HMAC(chaining_key, data)          # extract; data == IKM
    #   T1  = HMAC(prk, [0x01])                 # -> out1
    #   T2  = HMAC(prk, T1 || [0x02])           # -> out2
    #   T3  = HMAC(prk, T2 || [0x03])           # -> out3
    # `num` selects how many 32-byte outputs to produce (1..3). The
    # chaining_key is 32 bytes (the HKDF salt/key).
    wg_hmac_blake2s(cast[Ptr[uint8]](&_wgk_prk[0]),
                    chaining_key, 32, data, data_len)
    # T1
    _wgk_t[0] = 0x01
    wg_hmac_blake2s(out1, cast[Ptr[uint8]](&_wgk_prk[0]), 32,
                    cast[Ptr[uint8]](&_wgk_t[0]), 1)
    if num < 2:
        return
    # T2 = HMAC(prk, T1 || 0x02)
    i: uint64 = 0
    while i < 32:
        _wgk_t[i] = out1[i]
        i = i + 1
    _wgk_t[32] = 0x02
    wg_hmac_blake2s(out2, cast[Ptr[uint8]](&_wgk_prk[0]), 32,
                    cast[Ptr[uint8]](&_wgk_t[0]), 33)
    if num < 3:
        return
    # T3 = HMAC(prk, T2 || 0x03)
    i = 0
    while i < 32:
        _wgk_t[i] = out2[i]
        i = i + 1
    _wgk_t[32] = 0x03
    wg_hmac_blake2s(out3, cast[Ptr[uint8]](&_wgk_prk[0]), 32,
                    cast[Ptr[uint8]](&_wgk_t[0]), 33)


# ============================================================================
# BLAKE2s known-answer self-test (proves correctness, not assumed)
# ============================================================================

_wgkat_in:  Array[3, uint8]
_wgkat_out: Array[32, uint8]
_wgkat_exp: Array[32, uint8]


def wg_blake2s_kat() -> int32:
    # RFC 7693 / official BLAKE2s test: BLAKE2s("abc") =
    #   508c5e8c327c14e2e1a72ba34eeb452f37458b209ed63a294d999b4c86675982
    _wgkat_in[0] = 0x61   # 'a'
    _wgkat_in[1] = 0x62   # 'b'
    _wgkat_in[2] = 0x63   # 'c'
    _wgkat_exp[0]=0x50
    _wgkat_exp[1]=0x8c
    _wgkat_exp[2]=0x5e
    _wgkat_exp[3]=0x8c
    _wgkat_exp[4]=0x32
    _wgkat_exp[5]=0x7c
    _wgkat_exp[6]=0x14
    _wgkat_exp[7]=0xe2
    _wgkat_exp[8]=0xe1
    _wgkat_exp[9]=0xa7
    _wgkat_exp[10]=0x2b
    _wgkat_exp[11]=0xa3
    _wgkat_exp[12]=0x4e
    _wgkat_exp[13]=0xeb
    _wgkat_exp[14]=0x45
    _wgkat_exp[15]=0x2f
    _wgkat_exp[16]=0x37
    _wgkat_exp[17]=0x45
    _wgkat_exp[18]=0x8b
    _wgkat_exp[19]=0x20
    _wgkat_exp[20]=0x9e
    _wgkat_exp[21]=0xd6
    _wgkat_exp[22]=0x3a
    _wgkat_exp[23]=0x29
    _wgkat_exp[24]=0x4d
    _wgkat_exp[25]=0x99
    _wgkat_exp[26]=0x9b

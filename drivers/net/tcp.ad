# drivers/net/tcp.ad
#
# L37+ scaffold: TCP segment layout + state-machine constants. Stock
# Linux's net/ipv4/tcp_input.c is ~7 KLOC of state machine, congestion
# control, SACK, fast retransmit, etc.; this file just gives the L37+
# work a place to start. tcp_rx() is a log-and-drop stub.

from kernel.printk.printk import printk0, printk2


# TCP control-block states (RFC 793). Numbered to match the order
# stock Linux uses in include/net/tcp_states.h so a future debugger
# can share the enum.
TCP_CLOSED:      uint32 = 0
TCP_LISTEN:      uint32 = 1
TCP_SYN_SENT:    uint32 = 2
TCP_SYN_RECV:    uint32 = 3
TCP_ESTABLISHED: uint32 = 4
TCP_FIN_WAIT_1:  uint32 = 5
TCP_FIN_WAIT_2:  uint32 = 6
TCP_CLOSE_WAIT:  uint32 = 7
TCP_CLOSING:     uint32 = 8
TCP_LAST_ACK:    uint32 = 9
TCP_TIME_WAIT:   uint32 = 10


# Flag bits in TcpHdr.flags (low byte of the data_off/flags word).
# We model them as individual uint8 constants; a future bitfield
# accessor can OR them together.
TCP_FIN: uint8 = 0x01
TCP_SYN: uint8 = 0x02
TCP_RST: uint8 = 0x04
TCP_PSH: uint8 = 0x08
TCP_ACK: uint8 = 0x10
TCP_URG: uint8 = 0x20


# 20-byte fixed TCP header (no options). data_off packs the header
# length in 32-bit words (high 4 bits) and 4 reserved bits.
class TcpHdr:
    src:      uint16    # 0:  source port      (big-endian on wire)
    dst:      uint16    # 2:  dest port        (big-endian on wire)
    seq:      uint32    # 4:  sequence number
    ack:      uint32    # 8:  ack number
    data_off: uint8     # 12: header length<<4 | reserved
    flags:    uint8     # 13: TCP_FIN .. TCP_URG
    window:   uint16    # 14: receive window
    checksum: uint16    # 16
    urg_ptr:  uint16    # 18


# Per-direction segment counter. The real stack tracks per-socket
# stats in struct tcp_sock; we'll grow into that in the L37+ work.
tcp_in_segs:  uint64 = 0
tcp_out_segs: uint64 = 0


def tcp_rx(pkt: Ptr[uint8], length: uint64):
    # Scaffold stub. Eventual flow:
    #   1. Length-check (>= 20).
    #   2. Verify checksum (pseudo-header from IP layer + segment).
    #   3. Look up the matching listen/established socket by 4-tuple
    #      (src_ip, src_port, dst_ip, dst_port).
    #   4. Run the state machine on the matching tcp_sock.
    tcp_in_segs = tcp_in_segs + 1
    if length < 20:
        printk0("tcp_rx: runt\n")
        return
    hdr: Ptr[TcpHdr] = cast[Ptr[TcpHdr]](pkt)
    sp: uint64 = cast[uint64](hdr[0].src)
    dp: uint64 = cast[uint64](hdr[0].dst)
    printk2("tcp_rx: src_port=%x dst_port=%x\n", sp, dp)


def tcp_init():
    tcp_in_segs  = 0
    tcp_out_segs = 0
    printk0("tcp: scaffold initialized\n")
